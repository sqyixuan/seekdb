--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoqiu.wy
#description:information schema/columns
--disable_warnings
drop database if exists db_is;
drop database if exists jx_db;
--enable_warnings
create database db_is;
create database jx_db;
use db_is;

#
# 
#
#不应该显示索引表列以及主表的隐藏主键
create table t1(c1 int, c2 int);
create index idx on t1(c1);
create unique index uidx on t1(c2);

select table_schema, table_name, column_name from information_schema.columns where table_schema='db_is' and table_name = 't1';

create table jx_t1(c1 int primary key, c2 int, c3 int);
create index idx on jx_t1(c2);
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'jx_t1';

create table jx_t2(c1 int, c2 int, c3 int, c4 int, primary key(c2, c1));
create index idx on jx_t2(c4, c3);
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'jx_t2';

drop table jx_t1;
--error 1064
create table jx_t1 (c1 float(5,2), c2 double(5,2), c3 decimal(5,2), c4 float, c5 float(10), c6 float(20), c7 float(30), c8 double, c9 double(10), c10 double(20), c11 double(30));
select `COLUMN_NAME` ,upper(`COLUMN_TYPE`) ,`CHARACTER_MAXIMUM_LENGTH` ,`NUMERIC_PRECISION`,`NUMERIC_SCALE` from information_schema.columns where table_schema= 'db_is' and table_name = 'jx_t1' order by ORDINAL_POSITION asc;
create table t3 (c1 int, c2 varchar(20), c3 varchar(20) default 'NULL');
desc t3;
select COLUMN_NAME, COLUMN_DEFAULT, length(COLUMN_DEFAULT)  from information_schema.columns where table_schema='db_is' and table_name='t3';
drop database db_is;

##
## 测试正确性
##
desc information_schema.columns;
create database db_is;
use db_is;
--let $num = 0
while ($num < 5)
{
--error 1064
  eval create table db_is_tbl_$num(c1 smallint, c2 float, c3 varchar(16) default 'ant_alibaba', 
                                   c4 time, c5 time(5), c6 datetime, c7 datetime(5), 
                                   c8 timestamp, c9 timestamp(5), c10 year, 
                                   c11 float(10), c12 double(12), c13 decimal(20, 5));
  
  inc $num;
}

use jx_db;
--let $num = 0
while ($num < 5)
{
--error 1064
 eval create table jx_db_tbl_$num(c1 smallint, c2 float, c3 varchar(16) default 'ant_alibaba', 
                                  c4 time, c5 time(5), c6 datetime, c7 datetime(5), 
                                  c8 timestamp, c9 timestamp(5), c10 year, 
                                  c11 float(10), c12 double(12), c13 decimal(20, 5));
 inc $num;
}

#
# 测试只有db_name
select * from information_schema.columns where table_schema='db_is';
select * from information_schema.columns where table_schema='jx_db';
# 测试只有db_name or/and db_name
select * from information_schema.columns where table_schema='db_is' or table_schema='jx_db';
select * from information_schema.columns where table_schema='db_is' and table_schema='jx_db';
# 测试只有table_name
# 测试只有in(table_name, table_name,..)
select * from information_schema.columns where table_name = 'jx_db_tbl_1';
select * from information_schema.columns where table_name like 'jx_db_tbl_%';
select * from information_schema.columns where table_name in ('jx_db_tbl_1', 'jx_db_tbl_2');
# 测试db_name and table_name
select * from information_schema.columns where table_schema = 'jx_db' and table_name in ('jx_db_tbl_1', 'jx_db_tbl_2');
# 测试db_name or table_name
select * from information_schema.columns where table_schema = 'jx_db' or table_name like '%_tbl_%';
# 测试db_name or db_name and table_name
select * from information_schema.columns where table_schema = 'db_is' or table_schema = 'jx_db' and table_name like '%_tbl_%';
# 测试(db_name or db_name) and table_name
select * from information_schema.columns where (table_schema = 'db_is' or table_schema = 'jx_db') and table_name like '%_tbl_%';

##
## bug23937866: column type未显示zerofill
##
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1 (c1 tinyint signed zerofill, c2 float signed zerofill, c3 double signed zerofill, c4 decimal(5,2) signed zerofill);
create table t2 (c1 tinyint unsigned zerofill, c2 float unsigned zerofill, c3 double unsigned zerofill, c4 decimal(5,2) unsigned zerofill);
create table t3 (c1 tinyint signed, c2 float signed, c3 double signed, c4 decimal(5,2) signed);
create table t4 (c1 tinyint unsigned, c2 float unsigned, c3 double unsigned, c4 decimal(5,2) unsigned);
select * from information_schema.columns where table_schema = 'jx_db' and table_name in ('t1','t2','t3','t4') order by TABLE_NAME, COLUMN_NAME;

drop table t1,t2,t3,t4;

##
## bug29616644: extra字段未显示on update current_timestamp
##
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 timestamp on update current_timestamp, c2 timestamp);
select * from information_schema.columns where table_schema = 'jx_db' and table_name = 't1';

create view v1 as select * from t1;
select * from information_schema.columns where table_schema = 'jx_db' and table_name = 'V1';

drop table t1;
select * from information_schema.columns where table_schema = 'jx_db' and table_name = 'V1';
drop view v1;

##
## bug29809985: __ALL_VIRTUAL_INFORMATION_COLUMNS的主键不唯一
##
--disable_warnings
drop table if exists yibo_t1;
--enable_warnings
create table yibo_t1 (c1 int, c2 int, c3 varchar(10));
select /*+no_pred_deduce leading(__all_virtual_information_columns, t) use_merge(t)*/ c.*
from information_schema.columns c, information_schema.tables t 
where c.table_name = t.table_name and c.table_schema = t.table_schema and t.table_schema = 'jx_db' and c.table_name = 'yibo_t1';


select * from information_schema.columns where table_schema in ('', 'jx_db');
drop table yibo_t1;

--disable_warnings
drop table if exists ls_t1;
drop view if exists ls_v1;
--enable_warnings

CREATE TABLE ls_t1 (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `sex` enum('male','female') CHARACTER SET gbk NOT NULL DEFAULT 'male'
);
create view ls_v1 as select * from ls_t1;

select COLUMN_DEFAULT from information_schema.columns where table_name in ('LS_T1', 'LS_V1');

select table_name from information_schema.columns where table_schema = 'jx_db' and table_name = 'ls_t1';
select table_name from information_schema.columns where table_schema = 'jx_db ' and table_name = 'ls_t1';
select table_name from information_schema.columns where table_schema = 'jx_db ' and table_name = 'ls_t1 ';
select table_name from information_schema.columns where table_schema = 'jx_db' and table_name = 'ls_t1 ';

drop table ls_t1;
drop view ls_v1;

--disable_warnings
drop table if exists verification_code_blacklist;
--enable_warnings
CREATE TABLE `verification_code_blacklist` (
`disable_rule` enum('DISABLE_PHONE_SECOND','DISABLE_PHONE_HOUR','DISABLE_PHONE_TODAY','DISABLE_IP_ALWAYS_MINUTE','DISABLE_IP_ALWAYS_DAY') NOT NULL COMMENT '禁用规则: DISABLE_PHONE_SECOND:\"同一手机号短时间（30秒）内请求发送验证码3次以上\",DISABLE_PHONE_HOUR: \"同一手机号一小时内请求发送验证码8次以上\", DISABLE_PHONE_TODAY: \"禁止对该手机号的验证码发送请求到当日24点\",DISABLE_IP_ALWAYS_MINUTE:\"在短时间内（一分钟内）收到大量验证请求（100次）\",DISABLE_IP_ALWAYS_DAY:\"在长时间内累计发出大量验证请求（在超过30天里每天发送超过10条）的IP\"'
);
desc verification_code_blacklist;
select * from information_schema.columns where table_name = 'verification_code_blacklist';
drop table verification_code_blacklist;

drop database db_is;
drop database jx_db;

create database db_is;
create database jx_db;
create table db_is.t1(c1 int);
create table jx_db.t2(c1 int);
select table_schema, table_name from information_schema.columns where table_schema = 'db_is';
select table_schema, table_name from information_schema.columns where table_schema like 'jx_db%';
select table_schema, table_name from information_schema.columns where table_schema = 'db_is' or table_schema like 'jx_db%';

use db_is;
--disable_warnings
drop table if exists column_key_t1;
--enable_warnings
create table column_key_t1 (c1 bigint, c2 bigint unique, c3 bigint not null unique, c4 bigint, primary key(c1));
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'column_key_t1';
drop table column_key_t1;

create table column_key_t1 (c1 bigint, c2 bigint unique, c3 bigint not null unique, c4 bigint);
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'column_key_t1';
drop table column_key_t1;

create table column_key_t1 (c1 bigint, c2 bigint unique, c3 bigint not null unique, c4 bigint not null unique, key(c1));
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'column_key_t1';
drop table column_key_t1;

create table column_key_t1 (c1 bigint, c2 bigint unique, c3 bigint not null, c4 bigint not null, key(c1), unique key u4(c4), unique key u3(c3));
select table_schema, table_name, column_name, column_key from information_schema.columns where table_schema='db_is' and table_name = 'column_key_t1';
drop table column_key_t1;

drop database db_is;
drop database jx_db;
