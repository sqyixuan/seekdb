#
# Bug#10964 Information Schema:Authorization check on privilege tables is improper
#

create database mysqltest;
create table mysqltest.t1 (f1 int, f2 int);
create table mysqltest.t2 (f1 int);
#grant select (f1) on mysqltest.t1 to user1;
grant select  on mysqltest.t1 to user1;
grant select on mysqltest.t2 to user2;
grant select on mysqltest.* to user3;
grant select on *.* to user4;

#connect (con1,localhost,user1,,mysqltest);
#connect (con2,localhost,user2,,mysqltest);
#connect (con3,localhost,user3,,mysqltest);
#connect (con4,localhost,user4,,);
--source mysql_test/include/check_schema_sync.inc
connect (con1,$OBMYSQL_MS0,user1,,mysqltest,$OBMYSQL_PORT);
connect (con2,$OBMYSQL_MS0,user2,,mysqltest,$OBMYSQL_PORT);
connect (con3,$OBMYSQL_MS0,user3,,mysqltest,$OBMYSQL_PORT);
connect (con4,$OBMYSQL_MS0,user4,,,$OBMYSQL_PORT);
connection con1;
#bug no information_schema.column_privileges
#select * from information_schema.column_privileges order by grantee;
select * from information_schema.table_privileges order by grantee;
select * from information_schema.schema_privileges order by grantee;
select * from information_schema.user_privileges order by grantee;
show grants;
connection con2;
#select * from information_schema.column_privileges order by grantee;
select * from information_schema.table_privileges order by grantee;
select * from information_schema.schema_privileges order by grantee;
select * from information_schema.user_privileges order by grantee;
show grants;
connection con3;
#select * from information_schema.column_privileges order by grantee;
select * from information_schema.table_privileges order by grantee;
select * from information_schema.schema_privileges order by grantee;
select * from information_schema.user_privileges order by grantee;
show grants;
connection con4;
#select * from information_schema.column_privileges where grantee like '%user%'
#order by grantee;
