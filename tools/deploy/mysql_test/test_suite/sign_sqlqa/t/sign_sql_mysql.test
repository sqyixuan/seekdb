CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;

#SELECT
SELECT e.id, sign(e.id) FROM t1_view e;
SELECT e.consumer, sign(e.consumer) FROM t1_view e;
SELECT e.brand, sign(e.brand) FROM t1_view e;

SELECT sign(e.sal) sal,sign(p.Price) FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.sal DESC;
SELECT sign(e.sal) sal,sign(p.Price) FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.sal DESC;
SELECT sign(e.sal) sal,sign(p.Price) FROM t1_view e INNER JOIN t2_view p ON e.id = p.id ORDER BY e.sal DESC;
SELECT * FROM (SELECT e.id,sign(e.sal) sal,sign(p.Price) FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ) e ORDER BY e.sal;

#ANY
SELECT *  FROM t1_view e WHERE sign(e.sal) = ANY (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE sign(e.sal) < ANY (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE sign(e.sal) > ANY (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;

#ALL
SELECT *  FROM t1_view e WHERE sign(e.sal) < ALL (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE sign(e.sal) > ALL (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE sign(e.sal) = ALL (SELECT sign(p.Price) FROM t2_view p WHERE p.model = 'oppo findx') ORDER BY e.id;

#EXISTS AND NOT EXISTS
SELECT *  FROM t1_view e WHERE EXISTS (SELECT sign(p.Price) FROM t2_view p ) ORDER BY e.id;
SELECT sign(e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE sign(p.Price)=7500 ) ORDER BY e.id;


#CREATE AS
CREATE TABLE t3 AS SELECT * FROM t1_view e WHERE sign(e.sal) = 1;
select * from t3;
drop table t3;
CREATE TABLE t3 AS SELECT * FROM t1_view e WHERE sign(e.sal) = 0;
SELECT *  FROM t3;
drop table t3;
CREATE TABLE t3 AS SELECT * FROM t1_view e WHERE sign(e.sal) = NUll;
SELECT *  FROM t3;


#LIKE
SELECT brand, sign(brand) FROM t1_view e WHERE e.brand LIKE '%a%';
SELECT sal, sign(sal) FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id WHERE e.sal LIKE '%00%';


#WHERE
SELECT * FROM t1_view e WHERE sign(e.sal) = 0;
SELECT * FROM t1_view e WHERE sign(e.sal) = 1;
SELECT * FROM t1_view e WHERE sign(e.sal) = NULL;
SELECT * FROM t1_view e WHERE sign(e.sal) > 0 ORDER BY e.id;
SELECT * FROM t1_view e WHERE sign(e.sal) < 0 ORDER BY e.id;
SELECT * FROM t1_view e WHERE sign(e.sal) = 1 ORDER BY e.id;
SELECT * FROM t1_view e WHERE sign(e.sal) <> 0 ORDER BY e.id;


#ORDER BY
SELECT e.id, e.sal, sign(e.sal) FROM t1_view e WHERE e.id > 0 ORDER BY sign(e.sal);
SELECT e.id, e.sal, sign(e.sal) FROM t1_view e WHERE e.id > 0 ORDER BY sign(e.sal) DESC;
SELECT e.id, e.sal, sign(e.brand) FROM t1_view e WHERE e.id > 0 ORDER BY sign(e.brand) ASC;
SELECT e.id, e.sal, sign(e.brand) FROM t1_view e WHERE e.id > 0 ORDER BY sign(e.brand) DESC;


#GROUP BY HAVING
SELECT e.id, sign(e.sal), SUM(e.sal+p.Price) FROM t1_view e ,t2_view p WHERE e.id=p.id GROUP BY e.id, sign(e.sal)  ORDER BY e.id;
SELECT e.id, sign(e.sal) tt, SUM(e.sal+p.Price) FROM t1_view e ,t2_view p WHERE e.id=p.id GROUP BY e.id, tt HAVING tt > -1 ORDER BY e.id;


#CASE WHEN
select id, sal, sign(case when sal=0 then 200 else sal end ) from t1_view ORDER BY id;
select id, sal, sign(case when sal>0 then 200 else sal end ) from t1_view order by id;
select id, sal, sign(case when sal=0 then 200 else sal end ), COUNT(*) from t1_view GROUP by sign(case when sal=0 then 200 else sal end ),id ORDER BY id;


