SELECT LEAST(sign(10),sign(-10),sign(0),sign(NULL)) from dual;
SELECT LEAST(LEAST(sign(consumer),datetime1),datetime2) FROM t1;
SELECT sign(least(consumer, sal)) from t1;
SELECT sign(sign(sal)) from t1;

SELECT sign(sum(sal)) from t1;
SELECT SUM(sign(sal)) FROM t1 ORDER BY id;
SELECT SUM(sign(sal)+sign(price)) FROM t1 ORDER BY id;

SELECT COUNT(sign(sal)) FROM t1 ORDER BY id;
SELECT COUNT(sign(sal)+sign(consumer)) FROM t1 ORDER BY id;
SELECT sign(COUNT(sal+consumer)) FROM t1 ORDER BY id;


SELECT MAX(sign(sal)) FROM t1 ORDER BY id;
SELECT sign(MAX(sal)) FROM t1 ORDER BY id;


SELECT MIN(sign(sal)) FROM t1 ORDER BY id;
SELECT sign(MIN(sal)) FROM t1 ORDER BY id;


SELECT AVG(sign(sal)) FROM t1 ORDER BY id;
SELECT sign(AVG(sal)) FROM t1 ORDER BY id;


SELECT ABS(sign(sal)) FROM t1 ORDER BY id;
SELECT sign(ABS(sal)) FROM t1 ORDER BY id;


SELECT CEIL(sign(sal)) FROM t1 ORDER BY id;
SELECT sign(CEIL(sal)) FROM t1 ORDER BY id;


SELECT FLOOR(sign(price)) FROM t1 ORDER BY id;
SELECT sign(FLOOR(price)) FROM t1 ORDER BY id;


SELECT MOD(sign(sal),2) FROM t1 ORDER BY id;
SELECT sign(MOD(sal,3)) FROM t1 ORDER BY id;


SELECT LENGTH(sign(price)) FROM t1;
SELECT sign(LENGTH(price)) FROM t1;


SELECT INSTR(sign(price),'-1') FROM t1;
SELECT sign(INSTR(consumer,'局')) FROM t1;


SELECT sign(CAST(datetime1 AS CHAR(200))) FROM t1;
SELECT CAST(sign(sal) AS CHAR(200)) FROM t1;
SELECT CAST(sign(sal) AS SIGNED) FROM t1;
SELECT CAST(sign(price) AS SIGNED ) FROM t1;
SELECT CAST(sign(datetime1) AS datetime) FROM t1;


