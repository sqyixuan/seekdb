#description: 参数类型，参数个数

--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user wmj456@'%';
--enable_warnings
create user wmj456 identified by 'wmj456';
grant all on *.* to wmj456 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,test,$OBMYSQL_PORT);


--echo obmysql-sign-1
--error 0,1582
# 参数个数
SELECT sign() FROM dual;
SELECT sign(' ') FROM dual;
SELECT sign(NUll) FROM dual;
SELECT sign(-1) FROM dual;
SELECT sign(0) FROM dual;
SELECT sign(1) FROM dual;
--error 0,1582
SELECT sign(1,2) FROM dual;
--error 0,1582
SELECT sign(1,2,3) FROM dual;

# 参数类型
SELECT sign(100) FROM dual;
SELECT sign(10000) FROM dual;
SELECT sign(-10000) FROM dual;
SELECT sign(10000000) FROM dual;
SELECT sign(1000000000) FROM dual;
SELECT sign(10000000000000) FROM dual;
SELECT sign(11011101011001101110011001000) From dual;
 # float
SELECT sign(1.175494351E-38) From dual;
SELECT sign(-3.402823466E+38) From dual;
SELECT sign(-1.7976931348623157E+308) From dual;
 # double
SELECT sign(2.2250738585072014E-308) From dual;
SELECT sign(1.7976931348623157E+308) From dual;
 # char / varchar / tinytext / text / longtext
SELECT sign('斯巴达') From dual;
SELECT sign('斯巴达斯巴达斯巴达斯巴达斯巴达斯巴') From dual;
 # tinyblob / blob / mediumblob / longblob 
SELECT sign('001') From dual;
SELECT sign('-111000111') From dual;
SELECT sign('1100111011110101111010000000111000111') From dual;
 # date
SELECT sign('0000-12-25') From dual;
SELECT sign('0000-13-25') From dual;
SELECT sign('0001-12-33') From dual;
 # time
SELECT sign('00:00:00') From dual;
SELECT sign('00:00:01') From dual;
SELECT sign('00:01:00') From dual;
SELECT sign('01:00:00') From dual;
SELECT sign('01:00:88') From dual;
 # year
SELECT sign('2020') From dual;
SELECT sign('0999') From dual;
SELECT sign('0001') From dual;
 # datetime
SELECT sign('0000-12-25 00:00:00') From dual;
SELECT sign('0001-12-25 00:00:00') From dual;
 # timestamp
SELECT sign('2147483647') From dual;
 # other
SELECT sign("wmj456") FROM dual;
SELECT sign("456wmj") FROM dual;
SELECT sign("wmj 456") FROM dual;
SELECT sign("2020-12-25 wmj456") FROM dual;
SELECT sign("2020 NULL wmj456") FROM dual;
SELECT sign("……&%￥#*（——！@#") FROM dual;
SELECT sign("1……&%￥#*（——！@#") FROM dual;
SELECT sign('α β γ δ ε ζ η θ ι κ λ μ ν ξ') FROM dual;
SELECT sign('∑ΤΥΦΧΨΩ') FROM dual;
SELECT sign('w(ﾟДﾟ)w') FROM dual;
SELECT sign('ヽ(✿ﾟ▽ﾟ)ノ') FROM dual;
SELECT sign('-@2') FROM dual;
SELECT sign('@') FROM dual;
SELECT sign('*2') FROM dual;

