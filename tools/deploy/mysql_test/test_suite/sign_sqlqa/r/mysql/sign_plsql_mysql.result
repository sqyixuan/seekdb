begin
declare i int;
set i := 1;
WHILE i <= 5 do
INSERT INTO t1 VALUES(0,'哈哈哈','600',wb+100,'2021-01-01 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,'哦哦哦','19111',wb+200,'2021-01-01 10:11:59',20200228101159);
set i := i+1;
END while;
END;
//
