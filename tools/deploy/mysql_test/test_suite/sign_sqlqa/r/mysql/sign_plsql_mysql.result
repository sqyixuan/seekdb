drop function f_test ;//
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT  sign(samplename) FROM t1 e WHERE sign(sal)=0 INTO a ;
return a;
END;
//
SELECT f_test(-100);
f_test(-100)
-1
SELECT f_test(-0.1);
f_test(-0.1)
-1
SELECT f_test(0);
f_test(0)
0
SELECT f_test(0.22222);
f_test(0.22222)
1
SELECT f_test(abc);
SELECT f_test(NULL);
f_test(NULL)
NULL
