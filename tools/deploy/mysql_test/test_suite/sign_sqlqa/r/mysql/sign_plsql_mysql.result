drop procedure p_test;//
CREATE  PROCEDURE p_test()
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into b;
WHILE i <= 10 do
INSERT INTO t1 VALUES(0,a,concat('无参存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,concat('无参存储过程b参数第',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
END while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
CALL p_test();
SELECT COUNT(*) FROM t1;
COUNT(*)
29
delete from t1 where price like '%存储%';
drop procedure p_test;//
CREATE PROCEDURE p_test(in samplename  varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = samplename into b;
set i := 1;
repeat
INSERT INTO t1 VALUES(0,a,concat('in存储过程a参数第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(0,b,concat('in存储过程b参数第',i,'次'),90000,'2020-02-29 10:11:59',20200228101159);
set i := i+1;
until i >= 10
end	 repeat;
END ;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
CALL p_test(500);
CALL p_test(0);
CALL p_test(-1);
CALL p_test(NULL);
SELECT COUNT(*) FROM t1;
COUNT(*)
79
delete from t1 where price like '%存储%';
drop procedure p_test;//
CREATE PROCEDURE p_test(out wb  varchar(200), out wb1  varchar(200))
begin
declare i int;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = 0 into wb;
SELECT sign(sal) FROM t1 e WHERE sign(e.sal) = -1 into wb1;
set i :=  1;
while i <= 10 do
INSERT INTO t1 VALUES(0,'哈哈哈',concat('存储过程out第',i,'次'),7000,'2020-08-21 10:11:59',20190821101159);
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM t1;
COUNT(*)
7
call p_test(@wb,@wb1);
SELECT COUNT(*) FROM t1;
COUNT(*)
17
delete from t1 where price like '%存储%';
