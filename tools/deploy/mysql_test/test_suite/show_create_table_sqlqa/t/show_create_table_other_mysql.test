show create table t1;
create view t2 as select * from t1;
show create table t2;

drop view if exists t2;
drop table if exists t1;


--echo #alter

drop table if exists t1;
create table t1(c0 int,c1 varchar(50));
show create table t1;

--echo #添加列
alter table t1 add c2 datetime first;
show create table t1;

--echo #修改列名

alter table t1 change c1 c3 varchar(20) ;
show create table t1;

--echo #修改列属性

alter table t1 modify c0 int primary key auto_increment;
#mysql 默认 auto_increment = 1 不显示，ob显示，mysql从auto_increment = 2 开始显示
show create table t1;

--echo #修改列默认值

alter table t1 modify column c3 varchar(10) default 'AAA';
show create table t1;


--echo #删除列默认值

alter table t1 alter c3 drop default;
--echo #删除列的默认值，mysql就没有default null，ob还是有default null 不兼容
show create table t1;

--echo #删除列  

alter table t1 drop column c3;
show create table t1;


--echo #修改索引状态

create index t_i on t1(c2);
show create table t1;

alter table t1 alter index t_i invisible;
--echo #mysql 显示索引状态无效,忽略不兼容
show create table t1;

alter table t1 alter index t_i visible;
show create table t1;


--echo #添加分区

drop table if exists t2;
create table t2 (
    log_id      bigint not null 
    , log_value varchar(50)
    , log_date  timestamp not null  
) partition by range(unix_timestamp(log_date)) 
(
    partition m202001 values less than(unix_timestamp('2020/02/01'))
    , partition m202002 values less than(unix_timestamp('2020/03/01'))
    , partition m202003 values less than(unix_timestamp('2020/04/01'))
    , partition m202004 values less than(unix_timestamp('2020/05/01'))
    , partition m202005 values less than(unix_timestamp('2020/06/01')));

show create table t2;

alter table t2 add partition (partition m202006 values less than(unix_timestamp('2020/07/01')));

show create table t2;


--echo #删除分区

alter table t2 drop partition m202001;
show create table t2;


--echo #TRUNCATE 
create index t_c on t2(log_date);
show create table t2;

alter table t2 truncate partition m202003;
show create table t2;

--echo #rename

alter table t2 rename t3;
show create table t3;


--echo #rename index

alter table t3 rename index t_c to t_q;
show create table t3;

drop table t3;


--echo #修改表属性
--echo #修改表组

alter table t1 tablegroup = 'myTableGroup1';
show create table t1;

--echo #修改 block_size

alter table t1 block_size = 1024;
show create table t1;

--echo #compression

alter table t1 compression = 'none';
#压缩方式不同,ob不展示compression,
show create table t1;

--echo #auto_increment

alter table t1  auto_increment = 10;
show create table t1;

--echo #comment

alter table t1 comment "测试表";
show create table t1;

--echo #duplicate_scope
#master分支不支持
#alter table t1 duplicate_scope = 'cluster';
#show create table t1;

--echo #PROGRESSIVE_MERGE_NUM

alter table t1 progressive_merge_num = 10;
show create table t1;

--echo #parallel_clause

alter table t1 parallel 10;
show create table t1;


--echo #noparallel

alter table t1 noparallel;
show create table t1;

drop table t1;

--echo #drop foreign key

drop table if exists t1;
create table t1(c0 int primary key,c1 varchar(50));
show create table t1;

drop table if exists t2; 
create table t2(c0 int,c2 varchar(100));
alter table t2 add constraint fk1 foreign key (c0) references t1(c0);
show create table t2;

alter table t2 drop foreign key fk1;
show create table t2;

--echo #drop primary key

alter table t1 drop primary key;
show create table t1;

--echo #check enforced

alter table t1 add constraint my_check check (c0 > 100)not enforced;
show create table t1;

alter table t1 drop constraint my_check;
show create table t1;

drop table t1;
drop table t2;
drop tablegroup myTableGroup1;
#drop tablespace tp;

set _show_ddl_in_compat_mode = 0;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings
