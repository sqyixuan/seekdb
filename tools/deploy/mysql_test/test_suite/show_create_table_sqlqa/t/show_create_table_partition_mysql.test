#owner:wuyuming.wym
#owner group:sql1
#description:partition
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);

set _show_ddl_in_compat_mode = 1;
--echo #partition
--echo #range\range columns

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;


drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range columns(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

--echo #list\list columns

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by list(c0)(partition p0 values in(100),partition p1 values in (200));
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by list columns(c0)(partition p0 values in(100),partition p1 values in (200));
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by list(c0)(partition p0 values in(100),partition p1 values in (default));
show create table t1;


--echo #hash\key

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by hash(c0) partitions 8;
show create table t1;


drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by key(c0) partitions 8;
show create table t1;


--echo #组合分区
--echo #range-hash

drop table if exists t1;
create table t1(c0 int,c2 int) partition by range(c0) subpartition by hash(c2) subpartitions 2(
        partition p0 values less than (1990),
        partition p1 values less than (2000),
        partition p2 values less than maxvalue);

show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 int)
    partition by range(c0) subpartition by hash(c2) (
        partition p0 values less than (1990) (
            subpartition s0,
            subpartition s1
        ),
        partition p1 values less than (2000) (
            subpartition s2,
            subpartition s3
        ),
        partition p2 values less than maxvalue(
            subpartition s4,
            subpartition s5
        )
    );
show create table t1;


--echo #range-range 分区

drop table if exists t1;
create table t1(c0 int,c2 int) 
         partition by range columns(c0)
         subpartition by range(c2)
         subpartition template 
          (subpartition p1 values less than(3),
           subpartition p2 values less than(6),
           subpartition p3 values less than(9)
          )
          (partition p0 values less than(100),
           partition p1 values less than(200),
           partition p2 values less than(300)
          ); 

show create table t1;


--echo #模板化 Range Columns + Range Columns


drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by range columns(c0)
     subpartition by range columns(c2)
     subpartition template  
      (subpartition mp0 values less than(1000),
       subpartition mp1 values less than(2000),
       subpartition mp2 values less than(3000))
      (partition p4 values less than(100),
       partition p5 values less than(200),
       partition p6 values less than(300)); 
	  
show create table t1;


--echo #模板化 Range Columns + List Columns

drop table if exists t1;
	  
create table t1(c0 int,c2 int) 
     partition by range columns(c0)
     subpartition by list columns(c2)
     subpartition template 
      (subpartition mp0 values in(1,3),
       subpartition mp1 values in(4,6),
       subpartition mp2 values in(7))
      (partition p0 values less than(100),
       partition p1 values less than(200),
       partition p2 values less than(300)); 

show create table t1;


drop table if exists t1;
	  
create table t1(c0 int,c2 int) 
     partition by range columns(c0)
     subpartition by list columns(c2)
     subpartition template 
      (subpartition mp0 values in(1,3),
       subpartition mp1 values in(4,6),
       subpartition mp2 values in(default))
      (partition p0 values less than(100),
       partition p1 values less than(200),
       partition p2 values less than(300)); 

show create table t1;

--echo #模板化 Range Columns + Hash

drop table if exists t1;
create table t1(c0 int,c2 int) 
     partition by range columns(c0)
     subpartition by hash(c2) subpartitions 5
      (partition p0 values less than(100),
       partition p1 values less than(200),
       partition p2 values less than(300));

show create table t1;


--echo #模板化 Range Columns + Key

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by range columns(c0)
     subpartition by key(c2) subpartitions 3
      (partition p0 values less than(100),
       partition p1 values less than(200),
       partition p2 values less than(300)); 
	 
show create table t1;


--echo #模板化 List Columns + Range Columns

drop table if exists t1;

create table t1(c0 int,c2 int) 
 partition by list columns(c0)
     subpartition by range columns(c2)
     subpartition template 
      (subpartition mp0 values less than(100),
       subpartition mp1 values less than(200),
       subpartition mp2 values less than(300))
      (partition p0 values in(1,3),
       partition p1 values in(4,6),
       partition p2 values in(7,9));
	  
show create table t1;


drop table if exists t1;

create table t1(c0 int,c2 int) 
 partition by list columns(c0)
     subpartition by range columns(c2)
     subpartition template 
      (subpartition mp0 values less than(100),
       subpartition mp1 values less than(200),
       subpartition mp2 values less than(300))
      (partition p0 values in(1,3),
       partition p1 values in(4,6),
       partition p2 values in(default));
	  
show create table t1;



--echo #模板化 List Columns + List Columns

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by list columns(c0)
     subpartition by list columns(c2)
     subpartition template 
      (subpartition mp0 values in(2),
       subpartition mp1 values in(5),
       subpartition mp2 values in(8))
      (partition p0 values in(1,3),
       partition p1 values in(4,6),
       partition p2 values in(7,9));

show create table t1;


drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by list columns(c0)
     subpartition by list columns(c2)
     subpartition template 
      (subpartition mp0 values in(2),
       subpartition mp1 values in(5),
       subpartition mp2 values in(8))
      (partition p0 values in(1,3),
       partition p1 values in(4,6),
       partition p2 values in(default));

show create table t1;


--echo #模板化 List Columns + List Columns default 分区
drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by list columns(c0)
     subpartition by list columns(c2)
     subpartition template 
      (subpartition mp0 values in(2),
       subpartition mp1 values in(5),
       subpartition mp2 values in(default))
      (partition p0 values in(1,3),
       partition p1 values in(4,6),
       partition p2 values in(default));

show create table t1;
   

--echo #模板化 List Columns + Hash 

drop table if exists t1;

create table t1(c0 int,c2 int) 
partition by list columns(c0)
     subpartition by hash(c2) subpartitions 5
      (partition p0 values in(100),
       partition p1 values in(200),
       partition p2 values in(300)); 

show create table t1;


drop table if exists t1;

create table t1(c0 int,c2 int) 
partition by list columns(c0)
     subpartition by hash(c2) subpartitions 5
      (partition p0 values in(100),
       partition p1 values in(200),
       partition p2 values in(default)); 

show create table t1;


--echo #模板化 List Columns + Key

drop table if exists t1;

create table t1(c0 int,c2 int) 
partition by list columns(c0)
     subpartition by key(c2)
      subpartitions 3
      (partition p0 values in(100),
       partition p1 values in(200),
       partition p2 values in(300)); 

show create table t1;


drop table if exists t1;

create table t1(c0 int,c2 int) 
partition by list columns(c0)
     subpartition by key(c2)
      subpartitions 3
      (partition p0 values in(100),
       partition p1 values in(200),
       partition p2 values in(default)); 

show create table t1;

--echo #模板化 Hash + Range

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by hash(c0)
     subpartition by range(c2)
     subpartition template
      (subpartition p0 values less than(100),
       subpartition p1 values less than(200),
       subpartition p2 values less than(300))
      partitions 5;

show create table t1;


--echo #模板化 Hash + List 

drop table if exists t1;

create table t1(c0 int,c2 int) 
partition by hash(c0)
     subpartition by list(c2)
     subpartition template
      (subpartition p0 values in(1,3),
       subpartition p1 values in(4,6),
       subpartition p2 values in(7,9))
      partitions 5;

show create table t1;


--echo #模板化 Hash + Hash

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by hash(c0)
     subpartition by hash(c2)
     subpartition template
      (subpartition sp0,
       subpartition sp1,
       subpartition sp2)
      partitions 5;

show create table t1;


--echo #模板化 Hash + Key

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by hash(c0)
     subpartition by key(c2)
     subpartition template
      (subpartition sp0,
       subpartition sp1,
       subpartition sp2)
      partitions 5;

show create table t1;


--echo #模板化 Key + Range Columns

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by key(c0)
     subpartition by range columns(c2)
     subpartition template
      (subpartition sp0 values less than(100),
       subpartition sp1 values less than(200),
       subpartition sp2 values less than(300))
      (partition p0,
       partition p1,
       partition p2);

show create table t1;


--echo #模板化 Key + List Columns

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by key(c0)
     subpartition by list columns(c2)
     subpartition template
      (subpartition p0 values in(1,3),
       subpartition p1 values in(4,6),
       subpartition p2 values in(7,9))
     partitions 5;

show create table t1;


--echo #模板化 Key + Hash 

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by key(c0)
     subpartition by hash(c2)
     subpartition template
      (subpartition sp0,
       subpartition sp1,
       subpartition sp2)
      partitions 5;

show create table t1;


--echo #模板化 Key + Key

drop table if exists t1;

create table t1(c0 int,c2 int) 
     partition by key(c0)
     subpartition by key(c2)
     subpartition template
      (subpartition sp0,
       subpartition sp1,
       subpartition sp2)
      partitions 5;

show create table t1;


--echo #非模板化 Range + Range

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by range(c0)
     subpartition by range(c1)
      (partition p0 values less than(100)
         (subpartition sp0 values less than(25),
          subpartition sp1 values less than(50),
          subpartition sp2 values less than(75),
          subpartition sp3 values less than(100)),
       partition p1 values less than(200)
         (subpartition sp4 values less than(125),
          subpartition sp5 values less than(150),
          subpartition sp6 values less than(175),
          subpartition sp7 values less than(200)));

show create table t1;


--echo #非模板化 Range Columns + List Columns 

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by range columns(c0)
     subpartition by list columns(c1)
     (partition p0 values less than(100)
       (subpartition sp0 values in(1,3),
        subpartition sp1 values in(4,6),
        subpartition sp2 values in(7,9)),
      partition p1 values less than(200)
       (subpartition sp3 values in(1,3),
        subpartition sp4 values in(4,6),
        subpartition sp5 values in(7,9))
     ); 

show create table t1;


drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by range columns(c0)
     subpartition by list columns(c1)
     (partition p0 values less than(100)
       (subpartition sp0 values in(1,3),
        subpartition sp1 values in(4,6),
        subpartition sp2 values in(7,9)),
      partition p1 values less than(200)
       (subpartition sp3 values in(1,3),
        subpartition sp4 values in(4,6),
        subpartition sp5 values in(default))
     ); 

show create table t1;



--echo #非模板化 Range Columns + Hash

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by range(c0)
     subpartition by hash(c1)
     (partition p0 values less than(100)
       (subpartition sp0,
        subpartition sp1,
        subpartition sp2),
      partition p1 values less than(200)
       (subpartition sp3,
        subpartition sp4,
        subpartition sp5)
     ); 

show create table t1;


--echo #非模板化 Hash + Range

drop table if exists t1;
create table t1(c0 int,c1 int) 
 partition by key(c0) 
     subpartition by range(c1)
       (partition p1
        (subpartition sp0 values less than (2020)
        ,subpartition sp1 values less than (2021)
        ,subpartition sp2 values less than (2022)
        ,subpartition sp3 values less than (2023)
        ),
        partition p2
        (subpartition sp4 values less than (2020)
        ,subpartition sp5 values less than (2021)
        ,subpartition sp6 values less than (2022)
        ,subpartition sp7 values less than (2023)
        )
       );

show create table t1;


--echo #非模板化 Hash + List

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by hash(c0) 
     subpartition by list(c1)
      (partition p1
        (subpartition sp0 values in (2020)
        ,subpartition sp1 values in (2021)
        ,subpartition sp2 values in (2022)
        ,subpartition sp3 values in (2023)
         ),
       partition p2
        (subpartition sp4 values in (2020)
        ,subpartition sp5 values in (2021)
        ,subpartition sp6 values in (2022)
        ,subpartition sp7 values in (2023)
         )
      );

show create table t1;

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by hash(c0) 
     subpartition by list(c1)
      (partition p1
        (subpartition sp0 values in (2020)
        ,subpartition sp1 values in (2021)
        ,subpartition sp2 values in (2022)
        ,subpartition sp3 values in (default)
         ),
       partition p2
        (subpartition sp4 values in (2020)
        ,subpartition sp5 values in (2021)
        ,subpartition sp6 values in (2022)
        ,subpartition sp7 values in (default)
         )
      );

show create table t1;


--echo #非模板化 Hash + Key

drop table if exists t1;
create table t1(c0 int,c1 int) 
     partition by hash(c0) 
     subpartition by key(c1)
      (partition p1
       (subpartition sp0
       ,subpartition sp1
       ,subpartition sp2
       ,subpartition sp3
       ),
       partition p2
       (subpartition sp4
       ,subpartition sp5
       ,subpartition sp6
       ,subpartition sp7
       ));

show create table t1;

drop table if exists t1;

set _show_ddl_in_compat_mode = 0;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings

