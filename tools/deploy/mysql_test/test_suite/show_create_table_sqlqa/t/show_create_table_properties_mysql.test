#drop table if exists t1;
#create table t1(c0 int,c2 varchar(100))ENGINE=MyISAM compression 'ZLIB';
#show create table t1;


--echo #PARALLEL 

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) parallel 10;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) noparallel;
show create table t1;

--echo #comment 

drop table if exists t1;
create table t1(c0 int comment "数字列",c2 varchar(100)) comment "用户表";
show create table t1;

alter table t1 modify column c2 varchar(100) comment "名称";
show create table t1;

--echo #CHARACTER SET
--echo #默认collate,ob不做展示
drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) character set'utf8mb4') character set = 'utf8mb4';
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) character set'utf8mb4') character set = 'gbk';
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) character set'utf8mb4') character set = 'utf16';
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) character set'utf8mb4') character set = 'gb18030';
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) character set'utf8mb4') character set = 'binary';
show create table t1;


--echo #collate
--disable_abort_on_error

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf8mb4_general_ci) collate utf8mb4_general_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf8mb4_bin) collate utf8mb4_bin;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf8_unicode_ci) collate utf8_unicode_ci;
show create table t1;


drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate gbk_chinese_ci) collate gbk_chinese_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate gbk_bin) collate gbk_bin;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf16_general_ci) collate utf16_general_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf16_bin) collate utf16_bin;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf8mb4_unicode_ci) collate utf8mb4_unicode_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate utf16_unicode_ci) collate utf16_unicode_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate gb18030_chinese_ci) collate gb18030_chinese_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate gb18030_bin) collate gb18030_bin;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate latin1_swedish_ci) collate latin1_swedish_ci;
show create table t1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100) collate latin1_bin) collate latin1_bin;
show create table t1;

--enable_abort_on_error

