--echo #table_tablegroup
--error 0,5151
drop tablegroup myTableGroup1;
create tablegroup myTableGroup1;

drop table if exists t1;
create table t1(c0 int ,c2 varchar(100)) tablegroup = myTableGroup1 ;
show create table t1;

drop table if exists t1;

--echo #AUTO_INCREMENT

drop table if exists t1;
create table t1(c0 int primary key auto_increment,c2 varchar(100));
show create table t1;

--echo #PCTFREE

drop table if exists t1;
create table t1(c0 int primary key auto_increment,c2 varchar(100)) pctfree 5;
show create table t1;


--echo #USE_BLOOM_FILTER

drop table if exists t1;
create table t1(c0 int primary key auto_increment,c2 varchar(100)) use_bloom_filter = true;
show create table t1;


--echo #TABLET_SIZE

drop table if exists t1;
create table t1(c0 int primary key auto_increment,c2 varchar(100)) tablet_size = 134217728;
show create table t1;

--echo #REPLICA_NUM

drop table if exists t1;
create table t1(c0 int primary key auto_increment,c2 varchar(100)) replica_num = 2;
show create table t1;


--echo #Generated colum

drop table if exists t1;

create table t1(c0 int,c2 varchar(100),generated_column int AS (c0*10) stored);
show create table t1;

drop table if exists t1;

create table t1(c0 int,c2 varchar(100),generated_column int AS (length(c2)) virtual not null);
show create table t1;

drop table if exists t1;

create table t1(c0 int,c2 varchar(100),generated_column int AS (length(c2)) virtual not null,index(generated_column));
show create table t1;


drop table if exists t1;

#create table t1(c0 int,c2 varchar(100),generated_column int AS (length(c2)) virtual check(generated_column > 5),index(generated_column));
create table t1(c0 int,c2 varchar(100),generated_column int AS (length(c2)) virtual constraint ck check(generated_column > 5),index(generated_column));
show create table t1;

alter table t1 add generated_column1 int as(c0 * 5) stored not null;
alter table t1 add generated_column2 int as(c0 * 10) virtual;
show create table t1;

drop table if exists t1;
#drop tablespace tp;
drop tablegroup myTableGroup1;

set _show_ddl_in_compat_mode = 0;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings
