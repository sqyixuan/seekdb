#owner:wuyuming.wym
#owner group:sql1
#description:show create table,index,datatype
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);

set _show_ddl_in_compat_mode = 1;

--echo #不存在表
--error 0,1146
show create table t1;


--echo #数据类型
drop table if exists t1;
create table t1(c0 bool,c1 boolean,c2 tinyint,c3 smallint,c4 mediumint,c5 int,c6 integer,c7 bigint,c8 decimal,c9 numeric,c10 float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10),c19 varchar(10),c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json);
show create table t1;


--echo #index

drop table if exists t1;
create table t1(c0 bool,c1 boolean,c2 tinyint,c3 smallint,c4 mediumint,c5 int,c6 integer,c7 bigint,c8 decimal,c9 numeric,c10 float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10),c19 varchar(10),c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json,index (c0),index c2_ix(c2),unique index (c4),unique index u_i(c5),unique index f_ui(c0,c1),index(c7,c8),key (c9));
show create table t1;

alter table t1 add index (c10);
show create table t1;

create index index_name on t1(c11);
show create table t1;

alter table t1 add unique index (c12);
show create table t1;

create index composite_index on t1(c10,c11);
show create table t1;

--echo #无效的index没有显示,不做兼容
alter table t1 alter index index_name invisible;
show create table t1;

alter table t1 alter index index_name visible;
show create table t1;

drop table if exists t1;
CREATE TABLE t1 (c varchar(20), g INT GENERATED ALWAYS AS (length(c)),INDEX i (g));
show create table t1;

--echo #local index

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c0);
show create table t1;

create unique index t_y on t1(c0,c2);
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c0) storing(c2);
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c0) using btree;
--echo #ob只支持using btree,mysql 支持using btree 和 using hash,指定using btree 后show create table 显示using btree
show create table t1;

create index t_c on t1(c2) using hash;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c0 asc) comment "索引";
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100),index ind(c2) global);  
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;
 
#create index t_b on t1(c2) compression 'none';
#show create table t1;

create index t_b on t1(c2 asc) block_size = 16384 ;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c0 asc) storing(c2);
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c2(10));
show create table t1;


drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) partition by range(c0)(partition p0 values less than(100),partition p1 values less than(200),partition p2 values less than(300));  
show create table t1;

create index t_b on t1(c2(10)) INVISIBLE ;
--echo #不跟mysql兼容
show create table t1;

drop table if exists t1;
create table t1 (seed bigint not null ,secondseed bigint not null ,partitionkey bigint not null ,subpartitionkey bigint not null ) PARTITION BY HASH(partitionkey) SUBPARTITION BY HASH(subpartitionkey) SUBPARTITIONS 40 PARTITIONS 65;

show create table t1;

drop table if exists t1;

--echo #global index

drop table if exists t1;
create table t1(c0 int,c2 int,index ix(c2) global);
show create table t1;


drop table if exists t1;
create table t1(c0 int,c2 int);
show create table t1;

create index t_g on t1(c0) global 
       partition by range(c0)
       (partition p0 values less than(100),
        partition p1 values less than(200),
        partition p2 values less than(300)); 

show create table t1;

--echo #constraint

#drop table if exists t1;
#create table t1(c0 bool not null,c1 boolean,c2 tinyint unique,c3 smallint check(c3 > 10),c4 mediumint default 10,c5 int primary key,c6 integer,c7 bigint,c8 decimal,c9 numeric,c10 #float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10),c19 varchar(10),c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 #mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json);
#show create table t1;

drop table if exists t1;
create table t1(c0 bool not null,c1 boolean,c2 tinyint unique,c3 smallint constraint ck check(c3 > 10),c4 mediumint default 10,c5 int primary key,c6 integer,c7 bigint,c8 decimal,c9 numeric,c10 float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10),c19 varchar(10),c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json);
show create table t1;

#drop table if exists t2;
#create table t2(c0 int,c2 varchar(100),foreign key(c0) references t1(c5));
#--echo #外键约束obmysql显示ON UPDATE RESTRICT ON DELETE RESTRICT,mysql默认不显示
#show create table t2;
#drop table if exists t2;

drop table if exists t2;
create table t2(c0 int,c2 varchar(100),constraint f foreign key(c0) references t1(c5));
--echo #外键约束obmysql显示ON UPDATE RESTRICT ON DELETE RESTRICT,mysql默认不显示
show create table t2;
drop table if exists t2;

drop table if exists t1;
CREATE TABLE t1 (c varchar(20),c1 int,primary key(c,c1));
show create table t1;

drop table if exists t1;
CREATE TABLE t1 (c varchar(20),c1 int);
show create table t1;
alter table t1 add constraint t_p primary key(c,c1);
show create table t1;


drop table if exists t1;
create table t1(c0 bool,c1 boolean,c2 tinyint,c3 smallint,c4 mediumint,c5 int,c6 integer,c7 bigint not null,c8 decimal not null,c9 numeric default 10,c10 float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10) default 'AAA' not null,c19 varchar(10) default 'BBBB' not null,c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json,constraint pk_r primary key(c0),constraint c_k check(c4 > 10),constraint uq unique(c5));
show create table t1;


drop table if exists t1;
create table t1(c0 bool,c1 boolean,c2 tinyint,c3 smallint,c4 mediumint,c5 int,c6 integer,c7 bigint,c8 decimal,c9 numeric,c10 float,c11 double,c12 bit,c13 datetime,c14 timestamp,c15 date,c16 time,c17 year,c18 char(10),c19 varchar(10),c20 binary(10),c21 varbinary(10),c22 tinyblob,c23 blob,c24 mediumblob,c25 longblob,c26 tinytext,c27 text,c28 mediumtext,c29 longtext,c30 enum('男','女'),c31 set('中','英'),c32 json);
show create table t1;

alter table t1 add constraint t_p primary key(c5);
show create table t1;

alter table t1 add constraint u_q unique(c3);
show create table t1;

alter table t1 add constraint c_q check(c4 > 100);
show create table t1;

alter table t1 modify c6 integer not null;
show create table t1;

alter table t1 modify c7 bigint default 100 not null;
show create table t1;


drop table if exists t2;
create table t2(c0 int default 10,c2 varchar(100));
show create table t2;
alter table t2 add constraint f_r foreign key(c0) references t1(c5);
show create table t2;

alter table t2 drop foreign key f_r;
alter table t2 add constraint f_r foreign key(c0) references t1(c5) on delete restrict on update restrict;
show create table t2;

alter table t2 drop foreign key f_r;
alter table t2 add constraint f_r foreign key(c0) references t1(c5) on delete cascade on update cascade;
show create table t2;

alter table t2 drop foreign key f_r;
alter table t2 add constraint f_r foreign key(c0) references t1(c5) on update no action on delete no action;
show create table t2;


drop table if exists t2;
drop table if exists t1;


--echo #DUPLICATE_SCOPE
--echo #master不支持,语法报错
#drop table if exists t1;
#create table t1(c0 int,c2 varchar(100)) duplicate_scope = 'cluster';
#show create table t1;


--echo #ROW_FORMAT

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format redundant;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compact;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format dynamic;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compressed;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format default;
show create table t1;


--echo #BLOCK_SIZE

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compressed block_size= 32678;
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compressed;
show create table t1;

alter table t1 set block_size = 32678;

show create table t1;


--echo #COMPRESSION
--echo #ob 跟 mysql 取值不同，不做显示
drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compressed compression 'none';
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100))row_format compressed compression 'zstd_1.0';
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100)) row_format compressed compression 'lz4_1.0';
show create table t1;

drop table if exists t1;
create table t1(c0 int,c2 varchar(100))row_format compressed compression 'snappy_1.0';
show create table t1;

