drop user longpy cascade;
create user longpy IDENTIFIED BY longpy;
grant all on *.* to longpy WITH GRANT OPTION;
grant dba to longpy;
ob_no_primary_table_3_2
##无主键表，虚拟列
drop table t1;
drop table t2;
create table t2(deptno number,dname varchar2(20),loc varchar2(20));
insert into t2 values(10,'AccounTing','New York');
insert into t2 values (20,'ReSeaRch','DallAs');
insert into t2 values(30,'SaLeS','ChiCaGo');
insert into t2 values(40,'OperaTions','BoSton');
create table t1(EMPNO number(4),ENAME nvarchar2(10),JOB nvarchar2(9),MGR number(4),HIREDATE date,SAL number(7,2),COMM number(7,2),DEPTNO number(2),t_rowid rowid,sl_pk generated always as (sal + comm)virtual);
