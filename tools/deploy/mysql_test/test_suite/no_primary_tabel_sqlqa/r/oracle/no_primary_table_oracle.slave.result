#delete
delete from t1 where t_rowid = '*AAIKAQMAAAAAAAA=';
delete from t1 where t_rowid = 'AAAACOAABAAAAWJAAK';
delete from t1 where sl_pk < 1000;
delete from t1 where rowid = 'gAAYbMAAAAAABA==';
delete from t1 where rowid = 'AAGhLoAAHAAGAlOAAD';
delete from t1 where sl_pk in (select sl_pk from t1 where job = 'MANAGER');
select count(*) from t1;
COUNT(*)
13
