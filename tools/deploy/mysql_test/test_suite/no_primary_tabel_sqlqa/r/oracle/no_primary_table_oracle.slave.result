declare
t_r rowid ;
begin
select rowid into t_r from t1 where ename = 'JAMES';
if t_r like '%AA%' then
dbms_output.put_line('t_rowid='||t_r||'success');
else
dbms_output.put_line('t_rowid='||t_r||'false');
end if;
end;
