declare
v_sl_pk number;
begin
select sl_pk into v_sl_pk from t1 where ename = 'JAMES' order by 1;
dbms_output.put_line('sl_pk='||v_sl_pk);
end;
//
declare
v_sl_pk number;
begin
select sl_pk into v_sl_pk from t1 where ename = 'BLAKE' order by 1;
if v_sl_pk < 1000 then
dbms_output.put_line('sl_pk='||v_sl_pk||'低');
else
dbms_output.put_line('sl_pk='||v_sl_pk||'高');
end if;
end;
