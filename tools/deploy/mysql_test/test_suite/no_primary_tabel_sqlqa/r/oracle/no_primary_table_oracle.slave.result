drop trigger m_t;
create or replace trigger m_t after
insert or update or delete on t2 for each row
declare
t_r rowid;
v_r rowid;
begin
select rowid into v_r from t1 where ename = 'BLAKE' order by 1;
dbms_output.put_line('rowid = '|| v_r);
select t_rowid into t_r from t1 where ename = 'CLARK' order by 1;
dbms_output.put_line('t_rowid = '|| t_r);
if inserting then
insert into t1(empno,ename,job,sal,comm,deptno,t_rowid) values (7900,'KOBE','CLERK',3000,100,20,:old.rowid);
insert into t1(empno,ename,job,sal,comm,deptno,t_rowid) values (7900,'KOBE','CLERK',3000,100,20,:new.rowid);
end if;
if deleting then
delete from t1 where ename = 'JAMES';
end if;
if updating then
update t1 set sal = 3500 where ename = 'SCOTT';
end if;
end;
