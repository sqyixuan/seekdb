#insert
insert into t1(empno,ename,job,mgr,hiredate,sal,comm,deptno,t_rowid) select empno,ename,job,mgr,hiredate,sal,comm,deptno,t_rowid from t1 where rowid = 'gAAYbMAAAAAABA==';
insert into t1(empno,ename,job,mgr,hiredate,sal,comm,deptno,t_rowid) select empno,ename,job,mgr,hiredate,sal,comm,deptno,t_rowid from t1 where rowid = 'AAGhLoAAHAAGAlOAAD';
select count(*) from t1;
COUNT(*)
14
insert into t1(empno,ename,job,sal,comm) select empno,ename,job,sal,comm from t1 where ename = 'SCOTT' order by 1;
select count(*) from t1;
COUNT(*)
15
insert into t1(empno,ename,job,sal,comm)  values (8000,'KOBE','MANAGER',2600,400);
select count(*) from t1;
COUNT(*)
16
insert into t1(empno,ename,job,sal,comm) select empno,ename,job,sal,comm from t1 where sl_pk > 4500 order by 1;
select count(*) from t1;
COUNT(*)
19
