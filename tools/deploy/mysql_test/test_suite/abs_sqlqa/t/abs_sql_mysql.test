#owner group: SQL2
#description: abs函数
#tags: SQL dml操作
#author: wb-lyq858317

--disable_warnings
--error 0,1051
DROP TABLE abs_table1;
--error 0,1051
DROP TABLE abs_table2;
--error 0,1051
DROP TABLE abs_table3;


--echo abs-select-1
CREATE TABLE abs_table1(num INT,food char(20),price varchar(200));
INSERT INTO abs_table1 VALUES(1,'面包',-5.12315);
INSERT INTO abs_table1 VALUES(2,'牛奶','');
INSERT INTO abs_table1 VALUES(3,'大面包',-0.13545);
INSERT INTO abs_table1 VALUES(4,'奶牛奶',-1200);
INSERT INTO abs_table1 VALUES(5,'奶奶牛',NULL);
INSERT INTO abs_table1 VALUES(6,'牛奶奶',10);
INSERT INTO abs_table1 VALUES(7,'牛奶奶',-10);

CREATE TABLE abs_table2(num INT,name varchar(200),money varchar(200));
INSERT INTO abs_table2 VALUES(1,'Bing',-100);
INSERT INTO abs_table2 VALUES(2,'Bob',+10);
INSERT INTO abs_table2 VALUES(3,'Reachl',-0.23566000);
INSERT INTO abs_table2 VALUES(4,'Ross',NULL);
INSERT INTO abs_table2 VALUES(5,'friends','');

--echo abs-select-1-1 where、join 
select SUM(abs(price)) FROM abs_table1 WHERE num = 1;
select abs(price),abs(money),abs(price)+abs(money) from abs_table1 t1 left join abs_table2 t2 ON t1.num = t2.num;
select abs(price),abs(money),abs(price)+abs(money) from abs_table1 t1 RIGHT join abs_table2 t2 ON t1.num = t2.num;
select abs(price),abs(money),abs(price)+abs(money) from abs_table1 t1 INNER join abs_table2 t2 ON t1.num = t2.num;
select abs(price),abs(money),abs(price)+abs(money) from abs_table1 t1 left join abs_table2 t2 ON t1.num = t2.num ORDER BY t1.price DESC;

--echo abs-select-1-2 any、all、exists
SELECT * FROM abs_table1 WHERE abs(price) = ANY(SELECT price FROM abs_table1);
SELECT * FROM abs_table1 WHERE abs(price) > ANY(SELECT price FROM abs_table1);
SELECT * FROM abs_table1 WHERE abs(price) < ANY(SELECT price FROM abs_table1);

SELECT * FROM abs_table1 WHERE abs(price) = ALL(SELECT price FROM abs_table1);
SELECT * FROM abs_table1 WHERE abs(price) > ALL(SELECT price FROM abs_table1);
SELECT * FROM abs_table1 WHERE abs(price) < ALL(SELECT price FROM abs_table1 WHERE abs(price) > 1200);
SELECT * FROM abs_table1 WHERE abs(price) > ALL(SELECT price FROM abs_table1 WHERE abs(price) < 1200);

SELECT * FROM abs_table1 WHERE EXISTS (SELECT * FROM abs_table2 WHERE ABS(money)>1);
SELECT * FROM abs_table1 WHERE NOT EXISTS (SELECT * FROM abs_table2 WHERE ABS(money)<0);

--echo abs-select-1-3 create as 
CREATE TABLE abs_table3 AS SELECT ABS(price) pr FROM abs_table1;
SELECT * FROM abs_table3;

--echo abs-select-1-4 distinct、cast
SELECT DISTINCT ABS(price) FROM abs_table1;
--error 1064
SELECT  ABS(DISTINCT price) FROM abs_table1;
SELECT ABS(CAST(price AS char(10))) FROM abs_table1;
SELECT CAST(ABS(price) AS char(10)) FROM abs_table1;

--echo abs-select-1-5 group by having
SELECT t1.num,SUM(ABS(money)+ABS(price)) FROM abs_table1 t1 
LEFT JOIN abs_table2 t2 
ON t1.num = t2.num 
GROUP BY t1.num;
SELECT t1.price FROM abs_table1 t1 
GROUP BY t1.price
HAVING ABS(t1.price) > 10 ;

--echo abs-select-1-6 case when
SELECT num, CASE WHEN ABS(price)>10 THEN 1 ELSE 0 END FROM abs_table1;
SELECT num, CASE WHEN price < 0 THEN ABS(PRICE) WHEN PRICE = NULL THEN 1 ELSE 0 END FROM abs_table1;

--echo abs-insert-2-1 insert
INSERT INTO abs_table1 VALUES(8,'abc',abs(-10));
SELECT * FROM abs_table1;

INSERT INTO abs_table1 SELECT * FROM abs_table1 WHERE ABS(price) > 1;
SELECT * FROM abs_table1;

--echo abs-update-3-1 update

UPDATE abs_table1 SET food = '奶奶奶' WHERE ABS(price) > 0.1;
SELECT * FROM abs_table1;

UPDATE abs_table1 SET food = (SELECT ABS(money) FROM abs_table2 WHERE num = 3) WHERE ABS(price) > 0.1;
SELECT * FROM abs_table1;

--echo abs-update-4-1 delete
DELETE FROM abs_table1 WHERE ABS(price) < 1 ;
SELECT * FROM abs_table1;


--error 0,1051
DROP TABLE abs_table1;
--error 0,1051
DROP TABLE abs_table2;
--error 0,1051
DROP TABLE abs_table3;
