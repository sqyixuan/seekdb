#owner group: SQL2
#description: abs函数
#tags: 常见参数及函数结果使用等
#author: wb-lyq858317

--disable_warnings
--error 0, 1051
drop table abs_table;
--error 0, 1051
drop table ABS_TABLE1;

--echo  parameter-1-1  整数
select abs(10) from dual;
select abs(-10) from dual;
--echo  parameter-1-1  科学计数法
select abs(-1.99714E13) from dual;
select abs(1.99714E13) from dual;
--echo  parameter-1-1  小数
select abs(1.02345) from dual;
select abs(00.21323) from dual;
select abs(0.2135) from dual;
select abs(10.0) from dual;
select abs(0.0) from dual;
select abs(0.2) from dual;
select abs(-1.02345) from dual;
select abs(-00.21323) from dual;
select abs(-0.2135) from dual;
select abs(-10.0) from dual;
select abs(-0.0) from dual;
select abs(-0.2) from dual;
--echo  parameter-1-1 NULL and 0
select abs(NULL) from dual;
select abs(0) from dual;
select abs(-0) from dual;

--echo  parameter-1-2 没有参数
--error 1582 
select abs() from dual;

--error 1582
select abs( ) from dual;

--error 1582
select abs(	) from dual;

--error 1582
select abs(  ) from dual;

--echo  parameter-1-2 2个参数
--error 1582
select abs(10,10) from dual;
--error 1582
select abs(-10,32,-6) from dual;

--echo  parameter-1-2 无效参数
--error 0,1054
select abs(哈哈哈) from dual;
--error 0,1054
select abs(haha) from dual;
--error 0,1054
select abs(hah-10) from dual;
--error 0,1054
select abs(-10+haha) from dual;

--error 0,1064
select abs(0.12.012) from dual;

--error 0,1064
select abs(0..45) from dual;

--error 0,1064
select abs(-10&^%$) from dual;
--error 0,1054
select abs($10) from dual;


--echo parameter-2-1-1 加法参数算术运算
select abs(1+10) from dual;
select abs(-1+-10) from dual;
select abs(-10+(-100000)) from dual;
select abs(-100++50) from dual;
select abs(-0.1234+90) from dual;
select abs(1.2649+-0.12354) from dual;
--error 0,1064
select abs(-100+++50) from dual;

--echo parameter-2-1-2 减法
select abs(50-100) from dual;
select abs(-90- -60) from dual;
select abs(-60-50) from dual;
select abs(50-+20) from dual;
select abs(1.23564-+0.23654) from dual;
select abs(0.245464- -50) from dual; 
--error 0,1064
slect abs(-90--10) from dual;

--error 0,1064
select abs(-90-+-50) from dual;

select abs(-90+60-50+63-42+50-+54- -45+545-548+96321-0.02135+0.25145-1.2456-5800.3648865) from dual;

--echo parameter-2-1-3 乘法
select abs(10*10) from dual;
select abs(100*-1000) from dual;
select abs(-50*-90) from dual;
select abs(-1.56843*0.2564) from dual;
select abs(0*-956.23156) from dual;

--error 0,1064
select abs(-983.12**365) from dual;

--echo parameter-2-1-4 除法
select abs(100/63) from dual;
select abs(-2.6985/+9856.21) from dual;
select abs(562/-0.26498) from dual;

--error 0,1064
select abs(6//9) from dual;

select abs(-98+20.365*123/644- -24*562/-0.215) from dual;
--error 0,1064
select abs(10%2) from dual;

--echo parameter-2-2-1 函数结果
select abs(-1*count(1)) from dual;
select abs(-1/sum(10+10)) from dual;
select abs(-1.01234564123145647898)-98564521.2012548750012 from dual;
select abs(abs(-0.122456784646)*-2123.142467824562) from dual;
select abs(1-10) abs你好 from dual;
select abs(-100) as abs from dual;
select a-1 from (select abs(-0.123) a from dual) t1;

--echo parameter-2-2-2 拼接
select abs(-99)||45 from dual;
select abs(-65||123) from dual;
select abs(-10*10)||99 from dual;
select abs(-1*100||99) from dual;
select concat(abs(-10),99) from dual;
select abs(concat(-10,99)) from dual;

--error 0,1054
select abs(-0.12||abc) from dual;
--error 0,1054
select abs(-0.12)||abc from dual;
--error 0,1054
select concat(abs(-10),aa) from dual;


 
--echo   abs-3-1 TINYINT
--error 0, 1051
drop table abs_table ;
create table abs_table(a TINYINT(10));
insert into abs_table values('-128');
SELECT abs(t1.a) FROM abs_table t1;


