CREATE TABLE abs_table1(num INT,food char(20),price varchar(200));
INSERT INTO abs_table1 VALUES(1,'面包',-5.12315);
INSERT INTO abs_table1 VALUES(2,'牛奶','');
INSERT INTO abs_table1 VALUES(3,'大面包',-0.13545);
INSERT INTO abs_table1 VALUES(4,'奶牛奶',-1200);
INSERT INTO abs_table1 VALUES(5,'奶奶牛',NULL);
INSERT INTO abs_table1 VALUES(6,'牛奶奶',10);
INSERT INTO abs_table1 VALUES(7,'牛奶奶',-10);

CREATE TABLE abs_table2(num INT,name varchar(200),money varchar(200));
INSERT INTO abs_table2 VALUES(1,'Bing',-100);
INSERT INTO abs_table2 VALUES(2,'Bob',+10);
INSERT INTO abs_table2 VALUES(3,'Reachl',-0.23566000);
INSERT INTO abs_table2 VALUES(4,'Ross',NULL);
INSERT INTO abs_table2 VALUES(5,'friends','');



--echo abs-1
--echo abs-1-1
DELIMITER //;


#定义一个无参的函数
--error 0,1305
drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 INTO a;
	return a;
END;
//
SELECT  abs_func();//


#定义一个有参的函数
--error 0,1305
drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func(para varchar(200))
returns  varchar(200)
begin
	declare a varchar(200);
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para into a ;
	return a;
END ;
//

SELECT  abs_func(-0.23566000);//
SELECT  abs_func(0.23566000);//


--echo abs-1-1-2
#定义函数用while循环
--error 0,1305
drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func()
returns  varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into a ;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into b ;
	WHILE i <= 3 do
	INSERT INTO abs_table2 VALUES(1111,'friends',-10);
	set i := i + 1;
	END while;
	return a;
END ;
//
select count(*) from abs_table2;//
SELECT  abs_func()  FROM  dual;//
select count(*) from abs_table2;//

#定义函数用loop循环
--error 0,1305
drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func(para varchar(200),para1 varchar(200))
returns  varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para into a ;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para1 into b ;
	
	lp1 : loop
	set i := i + 1;
	INSERT INTO abs_table2 VALUES(2222,'friends',-10);
	if i > 3 then
	leave lp1;
	end if;
	end loop;
	return b;
END;
//

SELECT  abs_func(100,100)  FROM  dual;//
SELECT COUNT(*) FROM abs_table2;//





--echo abs-1-2
--echo abs-1-2-1
#无参的存储过程
--error 0,1305
drop procedure abs_pro;//
CREATE  PROCEDURE abs_pro()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into a ;
	WHILE i <= 3 do
	INSERT INTO abs_table2 VALUES(3333,'friends',-10);
	set i := i + 1;
	END while;
END ;
//

SELECT COUNT(*) FROM abs_table2;//
CALL abs_pro();//
SELECT COUNT(*) FROM abs_table2;//



#只有一个in参数的存储过程
--echo abs-1-2-2
--error 0,1305
drop procedure abs_pro;//
CREATE PROCEDURE abs_pro(in para  varchar(200))
begin
	declare i int;
	declare a varchar(200);
	declare b varchar(200);
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para into a ;
    set i := 1;
   	repeat
	INSERT INTO abs_table2 VALUES(4444,'friends',-10);
	set i := i+1;
	until i >= 3	
	end	 repeat;
END ;
//

SELECT COUNT(*) FROM abs_table2; //
CALL abs_pro(100); //
SELECT COUNT(*) FROM abs_table2;//




#包含out参数的存储过程
--echo abs-1-2-3
--error 0,1305
drop procedure abs_pro;//
CREATE  PROCEDURE abs_pro(out wb  varchar(200),OUT wb1  varchar(200))
begin
	declare i int;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb ;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb1 ;
   	set i :=  1; 
	while i <= 3 do
	INSERT INTO abs_table2 VALUES(5555,'friends',-10);
	set i := i + 1;
	end while;
END;
//

SELECT COUNT(*) FROM abs_table2;//
call abs_pro(@wb,@wb1);//
SELECT COUNT(*) FROM abs_table2;//



#包含in out参数的存储过程
--echo abs-1-2-4
--error 0,1305
drop procedure abs_pro;//
CREATE  PROCEDURE abs_pro( out wb varchar(200),inout  wb1 varchar(200))
begin
	declare i int;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb ;
	SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb1 ;
    set i := 1;
	WHILE i <= 3 do
	INSERT INTO abs_table2 VALUES(6666,'friends',-10);
	set i := i+1;
	END while;
END;
//


call abs_pro(@wb,@wb1);//
SELECT COUNT(*) FROM abs_table2;//
select * from abs_table2 order by num;//




DELIMITER ;//

