drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func()
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into a ;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into b ;
WHILE i <= 3 do
INSERT INTO abs_table2 VALUES(1111,'friends',-10);
set i := i + 1;
END while;
return a;
END ;
//
select count(*) from abs_table2;//
count(*)
5
SELECT  abs_func()  FROM  dual;//
abs_func()
100
select count(*) from abs_table2;//
count(*)
9
drop FUNCTION abs_func;//
CREATE  FUNCTION abs_func(para varchar(200),para1 varchar(200))
returns  varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para into a ;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = para1 into b ;
lp1 : loop
set i := i + 1;
INSERT INTO abs_table2 VALUES(2222,'friends',-10);
if i > 3 then
leave lp1;
end if;
end loop;
return b;
END;
//
SELECT  abs_func(100,100)  FROM  dual;//
abs_func(100,100)
100
