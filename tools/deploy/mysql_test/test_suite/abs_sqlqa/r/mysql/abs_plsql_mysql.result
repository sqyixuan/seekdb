CREATE  PROCEDURE abs_pro(out wb  varchar(200),OUT wb1  varchar(200))
begin
declare i int;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb ;
SELECT  ABS(money) FROM abs_table2 t2 WHERE ABS(money) = 100 into wb1 ;
set i :=  1; 
while i <= 3 do
INSERT INTO abs_table2 VALUES(5555,'friends',-10);
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM abs_table2;//
COUNT(*)
19
call abs_pro(@wb,@wb1);//
SELECT COUNT(*) FROM abs_table2;//
COUNT(*)
22
