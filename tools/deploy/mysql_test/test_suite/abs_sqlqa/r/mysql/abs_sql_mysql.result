abs-select-1
CREATE TABLE abs_table1(num INT,food char(20),price varchar(200));
INSERT INTO abs_table1 VALUES(1,'面包',-5.12315);
INSERT INTO abs_table1 VALUES(2,'牛奶','');
INSERT INTO abs_table1 VALUES(3,'大面包',-0.13545);
INSERT INTO abs_table1 VALUES(4,'奶牛奶',-1200);
INSERT INTO abs_table1 VALUES(5,'奶奶牛',NULL);
INSERT INTO abs_table1 VALUES(6,'牛奶奶',10);
INSERT INTO abs_table1 VALUES(7,'牛奶奶',-10);
CREATE TABLE abs_table2(num INT,name varchar(200),money varchar(200));
INSERT INTO abs_table2 VALUES(1,'Bing',-100);
INSERT INTO abs_table2 VALUES(2,'Bob',+10);
INSERT INTO abs_table2 VALUES(3,'Reachl',-0.23566000);
INSERT INTO abs_table2 VALUES(4,'Ross',NULL);
INSERT INTO abs_table2 VALUES(5,'friends','');
abs-select-1-1 where、join 
select SUM(abs(price)) FROM abs_table1 WHERE num = 1;
SUM(abs(price))
5.12315
select abs(price),abs(money),abs(price)+abs(money) from abs_table1 t1 left join abs_table2 t2 ON t1.num = t2.num;
