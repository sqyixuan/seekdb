abs-select-1-2 any、all、exists
SELECT * FROM abs_table1 WHERE abs(price) = ANY(SELECT price FROM abs_table1);
num	food	price
2	牛奶	
6	牛奶奶	10
7	牛奶奶	-10
SELECT * FROM abs_table1 WHERE abs(price) > ANY(SELECT price FROM abs_table1);
