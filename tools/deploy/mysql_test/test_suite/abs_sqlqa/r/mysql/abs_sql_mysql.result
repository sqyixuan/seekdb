abs-select-1-5 group by having
SELECT t1.num,SUM(ABS(money)+ABS(price)) FROM abs_table1 t1 
LEFT JOIN abs_table2 t2 
ON t1.num = t2.num 
GROUP BY t1.num;
num	SUM(ABS(money)+ABS(price))
1	105.12315
2	10
3	0.37111
4	NULL
5	NULL
6	NULL
7	NULL
SELECT t1.price FROM abs_table1 t1 
GROUP BY t1.price
HAVING ABS(t1.price) > 10 ;
price
-1200
