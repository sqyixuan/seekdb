abs-4-4 foreign key 外键约束 
drop table abs_table ;
CREATE TABLE ABS_TABLE1(a1 char(10) not null primary key);
insert into ABS_TABLE1 values('-10');
create table abs_table(a char(10) NOT NULL,FOREIGN KEY (a)  references ABS_TABLE1(a1));
insert into abs_table values('-10');
SELECT abs(t1.a) FROM abs_table t1;
abs(t1.a)
10
drop table abs_table ;
drop table ABS_TABLE1 ;
abs-4-6 default 约束 
drop table abs_table ;
create table abs_table(a CHAR(10) default '-10',b char(10));
insert into abs_table(b) values('-50.23');
SELECT abs(t1.a) FROM abs_table t1;
abs(t1.a)
10
drop table abs_table;
drop table ABS_TABLE1;
