# owner: lixia.yq
# owner group: storage
# tags: storage schema, security/virtual column
# descrpt: test create tablet with special schema

--echo # step1.准备数据
--disable_warnings
--error 0,1051
drop table tde_t1;
purge recyclebin;
--enable_warnings

connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
alter system set undo_retention = 0;
alter system set _mvcc_gc_using_min_txn_snapshot = 'FALSE';

# create table with virtual generated column
create table tde_t1 (c1 int, c2 int, c3 varchar(100), c4 varchar(10) generated always as (substring(c3, 2, 8)) virtual) ;
let $__freeze_table_name__ = "tde_t1";
connection sys_conn;
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name=$__freeze_table_name__, tenant_id, 1);
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name=$__freeze_table_name__, table_id, 1);
let $__tablet_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tablet_id from oceanbase.__all_virtual_table where table_name=$__freeze_table_name__, tablet_id, 1);

connection conn1;
let $_i_ = 0;
while ($_i_ < 100)
{
  eval insert into tde_t1(c1,c2,c3) values($_i_, $_i_, 'Hello OceanBase & Happy New Year');
  inc $_i_;
}

connection conn1;
--source mysql_test/include/minor_freeze_tablet_and_wait_done.inc

connection conn1;
while ($_i_ < 200)
{
  eval insert into tde_t1(c1,c2,c3) values($_i_, $_i_, 'Hello OceanBase & Happy New Year');
  inc $_i_;
}

connection conn1;
alter system major freeze;

--source mysql_test/include/check_merge_status.inc
--source mysql_test/include/wait_daily_merge.inc

# rollback settings
connection conn1;
alter system set undo_retention = 1800;
alter system set _mvcc_gc_using_min_txn_snapshot = 'TRUE';
