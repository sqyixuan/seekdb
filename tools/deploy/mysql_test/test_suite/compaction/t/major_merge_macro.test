# owner: chaser.ch
# group: storage
# desc: test major macro merge

--disable_warnings
drop table if exists test;
--enable_warnings
create table test (c1 int primary key, c2 varchar(2048)) row_format = REDUNDANT compression = 'none' pctfree = 0;
let $tablet_id = query_get_value(select tablet_id from oceanbase.__all_virtual_table where table_name = 'test', tablet_id, 1);
let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.__all_virtual_table where table_name = 'test', tenant_id, 1);
let $__table_id__ = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'test', table_id, 1);

--disable_query_log
--disable_result_log

--let $count=0
while ($count < 2500)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $major_reuse_micro = query_get_value(select MAX(multiplexed_micro_count_in_new_macro) as mb from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = $tablet_id and tenant_id = $__tenant_id__ and type = 'MAJOR_MERGE', mb, 1);
--echo "major reuse micro count", $major_reuse_micro

connection default;

while ($count < 2800)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection obsys;

let $major_reuse_micro = query_get_value(select MAX(multiplexed_micro_count_in_new_macro) as mb from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = $tablet_id and tenant_id = $__tenant_id__ and type = 'MAJOR_MERGE', mb, 1);
--echo "major reuse micro count", $major_reuse_micro
connection default;

while ($count < 3000)
{
  --let $stmt=INSERT INTO test VALUES($count, repeat($count,512))
  eval $stmt;
  inc $count;
}
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection obsys;

let $major_reuse_micro = query_get_value(select MAX(multiplexed_micro_count_in_new_macro) as mb from oceanbase.__all_virtual_tablet_compaction_history where tablet_id = $tablet_id and tenant_id = $__tenant_id__ and type = 'MAJOR_MERGE', mb, 1);
--echo "major reuse micro count", $major_reuse_micro
connection default;


disconnect obsys;

connection default;
drop table test;
