purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo ---------------------------------------------------------------------------------
--echo ######################## 标签：generator-1      2、随机函数  ######################
--echo ######################## 标签：distribution-1   3、分布函数  ######################
--echo ######################## 标签：table-function-3 PL/SQL场景   ######################
--echo ######## table-function-3-1 存储过程
--echo ###### 测试表
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
  id int,
  c1 double,
  c2 varchar(50),
  c3 double default 0,
  c4 double default 0,
  c5 double default 0);

INSERT INTO t1 VALUES(1,1,10,20,30,40);
INSERT INTO t1 VALUES(2,2,12,13,14,15);
INSERT INTO t1 VALUES(3,3,23,24,25,26);

--error 0,1051
DROP TABLE t2;
CREATE TABLE t2(
  id int,
  c1 int,
  c2 int);

--echo ###### 参数 - 无参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
begin
  declare a,b,c,d,e varchar(200);
  SELECT random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) into a,b,c,d,e FROM dual;
  INSERT INTO t1 VALUES(4,a,b,c,d,e);
END;
//
DELIMITER ;//

CALL pro1();
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ###### 参数 - 只有一个in参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1(in invalue varchar(200))
begin
  declare a,b,c,d,e varchar(200);
  SELECT random(invalue),randstr(5,invalue),normal(1,2,invalue),uniform(1,10,invalue),zipf(1,10,invalue) into a,b,c,d,e FROM dual;
  INSERT INTO t1 VALUES(5,a,b,c,d,e);
END;
//
DELIMITER ;//

CALL pro1(3);
SELECT * FROM t1 ORDER BY 1,2,3;

CALL pro1(random(1));
SELECT * FROM t1 ORDER BY 1,2,3;

CALL pro1(randstr(5,1));
SELECT * FROM t1 ORDER BY 1,2,3;

CALL pro1(normal(1,2,1));
SELECT * FROM t1 ORDER BY 1,2,3;

CALL pro1(uniform(1,10,1));
SELECT * FROM t1 ORDER BY 1,2,3;

CALL pro1(zipf(1,10,1));
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ###### 参数 - 包含out参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE  PROCEDURE pro1(out outa double,OUT outb varchar(200),OUT outc double,OUT outd double,OUT oute double)
begin
  SELECT random(1),randstr(5,2),normal(1,2,3),uniform(1,10,3),zipf(1,10,3) into outa,outb,outc,outd,oute FROM dual;
END;
//
DELIMITER ;//

CALL pro1(@outa,@outb,@outc,@outd,@oute);
SELECT @outa,@outb,@outc,@outd,@oute;


--echo ###### 参数 - 包含inout参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1(INOUT invar varchar(200),out outa double,OUT outb double,OUT outc double,OUT outd double)
begin
  declare invalue varchar(200);
  set invalue := invar;
  SELECT random(invalue),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) into outa,invar,outb,outc,outd FROM dual;
END;
//
DELIMITER ;//

SET @invar := random(1);
CALL pro1(@invar,@outa,@outb,@outc,@outd);
SELECT @invar,@outa,@outb,@outc,@outd;


--echo ###### dml语句 - 条件语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1(IN invalue varchar(200),IN ina int)
begin
  IF invalue = random(1) THEN 
    INSERT INTO t1 VALUES(6,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
  ELSE 
    INSERT INTO t1 VALUES(7,random(ina),randstr(5,ina),normal(1,2,ina),uniform(1,10,ina),zipf(1,10,ina));
  END IF;
END;
//
DELIMITER ;//

SET @invalue := random(1);
SET @ina := 1;
CALL pro1(@invalue,@ina);
SELECT * FROM t1 ORDER BY 1,2,3;

SET @invalue := random(2);
SET @ina := 2;
CALL pro1(@invalue,@ina);
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ###### dml语句 - 循环语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
begin
  declare i int default 8;
  WHILE i <= 10 do
    INSERT INTO t1 VALUES(i,random(i),randstr(5,i),normal(1,2,random(1)),uniform(1,10,i),zipf(1,10,i));
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO t1 VALUES(i,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
    SET i := i+1;
    IF i > 12 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO t1 VALUES(i,random(1),randstr(5,1),normal(1,2,1),uniform(1,10,1),zipf(1,10,1));
    SET i := i+1;
    until i > 14	
  END  REPEAT;
END;
//
DELIMITER ;//

CALL pro1();
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ###### 游标
DELIMITER //;
--error 0,1305
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
  declare a,b,c,d,e varchar(200);
  DECLARE done INT DEFAULT 0;
  DECLARE cur1 CURSOR FOR SELECT random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) from table(generator(5));
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  
  OPEN cur1;
  FETCH cur1 INTO a,b,c,d,e;
  WHILE done<>1 DO
    INSERT INTO t1 VALUES(15,a,b,c,d,e);
    FETCH cur1 INTO a,b,c,d,e;
  END WHILE;
  CLOSE cur1;
END;
//
DELIMITER ;//

CALL test_pro();
SELECT * FROM t1 where id = 15 ORDER BY 1,2,3;


--echo ###### 动态sql
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
BEGIN
  SET @s = 'INSERT INTO t1 VALUES(?,random(?),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));';
  PREPARE stmsha_table1 FROM @s;
  SET @a = 16;
  SET @b = 2;
  EXECUTE stmsha_table1 USING @a,@b;

  SET @s = 'SELECT * FROM t1 WHERE c1 = ?';
  PREPARE stmt2 FROM @s;
  SET @a = random(2);
  EXECUTE stmt2 USING @a; 
END;
//
DELIMITER ;//

CALL pro1();
SELECT * FROM t1 ORDER BY 1,2,3;


DELIMITER //;
--error 0,1305
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
BEGIN
  SET @s = 'UPDATE t1 SET c1 = ? WHERE c5 = zipf(1,10,1);';
  PREPARE stmsha_table1 FROM @s;
  SET @a = random(NULL);
  EXECUTE stmsha_table1 USING @a;

  SET @s = 'SELECT * FROM t1 WHERE c5 = ?;';
  PREPARE stmt2 FROM @s;
  SET @a = zipf(1,10,1);
  EXECUTE stmt2 USING @a; 
  
  SET @s = 'DELETE FROM t1 WHERE c4 = ?;';
  PREPARE stmsha_table1 FROM @s;
  SET @a = uniform(1,10,8);
  EXECUTE stmsha_table1 USING @a;

  SET @s = 'SELECT * FROM t1 WHERE c4 = ?;';
  PREPARE stmt2 FROM @s;
  SET @a = uniform(1,10,8);
  EXECUTE stmt2 USING @a; 
END;
//
DELIMITER ;//

CALL pro1();


--echo ######## table-function-3-2 自定义函数
--echo ###### 参数 - 无参的函数
DELIMITER //;
--error 0,1305
drop function fun1;//
CREATE FUNCTION fun1() returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  SELECT random(c1) into a FROM t1 WHERE id = 1;
  SELECT randstr(5,c2),normal(1,2,c3),uniform(1,10,c4),zipf(1,10,c5) into @b,@c,@d,@e FROM t1 WHERE id = 1;
  return a;
END;
//
DELIMITER ;//

SELECT fun1();
SELECT @b,@c,@d,@e;


--echo ###### 参数 - 有参的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION fun1;//
CREATE FUNCTION fun1(invalue varchar(200)) returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  SELECT random(invalue),randstr(5,invalue),normal(1,2,invalue),uniform(1,10,invalue),zipf(1,10,invalue) into a,@b,@c,@d,@e FROM t1 WHERE id = 1;
  return a;
END ;
//
DELIMITER ;//

SELECT fun1(22);
SELECT @b,@c,@d,@e;

SELECT fun1(random(1));
SELECT @b,@c,@d,@e;


--echo ###### dml语句 - 条件语句
DELIMITER //;
--error 0,1305
DROP FUNCTION fun1;//
CREATE FUNCTION fun1(invalue varchar(200),ina int) returns varchar(200) READS SQL DATA 
begin
  IF invalue = random(1) THEN 
    INSERT INTO t1 VALUES(20,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
  ELSE 
    INSERT INTO t1 VALUES(21,random(ina),randstr(5,ina),normal(1,2,ina),uniform(1,10,ina),zipf(1,10,ina));
  END IF;
  return 'dml语句 - 条件语句';
END;
//
DELIMITER ;//

SET @invalue := random(1);
SET @ina := 1;
SELECT fun1(@invalue,@ina);
SELECT * FROM t1 ORDER BY 1,2,3;

SET @invalue := random(2);
SET @ina := 2;
SELECT fun1(@invalue,@ina);
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ###### dml语句 - 循环语句
DELIMITER //;
--error 0,1305
DROP FUNCTION fun1;//
CREATE FUNCTION fun1() returns varchar(200) READS SQL DATA 
begin
  declare i int default 22;
  WHILE i <= 23 do
    INSERT INTO t1 VALUES(i,random(i),randstr(5,i),normal(1,2,random(1)),uniform(1,10,i),zipf(1,10,i));
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO t1 VALUES(i,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
    SET i := i+1;
    IF i > 25 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO t1 VALUES(i,random(1),randstr(5,1),normal(1,2,1),uniform(1,10,1),zipf(1,10,1));
    SET i := i+1;
    until i > 27	
  END  REPEAT;
  return 'dml语句 - 循环语句';
END;
//
DELIMITER ;//

SELECT fun1();
SELECT * FROM t1 ORDER BY 1,2,3;


--echo ### 标签：table-function-3-3 触发器
DELIMITER //;
--error 0,1360
DROP TRIGGER tri1;//
CREATE TRIGGER tri1 BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	DECLARE a int default 30;
	DECLARE b int default 10;

	loop1: LOOP
	  if a < 35 then
	    INSERT INTO t1 VALUES(a,random(a),randstr(5,b),normal(1,2,b),uniform(1,10,b),zipf(1,10,b));
	  elseif a = 36 then
	    UPDATE t1 set c1 = zipf(1,10,null) WHERE id >= 32;
	    LEAVE loop1;
	  else
	    delete FROM t1 WHERE id = 31;	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//
DELIMITER ;//

INSERT INTO t2 VALUES(1,uniform(1,10,random(1)),zipf(1,10,random(1)));
SELECT * FROM t1 ORDER BY 1,2,3;


