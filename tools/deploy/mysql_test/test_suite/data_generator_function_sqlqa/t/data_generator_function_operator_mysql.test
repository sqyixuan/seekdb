# owner: @dachuan.sdc
# owner group: sql-执行器
# description: mysql模式 随机/分布函数 - 运算符，函数间嵌套
# tags: sql
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo ---------------------------------------------------------------------------------
--echo ######################## 标签：generator-1      2、随机函数  ######################
--echo ######################## 标签：distribution-1   3、分布函数  ######################
--echo ######################## 标签：table-function-4 运算符       ######################
--echo ######## table-function-4-1 算术运算符 
SELECT random(9+8-1*2/3),random(5 DIV 2),random(5 MOD 2) FROM TABLE(GENERATOR(5));
SELECT randstr(9+8-1*2/3,9+8-1*2/3) FROM TABLE(GENERATOR(5));
SELECT normal(9+8-1*2/3,9+8-1*2/3,9+8-1*2/3) FROM TABLE(GENERATOR(5));
SELECT uniform(9+8-1*2/3,9+8-1*2/3,9+8-1*2/3) FROM TABLE(GENERATOR(5));
SELECT zipf(9+8-1*2/3,9+8-1*2/3,9+8-1*2/3) FROM TABLE(GENERATOR(5));

SELECT random(1/0) FROM TABLE(GENERATOR(5));
SELECT randstr(1/0,1/0) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(1/0,1/0,1/0) FROM TABLE(GENERATOR(5));
--error 1210
SELECT uniform(1/0,1/0,1/0) FROM TABLE(GENERATOR(5));
--error 1210
SELECT zipf(1/0,1/0,1/0) FROM TABLE(GENERATOR(5));

SELECT random(1)/random(1),random(1) DIV random(1) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1))+randstr(5,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,random(1))*normal(1,2,3) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,random(1))/uniform(1,10,3) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,random(1)) MOD zipf(1,10,3) FROM TABLE(GENERATOR(5));


--echo ######## table-function-4-2 逻辑运算符  
SELECT random(2 and 1) FROM TABLE(GENERATOR(5));
SELECT randstr(1 or 0,1 xor 2) FROM TABLE(GENERATOR(5));
SELECT normal(not 0,1 and 1,1 and 0) FROM TABLE(GENERATOR(5));
SELECT uniform(1 xor 1,1 or 1,1 or 1) FROM TABLE(GENERATOR(5));
SELECT zipf(1 or 0,1 or 2,1 xor 2) FROM TABLE(GENERATOR(5));

SELECT random(1) and random(1) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) or randstr(5,1) FROM TABLE(GENERATOR(5));
SELECT not normal(1,2,random(1)) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,random(1)) xor uniform(1,10,3) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,random(1)) and zipf(1,10,3) FROM TABLE(GENERATOR(5));


--echo ######## table-function-4-3 位运算符 
SELECT random(2 & 1) FROM TABLE(GENERATOR(5));
SELECT randstr(1 | 0,1 ^ 2) FROM TABLE(GENERATOR(5));
SELECT normal(! 0,1 << 1,1 << 0) FROM TABLE(GENERATOR(5));
SELECT uniform(1 ^ 1,1 >> 1,1 >> 1) FROM TABLE(GENERATOR(5));
SELECT zipf(1 << 0,1 << 2,1 & 2) FROM TABLE(GENERATOR(5));

SELECT random(1) & random(1) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) | randstr(5,1) FROM TABLE(GENERATOR(5));
SELECT ! normal(1,2,random(1)) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,random(1)) >> uniform(1,10,3) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,random(1)) << zipf(1,10,3) FROM TABLE(GENERATOR(5));


--echo ######## table-function-4-4 比较运算符 
SELECT random(2 = 1) FROM TABLE(GENERATOR(5));
SELECT randstr(1 > 0,1 < 2) FROM TABLE(GENERATOR(5));
SELECT normal(1,1 >= 1,1 <= 0) FROM TABLE(GENERATOR(5));
SELECT uniform(1 != 1,1 <> 1,1 = 1) FROM TABLE(GENERATOR(5));
SELECT zipf(1 <=> 1,1 < 2,1 < 2) FROM TABLE(GENERATOR(5));

SELECT random(1) > random(1) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) = randstr(5,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,random(1)) != normal(1,2,random(1)) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,random(1)) >= uniform(1,10,3) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,random(1)) <= zipf(1,10,3) FROM TABLE(GENERATOR(5));

SELECT random(1) in (random(1),random(1),random(2)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) LIKE '%A%' FROM TABLE(GENERATOR(5));
SELECT normal(1,2,random(1)) is null FROM TABLE(GENERATOR(5));
SELECT uniform(1,2,random(1)) between 1 and 10 FROM TABLE(GENERATOR(5));
SELECT zipf(1,2,random(1)) is not null FROM TABLE(GENERATOR(5));


