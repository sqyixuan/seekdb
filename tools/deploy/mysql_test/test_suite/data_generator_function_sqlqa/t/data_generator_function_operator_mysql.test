--echo ######## table-function-5-3 多级函数嵌套 
SELECT random(random(random(random(-1)))) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(random(random(random(-1))))) FROM TABLE(GENERATOR(5));
SELECT normal(1,10,random(random(random(random(-1))))) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,random(random(random(random(-1))))) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,random(random(random(random(-1))))) FROM TABLE(GENERATOR(5));

SELECT random(random(random(random(random(random(random(random(random(1))))))))) FROM TABLE(GENERATOR(5));
SELECT randstr(5,randstr(5,randstr(5,randstr(5,randstr(5,randstr(5,random(1))))))) FROM TABLE(GENERATOR(5));
SELECT normal(1,10,normal(1,10,normal(1,10,normal(1,10,normal(1,10,random(1)))))) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,uniform(1,10,uniform(1,10,uniform(1,10,uniform(1,10,random(1)))))) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,zipf(1,10,zipf(1,10,zipf(1,10,zipf(1,10,zipf(1,10,random(1))))))) FROM TABLE(GENERATOR(5));

SELECT random(abs(floor(ceil(round(abs(abs(abs(-1)))))))) FROM TABLE(GENERATOR(5));
SELECT randstr(abs(floor(ceil(round(abs(abs(abs(-1))))))),random(1)) FROM TABLE(GENERATOR(5));
SELECT normal(1,10,abs(floor(ceil(round(abs(abs(abs(-1)))))))) FROM TABLE(GENERATOR(5));
SELECT uniform(1,10,abs(floor(ceil(round(abs(abs(abs(-1)))))))) FROM TABLE(GENERATOR(5));
SELECT zipf(1,10,abs(floor(ceil(round(abs(abs(abs(-1)))))))) FROM TABLE(GENERATOR(5));


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
