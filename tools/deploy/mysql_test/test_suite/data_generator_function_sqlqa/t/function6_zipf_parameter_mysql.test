--error 1210
SELECT zipf('good',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf('好',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf('良い',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf('abc123',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

SELECT count(*),zipf('123abc',123,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;

SELECT count(*),zipf(date'1-1-1',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(date'50-1-1',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(date'60-1-1',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(date'70-12-12',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(date'100-1-1',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(date'1000-1-1',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
