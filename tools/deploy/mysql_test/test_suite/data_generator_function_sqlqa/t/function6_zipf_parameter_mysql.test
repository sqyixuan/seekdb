delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 内置函数
SELECT count(*),zipf(1,abs(-10),random(1)) v FROM TABLE(GENERATOR(100)) order by 1,2;
SELECT count(*),zipf(1,floor(3.54),random(1)) v FROM TABLE(GENERATOR(100)) order by 1,2;
