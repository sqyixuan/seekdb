# owner: dachuan.sdc
# owner group: sql-执行器
# description: mysql模式 分布函数 - ③ ZIPF( <s> , <N> , <gen> ) 
# tags: sql
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo --------------------------------------------------------------------------
--echo ######################## 标签：distribution-1 2、分布函数  ########################
--echo ######## distribution-1-3 ③ ZIPF( <s> , <N> , <gen> ) 
--echo ###### distribution-1-3-1 参数个数
--echo ### distribution-1-3-1-1 0个
--error 1582
SELECT zipf() v FROM TABLE(GENERATOR(100)) group by v order by 1;

--echo ###### distribution-1-3-1-2 1个
--error 1582
SELECT zipf(-1) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(0) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(1) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(1.5) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf('abc') v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(null) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(rand(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;


--echo ###### distribution-1-3-1-3 2个
--error 1582
SELECT zipf(1,2) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1582
SELECT zipf(1.1,1.2) v FROM TABLE(GENERATOR(100)) group by v order by 1;


--echo ###### distribution-1-3-1-4 3个
--echo #### s-参数值(特征指数) - 常量
--echo ## 数值
--error 1210
SELECT zipf(-10,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf(0,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

select count(*),zipf(1,10,random(1)) v from table(generator(10000)) group by v order by 1,2;
select count(*),zipf(5,10,random(1)) v from table(generator(10000)) group by v order by 1,2;
select count(*),zipf(1.7976931348623157E+308,1000,random(1)) v from table(generator(10000)) group by v order by 1,2;

--error 1367
SELECT zipf(1.7976931348623157E+309,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

select count(*),zipf('1',10,random(1)) v from table(generator(10000)) group by v order by 1,2;
select count(*),zipf("1",10,random(1)) v from table(generator(10000)) group by v order by 1,2;

--error 1054
SELECT zipf(５,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1054
SELECT zipf(－５,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

SELECT count(*),zipf(3.1415,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(10.01,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(10.15,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(10.55,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(1.0E+2,2000,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(3.5E+2,2000,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;

SELECT count(*),zipf(TRUE,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT count(*),zipf(FALSE,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

SELECT count(*),zipf(100+2-30*2/3,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(1+20-30*2/3,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(!5|2&2|3^2,20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(4>=2,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(-1<=1,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(2<<2,10,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(24>>2,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;

--echo ## 非数值
--error 1210
SELECT zipf(NULL,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf('',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf(' ',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf('!@#$%^&*',2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
