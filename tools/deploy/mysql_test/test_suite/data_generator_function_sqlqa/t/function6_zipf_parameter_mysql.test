--echo #### gen-参数值（数值生成函数） - 常量/随机函数以外场景
--echo ## 变量
delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT zipf(1,2,inval) into @res1 FROM TABLE(GENERATOR(1));
  SELECT zipf(1,2,var) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 内置函数
SELECT count(*),zipf(1,2,abs(-10)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(1,2,floor(3.54)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(1,2,ceil(3.54)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;

SELECT count(*),zipf(1,2,avg(-10)) v FROM TABLE(GENERATOR(100)) order by 1,2;
SELECT count(*),zipf(1,2,count(3.54)) v FROM TABLE(GENERATOR(100)) order by 1,2;
SELECT count(*),zipf(1,2,min(3.54)) v FROM TABLE(GENERATOR(100)) order by 1,2;
SELECT count(*),zipf(1,2,max(3.54)) v FROM TABLE(GENERATOR(100)) order by 1,2;

