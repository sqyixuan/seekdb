delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT zipf(1,inval,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT zipf(1,var,3) into @res2 FROM TABLE(GENERATOR(1));
end;
