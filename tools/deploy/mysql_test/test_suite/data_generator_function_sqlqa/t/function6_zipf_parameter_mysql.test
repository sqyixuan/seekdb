--echo #### s-参数值(特征指数) - 常量以外场景
--echo ## 变量
delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 2; 
  SELECT zipf(inval,10,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT zipf(var,10,3) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(1);
select @res1,@res2 from dual;

--echo ## 内置函数
SELECT count(*),zipf(abs(-1),10,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(floor(3.54),20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;
SELECT count(*),zipf(ceil(3.54),20,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1,2;

--error 1210
SELECT zipf(avg(-10),20,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT zipf(count(3.54),20,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT zipf(min(3.54),20,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT zipf(max(3.54),20,3) FROM TABLE(GENERATOR(5));

--echo ## 表列字段
--error 0,1051
drop table t1;
create table t1 (a int);
insert into t1 values(1);

--error 1210
SELECT zipf(t1.a,20,random(1)) FROM t1;
--error 1210
SELECT zipf(t1.a,20,random(1)) FROM TABLE(GENERATOR(5)) g,t1;

--echo ## 随机函数
--error 1210
SELECT zipf(rand(1),2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf(random(1),2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf(rand(123),2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
--error 1210
SELECT zipf(random(1),2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;

