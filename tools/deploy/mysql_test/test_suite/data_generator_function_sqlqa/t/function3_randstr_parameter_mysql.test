--echo #### gen-参数值 - 随机函数
SELECT randstr(5,rand(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,rand(123)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(123)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,randstr(1,1)) FROM TABLE(GENERATOR(5));


--echo #### gen-参数值 - 分布函数
SELECT randstr(5,zipf(1,5,random(1))) FROM TABLE(GENERATOR(5));
SELECT randstr(5,normal(0,1,random(1))) FROM TABLE(GENERATOR(5));
SELECT randstr(5,uniform(0,10,random(1))) FROM TABLE(GENERATOR(5));


--echo #### gen-参数值 - 常量/随机分布函数以外场景
--echo ## 变量
delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT randstr(5,inval) into @res1 FROM TABLE(GENERATOR(1));
  SELECT randstr(5,var) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 表列字段
--error 0,1051
drop table t1;
create table t1 (a int);
insert into t1 values(10);

SELECT randstr(5,t1.a) FROM t1;
SELECT randstr(5,t1.a) FROM TABLE(GENERATOR(5)) g,t1;

--echo ## 内置函数
SELECT randstr(5,abs(-10)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,floor(3.54)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,ceil(3.54)) FROM TABLE(GENERATOR(5));

--echo ## 自定义函数
delimiter //;
--error 0,1305
drop function f0;//
create function f0() returns int
begin
  return 10;
end;
//
delimiter ;//

SELECT randstr(5,f0) FROM TABLE(GENERATOR(5));

--echo ## 用户自定义变量
set @userval=9;
SELECT randstr(5,@userval) FROM TABLE(GENERATOR(5));

--echo ## sql语句
SELECT randstr(5,(select 8 from dual)) FROM TABLE(GENERATOR(5));


