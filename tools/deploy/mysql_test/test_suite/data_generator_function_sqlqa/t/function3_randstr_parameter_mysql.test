purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo --------------------------------------------------------------------------
--echo ######################## 标签：random-1 2、随机函数  ########################
--echo ######## random-1-2  ② RANDSTR(N, gen)
--echo ###### random-1-2-1 参数个数
--echo ### random-1-2-1-1 0个
--error 1582
SELECT randstr() FROM TABLE(GENERATOR(5));

--echo ###### random-1-2-1-2 1个
--error 1582
SELECT randstr(-1) FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr(0) FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr(1) FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr(1.5) FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr('abc') FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr(rand(1)) FROM TABLE(GENERATOR(5));
--error 1582
SELECT randstr(random(1)) FROM TABLE(GENERATOR(5));


--echo ###### random-1-2-1-3 2个
--echo #### N-参数值（随机字符串长度） - 常量
--echo ## 数值
SELECT randstr(-10,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(0,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(10,random(1)) FROM TABLE(GENERATOR(5));
SELECT length(randstr(4194304,5)) FROM TABLE(GENERATOR(1));

--disable_warnings
SELECT randstr(4194305,5) FROM TABLE(GENERATOR(1));
--enable_warnings

SELECT randstr('-1',random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr('1',random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr("-10",random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr("10",random(1)) FROM TABLE(GENERATOR(5));

--error 1054
SELECT randstr(－５,random(1)) FROM TABLE(GENERATOR(5));
--error 1054
SELECT randstr(５,random(1)) FROM TABLE(GENERATOR(5));

SELECT randstr(3.1415,5) FROM TABLE(GENERATOR(5));
SELECT randstr(10.01,5) FROM TABLE(GENERATOR(5));
SELECT randstr(10.15,5) FROM TABLE(GENERATOR(5));
SELECT randstr(10.55,5) FROM TABLE(GENERATOR(5));
SELECT randstr(1.0E+2,5) FROM TABLE(GENERATOR(5));
SELECT randstr(3.5E+2,5) FROM TABLE(GENERATOR(5));

SELECT randstr(TRUE,5) FROM TABLE(GENERATOR(5));
SELECT randstr(FALSE,5) FROM TABLE(GENERATOR(5));

SELECT randstr(1+2-30*2/3,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(1+20-30*2/3,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(!5|2&2|3^2,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(4>=2,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(4<=2,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(2<<2,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(2>>2,random(1)) FROM TABLE(GENERATOR(5));

--echo ## 非数值
SELECT randstr(NULL,5) FROM TABLE(GENERATOR(5));
SELECT randstr('',5) FROM TABLE(GENERATOR(5));
SELECT randstr(' ',5) FROM TABLE(GENERATOR(5));
SELECT randstr('good',5) FROM TABLE(GENERATOR(5));
SELECT randstr('好',5) FROM TABLE(GENERATOR(5));
SELECT randstr('良い',5) FROM TABLE(GENERATOR(5));
SELECT randstr('abc123',5) FROM TABLE(GENERATOR(5));
SELECT randstr('123abc',5) FROM TABLE(GENERATOR(5));
SELECT randstr('!@#$%^&*',5) FROM TABLE(GENERATOR(5));
SELECT randstr('\n',5) FROM TABLE(GENERATOR(5));
SELECT randstr('\r',5) FROM TABLE(GENERATOR(5));
SELECT randstr('\t',5) FROM TABLE(GENERATOR(5));

--disable_warnings
SELECT randstr(date'1678-1-1',5) FROM TABLE(GENERATOR(1));
SELECT length(randstr(date'1677-12-12',5)) FROM TABLE(GENERATOR(1));
SELECT length(randstr(date'100-1-1',5)) FROM TABLE(GENERATOR(5));
SELECT length(randstr(date'1000-1-1',5)) FROM TABLE(GENERATOR(5));
SELECT length(randstr(timestamp'1000-01-01 00:00:00',5)) FROM TABLE(GENERATOR(5));
--enable_warnings

SELECT randstr('100',5) FROM TABLE(GENERATOR(5));
SELECT randstr(time'00:00:10',5) FROM TABLE(GENERATOR(5));
--error 4013


--echo #### N-参数值 - 常量以外场景
--echo ## 变量
delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT randstr(inval,5) into @res1 FROM TABLE(GENERATOR(1));
  SELECT randstr(var,5) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 表列字段
--error 0,1051
drop table t1;
create table t1 (a int);
insert into t1 values(10);

SELECT randstr(t1.a,5) FROM t1;
SELECT randstr(t1.a,5) FROM TABLE(GENERATOR(5)) g,t1;

--echo ## 内置函数
SELECT randstr(abs(-10),5) FROM TABLE(GENERATOR(5));
SELECT randstr(floor(3.54),5) FROM TABLE(GENERATOR(5));
SELECT randstr(ceil(3.54),5) FROM TABLE(GENERATOR(5));

--echo ## 随机函数
SELECT randstr(rand(1),5) FROM TABLE(GENERATOR(5));
SELECT randstr(rand(123),5) FROM TABLE(GENERATOR(5));
SELECT randstr(random(1),5) FROM TABLE(GENERATOR(5));
SELECT randstr(random(123),5) FROM TABLE(GENERATOR(5));

--echo ## 自定义函数
delimiter //;
--error 0,1305
drop function f0;//
create function f0() returns int
begin
  return 10;
end;
//
delimiter ;//

SELECT randstr(f0,4) FROM TABLE(GENERATOR(5));

--echo ## 用户自定义变量
set @userval=9;
SELECT randstr(@userval,4) FROM TABLE(GENERATOR(5));

--echo ## sql语句
SELECT randstr((select 8 from dual),4) FROM TABLE(GENERATOR(5));


