--echo ## 非数值
SELECT randstr(5,NULL) FROM TABLE(GENERATOR(5));
SELECT randstr(5,'') FROM TABLE(GENERATOR(5));
SELECT randstr(5,' ') FROM TABLE(GENERATOR(5));
SELECT randstr(5,'good') FROM TABLE(GENERATOR(5));
