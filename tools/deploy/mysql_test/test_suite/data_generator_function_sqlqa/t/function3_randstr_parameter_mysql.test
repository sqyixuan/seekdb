--echo ######## random-1-2-2  功能点测试
--echo ###### 生成长度为N的随机字符串
SELECT randstr(10,10) FROM TABLE(GENERATOR(5));
SELECT randstr(10,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(10,random(1)) FROM TABLE(GENERATOR(5));


--echo ###### 验证 N 取不同值时对输出结果影响
SELECT randstr(1,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(2,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(3,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(4,random(1)) FROM TABLE(GENERATOR(5));
SELECT randstr(5,random(1)) FROM TABLE(GENERATOR(5));


--echo ###### 验证 gen 取相同/不同常量时对输出结果影响
SELECT randstr(10,1) FROM TABLE(GENERATOR(5));
SELECT randstr(10,2) FROM TABLE(GENERATOR(5));
SELECT randstr(10,3) FROM TABLE(GENERATOR(5));
SELECT randstr(10,4) FROM TABLE(GENERATOR(5));
SELECT randstr(10,5) FROM TABLE(GENERATOR(5));

SELECT randstr(1,5) FROM TABLE(GENERATOR(5));
SELECT randstr(2,5) FROM TABLE(GENERATOR(5));
SELECT randstr(3,5) FROM TABLE(GENERATOR(5));
SELECT randstr(4,5) FROM TABLE(GENERATOR(5));
SELECT randstr(5,5) FROM TABLE(GENERATOR(5));


