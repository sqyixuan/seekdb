--echo ######## 字符串类型
--error 0,1051
DROP TABLE char_table1;
CREATE TABLE char_table1( 
  id int,
  c1 CHAR(100), 
  c2 VARCHAR(100), 
  c3 BINARY(100),
  c4 VARBINARY(100), 
  c5 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c6 SET('a', 'b', 'c', 'd', 'e')
);

insert into char_table1 values(1,0,0,0,0,1,1);
insert into char_table1 values(2,null,null,null,null,null,null);
insert into char_table1 values(3,'char-类型','VARCHAR-类型','BINARY-类型','VARBINARY-类型','星期一','a,b,c');

SELECT id,c1,randstr(c1,random(1)) FROM TABLE(GENERATOR(3)),char_table1 order by 1;
SELECT id,c2,randstr(c2,random(1)) FROM TABLE(GENERATOR(3)),char_table1 order by 1;
SELECT id,c3,randstr(c3,random(1)) FROM TABLE(GENERATOR(3)),char_table1 order by 1;
