SELECT randstr(5,1.0E+309) FROM TABLE(GENERATOR(5));

SELECT randstr(5,'-1') FROM TABLE(GENERATOR(5));
SELECT randstr(5,'1') FROM TABLE(GENERATOR(5));
SELECT randstr(5,"-10") FROM TABLE(GENERATOR(5));
SELECT randstr(5,"10") FROM TABLE(GENERATOR(5));

--error 1054
SELECT randstr(5,－５) FROM TABLE(GENERATOR(5));
--error 1054
SELECT randstr(5,５) FROM TABLE(GENERATOR(5));

