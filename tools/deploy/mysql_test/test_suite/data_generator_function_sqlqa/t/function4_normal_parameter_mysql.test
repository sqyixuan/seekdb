DROP TABLE date_table1;
CREATE TABLE date_table1( 
  id int,
  c1 date, 
  c2 time, 
  c3 year, 
  c4 datetime, 
  c5 timestamp
);

insert into date_table1 values(1,0,0,0,0,0);
insert into date_table1 values(2,null,null,null,null,null);
insert into date_table1 values(3,'9999-12-31','23:59:59.99999999','2022','2022-12-31 23:59:59.999999','2022-01-01 03:26:07.999999');

SELECT id,c1,normal(1,2,c1) FROM TABLE(GENERATOR(3)),date_table1 order by 1;
SELECT id,c2,normal(1,2,c2) FROM TABLE(GENERATOR(3)),date_table1 order by 1;
SELECT id,c3,normal(1,2,c3) FROM TABLE(GENERATOR(3)),date_table1 order by 1;
SELECT id,c4,normal(1,2,c4) FROM TABLE(GENERATOR(3)),date_table1 order by 1;
SELECT id,c5,normal(1,2,c5) FROM TABLE(GENERATOR(3)),date_table1 order by 1;


