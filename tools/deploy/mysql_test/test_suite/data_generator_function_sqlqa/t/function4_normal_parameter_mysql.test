purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo --------------------------------------------------------------------------
--echo ######################## 标签：distribution-1 2、分布函数  ########################
--echo ######## distribution-1-1 ① NORMAL(<mean> , <stddev> , <gen>)
--echo ###### distribution-1-1-1 参数个数
--echo ### distribution-1-1-1-1 0个
--error 1582
SELECT normal() FROM TABLE(GENERATOR(5));

--echo ###### distribution-1-1-1-2 1个
--error 1582
SELECT normal(-1) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(0) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(1) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(1.5) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal('abc') FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(null) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(rand(1)) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(random(1)) FROM TABLE(GENERATOR(5));


--echo ###### distribution-1-1-1-3 2个
--error 1582
SELECT normal(1,2) FROM TABLE(GENERATOR(5));
--error 1582
SELECT normal(1.1,1.2) FROM TABLE(GENERATOR(5));


--echo ###### distribution-1-1-1-4 3个
--echo #### mean-参数值（均值） - 常量
--echo ## 数值
SELECT normal(-10,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(0,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(10,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(1.7976931348623157E+308,2,3) FROM TABLE(GENERATOR(5));
--error 1367
SELECT normal(1.7976931348623157E+309,2,3) FROM TABLE(GENERATOR(5));

SELECT normal('-1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal("-10",2,3) FROM TABLE(GENERATOR(5));
SELECT normal("10",2,3) FROM TABLE(GENERATOR(5));

--error 1054
SELECT normal(５,2,3) FROM TABLE(GENERATOR(5));
--error 1054
SELECT normal(－５,2,3) FROM TABLE(GENERATOR(5));

SELECT normal(3.1415,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(10.01,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(10.15,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(10.55,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(1.0E+2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(3.5E+2,2,3) FROM TABLE(GENERATOR(5));

SELECT normal(TRUE,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(FALSE,2,3) FROM TABLE(GENERATOR(5));

SELECT normal(1+2-30*2/3,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(1+20-30*2/3,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(!5|2&2|3^2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(4>=2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(4<=2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(2<<2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(2>>2,2,3) FROM TABLE(GENERATOR(5));

--echo ## 非数值
--error 1210
SELECT normal(NULL,2,3) FROM TABLE(GENERATOR(5));

SELECT normal('',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(' ',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('good',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('好',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('良い',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('abc123',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('123abc',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('!@#$%^&*',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('\n',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('\r',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('\t',2,3) FROM TABLE(GENERATOR(5));


SELECT normal(date'1-1-1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(date'50-1-1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(date'60-1-1',2,3) FROM TABLE(GENERATOR(1));
SELECT normal(date'70-12-12',2,3) FROM TABLE(GENERATOR(1));
SELECT normal(date'100-1-1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(date'1000-1-1',2,3) FROM TABLE(GENERATOR(5));
SELECT normal('100',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(time'00:00:10',2,3) FROM TABLE(GENERATOR(5));
SELECT normal(timestamp'1000-01-01 00:00:00',2,3) FROM TABLE(GENERATOR(5));


--echo #### mean-参数值 - 常量以外场景
-- echo # bug: 
--echo ## 变量
delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT normal(inval,2,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT normal(var,2,3) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 表列字段
--error 0,1051
drop table t1;
create table t1 (a int);
insert into t1 values(10);

--error 1210
SELECT normal(t1.a,2,3) FROM t1;
--error 1210
SELECT normal(t1.a,2,3) FROM TABLE(GENERATOR(5)) g,t1;

--echo ## 内置函数
SELECT normal(abs(-10),2,3) FROM TABLE(GENERATOR(5));
SELECT normal(floor(3.54),2,3) FROM TABLE(GENERATOR(5));
SELECT normal(ceil(3.54),2,3) FROM TABLE(GENERATOR(5));

--error 1210
SELECT normal(avg(10),2,random(1)) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(count(10),2,random(1)) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(min(10),2,random(1)) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(max(10),2,random(1)) FROM TABLE(GENERATOR(5));

--echo ## 随机函数
--error 1210
SELECT normal(rand(1),2,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(random(1),2,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(rand(123),2,3) FROM TABLE(GENERATOR(5));
--error 1210
SELECT normal(random(1),2,3) FROM TABLE(GENERATOR(5));

--echo ## 自定义函数
delimiter //;
--error 0,1305
drop function f0;//
create function f0() returns int
begin
  return 10;
end;
//
delimiter ;//

--error 1210
SELECT normal(f0,2,3) FROM TABLE(GENERATOR(5));

--echo ## 用户自定义变量
set @userval=9;
SELECT normal(@userval,2,3) FROM TABLE(GENERATOR(5));

--echo ## sql语句
SELECT normal((select 8 from dual),2,3) FROM TABLE(GENERATOR(5));


