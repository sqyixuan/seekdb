--echo ###### distribution-1-1-2 功能点测试    
--echo ### 验证结果是否符合正态分布的浮点数
SELECT normal(1,10,random(1)) FROM TABLE(GENERATOR(30));


--echo ### 验证 mean/stddev 取不同值时对输出结果影响
SELECT normal(1,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(2,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(3,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(4,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(5,2,3) FROM TABLE(GENERATOR(5));

SELECT normal(1,1,3) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(1,3,3) FROM TABLE(GENERATOR(5));
SELECT normal(1,4,3) FROM TABLE(GENERATOR(5));
SELECT normal(1,5,3) FROM TABLE(GENERATOR(5));

--echo ### 验证 gen 取相同/不同常量值时对输出结果影响
SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));

SELECT normal(1,2,1) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,2) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,3) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,4) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,5) FROM TABLE(GENERATOR(5));


