delimiter //;
--error 0,1305
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT normal(1,2,inval) into @res1 FROM TABLE(GENERATOR(1));
  SELECT normal(1,2,var) into @res2 FROM TABLE(GENERATOR(1));
end;
//
delimiter ;//

call p0(10);
select @res1,@res2 from dual;

--echo ## 内置函数
SELECT normal(1,2,abs(-10)) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,floor(3.54)) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,ceil(3.54)) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,avg(-10)) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,min(3.54)) FROM TABLE(GENERATOR(5));
SELECT normal(1,2,max(3.54)) FROM TABLE(GENERATOR(5));

