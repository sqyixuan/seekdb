# description: mysql模式 随机/分布函数 - SQL场景
# tags: sql
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

set ob_query_timeout = 10000000000;

--echo ---------------------------------------------------------------------------------
--echo ######################## 标签：generator-1      2、随机函数  ######################
--echo ######################## 标签：distribution-1   3、分布函数  ######################
--echo ######################## 标签：table-function-2 SQL场景   ######################
--echo ######## table-function-2-1 select
--echo ###### 测试表
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
  id int not null, 
  c1 varchar(50), 
  c2 varchar(50),
  c3 varchar(50), 
  PRIMARY KEY (id))
PARTITION BY HASH(id) PARTITIONS 3;
  
INSERT INTO t1 VALUES(1,'中','国','china');
INSERT INTO t1 VALUES(2,'中','国','china');
INSERT INTO t1 VALUES(3,'中','国','china');
INSERT INTO t1 VALUES(4,'中','国','china');

--error 0,1051
DROP TABLE t2;
CREATE TABLE t2(
  id int,
  c1 int unique,
  c2 int,
  INDEX index_name (c1))
PARTITION BY LIST(c1)( 
  PARTITION p0 VALUES IN (1,2),
  PARTITION p1 VALUES IN (3,4),
  PARTITION p2 VALUES IN (5,6));
  
INSERT INTO t2 VALUES(1,1,11);
INSERT INTO t2 VALUES(2,2,12);
INSERT INTO t2 VALUES(3,3,13);

--error 0,1051
DROP TABLE t3;
CREATE TABLE t3(
  id int unique,
  c1 double,
  c2 varchar(50),
  c3 double default 0,
  c4 double default 0,
  c5 double default 0)
PARTITION BY RANGE (id) ( 
  PARTITION p0 VALUES LESS THAN (5), 
  PARTITION p1 VALUES LESS THAN (10),  
  PARTITION p2 VALUES LESS THAN MAXVALUE);

INSERT INTO t3 VALUES(1,1,10,20,30,40);
INSERT INTO t3 VALUES(2,2,12,13,14,15);
INSERT INTO t3 VALUES(3,3,23,24,25,26);

--error 0,1051
DROP VIEW v1;
CREATE VIEW v1 as select t1.id,t1.c1,t2.c2 from t1,t2 where t1.id = t2.id;


--echo ###### select 普通查询
SELECT random(1),randstr(5,random(1)) FROM dual;
SELECT normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) FROM dual;

SELECT c2,random(c1),randstr(5,c1) FROM v1 order by 1;
SELECT c2,normal(1,2,c2),uniform(1,10,c2),zipf(1,10,c2) FROM v1 order by 1;

SELECT id,random(id) FROM t1 order by 1;
SELECT id,randstr(5,id) FROM t1 order by 1;
SELECT c1,normal(1,2,c1) FROM t2 order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 order by 1;

--echo ###### where 子句
SELECT id,random(id) FROM t1 where random(id) > 0 order by 1;
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' order by 1;
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0 order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5 order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0 order by 1;

--echo ###### order by 子句
SELECT id,random(id) FROM t1 where random(id) > 0 order by random(id);
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' order by randstr(5,id);
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0 order by normal(1,2,c1);
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5 order by uniform(1,10,c1);
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0 order by zipf(1,10,c1);


--echo ###### group by having 子句
SELECT id,random(id) col FROM t1 group by col having random(id) > 0 order by 1;
SELECT id,randstr(5,id) col FROM t1 group by col having randstr(5,id) LIKE '%C%' order by 1;
SELECT c1,normal(1,2,c1) col FROM t2 group by col having normal(1,2,c1) > 0 order by 1;
SELECT c1,uniform(1,10,c1) col FROM t2 group by col having normal(1,2,c1) > 1 order by 1;
SELECT c1,zipf(1,10,c1) col FROM t2 group by col having zipf(1,10,c1) > 0 order by 1;


--echo ###### distinct
SELECT distinct random(id),id FROM t1 order by 1;
SELECT distinct randstr(5,id),id FROM t1 order by 1;
SELECT distinct normal(1,2,c1),c1 FROM t2 order by 1;
SELECT distinct uniform(1,10,c1),c1 FROM t2 order by 1;
SELECT distinct zipf(1,10,c1),c1 FROM t2 order by 1;


--echo ###### case when
SELECT id,random(id),CASE WHEN random(id)>0 THEN '>0' ELSE '<0' END FROM t1 order by 1;
SELECT id,randstr(5,CASE WHEN id%2=0 THEN 0 ELSE 1 END) FROM t1 order by 1;
SELECT c1,normal(1,2,c1),CASE WHEN normal(1,2,c1)>0 THEN '>0' ELSE '<0' END FROM t2 order by 1;
SELECT c1,uniform(1,10,c1),CASE WHEN uniform(1,10,c1)>0 THEN '>0' ELSE '<0' END FROM t2 order by 1;
SELECT c1,zipf(1,10,c1),CASE zipf(1,10,c1) WHEN zipf(1,10,100)  THEN 'c1=100'  ELSE 'c1!=100' END FROM t2 order by 1;


--echo ###### 连接查询
SELECT t2.c1,random(t2.c1) FROM t1,t2 where t1.id=t2.id order by 1;
SELECT t2.c1,randstr(5,t2.c1) FROM t1,t2 where t1.id=t2.id order by 1;
SELECT t2.c1,normal(1,2,t2.c1) FROM t1,t2 where t1.id=t2.id order by 1;
SELECT t2.c1,uniform(1,10,t2.c1) FROM t1,t2 where t1.id=t2.id order by 1;
SELECT t2.c1,zipf(1,10,t2.c1) FROM t1,t2 where t1.id=t2.id order by 1;

SELECT t2.c2,random(t2.c2) FROM t1 LEFT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,randstr(5,t2.c2) FROM t1 LEFT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,normal(1,2,t2.c2) FROM t1 LEFT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,uniform(1,10,t2.c2) FROM t1 LEFT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,zipf(1,10,t2.c2) FROM t1 LEFT JOIN t2 ON t1.id=t2.id order by 1;

SELECT t2.c1,random(t2.c1) FROM t1 RIGHT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c1,randstr(5,t2.c1) FROM t1 RIGHT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c1,normal(1,2,t2.c1) FROM t1 RIGHT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c1,uniform(1,10,t2.c1) FROM t1 RIGHT JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c1,zipf(1,10,t2.c1) FROM t1 RIGHT JOIN t2 ON t1.id=t2.id order by 1;

SELECT t2.c2,random(t2.c2) FROM t1 INNER JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,randstr(5,t2.c2) FROM t1 INNER JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,normal(1,2,t2.c2) FROM t1 INNER JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,uniform(1,10,t2.c2) FROM t1 INNER JOIN t2 ON t1.id=t2.id order by 1;
SELECT t2.c2,zipf(1,10,t2.c2) FROM t1 INNER JOIN t2 ON t1.id=t2.id order by 1;


--echo ###### select嵌套
--echo ### SELECT
SELECT col,random(col) FROM (SELECT id,random(id) col FROM t1) order by 1;
SELECT col,randstr(5,col) FROM (SELECT id,randstr(5,id) col FROM t1) order by 1;
SELECT col,normal(1,2,col) FROM (SELECT c1,normal(1,2,c1) col FROM t2) order by 1;
SELECT col,uniform(1,10,col) FROM (SELECT c1,uniform(1,10,c1) col FROM t2) order by 1;
SELECT col,zipf(1,10,col) FROM (SELECT c1,zipf(1,10,c1) col FROM t2) order by 1;


--echo ### EXISTS
SELECT id,random(id) FROM t1 where EXISTS (SELECT id,random(id) FROM t1 where random(id) > 0) order by 1;
SELECT id,randstr(5,id) FROM t1 where EXISTS (SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' ) order by 1;
SELECT c1,normal(1,2,c1) FROM t2 where EXISTS (SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 where EXISTS (SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 where EXISTS (SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;


--echo ### ANY
SELECT id,random(id) FROM t1 where random(id) > ANY(SELECT random(id) FROM t1 where random(id) > 0) order by 1;
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) = ANY(SELECT randstr(5,id) FROM t1 where randstr(5,id) like '%A%') order by 1;
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) < ANY(SELECT normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) >= ANY(SELECT uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) <= ANY(SELECT zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;


--echo ### ALL
SELECT id,random(id) FROM t1 where random(id) > ALL(SELECT random(id) FROM t1 where random(id) > 0) order by 1;
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) = ALL(SELECT randstr(5,id) FROM t1 where randstr(5,id) like '%A%') order by 1;
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) < ALL(SELECT normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) >= ALL(SELECT uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) <= ALL(SELECT zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;


--echo ### CREATE AS
--error 0,1051
DROP TABLE t4;
CREATE TABLE t4 AS SELECT c1,random(c1) c2,randstr(5,c1) c3,normal(1,2,c1) c4,uniform(1,10,c1) c5,zipf(1,10,c1) c6 FROM t2; 
SELECT * FROM t4 order by 1;


--echo ### INSERT INTO AS
INSERT INTO t4 SELECT 111,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) FROM TABLE(generator(3));
SELECT * FROM t4 order by 1;


--echo ### UPDATE SET
UPDATE t4 e INNER JOIN t2 p ON e.c1 = p.c1 SET e.c2=random(1) where e.c1 = 101;
UPDATE t4 e INNER JOIN t2 p ON e.c1 = p.c1 SET e.c3=randstr(5,random(1)) where e.c1 = 102;
UPDATE t4 e INNER JOIN t2 p ON e.c1 = p.c1 SET e.c4=normal(1,2,random(1)) where e.c1 = 103;
SELECT * FROM t4 order by 1;


--echo #WITH AS的SELECT
WITH a AS(
  SELECT id,random(c2) random,randstr(5,c2) randstr,normal(1,2,c2) normal,uniform(1,10,c2) uniform,zipf(1,10,c2) zipf 
  FROM t2)
SELECT a.id,a.random,a.randstr,a.normal,a.uniform,a.zipf FROM a ORDER BY a.id;


--echo #模糊查询like 
SELECT id,random(id) FROM t1 where random(id) like '%0%' order by 1;
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' order by 1;
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) like '%1%' order by 1;
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) like '%1%' order by 1;
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) like '%2%' order by 1;


--echo ### 标签：table-function-2-2 insert
INSERT INTO t4 values(222,random(123),randstr(5,123),normal(1,2,123),uniform(1,10,123),zipf(1,10,123));
INSERT INTO t4 SELECT 333,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) FROM TABLE(generator(3));
SELECT * FROM t4 order by 1;


--echo ### 标签：table-function-2-3 update
UPDATE t3 SET c1 = random(123),c2 = randstr(5,123),c3 = normal(1,2,123),c4 = uniform(1,10,123),c5 = zipf(1,10,123) WHERE random(id)=random(1);
SELECT * FROM t3 order by 1;


--echo ### 标签：sha-2-4 delete
SELECT * FROM t4 order by 1;
DELETE FROM t4 WHERE c2 = (select random(c1) from t2 where id = 2);
SELECT * FROM t4 order by 1;


--echo ### 标签：table-function-2-5 replace   
REPLACE INTO t2 values(4,uniform(1,10,123),zipf(1,10,123));
SELECT * FROM t2 order by 1;

REPLACE INTO t2 values(4,zipf(1,10,3),uniform(1,10,3));
SELECT * FROM t2 order by 1;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
