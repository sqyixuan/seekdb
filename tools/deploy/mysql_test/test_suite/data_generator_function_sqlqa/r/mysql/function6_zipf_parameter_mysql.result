#### s-参数值(特征指数) - 常量以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 2; 
  SELECT zipf(inval,10,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT zipf(var,10,3) into @res2 FROM TABLE(GENERATOR(1));
end;
//
call p0(1);
select @res1,@res2 from dual;
+-------+-------+
| @res1 | @res2 |
+-------+-------+
|     2 |     0 |
+-------+-------+
