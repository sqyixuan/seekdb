purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


set ob_query_timeout = 10000000000;
--------------------------------------------------------------------------
######################## 标签：distribution-1 2、分布函数  ########################
######## distribution-1-3 ③ ZIPF( <s> , <N> , <gen> ) 
###### distribution-1-3-1 参数个数
### distribution-1-3-1-1 0个
SELECT zipf() v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
###### distribution-1-3-1-2 1个
SELECT zipf(-1) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(0) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(1) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(1.5) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf('abc') v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(null) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(rand(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
###### distribution-1-3-1-3 2个
SELECT zipf(1,2) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
SELECT zipf(1.1,1.2) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR 42000: Incorrect parameter count in the call to native function 'zipf'
###### distribution-1-3-1-4 3个
#### s-参数值(特征指数) - 常量
## 数值
SELECT zipf(-10,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR HY000: Incorrect arguments to zipf first argument. must be a constant expression no less than 1
SELECT zipf(0,2,random(1)) v FROM TABLE(GENERATOR(100)) group by v order by 1;
ERROR HY000: Incorrect arguments to zipf first argument. must be a constant expression no less than 1
select count(*),zipf(1,10,random(1)) v from table(generator(10000)) group by v order by 1,2;
