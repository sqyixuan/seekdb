### 标签：table-function-3-3 触发器
DROP TRIGGER tri1;//
CREATE TRIGGER tri1 BEFORE INSERT ON t2 FOR EACH ROW
BEGIN
	DECLARE a int default 30;
	DECLARE b int default 10;

	loop1: LOOP
	  if a < 35 then
	    INSERT INTO t1 VALUES(a,random(a),randstr(5,b),normal(1,2,b),uniform(1,10,b),zipf(1,10,b));
	  elseif a = 36 then
	    UPDATE t1 set c1 = zipf(1,10,null) WHERE id >= 32;
	    LEAVE loop1;
	  else
	    delete FROM t1 WHERE id = 31;	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//
