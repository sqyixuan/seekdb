###### dml语句 - 循环语句
DROP FUNCTION fun1;//
CREATE FUNCTION fun1() returns varchar(200) READS SQL DATA 
begin
  declare i int default 22;
  WHILE i <= 23 do
    INSERT INTO t1 VALUES(i,random(i),randstr(5,i),normal(1,2,random(1)),uniform(1,10,i),zipf(1,10,i));
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO t1 VALUES(i,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
    SET i := i+1;
    IF i > 25 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO t1 VALUES(i,random(1),randstr(5,1),normal(1,2,1),uniform(1,10,1),zipf(1,10,1));
    SET i := i+1;
    until i > 27	
  END  REPEAT;
  return 'dml语句 - 循环语句';
END;
//
