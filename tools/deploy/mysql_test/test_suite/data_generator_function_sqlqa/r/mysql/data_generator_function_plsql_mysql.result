###### 参数 - 包含inout参数的存储过程
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1(INOUT invar varchar(200),out outa double,OUT outb double,OUT outc double,OUT outd double)
begin
  declare invalue varchar(200);
  set invalue := invar;
  SELECT random(invalue),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) into outa,invar,outb,outc,outd FROM dual;
END;
//
SET @invar := random(1);
CALL pro1(@invar,@outa,@outb,@outc,@outd);
