###### dml语句 - 条件语句
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1(IN invalue varchar(200),IN ina int)
begin
  IF invalue = random(1) THEN 
    INSERT INTO t1 VALUES(6,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
  ELSE 
    INSERT INTO t1 VALUES(7,random(ina),randstr(5,ina),normal(1,2,ina),uniform(1,10,ina),zipf(1,10,ina));
  END IF;
END;
//
SET @invalue := random(1);
SET @ina := 1;
CALL pro1(@invalue,@ina);
SELECT * FROM t1 ORDER BY 1,2,3;
