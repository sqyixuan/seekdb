###### dml语句 - 条件语句
DROP FUNCTION fun1;//
CREATE FUNCTION fun1(invalue varchar(200),ina int) returns varchar(200) READS SQL DATA 
begin
  IF invalue = random(1) THEN 
    INSERT INTO t1 VALUES(20,random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));
  ELSE 
    INSERT INTO t1 VALUES(21,random(ina),randstr(5,ina),normal(1,2,ina),uniform(1,10,ina),zipf(1,10,ina));
  END IF;
  return 'dml语句 - 条件语句';
END;
