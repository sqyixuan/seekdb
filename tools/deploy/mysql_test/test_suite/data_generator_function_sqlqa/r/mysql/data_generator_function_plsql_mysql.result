###### 游标
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
  declare a,b,c,d,e varchar(200);
  DECLARE done INT DEFAULT 0;
  DECLARE cur1 CURSOR FOR SELECT random(1),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) from table(generator(5));
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  
  OPEN cur1;
  FETCH cur1 INTO a,b,c,d,e;
  WHILE done<>1 DO
    INSERT INTO t1 VALUES(15,a,b,c,d,e);
    FETCH cur1 INTO a,b,c,d,e;
  END WHILE;
  CLOSE cur1;
END;
//
CALL test_pro();
SELECT * FROM t1 where id = 15 ORDER BY 1,2,3;
+------+-----------------------+-------+---------------------+------+------+
| id   | c1                    | c2    | c3                  | c4   | c5   |
+------+-----------------------+-------+---------------------+------+------+
|   15 | -8.835543475904201e18 | ZKNmZ |  1.1817571798310198 |   10 |    7 |
|   15 | -6.753783847308464e18 | Z8bwj | -1.1668020685810387 |    4 |    0 |
|   15 | -6.707106347154343e18 | BQNIz |   1.548042646501783 |    2 |    0 |
|   15 | -2.750444335953844e18 | fyPid | -0.5523958022520625 |   10 |    9 |
|   15 | -8.999261833911159e17 | nMVCX |   5.471170747395348 |    9 |    6 |
+------+-----------------------+-------+---------------------+------+------+
###### 动态sql
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
BEGIN
  SET @s = 'INSERT INTO t1 VALUES(?,random(?),randstr(5,random(1)),normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)));';
  PREPARE stmsha_table1 FROM @s;
  SET @a = 16;
  SET @b = 2;
  EXECUTE stmsha_table1 USING @a,@b;

  SET @s = 'SELECT * FROM t1 WHERE c1 = ?';
  PREPARE stmt2 FROM @s;
  SET @a = random(2);
  EXECUTE stmt2 USING @a; 
END;
//
CALL pro1();
