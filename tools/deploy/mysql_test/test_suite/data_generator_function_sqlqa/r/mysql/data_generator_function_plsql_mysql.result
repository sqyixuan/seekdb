drop function fun1;//
CREATE FUNCTION fun1() returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  SELECT random(c1) into a FROM t1 WHERE id = 1;
  SELECT randstr(5,c2),normal(1,2,c3),uniform(1,10,c4),zipf(1,10,c5) into @b,@c,@d,@e FROM t1 WHERE id = 1;
  return a;
END;
