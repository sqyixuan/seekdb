###### 参数 - 包含out参数的存储过程
DROP PROCEDURE pro1;//
CREATE  PROCEDURE pro1(out outa double,OUT outb varchar(200),OUT outc double,OUT outd double,OUT oute double)
begin
  SELECT random(1),randstr(5,2),normal(1,2,3),uniform(1,10,3),zipf(1,10,3) into outa,outb,outc,outd,oute FROM dual;
END;
//
CALL pro1(@outa,@outb,@outc,@outd,@oute);
SELECT @outa,@outb,@outc,@outd,@oute;
