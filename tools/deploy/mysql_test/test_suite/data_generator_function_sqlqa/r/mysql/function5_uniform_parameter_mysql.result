#### min-参数值 - 常量以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT uniform(inval,20,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT uniform(var,20,3) into @res2 FROM TABLE(GENERATOR(1));
end;
//
call p0(10);
select @res1,@res2 from dual;
+-------+-------+
| @res1 | @res2 |
+-------+-------+
|    16 |    20 |
+-------+-------+
