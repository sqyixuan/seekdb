purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


set ob_query_timeout = 10000000000;
--------------------------------------------------------------------------
######################## 标签：distribution-1 2、分布函数  ########################
######## distribution-1-2 ② UNIFORM(<min> , <max> , <gen>)
###### distribution-1-1-2 参数个数
### distribution-1-1-2-1 0个
SELECT uniform() FROM TABLE(GENERATOR(5));
ERROR 42000: Incorrect parameter count in the call to native function 'uniform'
