#### N-参数值 - 常量以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT random(inval) into @res1 FROM TABLE(GENERATOR(1));
  SELECT random(var) into @res2 FROM TABLE(GENERATOR(1));
end;
//
call p0(10);
select @res1,@res2 from dual;
+---------------------+---------------------+
| @res1               | @res2               |
+---------------------+---------------------+
| 1868343560109015986 | 3978186780997236933 |
+---------------------+---------------------+
## 表列字段
drop table t1;
create table t1 (a int);
insert into t1 values(30);
SELECT random(t1.a) FROM t1;
