#### stddev-参数值（标准差） - 常量以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT normal(1,inval,3) into @res1 FROM TABLE(GENERATOR(1));
  SELECT normal(1,var,3) into @res2 FROM TABLE(GENERATOR(1));
end;
//
call p0(10);
select @res1,@res2 from dual;
+---------------------+---------------------+
| @res1               | @res2               |
+---------------------+---------------------+
| -12.583482608519827 | -26.166965217039653 |
+---------------------+---------------------+
