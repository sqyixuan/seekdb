######## 字符串类型
DROP TABLE char_table1;
CREATE TABLE char_table1( 
  id int,
  c1 CHAR(100), 
  c2 VARCHAR(100), 
  c3 BINARY(100),
  c4 VARBINARY(100), 
  c5 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c6 SET('a', 'b', 'c', 'd', 'e')
);
