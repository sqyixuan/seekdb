#### gen-参数值（数值生成函数） - 常量/随机函数以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT normal(1,2,inval) into @res1 FROM TABLE(GENERATOR(1));
  SELECT normal(1,2,var) into @res2 FROM TABLE(GENERATOR(1));
end;
//
call p0(10);
select @res1,@res2 from dual;
+-------------------+--------------------+
| @res1             | @res2              |
+-------------------+--------------------+
| 2.555811371791295 | 1.9931154433267224 |
+-------------------+--------------------+
