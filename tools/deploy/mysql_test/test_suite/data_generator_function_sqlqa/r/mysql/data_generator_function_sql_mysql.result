purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


set ob_query_timeout = 10000000000;
---------------------------------------------------------------------------------
######################## 标签：generator-1      2、随机函数  ######################
######################## 标签：distribution-1   3、分布函数  ######################
######################## 标签：table-function-2 SQL场景   ######################
######## table-function-2-1 select
###### 测试表
DROP TABLE t1;
CREATE TABLE t1(
  id int not null, 
  c1 varchar(50), 
  c2 varchar(50),
  c3 varchar(50), 
  PRIMARY KEY (id))
PARTITION BY HASH(id) PARTITIONS 3;
INSERT INTO t1 VALUES(1,'中','国','china');
INSERT INTO t1 VALUES(2,'中','国','china');
INSERT INTO t1 VALUES(3,'中','国','china');
INSERT INTO t1 VALUES(4,'中','国','china');
DROP TABLE t2;
CREATE TABLE t2(
  id int,
  c1 int unique,
  c2 int,
  INDEX index_name (c1))
PARTITION BY LIST(c1)( 
  PARTITION p0 VALUES IN (1,2),
  PARTITION p1 VALUES IN (3,4),
  PARTITION p2 VALUES IN (5,6));
INSERT INTO t2 VALUES(1,1,11);
INSERT INTO t2 VALUES(2,2,12);
INSERT INTO t2 VALUES(3,3,13);
DROP TABLE t3;
CREATE TABLE t3(
  id int unique,
  c1 double,
  c2 varchar(50),
  c3 double default 0,
  c4 double default 0,
  c5 double default 0)
PARTITION BY RANGE (id) ( 
  PARTITION p0 VALUES LESS THAN (5), 
  PARTITION p1 VALUES LESS THAN (10),  
  PARTITION p2 VALUES LESS THAN MAXVALUE);
INSERT INTO t3 VALUES(1,1,10,20,30,40);
INSERT INTO t3 VALUES(2,2,12,13,14,15);
INSERT INTO t3 VALUES(3,3,23,24,25,26);
DROP VIEW v1;
CREATE VIEW v1 as select t1.id,t1.c1,t2.c2 from t1,t2 where t1.id = t2.id;
###### select 普通查询
SELECT random(1),randstr(5,random(1)) FROM dual;
+----------------------+----------------------+
| random(1)            | randstr(5,random(1)) |
+----------------------+----------------------+
| -6753783847308464280 | Z8bwj                |
+----------------------+----------------------+
SELECT normal(1,2,random(1)),uniform(1,10,random(1)),zipf(1,10,random(1)) FROM dual;
+-----------------------+-------------------------+----------------------+
| normal(1,2,random(1)) | uniform(1,10,random(1)) | zipf(1,10,random(1)) |
+-----------------------+-------------------------+----------------------+
|   -1.1668020685810387 |                       4 |                    0 |
+-----------------------+-------------------------+----------------------+
SELECT c2,random(c1),randstr(5,c1) FROM v1 order by 1;
+------+----------------------+---------------+
| c2   | random(c1)           | randstr(5,c1) |
+------+----------------------+---------------+
|   11 | -6275704758082610114 | HYzwJ         |
|   12 | -6275704758082610114 | HYzwJ         |
|   13 | -6275704758082610114 | HYzwJ         |
+------+----------------------+---------------+
SELECT c2,normal(1,2,c2),uniform(1,10,c2),zipf(1,10,c2) FROM v1 order by 1;
+------+---------------------+------------------+---------------+
| c2   | normal(1,2,c2)      | uniform(1,10,c2) | zipf(1,10,c2) |
+------+---------------------+------------------+---------------+
|   11 |  1.9692873643275037 |                2 |             0 |
|   12 |  1.5011740324425584 |                2 |             0 |
|   13 | -1.9108987947763545 |                7 |             2 |
+------+---------------------+------------------+---------------+
SELECT id,random(id) FROM t1 order by 1;
+----+----------------------+
| id | random(id)           |
+----+----------------------+
|  1 | -6753783847308464280 |
|  2 |  7445180178319379020 |
|  3 |  1084041170817055659 |
|  4 |  5267436225003336391 |
+----+----------------------+
SELECT id,randstr(5,id) FROM t1 order by 1;
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  1 | GLC9O         |
|  2 | DAPMR         |
|  3 | CxcZU         |
|  4 | 9mpmX         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 order by 1;
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    1 | 0.22633647675792012 |
|    2 | -0.1829602411067861 |
|    3 | -1.7166965217039651 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 order by 1;
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    1 |                2 |
|    2 |               10 |
|    3 |                6 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 order by 1;
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    1 |             0 |
|    2 |             7 |
|    3 |             2 |
+------+---------------+
###### where 子句
SELECT id,random(id) FROM t1 where random(id) > 0 order by 1;
+----+---------------------+
| id | random(id)          |
+----+---------------------+
|  2 | 7445180178319379020 |
|  3 | 1084041170817055659 |
|  4 | 5267436225003336391 |
+----+---------------------+
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' order by 1;
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  2 | DAPMR         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0 order by 1;
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    1 | 0.22633647675792012 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5 order by 1;
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    2 |               10 |
|    3 |                6 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0 order by 1;
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    2 |             7 |
|    3 |             2 |
+------+---------------+
###### order by 子句
SELECT id,random(id) FROM t1 where random(id) > 0 order by random(id);
+----+---------------------+
| id | random(id)          |
+----+---------------------+
|  3 | 1084041170817055659 |
|  4 | 5267436225003336391 |
|  2 | 7445180178319379020 |
+----+---------------------+
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' order by randstr(5,id);
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  2 | DAPMR         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0 order by normal(1,2,c1);
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    1 | 0.22633647675792012 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5 order by uniform(1,10,c1);
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    3 |                6 |
|    2 |               10 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0 order by zipf(1,10,c1);
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    3 |             2 |
|    2 |             7 |
+------+---------------+
###### group by having 子句
SELECT id,random(id) col FROM t1 group by col having random(id) > 0 order by 1;
+----+---------------------+
| id | col                 |
+----+---------------------+
|  2 | 7445180178319379020 |
|  3 | 1084041170817055659 |
|  4 | 5267436225003336391 |
+----+---------------------+
SELECT id,randstr(5,id) col FROM t1 group by col having randstr(5,id) LIKE '%C%' order by 1;
+----+-------+
| id | col   |
+----+-------+
|  1 | GLC9O |
|  3 | CxcZU |
+----+-------+
SELECT c1,normal(1,2,c1) col FROM t2 group by col having normal(1,2,c1) > 0 order by 1;
+------+---------------------+
| c1   | col                 |
+------+---------------------+
|    1 | 0.22633647675792012 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) col FROM t2 group by col having normal(1,2,c1) > 1 order by 1;
+------+------+
| c1   | col  |
+------+------+
+------+------+
SELECT c1,zipf(1,10,c1) col FROM t2 group by col having zipf(1,10,c1) > 0 order by 1;
+------+------+
| c1   | col  |
+------+------+
|    2 |    7 |
|    3 |    2 |
+------+------+
###### distinct
SELECT distinct random(id),id FROM t1 order by 1;
+----------------------+----+
| random(id)           | id |
+----------------------+----+
| -6753783847308464280 |  1 |
|  1084041170817055659 |  3 |
|  5267436225003336391 |  4 |
|  7445180178319379020 |  2 |
+----------------------+----+
SELECT distinct randstr(5,id),id FROM t1 order by 1;
+---------------+----+
| randstr(5,id) | id |
+---------------+----+
| 9mpmX         |  4 |
| CxcZU         |  3 |
| DAPMR         |  2 |
| GLC9O         |  1 |
+---------------+----+
SELECT distinct normal(1,2,c1),c1 FROM t2 order by 1;
+---------------------+------+
| normal(1,2,c1)      | c1   |
+---------------------+------+
| -1.7166965217039651 |    3 |
| -0.1829602411067861 |    2 |
| 0.22633647675792012 |    1 |
+---------------------+------+
SELECT distinct uniform(1,10,c1),c1 FROM t2 order by 1;
+------------------+------+
| uniform(1,10,c1) | c1   |
+------------------+------+
|                2 |    1 |
|                6 |    3 |
|               10 |    2 |
+------------------+------+
SELECT distinct zipf(1,10,c1),c1 FROM t2 order by 1;
+---------------+------+
| zipf(1,10,c1) | c1   |
+---------------+------+
|             0 |    1 |
|             2 |    3 |
|             7 |    2 |
+---------------+------+
###### case when
SELECT id,random(id),CASE WHEN random(id)>0 THEN '>0' ELSE '<0' END FROM t1 order by 1;
+----+----------------------+------------------------------------------------+
| id | random(id)           | CASE WHEN random(id)>0 THEN '>0' ELSE '<0' END |
+----+----------------------+------------------------------------------------+
|  1 | -6753783847308464280 | <0                                             |
|  2 |  7445180178319379020 | >0                                             |
|  3 |  1084041170817055659 | >0                                             |
|  4 |  5267436225003336391 | >0                                             |
+----+----------------------+------------------------------------------------+
SELECT id,randstr(5,CASE WHEN id%2=0 THEN 0 ELSE 1 END) FROM t1 order by 1;
+----+-----------------------------------------------+
| id | randstr(5,CASE WHEN id%2=0 THEN 0 ELSE 1 END) |
+----+-----------------------------------------------+
|  1 | GLC9O                                         |
|  2 | HYzwJ                                         |
|  3 | GLC9O                                         |
|  4 | HYzwJ                                         |
+----+-----------------------------------------------+
SELECT c1,normal(1,2,c1),CASE WHEN normal(1,2,c1)>0 THEN '>0' ELSE '<0' END FROM t2 order by 1;
+------+---------------------+----------------------------------------------------+
| c1   | normal(1,2,c1)      | CASE WHEN normal(1,2,c1)>0 THEN '>0' ELSE '<0' END |
+------+---------------------+----------------------------------------------------+
|    1 | 0.22633647675792012 | >0                                                 |
|    2 | -0.1829602411067861 | <0                                                 |
|    3 | -1.7166965217039651 | <0                                                 |
+------+---------------------+----------------------------------------------------+
SELECT c1,uniform(1,10,c1),CASE WHEN uniform(1,10,c1)>0 THEN '>0' ELSE '<0' END FROM t2 order by 1;
+------+------------------+------------------------------------------------------+
| c1   | uniform(1,10,c1) | CASE WHEN uniform(1,10,c1)>0 THEN '>0' ELSE '<0' END |
+------+------------------+------------------------------------------------------+
|    1 |                2 | >0                                                   |
|    2 |               10 | >0                                                   |
|    3 |                6 | >0                                                   |
+------+------------------+------------------------------------------------------+
SELECT c1,zipf(1,10,c1),CASE zipf(1,10,c1) WHEN zipf(1,10,100)  THEN 'c1=100'  ELSE 'c1!=100' END FROM t2 order by 1;
+------+---------------+---------------------------------------------------------------------------+
| c1   | zipf(1,10,c1) | CASE zipf(1,10,c1) WHEN zipf(1,10,100)  THEN 'c1=100'  ELSE 'c1!=100' END |
+------+---------------+---------------------------------------------------------------------------+
|    1 |             0 | c1!=100                                                                   |
|    2 |             7 | c1!=100                                                                   |
|    3 |             2 | c1!=100                                                                   |
+------+---------------+---------------------------------------------------------------------------+
