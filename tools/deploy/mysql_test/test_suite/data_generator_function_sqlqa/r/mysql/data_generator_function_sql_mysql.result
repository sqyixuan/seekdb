###### select嵌套
### SELECT
SELECT col,random(col) FROM (SELECT id,random(id) col FROM t1) order by 1;
+----------------------+----------------------+
| col                  | random(col)          |
+----------------------+----------------------+
| -6753783847308464280 | -3616236869674197915 |
|  1084041170817055659 | -1641300189172225232 |
|  5267436225003336391 | -2573818771448689138 |
|  7445180178319379020 | -3001497895515806538 |
+----------------------+----------------------+
SELECT col,randstr(5,col) FROM (SELECT id,randstr(5,id) col FROM t1) order by 1;
+-------+----------------+
| col   | randstr(5,col) |
+-------+----------------+
| 9mpmX | 0nsro          |
| CxcZU | HYzwJ          |
| DAPMR | HYzwJ          |
| GLC9O | HYzwJ          |
+-------+----------------+
SELECT col,normal(1,2,col) FROM (SELECT c1,normal(1,2,c1) col FROM t2) order by 1;
+---------------------+--------------------+
| col                 | normal(1,2,col)    |
+---------------------+--------------------+
| -1.7166965217039651 | 1.4931672764815447 |
| -0.1829602411067861 | 1.2038371110290758 |
| 0.22633647675792012 | 1.2038371110290758 |
+---------------------+--------------------+
SELECT col,uniform(1,10,col) FROM (SELECT c1,uniform(1,10,c1) col FROM t2) order by 1;
+------+-------------------+
| col  | uniform(1,10,col) |
+------+-------------------+
|    2 |                10 |
|    6 |                 8 |
|   10 |                 7 |
+------+-------------------+
SELECT col,zipf(1,10,col) FROM (SELECT c1,zipf(1,10,c1) col FROM t2) order by 1;
+------+----------------+
| col  | zipf(1,10,col) |
+------+----------------+
|    0 |              0 |
|    2 |              7 |
|    7 |              4 |
+------+----------------+
### EXISTS
SELECT id,random(id) FROM t1 where EXISTS (SELECT id,random(id) FROM t1 where random(id) > 0) order by 1;
+----+----------------------+
| id | random(id)           |
+----+----------------------+
|  1 | -6753783847308464280 |
|  2 |  7445180178319379020 |
|  3 |  1084041170817055659 |
|  4 |  5267436225003336391 |
+----+----------------------+
SELECT id,randstr(5,id) FROM t1 where EXISTS (SELECT id,randstr(5,id) FROM t1 where randstr(5,id) like '%A%' ) order by 1;
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  1 | GLC9O         |
|  2 | DAPMR         |
|  3 | CxcZU         |
|  4 | 9mpmX         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 where EXISTS (SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    1 | 0.22633647675792012 |
|    2 | -0.1829602411067861 |
|    3 | -1.7166965217039651 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 where EXISTS (SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    1 |                2 |
|    2 |               10 |
|    3 |                6 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 where EXISTS (SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    1 |             0 |
|    2 |             7 |
|    3 |             2 |
+------+---------------+
### ANY
SELECT id,random(id) FROM t1 where random(id) > ANY(SELECT random(id) FROM t1 where random(id) > 0) order by 1;
+----+---------------------+
| id | random(id)          |
+----+---------------------+
|  2 | 7445180178319379020 |
|  4 | 5267436225003336391 |
+----+---------------------+
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) = ANY(SELECT randstr(5,id) FROM t1 where randstr(5,id) like '%A%') order by 1;
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  2 | DAPMR         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) < ANY(SELECT normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    2 | -0.1829602411067861 |
|    3 | -1.7166965217039651 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) >= ANY(SELECT uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    2 |               10 |
|    3 |                6 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) <= ANY(SELECT zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    1 |             0 |
|    2 |             7 |
|    3 |             2 |
+------+---------------+
### ALL
SELECT id,random(id) FROM t1 where random(id) > ALL(SELECT random(id) FROM t1 where random(id) > 0) order by 1;
+----+------------+
| id | random(id) |
+----+------------+
+----+------------+
SELECT id,randstr(5,id) FROM t1 where randstr(5,id) = ALL(SELECT randstr(5,id) FROM t1 where randstr(5,id) like '%A%') order by 1;
+----+---------------+
| id | randstr(5,id) |
+----+---------------+
|  2 | DAPMR         |
+----+---------------+
SELECT c1,normal(1,2,c1) FROM t2 where normal(1,2,c1) < ALL(SELECT normal(1,2,c1) FROM t2 where normal(1,2,c1) > 0) order by 1;
+------+---------------------+
| c1   | normal(1,2,c1)      |
+------+---------------------+
|    2 | -0.1829602411067861 |
|    3 | -1.7166965217039651 |
+------+---------------------+
SELECT c1,uniform(1,10,c1) FROM t2 where uniform(1,10,c1) >= ALL(SELECT uniform(1,10,c1) FROM t2 where uniform(1,10,c1) > 5) order by 1;
+------+------------------+
| c1   | uniform(1,10,c1) |
+------+------------------+
|    2 |               10 |
+------+------------------+
SELECT c1,zipf(1,10,c1) FROM t2 where zipf(1,10,c1) <= ALL(SELECT zipf(1,10,c1) FROM t2 where zipf(1,10,c1) > 0) order by 1;
+------+---------------+
| c1   | zipf(1,10,c1) |
+------+---------------+
|    1 |             0 |
|    3 |             2 |
+------+---------------+
### CREATE AS
DROP TABLE t4;
CREATE TABLE t4 AS SELECT c1,random(c1) c2,randstr(5,c1) c3,normal(1,2,c1) c4,uniform(1,10,c1) c5,zipf(1,10,c1) c6 FROM t2;
SELECT * FROM t4 order by 1;
+------+----------------------+-------+---------------------+------+------+
| c1   | c2                   | c3    | c4                  | c5   | c6   |
+------+----------------------+-------+---------------------+------+------+
|    1 | -6753783847308464280 | GLC9O | 0.22633647675792012 |    2 |    0 |
|    2 |  7445180178319379020 | DAPMR | -0.1829602411067861 |   10 |    7 |
|    3 |  1084041170817055659 | CxcZU | -1.7166965217039651 |    6 |    2 |
+------+----------------------+-------+---------------------+------+------+
