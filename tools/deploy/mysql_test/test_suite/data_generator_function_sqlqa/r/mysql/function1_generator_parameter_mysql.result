## TABLE(GENERATOR(N)) 表字段和表起别名
SELECT 123 col FROM TABLE(GENERATOR(5));
+-----+
| col |
+-----+
| 123 |
| 123 |
| 123 |
| 123 |
| 123 |
+-----+
SELECT 123 as col FROM TABLE(GENERATOR(5));
+-----+
| col |
+-----+
| 123 |
| 123 |
| 123 |
| 123 |
| 123 |
+-----+
SELECT 123 col FROM TABLE(GENERATOR(5)) gen;
+-----+
| col |
+-----+
| 123 |
| 123 |
| 123 |
| 123 |
| 123 |
+-----+
SELECT 123 col FROM TABLE(GENERATOR(5)) as gen;
+-----+
| col |
+-----+
| 123 |
| 123 |
| 123 |
| 123 |
| 123 |
+-----+
SELECT 123 as col FROM TABLE(GENERATOR(5)) as gen;
+-----+
| col |
+-----+
| 123 |
| 123 |
| 123 |
| 123 |
| 123 |
+-----+
