######## generator-1-2  功能点测试
###### 配合随机/分布函数使用
select rand(1) from table(generator(5));
+---------------------+
| rand(1)             |
+---------------------+
| 0.40540353712197724 |
|  0.8716141803857071 |
|  0.1418603212962489 |
| 0.09445909605776807 |
| 0.04671454713373868 |
+---------------------+
select rand(123) from table(generator(5));
+--------------------+
| rand(123)          |
+--------------------+
| 0.9277428611440052 |
| 0.4609715924234796 |
| 0.5216294094190276 |
| 0.2252323005583438 |
| 0.5612733052682815 |
+--------------------+
select random(1) from table(generator(5));
+----------------------+
| random(1)            |
+----------------------+
| -6753783847308464280 |
| -6707106347154343346 |
|  -899926183391115878 |
| -8835543475904200562 |
| -2750444335953844424 |
+----------------------+
select random(123) from table(generator(5));
+----------------------+
| random(123)          |
+----------------------+
| -3445848496932922304 |
|  1032632488948585963 |
|  8084933221873407293 |
|  4359373536036025982 |
| -5674079147706729428 |
+----------------------+
select randstr(1,123) str from table(generator(5));
+------+
| str  |
+------+
| G    |
| G    |
| G    |
| G    |
| G    |
+------+
select randstr(1,random(1)) str from table(generator(5));
+------+
| str  |
+------+
| Z    |
| B    |
| n    |
| Z    |
| f    |
+------+
select randstr(1,zipf(1,5,random(1))) str from table(generator(5));
+------+
| str  |
+------+
| H    |
| H    |
| C    |
| C    |
| 9    |
+------+
select randstr(1,normal(0,1,random(1))) str from table(generator(5));
+------+
| str  |
+------+
| K    |
| H    |
| D    |
| H    |
| K    |
+------+
select randstr(1,uniform(0,10,random(1))) str from table(generator(5));
+------+
| str  |
+------+
| C    |
| G    |
| 0    |
| 0    |
| x    |
+------+
select zipf(1,5,random(1)) from table(generator(5));
+---------------------+
| zipf(1,5,random(1)) |
+---------------------+
|                   0 |
|                   0 |
|                   3 |
|                   3 |
|                   4 |
+---------------------+
select normal(0,1,random(1)) from table(generator(5));
+-----------------------+
| normal(0,1,random(1)) |
+-----------------------+
|   -1.0834010342905194 |
|   0.27402132325089146 |
|     2.235585373697674 |
|   0.09087858991550991 |
|   -0.7761979011260313 |
+-----------------------+
select uniform(0,10,random(1)) from table(generator(5));
+-------------------------+
| uniform(0,10,random(1)) |
+-------------------------+
|                       3 |
|                       1 |
|                       9 |
|                       9 |
|                      10 |
+-------------------------+
