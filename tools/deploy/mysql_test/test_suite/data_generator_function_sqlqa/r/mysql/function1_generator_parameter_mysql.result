#### N-参数值 - 常量以外场景
## 变量
drop procedure p0;//
create procedure p0(in inval int) 
begin
  declare var int;
  set var = 20; 
  SELECT COUNT(*) into @res1 FROM TABLE(GENERATOR(inval));
  SELECT COUNT(*) into @res2 FROM TABLE(GENERATOR(var));
end;
//
set @res1=null,@res2=null;
call p0(10);
select @res1,@res2 from dual;
+-------+-------+
| @res1 | @res2 |
+-------+-------+
|    10 |    20 |
+-------+-------+
## 表列字段
drop table t1;
create table t1 (a int);
insert into t1 values(30);
SELECT COUNT(g.*) FROM TABLE(GENERATOR(t1.a)) g,t1;
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
## 内置函数
SELECT COUNT(*) FROM TABLE(GENERATOR(abs(-40)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
SELECT COUNT(*) FROM TABLE(GENERATOR(floor(3.54)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
SELECT COUNT(*) FROM TABLE(GENERATOR(ceil(3.54)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
## 随机函数
SELECT COUNT(*) FROM TABLE(GENERATOR(rand(1)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
SELECT COUNT(*) FROM TABLE(GENERATOR(random(1)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
## 自定义函数
drop function f0;//
create function f0() returns int
begin
  return 50;
end;
//
SELECT COUNT(*) FROM TABLE(GENERATOR(f0));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
## 用户自定义变量
set @userval=60;
SELECT COUNT(*) FROM TABLE(GENERATOR(@userval));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
## sql语句
SELECT COUNT(*) FROM TABLE(GENERATOR((select 10 from dual)));
ERROR HY000: Incorrect arguments to generator function. The argument should be a constant integer
