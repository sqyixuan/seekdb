###### GENERATOR(N) 出现在 table function 内部以外场景
select * from generator(20);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(20)' at line 1
select generator(20) from dual;
ERROR 42000: Incorrect parameters in the call to native function 'generator'
select * from generator(20) where generator(20) > 3;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(20) where generator(20) > 3' at line 1
select * from table(generator(20)) where generator(20) > 3;
ERROR 42000: Incorrect parameters in the call to native function 'generator'
select * from table(generator(20) + generator(20));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '+ generator(20))' at line 1
select abs(generator(20)) from dual;
ERROR 42000: Incorrect parameters in the call to native function 'generator'
###### TABLE(GENERATOR(N))和其他表关联
DROP TABLE t1;
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES(123);
INSERT INTO t1 VALUES(456);
## 集合运算
SELECT 123 FROM TABLE(GENERATOR(5))
UNION
SELECT * FROM t1;
+------+
| 123  |
+------+
|  123 |
|  456 |
+------+
SELECT 123 FROM TABLE(GENERATOR(5))
INTERSECT
SELECT * FROM t1;
+------+
| 123  |
+------+
|  123 |
+------+
SELECT 123 FROM TABLE(GENERATOR(5))
EXCEPT
SELECT * FROM t1;
+------+
| 123  |
+------+
+------+
## 多表连接
SELECT * FROM (SELECT 123 as b FROM TABLE(GENERATOR(5))) g left join t1 on g.b=t1.a;
+-----+------+
| b   | a    |
+-----+------+
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
+-----+------+
SELECT * FROM (SELECT 123 as b FROM TABLE(GENERATOR(5))) g right join t1 on g.b=t1.a;
+-----+------+
| b   | a    |
+-----+------+
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| NULL |  456 |
+-----+------+
SELECT * FROM (SELECT 123 as b FROM TABLE(GENERATOR(5))) g inner join t1 on g.b=t1.a;
+-----+------+
| b   | a    |
+-----+------+
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
| 123 |  123 |
+-----+------+
## select 后面添加具体的表达式
drop function f0;//
create function f0() returns int
begin
  return 444;
end;
//
set @var = 222;
SELECT 111 FROM TABLE(GENERATOR(5));
+-----+
| 111 |
+-----+
| 111 |
| 111 |
| 111 |
| 111 |
| 111 |
+-----+
SELECT @var FROM TABLE(GENERATOR(5));
+------+
| @var |
+------+
|  222 |
|  222 |
|  222 |
|  222 |
|  222 |
+------+
SELECT abs(-333) FROM TABLE(GENERATOR(5));
+-----------+
| abs(-333) |
+-----------+
|       333 |
|       333 |
|       333 |
|       333 |
|       333 |
+-----------+
SELECT f0 FROM TABLE(GENERATOR(5));
