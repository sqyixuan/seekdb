drop table if EXISTS test1;
CREATE TABLE test1(id INT(5) PRIMARY KEY AUTO_INCREMENT,h2 FLOAT ,h3 DOUBLE NOT NULL,h4 CHAR(10) DEFAULT 'A',
h5 VARCHAR(10) UNIQUE,h6 CHAR(10),h7 INT,h8 TIME,h9 YEAR ,CHECK(h9>=2000));
