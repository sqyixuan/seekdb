drop table if EXISTS test2;
CREATE TABLE test2(id INT(5),h2 CHAR(10),h3 TIME);
INSERT INTO test2 VALUES(111111,'yinghe','00:00:00');
INSERT INTO test2 VALUES(222222,'yuzhou','59:59:59');
INSERT INTO test2 VALUES(333333,'taiyang','00:00:01');
select * from test2 order by id asc;
select /*+ parallel(3) */ count(distinct h3),sum(distinct h2) from test2 group by h2 order by h2;
explain basic select /*+ parallel(3) */ count(distinct h3),sum(distinct h2) from test2 group by h2 order by h2;
select /*+ parallel(3) GBY_PUSHDOWN */ count(distinct(select h3 from test1 LIMIT 1)),sum(distinct h2) from test2 group by h2;
explain basic select /*+ parallel(3) GBY_PUSHDOWN */ count(distinct(select h3 from test1 LIMIT 1)),sum(distinct h2) from test2 group by h2;
select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),count(distinct h2) from test2 group by h2;
explain basic select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),count(distinct h2) from test2 group by h2;
select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),avg(distinct h2) from test2 group by h2;
explain basic select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),avg(distinct h2) from test2 group by h2;
select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),max(distinct h2) from test2 group by h2;
explain basic select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),max(distinct h2) from test2 group by h2;
select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),min(distinct h2) from test2 group by h2;
explain basic select /*+ parallel(3) */ count(distinct(select h3 from test1 LIMIT 1)),min(distinct h2) from test2 group by h2;
select (select /*+ parallel(3) */ count(distinct h3) from test1 group by h3 LIMIT 1),min(distinct h3) from test2 group by h2;
explain basic select (select /*+ parallel(3) */ count(distinct h3) from test1 group by h3 LIMIT 1),min(distinct h3) from test2 group by h2;
drop table if EXISTS test1,test2;


