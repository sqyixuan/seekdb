select /*+parallel(3)*/ avg(distinct(h4)),avg(distinct(h4)),avg(distinct(h4)),avg(distinct(h4)),count(distinct(h4)) from test1 group by id order by id asc;
explain basic select /*+parallel(3)*/ avg(distinct(h4)),avg(distinct(h4)),avg(distinct(h4)),avg(distinct(h4)),count(distinct(h4)) from test1 group by id order by id asc;
select /*+parallel(3)*/ count(distinct(h5)),count(distinct(h5)),count(distinct(h5)),count(distinct(h5)),count(distinct(h5)) from test1 group by id order by id asc;
