select /*+ parallel(3) NO_USE_HASH_AGGREGATION */  id, sum(distinct h2),sum(distinct h3),sum(distinct h7),sum(distinct h8),sum(distinct h9) from test1 group by h2 order by id asc;
explain basic select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ id, sum(distinct h2),sum(distinct h3),sum(distinct h7),sum(distinct h8),sum(distinct h9)from test1 group by h2 order by id asc;
