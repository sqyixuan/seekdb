select /*+parallel(3)*/ sum(distinct(h6)),sum(distinct(h6)),sum(distinct(h6)),sum(distinct(h6)),count(distinct(h6)) from test1 group by id order by id asc;
explain basic select /*+parallel(3)*/ sum(distinct(h6)),sum(distinct(h6)),sum(distinct(h6)),sum(distinct(h6)),count(distinct(h6)) from test1 group by id order by id asc;
