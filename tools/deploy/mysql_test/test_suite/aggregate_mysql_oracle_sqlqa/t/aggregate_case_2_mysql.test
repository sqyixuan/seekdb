select /*+ parallel(3) */ case when h2 then 7777.7777 else 9999.999999 end h2,count(distinct h3),sum(distinct h2),min(distinct h4) from test1  order by h2 asc;
EXPLAIN select /*+ parallel(3) */ case when h2 then 7777.7777 else 9999.999999 end h2,count(distinct h3),sum(distinct h2),min(distinct h4) from test1 order by h2 asc;
select /*+ parallel(3) */ case when h2 then 7777.7777 else 9999.999999 end h2,count(distinct h3),sum(distinct h2),min(distinct h4) from test1 group by h2 order by h2 asc;
