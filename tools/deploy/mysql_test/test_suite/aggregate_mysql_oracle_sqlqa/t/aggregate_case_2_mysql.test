INSERT INTO test1 VALUES(2,7777.7777,1,'cccccc','11:11:11','2020');
INSERT INTO test1 VALUES(3,8888.88888,2,'zzzzzz','22:22:22','2010');
INSERT INTO test1 VALUES(4,6666.666,2,'qqqqqq','11:11:11','2000');
INSERT INTO test1 VALUES(5,8888.88888,2,'tttttt','22:22:22','2020');
