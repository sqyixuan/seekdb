explain basic select /*+ parallel(3) */ max(distinct h2)+avg(distinct h2)+min(distinct h2)+count(distinct h3)+sum(distinct h4) from test1 group by h2 order by h2 asc;
select /*+ parallel(3) */ max(distinct h2)+avg(distinct h2)+min(distinct h2)+count(distinct h3)+sum(distinct h4) from test1 group by h2 order by h2 asc;
explain basic select /*+ parallel(3) */ max(distinct h2)-avg(distinct h2)-min(distinct h2)-count(distinct h3)-sum(distinct h4) from test1 group by h2 order by h2 asc;
select /*+ parallel(3) */ max(distinct h2)-avg(distinct h2)-min(distinct h2)-count(distinct h3)-sum(distinct h4) from test1 group by h2 order by h2 asc;
explain basic select /*+ parallel(3) */ max(distinct h2)*avg(distinct h2)*min(distinct h2)*count(distinct h3)*sum(distinct h4) from test1 group by h2 order by h2 asc;
select /*+ parallel(3) */ max(distinct h2)*avg(distinct h2)*min(distinct h2)*count(distinct h3)*sum(distinct h4) from test1 group by h2 order by h2 asc;
explain basic select /*+ parallel(3) */ max(distinct h2)/avg(distinct h2)/min(distinct h2)/count(distinct h3)/sum(distinct h4) from test1 group by h2 order by h2 asc;
select /*+ parallel(3) */ max(distinct h2)/avg(distinct h2)/min(distinct h2)/count(distinct h3)/sum(distinct h4) from test1 group by h2 order by h2 asc;
set @a=5;
select  max(distinct @a),sum(distinct @a) from test1 GROUP by @a order by 1 asc;
select /*+ parallel(3) */ max(distinct @a),sum(distinct @a) from test1 GROUP by @a order by 1 asc;
explain basic select /*+ parallel(3) */ max(distinct @a),sum(distinct @a) from test1 GROUP by @a order by 1 asc;
set @b=1;
set @c=null;
select  max(distinct @a),sum(distinct @b),count(distinct @c) from test1 GROUP by @a order by 1 asc;
select /*+ parallel(3) */ max(distinct @a),sum(distinct @b),count(distinct @c) from test1 GROUP by @a order by 1 asc;
explain basic select /*+ parallel(3) */ max(distinct @a),sum(distinct @b),count(distinct @c) from test1 GROUP by @a order by 1 asc;
drop table if EXISTS test1;
