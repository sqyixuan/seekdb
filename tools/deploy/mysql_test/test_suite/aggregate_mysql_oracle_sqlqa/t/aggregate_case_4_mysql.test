--echo  #********************************************执行hash-hash-hash********************************************
alter system set _sqlexec_disable_hash_based_distagg_tiv=false;
--echo	#左连接   left join
--error 0,1051
drop table if EXISTS test1,test2;
create table test1(id int PRIMARY key AUTO_INCREMENT,name char(20),School char(20),class int);
create table test2(id int PRIMARY key AUTO_INCREMENT,Fraction int,time_1 time);
insert into test1(name,School,class) values('小一','清华',1);
insert into test1(name,School,class) values('小二','北大',1);
insert into test1(name,School,class) values('小三','人大',2);
insert into test1(name,School,class) values('小四','科技',2);
insert into test1(name,School,class) values('小五','北航',3);
insert into test1(name,School,class) values('小五','北师',3);
insert into test2(Fraction,time_1) values(130,'022059');
insert into test2(Fraction,time_1) values(null,'025959');
insert into test2(Fraction,time_1) values(130,'125959');
insert into test2(Fraction,time_1) values(150,'205959');
insert into test2(Fraction,time_1) values(140,'225959');
insert into test2(Fraction,time_1) values(99,'235959');
select * from test1 order by id asc;
select * from test2 order by id asc;
select /*+ parallel(3) */ count(Fraction),count(distinct(select Fraction from test2 where Fraction>145)),count(distinct(time_1)+time_1) from test1 left JOIN test2 on test1.id=test2.id GROUP by test1.class order by test2.Fraction asc;
explain basic select /*+ parallel(3) */ count(Fraction),count(distinct(select distinct(Fraction) from test2 where Fraction>145)),count(distinct(time_1)+time_1) from test1 left JOIN test2 on test1.id=test2.id GROUP by test1.class order by test2.Fraction asc;
