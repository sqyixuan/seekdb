drop user if exists u1,u2;
create user u1 identified by '123';
create user u2 identified by '123';
grant select on test.* to u2;
grant all on *.* to u1 with grant option;
revoke execute, alter routine, create routine on *.* from u1;
result_format: 4
show grants;
Grants for u1@%
GRANT ALTER, CREATE, CREATE USER, DELETE, DROP, INSERT, UPDATE, SELECT, INDEX, CREATE VIEW, SHOW VIEW, SHOW DATABASES, SUPER, PROCESS, REFERENCES, FILE, ALTER TENANT, ALTER SYSTEM, CREATE RESOURCE POOL, CREATE RESOURCE UNIT, REPLICATION SLAVE, REPLICATION CLIENT, DROP DATABASE LINK, CREATE DATABASE LINK, CREATE TABLESPACE, SHUTDOWN, RELOAD, LOCK TABLES, CREATE ROLE, DROP ROLE, TRIGGER, EVENT, CREATE CATALOG, USE CATALOG ON *.* TO 'u1' WITH GRANT OPTION

revoke all on test.* from u2;
ERROR 42000: Access denied for user 'u1'@'%' to database 'test'
show grants for u2;
