result_format: 4
set global ob_compatibility_version = '1.0.0.0';

show variables like 'ob_compatibility_%';
Variable_name	Value
ob_compatibility_control	MYSQL5.7
ob_compatibility_mode	MYSQL
ob_compatibility_version	1.0.0.0

# test ob_compatibility_control
set ob_compatibility_control = 'MYSQL57';
ERROR HY000: Variable 'ob_compatibility_control' is a read only variable
set ob_compatibility_control = 'abc';
ERROR HY000: Variable 'ob_compatibility_control' is a read only variable
set global ob_compatibility_control = 'MYSQL57';
ERROR HY000: Variable 'ob_compatibility_control' is a read only variable
set global ob_compatibility_control = 'abc';
ERROR HY000: Variable 'ob_compatibility_control' is a read only variable

# test ob_compatibility_version
set ob_compatibility_version = '1.0.0.0';
ERROR HY000: Variable 'ob_compatibility_version' is a GLOBAL variable and should be set with SET GLOBAL
set global ob_compatibility_version = '4.3.2.0.0';
ERROR 42000: Variable 'ob_compatibility_version' can't be set to the value of '4.3.2.0.0'
set global ob_compatibility_version = '4.2.2.100';
ERROR 0A000: target version not supported
set global ob_compatibility_version = default;
ERROR 42000: Variable 'ob_compatibility_version' doesn't have a default value

# test views
show variables like 'ob_compatibility_%';
Variable_name	Value
ob_compatibility_control	MYSQL5.7
ob_compatibility_mode	MYSQL
ob_compatibility_version	1.0.0.0
desc oceanbase.V$OB_COMPATIBILITY_CONTROL;
+-----------------+---------------+------+-----+---------+-------+
| Field           | Type          | Null | Key | Default | Extra |
+-----------------+---------------+------+-----+---------+-------+
| NAME            | varchar(128)  | NO   |     | NULL    |       |
| DESCRIPTION     | varchar(4096) | NO   |     | NULL    |       |
| IS_ENABLE       | varchar(5)    | NO   |     | NULL    |       |
| ENABLE_VERSIONS | longtext      | NO   |     | NULL    |       |
+-----------------+---------------+------+-----+---------+-------+
select * from oceanbase.V$OB_COMPATIBILITY_CONTROL;
+-----------------------------------+---------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------+
| NAME                              | DESCRIPTION                                                                                                                                             | IS_ENABLE | ENABLE_VERSIONS |
+-----------------------------------+---------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------+
| FUNC_REPLACE_NULL                 | The result of REPLACE('abd', '', null) is different in MySQL 5.7 and 8.0                                                                                | TRUE      | [1.0.0.0, )     |
| UPD_LIMIT_OFFSET                  | MySQL do not support the use of OFFSET in the LIMIT clause of UPDATE/DELETE statement                                                                   | TRUE      | [1.0.0.0, )     |
| PROJECT_NULL                      | MySQL will rename the projection item names with pure null values to `NULL`                                                                             | TRUE      | [1.0.0.0, )     |
| VAR_NAME_LENGTH                   | MySQL will limit the length of user-defined variable names to within 64 characters                                                                      | TRUE      | [1.0.0.0, )     |
| NULL_VALUE_FOR_CLOSED_CURSOR      | Return null value to client for closed cursor, indicating that the cursor is not open                                                                   | TRUE      | [1.0.0.0, )     |
| FUNC_LOCATE_NULL                  | The result of REPLACE('x', 'abc', null) is different in MySQL 5.7 and 8.0                                                                               | TRUE      | [1.0.0.0, )     |
| INVOKER_RIGHT_COMPILE             | Use the definer's database during compile, regardless of whether is definer or invoker right                                                            | TRUE      | [1.0.0.0, )     |
| RECV_PLAIN_PASSWORD               | The set password command is different in different OceanBase versions                                                                                   | TRUE      | [1.0.0.0, )     |
| OUT_ANONYMOUS_COLLECTION_IS_ALLOW | The output parameter is returned according to the original input param 
type which is not empty for inout anonymous array which used in anonymous block | TRUE      | [1.0.0.0, )     |
+-----------------------------------+---------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------+


