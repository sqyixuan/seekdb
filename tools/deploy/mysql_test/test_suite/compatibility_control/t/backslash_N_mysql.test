--result_format 4

--echo 投影项名称变更兼容控制

--source mysql_test/test_suite/compatibility_control/include/reset_compatibility_version.inc

--echo \N 兼容控制 (MySQL8.0 不支持)
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys;
let $compat_type='MYSQL8.0';
let $version_name=ob_compatibility_version;
#--source mysql_test/test_suite/compatibility_control/include/create_tenant.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
--error 0,1235
select \N, null+1, Null, length(Null) from dual;
