# owner: sean.yyj
# owner group: sql1

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

let $compat_type='MYSQL5.7';
let $version_name=ob_security_version;
#--source mysql_test/test_suite/compatibility_control/include/create_tenant.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
--disable_warnings
drop user if exists u1;
--enable_warnings
create user u1 identified by '123';
grant select on *.* to u1;
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

--result_format 4
show variables like 'ob_security_version';

#create outline o1 on select 1 from dual;
#--error 5272
#alter outline o1 add select 1 from dual;
#drop outline o1;

#create sequence s1;
#alter sequence s1 maxvalue 10;
#drop sequence s1;

#create tablespace ts1;
#alter tablespace ts1 encryption = 'n';
#drop tablespace ts1;

#connection conn_compat_test_root;
#create tablespace ts1;

disconnect conn_compat_test_root;
disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show variables like 'ob_security_version';
--error 1044
create outline o1 on select 1 from dual;
--error 1044
alter outline o1 add select 1 from dual;
--error 1044
drop outline o1;

--error 1044
create sequence s1;
--error 1044
alter sequence s1 maxvalue 10;
--error 1044
drop sequence s1;

#--error 1227
#create tablespace ts1;
#--error 1227
#alter tablespace ts1 encryption = 'n';
#--error 1227
#drop tablespace ts1;

connection conn_compat_test_root;
#drop tablespace ts1;
grant create, alter, drop on test.* to u1;
grant create tablespace on *.* to u1;

disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show grants;
create outline o1 on select 1 from dual;
--error 5272
alter outline o1 add select 1 from dual;
drop outline o1;

create sequence s1;
alter sequence s1 maxvalue 10;
drop sequence s1;

#create tablespace ts1;
#alter tablespace ts1 encryption = 'n';
#drop tablespace ts1;

#--source mysql_test/test_suite/compatibility_control/include/drop_tenant.inc
