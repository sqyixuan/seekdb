# owner: sean.yyj
# owner group: sql1

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

let $compat_type='MYSQL5.7';
let $version_name=ob_security_version;
#--source mysql_test/test_suite/compatibility_control/include/create_tenant.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
--disable_warnings
drop user IF EXISTS u1;
--enable_warnings
create user u1 identified by '123';
grant all on *.* to u1;
revoke trigger ON *.* FROM u1;
--source mysql_test/include/check_schema_fast_sync.inc
# 低版本不检查权限 创建租户设置4.2.1.0版本，单机轻量版不创建租户 注释
connect (conn_u1,$TE_SERVER_IP,u1,123,test,$TE_SERVER_PORT);

--result_format 4
show variables like 'ob_security_version';
--disable_warnings
drop table IF EXISTS t1;
drop table IF EXISTS t2;
--enable_warnings
CREATE TABLE t1(num_value INT);
CREATE TABLE t2(user_str TEXT);

#CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
#CREATE TRIGGER trg2 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
#drop trigger trg1;
INSERT INTO t1 VALUES(1);
#show create trigger trg2;
--replace_column 6 time
#show triggers;
--replace_column 6 time
#show triggers like 't%';
--replace_column 17 time
select * from information_schema.TRIGGERS;
select * from t1;
select * from t2;

connection conn_compat_test_root;
#set global ob_security_version = '4.2.4.0';

disconnect conn_compat_test_root;
disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show variables like 'ob_security_version';

--error 1360
drop trigger trg2;
--error 1142
CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
--error 0,1142
INSERT INTO t1 VALUES(1);
--error 1360,1227
show create trigger trg2;
show triggers;
show triggers like 't%';
select * from information_schema.TRIGGERS;
select * from t1;
select * from t2;

connection conn_compat_test_root;
grant trigger on *.* to u1;

disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show grants;

CREATE TRIGGER trg1 AFTER INSERT ON t1 FOR EACH ROW INSERT INTO t2 VALUES(CURRENT_USER());
drop trigger if exists trg2;
INSERT INTO t1 VALUES(1);
show create trigger trg1;
--replace_column 6 time
show triggers;
--replace_column 6 time
show triggers like 't%';
--replace_column 17 time
select * from information_schema.TRIGGERS;
select * from t1;
select * from t2;

#--source mysql_test/test_suite/compatibility_control/include/drop_tenant.inc
