# owner: linyi.cl
# owner group: sql3

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

let $compat_type='MYSQL5.7';
let $version_name=ob_security_version;
#--source mysql_test/test_suite/compatibility_control/include/create_tenant.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
--disable_warnings
drop user if exists u1;
--enable_warnings
create user u1 identified by '123';
grant all on *.* to u1;
revoke references on *.* from u1;
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

--result_format 4
show variables like 'ob_security_version';

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int primary key);
#create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));

connection conn_compat_test_root;

disconnect conn_compat_test_root;
disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show variables like 'ob_security_version';
--error 1142
create table t3(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));

connection conn_compat_test_root;
grant references on test.t1 to u1;

disconnect conn_u1;
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

show grants;
create table t3(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));

#--source mysql_test/test_suite/compatibility_control/include/drop_tenant.inc
