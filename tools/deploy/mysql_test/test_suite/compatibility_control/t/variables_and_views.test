# owner: sean.yyj
# owner group: sql1

--result_format 4

set global ob_compatibility_version = '1.0.0.0';
--source mysql_test/include/check_schema_fast_sync.inc
connect (conn0,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection conn0;
show variables like 'ob_compatibility_%';

--echo # test ob_compatibility_control
--error 1238
set ob_compatibility_control = 'MYSQL57';
--error 1238
set ob_compatibility_control = 'abc';
--error 1238
set global ob_compatibility_control = 'MYSQL57';
--error 1238
set global ob_compatibility_control = 'abc';

--echo # test ob_compatibility_version
--error 1229
set ob_compatibility_version = '1.0.0.0';
--error 1231
set global ob_compatibility_version = '4.3.2.0.0';
--error 1235
set global ob_compatibility_version = '4.2.2.100';
--error 1230
set global ob_compatibility_version = default;

--echo # test views
show variables like 'ob_compatibility_%';
desc oceanbase.V$OB_COMPATIBILITY_CONTROL;
select * from oceanbase.V$OB_COMPATIBILITY_CONTROL;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn1,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection conn1;
show variables like 'ob_compatibility_%';
select * from oceanbase.V$OB_COMPATIBILITY_CONTROL;

disconnect conn0;
connect (conn0,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection conn0;
show variables like 'ob_compatibility_%';
select * from oceanbase.V$OB_COMPATIBILITY_CONTROL;

--echo # cleanup
connection default;
--source mysql_test/test_suite/compatibility_control/include/reset_compatibility_version.inc
