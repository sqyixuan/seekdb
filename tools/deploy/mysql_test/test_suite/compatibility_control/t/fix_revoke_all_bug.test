# owner: sean.yyj
# owner group: sql1

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

let $compat_type='MYSQL5.7';
let $version_name=ob_security_version;
#--source mysql_test/test_suite/compatibility_control/include/create_tenant.inc
--source mysql_test/test_suite/compatibility_control/include/conn_tenant.inc
--disable_warnings
drop user if exists u1,u2;
--enable_warnings
create user u1 identified by '123';
create user u2 identified by '123';
grant select on test.* to u2;

grant all on *.* to u1 with grant option;
revoke execute, alter routine, create routine on *.* from u1;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);

--result_format 4
show grants;

--error 1044
revoke all on test.* from u2;
show grants for u2;
disconnect conn_u1;



connection conn_compat_test_root;
grant execute on test.* to u2;
connect (conn_u1, $TE_SERVER_IP, u1,123,test, $TE_SERVER_PORT);
--error 1044
revoke execute on test.* from u2;
disconnect conn_u1;

connection conn_compat_test_root;
show grants for u2;

grant select on test.* to u2;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1, $OBMYSQL_MS0, u1,123,test, $OBMYSQL_PORT);

--error 1044
revoke all on test.* from u2;

