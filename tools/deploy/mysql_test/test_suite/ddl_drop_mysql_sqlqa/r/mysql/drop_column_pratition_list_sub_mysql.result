#分区键为VIRTUAL型生成列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
c4 VARCHAR(10) GENERATED ALWAYS AS (CONCAT(c3,c5)) VIRTUAL COMMENT '字符串生成列' ,
c5 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
c6 INT,
c7 DATE,
c8 YEAR)
PARTITION BY LIST COLUMNS(c4)
SUBPARTITION BY HASH(c0) SUBPARTITIONS 3
(PARTITION p1 VALUES IN('中文','中!文a','中!文b','中!文c','中!文d','中!文e'),
PARTITION p2 VALUES IN('中!文f','中!文g','中!文h','中!文i','中!文j'),
PARTITION p3 VALUES IN('中!文k','中!文l','中!文m','中!文n','中!文o'),
PARTITION p4 VALUES IN('P','Q','R','S','T'),
PARTITION p5 VALUES IN('U','V','W','X','Y','Z')
);
