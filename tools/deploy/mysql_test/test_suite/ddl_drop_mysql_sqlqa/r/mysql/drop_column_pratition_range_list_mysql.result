#分区键带有自增约束和生成列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT AUTO_INCREMENT,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR GENERATED ALWAYS AS (c6*2) STORED COMMENT '数值生成列')
PARTITION BY LIST(c8)
SUBPARTITION BY HASH(c0)
(PARTITION l1 VALUES IN (2000,2002,2004,2006,2008,2010,2012)
(SUBPARTITION s1,SUBPARTITION s2),
PARTITION l2 VALUES IN (2001,2003,2005,2007,2009,2011,2013)
(SUBPARTITION s3,SUBPARTITION s4)
);
