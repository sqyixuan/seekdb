c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 DATE,
c8 YEAR)
PARTITION BY RANGE(c0)
(PARTITION l1 VALUES LESS THAN(7),
