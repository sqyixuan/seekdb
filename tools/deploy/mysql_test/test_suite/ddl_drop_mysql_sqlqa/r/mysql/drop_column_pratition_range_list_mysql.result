#分区键带有非空/default/check约束
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT NOT NULL DEFAULT 0,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 DATE,
c8 YEAR,CHECK(c8>=c6))
PARTITION BY RANGE(c8)
SUBPARTITION BY KEY(c0) SUBPARTITIONS 3
(PARTITION l1 VALUES LESS THAN(2000),
PARTITION l2 VALUES LESS THAN(2005),
PARTITION l3 VALUES LESS THAN(2010),
PARTITION l4 VALUES LESS THAN(2015),
PARTITION l5 VALUES LESS THAN MAXVALUE
);
