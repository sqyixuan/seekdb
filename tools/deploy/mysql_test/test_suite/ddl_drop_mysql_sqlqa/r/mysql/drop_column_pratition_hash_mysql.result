#分区键为生成列的引用列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT GENERATED ALWAYS AS (CONCAT(c6,c8)) VIRTUAL COMMENT '数值生成列',
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT ,
c7 TIME,
c8 YEAR)
PARTITION BY HASH(c6)
(PARTITION p1,PARTITION p2,PARTITION p3,PARTITION p4);
