DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c4 VARCHAR(10) PRIMARY KEY,
                c5 CHAR(10) CHARACTER SET 'gbk' COLLATE 'gbk_bin',
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY LIST COLUMNS(c4)
(PARTITION p1 VALUES IN('','A','B','C','D','E'),
 PARTITION p2 VALUES IN('F','G','H','I','J'),
 PARTITION p3 VALUES IN('K','L','M','N','O'),
 PARTITION p4 VALUES IN('P','Q','R','S','T'),
 PARTITION p5 VALUES IN('U','V','W','X','Y','Z')
);

