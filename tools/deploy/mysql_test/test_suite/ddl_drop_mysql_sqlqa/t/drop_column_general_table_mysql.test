DESC t1;


BEGIN;
SAVEPOINT s1;
--error 0,1054
ALTER TABLE t1 DROP COLUMN c1;
SAVEPOINT s2;
--error 0,1054
ALTER TABLE t1 DROP COLUMN c2;
SAVEPOINT s3;
--error 0,3108
ALTER TABLE t1 DROP COLUMN c3;

--error 0, 01305
ROLLBACK TO s1;

DESC t1;

