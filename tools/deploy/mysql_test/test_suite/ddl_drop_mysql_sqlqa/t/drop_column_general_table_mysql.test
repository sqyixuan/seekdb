--echo #删除列同时修改列及属性并新增列

ALTER TABLE t1 DROP COLUMN c12 ,MODIFY COLUMN c7 VARCHAR(50) DEFAULT 'A', ADD COLUMN c0 INT(5) ZEROFILL;


--echo #多个操作同时进行

ALTER TABLE t1 DROP COLUMN ,ADD COLUMN ,MODIFY COLUMN ,DROP COLUMN ,ADD KEY ,DROP INDEX , PARALLEL 4;

--echo #删除列并同时修改表的并行度


ALTER TABLE t1 DROP COLUMN c2,PARALLEL 2;


