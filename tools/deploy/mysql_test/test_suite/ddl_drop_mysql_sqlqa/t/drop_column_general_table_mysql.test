DESC t1;

NSERT INTO t1() VALUES();




--echo #同时删除所有列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(5) ,
                c1 FLOAT ,
                c2 DOUBLE ,
                c3 BIT(20) ,
                c4 BLOB ,
                c5 TEXT ,
                c6 VARCHAR(50) ,
                c7 CHAR(50) ,
                c8 BINARY(50) ,
                c9 VARBINARY(50) ,
                c10 ENUM('a','b','c','d','e','f','g','h') ,
                c11 SET('i','j','k','l','m','n','o','p') ,
                c12 TIME ,
                c13 DATE ,
                c14 DATETIME ,
                c15 TIMESTAMP ,
                c16 YEAR);
