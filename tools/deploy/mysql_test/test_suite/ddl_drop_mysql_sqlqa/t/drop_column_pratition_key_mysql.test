--echo #在分区键上创建分区索引

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY KEY(c8) PARTITIONS 3;

INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'2010-10-11','1989'),
                     (2,1.1,1.2,'中!文','A','a',1,'2001-01-11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'2016-02-11','2002'),
                     (4,1.3,3.2,'中!文','C','a',1,'2021-03-11','2003'),
                     (5,1.4,4.2,'中!文','D','a',2,'2011-11-01','2004'),
                     (6,1.5,5.2,'中!文','E','a',1,'2014-01-11','2005'),
                     (7,1.6,6.2,'中!文','F','a',3,'2011-11-01','2006'),
                     (8,1.7,7.2,'中!文','G','a',1,'2017-01-11','2007'),
                     (9,1.8,8.2,'中!文','H','a',4,'2013-11-01','2011'),
                     (10,1.9,9.2,'中!文','I','a',5,'2011-11-11','2013'),
