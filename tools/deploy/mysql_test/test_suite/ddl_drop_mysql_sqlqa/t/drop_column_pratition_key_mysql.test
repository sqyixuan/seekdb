--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log



--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;

--echo #mysql_drop-3
--echo #mysql_drop-3-1/mysql_drop-3-2/mysql_drop-3-4


--echo #PARTITION BY KEY

--echo #普通哈希分区表

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY KEY(c8) PARTITIONS 3;

