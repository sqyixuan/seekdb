                c1 FLOAT,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));

