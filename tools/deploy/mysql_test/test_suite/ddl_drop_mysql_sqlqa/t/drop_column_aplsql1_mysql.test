                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',1,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',1,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',1,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',1,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',1,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',1,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',1,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',1,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',1,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',1,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT UNIQUE,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',1,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',1,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',1,'11:11:11');


--echo #创建trigger后，删除引用列，然后触发trigger执行


--echo #insert型触发器

--error 0,1360
DROP TRIGGER  trg_insert;


DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE a VARCHAR(10);
    SET a=CONCAT(NEW.c4,'A');
    INSERT INTO t1(c0,c1,c2,c4,c5,c6,c7,c8) VALUES(NEW.c0+10,NEW.c1,NEW.c2,a,NEW.c5,NEW.c6,'12:12:12','2020');
END
//

DELIMITER ;//

--echo #删除非引用列

ALTER TABLE t2 DROP c3;
#SHOW CREATE TABLE t2;

INSERT INTO t2 VALUES(6,1.5,5.2,'a',1,'11:11:11');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #删除引用列

--error 0,1210
ALTER TABLE t2 DROP c2;
#SHOW CREATE TABLE t2;

--error 0, 01327
INSERT INTO t2 VALUES(7,1.6,'b',2,'12:12:12');

--echo #重新创建触发器
DROP TRIGGER  trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE a VARCHAR(10);
    SET a=CONCAT(NEW.c4,'A');
    INSERT INTO t1(c0,c1,c2,c4,c5,c6,c7,c8) VALUES(NEW.c0+10,NEW.c1,0,a,NEW.c5,NEW.c6,'12:12:12','2020');
END
//

DELIMITER ;//

INSERT INTO t2 VALUES(7,1.6,'b',2,'12:12:12');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


ALTER TABLE t1 DROP c1;
DESC t1;

--error 0, 01054
INSERT INTO t2 VALUES(8,1.7,'c',3,'13:13:13');

SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #update型触发器

DROP TABLE  t2;
DROP TABLE  t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT UNIQUE,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');
--error 0,1360
DROP TRIGGER  trg_update;

DELIMITER //;

CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
    UPDATE t1 SET c1=NEW.c1,c2=NEW.c2,c4=CONCAT(NEW.c4,'A'),c7=NEW.c6 WHERE c6=NEW.c5; 
END
//

DELIMITER ;//


--echo #删除非引用列

ALTER TABLE t2 DROP c3;
#SHOW CREATE TABLE t2;

UPDATE t2 SET c1=1.5,c2=5.2,c4='b',c5=1,c6='12:12:12' WHERE c0=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #删除引用列

ALTER TABLE t2 DROP c2;
#SHOW CREATE TABLE t2;

--error 0, 01327
UPDATE t2 SET c1=1.6,c4='c',c5=2,c6='13:13:13' WHERE c0=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #重新创建触发器
--error 0,1360
DROP TRIGGER  trg_update;

DELIMITER //;

CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
    UPDATE t1 SET c1=NEW.c1,c2=NEW.c1+1.1,c4=CONCAT(NEW.c4,'A'),c7=NEW.c6 WHERE c6=NEW.c5; 
END
//

DELIMITER ;//


UPDATE t2 SET c1=1.6,c4='c',c5=2,c6='13:13:13' WHERE c0=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


ALTER TABLE t1 DROP c2;
DESC t1;

--error 0, 01054
UPDATE t2 SET c1=1.7,c4='d',c5=3,c6='14:14:14' WHERE c0=2;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

--echo #重新创建触发器

DROP TRIGGER  trg_update;

DELIMITER //;

CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
    UPDATE t1 SET c1=NEW.c1,c4=CONCAT(NEW.c4,'A'),c7=NEW.c6 WHERE c6=NEW.c5; 
END
//

DELIMITER ;//

UPDATE t2 SET c1=1.7,c4='d',c5=3,c6='14:14:14' WHERE c0=2;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #delete型触发器

DROP TABLE  t2;
DROP TABLE  t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');
--error 0,1360                     
DROP TRIGGER  trg_delete;


DELIMITER //;

CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c1=OLD.c1 OR c2=OLD.c2;
END
//

DELIMITER ;//


--echo #删除非引用列

ALTER TABLE t2 DROP c3;
#SHOW CREATE TABLE t2;

--error 0, 01054
DELETE FROM t2 WHERE c3='中文';

DELETE FROM t2 WHERE c5=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

DELETE FROM t2 WHERE c1 LIKE '1.2%';
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

ALTER TABLE t2 DROP c1,DROP c2;
--error 0, 01327
DELETE FROM t2 WHERE c5=0;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

DROP TABLE  t2;
DROP TABLE  t1;

