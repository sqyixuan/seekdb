--echo #使用like关键字创建复制表
DROP TABLE IF EXISTS t3;
CREATE TABLE t3 LIKE t1;
INSERT INTO t3 SELECT * FROM t1;
create index index_1 on t3(c1);
DESC t3;

ALTER TABLE t3 DROP COLUMN c0 ,MODIFY COLUMN c6 VARCHAR(500);

--echo #删除列并修改列属性
--error 0,1091
ALTER TABLE t3 DROP COLUMN c0 ,MODIFY COLUMN c6 VARCHAR(100);
DESC t3;

--echo #删除列同时修改列及属性并新增列

ALTER TABLE t3 DROP COLUMN c12 ,MODIFY COLUMN c7 VARCHAR(50) DEFAULT 'A', ADD COLUMN c0 INT(5) ZEROFILL;


--echo #多个操作同时进行
--error 0,1235
ALTER TABLE t3 DROP COLUMN c0 ,ADD c99 int ,MODIFY COLUMN c9 varbinary(100),DROP COLUMN c16 ,ADD PRIMARY KEY(c1) ,DROP INDEX index_1;
--echo #删除列并同时修改表的并行度


ALTER TABLE t3 DROP COLUMN c2,PARALLEL 2;


ALTER TABLE t3 DROP COLUMN c4,PARALLEL 2;
#SHOW CREATE TABLE t3;

--echo #删除列的同时新增约束

ALTER TABLE t3 DROP COLUMN c3 ,ADD CONSTRAINT UNIQUE KEY(c1);

--echo #删除列并新增默认值约束

ALTER TABLE t3 DROP COLUMN c3, ALTER c16 SET DEFAULT 2022;
DESC t3;

INSERT INTO t3() VALUES();





--echo #使用as关键字创建复制表

DROP TABLE IF EXISTS t3;
CREATE TABLE t3 AS SELECT * FROM t1;
create index index_1 on t3(c1);
DESC t3;

ALTER TABLE t3 DROP COLUMN c0 ,MODIFY COLUMN c6 VARCHAR(500);

--echo #删除列并修改列属性
ALTER TABLE t3 DROP COLUMN c0 ,MODIFY COLUMN c6 VARCHAR(100);
DESC t3;
