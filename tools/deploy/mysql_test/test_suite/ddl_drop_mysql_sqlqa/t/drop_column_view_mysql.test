ALTER TABLE t2 ADD c9 INT AFTER c0,DROP c3,MODIFY c5 VARCHAR(15);
DESC v1;

UPDATE v1 SET c5='abcdefghig',c3='中9文' WHERE c2=1.1;
SELECT * FROM v1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;

ALTER TABLE t2 CHANGE c9 c9 INT(5) ZEROFILL AFTER c7,DROP c8,MODIFY c2 DOUBLE(5,0);

--error 0, 01356
DESC v1;
--error 0, 01356
UPDATE v1 SET c5='abcdefghig',c3='中9文' WHERE c2=1.1;
--error 0, 01356
SELECT * FROM v1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;


--echo #对基表进行删除操作

DROP VIEW IF EXISTS v1;
CREATE VIEW v1 AS SELECT t1.c0,t2.c2,t1.c3,t2.c4,t1.c5,t2.c6,t1.c7,t2.c9 FROM t1 JOIN t2 ON t1.c0=t2.c0;
SELECT * FROM v1 ORDER BY 1;
DESC v1;
#SHOW INDEX FROM v1;

ALTER TABLE t2 DROP INDEX ind_2,DROP c9;
--error 0, 01356
DESC v1;
--error 0, 01356
UPDATE v1 SET c5='abc',c3='中8文' WHERE c2=1.1;
--error 0, 01356
SELECT * FROM v1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;

--enable_parsing


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
DROP VIEW IF EXISTS v1;

--enable_warnings


