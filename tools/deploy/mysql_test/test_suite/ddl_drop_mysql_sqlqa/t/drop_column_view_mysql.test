CREATE INDEX ind_1 ON t1(c5);
CREATE INDEX ind_2 ON t2(c6,c7);


CREATE VIEW v1 AS SELECT t1.c0,t2.c1,t1.c3,t2.c4,t1.c5,t2.c6,t1.c7,t2.c8 FROM t1 JOIN t2 ON t1.c0=t2.c0;
SELECT * FROM v1 ORDER BY 1;
DESC v1;
#SHOW INDEX FROM v1;

--error 0, 01347
ALTER TABLE v1 DROP c1;

#ALTER TABLE t2 DROP c1;

--error 0, 01356
DESC v1;
