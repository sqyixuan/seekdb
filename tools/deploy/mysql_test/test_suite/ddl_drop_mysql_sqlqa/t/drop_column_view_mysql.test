--echo #CREATE DATA (DATA TYPE + INDEX + CONSTRAINT)

CREATE TABLE t1(c0 INT(5) ZEROFILL,
                c1 FLOAT AUTO_INCREMENT PRIMARY KEY,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
