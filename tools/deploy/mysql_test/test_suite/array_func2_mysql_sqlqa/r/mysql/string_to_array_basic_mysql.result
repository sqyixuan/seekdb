CREATE TABLE example_table (
id INT AUTO_INCREMENT PRIMARY KEY,
is_active BOOL,
tiny_value TINYINT,
small_value SMALLINT,
medium_value MEDIUMINT,
big_value BIGINT,
decimal_value DECIMAL(10, 2),
numeric_value NUMERIC(10, 2),
float_value FLOAT,
double_value DOUBLE,
bit_value BIT(1)
);
INSERT INTO example_table (is_active, tiny_value, small_value, medium_value, big_value, decimal_value, numeric_value, float_value, double_value, bit_value) 
VALUES 
(TRUE, 10, 100, 1000, 10000, 1234.56, 78.90, 1.23, 4.567, b'1'),
(FALSE, -10, -100, -1000, -10000, 4567.89, 12.34, 5.67, 8.910, b'0'),
(TRUE, 127, 32767, 8388607, 9223372036854775807, 9876.54, 98.76, 9.12, 3.456, b'1'),
(FALSE, -128, -32768, -8388608, -9223372036854775808, 1357.24, 46.68, 2.34, 7.890, b'0'),
(TRUE, 0, 0, 0, 0, 2468.80, 13.14, 8.76, 5.432, b'1');
