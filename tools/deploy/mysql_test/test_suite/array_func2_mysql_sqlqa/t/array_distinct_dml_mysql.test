##子查询
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,4],[1.2,2.3,6.9,-1.02],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,6],[1.123,2.3126,2.30,-0.25],[null,'a','sss']);
insert into t1 values(3,[7,1,5,9],[0.12345,null,966.66],['null','a','sss']);
insert into t1 values(4,[2,3,2,5],[2,3,3,5],[2,3,4,5]);
insert into t1 values(5,null,null,null);
select c1,(select array_distinct(t1.c4) from t1 order by c1 limit 1) from t1 order by c1;
select c1 from (select c1,array_distinct(c2+c3) c2 from t1 order by c1 limit 1) a order by a.c1;
select array_distinct(c2)  from (select c1,array_distinct([c2]) c2 from t1 order by c1 limit 1) a order by a.c1;
select array_distinct(t1.c2) from t1,(select c1,array_distinct([c2]) c2 from t1 order by c1 limit 1) a where a.c1=t1.c1 order by a.c1;


