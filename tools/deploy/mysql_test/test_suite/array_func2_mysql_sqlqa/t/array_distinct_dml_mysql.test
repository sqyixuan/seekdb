select c1,c2,c3,c4,array_distinct(c4) from t1 where array_distinct(c4) = ['中文ing123',1] for update;
select c1,c2,c3,c4,array_distinct(c4) from t1 where array_distinct([c4]) = [['中文ing123',1,'1']] ;
