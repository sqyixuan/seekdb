select count(*) from t1;
select count(*) from t2;

##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1(c2,c3,c4) values(array_distinct([12,3,4,31,1]) + array_distinct([12,3,4,31,1]),array_distinct([12,3,4,31,2])+array_distinct([12,3,4,31,2]),array_distinct([[12,3,4,31,'中文']]));
insert into t1(c2,c3,c4) values(array_distinct([12,3,4,31,1]) + array_distinct([12,3,4,31,1]),array_distinct([12,3,4,31,2])+array_distinct([12,3,4,31,2]),array_distinct([[12,3,4,31,'中文']]));
insert into t1(c2,c3,c4) values(array_distinct([12,3,4,31,1]) + array_distinct([12,3,4,31,1]),array_distinct([12,3,4,31,2])+array_distinct([12,3,4,31,2]),array_distinct([[12,3,4,31,'中文']]));
insert into t1(c2,c3,c4) values(array_distinct([12,3,4,31,1]) + array_distinct([12,3,4,31,1]),array_distinct([12,3,4,31,2])+array_distinct([12,3,4,31,2]),array_distinct([[12,3,4,31,'中文']]));

select c1,array_distinct(c2) from t1 order by c1;
select c1,array_distinct(c3) from t1 order by c1;
select c1,array_distinct(c4) from t1 order by c1;



