insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t2 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
