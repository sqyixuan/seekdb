insert IGNORE t1(c2,c3,c4) values(array_distinct([12,3,4,31,1]) + array_distinct([12,3,4,31,1]),array_distinct([12,3,4,31,2])+array_distinct([12,3,4,31,2]),array_distinct([[12,3,4,31,'中文']]));
