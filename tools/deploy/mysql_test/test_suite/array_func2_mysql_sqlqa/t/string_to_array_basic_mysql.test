insert into t1 values(2,'[2,2,3]',[3,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1 values(5,null,null);
insert into t1 values(6,'null',null);
select string_to_array('[1,1,2]',c2,c2) from t1 order by c1;
select string_to_array('[1,1,2]',c2,'null') from t1 order by c1;
select string_to_array(c2,'1','null') from t1 order by c1;
--error 5083
select string_to_array(c3,'1','null') from t1;

