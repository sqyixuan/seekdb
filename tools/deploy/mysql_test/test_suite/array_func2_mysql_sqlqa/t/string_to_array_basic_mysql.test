#owner: ht353245
#owner group: 多模
#description: string_to_array
#tags:array
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system set ob_vector_memory_limit_percentage =44;

##参数校验
##验证元素类型
--error 1582
select string_to_array(null);
select string_to_array(null, null);
select string_to_array(null,'null','null');
select string_to_array(null, null,null);
select string_to_array(null,',','null') ;

--error 1582
select string_to_array('');
select string_to_array(' ', ' ');
select string_to_array(' ', ' ',' ');
select string_to_array('中文ing123', ' ',' ');
select string_to_array('中文ing123', '123','123');
select string_to_array('A,I,H5,M',',');
select string_to_array('1中文123ing2,3', '中文');
select string_to_array('1中文123ing2,3', '123ing2,3');
select string_to_array('1 中文 123ing2,3', '中文 ');
select string_to_array('1 中文 123ing2,3', '中文 ','null');
select string_to_array("'中文ing123',1,'1'", ',') ;
select string_to_array("'中文ing123',1,'1'", 'null') ;

select string_to_array('[[[[[[test]],null],null],null]]',null);
select string_to_array('[[[[[[test]],null],null],null]]',',',null);
--error 5083
select string_to_array('中文', lpad('a',1000,'b'));
select string_to_array(lpad('a',1000,'b'), ',');

--error 5083
select string_to_array([[null],[null]],',');
--error 5083
select string_to_array([[null],[null]],'/','a');
select string_to_array('abc', ',');
select string_to_array('[12,3,4]', '[','[123123]');
select string_to_array('[12,3,4]', ']','12');
select string_to_array('[12,3,4]', '12,');
select string_to_array('apple123,banana456,789orang', ',');
select string_to_array('世界,你好', 'null');

select string_to_array('-oceanbase', '-');
select string_to_array('-oceanbase', 'null','-');
select string_to_array('+oceanbase', '+');
select string_to_array('oceanbase~', '~');
select string_to_array('oceanbase!', '!');
select string_to_array('oceanbase@', '@');
select string_to_array('oceanbase#', '#');
select string_to_array('oceanbase$', '$');
select string_to_array('oceanbase%', '%');
select string_to_array('oceanbase^', '^');
select string_to_array('oceanbase&', '&');
select string_to_array('oceanbase*', '*');


##存在乱码
select string_to_array('世界,你好', null);
select string_to_array('a/a/a/a', '/','a');
select string_to_array('A/A/A/A', 'a');
select string_to_array('A/A/A/A', 'A');
select string_to_array(lpad('a',100,'b'), 'a');
select string_to_array(lpad('a',100,'b'), null);

select string_to_array('[[世界你好],[xml]]', 'xml');
select string_to_array('[[[[[[世界,你好]]]]]]', ',');
select string_to_array('[[[[[[世界,你好]]]]]]', '[]');
select string_to_array('[[[[[[世界,你好]]]]]]', '[[[[[[');
select string_to_array('[[[[[[世界,你好]]]]]]', ']]]]]]');
select string_to_array('[[[[[[世界你好]]]]]]', ']]]]]]');
select string_to_array('[[[[[[世界你好]]]]]]', '世界你好');
select string_to_array('3.5555555555559999999999999999911111111111111111111110000000000000000000000000000000001', '3.5');
select string_to_array('$699','$');


##字符串函数
select string_to_array(UPPER('obclient您好！'), '您好');
select string_to_array(lower('oCeanBAse您好！'), 'oceanbase') ;


##array函数嵌套
select array_map((x)-> (string_to_array(lower('oCeanBAse您好！'), 'oceanbase')),[1])  from dual ;
--error 5083
select string_to_array(array_map((a) -> (a),[[[[[null,null,'null',1,2,3,'a','中文'],[null,null,null,1,2,false,'a','中文','中文',null]]]]]),'1') ;
select string_to_array(array_to_string([1,2,NULL,3], '-', 'N'),'1') ;
select array_to_string(string_to_array('1,中文,NULL,3', '-', 'N'),'1') ;

select array_remove(string_to_array('[1,2,NULL,3]', ','),"[1") ;
select array_remove(string_to_array('[1,2,NULL,3]', ','),"NULL") ;
select array_append(string_to_array('[1,2,NULL,3]', '-', 'N'),1) ;
--error 5083
select string_to_array(array_append([1,2,NULL,3], 1),'1') ;

--sorted_result
select * from unnest(string_to_array('[1,中文,NULL,3]', '-', 'N'));
--sorted_result
select * from unnest(string_to_array('[1,中文,NULL,3]', ',','null'));
--sorted_result
select * from unnest(string_to_array('[[[[[[[1,中文,[[NULL,3]]]]]]]', ',','null'));
--sorted_result
select * from unnest(string_to_array('null', ',','null'));



##数据类型验证
##数值类型
CREATE TABLE example_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    is_active BOOL,
    tiny_value TINYINT,
    small_value SMALLINT,
    medium_value MEDIUMINT,
    big_value BIGINT,
    decimal_value DECIMAL(10, 2),
    numeric_value NUMERIC(10, 2),
    float_value FLOAT,
    double_value DOUBLE,
    bit_value BIT(1)
);
INSERT INTO example_table (is_active, tiny_value, small_value, medium_value, big_value, decimal_value, numeric_value, float_value, double_value, bit_value) 
VALUES 
    (TRUE, 10, 100, 1000, 10000, 1234.56, 78.90, 1.23, 4.567, b'1'),
    (FALSE, -10, -100, -1000, -10000, 4567.89, 12.34, 5.67, 8.910, b'0'),
    (TRUE, 127, 32767, 8388607, 9223372036854775807, 9876.54, 98.76, 9.12, 3.456, b'1'),
    (FALSE, -128, -32768, -8388608, -9223372036854775808, 1357.24, 46.68, 2.34, 7.890, b'0'),
    (TRUE, 0, 0, 0, 0, 2468.80, 13.14, 8.76, 5.432, b'1');
--error 5083
select string_to_array(id,'1','null') from  example_table;
--error 5083
select string_to_array(is_active,'1','null') from  example_table;
--error 5083
select string_to_array(tiny_value,'1','null') from  example_table;
--error 5083
select string_to_array(small_value,'1','null') from  example_table;
--error 5083
select string_to_array(medium_value,'1','null') from  example_table;
--error 5083
select string_to_array(big_value,'1','null') from  example_table;
--error 5083
select string_to_array(decimal_value,'1','null') from  example_table;
--error 5083
select string_to_array(numeric_value,'1','null') from  example_table;
--error 5083
select string_to_array(float_value,'1','null') from  example_table;
--error 5083
select string_to_array(double_value,'1','null') from  example_table;
--error 5083
select string_to_array(bit_value,'1','null') from  example_table;


##时间类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 DATE,c3 TIME,c4 DATETIME(6),c5 TIMESTAMP,c6 YEAR);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (1, '2023-04-01', '12:34:56', '2023-04-01 12:34:56', '2023-04-01 12:34:56', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (2, '2023-04-02', '13:45:00', NULL, '2023-04-02 13:45:00', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (3, NULL, NULL, '2023-04-03 01:23:45', '2023-04-03 01:23:45', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (4, NULL, NULL, NULL, '2023-04-04 00:00:00', NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (5, '2023-04-05', '02:30:00', '2023-04-05 02:30:00', '2023-04-05 02:30:00', NULL);

--error 5083
select string_to_array(c1,'1','null') from t1;
--error 5083
select string_to_array(c2,'1','null') from t1;
--error 5083
select string_to_array(c3,'1','null') from t1;
--error 5083
select string_to_array(c4,'1','null') from t1;
--error 5083
select string_to_array(c5,'1','null') from t1;



##char + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3));
insert into t1 values(1,'[1,1,2]',[2,2,3]);
insert into t1 values(2,'[2,2,3]',[3,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1 values(5,null,null);
insert into t1 values(6,'null',null);
select string_to_array(c2,'1','null') from t1;

select string_to_array('[1,1,2]',c2,'null') from t1 order by c1;
--error 5083
select string_to_array(c3,'1','null') from t1;


##varchar + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
