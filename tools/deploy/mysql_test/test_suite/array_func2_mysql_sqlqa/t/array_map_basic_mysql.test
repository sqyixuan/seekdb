select array_map((x) -> (b), [1]) from test3;
select array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(x),x)),x)),x)),x)),x)),[[[[[[a]]]]]]) from test3;
select array_map((x) -> (array_map((x)->(x),x)), [[1]]) from test3;

