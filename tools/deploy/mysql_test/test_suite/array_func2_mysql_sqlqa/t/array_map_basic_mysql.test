insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);

select array_map((x)->([(array_map((x)->(x),x))]),[c3]) from t1 order by c1;
select array_map((x)->([(array_map((x)->(x),c2))]),[c3]) from t1 order by c1;
select array_map((x)->([(array_map((x)->(x),c3))]),[c3]) from t1 order by c1;
select array_map((x)->([(array_map((x)->(x),c4))]),[c3]) from t1 order by c1;

select array_map((x)->([(array_map((x)->([c2]),c2))]),[c3]) from t1 order by c1;
select array_map((x)->([(array_map((x)->([c3]),c3))]),[c3]) from t1 order by c1;
select array_map((x)->([(array_map((x)->([c4]),c4))]),[c3]) from t1 order by c1;


select array_map((x) -> (c2), [1]) from t1 order by c1;
select array_map((x) -> (c3), [1]) from t1 order by c1;
select array_map((x) -> (c4), [1]) from t1 order by c1;
select array_map((x) -> ([c2]), [1]) from t1 order by c1;
select array_map((x) -> ([c3]), [1]) from t1 order by c1;
