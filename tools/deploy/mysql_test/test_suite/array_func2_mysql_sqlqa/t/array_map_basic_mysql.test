##varchar + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 vector(3));
insert into t1 values(1,'[1,1,2]',[2,2,3]);
insert into t1 values(2,'[2,2,3]',[3,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1 values(5,null,null);
select array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(x),x)),x)),x)),x)),x)),[[[[[[c2]]]]]]) from t1 order by c1;
select array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(array_map((x)->(x),x)),x)),x)),x)),x)),[[[[[c3]]]]]) from t1 order by c1;
select array_map((x)->(array_map((x)->(x),x)),[c3]) from t1 order by c1;
select array_map((x) -> (c2), [1]) from t1 order by c1;
select array_map((x) -> (c3), [1]) from t1 order by c1;
select array_map((x)->((array_map((x)->(x),[c2]))),[c2]) from t1 order by c1;
select array_map((x)->((array_map((x)->(x),c3))),[c3]) from t1 order by c1;
select array_map((x)->((array_map((x)->(c2-c3),[x]))),[null]) from t1 order by c1;
select array_map((x)->((array_map((x)->(c2-c3),c3))),c3+c3) from t1 order by c1;
select array_map((x)->((array_map((x)->(c2-c3),c3))),c3+c2) from t1 order by c1;
select array_map((x)->((array_map((x)->(c2*c3),c3))),[c3]) from t1 order by c1;
select array_map((x)->((array_map((x)->(c2+c3+[11,2,3]),c3))),[c3]) from t1 order by c1;


