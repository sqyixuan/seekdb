##array类型嵌套
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
select array_append(c2,1) from t1 order by c1;
select array_append(c3,1) from t1 order by c1;
select array_append(c4,[1]) from t1 order by c1;
select array_append([c2],[1]) from t1 order by c1;
select array_append([c3],[1]) from t1 order by c1;
select array_append([c4],[[1]]) from t1 order by c1;
select array_append([c2],c2) from t1 order by c1;
select array_append([c3],c3) from t1 order by c1;
select array_append([c4],c4) from t1 order by c1;
select array_append([[[[c4]]]],[[[c4]]]) from t1 order by c1;
select array_append([[[[c4]]]],[[[[[null]]]]]) from t1 order by c1;


##json类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 json);
INSERT INTO t1 (c1, c2) VALUES (1, '{"name": "Alice", "age": 30}');
INSERT INTO t1 (c1, c2) VALUES (2, '[{"item": "apple"}, {"item": "banana"}]');
INSERT INTO t1 (c1, c2) VALUES (3, '{"person": {"name": "Bob", "details": {"age": 25, "city": "New York"}}}');
INSERT INTO t1 (c1, c2) VALUES (4, NULL);
INSERT INTO t1 (c1, c2) VALUES (5, '{}');
insert into t1 values(6,null);
--error 5083
select array_append(c2,1) from t1 order by c1;
--error 5083
select array_append(c2,c1) from t1 order by c1;
--error 1235
select array_append([c2],c1) from t1 order by c1;
--error 5083
select array_append([1],c2) from t1 order by c1;




##int[], varchar(256)[],bigint[],TINYINT[],float[],double[],SMALLINT[]
##select
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int[] , c2 varchar(256)[], c3 bigint[], c4 TINYINT[], c5 float[], c6 double[], c7 SMALLINT[],c8 int );
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values([1],['abc'],[999999999],[22],[1.123456],[2.2133],[1.123],1);
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(null,null,null,null,null,null,null,2);
select  array_append(c1,1)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c1,1)  from t1 order by c8;
select  array_append(c2,'abc')  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c2,'abc')  from t1 order by c8;
select  array_append(c3,999999999)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c3,999999999)  from t1 order by c8;
select  array_append(c4,22)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c4,22)  from t1 order by c8;
select  array_append(c5,1.123456)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c5,1.123456)  from t1 order by c8;
select  array_append(c6,2.2133)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c6,2.2133)  from t1 order by c8;
select  array_append(c7,1)  from t1 order by c8;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ array_append(c7,1)  from t1 order by c8;

--error 1064
select  c1,array_append(c7,1)  from t1 where array_append(c7,1)= [];
select  c1,array_append(c7,1)  from t1 where array_append(c7,1)= [1,1];
select  /*+ ENABLE_PARALLEL_DML PARALLEL(3) */array_append(c7,1)  from t1 where array_append(c7,1)= [1,1];
select  c1,array_append(c1,c8)  from t1 order by c8;
