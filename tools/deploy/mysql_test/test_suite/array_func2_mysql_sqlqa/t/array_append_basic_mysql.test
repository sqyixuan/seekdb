select  c1,array_append(c4,c8)  from t1 order by c8;
select  c1,array_append(c5,c8)  from t1 order by c8;
select  c1,array_append(c6,c8)  from t1 order by c8;
select  c1,array_append(c7,c8)  from t1 order by c8;


##array支持的元素类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 tinyint[],c2 tinyint UNSIGNED[],c3 smallint[],c4 smallint UNSIGNED[],c5 int[] ,c6 int UNSIGNED[],c7 int primary key) ;
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(1),array(0),array(-32768),array(65535),array(2147483647),array(0),1);
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(127),array(255),array(32767),array(65534),array(-2147483648),array(4294967295),2);
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(127),array(253),array(100),array(0),array(0),array(4294967294),3);
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(-128),array(10),array(null),array(32768),array(-65535),array(10000),4);
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(-127),array(null),array(0),array(null),array(null),array(null),6);
insert into t1(c1,c2,c3,c4,c5,c6,c7) values (array(null),array(80),array(1),array(1),array(10000000),array(2147),10);
select  c7,array_append(c1,1)  from t1 order by c7;
select  c7,array_append(c2,0)  from t1 order by c7;
select  c7,array_append(c3,-32768)  from t1 order by c7;
select  c7,array_append(c4,65535)  from t1 order by c7;
select  c7,array_append(c5,2147483647)  from t1 order by c7;
select  c7,array_append(c6,4294967295)  from t1 order by c7;

select  c7,array_append([c1],c1)  from t1 order by c7;
select  c7,array_append([c2],c2)  from t1 order by c7;
select  c7,array_append([c3],c3)  from t1 order by c7;
select  c7,array_append([c4],c4)  from t1 order by c7;
select  c7,array_append([c5],c5)  from t1 order by c7;
select  c7,array_append([c6],c6)  from t1 order by c7;



--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 float[],c2 float UNSIGNED[],c3 double[],c4 double UNSIGNED[],c5 varchar(30)[],c6 bigint[],c7 bigint UNSIGNED[],c8 int primary key AUTO_INCREMENT) ;
insert into t1 (c1,c2,c3,c4,c5,c6,c7) values([-3.402823466E+38, -1.175494351E-38],[1.175494351E-38,3.402823466E+38],[-1.7976931348623157E+308, -2.2250738585072014E-308],[2.2250738585072014E-308,1.7976931348623157E+308],['aaa'],[100],[10000]);
select  c7,array_append(c1,1)  from t1 order by c8;
select  c7,array_append(c2,0)  from t1 order by c8;
select  c7,array_append(c3,-32768)  from t1 order by c8;
select  c7,array_append(c4,65535)  from t1 order by c8;
select  c7,array_append(c5,2147483647)  from t1 order by c8;
select  c7,array_append(c6,4294967295)  from t1 order by c8;
select  c7,array_append(c7,4294967295)  from t1 order by c8;

select  c7,array_append([c1],c1)  from t1 order by c8;
