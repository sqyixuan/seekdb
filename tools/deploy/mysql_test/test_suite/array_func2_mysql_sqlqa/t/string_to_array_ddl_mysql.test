purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


alter system set ob_vector_memory_limit_percentage =44;

###create table/view as select 表达式
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select  string_to_array(null,'null','null') from dual ;
select * from t1;


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as   select string_to_array('中文ing123', '123','123');
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select string_to_array('中文ing123', ' ',' ');
select * from t1;
desc t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select string_to_array(lpad('a',512,'b'), 'b');
select * from t1;


--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select  string_to_array(null,'null','null') from dual ;
##导致core  已修复
select * from v1;


--disable_warnings
drop view if exists v1;
--enable_warnings
##create view v1 as   select string_to_array('中文ing123', '123','123');
##select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select string_to_array('中文ing123', ' ',' ');
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select string_to_array(lpad('a',512,'b'), 'b');
select * from v1;

##物化视图验证
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1  as select c1,string_to_array(c2,',') c2 from t1;
select * from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,string_to_array(c2,null) c2 from t1;
select * from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,c2,c3  from t1 where c3=string_to_array(c2,',') ;
select * from mv1 order by c1;
--sorted_result
select string_to_array(c2,',') from mv1 union  select string_to_array(c2,',') from t1;
--sorted_result
select string_to_array(a.c2,',') from mv1 a, t1 order by a.c1;


--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1, string_to_array(c2,',')c2,string_to_array(c2,',') c3,string_to_array(c2,',') c4 from t1;
##show create table mv1;
select string_to_array(t1.c2,',') from t1,mv1 where t1.c1=mv1.c1 order by t1.c1,mv1.c1;
select string_to_array(t1.c2,',') from t1,mv1 where t1.c3 =mv1.c2 order by t1.c1,mv1.c1;
select string_to_array(t1.c2,',') from t1,mv1 where array_distinct(t1.c3)=mv1.c3 order by t1.c1,mv1.c1;


##分区表
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

select string_to_array(a.c2,',') from t1 a,t1 b,t1 c where a.c3=b.c3 and b.c3=c.c3;
delete  from t1 partition(p0);
delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 ;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--sorted_result
select string_to_array(a.c2,',') from t1 a,t1 b,t1 c where a.c3=b.c3 and b.c3=c.c3;
delete  from t1 partition(p0);
delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where c3=string_to_array(c2,',');
delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where c3 =(select c3 from t1);

drop table t1;
create table t1(c1 int primary key,c2 bigint, c3 varchar(100),c4 double,c5 array(float),c6 int[])
PARTITION BY range COLUMNS(c1)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into t1 values(1,1,'test','1.2E-2',[1,525.12E-2],[1,2,3,4,5]);
insert into t1 values(2,1,'test1','1.5E-2',[1,523.12E-2],[1,2,3,4,5]);
insert into t1 values(3,1,'test2','1.5E-2',[1,523.12E-2],[1,2,3,4,5]);
insert into t1 values(4,2,'test3','142143144.5E-7',[1,523.12E-2],[1,6,3,4,5]);
insert into t1 values(5,2,'test4','142143144.5E-7',[1,523.12E-2],[1,2,3,4,5]);
insert into t1 values(6,null,'test4','142143144.5E-7',[1,523.12E-2],[5,2,3,4,5]);
insert into t1 values(7,null,'test5','142143144.5E-7',[1,523.12E-2],[1,2,3,4,5]);
insert into t1 values(8,3,'test6','142143144.5E-7',[1,523.12E+2,1,6,9],[1,2,3,4,5]);
insert into t1 values(9,3,'test6','142143144.5E-7',null,[1,2,3,4,5]);
insert into t1 values(20,3,null,'142143144.5E-7',null,[1,2,3,4,6]);

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select * from t1;
select string_to_array(c3,null) from mv1 order by c1;
--sorted_result
select string_to_array(t1.c3,',') from mv1 ,t1;
select count(string_to_array(c.c3,',')) from mv1 a,t1 b,t1 c;


##分区表旁路导入
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
replace /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select 3, 'a',string_to_array('zss121',',');
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,c2,string_to_array(c2,',') from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select 3, 'a',string_to_array('zss121',',');
insert /*+enable_parallel_dml parallel(2) */ into t1 select 3, 'a',string_to_array('zss121',',');
insert /*+enable_parallel_dml parallel(2) */ into t1 select c1,c2,string_to_array(c2,',') from t1;
select count(c2) from t1;

##视图
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select c1,c2,string_to_array(c2,',') from t1;
select * from v1 order by c1;

select count(string_to_array(v1.c2,',')) from t1,v1 order by t1.c1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select *  from t1 ;
select c1,c2,c3,string_to_array(v1.c2,',') from v1 where c3 is null order by c1;
select c1,c2,c3,string_to_array(v1.c2,',') from v1 where string_to_array(v1.c2,',') = v1.c3 order by c1;


##分区表视图
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select c1,c2,c3 from t1;
select * from v1 order by c1;
replace into t1 select c1,c2,string_to_array(v1.c2,',') from v1 ;
replace into v1 select c1,c2,string_to_array(t1.c2,',') from t1 ;
select count(*) from v1 order by c1;
select count(*) from t1 order by c1;



##函数索引/全文索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--error 3762
create index idx1 on t1((string_to_array(c2,',')));
--error 3762
create index idx1 on t1(c1,(string_to_array(c2,',')));

--error 1072
CREATE FULLTEXT INDEX idx1 ON t1((string_to_array(c2,',')));


##函数索引正交其他类型
