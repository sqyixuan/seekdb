##添加/删除STORED生成列

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[],c4 varchar(30)[] AS (string_to_array(c2,',')) STORED)partition by hash(c1) partitions 4;
INSERT INTO t1(c1,c2,c3) VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
select * from t1 order by c1;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[])partition by hash(c1) partitions 4;
INSERT INTO t1(c1,c2,c3) VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
ALTER TABLE t1 ADD COLUMN c5 varchar(256)[] AS (string_to_array(c2,',')) STORED;
--error 1366
ALTER TABLE t1 ADD COLUMN c6 int[] AS (string_to_array(c2,',')) STORED;
--error 1292
ALTER TABLE t1 ADD COLUMN c7 float[] AS (string_to_array(c2,',')) STORED;
##show create table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[],c4 varchar(30)[] AS (string_to_array(c2,'null')) STORED)partition by hash(c1) partitions 4;
INSERT INTO t1(c1,c2,c3) VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
select * from t1 order by c1;

