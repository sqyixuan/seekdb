##check约束
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 varchar(30),c3 varchar(30)[],check (c3=string_to_array(c2,',')))partition by hash(c1) partitions 4;
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--error 3819
insert into t1 values(3,'[null]',[2.123,2.123,3.123,4.123]);
