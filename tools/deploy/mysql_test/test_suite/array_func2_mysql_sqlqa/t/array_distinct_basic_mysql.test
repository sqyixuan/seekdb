##array类型嵌套
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);

select array_distinct([c2]) from t1 order by c1;
select array_distinct([c3]) from t1 order by c1;
select array_distinct([c4]) from t1 order by c1;
select array_distinct([[c2]]) from t1 order by c1;
select array_distinct([[c3]]) from t1 order by c1;
select array_distinct([[c4]]) from t1 order by c1;
select array_distinct([[[c2]]]) from t1 order by c1;
select array_distinct([[[c3]]]) from t1 order by c1;
select array_distinct([[[c4]]]) from t1 order by c1;

##json类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 json);
INSERT INTO t1 (c1, c2) VALUES (1, '{"name": "Alice", "age": 30}');
INSERT INTO t1 (c1, c2) VALUES (2, '[{"item": "apple"}, {"item": "banana"}]');
INSERT INTO t1 (c1, c2) VALUES (3, '{"person": {"name": "Bob", "details": {"age": 25, "city": "New York"}}}');
INSERT INTO t1 (c1, c2) VALUES (4, NULL);
INSERT INTO t1 (c1, c2) VALUES (5, '{}');
--error 5083
select array_distinct(c2) from t1;
--error 1235
select array_distinct([[c2]]) from t1;


##结合array其他表达式
select array_distinct(array_append([3,4], 3)) from dual;
select array_distinct(array_distinct([3,4,3])) from dual;
select array_distinct(array_Map((x) -> ([[[[1,2,3,3]]]]), [[[[[[1,2,3,2]]]]]])) from dual;
select array_distinct(array_remove([3,4], 3)) from dual;

select array_distinct([cardinality([3,4])]) from dual;
select array_distinct([element_at([3,4,3,4,5],2)]) from dual;
select array_distinct([element_at([3,4,3,4,5],0)]) from dual;
select array_distinct([array_contains_all([1,2,3], [2])]) from dual;
select array_distinct([array_overlaps([1,2,3], [2])]) from dual;
select array_distinct([array_overlaps([["hello", "world"], ["hi", "what"], ["are you?"]], [["are you?"]])]) from dual;
select array_distinct(string_to_array('1and2and2and', 'and')) from dual;
--error 1235
select array_distinct([ARRAY_TO_STRING([1,2,NULL,3], '-', 'N')]) from dual;
select array_distinct([null]) from unnest([1,2,3,2]);
select array_distinct([1,2,3,2,null]) from unnest([1,2,3,2,null]);

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);

select array_distinct(c4) from t1 order by c1;
select array_distinct([[[c2]]]) from t1 order by c1;
select array_distinct([[[c3]]]) from t1 order by c1;
##导致core
select array_distinct([[[c4]]]) from t1 order by c1;

alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);
select array_distinct(c2) from t1 order by c1;
select array_distinct(c3) from t1 order by c1;
select array_distinct(c4) from t1 order by c1;
select array_distinct(c4) from t1 order by c1;
select array_distinct([[[c2]]]) from t1 order by c1;
select array_distinct([[[c3]]]) from t1 order by c1;
##导致core 已修复
select array_distinct([[[c4]]]) from t1 order by c1;


