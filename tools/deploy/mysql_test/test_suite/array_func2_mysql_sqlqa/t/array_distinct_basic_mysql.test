##BLOB
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 BLOB,c3 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]');
insert into t1 values(2,'[2,2,3]','[3,2,3]');
