purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system set ob_vector_memory_limit_percentage =44;

##参数校验
##验证元素类型

select array_distinct(null);
--error 1582
select array_distinct(null,null);
select array_distinct([null,null]);
select array_distinct([null,'null']);
select array_distinct([null,'null','null',null]);
select array_distinct([' ','  a','  a']);
select array_distinct([' ','  a','  a','1']);
select array_distinct([' ','  a','  a',1,'+1']);
select array_distinct([1,2,3,+1,1/1,5+1,8+1,0,null,1/0]);
select array_distinct([1,2,3,+1,1/1,5+1,8+1,0,null,1/0,abs(-1)]);
select array_distinct([1,2,3,+1,1/1,5+1,8+1,0,null,1/0,abs(false)]);
select array_distinct([true,false,true,1,0,1,false]);
select array_distinct([null,1.01,1.02,1.03,1.00,1,0.1,null,-0.1,1.123]);
select array_distinct([1.01,1.02,1.03,1.00,1,0.1,null,-0.1,1.123,1.1230]);
select array_distinct([-1.01,-1.02,-1.03,-1.00,-1,-0.1,null,-0.1,-1.123,-1.1230]);
select array_distinct([1,2,3,4,5,1,1,3,4,5,6,10]);
select array_distinct(['a,b','a','b','A,B']);
select array_distinct([null,'false','true','oceanbase','1','true','null']);
select array_distinct([null,'false','true','oceanbase','1','true',null]);
select array_distinct([null,'false','true','oceanbase','1','true',null,'null']);
select array_distinct([1, 2.5, 2.5, true, false, true,2.555555555,2.555555555,2.55555555556]);
select array_distinct([[1,2,3,4,5,1,1,3,4,5,6,max(100)]]);
select array_distinct([(select max(100))]);
select array_distinct([(select max(100)),1]);
select array_distinct([(select null),null]);
select array_distinct([(select null),(select 1)]);
select array_distinct([(select null),(select null)]);
select array_distinct([(select array_distinct([1,2,3,null,5,1,1,1])),(select array_distinct([1,2,3,4,null,1,1,1]))]);
select array_distinct([(select array_distinct([1,2,3,null,5,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([null,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1]))]);

--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 as select array_distinct([[NULL,NULL],[null,null]]) a,array_distinct([[NULL,NULL]]) b;

--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 as select array_distinct([(select array_distinct([1,2,3,null,5,1,null,1])),(select array_distinct([1,2,3,4,null,1,null,1]))]);

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int);
insert into t1 values(1);
insert into t1 values(1);
insert into t1 values(null);
insert into t1 values(null);
select array_distinct([(select max(c1) from t1 limit 1)]) from t1 order by c1;

