##char + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3));
insert into t1 values(1,'[1,1,2]',[2,2,3]);
insert into t1 values(2,'[2,2,3]',[3,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1 values(5,null,null);
--error 5083
select array_distinct(c2) from t1;
--error 1235
select array_distinct([[[c2]]]) from t1;
##结果有误--已修复
select array_distinct(c3) from t1 order by c1;

##varchar + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 vector(3));
insert into t1 values(1,'[1,1,2]',[2,2,3]);
insert into t1 values(2,'[2,2,3]',[3,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1 values(5,null,null);
--error 5083
select array_distinct(c2) from t1;
select c3,array_distinct([[[c2]]]) from t1 order by c1;
##结果有误--已修复
select array_distinct(c3) from t1 order by c1;

