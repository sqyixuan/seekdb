INSERT IGNORE t1(c2,c3,c4) values(array_map((x) -> (1), [1])+ array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
INSERT IGNORE t1(c2,c3,c4) values(array_map((x) -> (1), [1])- array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
INSERT IGNORE t1(c2,c3,c4) values(array_map((x) -> (1), [1])* array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
select c1,array_map((x) -> (c2+c3), [1]) from t1 order by c1;

##INSERT ... ON DUPLICATE KEY UPDATE
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;
insert into t1(c1) values(5) ON DUPLICATE KEY UPDATE c4 = array_map((x) -> (c2+c3), [1]);

insert into t1(c1) values(5)ON DUPLICATE KEY UPDATE c2=array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3,4]),array_map(x1->(x1+2),[1,2,3,3])) ;
insert into t1(c1) values(2)ON DUPLICATE KEY UPDATE c2=array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3,5]),array_map(x1->(x1+2),[1,2,3,4])) ;
insert into t1(c2,c3,c4) values([1,2,3,3],[1,3,3,3],[[2,1,2,3]]) ON DUPLICATE KEY UPDATE c4=array_map((x) -> (c2+c3), [1]);
insert into t1(c2,c3,c4) values([1,6,3,3],[1,4,3,3],[[2,3,2,3]]) ON DUPLICATE KEY UPDATE c4=array_map((x) -> (c2+c3), [1]);

insert into t1(c1) values(5) ON DUPLICATE KEY UPDATE c4 = array_map((x) -> (c2+c3), [1]);
select array_map((x) -> (c2+c3), [1]) from t1 order by c1;


##insert overwrite
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;

insert /*+ parallel(10) */ overwrite t1(c4) select array_map((x) -> (c2+c3), [1]) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c4) select array_map((x) -> (x), [c2]) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c2) select array_map((x) -> (x), c2) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c2) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3]));
select * from t1;

##普通表旁路导入
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT , c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;
create view v1 as select * from t1;

insert /*+ direct(true,100) enable_parallel_dml parallel(2)*/ into v1 select c1,c2,c3,c4 from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c4) select array_map((x) -> (['1,2,3,4','中文','abc']), [1]) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2,c4) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])),array_map((x) -> (['1,2,3,4','中文','abc']), [1]) from t1;

select count(*) from t1;


##分区表旁路导入
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT , c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;

insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c4) select array_map((x) -> (['1,2,3,4','中文','abc']), [1]) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2,c4) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])),array_map((x) -> (['1,2,3,4','中文','abc']), [1]) from t1;

select count(*) from t1;
select count(array_map((x) -> (c4), [1])) from t1;
select count(array_map((x) -> (c3), [1])) from t1;
select count(array_map((x) -> (c2), [1])) from t1;



##delete 
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
