## for update
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;

select c1,c2,c3,c4 from t1 where array_map((x) -> (x), c2) = [1,2,3,5] ;
select c1,c2,c3,c4 from t1 where array_map((x) -> (x), c2) = [1,2,3,5] for update;

select c1,c2,c3,c4 from t1 where array_map((x) -> (x), c4) = ['中文ing123',1,'1'] ;
select c1,c2,c3,c4 from t1 where array_map((x) -> (x), c4) = ['中文ing123',1,'1'] for update;



select array_map((x) -> (c2), c3) from t1 order by t1.c1 for update;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */array_map((x) -> (c2), c3) from t1 order by t1.c1 for update;


select array_map((x) -> (t1.c2), t1.c3) from t1,t2 where t1.c2=t2.c2 order by t1.c1 for update;
select array_map((x) -> (t2.c2), t2.c4) from t1,t2 where t1.c2=t2.c2 order by t1.c1 for update;

select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */array_map((x) -> (t1.c2), t1.c3) from t1,t2 where t1.c2=t2.c2 order by t1.c1 for update;
select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */array_map((x) -> (t2.c2), t2.c4) from t1,t2 where t1.c2=t2.c2 order by t1.c1 for update;


