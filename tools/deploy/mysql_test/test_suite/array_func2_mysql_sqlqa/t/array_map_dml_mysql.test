select array_map((x) -> (x), c3) from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((x) -> (x), c3) from t1 order by c1;

select array_map((x) -> (c3), c3) from t1 order by c1;
#select /*+read_consistency(weak) */array_map((x) -> (c3), c3) from t1 order by c1;

select array_map((x) -> (c4), c3) from t1 order by c1;
#select /*+read_consistency(weak) */array_map((x) -> (c4), c3) from t1 order by c1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select array_map((x) -> (1), null);
##缺少)括号
##desc t1;


--disable_warnings
drop table if exists t1;
drop table if exists tt1;
--enable_warnings

CREATE TABLE t1 (c1 int , c2 int[]);
insert into t1 values(1,[1,false]);
insert into t1 values(2,[0,0]);
select array_map((x) -> (c1), [1]) from t1 order by c1;
select array_map((x) -> (c2+c2), c2) from t1 order by c1;
create table tt1 like t1;
insert into tt1 select /*+ enable_parallel_dml parallel(2) */* from t1 order by c1;
replace into tt1 select /*+ enable_parallel_dml parallel(2) */* from t1 order by c1;
select * from t1,tt1 where array_map((x) -> (tt1.c1), ['中二五年'])=array_map((x) -> (t1.c1), [1]) order by t1.c1,tt1.c1 ;
select * from t1 where array_map((x) -> (c2), [1])  =[[1,0]] order by t1.c1 ;

select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */array_map((c2) -> (c2), [1])  from t1 order by t1.c1 ;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_map((c2) -> (c2), [1]) from t1 order by t1.c1  ;
replace  into t1 select c1,array_map((c2) -> (c2), [1]) from t1 ;


