##insert into select/replace into select
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);


--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t2 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t2 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t2 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t2 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);

insert into t1(c4) select [[1,2,3]] from t2;
insert into t1(c4) select array_map((x) -> (c4), [1]) from t2;
insert into t1(c4) select array_map((x,y)->(x+y), array_map(x2->([x2+1]),[1,2,3]),array_map(x1->([x1+2]),[1,2,3])) ;
insert into t1(c2) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])) ;
replace into t1(c4) select [[1,2,3]] from t2;
replace into t1(c4) select array_map((x) -> (x), [['中文','a']]) from t2;
replace into t1(c4) select array_map((x,y)->(x+y), array_map(x2->([x2+1]),[1,2,3]),array_map(x1->([x1+2]),[1,2,3])) ;
replace into t1(c2) select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])) ;
select count(*) from t1 order by c1 ;

##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1(c2,c3,c4) values(array_map((x) -> (1), [1])+ array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
insert into t1(c2,c3,c4) values(array_map((x) -> (1), [1])- array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
insert into t1(c2,c3,c4) values(array_map((x) -> (1), [1])* array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
--error 5083
insert into t1(c2,c3,c4) values(array_map((x) -> (1), [1])/ array_map((x) -> (2), [1]),array_map((x) -> (2), [1])+array_map((x) -> (3), [1]),array_map((x) -> ([null]), [1]));
select c1,array_map((x) -> (c2+c3), [1]) from t1 order by c1;

##INSERT IGNORE
