##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
select array_map((x) -> (x), (select c4 from t1 order by c1 limit 1)) from t1 order by c1;
select array_map((x,y) -> (x+y), c2,c3+c2) from t1 order by c1;
select array_map((x,y) -> (x+y), c2,c3+[1,2,3,4]) from t1 order by c1;

select array_map((x,y) -> (x+y), c2,c3) +c2 from t1 order by c1;
select array_map((x,y) -> (x+y), c2,c3) +c3 from t1 order by c1;

select array_map((x,y) -> (x*y), c2,c3+c2) from t1 order by c1;
select array_map((x,y) -> (x*y), c2,c3+[1,2,3,4]) from t1 order by c1;

select array_map((x,y) -> (x*y), c2,c3) +c2 from t1 order by c1;
select array_map((x,y) -> (x*y), c2,c3) +c3 from t1 order by c1;


select array_map((x,y) -> (x-y), c2,c3+c2) from t1 order by c1;
select array_map((x,y) -> (x-y), c2,c3+[1,2,3,4]) from t1 order by c1;

select array_map((x,y) -> (x-y), c2,c3) +c2 from t1 order by c1;
select array_map((x,y) -> (x-y), c2,c3) +c3 from t1 order by c1;


select array_map((x,y) -> (x/y), c2,c3+c2) from t1 order by c1;
select array_map((x,y) -> (x/y), c2,c3+[1,2,3,4]) from t1 order by c1;

select array_map((x,y) -> (x/y), c2,c3) +c2 from t1 order by c1;
select array_map((x,y) -> (x/y), c2,c3) +c3 from t1 order by c1;

select array_map((x,y) -> (x/y+x*y-x), c2,c3+c2) from t1 order by c1;
select array_map((x,y) -> (x/y+x*y-x), c2,c3+[1,2,3,4]) from t1 order by c1;

select array_map((x,y) -> (x/y+x*y-x), c2,c3) +c2 from t1 order by c1;
select array_map((x,y) -> (x/y+x*y-x), c2,c3) +c3 from t1 order by c1;

