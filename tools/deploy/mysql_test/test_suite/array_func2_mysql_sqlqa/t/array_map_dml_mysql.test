delete from t1 where c2=array_map((x) -> (x), [null]) order by c1;
delete from t1 where c2=array_map((x) -> (x), [null]) limit 1;
delete from t1 where c4=array_map((x) -> (x), [[null,'a','sss']]);
delete from t1 where c3=array_map((x) -> (x), c3);
delete from t1;


