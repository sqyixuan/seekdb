select * from t1 order by element_at(c3,1) asc;
select * from t1 order by element_at(c4,1) asc;
select * from t1 order by element_at(c4,(select c1)) asc;



##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);


select element_at(c2+c2,1) from t1 order by c1;
select element_at(c3+c2,1) from t1 order by c1;
--error 1210
select element_at(c4+c2,1) from t1 order by c1;

select element_at(c2,2) + element_at(c2,3) from t1 order by c1;
select element_at(c2,3) - element_at(c2,2) from t1 order by c1;
select element_at(c2,4) * element_at(c2,4) from t1 order by c1;
select element_at(c2,1) / element_at(c2,2) from t1 order by c1;

select element_at(c2,2) + element_at(c2,3) - element_at(c3,3) from t1 order by c1;
select element_at(c2,3) - element_at(c2,2) - element_at(c3,3) from t1 order by c1;
select element_at(c2,4) * element_at(c2,4) - element_at(c3,3) from t1 order by c1;
select element_at(c2,1) / element_at(c2,2) - element_at(c3,3) from t1 order by c1;


select element_at(c2,2) + element_at(c2,3) / element_at(c3,3) from t1 order by c1;
select element_at(c2,3) - element_at(c2,2) * element_at(c3,3) from t1 order by c1;
select element_at(c2,4) * element_at(c2,4) - element_at(c3,3) from t1 order by c1;
select element_at(c2,1) / element_at(c2,2) + element_at(c3,3) from t1 order by c1;


##cast
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
select element_at(c2,cast(1 as json)) from t1 order by c1;
select element_at(c2,cast(1 as date)) from t1 order by c1;
select element_at(c2,cast(1 as TIME)) from t1 order by c1;
select element_at(c2,cast(1 as DATETIME(4))) from t1 order by c1;
select element_at(c2,cast(1 as DECIMAL(10,2))) from t1 order by c1;
select element_at(c2,cast(1 as char(20))) from t1 order by c1;
select element_at(c2,cast(1 as UNSIGNED)) from t1 order by c1;
select element_at(c2,cast(1 AS CHAR CHARACTER SET gbk)) from t1 order by c1;


##distinct
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
select  distinct element_at(c4,2) from t1 order by c1;
select  element_at(c2,(select distinct element_at(c2,1) from t1 order by c1 limit 1)) from t1 order by c1;
--error 1064
select  element_at(distinct c2,1) from t1 order by c1;
select  element_at((select c2 from t1 order by c1 limit 1),1) from t1 order by c1;
select  element_at((select [c4] from t1 order by c1 limit 1),1) from t1 order by c1;
select  element_at((select [[c4]] from t1 order by c1 limit 1),1) from t1 order by c1;

##聚合函数
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);

