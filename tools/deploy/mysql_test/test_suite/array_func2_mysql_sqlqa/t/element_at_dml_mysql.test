insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;

select array_map((x) -> (x), [(select element_at(c2,2) from t1 order by c1 limit 1)]);
select array_map((x) -> (x), [(select element_at(c3,2) from t1 order by c1 limit 1)]);
select array_map((x) -> (x), [(select element_at(c4,2) from t1 order by c1 limit 1)]);

--sorted_result
with ct1 as(
select element_at(c2,2) from t1 order by c1)
select element_at(c2,2) from t1 where c3 is not null order by c1 ;
--sorted_result
with ct1 as(
select  element_at(t1.c4,2) from t1 order by c1)
select  t1.c1,t2.c2,element_at(t1.c4,2) from t1 join t2 on element_at(t1.c4,2)=element_at(t1.c4,2) order by t1.c1,t1.c2;
--sorted_result
with ct1 as(
select  element_at(t1.c4,2) from t1 order by c1)
select  t1.c1,t2.c2,element_at(t1.c4,2) from t1 join t2 on element_at(t1.c4,2)<>element_at(t1.c4,2) order by t1.c1,t1.c2;

SELECT count(c4), CASE WHEN element_at([t1.c4],1)=['中文ing123',1,'1'] THEN [1,2,3] ELSE [2,3,4] END AS A FROM T1;
SELECT count(c1), CASE WHEN element_at([t1.c4],1)=['中文ing123',1,'1'] THEN element_at(t1.c4,2) ELSE element_at(t1.c3,3) END AS A FROM T1;

