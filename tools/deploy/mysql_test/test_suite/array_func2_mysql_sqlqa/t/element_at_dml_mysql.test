##insert overwrite
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;

insert /*+ parallel(10) */ overwrite t1(c4) select element_at([[[12,3,4,31,'中文']]],1) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c4) select element_at([[[12,3,4,31,'中文']]],1) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c2) select element_at([[12,3,4,31]],1) from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c2) select element_at([[12,3,4,32]],1);
select * from t1;

##普通表旁路导入
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT , c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;
create view v1 as select c2 from t1;

insert /*+ direct(true,100) enable_parallel_dml parallel(2)*/ into v1 select element_at([[12,3,4,32]],1) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select element_at([[12,3,4,32]],1) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c4) select element_at([[[12,3,4,31,'中文']]],1) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2,c4) select element_at([[12,3,4,32]],1), element_at([[[12,3,4,31,'中文']]],1) from t1;

select count(*) from t1;


