purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system set ob_vector_memory_limit_percentage =44;

##存在null值列
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(3,null,null,null);
select element_at(c2,1) from t1;
select element_at(c3,1) from t1;
select element_at(c4,1) from t1;


##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,4],[1.2,2.3,6.9,-1.02],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,6],[1.123,2.3126,2.30,-0.25],[null,'a','sss']);
insert into t1 values(3,[7,1,5,9],[0.12345,null,966.66],['null','a','sss']);
insert into t1 values(4,null,null,null);
select c1,c2,c3,element_at(c4,c1) from t1 where element_at(c4,1) = '中文ing123';
select c1,c2,c3,element_at(c3,1) from t1 where element_at(c3,1) = 0.12345;
select c1,c2,c3,element_at(c2,4) from t1 where element_at(c2,3) = 99999 order by c1;
select c1,c2,c3,c4 from t1 where c1 > element_at(c2,3) order by c1;
select c1,c2,c3,c4 from t1 where c1 < element_at(c2,3) order by c1;
select c1,c2,c3,c4 from t1 where c1 <= element_at(c2,3) order by c1;
select c1,c2,c3,c4 from t1 where c1 <> element_at(c2,3) order by c1;
select c1,c2,c3,c4 from t1 where c1 = element_at(c2,3) order by c1;

select c1,c2,c3,c4 from t1 where c1 between element_at(c2,1) and element_at(c3,1) ;
select c1,c2,c3,c4 from t1 where element_at(c2,1) like '%2%';
select c1,c2,c3,c4 from t1 where element_at(c3,1) like '%2%';
select c1,c2,c3,c4 from t1 where element_at(c4,1) like '%中文%';
select c1,c2,c3,c4 from t1 where element_at(c2,1) not like '%2%';
select c1,c2,c3,c4 from t1 where element_at(c3,1) not like '%2%';
select c1,c2,c3,c4 from t1 where element_at(c4,1) not like '%中文%';

select c1,c2,c3,c4,element_at(c4,1) from t1 where EXISTS (SELECT element_at(c4,1) FROM t1) order by c1;
select c1,c2,c3,c4,element_at(c4,1) from t1 where not EXISTS (SELECT element_at(c4,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 = any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 >= any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 <= any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 <> any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 != any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 > any (SELECT element_at(c2,1) FROM t1) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c1 < any (SELECT element_at(c2,1) FROM t1) order by c1;

select [element_at(c2,1),element_at(c3,1),element_at(c4,1)] from t1 order by c1 ;

SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c4 in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c3 in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c2 in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c2,1) from t1 where c1 in (element_at(c2,1),element_at(c2,2),element_at(c2,3)) order by c1;

SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c4 not in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c3 not in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c4,1) from t1 where c2 not in ([element_at(c4,1),element_at(c4,2),element_at(c4,3)]) order by c1;
SELECT c1,c2,c3,c4,element_at(c2,1) from t1 where c1 not in (element_at(c2,1),element_at(c2,2),element_at(c2,3)) order by c1;

##join
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,4],[1.2,2.3,6.9,-1.02],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,6],[1.123,2.3126,2.30,-0.25],[null,'a','sss']);
insert into t1 values(3,[7,1,5,9],[0.12345,null,966.66],['null','a','sss']);
insert into t1 values(4,null,null,null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t2;

##select /*+parallel(10)*/ element_at(c2,1) from t1 union  select element_at(c2,1) from ;
##select element_at(c3,1) from t1 union  select element_at(c3,1) from t2;
##select element_at(c4,1) from t1 union  select element_at(c4,1) from t2;
select * from t1,t2 where element_at(t1.c3,1)=element_at(t2.c3, 1) order by t1.c1,t2.c1;
##执行两次就core了 
select * from t1,t2 where element_at(t1.c3,2)<>element_at(t2.c3,2) order by t1.c1,t2.c1;

##select * from t1,t2 where t1.c3<>t2.c3 order by t1.c1,t2.c1;
--error 5083
select * from t1,t2 where t1.c3>t2.c3 order by t1.c1,t2.c1;
--error 5083
select * from t1,t2 where t1.c3<t2.c3 order by t1.c1,t2.c1;
select * from t1,t2 where element_at(t1.c3,1)>element_at(t2.c3, 1) order by t1.c1,t2.c1;
select * from t1,t2 where element_at(t1.c3,1)<element_at(t2.c3, 1) order by t1.c1,t2.c1;
select * from t1,t2 where element_at(t1.c3,1)<=>element_at(t2.c3, 1) order by t1.c1,t2.c1;


select t1.c1,element_at(t1.c3,1) from t1  join t2  on element_at(t1.c3,1)=element_at(t2.c3, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  inner join t2  on element_at(t1.c3,1)=element_at(t2.c3, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  right join t2  on element_at(t1.c3,1)=element_at(t2.c3, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  left join t2  on element_at(t1.c3,1)=element_at(t2.c3, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  cross  join t2 on element_at(t1.c3,1)=element_at(t2.c3, 1)  order by t1.c1;

select t1.c1,element_at(t1.c3,1) from t1  join t2  on element_at(t1.c4,1)=element_at(t2.c4, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  inner join t2  on element_at(t1.c4,1)=element_at(t2.c4, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  right join t2  on element_at(t1.c4,1)=element_at(t2.c4, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  left join t2  on element_at(t1.c4,1)=element_at(t2.c4, 1)  order by t1.c1;
select t1.c1,element_at(t1.c3,1) from t1  cross  join t2 on element_at(t1.c4,1)=element_at(t2.c4, 1)  order by t1.c1;


