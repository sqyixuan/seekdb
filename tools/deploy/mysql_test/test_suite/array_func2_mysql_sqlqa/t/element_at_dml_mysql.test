insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,[null],[null],[[null]]);
insert into t1(c1) values(6) ;

delete from t1 where c2=(select element_at([c2],1) from t1 order by c1 limit 1) order by c1;
delete from t1 where c4=element_at([[[null,'a','sss']]],1) ;
delete from t1 where c3=element_at([[4.123,2.123,3.123,4.123]],1);
delete from t1;
truncate table t1;
select * from t1;

