create index idx1 on t1((array_distinct([c1])));
--error 3762
create index idx2 on t1(c1,(array_distinct([c1])));
--error 3762
create index idx3 on t1((array_distinct(c2)));
--error 3762
create index idx4 on t1((array_distinct(c3)));
--error 3762
create index idx5 on t1((array_distinct(c4)));
--error 1072
