##check约束
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][],check (c2 = (array_distinct(array_distinct(c2)))));
--error 3819
insert into t1 values(1,[1,1,1,1],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[null],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);

select * from t1 a join t1 b where array_distinct([a.c2]) =array_distinct([b.c2]) order by a.c1;
select * from t1 a join t1 b where array_distinct([a.c2]) <>array_distinct([b.c2]) order by a.c1;



##添加/删除STORED生成列
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1(c1,c2,c3,c4) values(2,[12,3,4],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
ALTER TABLE t1 ADD COLUMN c5 varchar(256)[] AS (array_distinct(c2)) STORED;
ALTER TABLE t1 ADD COLUMN c6 int[] AS (array_distinct(c2)) STORED;
ALTER TABLE t1 ADD COLUMN c7 varchar(30)[][] AS (array_distinct(array_distinct(c4))) STORED;
ALTER TABLE t1 ADD COLUMN c8 vector(3) AS (array_distinct(c2)) STORED;
insert into t1(c1,c2,c3,c4) values(3,[1,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
##show create table t1;

select array_distinct(c5) from t1 order by c1;
select array_distinct(c6) from t1 order by c1;
select array_distinct(c7) from t1 order by c1;
select array_distinct(c8) from t1 order by c1;

