purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system set ob_vector_memory_limit_percentage =44;

###create table/view as select 表达式
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select array_distinct(null)  from dual ;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as   select  array_distinct([null])  from dual ; 
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select array_distinct([null,2,null,'[1]','null']) a  from dual ;
select * from t1;
desc t1;
select array_distinct([a])  from t1 ;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1264
create table t1 as  select array_distinct([999999999999999999999999]) a  from dual ;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select array_distinct([[1],[null]]) a;
select * from t1;
select array_distinct(a) from t1;


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as  select array_distinct(['中文','中文'])  a from dual ;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select array_distinct([null,null,'null',1,2,3,'a','中文',0,false,'中文']);
select * from t1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select array_distinct([null])  from dual ;
select * from v1;
#show create view v1;


--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as   select array_distinct([null,2,null,'[1]',2,3,'中文']) a  from dual ; 
select * from v1;
#show create table v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select array_distinct([999999999999999999999999]) a   from dual ;
select * from v1;


--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select array_distinct([[1],[null]]) a;
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select array_distinct([[['中文']]])  a from dual ;
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as  select array_distinct([null,null,'null',1,2,3,'a','中文']);
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select array_distinct([[1],[null]]) a;
select * from v1;
#--error 1356
#desc v1;


##物化视图验证
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,4,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,5,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);


--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,array_distinct(c2) c2 from t1;
select * from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,c2,c3,c4  from t1 where c4=array_distinct(c4) ;
select * from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
--error 1167
create materialized view mv1(primary key(c2))  as select c1,array_distinct(c2) c2  from t1 where c2 is not null;


--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1, c2 ,c3,c4 from t1 where c2 is not null;
select * from mv1 order by c1;

select array_distinct(t1.c2) from mv1,t1 where array_distinct(mv1.c4) =array_distinct(t1.c4) order by t1.c1;
select count(array_distinct(t1.c2)) from mv1,t1 where array_distinct(mv1.c4) <>array_distinct(t1.c4) order by t1.c1;


##分区表
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);

select array_distinct(c2) from t1 order by c1;
select array_distinct([c2]) from t1 order by c1;
select array_distinct(c3) from t1 order by c1;
select array_distinct([c3]) from t1 order by c1;
select array_distinct(c4) from t1 order by c1;
select array_distinct([c4]) from t1 order by c1;

##向量索引表
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY,c2 vector(3),c3 vector(3), c4 vector(3),c5 vector(3) AS (array_distinct([1,2,3,3,1,2])) STORED);
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
--error 3762
CREATE  INDEX idx  ON t1 ((array_distinct(c4)));

replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);
select * from t1 order by c1;
select array_distinct(c5) from t1 order by c1;
drop index vector_idx_c4 on t1;


alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);
select array_distinct(c4) from t1 order by c1;
##结果不符合预期  已修复
select array_distinct([c4]) from t1 order by c1;
select array_distinct([[c4]]) from t1 order by c1;
select array(array_distinct([c4])) from t1 order by c1;
select array_map((a) -> (array_distinct([a])),array_distinct([c4]))  from t1 order by c1;

select *,array_distinct(b.c4) from t1 a,t1 b where array_distinct(a.c4)=array_distinct(b.c4) order by l2_distance(b.c4, [1,2,3]) approximate limit 10;

select c1,[c2],[array_distinct([c4])],c4  from t1 where array_distinct(c2) =[1,-1,3] order by c1;
select c1,[c2],[array_distinct([c4])],c4  from t1 where array_distinct(c4) =[1,2,3]  order by c1;
select c1,[c2],[array_distinct([c4])],c4  from t1 where array_distinct([c4]) = array_distinct([c4]) order by c1;
select /*+enable_parallel_dml parallel(2) */array_distinct(c4)  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_distinct([c4])  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_distinct([[c4]])  from t1 order by c1;

##select /*+read_consistency(weak) */array_distinct(c4)  from t1 order by c1;
##select /*+read_consistency(weak) */array_distinct([c4])  from t1 order by c1;
##select /*+read_consistency(weak) */array_distinct([[c4]])  from t1 order by c1;

alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,2,3]');
replace into t1(c1, c2, c3,c4) values(2,'[1,-1,3]','[1,0,3]','[1,2,4]');
replace into t1(c1, c2, c3) values(3,'[1,-1,3]','[1,0,3]');
--error 1235
select * from t1  order by array_distinct([l2_distance(c4, [1,2,3])])  approximate limit 10;



##分区表旁路导入
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int ,  c2 varchar(256)[]) partition by hash(c1);
insert into t1 values(1,[1,1,1]);
insert into t1 values(2,null);
replace /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select 3, array_distinct([1,2,3,4,5,5]);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_distinct([1,2,3,4,5,5]) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_distinct([1,2,3,4,5,5]) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_distinct([1,2,3,4,5,5]) + array_distinct([1,2,3,4,5,5]) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_distinct([1,2,3,4,5,5]) * array_distinct([1,2,3,4,5,5]) from t1;
select /*+enable_parallel_dml parallel(2)*/count(*) from t1 a,t1 b where array_distinct(a.c2)=array_distinct(b.c2);
select count(*) from t1;


##视图
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert /*+ ENABLE_PARALLEL_DML parallel(25) */into t1 values(1,array_map((x,y) -> (x+y),[1,2,3,4],[0,0,0,1]),[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
select c1,c2,c4  from t1  where c2 =array_distinct(c2)  order by c1;
select c1,c2,c4  from t1  where c2+c2 =array_distinct(c2+c2)  order by c1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select c1,array_distinct(c4) c2 from t1 order by c1;
##show create table v1;
select v1.c2,array_distinct([c4]) from v1,t1 where t1.c4=v1.c2 order by v1.c1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select c1,c2,c4  from t1  where c2 =array_distinct(c2)  order by c1;
select * from v1 order by c1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select c1, array_distinct(c2)+ array_distinct(c2) from t1 order by c1;
##show create table v1;
select * from v1 order by c1;


##分区表视图
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]) partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,2,3,5]','[2.123,2.123,3.123,4.123]',[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select c1,c2,c3,c4 from t1;
select * from v1 order by c1;
