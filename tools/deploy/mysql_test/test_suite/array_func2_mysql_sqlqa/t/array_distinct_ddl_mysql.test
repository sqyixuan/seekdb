replace into t1 select c1,array_distinct(c3),c3,c4 from v1 ;
select * from t1 order by c1;
select array_distinct([c2]) from v1 order by c1;
select array_distinct([c3]) from v1 order by c1;
select array_distinct([c4]) from v1 order by c1;


