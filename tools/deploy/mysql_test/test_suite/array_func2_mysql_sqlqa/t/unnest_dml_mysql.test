insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select a1 from unnest([[2,0,4,2]])a(a1);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select a1 from unnest([[1,2,0,4]])a(a1);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select a1 from t1,unnest([c2])a(a1);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c4) select a1 from t1,unnest([[c2]])a(a1);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2,c4)  select a1,a2 from t1,unnest([c2],[[c2]])a(a1,a2);
