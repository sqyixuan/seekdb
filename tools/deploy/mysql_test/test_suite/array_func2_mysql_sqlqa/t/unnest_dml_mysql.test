##子查询  存在core
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,'[1,1,2]','[2,2,3]','[[1,3,2]]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[[2,3,2]]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[[4,3,3]]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[[2,3,1]]');
--sorted_result
select * from t1,(select * from unnest([[1,2,3]])) order by c1;
--sorted_result
select * from (select * from unnest([[1,2,3]])),t1 order by c1;
--sorted_result
select * from t1,(select unnest.* from t1,unnest([c2])) order by c1;
--sorted_result
select * from (select unnest.* from t1,unnest([c2])),t1 order by c1;


