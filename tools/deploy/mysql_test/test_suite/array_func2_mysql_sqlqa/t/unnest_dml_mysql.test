insert into t1 values(4,null,null,null);
--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
--error 1235
create materialized view mv1(primary key(c1))  as select * from unnest(t1.c2,t1.c3);
--error 1235
create materialized view mv1(primary key(c1))  as select * from t1,unnest(t1.c1,t1.c2);


