--sorted_result
select a1-a1 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;
--sorted_result
select a1+a1-c1 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;
--sorted_result
select a1/0 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;


