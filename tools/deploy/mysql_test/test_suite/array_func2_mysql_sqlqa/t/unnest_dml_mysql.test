insert into t1 values(5,null,null,null);
--error 1064
select * from t1,unnest(c2+c2) a(a1) order by c1,a3  ;
--sorted_result
select a1+a2 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;
--sorted_result
select a1*a1 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;
--sorted_result
select a1/a1 from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1,a3  ;
