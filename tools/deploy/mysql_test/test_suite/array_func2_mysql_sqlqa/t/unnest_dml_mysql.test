##with as, case when
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;
--sorted_result
with ct1 as(
select * from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1)
select * from t1,unnest(c2,c3,c4) a(a1,a2,a3) where c3 is not null order by c1 ;
--sorted_result
with ct1 as(
select  * from t1,unnest(c2,c3,c4) a(a1,a2,a3) order by c1)
select  * from t1 join unnest(c2,c3,c4) a(a1,a2,a3) on a.a1=t1.c1 order by t1.c1;

--error 1064
SELECT  CASE 1 WHEN 2 THEN (select 1),unnest([1]) ELSE (select 1),unnest([2]) END AS A FROM T1;
--error 1064
SELECT  CASE 1 WHEN 2 THEN (select 1) a,unnest([1]) ELSE (select 1),unnest([2]) END AS A FROM T1;


