purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


alter system set ob_vector_memory_limit_percentage =44;

##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
select string_to_array(c2, c2) from t1 order by c1 ;
select string_to_array(c2, ',') from t1 order by c1;
select c1,c2,c3,string_to_array(c2,null) from t1 where  string_to_array(c2, null) is null order by c1;


select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  = c3 order by c1;
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  <> c3 order by c1;
--error 5083
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  > c3 order by c1;
--error 5083
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  < c3 order by c1;
--error 5083
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  <= c3 order by c1;
--error 5083
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  >= c3 order by c1;
--error 5083
select c1,c2,c3,string_to_array(c2,',') from t1 where  string_to_array(c2, ',')  <=> c3 order by c1;

select c1,c2,c3,string_to_array(c2,',') from t1 where  [c2]  =string_to_array(c2, ',') order by c1;

--error 5083
select c1,c2,c3,c4 from t1 where [c2] between string_to_array(c2, ',') and string_to_array(c2, ',') ;
--error 5083
select c1,c2,c3,c4 from t1 where string_to_array(c2, ',') like '%2%';


select c1,c2,c3,string_to_array(c2, ',') from t1 where EXISTS (SELECT string_to_array(c2, ',') FROM t1) order by c1;
select c1,c2,c3,string_to_array(c2, ',') from t1 where not EXISTS (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 = any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 >= any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 <= any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 <> any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 != any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 > any (SELECT string_to_array(c2, ',') FROM t1) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 < any (SELECT string_to_array(c2, ',') FROM t1) order by c1;

select [string_to_array(c2, ','),string_to_array(c2, ','),string_to_array(c2, ',')] from t1 order by c1 ;
select [[[[[string_to_array(c2, ','),string_to_array(c2, ','),string_to_array(c2, ',')]]]]] from t1 order by c1 ;

SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 in (string_to_array(c2, ',')) order by c1;
--error 5083
SELECT c1,c2,c3,string_to_array(c2, ',') from t1 where c3 in (string_to_array(c2, ','),string_to_array(c2, ','),string_to_array(c2, ',')) order by c1;


##join
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t2;

