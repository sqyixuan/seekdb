##insert into select/replace into select
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int , c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (c1 int , c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t2 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

insert into t1(c3) select string_to_array(c2,',') from t2;

replace into t1(c3) select string_to_array(c2,',') from t2;

select count(*) from t1;
select count(*) from t2;


##INSERT IGNORE
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT IGNORE t1 VALUES (1,'中文1', string_to_array('aaaa',','));
select * from t1;

##INSERT ... ON DUPLICATE KEY UPDATE
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int , c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

insert into t1(c1) values(4) ON DUPLICATE KEY UPDATE c3 = string_to_array('zsss',',');

insert into t1(c1) values(5)ON DUPLICATE KEY UPDATE c3= string_to_array('zsss',',');
insert into t1(c1) values(5)ON DUPLICATE KEY UPDATE c3= string_to_array('zsss',',');

select count(string_to_array(c2,',')) from t1 order by c1;

##insert overwrite
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key AUTO_INCREMENT, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

insert /*+ parallel(10) */ overwrite t1(c3) select string_to_array('zsss',',') from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c3) select string_to_array('zsss',',') from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c3) select string_to_array('zsss',',') from t1 where c1>2;
insert /*+ parallel(10) */ overwrite t1(c3) select string_to_array('zsss',',');
select * from t1;

##普通表旁路导入
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
create view v1 as select c3 from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2)*/ into v1 select string_to_array(c2,',') from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c3) select string_to_array(c2,',') from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c3) select string_to_array(c2,',') from t1;
select count(*) from t1;

##delete 
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
insert into t1(c1) values(6) ;

delete from t1 where c3=(select string_to_array(c2,',') from t1 order by c1 limit 1) order by c1;
delete from t1 where string_to_array(c2,',') is null;

truncate table t1;
select * from t1;

