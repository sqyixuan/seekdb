##子查询
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
select c1,(select string_to_array(c2, ',') from t1 order by c1 limit 1) from t1 order by c1;
select c1 from (select c1,string_to_array(c2, ',') c2 from t1 order by c1 limit 1) a order by a.c1;
select string_to_array(c2, ',')  from (select c1,c2 from t1 order by c1 limit 1) a order by a.c1;
select * from t1,(select c1,string_to_array(c2, ',') c2 from t1 order by c1 limit 1) a where a.c1=t1.c1 order by a.c1;


