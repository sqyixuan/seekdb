##with as, case when
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;


with ct1 as(
select string_to_array(c2,',') from t1 order by c1)
select string_to_array(c2,',') from t1 where c3 is not null order by c1 ;

with ct1 as(
select  string_to_array(c2,',') from t1 order by c1)
select  count(string_to_array(t1.c2,',')) from t1 join t2 on string_to_array(t1.c2,',')=string_to_array(t1.c2,',') order by t1.c1,t1.c2;


