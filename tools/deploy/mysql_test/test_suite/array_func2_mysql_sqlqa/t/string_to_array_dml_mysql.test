##普通表和视图join
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

create view v1 as select * from t1;
select *,string_to_array(t1.c2, ',') from t1,v1 where string_to_array(t1.c2, ',')=v1.c3 order by t1.c1;
select *,string_to_array(t1.c2, ',') from t1,v1 where string_to_array(t1.c2, ',')<>v1.c3 order by t1.c1;
select string_to_array(v1.c2, ',') from v1 union select string_to_array(t1.c2, ',') from t1;
--error 5083
select /*+parallel(10)*/string_to_array(v1.c2, ',') from v1 union select string_to_array(t1.c2, ',') from t1;
--error 5083
select /*+parallel(10)*/c3 from v1 union select c3 from t1;


##普通表和物化视图join
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select * from t1;
select a.c1,string_to_array(a.c2, ',') from mv1 a,t1 b order by a.c1;
select /*+parallel(10)*/a.c1,string_to_array(a.c2, ',') from mv1 a,t1 b order by a.c1;

select string_to_array(mv1.c2, ',') from mv1 union select string_to_array(t1.c2, ',') from t1;
--error 5083
select /*+parallel(10)*/string_to_array(mv1.c2, ',') from mv1 union select string_to_array(t1.c2, ',') from t1;

select count(string_to_array(a.c2, ',')) from mv1 a,t1 b,mv1 c order by a.c1;
select  count(string_to_array(a.c2, ','))from mv1 a,t1 b,mv1 c order by a.c1;



##超过两表join
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 varchar(30)[]);
INSERT INTO t1 VALUES (1,'中文1', ['中文1']), (2,'中文2', ['中文2']), (3,'中文3', ['中文3']), (4,'中文4', ['中文4']), (5,null, null);
select count(*) from t1 a,t1 b,t1 c where string_to_array(a.c2, ',')=string_to_array(b.c2, ',') and string_to_array(a.c2, ',')=string_to_array(c.c2, ',');
select count(*) from t1 a,t1 b,t1 c where string_to_array(a.c2, ',')=string_to_array(b.c2, ',') or string_to_array(a.c2, ',')=string_to_array(c.c2, ',');
select count(*) from t1 a,t1 b,t1 c where string_to_array(a.c2, ',')=string_to_array(b.c2, ',') or string_to_array(a.c2, ',')=c.c3;

