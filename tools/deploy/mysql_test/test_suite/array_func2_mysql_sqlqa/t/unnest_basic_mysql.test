##array表达式嵌套
--sorted_result
select * from (select 1 a,[2] b) a,unnest((select * from unnest([[1,2,3,4]])),[1,2,3]) order by a;
--sorted_result
select * from (select [1] a,[2] b) a,unnest((select * from unnest([[1,2,3,4]])),[1,2,3]) order by a;
--sorted_result
select * from (select [[1]] a,[2] b) a(a1,b1),unnest((select * from unnest(a.a1)),[1,2,3]) order by a.a1;
--sorted_result
select * from unnest(array_distinct([1,2,1])) t1(c1), unnest(array_distinct([1,2,3,3,4,3,3,3,1,12,3,5])) as t2(c2);
--sorted_result
select * from unnest([1,2,3]) t1(c1), unnest(['11','22']) as t2(c2);
--sorted_result
select * from (select [1,2,3]) a(a1),(select [[1,2,3]]) b(b1),unnest(a.a1,b.b1);
--sorted_result
select * from (select [[1,2,3]]) a(a1),(select [[1,2,3]]) b(b1),unnest(a.a1,b.b1);
--sorted_result
select * from (select [1,2,3,4]) c(d),unnest([[d]],[[d]]) a(b1,b2),unnest(a.b1,a.b2);
--sorted_result
select * from (select 1) c(d),unnest([[d]],[[d]]) a(b1,b2),unnest(a.b1,a.b2);
--sorted_result
select * from (select null) c(d),unnest([[d]],[[d]]) a(b1,b2),unnest(a.b1,a.b2);
--sorted_result
select * from (select array_map((x) -> (x), [1,2,3,4,2,1])) c(d),unnest([[d]],[[d]]) a(b1,b2),unnest(a.b1,a.b2);
--sorted_result
select b1,b2 from (select array_map((x) -> (x), [1,2,3,4,2,1])) c(d),unnest([[d]],[[d]]) a(b1,b2),unnest(a.b1,a.b2);


--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 vector(3));
insert into t1(c1,c2,c3) values(1,'[1,1,2]',[2,2,3]);
insert into t1(c1,c2,c3) values(2,'[2,2,3]',[3,2,3]);
insert into t1(c1,c2,c3) values(3,'[29,2,2]',[3,2,3]);
insert into t1(c1,c2,c3) values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1(c1,c2,c3) values(5,null,null);
--sorted_result
select * from t1,unnest(c3,[c3],c3,c3,[c3],c3,[null],[[[[[c3]]]]],array_map((x,y) -> (x+y),[null],[null]))a(a1,a2,a3,a4,a5,a6,a7,a8,a9);
create table tt1 as select * from t1,unnest(c3,[c3],c3,c3,[c3],c3,[null],[[[[[c3]]]]]) a(a1,a2,a3,a4,a5,a6,a7,a8);
insert into tt1 select * from t1,unnest(c3,[c3],c3,c3,[c3],c3,[null],[[[[[c3]]]]]);
--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 as select * from unnest([1],[2,2],[3,3,3],[4,4,4,4]) a(a1,a2,a3,a4) order by a.a1;

##数据类型验证
##无符号定点类型
create table tt3(id DECIMAL,id1 DECIMAL  unsigned,id2 NUMERIC,id3 FIXED unsigned,id4 FIXED,id5 NUMERIC unsigned);
insert into tt3 values(1,2,3,4,5,6);
--error 3064
select * from tt3,unnest(id);
--error 3064
select * from tt3,unnest(id1);
--error 3064
select * from tt3,unnest(id2);
--error 3064
select * from tt3,unnest(id3);
--error 3064
select * from tt3,unnest(id4);
--error 3064
select * from tt3,unnest(id5);

select * from tt3,unnest([id]);
select * from tt3,unnest([id1]);
select * from tt3,unnest([id2]);
select * from tt3,unnest([id3]);
select * from tt3,unnest([id4]);
select * from tt3,unnest([id5]);


##无符号浮点类型
create table test3(a FLOAT unsigned,b double unsigned);
insert into test3 values(1.12,1.123);
--error 3064
select * from test3,unnest(a);
--error 3064
select * from test3,unnest(b);
select * from test3,unnest([a]);
select * from test3,unnest([b]);

##浮点类型
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 FLOAT[],c2 double[]);
insert into t1 values([1,2,1],[1]);
--sorted_result
select *  from t1,unnest(c1);
--sorted_result
select *  from t1,unnest(c2);


