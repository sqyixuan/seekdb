##ctas
--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 as select * from (select [[1,2,3,3,4,5]]) a(a1),unnest(a.a1) b(b);
select * from tt1 a,unnest(a.a1);
select * from tt1 a,tt1 b,unnest(a.a1);
desc tt1;
insert into tt1 select * from unnest([[[1]]],[[1]]);
replace into tt1 select * from unnest([[[1]]],[[1]]);

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 varchar(30),c3 vector(3));
insert into t1(c1,c2,c3) values(1,'[1,1,2]',[2,2,3]);
insert into t1(c1,c2,c3) values(2,'[2,2,3]',[3,2,3]);
insert into t1(c1,c2,c3) values(3,'[29,2,2]',[3,2,3]);
insert into t1(c1,c2,c3) values(4,'[-1,-2,-2]',[3,2,3]);
insert into t1(c1,c2,c3) values(5,null,null);
--sorted_result
select * from t1,unnest(c3,[c3],c3,c3,[c3],c3,[null],[[[[[c3]]]]]);
--sorted_result
select * from t1 a,t1 b,unnest(a.c3);
##必现core 已修复
--sorted_result
select * from t1 a,t1 b,unnest(a.c3,b.c3);

