##array类型嵌套
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
--sorted_result
select * from t1,unnest(c2,c3) order by c1;
--sorted_result
select * from t1,unnest([c2],[c3]) order by c1;
--sorted_result
select c3 from t1,unnest(c3) order by c1,unnest;
--sorted_result
select c3 from t1,unnest([c3],[c3]) order by c1;
--sorted_result
select c3 from t1,unnest(c4) order by c1;
--sorted_result
select c3 from t1,unnest([c4],[c4]) order by c1;
--sorted_result
select c3 from t1,unnest((select * from unnest([[1,2,3,4]])),[c4]) order by c1;

