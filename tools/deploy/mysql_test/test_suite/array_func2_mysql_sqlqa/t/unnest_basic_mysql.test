##char + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3),c4 int[]);
insert into t1 values(1,'[1,1,2]',[2,2,3],[1,2,3]);
insert into t1 values(2,'[2,2,3]',[3,2,3],[1,2,3]);
insert into t1 values(3,'[29,2,2]',[3,2,3],[1,2,3]);
insert into t1 values(4,'[-1,-2,-2]',[3,2,3],[1,2,3]);
insert into t1 values(5,null,null,null);
--error 1235
select * from t1,unnest([c2]) ;
--error 3064
