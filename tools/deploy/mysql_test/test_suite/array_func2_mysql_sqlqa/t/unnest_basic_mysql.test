##join
--sorted_result
select * from (select 1) a,unnest([1,2,3]);
--sorted_result
select * from (select 1) a,unnest([[1,2,3]]);
--sorted_result
select * from unnest([1,2,3]) union select * from unnest([1,2,3]);
--error 1210
select * from unnest([1,2,3]) union  select * from unnest([[1,2,3]]); 
--sorted_result
select * from unnest([[1,2,3]]) union select * from unnest([[1,2,3]]);
select * from (select [[1,2,3]])a,unnest([[1,2,3]]) union select * from (select [[1,2,3]])a,unnest([[1,2,3]]);
--sorted_result
select * from unnest([1,2,3]) union all select * from unnest([1,2,3]);
--sorted_result
select * from unnest([1,2,3]) union  select * from unnest([2,3,4]);
--sorted_result
select * from unnest([1,2,3])c,unnest(['a']) d union  select * from unnest(['中文']) a,unnest(['a']) b;
--error 1210
select * from unnest([1,2,3])c,unnest(['a']) d union all select * from unnest(['中文']) a,unnest([['a']]) b;
--error 1210
select * from unnest([[1,2,3]]) union   select * from unnest([1,2,3]);
--error 1210
select * from unnest([[1,2,3]]) union  all select * from unnest([1,2,3]);

