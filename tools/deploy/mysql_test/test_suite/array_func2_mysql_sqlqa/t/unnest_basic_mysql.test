select * from (select [1,'中文',3])a(c1),(select [1,2,3,213,1,23])b(c2),unnest(c1,c2);
--sorted_result
select * from (select [[1,'中文',3]])a(c1),(select [1,2,3,213,1,23])b(c2),unnest(c1,c2);

##列别名
