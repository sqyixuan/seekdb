purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


alter system set ob_vector_memory_limit_percentage =44;

###参数校验
--error 3064
select * from unnest(null);
--error 3064
select * from unnest('null');
--error 3064
select * from unnest('[NULL]');

select * from unnest([NULL]);
select * from unnest([NULL]);
select * from unnest([[[[[[NULL]]]]]],[[[[[[NULL]]]]]]);
select * from unnest([''], ['']);
select * from unnest([' '], [' ']);
select * from unnest([[1]], [['']]);
--sorted_result
select * from unnest([1,2,3]) order by unnest;
--sorted_result
select * from unnest([1,2,NULL,3], ['11',NULL,'22']);
--sorted_result
select * from unnest([[1,2],[3],NULL,[4,5,6]]) as t ;
--sorted_result
select * from unnest([[1,2],[3],NULL,[4,5,6]], ['hi','hello']) as t(c1,c2);
--sorted_result
select * from unnest([1,2,3]) t1(c1), unnest(['11','22']) as t2(c2);
--sorted_result
select * from unnest([[1,2],[3],NULL,[4,5,6]]) ;
--sorted_result
select * from unnest([[1]], [[' '],['a']]);
--sorted_result
select * from unnest([[1]], [[' '],[' a']]);
--sorted_result
select * from unnest(['中文ing','2','3','4',1,1,null], [[1,2]]);
--sorted_result
select * from unnest(['中文ing','2','3','4'], [['中文ing','中文ing','中文ing','中文ing']]);
--sorted_result
select * from unnest([['中文ing','2','3','4']], [['中文ing','中文ing','中文ing','中文ing']]);
--sorted_result
select * from unnest([['中文ing','2','3','4'],['中文ing','2','3','4']], [['中文ing','中文ing','中文ing','中文ing']]);
--sorted_result
select * from (select (1)) as t, unnest([['中文ing','2','3','4']], [[[[[['中文ing','中文ing','中文ing','中文ing']]]]]]);
--sorted_result
select * from (select (1)) as t, unnest([[(cast(100 as char(20)))]]);
--sorted_result
select * from unnest([1],[2,2],[3,3,3],[4,4,4,4]) a(a1,a2,a3,a4) order by a.a1,a.a2,a.a3,a.a4;
--error 3064
select * from (select null) a(a) ,unnest(a) ;

--sorted_result
select * from unnest([null], [null]);
--sorted_result
select * from unnest([null], [null,null,'']);
--sorted_result
select * from unnest([null], [null,null,''],[null,null,''],[null,null,''],[null,null,''],[null,null,''],[null,null,''],[null,null,''],[null,null,''],[1,2,3]);
--sorted_result
select * from (select 1) a, unnest([null,1,2,3],[[1,2,3,4]]);
--sorted_result
select * from (select 1) a, unnest([null,1,2,3],[[1,2,3,4]]) b(c1,c2),unnest([null,1,2,3],[[1,2,3,4]]) c(b1,b2);
--sorted_result
select * from (select 1) a, unnest([null,1,2,3],[[1,2,3,4]]) b(c1,c2),unnest([null,1,2,3],[[1,2,3,4]]) c(b1,b2),unnest([null,1,2,3],[[1,2,3,4]]) d(e1,e2);
--sorted_result
select * from (select [[[[[[1,2,3,4,'中文']]]]]]) a,unnest([[[[[1,2,3]]]]]);
--sorted_result
select * from (select null) a,unnest([[[[[1,2,3]]]]]);


alter system set ob_vector_memory_limit_percentage =44;
sleep 5;
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
--sorted_result
select * from t1,unnest(c2, c3) ;
--error 1064
select * from t1,unnest([[c2]], [c3],(select [max(1)]))) ;
--sorted_result
select * from unnest([1,2,4], [[1,1,2]]) a(c2,c3) ,t1 where a.c3=t1.c2 order by c1  ;
--sorted_result
select a.* from unnest([1,2,null,4], [false,true,2,1])a;
--sorted_result
select a.* from unnest([1,2,null,4], [false,true,2,1])a(a,b) order by a,b limit 0,100;

##多个select
