drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],['这家safasf']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,' '],[1]]);
insert into t1 values(5,null,null,null);
update t1 set c1=38 where c4=array_append([[2,3,4,' ']],[1]);
update t1 set c1=33 where c4=array_append([['null','a','sss']],['这家safasf']);
update t1 set c2=array_append([4.123,2.123,3.123],4.123) where c4 is null;
update t1 set c2=array_append([3,3,3,3],1111) where c1=1;
update t1 set c4=array_append([[3,3,3,3]],[null]) where c4 is null;
update t1 set c3=array_append([3,3,3,3],1.123) where c3 is null;
update t1 set c3=(select array_append([null],null) from dual ) where c2 is not null;
select * from t1 order by c1;



