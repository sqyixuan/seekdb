purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

alter system set ob_vector_memory_limit_percentage =44;

##存在null值列
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,false],[1.123,null,96666],['中文ing123','abc','1']);
insert into t1 values(2,[0,0,99999,null],[0.12345,null,966.66],[null,'a','sss']);
insert into t1 values(3,null,null,null);
select array_append([[1,2,3,4]],c4) from t1 order by c1;
select array_append([[1,2,3,4]],c3) from t1 order by c1;
select array_append([[1,2,3,4]],c2) from t1 order by c1;
select array_append(c4,null) from t1 order by c1;
select array_append(c4,1) from t1 order by c1;
select array_append(c4,'a') from t1 order by c1;
--error 5083
select array_append(c4,b'1011') from t1 order by c1;
select array_append(c3,null) from t1 order by c1;
select array_append(c3,1) from t1 order by c1;
select array_append(c3,'a') from t1 order by c1;
--error 5083
select array_append(c3,b'1011') from t1 order by c1;
select array_append(c2,null) from t1 order by c1;
select array_append(c2,1) from t1 order by c1;
select array_append(c2,'a') from t1 order by c1;
--error 5083
select array_append(c2,b'1011') from t1 order by c1;


