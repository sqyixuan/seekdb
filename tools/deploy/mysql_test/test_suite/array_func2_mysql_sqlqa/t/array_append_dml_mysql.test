select array_append(t1.c4, t1.c2),(select array_append(t1.c4, t1.c2) from t1 order by c1 limit 1) from t1 order by c1;
select array_append(a.c4, [c1]) from (select c1,array_append(t1.c4, t1.c2) c4 from t1 order by c1 limit 1) a order by a.c1;
select array_append(a.c4, [c1]) from (select c1,array_append(t1.c4, t1.c2) c4 from t1 order by c1 limit 1) a order by a.c1;
select array_append(a.c4, [c1]) from (select c1,array_append(t1.c4, t1.c2) c4 from t1 order by c1 limit 1) a order by a.c1;

