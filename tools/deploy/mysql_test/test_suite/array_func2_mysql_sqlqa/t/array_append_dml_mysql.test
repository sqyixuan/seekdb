insert into t1(c3) select array_append(c3,null) from t2;
insert into t1(c4) select array_append(c4,[null]) from t2;

replace into t1(c2) select array_append(c2,null) from t2;
replace into t1(c3) select array_append(c3,null) from t2;
replace into t1(c4) select array_append(c4,[null]) from t2;

select count(*) from t1 order by c1 ;


