##with as, case when
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],['中文ing123',1,'1']);
insert into t1 values(2,[2,3,4,4],[2.123,2.123,3.123,4.123],[null,'a','sss']);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],['null','a','sss']);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[2,3,4,5]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 like t1;
replace into t2 select * from t1;

with ct1 as(
select array_append(c2,1) from t1 order by c1)
select array_append(c2,1) from t1 where c3 is not null order by c1 ;

with ct1 as(
select array_append(c3,1) from t1 order by c1)
select array_append(c3,1) from t1 where c3 is not null order by c1 ;

with ct1 as(
select array_append(c4,1) from t1 order by c1)
select array_append(c4,1) from t1 where c3 is not null order by c1 ;

SELECT c2, CASE c2 WHEN array_append(c4,1) THEN 'High' ELSE 'Low' END AS A FROM T1 order by c1;

