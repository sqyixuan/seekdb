drop table if exists t1;
--enable_warnings
--disable_warnings
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT , c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1(c1) values(5) ;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select array_append([2,3,4,5],null) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c4) select array_append([[2,3,4,5]],[null]) from t1;
insert /*+ enable_parallel_dml parallel(2) */ into t1(c2) select array_append([2,3,4,5],null) from t1;
insert /*+ enable_parallel_dml parallel(2) */ into t1(c4) select array_append([[2,3,4,5]],[null]) from t1;

select count(*) from t1;



##delete 
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],[null]]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,[null],[null],[[null]]);
insert into t1(c1) values(6) ;

delete from t1 where c2=array_append([2,3,5],4) order by c1;
delete from t1 where c2=array_append([2,3,4],5) order by c1;
delete from t1 where c4=array_append([['null','a','sss']],[null]) limit 1;
delete from t1;


##hint使用
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,[null],[null],[[null]]);
insert into t1(c1) values(6) ;

select array_append(c2,null) from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */ array_append(c2,null) from t1 order by c1;


select array_append(c3,null) from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */ array_append(c3,null) from t1 order by c1;


select array_append(c3,null) from t1 order by c1;
##select /*+read_consistency(weak) */array_append(c3,null) from t1 order by c1;

select array_append(c4,[null]) from t1 order by c1;
##select /*+read_consistency(weak) */array_append(c4,[null]) from t1 order by c1;

