--enable_warnings
create table t2 like t1;
insert  into t2 select * from t1;
--error 5083
update t1 set t1.c2 =[1,2,4,2] where c4 in (select array_append([[2,3,4,' ']],[1]) from t1 inner join t2 on t1.c2=t2.c2 order by t1.c1 limit 1,1);

update t1 join t2 on array_append(t1.c2,111)=array_append(t2.c2,111) set t1.c4 =array_append([[2,3,4,' ']],[1]) where t1.c3 is not null;
update t1 set c2 = array_append([4.123,2.123,3.123],4.123) where c1 in (select t1.c1 from t1 inner join t2 on t1.c2=t2.c2 order by t1.c1 limit 1);
select * from t1 order by c1;


