insert into t1 values(2,[null],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
ALTER TABLE t1 ADD CONSTRAINT chk_salary CHECK (array_map((a) -> (a), c4) =[['中文ing123',1,'1']]);
insert into t1 values(3,[null],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
--error 3819
insert into t1 values(3,[null],[2.123,2.123,3.123,4.123],[['中文ing123',2,'1']]);
