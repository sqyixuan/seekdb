--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
create materialized view mv1  parallel 9 refresh fast on demand  as select c1 as c1,count(*) as cnt from t1 group by c1;
insert into t1 values(1,2);
insert into t1 values(2,null);
insert into t1 values(4,2);
update t1 set c1= 5 where c2 is null;
delete  from t1  where c2 is not null ;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from mlog$_t1 order by SEQUENCE$$;



##物化视图验证
DROP MATERIALIZED VIEW LOG ON t1;
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,array_map((x)->(array_map((x)->(x),c2)),c4) c2 from t1;
select * from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,c2,c3,c4  from t1 where c2=array_map((x) -> (x), c2);
select c1,array_map((z) -> (c2), c4),array_map((z) -> (c4), c2) from mv1 order by c1;
select array_map((x)->(array_map((x)->(x),c2)),c4) from mv1 order by c1;

select array_distinct(c4) from t1 order by c1;
select array_distinct([c4]) from t1 order by c1;
##导致core
select array_distinct([[c4]]) from t1 order by c1;
select array_distinct([[[c4]]]) from t1 order by c1;
select array_map((x) -> ([[c4]]), [1]) from t1 order by c1;
select array_map((x) -> ([[[c4]]]), [1]) from t1 order by c1;
select array_append([[[c4]]], [[[[2]]]]) from t1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,array_map((x) -> (x), c2) c2,array_map((x) -> (x), c4) c4  from t1 ;
select c1,array_map((z) -> (c2), c4),array_map((z) -> (c4), c2) from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,array_map((x,y) -> (x*y), c2,c2) c2  from t1 ;
select c1,array_map((z) -> (z), c2),array_map((z) -> (c2), c2) from mv1 order by c1;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select c1,array_map((x,y) -> (x), c2,c2) c2  from t1 ;

##分区表
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);

select array_map((x) -> ([[c1]]), [1]) from t1 order by c1;
select array_map((x) -> ([[c1]]), [1]) from t1 order by c1;
select array_map((x) -> ([[[c1]]]), [1]) from t1 order by c1;
select array_map((x) -> ([[c2]]), [1]) from t1 order by c1;
select array_map((x) -> ([[[c2]]]), [1]) from t1 order by c1;
select array_map((x) -> ([[c3]]), [1]) from t1 order by c1;
select array_map((x) -> ([[[c3]]]), [1]) from t1 order by c1;
select array_map((x) -> ([[c4]]), [1]) from t1 order by c1;
select array_map((x) -> ([[[c4]]]), [1]) from t1 order by c1;

select c1,c2,c3,array_map((x) -> (c2), [1]) from t1 where c2 = array_map((x) -> (x), [1,2,3,5]) order by c1;
select c1,c2,c3,array_map((x) -> ([[[c4]]]), c4) from t1 where c4 = array_map((x) -> (x), c4) order by c1;
select c1,c2,c3,array_map((x) -> (null), null) from t1 where c4 = array_map((x) -> (x), c4) order by c1;

select c1,c2,c3,array_map((x) -> (c2), [1]) from t1 where c2 = array_map((x) -> (x), [1,2,3,5]) order by c1;
select c1,c2,c3,array_map((x) -> ([[[c3]]]), c4) from t1 where c4 = array_map((x) -> (x), c4) order by c1;
select c1,c2,c3,array_map((x) -> (null), null) from t1 where c4 = array_map((x) -> (x), c4) order by c1;
select c1,c2,c3,array_map((x) -> ([[[c3]]]), c4) from t1 where c2 = array_map((x,y) -> (y), [1,1,1,1],[1,2,3,5]) order by c1;
select c1,c2,c3,array_map((x) -> ([x]), c4) from t1 where c2 = array_map((x,y) -> (x*y), [1,1,1,1],[1,2,3,5]) order by c1;


##向量索引表
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY,c2 vector(3),c3 vector(3), c4 vector(3),c5 int[] AS ([1,2,1,5]) STORED);
--error 3762
CREATE VECTOR INDEX vector_idx_c4  ON t1 ((array_map((x,y) -> (x*y),c2,c4)))  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
--error 3758
CREATE  INDEX idx_c5  ON t1 ((array_map((x,y) -> (x*y),c2,c4)));

alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);

select array(c3) from t1 order by c1;
select array_distinct(c3) from t1 order by c1;
select array_agg(c3) from t1 order by c1;
select array_map((a) -> ([a]),c3)  from t1 where c4= array_map((a) -> (a),c4)  order by c1;
select array_map((a) -> ([a]),c3)  from t1 where [[c2]]= array_map((a) -> ([c2]),c2)  order by c1;

alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);
select array_map((x) -> (x), sum(c3)) from t1 order by c1;
select array_map((x) -> (x), avg(c3)) from t1 order by c1;
--error 1235
select array_map((x) -> (sum(c3)), c2) from t1 order by c1;
--error 1235
select array_map((x) -> (avg(c3)), c2) from t1 order by c1;


select array(c3) from t1 order by c1;
select array_map((a) -> ([[[[c4+a]]]]),[c4])  from t1 order by c1;

select c1,[c2],[array_map((a) -> (a),c3)],c4  from t1 where array_map((a) -> (a),c4) = [1,2,3] order by c1;
select c1,[c2],[array_map((a) -> (a),c3)],c4  from t1 where array_map((a) -> ([a]),c4) = [[1],[2],[3]] order by c1;
select c1,[c2],[array_map((a) -> (a),c3)],c4  from t1 where array_map((a) -> ([[a]]),c4) = [[[1]],[[2]],[[3]]] order by c1;
select array_map((a) -> (a),c3)  from t1 order by c1;
select array_map((a) -> ([a]),[c4])  from t1 order by c1;
select array_map((a) -> (a),[c4])  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> (a),c3)  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> (a),c4)  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> ([c3]),[1])  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> ([c4]),[1])  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> ([[[[c4]]]]),[1])  from t1 order by c1;

#select /*+read_consistency(weak) */array_map((a) -> (a),c3)  from t1 order by c1;
#select /*+read_consistency(weak) */array_map((a) -> (a),c4)  from t1 order by c1;
#select /*+read_consistency(weak) */array_map((a) -> ([c3]),[1])  from t1 order by c1;
#select /*+read_consistency(weak) */array_map((a) -> ([c4]),[1])  from t1 order by c1;

alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,2,3]');
replace into t1(c1, c2, c3,c4) values(2,'[1,-1,3]','[1,0,3]','[1,2,4]');
replace into t1(c1, c2, c3) values(3,'[1,-1,3]','[1,0,3]');
--error 1235
select * from t1 order by l2_distance(array_map((a) -> (a),c4), [1,2,3]) APPROX limit 10;

select c1,c2,c3,c4 from t1 where c2 = [1,1,2] order by c1;
select c1,c2,c3,c4 from t1 where c2 = [1,1,2] order by c1 for update;


select array(c3) from t1 order by c1;
select array([[[[c2]]]]) from t1 order by c1;
select array(array(array(c3))) from t1 order by c1;
select array_map((a) -> (a),c3)  from t1  order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> (a),c3)  from t1 order by c1;
select /*+enable_parallel_dml parallel(2) */array_map((a) -> (a),c4)  from t1 order by c1;
#select /*+read_consistency(weak) */array_map((a) -> (a),c3)  from t1 order by c1;
#select /*+read_consistency(weak) */array_map((a) -> (a),c4)  from t1 order by c1;

select c1,c2,c3,array_map((x) -> (c2), [1,2,3]) from t1 where c2 = array_map((x) -> ((x)), [1,1,2]) order by c1;
select c1,c2,c3,array_map((x) -> (c3), [1]) from t1 where c3 = array_map((x) -> ((x)), [1,0,3]) order by c1;

select c1,c2,c3,c4 from t1 where array_map((x) -> (x),c2) = [1,1,2];
select c1,c2,c3,c4 from t1 where array_map((x) -> (x), c2) = [1,1,2] for update;


alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,2,3]');
replace into t1(c1, c2, c3,c4) values(2,'[1,-1,3]','[1,0,3]','[1,2,4]');
replace into t1(c1, c2, c3) values(3,'[1,-1,3]','[1,0,3]');
select array_map((x) -> ([[[(select array_map((x) -> ((x)), [c4]) from t1 limit 1)]]]), [23,23,100]) from t1 order by c1;

select c1,c2,c3,array_map((x) -> ([c4]), [1]) from t1 where c4 is null order by c1;
select c1,c2,c3,array_map((x) -> (x), c2) from t1 where array_map((x) -> ((x)), [c2]) = [c2] order by c1;
select c1,c2,c3,array_map((x) -> (x), c3) from t1 where array_map((x) -> ((x)), c3) = c3 order by c1;
select c1,c2,c3,array_map((x) -> (x), c4) from t1 where array_map((x) -> ((x)), c4) = c4 order by c1;

select c1,c2,c3,array_map((x) -> ([x]), c2) from t1 where array_map((x) -> ((x)), [c2]) = [c2] order by c1;
select c1,c2,c3,array_map((x) -> ([x]), c3) from t1 where array_map((x) -> ((x)), c3) = c3 order by c1;
select c1,c2,c3,array_map((x) -> ([x]), c4) from t1 where array_map((x) -> ((x)), c4) = c4 order by c1;

select c1,c2,c3,array_map((x) -> ([[[x]]]), c2) from t1 where array_map((x) -> ((x)), [c2]) = [c2] order by c1;
select c1,c2,c3,array_map((x) -> ([[[x]]]), c3) from t1 where array_map((x) -> ((x)), c3) = c3 order by c1;
select c1,c2,c3,array_map((x) -> ([[[x]]]), c4) from t1 where array_map((x) -> ((x)), c4) = c4 order by c1;

##分区表旁路导入
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int ,  c2 varchar(256)[][]) partition by hash(c1);
insert into t1 values(1,'[[1,1,1]]');
insert into t1 values(2,null);
replace /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select 3, [array_map((x,y)->(x/y),array_map((x,y)->(x+y),[2],[1]),array_map((x,y)->(x*y),[1],[2]))];

insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_map((a) -> (a),c2) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select 1,array_map((a) -> ([a]),[1]) ;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_map((a) -> (a),c2) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,array_map((a,b) -> (a*b),c2,c2) from t1;
insert /*+enable_parallel_dml parallel(2) */ into t1 select 1,array_map((a) -> ([a]),[1]) ;
insert /*+enable_parallel_dml parallel(2) */ into t1 select c1,array_map((a) -> (a),c2) from t1 ;
select count(c2) from t1;

