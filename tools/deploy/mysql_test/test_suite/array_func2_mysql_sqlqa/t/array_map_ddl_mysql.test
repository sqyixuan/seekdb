show index from t1;

##check约束
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][],check (c2=array_map((x,y) -> (x*y), c2,c2)));
