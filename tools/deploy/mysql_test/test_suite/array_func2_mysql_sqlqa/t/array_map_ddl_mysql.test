drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert /*+ ENABLE_PARALLEL_DML parallel(25) */into t1 values(1,array_map((x,y) -> (x+y),[1,2,3,4],[0,0,0,1]),[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
