select *  from t1  where c2 = array_map((x,y) -> (x/y),[null],[null]) ;
select *  from t1  where c2 = array_map((x,y) -> (x+y),[null],[null]) ;
select *  from t1  where c2 = array_map((x,y) -> (x-y),[null],[null]) ;
select *  from t1  where c2 = array_map((x,y) -> (x*y),[null],[null]) ;


--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select c1,c2,array_map((a) -> (a),[[[[[[null,null,'null',1,2,3,'a','中文'],c2]]]]])  from t1 ;
select * from v1 order by c1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select array_map((x) -> ([[[c4]]]), [1]) from t1 order by c1;
show create table v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select *  from t1  where c2 = array_map((x,y) -> (x+y),[1,2,3,4],[0,0,0,1]) ;
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create /*+ ENABLE_PARALLEL_DML parallel(25) */view v1 as select *  from t1  where c2 = array_map((x,y) -> (x/y),[null],[null]) ;
select * from v1;


--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select array_map((c1) -> (c1),[[[[[[null,null,'null',1,2,3,'a','中文'],c3]]]]])  from t1 ;
select * from v1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select *  from t1 ;
select c1,c2,c3,array_map((x) -> ([c4]), [1]) from v1 where c4 is null order by c1;
select c1,c2,c3,array_map((x) -> (x), c2) from v1 where array_map((x) -> ((x)), [c2]) = [c2] order by c1;
select c1,c2,c3,array_map((x) -> (x), c3) from v1 where array_map((x) -> ((x)), c3) = c3 order by c1;
select c1,c2,c3,array_map((x) -> (x), c4) from v1 where array_map((x) -> ((x)), c4) = c4 order by c1;


##分区表视图
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]) partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,2,3,5]','[2.123,2.123,3.123,4.123]',[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select c1,c2,c3,c4 from t1;
select * from v1 order by c1;
replace into t1 select c1,array_map((a) -> (c1),[1]),c3,c4 from v1 ;
replace into t1 select c1,array_map((a) -> (a+c1),[1]),c3,c4 from v1 ;
select * from t1 order by c1;
replace into v1 select c1,array_map((a) -> (a),c2),c3,c4 from t1 ;
replace into v1 select c1,c2,array_map((a) -> (a),c3),c4 from t1 ;
replace into v1 select c1,c2,c3,array_map((a) -> (a),c4) from v1 ;
select * from v1 order by c1;
select * from t1 order by c1;



##函数索引/全文索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][]);
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
--error 1235
create index idx1 on t1(c1,c2);
--error 3758
create index idx1 on t1(c1,(array_map((a) -> (a), c2)));

--error 3758
create index idx1 on t1((array_map((a) -> (a), c2)));
--error 3758
create index idx1 on t1((array_map((a) -> (a), c3)));
--error 3758
create index idx1 on t1((array_map((a) -> (a), c4)));

--error 1235
CREATE FULLTEXT INDEX idx1 ON t1(c4);
--error 1072
CREATE FULLTEXT INDEX idx1 ON t1((array_map((a) -> (c4), [1])));

