# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer, cross_validation

## 

--result_format 4

--disable_warnings
drop table if exists t1;
DROP TABLE IF EXISTS `bsds_bat_ctrl`;
DROP TABLE IF EXISTS `bsds_bat_file_body`;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 values (1,1,1), (2,2,2);
CREATE TABLE `bsds_bat_ctrl` (
  `ENT_NO` varchar(13) COLLATE utf8mb4_bin NOT NULL COMMENT '保险公司编码',
  `BAT_NO` varchar(40) COLLATE utf8mb4_bin NOT NULL COMMENT '批次号',
  `BK_NO` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '分行号',
  `OPER_NO` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '操作员',
  `ENT_BAT_NO` varchar(40) COLLATE utf8mb4_bin NOT NULL COMMENT '保险公司批次号',
  `FILE_NAME` varchar(100) COLLATE utf8mb4_bin NOT NULL COMMENT '文件名',
  `FILE_PATH` varchar(300) COLLATE utf8mb4_bin NOT NULL COMMENT '文件存放路径（文件存放的绝对路径）',
  `FILE_TYPE` varchar(10) COLLATE utf8mb4_bin NOT NULL COMMENT '文件类型',
  `RET_FILE` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结果文件',
  `IMP_BUS_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '导入业务日期（银行方受理该批次/文件的业务日期）',
  `IMP_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '导入日期（银行方受理该批次/文件的自然日期）',
  `IMP_TIME` char(6) COLLATE utf8mb4_bin NOT NULL COMMENT '导入时间（银行方受理该批次/文件的自然时间）',
  `BUS_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '业务日期',
  `START_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '开始日期',
  `START_TIME` char(6) COLLATE utf8mb4_bin NOT NULL COMMENT '开始时间',
  `DEAL_BUS_DATE` char(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '处理业务日期（银行方处理该批次/文件的业务日期）',
  `END_DATE` char(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结束日期',
  `END_TIME` char(6) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结束时间',
  `DC_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收付标志(D：代收；C：代付 E： 存量签约批量文件；)',
  `HOST_BAT_NO` char(24) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '核心批次号',
  `HOST_FILE` char(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '上送核心文件',
  `HOST_RET_FILE` char(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '核心结果文件',
  `DEAL_STATS` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '处理状态(0：等待处理 1：正在处理； 2：等待人工处理； 3：处理完毕； 9: 预授权) ',
  `BAT_STATS` char(1) COLLATE utf8mb4_bin NOT NULL COMMENT '批量状态',
  `TOTAL_NUM` int(11) NOT NULL COMMENT '总笔数',
  `TOTAL_AMT` decimal(18,2) NOT NULL COMMENT '总金额',
  `SUCC_NUM` int(11) DEFAULT NULL COMMENT '成功笔数',
  `SUCC_AMT` decimal(18,2) DEFAULT NULL COMMENT '成功金额',
  `FAIL_NUM` int(11) DEFAULT NULL COMMENT '失败笔数',
  `FAIL_AMT` decimal(18,2) DEFAULT NULL COMMENT '失败金额',
  `ERR_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '错误码',
  `ERR_MSG` varchar(1500) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '错误信息',
  `HAND_STATS` char(1) COLLATE utf8mb4_bin DEFAULT '1' COMMENT '0-总公司 1分公司',
  `PAY_REC_CHANNEL` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收付款渠道:7-城银',
  `DEAL_IP` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `BK_FLAG` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '1-行内；2-行外',
  `CLEAR_CHANNEL` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '1-杭州集代；2-上海集代；3-综合服务平台',
  `UPDATE_TIME` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '更新时间',
  PRIMARY KEY (`ENT_NO`, `BAT_NO`),
  KEY `BAT_NO_1` (`BAT_NO`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_CTRL_BUS_DATE_INDEX` (`BUS_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_CTRL_DC_FLAG_INDEX` (`DC_FLAG`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_CTRL_DEAL_STATS_INDEX` (`DEAL_STATS`, `BAT_STATS`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_CTRL_START_DATE_INDEX` (`START_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `START_DATE_TIME` (`START_DATE`, `START_TIME`) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `bsds_bat_file_body` (
  `ENT_NO` varchar(13) COLLATE utf8mb4_bin NOT NULL COMMENT '保险公司编码',
  `BAT_NO` varchar(40) COLLATE utf8mb4_bin NOT NULL COMMENT '批次号',
  `SEQ_NO` int(11) NOT NULL COMMENT '明细序号',
  `BUS_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '业务日期',
  `BUS_SEQ_NO` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '业务流水号',
  `ENT_BUS_DATE` char(8) COLLATE utf8mb4_bin NOT NULL COMMENT '保险公司业务日期',
  `ENT_SEQ` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '保险公司流水号',
  `APPLY_NO` varchar(35) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '投保单号',
  `POL_NO` varchar(35) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '保单号',
  `CUS_NAME` varchar(150) COLLATE utf8mb4_bin NOT NULL COMMENT '客户姓名',
  `ID_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '证件种类',
  `ID_NO` varchar(60) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '证件号码',
  `AGREEMENT_NO` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '协议编号',
  `EP_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT 'P' COMMENT '公私标志(E：对公；P：对私；)',
  `BK_FLAG` char(1) COLLATE utf8mb4_bin NOT NULL COMMENT '银行标志(1-交通银行 2-非交通银行)',
  `DS_BK_NO` char(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收款行行号(银行标志为2时该字段必输)',
  `PRD_NAME` varchar(300) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '险种名称',
  `ACT_NO` varchar(40) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账号',
  `CURRENCY` char(3) COLLATE utf8mb4_bin NOT NULL DEFAULT 'CNY' COMMENT '币种',
  `AMT` decimal(15,2) NOT NULL COMMENT '金额',
  `DTL_STATS` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '明细状态(F：成功；E：失败)',
  `EXTERNAL_SYS_SEQ` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外系统流水号',
  `EXTERNAL_SYS_DATE` char(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外系统会计日期',
  `DC_TYPE` char(3) COLLATE utf8mb4_bin NOT NULL COMMENT '收付种类',
  `MOBILE` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '手机号码',
  `DC_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收付标志(D：代收C：代付)',
  `MSG_TYPE` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应答类型(N：交易成功；E：交易失败)',
  `ERR_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '错误码',
  `ERR_MSG` varchar(1500) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '错误信息',
  `EXT_001` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '启用预留字段01留存附言信息',
  `EXT_002` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '启用预留字段02保存特殊防重字段',
  `EXT_003` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段03',
  `EXT_004` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段04',
  `EXT_005` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段05',
  `EXT_006` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段06',
  `EXT_007` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段07',
  `EXT_008` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段08',
  `EXT_009` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段09',
  `EXT_010` varchar(150) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '预留字段10',
  `HOST_SEQ` varchar(40) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '核心会计流水号',
  `HOST_DATE` char(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '核心会计日期',
  `PAY_REC_CHANNEL` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收付款渠道（1本行、2银联、3大额支付系统、4超网）',
  `AGREEMENT_NO_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL,
  `END_DATE` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易终态日期',
  `END_TIME` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易终态时间',
  `RCBP_SEQ_NO` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `CLEAR_CHANNEL` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '1-杭州集代；2-上海集代；3-综合服务平台',
  PRIMARY KEY (`ENT_NO`, `BAT_NO`, `SEQ_NO`),
  KEY `BAT_FILE_BODY_END_DATE` (`END_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_ACT_NO` (`ACT_NO`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_AGREEMENT_NO` (`AGREEMENT_NO`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_BK_FLAG_INDEX` (`BK_FLAG`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_BUS_DATE_INDEX` (`BUS_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_DC_FLAG_INDEX` (`DC_FLAG`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_ENT_BUS_DATE_INDEX` (`ENT_BUS_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_ENT_SEQ_INDEX` (`ENT_SEQ`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_IDX_BAT_NO` (`BAT_NO`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_IDX_ENT_NO` (`ENT_NO`) BLOCK_SIZE 16384 LOCAL,
  KEY `BSDS_BAT_FILE_BODY_MSG_TYPE_INDEX` (`MSG_TYPE`) BLOCK_SIZE 16384 LOCAL
);

--explain_protocol 1

select distinct a.*, row_number() over(partition by a.c2) from t1 a, t1 b;

SELECT
      distinct a.ENT_NO as "entNo",
      a.ENT_BAT_NO as "entBatNo",
      a.BAT_NO as "batNo",
      a.BK_NO as "bkNo",
      a.HOST_BAT_NO as "hostBatNo",
      a.TOTAL_NUM as "totalNum",
      a.TOTAL_AMT as "totalAmt",
      a.DEAL_IP as "dealIp",
      a.DEAL_STATS,
      a.BAT_STATS,
	  b.BK_FLAG,
	  ROW_NUMBER() OVER (
        ORDER BY
          a.START_DATE,
          a.START_TIME
      ) AS ROW
    FROM
      bsds_bat_ctrl a,
	  BSDS_BAT_FILE_BODY b
    WHERE
      a.DC_FLAG = 'C'
      AND a.DEAL_STATS = '1'
      AND a.BAT_STATS = '2'
      AND a.BAT_NO = b.BAT_NO
      AND a.ENT_NO = b.ENT_NO
      AND b.BK_FLAG = '1'
      AND a.DEAL_IP = '12.244.197.234';

drop table if exists t1;
DROP TABLE IF EXISTS `bsds_bat_ctrl`;
DROP TABLE IF EXISTS `bsds_bat_file_body`;
