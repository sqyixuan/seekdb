# owner group: SQL1
# tags: optimizer, cross_validation

## 

--disable_warnings
drop table if exists sms_rpt_230202;
--enable_warnings

CREATE TABLE `sms_rpt_230202` (
  `Id` int(11) NOT NULL AUTO_INCREMENT COMMENT '自动标识列',
  `Channel` int(11) DEFAULT '0' COMMENT '通道编码',
  `AppCode` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '状态应用编码',
  `MsgId` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '平台消息Id',
  `MsgId_` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '网关消息Id',
  `Phone` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '手机号',
  `RptType` int(1) DEFAULT '0' COMMENT '状态类型，0正常，1补发',
  `RptCode` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '状态码',
  `RptState` int(1) DEFAULT '0' COMMENT '状态报告状态，0成功，1失败',
  `ReceiveTime` datetime(3) DEFAULT NULL COMMENT '平台状态接收时间',
  `EndTime` datetime(3) DEFAULT NULL COMMENT '语音结束时间',
  `ChannelTime` datetime(3) DEFAULT NULL COMMENT '通道状态报告时间',
  `InsertTime` datetime(3) DEFAULT CURRENT_TIMESTAMP(3) COMMENT '入库时间',
  `ProductCode` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '产品编码',
  `SpNumCode` varchar(24) COLLATE utf8mb4_bin DEFAULT '' COMMENT '接入号编码',
  `Account` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账号',
  PRIMARY KEY (`Id`),
  KEY `i_Channel` (`Channel`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_Phone` (`Phone`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_MsgId` (`MsgId`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_MsgId_` (`MsgId_`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_RptType` (`RptType`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_RptCode` (`RptCode`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_RptState` (`RptState`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_ProductCode` (`ProductCode`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_SpNumCode` (`SpNumCode`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_Account` (`Account`) BLOCK_SIZE 16384 LOCAL
);

call dbms_stats.gather_table_stats('TEST', 'sms_rpt_230202');

