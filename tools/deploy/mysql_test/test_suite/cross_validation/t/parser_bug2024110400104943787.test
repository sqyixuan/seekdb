# owner: zhanyue.zzy
# owner group: SQL1
# description: query use force or cascade as column core when in parser

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (`force` int, `cascade` int);

select `force` from t1;
--error 1064
select force from t1;
select `cascade` from t1;
--error 1064
select cascade from t1;

drop table t1;
