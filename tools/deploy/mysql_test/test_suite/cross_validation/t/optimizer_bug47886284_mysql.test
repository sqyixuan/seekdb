# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer, cross_validation

--result_format 4

## 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 2;

insert into t1
with recursive cte as 
(select 1 as c1 union all select c1+1 from cte where c1 < 100)
select c1, c1, c1 from cte;

explain basic
SELECT /*+ parallel(2) */ c1, min((85 + 866)) OVER (ORDER BY (85 + 866) DESC)
FROM t1 ORDER BY c1 limit 10;

SELECT /*+ parallel(2) */ c1, min((85 + 866)) OVER (ORDER BY (85 + 866) DESC)
FROM t1 ORDER BY c1 limit 10;

drop table t1;

## 
--disable_warnings
drop table if exists t10, t20;
--enable_warnings
create table t10 (c1 NUMERIC(64,19) ,c2 VARBINARY(80) ,c3 NUMERIC(64,17) ,c4 BINARY(56) ,c5 INT(127) ,c6 BIGINT(127) ,c7 YEAR(4) ,c8 YEAR(4) ,c9 CHAR(152) ,c10 DATETIME,c11 YEAR(4) ,c12 CHAR(152) ,c13 VARCHAR(86) ,c14 BIGINT(127) ,c15 DECIMAL(64,18) ,c16 BINARY(155) , primary key(c4,c14))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c14) PARTITIONS 10;
create table t20 (c1 VARCHAR(86) ,c2 VARCHAR(86) ,c3 BINARY(126) ,c4 INT(127) ,c5 TIME,c6 INTEGER(127)  auto_increment,c7 CHAR(152) ,c8 BIGINT(127) ,c9 DATETIME,c10 CHAR(152) ,c11 DATETIME,c12 VARBINARY(72) ,c13 NUMERIC(64,26) ,c14 YEAR(4) ,c15 TIME, primary key(c10,c4,c1,c2,c13))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c4) PARTITIONS 10;

explain basic
SELECT
         /*+ parallel(2) */ 
         t10_52.c4,
         t10_52.c13,
         Min(t10_52.c10) OVER (partition BY t10_52.c10 ORDER BY t10_52.c10)
FROM     (
                SELECT t10_52.c1,
                       (
                                SELECT   t10_52.c2
                                FROM     t10 AS t10_52
                                ORDER BY 1 limit 1) AS c2,
                       t10_52.c4,
                       t10_52.c5,
                       (
                              SELECT min(t10_52.c6)
                              FROM   t10 AS t10_52) AS c6,
                       (
                                SELECT   t10_52.c7
                                FROM     t10 AS t10_52
                                ORDER BY 1 DESC limit 1) AS c7,
                       (
                                SELECT   t10_52.c8
                                FROM     t10 AS t10_52
                                ORDER BY 1 ASC limit 1) AS c8,
                       (
                                SELECT   t10_52.c9
                                FROM     t10 AS t10_52
                                ORDER BY 1 DESC limit 1) AS c9,
                       (
                              SELECT max(t10_52.c10)
                              FROM   t10 AS t10_52) AS c10,
                       t10_52.c11,
                       t10_52.c13,
                       t10_52.c14,
                       t10_52.c16
                FROM   t10 AS t10_52
                WHERE  t10_52.c10 > t10_52.c11
                AND    concat(t10_52.c13, t10_52.c7, timestamp '1992-4-11 17:9:55') LIKE '%Ab%') AS t10_52
GROUP BY t10_52.c14,
         t10_52.c11,
         t10_52.c16,
         t10_52.c4,
         t10_52.c13,
         t10_52.c10,
         t10_52.c1
HAVING   max(t10_52.c1) > 465
ORDER BY t10_52.c4 asc,
         t10_52.c13;

drop table if exists t10, t20;
