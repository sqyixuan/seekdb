# owner: dingjincheng.djc 
# owner group: SQL1
# tags: optimizer, cross_validation

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

# init env

create table t2(a int, b int) partition by hash(b) partitions 5;

create index t2i on t2(a);

create table t3 (a int(11) NOT NULL AUTO_INCREMENT, b text, PRIMARY KEY (a) );

create table t1 (a int not null, b char (10) not null);

insert into t2 values (100,100);
insert into t2 values (100,100);
insert into t2 values (1,1);
insert into t3 values (1,1);
insert into t3 values (2,2);
insert into t3 values (3,3);
insert into t3 values (4,4);

--explain_protocol 2
--result_format 4

# start tests

select * from t2 full join t3 on t2.a<t3.a where not exists (select null from t1 where t1.a<t2.a) for update;

# clean env
drop table t1;
drop table t2;
drop table t3;
