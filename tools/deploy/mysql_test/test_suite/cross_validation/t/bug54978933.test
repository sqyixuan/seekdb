# description: ps模式下指定别名正确性问题

--result_format 4

--disable_warnings
drop table if exists dmp_origin_res_owner_mapping;
--enable_warnings

create table dmp_origin_res_owner_mapping(id int, res_id int, res_type int, owner_id int, owner_username varchar(256), owner_name varchar(256));
insert into dmp_origin_res_owner_mapping values(649, 6, 3, 29188, 'chengwei6', '程炜');
prepare stmt from "SELECT RT.`id`, RT.`res_id` as 'resId', RT.`res_type` as 'resType', RT.`owner_id` as 'ownerId', RT.`owner_username` as 'ownerUsername', RT.`owner_name` as 'ownerName' from dmp_origin_res_owner_mapping RT where RT.res_type = 3 AND RT.`res_id` = ?";
set @i1 = 6;
execute stmt using @i1;


--disable_warnings
drop table if exists dmp_origin_res_owner_mapping;
--enable_warnings
