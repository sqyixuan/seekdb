--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
create table t1 (id int, c1 int, c2 int, c3 int,
                 primary key(id, c1),
                 index t1_idx_c2(c2) local,
                 index t1_gidx_c2(c2) global)
                 partition by hash(c1) partitions 5;

create table t2 (id int, c1 int, c2 int, c3 int,
                 primary key(id, c1),
                 index t2_idx_c2(c2) local)
                 partition by hash(c1) partitions 5;
create index t2_gidx_c2 on t2(c2) global partition by hash(c2) partitions 5;


create table t3 (c1 int primary key) partition by hash(c1) partitions 4;
create table t4 (c1 int primary key);
--explain_protocol 2
--result_format 4

select /*+no_use_px, use_nl(t1, t2), leading(t1,t2)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, index(t1 t1_gidx_c2), use_nl(t1, t2), leading(t1,t2)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, index(t2 t2_gidx_c2), use_nl(t1, t2), leading(t1,t2)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, index(t2 t2_gidx_c2), use_nl(t1, t2), leading(t2, t1)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, index(t1 t1_gidx_c2), use_nl(t1, t2), leading(t1,t2)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, index(t1 t1_gidx_c2), use_nl(t1, t2), leading(t2, t1)*/ count(*) from t1, t2 where t1.c2 = t2.c2 and t1.c1 = 1 and t2.c1 = 1;

select /*+no_use_px, use_nl(t3, t4), leading(t3, t4)*/ count(*) from t3, t4 where t3.c1 = t4.c1;

explain (SELECT /*+ NO_REWRITE  */ ALL t0.c1 
    FROM t2 t0 INNER JOIN t1 ON (t0.c1) OR (concat(t1.c1,'')) 
    WHERE (CAST('~' AS SIGNED)) && (5.80043436E8)) 
UNION ALL 
(SELECT /*+ NO_REWRITE  */ ALL t0.c1 
    FROM t2 t0 INNER JOIN t1 ON (t0.c1) OR (concat(t1.c1,'')) 
    WHERE (CAST('~' AS SIGNED)) AND ((NOT (5.80043436E8))));

explain SELECT   /*+use_concat*/
   (SELECT /*+unnest*/ SUM(c1) FROM t1 WHERE c2 != table1.c1 )
    FROM t2 AS table1, t1 AS table2
    WHERE (  ( SELECT /*+unnest*/  MAX(c1) FROM t1 )  ) 
    OR table1.c2 > 108 AND  table2.id  IN (select /*+no_unnest*/ * from ( SELECT 252 UNION  SELECT 8 )  );

set @var = 1;
explain select /*+no_semi_to_inner*/ * from t1 where c1 in (select @var from t2);

drop table t1, t2, t3, t4;

create table t1(id bigint not null auto_increment , c1 varchar(50), c2 timestamp not null default current_timestamp)  ;  
create table t2(id bigint not null auto_increment , c1 varchar(50), c2 timestamp not null default current_timestamp)  ;  

explain select * from t1;
explain select * from t1 union all select * from t2;

drop table t1,t2;

--disable_warnings
drop table if exists t3, t17;
--enable_warnings

CREATE TABLE `t17` (
  `c1` decimal(64,18) DEFAULT NULL,
  `c2` date DEFAULT NULL,
  `c3` datetime DEFAULT NULL,
  `c4` year(4) DEFAULT NULL,
  `c5` varchar(86) COLLATE utf8mb4_bin NOT NULL,
  `c6` varbinary(61) DEFAULT NULL,
  `c7` year(4) DEFAULT NULL,
  `c8` varbinary(61) DEFAULT NULL,
  `c9` varbinary(53) DEFAULT NULL,
  `c10` int(127) DEFAULT NULL,
  `c11` int(127) NOT NULL AUTO_INCREMENT,
  `c12` time DEFAULT NULL,
  `c13` int(127) NOT NULL,
  PRIMARY KEY (`c13`, `c11`, `c5`),
  UNIQUE KEY `g_u_WWcE` (`c6`, `c11`, `c8`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `g_u_yQGeTwqk` (`c10`, `c11`, `c13`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `g_u_cAkfyr` (`c10`, `c13`, `c9`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `g_u_KiXFfuaDq` (`c10`, `c13`, `c6`) BLOCK_SIZE 16384 GLOBAL,
  KEY `i_YHoLCQ` (`c13`, `c9`, `c8`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_UP` (`c6`, `c8`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_oOvsj` (`c6`) BLOCK_SIZE 16384 LOCAL,
  KEY `g_i_UyaW` (`c6`, `c5`) BLOCK_SIZE 16384 GLOBAL
)                                                                     
 partition by key(c13,c11) partitions 5;
insert into t17(c5, c13) values(1,1);

 CREATE TABLE `t3` (
  `c1` time DEFAULT NULL,
  `c2` decimal(64,13) DEFAULT NULL,
  `c3` bigint(127) NOT NULL AUTO_INCREMENT,
  `c4` binary(137) NOT NULL,
  `c5` decimal(64,28) DEFAULT NULL,
  `c6` decimal(64,3) DEFAULT NULL,
  `c7` datetime DEFAULT NULL,
  `c8` varbinary(82) DEFAULT NULL,
  `c9` bigint(127) DEFAULT NULL,
  `c10` varbinary(60) DEFAULT NULL,
  `c11` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c12` timestamp(3) NOT NULL DEFAULT '0000-00-00 00:00:00.000',
  `c13` varchar(86) COLLATE utf8mb4_bin NOT NULL,
  `c14` varbinary(81) DEFAULT NULL,
  `c15` datetime DEFAULT NULL,
  `c16` bigint(127) DEFAULT NULL,
  `c17` decimal(64,21) NOT NULL,
  `c18` binary(52) DEFAULT NULL,
  `c19` int(127) DEFAULT NULL,
  PRIMARY KEY (`c13`, `c17`, `c4`),
  UNIQUE KEY `u_qwAxOMO` (`c18`, `c14`, `c13`, `c19`, `c17`, `c4`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `u_BqaNCgNX` (`c9`, `c2`, `c19`, `c14`, `c13`, `c17`, `c4`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `u_AKxcBj` (`c3`, `c5`, `c16`, `c9`, `c13`, `c17`, `c4`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `u_jEpnpEJP` (`c14`, `c19`, `c13`, `c11`, `c17`, `c4`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_wgjTohAh` (`c19`, `c8`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_IFpFQV` (`c13`) BLOCK_SIZE 16384 LOCAL
) ;
insert into t3(c4, c13, c16, c17) values('1','1', 1,1);


SELECT (SELECT Min(c16)
        FROM   t3 AS t3_43),
        (SELECT Max(t3.c18)
                FROM   t3) AS c18
FROM   (SELECT t3.c4
        FROM   t3) AS t3_42
WHERE  EXISTS ((select 1 from dual) union (SELECT t17_39.c5
                FROM   t17 AS t17_39
                LIMIT  1)
               )
GROUP  BY t3_42.c4;

--disable_warnings
drop table if exists t3, t17;
--enable_warnings
