# owner: xiaoyi.xy
# owner group: SQL2
# description: fix bug: use database cause implicit commit
#
# BugFix: 

--disable_warnings
drop database if exists a;
--enable_warnings
create database a;
 
--echo
create table a.t1(a int);
set autocommit = 0;
insert into a.t1 values(2);
select * from a.t1;
use `a`;
rollback;
--echo
select * from a.t1;
 
--echo
use test;
drop database a;
