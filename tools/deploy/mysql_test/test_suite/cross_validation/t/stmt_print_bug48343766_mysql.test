# owner: zhanyue.zzy
# owner group: SQL1
# tags: cross_validation

--result_format 4

## 

--disable_warnings
drop table if exists t1, v1;
--enable_warnings

# init env
create table t1(c1 int);

create or replace view v1 as select /*+parallel(8) no_rewrite no_merge(@sel$2) no_merge(@sel$4) */ * from (select * from t1);
show create view v1;

create or replace view v1 as select /*+parallel(8) no_rewrite */ * from (select * from t1) union all select * from t1;
show create view v1;

create or replace view v1 as select /*+ no_rewrite */ * from (select * from t1) union all select /*+ parallel(8) */ * from t1;
show create view v1;

# clean env
drop table if exists t1;
drop view if exists v1;