SELECT     28        AS c0,
           subq_0.c0 AS c1,
           Avg( Cast(
           CASE
                      WHEN (
                                            subq_0.c2 IS NOT NULL)
                      OR         (
                                            (
                                                       subq_0.c1 + subq_0.c2)
                                 AND        (
                                                       EXISTS
                                                       (
                                                              SELECT subq_0.c0 AS c0,
                                                                     subq_0.c0 AS c1,
                                                                     subq_1.c0 AS c2,
                                                                     subq_0.c0 AS c3,
                                                                     subq_1.c0 AS c4,
                                                                     (
                                                                            SELECT Max(encscount)
                                                                            FROM   test.t_mon_application_hsm_hour) AS c5,
                                                                     ref_6.act_intro                                AS c6,
                                                                     ref_6.act_name                                 AS c7,
                                                                     subq_1.c1                                      AS c8,
                                                                     65                                             AS c9,
                                                                     71                                             AS c10,
                                                                     subq_1.c0                                      AS c11,
                                                                     ref_6.act_type                                 AS c12,
                                                                     34                                             AS c13,
                                                                     subq_1.c2                                      AS c14,
                                                                     subq_0.c0                                      AS c15,
                                                                     subq_1.c0                                      AS c16,
                                                                     subq_0.c0                                      AS c17,
                                                                     subq_0.c2                                      AS c18,
                                                                     subq_1.c1                                      AS c19,
                                                                     subq_0.c0                                      AS c20,
                                                                     subq_1.c2                                      AS c21
                                                              FROM   test.cool_activity                             AS ref_6
                                                              WHERE  EXISTS
                                                                     (
                                                                            SELECT
                                                                                   (
                                                                                          SELECT widgetid
                                                                                          FROM   test.t_dsb_widget_page limit 1 offset 3) AS c0,
                                                                                   subq_1.c0                                              AS c1
                                                                            FROM   test.t_vsm_cluster_policy                              AS ref_7
                                                                            WHERE  subq_1.c1 <= subq_1.c1)))) THEN subq_0.c2
                      ELSE subq_0.c1
           END AS DECIMAL)) OVER (partition BY subq_0.c1,subq_1.c2 ORDER BY subq_0.c2,subq_1.c0) AS c2,
           Max( Cast(
                      (
                      SELECT service_amount
                      FROM   test.gp_refund_event_00_00 limit 1 offset 3) AS DECIMAL(10, 2))) OVER (partition BY subq_1.c1,subq_1.c2,subq_0.c1 ORDER BY subq_0.c1,subq_0.c2) AS c3,
           subq_1.c0                                                                                                                                                         AS c4
FROM       (
           (
                      SELECT     Replace( Cast(ref_0.mcc_code AS CHAR), Cast(ref_0.mcc_name AS CHAR), Cast(
                                                                                                            (
                                                                                                            SELECT create_user_id
                                                                                                            FROM   test.uc_association_info limit 1 offset 36) AS CHAR)) AS c0,
                                 ref_1.id                                                                                                                                AS c1,
                                 Round( Cast(
                                              (
                                              SELECT max
                                              FROM   test.t_mon_eps_day limit 1 offset 6) AS DECIMAL(10, 2))) AS c2
                      FROM       ((test.cool_mcc_detail AS ref_0
                      RIGHT JOIN test.testtime          AS ref_1
                      ON         (
                                            ref_0.mcc_detail_id - ref_0.mcc_detail_id))
                      INNER JOIN test.testtime AS ref_2
                      ON         ((
                                                       ref_0.mcc_detail_id * ref_0.mcc_detail_id)
                                 OR         (
                                                       ref_1.hiredate IS NULL)))
                      WHERE      EXISTS
                                 (
                                                 SELECT DISTINCT ref_2.id               AS c0,
                                                                 ref_1.hiredate         AS c1,
                                                                 ref_1.hiredate         AS c2,
                                                                 ref_1.hiredate         AS c3
                                                 FROM            test.t_kms_vkek_export AS ref_3
                                                 WHERE           ref_2.id
                                                 OR              ref_1.id) limit 101) AS subq_0
INNER JOIN
           (
                      SELECT     ref_5.mcc_wx_cate_id        AS c0,
                                 ref_5.mcc_wx_cate_detail_id AS c1,
                                 ref_5.mcc_wx_cate_id        AS c2
                      FROM       (test.cool_business_service AS ref_4
                      INNER JOIN test.cool_mcc_wx_detail     AS ref_5
                      ON         (
                                            ref_4.tel = ref_5.mcc_name ))
                      WHERE      ref_4.business_service_id >>
                                 (
                                        SELECT driftimageid
                                        FROM   test.t_vsm_drift_imagefile limit 1 offset 6) ) AS subq_1
ON         (
                      subq_0.c1 = subq_1.c1 ))
WHERE      subq_0.c2
OR         subq_0.c2 limit 143 ;
+----+------+------+------+------+
| c0 | c1   | c2   | c3   | c4   |
+----+------+------+------+------+
+----+------+------+------+------+

