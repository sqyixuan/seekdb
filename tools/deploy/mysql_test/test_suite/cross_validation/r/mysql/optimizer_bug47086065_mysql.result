drop table if exists `t_mon_application_hsm_hour`;
drop table if exists `cool_activity`;
drop table if exists `t_dsb_widget_page`;
drop table if exists `t_vsm_cluster_policy`;
drop table if exists `gp_refund_event_00_00`;
drop table if exists `uc_association_info`;
drop table if exists `t_mon_eps_day`;
drop table if exists `cool_mcc_detail`;
drop table if exists `t_kms_vkek_export`;
drop table if exists `cool_business_service`;
drop table if exists `cool_mcc_wx_detail`;
drop table if exists `t_vsm_drift_imagefile`;
drop table if exists `testtime`;
CREATE TABLE `t_mon_application_hsm_hour` (
`applicationID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'applicationID',
`monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '监控时间',
`applicationName` varchar(20) DEFAULT NULL COMMENT '应用名称',
`encsCount` double DEFAULT NULL COMMENT '加密次数',
`decsCount` double DEFAULT NULL COMMENT '解密次数',
`count` double DEFAULT NULL COMMENT '加解密总次数',
`hsmUUID` varchar(50) DEFAULT NULL,
`vsmUUID` varchar(50) DEFAULT NULL,
PRIMARY KEY (`applicationID`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE `cool_activity` (
`act_id` int(11) NOT NULL AUTO_INCREMENT,
`act_type` varchar(30) DEFAULT NULL ,
`act_name` varchar(125) DEFAULT NULL ,
`act_intro` varchar(255) DEFAULT NULL ,
`begin_time` varchar(11) DEFAULT NULL ,
`end_time` varchar(11) DEFAULT NULL ,
`regtime` varchar(11) DEFAULT NULL ,
`applicants` text ,
PRIMARY KEY (`act_id`)
)  AUTO_INCREMENT=7 DEFAULT CHARSET=utf8 ;
create TABLE `t_dsb_widget_page` (
`pageID` int(11) NOT NULL COMMENT '微件页流水号',
`widgetID` int(11) NOT NULL COMMENT '微件流水号',
PRIMARY KEY (`pageID`,`widgetID`)
)  DEFAULT CHARSET=utf8 COMMENT='微件与微件页映射表\nWebServer:读/写';
CREATE TABLE `t_vsm_cluster_policy` (
`policyID` int(11) NOT NULL AUTO_INCREMENT,
`maxCpuUsage` float DEFAULT '0' COMMENT '最大CPU占用率',
`minCpuUsage` float DEFAULT '0' COMMENT '最小CPU占用率',
`maxMemoryUsage` float DEFAULT '0' COMMENT '最大内存占用率',
`minMemoryUsage` float DEFAULT '0' COMMENT '最小内存占用率',
`clusterID` int(11) DEFAULT NULL COMMENT '集群ID',
PRIMARY KEY (`policyID`)
)  DEFAULT CHARSET=utf8;
create table if not exists `gp_refund_event_00_00` (
`refund_event_no` varchar(64) not null,
`service_target` varchar(64),
`service_type` varchar(8),
`refund_no` varchar(128) not null,
`service_amount` decimal(20,4),
`refund_amount` decimal(15,4),
`consult_no` varchar(32),
`freeze_code` varchar(64),
`status` varchar(1) not null,
`gmt_service` timestamp(6),
`gmt_create` timestamp(6) not null,
`gmt_modified` timestamp(6) not null,
`refund_type` varchar(1) not null,
`properties` varchar(1000),
primary key (`refund_event_no`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `idx_service_target_type` on `gp_refund_event_00_00` (`service_target` ASC, `service_type` ASC) ;
create index `idx_status_gmtmodified_type` on `gp_refund_event_00_00` (`status` ASC, `gmt_modified` ASC, `refund_type` ASC) ;
CREATE TABLE `uc_association_info` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`version` int(11) NOT NULL DEFAULT 1 COMMENT '版本号',
`create_time` datetime NOT NULL COMMENT '创建时间',
`create_user_id` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '创建人',
`certificate_sno` varchar(64) COLLATE utf8_bin NOT NULL COMMENT '法人标识',
`act_area` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '活动地域',
`association_content` varchar(2000) COLLATE utf8_bin DEFAULT NULL COMMENT '业务范围',
`reg_address` varchar(128) COLLATE utf8_bin DEFAULT NULL COMMENT '住所',
`industry` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '所属行(事)业',
`reg_date` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '登记时间',
`reg_money` varchar(12) COLLATE utf8_bin DEFAULT NULL COMMENT '注册资金',
`association_owner` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '法定代表人',
`competent_org` varchar(320) COLLATE utf8_bin DEFAULT NULL COMMENT '业务主管单位',
`charity_org` varchar(6) COLLATE utf8_bin DEFAULT NULL COMMENT '是否慈善组织',
`social_orgType` varchar(6) COLLATE utf8_bin DEFAULT NULL COMMENT '社会组织类型',
`fund_kind` varchar(6) COLLATE utf8_bin DEFAULT NULL COMMENT '基金会类型',
`begin_date` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '证书有效期始',
`end_date` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '证书有效期止',
`update_time` datetime NOT NULL COMMENT '修改时间',
`update_user_id` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '修改人',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_certificate_sno` (`certificate_sno`)
)  DEFAULT CHARSET=utf8 COLLATE=utf8_bin COMMENT='社会组织法人信息';
CREATE TABLE `t_mon_eps_day` (
`epsID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'epsID',
`monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP,
`algorithm` varchar(20) DEFAULT NULL COMMENT '加密算法名称',
`max` double(20,0) DEFAULT NULL COMMENT '统计时间段内最大的加密次数',
`avg` double(20,0) DEFAULT NULL COMMENT '统计时间段内平均的加密次数',
`hsmUUID` varchar(50) CHARACTER SET utf8 DEFAULT NULL,
`vsmUUID` varchar(50) CHARACTER SET utf8 DEFAULT NULL,
PRIMARY KEY (`epsID`)
)  AUTO_INCREMENT=528 DEFAULT CHARSET=gbk;
CREATE TABLE `cool_mcc_detail` (
`mcc_detail_id` int(11) NOT NULL AUTO_INCREMENT,
`mcc_name` varchar(255) DEFAULT NULL,
`mcc_code` varchar(10) DEFAULT NULL,
`mcc_cate_id` varchar(5) DEFAULT NULL,
PRIMARY KEY (`mcc_detail_id`)
)  AUTO_INCREMENT=269 DEFAULT CHARSET=utf8;
create table testtime(id int,hiredate timestamp, primary key(hiredate));
insert into testtime values(1,'20151208000000');
CREATE TABLE `t_kms_vkek_export` (
`id` varchar(36) NOT NULL,
`platform_id` varchar(255) DEFAULT NULL COMMENT 'vpmk别名即平台id',
`opponent_platform_id` varchar(255) DEFAULT NULL COMMENT '对端id',
`vkek_version` varchar(36) DEFAULT NULL COMMENT 'vkek版本',
`app_id` varchar(36) DEFAULT NULL COMMENT '应用id',
`export_time` varchar(36) DEFAULT NULL COMMENT '导出时间'
)  DEFAULT CHARSET=utf8;
CREATE TABLE `cool_business_service` (
`business_service_id` int(11) NOT NULL AUTO_INCREMENT,
`companytitle` varchar(255) DEFAULT NULL ,
`service` varchar(255) DEFAULT NULL ,
`imageface` varchar(255) DEFAULT NULL ,
`contact` varchar(255) DEFAULT NULL ,
`tel` varchar(30) DEFAULT NULL ,
`change_time` varchar(20) DEFAULT NULL ,
PRIMARY KEY (`business_service_id`)
)  AUTO_INCREMENT=39 DEFAULT CHARSET=utf8;
CREATE TABLE `cool_mcc_wx_detail` (
`mcc_wx_cate_detail_id` int(10) unsigned NOT NULL AUTO_INCREMENT,
`mcc_name` varchar(255) DEFAULT NULL,
`mcc_wx_code` varchar(10) DEFAULT NULL,
`mcc_wx_cate_id` varchar(5) DEFAULT NULL,
PRIMARY KEY (`mcc_wx_cate_detail_id`)
)  AUTO_INCREMENT=178 DEFAULT CHARSET=utf8;
CREATE TABLE `t_vsm_drift_imagefile` (
`driftImageID` int(20) NOT NULL AUTO_INCREMENT COMMENT '影像文件ID',
`driftImageName` varchar(200) DEFAULT NULL COMMENT '影像文件的名称：系统默认生成该名称',
`systemCreateTime` datetime DEFAULT NULL COMMENT '系统时间',
`driftImageCreateTime` datetime DEFAULT NULL COMMENT '影像文件创建时间',
`driftImageVersion` char(50) DEFAULT NULL COMMENT '虚拟机版本',
`driftImageAlg` int(11) DEFAULT NULL COMMENT '签名算法',
`driftSign` varchar(255) DEFAULT NULL COMMENT '签名值',
`driftImageRealFilePath` varchar(200) DEFAULT NULL COMMENT '影像文件实际存储名称',
`vsmID` int(20) DEFAULT NULL COMMENT '对应的VSM ID',
`describes` varchar(50) DEFAULT '' COMMENT '快照描述',
PRIMARY KEY (`driftImageID`)
)  AUTO_INCREMENT=189 DEFAULT CHARSET=utf8 COMMENT='漂移影像文件';
result_format: 4
explain_protocol: 1
EXPLAIN BASIC SELECT     sum( subq_0.c2) OVER (partition BY subq_0.c1,subq_1.c0 ORDER BY subq_0.c2) AS c2,
           Max( subq_0.c2 ) OVER (partition BY subq_1.c1,subq_1.c0,subq_0.c1 ORDER BY subq_0.c2) AS c3
FROM       (SELECT     ref_1.id AS c1,
                        (SELECT max FROM test.t_mon_eps_day limit 1 offset 6) AS c2
            FROM  test.testtime AS ref_1) AS subq_0
INNER JOIN
           (SELECT     ref_5.mcc_wx_cate_id        AS c0,
                       ref_5.mcc_wx_cate_detail_id AS c1
            FROM test.cool_business_service AS ref_4,
                 test.cool_mcc_wx_detail     AS ref_5
            where ref_4.tel = ref_5.mcc_name) AS subq_1
where subq_0.c1 = subq_1.c1;
