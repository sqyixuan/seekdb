result_format: 4
drop table if exists sample_autolabel_file;
CREATE TABLE `sample_autolabel_file` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `file_id` varchar(150) NOT NULL DEFAULT '',
  `vin` varchar(40) NOT NULL DEFAULT '',
  `collect_time` bigint(20) NOT NULL DEFAULT '0',
  `file_name` varchar(255) NOT NULL DEFAULT '',
  `file_type` varchar(40) NOT NULL DEFAULT '',
  `bucket_name` varchar(60) NOT NULL DEFAULT '',
  `object_key` varchar(500) NOT NULL DEFAULT '',
  `model_name` varchar(60) NOT NULL DEFAULT '',
  `version_no` varchar(40) NOT NULL DEFAULT '',
  `origin_model_version` varchar(500) NOT NULL DEFAULT '',
  `frame_ts` bigint(20) unsigned NOT NULL DEFAULT '0',
  `frame_id` int(10) unsigned NOT NULL DEFAULT '0',
  `position` varchar(20) NOT NULL DEFAULT '',
  `belong_file_id` varchar(150) NOT NULL DEFAULT '',
  `belong_file_name` varchar(255) NOT NULL DEFAULT '',
  `tag` json DEFAULT NULL,
  `vid` varchar(60) NOT NULL DEFAULT '',
  `clip_vid` varchar(60) NOT NULL DEFAULT '',
  `ctime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `mtime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`, `collect_time`),
  UNIQUE KEY `uniq_cltime_fid` (`collect_time`, `file_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_bfid` (`belong_file_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_cvid_pos` (`clip_vid`, `position`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_vin_ft` (`vin`, `file_type`) BLOCK_SIZE 16384 LOCAL
);

prepare stmt from "INSERT INTO `sample_autolabel_file` (`belong_file_id`) VALUES ('abc') ON DUPLICATE KEY UPDATE `tag` = VALUES(`tag`), `tag` = VALUES(`tag`), `belong_file_id` = VALUES(`belong_file_id`)";

drop table if exists sample_autolabel_file;
