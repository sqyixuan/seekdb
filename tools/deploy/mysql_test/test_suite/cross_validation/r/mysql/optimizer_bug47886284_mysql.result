drop table t1;

## 
drop table if exists t10, t20;
create table t10 (c1 NUMERIC(64,19) ,c2 VARBINARY(80) ,c3 NUMERIC(64,17) ,c4 BINARY(56) ,c5 INT(127) ,c6 BIGINT(127) ,c7 YEAR(4) ,c8 YEAR(4) ,c9 CHAR(152) ,c10 DATETIME,c11 YEAR(4) ,c12 CHAR(152) ,c13 VARCHAR(86) ,c14 BIGINT(127) ,c15 DECIMAL(64,18) ,c16 BINARY(155) , primary key(c4,c14))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c14) PARTITIONS 10;
create table t20 (c1 VARCHAR(86) ,c2 VARCHAR(86) ,c3 BINARY(126) ,c4 INT(127) ,c5 TIME,c6 INTEGER(127)  auto_increment,c7 CHAR(152) ,c8 BIGINT(127) ,c9 DATETIME,c10 CHAR(152) ,c11 DATETIME,c12 VARBINARY(72) ,c13 NUMERIC(64,26) ,c14 YEAR(4) ,c15 TIME, primary key(c10,c4,c1,c2,c13))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c4) PARTITIONS 10;

explain basic
SELECT
         /*+ parallel(2) */ 
         t10_52.c4,
         t10_52.c13,
         Min(t10_52.c10) OVER (partition BY t10_52.c10 ORDER BY t10_52.c10)
FROM     (
                SELECT t10_52.c1,
                       (
                                SELECT   t10_52.c2
                                FROM     t10 AS t10_52
                                ORDER BY 1 limit 1) AS c2,
                       t10_52.c4,
                       t10_52.c5,
                       (
                              SELECT min(t10_52.c6)
                              FROM   t10 AS t10_52) AS c6,
                       (
                                SELECT   t10_52.c7
                                FROM     t10 AS t10_52
                                ORDER BY 1 DESC limit 1) AS c7,
                       (
                                SELECT   t10_52.c8
                                FROM     t10 AS t10_52
                                ORDER BY 1 ASC limit 1) AS c8,
                       (
                                SELECT   t10_52.c9
                                FROM     t10 AS t10_52
                                ORDER BY 1 DESC limit 1) AS c9,
                       (
                              SELECT max(t10_52.c10)
                              FROM   t10 AS t10_52) AS c10,
                       t10_52.c11,
                       t10_52.c13,
                       t10_52.c14,
                       t10_52.c16
                FROM   t10 AS t10_52
                WHERE  t10_52.c10 > t10_52.c11
                AND    concat(t10_52.c13, t10_52.c7, timestamp '1992-4-11 17:9:55') LIKE '%Ab%') AS t10_52
GROUP BY t10_52.c14,
         t10_52.c11,
         t10_52.c16,
         t10_52.c4,
         t10_52.c13,
         t10_52.c10,
         t10_52.c1
HAVING   max(t10_52.c1) > 465
ORDER BY t10_52.c4 asc,
         t10_52.c13;
Query Plan
===================================================
|ID|OPERATOR                             |NAME    |
---------------------------------------------------
|0 |PX COORDINATOR MERGE SORT            |        |
|1 |└─EXCHANGE OUT DISTR                 |:EX10001|
|2 |  └─SORT                             |        |
|3 |    └─WINDOW FUNCTION                |        |
|4 |      └─SORT                         |        |
|5 |        └─EXCHANGE IN DISTR          |        |
|6 |          └─EXCHANGE OUT DISTR (HASH)|:EX10000|
|7 |            └─SUBPLAN SCAN           |VIEW1   |
|8 |              └─WINDOW FUNCTION      |        |
|9 |                └─PX BLOCK ITERATOR  |        |
|10|                  └─TABLE FULL SCAN  |t10_52  |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(VIEW1.t10_52.c4, VIEW1.t10_52.c13, T_FUN_MIN(VIEW1.max(t10_52.c10)))]), filter(nil), rowset=16
      sort_keys([VIEW1.t10_52.c4, ASC], [VIEW1.t10_52.c13, ASC])
  1 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [INTERNAL_FUNCTION(VIEW1.t10_52.c4, VIEW1.t10_52.c13, T_FUN_MIN(VIEW1.max(t10_52.c10)))]), filter(nil), rowset=16
      dop=2
  2 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [T_FUN_MIN(VIEW1.max(t10_52.c10))]), filter(nil), rowset=16
      sort_keys([VIEW1.t10_52.c4, ASC], [VIEW1.t10_52.c13, ASC])
  3 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [T_FUN_MIN(VIEW1.max(t10_52.c10))]), filter(nil), rowset=16
      win_expr(T_FUN_MIN(VIEW1.max(t10_52.c10))), partition_by([VIEW1.max(t10_52.c10)]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), 
      lower(CURRENT ROW)
  4 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [VIEW1.max(t10_52.c10)]), filter(nil), rowset=16
      sort_keys([VIEW1.max(t10_52.c10), ASC])
  5 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [VIEW1.max(t10_52.c10)]), filter(nil), rowset=16
  6 - output([VIEW1.t10_52.c4], [VIEW1.t10_52.c13], [VIEW1.max(t10_52.c10)]), filter(nil), rowset=16
      (#keys=1, [VIEW1.max(t10_52.c10)]), dop=2
  7 - output([VIEW1.max(t10_52.c10)], [VIEW1.t10_52.c4], [VIEW1.t10_52.c13]), filter([VIEW1.t10_52.c1 > cast(465, DECIMAL_INT(64, 19))], [cast(VIEW1.t10_52.c10,
       VARCHAR(1048576)) > cast(VIEW1.t10_52.c11, VARCHAR(1048576))], [(T_OP_LIKE, concat(VIEW1.t10_52.c13, cast(VIEW1.t10_52.c7, VARCHAR(1048576)), cast('1992-04-11 
      17:09:55', VARCHAR(1048576))), cast('%Ab%', VARCHAR(1048576)), '\\')]), rowset=16
      access([VIEW1.max(t10_52.c10)], [VIEW1.t10_52.c4], [VIEW1.t10_52.c10], [VIEW1.t10_52.c11], [VIEW1.t10_52.c13], [VIEW1.t10_52.c7], [VIEW1.t10_52.c1])
  8 - output([T_FUN_MAX(t10_52.c10)], [t10_52.c4], [t10_52.c10], [t10_52.c11], [t10_52.c13], [t10_52.c7], [t10_52.c1]), filter(nil), rowset=16
      win_expr(T_FUN_MAX(t10_52.c10)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  9 - output([t10_52.c4], [t10_52.c10], [t10_52.c11], [t10_52.c13], [t10_52.c7], [t10_52.c1]), filter(nil), rowset=16
 10 - output([t10_52.c4], [t10_52.c10], [t10_52.c11], [t10_52.c13], [t10_52.c7], [t10_52.c1]), filter(nil), rowset=16
      access([t10_52.c4], [t10_52.c10], [t10_52.c11], [t10_52.c13], [t10_52.c7], [t10_52.c1]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, 
      range_key([t10_52.c4], [t10_52.c14]), range(MIN,MIN ; MAX,MAX)always true

drop table if exists t10, t20;
