result_format: 4
## 
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 2;

insert into t1
with recursive cte as 
(select 1 as c1 union all select c1+1 from cte where c1 < 100)
select c1, c1, c1 from cte;

explain basic
SELECT /*+ parallel(2) */ c1, min((85 + 866)) OVER (ORDER BY (85 + 866) DESC)
FROM t1 ORDER BY c1 limit 10;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |TOP-N SORT               |        |
|1 |└─WINDOW FUNCTION        |        |
|2 |  └─PX COORDINATOR       |        |
|3 |    └─EXCHANGE OUT DISTR |:EX10000|
|4 |      └─PX BLOCK ITERATOR|        |
|5 |        └─TABLE FULL SCAN|t1      |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [T_FUN_MIN(85 + 866)]), filter(nil), rowset=256
      sort_keys([t1.c1, ASC]), topn(10), local merge sort
  1 - output([t1.c1], [T_FUN_MIN(85 + 866)]), filter(nil), rowset=256
      win_expr(T_FUN_MIN(85 + 866)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  2 - output([t1.c1]), filter(nil), rowset=256
  3 - output([t1.c1]), filter(nil), rowset=256
      dop=2
  4 - output([t1.c1]), filter(nil), rowset=256
  5 - output([t1.c1]), filter(nil), rowset=256
      access([t1.c1]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true

SELECT /*+ parallel(2) */ c1, min((85 + 866)) OVER (ORDER BY (85 + 866) DESC)
FROM t1 ORDER BY c1 limit 10;
