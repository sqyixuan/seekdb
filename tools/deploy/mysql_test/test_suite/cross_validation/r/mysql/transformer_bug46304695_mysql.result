drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);
explain_protocol: 2
result_format: 4
EXPLAIN SELECT 1
FROM    (SELECT (SELECT 1 FROM t1 WHERE t2.c1) AS c0 FROM t2) AS subq_0
WHERE   subq_0.c0
    AND EXISTS (SELECT (SELECT 1 FROM   DUAL) AS c2
                FROM  t3
                WHERE  t3.c1 * subq_0.c0);
