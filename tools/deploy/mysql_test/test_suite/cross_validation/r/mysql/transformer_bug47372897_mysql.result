drop table if exists cool_feedback;
drop table if exists t_sys_cmd_category;
drop table if exists cool_business_setting;
drop table if exists t_chsm_log_statistics_record;
CREATE TABLE `cool_feedback` (
`back_id` int(11) NOT NULL AUTO_INCREMENT,
`admin_id` int(11) DEFAULT NULL,
`content` text,
`regtime` int(11) DEFAULT NULL,
`remark` text,
`status` int(1) DEFAULT '1',
`parent_id` int(11) DEFAULT '0' ,
`extra` varchar(255) DEFAULT '' ,
`user_read` int(1) DEFAULT NULL ,
`administrator_read` int(1) DEFAULT NULL ,
PRIMARY KEY (`back_id`)
) ENGINE=InnoDB AUTO_INCREMENT=82 DEFAULT CHARSET=utf8 ;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_sys_cmd_category` (
`cmdCategoryID` int(20) NOT NULL AUTO_INCREMENT COMMENT '命令分类ID',
`cmdCategoryName` char(100) DEFAULT NULL COMMENT '命令分类名称',
PRIMARY KEY (`cmdCategoryID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='命令分类表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `cool_business_setting` (
`id` int(11) NOT NULL AUTO_INCREMENT,
`business_id` int(11) NOT NULL DEFAULT '0' ,
`mch_code` varchar(32) NOT NULL ,
`sys_administrator_id` int(11) DEFAULT NULL ,
`create_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP ,
`save_time` tinyint(11) NOT NULL ,
PRIMARY KEY (`id`),
UNIQUE KEY `businessId` (`business_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=38 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create TABLE `t_chsm_log_statistics_record` (
`id` int(11) NOT NULL AUTO_INCREMENT COMMENT '记录编号',
`statisticsMethod` varchar(10) NOT NULL COMMENT '统计方法，按小时/按天统计',
`updateTime` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00' ON update CURRENT_TIMESTAMP COMMENT '记录更新时间yyyy-MM-dd HH:00:00',
PRIMARY KEY (`id`),
UNIQUE KEY `unique_method` (`statisticsMethod`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=2413 DEFAULT CHARSET=utf8 COMMENT='日志统计记录表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
