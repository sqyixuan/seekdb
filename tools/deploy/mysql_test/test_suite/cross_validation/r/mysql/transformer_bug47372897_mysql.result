EXPLAIN SELECT 52 AS c0
FROM   (test.cool_feedback AS ref_0
        RIGHT JOIN (SELECT ref_1.cmdcategoryid AS c0,
                           CASE
                             WHEN ref_1.cmdcategoryid - ref_1.cmdcategoryid THEN
                             ref_1.cmdcategoryid
                             ELSE ref_1.cmdcategoryid
                           end                 AS c1
                    FROM   test.t_sys_cmd_category AS ref_1
                    WHERE  ref_1.cmdcategoryid = ref_1.cmdcategoryid) AS subq_0
                ON ( ( ( ( 0 )
                         AND ( 0 ) )
                       AND ( ( ( ref_0.parent_id
                                  OR ref_0.status )
                               AND ( 0 ) )
                             AND ( subq_0.c1 IS NULL ) ) )
                      OR ( ( EXISTS (SELECT subq_0.c1            AS c0,
                                            (SELECT save_time
                                             FROM   test.cool_business_setting
                                             LIMIT  1 offset 29) AS c1,
                                            ref_2.updatetime     AS c2,
                                            ref_0.admin_id       AS c3
                                     FROM   test.t_chsm_log_statistics_record AS
                                            ref_2
                                     WHERE  ref_0.regtime
                                             OR subq_0.c0
                                     LIMIT  59) )
                           AND ( subq_0.c1 IS NOT NULL ) ) ))
WHERE  97 & ref_0.admin_id;
