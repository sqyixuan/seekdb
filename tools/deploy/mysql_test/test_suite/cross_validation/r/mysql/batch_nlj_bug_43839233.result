result_format: 4
drop table if exists t0, t1;
create table t0(pk int primary key, c1 int, c2 int);
create table t1(pk int primary key, c1 int, c2 int);

insert into t0 values(1,2,3);
insert into t1 values(1,2,1),(2,2,1),(3,2,1),(4,2,0),(5,3,1),(6,3,1),(7,3,1),(8,4,0),(9,4,1),(10,4,1),(11,4,1),(12,4,1),(13,4,1),(14,4,1);

alter system minor freeze;
delete from t1 where pk = 2;

explain basic select/*+ leading(t0,t1) use_nl(t0,t1) NO_USE_NL_MATERIALIZATION(t1) */ t1.pk,t1.c2 from t1 join t0 on t0.c1 = t1.c1 where t1.c2 = 1 order by t1.pk desc;
Query Plan
====================================
|ID|OPERATOR           |NAME       |
------------------------------------
|0 |SORT               |           |
|1 |└─NESTED-LOOP JOIN |           |
|2 |  ├─TABLE FULL SCAN|t0         |
|3 |  └─TABLE FULL SCAN|t1(Reverse)|
====================================
Outputs & filters:
-------------------------------------
  0 - output([t1.pk], [t1.c2]), filter(nil), rowset=16
      sort_keys([t1.pk, DESC])
  1 - output([t1.pk], [t1.c2]), filter(nil), rowset=16
      conds([t0.c1 = t1.c1]), nl_params_(nil), use_batch=false
  2 - output([t0.c1]), filter(nil), rowset=16
      access([t0.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t0.pk]), range(MIN ; MAX)always true
  3 - output([t1.pk], [t1.c1], [t1.c2]), filter([t1.c2 = 1]), rowset=16
      access([t1.pk], [t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.pk]), range(MIN ; MAX)always true
select/*+ leading(t0,t1) use_nl(t0,t1) NO_USE_NL_MATERIALIZATION(t1) */ t1.pk,t1.c2 from t1 join t0 on t0.c1 = t1.c1 where t1.c2 = 1 order by t1.pk desc;
+----+------+
| pk | c2   |
+----+------+
|  3 |    1 |
|  1 |    1 |
+----+------+

explain basic select/*+ leading(t0,t1) use_hash(t0,t1) */ t1.pk,t1.c2 from t1 join t0 on t0.c1 = t1.c1 where t1.c2 = 1 order by t1.pk desc;
Query Plan
====================================
|ID|OPERATOR           |NAME       |
------------------------------------
|0 |SORT               |           |
|1 |└─HASH JOIN        |           |
|2 |  ├─TABLE FULL SCAN|t0         |
|3 |  └─TABLE FULL SCAN|t1(Reverse)|
====================================
Outputs & filters:
-------------------------------------
  0 - output([t1.pk], [t1.c2]), filter(nil), rowset=16
      sort_keys([t1.pk, DESC])
  1 - output([t1.pk], [t1.c2]), filter(nil), rowset=16
      equal_conds([t0.c1 = t1.c1]), other_conds(nil)
  2 - output([t0.c1]), filter(nil), rowset=16
      access([t0.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t0.pk]), range(MIN ; MAX)always true
  3 - output([t1.pk], [t1.c1], [t1.c2]), filter([t1.c2 = 1]), rowset=16
      access([t1.pk], [t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.pk]), range(MIN ; MAX)always true
select/*+ leading(t0,t1) use_hash(t0,t1) */ t1.pk,t1.c2 from t1 join t0 on t0.c1 = t1.c1 where t1.c2 = 1 order by t1.pk desc;
+----+------+
| pk | c2   |
+----+------+
|  3 |    1 |
|  1 |    1 |
+----+------+

drop table t0,t1;
