CREATE OR REPLACE  VIEW "IM"."ORGANIZATION" ("ORGID", "REGION", "ORGNAME", "ORGTYPE", "ORGLEVEL", "ISINNER", "MANAGERID", "PARENTID", "OPENPHONE", "ADDRESS", "POSTCODE", "CONTACTMAN", "CONTACTPHONE", "FAX", "EMAIL", "COUNTY", "AREAID", "OWNERTYPE", "NOTES", "CREATEDATE", "STATUS", "STATUSDATE", "AGENTTYPEID", "STARLEVEL", "DISTTYPEID", "ISCHANNELAUTHFILTER", "DEPARTCODE", "AGENTSTYLE", "ISPROVCHAIN", "CHAINNAME") AS
  SELECT
  ORG.ORGAID             ORGID,
  to_number(ORG.AreaCode)      REGION,
  ORG.ORGANAME           ORGNAME,
  ORG.ORGATYPEID         ORGTYPE,
  ORG.OrgaLevel          ORGLEVEL,
  ORG.isInner            ISINNER,
  ORG.MONITORID          MANAGERID,
  ORG.PARENTID           PARENTID,
  ORG.OPENPHONE          OPENPHONE,
  ORG.ADDRESS            ADDRESS,
  ORG.POSTALCODE         POSTCODE,
  ORG.CONTACTSTAFFNO     CONTACTMAN,
  ORG.CONTACTTELNO       CONTACTPHONE,
  ORG.FAXNO              FAX,
  ORG.EMAIL              EMAIL,
  ORG.Cityflag           COUNTY,
  ORG.BelongOrga         AREAID,
  ORG.OWNERTYPE          OWNERTYPE,
  ORG.OrgaDesc           NOTES,
  ORG.CreateDate         CREATEDATE,
  to_number(decode(ORG.ORGASTATE,1,0,0,1,2,2,0,ORG.ORGASTATE))       STATUS,
  ORG.StatusDate         STATUSDATE,
  ORG.AGENTTYPEID        AGENTTYPEID,
  ORG.STARLEVEL          STARLEVEL,
  ORG.DISTTYPEID         DISTTYPEID,
  ORG.ISCHANNELAUTHFILTER ISCHANNELAUTHFILTER,
  ORG.DEPARTCODE         DEPARTCODE,
  ORG.AGENTSTYLE         AGENTSTYLE,
  ORG.ISPROVCHAIN ISPROVCHAIN,
  ORG.CHAINNAME CHAINNAME
FROM "ICDPUB".T_UCP_ORGAINFO ORG
;

CREATE OR REPLACE  VIEW "IM"."OPERATOR" ("OPERID", "REGION", "OPERNAME", "PASSWORD", "PASSCHGDATE", "OPERGROUP", "OPERTYPE", "OPERLEVEL", "ISMANAGER", "CONTACTPHONE", "ORGID", "ISRESTRICT", "STARTTIME", "ENDTIME", "ENABLEGPRS", "GPRSSTARTTIME", "GPRSENDTIME", "ISCHKMAC", "MAC", "NOTES", "CREATEDATE", "STATUS", "STATUSDATE", "RELE_STAFF_ID", "START_USING_TIME", "END_USING_TIME", "LOGINTYPE", "AREAID", "ISCHECKTICKET", "BBOSSOPERID") AS
  SELECT
    BASIC.STAFFID             OPERID,
    BASIC.CURRENTREGION       region,
    BASIC.STAFFNAME           OPERNAME,
    pwd.PASSWORD              PASSWORD,
    pwd.UPDATEDATE            PASSCHGDATE,
    BASIC.PteamId             OPERGROUP,
    BASIC.StaffType           OPERTYPE,
    BASIC.DlevelId            OPERLEVEL,
    BASIC.isManager           ISMANAGER,
    BASIC.TELNO              CONTACTPHONE,
    BASIC.CURRENTORGAID     orgid,
    RESTRICT.isRestrict       ISRESTRICT,
    RESTRICT.StartTime        STARTTIME,
    RESTRICT.EndTime          ENDTIME,
    RESTRICT.enableGRPS       ENABLEGPRS,
    RESTRICT.GPRSStartTime    GPRSSTARTTIME,
    RESTRICT.GPRSEndTime      GPRSENDTIME,
    RESTRICT.MacMode          ISCHKMAC,
    Mac.Macvalue              MAC,
    BASIC.Remark              NOTES,
    BASIC.CreateDate          CREATEDATE,
    to_number(decode(BASIC.STAFFIDSTATUS,'01','1','02','2','03','0',BASIC.STAFFIDSTATUS))       STATUS,
    BASIC.StatusDate          STATUSDATE,
    BASIC.RELESTAFFID         RELE_STAFF_ID,
    BASIC.BeginDate           START_USING_TIME,
    BASIC.EndDate             END_USING_TIME,
    BASIC.LOGINTYPE           LOGINTYPE,
    BASIC.areaid              areaid,
    RESTRICT.ISCHECKTICKET    ISCHECKTICKET,
    BBOSSINFO.BBOSSSTAFFID    BBOSSOPERID
from ICDPUB.T_UCP_STAFFBASICINFO BASIC ,
      ICDPUB.T_UCP_PASSWORD    pwd,
      ICDPUB.T_UCP_STAFFEXTENDINFO EXTEND,
      ICDPUB.T_UCP_STAFFRESTRICTINFO RESTRICT,
      ICDPUB.T_UCP_StaffMac Mac,
      ICDPUB.T_UCP_STAFF_BBOSS_INFO BBOSSINFO
WHERE BASIC.Staffid = pwd.staffid(+)
  AND BASIC.Staffid = EXTEND.Staffid(+)
  AND BASIC.Staffid = RESTRICT.Staffid(+)
  AND BASIC.Staffid = Mac.Staffid(+)
  AND BASIC.Staffid = BBOSSINFO.Staffid(+)
;

CREATE OR REPLACE VIEW "IM"."PSI_ORGANIZATION" ("ORGID", "REGION", "ORGNAME", "DISPLAYNAME", "ORGTYPE", "ORGLEVEL", "ISINNER", "MANAGERID", "PARENTID", "OPENPHONE", "ADDRESS", "POSTCODE", "CONTACTMAN", "CONTACTPHONE", "FAX", "EMAIL", "COUNTY", "AREAID", "OWNERTYPE", "NOTES", "CREATEDATE", "STATUS", "STATUSDATE", "AGENTTYPEID", "STARLEVEL", "DISTTYPEID", "ISCHANNELAUTHFILTER", "DEPARTCODE") AS
  SELECT
  ORG.ORGAID             ORGID,
  to_number(ORG.AreaCode)      REGION,
  ORG.ORGANAME           ORGNAME,
  ORG.ORGANAME||'('|| ORG.ORGAID ||')'   DISPLAYNAME,
  ORG.ORGATYPEID         ORGTYPE,
  ORG.OrgaLevel          ORGLEVEL,
  ORG.isInner            ISINNER,
  ORG.MONITORID          MANAGERID,
  ORG.PARENTID           PARENTID,
  ORG.OPENPHONE          OPENPHONE,
  ORG.ADDRESS            ADDRESS,
  ORG.POSTALCODE         POSTCODE,
  ORG.CONTACTSTAFFNO     CONTACTMAN,
  ORG.CONTACTTELNO       CONTACTPHONE,
  ORG.FAXNO              FAX,
  ORG.EMAIL              EMAIL,
  ORG.Cityflag           COUNTY,
  ORG.BelongOrga         AREAID,
  ORG.OWNERTYPE          OWNERTYPE,
  ORG.OrgaDesc           NOTES,
  ORG.CreateDate         CREATEDATE,
  to_number(decode(ORG.ORGASTATE,1,0,0,1,2,2,0,ORG.ORGASTATE))       STATUS,
  ORG.StatusDate         STATUSDATE,
  ORG.AGENTTYPEID        AGENTTYPEID,
  ORG.STARLEVEL          STARLEVEL,
  ORG.DISTTYPEID         DISTTYPEID,
  ORG.ISCHANNELAUTHFILTER ISCHANNELAUTHFILTER,
  ORG.ORGAID	         DEPARTCODE
FROM ICDPUB.T_UCP_ORGAINFO ORG
;




