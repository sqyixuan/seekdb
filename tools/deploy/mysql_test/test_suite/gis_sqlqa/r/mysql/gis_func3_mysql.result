drop table tt1;
create table tt1(g geometry not null);
insert into tt1 values(ST_GeomFromText('point(10 20)',26918));
insert into tt1 values(ST_GeomFromText('point(10 20)'));
insert into tt1 values(ST_GeomFromText('point(10 20)',0));
insert into tt1 values(ST_GeomFromText('LINESTRING(0 0, 10 10, 20 25, 50 60)',0));
insert into tt1 values(ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0),(5 5,7 5,7 7,5 7, 5 5))',26918));
insert into tt1 values(ST_GeomFromText('MULTIPOINT(0 0, 20 20, 60 60)'));
insert into tt1 values(ST_GeomFromText('MULTILINESTRING((10 10, 20 20), (15 15, 30 15))',26918));
insert into tt1 values(ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)),((5 5,7 5,7 7,5 7, 5 5)))'));
insert into tt1 values(ST_GeomFromText('GEOMETRYCOLLECTION(POINT(10 10), POINT(30 30), LINESTRING(15 15, 20 20))',26918));
select st_buffer(g,1) from tt1;
