##############VIEW##############
######update#####
drop table if exists T_GEO;
drop view if exists V_T_GEO;
create table T_GEO (gid int auto_increment primary key, geo geometry ,geo_c GEOMETRYCOLLECTION,poi point,lin linestring ,pol polygon,M_POI MULTIPOINT,M_LIN MULTILINESTRING ,M_POL MULTIPOLYGON );
create view V_T_GEO AS SELECT * FROM T_GEO;
INSERT INTO V_T_GEO VALUES (1,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL);
UPDATE V_T_GEO SET GEO=ST_GEOmfromtext('POINT(1 1)');
SELECT ST_ASTEXT(GEO),ST_ASTEXT(GEO_C),ST_ASTEXT(POI),ST_ASTEXT(M_POI),ST_ASTEXT(LIN),ST_ASTEXT(M_LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POL) FROM V_T_GEO;
+----------------+------------------+----------------+------------------+----------------+------------------+----------------+------------------+
| ST_ASTEXT(GEO) | ST_ASTEXT(GEO_C) | ST_ASTEXT(POI) | ST_ASTEXT(M_POI) | ST_ASTEXT(LIN) | ST_ASTEXT(M_LIN) | ST_ASTEXT(POL) | ST_ASTEXT(M_POL) |
+----------------+------------------+----------------+------------------+----------------+------------------+----------------+------------------+
| POINT(1 1)     | NULL             | NULL           | NULL             | NULL           | NULL             | NULL           | NULL             |
