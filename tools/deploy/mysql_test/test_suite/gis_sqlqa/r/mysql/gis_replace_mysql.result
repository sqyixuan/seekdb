###########REPLACE#############
drop table if exists T_GEO;
drop view if exists V_T_GEO;
create table T_GEO (gid int auto_increment primary key, geo geometry ,geo_c GEOMETRYCOLLECTION,poi point,lin linestring ,pol polygon,M_POI MULTIPOINT,M_LIN MULTILINESTRING ,M_POL MULTIPOLYGON );
create view V_T_GEO AS SELECT * FROM T_GEO;
##NULL##
replace into T_GEO VALUES (null,null,null,null,null,null,null,null,null);
REPLACE into T_GEO(geo) values (null);
REPLACE into T_GEO(geo) values (sT_GEOmfromtext(null));
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1 1)',null));
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1 1)',null,null));
