drop FUNCTION if EXISTS max_line;
create function max_line(len int) returns varchar(10000)
begin
	declare a varchar(10000) ;
    declare b varchar(10000) ;
	declare i int;
	set a = 'linestring(';
	set i = 0;
	while i < len do
		set i = i + 1;
		set a = concat(a,i,' ',i,',');
	end while;
	set b = concat(substr(a,1,length(a)-1),')');
	return b;
end;
//
select st_astext(st_geomfromtext(concat('linestring(1 1,1 1',')')));
+--------------------------------------------------------------+
| st_astext(st_geomfromtext(concat('linestring(1 1,1 1',')'))) |
+--------------------------------------------------------------+
| LINESTRING(1 1,1 1)                                          |
+--------------------------------------------------------------+
drop table if EXISTS ff01;
create table ff01 (g GEOMETRY);
insert into ff01 values (st_geomfromtext(max_line(64)));
select st_aswkt(g) from ff01;
