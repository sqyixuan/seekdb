SELECT _ST_DWITHIN(ST_GEOMFROMTEXT(CONCAT('POINT(','0 1',')')),ST_GEOMFROMTEXT(CONCAT('MULTILINESTRING(',CONCAT('(','-92968.23503214995 -68734.35580112855',',','1e-17 1e-17',',','-1 2',',','-913.3616294416527 154.1696418163881',')'),')')),1000);
