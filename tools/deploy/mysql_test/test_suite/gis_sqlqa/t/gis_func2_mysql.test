##SRID不同##
--error 3033
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)',4326),ST_GEOMFROMTEXT('POINT(1 2)',0),1000);

SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)'),ST_GEOMFROMTEXT('POINT(1 2)'),1);
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)'),ST_GEOMFROMTEXT('POINT(1 2)'),0);
--error 3037
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)'),ST_GEOMFROMTEXT('POINT(1 2)'),-1);

##pg显示超范围，ob正常执行##
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)'),ST_GEOMFROMTEXT('POINT(1 2)'),1E-324);
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT('POINT(1 2)'),ST_GEOMFROMTEXT('POINT(1 2)'),0.000000008);


##other type##
--error 3037
SELECT _ST_DWITHIN(1,1,1);
--error 3037
SELECT _ST_DWITHIN(0.1,0.1,0.1);
--error 3037
SELECT _ST_DWITHIN('POINT','POINT',10);
--error 3037
SELECT _ST_DWITHIN(true,true,false);


##PG可以写成如下格式，ob报错##
#SELECT _ST_DWITHIN('POINT(1 1)','POINT(1 1)',10);

##WKT_NOSRID##

SELECT _ST_DWITHIN(ST_GEOMFROMTEXT(CONCAT('POINT(','527.050859903703 -155.90278593360551',')')),ST_GEOMFROMTEXT(CONCAT('POINT(','0 0',')')),1000);
SELECT _ST_DWITHIN(ST_GEOMFROMTEXT(CONCAT('POINT(','-2057.8252218124508 -5980.149997060238',')')),ST_GEOMFROMTEXT(CONCAT('LINESTRING(','0.1234567898765432123456789 -0.12345678998765432123456789',',','-92968.23503214995 -68734.35580112855',',','1 2',',','51432.665263966715 26144.43555522214',')')),1000);
