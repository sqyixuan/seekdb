########################_ST_GeomFromEWKT####################
##仅支持在GEOMETRYCOLLECTION中使用empty##
#mysql not support:CIRCULARSTRING/COMPOUNDCURVE/CURVEPOLYGON/MULTICURVE/MULTISURFACE/POLYHEDRALSURFACE/TRIANGLE/TIN#
--error 3037
SELECT _ST_GEOMFROMEWKT('POINT');
--error 3037
SELECT _ST_GEOMFROMEWKT(1.23);
--error 3037
SELECT _ST_GEOMFROMEWKT(FALSE);
select _ST_ASEWKT(_ST_GeomFromEWKT('MULTIPOINT (1 2, 2 1, 0 0)'));
--error 1582
select _ST_ASEWKT(_ST_GeomFromEWKT());

select _ST_ASEWKT(_ST_GeomFromEWKT(null));
--error 3037
select _ST_ASEWKT(_ST_GeomFromEWKT(''));
select _ST_ASEWKT(_ST_GeomFromEWKT('GEOMETRYCOLLECTION empty'));

set @a = 'point(123.32112345678987654 -321.123)';
select _ST_ASEWKT(_ST_GeomFromEWKT(@a));

