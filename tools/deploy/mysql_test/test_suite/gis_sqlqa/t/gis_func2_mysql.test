####################_ST_TRANSFORM####################
#####对比pg加::geography，与pg存在误差，小数点12位后不一致#####
--error 1582
SELECT _ST_TRANSFORM(NULL);
SELECT _ST_TRANSFORM(NULL,NULL);
SELECT _ST_TRANSFORM(NULL,NULL,NULL);
--error 1582
SELECT _ST_TRANSFORM(NULL,NULL,NULL,NULL);

SELECT _ST_ASEWKT(_ST_Transform(ST_GeomFromText('POLYGON((743238 2967416,743238 2967450, 743265 2967450,743265.625 2967416,743238 2967416))',2249,'axis-order=long-lat'),4326));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POLYGON((743238 2967416,743238 2967450, 743265 2967450,743265.625 2967416,743238 2967416))',26918),4326));

##other type##
--error 3037
SELECT _ST_ASEWKT(_ST_TRANSFORM(1,1));
--error 3037
SELECT _ST_ASEWKT(_ST_TRANSFORM(0.01,0.011));
--error 3037
SELECT _ST_ASEWKT(_ST_TRANSFORM('POINT(1,1)',4326));
--error 3037
SELECT _ST_ASEWKT(_ST_TRANSFORM(TRUE,FALSE));
--error 3037
SELECT _ST_ASEWKT(_ST_TRANSFORM('POINT(1 1)',4326));

SELECT _ST_ASEWKT(_ST_TRANSFORM(_ST_GEOGRAPHYFROMTEXT('POINT(1 2)'),4326));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(180 90)',26918),4326));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(180 90)',4326,'axis-order=long-lat'),26918));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(180 90)',26918),'+proj=gnom +ellps=WGS84 +lat_0=70 +lon_0=-160 +no_defs'));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(90 180)',26918),'+proj=gnom +ellps=WGS84 +lat_0=70 +lon_0=-160 +no_defs','+proj=gnom +ellps=WGS84 +lat_0=80 +lon_0=-150 +no_defs'));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(90 180)',26918),'+proj=gnom +ellps=WGS84 +lat_0=80 +lon_0=-150 +no_defs',26918));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(90 180)',26918),'+proj=gnom +ellps=WGS84 +lat_0=80 +lon_0=-150 +no_defs',4326));

SELECT _ST_ASEWKT(_ST_TRANSFORM(ST_GEOMFROMTEXT('POINT(90 180)',26918),'+proj=gnom +ellps=WGS84'));

##结果有误差##
