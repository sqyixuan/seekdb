##index##
--disable_warnings
drop table if exists T_GEO;
--enable_warnings
create table T_GEO ( geo geometry NOT NULL ,INDEX SP_GEO(GEO));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','2 -1',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','9080.77045339013 -5435.342241394849',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','-65520.84410620509 -98697.07459123731',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','1796.813742519489 -5625.890596437841',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','-2057.8252218124508 -5980.149997060238',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','-56871.46664639187 92358.88139253986',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','-537.4528627587551 -378.5985437586205',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','595.4910208075078 -902.4453557940006',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','2 1',')')));
INSERT INTO T_GEO(GEO) VALUES (ST_GEOMFROMTEXT(CONCAT('POINT(','0 0',')')));

SELECT st_astext(geo) FROM T_GEO WHERE _ST_DWITHIN(GEO,sT_GEOmfromtext('MULTIPOINT (1 1, 2 2, 3 3)'),100);

#EXPLAIN EXTENDED SELECT st_astext(geo) FROM T_GEO WHERE _ST_DWITHIN(GEO,sT_GEOmfromtext('MULTIPOINT (1 1, 2 2, 3 3)'),100);

#EXPLAIN EXTENDED SELECT st_astext(geo) FROM T_GEO WHERE ST_CONTAINS(GEO,sT_GEOmfromtext('MULTIPOINT (0 0,0 0,0 0,0 0)'));

--disable_warnings
drop table if exists T_GEO;
--enable_warnings

##########################_ST_POINT#####################
--error 1582
SELECT _ST_POINT(NULL);
SELECT _ST_POINT(NULL,NULL);
SELECT _ST_POINT(NULL,NULL,NULL);
--error 1582
SELECT _ST_POINT(NULL,NULL,NULL,NULL);

--error 5083
SELECT _ST_POINT(point(2,1),point(1,2));

##WKT_NOSRID##
SELECT ST_ASTEXT(_ST_POINT(1,1));
SELECT ST_ASTEXT(_ST_POINT(1,2,4326));
SELECT ST_ASTEXT(_ST_POINT(1e-15,1e-15));
SELECT ST_ASTEXT(_ST_POINT(1e-16,1e-16));
SELECT ST_ASTEXT(_ST_POINT(1e-17,1e-17));

SELECT ST_ASTEXT(_ST_POINT(-1.7976931348623157E+308, -2.2250738585072014E-308));
##超出双精度值##
--error 1367
SELECT ST_ASTEXT(_ST_POINT(-1.7976931348623157E+309, -2.2250738585072014E-309));
--error 1367
SELECT ST_ASTEXT(_ST_POINT(2.2250738585072014E-308,1.7976931348623157E+309));

SELECT st_astext(_ST_POINT('123456789','-987654321'));
SELECT st_astext(_ST_POINT('1.234567890','-9.876543210'));
SELECT st_astext(_ST_POINT(1.000000,-9.00000));

SET @A = null;
SELECT st_astext(_ST_POINT(@A,@A));
SET @A = 0.000;
SELECT st_astext(_ST_POINT(@A,@A));

SELECT st_astext(_ST_POINT(round(1.23456789,-1),round(1.23456789,2)));
SELECT st_astext(_ST_POINT(abs(1.23456789),abs(-1.23456789)));
SELECT st_astext(_ST_POINT(acos(-0.54321),acos(-0.54321)));
SELECT st_astext(_ST_POINT(asin(0.54321),asin(0.54321)));
SELECT st_astext(_ST_POINT(atan(-111.234),atan(-111.234)));
SELECT st_astext(_ST_POINT(atan2(pi(),0),atan2(pi(),0)));

SELECT st_astext(_ST_POINT(ceil(-1.234),ceil(-1.234)));
SELECT st_astext(_ST_POINT(CEILING(111.123),CEILING(111.123)));

##WKT_SRID##
SELECT _ST_ASEWKT(_ST_POINT(90,90,4326));
SELECT _ST_ASEWKT(_ST_POINT(90,90,NULL));
SELECT _ST_ASEWKT(_ST_POINT(180,90,4326));

SELECT _ST_ASEWKT(_ST_POINT(180,90,26918));
SELECT _ST_ASEWKT(_ST_POINT(180,180,26918));

SELECT ST_ASTEXT(_ST_POINT(11,22,26918));
SELECT ST_ASTEXT(_ST_POINT(11,22,4326));
--error 1292
SELECT ST_ASTEXT(_ST_POINT(11,22,'4326S'));


##OB会判断经纬度范围##
--error 3617
SELECT _ST_POINT(180,180,4326);


##这条不兼容pg行为##
SELECT ST_ASTEXT(_ST_POINT(1E-324,1E-324));
##（bug）与pg行为不一致的问题##
##与point表达式行为一致##
##other type##
##其他类型ob与pg行为都不一致（已修复）##
--error 1292
SELECT _ST_POINT('','');
--error 1292
SELECT ST_ASTEXT(_ST_POINT('A123213','a23123'));
--error 1292
SELECT ST_ASTEXT(_ST_POINT('ABC','CBA'));
--error 5083
SELECT ST_ASTEXT(_ST_POINT(true,false));
--error 5083
SELECT ST_ASTEXT(_ST_POINT(DATE('2000-11-11'),DATE('2000-11-11')));


##（bug）srid为非正常类型，ob与pg行为不一致（已修复）##
--error 5083
SELECT _ST_ASEWKT(_ST_POINT(11,22,4326.123));
--error 1292
