##################POINT#####################
--disable_warnings
drop table if exists T_GEO;
--enable_warnings
create table T_GEO (GID INT auto_increment primary key, POI POINT ,M_POI MULTIPOINT,LIN LINESTRING,M_LIN MULTILINESTRING,POL POLYGON,M_POL MULTIPOLYGON);
#null#
REPLACE INTO T_GEO(poi,M_POI,LIN,M_LIN,POL,M_POL) VALUES (null,NULL,NULL,NULL,NULL,NULL);
REPLACE INTO T_GEO(poi,M_POI,LIN,M_LIN,POL,M_POL) VALUES (sT_GEOmfromtext(null),sT_GEOmfromtext(null),sT_GEOmfromtext(null),sT_GEOmfromtext(null),sT_GEOmfromtext(null),sT_GEOmfromtext(null));

select st_astext(poi),ST_ASTEXT(M_POI),ST_ASTEXT(LIN),ST_ASTEXT(M_LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POL) from T_GEO;

