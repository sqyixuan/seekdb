#LineString#
#pg/mysql应该都是整个binary长度不超过4G/1G,OB lob现在只能支持到48M#
#长度测试到65535个point#
#重合#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('linestring(1 1,1 1)'));
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('linestring(1 1,0 0,-1 -1,1 1)')),(sT_GEOmfromtext('linestring(1 1,0 0,-1 -1,1 1)'));
#交叉#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('linestring(0 0,1 1,1 0,0 1)'));
#环#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('linestring(0 0,1 1,1 0,0 0)'));

