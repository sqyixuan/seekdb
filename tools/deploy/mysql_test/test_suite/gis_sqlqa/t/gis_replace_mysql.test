drop table if exists TT_GEO;
--enable_warnings

create table TT_GEO (gid int auto_increment primary key,geo GEOMETRY SRID 4326,POI POINT NOT NULL);
replace into TT_GEO VALUES (1,st_geomfromtext('point(90 90)',4326),ST_GEOMFROMTEXT('POINT(1 2)'));
