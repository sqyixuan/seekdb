--result_format 4
--disable_warnings
--error 0,1396
drop user 'zc_gis_mysql'@'%';
create user 'zc_gis_mysql'@'%' IDENTIFIED BY 'zc_gis_mysql';
grant all on *.* to 'zc_gis_mysql'@'%' WITH GRANT OPTION;


####添加srs#####
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
--enable_warnings
--disable_query_log
--disable_result_log
--source mysql_test/test_suite/gis_sqlqa/default_srs_data_mysql.sql
--enable_query_log
--enable_result_log

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_gis_mysql,zc_gis_mysql,test,$OBMYSQL_PORT);
connection conn;

--disable_warnings
drop table if exists T_GEO;
drop view if exists V_T_GEO;
--enable_warnings


#########################REPLACE#########################
####写入GEOMETRY类型列（wkt不含srid）####
--disable_warnings
drop table if exists T_GEO;
--enable_warnings
create table T_GEO (gid int auto_increment primary key, geo geometry);
#null#
REPLACE into T_GEO(geo) values (null);
REPLACE into T_GEO(geo) values (sT_GEOmfromtext(null));
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1 1)',null));
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1 1)',null,null));
--error 1416
REPLACE into T_GEO(geo) values ('');

#point#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1 1)'));
#超过15位转为小数，与mysql一致#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(1234567898765432123456789 -12345678998765432123456789)'));
REPLACE into T_GEO(geo) values (point(2,-2));
#精度截取小数点后17位#
REPLACE into T_GEO(geo) values (sT_GEOmfromtext('point(0.1234567898765432123456789 -0.12345678998765432123456789)'));
