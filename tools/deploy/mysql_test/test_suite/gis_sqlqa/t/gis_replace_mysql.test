############srid############
drop table if exists T_GEO;
##不允许变量作为srid##
SET @A=4326;
--error 1064
create table T_GEO (gid int auto_increment primary key, geometry geometry srid @A,geom_coll GEOMETRYCOLLECTION SRID @A,poi point SRID 4269,lin linestring SRID 26918,pol polygon SRID 3395,M_POI MULTIPOINT SRID 31287,M_LIN MULTILINESTRING 4326,M_POL MULTIPOLYGON 4269);

create table T_GEO (gid int auto_increment primary key, geometry geometry srid 0,geom_coll GEOMETRYCOLLECTION SRID 4326,poi point SRID 4269,lin linestring SRID 26918,pol polygon SRID 3395,M_POI MULTIPOINT SRID 31287,M_LIN MULTILINESTRING SRID 4326,M_POL MULTIPOLYGON SRID 4269);

