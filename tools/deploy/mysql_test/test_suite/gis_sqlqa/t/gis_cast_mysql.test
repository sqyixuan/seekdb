purge recyclebin;
let $char_charset = 'utf8';

####添加srs#####
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
--disable_query_log
--disable_result_log
--source mysql_test/test_suite/gis_sqlqa/default_srs_data_mysql.sql
--enable_result_log
--enable_query_log
connection default;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--result_format 4
--error 0,1051
drop table tt1;
create table tt1(id int ,g geometry not null);
insert into tt1 values(1,ST_GeomFromText('point(10 20)',26918));
insert into tt1 values(2,ST_GeomFromText('point(10 20)'));
insert into tt1 values(3,ST_GeomFromText('point(10 20)',4326));
insert into tt1 values(4,ST_GeomFromText('LINESTRING(0 0, 10 10, 20 25, 50 60)',0));
insert into tt1 values(5,ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0),(5 5,7 5,7 7,5 7, 5 5))',4326));
insert into tt1 values(6,ST_GeomFromText('MULTIPOINT(0 0, 20 20, 60 60)'));
insert into tt1 values(7,ST_GeomFromText('MULTILINESTRING((10 10, 20 20), (15 15, 30 15))',26918));
insert into tt1 values(8,ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)),((5 5,7 5,7 7,5 7, 5 5)))',4236));
insert into tt1 values(9,ST_GeomFromText('GEOMETRYCOLLECTION(POINT(10 10), POINT(30 30), LINESTRING(15 15, 20 20))',26918));
