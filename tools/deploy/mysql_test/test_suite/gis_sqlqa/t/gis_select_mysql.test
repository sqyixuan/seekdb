SELECT (SELECT ST_ASTEXT(M_LIN) FROM T_GEO_SRID WHERE M_LIN <> ST_GEOMFROMTEXT(CONCAT('MULTILINESTRING(',CONCAT('(','-90 90',',','-90 -90',',','90 90',')'),',',CONCAT('(','-109.1009774 34.0795373',',','0 0',',','1e-16 1e-16',',','-90 90',')'),')'),4326,'axis-order=long-lat') LIMIT 1);

