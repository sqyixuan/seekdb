SELECT ST_ASTEXT(POI) FROM T_GEO_SRID WHERE POI <> (SELECT POI FROM T_GEO_4326 WHERE GID=1);

SELECT ST_ASTEXT(POL) FROM T_GEO_SRID WHERE GEO = (SELECT GEO FROM T_GEO_4326 WHERE GID=1);

