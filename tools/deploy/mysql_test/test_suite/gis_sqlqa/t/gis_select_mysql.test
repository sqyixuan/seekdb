drop user 'zc_gis_mysql'@'%';
create user 'zc_gis_mysql'@'%' IDENTIFIED BY 'zc_gis_mysql';
grant all on *.* to 'zc_gis_mysql'@'%' WITH GRANT OPTION;

####添加srs#####
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
--enable_warnings
--disable_query_log
--disable_result_log
--source mysql_test/test_suite/gis_sqlqa/default_srs_data_mysql.sql
--enable_query_log
--enable_result_log

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_gis_mysql,zc_gis_mysql,test,$OBMYSQL_PORT);
connection conn;

--disable_warnings
drop table if exists T_GEO;
drop view if exists V_T_GEO;
DROP TABLE IF EXISTS T_GEO_SRID;
DROP TABLE IF EXISTS T_GEO_4326;
--enable_warnings


############################SELECT#######################

create table T_GEO (gid int auto_increment primary key, geo geometry ,geo_c GEOMETRYCOLLECTION,poi point,lin linestring ,pol polygon,M_POI MULTIPOINT,M_LIN MULTILINESTRING ,M_POL MULTIPOLYGON );
create view V_T_GEO AS SELECT * FROM T_GEO;

--source mysql_test/test_suite/gis_sqlqa/insert_gis_data.sql

####where####
####gis类型作为条件####
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO=ST_GEOMFROMTEXT('POLYGON((67.18044684337276 43.13606885329847,13.07466064814453 6.21213795278766,14.034970716795877 5.453996921400399,5.170898858029036 -37.978003312451406,-59.827517708773 17.979769774227563,-1.978810124999957 21.54020784433005,67.18044684337276 43.13606885329847))');

SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT('GEOMETRYCOLLECTION empty');

SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE POI=ST_GEOMFROMTEXT('POINT(1e-16 1e-16)');

SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE LIN=ST_GEOMFROMTEXT('LINESTRING(1 1,1 1)');

SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE POL=ST_GEOMFROMTEXT('POLYGON((52.61714017789104 33.785077179805434,16.12832879204436 -22.25618347458587,19.93863169691776 -37.6442557582757,-1.971262048174262 -23.45093693628473,-42.684998609703285 18.713455219331312,52.61714017789104 33.785077179805434))');

SELECT ST_ASTEXT(M_POI) FROM T_GEO LIMIT 1;
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_POI=ST_GEOMFROMTEXT('MULTIPOINT((2 -1))');

SELECT @A:=ST_ASTEXT(M_LIN) FROM T_GEO LIMIT 1;
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_LIN=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(M_POL) FROM T_GEO LIMIT 1;
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_POL=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(GEO) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO>ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO<ST_GEOMFROMTEXT(@A);
SELECT COUNT(GEO) FROM T_GEO WHERE GEO!=ST_GEOMFROMTEXT(@A);

SELECT COUNT(GEO) FROM T_GEO WHERE GEO_C!=ST_GEOMFROMTEXT(@A);

SELECT COUNT(GEO) FROM T_GEO WHERE POI=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(GEO_C) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(GEO_C) FROM T_GEO WHERE GEO_C>ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO_C) FROM T_GEO WHERE GEO_C<ST_GEOMFROMTEXT(@A);
SELECT COUNT(GEO_C) FROM T_GEO WHERE GEO_C!=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(POI) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(POI) FROM T_GEO WHERE POI>ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(POI) FROM T_GEO WHERE POI<ST_GEOMFROMTEXT(@A);
SELECT COUNT(POI) FROM T_GEO WHERE POI!=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(LIN) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(LIN) FROM T_GEO WHERE LIN>ST_GEOMFROMTEXT(@A) OR LIN=ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(LIN) FROM T_GEO WHERE LIN<=ST_GEOMFROMTEXT(@A);
SELECT COUNT(LIN) FROM T_GEO WHERE LIN!=ST_GEOMFROMTEXT(@A) AND LIN = ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(POL) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(POL) FROM T_GEO WHERE POL>ST_GEOMFROMTEXT(@A) OR POL=ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(POL) FROM T_GEO WHERE POL<=ST_GEOMFROMTEXT(@A);
SELECT COUNT(POL) FROM T_GEO WHERE POL!=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(M_POI) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(M_POI) FROM T_GEO WHERE M_POI>=ST_GEOMFROMTEXT(@A) OR M_POI=ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(M_POI) FROM T_GEO WHERE M_POI<=ST_GEOMFROMTEXT(@A);
SELECT COUNT(M_POI) FROM T_GEO WHERE M_POI!=ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(M_LIN) FROM T_GEO LIMIT 1;
