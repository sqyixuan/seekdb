SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE POI=(SELECT POI FROM T_GEO WHERE GID=1);
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE LIN=(SELECT LIN FROM T_GEO WHERE GID=1);
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE POL=(SELECT POL FROM T_GEO WHERE GID=1);
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_POI=(SELECT M_POI FROM T_GEO WHERE GID=1);
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_LIN=(SELECT M_LIN FROM T_GEO WHERE GID=1);
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE M_POL=(SELECT M_POL FROM T_GEO WHERE GID=1);

