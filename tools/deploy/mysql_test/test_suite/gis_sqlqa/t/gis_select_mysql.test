SELECT ST_ASTEXT(GEO_C) FROM (SELECT GEO,GEO_C FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT(@A)) T;
SELECT @A:=ST_ASTEXT(POI) FROM T_GEO LIMIT 1;
SELECT ST_ASTEXT(POI) FROM (SELECT GEO,GEO_C,POI FROM T_GEO WHERE POI=ST_GEOMFROMTEXT(@A)) T;
