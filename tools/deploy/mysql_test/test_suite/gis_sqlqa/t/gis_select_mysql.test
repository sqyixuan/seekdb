#--error 1210
SELECT ST_ASTEXT(M_LIN) FROM T_GEO WHERE M_LIN<=>ST_GEOMFROMTEXT(@A);
SELECT ST_ASTEXT(M_LIN) FROM T_GEO WHERE GID<=>1;
--error 1210
SELECT ST_ASTEXT(M_LIN) FROM T_GEO WHERE M_LIN<=ST_GEOMFROMTEXT(@A);
SELECT COUNT(M_LIN) FROM T_GEO WHERE M_LIN<>ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(M_POL) FROM T_GEO LIMIT 1;
--error 1210
SELECT ST_ASTEXT(M_POL) FROM T_GEO WHERE M_POL BETWEEN ST_GEOMFROMTEXT(@A) AND ST_GEOMFROMTEXT(@A);
SELECT ST_ASTEXT(M_POL) FROM T_GEO WHERE M_POL IN (ST_GEOMFROMTEXT(@A));
SELECT ST_ASTEXT(M_POL) FROM T_GEO WHERE M_POL IN (ST_GEOMFROMTEXT(CONCAT('GEOMETRYCOLLECTION(',@A,')')));
##(bug)OB与mysql不一致（待修复取消注释）##
#--error 1210
#SELECT ST_ASTEXT(M_POL) FROM T_GEO WHERE M_POL LIKE ST_GEOMFROMTEXT(@A);
SELECT COUNT(M_POL) FROM T_GEO WHERE M_POL IS NOT TRUE;
SELECT COUNT(M_POL) FROM T_GEO WHERE M_POL IS NOT FALSE;
SELECT COUNT(M_POL) FROM T_GEO WHERE M_POL IS NOT NULL;

SELECT ST_ASTEXT(GEO),ST_ASTEXT(GEO_C),ST_ASTEXT(POI),ST_ASTEXT(LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POI),ST_ASTEXT(M_LIN),ST_ASTEXT(M_POL) FROM T_GEO WHERE GID=22;

SELECT @A:=ST_ASTEXT(POI) FROM T_GEO LIMIT 1;
--error 3726
SELECT ST_ASTEXT(GEO),ST_ASTEXT(GEO_C),ST_ASTEXT(POI),ST_ASTEXT(LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POI),ST_ASTEXT(M_LIN),ST_ASTEXT(M_POL) FROM T_GEO WHERE ST_LATITUDE(POI)= ST_LONGITUDE(@A);

####groupby####
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY POI WITH ROLLUP;

SELECT @A:=ST_ASTEXT(GEO_C) FROM T_GEO LIMIT 2;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C = ST_GEOMFROMTEXT(@A);
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C != ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C > ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C < ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C >= ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C <= ST_GEOMFROMTEXT(@A);
#(bug)与where问题一样（已修复）#
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C <=> ST_GEOMFROMTEXT(@A);
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C IS NULL;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C IS TRUE;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING GEO_C IS FALSE;

SELECT @A:=ST_ASTEXT(POI) FROM T_GEO LIMIT 2;
SELECT COUNT(GEO) FROM T_GEO GROUP BY POI HAVING POI = ST_GEOMFROMTEXT(@A);
SELECT COUNT(GEO) FROM T_GEO GROUP BY POI HAVING POI != ST_GEOMFROMTEXT(@A);

SELECT @A:=ST_ASTEXT(M_POL) FROM T_GEO LIMIT 2;
SELECT COUNT(GEO) FROM T_GEO GROUP BY M_POL HAVING M_POL = ST_GEOMFROMTEXT(@A);
SELECT COUNT(GEO) FROM T_GEO GROUP BY M_POL HAVING M_POL != ST_GEOMFROMTEXT(@A);

#(BUG)嵌套除了count，max，min函数，其他结果不一致（已修复）#
SELECT @A:=ST_ASTEXT(GEO_C) FROM T_GEO LIMIT 1;
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING COUNT(GEO_C) = 4;
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING AVG(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING STD(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING STDDEV_SAMP(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING SUM(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING VAR_POP(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING VAR_SAMP(GEO_C) = ST_GEOMFROMTEXT(@A);
--error 1210
SELECT ST_ASTEXT(GEO) FROM T_GEO GROUP BY GEO_C HAVING VARIANCE(GEO_C) = ST_GEOMFROMTEXT(@A);

####ORDERBY####
##根据gis类型字段order顺序不一致，预期##
SELECT @A:=ST_ASTEXT(GEO_C) FROM T_GEO LIMIT 2;
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO_C= ST_GEOMFROMTEXT(@A) ORDER BY 1;

SELECT ST_ASTEXT(GEO) FROM T_GEO ORDER BY GID LIMIT 5;

SELECT GID FROM T_GEO ORDER BY POL LIMIT 5;
SELECT GID FROM T_GEO ORDER BY POI LIMIT 5;

SELECT @A:=ST_ASTEXT(M_POL) FROM T_GEO LIMIT 2;
SELECT GID FROM T_GEO GROUP BY M_POL HAVING M_POL = ST_GEOMFROMTEXT(@A) ORDER BY M_POL;

#####join#####
###MYSQL没有full join###
DROP TABLE IF EXISTS T_GEO_SRID;
create table T_GEO_SRID (gid int auto_increment primary key, geo geometry SRID 4326,geo_c GEOMETRYCOLLECTION SRID 26918,poi point SRID 4326,lin linestring SRID 26918,pol polygon SRID 4326,M_POI MULTIPOINT SRID 26918,M_LIN MULTILINESTRING SRID 4326 ,M_POL MULTIPOLYGON SRID 26918);
DROP TABLE IF EXISTS T_GEO_4326;
create table T_GEO_4326 (gid int auto_increment primary key, geo geometry SRID 4326,geo_c GEOMETRYCOLLECTION SRID 4326,poi point SRID 4326,pol polygon SRID 4326,M_LIN MULTILINESTRING SRID 4326);

--source mysql_test/test_suite/gis_sqlqa/insert_gis_data_4326.sql

SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.GID=B.GID;
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.GEO=B.GEO;
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.POI=B.POI;
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.POL=B.POL;
SELECT ST_ASTEXT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.M_LIN=B.M_LIN;

SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.GID>B.GID;
--error 1210
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.GEO<B.GEO;
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.POI!=B.POI;
SELECT COUNT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.POL<>B.POL;
SELECT ST_ASTEXT(A.GEO) FROM T_GEO_4326 A,T_GEO_SRID B WHERE A.M_LIN IN (B.M_LIN);

##Self-Join##
SELECT COUNT(*) FROM T_GEO_SRID A,T_GEO_SRID B WHERE A.GEO=B.GEO;
--error 1210
SELECT COUNT(*) FROM T_GEO_SRID A,T_GEO_SRID B WHERE A.POI>B.POI;
--error 1210
SELECT COUNT(*) FROM T_GEO_SRID A,T_GEO_SRID B WHERE A.lin<B.lin;
SELECT COUNT(*) FROM T_GEO_SRID A,T_GEO_SRID B WHERE A.POL!=B.POL;
SELECT COUNT(*) FROM T_GEO_SRID A,T_GEO_SRID B WHERE A.GEO_C IN (B.GEO_C);

##Inner-Join##
SELECT COUNT(*) FROM T_GEO_SRID A JOIN T_GEO_4326 B USING(GEO);
SELECT COUNT(*) FROM T_GEO_SRID A JOIN T_GEO_4326 B USING(GEO_C);
SELECT COUNT(*) FROM T_GEO_SRID A JOIN T_GEO_4326 B USING(POI);
SELECT COUNT(*) FROM T_GEO_SRID A JOIN T_GEO_4326 B WHERE A.POL!=B.POI ;
SELECT COUNT(*) FROM T_GEO_SRID A FULL JOIN T_GEO_4326 B on A.POL!=B.POI ;

##Outer-Join##
SELECT ST_ASTEXT(A.GEO) FROM T_GEO_SRID A LEFT JOIN T_GEO_4326 B ON A.GEO=B.GEO ORDER BY A.GID LIMIT 10;

SELECT ST_ASTEXT(A.POI) FROM T_GEO_SRID A RIGHT JOIN T_GEO_4326 B ON A.GEO_C!=B.GEO_C ORDER BY A.GID LIMIT 10;

SELECT ST_ASTEXT(A.POI) FROM T_GEO_SRID A JOIN T_GEO_4326 B ON A.GEO_C!=B.GEO_C ORDER BY A.GID LIMIT 10;

SELECT ST_ASTEXT(A.GEO) FROM T_GEO_SRID A CROSS JOIN T_GEO_4326 B WHERE A.GEO=B.GEO ORDER BY A.GID LIMIT 10;

SELECT ST_ASTEXT(A.GEO) FROM T_GEO_SRID A NATURAL JOIN T_GEO_4326 B WHERE A.GEO=B.GEO ORDER BY A.GID LIMIT 10;

