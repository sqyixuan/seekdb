####DISTINCT####
SELECT DISTINCT ST_ASTEXT(GEO),GID FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT('GEOMETRYCOLLECTION EMPTY') ORDER BY GID;

SELECT DISTINCT ST_ASTEXT(GEO_C),ST_ASTEXT(GEO),ST_ASTEXT(POI),ST_ASTEXT(LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POI),ST_ASTEXT(M_LIN),ST_ASTEXT(M_POL) FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT('GEOMETRYCOLLECTION EMPTY') ORDER BY GID;

####FROM连接表#####
SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10;
SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A LEFT JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10;
SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A RIGHT JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10;
SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A CROSS JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10;

####UNION####
(SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10) UNION (SELECT ST_ASTEXT(A.GEO),ST_ASTEXT(B.GEO) FROM T_GEO A RIGHT JOIN T_GEO_SRID B ON A.GID=B.GID LIMIT 10);

(SELECT HEX(A.M_POL),HEX(B.POL) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.GEO),HEX(B.LIN) FROM T_GEO A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID);
(SELECT HEX(A.GEO_C),HEX(B.M_LIN) FROM T_GEO_SRID A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID) UNION (SELECT HEX(A.M_LIN),HEX(B.POL) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID);
(SELECT HEX(A.POL),HEX(B.GEO) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.POL),HEX(B.POI) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID);
(SELECT HEX(A.POL),HEX(B.GEO_C) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.M_LIN),HEX(B.M_LIN) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID);
(SELECT HEX(A.POI),HEX(B.GEO) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.POI),HEX(B.GEO_C) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID);
(SELECT HEX(A.M_POI),HEX(B.GEO_C) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.M_POL),HEX(B.M_POL) FROM T_GEO A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID);
(SELECT HEX(A.LIN),HEX(B.POL) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.GEO),HEX(B.LIN) FROM T_GEO_SRID A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID);
(SELECT HEX(A.GEO),HEX(B.M_POL) FROM T_GEO A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID) UNION (SELECT HEX(A.LIN),HEX(B.GEO) FROM T_GEO A INNER JOIN T_GEO_SRID B WHERE A.GID=B.GID);
(SELECT HEX(A.LIN),HEX(B.M_POL) FROM T_GEO_SRID A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.GEO_C),HEX(B.M_POI) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID);
(SELECT HEX(A.M_LIN),HEX(B.POI) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID) UNION (SELECT HEX(A.M_POL),HEX(B.M_POL) FROM T_GEO A INNER JOIN T_GEO B WHERE A.GID=B.GID);

