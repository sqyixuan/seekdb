SELECT ST_ASTEXT(M_LIN) FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT('GEOMETRYCOLLECTION EMPTY');
SELECT ST_ASTEXT(M_POL) FROM T_GEO WHERE GEO_C=ST_GEOMFROMTEXT('GEOMETRYCOLLECTION EMPTY');

