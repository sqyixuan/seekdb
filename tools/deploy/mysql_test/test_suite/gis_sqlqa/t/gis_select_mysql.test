SELECT ST_ASTEXT(POL) FROM T_GEO_SRID A WHERE NOT EXISTS (SELECT A.LIN,A.GEO FROM T_GEO_SRID WHERE A.POI != ST_GEOMFROMTEXT(CONCAT('POINT(','90 90',')'),4326,'axis-order=long-lat'));

SELECT ST_ASTEXT(POI) FROM T_GEO_SRID A WHERE NOT EXISTS (SELECT A.POI,A.M_POI FROM T_GEO_SRID WHERE A.GEO=ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','0 0',',','90 90',')'),4326,'axis-order=long-lat'));

SELECT ST_ASTEXT(POI) FROM T_GEO_SRID A WHERE POL = (SELECT POL FROM T_GEO_4326 B WHERE A.GEO=B.GEO LIMIT 1);

SELECT ST_ASTEXT(GEO) FROM T_GEO_SRID A WHERE POL != (SELECT POL FROM T_GEO_4326 B WHERE A.M_LIN <> B.M_LIN LIMIT 1);

SELECT ST_ASTEXT(M_LIN) FROM T_GEO_SRID A WHERE POI != (SELECT POI FROM T_GEO_4326 B WHERE A.M_LIN <> B.M_LIN LIMIT 1);

SELECT ST_ASTEXT(M_LIN) FROM T_GEO_SRID A WHERE GEO = (SELECT GEO FROM T_GEO_4326 B WHERE A.M_LIN <> B.M_LIN LIMIT 1);

