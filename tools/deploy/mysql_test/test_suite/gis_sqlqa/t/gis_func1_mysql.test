select st_astext(st_geomfromtext('GEOMETRYCOLLECTION()'));
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION empty'));
--error 3037
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION (0 0)'));
--error 3037
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION(null)'));
--error 3037
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION(())'));
--error 3037
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION((0 0))'));
--error 3037
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION(point())'));
select st_astext(st_geomfromtext('GEOMETRYCOLLECTION(point(0 0))'));
