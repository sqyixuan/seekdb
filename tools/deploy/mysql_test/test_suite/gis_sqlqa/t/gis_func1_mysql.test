##MULTIPOINT,MULTIPOINT##
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','-109.1009774 34.0795373',',','-90 -90',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','90 90',',','1e-17 1e-17',',','108.7816873 34.0818121',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','1e-17 1e-17',',','1e-14 1e-14',',','-90 90',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','90 90',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','108.9166131 -34.2701282',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','108.7816873 34.0818121',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','108.7816873 34.0818121',',','90 90',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','108.9571252 34.1841173',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','90 -90',',','90 90',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','90 -90',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','1e-16 1e-16',',','-90 90',',','1e-15 1e-15',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','1e-16 1e-16',')')));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','90 -90',')')),ST_GEOMFROMTEXT(CONCAT('MULTIPOINT(','-90 -90',',','1e-16 1e-16',')')));


##WKB##
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'0101000000B54C2B2A07325B4063F5A2D1780A4140'),ST_GEOMFROMWKB(X'010100000074E5FDC9A93A5B401A5D948F932241C0'));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'010100000000000000008056C00000000000805640'),ST_GEOMFROMWKB(X'0101000000000000000080564000000000008056C0'));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'01010000001656E79EAF03D23C1656E79EAF03D23C'),ST_GEOMFROMWKB(X'010100000074E5FDC9A93A5B401A5D948F932241C0'));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'01010000005B0B0E8A413D5B405C10DB2791174140'),ST_GEOMFROMWKB(X'010100000000000000008056C00000000000805640'));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'01010000005B0B0E8A413D5B405C10DB2791174140'),ST_GEOMFROMWKB(X'01010000009B2BA1869B84063D9B2BA1869B84063D'));

SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'010100000000000000008056C000000000008056C0',4326),ST_GEOMFROMWKB(X'010100000000000000008056400000000000805640',4326));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'01010000005C10DB279117414063F5A2D1780A4140',4326),ST_GEOMFROMWKB(X'0101000000000000000080564000000000008056C0',4326));
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'010100000097D44646F50E673C97D44646F50E673C',4326),ST_GEOMFROMWKB(X'010100000000000000008056C00000000000805640',4326));

##wkt&wkb##
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('POINT(','108.9571252 34.1841173',')'),4326,'axis-order=long-lat'),ST_GEOMFROMWKB(X'010100000000000000008056C00000000000805640',4326));

SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMWKB(X'01010000005C10DB279117414063F5A2D1780A4140',4326),ST_GEOMFROMTEXT(CONCAT('POINT(','-109.1009774 34.0795373',')'),4326,'axis-order=long-lat'));

##第三参数##
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('POINT(','1e-14 1e-14',')'),4326,'axis-order=long-lat'),ST_GEOMFROMTEXT(CONCAT('POINT(','108.9571252 34.1841173',')'),4326,'axis-order=long-lat'),'666');
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('POINT(','1e-15 1e-15',')'),4326,'axis-order=long-lat'),ST_GEOMFROMTEXT(CONCAT('POINT(','108.9571252 34.1841173',')'),4326,'axis-order=long-lat'),1e-100);
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT(CONCAT('POINT(','1e-15 1e-15',')'),4326,'axis-order=long-lat'),ST_GEOMFROMTEXT(CONCAT('POINT(','108.9571252 34.1841173',')'),4326,'axis-order=long-lat'),null);

