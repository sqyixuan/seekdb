#######################st_geomfromtext############################
SELECT ST_GEOMFROMTEXT(NULL);
--error 1582
SELECT ST_GEOMFROMTEXT(NULL,NULL,NULL,NULL);
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',' ',null));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',null));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',null,null));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',4326,null));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',4326,''));
--error 3037
select st_astext(st_geomfromtext(''));
--error 3037
SELECT ST_GEOMFROMTEXT(-1.2);
--error 3037
SELECT ST_GEOMFROMTEXT(FALSE);

#(bug)ob报错,mysql警告（已修复）#
SELECT ST_ASTEXT(ST_GEOMFROMTEXT('MULTIPOINT((2 0),(-1 -1))','',''));
#mysql警告#
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',''));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)','axis-order=srid-defined'));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)','axis-order=lat-long'));
select st_astext(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)','axis-order=long-lat'));
select _st_asEWKT(st_geomfromtext('MULTIPOINT (1 2, 2 1, 0 0)',FALSE,'axis-order=long-lat'));

##########################st_area##########################
#######非法的几何图形ob与mysql一致，与pg小数点十三位之前一致，十三位后不一致#######
#point,linestring#
select st_area(null);
--error 3037
select st_area('');
set @a = null;
select st_area(@a);
--error 3548
select st_area(-4326);
--error 3037
select st_area(FALSE);
--error 1582
select st_area(NULL,NULL);

--error 3516
select st_area(point(1,1));
--error 3516
select st_area(st_geomfromtext('POINT (1 1)'));
--error 3516
select st_area(st_geomfromtext('MULTIPOINT (1 1, 2 2, 3 3)'));
--error 3516
select st_area(ST_GeomFromText('linestring(0 0,1 1,1 0,0 0)'));
--error 3516
select st_area(st_geomfromtext('MULTILINESTRING((0 0,2 2,2 1,0 1),(0 0,1 1,0 0))'));
#GeometryCollection#
--error 3516
select st_area(st_geomfromtext('GEOMETRYCOLLECTION(polygon((0 0,0 0,0 0,0 0)))'));
--error 3516
select st_area(st_geomfromtext('GEOMETRYCOLLECTION empty'));

