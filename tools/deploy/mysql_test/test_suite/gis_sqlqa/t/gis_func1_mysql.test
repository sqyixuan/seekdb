ST_GEOMFROMTEXT('LINESTRING
(1e-17 1e-17,
-502 113,
595 -902)
'),
ST_GEOMFROMTEXT('LINESTRING
(514 2614,
1e-15 1e-15)'))A;



##############################ST_DISTANCE_SPHERE############################
##NULL##
SELECT ST_DISTANCE_SPHERE(NULL,NULL);
SELECT ST_DISTANCE_SPHERE(NULL,NULL,NULL);
--error 1582
SELECT ST_DISTANCE_SPHERE(NULL,NULL,NULL,NULL);
--error 3037
SELECT ST_DISTANCE_SPHERE('','');

##other type##
--error 3037
SELECT ST_DISTANCE_SPHERE(1,1);
--error 3037
SELECT ST_DISTANCE_SPHERE(0.1,0.1);
--error 3548
SELECT ST_DISTANCE_SPHERE('POINT(1 1)','POINT(1 1)');


##第三参数##
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(1 2)',4326),ST_GEOMFROMTEXT('POINT(1 2)',4326),1) A;
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(1 2)',4326),ST_GEOMFROMTEXT('POINT(2 1)',4326),9.22e+18) A;
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(1 2)',0),ST_GEOMFROMTEXT('POINT(2 1)',0),9.22e+18) A;

##不同srid##
--error 3033
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(1 2)',0),ST_GEOMFROMTEXT('POINT(2 1)',4326),9.22e+18) A;
##投影坐标系##
--error 3705
SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(1 2)',26918),ST_GEOMFROMTEXT('POINT(2 1)',26918),9.22e+18) A;

SELECT ST_DISTANCE_SPHERE(ST_GEOMFROMTEXT('POINT(180 90)',0),ST_GEOMFROMTEXT('POINT(-179.12345678987654321 -90)',0)) A;

