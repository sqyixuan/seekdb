select st_astext(ST_GeomFromText('linestring(-31.519125652386037 -72.76387666779343,75.01356355093947 8.71197128921537)'));
select st_astext(ST_GeomFromText
('linestring(1 2,1 3,1 4,1 5,1 6,1 7,1 8,1 9,1 10,1 11,1 12,1 13,1 14,1 15,1 16,1 17,1 18,1 19,1 20,1 21,1 22,1 23,1 24,1 25,1 26,1 27)'));

--disable_warnings
drop FUNCTION if EXISTS max_line;
--enable_warnings
delimiter //;
create function max_line(len int) returns varchar(10000)
begin
	declare a varchar(10000) ;
    declare b varchar(10000) ;
	declare i int;
	set a = 'linestring(';
	set i = 0;
	while i < len do
		set i = i + 1;
		set a = concat(a,i,' ',i,',');
	end while;
	set b = concat(substr(a,1,length(a)-1),')');
	return b;
end;
//
delimiter ;//
select st_astext(st_geomfromtext(concat('linestring(1 1,1 1',')')));
--disable_warnings
drop table if EXISTS ff01;
create table ff01 (g GEOMETRY);
insert into ff01 values (st_geomfromtext(max_line(64)));
select st_aswkt(g) from ff01;
drop table if EXISTS ff01;
--enable_warnings

