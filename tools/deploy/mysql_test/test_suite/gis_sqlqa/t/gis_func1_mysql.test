ST_GEOMFROMTEXT('LINESTRING
(1e-17 1e-17,
-502.5112588013556 113.09772483177494)
'),
ST_GEOMFROMTEXT('LINESTRING
(51432.665263966715 26144.43555522214,
1e-15 1e-15)'))A;

