--error 0,1396
drop user 'zc_gis_mysql'@'%';
create user 'zc_gis_mysql'@'%' IDENTIFIED BY 'zc_gis_mysql';
grant all on *.* to 'zc_gis_mysql'@'%' WITH GRANT OPTION;
--enable_warnings

####添加srs#####
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;
alter system change tenant sys;

--disable_query_log
--disable_result_log
--source mysql_test/test_suite/gis_sqlqa/default_srs_data_mysql.sql
--enable_query_log
--enable_result_log

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_gis_mysql,zc_gis_mysql,test,$OBMYSQL_PORT);
connection conn;

--disable_warnings
drop table if exists T_GEO;
drop view if exists V_T_GEO;
--enable_warnings

####################update###################

create table T_GEO (gid int auto_increment primary key, geo geometry ,geo_c GEOMETRYCOLLECTION,poi point,lin linestring ,pol polygon,M_POI MULTIPOINT,M_LIN MULTILINESTRING ,M_POL MULTIPOLYGON );
create view V_T_GEO AS SELECT * FROM T_GEO;

INSERT INTO T_GEO VALUES (1,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL);
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('POINT(1 1)');

SELECT ST_ASTEXT(GEO),ST_ASTEXT(GEO_C),ST_ASTEXT(POI),ST_ASTEXT(M_POI),ST_ASTEXT(LIN),ST_ASTEXT(M_LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POL) FROM T_GEO;

################geometry#################
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT(NULL);
SELECT ST_ASTEXT(GEO) FROM T_GEO;

##null##
UPDATE T_GEO SET GEO=sT_GEOmfromtext('point(1 1)',null);
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=sT_GEOmfromtext('point(1 1)',null,null);
SELECT ST_ASTEXT(GEO) FROM T_GEO;
--error 1416
UPDATE T_GEO SET GEO='';
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=null;
SELECT ST_ASTEXT(GEO) FROM T_GEO;
##varchar,int##
