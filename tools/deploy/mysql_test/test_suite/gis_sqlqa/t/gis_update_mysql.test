SELECT ST_ASTEXT(GEO) FROM T_GEO;

UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (2 1, 2 1, 2 1)',4326) where GEO IS NULL ORDER BY GEO LIMIT 1 ;
SELECT ST_ASTEXT(GEO) FROM T_GEO WHERE GEO= ST_GEOMFROMTEXT('MULTIPOINT (2 1, 2 1, 2 1)',4326);
DELETE FROM T_GEO;
