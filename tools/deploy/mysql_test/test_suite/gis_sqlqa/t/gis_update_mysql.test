SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=sT_GEOmfromtext('linestring(0 0,1 1,1 0,0 0)');
SELECT ST_ASTEXT(GEO) FROM T_GEO;
