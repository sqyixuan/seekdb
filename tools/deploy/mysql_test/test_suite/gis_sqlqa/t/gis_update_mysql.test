select _ST_ASEWKT(POI),_ST_ASEWKT(LIN),_ST_ASEWKT(POL),_ST_ASEWKT(M_POI),_ST_ASEWKT(M_LIN),_ST_ASEWKT(M_POL),_ST_ASEWKT(GEO),_ST_ASEWKT(GEO_C) from V_T_GEO;

UPDATE V_T_GEO SET GEO=NULL,GEO_C=NULL,POI=NULL,LIN=NULL,POL=NULL,M_POI=NULL,M_LIN=NULL,M_POL=NULL;

select ST_ASTEXT(POI),ST_ASTEXT(LIN),ST_ASTEXT(POL),ST_ASTEXT(M_POI),ST_ASTEXT(M_LIN),ST_ASTEXT(M_POL),ST_ASTEXT(GEO),ST_ASTEXT(GEO_C) from T_GEO;

##notnull##
drop table if exists T_GEO;
create table T_GEO (gid int auto_increment primary key, geo geometry not null srid 4326);
drop view if exists V_T_GEO;
create view V_T_GEO AS SELECT * FROM T_GEO;

REPLACE into T_GEO(geo) VALUES(ST_GEOMETRYFROMWKB(X'010700000000000000',4326));
