SELECT HEX(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMWKB(x'');
SELECT HEX(GEO) FROM T_GEO;

#where#
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 2, 2 1, 0 0)',4326) where gid=1;
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (2 2, 2 2, 2 2)',4326) where GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 2, 2 1, 0 0)',4326);
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 1, 1 1, 1 1)',4326) where GEO=ST_GEOMFROMTEXT('MULTIPOINT (2 2, 2 2, 2 2)');
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 1, 1 1, 1 1)',4326) where GEO=ST_GEOMFROMTEXT('MULTIPOINT (2 2, 2 2, 2 2)',4326,'axis-order=LONG-LAT');
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 2, 1 2, 1 2)',4326) where GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 1, 1 1, 1 1)',4326);
SELECT ST_ASTEXT(GEO) FROM T_GEO;
UPDATE T_GEO SET GEO=ST_GEOMFROMTEXT('MULTIPOINT (2 1, 2 1, 2 1)',4326) where GEO=ST_GEOMFROMTEXT('MULTIPOINT (1 2, 1 2, 1 2)',4326,'axis-order=LONG-LAT');
SELECT ST_ASTEXT(GEO) FROM T_GEO;

