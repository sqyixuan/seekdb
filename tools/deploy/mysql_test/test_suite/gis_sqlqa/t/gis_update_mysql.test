SELECT ST_ASTEXT(GEO) FROM V_T_GEO;
UPDATE V_T_GEO SET GEO=ST_GEOmfromtext('point(1 1)',null,null);
SELECT ST_ASTEXT(GEO) FROM V_T_GEO;
