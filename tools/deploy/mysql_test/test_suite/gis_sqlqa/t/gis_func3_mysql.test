--disable_query_log
--disable_result_log
--source mysql_test/test_suite/gis_sqlqa/default_srs_data_mysql.sql
--enable_result_log
--enable_query_log
connection default;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
