--echo st_intersects 
drop table tt1;
create table tt1(id int,g geometry not null);
select id ,st_astext(g) from tt1 where id =1 and st_intersects(g,ST_GeomFromText('point(10 20)',26918)); 
select id ,st_astext(g) from tt1 where id =1 and st_intersects(ST_GeomFromText('point(10 20)',26918),g); 
select id ,st_astext(g) from tt1 where id =1 and st_intersects(g,ST_GeomFromText('point(10 20)',269)); 
select id ,st_astext(g) from tt1 where id =1 and st_intersects(ST_GeomFromText('point(10 20)',269),g);

select id ,st_astext(g) from tt1 where id =1 and _st_covers(g,ST_GeomFromText('point(10 20)',26918)); 
select id ,st_astext(g) from tt1 where id =1 and _st_covers(ST_GeomFromText('point(10 20)',26918),g); 
select id ,st_astext(g) from tt1 where id =1 and _st_covers(g,ST_GeomFromText('point(10 20)',269)); 
select id ,st_astext(g) from tt1 where id =1 and _st_covers(ST_GeomFromText('point(10 20)',269),g);

