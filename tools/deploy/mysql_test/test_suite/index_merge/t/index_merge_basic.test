explain select /*+no_rewrite union_merge(t9 i_0_ZYM PRIMARY)*/ * from t9 where c48 <= 1 or c30 >= NULL;
select /*+no_rewrite union_merge(t9 i_0_ZYM PRIMARY)*/ * from t9 where c48 <= 1 or c30 >= NULL;

--explain_protocol 2
select * from t12 where c2 = 1 and c3 = 200001 or c3 > 399900;
alter system _enable_index_merge = false;
select * from t12 where c2 = 1 and c3 = 200001 or c3 > 399900;
select /*+union_merge(t12 c2 c3)*/ * from t12 where c2 = 1 and c3 = 200001 or c3 > 399900;

alter system _enable_index_merge = false;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11,t12 cascade;
drop sequence if exists s1;
--enable_warnings

connection conn_admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
alter system set_tp tp_no=554, error_code=1, frequency=0;
alter system set_tp tp_no=311, error_code=2, frequency=0;
alter system set_tp tp_no=400, error_code=4, frequency=0;
alter system set_tp tp_no=315, error_code=1, frequency=0;
connection default;
