--disable_warnings
drop table if exists E; 
--enable_warnings
CREATE  TABLE E (
col_datetime datetime,
col_int int,
col_int_key int,
pk int,
col_text text,
col_datetime_key datetime,
col_varchar_10_key varchar(10),
col_text_key text,
col_varchar_10 varchar(10),
primary key(pk, col_int_key),
key idx1(col_int_key ),
key idx7(col_datetime_key ),
key idx3(col_varchar_10_key ),
key idx5(col_text_key  (255)))
PARTITION BY hash (pk)
subpartition by range(col_int_key)
subpartition template
(subpartition p0 values less than (100),
subpartition p1 values less than (500),
subpartition p2 values less than (1000),
subpartition p3 values less than (maxvalue))
partitions 5; 
CREATE FULLTEXT INDEX fidxE ON E(COL_TEXT);
CREATE INDEX EG0 ON E(COL_INT,COL_INT_KEY);
ALTER SYSTEM _enable_index_merge=true;
explain SELECT  * FROM E AS OUTR WHERE OUTR . col_int_key = 1 and (MATCH(OUTR.col_text) AGAINST('g') or MATCH(OUTR.col_text) AGAINST('k') or MATCH(OUTR.col_text) AGAINST('xk') or MATCH(OUTR.col_text) AGAINST('c') or MATCH(OUTR.col_text) AGAINST('hqg') or MATCH(OUTR.col_text) AGAINST('yvc'));
explain SELECT  * FROM E AS OUTR WHERE OUTR . COL_INT = 1 or (MATCH(OUTR.col_text) AGAINST('g') or MATCH(OUTR.col_text) AGAINST('k') or MATCH(OUTR.col_text) AGAINST('xk') or MATCH(OUTR.col_text) AGAINST('c') or MATCH(OUTR.col_text) AGAINST('hqg') or MATCH(OUTR.col_text) AGAINST('yvc'));


--disable_warnings
drop table if exists t3;
--enable_warnings
alter system _enable_index_merge=true;
create table t3 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100));
create FULLTEXT INDEX fidx4 ON t3(c4);
explain select a.c1,a.c3,b.c1 from t3 a inner join t3 b on a.c2 = b.c2 where a.c1 = 5 or (a.c3 < 390000 and MATCH(b.c4) AGAINST('鄂A1'));


--disable_warnings
drop table if exists t4;
drop sequence if exists s1;
--enable_warnings
alter system _enable_index_merge=true;
create table t4 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100));
create sequence s1 cache 1000000 order;
insert /*+enable_parallel_dml parallel(16) query_timeout(1000000000)*/ into t4 select s1.nextval, s1.currval-200000, s1.currval%1000, CONCAT('鄂A', s1.currval), CONCAT('鄂A', s1.currval%1000) from table(generator(400000));
create index c2 on t4(c2) local;
create index c3 on t4(c3) local;
create index cg3 on t4(c3) global;
create index c4 on t4(c4) local;
create FULLTEXT INDEX fidx4 ON t4(c4);
create index c5 on t4(c5) local;
create index c23 on t4(c2,c3) local;
call dbms_stats.gather_schema_stats(NULL);
explain select * from t4 where (MATCH(c4) AGAINST('鄂A321312') or c3 > 5 or c2 < -100000 or c1 > 199000) and (MATCH(c4) AGAINST('鄂A321313') or c2 = 121314 or c1 = 199900) and (MATCH(c4) AGAINST('鄂A321314') or c1 > 199000) and (c1 > 188000);
explain select /*+union_merge(t4 fidx4 c2 primary)*/* from t4 where (MATCH(c4) AGAINST('鄂A321312') or c3 > 5 or c2 < -100000 or c1 > 199000) and (MATCH(c4) AGAINST('鄂A321313') or c2 = 121314 or c1 = 199900) and (MATCH(c4) AGAINST('鄂A321314') or c1 > 199000) and (c1 > 188000);



--disable_warnings
drop table if exists t1,t2,t3,t4;
drop table if exists E; 
drop sequence if exists s1;
--enable_warnings
alter system set _enable_index_merge = false;

connection conn_admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
alter system set_tp tp_no=554, error_code=1, frequency=0;
alter system set_tp tp_no=311, error_code=2, frequency=0;
alter system set_tp tp_no=400, error_code=4, frequency=0;
alter system set_tp tp_no=315, error_code=1, frequency=0;
connection default;