connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
alter system set_tp tp_no=554, error_code=1, frequency=1;
alter system set_tp tp_no=311, error_code=2, frequency=1;
alter system set_tp tp_no=400, error_code=4, frequency=1;
alter system set_tp tp_no=315, error_code=1, frequency=1;
connection default;
--result_format 4

alter system set _enable_index_merge = true;
sleep 3;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
  id int primary key, 
  name varchar(128),
  detail text,
  year int,
  fulltext index i1(name),
  fulltext index i2(detail),
  index i3(year));

insert into t1 values 
(0, "IBM Db2", "Db2 is a family of data management products, including database servers, developed by IBM. It initially supported the relational model, but was extended to support object–relational features and non-relational structures like JSON and XML. The brand name was originally styled as DB2 until 2017, when it changed to its present form. (In the early days, it was sometimes wrongly styled as DB/2 - in a false derivation from the operating system OS/2.)", 1983),
(1, "Oracle", "Oracle Database (commonly referred to as Oracle DBMS, Oracle Autonomous Database, or simply as Oracle) is a proprietary multi-model database management system produced and marketed by Oracle Corporation. It is a database commonly used for running online transaction processing (OLTP), data warehousing (DW) and mixed (OLTP & DW) database workloads. Oracle Database is available by several service providers on-premises, on-cloud, or as a hybrid cloud installation.", 1979),
(2, "Microsoft SQL Server", "Microsoft SQL Server (MSSQL) is a relational database management system (RDBMS) developed by Microsoft. It has been the most popular database management system in use today, and is used as the primary database for many large-scale systems.", 1989),
(3, "MySQL", "MySQL is an open-source relational database management system (RDBMS). Its name is derived from 'My', the initial of co-founder Michael Widenius's daughter, and 'SQL', the abbreviation for Structured Query Language. MySQL was originally designed with a focus on speed and scalability, making it suitable for handling large volumes of data and high levels of concurrency. The software is available under the GNU General Public License (GPL), which allows users to freely download, modify, and distribute the source code. Additionally, MySQL offers commercial licenses that provide additional support and features.", 1995),
(4, "PostgreSQL", "PostgreSQL is a powerful, open source object-relational database system with over 30 years of active development that has earned it a strong reputation for reliability, data integrity, and correctness. PostgreSQL runs on all major operating systems, including Linux, UNIX, Windows, and OS X, and is used by many of the largest financial, government, and telecom companies in the world. It has a rich feature set that includes advanced query capabilities, transactions, stored procedures, and more.", 1989),
(5, "Elasticsearch", "Elasticsearch is a popular open-source search and analytics engine that allows users to store, search, and analyze large volumes of data. It is built on top of the Apache Lucene search engine library and is written in Java. It provides a RESTful API for accessing its features, making it easy to integrate with existing applications. It is also highly scalable and can handle large amounts of data, making it a popular choice for big data applications.", 2010),
(6, "MongoDB", "MongoDB is a popular open-source NoSQL database that stores data in JSON-like documents. It is designed to be highly scalable and flexible, making it a popular choice for web applications and mobile apps. It is also highly performant, with fast read and write speeds, making it ideal for real-time", 2009),
(7, "Redis", "Redis is an open-source in-memory data structure store that can be used as a database, cache, and message broker. It supports various data types such as strings, hashes, lists, sets, sorted sets, and bitmaps. It is known for its high performance, with low latency and high throughput, making it ideal for high-performance applications. It is also highly scalable, with support for sharding and replication, making it suitable for large-scale deployments.", 2009),
(8, "SQLite", "SQLite is a software library that implements a self-contained, serverless, zero-configuration, transactional SQL database engine. SQLite is the most deployed database engine in the world, with more than 10 million installations. SQLite is a self-contained, serverless, zero-configuration, transactional SQL database engine. SQLite is the most deployed database engine in the world, with more than 10 million installations.", 2000),
(9, "ClickHouse", "ClickHouse is a high-performance open-source column-oriented database management system (DBMS) that is designed to handle large volumes of data and perform fast queries. It is designed to be easy to use, with a simple SQL-like syntax and a focus on performance. ClickHouse is optimized for high performance and scalability, with a focus on real-time analytics. It is written in C++ and can be used as a standalone database or as part of an enterprise database management system (DBMS).", 2013),
(10, "Cassandra", "Cassandra is a scalable, open-source NoSQL database that is designed to handle large volumes of data and provide high availability and fault tolerance. It is built on top of the Apache Cassandra project, which was originally developed by Facebook in 2007. Cassandra is known for its ability to scale horizontally, with support for sharding and replication, making it ideal for large-scale deployments.", 2008),
(11, "HBase", "HBase is an open-source, distributed, column-oriented database management system (DBMS) that is designed to handle large volumes of data and provide high availability and fault tolerance. It is built on top of the Apache Hadoop project, which provides a framework for distributed computing. HBase is known for its ability to scale horizontally, with support for sharding and replication, making it ideal for large-scale deployments.", 2009),
(12, "Apache Hive", "Apache Hive is an open-source data warehouse software tool that allows users to query and analyze large datasets using SQL-like queries. It is built on top of Apache Hadoop, which provides a framework for distributed computing. Hive is designed to be easy to use, with a simple SQL-like syntax and a focus on performance. Hive is optimized for large-scale data processing, with support for distributed computing and fault tolerance.", 2007),
(13, "Apache Spark", "Apache Spark is an open-source distributed computing framework that provides fast and easy-to-use APIs for big data processing. It is designed to be highly scalable and fault-tolerant, making it ideal for large-scale deployments. Apache Spark supports a wide range of programming languages, including Java, Python, and R, making it easy to integrate with existing applications. Apache Spark is known for its ability to handle large volumes of data and perform complex computations in real-time, making it a popular choice for big data analytics and machine learning applications.", 2009),
(14, "Apache Flink", "Apache Flink is an open-source stream processing framework that allows users to process and analyze streaming data in real-time. It is designed to be highly scalable and fault-tolerant, making it ideal for large-scale deployments. Apache Flink supports a wide range of programming languages, including Java, Python, and Scala, making it easy to integrate with existing applications. Apache Flink is known for its ability to handle large volumes of data and perform complex computations in real-time, making it a popular choice for real-time data processing and analytics applications.", 2012),
(15, "Apache Kafka", "Apache Kafka is an open-source distributed event streaming platform that allows users to publish and subscribe to streams of events. It is designed to be highly scalable and fault-tolerant, making it ideal for large-scale deployments. Apache Kafka supports a wide range of programming languages, including Java, Python, and Scala, making it easy to integrate with existing applications. Apache Kafka is known for its ability to handle large volumes of data and perform complex computations in real-time, making it a popular choice for big data analytics and machine learning applications.", 2011),
(16, "Apache Storm", "Apache Storm is an open-source distributed computing framework that provides fast and easy-to-use APIs for big data processing. It is designed to be highly scalable and fault-tolerant, making it ideal for large-scale deployments. Apache Storm supports a wide range of programming languages, including Java, Python, and R, making it easy to integrate with existing applications. Apache Storm is known for its ability to handle large volumes of data and perform complex computations in real-time, making it a popular choice for big data analytics and machine learning applications.", 2012);

## basic test
explain select * from t1 where match(name) against ('SQL') or year > 1990;
select * from t1 where match(name) against ('SQL') or year > 1990;

explain select * from t1 where match(detail) against ('open source') or year = 2009;
select * from t1 where match(detail) against ('open source') or year = 2009;

explain select * from t1 where id > 1 and year > 1990 and (match(detail) against ('database') or match(detail) against ('distributed') or match(detail) against ('serverless'));
select * from t1 where id > 1 and year > 1990 and (match(detail) against ('database') or match(detail) against ('distributed') or match(detail) against ('serverless'));

explain select * from t1 where id > 2000 or match(detail) against ('distributed') or match(name) against ('Apache');
select * from t1 where id > 2000 or match(detail) against ('distributed') or match(name) against ('Apache');

explain select id from t1 where match(detail) against ('distributed') or (match(name) against ('Apache') and year > 1990);
select id from t1 where match(detail) against ('distributed') or (match(name) against ('Apache') and year > 1990);

explain select id, match(name) against ('Apache') from t1 where match(name) against ('Apache') or match(detail) against ('distributed');
select id, match(name) against ('Apache') from t1 where match(name) against ('Apache') or match(detail) against ('distributed');

explain select id, match(name) against ('Apache'), match(detail) against ('distributed') from t1 where match(name) against ('Apache') or match(detail) against ('distributed');
select id, match(name) against ('Apache'), match(detail) against ('distributed') from t1 where match(name) against ('Apache') or match(detail) against ('distributed');

explain select id, match(name) against ('Apache') from t1 where 
  year >= 2010 
  and id < 10 
  and 
  (
    match(detail) against ('database') 
    or match(detail) against ('distributed') 
    or match(detail) against ('serverless')
  );

select id, match(name) against ('Apache') from t1 where 
  year >= 2010
  and id < 10
  and 
  (
    match(detail) against ('database') 
    or match(detail) against ('distributed') 
    or match(detail) against ('serverless')
  );

explain select * from t1 where
  id > 0
  and match(detail) against ('data') 
  and 
  (
    (
      (
        match(detail) against ('large') 
        or match(name) against ('Apache')
      )
      and year > 2000
    )
    or 
    (
      match(detail) against ('distributed') 
      and year < 2000
    )
  );

select * from t1 where
  id > 0
  and match(detail) against ('data') 
  and 
  (
    (
      (
        match(detail) against ('large') 
        or match(name) against ('Apache')
      )
      and year > 2000
    )
    or 
    (
      match(detail) against ('distributed') 
      and year < 2000
    )
  );

## index merge + DML
begin;
--error 1235 
explain update t1 set id = id + 20 where match(name) against("Apache") or year > 2000;
--error 1235
update t1 set id = id + 20 where match(name) against("Apache") or year > 2000;
rollback;

begin;
--error 1235
explain update t1 set id = id + 20 where match(name) against("Apache") or match(detail) against('database');
--error 1235
update t1 set id = id + 20 where match(name) against("Apache") or match(detail) against('database') or year = 1990;
rollback;

begin;
--error 1235
explain delete from t1 where match(detail) against ('database') or (match (detail) against ('distributed') and year = 2000);
--error 1235
delete from t1 where match(detail) against ('database') or (match (detail) against ('distributed') and year = 2000);
rollback;

begin;
--error 1235
explain update t1 set id = id + 20 where match(name) against ("Apache") or (match(detail) against ('database') and match(detail) against ('use'));
--error 1235
update t1 set id = id + 20 where match(name) against ("Apache") or (match(detail) against ('database') and match(detail) against ('use'));
rollback;

