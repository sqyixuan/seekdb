## partitioned table
--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2(
  id int primary key, 
  name varchar(128),
  detail text,
  year int,
  fulltext index i1(name),
  fulltext index i2(detail),
  index i3(year)) partition by hash(id) partitions 3;

insert into t2 select * from t1;
explain select * from t2 where match(name) against ('SQL') or year > 1990;
