drop table if exists t7 cascade;
explain_protocol: 0
create table t7(c1 int primary key, c2 int) partition by hash(c1) partitions 5;
alter table t7 add column (c3 int generated always as (c1+1) stored);
alter table t7 add column (c4 int generated always as (c2-1) stored);
alter table t7 add column (c5 int generated always as (c1+c2) virtual);
alter table t7 add column (c6 int generated always as (c1 * 2) virtual);
create index c3 on t7(c3) local;
create index c4 on t7(c4) local;
create index c5 on t7(c5) local;
create index c6 on t7(c6) local;
