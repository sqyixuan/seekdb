alter system set _enable_index_merge = false;

drop table if exists t12 cascade;
drop sequence if exists s1;
explain_protocol: 0
alter system _enable_index_merge = true;
create table t12 (c1 int primary key, c2 int, c3 int, c4 varchar(100), c5 varchar(100)) 
PARTITION BY RANGE(c1)
(
    PARTITION p0 VALUES LESS THAN (100000),
    PARTITION p1 VALUES LESS THAN (200000),
    PARTITION p2 VALUES LESS THAN (300000),
    PARTITION p3 VALUES LESS THAN MAXVALUE
);

create sequence s1;
insert /*+enable_parallel_dml parallel(16) query_timeout(1000000000)*/ into t12 select s1.nextval, s1.currval-200000, 400000-s1.currval, CONCAT('鄂A', s1.currval), CONCAT('鄂A', 400000-s1.currval) from table(generator(400000));

create index c2 on t12(c2) local;
create index c3 on t12(c3) local;
create index c23 on t12(c2,c3) local;

call dbms_stats.gather_schema_stats('test');

