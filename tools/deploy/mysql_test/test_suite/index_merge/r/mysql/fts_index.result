drop table if exists E;
CREATE  TABLE E (
col_datetime datetime,
col_int int,
col_int_key int,
pk int,
col_text text,
col_datetime_key datetime,
col_varchar_10_key varchar(10),
col_text_key text,
col_varchar_10 varchar(10),
primary key(pk, col_int_key),
key idx1(col_int_key ),
key idx7(col_datetime_key ),
key idx3(col_varchar_10_key ),
key idx5(col_text_key  (255)))
PARTITION BY hash (pk)
subpartition by range(col_int_key)
subpartition template
(subpartition p0 values less than (100),
subpartition p1 values less than (500),
subpartition p2 values less than (1000),
subpartition p3 values less than (maxvalue))
partitions 5;
CREATE FULLTEXT INDEX fidxE ON E(COL_TEXT);
CREATE INDEX EG0 ON E(COL_INT,COL_INT_KEY);
ALTER SYSTEM _enable_index_merge=true;
explain SELECT  * FROM E AS OUTR WHERE OUTR . col_int_key = 1 and (MATCH(OUTR.col_text) AGAINST('g') or MATCH(OUTR.col_text) AGAINST('k') or MATCH(OUTR.col_text) AGAINST('xk') or MATCH(OUTR.col_text) AGAINST('c') or MATCH(OUTR.col_text) AGAINST('hqg') or MATCH(OUTR.col_text) AGAINST('yvc'));
