      is_index_back=true, is_global_index=false, use_index_merge=true, filter_before_indexback[false], 
      index_name: i1, range_cond(nil), filter(nil)
      index_name: i3, range_cond([t1.year > 1990]), filter(nil)
      lookup_filter([MATCH(t1.name) AGAINST('SQL') OR t1.year > 1990])
