select /*+ parallel(3) */ c1,count(c2) from (select * from lyq_test) a where c8 is null GROUP BY c1,c3,c7 with rollup HAVING c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) order by c1;

--sorted_result
select /*+ parallel(3) */ t2.c1,count(t2.c2) from (select c1,c2,c3,c7,c8 from lyq_test where c1 < 10000 ) t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1
where t1.c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) GROUP BY t2.c1,t1.c3,t1.c7 with rollup 
HAVING count(distinct t1.c7)> 1 order by t2.c1;

