select /*+ parallel(3) */ c1,count(c2) from lyq_test where c8 is null GROUP BY c1,c3,c7 with rollup HAVING c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) order by c1;

