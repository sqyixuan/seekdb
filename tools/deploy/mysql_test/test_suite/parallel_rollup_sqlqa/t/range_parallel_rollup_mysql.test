#owner group: SQL2
#description: obmysql parallel rollup
#author: wb-lyq858317
#tags:

--disable_warnings
purge recyclebin;

--echo  mysql不支持并行执行，只是兼容parallel hint的语法。  obmysql模式支持并行

SET SESSION sql_mode = 'ONLY_FULL_GROUP_BY,NO_ENGINE_SUBSTITUTION';

--error 0,1051
DROP TABLE lyq_test_fk;

--error 0,1051
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
  c1 int primary key,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 BLOB(100), 
  c5 bit(16),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),   
  c9 timestamp,
  c10 VARCHAR(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列') 
  #PARALLEL 5
    PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (3),
PARTITION b_3_8 VALUES less than (8),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);

--error 0,1305
DROP PROCEDURE get_data1;

DELIMITER //;
CREATE  PROCEDURE get_data1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into lyq_test(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(i,mod(i,5),round(i/8, 0),substr('这是aseriqon一个字符串@$$测试lnczlbga!%&^这是aseriqon一个字符串@$$测试',round(i/1, 0)),
		hex((CASE round(i/20, 0) WHEN 0 THEN 1 ELSE round(i/20, 0) END)),ADDDATE('2018-12-22 22:22:22', round(i/6, 0)*10000) ,JSON_ARRAY(mod(i,5), "abc", NULL, TRUE, '{"a":100}'),
		CASE mod(i,5) WHEN 0 THEN null ELSE 'b,d' END,ADDDATE('2018-12-22 22:22:22', 1 ));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//

call get_data1(10);


create table lyq_test_fk(
c1 INT,
c2 VARCHAR(100)) 
#NOPARALLEL
;

--error 0,1305
DROP PROCEDURE get_data2;

DELIMITER //;
CREATE  PROCEDURE get_data2(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into lyq_test_fk values(i,CASE mod(i,5) WHEN 0 THEN null ELSE mod(i,5) END);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//

call get_data2(9);

--echo create-1-1 普通索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c1);

--echo create-1-3 组合索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(c3,c2,c5);

--echo create-1-4 hash索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 USING HASH ON lyq_test(c6);

--echo create-1-5 json 生成列索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T5 ON lyq_test(c10);

--echo create-1-6 全局分区索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T6 ON lyq_test(c1)
   GLOBAL   PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (2),
PARTITION b_3_8 VALUES less than (5),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);

--echo distinct
--sorted_result
select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ grouping(c1),c1,count(distinct c2),count(distinct c2) FROM lyq_test where c8 is not null and c4 like '%测试%'  
GROUP BY c1,c2 with ROLLUP  HAVING c2 NOT IN (4) order by c1;

--sorted_result
select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ grouping(c2),c1,min(distinct c2),min(distinct c9) FROM lyq_test where c3 <> 2 GROUP BY c1,c9,(c2) with rollup
HAVING c2 > some(SELECT  min(c2) FROM lyq_test GROUP BY c3 with ROLLUP) order by c1;

--sorted_result
select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ CASE  WHEN avg(distinct c2) =1  THEN 1 when avg( distinct c2) > 1 then 2 else 3 END as a FROM lyq_test 
where c3 is not null and c4 like '这是aseri%'  GROUP BY c3 with ROLLUP HAVING c3 NOT IN (4,40,400) order by c3;


--sorted_result
select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ c1,min(distinct c2),max(distinct c9),count(distinct c4),sum(distinct c6), avg(distinct c2) FROM lyq_test 
where c3 <> 2 GROUP BY c1,c9,c4,c2,c3 with ROLLUP HAVING c2 > any(SELECT  min(c2) FROM lyq_test GROUP BY c3 with ROLLUP ) order by c1;

--sorted_result
select /*+ parallel(3) NO_USE_HASH_AGGREGATION */ grouping(c8),c1,min(distinct c2),max(distinct c2),count(distinct c2),sum(distinct c2), avg(distinct c2) FROM lyq_test 
where c3 <> 2 GROUP BY c1,c9,c4,c2,c8 with ROLLUP HAVING c2 > any(SELECT  min(c2) FROM lyq_test GROUP BY c8 with ROLLUP ) order by 1, 2;

--sorted_result
select /*+ parallel(3) */ count(distinct cast(c2 as char(100))),sum(distinct c2) FROM lyq_test where c2 is not null  
GROUP BY c1,c4 with ROLLUP HAVING sum(distinct c1) NOT IN (4) order by c1;

--sorted_result
select /*+ parallel(3) */ c1,count(distinct upper(c6)),avg(distinct c3) FROM lyq_test where c2 is not null and c4 like '%这是aseri%'  
GROUP BY c1,c3 with ROLLUP HAVING max(distinct c1) NOT IN (4) order by c1;

--sorted_result
select /*+ parallel(3) */ c1,max(distinct upper(c4)),avg(distinct upper(c6)) FROM lyq_test where c2 is not null and c4 like '%这是aseri%'  
GROUP BY c1,c3,c8 with ROLLUP HAVING count(distinct c1) NOT IN (4) order by c1;

--sorted_result
select /*+ parallel(3) */ sum(DISTINCT c2+c3),min(DISTINCT c2 + 1000),avg(DISTINCT c1)
FROM lyq_test GROUP BY  c1,c3 with ROLLUP ORDER BY c1 desc;


