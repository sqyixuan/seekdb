--error 0,1051
DROP TABLE t0;

CREATE TABLE IF NOT EXISTS t0(c0 TINYINT(223) , c1 DATETIME )  PARTITION BY KEY (c0) SUBPARTITION BY RANGE (c0) subpartition template (subpartition sp0 VALUES LESS THAN(-1000000000), subpartition sp1 VALUES LESS THAN(0), subpartition sp2 VALUES LESS THAN(1000000000), subpartition sp3 VALUES LESS THAN(maxvalue)) partitions 10;
 (SELECT /*+  PARALLEL(2),enable_parallel_dml  */ ALL AVG(DISTINCT t0.c0) AS AF0, * FROM t0 WHERE (3) < (0) GROUP BY t0.c0, t0.c1 WITH ROLLUP HAVING t0.c0 ORDER BY t0.c1 DESC) UNION ALL (SELECT /*+  PARALLEL(2),enable_parallel_dml  */ AVG(DISTINCT t0.c0) AS AF0, * FROM t0 WHERE (3) < (0) GROUP BY t0.c0, t0.c1 WITH ROLLUP HAVING (! (t0.c0)) ORDER BY t0.c1 DESC) UNION ALL (SELECT /*+  PARALLEL(2),enable_parallel_dml  */ AVG(DISTINCT t0.c0) AS AF0, * FROM t0 WHERE (3) < (0) GROUP BY t0.c0, t0.c1 WITH ROLLUP HAVING (t0.c0) IS UNKNOWN ORDER BY t0.c1 DESC);
drop table t0;
