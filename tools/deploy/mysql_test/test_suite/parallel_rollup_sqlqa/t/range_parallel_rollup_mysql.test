--echo rollup + join

--sorted_result
select /*+ parallel(lyq_test 3) */ t1.c1,count(t2.c2) from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1
GROUP BY t1.c1,t1.c7 with rollup order by t1.c1;
--error 1055
select /*+ parallel(3) */ t1.c1,count(t2.c2) from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1
where t1.c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) GROUP BY t2.c1,t1.c3,t1.c7 with rollup 
HAVING count(distinct t1.c7)> 1 order by t2.c1;

--sorted_result
select /*+ parallel(3) */ t2.c1,count(t2.c2) from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1
where t1.c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) GROUP BY t2.c1,t1.c3,t1.c7 with rollup 
HAVING count(distinct t1.c7)> 1 order by t2.c1;

--sorted_result
select /*+ parallel(3) */ t1.c1,count(t2.c2) from lyq_test t1 
inner join lyq_test_fk t2 on t1.c1 = t2.c1
where t1.c1 > some(SELECT c2 FROM lyq_test GROUP BY c2 with ROLLUP  ) GROUP BY t1.c1,t1.c3,t1.c4,t1.c7 with rollup 
HAVING t1.c4 like '%a' order by t1.c1;

