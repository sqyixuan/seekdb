select /*+ parallel(lyq_test 3) */ c1,count(c3) from (select c1,c3,c7 from lyq_test where c1 < 10000 GROUP BY c1,c3,c7 with rollup ) a GROUP BY c1,c7 with rollup order by 1, 2;

