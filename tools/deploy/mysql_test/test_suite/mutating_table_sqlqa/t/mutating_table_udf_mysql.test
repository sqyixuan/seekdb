--echo ##无参
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
delimiter //;
CREATE  FUNCTION f1()
returns int
begin
	declare a int;
	SELECT  sum(c1)  FROM t1 inner join t2 on t1.c1=t2.a1 into a ;
	return a;
END
//
select f1();
//
delimiter ;//

--echo ##定义有参的函数
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
delimiter //;
CREATE  FUNCTION f1(a int)
returns int
begin
	declare a int;
	SELECT  sum(c1)  FROM t1 inner join t2 on t1.c1=t2.a1 into a ;
	return a;
END
//
select f1(10);
//
delimiter ;//

--echo ##无参存储过程
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
delimiter //;
CREATE  procedure p1()
begin
	insert into t1 values(2,'dddd',2.32);
	insert into t2 values(2,'dddd',3.120);
	insert into t2 values(222,'ssss',0.012);
	insert into t1(c1) select a1 from t2 where a2='ssss';
END
//
call p1();
//
delimiter ;//


--echo ##in参数
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
delimiter //;
CREATE PROCEDURE p1 (IN a CHAR(5),in b int)
BEGIN
    if (a is not null) then
	set a = a + 0.495;
	set b = a + b;
end if;
insert into t1 values(4,a,b);
END
//
delimiter ;//
call p1('3',2);

--echo ##out参数
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
delimiter //;
CREATE PROCEDURE p1 (out a CHAR(10))
BEGIN
    if (a is null) then
	set a ='99.954';
	set a = a + 0.495;
end if;
insert into t1 values(4,a,a);
END
//
delimiter ;//
call p1(@a);
select @a;


--echo ##inout参数
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
DELIMITER //;
CREATE PROCEDURE p1(INOUT a INT)
BEGIN
  DECLARE b INT(11);
  IF a > 3 THEN
     SET b = 100;
  ELSE 
     SET b = 500;
  END IF;
  SET a = b;
insert into t1 values(a,b,a);
END 
//
DELIMITER ;//
--error 1414
call p1(100);

--echo ##存储过程用循环
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t1(c1) select a1 from t2 where a2='ssss';
delimiter //;
CREATE  procedure p1()
begin
	declare i int;
  	set i := 1;
	WHILE i <= 10 do
	insert into t1 values(i,'dddd',2.32);
	set i := i+1;
	END while;
END
//
delimiter ;//
CALL p1();
SELECT COUNT(*)  FROM  t1;

--echo ##procedure异常
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
delimiter //;
CREATE  PROCEDURE p1()
begin
	insert into t1 values(2,'dddd',2.32);
	insert into t2 values(2,'dddd',3.120);
	insert into t2 values(222,'ssss',0.012);
	insert into t1(c2) select a1 from t2 where a2='ssss';
end//
DELIMITER ;//
--error 1364
call p1();
select sum(c1) from t1;


--echo ##调用语句异常
drop table if exists  t1;
drop table if exists  t2;
drop function if exists  f1;
drop procedure if exists  p1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
delimiter //;
CREATE  PROCEDURE p1()
begin
	insert into t1 values(2,'dddd',2.32);
	insert into t2 values(2,'dddd',3.120);
	insert into t2 values(222,'ssss',0.012);
end//
DELIMITER ;//
--error 1064
call p1(select c1 from t1);
select sum(c1) from t1;

--echo  ########清空回收站，删除测试数据库，表等 ##########
--disable_warnings
drop database IF EXISTS  db1;