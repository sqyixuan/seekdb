--echo ##多个触发事件的组合触发
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128) not null) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128) not null) default charset='utf8';
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	insert into t2 values(333,'ssss');
	update t2 set a2='true' where a1=333;
	delete from t2 where a1=2;
end
//
delimiter ;//
--error 0,1442
update t1 set c1=1000.01 where c2=(select a2 from t2 as a  where a1=222);

--echo ##触发sql异常
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	insert into t2 values(333,'ssss');
	update t2 set a2='true' where a1=333;
	delete from t2 where a1=2;
end
//
delimiter ;//
--error 1062
update t1 set c2='asdd';

--echo ##触发器中sql作用于原表
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a2='false' where a1=(select min(c1) from t1);
end
//
delimiter ;//
--error 0,1442
update t1 set c2='asdd';

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t1 a  set c2='false' where c1=2;
end
//
delimiter ;//
--error 0,1442
update t1 set c2='asdd' where c1=111;


