--echo ##多表join
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	insert into t2 values(333,'ssss');
	update t2 set a2='true' where a1=333;
	delete from t2 where a1=2;
end
//
delimiter ;//
--error 0,1442
update t1 set c1 = (select t2.a1 from t1 inner join t2  on t1.c2=t2.a2 where a2='ssss') where c2='ssss';


--echo ##触发器类型
--echo ##insert into select
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
insert into t2 values(333,null);
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	update t2 set a2='false' where a1=333;
end
//
delimiter ;//
--error 0,1442
insert into t1(c1,c2) select a1,a2 from t2 where a2 is null;

--echo ##values函数
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
insert into t2 values(333,null);
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	update t1 set c2='false' where c1=cast(111 as char(10));
end
//
delimiter ;//
--error 0,1442
insert into t1(c1) values(cast(200 as char(10))); 

--echo ##运算符
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128)) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128)) default charset='utf8';
insert into t1 values(2,'dddd');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
insert into t2 values(333,null);
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	update t2 set a2='false' where a1=333;
	insert into t1 values(222,'cast');
end
//
delimiter ;//
--error 0,1442
insert into t1(c1) values(200-100);

--echo ##插入多个字段值
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	update t2 set a2='false' where a1=333;
	insert into t1 values(222,'cast',3.33);
end
//
delimiter ;//
--error 0,1442
insert into t1(c1,c3) values(200-100,2.3210-9.32);    

--echo ##set列名=函数
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//
delimiter ;//
update t1 set c1=SQRT(9) where c2='ssss';

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=SQRT(16) where a2='ssss';
end
//
delimiter ;//
update t1 set c1=SQRT(9) where c2='ssss';

--echo ##运算符
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3+3/3*3-3/0.1 where a2='ssss';
end
//
delimiter ;//
update t1 set c1=3+3/3*3-3 where c2='ssss';

--echo ##更新多个字段
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//
delimiter ;//
update t1 set c1=SQRT(9),c3=TRUNCATE(c3,1) where c2='ssss';

--echo ##=,<,<=,>=,<>
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
	update t2 set a2='梅西' where a1<3;
	update t2 set a2='c罗' where a1<=2;
	update t2 set a2='伊布' where a1>=333;
	update t2 set a2='贝克汉姆' where a1<>2;
end
//
delimiter ;//
update t1 set c1=3 where c2='ssss';

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t2
for each row 
begin
	update t1 set c1=3 where c2='ssss';
end
//
update t2 set a1=3 where a2='ssss';
update t2 set a2='梅西' where a1<3;
update t2 set a2='c罗' where a1<=2;
update t2 set a2='伊布' where a1>=333;
update t2 set a2='贝克汉姆' where a1<>2;
//
delimiter ;//

--echo ##and or
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where c2='ssss' or c3=2.999;
update t1 set c1=4 where c2='dddd' and c3=2.32;

--echo ##between and
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a1 between 223 and 333;
end
//   
delimiter ;//
update t1 set c1=3 where c2='ssss';

--echo ##like,not like
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where c2 like 's%';
update t1 set c1=4 where c2 not like 'dd%';

--echo ##exists,any,all,in
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(222,'ssss',0.012);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where exists (select c1 from t1 where c1=2);

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(222,'ssss',0.012);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where 3>= any (select c1 from t1 where c1=2);

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(222,'ssss',0.012);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where 3>= all (select c1 from t1 where c1=2);

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(222,'ssss',0.012);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a1=3 where a2='ssss';
end
//   
delimiter ;//
update t1 set c1=3 where 2  in (select c1 from t1 where c1=2);


--echo ##delete
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
