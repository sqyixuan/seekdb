--disable_warnings
drop database IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##单条sql嵌套触发
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128) not null) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128) not null) default charset='utf8';
insert into t1 values(1,'xinguan1');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
end
//
delimiter ;//
update t1 set c1=1000.01 where c2='ssss';
--disable_result_log
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--enable_result_log

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128) not null) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128) not null) default charset='utf8';
insert into t1 values(1,'xinguan1');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
end
//
delimiter ;//
--error 0,1442
insert into t1 (c1,c2) select a1,a2 from t2;
insert into t1 (c1,c2) select c1+1,c2 from t1 inner join t2 on t1.c1=t2.a1 where c1 is not null or c1 !=111 order by c1 limit 1;
--disable_result_log
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--enable_result_log

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128) not null) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128) not null) default charset='utf8';
insert into t1 values(1,'xinguan1');
insert into t1 values(111,'ssss');
insert into t2 values(2,'dddd');
insert into t2 values(222,'ssss');
DELIMITER //;
create trigger tr1
before delete on t1
for each row 
begin
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
	update t2 set a2='false' where a1=222;
end
//
delimiter ;//
--error 0,1442
delete from t1 where c2=(select a2 from t2 where a1=222);
--disable_result_log
--sorted_result 
select * from t1;
--sorted_result 
select * from t2;
--enable_result_log

--echo ##多条sql同时嵌套触发
