drop database IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##多次调用udf
drop table if exists  t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop table if exists  t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop function if exists  f1;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
CREATE  FUNCTION f1()
returns int
begin
declare a int;
SELECT  sum(c1)  FROM t1 inner join t2 on t1.c1=t2.a1 into a ;
return a;
END
