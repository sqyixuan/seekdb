##=,<,<=,>=,<>
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t1 values(111,'ssss',2.999);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
insert into t2 values(333,null,1.11);
create trigger tr1
before update on t1
for each row 
begin
update t2 set a1=3 where a2='ssss';
update t2 set a2='梅西' where a1<3;
update t2 set a2='c罗' where a1<=2;
update t2 set a2='伊布' where a1>=333;
update t2 set a2='贝克汉姆' where a1<>2;
end
//
update t1 set c1=3 where c2='ssss';
drop table if exists t1;
drop table if exists t2;
