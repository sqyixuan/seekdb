##delete
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
create trigger tr1
before delete on t1
for each row 
begin
update t2 set a1=3 where a2='ssss';
end
//
DELETE  a FROM t1 AS a LEFT JOIN t2 AS b ON a.c1 = b.a1 WHERE b.a1 > 0;
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) default charset='utf8';
create table t2 (a1 int primary key, a2 varchar(128),a3 float) default charset='utf8';
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
create trigger tr1
before delete on t1
for each row 
begin
DELETE  from t2 where a1 = case a1 when a2='dddd' then a1=222 else a1 end;
end
//
DELETE  a FROM t1 AS a LEFT JOIN t2 AS b ON a.c1 = b.a1 WHERE b.a1 > 0;
##分区表
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) partition by key(c1) partitions 3;
create table t2 (a1 int primary key, a2 varchar(128),a3 float) partition by key(a1) partitions 3;
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
create trigger tr1
before delete on t1
for each row 
begin
update t2 set a1=3 where a2='ssss';
end
//
DELETE  a FROM t1 AS a LEFT JOIN t2 AS b ON a.c1 = b.a1 WHERE b.a1 > 0;
drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 varchar(128),c3 float) partition by key(c1) partitions 3;
create table t2 (a1 int primary key, a2 varchar(128),a3 float) partition by key(a1) partitions 3;
insert into t1 values(2,'dddd',2.32);
insert into t2 values(2,'dddd',3.120);
insert into t2 values(222,'ssss',0.012);
create trigger tr1
before delete on t1
for each row 
begin
DELETE  from t2 where a1 = case a1 when a2='dddd' then a1=222 else a1 end;
end
