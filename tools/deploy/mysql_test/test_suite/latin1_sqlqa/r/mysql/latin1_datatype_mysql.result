DROP PROCEDURE create_latin1;
CREATE PROCEDURE create_latin1()
BEGIN
DECLARE i INT DEFAULT 0;
DECLARE max_value INT DEFAULT 256;
WHILE i <= max_value DO
select char(i);
SET i = i + 1;
END WHILE;
END;
