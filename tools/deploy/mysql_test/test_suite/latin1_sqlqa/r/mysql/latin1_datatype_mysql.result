############################# ¶r≤≈?´¨ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET latin1;
use db1;
drop table t1;
CREATE TABLE t1 (
id int AUTO_INCREMENT PRIMARY KEY,
char_column CHAR(100),
nchar_column NATIONAL CHAR(100),
varchar_column VARCHAR(100),
nvarchar_column NATIONAL VARCHAR(100),
text_column TEXT,
blob_column BLOB
)DEFAULT CHARACTER SET = latin1;
DROP PROCEDURE build_latin1_table;
create procedure build_latin1_table()
begin
DECLARE i int;
set i=0;
WHILE i<256
DO
IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
END IF;
SET i=i+1;
END WHILE;
commit;
end ;
/
call build_latin1_table();
/
DROP PROCEDURE build_latin1_table;
/
create procedure build_latin1_table()
begin
DECLARE i int;
set i=0;
WHILE i<256
DO
IF (i < 128 ) THEN
insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
END IF;
SET i=i+1;
END WHILE;
commit;
end ;
/
call build_latin1_table();
/
