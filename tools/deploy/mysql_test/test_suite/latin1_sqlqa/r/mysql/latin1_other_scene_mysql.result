drop table if exists t1,t2,t3,t4,t5,t6,t7,t8;
SET NAMES latin1 COLLATE latin1_swedish_ci;
create table t1 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_bin;
create table t2 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_german1_ci;
create table t3 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_german2_ci;
create table t4 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_danish_ci;
create table t5 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_general_ci;
create table t6 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_general_cs;
create table t7 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;
SET NAMES latin1 COLLATE latin1_spanish_ci;
create table t8 select 2 as a, concat(repeat('MySQL', @@max_allowed_packet/10), ';') as b;

############################# ¦r²Å?«¬ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET latin1;
use db1;

drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(100),
    nchar_column NATIONAL CHAR(100),
    varchar_column VARCHAR(100),
    nvarchar_column NATIONAL VARCHAR(100),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = latin1;

DROP PROCEDURE build_latin1_table;


create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_latin1_table();
/


