#### ¥þ³¡ latin1 ¦r²Å??
SET NAMES latin1;
DROP TABLE t1;
CREATE TABLE t1 (b VARCHAR(2));
INSERT INTO t1 VALUES ('0'),('1'),('2'),('3'),('4'),('5'),('6'),('7');
INSERT INTO t1 VALUES ('8'),('9'),('A'),('B'),('C'),('D'),('E'),('F');
DROP TABLE tail;
CREATE  TABLE head AS SELECT concat(b1.b, b2.b) AS head FROM t1 b1, t1 b2;
CREATE  TABLE tail AS SELECT concat(b1.b, b2.b) AS tail FROM t1 b1, t1 b2;

DROP TABLE t_test;
CREATE TABLE t_test AS
SELECT concat(head, tail) AS code
FROM head, tail
WHERE (head BETWEEN '81' AND 'FE') AND (tail BETWEEN '40' AND '7E' OR tail BETWEEN 'A1' AND 'FE')
ORDER BY head, tail;
SELECT COUNT(*) FROM t_test;
+----------+
| COUNT(*) |
+----------+
|    19782 |
+----------+

SELECT * FROM T_TEST;
SELECT unhex(code) FROM T_TEST;
