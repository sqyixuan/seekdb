+----------------------------------------------------------------------------+----------------------------------------------------------------------------+

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100) charset latin1 collate latin1_swedish_ci );

DROP PROCEDURE build_latin1_table;

create procedure build_latin1_table()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/

