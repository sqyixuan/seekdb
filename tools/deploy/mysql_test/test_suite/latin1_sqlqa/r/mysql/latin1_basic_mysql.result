#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###?Â¸mÂ¦}Â¬dÂ¬Ã?Â«eÂ¦rÂ²ÃÂ¶Â°?Â¸m
set names 'latin1';
set character_set_database = 'latin1';
set character_set_server = 'latin1';
set character_set_results = 'utf8mb4';
show character set where Charset = 'latin1';
Charset	Description	Default collation	Maxlen
latin1	cp1252 West European	latin1_swedish_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	latin1
character_set_connection	latin1
character_set_database	latin1
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	latin1
character_set_system	utf8mb4
# ?Â«ÃÂ¯Â²??Â«Ã¼Â©wÂ¦rÂ²ÃÂ¶Â°Â¡A???Â«eÂ¨t?Â¦rÂ²ÃÂ¶Â°
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET latin1;
use db1;
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(100));

DROP PROCEDURE build_latin1_table;

create procedure build_latin1_table()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128|| (i >= 0xA1 && i < 0xE0) ) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/

DROP PROCEDURE build_latin1_table;
/

create procedure build_latin1_table()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128) THEN
      insert into t1(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call build_latin1_table();
/


