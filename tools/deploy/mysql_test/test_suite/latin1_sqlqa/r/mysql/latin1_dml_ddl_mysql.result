DROP DATABASE db2;
CREATE DATABASE db2 CHARACTER SET latin1;
DROP table db2.t2;
CREATE TABLE db2.t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(100)
)DEFAULT CHARACTER SET = latin1;

DROP PROCEDURE build_latin1_table;

create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into db2.t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/

