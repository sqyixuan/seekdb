--error 0,1305
DROP PROCEDURE build_latin1_table;
/

create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(numeric_column,float_column,double_column) values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
/

