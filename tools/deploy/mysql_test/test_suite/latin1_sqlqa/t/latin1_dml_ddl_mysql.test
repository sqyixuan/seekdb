show variables like 'character_set%';
--enable_query_log

########################## select ########################

--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET latin1;
use db1;

--enable_sorted_result
--error 0,1051
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(100)
)DEFAULT CHARACTER SET = latin1;

--error 0,1305
DROP PROCEDURE build_latin1_table;

delimiter /;
create procedure build_latin1_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into t2(a) values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/
delimiter ;/


