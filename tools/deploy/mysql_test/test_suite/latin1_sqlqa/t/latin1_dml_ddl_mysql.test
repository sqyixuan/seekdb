--echo #Environmental cleaning
connection default;
purge recyclebin;

--disable_query_log
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--disable_warnings
--enable_warnings
#call oceanbase.create_mysql_tenant_1c2g_with_arg('tenant_charset_test','charset=latin1');
