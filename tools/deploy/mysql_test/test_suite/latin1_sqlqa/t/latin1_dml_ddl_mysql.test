select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id = 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id > 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id < 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id between 100 and 200 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id = 100 or t1.id = 10 order by t1.id;

select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a = 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a > 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a < 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a between 'a' and 'y' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a = 'w' or t1.id = 'p' order by t1.id;

select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like '%}%' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like '% } %' order by t1.id;
