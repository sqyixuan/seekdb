SET sql_mode = '';
select id,sum(a) from db1.t2 order by db1.t2.a;
select sum(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
#count
select count(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select count(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
#max
select max(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select max(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
#min
select min(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select min(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
#avg
select avg(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select avg(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;

#union/union all
select * from db1.t2 union select * from db2.t2;
select * from db1.t2 union all select * from db2.t2;
select * from (select * from db1.t2 union select * from db2.t2) t order by t.a;
select * from (select * from db1.t2 union all select * from db2.t2) t order by t.a;

--error 0,1305
DROP PROCEDURE create_latin1;
delimiter //;
CREATE PROCEDURE create_latin1()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a like char(i) order by t1.id;
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_latin1();

