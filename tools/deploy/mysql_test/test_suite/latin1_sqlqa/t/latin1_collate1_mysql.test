--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET latin1;
use db1;

drop table if exists latin1_german1_table,latin1_danish_table,latin1_german2_table,latin1_general1_table,latin1_general2_table,latin1_spanish_table;

--error 0,1305
drop procedure if exists build_latin1_german1_table;
--error 0,1305
drop procedure if exists build_latin1_danish_table;
--error 0,1305
drop procedure if exists build_latin1_german2_table;
--error 0,1305
drop procedure if exists build_latin1_general1_table;
--error 0,1305
drop procedure if exists build_latin1_general2_table;
--error 0,1305
drop procedure if exists build_latin1_spanish_table;

create table latin1_german1_table(c1 char(30) charset latin1 collate latin1_german1_ci);
create table latin1_danish_table(c1 char(30) charset latin1 collate latin1_danish_ci);
create table latin1_german2_table(c1 char(30) charset latin1 collate latin1_german2_ci);
create table latin1_general1_table(c1 char(30) charset latin1 collate latin1_general_ci);
create table latin1_general2_table(c1 char(30) charset latin1 collate latin1_general_cs);
create table latin1_spanish_table(c1 char(30) charset latin1 collate latin1_spanish_ci);

--error 0,1305
DROP PROCEDURE build_latin1_german1_table;

delimiter /;
create procedure build_latin1_german1_table()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
    IF (i < 128 ) THEN
      insert into latin1_german1_table values(unhex(hex(i)));
    END IF;
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_german1_table();
/
