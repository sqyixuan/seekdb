SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8mb4))
  FROM latin1_german1_table order by c1;

insert into latin1_danish_table select * from latin1_german1_table;
insert into latin1_german2_table select * from latin1_german1_table;
insert into latin1_general1_table select * from latin1_german1_table;
insert into latin1_general2_table select * from latin1_german1_table;
insert into latin1_spanish_table select * from latin1_german1_table;

SELECT c1,
  hex(c1) c2,
  hex(@u:=convert(c1 using latin1)) c3
  FROM latin1_danish_table order by c2;

SELECT c1,
  hex(c1) c2,
  hex(@u:=convert(c1 using gbk)) c3
  FROM latin1_german2_table order by c1,c2;

SELECT c1,
  hex(c1) c2,
  hex(@u:=convert(c1 using utf16)) c3
  FROM latin1_general1_table order by c1,c3;

SELECT hex(@u:=convert(c1 using gb18030)) c1,
  hex(@u:=convert(c1 using dec8)) c2,
  hex(@u:=convert(c1 using hkscs)) c3
  FROM latin1_general2_table order by c2,c3;

SELECT hex(@u:=convert(c1 using latin1)) c1,
  hex(@u:=convert(c1 using binary)) c2,
  hex(@u:=convert(c1 using gb18030_2022)) c3
  FROM latin1_spanish_table order by c1,c2,c3;

--error 0,1051
drop table test_latin1_bak;
create table test_latin1_bak(c0 varchar(100) collate latin1_german1_ci ,c1 varchar(100) collate latin1_danish_ci,c2 varchar(100) collate latin1_german2_ci ,c3 varchar(100) collate latin1_general_ci,c4 varchar(100) collate latin1_general_ci,c5 varchar(100) collate latin1_general_cs ,c6 varchar(100) collate latin1_spanish_ci,sal int,id int) character set latin1;

--error 0,1305
drop procedure test_latin1_bak_ascii_pro;

delimiter /;
create procedure test_latin1_bak_ascii_pro()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_latin1_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call test_latin1_bak_ascii_pro();
/

delimiter ;/

SELECT c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM test_latin1_bak order by c1;

