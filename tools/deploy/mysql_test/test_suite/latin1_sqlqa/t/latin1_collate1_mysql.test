--error 0,1305
drop procedure build_latin1_table;

delimiter /;
create procedure build_latin1_table()
  begin
        DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_latin1_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_latin1_table();
/
delimiter ;/
SELECT c0,c1,
  hex(c1),
  hex(@u:=convert(c1 using gbk))
  FROM test_latin1_bak order by c1;

