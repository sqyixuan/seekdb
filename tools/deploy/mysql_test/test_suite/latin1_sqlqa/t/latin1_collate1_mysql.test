drop table test_latin1_bak;

CREATE TABLE test_latin1_bak(
    c0 TEXT COLLATE latin1_german1_ci,
    c1 TEXT COLLATE latin1_danish_ci,
    c2 TEXT COLLATE latin1_german2_ci,
    c3 TEXT COLLATE latin1_general_ci,
    c4 TEXT COLLATE latin1_general_ci,
    c5 TEXT COLLATE latin1_general_cs,
    c6 TEXT COLLATE latin1_spanish_ci,
    sal INT,
    id INT
) CHARACTER SET latin1;

--error 0,1305
drop procedure test_latin1_bak_ascii_pro;

delimiter /;
CREATE PROCEDURE test_latin1_bak_ascii_pro()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_latin1_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), CONVERT(CHAR(i) USING latin1), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /
DELIMITER ;/

