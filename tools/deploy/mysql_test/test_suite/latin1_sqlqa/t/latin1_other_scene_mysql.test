select t1.*,t2.* from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t2.id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t1.id;

select
    t1.id,hex(t1.char_column),t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.char_column=t2.char_column order by id;

select
    t1.id,hex(t1.char_column),t1.char_column,ascii(t1.char_column)
from db1.t1 t1 ,db1.t2 t2 where t1.char_column=t2.char_column
and ascii(t1.char_column)='00'
order by id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.varchar_column=t2.varchar_column order by id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.text_column=t2.text_column order by id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.blob_column=t2.blob_column order by id;

select
    t1.id,t1.char_column,t2.char_column
from db1.t1 t1 ,db1.t2 t2 where t1.varchar_column=t2.varchar_column order by id;

