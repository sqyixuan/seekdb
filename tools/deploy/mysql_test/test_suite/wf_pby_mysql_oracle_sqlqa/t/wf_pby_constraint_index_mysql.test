--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);

--echo     #wf_gby-7    约束
--echo     #wf_gby-8    索引




set _windowfunc_optimization_settings = 0;

--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 bigint primary key UNIQUE,c2 bigint default 1,c3 varchar(100) not null,c4 FLOAT check(c4<=9999999),c5 json);
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<101
        do
                INSERT INTO test1 values(i,100,'张三',2000,JSON_ARRAY(mod(i,5)+1));
        set i=i+1;
        end while;
        commit;
end;
/
delimiter ;/
call procedure_1();
select count(c1) from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

explain basic SELECT /*+ parallel(3)*/ max(c2)over(PARTITION by c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/distinct max(c2)over(PARTITION by c3) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c2)over(PARTITION by c3),min(c4)over(PARTITION by c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c2)over(PARTITION by c3),min(c4)over(PARTITION by c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c2)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c2)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c3)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c3)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c4)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c4)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c5)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c5)over(PARTITION by c2,c3,c4,c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ sum(c5)over(PARTITION by c2,c1,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ sum(c5)over(PARTITION by c2,c1,c5) from test1 order by c2 asc;
drop procedure procedure_1;
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;



CREATE TABLE test1
( c1 bigint not null,
 c2 varchar(50) not null,
 c3 varchar(50),
 CONSTRAINT waijian PRIMARY KEY (c1)
);

CREATE TABLE test2
( c1 bigint not null,
 c2 bigint not null,
 CONSTRAINT waijian
 FOREIGN KEY (c1)
 REFERENCES test1(c1)
);

insert into test1 values(55,'aqefqf','cwewwfwf');
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<101
        do
                INSERT INTO test2 values(55,i);
        set i=i+1;
        end while;
        commit;
end;
/
delimiter ;/
call procedure_1();
select count(c1) from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST2', method_opt=>'for all columns size auto', estimate_percent=>100);

explain basic SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c2) from test2 order by c2 asc;
SELECT /*+ parallel(3)*/distinct max(c2)over(PARTITION by c2) from test2 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ max(c2)over(PARTITION by c2) from test2 order by c2 asc;
SELECT /*+ parallel(3)*/ max(c2)over(PARTITION by c2) from test2 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1) from test2 order by c2 asc;
SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1) from test2 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1,c1) from test2 order by c2 asc;
SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1,c1) from test2 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1,c2,c1) from test2 order by c2 asc;
SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c1,c2,c1) from test2 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ max(test1.c1)over(PARTITION by test1.c1,test2.c1) from test2 left JOIN test1 on test1.c1=test2.c1 order by test1.c1 asc;
SELECT /*+ parallel(3)*/ max(test1.c1)over(PARTITION by test1.c1,test2.c1) from test2 left JOIN test1 on test1.c1=test2.c1 order by test1.c1 asc;
drop table test2;
drop table test1;
drop procedure procedure_1;








--echo     #wf_gby-8    索引
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 bigint,c2 bigint,c3 varchar(100),c4 FLOAT,c5 json);
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<101
        do
                INSERT INTO test1 values(i,100,'张三',2000,JSON_ARRAY(mod(i,5)+1));
        set i=i+1;
        end while;
        commit;
end;
/
delimiter ;/
call procedure_1();
select * from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
create index index_1 on test1(c2);
create UNIQUE index index_2 on test1(c1);
--error 0,3152
create index index_3 on test1(c1,c2,c3,c4,c5);
create index index_3 on test1(c1,c2,c3,c4);
create index index_4 on test1(c4 asc);


explain basic SELECT /*+ parallel(3)*/ c1,max(c1)over(PARTITION by c2) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,max(c1)over(PARTITION by c2) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c2,max(c2)over(PARTITION by c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,max(c1)over(PARTITION by c3) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c4,max(c4)over(PARTITION by c4) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,max(c1)over(PARTITION by c3) from test1 order by c2 asc;


explain basic SELECT /*+ parallel(3)*/ c1,sum(c1)over(PARTITION by c2) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,sum(c1)over(PARTITION by c2) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c2,sum(c2)over(PARTITION by c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,sum(c1)over(PARTITION by c3) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c4,sum(c4)over(PARTITION by c4) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,sum(c1)over(PARTITION by c3) from test1 order by c2 asc;


explain basic SELECT /*+ parallel(3)*/ c1,sum(c1)over(PARTITION by c2,c3,c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,sum(c1)over(PARTITION by c2,c3,c5) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c2,sum(c2)over(PARTITION by c2,c4) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,sum(c1)over(PARTITION by c2,c4) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c4,sum(c4)over(PARTITION by c4,c5,c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,sum(c1)over(PARTITION by c4,c5,c3) from test1 order by c2 asc;


explain basic SELECT /*+ parallel(3)*/ c1,count(c3)over(PARTITION by c2) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,count(c3)over(PARTITION by c2) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c2,count(c2)over(PARTITION by c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,count(c4)over(PARTITION by c4) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c4,count(c5)over(PARTITION by c5) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c2,count(c5)over(PARTITION by c5) from test1 order by c2 asc;


explain basic SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c1)over(PARTITION by c2) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c1)over(PARTITION by c2) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c3)over(PARTITION by c3) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c3)over(PARTITION by c3) from test1 order by c2 asc;

explain basic SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c5)over(PARTITION by c4) from test1 order by c2 asc;
SELECT /*+ parallel(3)*/ c1,c2,c3,c4,c5,avg(c5)over(PARTITION by c4) from test1 order by c2 asc;


drop table test1;
drop procedure procedure_1;




