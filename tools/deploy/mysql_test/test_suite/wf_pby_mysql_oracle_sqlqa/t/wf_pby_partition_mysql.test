--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo     #wf_gby-9    分区表




--echo    #hash分区
--error 0,1051
drop table test1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 varchar(50)) PARTITION by hash(c1)(PARTITION p1,PARTITION p2,PARTITION p3);
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<61
        do
                INSERT INTO test1 values(i,100,'ugitdyffj');
        set i=i+1;
        end while;
        commit;
end;
/
delimiter ;/
call procedure_1();
select * from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
select * from test1 PARTITION(p1) order by c1 asc;
select * from test1 PARTITION(p2) order by c1 asc;
select * from test1 PARTITION(p3) order by c1 asc;

EXPLAIN basic SELECT /*+ parallel(3)*/c2,max(c1)OVER(PARTITION by c3) from test1 PARTITION(p1) order by c1 asc;
SELECT /*+ parallel(3)*/c2,max(c1)OVER(PARTITION by c3) from test1 PARTITION(p1) order by c1 asc;

EXPLAIN basic SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2) from test1 PARTITION(p1) order by c1 asc;
SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2) from test1 PARTITION(p1) order by c1 asc;

EXPLAIN basic SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3) from test1 PARTITION(p1) order by c1 asc;
SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3) from test1 PARTITION(p1) order by c1 asc;

EXPLAIN basic SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3) from test1 order by c1 asc;
SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3) from test1 order by c1 asc;

--error 0,1064
EXPLAIN basic SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3)OVER(PARTITION by c2,c3) from test1 PARTITION(p1) order by c1 asc;
