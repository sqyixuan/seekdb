--echo    #二级分区
--error 0,1051
drop table test1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 varchar(50)) PARTITION by hash(c1) subPARTITION by hash(c1)(
PARTITION p1(subpartition p11),
PARTITION p2(subpartition p22),
PARTITION p3(subpartition p33));
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<61
        do
                INSERT INTO test1 values(i,100,'ugitdyffj');
        set i=i+1;
        end while;
        commit;
end;
/
