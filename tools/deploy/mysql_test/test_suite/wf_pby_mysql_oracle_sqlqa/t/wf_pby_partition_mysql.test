--error 0,4016
SELECT /*+ parallel(3)*/c2,c3,max(c2)OVER(PARTITION by c2,c3 order by c2 asc) from test1 order by c1 asc;

--error 0,1064
EXPLAIN basic SELECT /*+ parallel(3)*/c2,c3,max(c1)OVER(PARTITION by c2,PARTITION by c3) from test1 order by c1 asc;
