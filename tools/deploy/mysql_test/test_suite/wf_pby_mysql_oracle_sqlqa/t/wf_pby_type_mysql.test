--echo   #over======>虚拟列\parallel
CREATE TABLE test1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
  SELECT 0, 0, 1, 0
  UNION ALL
  SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1,round((c3+100)/10,0) FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;

alter table test1 add c5 bigint(20) AS (c4);
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
set _windowfunc_optimization_settings = 0;

EXPLAIN BASIC select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c1) over (partition by c5) from test1 order by c3 asc;
select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c1) over (partition by c5) from test1 order by c3 asc;

EXPLAIN BASIC select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5) from test1 order by c3 asc;
select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5) from test1 order by c3 asc;

EXPLAIN BASIC select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;
select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;

EXPLAIN BASIC select /*+parallel(1) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;
select /*+parallel(1) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;

EXPLAIN BASIC select /*+parallel(10) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;
select /*+parallel(10) */c1,c2,c3,c4,c5, sum(c5) over (partition by c5,c2) from test1 order by c3 asc;
DROP TABLE test1;






--echo   #wf_gby-2-1   字符类型
CREATE TABLE test1(id bigint, c1 CHAR(20),c2 VARCHAR(20),c3 TINYBLOB,c4 TINYTEXT,c5 BLOB(20));
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<10
	do
		INSERT INTO test1 values(i,'aaa','bbb','ccc','ddd','eee');
		INSERT INTO test1 values(i,'jjj','aaa','hhh','ooo','sss');
		INSERT INTO test1 values(i,'bbb','yyy','ttt','lll','mmm');
		INSERT INTO test1 values(i,'fff','zzz','hhh','vvvv','nnn');
		INSERT INTO test1 values(i,'fff','xxx','ccc','ooo','eee');
		INSERT INTO test1 values(i,'bbb','zzz','ttt','vvvv','mmm');
		INSERT INTO test1 values(i,'aaa','yyy','hhh','lll','sss');
		INSERT INTO test1 values(i,'fff','xxx','ccc','ooo','mmm');
		INSERT INTO test1 values(i,'jjj','zzz','ttt','lll','nnn');
		INSERT INTO test1 values(i,'aaa','bbb','hhh','ddd','sss');
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/

call procedure_1();
select * from test1 order by id asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,count(c2)over(partition by c1) from test1 order by id asc ;
