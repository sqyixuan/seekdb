explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5, min(c4)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5, min(c4)over(partition by c2) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5, avg(c2)over(partition by c3/4) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5, avg(c2)over(partition by c3/4) from test1 order by id asc ;
drop procedure procedure_1;
drop table test1;















