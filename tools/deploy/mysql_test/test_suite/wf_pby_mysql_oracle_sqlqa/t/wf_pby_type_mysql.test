set _windowfunc_optimization_settings = 0;


--echo   #over======>单列
--error 0,1051
drop table test1;
CREATE TABLE test1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
  SELECT 0, 0, 1, 2
  UNION ALL
  SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1,round((c4+2)/2.5,0)  FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;

call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
set _windowfunc_optimization_settings = 0;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c1), sum(c2) over (partition by c1) from test1 order by c2 asc;
#select /*+parallel(3) */DISTINCT(c1), sum(c2) over (partition by c1) from test1 order by c2 asc;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c2), sum(c2) over (partition by c2) from test1 order by c2 asc;
select /*+parallel(3) */DISTINCT(c2), sum(c2) over (partition by c2) from test1 order by c2 asc;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c3), sum(c2) over (partition by c3) from test1 order by c2 asc;
select /*+parallel(3) */DISTINCT(c3), sum(c3) over (partition by c3) from test1 order by c2 asc;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c4), sum(c2) over (partition by c4) from test1 order by c2 asc;
select /*+parallel(3) */DISTINCT(c4), sum(c3) over (partition by c4) from test1 order by c2 asc;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c4), sum(c1) over (partition by c4) from test1 order by c2 asc;
select /*+parallel(3) */DISTINCT(c4), sum(c1) over (partition by c4) from test1 order by c2 asc;

EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c4), sum(c2) over (partition by c4) from test1 order by c2 asc;
