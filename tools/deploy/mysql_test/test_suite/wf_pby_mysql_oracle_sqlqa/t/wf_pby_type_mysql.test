--echo   #wf_gby-2-2   数值类型
CREATE TABLE test1(id bigint, c1 TINYINT(20),c2 SMALLINT(20),c3 MEDIUMINT(20),
c4 INTEGER(20),c5 FLOAT(20),c6 DOUBLE,c7 DECIMAL(20));
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<11
	do
		INSERT INTO test1 values(i,1,2,3,4,5,6,7);
		INSERT INTO test1 values(i,2,3,4,5,6,7,8);
		INSERT INTO test1 values(i,3,4,5,6,7,8,9);
		INSERT INTO test1 values(i,4,5,6,7,8,9,10);
		INSERT INTO test1 values(i,5,6,7,8,9,10,11);
		INSERT INTO test1 values(i,6,7,8,9,10,11,12);
		INSERT INTO test1 values(i,7,8,9,10,11,12,13);
		INSERT INTO test1 values(i,6,7,8,9,10,11,12);
		INSERT INTO test1 values(i,5,6,7,8,9,10,11);
		INSERT INTO test1 values(i,4,5,6,7,8,9,10);
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();
select * from test1 order by id asc;

set _windowfunc_optimization_settings = 0;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, count(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, count(c2)over(partition by c1) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, sum(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, sum(c2)over(partition by c1) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, max(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, max(c2)over(partition by c1) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, min(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, min(c2)over(partition by c1) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, avg(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, avg(c2)over(partition by c1) from test1 order by id asc ;


explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, count(c2)over(partition by c2+c3+c4+c5-c6) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, count(c2)over(partition by c2+c3+c4+c5-c6) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, sum(c2+c3+c4+c5-c6)over(partition by c2+c3+c4+c5-c6) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, sum(c2+c3+c4+c5-c6)over(partition by c2+c3+c4+c5-c6) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, max(c2)over(partition by c2,c3) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, max(c2)over(partition by c2,c3) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, min(c4)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, min(c4)over(partition by c2) from test1 order by id asc ;

explain basic select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, avg(c2)over(partition by c6/4) from test1 order by id asc ;
select /*+parallel(3) */id,c1,c2,c3,c4,c5,c6,c7, avg(c2)over(partition by c6/4) from test1 order by id asc ;
drop procedure procedure_1;
drop table test1;




--echo   #wf_gby-2-3   时间日期类型
CREATE TABLE test1(id bigint, c1 DATE,c2 TIME,c3 YEAR,c4 DATETIME,c5 TIMESTAMP);
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<61
	do
		INSERT INTO test1 values(i,'2022-12-14','23:23:23',i+'1996','2022-12-14 23:23:23','2022-12-14 01:01:01');
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();

select * from test1 order by id asc;

set _windowfunc_optimization_settings = 0;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

explain basic select /*+parallel(3) */id,c2,c3,c5, count(c2)over(partition by c2) from test1 order by id asc ;
select /*+parallel(3) */id,c2,c3,c5, count(c2)over(partition by c2) from test1 order by id asc ;

drop procedure procedure_1;
drop table test1;
