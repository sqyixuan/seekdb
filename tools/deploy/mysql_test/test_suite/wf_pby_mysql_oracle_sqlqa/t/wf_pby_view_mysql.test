--echo  #select语句
CREATE table test1(c1 bigint,c2 FLOAT,c3 int, c4 bigint);
create view view_1 as select * from test1;
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<61
	do
		INSERT INTO view_1 values(i,i+null,i,i-i);
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();
select * from view_1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);


