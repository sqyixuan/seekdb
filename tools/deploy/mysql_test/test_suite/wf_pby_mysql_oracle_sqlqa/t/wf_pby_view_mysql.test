--echo    #聚合函数后跟xxxx
CREATE table test1(c1 bigint,c2 FLOAT,c3 char(20));
create view view_1 as select * from test1;
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<61
	do
		INSERT INTO view_1 values(i,531,'小赵');
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();
select * from view_1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
--disable_parsing
explain basic select /*+parallel(3) */c1,c2,c3,max(c1)over(PARTITION by c2 ROWS BETWEEN 1 preceding AND 1 following) from view_1 order by c1 asc;
select /*+parallel(3) */c1,c2,c3,max(c1)over(PARTITION by c2 ROWS BETWEEN 1 preceding AND 1 following) from view_1 order by c1 asc;

explain basic select /*+parallel(3) */c1,c2,c3,max(c2)over(PARTITION by c2 ROWS BETWEEN 1 preceding AND 1 following) from view_1 order by c1 asc;
select /*+parallel(3) */c1,c2,c3,max(c3)over(PARTITION by c2 ROWS BETWEEN 1 preceding AND 1 following) from view_1 order by c1 asc;

explain basic select /*+parallel(3) */c1,c2,c3,max(c2)over(PARTITION by c2) from view_1 order by c1 asc;
select /*+parallel(3) */c1,c2,c3,max(c2)over(PARTITION by c2) from view_1 order by c1 asc;

explain basic select /*+parallel(3) */c1,c2,c3,max(c2)over(PARTITION by c2 ROWS BETWEEN 1 preceding AND 1 following) from view_1 order by c1 asc;
