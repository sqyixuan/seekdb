--echo  #insert语句
--error 0,1051
drop table test1;
--error 0,1051
drop view view_1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 int, c4 bigint);
create view view_1 as select * from test1;
insert into view_1 values(1,55,-55,66);
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<61
	do
		INSERT INTO view_1 select i,c2,c3+i,c4 from view_1 order by c1 desc limit 1;
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();
select * from view_1 order by c1 asc;

EXPLAIN basic select /*+parallel(3) */ c2,sum(c2) over(partition by c2)from view_1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

EXPLAIN basic select /*+parallel(3) */ c2,sum(c2) over(partition by c2)from view_1 order by c1 asc;
