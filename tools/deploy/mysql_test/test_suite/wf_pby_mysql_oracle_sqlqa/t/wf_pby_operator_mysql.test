--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo     #wf_gby-6    运算符


set _windowfunc_optimization_settings = 0;


--echo     #wf_gby-6-1    计算运算符
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(c1 bigint,c2 bigint,c3 varchar(100),c4 FLOAT,c5 YEAR);
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
        declare i int default 1;
        while i<101
        do
                INSERT INTO test1 values(i,001,'张三',0.25,2000);
                INSERT INTO test1 values(i,500,'李斯',8.5,2050);
        set i=i+1;
        end while;
        commit;
end;
/
delimiter ;/
call procedure_1();
select * from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);

explain  basic select /*+parallel(3)*/ max(c2)over(PARTITION by c2+c3+c4+c5) from test1 order by c2 asc;
select /*+parallel(3)*/distinct max(c2)over(PARTITION by c2+c3+c4+c5) from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ max(c3)over(PARTITION by c2-c3-c4-c5) from test1 order by c2 asc;
select /*+parallel(3)*/distinct max(c3)over(PARTITION by c2-c3-c4-c5) from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ max(c4)over(PARTITION by c2*c3*c4*c5) from test1 order by c2 asc;
select /*+parallel(3)*/ distinct max(c4)over(PARTITION by c2*c3*c4*c5) from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ max(c5)over(PARTITION by c2/c3/c4/c5) from test1 order by c2 asc;
select /*+parallel(3)*/ distinct max(c5)over(PARTITION by c2/c3/c4/c5) from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ max(c5)over(PARTITION by c2/c3/c4/c5),min(c5)over(PARTITION by c2*c3*c4*c5) from test1 order by c2 asc;
--error 0,4016
select /*+parallel(3)*/distinct max(c5)over(PARTITION by c2/c3/c4/c5),min(c5)over(PARTITION by c2*c3*c4*c5) from test1 order by c2 asc;


explain  basic select /*+parallel(3)*/ sum(c2)over(PARTITION by (c2+c3+c4+c5))*max(c2)over(PARTITION by (c2-c3*c4+c5)) from test1 order by c2 asc;
--error 0,4016
select /*+parallel(3)*/ sum(c2)over(PARTITION by (c2+c3+c4+c5))*max(c2)over(PARTITION by (c2-c3*c4+c5)) from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ sum(c2)over(PARTITION by c2+c3+c4+c5)*0.85 from test1 order by c2 asc;
select /*+parallel(3)*/distinct sum(c2)over(PARTITION by c2+c3+c4+c5)*0.85 from test1 order by c2 asc;

explain  basic select /*+parallel(3)*/ sum(c3)over(PARTITION by c2-c3-c4-c5)*0.85 from test1 order by c2 asc;
select /*+parallel(3)*/distinct sum(c3)over(PARTITION by c2-c3-c4-c5)*0.85 from test1 order by c2 asc;

