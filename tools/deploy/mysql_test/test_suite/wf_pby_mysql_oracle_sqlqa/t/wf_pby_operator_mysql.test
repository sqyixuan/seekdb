explain  basic select /*+parallel(3)*/ sum(c5)over(PARTITION by c2/c3/c4/c5),avg(c3)over(PARTITION by c2/c3*c4/c5) from test1 order by c2 asc;
--error 0,4016
select /*+parallel(3)*/ sum(c5)over(PARTITION by c2/c3/c4/c5),avg(c3)over(PARTITION by c2/c3*c4/c5) from test1 order by c2 asc;



