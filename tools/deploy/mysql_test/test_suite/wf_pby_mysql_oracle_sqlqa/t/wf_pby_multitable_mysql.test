--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo    #wf_gby-5   多表联查


set _windowfunc_optimization_settings = 0;


--error 0,1051
drop table test1;
--error 0,1051
drop table test2;

CREATE table test1(c1 BIGINT,c2 FLOAT,c3 DECIMAL);
CREATE table test2(c1 bigint,c2 char(20),c3 VARCHAR(20));
--error 0,1305
drop procedure procedure_1;
delimiter /;
create procedure procedure_1()
begin
	declare i int default 1;
	while i<51
	do
		INSERT INTO test1 values(i,i+2,i+5);
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_1();

--error 0,1305
drop procedure procedure_2;
delimiter /;
create procedure procedure_2()
begin
	declare i int default 1;
	while i<51
	do
		INSERT INTO test2 values(i,'华莉','晓晴');
		INSERT INTO test2 values(i,'王刚','赵四');
		set i=i+1;
	end while;
	commit;
end;
/
delimiter ;/
call procedure_2();

SELECT * from test1 order by c1 asc;
SELECT * from test2 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'TEST2', method_opt=>'for all columns size auto', estimate_percent=>100);
CREATE index index_1 on test1(c1,c2,c3);
CREATE index index_2 on test2(c1,c2,c3);



--echo    #交叉连接
SET SESSION ob_query_timeout=12000000000;      #数据太大超时
