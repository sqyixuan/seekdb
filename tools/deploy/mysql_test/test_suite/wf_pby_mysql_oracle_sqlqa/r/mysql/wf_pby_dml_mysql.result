drop procedure procedure_1;
drop table test1;
#聚合函数后跟xxxx
CREATE table test1(c1 bigint,c2 FLOAT,c3 char(20));
create procedure procedure_1()
begin
declare i int default 1;
while i<51
do
INSERT INTO test1 values(i,531,'小赵');
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
