#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#wf_gby-3   DML语句
set _windowfunc_optimization_settings = 0;
#wf_gby-3-1   insert语句
drop table test1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 int, c4 bigint);
insert into test1 values(1,55,-55,66);
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int default 1;
while i<51
do
INSERT INTO test1 select i,c2,c3+i,c4 from test1 order by c1 desc limit 1;
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
select * from test1 order by c1 asc;
EXPLAIN basic select /*+parallel(3) */ c2,sum(c2) over(partition by c2)from test1 order by c1 asc;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
EXPLAIN basic select /*+parallel(3) */ c2,sum(c2) over(partition by c2)from test1 order by c1 asc;
