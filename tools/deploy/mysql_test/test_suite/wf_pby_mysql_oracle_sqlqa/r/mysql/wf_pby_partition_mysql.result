drop table test1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 varchar(50)) PARTITION by list(c1)subPARTITION by list(c1)(
PARTITION p1 values in(350)(subPARTITION p11 values in(350)),
PARTITION p2 values in(750)(subPARTITION p22 values in(750)),
PARTITION p3 values in(1000)(subPARTITION p33 values in(1000)));
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int default 1;
while i<60
do
INSERT INTO test1 values(350,100,'ugitdyffj');
INSERT INTO test1 values(750,100,'ugitdyffj');
INSERT INTO test1 values(1000,100,'ugitdyffj');
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
