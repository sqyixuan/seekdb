#range分区
drop table test1;
CREATE table test1(c1 bigint,c2 FLOAT,c3 varchar(50)) PARTITION by range(c1)(
PARTITION p1 values less than(1500),
PARTITION p2 values less than(2900),
PARTITION p3 values less than(4000));
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int default 1;
while i<61
do
INSERT INTO test1 values(i,100,'ugitdyffj');
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
