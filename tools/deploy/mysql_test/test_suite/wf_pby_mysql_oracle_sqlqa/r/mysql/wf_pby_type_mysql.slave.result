DROP TABLE test1;
#over======>虚拟列\parallel
CREATE TABLE test1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
SELECT 0, 0, 1, 0
UNION ALL
SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1,round((c3+100)/10,0) FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;
alter table test1 add c5 bigint(20) AS (c4);
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
set _windowfunc_optimization_settings = 0;
EXPLAIN BASIC select /*+parallel(3) */c1,c2,c3,c4,c5, sum(c1) over (partition by c5) from test1 order by c3 asc;
Query Plan
===================================================
|ID|OPERATOR                             |NAME    |
---------------------------------------------------
|0 |PX COORDINATOR MERGE SORT            |        |
|1 |└─EXCHANGE OUT DISTR                 |:EX10001|
|2 |  └─SORT                             |        |
|3 |    └─WINDOW FUNCTION                |        |
|4 |      └─PARTITION SORT               |        |
|5 |        └─EXCHANGE IN DISTR          |        |
|6 |          └─EXCHANGE OUT DISTR (HASH)|:EX10000|
|7 |            └─PX BLOCK ITERATOR      |        |
|8 |              └─TABLE FULL SCAN      |test1   |
===================================================
