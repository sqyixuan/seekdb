#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#wf_gby-1   over
#wf_gby-2   数据类型
set _windowfunc_optimization_settings = 0;
#over======>单列
drop table test1;
CREATE TABLE test1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
SELECT 0, 0, 1, 2
UNION ALL
SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1,round((c4+2)/2.5,0)  FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
set _windowfunc_optimization_settings = 0;
EXPLAIN BASIC select /*+parallel(3) */DISTINCT(c1), sum(c2) over (partition by c1) from test1 order by c2 asc;
Query Plan
==================================================================
|ID|OPERATOR                                            |NAME    |
------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT                           |        |
|1 |└─EXCHANGE OUT DISTR                                |:EX10002|
|2 |  └─SORT                                            |        |
|3 |    └─HASH DISTINCT                                 |        |
|4 |      └─EXCHANGE IN DISTR                           |        |
|5 |        └─EXCHANGE OUT DISTR (HASH)                 |:EX10001|
|6 |          └─MATERIAL                                |        |
|7 |            └─HASH DISTINCT                         |        |
|8 |              └─WINDOW FUNCTION CONSOLIDATOR        |        |
|9 |                └─EXCHANGE IN MERGE SORT DISTR      |        |
|10|                  └─EXCHANGE OUT DISTR (HASH HYBRID)|:EX10000|
|11|                    └─WINDOW FUNCTION               |        |
|12|                      └─PARTITION SORT              |        |
|13|                        └─PX BLOCK ITERATOR         |        |
|14|                          └─TABLE FULL SCAN         |test1   |
==================================================================
