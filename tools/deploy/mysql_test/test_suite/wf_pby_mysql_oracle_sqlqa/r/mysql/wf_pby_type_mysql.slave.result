drop table test1;
#wf_gby-2-3   时间日期类型
CREATE TABLE test1(id bigint, c1 DATE,c2 TIME,c3 YEAR,c4 DATETIME,c5 TIMESTAMP);
create procedure procedure_1()
begin
declare i int default 1;
while i<61
do
INSERT INTO test1 values(i,'2022-12-14','23:23:23',i+'1996','2022-12-14 23:23:23','2022-12-14 01:01:01');
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
