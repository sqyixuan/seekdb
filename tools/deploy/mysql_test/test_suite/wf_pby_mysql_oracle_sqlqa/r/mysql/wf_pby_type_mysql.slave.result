#wf_gby-2-2   数值类型
CREATE TABLE test1(id bigint, c1 TINYINT(20),c2 SMALLINT(20),c3 MEDIUMINT(20),
c4 INTEGER(20),c5 FLOAT(20),c6 DOUBLE,c7 DECIMAL(20));
create procedure procedure_1()
begin
declare i int default 1;
while i<11
do
INSERT INTO test1 values(i,1,2,3,4,5,6,7);
INSERT INTO test1 values(i,2,3,4,5,6,7,8);
INSERT INTO test1 values(i,3,4,5,6,7,8,9);
INSERT INTO test1 values(i,4,5,6,7,8,9,10);
INSERT INTO test1 values(i,5,6,7,8,9,10,11);
INSERT INTO test1 values(i,6,7,8,9,10,11,12);
INSERT INTO test1 values(i,7,8,9,10,11,12,13);
INSERT INTO test1 values(i,6,7,8,9,10,11,12);
INSERT INTO test1 values(i,5,6,7,8,9,10,11);
INSERT INTO test1 values(i,4,5,6,7,8,9,10);
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
