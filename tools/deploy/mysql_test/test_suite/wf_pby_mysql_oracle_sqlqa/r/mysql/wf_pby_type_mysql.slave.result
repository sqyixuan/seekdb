DROP TABLE test1;
#wf_gby-2-1   字符类型
CREATE TABLE test1(id bigint, c1 CHAR(20),c2 VARCHAR(20),c3 TINYBLOB,c4 TINYTEXT,c5 BLOB(20));
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int default 1;
while i<10
do
INSERT INTO test1 values(i,'aaa','bbb','ccc','ddd','eee');
INSERT INTO test1 values(i,'jjj','aaa','hhh','ooo','sss');
INSERT INTO test1 values(i,'bbb','yyy','ttt','lll','mmm');
INSERT INTO test1 values(i,'fff','zzz','hhh','vvvv','nnn');
INSERT INTO test1 values(i,'fff','xxx','ccc','ooo','eee');
INSERT INTO test1 values(i,'bbb','zzz','ttt','vvvv','mmm');
INSERT INTO test1 values(i,'aaa','yyy','hhh','lll','sss');
INSERT INTO test1 values(i,'fff','xxx','ccc','ooo','mmm');
INSERT INTO test1 values(i,'jjj','zzz','ttt','lll','nnn');
INSERT INTO test1 values(i,'aaa','bbb','hhh','ddd','sss');
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
