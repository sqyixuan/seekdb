drop procedure procedure_1;
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1
( c1 bigint not null,
c2 varchar(50) not null,
c3 varchar(50),
CONSTRAINT waijian PRIMARY KEY (c1)
);
CREATE TABLE test2
( c1 bigint not null,
c2 bigint not null,
CONSTRAINT waijian
FOREIGN KEY (c1)
REFERENCES test1(c1)
);
insert into test1 values(55,'aqefqf','cwewwfwf');
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int default 1;
while i<101
do
INSERT INTO test2 values(55,i);
set i=i+1;
end while;
commit;
end;
/
call procedure_1();
select count(c1) from test1 order by c1 asc;
count(c1)
1
call dbms_stats.gather_table_stats('TEST', 'TEST2', method_opt=>'for all columns size auto', estimate_percent=>100);
