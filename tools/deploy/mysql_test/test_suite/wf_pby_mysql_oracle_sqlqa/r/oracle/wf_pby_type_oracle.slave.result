INSERT INTO wf_test1 values(i,7,8,9,10);
INSERT INTO wf_test1 values(i,6,7,8,9);
INSERT INTO wf_test1 values(i,5,6,7,8);
INSERT INTO wf_test1 values(i,4,5,6,7);
i := i +1;
END;
END loop;
end;
/
