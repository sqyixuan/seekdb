drop user hjw cascade;
create user hjw IDENTIFIED BY hjw;
grant all on *.* to hjw WITH GRANT OPTION;
grant dba to hjw;
#wf_gby-2   数据类型
#wf_gby-2-1     字 符 类 型
DROP TABLE wf_test1;
CREATE TABLE wf_test1(id number, c1 CHAR(20),c2 VARCHAR(20),c3 nchar(20),c4 nvarchar2(50),c5 varchar2(20));
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 16 LOOP
begin
INSERT INTO wf_test1 values(i,'aaa','bbb','ccc','ddd','eee');
INSERT INTO wf_test1 values(i,'jjj','aaa','hhh','ooo','sss');
INSERT INTO wf_test1 values(i,'bbb','yyy','ttt','lll','mmm');
INSERT INTO wf_test1 values(i,'fff','zzz','hhh','vvvv','nnn');
INSERT INTO wf_test1 values(i,'fff','xxx','ccc','ooo','eee');
INSERT INTO wf_test1 values(i,'bbb','zzz','ttt','vvvv','mmm');
INSERT INTO wf_test1 values(i,'aaa','yyy','hhh','lll','sss');
INSERT INTO wf_test1 values(i,'fff','xxx','ccc','ooo','mmm');
INSERT INTO wf_test1 values(i,'jjj','zzz','ttt','lll','nnn');
INSERT INTO wf_test1 values(i,'aaa','bbb','hhh','ddd','sss');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
