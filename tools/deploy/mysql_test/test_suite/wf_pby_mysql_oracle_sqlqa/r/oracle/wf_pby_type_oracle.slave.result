CREATE TABLE wf_test1(id date,c1 timestamp,c2 timestamp with time zone,c3 timestamp with local time zone,c4 interval year to MONTH,c5 interval day to second);
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 11 LOOP
begin
INSERT INTO wf_test1 values(to_date('2015-1-30','YYYY-MM-DD'),to_timestamp('2020-12-12 12:12:12','yyyy-mm-dd hh24:mi:ss'),
to_timestamp('2022-10-10 12:12:12','yyyy-mm-dd hh24:mi:ss'),to_timestamp('2022-10-10 12:12:12','yyyy-mm-dd hh24:mi:ss'),
INTERVAL '12-3' YEAR TO MONTH,INTERVAL '15 06:10:08' DAY TO SECOND);
INSERT INTO wf_test1 values(to_date('2023-1-30','YYYY-MM-DD'),to_timestamp('2022-12-12 12:12:12','yyyy-mm-dd hh24:mi:ss'),
to_timestamp('2028-10-10 12:12:12','yyyy-mm-dd hh24:mi:ss'),to_timestamp('2023-10-10 12:12:12','yyyy-mm-dd hh24:mi:ss'),
INTERVAL '12-6' YEAR TO MONTH,INTERVAL '10 06:10:08' DAY TO SECOND);
i := i +1;
END;
END loop;
end;
