drop user hjw cascade;
create user hjw IDENTIFIED BY hjw;
grant all on *.* to hjw WITH GRANT OPTION;
grant dba to hjw;
#wf_gby-4   视图
#insert语句
drop table wf_test1;
drop view view_1;
CREATE table wf_test1(c1 number,c2 FLOAT,c3 INTEGER, c4 binary_double);
create view view_1 as select * from wf_test1;
insert into view_1 values(1,55,-55,66);
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 41 LOOP
begin
INSERT INTO view_1 select i,c2,c3+i,c4 from view_1 WHERE rownum<2;
i := i +1;
END;
END loop;
end;
/
call procedure_1();
select * from view_1 order by c1 asc;
