drop procedure procedure_1;
drop view view_1;
drop table wf_test1;
#聚合函数后跟xxxx
CREATE table wf_test1(c1 number,c2 FLOAT,c3 varchar(20));
CREATE VIEW view_1 AS SELECT * FROM wf_test1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO VIEW_1 values(i,531,'小赵');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
select * from VIEW_1 order by c1 asc;
