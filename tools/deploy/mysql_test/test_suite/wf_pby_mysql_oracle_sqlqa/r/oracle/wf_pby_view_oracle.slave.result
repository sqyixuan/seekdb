drop procedure procedure_1;
drop view view_1;
drop table WF_TEST1;
#select语句
CREATE table wf_test1(c1 number,c2 FLOAT,c3 INTEGER, c4 binary_double);
create view view_1 as select * from wf_test1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 41 LOOP
begin
INSERT INTO view_1 values(i,i+null,i,i-i);
i := i +1;
END;
END loop;
end;
/
call procedure_1();
