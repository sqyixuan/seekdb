drop user hjw cascade;
create user hjw IDENTIFIED BY hjw;
grant all on *.* to hjw WITH GRANT OPTION;
grant dba to hjw;
#wf_gby-7    约束
#wf_gby-8    索引
DROP TABLE test1;
CREATE TABLE test1(c1 NUMBER primary key ,c2 NUMBER default 1,c3 varchar(100) not NULL,c4 FLOAT check(c4<=9999999),c5 varchar(80)UNIQUE);
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test1 values(i,100,'张三',2000,i+2);
i := i +1;
END;
END loop;
end;
/
call procedure_1();
set "_windowfunc_optimization_settings" = 0;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
explain basic SELECT /*+ parallel(3)*/ max(c2)over(PARTITION by c3) from test1 order by c2 asc;
