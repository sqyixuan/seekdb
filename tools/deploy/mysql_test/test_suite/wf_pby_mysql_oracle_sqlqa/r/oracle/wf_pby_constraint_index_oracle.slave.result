drop procedure procedure_1;
DROP TABLE test1;
CREATE TABLE test1
( c1 number not null,
c2 varchar(50) not null,
c3 varchar(50),
CONSTRAINT waijian PRIMARY KEY (c1)
);
CREATE TABLE test2
( c1 number not null,
c2 number not null,
CONSTRAINT waijian_1
FOREIGN KEY (c1)
REFERENCES test1(c1)
);
insert into test1 values(55,'aqefqf','cwewwfwf');
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test2 values(55,i);
i := i +1;
END;
END loop;
end;
/
call procedure_1();
set "_windowfunc_optimization_settings" = 0;
call dbms_stats.gather_table_stats('TEST', 'TEST1', method_opt=>'for all columns size auto', estimate_percent=>100);
explain basic SELECT /*+ parallel(3)*/ max(c1)over(PARTITION by c2) from test2 order by c2 asc;
