drop user hjw cascade;
create user hjw IDENTIFIED BY hjw;
grant all on *.* to hjw WITH GRANT OPTION;
grant dba to hjw;
#wf_gby-5   多表联查
drop table wf_test1;
drop table wf_test2;
CREATE table wf_test1(c1 INTEGER,c2 FLOAT,c3 binary_double);
CREATE table wf_test2(c1 NUMBER,c2 char(20),c3 VARCHAR(20));
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO wf_test1 values(i,i+2,i+5);
i := i +1;
END;
END loop;
end;
/
drop procedure procedure_2;
create procedure procedure_2 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO wf_test2 values(i,'华莉','晓晴');
INSERT INTO wf_test2 values(i,'王刚','赵四');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
call procedure_2();
