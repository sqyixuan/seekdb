#二级分区
drop table test1;
CREATE table test1(c1 number,c2 FLOAT,c3 varchar(50)) PARTITION by hash(c1) subPARTITION by hash(c1)(
PARTITION p1(subpartition p11),
PARTITION p2(subpartition p22),
PARTITION p3(subpartition p33));
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test1 values(i,100,'ugitdyffj');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
select * from test1 order by c1 asc;
