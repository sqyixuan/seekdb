drop user hjw cascade;
create user hjw IDENTIFIED BY hjw;
grant all on *.* to hjw WITH GRANT OPTION;
grant dba to hjw;
#wf_gby-9    分区表
#hash分区
drop table test1;
CREATE table test1(c1 number,c2 FLOAT,c3 varchar(50)) PARTITION by hash(c1)(PARTITION p1,PARTITION p2,PARTITION p3);
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test1 values(i,100,'ugitdyffj');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
