#range分区
drop table test1;
CREATE table test1(c1 number,c2 FLOAT,c3 varchar(50)) PARTITION by range(c1)(
PARTITION p1 values less than(1500),
PARTITION p2 values less than(2900),
PARTITION p3 values less than(4000));
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test1 values(i,100,'ugitdyffj');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
