drop table test1;
CREATE table test1(c1 number,c2 FLOAT,c3 varchar(50)) PARTITION by list(c1)subPARTITION by list(c1)(
PARTITION p1 values (350)(subPARTITION p11 values (350)),
PARTITION p2 values (750)(subPARTITION p22 values (750)),
PARTITION p3 values (1000)(subPARTITION p33 values (1000)));
drop procedure procedure_1;
create procedure procedure_1 AS
i number;
BEGIN
i:=1;
WHILE i< 61 LOOP
begin
INSERT INTO test1 values(350,100,'ugitdyffj');
INSERT INTO test1 values(750,100,'ugitdyffj');
INSERT INTO test1 values(1000,100,'ugitdyffj');
i := i +1;
END;
END loop;
end;
/
call procedure_1();
