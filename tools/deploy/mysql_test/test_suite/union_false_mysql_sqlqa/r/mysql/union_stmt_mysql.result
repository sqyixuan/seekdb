      is_index_back=false, is_global_index=false, 
      range_key([t3.c1], [t3.c2]), range(MIN,MIN ; MAX,MAX)always true
select c1 from t1  where 1 = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT
select c1 from t3  INTERSECT
select c1 from v4 order by c1;
c1
select c1 from v4 where abs(-1) = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT  
select c1 from t3 where 1 = 0 INTERSECT 
select c1 from t1 where 1 = 0 order by c1;
