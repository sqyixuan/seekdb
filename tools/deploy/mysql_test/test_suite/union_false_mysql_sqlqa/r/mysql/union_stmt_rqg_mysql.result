WITH RECURSIVE MY_CTE AS ( SELECT /*+ PX_JOIN_FILTER */ ALL A.c4 FROM t1 A LEFT OUTER JOIN v4 B ON A.c4 = B.c4 WHERE 1 > 2 AND 1 = 1 OR 1 < 0  INTERSECT SELECT /*+ NO_PUSH_LIMIT(B)*/  A.c4 FROM t3 A JOIN t3 B ON A.c4 = B.c4 WHERE 1 <> 1 OR 1 != 1  EXCEPT SELECT /*+ push_limit*/ DISTINCT A.c4 FROM v4 A INNER JOIN t1 B ON A.c4 = B.c4 WHERE 1 <> 1 OR 1 != 1 GROUP BY A.c4  EXCEPT SELECT /*+ NO_PUSH_LIMIT(A)*/ ALL A.c4 FROM t2 A RIGHT JOIN t1 B ON A.c4 = B.c4   UNION SELECT /*+ MONITOR*/  A.c4 FROM v4 A,v4 B  GROUP BY A.c4 WITH ROLLUP HAVING 1 <> 1 OR 1 != 1 UNION ALL SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 NONE, PARTITION) USE_HASH (t3)*/  A.c4 FROM t2 A,t2 B   INTERSECT SELECT   A.c4 FROM t2 A JOIN t1 B ON A.c4 = B.c4   EXCEPT SELECT /*+ no_push_limit(A)*/ ALL A.c4 FROM t1 A RIGHT JOIN t3 B ON A.c4 = B.c4   EXCEPT SELECT /*+ push_limit(B)*/  A.c4 FROM t2 A RIGHT JOIN t3 B ON A.c4 = B.c4   UNION SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 PARTITION, NONE) USE_HASH (t2)*/  A.c4 FROM t2 A,t3 B   EXCEPT SELECT /*+ push_limit(B)*/  A.c4 FROM t3 A LEFT JOIN t2 B ON A.c4 = B.c4   EXCEPT SELECT /*+ push_limit*/  A.c4 FROM t2 A RIGHT JOIN v4 B ON A.c4 = B.c4 WHERE 1 = ANY (SELECT 0 FROM v4 WHERE 1 = 0) GROUP BY A.c4 UNION SELECT /*+ push_limit*/ DISTINCT A.c4 FROM t1 A RIGHT JOIN t1 B ON A.c4 = B.c4   UNION ALL SELECT /*+ no_push_limit(B)*/  A.c4 FROM t1 A LEFT OUTER JOIN v4 B ON A.c4 = B.c4   UNION ALL SELECT /*+ no_push_limit(A)*/ DISTINCT A.c4 FROM t3 A LEFT JOIN v4 B ON A.c4 = B.c4 WHERE 1 = SOME (SELECT 0 FROM t1 WHERE 1 = 0) GROUP BY A.c4 UNION SELECT /*+ PQ_DISTRIBUTE(t1, RANDOM) */  A.c4 FROM t3 A JOIN t3 B ON A.c4 = B.c4 WHERE 1 > 2 AND 1 = 1 OR 1 < 0  UNION ALL SELECT /*+ push_limit(A B)*/ DISTINCT A.c4 FROM t2 A CROSS JOIN t1 B ON A.c4 = B.c4   UNION ALL SELECT   A.c4 FROM t3 A INNER JOIN t2 B ON A.c4 = B.c4   ORDER BY c4 ) SELECT * FROM MY_CTE ORDER BY 1;
