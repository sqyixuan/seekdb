drop table t1;
create table t1(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111, 
c4 boolean,
c5 bigint auto_increment,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2),
index t1_ind1(c2),
unique index t1_ind2(c1));
INSERT INTO t1 (c1, c2, c4) VALUES (1, 'Text for c2 1', true);
drop table t2;
create table t2(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111, 
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2,c5),
index t1_ind1(c2) LOCAL,
unique index t1_ind2(c1,c5) LOCAL)
PARTITION by RANGE (c1) 
SUBPARTITION BY HASH(c5)
SUBPARTITIONS 2 (
PARTITION p0 VALUES LESS THAN (2),
PARTITION p1 VALUES LESS THAN (5),
PARTITION p2 VALUES LESS THAN MAXVALUE
);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (1, 'Text for c2 1', true , 1);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (2, 'Text for c2 2', false, 2);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (3, 'Text for c2 3', true , 3);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (4, 'Text for c2 4', false, 4);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (5, 'Text for c2 5', true , 5);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (6, 'Text for c2 6', false, 6);
drop table t3;
create table t3(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111,  
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2),
index t1_ind1(c2),
unique index t1_ind2(c1));
INSERT INTO t3 (c1, c2, c4, c5) VALUES (1, 'Text for c2 1', true , 1);
INSERT INTO t3 (c1, c2, c4, c5) VALUES (2, 'Text for c2 2', false, 2);
drop VIEW v4;
CREATE VIEW v4 AS
SELECT * FROM t2 WHERE 1 = 1;
SELECT /*+ USE_MERGE(t1 t2) */  c6 FROM t3 WHERE 1 = ANY (SELECT 0 FROM t3 WHERE 1 = 0)  EXCEPT SELECT /*+ USE_LATE_MATERIALIZATION */  c6 FROM t1 WHERE 1 <= 0 AND 1 = 1 and C7 IS NULL GROUP BY c6 WITH ROLLUP HAVING 1 = ALL (SELECT 0 FROM t1 WHERE 1 = 0) EXCEPT SELECT /*+ USE_LATE_MATERIALIZATION */  c6 FROM t3   EXCEPT SELECT /*+ NO_REWRITE */ DISTINCT c6 FROM v4 WHERE 1 = ALL (SELECT 0 FROM t2 WHERE 1 = 0)  ORDER BY c6;
c6
WITH RECURSIVE MY_CTE AS ( SELECT /*+ USE_NL_MATERIALIZATION(t2) */  c3 FROM t1  GROUP BY c3 WITH ROLLUP  INTERSECT SELECT /*+ ORDERED PQ_DISTRIBUTE(t3 HASH, HASH) USE_HASH (t2)*/ DISTINCT c3 FROM t2   INTERSECT SELECT /*+ MONITOR*/  c3 FROM t2 WHERE 1 = ALL (SELECT 0 FROM v4 WHERE 1 = 0)  INTERSECT SELECT /*+ INLINE*/  c3 FROM t1 WHERE 1 = ANY (SELECT 0 FROM t2 WHERE 1 = 0) GROUP BY c3 WITH ROLLUP HAVING 1 = ANY (SELECT 0 FROM v4 WHERE 1 = 0) ORDER BY c3 ) SELECT * FROM MY_CTE;
c3
SELECT /*+ TRACING(1)*/  c7 FROM t3  GROUP BY c7 HAVING 1 = ANY (SELECT 0 FROM t2 WHERE 1 = 0) UNION ALL SELECT /*+ MAX_CONCURRENT(10)*/  c7 FROM t1   UNION ALL SELECT /*+ STAT(1) */  c7 FROM v4   UNION ALL SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 BROADCAST, NONE) USE_HASH (t1)*/  c7 FROM v4 WHERE 1 = 0 and C5 IS NOT NULL  ORDER BY c7;
c7
