SELECT /*+ USE_NL(t3 v4) */ ALL A.c7 FROM t3 A RIGHT JOIN t3 B ON A.c7 = B.c7 WHERE 1 < 0 GROUP BY A.c7 UNION SELECT /*+ INLINE*/  A.c7 FROM v4 A LEFT JOIN v4 B ON A.c7 = B.c7  GROUP BY A.c7 UNION SELECT /*+ ORDERED PQ_DISTRIBUTE(t3 NONE, BROADCAST) USE_HASH (t1)*/  A.c7 FROM t3 A LEFT JOIN t1 B ON A.c7 = B.c7 WHERE 1 <> 1 OR 1 != 1  UNION SELECT  ALL A.c7 FROM t1 A RIGHT OUTER JOIN v4 B ON A.c7 = B.c7  GROUP BY A.c7 WITH ROLLUP HAVING 1 > 2 AND 1 = 1 OR 1 < 0 UNION SELECT /*+ push_limit(A B)*/  A.c7 FROM t3 A,t1 B WHERE 1 = SOME (SELECT 0 FROM t2 WHERE 1 = 0) GROUP BY A.c7 HAVING 1 < 0 UNION SELECT /*+ QUERY_TIMEOUT(10000000) */ ALL A.c7 FROM t3 A LEFT OUTER JOIN v4 B ON A.c7 = B.c7 WHERE NOT EXISTS (SELECT 1 FROM t1 WHERE 1 = 1) GROUP BY A.c7 WITH ROLLUP HAVING 1 = ANY (SELECT 0 FROM v4 WHERE 1 = 0) UNION SELECT /*+ no_push_limit(A)*/  A.c7 FROM t2 A CROSS JOIN v4 B ON A.c7 = B.c7 WHERE 1 = 0 GROUP BY A.c7 WITH ROLLUP HAVING 1 < 0 UNION SELECT /*+ push_limit(A B)*/  A.c7 FROM t2 A INNER JOIN v4 B ON A.c7 = B.c7   UNION SELECT /*+ NO_PUSH_LIMIT(A)*/  A.c7 FROM t1 A RIGHT JOIN t3 B ON A.c7 = B.c7 WHERE 1 <= 0 AND 1 = 1  UNION SELECT /*+ no_push_limit*/  A.c7 FROM t3 A RIGHT JOIN v4 B ON A.c7 = B.c7  GROUP BY A.c7 UNION SELECT /*+ no_push_limit*/  A.c7 FROM t3 A LEFT JOIN t1 B ON A.c7 = B.c7  GROUP BY A.c7 UNION SELECT /*+ NO_USE_NL_MATERIALIZATION(t2) */ DISTINCT A.c7 FROM t2 A INNER JOIN t3 B ON A.c7 = B.c7 WHERE 1 = ANY (SELECT 0 FROM t1 WHERE 1 = 0)  UNION SELECT /*+ push_limit(A)*/  A.c7 FROM v4 A CROSS JOIN t2 B ON A.c7 = B.c7 WHERE 1 > 2 AND 1 = 1 OR 1 < 0 GROUP BY A.c7 UNION SELECT /*+ NO_USE_NL(t2 t3) */  A.c7 FROM t1 A CROSS JOIN t2 B ON A.c7 = B.c7   UNION SELECT /*+ push_limit*/  A.c7 FROM t1 A RIGHT JOIN v4 B ON A.c7 = B.c7   UNION SELECT /*+ no_push_limit(B)*/  A.c7 FROM t3 A,t1 B   UNION SELECT /*+ PUSH_LIMIT*/  A.c7 FROM t3 A,v4 B WHERE 1 = 0  UNION SELECT /*+ push_limit(B)*/  A.c7 FROM t3 A INNER JOIN t3 B ON A.c7 = B.c7   ORDER BY c7;
