c2
SELECT  ALL c1 FROM t3   EXCEPT SELECT   c1 FROM t3   EXCEPT SELECT /*+ ORDERED PQ_DISTRIBUTE(t1 PARTITION, NONE) USE_HASH (t3)*/  c1 FROM t2  GROUP BY c1 WITH ROLLUP HAVING 1 = ANY (SELECT 0 FROM t1 WHERE 1 = 0) EXCEPT SELECT /*+ PARALLEL(1) NO_REWRITE*/ ALL c1 FROM t1 WHERE 1 > 2 AND 1 = 1 OR 1 < 0 GROUP BY c1 ORDER BY c1;
c1
