c2
SELECT  DISTINCT c4 FROM v4  GROUP BY c4 HAVING EXISTS (SELECT 1 FROM v4 WHERE 1 = 0) UNION ALL SELECT /*+ USE_PX PARALLEL(4)*/  c4 FROM v4 WHERE NOT EXISTS (SELECT 1 FROM t1 WHERE 1 = 1) GROUP BY c4 WITH ROLLUP HAVING 1 = SOME (SELECT 0 FROM t3 WHERE 1 = 0) UNION ALL SELECT   c4 FROM t2   UNION ALL SELECT /*+ USE_MERGE(t1 t2) */ ALL c4 FROM t1 WHERE 1 = 0 and C2 IS NOT NULL  ORDER BY c4;
