SELECT /*+ PUSH_LIMIT*/  A.c1 FROM t1 A INNER JOIN t1 B ON A.c1 = B.c1   EXCEPT SELECT /*+ PUSH_LIMIT*/  A.c1 FROM v4 A,t3 B   EXCEPT SELECT /*+ push_limit(A B)*/ ALL A.c1 FROM t1 A RIGHT JOIN t2 B ON A.c1 = B.c1 WHERE 1 = 0 GROUP BY A.c1 EXCEPT SELECT /*+ no_push_limit*/  A.c1 FROM t2 A RIGHT JOIN t2 B ON A.c1 = B.c1   EXCEPT SELECT /*+ push_limit(B)*/  A.c1 FROM t2 A LEFT JOIN t1 B ON A.c1 = B.c1   EXCEPT SELECT /*+ PUSH_LIMIT*/  A.c1 FROM t3 A,t3 B   EXCEPT SELECT  ALL A.c1 FROM t2 A LEFT OUTER JOIN t3 B ON A.c1 = B.c1 WHERE 1 = 0  EXCEPT SELECT /*+ NO_PUSH_LIMIT*/  A.c1 FROM t3 A,t2 B  GROUP BY A.c1 WITH ROLLUP HAVING 1 <> 1 OR 1 != 1 EXCEPT SELECT /*+ PUSH_LIMIT*/  A.c1 FROM v4 A RIGHT JOIN v4 B ON A.c1 = B.c1   EXCEPT SELECT /*+ NO_PUSH_LIMIT*/  A.c1 FROM t1 A INNER JOIN t3 B ON A.c1 = B.c1   EXCEPT SELECT /*+ PUSH_LIMIT*/  A.c1 FROM t1 A LEFT OUTER JOIN t1 B ON A.c1 = B.c1   EXCEPT SELECT /*+ NO_PUSH_LIMIT*/ DISTINCT A.c1 FROM t2 A INNER JOIN t3 B ON A.c1 = B.c1 WHERE 1 > 2 AND 1 = 1 OR 1 < 0  EXCEPT SELECT /*+ NO_USE_MERGE(t3 t2) */  A.c1 FROM t3 A JOIN t3 B ON A.c1 = B.c1 WHERE 1 <> 1 OR 1 != 1 GROUP BY A.c1 EXCEPT SELECT   A.c1 FROM t3 A LEFT JOIN t2 B ON A.c1 = B.c1 WHERE 1 = ALL (SELECT 0 FROM t2 WHERE 1 = 0) GROUP BY A.c1 HAVING 1 = ANY (SELECT 0 FROM t2 WHERE 1 = 0) EXCEPT SELECT  DISTINCT A.c1 FROM t1 A INNER JOIN v4 B ON A.c1 = B.c1  GROUP BY A.c1 EXCEPT SELECT /*+ PUSH_LIMIT*/ DISTINCT A.c1 FROM t3 A JOIN t2 B ON A.c1 = B.c1   EXCEPT SELECT /*+ NO_PUSH_LIMIT(B)*/  A.c1 FROM v4 A INNER JOIN t2 B ON A.c1 = B.c1 WHERE 1 = ANY (SELECT 0 FROM v4 WHERE 1 = 0) GROUP BY A.C1,A.C2,A.C3,A.C4,A.C5,A.C6,A.c7 WITH ROLLUP HAVING 1 = SOME (SELECT 0 FROM t2 WHERE 1 = 0) EXCEPT SELECT /*+ NO_PUSH_LIMIT*/ ALL A.c1 FROM t3 A INNER JOIN t2 B ON A.c1 = B.c1 WHERE EXISTS (SELECT 1 FROM t3 WHERE 1 = 0) GROUP BY A.c1  ORDER BY c1;
