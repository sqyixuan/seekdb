SELECT /*+ PUSH_LIMIT(B)*/  A.c4 FROM t1 A JOIN t2 B ON A.c4 = B.c4  GROUP BY A.c4 WITH ROLLUP  UNION SELECT /*+ push_limit(A)*/  A.c4 FROM t1 A,t3 B WHERE (SELECT 0) >= 1 GROUP BY A.c4 EXCEPT SELECT /*+ PQ_DISTRIBUTE(t2, NONE) */  A.c4 FROM t3 A,v4 B   INTERSECT SELECT /*+ push_limit(A)*/  A.c4 FROM t1 A LEFT JOIN t3 B ON A.c4 = B.c4 WHERE 1 < 0  UNION SELECT /*+ push_limit(A B)*/ ALL A.c4 FROM t1 A CROSS JOIN t1 B ON A.c4 = B.c4 WHERE 1 = 0 GROUP BY A.c4 UNION SELECT /*+ USE_NL(t2 t1) */  A.c4 FROM v4 A CROSS JOIN v4 B ON A.c4 = B.c4  GROUP BY A.c4 HAVING 1 > 2 AND 1 = 1 OR 1 < 0 INTERSECT SELECT /*+ TRACING(1)*/  A.c4 FROM v4 A LEFT JOIN t1 B ON A.c4 = B.c4 WHERE 1 <= 0 AND 1 = 1  INTERSECT SELECT  ALL A.c4 FROM t3 A RIGHT OUTER JOIN t1 B ON A.c4 = B.c4 WHERE 1 < 0  UNION ALL SELECT /*+ push_limit*/  A.c4 FROM t1 A,t3 B WHERE NOT EXISTS (SELECT 1 FROM t3 WHERE 1 = 1)  UNION ALL SELECT /*+ PX_JOIN_FILTER */  A.c4 FROM t3 A,t3 B WHERE EXISTS (SELECT 1 FROM v4 WHERE 1 = 0) GROUP BY A.c4 WITH ROLLUP  UNION SELECT /*+ PUSH_LIMIT(A B)*/ DISTINCT A.c4 FROM t1 A RIGHT JOIN v4 B ON A.c4 = B.c4 WHERE 1 > 2 AND 1 = 1 OR 1 < 0  EXCEPT SELECT /*+ ORDERED */  A.c4 FROM t3 A,t2 B   UNION ALL SELECT /*+ push_limit(A B)*/  A.c4 FROM v4 A RIGHT JOIN v4 B ON A.c4 = B.c4 WHERE 1 = SOME (SELECT 0 FROM t2 WHERE 1 = 0)  EXCEPT SELECT /*+ push_limit*/  A.c4 FROM t2 A,t3 B   INTERSECT SELECT /*+ MAX_CONCURRENT(10)*/  A.c4 FROM t3 A JOIN t1 B ON A.c4 = B.c4   UNION ALL SELECT /*+ PUSH_LIMIT*/  A.c4 FROM t1 A JOIN v4 B ON A.c4 = B.c4  GROUP BY A.c4 EXCEPT SELECT /*+ NO_PUSH_LIMIT(A)*/  A.c4 FROM v4 A JOIN t3 B ON A.c4 = B.c4 WHERE EXISTS (SELECT 1 FROM t1 WHERE 1 = 0)  UNION SELECT /*+ PUSH_LIMIT(A)*/  A.c4 FROM v4 A CROSS JOIN t1 B ON A.c4 = B.c4   ORDER BY c4;
