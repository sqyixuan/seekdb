WITH RECURSIVE MY_CTE AS ( SELECT /*+ READ_CONSISTENCY(WEAK) */  A.c7 FROM t2 A LEFT OUTER JOIN t2 B ON A.c7 = B.c7 WHERE 1 <> 1 OR 1 != 1 GROUP BY A.c7 HAVING (SELECT 0) >= 1 UNION ALL SELECT /*+ push_limit(A)*/  A.c7 FROM t3 A JOIN t1 B ON A.c7 = B.c7  GROUP BY A.c7 WITH ROLLUP HAVING 1 = SOME (SELECT 0 FROM t2 WHERE 1 = 0) UNION ALL SELECT /*+ no_push_limit*/  A.c7 FROM t1 A LEFT JOIN v4 B ON A.c7 = B.c7   UNION ALL SELECT  ALL A.c7 FROM t3 A CROSS JOIN t2 B ON A.c7 = B.c7   UNION ALL SELECT /*+ NO_PLACE_GROUP_BY*/ DISTINCT A.c7 FROM v4 A,v4 B  GROUP BY A.c7 UNION ALL SELECT /*+ MATERIALIZE*/ ALL A.c7 FROM v4 A,t1 B WHERE 1 = 0  UNION ALL SELECT /*+ NO_PUSH_LIMIT(A)*/  A.c7 FROM v4 A,t1 B WHERE 1 = 0  UNION ALL SELECT /*+ push_limit*/ DISTINCT A.c7 FROM t2 A LEFT JOIN t3 B ON A.c7 = B.c7 WHERE 1 < 0  UNION ALL SELECT /*+ no_push_limit(A B)*/  A.c7 FROM t2 A JOIN t2 B ON A.c7 = B.c7 WHERE 1 < 0  UNION ALL SELECT /*+ no_push_limit(A B)*/  A.c7 FROM v4 A RIGHT JOIN t3 B ON A.c7 = B.c7 WHERE 1 = SOME (SELECT 0 FROM v4 WHERE 1 = 0)  UNION ALL SELECT /*+ NO_PUSH_LIMIT(A)*/  A.c7 FROM t3 A JOIN t2 B ON A.c7 = B.c7  GROUP BY A.c7 UNION ALL SELECT /*+ push_limit*/ DISTINCT A.c7 FROM t3 A CROSS JOIN t1 B ON A.c7 = B.c7  GROUP BY A.c7 WITH ROLLUP  UNION ALL SELECT /*+ TOPK(1,10) */  A.c7 FROM t1 A,t3 B   UNION ALL SELECT /*+ no_push_limit(A)*/  A.c7 FROM t1 A INNER JOIN t2 B ON A.c7 = B.c7  GROUP BY A.c7 HAVING NOT EXISTS (SELECT 1 FROM t2 WHERE 1 = 1) UNION ALL SELECT /*+ push_limit(A B)*/ ALL A.c7 FROM t3 A,t1 B   UNION ALL SELECT /*+ PUSH_LIMIT*/  A.c7 FROM t3 A RIGHT JOIN t2 B ON A.c7 = B.c7   UNION ALL SELECT /*+ push_limit*/  A.c7 FROM t3 A,t3 B  GROUP BY A.c7 HAVING 1 < 0 UNION ALL SELECT /*+ USE_NL_MATERIALIZATION(t2) */ DISTINCT A.c7 FROM v4 A RIGHT OUTER JOIN t1 B ON A.c7 = B.c7   ORDER BY c7 ) SELECT * FROM MY_CTE ORDER BY 1;
