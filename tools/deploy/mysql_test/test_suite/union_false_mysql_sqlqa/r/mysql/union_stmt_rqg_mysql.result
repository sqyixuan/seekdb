SELECT /*+ QUERY_TIMEOUT(10000000) */ ALL c3 FROM t1 WHERE 1 > 2 AND 1 = 1 OR 1 < 0  UNION ALL SELECT /*+ ORDERED */  c3 FROM t3 WHERE 1 > 2 AND 1 = 1 OR 1 < 0 GROUP BY c3 HAVING 1 < 0 UNION ALL SELECT /*+ ORDERED PQ_DISTRIBUTE(t3 PARTITION, NONE) USE_HASH (v4)*/ DISTINCT c3 FROM t1  GROUP BY c3 HAVING 1 <> 1 OR 1 != 1 UNION ALL SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 NONE, NONE) USE_HASH (t3)*/  c3 FROM t1 WHERE 1 < 0 GROUP BY c3 ORDER BY c3;
c3
SELECT /*+ ORDERED PQ_DISTRIBUTE(t1 NONE, NONE) USE_HASH (t2)*/  c6 FROM v4  GROUP BY c6 INTERSECT SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 PARTITION, NONE) USE_HASH (t2)*/  c6 FROM t1   INTERSECT SELECT /*+ INLINE*/  c6 FROM t1  GROUP BY c6 HAVING 1 = ALL (SELECT 0 FROM t1 WHERE 1 = 0) INTERSECT SELECT /*+ QUERY_TIMEOUT(10000000) */  c6 FROM t3  GROUP BY c6 ORDER BY c6;
c6
Text for c
SELECT /*+ NO_UNNEST*/  c3 FROM t2  GROUP BY c3 UNION ALL SELECT   c3 FROM t2 WHERE NOT EXISTS (SELECT 1 FROM t1 WHERE 1 = 1) GROUP BY c3 UNION ALL SELECT /*+ NO_USE_LATE_MATERIALIZATION */  c3 FROM t3 WHERE 1 = SOME (SELECT 0 FROM t3 WHERE 1 = 0) GROUP BY c3 HAVING 1 <= 0 AND 1 = 1 and c3 IS NULL UNION ALL SELECT /*+ PARALLEL(4)*/  c3 FROM t1 WHERE EXISTS (SELECT 1 FROM t1 WHERE 1 = 0)  ORDER BY c3;
c3
111
SELECT /*+ FULL(t1) */ DISTINCT c7 FROM t1 WHERE 1 <= 0 AND 1 = 1 and C1 IS NULL GROUP BY c7 WITH ROLLUP  UNION SELECT /*+ ORDERED PQ_DISTRIBUTE(v4 NONE, NONE) USE_HASH (t3)*/  c7 FROM v4 WHERE (SELECT 0) >= 1  UNION SELECT /*+ MERGE(t1) */  c7 FROM t2 WHERE 1 = 0 and C7 IS NOT NULL  UNION SELECT /*+ USE_JIT */  c7 FROM t1   ORDER BY c7;
c7
Text for c
SELECT /*+ NO_UNNEST*/  c4 FROM v4  GROUP BY c4 UNION ALL SELECT /*+ ENABLE_PARALLEL_DML*/  c4 FROM t2 WHERE 1 < 0  UNION ALL SELECT /*+ ORDERED PQ_DISTRIBUTE(t3 NONE, BROADCAST) USE_HASH (t1)*/  c4 FROM t2   UNION ALL SELECT /*+ USE_NL_MATERIALIZATION(t3) */ ALL c4 FROM v4 WHERE 1 < 0 GROUP BY c4 WITH ROLLUP  ORDER BY c4;
c4
