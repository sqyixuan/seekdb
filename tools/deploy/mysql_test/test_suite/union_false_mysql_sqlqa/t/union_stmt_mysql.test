# owner: sean.yyj
# description: 集合运算分支裁剪

--error 0,1051
drop table t1;
create table t1(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111, 
c4 boolean,
c5 bigint auto_increment,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2),
index t1_ind1(c2),
unique index t1_ind2(c1));

INSERT INTO t1 (c1, c2, c4) VALUES (1, 'Text for c2 1', true);

--error 0,1051
drop table t2;
create table t2(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111, 
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2,c5),
index t1_ind1(c2) LOCAL,
unique index t1_ind2(c1,c5) LOCAL)
PARTITION by RANGE (c1) 
SUBPARTITION BY HASH(c5)
SUBPARTITIONS 2 (
PARTITION p0 VALUES LESS THAN (2),
PARTITION p1 VALUES LESS THAN (5),
PARTITION p2 VALUES LESS THAN MAXVALUE
);

INSERT INTO t2 (c1, c2, c4, c5) VALUES (1, 'Text for c2 1', true , 1);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (2, 'Text for c2 2', false, 2);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (3, 'Text for c2 3', true , 3);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (4, 'Text for c2 4', false, 4);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (5, 'Text for c2 5', true , 5);
INSERT INTO t2 (c1, c2, c4, c5) VALUES (6, 'Text for c2 6', false, 6);

--error 0,1051
drop table t3;
create table t3(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111,  
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2),
index t1_ind1(c2),
unique index t1_ind2(c1));

INSERT INTO t3 (c1, c2, c4, c5) VALUES (1, 'Text for c2 1', true , 1);
INSERT INTO t3 (c1, c2, c4, c5) VALUES (2, 'Text for c2 2', false, 2);

--error 0,1051
drop VIEW v4;
CREATE VIEW v4 AS
SELECT * FROM t2 WHERE 1 = 1;

--echo UNION
--echo 返回空集的分支小于 N-1，删除这些分支
explain basic  select /*+ NO_REWRITE */ c1 from t1  UNION 
select /*+ NO_REWRITE */ c1 from t2 where 1 = 0 UNION 
select /*+ NO_REWRITE */ c1 from t3 where 1 = 0 UNION 
select c1 from v4 order by c1;

--echo  N-1个分支返回空集，将剩余的一个分支转换为普通stmt
select c1 from t1  where 1 = 0 UNION 
select c1 from t2 where 1 = 0 UNION 
select c1 from t3 UNION 
select c1 from v4 where 1 = 0 order by c1;

--echo   所有分支都返回空集，保留一个分支，转换为普通stmt
select c1 from t1 where 1 = 0 UNION 
select c1 from t2 where 1 = 0 UNION 
select c1 from t3 where 1 = 0 UNION 
select c1 from v4 where 1 = 0 order by c1;

--echo UNION ALL
--echo 返回空集的分支小于 N-1，删除这些分支
explain basic  select /*+ NO_REWRITE */ c1 from t1  UNION ALL 
select /*+ NO_REWRITE */ c1 from t2 where 1 = 0 UNION ALL 
select /*+ NO_REWRITE */ c1 from t3  UNION ALL 
select c1 from v4 where 1 = 0 order by c1;

--echo  N-1个分支返回空集，将剩余的一个分支转换为普通stmt
select c1 from t1  where 1 = 0 UNION ALL  
select c1 from t2 where 1 = 0 UNION ALL  
select c1 from t3 where 1 = 0 UNION ALL  
select c1 from v4 order by c1;

--echo   所有分支都返回空集，保留一个分支，转换为普通stmt
select c1 from t1 where 1 = 0 UNION ALL   
select c1 from t2 where 1 = 0 UNION ALL   
select c1 from t3 where 1 = 0 UNION ALL   
select c1 from v4 where abs(-1) = 0 order by c1;

--echo INTERSECT
--echo 任意分支返回空集，保留返回空集的一个分支，转换为普通stmt
explain basic  select c1 from t1  where 1 = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT
select c1 from t3 where 1 = 0 INTERSECT
select c1 from v4 order by c1;

select c1 from t1  where 1 = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT
select c1 from t3  INTERSECT
select c1 from v4 order by c1;

select c1 from v4 where abs(-1) = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT  
select c1 from t3 where 1 = 0 INTERSECT 
select c1 from t1 where 1 = 0 order by c1;

--echo EXCEPT
--echo 任意分支返回空集，保留左支，转换为普通stmt

explain basic  select c1 from t1  where 1 = 0 EXCEPT
select c1 from t2 where 1 = 0 EXCEPT
select c1 from t3 where 1 = 0 order by c1;

select c1 from t2  EXCEPT
select c1 from t1 EXCEPT
select c1 from t3 where 1 = 0 order by c1;

select c1 from t2  EXCEPT
select c1 from t1  where 1 = 0 EXCEPT
select c1 from t3 order by c1;

--echo RECURSIVE UNION ALL
--echo 右支返回空集时，保留左支，转换为普通stmt

explain basic  WITH RECURSIVE my_cte AS
(
select c1 from t1  where 1 = 0 UNION ALL  
select c1 from t2 where 1 = 0 UNION ALL  
select c1 from t3 where 1 = 0 UNION ALL  
select c1 from v4 order by c1
)
select * from my_cte;

WITH RECURSIVE my_cte AS
(
select c1 from t1 UNION   
select c1 from t2 where 1 = 0 UNION  
select c1 from t3 where 1 = 0 UNION  
select c1 from v4 order by c1
)
select * from my_cte;

WITH RECURSIVE my_cte AS
(
select c1 from t1  where 1 = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT
select c1 from t3  INTERSECT
select c1 from v4 order by c1
)
select * from my_cte;

WITH RECURSIVE my_cte AS
(
select c1 from t2  EXCEPT
select c1 from t1 EXCEPT
select c1 from t3 where 1 = 0 order by c1
)
select * from my_cte;

SELECT c7 FROM t1
UNION ALL SELECT c7 FROM t1 WHERE 1 = 0 and C1 IS NOT NULL
UNION ALL SELECT c7 FROM t3 WHERE NOT EXISTS (SELECT 1 FROM DUAL WHERE 1 = 1)
UNION ALL SELECT c7 FROM t2 WHERE (SELECT 0) >= 1 ORDER BY c7;

SELECT c3 FROM t2  
UNION SELECT c3 FROM t3  
UNION SELECT c3 FROM t3 WHERE  EXISTS (SELECT 1 FROM dual WHERE 1 = 0) 
UNION SELECT c3 FROM t1 WHERE 1 = ANY (SELECT 0 FROM t1 WHERE 1 = 0) ORDER BY c3;

SELECT c1 FROM v4  
UNION ALL SELECT c1 FROM t3 WHERE 1 <> ALL (SELECT 0 FROM t2 WHERE 1 = 0) 
UNION ALL SELECT c1 FROM t3 WHERE 1 <= 0 AND 1 = 1 and C5 IS NULL 
UNION ALL SELECT c1 FROM t1  ORDER BY c1;

explain basic select c1 from v4  where 1 = 0 UNION 
select c1 from t2 where 1 = 0 UNION 
select c1 from t1 UNION 
select c1 from t3 order by c1 limit 0;

select c1 from t1  where 1 = 0 INTERSECT
select c1 from t2 where 1 = 0 INTERSECT
select c1 from t3  INTERSECT
select c1 from v4 order by c1 limit 0;

--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t3;
--error 0,1051
drop table v4;
