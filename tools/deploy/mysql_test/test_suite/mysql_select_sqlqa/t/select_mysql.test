--echo ##同 36381693
create procedure cai_pro()
begin
declare t1 integer;
declare t2 smallint;
declare t3 decimal;
declare t4 numeric;
declare t5 float;
declare t6 real;
declare t7 double precision;
declare t8 int;
declare done int default 0;
declare c_cursor cursor for select * from c1 a order by a.t1;
declare continue handler for not found set done=1;
open c_cursor;
while done!=1 do
 fetch c_cursor into t1,t2,t3,t4,t5,t6,t7,t8;
 if done!=1 then
 select t1,t2,t3,t4,t5,t6,t7,t8;
 end if;
end while;
close c_cursor;
end;
/
call cai_pro();/
drop procedure cai_pro;/
