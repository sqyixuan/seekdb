call cai_pro();/
--enable_result_log
drop procedure cai_pro;/

create procedure cai_pro()
begin
set @c_sql="begin 
select 1; 
end;";
prepare stmt from @c_sql;
execute stmt;
deallocate prepare stmt;
end;
/
