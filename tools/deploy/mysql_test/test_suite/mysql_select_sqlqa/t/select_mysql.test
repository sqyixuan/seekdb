--echo ##数据类型互转(可互转类型赋值后输出 + 不可互转类型赋值后输出)
create procedure cai_pro()
begin
declare a int default 3;
declare b char(20) default a;
select a,b;
end;
$
call cai_pro();$
drop procedure cai_pro;$

create procedure cai_pro()
begin
declare a char(20) default 'aa';
declare b int default a;
select a,b;
end;
$
--error 1366
call cai_pro();$
drop procedure cai_pro;$





