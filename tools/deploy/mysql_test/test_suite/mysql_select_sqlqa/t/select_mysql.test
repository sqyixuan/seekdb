create table c16(t1 char(200),t2 char(200));/
delete from c16;/
insert into c16 values(CONCAT(' 1a f %.7# ’‘ ',1,true,"哈哈哈啊",'fddjhgfds'),power(2,100));/
create procedure cai_pro()
begin
select CONCAT(' 1a f %.7# ’‘ ',1,true,"哈哈哈啊",'fddjhgfds',1e100);
select CONCAT(-3.3,0.1,0,1,-2,2,2.35);
select ' 1a f %.7# ’‘ ';
select null from dual;
select power(2,100) from dual;
select "哈哈哈啊"||'fddjhgfds' from c9;
select t1,t2 from c16 order by t1,t2;
end;
/
call cai_pro();/
drop procedure cai_pro;/
select t1,t2 from c16 order by t1,t2;/

