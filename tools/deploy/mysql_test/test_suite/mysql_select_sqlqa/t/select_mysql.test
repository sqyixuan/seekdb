--echo ##动态执行(pl + sql)
drop table c13;/
create table c13(t1 int);/
create table c15(t1 varchar(200),t2 varchar(200),t3 varchar(200),t4 varchar(200),t5 varchar(200),t6 varchar(200));/
delete from c15;/
delete from c13;/
insert into c15 values('desc select * from c13;','desc c13;','show create table c8;','select 6,7;','select * from c15','show columns from c1;');/
insert into c13 values(1);/
create procedure cai_pro()
begin
declare t1 varchar(200);
declare t2 varchar(200);
declare t3 varchar(200);
declare t4 varchar(200);
declare t5 varchar(200);
declare t6 varchar(200);
declare done int default 0;
declare c_cursor1 cursor for select a.t2,a.t3,a.t4,a.t5,a.t6 from c15 a order by a.t1;
declare continue handler for not found set done=1;
open c_cursor1;
while done!=1 do
 fetch c_cursor1 into t2,t3,t4,t5,t6;
 if done!=1 then
 set @c_sq2=t2;
 set @c_sq3=t3;
 set @c_sq4=t4;
 set @c_sq5=t5;
 set @c_sq6=t6;
 prepare stmt from @c_sq2;
 execute stmt;
 prepare stmt from @c_sq3;
 execute stmt;
 prepare stmt from @c_sq4;
 execute stmt;
 prepare stmt from @c_sq5;
 execute stmt;
 prepare stmt from @c_sq6;
 execute stmt;
 deallocate prepare stmt;
 end if;
end while;
close c_cursor1;

end;
/
call cai_pro();/
drop procedure cai_pro;/

create procedure cai_pro()
begin
declare t1 varchar(200);
declare done int default 0;
declare c_cursor1 cursor for select a.t1 from c15 a order by a.t1;
declare continue handler for not found set done=1;
open c_cursor1;
while done!=1 do
 fetch c_cursor1 into t1;
 if done!=1 then
 set @c_sql=t1;
 prepare stmt from @c_sql;
 execute stmt;
 deallocate prepare stmt;
 end if;
end while;
close c_cursor1;
end;
/
