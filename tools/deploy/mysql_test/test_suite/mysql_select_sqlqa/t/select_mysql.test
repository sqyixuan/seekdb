delimiter ;/

delimiter $;
--echo ##存在运算（+-/and not/>= 等），连接符，函数嵌套（to_date等）等 + where子句（存在判断，in ，and等，case，group by等）
create table c17(t1 int,t2 int,t3 char(200));$
delete from c17;$
insert into c17(t1,t2) values(2,4);$
insert into c17(t1,t2) values(-1,-5);$
insert into c17 values(2,4,'9a');$
create procedure cai_pro()
begin
select -2*9+60-4/7,5||4;
select date(20200101) from dual;
select 1 and 2,3<4;
select (case t1 when 2 then '是2呀' else '不是2' end)a_t1,(case when t2+3-6*0.6>=0 then '是正数' else '是负数' end) a_t2,sum(distinct t1) from c17 
where t3 is null and t1 between -9 and 9 and (t2 not in(7,8) or t2>-10) group by t1 having sum(t1)>0 order by t1,t2;
select * from c17 where t1>(case t1 when 2 then 0 else 7 end) or t2 in (4,-5);
select * from c17 where t3 like '%9%' and t1=2;
end;
$
call cai_pro();$
drop procedure cai_pro;$

--echo ##存在多表链接 union，left join等
delete from c16;$
delete from c17;$
insert into c16 values(1,2);$
insert into c16 values(2,2);$
insert into c17 values(1,3,4);$
insert into c17 values(3,3,4);$
create procedure cai_pro()
begin
select * from c16,c17 order by c16.t1,c17.t1;
select * from c16 where exists (select t1 from c17) order by t1,t2;
select * from c16 left join c17 on c16.t1=c17.t1 order by c16.t1,c17.t1;
select * from c16 where t1 in(select t1 from c17) order by t1,t2;
select t1 from c16 union select t1 from c17;
end;
$
call cai_pro();$
drop procedure cai_pro;$


--echo ##pl部分
--echo ##存在循环（while/loop/repeat）
create procedure cai_pro()
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
while i<=a do
 set sum=sum+i;
 set i=i+1;
 if i=a then
 select i+sum;
 end if;
end while;

set i=i+0;
loop1:loop
if i>a then
leave loop1;
end if;
set sum=sum+sum;
end loop;
select sum;

repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;
select sum;
end;
$
call cai_pro();$
drop procedure cai_pro;$

--echo ##存在判断（case when/if/elt/ifnull 等等）
create procedure cai_pro(in t1 int,in t2 int)
begin
if t1 is null then
 case when t2 is null then set t2=1;
 end case;
 case t2 when 1 then set t1=1;
 end case;
 if elt(t2,0,1)=0 then
 select elt(t2,0,1);
 end if;
else
select t1+t2;
end if;
end;
$
call cai_pro(null,null);$
call cai_pro(3,4);$
drop procedure cai_pro;$

--echo ##存在异常(自定义 +异常定义+异常捕获)
create procedure cai_pro()
begin
declare t1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1='a';
set @t2='b';
select @t2,t1;

begin
declare exit handler for sqlstate '42000' set t1='a';
set @t2='a';
select @t2,t1;
end;
end;
$
call cai_pro();$
drop procedure cai_pro;$

--echo ##存在 iterate，exit
create procedure cai_pro()
begin
declare sum int default 0;
declare i int default 1;
declare a int default 2;
declare b int default 0;
loop1:loop
 set sum=sum+i;
 set i=i+1;
 if sum<2 then 
 set b=b+sum;
 iterate loop1;
 elseif sum>2 then
 set b=b+sum;
 leave loop1;
 end if;
end loop;
select b;
end;
$
call cai_pro();$
drop procedure cai_pro;$

--echo ##存在嵌套子程序（仅支持嵌套begin end）
create procedure cai_pro()
begin
 begin
 select 1+1;
 end;
end;
$
call cai_pro();$
drop procedure cai_pro;$


--echo ##存在其他子程序的调用
create function cai_func() returns int
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;

begin
declare t1_1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1_1='a';
set t1_1=7;
return sum+t1_1;
end;
end;
$
create procedure cai_pro()
begin
select cai_func() from dual;
end;
$
call cai_pro();$
drop procedure cai_pro;$
drop function cai_func;$


--echo ##select触发方式
--echo ##子程序中 + 私有嵌套子程序中(特指匿名块) +sql语句中 select xx from dual + execute immediate中
create function cai_func() returns int
begin
return concat(1,1);
end;
$
--echo ##36473748,select 调用无（）的方法名，ob成功，MySQL失败;预期结果：ob调用失败
select cai_func from dual;$
select cai_func() from dual;$
select cai_func() from c1;$
--error 1096
select cai_func() from (select * from dual) a;$

create procedure cai_pro()
begin
 begin
 select cai_func() from dual;
 select cai_func() from c1;
 end;
end;
$
call cai_pro();$
drop procedure cai_pro;$

create procedure cai_pro()
begin
set @c_sql1="select cai_func() from dual;";
prepare stmt from @c_sql1;
execute stmt;
deallocate prepare stmt;

set @c_sql2="select cai_func() from c1";
prepare stmt from @c_sql1;
execute stmt;
deallocate prepare stmt;

end;
$
call cai_pro();$
drop procedure cai_pro;$

drop function cai_func;$


create table c18(t1 char(20),t2 char(20));$
insert into c18 values('assdsfdsfd','fdgfdd'),('ass\fd','fdgfdd'),('s','s');$
--echo ##其他场景
--echo ##select中别名重复，查看输出 + like的扩展用法 ，如 select * from code_dict a where 'aabfagfera' like a.code; + 游标输出时均赋值同一变量 + 列名同变量名
create procedure cai_pro()
begin
declare t1 char(20) default 'bbbb';
declare t2 char(20) default 'cccc';
declare done int default 0;
declare c_cursor cursor for select t1,t2 from c18;
declare continue handler for not found set done=1;
select t1,t2 from dual;
open c_cursor;
while done!=1 do
 fetch c_cursor into t1,t1;
 if done!=1 then
 select t1,t1;
 end if;
end while;
close c_cursor;

select 1 as a,2 as a from dual;
select * from c18 a where 'assdsfdsfd' like a.t1;
end;
$
call cai_pro();$
drop procedure cai_pro;$

create procedure cai_pro()
begin
declare t1 char(20);
declare t2 char(20);
declare done int default 0;
declare c_cursor cursor for select * from c18 order by t1;
declare continue handler for not found set done=1;
open c_cursor;
while done!=1 do
 fetch c_cursor into t1,t1;
 if done!=1 then
 select t1,t1;
 end if;
end while;
close c_cursor;
end;
$
call cai_pro();$
drop procedure cai_pro;$


--echo ##输出不存在的列、变量等 + call 使用select方法触发  如：select call pro；
