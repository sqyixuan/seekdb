##pl部分
##存在循环（while/loop/repeat）
create procedure cai_pro()
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
while i<=a do
set sum=sum+i;
set i=i+1;
if i=a then
select i+sum;
end if;
end while;
set i=i+0;
loop1:loop
if i>a then
leave loop1;
end if;
set sum=sum+sum;
end loop;
select sum;
repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;
select sum;
end;
$
call cai_pro();$
i+sum
sum
sum
6
6
12
drop procedure cai_pro;$
##存在判断（case when/if/elt/ifnull 等等）
create procedure cai_pro(in t1 int,in t2 int)
begin
if t1 is null then
case when t2 is null then set t2=1;
end case;
case t2 when 1 then set t1=1;
end case;
if elt(t2,0,1)=0 then
select elt(t2,0,1);
end if;
else
select t1+t2;
end if;
end;
$
call cai_pro(null,null);$
elt(t2,0,1)
0
call cai_pro(3,4);$
t1+t2
7
drop procedure cai_pro;$
##存在异常(自定义 +异常定义+异常捕获)
create procedure cai_pro()
begin
declare t1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1='a';
set @t2='b';
select @t2,t1;
begin
declare exit handler for sqlstate '42000' set t1='a';
set @t2='a';
select @t2,t1;
end;
end;
$
call cai_pro();$
@t2	t1
@t2	t1
b	NULL
a	NULL
drop procedure cai_pro;$
##存在 iterate，exit
create procedure cai_pro()
begin
declare sum int default 0;
declare i int default 1;
declare a int default 2;
declare b int default 0;
loop1:loop
set sum=sum+i;
set i=i+1;
if sum<2 then 
set b=b+sum;
iterate loop1;
elseif sum>2 then
set b=b+sum;
leave loop1;
end if;
end loop;
select b;
end;
$
call cai_pro();$
b
4
drop procedure cai_pro;$
##存在嵌套子程序（仅支持嵌套begin end）
create procedure cai_pro()
begin
begin
select 1+1;
end;
end;
$
call cai_pro();$
1+1
2
drop procedure cai_pro;$
##存在其他子程序的调用
create function cai_func() returns int
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;
begin
declare t1_1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1_1='a';
set t1_1=7;
return sum+t1_1;
end;
end;
$
create procedure cai_pro()
begin
select cai_func() from dual;
end;
$
call cai_pro();$
cai_func()
7
drop procedure cai_pro;$
drop function cai_func;$
##select触发方式
##子程序中 + 私有嵌套子程序中(特指匿名块) +sql语句中 select xx from dual + execute immediate中
create function cai_func() returns int
begin
return concat(1,1);
end;
$
