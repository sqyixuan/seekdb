drop procedure if exists cai_pro;/
##show (create + status)
create function cai_func() returns int
return 1;
/
create procedure cai_pro()
begin
show create table c1;
show create table c2;
show create table c3;
show create table c4;
show create table c8;
show create table c9;
show create table c10;
show create table c11;
show create table c12;
show create table c13;
#show create table c14;
show create view c9_view;
show create view c2_view;
show columns from c1;
show index from c8;
show create procedure cai_pro;
show create function cai_func;
show databases like 'cwx_db';
show schemas like 'cwx_db';
end;
/
call cai_pro();/
