# 创建新租户及用户
# 创建测试用户
drop database if exists cwx_db;
drop database if exists cwx_db1;
drop user if exists cwx;
drop user if exists cwx1;
create database cwx_db;
use cwx_db;
create user 'cwx' identified by 'cwx';
grant all privileges on *.* to 'cwx';
create database cwx_db1;
use cwx_db1;
create user 'cwx1' identified by 'cwx1';
grant all privileges on *.* to 'cwx1';
# 建立链接
##输出 + 数据查看 + 结果 + 其他场景
##select-1，select-2，select-3，select-4
##本次验证对标mysql5.7版本
##不同 数据类型 + 表
drop table if exists c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12;
create table c1(t1 integer,t2 smallint,t3 decimal,t4 numeric,t5 float,t6 real,t7 double precision,t8 int);
create table c2(t1 date,t2 time,t3 datetime,t4 timestamp,t5 year);
create table c3(t1 char(20),t2 varchar(20),t3 binary(10),t4 varbinary(10),t5 blob,t6 text,t7 enum('1','2'),t8 set('1','2'));
create table c4(t1 boolean,t2 int default 3);
create table c6(t1 json);
create table c5(t1 geometry,t2 point,t3 linestring,t4 polygon);
create table c7(t1 long);
联合索引、唯一,主键，函数，运算符等
create table c8(t1 char(100) not null default '11111',primary key(t2),t2 varchar(100) default '222222',t3 char(100) as (t1+t2),t4 double as(length (t1)));
create index c8_index on c8(t3,t4);
CREATE UNIQUE INDEX c8_index1 ON c8(t3);
ALTER TABLE c8 ADD INDEX c8_index2(t3);
alter table c8 add constraint ck_emp_age unique(t4);
##分区（range，list，hash，subpartition）
CREATE TABLE c9(t1 int) partition by range (t1)(
partition part_1 values less than (10),
partition part_2 values less than (20));
CREATE TABLE c10(t1 int) partition by list (t1)(
partition part_1 values in (10,15),
partition part_2 values in (20,30));
CREATE TABLE c11(t1 int) partition by hash (t1) PARTITIONS 2;
create table c12(t1 int,t2 int) partition by range(t1) subpartition by hash(t2) subpartitions 3 (
partition part_1 values less than (10),
partition part_2 values less than maxvalue);
##视图
create view c9_view as select * from c9;
create view c2_view as select * from c2;
##临时表
create table c13(t1 int);
##输出
##经柏泽确定：MySQL的计划展示做的很差，ob的是更好的计划展示 ； 故以ob为准
##desc(table + 查询语句)
create procedure cai_pro()
begin
desc c1;
desc c2;
desc c3;
desc c4;
desc c8;
desc c9;
desc c10;
desc c11;
desc c12;
desc c13;
#desc c14;
desc c9_view;
desc c2_view;
select '-------------------------------------------------------';
desc select * from c1;
desc select * from c2;
desc select * from c3;
desc select * from c4;
desc select * from c8;
desc select * from c9;
desc select * from c10;
desc select * from c11;
desc select * from c12;
desc select * from c13;
desc select * from c9_view;
desc select * from c2_view;
#desc select * from c14;
end;
/
call cai_pro();/
