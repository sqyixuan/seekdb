create procedure cai_pro()
begin
set @c_sql1="select cai_func() from dual;";
prepare stmt from @c_sql1;
execute stmt;
deallocate prepare stmt;
set @c_sql2="select cai_func() from c1";
prepare stmt from @c_sql1;
execute stmt;
deallocate prepare stmt;
end;
$
call cai_pro();$
cai_func()
cai_func()
11
11
drop procedure cai_pro;$
drop function cai_func;$
create table c18(t1 char(20),t2 char(20));$
insert into c18 values('assdsfdsfd','fdgfdd'),('ass\fd','fdgfdd'),('s','s');$
##其他场景
##select中别名重复，查看输出 + like的扩展用法 ，如 select * from code_dict a where 'aabfagfera' like a.code; + 游标输出时均赋值同一变量 + 列名同变量名
create procedure cai_pro()
begin
declare t1 char(20) default 'bbbb';
declare t2 char(20) default 'cccc';
declare done int default 0;
declare c_cursor cursor for select t1,t2 from c18;
declare continue handler for not found set done=1;
select t1,t2 from dual;
open c_cursor;
while done!=1 do
fetch c_cursor into t1,t1;
if done!=1 then
select t1,t1;
end if;
end while;
close c_cursor;
select 1 as a,2 as a from dual;
select * from c18 a where 'assdsfdsfd' like a.t1;
end;
$
call cai_pro();$
t1	t2
t1	t1
t1	t1
t1	t1
a	a
t1	t2
bbbb	cccc
cccc	cccc
cccc	cccc
cccc	cccc
1	2
assdsfdsfd	fdgfdd
drop procedure cai_pro;$
create procedure cai_pro()
begin
declare t1 char(20);
declare t2 char(20);
declare done int default 0;
declare c_cursor cursor for select * from c18 order by t1;
declare continue handler for not found set done=1;
open c_cursor;
while done!=1 do
fetch c_cursor into t1,t1;
if done!=1 then
select t1,t1;
end if;
end while;
close c_cursor;
end;
$
call cai_pro();$
t1	t1
t1	t1
t1	t1
fdgfdd	fdgfdd
fdgfdd	fdgfdd
s	s
drop procedure cai_pro;$
