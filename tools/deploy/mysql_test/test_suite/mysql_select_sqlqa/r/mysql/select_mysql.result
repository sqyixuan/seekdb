create table c17(t1 int,t2 int,t3 char(200));$
delete from c17;$
insert into c17(t1,t2) values(2,4);$
insert into c17(t1,t2) values(-1,-5);$
insert into c17 values(2,4,'9a');$
create procedure cai_pro()
begin
select -2*9+60-4/7,5||4;
select date(20200101) from dual;
select 1 and 2,3<4;
select (case t1 when 2 then '是2呀' else '不是2' end)a_t1,(case when t2+3-6*0.6>=0 then '是正数' else '是负数' end) a_t2,sum(distinct t1) from c17 
where t3 is null and t1 between -9 and 9 and (t2 not in(7,8) or t2>-10) group by t1 having sum(t1)>0 order by t1,t2;
select * from c17 where t1>(case t1 when 2 then 0 else 7 end) or t2 in (4,-5);
select * from c17 where t3 like '%9%' and t1=2;
end;
$
call cai_pro();$
