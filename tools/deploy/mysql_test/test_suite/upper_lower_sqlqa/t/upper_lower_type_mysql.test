--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);



--echo obmysql-upper-1-1
--error 0,1582
select upper() from dual;
select upper('a') from dual;
select upper('') from dual;
SELECT UPPER('壹') FROM dual;
SELECT UPPER('卍') FROM dual;
SELECT UPPER('o(‧') FROM dual;
SELECT UPPER('ⅶ ⅷ') FROM dual;
select upper('Aluk') from dual;
SELECT UPPER('abc卍') FROM dual;
SELECT UPPER('Ж阿梁Θ') FROM dual;
SELECT UPPER('梦琳2002') FROM dual;
SELECT UPPER('伍fck伍') FROM dual;
SELECT UPPER('amy￥Ж') FROM dual;
SELECT UPPER('㊊㊋㊌㊍㊎㊏') FROM dual;
SELECT UPPER('ＳＺｚОo') FROM dual;
SELECT UPPER('しovのyoｕ') FROM dual;
SELECT UPPER('ō ó ǒ ò') FROM dual; 
SELECT UPPER('囧Ｋ┣┫糖の果') FROM dual;
SELECT UPPER('ＳＶmm丫丫ｙ') FROM dual;
SELECT UPPER('时差 7  or 8 小时') FROM dual;
SELECT UPPER('μ τ υ φ χ ψ') FROM dual;
SELECT UPPER('ц ч ш щ ъ ы') FROM dual;
SELECT UPPER('☒☢ ☺ ☻ ☼ ☽☾') FROM dual;
SELECT UPPER('Λ Μ Ν Ξ Ο Π Ρ Σ') FROM dual;
SELECT UPPER('è ī í ǐ ì ū ú ǔ') FROM dual;
select upper(convert('Kobe1' using gbk)) from dual;
select upper(convert('Kobe1' using utf16)) from dual;
select upper(convert('Kobe1' using utf8mb4)) from dual;
select upper(convert('Kobe1' using gb18030)) from dual;

--error 0,1582
select lower() from dual;
select lower('A') from dual;
select lower('') from dual;
SELECT lower('壹') FROM dual;
SELECT lower('卍') FROM dual;
SELECT lower('O(‧') FROM dual;
SELECT lower('ⅶ ⅷ') FROM dual;
select lower('Aluk') from dual;
SELECT lower('ABC卍') FROM dual;
SELECT lower('Ж阿梁Θ') FROM dual;
SELECT lower('梦琳2002') FROM dual;
SELECT lower('伍fck伍') FROM dual;
SELECT lower('AMY￥Ж') FROM dual;
SELECT lower('㊊㊋㊌㊍㊎㊏') FROM dual;
SELECT lower('ＳＺｚОo') FROM dual;
SELECT lower('しOVのYoｕ') FROM dual;
SELECT lower('Ō Ó Ǒ Ò') FROM dual; 
SELECT lower('囧Ｋ┣┫糖の果') FROM dual;
SELECT lower('ＳＶMM丫丫ｙ') FROM dual;
SELECT lower('时差 7  OR 8 小时') FROM dual;
SELECT lower('Μ Τ Υ Φ Χ Ψ') FROM dual;
SELECT lower('Ц Ч Ш Щ Ъ Ы') FROM dual;
SELECT lower('☒☢ ☺ ☻ ☼ ☽☾') FROM dual;
SELECT lower('Λ Μ Ν Ξ Ο Π Ρ Σ') FROM dual;
SELECT lower('È Ī Í Ǐ Ì Ū Ú Ǔ ') FROM dual;
