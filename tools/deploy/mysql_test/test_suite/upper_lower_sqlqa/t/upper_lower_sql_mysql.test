#LIKE 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE '%C%' ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE 'S%' ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE '%K' ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE '_A%' ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE '%R_' ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.ename) LIKE '%C%' AND UPPER(e.job) LIKE '_A%' ORDER BY e.empno;  


SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE '%c%' ORDER BY e.empno; 
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE 's%' ORDER BY e.empno; 
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE '%k' ORDER BY e.empno; 
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE '_a%' ORDER BY e.empno;  
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE '%r_' ORDER BY e.empno; 
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.ename) LIKE '%c%' AND LOWER(e.job) LIKE '_a%' ORDER BY e.empno;  


#Multi column single COLUMN
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE  UPPER(e.ename) = 'MARTIN' OR UPPER(e.job) = 'PRESIDENT' ORDER BY e.empno;
SELECT UPPER(e.ename) || UPPER(e.job) ejob FROM t2_view e WHERE  UPPER(e.ename) = 'MARTIN' OR UPPER(e.job) = 'PRESIDENT' ORDER BY e.empno;

SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE  LOWER(e.ename) = 'martin' OR LOWER(e.job) = 'president' ORDER BY e.empno;
SELECT LOWER(e.ename) || LOWER(e.job) ejob FROM t2_view e WHERE  LOWER(e.ename) = 'martin' OR LOWER(e.job) = 'president' ORDER BY e.empno;


#WHERE
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) = 'ANALYST' ORDER BY e.empno;	
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE 1 = 1 AND UPPER(mgr) IS NULL ORDER BY e.empno;
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) IN ('SALESMAN','CLERK') ORDER BY e.empno;
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE 1 = 1 AND UPPER(e.deptno) BETWEEN 10 AND 20 ORDER BY e.empno; 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE 1 = 1 AND UPPER(e.job) = 'CLERK' OR UPPER(e.ename) = 'JONES' ORDER BY e.empno;
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE 1 = 1 AND UPPER(e.ename) = (SELECT UPPER(p.ename) FROM t2_view p WHERE UPPER(p.ename)='JAMES' )ORDER BY e.empno;


SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) = 'analyst' ORDER BY e.empno;	
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE 1 = 1 AND LOWER(mgr) IS NULL ORDER BY e.empno;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) IN ('salesman','clerk') ORDER BY e.empno;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE 1 = 1 AND LOWER(e.deptno) BETWEEN 10 AND 20 ORDER BY e.empno; 
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE 1 = 1 AND LOWER(e.job) = 'clerk' OR LOWER(e.ename) = 'jones' ORDER BY e.empno;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE 1 = 1 AND LOWER(e.ename) = (SELECT LOWER(p.ename) FROM t2_view p WHERE LOWER(p.ename)='james' )ORDER BY e.empno;


#ORDER BY 
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' ORDER BY 1;
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' ORDER BY UPPER(e.ename);
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' ORDER BY UPPER(e.ename) ASC;
SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' ORDER BY UPPER(e.ename) DESC;

SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) = 'salesman' ORDER BY 1;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) = 'salesman' ORDER BY LOWER(e.ename);
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) = 'salesman' ORDER BY LOWER(e.ename) ASC;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2_view e WHERE LOWER(e.job) = 'salesman' ORDER BY LOWER(e.ename) DESC;


#GROUP BY HAVING
SELECT e.deptno,COUNT(UPPER(e.job))job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' OR UPPER(e.job) = 'ANALYST' GROUP BY e.deptno ORDER BY e.deptno;
SELECT COUNT(UPPER(e.job))job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' OR UPPER(e.job) = 'ANALYST' GROUP BY UPPER(e.job) ORDER BY COUNT(UPPER(e.job));
SELECT e.deptno,COUNT(UPPER(e.job))job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' OR UPPER(e.job) = 'ANALYST' GROUP BY UPPER(e.job),e.deptno ORDER BY e.deptno;
SELECT e.deptno,COUNT(UPPER(e.job))job FROM t2_view e WHERE UPPER(e.job) = 'SALESMAN' OR UPPER(e.job) = 'ANALYST' GROUP BY UPPER(e.job),e.deptno HAVING COUNT(UPPER(e.job)) > 2 ORDER BY e.deptno;


SELECT e.deptno,COUNT(LOWER(e.job))job FROM t2_view e WHERE LOWER(e.job) = 'salesman' OR LOWER(e.job) = 'analyst' GROUP BY e.deptno ORDER BY e.deptno;
SELECT COUNT(LOWER(e.job))job FROM t2_view e WHERE LOWER(e.job) = 'salesman' OR LOWER(e.job) = 'analyst' GROUP BY LOWER(e.job) ORDER BY COUNT(LOWER(e.job));
SELECT e.deptno,COUNT(LOWER(e.job))job FROM t2_view e WHERE LOWER(e.job) = 'salesman' OR LOWER(e.job) = 'analyst' GROUP BY LOWER(e.job),e.deptno ORDER BY e.deptno;
SELECT e.deptno,COUNT(LOWER(e.job))job FROM t2_view e WHERE LOWER(e.job) = 'salesman' OR LOWER(e.job) = 'analyst' GROUP BY LOWER(e.job),e.deptno HAVING COUNT(LOWER(e.job)) > 2 ORDER BY e.deptno;


#CASE WHEN
SELECT UPPER(e.ename),(CASE UPPER(e.job) WHEN 'SALESMAN' THEN '1' WHEN 'CLERK' THEN '2' WHEN 'MANAGER' THEN '3' WHEN 'PRESIDENT' THEN '4' ELSE '5' END)job FROM t2_view e limit 5;
SELECT UPPER(e.ename),UPPER(CASE WHEN e.sal < 2000 THEN NULL ELSE 'HighSalary' END )sal FROM  t2_view e WHERE UPPER(CASE WHEN e.sal < 2000 THEN NULL ELSE 'HighSalary' END ) IS NOT NULL ORDER BY e.empno;


SELECT LOWER(e.ename),(CASE LOWER(e.job) WHEN 'salesman' THEN '1' WHEN 'clerk' THEN '2' WHEN 'manager' THEN '3' WHEN 'president' THEN '4' ELSE '5' END)job FROM t2_view e limit 5;
SELECT LOWER(e.ename),LOWER(CASE WHEN e.sal < 2000 THEN NULL ELSE 'HighSalary' END )sal FROM  t2_view e WHERE LOWER(CASE WHEN e.sal < 2000 THEN NULL ELSE 'HighSalary' END ) IS NOT NULL ORDER BY e.empno;


