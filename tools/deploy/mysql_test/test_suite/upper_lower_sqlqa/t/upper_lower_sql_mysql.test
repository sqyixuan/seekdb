insert into t1 values(7369,'Smith','Clerk',7902,'1980-12-17',800,100,20),(7499,'Allen','SaLesMan',7698,'1981-02-20',1600,300,30),(7521,'WaRd','SaLeSman',7698,'1981-2-22',1250,500,30),(7566,'Jones','MaNaGer',7839,'1981-04-02',2975,358.69,20),
(7654,'MarTin','SaleSman',7698,'1981-09-28',1250,1400,30),(7698,'Blake','ManaGer',7839,'1981-05-01',2850,-2100,30),(7782,'Clark','ManaGer',7839,'1981-06-09',2450,744.9,10),(7788,'ScotT','AnalysT',7566,'1987-04-13',3000,-200,20),(7839,'King','PresiDent',NULL,'1981-11-17',5000,-196.7,10),
(7844,'TurNeR','SaLeSmaN',7698,'1981-09-08',1500,0,30),(7876,'Adams','ClerK',7788,'1987-05-13',1100,-99.9,20),(7900,'JaMeS','CLerK',7698,'1981-12-03',950,-1808,30),(7902,'ForD','AnalyST',7566,'1981-12-03',3000,753.9,20),(7934,'MIller','Clerk',7782,'1982-01-23',1300,729,10);

--echo obmysql-upper-1-5-3
ALTER TABLE t1 ADD INDEX t1_index (sal,job,empno,ename);
#select  
select UPPER(e.empno)empno,UPPER(e.job)job,UPPER(e.ename)ename,UPPER(e.sal)sal from t1 e order by e.empno;
select * from t1 e where UPPER(e.job) = 'CLERK' and UPPER(e.ename) = 'SMITH' order by e.empno;
select * from t1 e where UPPER(e.job) = 'MANAGER' or UPPER(e.sal) > 3000 order by e.empno;
select SUM(UPPER(e.sal))sal,UPPER(e.ename)ename from t1 e where UPPER(e.job) = 'CLERK' group by UPPER(e.ename),e.empno order by e.empno;


select LOWER(e.empno)empno,LOWER(e.job)job,LOWER(e.ename)ename,LOWER(e.sal)sal from t1 e order by e.empno;
select * from t1 e where LOWER(e.job) = 'clerk' and LOWER(e.ename) = 'smith' order by e.empno;
select * from t1 e where LOWER(e.job) = 'manager' or LOWER(e.sal) > 3000 order by e.empno;
select SUM(LOWER(e.sal))sal,LOWER(e.ename)ename from t1 e where LOWER(e.job) = 'clerk' group by LOWER(e.ename),e.empno order by e.empno;



#insert  
insert into  t1 values(7999,UPPER('KoBe'),UPPER('Clerk'),7735,'1982-12-06',7300,500,20);
select COUNT(*)  from t1;


insert into t1 values(7949,LOWER('Kuli'),LOWER('Clerk'),7735,'1980-3-15',7300,500,20);
select COUNT(*)  from t1;



#update
update t1 SET ename = UPPER('yM') where UPPER(ename) = 'KULI';
update t1 SET sal = UPPER('8599')  where sal = 2975;
update t1 SET job = UPPER('Athletes') where UPPER(job) = 'ANALYST';
update t1 SET empno = UPPER('7354')  where  UPPER(empno) = 7566;
select *  from t1;

update t1 SET ename = LOWER('Ow') where LOWER(ename) = 'kobe';
update t1 SET sal = LOWER('3075')  where sal = 1250;
update t1 SET job = LOWER('Athletes') where LOWER(job) = 'clerk';
update t1 SET empno = LOWER('7254')  where LOWER(empno) = 7499;
select *  from t1;

#delete 
delete from t1 where UPPER(ename) = 'SMITH';
delete from t1 where UPPER(sal) = 8599;
delete from t1 where UPPER(job) = 'ATHLETES';
delete from t1 where UPPER(empno) = 7254;
select COUNT(*)  from t1;


delete from t1 where LOWER(ename) = 'king';
delete from t1 where LOWER(sal) = 1500;
delete from t1 where LOWER(job) = 'salesman';
delete from t1 where LOWER(empno) = 7782;
select COUNT(*)  from t1;


--error 0,1051
drop table t1;






