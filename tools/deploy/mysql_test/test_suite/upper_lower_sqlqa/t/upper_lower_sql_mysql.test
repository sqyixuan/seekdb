--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);


--enable_sorted_result

--error 0,1051
drop table t1;
create table t1 (name varchar(20),sal varchar(20));
insert into t1 values('Smith','4500'),('MarTin','3900'),('Clark','5200'),('ScotT','3500'),('TurNeR','4785'),('JaMeS','7856');


--echo obmysql-upper-1-6
--echo obmysql-upper-1-6-1
select upper(e.sal*5-200) / upper(e.sal/5-500) from t1 e;
select upper(e.sal+1000) + upper(e.sal-100*2) sal from t1 e;
select upper(e.sal*5-500/2) - upper(e.sal * 2) sal from t1 e;
select upper(e.sal-1000) * 2 - upper(e.sal + 800) sal from t1 e;
select upper(e.sal+1000/2*1.5) + upper(e.sal-100*5+2) from t1 e;
select upper(e.sal/50-1000) * upper(e.sal/100-30) sal from t1 e;

select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.sal) > 5000;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.sal) >= 4500;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.sal) < 5000;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.sal) <= 4000;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) = 'JAMES';
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) != 'CLARK';
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) <> 'SCOTT';


select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) in ('SMITH','CLARK');
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) not in ('SMITH','CLARK');
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) = 'SMITH' and upper(e.sal) = 4500;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) = 'SMITH' or upper(e.sal) = 3900;
select upper(e.name)name,upper(e.sal)sal from t1 e where upper(e.name) = 'SMITH' or upper(e.name) = 'CLARK';


select sum(upper(e.sal))sal from t1 e;
select upper(sum(e.sal))sal from t1 e;

select avg(upper(e.sal))sal from t1 e;
select upper(avg(e.sal))sal from t1 e;

select abs(upper(e.sal))sal from t1 e;
select upper(abs(e.sal))sal from t1 e;

select ceil(upper(e.sal))sal from t1 e;
select upper(ceil(e.sal))sal from t1 e;

select floor(upper(e.sal))sal from t1 e;
select upper(floor(e.sal))sal from t1 e;

select mod(upper(e.sal),7)sal from t1 e;
select upper(mod(e.sal,7))sal from t1 e;

select length(upper(e.name))name from t1 e;
select upper(length(e.name))name from t1 e;

select instr(upper(e.name),'T')name from t1 e;
select upper(instr(e.name,'t'))name from t1 e;

select max(upper(e.sal))sal from t1 e;
select upper(max(e.sal))sal from t1 e;

select min(upper(e.sal))sal from t1 e;
select upper(min(e.sal))sal from t1 e;

select cast(upper(e.name) as char(20)) from t1 e;
select upper(cast(e.name as char(20))) from t1 e;

select upper(concat(e.name,e.sal)) from t1 e;
select concat(upper(e.name),upper(e.sal))sal from t1 e;


select convert(upper(e.name) using gbk) from t1 e;
select convert(upper(e.name) using utf16) from t1 e;
select convert(upper(e.name) using utf8mb4) from t1 e;
select convert(upper(e.name) using gb18030) from t1 e;
select upper(convert(e.name using gbk)) from t1 e ;
select upper(convert(e.name using utf16)) from t1 e;
select upper(convert(e.name using utf8mb4)) from t1 e ;
select upper(convert(e.name using gb18030)) from t1 e;

select upper(trim(e.name)) from t1 e;
select trim(upper(e.name)) from t1 e;
select upper(rtrim(e.name)) from t1 e;
select rtrim(upper(e.name)) from t1 e;
select upper(ltrim(e.name)) from t1 e;
select ltrim(upper(e.name)) from t1 e;


select upper(upper(upper(upper(e.name)))) from t1 e;
select upper(lower(upper(lower(e.name)))) from t1 e;


