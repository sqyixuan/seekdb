--echo obmysql-upper-1-3
--echo obmysql-upper-1-3-1
SELECT UPPER(e.dname),UPPER(e.loc) FROM t1 e;
SELECT LOWER(e.dname),LOWER(e.loc) FROM t1 e;
SELECT UPPER(e.ename),UPPER(e.job) FROM t2 e limit 5;
SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e limit 5;

SELECT * FROM (SELECT DISTINCT UPPER(e.job)job,e.deptno FROM t2 e ORDER BY e.deptno) e limit 5;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE UPPER(e.ename) = 'JAMES' ORDER BY e.empno) e;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE UPPER(e.ename) = 'WARD' AND UPPER(e.job) = 'SALESMAN' ORDER BY e.empno) e;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE UPPER(e.ename) = 'WARD' OR UPPER(e.job) = 'MANAGER' ORDER BY e.empno) e;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE UPPER(e.ename) IN ('WARD','JAMES') ORDER BY e.empno) e;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE UPPER(e.job) NOT IN ('SALESMAN','CLERK','MANAGER') ORDER BY e.empno) e;

SELECT * FROM (SELECT DISTINCT LOWER(e.job)job,e.deptno FROM t2 e ORDER BY e.deptno) e limit 5;
SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE LOWER(e.ename) = 'james' ORDER BY e.empno) e;
SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE LOWER(e.ename) = 'ward' AND LOWER(e.job) = 'salesman' ORDER BY e.empno) e;
SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE LOWER(e.ename) = 'ward' OR LOWER(e.job) = 'manager' ORDER BY e.empno) e;
SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE LOWER(e.ename) IN ('ward','james') ORDER BY e.empno) e;
SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE LOWER(e.job) NOT IN ('salesman','clerk','analyst') ORDER BY e.empno) e;


#EXISTS
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE EXISTS (SELECT * FROM t1 p WHERE UPPER(p.dname) = 'ACCOUNTING') AND UPPER(e.job) = 'SALESMAN' ORDER BY e.empno) e;
SELECT * FROM (SELECT UPPER(e.ename)ename,UPPER(e.job)job FROM t2 e WHERE NOT EXISTS (SELECT * FROM t1 p WHERE UPPER(p.dname) = 'ACCOUNTING' AND UPPER(p.loc) = 'DALLAS') AND UPPER(e.job) = 'SALESMAN' ORDER BY e.empno) e;

SELECT * FROM (SELECT LOWER(e.ename)ename,LOWER(e.job)job FROM t2 e WHERE EXISTS (SELECT * FROM t1 p WHERE LOWER(p.dname) = 'accounting') AND LOWER(e.job) = 'salesman' ORDER BY e.empno) e;
