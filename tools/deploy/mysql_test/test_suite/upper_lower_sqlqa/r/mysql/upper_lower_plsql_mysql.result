drop function m_f; //
create function m_f()
returns varchar(20)
begin
declare a varchar(20) character set utf16;
select concat(upper(e.ename),upper(e.job)) from t1 e where sal > 3000 order by e.empno into a;
return a;
end;
//
select m_f();//
m_f()
KINGPRESIDENT
drop function m_f;//
create function m_f(in_name varchar(20))
returns varchar(20)
begin
declare a varchar(20) character set gb18030;
select concat(upper(e.ename),upper(e.job)) from t1 e where upper(e.ename) = in_name order by e.empno into a;
return a;
end;
//
select m_f('MARTIN');//
m_f('MARTIN')
MARTINSALESMAN
