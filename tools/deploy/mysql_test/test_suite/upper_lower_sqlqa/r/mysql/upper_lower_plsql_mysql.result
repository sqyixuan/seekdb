drop procedure m_p;//
create procedure m_p(in in_name varchar(20),out out_name varchar(20),inout inout_name varchar(20))
begin
declare i int default 0;
select upper(e.job) into out_name from t1 e where upper(e.ename) = in_name order by e.empno;
select upper(e.job) from t1 e where upper(e.ename) = inout_name order by e.empno into inout_name;
while i <= 10 do
insert into t1 values(7596,upper(in_name),upper(out_name),7902,'1980-07-18',1000,1200,20);
set i := i + 1;
end while;
end;
//
select count(*) from t1;//
count(*)
51
call m_p(upper('Smith'),@out_name,@inout_name);//
select count(*) from t1;//
count(*)
62
