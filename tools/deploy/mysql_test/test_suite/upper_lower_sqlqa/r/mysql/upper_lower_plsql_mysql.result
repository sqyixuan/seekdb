drop function m_f;//
create function m_f(in_name varchar(20))
returns varchar(20)
begin
declare a varchar(20) character set gbk;
declare i int default 0;
select concat(upper(e.ename),upper(e.job)) from t1 e where upper(e.ename) = in_name order by e.empno into a;
while i <= 5 do
insert into t1 values(7596,upper('KoBe'),upper('Clerk'),7902,'1980-07-18',1000,1200,20);
set i := i + 1;
end while;
return a;
end;
//
select count(*) from t1;//
count(*)
14
select m_f('MARTIN');//
m_f('MARTIN')
MARTINSALESMAN
select count(*) from t1;//
count(*)
20
