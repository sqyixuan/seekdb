drop procedure m_p;//
create procedure m_p(in in_name varchar(20))
begin
declare a varchar(20) character set gb18030;
declare i int default 0;
select upper(e.job) from t1 e where upper(e.ename) = in_name order by e.empno into a;
repeat 
insert into t1 values(7596,upper('KoBe'),upper('Clerk'),7902,'1980-07-18',1000,1200,20);
set i := i + 1;
until i >= 10 end repeat;
end;
//
select count(*) from t1;//
count(*)
30
call m_p('JAMES');//
select count(*) from t1;//
count(*)
