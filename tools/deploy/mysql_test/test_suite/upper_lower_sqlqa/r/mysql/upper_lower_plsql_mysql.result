drop procedure m_p;//
create procedure m_p()
begin
declare a varchar(20) character set binary;
declare i int default 0;
select upper(e.job) from t1 e where upper(e.ename) = 'WARD' into a;
loop_lable:loop
insert into t1 values(7596,upper('KoBe'),upper('Clerk'),7902,'1980-07-18',1000,1200,20);
set i := i + 1;
if i >= 10 then leave loop_lable;
end if;
end loop;
end;
//
select count(*) from t1;//
count(*)
20
call m_p;//
select count(*) from t1;//
count(*)
30
