drop procedure m_p;//
create procedure m_p(out in_name varchar(20))
begin
declare i int default 0;
select upper(e.job) into in_name  from t1 e where upper(e.ename) = 'JAMES' order by e.empno;	
while i <= 10 do
insert into t1 values(7596,upper('KoBe'),upper('Clerk'),7902,'1980-07-18',1000,1200,20);
set i := i + 1;
end while;
