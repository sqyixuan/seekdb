#Environmental cleaning
drop user longpy@'%';
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
drop table t1;
drop function m_f;
drop procedure m_p;
CREATE TABLE t1(EMPNO decimal(4),ENAME VARCHAR(10),JOB VARCHAR(9),MGR decimal(4),HIREDATE DATE,SAL decimal(7,2),COMM decimal(7,2),DEPTNO decimal(2));
