drop table t1;
create table t1(EMPNO decimal(4) primary key,ENAME VARCHAR(10),JOB VARCHAR(9)not null,MGR decimal(4),HIREDATE DATE,SAL decimal(7,2),COMM decimal(7,2),DEPTNO decimal(2),constraint uq unique(ename));
