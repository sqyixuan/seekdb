CREATE TABLE t2(EMPNO decimal(4) PRIMARY KEY,ENAME VARCHAR(10),JOB VARCHAR(9),MGR decimal(4),HIREDATE DATE,SAL decimal(7,2),COMM decimal(7,2),DEPTNO decimal(2));
