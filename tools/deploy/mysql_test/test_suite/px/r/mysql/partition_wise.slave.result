      (#keys=1, [lineitem.l_partkey]), dop=1
  7 - output([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=16
      force partition granule
  8 - output([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=16
