      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([part.p_partkey]), range(MIN ; MAX)always true
 11 - output([cast(T_FUN_APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(T_FUN_APPROX_COUNT_DISTINCT_SYNOPSIS(lineitem.l_quantity)), DOUBLE(-1, -1)) - cast(10, DOUBLE(-1,
       -1))]), filter(nil), rowset=16
