drop database if exists muhangtest;
create database muhangtest;
use muhangtest;
result_format: 4
create table lineitem(
 l_orderkey           bigint NOT NULL ,
 l_partkey            bigint NOT NULL ,
 l_suppkey            bigint NOT NULL ,
 l_linenumber         bigint NOT NULL ,
 l_quantity           bigint NOT NULL ,
 l_extendedprice      number(10,2) NOT NULL ,
 l_discount           number(10,2) NOT NULL ,
 l_tax                number(10,2) NOT NULL ,
 l_returnflag         char(1) ,
 l_linestatus         char(1) ,
 l_shipdate           date ,
 l_commitdate         date ,
 l_receiptdate        date ,
 l_shipinstruct       char(25) ,
 l_shipmode           char(10) ,
 l_comment            varchar(44),
 primary key(L_ORDERKEY, L_LINENUMBER),
 index
 i_l_orderkey(l_orderkey)
  local
  ) partition by hash(L_ORDERKEY) partitions 5;

create table part(
 p_partkey            bigint NOT NULL ,
 p_name               varchar(55) ,
 p_mfgr               char(25) ,
 p_brand              char(10) ,
 p_type               varchar(25) ,
 p_size               bigint ,
 p_container          char(10) ,
 p_retailprice        number(10,2) ,
 p_comment            varchar(23) ,
 primary key (P_PARTKEY)
  ) partition by hash(P_PARTKEY) partitions 5;

create table customer(
 c_custkey            bigint NOT NULL ,
 c_name               varchar(25) ,
 c_address            varchar(40) ,
 c_nationkey          bigint ,
 c_phone              char(15) ,
 c_acctbal            number(10,2) ,
 c_mktsegment         char(10) ,
 c_comment            varchar(117),
 primary key(C_CUSTKEY),
 unique index i_c_custkey(c_custkey) local
  ) partition by hash(C_CUSTKEY) partitions 5;

create table orders(
 o_orderkey           bigint NOT NULL ,
 o_custkey            bigint NOT NULL ,
 o_orderstatus        char(1) ,
 o_totalprice         number(10,2) ,
 o_orderdate          date ,
 o_orderpriority      char(15) ,
 o_clerk              char(15) ,
 o_shippriority       bigint ,
 o_comment            varchar(79),
 primary key(o_orderkey),
 index(o_orderkey) local
  ) partition by hash(o_orderkey) partitions 5;

## from transformer_win_magic.test  tpch_17
EXPLAIN SELECT SUM(L_EXTENDEDPRICE)/7.0 AS AVG_YEARLY FROM LINEITEM, PART WHERE P_PARTKEY = L_PARTKEY AND P_BRAND != 'Brand#23' AND P_CONTAINER = 'MED BOX' AND L_QUANTITY < (SELECT 0.2*AVG(L_QUANTITY) FROM LINEITEM WHERE L_PARTKEY = P_PARTKEY);
Query Plan
===============================================================================
|ID|OPERATOR                                   |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------------
|0 |SCALAR GROUP BY                            |        |1       |26          |
|1 |└─PX COORDINATOR                           |        |1       |26          |
|2 |  └─EXCHANGE OUT DISTR                     |:EX10001|1       |26          |
|3 |    └─MERGE GROUP BY                       |        |1       |25          |
|4 |      └─SUBPLAN SCAN                       |VIEW1   |1       |25          |
|5 |        └─WINDOW FUNCTION                  |        |1       |25          |
|6 |          └─SORT                           |        |1       |24          |
|7 |            └─HASH JOIN                    |        |1       |24          |
|8 |              ├─EXCHANGE IN DISTR          |        |1       |13          |
|9 |              │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|1       |12          |
|10|              │   └─PX PARTITION ITERATOR  |        |1       |11          |
|11|              │     └─TABLE FULL SCAN      |lineitem|1       |11          |
|12|              └─PX PARTITION ITERATOR      |        |1       |11          |
|13|                └─TABLE FULL SCAN          |part    |1       |11          |
===============================================================================
Outputs & filters:
-------------------------------------
  0 - output([cast(T_FUN_SUM(T_FUN_SUM(VIEW1.lineitem.l_extendedprice)), DECIMAL(32, 2)) / cast(7.0, DECIMAL(2, 1))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(T_FUN_SUM(VIEW1.lineitem.l_extendedprice))])
  1 - output([T_FUN_SUM(VIEW1.lineitem.l_extendedprice)]), filter(nil), rowset=16
  2 - output([T_FUN_SUM(VIEW1.lineitem.l_extendedprice)]), filter(nil), rowset=16
      dop=1
  3 - output([T_FUN_SUM(VIEW1.lineitem.l_extendedprice)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(VIEW1.lineitem.l_extendedprice)])
  4 - output([VIEW1.lineitem.l_extendedprice]), filter([cast(VIEW1.lineitem.l_quantity, DECIMAL(20, 0)) < VIEW1.0.2*AVG(L_QUANTITY)]), rowset=16
      access([VIEW1.0.2*AVG(L_QUANTITY)], [VIEW1.lineitem.l_quantity], [VIEW1.lineitem.l_extendedprice])
  5 - output([cast(0.2, DECIMAL(2, 1)) * cast(cast(T_FUN_SUM(lineitem.l_quantity), DECIMAL(42, 0)) / cast(T_FUN_COUNT(lineitem.l_quantity), DECIMAL(20, 
      0)), DECIMAL(24, 4))], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=16
      win_expr(T_FUN_SUM(lineitem.l_quantity)), partition_by([lineitem.l_partkey]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
      win_expr(T_FUN_COUNT(lineitem.l_quantity)), partition_by([lineitem.l_partkey]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  6 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=16
      sort_keys([lineitem.l_partkey, ASC])
  7 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=16
      equal_conds([lineitem.l_partkey = part.p_partkey]), other_conds(nil)
  8 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=16
  9 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=16
      (#keys=1, [lineitem.l_partkey]), dop=1
 10 - output([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=16
      force partition granule
 11 - output([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=16
      access([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), partitions(p[0-4])
      is_index_back=false, is_global_index=false, 
      range_key([lineitem.l_orderkey], [lineitem.l_linenumber]), range(MIN,MIN ; MAX,MAX)always true
 12 - output([part.p_partkey]), filter(nil), rowset=16
      affinitize, partition wise, force partition granule
 13 - output([part.p_partkey]), filter([part.p_brand != 'Brand#23'], [part.p_container = 'MED BOX']), rowset=16
      access([part.p_partkey], [part.p_brand], [part.p_container]), partitions(p[0-4])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([part.p_partkey]), range(MIN ; MAX)always true

EXPLAIN SELECT /*+NO_REWRITE*/ SUM(L_EXTENDEDPRICE)/7.0 AS AVG_YEARLY FROM LINEITEM, PART WHERE P_PARTKEY = L_PARTKEY AND P_BRAND != 'Brand#23' AND P_CONTAINER = 'MED BOX' AND L_QUANTITY < (SELECT APPROX_COUNT_DISTINCT_SYNOPSIS(L_QUANTITY) - 10  FROM LINEITEM WHERE P_PARTKEY=L_PARTKEY);
