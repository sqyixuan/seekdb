drop table if exists px1;
drop table if exists sp1;
drop table if exists t1;
drop table if exists t2;
alter system set enable_sql_audit = true;
alter system flush sql audit global;
create table px1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table sp1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table t2 (c1 int primary key, c2 int);
insert into px1 values (1,1);
explain basic (select /*+ xiaochu-px_admission test-bushy-px parallel(2) */ count(*) from t2 group by c1) union (select count(*) from t2 group by c1);
