CREATE TABLE `t1` (
  `c1` decimal(64,19) DEFAULT NULL,
  `c2` bigint(127) DEFAULT NULL,
  `c3` date DEFAULT NULL,
  `c4` datetime DEFAULT NULL,
  `c5` timestamp(2) NOT NULL DEFAULT '0000-00-00 00:00:00.00',
  `c6` varchar(86) COLLATE utf8mb4_bin NOT NULL,
  `c7` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c8` varbinary(51) DEFAULT NULL,
  `c9` int(127) DEFAULT NULL,
  `c10` decimal(64,20) DEFAULT NULL,
  `c11` bigint(127) NOT NULL,
  `c12` int(127) DEFAULT NULL,
  `c13` timestamp(5) NOT NULL DEFAULT '0000-00-00 00:00:00.00000',
  `c14` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00',
  PRIMARY KEY (`c11`, `c6`)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(c11)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`);

CREATE TABLE `t2` (
  `c1` decimal(64,19) DEFAULT NULL,
  `c2` bigint(127) DEFAULT NULL,
