drop database if exists test_gi_rescan;
create database test_gi_rescan;
use test_gi_rescan;
create table t1(v1 int, v2 int) partition by hash(v1) partitions 4;
create table t2(v1 int) partition by hash(v1) partitions 3;
create table t3(v1 int) partition by hash(v1) partitions 3;
insert into t1 values(1,2), (3,4), (5,6), (7,8);
insert into t2 values(1),(2), (3),(4), (5),(6), (7),(8);
insert into t3 values(1),(2), (3),(4), (5),(6), (7),(8);
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
result_format: 4
select * from t1, t2 , t3 where t3.v1 = t2.v1 and t1.v2 = t2.v1;
+------+------+------+------+
| v1   | v2   | v1   | v1   |
+------+------+------+------+
|    1 |    2 |    2 |    2 |
|    3 |    4 |    4 |    4 |
|    5 |    6 |    6 |    6 |
|    7 |    8 |    8 |    8 |
+------+------+------+------+

explain basic select /*+ PQ_DISTRIBUTE(@"SEL$1" ("test_gi_rescan"."t2"@"SEL$1" "test_gi_rescan"."t3"@"SEL$1" ) BROADCAST NONE) NO_USE_NL_MATERIALIZATION(@"SEL$1" ("TEST_GI_RESCAN"."T2"@"SEL$1" "TEST_GI_RESCAN"."T3"@"SEL$1" )) parallel(2) USE_NL(@"SEL$1" ("TEST_GI_RESCAN"."T2"@"SEL$1" "TEST_GI_RESCAN"."T3"@"SEL$1" )) leading(t1 (t2 t3))*/* from t1, t2 , t3 where t3.v1 = t2.v1 and t1.v2 = t2.v1;
Query Plan
====================================================
|ID|OPERATOR                              |NAME    |
----------------------------------------------------
|0 |PX COORDINATOR                        |        |
|1 |└─EXCHANGE OUT DISTR                  |:EX10001|
|2 |  └─NESTED-LOOP JOIN                  |        |
|3 |    ├─EXCHANGE IN DISTR               |        |
|4 |    │ └─EXCHANGE OUT DISTR (BROADCAST)|:EX10000|
|5 |    │   └─PX BLOCK ITERATOR           |        |
|6 |    │     └─TABLE FULL SCAN           |t1      |
|7 |    └─PX PARTITION ITERATOR           |        |
|8 |      └─HASH JOIN                     |        |
|9 |        ├─TABLE FULL SCAN             |t2      |
|10|        └─TABLE FULL SCAN             |t3      |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.v1, t1.v2, t2.v1, t3.v1)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.v1, t1.v2, t2.v1, t3.v1)]), filter(nil), rowset=16
      dop=2
  2 - output([t1.v2], [t2.v1], [t1.v1], [t3.v1]), filter(nil), rowset=16
