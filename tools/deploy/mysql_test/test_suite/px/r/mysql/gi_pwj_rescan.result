  3 - output([t1.v2], [t1.v1]), filter(nil), rowset=16
  4 - output([t1.v2], [t1.v1]), filter(nil), rowset=16
      dop=2
  5 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
  6 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
      access([t1.v1], [t1.v2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  7 - output([t2.v1], [t3.v1]), filter(nil), rowset=16
      partition wise, force partition granule
  8 - output([t2.v1], [t3.v1]), filter(nil), rowset=16
      equal_conds([t3.v1 = t2.v1]), other_conds(nil)
  9 - output([t2.v1]), filter(nil), rowset=16
      access([t2.v1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
 10 - output([t3.v1]), filter(nil), rowset=16
      access([t3.v1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true

