drop database if exists wlzpxtest;
drop table t1;
drop table t2;
drop table t3;
create database wlzpxtest;
use wlzpxtest;
result_format: 4
set ob_enable_plan_cache = false;

create table t1(c1 bigint,c2 bigint,c3 bigint,c4 bigint);
insert into t1 values(1,2,3,4);
insert into t1 select c1+1,c2+1,c3+1,c4+1 from t1;
insert into t1 select c1+10,c2+10,c3+1,c4+1 from t1;
insert into t1 select c1+100,c2+100,c3+1,c4+1 from t1;
insert into t1 select c1+1000,c2+1000,c3+1,c4+1 from t1;
insert into t1 select c1+10000,c2+10000,c3+1,c4+1 from t1;
insert into t1 select c1+100000,c2+100000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000,c2+1000000,c3+1,c4+1 from t1;
insert into t1 select c1+10000000,c2+10000000,c3+1,c4+1 from t1;
insert into t1 select c1+100000000,c2+100000000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000000,c2+1000000000,c3+1,c4+1 from t1;
insert into t1 select c1+10000000000,c2+10000000000,c3+1,c4+1 from t1;
insert into t1 select c1+100000000000,c2+100000000000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000000000,c2+1000000000000,c3+1,c4+1 from t1;
select count(*) from t1;
+----------+
| count(*) |
+----------+
|     8192 |
+----------+

create table t2(c1 bigint,c2 bigint,c3 bigint,c4 bigint) partition by hash (c1) partitions 10;
insert into t2 select * from t1;

create table t3(c1 bigint,c2 bigint,c3 bigint,c4 bigint) partition by hash (c1) partitions 10;
insert into t3 select * from t1;

##test only block gi
explain select /*+ no_place_group_by use_px parallel(2)*/sum(d1) from (select count(*) as d1 from t1 a, t1 b where a.c1=b.c2 group by a.c2) order by 1;
