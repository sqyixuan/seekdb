drop database if exists muhangtest;
drop table if exists t1;
drop table if exists t2;
create database muhangtest;
use muhangtest;
result_format: 4
create table t1_sort(c1 int, c2 longtext, c3 double, c4 longtext, c5 char(38), primary key(c1)) COMPRESSION = 'none' partition by range(c1)
(partition p0 values less than(50),
partition p1 values less than(100),
partition p2 values less than(150),
partition p3 values less than(300),
partition p4 values less than(450),
partition p5 values less than(600));

merge
alter system minor freeze;
call dbms_stats.gather_table_stats('muhangtest', 'T1_SORT', method_opt=>'for all columns size auto');
end merge

explain select /*+parallel(2)*/ c1 from t1_sort partition(p3, p5) order by c1 desc;
Query Plan
======================================================================
|ID|OPERATOR                  |NAME            |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT |                |300     |128         |
|1 |└─EXCHANGE OUT DISTR      |:EX10000        |300     |71          |
|2 |  └─PX BLOCK ITERATOR     |                |300     |6           |
|3 |    └─TABLE FULL SCAN     |t1_sort(Reverse)|300     |6           |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1_sort.c1)]), filter(nil), rowset=256
      sort_keys([t1_sort.c1, DESC])
  1 - output([t1_sort.c1], [INTERNAL_FUNCTION(t1_sort.c1)]), filter(nil), rowset=256
      dop=2
  2 - output([t1_sort.c1]), filter(nil), rowset=256
      desc
  3 - output([t1_sort.c1]), filter(nil), rowset=256
      access([t1_sort.c1]), partitions(p3, p5)
      is_index_back=false, is_global_index=false, 
      range_key([t1_sort.c1]), range(MIN ; MAX)always true

select /*+parallel(2)*/ c1 from t1_sort partition(p3, p5) order by c1 desc;
