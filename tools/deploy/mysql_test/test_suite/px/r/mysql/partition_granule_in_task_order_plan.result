create table t1(c1 int, primary key(c1)) COMPRESSION = 'none' partition by range(c1)
(partition p0 values less than(50),
partition p1 values less than(100),
partition p2 values less than(150),
partition p3 values less than(300),
partition p4 values less than(450),
partition p5 values less than(600));

insert into t1 values(1),(51),(101),(151),(301),(451);

create table t2(c1 int);
insert into t2 select * from t1 order by c1 limit 3;
select * from t2;
+------+
| c1   |
+------+
|    1 |
|   51 |
|  101 |
+------+

drop table t1;
drop table t2;
