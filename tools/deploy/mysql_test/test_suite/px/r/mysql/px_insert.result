drop database if exists muhangtest;
drop table if exists test;
drop table if exists tt;
create database muhangtest;
use muhangtest;
create table test(c1 int, c2 int, c3 int, c4 char(14) default 'nihao' primary key) partition by key(c4) partitions 4;
insert into test values(1,2,3, 'damdam');
insert into test(c1,c2,c3) values(10,2,3);
create table tt(c1 int,c2 int, c3 int, c4 varchar(12));
insert into tt values(4,5,6,'xxx');
explain insert into test(c1,c2,c3,c4) select * from tt;
Query Plan
==============================================================
|ID|OPERATOR           |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |DISTRIBUTED INSERT |               |1       |16          |
|1 |└─SUBPLAN SCAN     |ANONYMOUS_VIEW1|1       |3           |
|2 |  └─TABLE FULL SCAN|tt             |1       |3           |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{test: ({test: (test.c4, test.c1, test.c2, test.c3)})}]), partitions(p[0-3]), 
      column_values([column_conv(CHAR,utf8mb4_general_ci,length:14,NOT NULL,cast(ANONYMOUS_VIEW1.c4, CHAR(1048576)))], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c1)],
       [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c3)])
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.c4]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.c4])
  2 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4]), filter(nil), rowset=16
      access([tt.c1], [tt.c2], [tt.c3], [tt.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([tt.__pk_increment]), range(MIN ; MAX)always true
explain insert into test(c1,c2,c3,c4) select /*+parallel(4)*/ * from tt;
