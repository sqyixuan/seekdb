drop database if exists px_test;
create database px_test;
use px_test;
create table stu (
sid     int,
tid     int,
name    varchar(32),
primary key (sid)
) partition by hash(sid) partitions 6;
insert into stu values
(1, 4, 'John'),
(2, 7, 'Marry'),
(3, 8, 'Austin'),
(4, 3, 'Jack');
create table teacher (
tid        int,
name       varchar(32),
subject    varchar(4),
primary key (tid)
) partition by hash(tid) partitions 8;
insert into teacher values
(1, 'Miss Zhang', 'EN'),
(2, 'Mr Wang', 'MA'),
(3, 'Mr Tao', 'CH'),
(4, 'Miss XIAN', 'PHY'),
(5, 'Mr WU', 'BIO'),
(6, 'Miss KANG', 'PE'),
(7, 'Mr HOU', 'PSY'),
(8, 'Miss LAI', 'CS'),
(9, 'Mr HUANG', 'RE'),
(10, 'Miss CHEN', 'ART');
alter system set enable_sql_audit = true;
select /*+ use_px parallel(4) */* from teacher;
select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
