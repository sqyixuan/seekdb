drop table t2;
create table t2(v1 int , v2 int auto_increment) partition by hash(v1) partitions 4;
result_format: 4
explain basic insert into t2(v1) values(1), (2), (3), (4);
Query Plan
============================
|ID|OPERATOR          |NAME|
----------------------------
|0 |DISTRIBUTED INSERT|    |
|1 |└─EXPRESSION      |    |
============================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t2: ({t2: (t2.__pk_increment, t2.v1, t2.v2)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,__values.v1)], [column_conv(INT,PS:(11,0),NOT NULL,cast(t2.v2.nextval(), INT(-1, 0)))])
  1 - output([__values.v1]), filter(nil)
      values({1}, {2}, {3}, {4})

insert into t2(v1) values(1), (2), (3), (4);

explain basic insert /*+ parallel(2)*/into t2(v1) values(4), (5), (6), (7);
