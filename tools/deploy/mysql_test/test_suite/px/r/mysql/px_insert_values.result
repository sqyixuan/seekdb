============================
|ID|OPERATOR          |NAME|
----------------------------
|0 |DISTRIBUTED INSERT|    |
|1 |└─EXPRESSION      |    |
============================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t2: ({t2: (t2.__pk_increment, t2.v1, t2.v2)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,__values.v1)], [column_conv(INT,PS:(11,0),NOT NULL,cast(t2.v2.nextval(), INT(-1, 0)))])
  1 - output([__values.v1]), filter(nil)
      values({4}, {5}, {6}, {7})

insert /*+ parallel(2)*/into t2(v1) values(4), (5), (6), (7);

