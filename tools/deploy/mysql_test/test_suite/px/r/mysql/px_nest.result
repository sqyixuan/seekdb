drop database if exists wlz;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create database wlz;
use wlz;
CREATE TABLE t1 (
c1 int primary key,
c2 int, c3 int
)partition by hash(c1) partitions 4;
create table t2 (
c1 int primary key,
c2 int, c3 int
)
;
create table t3 (
c1 int primary key,
c2 int, c3 int
)
;
INSERT INTO t1 VALUES (1,1,1);
INSERT INTO t1 VALUES (2,2,2);
INSERT INTO t1 VALUES (3,3,3);
INSERT INTO t1 VALUES (4,4,4);
INSERT INTO t1 VALUES (5,5,5);
insert into t2 select * from t1;
insert into t3 select * from t2;
commit;
alter system set _bloom_filter_enabled = false;
explain select /*+ use_px parallel(3)*/* from (select /*+ no_rewreite parallel(1) */ t1.* from t2 t1 join t1 t4 on t1.c2=t4.c2 where t1.c1 in (select /*+ no_use_hash_aggregation*/c1 from t2 sp1 where sp1.c1 + 10> t1.c2 group by c2 having count(c1) > 0)
)b where b.c2 in (
select a.c1 from
(select /*+ use_px parallel(3) */ * from t2 t0)a
,
(select /*+ no_rewreite parallel(1) */ a.*from t3 a join t2 b on a.c2=b.c2 where a.c2 = (select /*+ no_use_hash_aggregation*/c1 from t2 sp1 where sp1.c3 = a.c3)
)b where a.c2=b.c2) order by 1,2,3;
