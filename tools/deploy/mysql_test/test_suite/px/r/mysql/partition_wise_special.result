drop database if exists px;
create database px;
use px;
CREATE TABLE t1 (c1 int)
partition by range(c1)
(
partition p0 values less than (0),
partition p1 values less than (1),
partition p2 values less than (2),
partition p3 values less than (3),
partition p4 values less than (4),
partition p5 values less than (5));
CREATE TABLE t2 (c1 int) 
partition by range(c1)
(
partition p1 values less than (1),
partition p2 values less than (2),
partition p3 values less than (3),
partition p4 values less than (4),
partition p5 values less than (5));
insert into t1 values(0);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);
insert into t2 values(0);
insert into t2 values(1);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(4);
create table t3(c1 int);
insert into t3 select c1 from t1;
explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
Query Plan
=========================================================================
|ID|OPERATOR                             |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |PX COORDINATOR                       |        |4       |7           |
|1 |└─EXCHANGE OUT DISTR                 |:EX10001|4       |7           |
|2 |  └─HASH JOIN                        |        |4       |6           |
|3 |    ├─HASH JOIN                      |        |4       |4           |
|4 |    │ ├─PART JOIN FILTER CREATE      |:RF0000 |4       |2           |
|5 |    │ │ └─EXCHANGE IN DISTR          |        |4       |2           |
|6 |    │ │   └─EXCHANGE OUT DISTR (PKEY)|:EX10000|4       |1           |
|7 |    │ │     └─PX BLOCK ITERATOR      |        |4       |1           |
|8 |    │ │       └─TABLE FULL SCAN      |t3      |4       |1           |
|9 |    │ └─PX PARTITION HASH JOIN-FILTER|:RF0000 |4       |3           |
|10|    │   └─TABLE FULL SCAN            |t1      |4       |3           |
|11|    └─PX PARTITION ITERATOR          |        |4       |3           |
|12|      └─TABLE FULL SCAN              |t2      |4       |3           |
=========================================================================
