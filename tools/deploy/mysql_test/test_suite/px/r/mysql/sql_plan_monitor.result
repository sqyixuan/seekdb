set ob_query_timeout = 10000000000;
drop table if exists llc6;
create table llc6(id INT auto_increment PRIMARY key,c1 int, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int,c9 int,c10 int,c11 int,c12 int,c13 int,c14 int)partition by hash (id) partitions 5;
drop sequence if exists s1;
create sequence s1 cache 3000000;
insert /*+ parallel(16) */ into llc6 select null,s1.nextval,abs(random(1)) % 2 + 1, abs(random(1)) % 50000 + 1,abs(random(1)) % 500000+1, abs(random(1)) % 1000000+1,abs(random(1)) % 3000000+1,s1.nextval,abs(random(1)) % 2+1,s1.nextval,s1.nextval,s1.nextval,s1.nextval,s1.nextval,null from table(generator(3000000));
select count(*) from llc6;
count(*)
3000000
select /*+monitor*/ max(c1+c2+c3+c4+c5+c6+c7+c9+c10+c11+c12+c13+c14) from llc6;
