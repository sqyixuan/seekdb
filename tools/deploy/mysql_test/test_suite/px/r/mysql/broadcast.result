Query Plan
===============================================
|ID|OPERATOR                         |NAME    |
-----------------------------------------------
|0 |PX COORDINATOR                   |        |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|
|2 |  └─HASH JOIN                    |        |
|3 |    ├─PX PARTITION ITERATOR      |        |
|4 |    │ └─TABLE FULL SCAN          |t2      |
|5 |    └─EXCHANGE IN DISTR          |        |
|6 |      └─EXCHANGE OUT DISTR (PKEY)|:EX10000|
|7 |        └─PX PARTITION ITERATOR  |        |
|8 |          └─TABLE FULL SCAN      |t1      |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      dop=1
  2 - output([t1.c2], [t2.c2], [t2.c1], [t2.c3], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
      equal_conds([t1.c2 = t2.c2]), other_conds(nil)
  3 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      affinitize, force partition granule
  4 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  5 - output([t1.c2], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
  6 - output([t1.c2], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
      (#keys=1, [t1.c2]), dop=1
  7 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      force partition granule
  8 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
