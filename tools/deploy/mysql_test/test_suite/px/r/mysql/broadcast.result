| 11 |   11 |   41 | NULL |  9 | 11 | 41 |
| 12 |   12 |   42 | NULL |  9 | 12 | 42 |
| 13 |   13 |   43 | NULL |  9 | 13 | 43 |
| 14 |   14 |   44 | NULL |  9 | 14 | 44 |
| 15 |   15 |   45 | NULL |  9 | 15 | 45 |
| 16 |   16 |   46 | NULL |  9 | 16 | 46 |
| 17 |   17 |   47 | NULL |  9 | 17 | 47 |
