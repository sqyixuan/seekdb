## 看看hint是否是右边生效
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
Query Plan
=================================================
|ID|OPERATOR                           |NAME    |
-------------------------------------------------
|0 |PX COORDINATOR                     |        |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|
|2 |  └─HASH JOIN                      |        |
|3 |    ├─PART JOIN FILTER CREATE      |:RF0000 |
|4 |    │ └─EXCHANGE IN DISTR          |        |
|5 |    │   └─EXCHANGE OUT DISTR (PKEY)|:EX10000|
|6 |    │     └─PX BLOCK ITERATOR      |        |
|7 |    │       └─TABLE FULL SCAN      |t1      |
|8 |    └─PX PARTITION HASH JOIN-FILTER|:RF0000 |
|9 |      └─TABLE FULL SCAN            |t2      |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      dop=3
  2 - output([t1.c2], [t2.c2], [t1.c1], [t1.c3], [t1.c4], [t2.c1], [t2.c3]), filter(nil), rowset=256
      equal_conds([t1.c2 = t2.c2]), other_conds(nil)
  3 - output([t1.c2], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
      RF_TYPE(bloom), RF_EXPR[calc_tablet_id(partition_key(t1.c2))]
  4 - output([t1.c2], [calc_tablet_id(partition_key(t1.c2))], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
  5 - output([t1.c2], [calc_tablet_id(partition_key(t1.c2))], [t1.c1], [t1.c3], [t1.c4]), filter(nil), rowset=256
      (#keys=1, [t1.c2]), dop=3
  6 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
  7 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
  8 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      affinitize
  9 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
+----+------+------+------+----+----+----+
| c1 | c2   | c3   | c4   | c1 | c2 | c3 |
+----+------+------+------+----+----+----+
|  1 |    1 |   31 | NULL |  1 |  1 | 31 |
|  2 |    2 |   32 | NULL |  1 |  2 | 32 |
