UNION
SELECT 'ED_FILE_DIR' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/UAPDataShare' AS PARAM_VALUE,                      '日终文件目录' AS PARAM_DESC,      'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'TO_HKEX' AS PARAM_KEY,     0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/to_hkex' AS PARAM_VALUE,      '港交所发送文件路径' AS PARAM_DESC, 'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'FROM_HKEX' AS PARAM_KEY,   0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/from_hkex' AS PARAM_VALUE,    '港交所接收文件路径' AS PARAM_DESC, 'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'PFX_CSDCKEY' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/pfxdata/NULL' AS PARAM_VALUE, '密钥路径' AS PARAM_DESC,          'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'PROGRAM_DIR' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/home/kcbp/kcbp/bin64/fileconv' AS PARAM_VALUE,     '外部程序路径' AS PARAM_DESC,       'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION ALL
SELECT
    'PFX_BACKUP_DIR'                   AS PARAM_KEY
    ,0                                   AS PARAM_CHANNEL
                ,CONCAT('backup/',A.BIZ_DATE,'/')    AS PARAM_VALUE
    ,'PFX发送文件监控路径'             AS PARAM_DESC
    ,'Dir'                             AS PARAM_CLASS
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS IN_DATE
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS LM_DATE
FROM SUBSYS_PVT_CFG A
UNION ALL
SELECT
    '@T-1'                               AS PARAM_KEY
    ,0                                   AS PARAM_CHANNEL
    ,CAST(A.LAST_BIZ_DATE AS CHAR(8))    AS PARAM_VALUE
    ,'T-1业务日期'                        AS PARAM_DESC
    ,'date'                              AS PARAM_CLASS
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS IN_DATE
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS LM_DATE
FROM SUBSYS_PVT_CFG A;
