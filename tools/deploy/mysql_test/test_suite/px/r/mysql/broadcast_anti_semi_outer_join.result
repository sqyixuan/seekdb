## t2表的分区1被裁掉
EXPLAIN select /*+use_px parallel(4)*/ c1 from t12 where c1 not in (select c1 from t11 where c2 not in (select c2 from t11)) and t12.c1 > 55;
Query Plan
================================================================================
|ID|OPERATOR                                    |NAME    |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------------------
|0 |PX COORDINATOR                              |        |4       |8           |
|1 |└─EXCHANGE OUT DISTR                        |:EX10002|4       |7           |
|2 |  └─SHARED HASH RIGHT ANTI JOIN NA          |        |4       |7           |
|3 |    ├─EXCHANGE IN DISTR                     |        |1       |6           |
|4 |    │ └─EXCHANGE OUT DISTR (BC2HOST)        |:EX10001|1       |6           |
|5 |    │   └─SUBPLAN SCAN                      |VIEW2   |1       |6           |
|6 |    │     └─SHARED HASH RIGHT ANTI JOIN NA  |        |1       |6           |
|7 |    │       ├─EXCHANGE IN DISTR             |        |17      |4           |
|8 |    │       │ └─EXCHANGE OUT DISTR (BC2HOST)|:EX10000|17      |3           |
|9 |    │       │   └─PX BLOCK ITERATOR         |        |17      |2           |
|10|    │       │     └─TABLE FULL SCAN         |t11     |17      |2           |
|11|    │       └─PX BLOCK ITERATOR             |        |17      |2           |
|12|    │         └─TABLE FULL SCAN             |t11     |17      |2           |
|13|    └─PX BLOCK ITERATOR                     |        |5       |1           |
|14|      └─TABLE FULL SCAN                     |t12     |5       |1           |
================================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t12.c1)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t12.c1)]), filter(nil), rowset=256
      dop=4
  2 - output([t12.c1]), filter(nil), rowset=256
      equal_conds([t12.c1 = VIEW2.c1]), other_conds(nil)
  3 - output([VIEW2.c1]), filter(nil), rowset=256
  4 - output([VIEW2.c1]), filter(nil), rowset=256
      dop=4
  5 - output([VIEW2.c1]), filter(nil), rowset=256
      access([VIEW2.c1])
  6 - output([t11.c1]), filter(nil), rowset=256
      equal_conds([t11.c2 = t11.c2]), other_conds(nil)
  7 - output([t11.c2]), filter(nil), rowset=256
  8 - output([t11.c2]), filter(nil), rowset=256
      dop=4
  9 - output([t11.c2]), filter(nil), rowset=256
 10 - output([t11.c2]), filter(nil), rowset=256
      access([t11.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t11.__pk_increment]), range(MIN ; MAX)always true
 11 - output([t11.c1], [t11.c2]), filter(nil), rowset=256
 12 - output([t11.c1], [t11.c2]), filter(nil), rowset=256
      access([t11.c1], [t11.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t11.__pk_increment]), range(MIN ; MAX)always true
 13 - output([t12.c1]), filter(nil), rowset=256
 14 - output([t12.c1]), filter([t12.c1 > 55]), rowset=256
      access([t12.c1]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t12.__pk_increment]), range(MIN ; MAX)always true
select /*+use_px parallel(4)*/ c1 from t12 where c1 not in (select c1 from t11 where c2 not in (select c2 from t11)) and t12.c1 > 55;
