##semi join 两遍被随意broadcast
EXPLAIN select /*+ USE_NL(xy_t1, xy_t2) */ * from xy_t1 where exists (select 1 from xy_t2 where xy_t1.c1 = xy_t2.c1);
Query Plan
=======================================================================
|ID|OPERATOR                           |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |PX COORDINATOR                     |        |6       |18          |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|6       |16          |
|2 |  └─NESTED-LOOP SEMI JOIN          |        |6       |13          |
|3 |    ├─PX PARTITION ITERATOR        |        |8       |9           |
|4 |    │ └─TABLE FULL SCAN            |xy_t1   |8       |9           |
|5 |    └─MATERIAL                     |        |5       |10          |
|6 |      └─EXCHANGE IN DISTR          |        |5       |9           |
|7 |        └─EXCHANGE OUT DISTR (PKEY)|:EX10000|5       |9           |
|8 |          └─PX PARTITION ITERATOR  |        |5       |7           |
|9 |            └─TABLE FULL SCAN      |xy_t2   |5       |7           |
=======================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(xy_t1.c1, xy_t1.c2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(xy_t1.c1, xy_t1.c2)]), filter(nil), rowset=16
      dop=1
  2 - output([xy_t1.c1], [xy_t1.c2]), filter(nil), rowset=16
      conds([xy_t1.c1 = xy_t2.c1]), nl_params_(nil), use_batch=false
  3 - output([xy_t1.c1], [xy_t1.c2]), filter(nil), rowset=16
      affinitize, force partition granule
  4 - output([xy_t1.c1], [xy_t1.c2]), filter(nil), rowset=16
      access([xy_t1.c1], [xy_t1.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([xy_t1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([xy_t2.c1]), filter(nil), rowset=16
  6 - output([xy_t2.c1]), filter(nil), rowset=16
  7 - output([xy_t2.c1]), filter(nil), rowset=16
      (#keys=1, [xy_t2.c1]), dop=1
  8 - output([xy_t2.c1]), filter(nil), rowset=16
      force partition granule
  9 - output([xy_t2.c1]), filter(nil), rowset=16
      access([xy_t2.c1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([xy_t2.__pk_increment]), range(MIN ; MAX)always true
select /*+ USE_NL(xy_t1, xy_t2) */ * from xy_t1 where exists (select 1 from xy_t2 where xy_t1.c1 = xy_t2.c1);
