      conds(nil), nl_params_([a.c1(:0)]), use_batch=true
  3 - output([a.c1], [a.c2]), filter(nil), rowset=16
  4 - output([a.c1], [a.c2]), filter(nil), rowset=16
      access([a.c1], [a.c2]), partitions(p[0-7])
      is_index_back=false, is_global_index=false, 
      range_key([a.__pk_increment]), range(MIN ; MAX)always true
  5 - output([b.c1], [b.c2]), filter(nil), rowset=16
      access([GROUP_ID], [b.c1], [b.c2]), partitions(p[0-5])
      is_index_back=false, is_global_index=false, 
      range_key([b.c1]), range(MIN ; MAX), 
      range_cond([:0 = b.c1])
