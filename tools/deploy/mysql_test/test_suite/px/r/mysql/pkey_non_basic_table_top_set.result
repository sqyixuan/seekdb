result_format: 4
drop table if exists t1;
drop table if exists t1_1;
drop table if exists t1_2;
drop table if exists t2;
drop table if exists t3;
CREATE TABLE T1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_2 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T2 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 4;
CREATE TABLE T3 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 5;
insert into t1 values(1, 1, 1), (2,2,2), (3,3,3), (4,4,4);
insert into t1_1 values(1, 1, 1), (2,2,2), (3,3,3), (4,4,4);
insert into t2 values(1, 1, 1), (2,2,2), (4,4,4), (5,5,5), (6,6,6);
insert into t3 values(2,2,2), (4,4,4), (5,5,5), (6,6,6);
explain_protocol: 2

######################################## pkey to simple pw ######################################
## pw hash join
EXPLAIN select c2 from t2 union select /*+ use_hash(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |9       |33          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|9       |31          |
|2 |  └─HASH UNION DISTINCT          |        |9       |28          |
|3 |    ├─PX PARTITION ITERATOR      |        |4       |14          |
|4 |    │ └─HASH JOIN                |        |4       |14          |
|5 |    │   ├─TABLE FULL SCAN        |t1_1    |4       |7           |
|6 |    │   └─TABLE FULL SCAN        |t1      |4       |7           |
|7 |    └─EXCHANGE IN DISTR          |        |4       |12          |
|8 |      └─EXCHANGE OUT DISTR (PKEY)|:EX10000|4       |12          |
|9 |        └─HASH DISTINCT          |        |4       |10          |
|10|          └─PX PARTITION ITERATOR|        |5       |9           |
|11|            └─TABLE FULL SCAN    |t2      |5       |9           |
=====================================================================
