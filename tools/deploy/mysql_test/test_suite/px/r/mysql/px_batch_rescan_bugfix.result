drop table t1;
DROP TABLE IF EXISTS t1bnoquj;
create table if not exists `t1bnoquj` (
`id` int(11) not null,
`fname` varchar(30),
`lname` varchar(30),
`hired` date not null default '1970-01-01',
`separated` date not null default '9999-12-31',
`job_code` int(11),
`store_id` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (year(hired))
(
PARTITION `p0`,
PARTITION `p1`,
PARTITION `p2`,
PARTITION `p3`
);
create index `gidx_t1g9qzyh` on `t1bnoquj` (`hired` ASC) GLOBAL;
CREATE TABLE if not exists `sub_listkey` (
`userid` int(11) NOT NULL,
`usertype` int(11) NOT NULL,
PRIMARY KEY (`userid`,
`usertype`)
) DEFAULT CHARSET = utf8mb4 
partition by list(usertype) subpartition by key(`userid`) subpartition template (
subpartition p0,
subpartition p1,
subpartition p2)
(partition p1 values in (1),
partition p2 values in (2),
partition p3 values in (3));
CREATE TABLE t1 (f1 INT, CONSTRAINT CAFE CHECK (f1 < 10));
insert into t1 values(null);
DROP TABLE IF EXISTS list_default_test_npk;
CREATE TABLE `list_default_test_npk` (
`id` int(11) NOT NULL,
`name` varchar(10) NOT NULL
) DEFAULT CHARSET = utf8mb4 
partition by list(id)
(partition p0 values in (1,3,5,7,9),
partition p1 values in (2,4,6,8));
create table if not exists `t15xvnef` (
`c1` varchar(1),
`c2` varchar(1),
`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
