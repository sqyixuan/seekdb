drop table if exists t1,t2;
create table t1 (c1 int, c2 enum('Alice','Bob','Charlie','David') NOT NULL);
create table t2 (d1 smallint(5) unsigned DEFAULT '42909');
insert into t1 values(1, 'Alice'),(2,'Bob');
insert into t2 values(1),(2),(3);
explain select /*+ parallel(3) use_hash(t1,t2) leading(t1 t2) px_join_filter(t2) */* from t1 join t2 on t1.c2 = t2.d1;
