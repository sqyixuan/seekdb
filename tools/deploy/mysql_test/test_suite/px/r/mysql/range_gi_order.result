result_format: 4
drop table if exists t1;

create table t1(a int, b int, primary key(a,b), index i1 (b) local) partition by range columns(b) (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than (30)
);

insert into t1 values (1,1);
alter table t1 truncate partition p0;

insert into t1 values (4,4);
insert into t1 values (6,6);
insert into t1 values (15,15);

explain basic select  * from t1 order by b asc;
Query Plan
========================================
|ID|OPERATOR                  |NAME    |
----------------------------------------
|0 |PX COORDINATOR MERGE SORT |        |
|1 |└─EXCHANGE OUT DISTR      |:EX10000|
|2 |  └─PX PARTITION ITERATOR |        |
|3 |    └─TABLE FULL SCAN     |t1(i1)  |
========================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, t1.b)]), filter(nil), rowset=16
      sort_keys([t1.b, ASC])
  1 - output([t1.b], [INTERNAL_FUNCTION(t1.a, t1.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.a], [t1.b]), filter(nil), rowset=16
      force partition granule, asc
  3 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.b], [t1.a]), range(MIN,MIN ; MAX,MAX)always true
select * from t1 order by b asc;
+----+----+
| a  | b  |
+----+----+
|  4 |  4 |
|  6 |  6 |
| 15 | 15 |
+----+----+

explain basic select  * from t1 order by b desc;
Query Plan
==============================================
|ID|OPERATOR                  |NAME          |
----------------------------------------------
|0 |PX COORDINATOR MERGE SORT |              |
|1 |└─EXCHANGE OUT DISTR      |:EX10000      |
|2 |  └─PX PARTITION ITERATOR |              |
|3 |    └─TABLE FULL SCAN     |t1(i1,Reverse)|
==============================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, t1.b)]), filter(nil), rowset=16
      sort_keys([t1.b, DESC])
  1 - output([t1.b], [INTERNAL_FUNCTION(t1.a, t1.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.a], [t1.b]), filter(nil), rowset=16
      force partition granule, desc
  3 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.b], [t1.a]), range(MIN,MIN ; MAX,MAX)always true
select * from t1 order by b desc;
+----+----+
| a  | b  |
+----+----+
| 15 | 15 |
|  6 |  6 |
|  4 |  4 |
+----+----+

