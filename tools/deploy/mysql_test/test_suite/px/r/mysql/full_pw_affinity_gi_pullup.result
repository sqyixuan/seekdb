      dop=1
  2 - output([t2.C1], [T_FUN_COUNT(*)], [t1_1.C2], [t2.C2], [t1.C1], [t1_1.C1]), filter([t1_1.C2 != T_FUN_COUNT(*)]), rowset=16
      group([t2.C1], [t2.__pk_increment], [t1_1.__pk_increment]), agg_func([T_FUN_COUNT(*)])
  3 - output([t2.C1], [t2.__pk_increment], [t1_1.__pk_increment], [t1_1.C2], [t2.C2], [t1.C1], [t1_1.C1]), filter(nil), rowset=16
