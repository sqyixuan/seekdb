## 5. pkey到pwj，并且pwj的两个表不是按顺序匹配
drop table t1, t2, t3;
CREATE TABLE t1 (c1 int, c2 varchar(10)) PARTITION BY LIST (c1) 
(PARTITION p1 VALUES IN (0, 1, 2),
PARTITION p2 VALUES IN (3, 4, 5),
PARTITION p3 VALUES IN (6, 7),
PARTITION p4 VALUES IN (8),
PARTITION p5 VALUES IN (9, 10));

CREATE TABLE t2 (c1 int, c2 varchar(10)) PARTITION BY LIST (c1) 
(PARTITION p1 VALUES IN (8),
PARTITION p2 VALUES IN (9, 10),
PARTITION p3 VALUES IN (0, 1, 2),
PARTITION p4 VALUES IN (6, 7),
PARTITION p5 VALUES IN (3, 4, 5));

create table t3(c1 int, c2 varchar(10));
