result_format: 4
drop table if exists t1,t2;
drop view if exists v3;

create table t1(v1 int, v2 int) partition by hash(v1) partitions 4;
create table t2(v1 int, v2 int) partition by hash(v1) partitions 5;
create view v3 as select * from t2;
explain basic select /*+ parallel(2) no_rewrite() use_hash(v3) leading(t1 v3) pq_distribute(v3 partition none)*/* from t1, v3 where t1.v1 = v3.v1;
