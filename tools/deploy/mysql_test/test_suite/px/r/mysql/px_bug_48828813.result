-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.v1, t1.v2, v3.v1, v3.v2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.v1, t1.v2, v3.v1, v3.v2)]), filter(nil), rowset=16
      dop=2
  2 - output([t1.v1], [v3.v1], [t1.v2], [v3.v2]), filter(nil), rowset=16
      equal_conds([t1.v1 = v3.v1]), other_conds(nil)
  3 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
  4 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
      (#keys=1, [t1.v1]), dop=2
  5 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
  6 - output([t1.v1], [t1.v2]), filter(nil), rowset=16
      access([t1.v1], [t1.v2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  7 - output([v3.v1], [v3.v2]), filter(nil), rowset=16
      access([v3.v1], [v3.v2])
  8 - output([t2.v1], [t2.v2]), filter(nil), rowset=16
      affinitize
  9 - output([t2.v1], [t2.v2]), filter(nil), rowset=16
      access([t2.v1], [t2.v2]), partitions(p[0-4])
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+ parallel(2) no_rewrite() use_hash(v3) leading(t1 v3) pq_distribute(v3 partition none)*/* from t1, v3 where t1.v1 = v3.v1;
