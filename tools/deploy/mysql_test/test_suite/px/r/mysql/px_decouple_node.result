drop table if exists tt2;
CREATE TABLE tt2 (
c1 BIGINT AUTO_INCREMENT,
c2 BIGINT,
c3 BIGINT,
c4 BIGINT,
PRIMARY KEY (c1, c2)
)
PARTITION BY RANGE(c2) (
PARTITION p1 VALUES LESS THAN (700000),
PARTITION p2 VALUES LESS THAN (800000),
PARTITION p3 VALUES LESS THAN (900000),
PARTITION p4 VALUES LESS THAN (MAXVALUE)
);
insert into tt2(c2,c3,c4) select abs(random(456) % 1000000), abs(random(456) % 1000000), abs(random(456) % 1000000) from table(generator(10000));
select /*+ monitor parallel(20) PX_NODE_POLICY('data')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;
count(distinct svr_ip, svr_port)
1
