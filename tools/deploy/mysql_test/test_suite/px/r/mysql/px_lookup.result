      range_key([t2.c1], [t2.c2]), range(MIN,MIN ; MAX,MAX)always true
update /*+index(t2 gkey) parallel(2)*/ t2 set c3=123 where c2 = 1 or c2 = 2 or c2 = 3;
select * from t2 order by c1;
