alter system flush plan cache global;
drop table if exists t, t0;
result_format: 4
create table t(c1 int, c2 int);
create table t0(c1 int, c2 int) partition by hash(c1) partitions 8;

## minimal worker more than parallel_servers_target
select /*+ parallel(2) no_rewrite */ c1, c2, (select min(c2) from t0), (select avg(c2) from t0 group by c1), 
(select avg(c2) from t0), (select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),
(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),
(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),
(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0),(select avg(c2) from t0) from t;
+------+------+--------------------------+--------------------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+
| c1   | c2   | (select min(c2) from t0) | (select avg(c2) from t0 group by c1) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) | (select avg(c2) from t0) |
+------+------+--------------------------+--------------------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+
+------+------+--------------------------+--------------------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+--------------------------+

## expected worker less than parallel_servers_target
select /*+ px_bug_53518561_sql_audit1 parallel(2) no_rewrite */ c1, c2, (select min(c2) from t0), (select avg(c2) from t0 group by c1) from t;
+------+------+--------------------------+--------------------------------------+
| c1   | c2   | (select min(c2) from t0) | (select avg(c2) from t0 group by c1) |
+------+------+--------------------------+--------------------------------------+
+------+------+--------------------------+--------------------------------------+
select EXPECTED_WORKER_COUNT, USED_WORKER_COUNT from oceanbase.gv$ob_sql_audit
where trace_id = ((select trace_id from oceanbase.gv$ob_sql_audit where query_sql like '%px_bug_53518561_sql_audit1%' order by request_time desc limit 1))
order by 1 desc limit 1;
+-----------------------+-------------------+
| EXPECTED_WORKER_COUNT | USED_WORKER_COUNT |
+-----------------------+-------------------+
|                     2 |                 2 |
+-----------------------+-------------------+

