DROP TABLE t1;

create table t1(c1 int, c2 int) partition by range(c2)
(partition p0 values less than (10),
 partition p1 values less than (100));

insert t1 values(10,1), (20,2), (30,3), (100, 10), (200, 20), (900, 90);

create table t2(c1 int, c2 int) partition by range(c1)
(partition p0 values less than (10),
 partition p1 values less than (100));
insert t2 values(1,10), (2,20), (3,30), (10, 100), (20, 200), (90, 900);

explain select /*+ parallel(3) */* from t1 union select * from t2;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |12      |18          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|12      |15          |
|2 |  └─HASH UNION DISTINCT          |        |12      |10          |
|3 |    ├─EXCHANGE IN DISTR          |        |6       |5           |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|6       |4           |
|5 |    │   └─HASH DISTINCT          |        |6       |3           |
|6 |    │     └─PX BLOCK ITERATOR    |        |6       |2           |
|7 |    │       └─TABLE FULL SCAN    |t1      |6       |2           |
|8 |    └─PX PARTITION ITERATOR      |        |6       |3           |
|9 |      └─TABLE FULL SCAN          |t2      |6       |3           |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(UNION([1]), UNION([2]))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(UNION([1]), UNION([2]))]), filter(nil), rowset=16
      dop=2
  2 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
  4 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      (#keys=1, [t1.c1]), dop=3
  5 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      distinct([t1.c1], [t1.c2])
  6 - output([t1.c2], [t1.c1]), filter(nil), rowset=16
  7 - output([t1.c2], [t1.c1]), filter(nil), rowset=16
      access([t1.c2], [t1.c1]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  8 - output([t2.c1], [t2.c2]), filter(nil), rowset=16
      affinitize
  9 - output([t2.c1], [t2.c2]), filter(nil), rowset=16
      access([t2.c1], [t2.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+ parallel(3) */* from t1 union select * from t2 order by 1,2;
