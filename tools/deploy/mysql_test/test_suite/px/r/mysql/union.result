drop table t1,t2;


create table t1(c1 int);
create table t2 (C1 int) partition by range(c1) (partition p0 values less than (100), partition p1 values less than (200));
insert into t2 values(1);
insert into t2 values(101);
insert into t2 values(2);
insert into t2 values(102);

insert into t1 values(501);
insert into t1 values(401);
insert into t1 values(601);
insert into t1 values(401);

alter system set _rowsets_max_rows = 2;

select  /*+parallel(2)*/ c1 from t1 union select c1 from t2 order by 1;
+------+
| c1   |
+------+
|    1 |
|    2 |
|  101 |
|  102 |
|  401 |
|  501 |
|  601 |
+------+

alter system set _rowsets_max_rows = 256;

drop table t1;
drop table t2;


