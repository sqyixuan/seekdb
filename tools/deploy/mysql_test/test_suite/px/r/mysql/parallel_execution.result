CREATE TABLE department
 (
 DepartmentID INT Primary key,
 DepartmentName VARCHAR(20)
 )partition by hash(DepartmentID) partitions 4;

CREATE TABLE employee
 (
 LastName VARCHAR(20),
 DepartmentID INT
)partition by hash(DepartmentID) partitions 4;

