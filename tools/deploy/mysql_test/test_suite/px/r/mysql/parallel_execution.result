## 按分区进行group by
create table t1(a int, b int, c int) partition by hash(a) partitions 4;
explain select a, sum(b) from t1 group by a;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |11          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |10          |
|2 |  └─PX PARTITION ITERATOR|        |1       |9           |
|3 |    └─HASH GROUP BY      |        |1       |9           |
|4 |      └─TABLE FULL SCAN  |t1      |1       |9           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, T_FUN_SUM(t1.b))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.a, T_FUN_SUM(t1.b))]), filter(nil), rowset=16
      dop=1
  2 - output([t1.a], [T_FUN_SUM(t1.b)]), filter(nil), rowset=16
      partition wise, force partition granule
  3 - output([t1.a], [T_FUN_SUM(t1.b)]), filter(nil), rowset=16
      group([t1.a]), agg_func([T_FUN_SUM(t1.b)])
  4 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

