result_format: 4
drop table if exists t1;
drop table if exists t1_1;
drop table if exists t1_2;
drop table if exists t2;
drop table if exists t3;
CREATE TABLE T1 (C1 INT, C2 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_1 (C1 INT, C2 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_2 (C1 INT, C2 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T2 (C1 INT, C2 INT) PARTITION BY HASH(C1) PARTITIONS 4;
CREATE TABLE T3 (C1 INT, C2 INT) PARTITION BY HASH(C1) PARTITIONS 5;
insert into t1 values(1, 1), (2,2), (3,3), (4,4);
insert into t1_1 values(1, 1), (2,2), (3,3), (4,4);
insert into t2 values(1, 1), (2,2), (4,4), (5,5), (6,6);
insert into t3 values(2,2), (4,4), (5,5), (6,6);
explain_protocol: 2

######################################## pkey to simple pw ######################################
## pw hash join
EXPLAIN select /*+ use_hash(t1_1) leading(t2 (t1 t1_1))) */ * from t2 join t1 join t1_1 on t1.c1 = t1_1.c1 and t2.c2 = t1.c1;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |4       |42          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|4       |38          |
|2 |  └─HASH JOIN                    |        |4       |30          |
|3 |    ├─EXCHANGE IN DISTR          |        |5       |14          |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|5       |13          |
|5 |    │   └─PX PARTITION ITERATOR  |        |5       |9           |
|6 |    │     └─TABLE FULL SCAN      |t2      |5       |9           |
|7 |    └─PX PARTITION ITERATOR      |        |4       |15          |
|8 |      └─HASH JOIN                |        |4       |15          |
|9 |        ├─TABLE FULL SCAN        |t1      |4       |7           |
|10|        └─TABLE FULL SCAN        |t1_1    |4       |7           |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t2.C1, t2.C2, t1.C1, t1.C2, t1_1.C1, t1_1.C2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t2.C1, t2.C2, t1.C1, t1.C2, t1_1.C1, t1_1.C2)]), filter(nil), rowset=16
      dop=1
  2 - output([t2.C2], [t1.C1], [t2.C1], [t1_1.C1], [t1.C2], [t1_1.C2]), filter(nil), rowset=16
      equal_conds([t2.C2 = t1.C1]), other_conds(nil)
  3 - output([t2.C2], [t2.C1]), filter(nil), rowset=16
  4 - output([t2.C2], [t2.C1]), filter(nil), rowset=16
      (#keys=1, [t2.C2]), dop=1
  5 - output([t2.C1], [t2.C2]), filter(nil), rowset=16
      force partition granule
  6 - output([t2.C1], [t2.C2]), filter(nil), rowset=16
      access([t2.C1], [t2.C2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  7 - output([t1.C1], [t1_1.C1], [t1.C2], [t1_1.C2]), filter(nil), rowset=16
      affinitize, partition wise, force partition granule
  8 - output([t1.C1], [t1_1.C1], [t1.C2], [t1_1.C2]), filter(nil), rowset=16
      equal_conds([t1.C1 = t1_1.C1]), other_conds(nil)
  9 - output([t1.C1], [t1.C2]), filter(nil), rowset=16
      access([t1.C1], [t1.C2]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
 10 - output([t1_1.C1], [t1_1.C2]), filter(nil), rowset=16
      access([t1_1.C1], [t1_1.C2]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1_1.__pk_increment]), range(MIN ; MAX)always true
select /*+ use_hash(t1_1) leading(t2 (t1 t1_1))) */ * from t2 join t1 join t1_1 on t1.c1 = t1_1.c1 and t2.c2 = t1.c1;
