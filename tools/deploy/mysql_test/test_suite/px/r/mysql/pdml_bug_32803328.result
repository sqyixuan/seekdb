UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ table10_bigint SET pk = LENGTH( REPEAT( CAST( 3 AS CHAR(20) ) , 0 + 1 ) ) , col_bigint = ROUND( ABS( col_bigint ) ) - LENGTH('EGVMV') WHERE STR_TO_DATE( DATE_FORMAT( col_timestamp_6_index , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ) != CONCAT( CAST( 2015 + 4 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') ORDER BY col_timestamp_6_index ASC , pk DESC LIMIT 5 ;
