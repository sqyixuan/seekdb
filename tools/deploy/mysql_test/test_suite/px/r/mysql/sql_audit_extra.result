select /*+ parallel(2) BEGIN_OUTLINE_DATA PQ_DISTRIBUTE(@"SEL$C6D21C0F" "test"."t"@"SEL$1" LOCAL LOCAL) END_OUTLINE_DATA */*  from t_audit join t on t_audit.c1 != t.c2;

SELECT
    (TOTAL_MEMSTORE_READ_ROW_COUNT - MEMSTORE_READ_ROW_COUNT + TOTAL_SSSTORE_READ_ROW_COUNT - SSSTORE_READ_ROW_COUNT) AS SQC_ROW_COUNTS
FROM
    oceanbase.gv$OB_SQL_AUDIT
WHERE
    trace_id = (select last_trace_id() as trace_id from dual)
    AND (
        QUERY_SQL LIKE '%select /*+ parallel(2) BEGIN_OUTLINE_DATA PQ_DISTRIBUTE(@"SEL$C6D21C0F" "test"."t"@"SEL$1" LOCAL LOCAL) END_OUTLINE_DATA */% from t_audit join t on t_audit.c1 != t.c2%'
    );
+----------------+
| SQC_ROW_COUNTS |
+----------------+
|             14 |
+----------------+

