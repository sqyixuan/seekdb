result_format: 4
drop table if exists t_audit;
create table t_audit(c1 int, c2 int) partition by hash(c1) partitions 16;
insert into t_audit values(1, 1);
insert into t_audit values(2, 2);
insert into t_audit values(3, 3);
insert into t_audit values(6, 6);
ALTER SYSTEM MINOR FREEZE;
insert into t_audit values(108, 108);
insert into t_audit values(221, 221);
insert into t_audit values(273, 273);
insert into t_audit values(336, 336);

drop table if exists t;
create table t(c1 int, c2 int) partition by hash(c1) partitions 16;
insert into t values(1, 1);
insert into t values(2, 2);
insert into t values(3, 3);
insert into t values(4, 4);
insert into t values(5, 5);
insert into t values(6, 6);

alter system flush plan cache;
explain select /*+ parallel(2) BEGIN_OUTLINE_DATA PQ_DISTRIBUTE(@"SEL$C6D21C0F" "test"."t"@"SEL$1" LOCAL LOCAL) END_OUTLINE_DATA */*  from t_audit join t on t_audit.c1 != t.c2;
