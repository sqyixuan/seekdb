result_format: 4
DROP DATABASE IF EXISTS SAMPLE_SCAN;
CREATE DATABASE SAMPLE_SCAN;
USE SAMPLE_SCAN;

create table empty_1 (c1 int, c2 int);
create table empty_2 (c1 int, c2 int);

create table t1(c1 int, c2 int);

select /*+parallel(3)*/ * FROM empty_1;
+------+------+
| c1   | c2   |
+------+------+
+------+------+

# alias, not SAMPLE SCAN
select /*+parallel(3)*/ * FROM empty_2 SAMPLE;
+------+------+
| c1   | c2   |
+------+------+
+------+------+

# sampling scope
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK ALL (3);
Query Plan
=================================================================
|ID|OPERATOR                     |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |PX COORDINATOR               |        |1       |2           |
|1 |└─EXCHANGE OUT DISTR         |:EX10000|1       |1           |
|2 |  └─PX BLOCK ITERATOR        |        |1       |1           |
|3 |    └─TABLE BLOCK SAMPLE SCAN|t1      |1       |1           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2)]), filter(nil), rowset=16
      dop=3
  2 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
