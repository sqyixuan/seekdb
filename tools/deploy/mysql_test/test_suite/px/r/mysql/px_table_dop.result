partition `p1`,
partition `p2`,
partition `p3`)
create table t2(c1 int primary key, c2 int) parallel 5 partition by hash(c1) partitions 4;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 PARALLEL 5
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
