result_format: 4
drop table if exists p1,p2,p3,p4,t1,t2;
## 分区表与非分区表对比
create table p1(c1 int primary key, c2 int) parallel 1;
show create table p1;
Table	Create Table
p1	CREATE TABLE `p1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
create table p2(c1 int primary key, c2 int) parallel 1 partition by hash(c1) partitions 4;
show create table p2;
Table	Create Table
p2	CREATE TABLE `p2` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
explain select * from p2;
