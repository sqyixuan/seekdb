set global parallel_servers_target = 40;
alter system set _max_px_workers_per_cpu = 20;
drop table if exists t1, t2;
create table t1(c1 bigint);
create table t2(c1 bigint, c2 bigint, c3 bigint, c4 varchar(65), c5 varchar(60)) partition by hash(c1) partitions 256;
create index i2 on t2(c3);
insert into t1 values(1);
explain basic select /*+parallel(20) + query_timeout(10000000000) use_plan_cache(none) leading(t1 t2) use_hash(t1 t2) PQ_DISTRIBUTE(t2 hash hash) px_part_join_filter(t2) no_px_join_filter(t2) index(t2 i2)*/ *, substr(t2.c1, 1, 2), substr(t2.c2, 3, 4) from t1 join t2 on t1.c1=t2.c1 where t2.c3 < regexp_like('aaaaaaaaaaaaaaaaa1', '^(a+)+$') + length(substr('a', 1, 1));
