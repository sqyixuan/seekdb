-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t2.c1, t2.c2, t2.c3, t2.c4, t2.c5, substr(cast(t2.c1, VARCHAR(1048576)), 1, 2), substr(cast(t2.c2, VARCHAR(1048576)),
       3, 4))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t2.c1, t2.c2, t2.c3, t2.c4, t2.c5, substr(cast(t2.c1, VARCHAR(1048576)), 1, 2), substr(cast(t2.c2, VARCHAR(1048576)),
       3, 4))]), filter(nil), rowset=16
      dop=20
