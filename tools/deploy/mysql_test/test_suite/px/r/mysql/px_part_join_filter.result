      is_index_back=true, is_global_index=false, 
      range_key([t2.c3], [t2.__pk_increment]), range(NULL,MAX ; 1,MIN), 
      range_cond([t2.c3 < regexp_like(cast('aaaaaaaaaaaaaaaaa1', VARCHAR(1048576)), cast('^(a+)+$', VARCHAR(1048576))) + length(substr('a', 1, 1))])
