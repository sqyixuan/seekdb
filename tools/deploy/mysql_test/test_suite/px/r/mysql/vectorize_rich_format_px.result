result_format: 4
drop database if exists db;
create database db;
use db;
set timestamp = 1600000000;
set _enable_rich_vector_format = true;
create table t0(c1 int, c2 int, c3 varchar(150), c4 datetime) partition by hash(c1) partitions 8;
create table t1(c1 int);
create table t2(c1 int, c2 int, c3 varchar(150), c4 datetime);

insert into t0 values(1, 1, substr(repeat(1, 50), 1, 150), now() + interval 1 day);
insert into t0 values(2, 2, substr(repeat(2, 50), 1, 150), now() + interval 2 day);
