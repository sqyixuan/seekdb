drop table if exists t0,t1;
DROP DATABASE IF EXISTS database46;
CREATE DATABASE database46;
USE database46;
CREATE TABLE t0(c0 FLOAT  PRIMARY KEY COMMENT 'asdf' )  PARTITION BY KEY (c0) partitions 15;
CREATE TABLE t1 LIKE t0;
CREATE UNIQUE INDEX i390 ON t0(c0) VISIBLE;
TRUNCATE TABLE t0;
UPDATE t0 SET c0= EXISTS (SELECT 1 from dual wHERE FALSE);
CREATE INDEX i410 ON t0(c0);
DELETE FROM t1;
DELETE FROM t0 WHERE (BIT_COUNT(BIT_COUNT(-1691812103))) AND ((-1691812103) || (((+ ((t0.c0) || (t0.c0)))) IS NOT TRUE));
ALTER TABLE t0 COMPRESSION 'NONE';
CREATE INDEX i710 ON t0(c0);
CREATE UNIQUE INDEX i759 ON t0(c0);

