drop table if exists t1,t2;

create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 13;
create table t2(c1 int primary key, c2 int) partition by hash(c1) partitions 13;

insert into t1 values(1,1),(13,13),(0,0),(4,4);
