explain basic SELECT /*+parallel(2) use_concat 
      FULL(@"SEL$13" "test.t1"@"SEL$13")
      FULL(@"SEL$15" "test.t1"@"SEL$15")
      FULL(@"SEL$14" "test.t1"@"SEL$14")
      FULL(@"SEL$16" "test.t1"@"SEL$16")*/ c1 FROM (SELECT c1, (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) AS c2 FROM t1) 
WHERE c2 <= (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) OR c1 = 561 ORDER BY 1;
