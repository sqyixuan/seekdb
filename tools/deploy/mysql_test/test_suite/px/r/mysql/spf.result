drop database if exists muhangtest;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create database muhangtest;
use muhangtest;
result_format: 4
create table t1(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table t3(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table t2(a int, b int, c int, d int, primary key (a), index idx_t2_bc (b,c) local) partition by hash(a) partitions 3;

explain select /*+NO_REWRITE*/ * from t1,t3 where t1.a = t3.a and exists (select /*+index(t2 idx_t2_bc)*/ 1 from t2 where t1.a = t2.a and t1.b = t2.b);
Query Plan
===========================================================================
|ID|OPERATOR                          |NAME         |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------
|0 |PX COORDINATOR                    |             |1       |61          |
|1 |└─EXCHANGE OUT DISTR              |:EX10000     |1       |61          |
|2 |  └─SUBPLAN FILTER                |             |1       |59          |
|3 |    ├─PX PARTITION ITERATOR       |             |1       |13          |
|4 |    │ └─MERGE JOIN                |             |1       |13          |
|5 |    │   ├─TABLE FULL SCAN         |t1           |1       |7           |
|6 |    │   └─TABLE FULL SCAN         |t3           |1       |7           |
|7 |    └─DISTRIBUTED TABLE RANGE SCAN|t2(idx_t2_bc)|1       |46          |
===========================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, t1.b, t1.c, t1.d, t3.a, t3.b, t3.c, t3.d)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.a, t1.b, t1.c, t1.d, t3.a, t3.b, t3.c, t3.d)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.a], [t1.b], [t3.a], [t1.c], [t1.d], [t3.b], [t3.c], [t3.d]), filter([(T_OP_EXISTS, subquery(1))]), rowset=16
      exec_params_([t1.a(:0)], [t1.b(:1)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=true
  3 - output([t1.a], [t1.b], [t3.a], [t1.c], [t1.d], [t3.b], [t3.c], [t3.d]), filter(nil), rowset=16
      partition wise, force partition granule
  4 - output([t1.a], [t1.b], [t3.a], [t1.c], [t1.d], [t3.b], [t3.c], [t3.d]), filter(nil), rowset=16
      equal_conds([t1.a = t3.a]), other_conds(nil)
      merge_directions([ASC])
  5 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      access([t1.a], [t1.b], [t1.c], [t1.d]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.a]), range(MIN ; MAX)always true
  6 - output([t3.a], [t3.b], [t3.c], [t3.d]), filter(nil), rowset=16
      access([t3.a], [t3.b], [t3.c], [t3.d]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t3.a]), range(MIN ; MAX)always true
  7 - output([1]), filter([:0 = t2.a]), rowset=16
      access([GROUP_ID], [t2.a]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.b], [t2.c], [t2.a]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true, 
      range_cond([:1 = t2.b])
select /*+NO_REWRITE*/ * from t1,t3 where t1.a = t3.a and exists (select /*+index(t2 idx_t2_bc)*/ 1 from t2 where t1.a = t2.a and t1.b = t2.b);
