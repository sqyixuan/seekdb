| a | b    | c    | d    | a | b    | c    | d    |
+---+------+------+------+---+------+------+------+
+---+------+------+------+---+------+------+------+

drop table t1;

CREATE TABLE t1 (c1 int, c2 varchar(67)) partition by hash(c1) partitions 3;
