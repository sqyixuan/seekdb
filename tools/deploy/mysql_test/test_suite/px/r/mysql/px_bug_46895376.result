DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ FROM j WHERE PK IN (SELECT PK FROM (SELECT DISTINCT MIN( OUTR . `col_int_key` ) AS X FROM C AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_int_key` < OUTR . `pk` ) WHERE ( OUTR . `col_int_key` , OUTR . `col_int_key` ) IN ( SELECT DISTINCT INNR . `col_int` AS X , INNR . `pk` AS Y FROM BB AS INNR WHERE INNR . `col_int` < INNR . `col_int` OR NOT OUTR . `pk` > 3  ) OR ( OUTR . `col_date` IS NOT NULL AND OUTR . `col_int_key` < 5 )  ORDER BY 1 ASC, OUTR . `pk` ASC , OUTR . `pk` ASC)TC1);
