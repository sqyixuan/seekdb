CREATE TABLE `st` (
`CUSTOMER_ID` bigint(20) NOT NULL,
`ID_SN` bigint(20) NOT NULL,
`ACCOUNT_ID` varbinary(20) NOT NULL,
`SECURITY_ACCOUNT_TYPE` char(2) CHARACTER SET gbk NOT NULL,
`SECURITY_ACCOUNT_ID` varbinary(20) NOT NULL,
`BRANCH_CODE` char(2) CHARACTER SET gbk NOT NULL,
`EXCHANGE_ID` char(1) CHARACTER SET gbk NOT NULL,
`PBU` varbinary(8) NOT NULL,
`AGENT_ID` char(6) CHARACTER SET gbk NOT NULL,
`BRANCH_ID` char(10) CHARACTER SET gbk NOT NULL,
`DCL_DATE` int(11) NOT NULL,
`CANCEL_DATE` decimal(11,0) NOT NULL,
`CLOSE_DATE` int(11) NOT NULL DEFAULT '0'
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
insert into CUSTOMER values(100000000000, 0, 1, 20151212, 190001, 1900010001, 0, 190001, 1900010001, '');
insert into CUSTOMER values(100000000001, 0, 1, 20140101, 100001, 1000010001, 0, '', '', '');
insert into CUSTOMER values(100000000002, 0, 1, 20140202, 100002, 1000020001, 0, '', '', '');
insert into CUSTOMER values(100000000003, 0, 0, 20140303, 100003, 1000030001, 0, '', '', '');
insert into CUSTOMER values(100000000004, 0, 0, 20140404, 100004, 1000040001, 0, '', '', '');
insert into CUSTOMER values(100000000005, 0, 0, 20140505, 100005, 1000050001, 0, '', '', '');
insert into CUSTOMER values(100000000006, 0, 0, 20140606, 100006, 1000060001, 0, '', '', '');
insert into CUSTOMER values(100000000007, 0, 1, 20140707, 100007, 1000070001, 0, 100007, 1000070001, '');
insert into CUSTOMER values(100000000008, 0, 0, 20140808, 100008, 1000080001, 0, '', '', '');
insert into CUSTOMER values(100000000009, 0, 0, 20140909, 100009, 1000090001, 0, '', '', '');
insert into CUSTOMER values(100000000010, 0, 0, 20140910, 100010, 1000090001, 0, '', '', '');
INSERT   /*+ parallel(5)  enable_parallel_dml */ INTO
st (CUSTOMER_ID,ID_SN,ACCOUNT_ID,SECURITY_ACCOUNT_TYPE,SECURITY_ACCOUNT_ID,BRANCH_CODE,EXCHANGE_ID,PBU,AGENT_ID,BRANCH_ID,DCL_DATE,CANCEL_DATE,CLOSE_DATE)
SELECT A.CUSTOMER_ID, A.CUSTOMER_ID, 80000000000 + A.CUSTOMER_ID AS YMTH, '21', CONCAT(REPEAT('0',10-LENGTH(A.CUSTOMER_ID-100000000000 )),A.CUSTOMER_ID-100000000000 ) AS ZQZH,
'BJ',2,200500, A.OPEN_AGENT_ID, A.OPEN_BRANCH_ID, A.OPEN_DATE, A.CLOSE_DATE, A.CLOSE_DATE
FROM CUSTOMER A WHERE A.CUSTOMER_TYPE='0' AND A.CUSTOMER_ID BETWEEN 100000000000 AND 100000000019 order by a.CUSTOMER_ID;
select * from st order by 1;
