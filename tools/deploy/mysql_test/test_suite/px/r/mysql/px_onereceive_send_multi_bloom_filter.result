result_format: 4
drop table if exists t1, t2,t3;
create table t1 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C5_RAND) partitions 5;
create table t2 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C5_RAND) partitions 5;
create table t3 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C5_RAND) partitions 5;
insert into t1 values(0,0,0,0,0);
insert into t1 values(1,1,1,1,1);
insert into t1 values(2,2,2,2,2);
insert into t1 values(3,3,3,3,3);
insert into t1 values(4,4,4,4,4);
insert into t1 values(5,5,5,5,5);
insert into t1 values(6,6,6,6,6);
insert into t1 values(7,7,7,7,7);
insert into t2 values(1,2,3,4,5);
insert into t2 values(2,3,4,5,6);
insert into t2 values(3,4,5,6,7);
insert into t2 values(7,6,5,4,3);
insert into t2 values(6,5,4,3,2);
insert into t2 select * from t1;
insert into t1 values(1,2,3,4,5);
insert into t2 values(2,3,4,5,6);
insert into t1 select * from t2;
insert into t3 select * from t2;
insert into t3 select * from t1;

explain basic select /*+ leading(a (b  c)) parallel(3) use_hash(b) use_hash(c) pq_distribute(c hash hash) px_join_filter(c a)  px_join_filter(c b) */ count(*) from t1 a, t2 b, t3 c where a.C1_RAND=b.C1_RAND and a.C2_RAND = c.C2_RAND and b.C3_RAND = c.C3_RAND;
