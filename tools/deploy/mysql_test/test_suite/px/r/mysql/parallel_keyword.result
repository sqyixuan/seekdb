result_format: 4

## 以parallel作为列名
drop table if exists t1,t2,t3;

create table t1(parallel int);
create table t2(parallel int) parallel 4;
create table t3(parallel int) noparallel;

insert into t1 values (1);
insert into t2 values (2);
insert into t3 values (3);

update t1 set parallel=10 where parallel=1;
update t2 set parallel=20 where parallel=2;
update t3 set parallel=30 where parallel=3;

select parallel from t1;
+----------+
| parallel |
+----------+
|       10 |
+----------+

select /*+ parallel(4) */ parallel from t2;
+----------+
| parallel |
+----------+
|       20 |
+----------+

select /*+ noparallel */ parallel from t3;
+----------+
| parallel |
+----------+
|       30 |
+----------+

explain basic select /*+ no_parallel */ parallel from t3;
Query Plan
=========================
|ID|OPERATOR       |NAME|
-------------------------
|0 |TABLE FULL SCAN|t3  |
=========================
Outputs & filters:
-------------------------------------
  0 - output([t3.parallel]), filter(nil), rowset=16
      access([t3.parallel]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true
set _force_parallel_query_dop = 4;
explain basic select parallel from t3;
Query Plan
===================================
|ID|OPERATOR             |NAME    |
-----------------------------------
|0 |PX COORDINATOR       |        |
|1 |└─EXCHANGE OUT DISTR |:EX10000|
|2 |  └─PX BLOCK ITERATOR|        |
|3 |    └─TABLE FULL SCAN|t3      |
===================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t3.parallel)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t3.parallel)]), filter(nil), rowset=16
      dop=4
  2 - output([t3.parallel]), filter(nil), rowset=16
  3 - output([t3.parallel]), filter(nil), rowset=16
      access([t3.parallel]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true
explain basic select /*+ parallel(4) */ parallel from t3;
Query Plan
===================================
|ID|OPERATOR             |NAME    |
-----------------------------------
|0 |PX COORDINATOR       |        |
|1 |└─EXCHANGE OUT DISTR |:EX10000|
|2 |  └─PX BLOCK ITERATOR|        |
|3 |    └─TABLE FULL SCAN|t3      |
===================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t3.parallel)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t3.parallel)]), filter(nil), rowset=16
      dop=4
  2 - output([t3.parallel]), filter(nil), rowset=16
  3 - output([t3.parallel]), filter(nil), rowset=16
      access([t3.parallel]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true
explain basic select /*+ no_parallel */ parallel from t3;
Query Plan
=========================
|ID|OPERATOR       |NAME|
-------------------------
|0 |TABLE FULL SCAN|t3  |
=========================
Outputs & filters:
-------------------------------------
  0 - output([t3.parallel]), filter(nil), rowset=16
      access([t3.parallel]), partitions(p0)
      is_index_back=false, is_global_index=false, 
