drop table if exists LINEITEM;
CREATE TABLE lineitem (
l_orderkey BIGINT NOT NULL,
l_partkey BIGINT NOT NULL,
l_suppkey INTEGER NOT NULL,
l_linenumber INTEGER NOT NULL,
l_comment varchar(44) DEFAULT NULL,
primary key(l_orderkey, l_linenumber)
)row_format = condensed
partition by key (l_orderkey) partitions 10;
alter system set_tp tp_name = ERRSIM_INTERRUPT_QC_FAILED, error_code = 4016, frequency = 1;
alter system set_tp tp_name = ERRSIM_DYNAMIC_SAMPLE_FAIL, error_code = 4016, frequency = 1;
alter system set_tp tp_no = 617, error_code = 4016, frequency = 1;
create/*+parallel(4) */ index i1 on lineitem(l_comment, l_orderkey, l_linenumber);
