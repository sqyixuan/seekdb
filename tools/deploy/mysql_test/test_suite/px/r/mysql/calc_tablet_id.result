## 一级分区固定。
drop table t1;
create table t1(c1 int, c2 int) partition by key(c2) subpartition by range(c1)
subpartition template
(
  subpartition `p0` values less than (10),
  subpartition `p1` values less than (30),
  subpartition `p2` values less than (100),
  subpartition `p3` values less than (150),
  subpartition `p4` values less than (200),
  subpartition `p5` values less than (250),
  subpartition `p6` values less than (300)
)
partitions 8;

insert into t1 values(1, 2), (2, 4), (3, 6), (4, 8), (5, 10), (6, 12), (7, 14), (8, 16), (9, 18);
insert into t1 select c1 + 9, c2 + 18 from t1;
insert into t1 select c1 + 18, c2 + 36 from t1;
insert into t1 select c1 + 36, c2 + 72 from t1;
insert into t1 select c1 + 72, c2 + 144 from t1;
insert into t1 select c1 + 144, c2 + 288 from t1;
当join condition只覆盖一级分区键时可以生成join filter，只覆盖二级分区键时不会生成，因此不存在共享。
explain select /*+ leading(a b) use_hash(b) parallel(2) px_part_join_filter(b a) pq_distribute(b partition none) */ * from t1 a, t1 b where a.c2 = b.c1 and b.c1 > 10 and b.c2 = 100;
Query Plan
