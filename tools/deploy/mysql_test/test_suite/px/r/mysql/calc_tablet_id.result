## 二级分区固定。
### 二级分区数 = 1
drop table t1;
create table t1(c1 int, c2 int) partition by range(c1) subpartition by key(c2) subpartition template (subpartition `p0`)
(partition `p0` values less than (10),
partition `p1` values less than (30),
partition `p2` values less than (100),
partition `p3` values less than (150),
partition `p4` values less than (200),
partition `p5` values less than (250),
partition `p6` values less than (300));

insert into t1 values(1, 2), (2, 4), (3, 6), (4, 8), (5, 10), (6, 12), (7, 14), (8, 16), (9, 18);
insert into t1 select c1 + 9, c2 + 18 from t1;
insert into t1 select c1 + 18, c2 + 36 from t1;
insert into t1 select c1 + 36, c2 + 72 from t1;
insert into t1 select c1 + 72, c2 + 144 from t1;
insert into t1 select c1 + 144, c2 + 288 from t1;
可以共享，transmit和join filter都是CALC_IGNORE_SUB_PART。
explain basic select /*+ leading(a b) use_hash(b) parallel(2) px_part_join_filter(b a) pq_distribute(b partition none) */ count(*) from t1 a, t1 b where a.c2 = b.c1 and b.c1 > 10;
