      dop=2
  2 - output([a.c2], [b.c1], [a.c1], [b.c2]), filter(nil), rowset=256
      equal_conds([a.c2 = b.c1]), other_conds(nil)
  3 - output([a.c2], [a.c1]), filter(nil), rowset=256
  4 - output([a.c2], [a.c1]), filter(nil), rowset=256
      (#keys=1, [a.c2]), dop=2
  5 - output([a.c2], [a.c1]), filter(nil), rowset=256
  6 - output([a.c2], [a.c1]), filter([a.c2 > 10]), rowset=256
      access([a.c2], [a.c1]), partitions(p0sp[0-6], p1sp[0-6], p2sp[0-6], p3sp[0-6], p4sp[0-6], p5sp[0-6], p6sp[0-6], p7sp[0-6])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([a.__pk_increment]), range(MIN ; MAX)always true
  7 - output([b.c2], [b.c1]), filter(nil), rowset=256
      affinitize
  8 - output([b.c2], [b.c1]), filter([b.c2 = 100], [b.c1 > 10]), rowset=256
      access([b.c2], [b.c1]), partitions(p0sp[1-6])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([b.__pk_increment]), range(MIN ; MAX)always true
