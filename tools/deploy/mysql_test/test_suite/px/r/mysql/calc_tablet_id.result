-------------------------------------
  0 - output([INTERNAL_FUNCTION(a.c1, a.c2, b.c1, b.c2)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(a.c1, a.c2, b.c1, b.c2)]), filter(nil), rowset=256
      dop=2
  2 - output([a.c2], [b.c1], [a.c1], [b.c2]), filter(nil), rowset=256
      equal_conds([a.c2 = b.c1]), other_conds(nil)
  3 - output([a.c2], [a.c1]), filter(nil), rowset=256
      RF_TYPE(bloom), RF_EXPR[calc_tablet_id(a.c2, 1)]
