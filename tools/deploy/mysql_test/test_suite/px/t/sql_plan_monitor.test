#owner: dachuan.sdc
#owner group: SQL2
# tags: optimizer, px
# test real time sql plan monitor

--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.gv$sql_plan_monitor;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.gv$sql_plan_monitor where request_id = 0;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.gv$sql_plan_monitor where request_id < 0;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.gv$sql_plan_monitor where request_id > 0;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.v$sql_plan_monitor;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.v$sql_plan_monitor where request_id = 0;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.v$sql_plan_monitor where request_id < 0;
--replace_regex /[0-9]+/YISHEN/
select count(*) from oceanbase.v$sql_plan_monitor where request_id > 0;

--replace_regex /[0-9]+/YISHEN/
select /*+ monitor*/plan_line_id from oceanbase.gv$sql_plan_monitor  where request_id < 0 limit 1;
--replace_regex /[0-9]+/YISHEN/
select plan_line_id from oceanbase.gv$sql_plan_monitor limit 1;
--replace_regex /[0-9]+/YISHEN/
select plan_line_id from oceanbase.gv$sql_plan_monitor  where request_id >= 0 limit 1;

# test real_time db_time and tsc info
connection default;
set ob_query_timeout = 10000000000;
--disable_warnings
drop table if exists llc6;
--enable_warnings
create table llc6(id INT auto_increment PRIMARY key,c1 int, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int,c9 int,c10 int,c11 int,c12 int,c13 int,c14 int)partition by hash (id) partitions 5;
--disable_warnings
drop sequence if exists s1;
--enable_warnings
create sequence s1 cache 3000000;
insert /*+ parallel(16) */ into llc6 select null,s1.nextval,abs(random(1)) % 2 + 1, abs(random(1)) % 50000 + 1,abs(random(1)) % 500000+1, abs(random(1)) % 1000000+1,abs(random(1)) % 3000000+1,s1.nextval,abs(random(1)) % 2+1,s1.nextval,s1.nextval,s1.nextval,s1.nextval,s1.nextval,null from table(generator(3000000));
select count(*) from llc6;
send select /*+monitor*/ max(c1+c2+c3+c4+c5+c6+c7+c9+c10+c11+c12+c13+c14) from llc6;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;

let $db_time_1 = query_get_value(select db_time from oceanbase.__all_virtual_sql_plan_monitor where TRACE_ID = (select trace_id from oceanbase.__all_virtual_processlist where sql_id = "D2DF3FF615B846DC596F08C9E1521800") and PLAN_OPERATION = "PHY_VEC_TABLE_SCAN", db_time, 1);
let $row_cnt_1 = query_get_value(select (OTHERSTAT_3_VALUE + OTHERSTAT_4_VALUE) as row_cnt from  oceanbase.__all_virtual_sql_plan_monitor where TRACE_ID = (select trace_id from oceanbase.__all_virtual_processlist where sql_id = "D2DF3FF615B846DC596F08C9E1521800") and PLAN_OPERATION = "PHY_VEC_TABLE_SCAN", row_cnt, 1);
if($db_time_1 <= 0)
{
  --echo "db_time error"
}
if($row_cnt_1 <= 0)
{
  --echo "row_cnt error"
}

sleep 1;

let $db_time_2 = query_get_value(select db_time from oceanbase.__all_virtual_sql_plan_monitor where TRACE_ID = (select trace_id from oceanbase.__all_virtual_processlist where sql_id = "D2DF3FF615B846DC596F08C9E1521800") and PLAN_OPERATION = "PHY_VEC_TABLE_SCAN", db_time, 1);
let $row_cnt_2 = query_get_value(select (OTHERSTAT_3_VALUE + OTHERSTAT_4_VALUE) as row_cnt from  oceanbase.__all_virtual_sql_plan_monitor where TRACE_ID = (select trace_id from oceanbase.__all_virtual_processlist where sql_id = "D2DF3FF615B846DC596F08C9E1521800") and PLAN_OPERATION = "PHY_VEC_TABLE_SCAN", row_cnt, 1);
if($db_time_2 <= 0)
{
  --echo "db_time error"
}
if($db_time_2 < $db_time_1)
{
  --echo "db_time error"
}
if($row_cnt_2 <= 0)
{
  --echo "row_cnt error"
}
if($row_cnt_2 < $row_cnt_1)
{
  --echo "row_cnt error"
}

connection default;
reap;
drop table if exists llc6;
