--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: peihan.dph
#owner group: sql3
# tags: optimizer

--disable_warnings
drop database if exists wlzpxtest;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t3;
create database wlzpxtest;
use wlzpxtest;
--enable_warnings

--result_format 4
set ob_enable_plan_cache = false;


create table t1(c1 bigint,c2 bigint,c3 bigint,c4 bigint);
insert into t1 values(1,2,3,4);
insert into t1 select c1+1,c2+1,c3+1,c4+1 from t1;
insert into t1 select c1+10,c2+10,c3+1,c4+1 from t1;
insert into t1 select c1+100,c2+100,c3+1,c4+1 from t1;
insert into t1 select c1+1000,c2+1000,c3+1,c4+1 from t1;
insert into t1 select c1+10000,c2+10000,c3+1,c4+1 from t1;
insert into t1 select c1+100000,c2+100000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000,c2+1000000,c3+1,c4+1 from t1;
insert into t1 select c1+10000000,c2+10000000,c3+1,c4+1 from t1;
insert into t1 select c1+100000000,c2+100000000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000000,c2+1000000000,c3+1,c4+1 from t1;
insert into t1 select c1+10000000000,c2+10000000000,c3+1,c4+1 from t1;
insert into t1 select c1+100000000000,c2+100000000000,c3+1,c4+1 from t1;
insert into t1 select c1+1000000000000,c2+1000000000000,c3+1,c4+1 from t1;
select count(*) from t1;


create table t2(c1 bigint,c2 bigint,c3 bigint,c4 bigint) partition by hash (c1) partitions 10;
insert into t2 select * from t1;

create table t3(c1 bigint,c2 bigint,c3 bigint,c4 bigint) partition by hash (c1) partitions 10;
insert into t3 select * from t1;

##test only block gi
explain select /*+ no_place_group_by use_px parallel(2)*/sum(d1) from (select count(*) as d1 from t1 a, t1 b where a.c1=b.c2 group by a.c2) order by 1;
select /*+ no_place_group_by use_px parallel(2)*/sum(d1) from (select count(*) as d1 from t1 a, t1 b where a.c1=b.c2 group by a.c2) order by 1;

## test hash join: none-broadcast
explain select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(2) PQ_DISTRIBUTE(c none Broadcast) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(2) PQ_DISTRIBUTE(c none Broadcast) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;

##test hash join: hash-hash
explain select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c HASH HASH) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c HASH HASH) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;

##test hash join: broadcast-none
explain select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) */count(*) from t1 a, t1 b,t1 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;

##test hash join: none-pk
explain select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) PQ_DISTRIBUTE(b NONE PARTITION) */count(*) from t2 a, t2 b,t2 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(a,b,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) PQ_DISTRIBUTE(b NONE PARTITION) */count(*) from t2 a, t2 b,t2 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;

##test hash join: pk-none
explain select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) PQ_DISTRIBUTE(b PARTITION NONE) */count(*) from t2 a, t2 b,t2 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(3) PQ_DISTRIBUTE(c Broadcast none) PQ_DISTRIBUTE(b PARTITION NONE) */count(*) from t2 a, t2 b,t2 c where a.c1=b.c2 and a.c2=c.c3 group by a.c2 order by 1;

##test hash join: partition-wise
explain select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(3) */count(*) from t2 a, t3 b where a.c1=b.c1 order by 1;
select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(3) */count(*) from t2 a, t3 b where a.c1=b.c1 order by 1;

##test hash join: hash hash
explain select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(4) PQ_DISTRIBUTE(b HASH HASH) */count(*) from t2 a, t3 b where a.c1=b.c1 order by 1;
select /*+ no_place_group_by leading(b,a,c) use_hash(a,b,c) use_px parallel(4) PQ_DISTRIBUTE(b HASH HASH) */count(*) from t2 a, t3 b where a.c1=b.c1 order by 1;

##test hash join:hybrid
explain select /*+ no_place_group_by leading(a,c,b) use_px parallel(3) use_hash(a c) PQ_DISTRIBUTE(c NONE PARTITION) */count(*) from t2 a, t3 b,t2 c where a.c1=b.c1 and a.c1=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(a,c,b) use_px parallel(3) use_hash(a c) PQ_DISTRIBUTE(c NONE PARTITION) */count(*) from t2 a, t3 b,t2 c where a.c1=b.c1 and a.c1=c.c3 group by a.c2 order by 1;

##test hash join:hybrid
explain select /*+ no_place_group_by leading(c,a,b) use_px parallel(3) use_hash(a c) PQ_DISTRIBUTE(a NONE PARTITION) */count(*) from t2 a, t3 b,t2 c where a.c1=b.c1 and a.c1=c.c3 group by a.c2 order by 1;
select /*+ no_place_group_by leading(c,a,b) use_px parallel(3) use_hash(a c) PQ_DISTRIBUTE(a NONE PARTITION) */count(*) from t2 a, t3 b,t2 c where a.c1=b.c1 and a.c1=c.c3 group by a.c2 order by 1;

--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t3;
drop database if exists wlzpxtest;
--enable_warnings

