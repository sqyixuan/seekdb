select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (80) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (99) SEED (23333);

--echo # incremental data
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE INCR (3) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (3) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE INCR (10) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (10) SEED (23333);
