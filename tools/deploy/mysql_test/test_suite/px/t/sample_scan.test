EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (10) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (10) SEED (23333);
