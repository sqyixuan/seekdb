EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK BASE (20) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (20) SEED (23333);

# sample
select /*+parallel(3)*/ * FROM empty_1 SAMPLE (3);

# sample block
select /*+parallel(3)*/ * FROM empty_1 SAMPLE BLOCK (3);

# sample with seed
select /*+parallel(3)*/ * FROM empty_2 SAMPLE (3) SEED(12345);

# sample with seed
select /*+parallel(3)*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345);

# sample with multi-tables; 
select /*+parallel(3)*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345), empty_2;

# sample with multi-tables; 
select /*+parallel(3)*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345), empty_2 SAMPLE BLOCK (6.66) SEED(45678);

select /*+parallel(3)*/ COUNT(*) FROM t1 SAMPLE (0.000001) SEED(23);
select /*+parallel(3)*/ * FROM t1 SAMPLE (0.000001) SEED(23);
select /*+parallel(3)*/ COUNT(*) FROM t1 SAMPLE (3.1415926) SEED(233);
select /*+parallel(3)*/ * FROM t1 SAMPLE (3.1415926) SEED(233);
select /*+parallel(3)*/ COUNT(*) FROM t1 SAMPLE (10) SEED(2333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (10) SEED(2333);
select /*+parallel(3)*/ COUNT(*) FROM t1 SAMPLE (99) SEED(23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (99) SEED(23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (40) SEED(2333) join t1 SAMPLE (20) SEED(2233) t2 where t1.c1 = t2.c1;

select /*+parallel(3)*/ COUNT(*) FROM t1 SAMPLE (0.4) SEED(12345);
select /*+parallel(3)*/ * FROM t1 SAMPLE (0.4) SEED(12345);
select /*+parallel(3)*/ * FROM t1 SAMPLE (0.4) SEED(12345);

--error 0,600
create table t2(c1 int, c2 int, primary key(c1)) partition by hash(c1) partitions 8;
--let $count=1
while($count < 5)
{
    --let $stmt=INSERT INTO t2 VALUES($count, 3)
    eval $stmt;
    inc $count; 
}
--let $count=5
while($count < 5)
{
    --let $stmt=INSERT INTO t2 VALUES($count, 2)
    eval $stmt;
    inc $count; 
}
--sleep 1

select /*+parallel(3)*/ * FROM empty_1;

--echo # alias, not SAMPLE SCAN
select /*+parallel(3)*/ * FROM empty_2 SAMPLE;

