--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# tags: optimizer

--result_format 4
# description: 验证采样算子的功能

--disable_warnings
DROP DATABASE IF EXISTS SAMPLE_SCAN;
--enable_warnings
CREATE DATABASE SAMPLE_SCAN;
USE SAMPLE_SCAN;

# these tables are used to test syntax.
create table empty_1 (c1 int, c2 int);
create table empty_2 (c1 int, c2 int);

# t1 is a 10000-row table, 5000 in memtable, 5000 in sstable
create table t1(c1 int, c2 int);
--disable_query_log
--disable_result_log

--let $count=1
while($count < 5)
{
    --let $stmt=INSERT INTO t1 VALUES($count, 3)
    eval $stmt;
    inc $count; 
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--let $count=5

while($count < 5)
{
    --let $stmt=INSERT INTO t1 VALUES($count, 2)
    eval $stmt;
    inc $count; 
}

select /*+parallel(3)*/ * FROM empty_1;

--echo # alias, not SAMPLE SCAN
select /*+parallel(3)*/ * FROM empty_2 SAMPLE;

--echo # sampling scope
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK ALL (3);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK BASE (3);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK INCR (3);

--echo # table alias, not sampling scope
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) BASE;
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) INCR;
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) whatever;

--echo # valid percentage: [0.000001, 100)
--error 5730
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (100);

--error 5730
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (0.0000002);

EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE (3) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (3) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE (10) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE (10) SEED (23333);
