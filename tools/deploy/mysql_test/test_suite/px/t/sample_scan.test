select /*+parallel(3)*/ * FROM t1 SAMPLE (20) SEED (23333);

EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK INCR (3) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (3) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK INCR (10) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (10) SEED (23333);
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK INCR (20) SEED (23333);
select /*+parallel(3)*/ * FROM t1 SAMPLE BLOCK (20) SEED (23333);

--echo # incremental data
EXPLAIN select /*+parallel(3)*/ * FROM t1 SAMPLE BASE (3) SEED (23333);
