#owner: zhouhaiyu.zhy
#owner group: sql2
# tags: optimizer,px

alter system set _px_join_skew_handling = true;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

CREATE TABLE t1 (
  c1 int(11) NOT NULL,
  c2 int(11) DEFAULT NULL,
  c3 int(11) DEFAULT NULL,
  PRIMARY KEY (c1)
);
INSERT INTO t1 VALUES (1,1,1),(2,2,21652899),(3,3,82781450),(4,4,4),(6,1,81211997),(7,2,7),(8,2,8),(9,40,9),(10,40,10),(11,2,11),(13,13,63805351),(14,2,14),(15,16,56371630),(16,1,16),(17,2,17),(18,16,18),(19,16,9773903),(20,2,71345857),(21,1,21),(23,2,70650990),(25,16,19619102),(26,2,26),(27,2,27),(28,16,28),(29,2,29),(30,16,91098277),(31,1,31),(32,2,32),(33,33,33),(34,34,34),(36,1,36),(37,2,37),(38,2,38),(39,39,39),(40,40,40),(41,2,41),(42,2,42),(43,40,43),(44,2,44),(45,40,45),(46,1,46),(47,2,47),(48,40,38095870),(50,2,50),(9980403,12,12),(17754290,2,24),(36197655,35,35),(38955189,40,49),(56379532,2,5),(90571519,16,22);

CREATE TABLE t2 (
  c1 int(11) NOT NULL,
  c2 int(11) DEFAULT NULL,
  c3 double DEFAULT NULL,
  PRIMARY KEY (c1)
);

INSERT INTO t2 VALUES (1,1,0.01),(2,2,0.461909273833),(3,3,0.03),(4,4,0.04),(6,1,0.06),(7,7,0.07),(8,2,0.08),(10,75706738,35.9944953877),(11,1,0.11),(13,13,43.9179005477),(14,2,0.14),(15,98549452,0.15),(16,1,88.888186619),(17,2,0.17),(19,60221010,0.708370224646),(20,2,0.2),(21,1,65.1480280353),(22,22,0.22),(24,58620277,0.24),(25,14713917,56.1019545291),(29,2,0.29),(30,30,0.3),(32,2,0.551832306256),(33,80677363,0.33),(35,2,0.33972205578),(36,1,0.36),(37,37,0.37),(38,2,0.316822481917),(39,39,0.39),(40,40,30.4840564867),(41,1,0.41),(42,42,0.42),(43,43,19.1296647653),(44,2,0.747861783272),(45,47782101,0.45),(47,2,0.685034605476),(48,48,0.48),(49,49,0.49),(50,2,0.5),(13444799,2,0.31),(19762771,1,0.05),(33200402,2,0.34),(33521358,23,0.23),(37380846,1,0.28),(42152375,2,0.12),(69142282,26,0.26),(71588883,9,86.0661378641),(83663222,2,0.46),(84494753,2,0.18),(96702061,1,0.27);


call dbms_stats.gather_table_stats('test', 't2', method_opt=>'for all columns size 100');
--sleep 3

alter system set _px_join_skew_minfreq = 10;
--sleep 6
explain basic select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
--sorted_result
select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
explain basic select /*+  parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
--sorted_result
select /*+  parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
--sorted_result
select * from t1, t2 where t1.c2 = t2.c2;


## check stat change
update t2 set c2 = 40;
call dbms_stats.gather_table_stats('test', 't2', method_opt=>'for all columns size 100');
--sleep 3
explain basic select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
--sorted_result
select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;


alter system set _px_join_skew_handling = false;
--sleep 5
explain basic select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;

update t2 set c2 = 20 limit 10;
call dbms_stats.gather_table_stats('test', 't2', method_opt=>'for all columns size 100');
alter system set _px_join_skew_handling = true;
alter system set _px_join_skew_minfreq = 50;
--sleep 6
explain basic select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;

alter system set _px_join_skew_minfreq = 10;
--sleep 6
explain basic select /*+ leading(t1, t2) use_hash(t2) pq_distribute(t2 hash hash) parallel(2) */* from t1, t2 where t1.c2 = t2.c2;
