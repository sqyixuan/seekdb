# desc: test adaptive gi resplit task

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
--enable_warnings

create table t1(c1 bigint) partition by hash(c1) partitions 64;
create table t2(c1 bigint);
insert into t1 values(10);
explain basic select /*+parallel(2) leading(t1 t2) use_nl(t2) pq_distribute(t2 none broadcast) query_timeout(10000000000)*/ * from t1 join t2 on t1.c1=t2.c1;
select /*+parallel(2) leading(t1 t2) use_nl(t2) pq_distribute(t2 none broadcast) query_timeout(10000000000)*/ * from t1 join t2 on t1.c1=t2.c1;

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
drop table if exists t1_colt;
--enable_warnings
alter system set _enable_px_task_rebalance='True';
alter system set _px_task_rebalance_trigger_time='1us';

create table t1_colt(pk1 bigint auto_increment, pk2 bigint, `dt` date DEFAULT NULL, name varchar(64), PRIMARY KEY (pk1, pk2)) with column group(each column);
