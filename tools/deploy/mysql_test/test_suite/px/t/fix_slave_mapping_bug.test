# owner: xf375358
# owner group: opensource

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
alter system set_tp tp_no = 2211, error_code = 4019, frequency = 1;
connection default;
--enable_query_log

--disable_warnings
drop table if exists truncate_partition_case1_t_1_inner;
drop table if exists truncate_partition_case1_t_2_inner;
--enable_warnings

create table truncate_partition_case1_t_1_inner(id int, c1 int, c2 int, c3 int);
create table truncate_partition_case1_t_2_inner(id int, c1 int, c2 int, c3 int) partition by range(c1)  (partition p0 values less than (0), partition p2 values less than (MAXVALUE));

insert into truncate_partition_case1_t_1_inner (id, c1, c2, c3) values(102, -1, 1, 1), (202, -2, 2, 2), (302, -3, 3, 3), (402, -4, 4, 4);
insert/*+parallel(2) enable_parallel_dml*/ into truncate_partition_case1_t_2_inner (id, c1, c2, c3) select id, c1, c2, c3 from truncate_partition_case1_t_1_inner ;

--disable_warnings
drop table truncate_partition_case1_t_1_inner;
drop table truncate_partition_case1_t_2_inner;
--enable_warnings

--disable_query_log
connection sys;
alter system set_tp tp_no = 2211, error_code = 4019, frequency = 0;
alter tenant sys set primary_zone = 'RANDOM';
sleep 2;
connection default;
--enable_query_log

--disable_warnings
drop table if exists f;
drop table if exists c;
--enable_warnings

CREATE TABLE `f` (
  `col_int_key` int(11) DEFAULT NULL,
  `pk` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(pk,col_int_key)
(partition `p0`,
partition `p1`,
partition `p2`);

CREATE TABLE `c` (
  `pk` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(pk)
(partition `p0`,
partition `p1`,
partition `p2`);

explain basic select pk from F union all select /*+leading(f) pq_distribute(v bc2host none)*/V.pk from F,  (select /*+pq_distinct(hash_local) parallel(12) dynamic_sampling(0)*/distinct pk from C )V where F.pk = V.pk;
select pk from F union all select /*+leading(f) pq_distribute(v bc2host none)*/V.pk from F,  (select /*+pq_distinct(hash_local) parallel(12) dynamic_sampling(0)*/distinct pk from C )V where F.pk = V.pk;
drop table if exists f;
drop table if exists c;

--disable_query_log
connection sys;
alter tenant sys set primary_zone = 'z1';
sleep 2;
connection default;
--enable_query_log

--disable_warnings
drop table if exists table_pwj;
--enable_warnings
CREATE TABLE `table_pwj` (
  `col_double` double DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_double_unique_index` double DEFAULT NULL,
  `col_double_index` double DEFAULT NULL,
  PRIMARY KEY (`pk`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(pk)
(partition `p1` values less than (50),
partition `p2` values less than (100),
partition `p3` values less than (MAXVALUE));

explain basic update
/*+
    USE_CONCAT(@"UPD$1" 't1.pk >= ? AND t2.col_double < cast(?, DOUBLE(-1, -1)) OR t1.pk <= ?')
    LEADING(@"SEL$1B40D483" ("t2"@"SEL$40AE581C_2" "t1"@"SEL$40AE581C_2"))
    USE_MERGE(@"SEL$1B40D483" "t1"@"SEL$40AE581C_2")
    PQ_DISTRIBUTE(@"SEL$1B40D483" "t1"@"SEL$40AE581C_2" HASH_LOCAL HASH_LOCAL)
*/
table_pwj t1 left join table_pwj t2 on t1.pk = t2.pk 
SET t1.col_double_index = 8283.7504, t1.col_double_unique_index = 775946.24 where t1.pk >= 37 and t2.col_double < 8283.7504 or t1.pk <= 79;

update
/*+
    USE_CONCAT(@"UPD$1" 't1.pk >= ? AND t2.col_double < cast(?, DOUBLE(-1, -1)) OR t1.pk <= ?')
    LEADING(@"SEL$1B40D483" ("t2"@"SEL$40AE581C_2" "t1"@"SEL$40AE581C_2"))
    USE_MERGE(@"SEL$1B40D483" "t1"@"SEL$40AE581C_2")
    PQ_DISTRIBUTE(@"SEL$1B40D483" "t1"@"SEL$40AE581C_2" HASH_LOCAL HASH_LOCAL)
*/
table_pwj t1 left join table_pwj t2 on t1.pk = t2.pk 
SET t1.col_double_index = 8283.7504, t1.col_double_unique_index = 775946.24 where t1.pk >= 37 and t2.col_double < 8283.7504 or t1.pk <= 79;
drop table if exists table_pwj;


