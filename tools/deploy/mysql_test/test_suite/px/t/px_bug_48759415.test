--result_format 4
--disable_warnings
drop table if exists t11,t7;


create table t11(c1 decimal(64,0), c2 decimal(64,27) primary key, c10 varchar(86)) partition by key(c2) (partition p0, partition p1, partition p2, partition p3, partition p4, partition p5, partition p6, partition p7, partition p8, partition p9);

create table t7(c1 int(127), c2 decimal(64,28), c10 varchar(86) primary key) partition by key(c10) (partition p0, partition p1, partition p2, partition p3, partition p4, partition p5, partition p6, partition p7, partition p8, partition p9);
insert into t11 values(1,1, 'YxnPXFLbyrEyACz001');
insert into t11 values(2,2, 'CYov002');
insert into t11 values(3,3, 'ztHyZdZHHjbTQiddDiYFuHNUHORgcdSGHKeZOKEiFllbBCQqehtImvZLDWrrzyGAfGMoXGaTfCDIrg003');


insert into t7 select * from t11;

create index i_1_yRG on t11(c1, c10) local;

select /*+ parallel(2) no_px_join_filter(t11) leading(t7 t11) index(t11 i_1_yRG)*/* from t7, t11 where t7.c1 = t11.c2 order by 1;

