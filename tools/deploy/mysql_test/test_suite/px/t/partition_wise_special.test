--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql3
# tags: optimizer,px

--disable_warnings
drop database if exists px;
create database px;
use px;
--enable_warnings

## test range partition
CREATE TABLE t1 (c1 int)
 partition by range(c1)
(
partition p0 values less than (0),
partition p1 values less than (1),
partition p2 values less than (2),
partition p3 values less than (3),
partition p4 values less than (4),
partition p5 values less than (5));



CREATE TABLE t2 (c1 int) 
 partition by range(c1)
(
partition p1 values less than (1),
partition p2 values less than (2),
partition p3 values less than (3),
partition p4 values less than (4),
partition p5 values less than (5));


insert into t1 values(0);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);

insert into t2 values(0);
insert into t2 values(1);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(4);


create table t3(c1 int);
insert into t3 select c1 from t1;


explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;

explain select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;

drop table t1;
drop table t2;
drop table t3;


CREATE TABLE t1 (c1 int)
 partition by range(c1)
(partition p1 values less than (1));
alter table t1 add partition (partition p2 values less than (2));
alter table t1 add partition (partition p3 values less than (3));
alter table t1 add partition (partition p4 values less than (4));
alter table t1 add partition (partition p5 values less than (5));



CREATE TABLE t2 (c1 int) 
 partition by range(c1)
(
partition p1 values less than (1),
partition p2 values less than (2),
partition p3 values less than (3),
partition p4 values less than (4),
partition p5 values less than (5));


insert into t1 values(0);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);

insert into t2 values(0);
insert into t2 values(1);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(4);


create table t3(c1 int);
insert into t3 select c1 from t1;

explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;

explain select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;


alter table t1 add partition (partition p6 values less than (6));

explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;

explain select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t1 t2) t3)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 >= 1 and t1.c1 = t3.c1;


## test list partition
drop table t1;
drop table t2;
drop table t3;
create table t1 (c1 int) partition by list (c1)
 (partition p0 values in (1),
  partition p1 values in (2),
  partition p2 values in (3),
  partition p3 values in (4),
  partition p4 values in (5),
  partition p5 values in (6),
	partition p6 values in (7),
  partition p7 values in (8),
  partition p8 values in (9),
  partition p9 values in (10));
create table t2 (c1 int) partition by list (c1)
 (partition p0 values in (1),
  partition p1 values in (3),
  partition p2 values in (5),
  partition p3 values in (7),
  partition p4 values in (9));

insert into t1 values(1), (3), (5), (7), (9);
insert into t2 values(1), (3), (5), (7), (9);

create table t3(c1 int);
insert into t3 select c1 from t1;
explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 in (1,3,5,7,9) and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 in (1,3,5,7,9) and t1.c1 = t3.c1;


drop table t1;
drop table t2;
create table t1 (c1 int) partition by list (c1)
(  partition p1 values in (2),
  partition p2 values in (3),
  partition p3 values in (4),
	partition p6 values in (7),
  partition p0 values in (1),
  partition p8 values in (9),
  partition p5 values in (6),
  partition p4 values in (5),
  partition p7 values in (8),
  partition p9 values in (10));
create table t2 (c1 int) partition by list (c1)
 (partition p0 values in (1),
  partition p1 values in (3),
  partition p2 values in (5),
  partition p3 values in (7),
  partition p4 values in (9));

insert into t1 values(1), (3), (5), (7), (9);
insert into t2 values(1), (3), (5), (7), (9);
explain select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 in (1,3,5,7,9) and t1.c1 = t3.c1;
--sorted_result
select /*+ parallel(4) leading((t3 t1) t2)*/ t1.* from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 in (1,3,5,7,9) and t1.c1 = t3.c1;


use test;
drop database px;