#owner: zhouhaiyu.zhy
#owner group: SQL2
#tags: px 

# test aggregation

--disable_warnings
DROP TABLE IF EXISTS T1;
DROP TABLE IF EXISTS T2;
DROP TABLE IF EXISTS T3;
--enable_warnings

CREATE TABLE `T1` (C1 INT PRIMARY KEY, C2 INT)  PARTITION BY HASH(C1) PARTITIONS 2;
CREATE TABLE `T2` (C1 INT PRIMARY KEY, C2 INT)  NOPARALLEL  PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE `T3` (C1 INT PRIMARY KEY, C2 INT)  PARALLEL 10  PARTITION BY HASH(C1) PARTITIONS 4;

--echo
--echo # ENABLE PARALLEL QUERY AND FORCE PARALLEL 7
--echo

SET _ENABLE_PARALLEL_QUERY = 1;
SET _FORCE_PARALLEL_QUERY_DOP = 7;
EXPLAIN SELECT * FROM T1;
EXPLAIN SELECT /*+ PARALLEL(4) */ * FROM T1;
EXPLAIN SELECT * FROM T2;
EXPLAIN SELECT * FROM T3;
EXPLAIN SELECT * FROM T1,T2,T3 WHERE T1.C1 = T2.C2 ORDER BY T1.C1;


--echo
--echo # DISABLE PARALLEL QUERY AND FORCE PARALLEL 7
--echo
SET _ENABLE_PARALLEL_QUERY = 0;
SET _FORCE_PARALLEL_QUERY_DOP = 7;
EXPLAIN SELECT * FROM T1;
EXPLAIN SELECT /*+ PARALLEL(4) */ * FROM T1;
EXPLAIN SELECT * FROM T2;
EXPLAIN SELECT * FROM T3;
EXPLAIN SELECT * FROM T1,T2,T3 WHERE T1.C1 = T2.C2 ORDER BY T1.C1;

--echo
--echo # DISABLE PARALLEL QUERY AND FORCE PARALLEL 1
--echo
SET _ENABLE_PARALLEL_QUERY = 0;
SET _FORCE_PARALLEL_QUERY_DOP = 1;
EXPLAIN SELECT * FROM T1;
EXPLAIN SELECT /*+ PARALLEL(4) */ * FROM T1;
EXPLAIN SELECT * FROM T2;
EXPLAIN SELECT * FROM T3;
EXPLAIN SELECT * FROM T1,T2,T3 WHERE T1.C1 = T2.C2 ORDER BY T1.C1;


--echo
--echo # FORCE PARALLEL 7 THEN ENABLE PARALLEL QUERY
--echo
SET _FORCE_PARALLEL_QUERY_DOP = 7;
SET _ENABLE_PARALLEL_QUERY = 1;
EXPLAIN SELECT * FROM T1;
EXPLAIN SELECT /*+ PARALLEL(4) */ * FROM T1;
EXPLAIN SELECT * FROM T2;
EXPLAIN SELECT * FROM T3;
EXPLAIN SELECT * FROM T1,T2,T3 WHERE T1.C1 = T2.C2 ORDER BY T1.C1;

--echo
--echo # TEST SWITCH FROM MULTI STATE
--echo
SET _FORCE_PARALLEL_QUERY_DOP = 3;
SET _ENABLE_PARALLEL_QUERY = 0;
EXPLAIN   SELECT  * FROM T3;
SET _ENABLE_PARALLEL_QUERY = 1;
EXPLAIN   SELECT  * FROM T3;
SET _FORCE_PARALLEL_QUERY_DOP = 1;
EXPLAIN   SELECT  * FROM T3;
SET _FORCE_PARALLEL_QUERY_DOP = 3;
EXPLAIN   SELECT  * FROM T3;


