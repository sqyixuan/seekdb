#owner: dachuan.sdc
#owner group: SQL3
#tags: optimizer

--disable_warnings
drop table if exists px1;
drop table if exists sp1;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sql_audit = true;
alter system flush sql audit global;

disconnect obsys;
connection default;
--enable_result_log


create table px1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table sp1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table t2 (c1 int primary key, c2 int);

insert into px1 values (1,1);

# bushy
explain basic (select /*+ xiaochu-px_admission test-bushy-px parallel(2) */ count(*) from t2 group by c1) union (select count(*) from t2 group by c1);
(select /*+ xiaochu-px_admission test-bushy-px parallel(2) */ count(*) from t2 group by c1) union (select count(*) from t2 group by c1);
# multi px
explain basic select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1;
explain basic select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1,px1 a2;
explain basic select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1, px1 a2, px1 a3;
explain basic select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1, px1 a2, px1 a3, px1 a4, px1 a5, px1 a6, px1 a7, px1 a8, px1 a9, px1 a10, px1 a11;

select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1;
select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1,px1 a2;
select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1, px1 a2, px1 a3;
select /*+ xiaochu-px_admission test-multi-px parallel(2) */ * from px1 a1, px1 a2, px1 a3, px1 a4, px1 a5, px1 a6, px1 a7, px1 a8, px1 a9, px1 a10, px1 a11;

# subplan filter
explain basic (select /*+ xiaochu-px_admission test-subplan-filter-px */ * from px1) union (select /*+ no_rewreite */ * from t1 where t1.c1 in (select count(c1) from sp1 where sp1.c1 > t1.c2 group by c2));
(select /*+ xiaochu-px_admission test-subplan-filter-px */ * from px1) union (select /*+ no_rewreite */ * from t1 where t1.c1 in (select count(c1) from sp1 where sp1.c1 > t1.c2 group by c2));

# query the record
select LEFT(QUERY_SQL, 80), EXPECTED_WORKER_COUNT,USED_WORKER_COUNT from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%xiaochu-px_admission test-%' and query_sql not like 'explain%' and query_sql not like '%sql_audit%';

