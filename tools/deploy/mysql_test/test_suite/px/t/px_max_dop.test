--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql3
#tags: optimizer

--disable_warnings
drop table if exists table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns;
--enable_warnings

CREATE TABLE table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns (
col_decimal_20_0 decimal(20,0),
col_int int,
col_char_20 char(20),
col_datetime datetime,
col_int_signed int signed,
col_mediumint_unsigned mediumint unsigned,
col_mediumint mediumint,
col_decimal_20_0_signed decimal(20,0) signed,
col_integer integer,
col_int_unsigned int unsigned,
col_integer_signed integer signed,
col_smallint smallint,
col_integer_unsigned integer unsigned,
col_bigint_signed bigint signed,
col_bigint_unsigned bigint unsigned,
col_bigint bigint,
col_decimal_20_0_unsigned decimal(20,0) unsigned,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_smallint_unsigned smallint unsigned,
col_smallint_signed smallint signed,
col_mediumint_signed mediumint signed)  PARTITION BY hash (ceil(col_mediumint_unsigned))
subpartition by range columns(col_datetime)
subpartition template
(subpartition p0 values less than ('1990-01-01 00:00:00'),
 subpartition p1 values less than ('2010-01-01 00:00:00'),
 subpartition p2 values less than ('2030-01-01 00:00:00'),
 subpartition p3 values less than (maxvalue)) partitions 8;

explain SELECT table1 . col_smallint FROM table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns AS table1 LEFT JOIN table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns AS table2 USING ( col_bigint ) WHERE table1 . col_bigint < 1 OR table1 . col_bigint >= COALESCE( 99999 , 4527 , 0 ) ORDER BY table1 . col_bigint DESC , table1 . col_bigint DESC , table1 . col_char_20 ASC , table1 . col_bigint DESC, table1 . col_bigint_signed ASC, table2 . col_bigint DESC, table1 . col_char_20 , table1 . col_decimal_20_0_signed DESC, table1 . col_bigint DESC, table1 . col_bigint_signed , table1 . col_datetime , table1 . col_bigint_unsigned ASC, table1 . col_decimal_20_0 ASC, table1 . col_timestamp_6 , table1 . col_decimal_20_0_unsigned DESC, table2 . col_char_20 , table2 . col_decimal_20_0_signed ASC, table2 . col_bigint , table2 . col_bigint_signed , table2 . col_datetime DESC, table2 . col_bigint_unsigned ASC, table2 . col_decimal_20_0 ASC, table2 . col_timestamp_6 ASC, table2 . col_decimal_20_0_unsigned DESC LIMIT 8 ;

SELECT table1 . col_smallint FROM table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns AS table1 LEFT JOIN table1_hash_ceil_col_mediumint_unsigned_subpart_by_range_columns AS table2 USING ( col_bigint ) WHERE table1 . col_bigint < 1 OR table1 . col_bigint >= COALESCE( 99999 , 4527 , 0 ) ORDER BY table1 . col_bigint DESC , table1 . col_bigint DESC , table1 . col_char_20 ASC , table1 . col_bigint DESC, table1 . col_bigint_signed ASC, table2 . col_bigint DESC, table1 . col_char_20 , table1 . col_decimal_20_0_signed DESC, table1 . col_bigint DESC, table1 . col_bigint_signed , table1 . col_datetime , table1 . col_bigint_unsigned ASC, table1 . col_decimal_20_0 ASC, table1 . col_timestamp_6 , table1 . col_decimal_20_0_unsigned DESC, table2 . col_char_20 , table2 . col_decimal_20_0_signed ASC, table2 . col_bigint , table2 . col_bigint_signed , table2 . col_datetime DESC, table2 . col_bigint_unsigned ASC, table2 . col_decimal_20_0 ASC, table2 . col_timestamp_6 ASC, table2 . col_decimal_20_0_unsigned DESC LIMIT 8 ;
