#owner: zhouhaiyu.zhy
#owner group: sql2
# tags: optimizer,px

--disable_warnings
--error 0, 942, 1051
drop table t1;
--error 0, 942, 1051
drop table t2;
--enable_warnings

alter system set _px_join_skew_handling  = 1;
alter system set _px_join_skew_minfreq = 30;
set global parallel_servers_target = 30;
--sleep 10

set ob_query_timeout = 100000000;
set ob_trx_timeout = 100000000;


create table t1 (c1 int) partition by hash(c1) partitions 2;
create table t2 (c1 int) partition by hash(c1) partitions 3;
insert into t1 values (1),(2),(3),(3),(3),(3),(3),(4),(5),(6),(null);
insert into t2 values (1),(1),(2);
insert into t1 values (null), (null), (null), (null), (null), (null), (null), (null), (null), (null), (null), (null);
call dbms_stats.gather_table_stats(NULL,'T1',method_opt=>'for all columns size 100');

 
explain basic select * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);
explain basic select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);

# result without null
--sorted_result
select * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);
--sorted_result
select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);
# make null result availiable
insert into t2 values (null);
--sorted_result
select * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);
--sorted_result
select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1  where exists (select * from t2 where t1.c1 <=> t2.c1);

# join on char=text, issue/50143130
--error 0,942
drop table t1,t2;
create table t1 (c1 int, c2 char(100)) partition by hash(c1) partitions 2;
create table t2 (c1 int, c2 text, c3 char(100)) partition by hash(c1) partitions 3;
insert into t1 values (1,'qqwe'),(2,'qweasd'),(3,'aweqr'),(3,'vxcvr'),(3,'iojoi'),(3,'qwrijvo'),(3,'oppqokwe'),(4,'oincoxzc'),(5,'oiowqe'),(6,'lkpok'),(null,null);
insert into t2 values (1, 'qqwe','qqwe'),(1,'qweasd','aweqr'),(2,'vxcvr','iojoi');
insert into t1 (c1) values (null), (null), (null), (null), (null), (null), (null), (null), (null), (null), (null), (null);
call dbms_stats.gather_table_stats(NULL,'T1',method_opt=>'for all columns size 100');
call dbms_stats.gather_table_stats(NULL,'T2',method_opt=>'for all columns size 100');
alter system set _px_join_skew_minfreq = 10;
explain basic select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1 where exists (select * from t2 where t1.c2 <=> t2.c2);
--sorted_result
select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1 where exists (select * from t2 where t1.c2 <=> t2.c2) order by c1;
drop table t1,t2;

#join on text=char issue/51959318
create table t1 (c1 int, c2 tinytext) partition by hash(c1) partitions 2;
create table t2 (c1 int, c2 mediumtext) partition by hash(c1) partitions 3;
insert into t1 values (1, '1'),(2, '2'),(3,'3'),(3,'3'),(3,'3'),(3,'3'),(3,'3'),(4,'4'),(5,'5'),(5, '6'),(null,null);
insert into t2 values (1,'1'),(1,'1'),(2,'2');
insert into t1 values (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null), (null,null);
call dbms_stats.gather_table_stats(NULL,'T1',method_opt=>'for all columns size 100');
--sorted_result
select /*+ parallel(4) leading(t2 t1) use_hash(t1) no_swap_join_inputs(t1) pq_distribute(t1 hash hash) */ * from t1  where exists (select * from t2 where t1.c2 <=> t2.c2);
drop table t1,t2;
