#owner: fy373789
#owner group: SQL-执行器
#description: Test for decoupling PX computing nodes from data nodes.
#tags: PX

connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection root;
let $dst_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_server_stat order by id, svr_ip, 1);
let $dst_port = query_get_value(select svr_port from oceanbase.__all_virtual_server_stat order by id, svr_port, 1);
let $dst_addr = $dst_ip:$dst_port;
--disable_query_log
connection default;
--enable_query_log

--disable_warnings
drop table if exists tt2;
--enable_warnings

CREATE TABLE tt2 (
    c1 BIGINT AUTO_INCREMENT,
    c2 BIGINT,
    c3 BIGINT,
    c4 BIGINT,
   PRIMARY KEY (c1, c2)
)
PARTITION BY RANGE(c2) (
   PARTITION p1 VALUES LESS THAN (700000),
   PARTITION p2 VALUES LESS THAN (800000),
   PARTITION p3 VALUES LESS THAN (900000),
   PARTITION p4 VALUES LESS THAN (MAXVALUE)
);

insert into tt2(c2,c3,c4) select abs(random(456) % 1000000), abs(random(456) % 1000000), abs(random(456) % 1000000) from table(generator(10000));

# test hint
--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('data')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('zone')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('cluster')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_COUNT(1)*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_COUNT(5)*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_query_log
--disable_result_log
eval select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_ADDRS('$dst_addr')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
--echo "select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_ADDRS('dst_addr')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;"
let $trace_id = query_get_value(select last_trace_id() as trace_id from dual, trace_id, 1);
--echo "select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;"
eval select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5;
--enable_query_log
let $excute_ip = query_get_value(select distinct svr_ip from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5, svr_ip, 1);
let $excute_port = query_get_value(select distinct svr_port from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5, svr_port, 1);
let $excute_addr = $excute_ip:$excute_port;
if ($excute_addr != $dst_addr) 
{
   --echo "use parallel hint addr error1";
   --echo $excute_addr;
   --echo $dst_addr
}

