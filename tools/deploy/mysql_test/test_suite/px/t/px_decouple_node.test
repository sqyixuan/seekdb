# Increase the data volume and test the auto DOP scenarios.
set ob_query_timeout=1000000000;
insert into tt2(c2,c3,c4) select abs(random(456) % 1000000), abs(random(456) % 1000000), abs(random(456) % 1000000) from table(generator(500000));
set parallel_degree_policy = AUTO;
set parallel_degree_limit = 0;
set parallel_min_scan_time_threshold = 10;

