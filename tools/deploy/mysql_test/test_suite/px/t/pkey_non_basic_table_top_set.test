# owner: dachuan.sdc
# owner group: sql2
# tags: optimizer,px

--result_format 4
--disable_warnings
drop table if exists t1;
drop table if exists t1_1;
drop table if exists t1_2;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

CREATE TABLE T1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_2 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T2 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 4;
CREATE TABLE T3 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 5;
insert into t1 values(1, 1, 1), (2,2,2), (3,3,3), (4,4,4);
insert into t1_1 values(1, 1, 1), (2,2,2), (3,3,3), (4,4,4);
insert into t2 values(1, 1, 1), (2,2,2), (4,4,4), (5,5,5), (6,6,6);
insert into t3 values(2,2,2), (4,4,4), (5,5,5), (6,6,6);
--explain_protocol 2


######################################## pkey to simple pw ######################################
## pw hash join
select c2 from t2 union select /*+ use_hash(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;

## pw nlj
select c2 from t2 union select /*+ use_nl(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;

## pw mj
create index idx_t1 on t1(c1, c2);
create index idx_t1_1 on t1_1(c1, c2);
select c2 from t2 union select /*+ use_merge(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;
select c2 from t2 except select /*+ use_merge(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;
alter table t1_1 drop index idx_t1_1;

### pw nlj with push-down param
select c2 from t2 union select /*+ index(t1 idx_t1) use_nl(t1) leading(t1_1 t1) */ t1.c1 from t1 join t1_1 on t1.c1 = t1_1.c1;


### pw nlj with push-down param and table lookup
alter table t1 drop index idx_t1;
create index idx_t1 on t1(c1) global;
select c2, c3 from t2 union select /*+ index(t1 idx_t1) use_nl(t1) leading(t1_1 t1) */ t1.c1, t1.c3 from t1 join t1_1 on t1.c1 = t1_1.c1;
alter table t1 drop index idx_t1;


create index idx_t1 on t1(c1) partition by hash(c1) partitions 3;
select c2, c3 from t2 union select /*+ index(t1 idx_t1) use_nl(t1) leading(t1_1 t1) */ t1.c1, t1.c3 from t1 join t1_1 on t1.c1 = t1_1.c1;
alter table t1 drop index idx_t1;



######################################## pkey to complicated pw ######################################
## child of pwj is pkey
select c2, c3 from t3 union select /*+  leading((t1 t2 t1_1)) pq_distribute(t1_1 none partition) */ t1.c1, t1.c3 from t1 join t1_1 join t2 on t1.c1 = t1_1.c1 and t1.c1 = t2.c2;
select c2, c3 from t3 union (select c1, c3 from t1_1 except select /*+  leading(t1 t2) pq_distribute(t2 none partition) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2);


## child of pwj is broadcast
--sorted_result
select c2, c3 from t3 union select /*+ parallel(2) leading(t1_1 (t1 t2)) pq_distribute(t2 none broadcast) */ t1.c1, t1.c3 from t1 join t1_1 join t2 on t1.c1 = t1_1.c1 and t1.c1 = t2.c2;
--sorted_result
select c2, c3 from t3 union (select c1, c3 from t1_1 except select /*+ parallel(2)  leading(t1 t2) pq_distribute(t2 none broadcast) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2);




######################################## pkey to pkey/broadcast ######################################
select c2, c3 from t3 union (select c1, c2 from t1 except select c2, c3 from t2);
select c2, c3 from t3 union (select c2, c3 from t2 except select c1, c2 from t1);
(select c1, c2 from t1 union select c2, c3 from t2) except select c2, c3 from t3;
(select c2, c3 from t2 union select c1, c2 from t1) except select c2, c3 from t3;


--sorted_result
select c2, c3 from t3 union (select /*+ parallel(2) leading(t1 t2) pq_distribute(t2 none broadcast) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2);
--sorted_result
select c2, c3 from t3 union (select /*+ parallel(2) leading(t2 t1) pq_distribute(t1 broadcast none) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2);


--sorted_result
(select /*+ parallel(2) leading(t1 t2) pq_distribute(t2 none broadcast) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2) union select c2, c3 from t3;
--sorted_result
(select /*+ parallel(2) leading(t2 t1) pq_distribute(t1 none broadcast) */ t1.c1, t1.c3 from t1 join t2 on t1.c1 = t2.c2) union select c2, c3 from t3;



#################################  pkey to subplan filter ###################################
## pw subplan filter
select t2.c2, t2.c3 from t2 union (select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c1 = t1_1.c1));
(select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c1 = t1_1.c1)) union select t2.c2, t2.c3 from t2;
select t2.c2, t2.c3 from t2 except (select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c1 = t1_1.c1));
(select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c1 = t1_1.c1)) except select t2.c2, t2.c3 from t2;

## pkey subplan filter
select t2.c2, t2.c3 from t2 union (select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c2 = t1_1.c1));
select t2.c2, t2.c3 from t2 except (select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c2 = t1_1.c1));
(select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c2 = t1_1.c1)) union select t2.c2, t2.c3 from t2 ;
(select /*+ no_rewrite */ t1.c1, t1.c2 from t1 where exists (select 1 from t1_1 where t1.c2 = t1_1.c1)) except select t2.c2, t2.c3 from t2 ;