
#owner: dachuan.sdc
#owner group: SQL2
#tag:px, optimizer

let $unit1 = unit_1;
let $pool1 = pool_1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_warnings
--disable_query_log
#drop tenant if exists tenant1 force;
#let $zone1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1);
#let $zone2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 2);
#eval CREATE RESOURCE UNIT if not exists $unit1 MAX_CPU=1, MEMORY_SIZE='2G';
#eval create resource pool if not exists $pool1 unit='$unit1', unit_num = 1, zone_list = ('$zone1');
#eval create tenant tenant1 resource_pool_list=('$pool1'), replica_num=2, zone_list=('$zone1','$zone2'),primary_zone='$zone1' set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings
connection default;
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

--disable_warnings
drop database if exists yishen;
--enable_warnings

create database yishen;
use yishen;

create table t1(v1 int) partition by hash(v1) partitions 3;
insert into t1 values(1), (2), (3);

create table t2(v1 int) partition by hash(v1) partitions 2;
insert into t2 values(1), (2), (3);

--disable_result_log
--disable_query_log
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log
--result_format 4

set ob_query_timeout = 1200000000;
