# owner: dachuan.sdc
# owner group: sql2
# 测试 bug fix
# tags: px,optimizer
--disable_warnings
drop table if exists obright;
--enable_warnings

set _force_parallel_query_dop=3;

CREATE TABLE `obright` (
  `grp_id` bigint(20) NOT NULL,
  `row_id` bigint(20) NOT NULL,
  `row_hex` varchar(2048) NOT NULL,
  `trx_grp` bigint(20) DEFAULT NULL,
  `v1` varchar(65536) DEFAULT NULL,
  `v1_check` bigint(20) DEFAULT NULL,
  `v2` varchar(65536) DEFAULT NULL,
  `v2_check` bigint(20) DEFAULT NULL,
  `r1` int(11) DEFAULT NULL,
  `r2` int(11) DEFAULT NULL,
  `glike` varchar(4096) DEFAULT NULL,
  `c1` bigint(20) DEFAULT NULL,
  `c2` bigint(20) DEFAULT NULL,
  `c3` bigint(20) DEFAULT NULL,
  `c4` bigint(20) DEFAULT NULL,
  `c5` bigint(20) DEFAULT NULL,
  `c6` tinyint(4) DEFAULT NULL,
  `c7` bigint(20) DEFAULT NULL,
  `c8` bigint(20) DEFAULT NULL,
  `c9` bigint(20) DEFAULT NULL,
  `c10` bigint(20) DEFAULT NULL,
  `v3` varchar(1024) DEFAULT NULL,
  `ts` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  `t1` timestamp(6) NULL DEFAULT NULL,
  `t2` datetime(6) DEFAULT NULL,
  `dec1` decimal(16,4) DEFAULT NULL,
  `dec2` decimal(16,4) DEFAULT NULL,
  `dec3` decimal(16,6) DEFAULT NULL,
  `b1` tinyint(1) DEFAULT NULL,
  `d1` bigint(20) DEFAULT '0',
  `ac1` bigint(20) NOT NULL AUTO_INCREMENT,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gen_v1` varchar(10) GENERATED ALWAYS AS (substr(`v1`,1,10)) VIRTUAL,
  `gen_v2` varchar(10) GENERATED ALWAYS AS (substr(`v1`,1,10)) STORED,
  PRIMARY KEY (`grp_id`, `row_id`, `row_hex`),
  UNIQUE KEY `obright1_uniq` (`t1`, `grp_id`, `row_id`, `row_hex`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `obright2_uniq` (`trx_grp`, `r1`, `row_hex`, `row_id`, `grp_id`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `obright3_uniq` (`row_hex`, `grp_id`, `row_id`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `obright4_uniq` (`dec1`, `ts`, `gmt_create`, `gmt_modified`, `row_id`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `obright5_uniq` (`trx_grp`, `row_hex`, `grp_id`) STORING (`v1`, `v1_check`, `r1`, `r2`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `obright6_uniq` (`row_id`, `gen_v1`, `gen_v2`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright1` (`row_id`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright2` (`trx_grp`, `row_id`, `ac1`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright3` (`glike`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright4` (`t1`, `ts`, `dec1`, `dec2`) STORING (`v1`, `v1_check`, `r1`, `r2`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright5` (`v1_check`, `v2_check`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright6` (`row_hex`, `v1_check`) STORING (`r1`, `glike`, `t1`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright7` (`grp_id`, `row_id`, `row_hex`, `trx_grp`, `v1_check`, `r1`, `r2`) STORING (`v1`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright8` (`ac1`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright9` (`grp_id`, `row_id`, `row_hex`) BLOCK_SIZE 16384 GLOBAL,
  KEY `obright10` (`gen_v1`, `gen_v2`) BLOCK_SIZE 16384 GLOBAL
);

explain basic select /*+ USE_LATE_MATERIALIZATION index(obright  obright1)*/grp_id, row_id, row_hex, trx_grp, c1, gmt_create, gmt_modified from obright where grp_id>=6009 and grp_id=72108 and row_id<72576 order by t1,t2,ts limit 468;

select /*+ USE_LATE_MATERIALIZATION index(obright obright1)*/ grp_id, row_id, row_hex, trx_grp, c1, gmt_create, gmt_modified from obright where grp_id>=6009 and grp_id=72108 and row_id<72576 order by t1,t2,ts limit 468;
