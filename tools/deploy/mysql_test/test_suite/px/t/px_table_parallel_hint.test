--sleep 1

explain basic select /*+use_px parallel(t1 3) parallel(t2 2) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(t1 3) parallel(t2 2) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;


--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int) parallel 8 partition by hash(c1) ;
create table t2 (c2 int) partition by hash(c2) partitions 3;
explain basic select /*+ parallel(t1 2) */ * from t1;
explain basic select /*+ parallel(a 2) */ * from t1 a;
explain basic select /*+ parallel(t1 2) */ * from t2;
explain basic select /*+ parallel(a 2) */ * from t2 a;
explain basic select  /*+ parallel(3) */  *, sum(c1) over (partition by c1 order by c1+2) from t1,t2;
explain basic select  /*+ parallel(t2 3) */  *, sum(c1) over (partition by c1 order by c1+2) from t1,t2;
explain basic select  /*+ parallel(t1 3) */  *, sum(c1) over (partition by c1 order by c1+2) from t1,t2;
explain basic select  /*+ parallel(t1 3) parallel(t2 4) */  *, sum(c1) over (partition by c1 order by c1+2) from t1,t2;
explain basic select  *, sum(c1) over (partition by c1 order by c1+2) from t1,t2;


## table parallel hint conflict bug:
--disable_warnings
drop table if exists lyq_test_t1;
drop table if exists lyq_test_t2;
--enable_warnings

CREATE TABLE lyq_test_t1(
PK INT primary key,
COL_INT INT check (COL_INT < 1000));

CREATE TABLE lyq_test_t2(
PK INT primary key,
COL_INT INT check (COL_INT < 1000));

insert into lyq_test_t1 values(1,1);
insert into lyq_test_t1 values(2,2);
insert into lyq_test_t2 values(1,1);
insert into lyq_test_t2 values(2,2);

explain basic
with
e as (select /*+ parallel(lyq_test_t2 2) */  COL_INT from lyq_test_t2  where COL_INT > 1),
d as (select /*+ parallel(lyq_test_t1 4) */  COL_INT from lyq_test_t1)
select e.COL_INT from e, d where e.COL_INT = d.COL_INT;

explain basic
select e.COL_INT from (select /*+ parallel(lyq_test_t2 2) */  COL_INT from lyq_test_t2  where COL_INT > 1) e,  (select /*+ no_merge parallel(lyq_test_t1 4) */  COL_INT from lyq_test_t1)d where e.COL_INT = d.COL_INT;

drop table lyq_test_t1;
drop table lyq_test_t2;
