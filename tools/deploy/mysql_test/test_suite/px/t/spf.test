--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql3
# tags: optimizer

--disable_warnings
drop database if exists muhangtest;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create database muhangtest;
use muhangtest;
--enable_warnings

--result_format 4

create table t1(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table t3(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table t2(a int, b int, c int, d int, primary key (a), index idx_t2_bc (b,c) local) partition by hash(a) partitions 3;

explain select /*+NO_REWRITE*/ * from t1,t3 where t1.a = t3.a and exists (select /*+index(t2 idx_t2_bc)*/ 1 from t2 where t1.a = t2.a and t1.b = t2.b);
select /*+NO_REWRITE*/ * from t1,t3 where t1.a = t3.a and exists (select /*+index(t2 idx_t2_bc)*/ 1 from t2 where t1.a = t2.a and t1.b = t2.b);

drop table t1;

CREATE TABLE t1 (c1 int, c2 varchar(67)) partition by hash(c1) partitions 3;
insert into t1 values(82, 'ljQviTMgkKnmsuKTuUFRCdFJggyXCQgGnOdaNFteIY');
insert into t1 values(76, 'NNpEglvIDeyNbuEaxmSVUxj');
insert into t1 values(78, 'JnWjqUyNTRHEkeUXK');
insert into t1 values(11, 'RXluUiKRBwBTPzGLxHRcmzyKPzUtoGbbpaxqBCSfMszPNznGj');

explain basic SELECT /*+parallel(2) use_concat 
      FULL(@"SEL$13" "test.t1"@"SEL$13")
      FULL(@"SEL$15" "test.t1"@"SEL$15")
      FULL(@"SEL$14" "test.t1"@"SEL$14")
      FULL(@"SEL$16" "test.t1"@"SEL$16")*/ c1 FROM (SELECT c1, (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) AS c2 FROM t1) 
WHERE c2 <= (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) OR c1 = 561 ORDER BY 1;

SELECT /*+parallel(2) use_concat 
      FULL(@"SEL$13" "test.t1"@"SEL$13")
      FULL(@"SEL$15" "test.t1"@"SEL$15")
      FULL(@"SEL$14" "test.t1"@"SEL$14")
      FULL(@"SEL$16" "test.t1"@"SEL$16")*/ c1 FROM (SELECT c1, (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) AS c2 FROM t1) 
WHERE c2 <= (SELECT c2 FROM t1 ORDER BY 1 LIMIT 1) OR c1 = 561 ORDER BY 1;

drop table t1;
drop table t2;
drop table t3;
