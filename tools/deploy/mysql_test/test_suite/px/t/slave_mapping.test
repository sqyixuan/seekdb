--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhouhaiyu.zhy
#owner group: sql3
#tags: optimizer

--disable_warnings
set recyclebin = off;
drop database if exists muhangtest_slave_mapping;
#drop table if exists t1;
#drop table if exists t2;
#drop table if exists t3;
#drop table if exists t4;
#drop table if exists t5;
#drop table if exists lineitem;
#drop table if exists part;
#drop table if exists customer;
#drop table if exists orders;
purge recyclebin;
drop tablegroup if exists pq_map_pwj;
create database muhangtest_slave_mapping;
use muhangtest_slave_mapping;
set recyclebin = on;
--enable_warnings

create tablegroup pq_map_pwj;

create table lineitem(
 l_orderkey           bigint NOT NULL ,
 l_partkey            bigint NOT NULL ,
 l_suppkey            bigint NOT NULL ,
 l_linenumber         bigint NOT NULL ,
 l_quantity           bigint NOT NULL ,
 l_extendedprice      number(10,2) NOT NULL ,
 l_discount           number(10,2) NOT NULL ,
 l_tax                number(10,2) NOT NULL ,
 l_returnflag         char(1) ,
 l_linestatus         char(1) ,
 l_shipdate           date ,
 l_commitdate         date ,
 l_receiptdate        date ,
 l_shipinstruct       char(25) ,
 l_shipmode           char(10) ,
 l_comment            varchar(44),
 primary key(L_ORDERKEY, L_LINENUMBER),
 index
 i_l_orderkey(l_orderkey)
  local
  ) tablegroup = pq_map_pwj partition by hash(L_ORDERKEY) partitions 5;


create table part(
 p_partkey            bigint NOT NULL ,
 p_name               varchar(55) ,
 p_mfgr               char(25) ,
 p_brand              char(10) ,
 p_type               varchar(25) ,
 p_size               bigint ,
 p_container          char(10) ,
 p_retailprice        number(10,2) ,
 p_comment            varchar(23) ,
 primary key (P_PARTKEY)
  ) tablegroup = pq_map_pwj partition by hash(P_PARTKEY) partitions 5;

create table customer(
 c_custkey            bigint NOT NULL ,
 c_name               varchar(25) ,
 c_address            varchar(40) ,
 c_nationkey          bigint ,
 c_phone              char(15) ,
 c_acctbal            number(10,2) ,
 c_mktsegment         char(10) ,
 c_comment            varchar(117),
 primary key(C_CUSTKEY),
 unique index i_c_custkey(c_custkey) local
  ) tablegroup = pq_map_pwj partition by hash(C_CUSTKEY) partitions 5;

create table orders(
 o_orderkey           bigint NOT NULL ,
 o_custkey            bigint NOT NULL ,
 o_orderstatus        char(1) ,
 o_totalprice         number(10,2) ,
 o_orderdate          date ,
 o_orderpriority      char(15) ,
 o_clerk              char(15) ,
 o_shippriority       bigint ,
 o_comment            varchar(79),
 primary key(o_orderkey),
 index(o_orderkey) local
  ) tablegroup = pq_map_pwj partition by hash(o_orderkey) partitions 5;

## 只有hash join hint才会生效
explain select /*TPC-H Q18 parallel(2) pq_map(orders)*/ c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice, sum(l_quantity) from customer, orders, lineitem where o_orderkey in ( select l_orderkey from lineitem group by l_orderkey having sum(l_quantity) > 314 ) and c_custkey = o_custkey and o_orderkey = l_orderkey group by c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice order by o_totalprice desc, o_orderdate limit 100;


create table t1 (c1 int, c2 int, c3 int) tablegroup = pq_map_pwj partition by hash(c1) partitions 5;
create table t2 (c1 int, c2 int, c3 int) tablegroup = pq_map_pwj partition by hash(c1) partitions 5;
create table t3 (c1 int, c2 int, c3 int) tablegroup = pq_map_pwj partition by hash(c1) partitions 5;

--let $count=1
while($count < 60)
{
    --let $stmt=INSERT INTO t1 VALUES($count, $count, $count)
    eval $stmt;
    --let $stmt=INSERT INTO t2 VALUES($count, $count, $count)
    eval $stmt;
    --let $stmt=INSERT INTO t3 VALUES($count, $count, $count)
    eval $stmt;
    inc $count; 
}

explain select /*+use_px parallel(4) leading(t1 t2) use_hash(t1 t2) pq_map(t2) */ * from t1,t2,t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
explain extended_noaddr select /*+use_px parallel(4) leading(t1 t2) use_hash(t1 t2) pq_map(t2) */ * from t1,t2 where t1.c1 = t2.c1;
explain select /*+use_px parallel(4) leading(t1 t2) use_hash(t1 t2) */ * from t1,t2 where t1.c1 = t2.c1;

--sorted_result
select /*+use_px parallel(4) leading(t1 t2) use_hash(t1 t2) pq_map(t2) */ * from t1,t2 where t1.c1 = t2.c1;


create table t4(c1 int primary key, c2 int, c3 int, c4 date);
create table t5(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by hash(c1) partitions 4;

insert into t4 values(1,1,1,'1991-1-1');
insert into t4 values(2,2,2,'1991-1-1');
insert into t4 values(3,3,3,'1991-1-1');
insert into t4 values(4,4,4,'1991-1-1');

insert into t5 values(1,1,1);
insert into t5 values(2,2,2);
insert into t5 values(3,3,3);
insert into t5 values(4,4,4);

explain basic select /*+pq_map(t5) leading(t4 t5) use_hash(t5)*/ * from t4 join t5 on t4.c2 = t5.c1;
--sorted_result
select /*+pq_map(t5) leading(t4 t5) use_hash(t5)*/ * from t4 join t5 on t4.c2 = t5.c1;

explain select /*+pq_map(t5) pq_distribute(t5 broadcast none) leading(t4 t5) use_hash(t5)*/ * from t4 join t5 on t4.c2 = t5.c1;
--sorted_result
select /*+pq_map(t5) pq_distribute(t5 broadcast none) leading(t4 t5) use_hash(t5)*/ * from t4 join t5 on t4.c2 = t5.c1;
explain select
/*+
  BEGIN_OUTLINE_DATA
  LEADING(@"SEL$1" ("muhangtest_slave_mapping.t4"@"SEL$1" "muhangtest_slave_mapping.t5"@"SEL$1" ))
  USE_HASH(@"SEL$1" ("muhangtest_slave_mapping.t5"@"SEL$1" ))
  PQ_DISTRIBUTE(@"SEL$1" ("muhangtest_slave_mapping.t5"@"SEL$1" ) BROADCAST NONE)
  PQ_MAP(@"SEL$1" "muhangtest_slave_mapping.t5"@"SEL$1" )
  FULL(@"SEL$1" "muhangtest_slave_mapping.t4"@"SEL$1")
  FULL(@"SEL$1" "muhangtest_slave_mapping.t5"@"SEL$1")
  END_OUTLINE_DATA
 */
* from t4 join t5 on t4.c2 = t5.c1;

explain select * from t4 join t5 on t4.c2 = t5.c1;
--sorted_result
select * from t4 join t5 on t4.c2 = t5.c1;

explain basic select /*+pq_map(t4) leading(t5 t4) use_hash(t4)*/ * from t4 join t5 on t4.c2 = t5.c1;
--sorted_result
select /*+pq_map(t4) leading(t5 t4) use_hash(t4)*/ * from t4 join t5 on t4.c2 = t5.c1;

explain basic select /*+pq_map(t4) leading(t5 t4) use_hash(t4) parallel(20)*/ * from t4 join t5 on t4.c2 = t5.c1;
--sorted_result
select /*+pq_map(t4) leading(t5 t4) use_hash(t4) parallel(20)*/ * from t4 join t5 on t4.c2 = t5.c1;


drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, pc int as (c1 + c2 + 1), primary key (c1, c2)) partition by hash(c2) partitions 4;
create table t2 (c1 INT(127) ,c2 DECIMAL(64,23) ,c3 VARBINARY(53) ,c4 DECIMAL(64,26) ,c5 DATE,c6 INT(127) ,c7 TIMESTAMP(4)  NOT NULL default 0,c8 NUMERIC(64,8) ,c9 INTEGER(127) ,c10 DATETIME,c11 DATE, primary key(c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c9) PARTITIONS 10;

select /*+ parallel(2) pq_map(t2) leading(t1 t2) use_nl(t2) pq_distribute(t2 none partition)*/ * from t1 join t2 on t1.c2 = t2.c1;

drop table if exists t1,t2;
CREATE TABLE `t0` (
  `c0` double(34,3) NOT NULL COMMENT 'asdf',
  `c1` longtext DEFAULT NULL COMMENT 'asdf',
  PRIMARY KEY (`c0`),
  UNIQUE KEY `c0` (`c0`) BLOCK_SIZE 16384 LOCAL
) partition by key(c0)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`);

CREATE TABLE `t2` (
  `c0` datetime DEFAULT NULL,
  `c1` datetime DEFAULT NULL
) partition by key(c0, c1)
(partition `p0`,
partition `p1`);


CREATE TABLE `q` (
  `col_datetime` datetime DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `pk` int(11) DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
 partition by hash(pk)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`,
partition `p10`,
partition `p11`,
partition `p12`,
partition `p13`,
partition `p14`,
partition `p15`,
partition `p16`,
partition `p17`,
partition `p18`) WITH COLUMN GROUP(all columns, each column);



CREATE TABLE `oo` (
  `col_int` int(11) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `pk` int(11) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
 partition by hash(col_int_key) subpartition by key(col_varchar_10_key) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`,
subpartition `p3`,
subpartition `p4`,
subpartition `p5`,
subpartition `p6`,
subpartition `p7`,
subpartition `p8`,
subpartition `p9`)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`) WITH COLUMN GROUP(all columns, each column);

insert into oo values(NULL, '2007-02-15', 'nkjfd', 12, NULL, 'english', '2007-12-11 06:16:54', 'english', '2002-12-23', '2000-05-23 02:08:11', 'english');
insert into q values('2006-04-18 23:55:45', 'uepyjhpu', 'ECBSN', '2003-04-01', 'english', 'english', '2007-03-02', -1198981120, 23, '2007-03-17 07:21:46', 472449024);
select /*+ monitor use_merge(OUTR, innr) PQ_DISTRIBUTE(@"SEL$612EAAC9" "innr"@"SEL$2" HASH_LOCAL BROADCAST) */ * from OO as OUTR where exists(select 1 from q as innr where OUTR.col_varchar_10_key = innr.col_varchar_10_key and OUTR.col_varchar_20_key = innr.col_varchar_20_key) and OUTR.col_int_key IS NULL;
explain basic select /*+ monitor use_merge(OUTR, innr) PQ_DISTRIBUTE(@"SEL$612EAAC9" "innr"@"SEL$2" HASH_LOCAL BROADCAST) */ * from OO as OUTR where exists(select 1 from q as innr where OUTR.col_varchar_10_key = innr.col_varchar_10_key and OUTR.col_varchar_20_key = innr.col_varchar_20_key) and OUTR.col_int_key IS NULL;
drop table q;
drop table oo;

drop database if exists muhangtest_slave_mapping;