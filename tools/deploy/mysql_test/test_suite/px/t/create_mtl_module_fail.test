#owner: xf375358
#owner group: opensource

connect (conn_sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection conn_sys;
alter system set_tp tp_name = "CREATE_MTL_MODULE_FAIL", error_code = 4016, frequency = 1;

#create tenant
let $zone1 = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);
--disable_warnings
--disable_query_log
#eval CREATE RESOURCE UNIT if not exists unit_create_mtl_module_fail MAX_CPU 1,MEMORY_SIZE '2G';
#eval CREATE RESOURCE POOL if not exists pool_create_mtl_module_fail UNIT='unit_create_mtl_module_fail',UNIT_NUM=1,ZONE_LIST=('$zone1');
--enable_query_log
--enable_warnings

--error 4016
#eval CREATE TENANT if not exists create_mtl_module_fail_user RESOURCE_POOL_LIST=('pool_create_mtl_module_fail') set ob_tcp_invited_nodes='%';

connection conn_sys;
alter system set_tp tp_name = "CREATE_MTL_MODULE_FAIL", error_code = 0, frequency = 0;

--disable_warnings
--disable_query_log
#DROP RESOURCE POOL if exists pool_create_mtl_module_fail;
#DROP RESOURCE UNIT if exists unit_create_mtl_module_fail;
--enable_query_log
--enable_warnings
