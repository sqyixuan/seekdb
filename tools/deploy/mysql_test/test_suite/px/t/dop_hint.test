#owner: zhouhaiyu.zhy
#owner group: SQL2
#tags: optimizer,px

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key) partition by hash(c1) partitions 3;
insert into t1 values (3);
explain basic select * from t1;
explain basic select /*+ dop(10000,3) */ * from t1;
explain basic select /*+ parallel(4) dop(10000,3) */ * from t1;
explain basic select /*+ parallel(4) dop(10000,1) */ * from t1;
explain basic select /*+ dop(10000,3) parallel(4) */ * from t1;
explain basic select /*+ dop(10000,3) parallel(4) dop(10000,2) */ * from t1;
explain basic select /*+ no_use_px dop(10000,3) parallel(4) dop(10000,2) */ * from t1;


select * from t1;
select /*+ dop(10000,3) */ * from t1;
select /*+ parallel(4) dop(10000,3) */ * from t1;
select /*+ parallel(4) dop(10000,1) */ * from t1;
select /*+ dop(10000,3) parallel(4) */ * from t1;
select /*+ dop(10000,3) parallel(4) dop(10000,7) */ * from t1;

set _force_parallel_query_dop = 3;
explain basic select * from t1;
explain basic select /*+ dop(10000,2) */ * from t1;
select * from t1;
select /*+ dop(10000,2) */ * from t1;


set _force_parallel_dml_dop = 3;
explain basic insert /*+ dop(10000, 2) */ into t1 select * from t1;
