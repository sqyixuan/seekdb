#owner: zhouhaiyu.zhy
#owner group: SQL executor
# tags: optimizer
# desc: 测试join filter 在左右两列类型不一致并且没有做cast时的compare function选择逻辑, 

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (c1 int, c2 enum('Alice','Bob','Charlie','David') NOT NULL);
create table t2 (d1 smallint(5) unsigned DEFAULT '42909');
insert into t1 values(1, 'Alice'),(2,'Bob');
insert into t2 values(1),(2),(3);
explain select /*+ parallel(3) use_hash(t1,t2) leading(t1 t2) px_join_filter(t2) */* from t1 join t2 on t1.c2 = t2.d1;
select /*+ parallel(3) use_hash(t1,t2) leading(t1 t2) px_join_filter(t2) */* from t1 join t2 on t1.c2 = t2.d1;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
