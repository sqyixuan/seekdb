#owner: dachuan.sdc
#owner group: sql2
#tags: px,optimizer
#description: rescan of gi


--disable_query_log
--disable_warnings
set @@session.explicit_defaults_for_timestamp=off;
drop table if exists t1;
drop table if exists t2;
--enable_query_log
--enable_warnings

create table t1(c1 int);
create table t2(c1 int, c2 int, key idx(c1) local, key idx2(c2) local) partition by hash(c1) partitions 4;
insert into t1 values(1);
insert into t2 values(1, 1);
select /*+ monitor inline leading(t1 t2) use_hash(t2) parallel(2) PX_JOIN_FILTER(t2) pq_distribute(t2 bc2host none) */ t1.* from t1, t2 where t1.c1 = t2.c1 union all select /*+ leading(t1 t2) use_nl(t2) no_use_das(t2) */ t1.c1 from t1, t2 where t1.c1 = t2.c1;
explain basic select /*+ monitor inline leading(t1 t2) use_hash(t2) parallel(2) PX_JOIN_FILTER(t2) pq_distribute(t2 bc2host none) */ t1.* from t1, t2 where t1.c1 = t2.c1 union all select /*+ leading(t1 t2) use_nl(t2) no_use_das(t2) */ t1.c1 from t1, t2 where t1.c1 = t2.c1;

select /*+ monitor inline leading(t1 t2) use_hash(t2) parallel(2) PX_JOIN_FILTER(t2) pq_distribute(t2 hash hash) */ t1.* from t1, t2 where t1.c1 = t2.c1 union all select /*+ leading(t1 t2) use_nl(t2) no_use_das(t2) */ t1.c1 from t1, t2 where t1.c1 = t2.c1;
drop table t1;
drop table t2;