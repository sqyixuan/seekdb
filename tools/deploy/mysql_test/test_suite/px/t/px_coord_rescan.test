#owner: dachuan.sdc
#owner group: SQL3
#tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists anti_semi_join_mysql_table_7;
drop table if exists anti_semi_join_mysql_table_8;
drop table if exists anti_semi_join_mysql_table_9;
--enable_warnings
create table t1(a int, b int, c int);
create table t2(a int, b int, c int);
create table t3(a int, b int, c int) partition by hash(a) partitions 4;
explain select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b = t3.b);
select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b = t3.b);
insert into t1 values (1,1,1),(2,2,2);
insert into t3 values (1,1,1),(2,2,2);
explain select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b = t3.b);
select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b = t3.b);
explain select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b in (select b from t3));
select/*+no_rewrite*/ * from t1 where t1.a in (select t3.a from t3 where t1.b in (select b from t3));



create table anti_semi_join_mysql_table_7(c1 int, c2 int, key idx_c2(c2, c1)) partition by hash(c1) partitions 3;
create table anti_semi_join_mysql_table_8(c1 int, c2 int, key idx_c2(c2, c1)) partition by hash(c1) partitions 4;
create table anti_semi_join_mysql_table_9(c1 int, c2 int, key idx_c2(c2, c1)) partition by hash(c1) partitions 5;


insert/*insert trace*/ into anti_semi_join_mysql_table_7 values(0, 0), (1,1), (2, null),(2,2), (5,5), (5,5), (5,7),(6,7), (6,6), (6, null),(7,7), (7, 0), (8,0), (8,8), (8, 5), (9, 0), (9, 7), (10,10), (null, 1), (1,1), (3,3), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (0, 0), (1,1), (2, null),(2,2), (5,5), (5,5), (5,7),(6,7), (6,6), (6, null),(7,7), (7, 0), (8,0), (8,8), (8, 5), (9, 0), (9, 7), (10,10), (null, 1), (1,1), (3,3), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (0, 0), (1,1), (2, null),(2,2), (5,5), (5,5), (5,7),(6,7), (6,6), (6, null),(7,7), (7, 0), (8,0), (8,8), (8, 5), (9, 0), (9, 7), (10,10), (null, 1), (1,1), (3,3), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (0, 0), (1,1), (2, null),(2,2), (5,5), (5,5), (5,7),(6,7), (6,6), (6, null),(7,7), (7, 0), (8,0), (8,8), (8, 5), (9, 0), (9, 7), (10,10), (null, 1), (1,1), (3,3), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1), (20,1);
insert/*insert trace*/ into anti_semi_join_mysql_table_8 values(null, 1), (1,1), (3,3), (5,5), (5,6), (5,4), (6,6), (9,9);
insert/*insert trace*/ into anti_semi_join_mysql_table_9 values(1,1), (3,3), (5,5), (5,6), (5,4), (6,6), (9,9), (5,7),(6,7), (6,6), (6, null),(7,7);


explain basic select /*+ no_rewrite*/ sum(c1), sum(c2) from anti_semi_join_mysql_table_7 where exists (select 1 from anti_semi_join_mysql_table_9 where c1 = anti_semi_join_mysql_table_7.c1) and  exists (select 1 from anti_semi_join_mysql_table_8 where c1 = anti_semi_join_mysql_table_7.c1);

select /*+ no_rewrite*/ sum(c1), sum(c2) from anti_semi_join_mysql_table_7 where exists (select 1 from anti_semi_join_mysql_table_9 where c1 = anti_semi_join_mysql_table_7.c1) and  exists (select 1 from anti_semi_join_mysql_table_8 where c1 = anti_semi_join_mysql_table_7.c1);


