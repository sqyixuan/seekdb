#owner: fy373789
#owner group: SQL2
#description: Used to verify whether the query will hang after a failure in notifying the QC (Query Coordinator) to interrupt.
# tags: qc_interrupt_fail

connect (conn_user,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn_sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection conn_user;
--disable_warnings
drop table if exists LINEITEM;
--enable_warnings
CREATE TABLE lineitem (
    l_orderkey BIGINT NOT NULL,
    l_partkey BIGINT NOT NULL,
    l_suppkey INTEGER NOT NULL,
    l_linenumber INTEGER NOT NULL,
    l_comment varchar(44) DEFAULT NULL,
primary key(l_orderkey, l_linenumber)
)row_format = condensed
partition by key (l_orderkey) partitions 10;

connection conn_sys;
alter system set_tp tp_name = ERRSIM_INTERRUPT_QC_FAILED, error_code = 4016, frequency = 1;
alter system set_tp tp_name = ERRSIM_DYNAMIC_SAMPLE_FAIL, error_code = 4016, frequency = 1;
alter system set_tp tp_no = 617, error_code = 4016, frequency = 1;

connection conn_user;
--error 4016
create/*+parallel(4) */ index i1 on lineitem(l_comment, l_orderkey, l_linenumber);

connection conn_sys;
alter system set_tp tp_name = ERRSIM_INTERRUPT_QC_FAILED, error_code = 0, frequency = 1;
alter system set_tp tp_name = ERRSIM_DYNAMIC_SAMPLE_FAIL, error_code = 0, frequency = 1;
alter system set_tp tp_no = 617, error_code = 0, frequency = 1;