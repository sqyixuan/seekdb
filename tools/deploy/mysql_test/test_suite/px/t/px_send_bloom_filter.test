--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
#tags: optimizer
# owner group: sql2
# tags: px, for update
--result_format 4

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 4;
create table t2 (c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 4;
create table t3 (c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 4;
create table t4 (c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 4;
create table t5 (c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 4;

insert into t1 values(0,0,0,0,0);
insert into t1 values(1,1,1,1,1);
insert into t1 values(2,2,2,2,2);
insert into t1 values(3,3,3,3,3);
insert into t1 values(4,4,4,4,4);
insert into t1 values(5,5,5,5,5);
insert into t1 values(6,6,6,6,6);
insert into t1 values(7,7,7,7,7);

insert into t2 select * from t1;
insert into t3 select * from t1;
insert into t4 select * from t1;
insert into t5 select * from t1;

insert into t1 values(1,2,3,4,5);
insert into t2 values(2,3,4,5,6);
insert into t3 values(3,4,5,6,7);
insert into t4 values(7,6,5,4,3);
insert into t5 values(6,5,4,3,2);

set ob_query_timeout = 20000000;

insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;

explain basic select /*+leading(a (b (c (d e))))  parallel(6) use_hash(e) use_hash((d e)) use_hash((c (d e))) use_hash((b (c (d e))))  PQ_DISTRIBUTE(e hash hash) px_join_filter(e a) */ count(*) from t1 a, t2 b, t3 c, t4 d, t5 e where a.c1 = b.c2 and b.c2 = c.c3 and c.c3 = d.c4 and d.c4 = e.c5 and a.c3 = e.c3;

select /*+leading(a (b (c (d e))))  parallel(6) use_hash(e) use_hash((d e)) use_hash((c (d e))) use_hash((b (c (d e))))  PQ_DISTRIBUTE(e hash hash) px_join_filter(e a) */ count(*) from t1 a, t2 b, t3 c, t4 d, t5 e where a.c1 = b.c2 and b.c2 = c.c3 and c.c3 = d.c4 and d.c4 = e.c5 and a.c3 = e.c3;

#clean environment
set ob_query_timeout = 10000000;
--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
