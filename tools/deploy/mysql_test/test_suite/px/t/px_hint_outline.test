create outline test_ot_28 on select /*+ PQ_DISTRIBUTE(b NONE BROADCAST) use_px parallel(4) use_hash(a b) */ * from t1 a, t2 b where a.c2 = b.c2;
select visible_signature, database_name, outline_name,  sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'test_ot_28';
let $outline_sql = query_get_value("SELECT * from oceanbase.__tenant_virtual_outline where outline_name = 'test_ot_28'", outline_sql, 1);
--echo $outline_sql
eval explain $outline_sql;
drop outline test_ot_28;

explain basic select /*+ PQ_DISTRIBUTE(b NONE PARTITION) use_px parallel(4) use_hash(a b) */ * from t1 a, t2 b where a.c2 = b.c2;
