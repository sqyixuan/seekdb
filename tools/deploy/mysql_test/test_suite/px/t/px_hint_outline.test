# broadcast subplan
explain basic select /*+leading(b a) no_rewrite() use_px parallel(4) use_hash(a, b) pq_distribute(a none, broadcast)*/ * from (select * from t1) a join t2 b on a.c1 = b.c1;
create outline test_ot_36 on select /*+leading(b a) no_rewrite() use_px parallel(4) use_hash(a, b) pq_distribute(a none, broadcast)*/ * from (select * from t1) a join t2 b on a.c1 = b.c1;
select visible_signature, database_name, outline_name,  sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'test_ot_36';
let $outline_sql = query_get_value("SELECT * from oceanbase.__tenant_virtual_outline where outline_name = 'test_ot_36'", outline_sql, 1);
--echo $outline_sql
eval explain $outline_sql;
drop outline test_ot_36;

