--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: dachuan.sdc
#owner group: sql3
# tags: optimizer,outline


--disable_warnings
drop database if exists muhangtest;
create database muhangtest;
use muhangtest;
--enable_warnings

--result_format 4
set ob_enable_plan_cache = false;

# outline test

create table stu (
  sid     int,
  name    varchar(32),
  cls     int,
  primary key (cls, sid)
) partition by hash(sid) partitions 6;

create table teacher (
  tid        int,
  name       varchar(32),
  subject    varchar(4),
  primary key (tid)
) partition by hash(tid) partitions 8;

create table score (
  sid     int,
  subject varchar(4),
  score   int,
  primary key (sid, subject)
) partition by hash(sid) partitions 6;

insert into stu values
(11, 'a1', 1),
(12, 'b1', 1),
(13, 'c1', 1);

insert into teacher values
(1, 'Miss Zhang', 'EN'),
(2, 'Mr Wang', 'MA');

insert into score values
(11, 'EN', 60),
(12, 'EN', 70),
(13, 'EN', 80);
--sleep 1

## 原始计划
explain select /*+ USE_PX parallel(2) pq_distri*/ * from score, teacher where teacher.subject = score.subject;
## 加了hint的计划
explain select /*+ USE_PX parallel(2) pq_distribute(teacher hash hash)*/ * from score, teacher where teacher.subject = score.subject;
## 绑定outline
create outline test_ot_1 on select/*+ USE_PX parallel(2) pq_distribute(teacher hash hash)*/ * from score, teacher where teacher.subject = score.subject;

select visible_signature, database_name, outline_name,  sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'test_ot_1';

let $outline_sql = query_get_value("SELECT * from oceanbase.__tenant_virtual_outline where outline_name = 'test_ot_1'", outline_sql, 1);
--echo $outline_sql
eval explain $outline_sql;

drop outline test_ot_1;

## 加了hint的计划
explain select /*+no_rewrite() ordered pq_distribute(stu none broadcast)*/ * from (select /*+USE_PX parallel(2) pq_distribute(teacher hash hash)*/ teacher.tid as sid, score.score as score from score, teacher where teacher.subject = score.subject) as new_table, stu where stu.sid = new_table.sid;
## 绑定outline
create outline test_ot_2 on select /*+no_rewrite() ordered pq_distribute(stu none broadcast)*/ * from (select /*+USE_PX parallel(2) pq_distribute(teacher hash hash)*/ teacher.tid as sid, score.score as score from score, teacher where teacher.subject = score.subject) as new_table, stu where stu.sid = new_table.sid;

select visible_signature, database_name, outline_name,  sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'test_ot_2';

let $outline_sql = query_get_value("SELECT * from oceanbase.__tenant_virtual_outline where outline_name = 'test_ot_2'", outline_sql, 1);
--echo $outline_sql
eval explain $outline_sql;

drop outline test_ot_2;

## 各类计划
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, c4 int, primary key (c1));
create table t2 (c1 int, c2 int, c3 int, c4 int, primary key (c1));
create table t3 (c1 int, c2 int, c3 int, c4 int, primary key (c1));
create table t4 (c1 int, c2 int, c3 int, c4 int, primary key (c1, c2))  partition by hash(c2) partitions 4;
create table t5 (c1 int, c2 int, c3 int, c4 int, primary key (c1, c2))  partition by hash(c2) partitions 4;

let $i = 5;
while ($i)
{
  let $v = 10;
  while ($v)
  {
    eval insert into t$i values ($v, $v, $v, $v);
    dec $v;
  }
  dec $i;
}
--sleep 1

## allocate exchange above subplan scan
explain basic select /*+ use_px parallel(4) use_hash(a, b) */ * from (select * from t1) a left join t2 b on a.c1 = b.c1;
create outline test_ot_3 on select /*+ use_px parallel(4) use_hash(a, b) */ * from (select * from t1) a left join t2 b on a.c1 = b.c1;
select visible_signature,sql_text,outline_target,outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'test_ot_3';
let $outline_sql = query_get_value("SELECT * from oceanbase.__tenant_virtual_outline where outline_name = 'test_ot_3'", outline_sql, 1);
--echo $outline_sql
eval explain $outline_sql;
drop outline test_ot_3;
## 非inner join不能broadcast
explain basic select /*+ PQ_DISTRIBUTE(b BROADCAST NONE) use_px parallel(4) use_hash(a, b) */ * from (select * from t1) a left join t2 b on a.c1 = b.c1;
create outline test_ot_4 on select /*+ PQ_DISTRIBUTE(b BROADCAST NONE) use_px parallel(4) use_hash(a, b) */ * from (select * from t1) a left join t2 b on a.c1 = b.c1;
