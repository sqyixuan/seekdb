#owner: dachuan.sdc
#owner group: SQL3
# tags: optimizer
#tag: px

--enable_sorted_result
--disable_result_log


--disable_warnings
drop database if exists px_test;
--enable_warnings

create database px_test;
use px_test;

--disable_query_log

set global parallel_servers_target = 16;
sleep 11;
--enable_query_log

create table stu (
   sid     int,
   tid     int,
   name    varchar(32),
   primary key (sid)
) partition by hash(sid) partitions 6;
insert into stu values
(1, 4, 'John'),
(2, 7, 'Marry'),
(3, 8, 'Austin'),
(4, 3, 'Jack');

create table teacher (
   tid        int,
   name       varchar(32),
   subject    varchar(4),
   primary key (tid)
) partition by hash(tid) partitions 8;
insert into teacher values
(1, 'Miss Zhang', 'EN'),
(2, 'Mr Wang', 'MA'),
(3, 'Mr Tao', 'CH'),
(4, 'Miss XIAN', 'PHY'),
(5, 'Mr WU', 'BIO'),
(6, 'Miss KANG', 'PE'),
(7, 'Mr HOU', 'PSY'),
(8, 'Miss LAI', 'CS'),
(9, 'Mr HUANG', 'RE'),
(10, 'Miss CHEN', 'ART');
--sleep 1


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sql_audit = true;
connection default;
select /*+ use_px parallel(4) */* from teacher;
connection obsys;
--enable_result_log
let $trace_id1 = query_get_value(select trace_id from oceanbase.__all_virtual_sql_audit where query_sql='select /*+ use_px parallel(4) */* from teacher', trace_id, 1);
--echo select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
--disable_query_log
eval select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '$trace_id1' and is_inner_sql =false;
--enable_query_log

connection default;
--disable_result_log
select /*+ use_px parallel(8) */* from teacher;
connection obsys;
--enable_result_log
let $trace_id2 = query_get_value(select trace_id from oceanbase.__all_virtual_sql_audit where query_sql='select /*+ use_px parallel(8) */* from teacher', trace_id, 1);
--echo select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
--disable_query_log
eval select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '$trace_id2' and is_inner_sql =false;
--enable_query_log

connection default;
--disable_result_log
select /*+ use_px parallel(4) */* from teacher;
connection obsys;
--enable_result_log
let $trace_id3 = query_get_value(select trace_id from oceanbase.__all_virtual_sql_audit where query_sql='select /*+ use_px parallel(4) */* from teacher', trace_id, 1);
--echo select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
--disable_query_log
eval select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '$trace_id3' and is_inner_sql =false;
--enable_query_log

connection default;
--disable_result_log
select /*+ use_px parallel(8) */* from teacher;
connection obsys;
--enable_result_log
let $trace_id4 = query_get_value(select trace_id from oceanbase.__all_virtual_sql_audit where query_sql='select /*+ use_px parallel(8) */* from teacher', trace_id, 1);
--echo select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
--disable_query_log
eval select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '$trace_id4' and is_inner_sql =false;
--enable_query_log

--disable_result_log
alter system flush plan cache;

connection default;
select /*+ use_px parallel(4) */* from stu inner join teacher on stu.tid = teacher.tid;
--enable_result_log
connection obsys;
let $trace_id5 = query_get_value(select trace_id from oceanbase.__all_virtual_sql_audit where query_sql='select /*+ use_px parallel(4) */* from stu inner join teacher on stu.tid = teacher.tid', trace_id, 1);
--echo select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '#' and is_inner_sql =false;
--disable_query_log
eval select qc_id, dfo_id, sqc_id, worker_id from oceanbase.__all_virtual_sql_audit where trace_id = '$trace_id5' and is_inner_sql =false;
--enable_query_log

--disable_result_log
