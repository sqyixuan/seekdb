#owner: zhouhaiyu.zhy
#owner group: sql2
# tags: optimizer,px

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
create table t1(c1 bigint) partition by key(c1) partitions 7;
create table t2(c1 bigint) partition by key(c1) partitions 7;
create table t3(c1 bigint) partition by key(c1) partitions 33;
create table t4(c1 bigint) partition by key(c1) partitions 33;
insert into t1 select random(1) % 5000 from table(generator(200));
insert into t2 select random(2) % 5000 from table(generator(200));
insert into t3 select random(3) % 5000 from table(generator(200));
insert into t4 select random(4) % 5000 from table(generator(200));
explain basic (select * from t3 join t4 on t3.c1=t4.c1) union all (select * from t1 join t2 on t1.c1=t2.c1) ;
(select * from t3 join t4 on t3.c1=t4.c1) union all (select * from t1 join t2 on t1.c1=t2.c1) ;
--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings

create table t1(c1 bigint,c2 bigint,c3 bigint);
insert into t1 select random(123), random(456), random(789) from table(generator(1));
CREATE TABLE t2 (C1 int) PARTITION BY LIST(C1)
 (
  PARTITION P0 VALUES IN (1),
  PARTITION P1 VALUES IN (3),
  PARTITION P2 VALUES IN (5),
  PARTITION P3 VALUES IN (7)
 );

 CREATE TABLE t3 (C1 int) PARTITION BY LIST(C1)
 (
  PARTITION P0 VALUES IN (1),
  PARTITION P1 VALUES IN (3),
  PARTITION P2 VALUES IN (5),
  PARTITION P3 VALUES IN (7)
 );
ALTER TABLE t2 DROP PARTITION p0;
ALTER TABLE t2 ADD PARTITION (partition p5 VALUES in(1));
insert into t2 values(1), (3), (5);
insert into t3 values(1), (3), (5);

explain basic
select max(c1) from
(
select /*+ parallel(2)*/ a.* from 
    (select
        (select c1 from (select distinct t2.c1 as c1, c.c2 from t2 join t3 on t2.c1=t3.c1) limit 1 ) c1
    from t1 c
)a, t1 b
where a.c1 = b.c1
);

select max(c1) from
(
select /*+ parallel(2)*/ a.* from 
    (select
        (select c1 from (select distinct t2.c1 as c1, c.c2 from t2 join t3 on t2.c1=t3.c1) limit 1 ) c1
    from t1 c
)a, t1 b
where a.c1 = b.c1
);

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
