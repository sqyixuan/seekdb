##  6.4两个都是一级range columns二级key的分区表，key分区为两个列。
create table t1(c1 int, c2 int, c3 varchar(32) not null, c4 int) partition by range columns(c2, c4) subpartition by key(c1,c3) subpartitions 2 (partition p0 values less than (5,43), partition p1 values less than (MAXVALUE, MAXVALUE));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, c4 int) partition by range columns(c2, c4) subpartition by key(c1,c3) subpartitions 4 (partition p0 values less than (3,43), partition p1 values less than (MAXVALUE, MAXVALUE));

--source mysql_test/include/dist_key_partition_insert4.inc

explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 and t1.c4=t2.c4 order by t1.c2;
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

explain basic select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;
select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;

drop table t1;
drop table t2;

## 6.5看看语法糖简历的key分区能不能重分区
create table t1(c1 int primary key, c2 int, c3 int, c4 date);
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2)) partition by key() partitions 16;

--source mysql_test/include/dist_key_partition_insert1.inc

explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 order by t2.c2;
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 order by t2.c2;
explain basic select * from t1 join t2 on (t1.c1, t2.c1)=(t2.c1, t2.c2) order by t2.c2;
select * from t1 join t2 on (t1.c1, t2.c1)=(t2.c1, t2.c2) order by t2.c2;
drop table t1;
drop table t2;

