#运行测试, 保证不同类型计算正确
#
#part one 对int测试
#t1未分区
#t2为一级key分区
#key(c2)
create table t1(c1 int primary key, c2 int, c3 int, c4 date);
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1) partitions 32;

--source mysql_test/include/dist_key_partition_insert1.inc

explain basic select * from t1 join t2 on t1.c2=t2.c1 order by t2.c2;
select * from t1 join t2 on t1.c2=t2.c1 order by t2.c2;
explain basic select * from t1 join t2 on t1.c1=t2.c1 order by t2.c2;
select * from t1 join t2 on t1.c1=t2.c1 order by t2.c2;

explain basic select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c1=t2.c1 order by t2.c2;
select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c1=t2.c1 order by t2.c2;
