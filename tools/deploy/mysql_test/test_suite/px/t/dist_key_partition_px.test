explain basic select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
explain basic select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
explain basic select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

