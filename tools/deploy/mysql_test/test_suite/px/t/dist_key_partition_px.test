explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

explain basic select * from t1 join t2 on (t1.c1,t1.c2,t1.c3) = (t2.c1,t2.c2,t2.c3) order by t1.c2;
select * from t1 join t2 on (t1.c1,t1.c2,t1.c3) = (t2.c1,t2.c2,t2.c3) order by t1.c2;

drop table t1;
drop table t2;

## part six key+range columns分区条件为两个列
##  6.1两个都是一级key的分区表，key分区为两个列，二级range columns。
create table t1 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by range columns(c2, c4) subpartition template(subpartition p0 values less than (3, 40), subpartition p1 values less than (MAXVALUE, MAXVALUE)) partitions 3;
create table t2 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by range columns(c2, c4) subpartition template(subpartition p0 values less than (14, 40), subpartition p1 values less than (MAXVALUE, MAXVALUE)) partitions 2;

--source mysql_test/include/dist_key_partition_insert4.inc

explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 and t1.c4=t2.c4 order by t1.c2;
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

explain basic select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;
select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;

drop table t1;
drop table t2;

##  6.2两个都是一级key的分区表，key分区为两个列，二级list columns。
create table t1 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by list columns(c2, c4) subpartition template(subpartition p0 values in ((3,43),(4,44)), subpartition p1 values in (default)) partitions 3;
create table t2 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by list columns(c2, c4) subpartition template(subpartition p0 values in ((3,43),(5,45)), subpartition p1 values in (default)) partitions 3;

--source mysql_test/include/dist_key_partition_insert4.inc

explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 and t1.c4=t2.c4 order by t1.c2;
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

explain basic select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;
select * from t1 join t2 on (t1.c1,t1.c2,t1.c3,t1.c4) = (t2.c1,t2.c2,t2.c3,t2.c4) order by t1.c2;

drop table t1;
drop table t2;

##  6.3两个都是一级list columns二级key的分区表，key分区为两个列。
create table t1(c1 int, c2 int, c3 varchar(32) not null, c4 int, primary key (c1, c2, c3, c4)) partition by list columns(c2, c4) subpartition by key(c1,c3) subpartitions 2 (partition p0 values in ((3,43),(4,44)), partition p1 values in (default));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, c4 int, primary key (c1, c2, c3, c4)) partition by list columns(c2, c4) subpartition by key(c1,c3) subpartitions 4 (partition p0 values in ((3,43),(4,44)),partition p1 values in (default));

--source mysql_test/include/dist_key_partition_insert4.inc

