#t1  8     6     4     7

create table t1(c1 int, c2 int, c3 int, c4 date, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 2 (partition p0 values less than (15), partition p1 values less than (50));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 4 (partition p0 values less than (10),partition p1 values less than (50));

--source mysql_test/include/dist_key_partition_insert1.inc

explain basic select * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
select * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
explain basic select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
explain basic select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
explain basic select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;
select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c3 and t1.c3=t2.c2 order by t1.c2;

drop table t1;
drop table t2;

#
#t1
#一级分区为range column(c2) 2 
#二级分区为key(c3) 4
#t2
#一级分区为range column(c2) 2
#二级分区为key(c3) 4
#实测分区数据分布为
#    p0sp0 p0sp1 p0sp2 p0sp3 p1sp0 p1sp1 p1sp2 p1sp3
#t2  4     2     4     4     3     3     1     4
#    p0sp0 p0sp1 p1sp0 p1sp1
#t1  8     6     4     7
#计划会按照t2的规则把t1进行重分区，具体的重分区列为t1.c1和t1.c2
#如果有任何一行发错了，结果都会出错

create table t1(c1 int, c2 int, c3 int, c4 date, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 2 (partition p0 values less than (15),partition p1 values less than (50));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 4 (partition p0 values less than (15),partition p1 values less than (50));

--source mysql_test/include/dist_key_partition_insert1.inc

explain basic select * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
explain basic select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_nl(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
explain basic select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_merge(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
explain basic select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
select /*+use_hash(t1 t2)*/ * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;

drop table t1;
drop table t2;

#
#t1
#一级key分区
#二级range column分区
#t2
#一级key分区
#二级range column分区
