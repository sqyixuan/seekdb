create table t1 (a1 char(64), a2 char(64), b char(16), c char(16) not null, d char(16), dummy char(248) default ' ');
insert into t1 (a1, a2, b, c, d) values('a','a','a','a111','xy1'),('a','a','a','b111','xy2');

create table t2 (a1 char(64), a2 char(64) not null, b char(16), c char(16), d char(16), dummy char(248) default ' ');
insert into t2 (a1, a2, b, c, d) values('a','a','a','a111','xy1'),('a','a','a','b111','xy2');

create table t3 (a1 char(1), a2 char(1), b char(1), c char(4) not null, d char(3), dummy char(1) default ' ');

create table t4 (num bigint);

create table t5 (num bigint) PARTITION BY HASH(num) PARTITIONS 10;

create table t6 (num bigint) PARTITION BY RANGE(num) (
PARTITION p0 VALUES LESS THAN (-2000000000000),
PARTITION p1 VALUES LESS THAN (-1000000000000),
PARTITION p2 VALUES LESS THAN (0),
PARTITION p3 VALUES LESS THAN (1000000000000),
PARTITION p4 VALUES LESS THAN (2000000000000),
PARTITION p5 VALUES LESS THAN MAXVALUE
);

create table t7 (num bigint)
PARTITION BY RANGE(num)
SUBPARTITION BY HASH(num)
SUBPARTITIONS 3
(PARTITION p0 VALUES LESS THAN (-2000000000000),
 PARTITION p1 VALUES LESS THAN (-1000000000000),
 PARTITION p2 VALUES LESS THAN (0),
 PARTITION p3 VALUES LESS THAN (1000000000000),
 PARTITION p4 VALUES LESS THAN (2000000000000),
 PARTITION p5 VALUES LESS THAN MAXVALUE
);

create table t8(a bigint, b bigint, c bigint, d bigint);
create table t9(a bigint, b bigint, c bigint, d bigint) PARTITION BY HASH(b) PARTITIONS 10;
create table t10(a bigint, b bigint, c bigint, d bigint) PARTITION BY RANGE(c) (
 PARTITION p0 VALUES LESS THAN (-20000000),
 PARTITION p1 VALUES LESS THAN (-10000000),
 PARTITION p2 VALUES LESS THAN (-5000000),
 PARTITION p3 VALUES LESS THAN (-2000000),
 PARTITION p4 VALUES LESS THAN (-1000000),
 PARTITION p5 VALUES LESS THAN (0),
 PARTITION p6 VALUES LESS THAN (100000),
 PARTITION p7 VALUES LESS THAN (1000000),
 PARTITION p8 VALUES LESS THAN (4000000),
 PARTITION p9 VALUES LESS THAN MAXVALUE
);
create table t11(a bigint, b bigint, c bigint, d bigint) PARTITION BY RANGE(b)
  SUBPARTITION BY HASH(c)
  SUBPARTITIONS 3
  (
  PARTITION p0 VALUES LESS THAN (-20000000),
  PARTITION p1 VALUES LESS THAN (-10000000),
  PARTITION p2 VALUES LESS THAN (0),
  PARTITION p3 VALUES LESS THAN (10000000),
  PARTITION p4 VALUES LESS THAN (20000000),
  PARTITION p5 VALUES LESS THAN MAXVALUE
);
--sleep 1

