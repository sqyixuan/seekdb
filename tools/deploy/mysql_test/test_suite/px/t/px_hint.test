## 1.1 看看hint是否是右边生效
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 BROADCAST NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 PARTITION NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 PARTITION NONE) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 HASH HASH) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 HASH HASH) LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t2 t1)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t2 t1)*/ * from t1 join t2 on t1.c2 = t2.c2;

## 1.2 两张表的hint都写上，只有右表t2 hint生效
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 BROADCAST NONE) PQ_DISTRIBUTE(t1 BROADCAST NONE)  LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 BROADCAST NONE) PQ_DISTRIBUTE(t1 BROADCAST NONE)  LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 PARTITION NONE) PQ_DISTRIBUTE(t1 PARTITION NONE)  LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t2 PARTITION NONE) PQ_DISTRIBUTE(t1 PARTITION NONE)  LEADING(t1 t2)*/ * from t1 join t2 on t1.c2 = t2.c2;

## 1.3 没有view merge的情况下, 这个hint的的作用范围不涉及外面，仅仅在自己的query block。
explain basic select * from (select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE)*/ * from t1) as t1alias join t2 on t1alias.c2 = t2.c2;
explain basic select /*+no_rewrite()*/ * from (select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE)*/ * from t1) as t1alias join t2 on t1alias.c2 = t2.c2;
--sorted_result
select /*+no_rewrite()*/ * from (select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE)*/ * from t1) as t1alias join t2 on t1alias.c2 = t2.c2;
## 1.4 能够识别在作用域中的别名, 理论上说一个子查询的结果可以做重分布。
explain basic select /*+no_rewrite() use_px parallel(3) PQ_DISTRIBUTE(t1alias BROADCAST NONE) LEADING(t2alias t1)*/ * from t2 as t2alias join (select * from t1) as t1alias on t2alias.c2 = t1alias.c2;
--sorted_result
select /*+no_rewrite() use_px parallel(3) PQ_DISTRIBUTE(t1alias BROADCAST NONE) LEADING(t2alias t1)*/ * from t2 as t2alias join (select * from t1) as t1alias on t2alias.c2 = t1alias.c2;

explain basic select /*+no_rewrite() use_px parallel(3) PQ_DISTRIBUTE(t1alias NONE PARTITION) LEADING(t2alias t1)*/ * from t2 as t2alias join (select * from t1) as t1alias on t2alias.c2 = t1alias.c2;
--sorted_result
select /*+no_rewrite() use_px parallel(3) PQ_DISTRIBUTE(t1alias NONE PARTITION) LEADING(t2alias t1)*/ * from t2 as t2alias join (select * from t1) as t1alias on t2alias.c2 = t1alias.c2;

## 1.5 从hash hash/broadcast-none，但是无法partition
explain basic select /*+use_px parallel(3) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;
--sorted_result
select /*+use_px parallel(3) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t2 t1) */ * from t1 join t2 on t1.c2=t2.c1;

## 1.6 nlj带条件下压，broadcast/pkey的是左表依然是可以的。
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE BROADCAST) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE BROADCAST) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;

explain basic select  /*+use_px parallel(3) LEADING(t2 t1) PQ_DISTRIBUTE(t1 NONE broadcast)*/ * from t1 join t2 on t1.c2=t2.c2;
--sorted_result
select  /*+use_px parallel(3) LEADING(t2 t1) PQ_DISTRIBUTE(t1 NONE broadcast)*/ * from t1 join t2 on t1.c2=t2.c2;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE PARTITION) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE PARTITION) LEADING(t2 t1) USE_NL(t1) */ * from t1 join t2 on t1.c2=t2.c2;

drop table t1;
drop table t2;

create table t1(c1 int primary key, c2 int, c3 int, c4 date) partition by hash(c1) partitions 2;
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1) partitions 4;
