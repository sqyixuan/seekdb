## use_nl
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE BROADCAST) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE BROADCAST) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 BROADCAST NONE) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;

## 左右表都可以做pkey的时候，hint是可以指定左右的。
explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE PARTITION) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 NONE PARTITION) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 PARTITION NONE) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;

explain basic select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;
--sorted_result
select /*+use_px parallel(3) PQ_DISTRIBUTE(t1 HASH HASH) USE_NL(t1) LEADING(t2 t1)*/ * from t1 join t2 on t1.c1 = t2.c1;

