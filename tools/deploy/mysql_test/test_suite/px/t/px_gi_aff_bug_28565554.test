--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: sql2
# 测试 dml 查询部分打开px
# tags: dml, px, optimizer
# dml查询部分打开px，必须使用 USE_PX hint
# description: replace支持PX
--result_format 4
--disable_warnings
drop table if exists t1,t2;

create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 13;
create table t2(c1 int primary key, c2 int) partition by hash(c1) partitions 13;

insert into t1 values(1,1),(13,13),(0,0),(4,4);
insert into t2 values(1,1);

explain basic SELECT /*+no_use_px*/ * FROM (SELECT * FROM t1 WHERE c1 IN (0, 1, 13, 4)) t3 UNION SELECT * FROM t2 WHERE c1 in (1);
--sorted_result
SELECT /*+no_use_px*/ * FROM (SELECT * FROM t1 WHERE c1 IN (0, 1, 13, 4)) t3 UNION SELECT * FROM t2 WHERE c1 in (1);
explain basic SELECT * FROM (SELECT * FROM t1 WHERE c1 IN (0, 1, 13, 4)) t3 UNION SELECT * FROM t2 WHERE c1 in (1);
--sorted_result
SELECT * FROM (SELECT * FROM t1 WHERE c1 IN (0, 1, 13, 4)) t3 UNION SELECT * FROM t2 WHERE c1 in (1);

delete from t1;
delete from t2;
insert into t1 values(1,1),(13,13),(0,0),(4,4),(14,14);
insert into t2 values(1,1),(14,14);
explain basic select /*+no_use_px*/ * from t1,t2 where t1.c1 = t2.c2 and t1.c1 in (0,14,1,3,4) order by t1.c1 desc;
--sorted_result
select /*+no_use_px*/ * from t1,t2 where t1.c1 = t2.c2 and t1.c1 in (0,14,1,3,4) order by t1.c1 desc;
explain basic select * from t1,t2 where t1.c1 = t2.c2 and t1.c1 in (0,14,1,3,4) order by t1.c1 desc;
--sorted_result
select * from t1,t2 where t1.c1 = t2.c2 and t1.c1 in (0,14,1,3,4) order by t1.c1 desc;

--disable_warnings
drop table if exists t0,t1;
DROP DATABASE IF EXISTS database46;
CREATE DATABASE database46;
USE database46;
CREATE TABLE t0(c0 FLOAT  PRIMARY KEY COMMENT 'asdf' )  PARTITION BY KEY (c0) partitions 15;
CREATE TABLE t1 LIKE t0;
CREATE UNIQUE INDEX i390 ON t0(c0) VISIBLE;
TRUNCATE TABLE t0;
UPDATE t0 SET c0= EXISTS (SELECT 1 from dual wHERE FALSE);
CREATE INDEX i410 ON t0(c0);
DELETE FROM t1;
DELETE FROM t0 WHERE (BIT_COUNT(BIT_COUNT(-1691812103))) AND ((-1691812103) || (((+ ((t0.c0) || (t0.c0)))) IS NOT TRUE));
ALTER TABLE t0 COMPRESSION 'NONE';
CREATE INDEX i710 ON t0(c0);
CREATE UNIQUE INDEX i759 ON t0(c0);

explain basic SELECT /*+  parallel(10)  */ t1.c0 AS ref0 FROM t1 WHERE (((-1691812103) IS NOT UNKNOWN) IS UNKNOWN) = (t1.c0) UNION ALL SELECT /*+  parallel(10)  */ t1.c0 AS ref0 FROM t1 WHERE (NOT ((((-1691812103) IS NOT UNKNOWN) IS NULL) = (t1.c0))) UNION ALL SELECT /*+  parallel(10)  */ ALL t1.c0 AS ref0 FROM t1 WHERE ((((-1691812103) IS NOT NULL) IS UNKNOWN) = (t1.c0)) IS NULL;
SELECT /*+  parallel(10)  */ t1.c0 AS ref0 FROM t1 WHERE (((-1691812103) IS NOT UNKNOWN) IS UNKNOWN) = (t1.c0) UNION ALL SELECT /*+  parallel(10)  */ t1.c0 AS ref0 FROM t1 WHERE (NOT ((((-1691812103) IS NOT UNKNOWN) IS NULL) = (t1.c0))) UNION ALL SELECT /*+  parallel(10)  */ ALL t1.c0 AS ref0 FROM t1 WHERE ((((-1691812103) IS NOT NULL) IS UNKNOWN) = (t1.c0)) IS NULL;