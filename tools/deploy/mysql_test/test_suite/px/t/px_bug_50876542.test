CREATE TABLE `bl_om_deliver` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '鍒嗗竷寮廔D',
  `company_id` bigint(20) NOT NULL COMMENT '绉熻祦鍏徃ID',
  `store_no` varchar(20) NOT NULL COMMENT '浠撳簱缂栧彿',
  `owner_no` varchar(10) NOT NULL COMMENT '璐т富',
  `bill_no` varchar(32) NOT NULL COMMENT '鍗曟嵁鍙�',
  `status` varchar(10) NOT NULL DEFAULT '10' COMMENT '鍗曟嵁鐘舵€� 10-寤哄崟, 20-鍑哄簱涓�, 30-宸插嚭搴�',
  `finance_status` varchar(10) DEFAULT NULL COMMENT '璐㈠姟瀹℃壒鐘舵€� 10-宸叉彁浜�, 20-瀹℃牳閫氳繃, 30-宸查┏鍥�',
  `finance_auditor_time` datetime DEFAULT NULL COMMENT '璐㈠姟澶勭悊鏃堕棿',
  `receiver_no` varchar(36) DEFAULT NULL COMMENT '鏀惰揣鏂圭紪鐮�',
  `receiver_name` varchar(128) DEFAULT NULL COMMENT '鏀惰揣鏂瑰悕绉�',
  `bill_type` varchar(10) NOT NULL DEFAULT '0' COMMENT '鍑哄簱绫诲瀷 2110-浠撳嚭搴椼€�2210-璋冩嫧銆�2310-鎵瑰彂銆�3410-鍏朵粬鍑哄簱',
  `biz_type` varchar(20) NOT NULL COMMENT '涓氬姟绫诲瀷 WMS_OM_NOTIFY_BIZ_TYPE',
  `carrier_no` varchar(32) DEFAULT NULL COMMENT '鎵胯繍鍟嗙紪鐮�',
  `carrier_number` varchar(32) DEFAULT NULL COMMENT '鎵胯繍鍗曞彿',
  `warehouse_no` varchar(32) DEFAULT NULL COMMENT '鍞搧浼氬叆搴撳崟鍙�',
  `trans_type` tinyint(4) DEFAULT '0' COMMENT '璐ц繍绫诲瀷 鏁版嵁瀛楀吀-WMS_EXPRESS_TYPE',
  `consignee_name` varchar(128) DEFAULT NULL COMMENT '鏀惰揣浜�',
  `consignee_phone` varchar(128) DEFAULT NULL COMMENT '鏀惰揣浜哄浐瀹氱數璇�',
  `consignee_mobi_phone` varchar(128) DEFAULT NULL COMMENT '鏀惰揣浜烘墜鏈哄彿鐮�',
  `consignee_address` varchar(1024) DEFAULT NULL COMMENT '鏀惰揣浜哄湴鍧€',
  `province_no` varchar(32) DEFAULT NULL COMMENT '鐪佺紪鐮�',
  `province_name` varchar(32) DEFAULT NULL COMMENT '鐪佸悕绉�',
  `city_no` varchar(32) DEFAULT NULL COMMENT '甯傜紪鐮�',
  `city_name` varchar(32) DEFAULT NULL COMMENT '甯傚悕绉�',
  `area_no` varchar(32) DEFAULT NULL COMMENT '鍖虹紪鐮�',
  `area_name` varchar(32) DEFAULT NULL COMMENT '鍖哄悕绉�',
  `street` varchar(128) DEFAULT NULL COMMENT '琛楅亾鍦板潃',
  `save_batch` varchar(36) DEFAULT NULL COMMENT '淇濆瓨鎵规',
  `arrive_time` datetime DEFAULT NULL COMMENT '瑕佹眰鍒拌揣鏃堕棿',
  `terminal_flag` tinyint(4) NOT NULL DEFAULT '0' COMMENT '缁堢鏍囪瘑 0-PC 1-RF',
  `trans_status` varchar(10) NOT NULL DEFAULT '10' COMMENT '鍥炰紶鐘舵€� 10-鏈洖浼� 20-宸插洖浼�',
  `creator` varchar(20) NOT NULL COMMENT '鍒涘缓浜�',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '鍒涘缓鏃堕棿(涓嶅彲浜轰负璋冩暣)',
  `modifier` varchar(20) DEFAULT NULL COMMENT '淇敼浜�',
  `modify_time` datetime DEFAULT NULL COMMENT '淇敼鏃堕棿',
  `auditor` varchar(20) DEFAULT NULL COMMENT '瀹℃牳浜�',
  `audit_time` datetime DEFAULT NULL COMMENT '瀹℃牳鏃堕棿',
  `remarks` varchar(255) DEFAULT NULL COMMENT '澶囨敞',
  `partion_no` varchar(20) NOT NULL COMMENT '鍒嗗簱缂栧彿',
  `del_tag` varchar(2) NOT NULL DEFAULT '0' COMMENT '褰掓。鍒犻櫎鏍囪瘑(0=姝ｅ父褰掓。锛屽垹闄ゅ悗鏁版嵁鍚屾涓嬫父 1=褰掓。鍒犻櫎锛屽垹闄ゅ悗鏁版嵁涓嶅悓姝ヤ笅娓�)',
  `update_time` datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '璁板綍鏇存柊鏃堕棿',
  `create_way` tinyint(4) DEFAULT '0' COMMENT '鍒涘缓鏂瑰紡 0-闆嗚揣鍑哄簱 1-鐩存帴鍑哄簱',
  `address_id` varchar(20) DEFAULT NULL COMMENT '瀹㈡埛鍦板潃ID',
  `express_pro_type` varchar(10) DEFAULT NULL COMMENT '蹇€掍骇鍝佺被鍨嬶細1->鏍囧噯蹇€掋€�2->椤轰赴鐗规儬銆�5->椤轰赴娆℃櫒銆�6->鍗虫棩浠�',
  `express_flag` varchar(32) DEFAULT NULL COMMENT '蹇€掓爣璇嗙紪鐮�',
  `express_pay_type` varchar(30) DEFAULT NULL COMMENT '蹇€掍粯娆炬柟寮� 1-瀵勪粯锛�2-鍒颁粯',
  `settle_company_no` varchar(20) DEFAULT NULL COMMENT '璁¤垂鍏徃缂栫爜',
  `ret_reason` varchar(255) DEFAULT NULL COMMENT '閫€璐у師鍥�',
  `ret_type` tinyint(4) DEFAULT NULL COMMENT '閫€鍘傜被鍨� 1-瀹㈡畫 2-缁翠慨 3-鍘熸畫',
  `ret_code` varchar(64) DEFAULT NULL COMMENT '閫€璐х紪鐮�',
  `if_qrcode` tinyint(4) NOT NULL DEFAULT '0' COMMENT '鏄惁浜岀淮鐮� 0-鍚� 1-鏄�',
  PRIMARY KEY (`id`, `partion_no`),
  UNIQUE KEY `uk_sno_bno` (`store_no`, `bill_no`, `partion_no`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `uk_id` (`id`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_create_time` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_update_time` (`update_time`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 131490930607400065 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 TABLEGROUP = 'tg_wms_partion_no' COMMENT = '鍑哄簱鍗曚富琛�'
 partition by list columns(partion_no)
(partition p1 values in ('wms_db001'),
partition p2 values in ('wms_db002'),
partition p3 values in ('wms_db003'),
partition p4 values in ('wms_db004'),
partition p5 values in ('wms_db005'),
partition p6 values in ('wms_db006'),
partition p7 values in ('wms_db007'),
partition p8 values in ('wms_db008'),
partition p9 values in ('wms_db009'));


CREATE TABLE `bl_om_deliver_dtl` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '鍒嗗竷寮廔D',
  `company_id` bigint(20) NOT NULL COMMENT '绉熻祦鍏徃ID',
  `store_no` varchar(20) NOT NULL COMMENT '浠撳簱缂栧彿',
  `bill_no` varchar(32) NOT NULL COMMENT '鍗曟嵁鍙�',
  `join_no` varchar(32) NOT NULL COMMENT '闆嗚揣鍗曞彿',
  `recheck_no` varchar(32) NOT NULL COMMENT '澶嶆牳鍗曞彿',
  `status` varchar(10) NOT NULL DEFAULT '10' COMMENT '鍗曟嵁鐘舵€� 10-寤哄崟, 20-宸插嚭搴�',
  `cell_no` varchar(20) DEFAULT NULL COMMENT '鍌ㄤ綅缂栫爜',
  `box_no` varchar(32) NOT NULL DEFAULT '0' COMMENT '绠卞彿',
  `item_no` varchar(20) NOT NULL COMMENT '鍟嗗搧缂栧彿',
  `size_no` varchar(20) NOT NULL COMMENT '灏虹爜缂栧彿',
  `brand_dept_no` varchar(20) NOT NULL COMMENT '鍝佺墝閮ㄧ紪鍙�',
  `batch_no` varchar(32) NOT NULL DEFAULT '0' COMMENT '鎵规鍙�',
  `item_quality` varchar(10) NOT NULL DEFAULT '0' COMMENT '鍟嗗搧鍝佽川-WMS_BM_ITEM_QUALITY',
  `if_box` tinyint(4) NOT NULL DEFAULT '0' COMMENT '鏄惁鏁寸搴撳瓨 0-鍚� 1-鏄�',
  `if_pack_box` tinyint(4) NOT NULL DEFAULT '0' COMMENT '鏄惁瑁呯鏄庣粏 0-鍚� 1-鏄�',
  `om_notify_no` varchar(32) NOT NULL COMMENT '绾夸笅閫氱煡鍗曞彿',
  `om_notify_type` varchar(10) NOT NULL DEFAULT '0' COMMENT '鍗曟嵁绫诲瀷 2110-浠撳嚭搴椼€�2210-璋冩嫧銆�2310-鎵瑰彂銆�3410-鍏朵粬鍑哄簱',
  `from_power_unit_no` varchar(20) DEFAULT NULL COMMENT '鏉ユ簮璐ф潈缂栧彿',
  `to_power_unit_no` varchar(20) DEFAULT NULL COMMENT '鐩殑璐ф潈缂栧彿',
  `if_span` tinyint(4) DEFAULT '0' COMMENT '鏄惁璺ㄥ尯 0-鍚� 1-鏄�',
  `purchase_bill_no` varchar(30) DEFAULT NULL COMMENT '棰勫埌璐у崟閫氱煡鍗曟潵婧愬崟鍙�',
  `if_through` tinyint(4) DEFAULT '0' COMMENT '鏄惁鐩撮€� 0鍚� 1鏄�',
  `pack_unit` tinyint(4) DEFAULT NULL COMMENT '鍖呰鍗曚綅-WMS_PACK_UNIT',
  `box_length` decimal(8,2) NOT NULL DEFAULT '0.00' COMMENT '绠遍暱搴︼紙鍗曚綅:cm锛�',
  `box_width` decimal(8,2) NOT NULL DEFAULT '0.00' COMMENT '绠卞搴︼紙鍗曚綅:cm锛�',
  `box_height` decimal(8,2) NOT NULL DEFAULT '0.00' COMMENT '绠遍珮搴︼紙鍗曚綅:cm锛�',
  `box_weight` decimal(8,4) NOT NULL DEFAULT '0.0000' COMMENT '绠辫嚜閲嶏紙鍗曚綅:kg锛�',
  `out_qty` decimal(12,3) NOT NULL DEFAULT '0.000' COMMENT '鍑哄簱鏁伴噺',
  `scan_user` varchar(20) DEFAULT NULL COMMENT '鎵弿浜�',
  `creator` varchar(20) NOT NULL COMMENT '鍒涘缓浜�',
  `create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '鍒涘缓鏃堕棿(涓嶅彲浜轰负璋冩暣)',
  `modifier` varchar(20) DEFAULT NULL COMMENT '淇敼浜�',
  `modify_time` datetime DEFAULT NULL COMMENT '淇敼鏃堕棿',
  `remarks` varchar(255) DEFAULT NULL COMMENT '澶囨敞',
  `partion_no` varchar(20) NOT NULL COMMENT '鍒嗗簱缂栧彿',
  `del_tag` varchar(2) NOT NULL DEFAULT '0' COMMENT '褰掓。鍒犻櫎鏍囪瘑(0=姝ｅ父褰掓。锛屽垹闄ゅ悗鏁版嵁鍚屾涓嬫父 1=褰掓。鍒犻櫎锛屽垹闄ゅ悗鏁版嵁涓嶅悓姝ヤ笅娓�)',
  `update_time` datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '璁板綍鏇存柊鏃堕棿',
  `box_volume` decimal(8,4) NOT NULL DEFAULT '0.0000' COMMENT '绠变綋绉紙鍗曚綅:cm鲁锛�',
  `om_source_no` varchar(32) NOT NULL COMMENT '閫氱煡鍗曞彿鏉ユ簮鍗曞彿',
  `ret_price` decimal(12,4) NOT NULL DEFAULT '0.0000' COMMENT '閫€璐т环鏍�',
  `if_print_label` tinyint(4) DEFAULT '0' COMMENT '鏄惁鎵撳嵃绠辨爣璐� 0-鍚�,1-鏄�',
  `re_qty` decimal(12,3) NOT NULL DEFAULT '0.000' COMMENT '褰掕繕鏁伴噺',
  PRIMARY KEY (`id`, `partion_no`),
  UNIQUE KEY `uk_id` (`id`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_create_time` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_update_time` (`update_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_sno_bno` (`store_no`, `bill_no`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 1673563339415430275 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 TABLEGROUP = 'tg_wms_partion_no' COMMENT = '鍑哄簱鍗曟槑缁嗚〃'
 partition by list columns(partion_no)
(partition p1 values in ('wms_db001'),
