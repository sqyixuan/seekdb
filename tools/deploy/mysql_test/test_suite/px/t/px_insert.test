--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql3
# tags: optimizer,dml

--disable_warnings
drop database if exists muhangtest;
drop table if exists test;
drop table if exists tt;
create database muhangtest;
use muhangtest;
--enable_warnings

create table test(c1 int, c2 int, c3 int, c4 char(14) default 'nihao' primary key) partition by key(c4) partitions 4;
insert into test values(1,2,3, 'damdam');
insert into test(c1,c2,c3) values(10,2,3);

create table tt(c1 int,c2 int, c3 int, c4 varchar(12));
insert into tt values(4,5,6,'xxx');

## 当要插入的表与查询表无关
explain insert into test(c1,c2,c3,c4) select * from tt;
explain insert into test(c1,c2,c3,c4) select /*+parallel(4)*/ * from tt;

explain insert into test(c1,c2,c3,c4) select test.c1,test.c2,test.c3,test.c4 from test,tt where tt.c1 = test.c4;
explain insert into test(c1,c2,c3,c4) select /*+parallel(4)*/ test.c1,test.c2,test.c3,test.c4 from test,tt where tt.c1 = test.c4;
explain insert into test(c1,c2,c3,c4) select /*+parallel(4) leading(tt test) pq_distribute(test none broadcast)*/ test.c1,test.c2,test.c3,test.c4 from test,tt where tt.c1 = test.c4;

## 分区键为default值的情况下
explain insert into test(c1,c2,c3) select /*+parallel(4)*/ c1, c2, c3 from tt;

