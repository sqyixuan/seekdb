### nlj(hash(t1 t2) t3)
explain basic select /*+ leading((t1 t2) t3) use_hash(t2) use_nl(t3) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
select /*+ leading((t1 t2) t3) use_hash(t2) use_nl(t3) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
