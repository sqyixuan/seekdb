--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
# tags: optimizer,px

--disable_warnings
drop database if exists st;
--enable_warnings

create database st;
use st;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create table t4(c1 int, c2 int);
create table t5(c1 int, c2 int);
create table t6(c1 int, c2 int);
create table t7(c1 int, c2 int);


## test subplan filter
### block operator above child
explain basic select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ min(c1) from t2), (select /*+ parallel(t3 5) */ min(c1) from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 4) */ min(c1) from t4 where t4.c2 = t1.c2) from t1;
select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ min(c1) from t2), (select /*+ parallel(t3 5) */ min(c1) from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 4) */ min(c1) from t4 where t4.c2 = t1.c2) from t1;
--echo expected_worker_count = max(dop_t2, dop_t3, dop_t4) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite%';

explain basic select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ min(c1) from t2), (select /*+ parallel(t3 9) */ min(c1) from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 8) */ min(c1) from t4 where t4.c2 = t1.c2) from t1;
select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ min(c1) from t2), (select /*+ parallel(t3 9) */ min(c1) from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 8) */ min(c1) from t4 where t4.c2 = t1.c2) from t1;
--echo expected_worker_count = max(dop_t2, dop_t3, dop_t4) = 9
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite%';


### no block operator above child
explain basic select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ c1 from t2), (select /*+ parallel(t3 5) */ c1 from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 4) */ c1 from t4 where t4.c2 = t1.c2) from t1;
select /*+ no_rewrite */ t1.*, (select /*+ parallel(t2 6) */ c1 from t2), (select /*+ parallel(t3 5) */ c1 from t3 where t3.c2 = t1.c2), (select /*+ parallel(t4 4) */ c1 from t4 where t4.c2 = t1.c2) from t1;
--echo expected_worker_count = max(dop_t2, dop_t3 + dop_t4) = 9
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite%';





## test join
### for hash join, expected_worker_count = max(left_parallel, right_parallel).
explain basic select /*+ leading(t1 t2) use_hash(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
select /*+ leading(t1 t2) use_hash(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
--echo expected_worker_count = max(dop_t1, dop_t2) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';

explain basic select /*+ leading(t1 t2) use_hash(t2) parallel(t1 6) parallel(t2 5) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
select /*+ leading(t1 t2) use_hash(t2) parallel(t1 6) parallel(t2 5) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
--echo expected_worker_count = max(dop_t1, dop_t2) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';



### for nlj, expected_worker_count = left_parallel + right_parallel.
explain basic select /*+ leading(t1 t2) use_nl(t2) USE_NL_MATERIALIZATION(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
select /*+ leading(t1 t2) use_nl(t2) USE_NL_MATERIALIZATION(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
--echo expected_worker_count = dop_t1 + dop_t2 = 11
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';

explain basic select /*+ leading(t1 t2) use_nl(t2) NO_USE_NL_MATERIALIZATION(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
select /*+ leading(t1 t2) use_nl(t2) NO_USE_NL_MATERIALIZATION(t2) parallel(t1 5) parallel(t2 6) pq_distribute(t2 local local) */ 1 from t1, t2 where t1.c1 = t2.c1;
--echo expected_worker_count = dop_t1 + dop_t2 = 11
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';


### nlj(nlj(t1 t2) t3)
explain basic select /*+ leading((t1 t2) t3) use_nl(t2 t3) USE_NL_MATERIALIZATION(t2) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
select /*+ leading((t1 t2) t3) use_nl(t2 t3) USE_NL_MATERIALIZATION(t2) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
--echo expected_worker_count = max(dop_t1 + dop_t2, dop_t1 + dop_t3) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';
select /*+ leading((t1 t2) t3) use_nl(t2 t3) USE_NL_MATERIALIZATION(t2) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 4) parallel(t3 3) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
--echo expected_worker_count = max(dop_t1 + dop_t2, dop_t1 + dop_t3) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';

explain basic select /*+ leading((t1 t2) t3) use_nl(t2 t3) USE_NL_MATERIALIZATION(t2) NO_USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
select /*+ leading((t1 t2) t3) use_nl(t2 t3) USE_NL_MATERIALIZATION(t2) NO_USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
--echo expected_worker_count = max(dop_t1 + dop_t2, dop_t1 + dop_t3) = 6
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';


explain basic select /*+ leading((t1 t2) t3) use_nl(t2 t3) NO_USE_NL_MATERIALIZATION(t2) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
select /*+ leading((t1 t2) t3) use_nl(t2 t3) NO_USE_NL_MATERIALIZATION(t2) USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
--echo expected_worker_count = dop_t1 + dop_t2 + dop_t3 = 9
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ leading%';



explain basic select /*+ leading((t1 t2) t3) use_nl(t2 t3) NO_USE_NL_MATERIALIZATION(t2) NO_USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
select /*+ leading((t1 t2) t3) use_nl(t2 t3) NO_USE_NL_MATERIALIZATION(t2) NO_USE_NL_MATERIALIZATION(t3) parallel(t1 2) parallel(t2 3) parallel(t3 4) pq_distribute(t2 local local) pq_distribute(t3 local local) */ 1 from t1, t2, t3 where t1.c1 = t2.c1 and t1.c1 = t3.c1;
