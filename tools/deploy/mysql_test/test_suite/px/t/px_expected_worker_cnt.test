## test union
explain basic (select /*+ PQ_SET(@"SET$1" local local) parallel(t1 4) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2);
(select /*+ PQ_SET(@"SET$1" local local) parallel(t1 4) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2);
--echo expected_worker_count = max(dop_t1 + dop_t2) = 4;
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like '(select /*%';

### nlj(union(t1 t2) t3)
explain basic select /*+ no_rewrite leading(tmp t3) use_nl(t3) pq_distribute(t3 local local)  */1
from  ((select /*+ parallel(t1 4) PQ_SET(@"SET$1"  local local) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2)) tmp,
  (select /*+ parallel(t3 5) */ * from t3) t3
where tmp.c1 = t3.c1;
select /*+ no_rewrite leading(tmp t3) use_nl(t3) pq_distribute(t3 local local)  */1
from  ((select /*+ parallel(t1 4) PQ_SET(@"SET$1"  local local) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2)) tmp,
  (select /*+ parallel(t3 5) */ * from t3) t3
where tmp.c1 = t3.c1;
--echo expected_worker_count = max(dop_t1 + dop_t3, dop_t2 + dop_t3) = 9
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite%';


### hj(union(t1 t2) t3)
explain basic select /*+ no_rewrite leading(tmp t3) use_hash(t3) pq_distribute(t3 local local)  */1
from  ((select /*+ parallel(t1 4) PQ_SET(@"SET$1"  local local) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2)) tmp,
  (select /*+ parallel(t3 5) */ * from t3) t3
where tmp.c1 = t3.c1;
select /*+ no_rewrite leading(tmp t3) use_hash(t3) pq_distribute(t3 local local)  */1
from  ((select /*+ parallel(t1 4) PQ_SET(@"SET$1"  local local) */ c1 from t1) union all (select /*+ parallel(t2 3) */ c1 from t2)) tmp,
  (select /*+ parallel(t3 5) */ * from t3) t3
where tmp.c1 = t3.c1;
--echo expected_worker_count = max(dop_t1, dop_t2, dop_t3) = 5
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite%';

## nlj(union(hj(t1 t2) t3) t4)
explain basic select /*+ no_rewrite leading(tmp t4) use_nl(t4) pq_distribute(t4 local local)  */1
from  ((select /*+ parallel(t1 8) parallel(t2 3) leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) PQ_SET(@"SET$1"  local local) */ t1.c1
        from t1, t2 where t1.c1 = t2.c1)
        union all (select /*+ parallel(t3 2) */ c1 from t3)
      ) tmp,
      (select /*+ parallel(t4 4) */ * from t4) t4
where tmp.c1 = t4.c1;
select /*+ no_rewrite leading(tmp t4) use_nl(t4) pq_distribute(t4 local local)  */1
from  ((select /*+ parallel(t1 8) parallel(t2 3) leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) PQ_SET(@"SET$1"  local local) */ t1.c1
        from t1, t2 where t1.c1 = t2.c1)
        union all (select /*+ parallel(t3 2) */ c1 from t3)
      ) tmp,
      (select /*+ parallel(t4 4) */ * from t4) t4
where tmp.c1 = t4.c1;
--echo expected_worker_count = max(dop_t1, dop_t2 + dop_t4, dop_t3 + dop_t4) = max(8, 2 + 4, 3 + 4) = 8;
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite leading%';


explain basic select /*+ no_rewrite leading(tmp t4) use_nl(t4) pq_distribute(t4 local local)  */1
from  ((select /*+ parallel(t1 8) parallel(t2 3) leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) PQ_SET(@"SET$1"  local local) */ t1.c1
        from t1, t2 where t1.c1 = t2.c1)
        union all (select /*+ parallel(t3 5) */ c1 from t3)
      ) tmp,
      (select /*+ parallel(t4 4) */ * from t4) t4
where tmp.c1 = t4.c1;
select /*+ no_rewrite leading(tmp t4) use_nl(t4) pq_distribute(t4 local local)  */1
from  ((select /*+ parallel(t1 8) parallel(t2 3) leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) PQ_SET(@"SET$1"  local local) */ t1.c1
        from t1, t2 where t1.c1 = t2.c1)
        union all (select /*+ parallel(t3 5) */ c1 from t3)
      ) tmp,
      (select /*+ parallel(t4 4) */ * from t4) t4
where tmp.c1 = t4.c1;
--echo expected_worker_count = max(dop_t1, dop_t2 + dop_t4, dop_t3 + dop_t4) = max(8, 5 + 4, 3 + 4) = 9;
select EXPECTED_WORKER_COUNT from oceanbase.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'select /*+ no_rewrite leading%';
drop database if exists st;
