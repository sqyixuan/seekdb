# owner: dachuan.sdc
# owner group: sql2
# 测试 px batch rescan
# tags: px,optimizer
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

--disable_warnings
#call oceanbase.drop_tenant_force('px_batch_rescan');
--enable_warnings

#eval call oceanbase.create_mysql_tenant_1c2g('px_batch_rescan');
alter tenant sys set primary_zone = 'RANDOM';
let $zone_num = query_get_value(select count(distinct zone) cnt from oceanbase.__all_server, cnt, 1);
let $ls_num = query_get_value(select count(1) cnt from oceanbase.__all_ls where status = 'NORMAL' and ls_id > 1, cnt, 1);
if ($zone_num != $ls_num)
{
  let $cnt = 20;
  while($cnt > 0)
  {
    --sleep 1
    let $ls_num = query_get_value(select count(1) cnt from oceanbase.__all_ls where status = 'NORMAL' and ls_id > 1, cnt, 1);
    dec $cnt;
    if ($zone_num == $ls_num)
    {
      let $cnt = 0;
    }
  }
}

connect (conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

set sql_mode = '';
--disable_warnings
drop table if exists t1,t2,bug_22957926_t_1,bug_22957926_t_2;
--enable_warnings
CREATE TABLE t1(a INT);  
CREATE TABLE t2 (c2 VARCHAR(1)) ;
let $table_id1 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
let $table_id2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2', table_id, 1);
let $ls_id1 = query_get_value(select min(ls_id) ls_id from oceanbase.__all_ls where ls_id > 1, ls_id, 1);
let $ls_id2 = query_get_value(select max(ls_id) ls_id from oceanbase.__all_ls where ls_id > 1, ls_id, 1);

--disable_query_log
#eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID = $table_id1, OBJECT_ID = $table_id1 TO LS $ls_id1;
#eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID = $table_id2, OBJECT_ID = $table_id2 TO LS $ls_id2;
--enable_query_log

INSERT INTO t1 VALUES ('2001-01-01 00:00:00.000001'); 
INSERT INTO t1 VALUES(0xAEAB); 
insert into t1 values (0xFFFFFFFFFFFFFFFE);

insert into t2 values (2);

select distinct (select 1 from `t2` where `a`) `d2`, a from `t1`;
explain basic select distinct (select 1 from `t2` where `a`) `d2`, a from `t1`;

connection sys;
