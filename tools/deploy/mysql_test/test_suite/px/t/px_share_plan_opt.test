# owner: dachuan.sdc
# owner group: sql2
# 测试 px batch rescan
# tags: px,optimizer
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

--disable_warnings
#call oceanbase.drop_tenant_force('px_batch_rescan');
--enable_warnings

#eval call oceanbase.create_mysql_tenant_1c2g('px_batch_rescan');
alter tenant sys set primary_zone = 'RANDOM';
let $zone_num = query_get_value(select count(distinct zone) cnt from oceanbase.__all_server, cnt, 1);
let $ls_num = query_get_value(select count(1) cnt from oceanbase.__all_ls where status = 'NORMAL' and ls_id > 1, cnt, 1);
if ($zone_num != $ls_num)
{
  let $cnt = 20;
  while($cnt > 0)
  {
    --sleep 1
    let $ls_num = query_get_value(select count(1) cnt from oceanbase.__all_ls where status = 'NORMAL' and ls_id > 1, cnt, 1);
    dec $cnt;
    if ($zone_num == $ls_num)
    {
      let $cnt = 0;
    }
  }
}

connect (conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

set sql_mode = '';
--disable_warnings
drop table if exists t1,t2,bug_22957926_t_1,bug_22957926_t_2;
--enable_warnings
CREATE TABLE t1(a INT);  
CREATE TABLE t2 (c2 VARCHAR(1)) ;
let $table_id1 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't1', table_id, 1);
let $table_id2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2', table_id, 1);
let $ls_id1 = query_get_value(select min(ls_id) ls_id from oceanbase.__all_ls where ls_id > 1, ls_id, 1);
let $ls_id2 = query_get_value(select max(ls_id) ls_id from oceanbase.__all_ls where ls_id > 1, ls_id, 1);

--disable_query_log
#eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID = $table_id1, OBJECT_ID = $table_id1 TO LS $ls_id1;
#eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID = $table_id2, OBJECT_ID = $table_id2 TO LS $ls_id2;
--enable_query_log

INSERT INTO t1 VALUES ('2001-01-01 00:00:00.000001'); 
INSERT INTO t1 VALUES(0xAEAB); 
insert into t1 values (0xFFFFFFFFFFFFFFFE);

insert into t2 values (2);

select distinct (select 1 from `t2` where `a`) `d2`, a from `t1`;

create table bug_22957926_t_1(a int, b int, c datetime, primary key(a)) partition by hash(a) partitions 3;
create table bug_22957926_t_2(a int, b int, c datetime, primary key(a)) partition by hash(a) partitions 5;
insert into bug_22957926_t_1 values(1, 1, 20161101),(2, 2, 20161102),(3, 3, 20161103),(4, 4, 20161104), (5, 5, 20161105),(6, 6, 20161106),(7, 7, 20161107),(8, 8, 20161108), (9, 9, 20161109),(10, 10, 20161110),(11, 11, 20161111),(12, 12, 20161112), (13, 13, 20161113),(14, 14, 20161114),(15, 15, 20161115),(16, 16, 20161116), (17, 17, 20161117),(18, 18, 20161118),(19, 19, 20161119),(20, 20, 20161120);
insert into bug_22957926_t_2 values(9, 9, 20161109),(10, 10, 20161110),(11, 11, 20161111),(12, 12, 20161112), (13, 13, 20161113),(14, 14, 20161114),(15, 15, 20161115),(16, 16, 20161116), (17, 17, 20161117),(18, 18, 20161118),(19, 19, 20161119),(20, 20, 20161120), (21, 21, 20161121),(22, 22, 20161122),(23, 23, 20161123),(24, 24, 20161124), (25, 25, 20161125),(26, 26, 20161126),(27, 27, 20161127),(28, 28, 20161128);

select /*+
  BEGIN_OUTLINE_DATA                                                                                                                                                                               |
  LEADING(@"SEL$1" ("A"@"SEL$1" "B"@"SEL$1"))                                                                                                                                                      |
  USE_NL(@"SEL$1" "B"@"SEL$1")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$1" "B"@"SEL$1" LOCAL LOCAL)                                                                                                                                                  |
  FULL(@"SEL$1" "A"@"SEL$1")                                                                                                                                                                       |
  LEADING(@"SEL$2" ("B"@"SEL$2" "A"@"SEL$2"))                                                                                                                                                      |
  USE_NL(@"SEL$2" "A"@"SEL$2")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$2" "A"@"SEL$2" BC2HOST NONE)                                                                                                                                                 |
  LEADING(@"SEL$3" ("B"@"SEL$3" "A"@"SEL$3"))                                                                                                                                                      |
  USE_NL(@"SEL$3" "A"@"SEL$3")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$3" "A"@"SEL$3" BC2HOST NONE)                                                                                                                                                 |
  INDEX(@"SEL$0D9517D3" "st"."bug_22957926_t_2"@"SEL$4" "primary")                                                                                                                                 |
  INDEX(@"SEL$3" "A"@"SEL$3" "primary")                                                                                                                                                            |
  INDEX(@"SEL$2" "A"@"SEL$2" "primary")                                                                                                                                                            |
  SIMPLIFY_WINFUNC(@"SEL$4")                                                                                                                                                                       |
  OPTIMIZER_FEATURES_ENABLE('4.3.5.3')                                                                                                                                                             |
  END_OUTLINE_DATA                                                                                                                                                                                 |
 */      B.*, A.a, A.a, A.a, A.a  from      bug_22957926_t_1 A,      (select /*+no_rewrite nlj_use_batch_with_window_function_bug_53453708.yaml NO_USE_NL_MATERIALIZATION(A) leading(B,A) use_nl(B,A)*/          B.*      from          bug_22957926_t_2 A,          (select /*+no_rewrite nlj_use_batch_with_window_function_bug_53453708.yaml NO_USE_NL_MATERIALIZATION(A) leading(B,A) use_nl(B,A)*/              B.*          from              bug_22957926_t_2 A,              (SELECT a a, a b, ROW_NUMBER()  OVER (PARTITION BY a ORDER BY a DESC, a DESC, a DESC) c from bug_22957926_t_2) B          where              A.a >= B.a and A.a <= B.a order by 1) B      where         A.a >= B.a and A.a <= B.a order by 1) B  where      A.a >= B.a and A.a <= B.a order by 1, 2, 3, 4, 5, 6, 7;
explain basic select /*+
  BEGIN_OUTLINE_DATA                                                                                                                                                                               |
  LEADING(@"SEL$1" ("A"@"SEL$1" "B"@"SEL$1"))                                                                                                                                                      |
  USE_NL(@"SEL$1" "B"@"SEL$1")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$1" "B"@"SEL$1" LOCAL LOCAL)                                                                                                                                                  |
  FULL(@"SEL$1" "A"@"SEL$1")                                                                                                                                                                       |
  LEADING(@"SEL$2" ("B"@"SEL$2" "A"@"SEL$2"))                                                                                                                                                      |
  USE_NL(@"SEL$2" "A"@"SEL$2")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$2" "A"@"SEL$2" BC2HOST NONE)                                                                                                                                                 |
  LEADING(@"SEL$3" ("B"@"SEL$3" "A"@"SEL$3"))                                                                                                                                                      |
  USE_NL(@"SEL$3" "A"@"SEL$3")                                                                                                                                                                     |
  PQ_DISTRIBUTE(@"SEL$3" "A"@"SEL$3" BC2HOST NONE)                                                                                                                                                 |
  INDEX(@"SEL$0D9517D3" "st"."bug_22957926_t_2"@"SEL$4" "primary")                                                                                                                                 |
  INDEX(@"SEL$3" "A"@"SEL$3" "primary")                                                                                                                                                            |
  INDEX(@"SEL$2" "A"@"SEL$2" "primary")                                                                                                                                                            |
  SIMPLIFY_WINFUNC(@"SEL$4")                                                                                                                                                                       |
  OPTIMIZER_FEATURES_ENABLE('4.3.5.3')                                                                                                                                                             |
  END_OUTLINE_DATA                                                                                                                                                                                 |
 */      B.*, A.a, A.a, A.a, A.a  from      bug_22957926_t_1 A,      (select /*+no_rewrite nlj_use_batch_with_window_function_bug_53453708.yaml NO_USE_NL_MATERIALIZATION(A) leading(B,A) use_nl(B,A)*/          B.*      from          bug_22957926_t_2 A,          (select /*+no_rewrite nlj_use_batch_with_window_function_bug_53453708.yaml NO_USE_NL_MATERIALIZATION(A) leading(B,A) use_nl(B,A)*/              B.*          from              bug_22957926_t_2 A,              (SELECT a a, a b, ROW_NUMBER()  OVER (PARTITION BY a ORDER BY a DESC, a DESC, a DESC) c from bug_22957926_t_2) B          where              A.a >= B.a and A.a <= B.a order by 1) B      where         A.a >= B.a and A.a <= B.a order by 1) B  where      A.a >= B.a and A.a <= B.a order by 1, 2, 3, 4, 5, 6, 7;

connection sys;
call oceanbase.drop_tenant_force('px_batch_rescan');
connection default;
--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings
create table t0(c1 varchar(10));
create table t1(c1 varchar(10) primary key);
insert into t0 values('a');
select /*+ leading(t0 t1) use_nl(t1) parallel(2) no_use_das(t1) no_rewrite*/ count(*) from (select format(null, t0.c1) a, format(null, t0.c1) b from t0) t0, t1 where t0.a =t1.c1 and t1.c1 >= t0.b;
drop table t0;
drop table t1;
