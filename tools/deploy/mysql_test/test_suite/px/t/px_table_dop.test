--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: sql2
# 测试 table dop
# tags: dml,px,optimizer
--result_format 4
--disable_warnings

--disable_warnings
drop table if exists p1,p2,p3,p4,t1,t2;
--enable_warnings

## 分区表与非分区表对比
create table p1(c1 int primary key, c2 int) parallel 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table p1;
create table p2(c1 int primary key, c2 int) parallel 1 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table p2;
explain select * from p2;
alter table p2 parallel 10;
explain select * from p2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table p2;
alter table p2 parallel 1;
explain select * from p2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table p2;

# parallel=1 的情况下，分区表与非分区表
explain basic select * from p1;
explain basic select * from p2;
--error 0,942
drop table p2;
create table p2(c1 int primary key, c2 int) parallel 2;
# 非分区表情况下，parallel=1与parallel>1的情况
explain basic select * from p1;
explain basic select * from p2;

# hint 与 table dop优先级
explain basic select /*+parallel(4)*/ * from p2;

create table p3(c1 int primary key, c2 int) parallel 3;
create table p4(c1 int primary key, c2 int) parallel 4;

explain basic select /*+use_hash(p1,p2)*/ * from p1,p2 where p1.c1 = p2.c1;
explain basic select /*+use_hash(p1,p2)*/ * from p1,p2 where p1.c1 = p2.c2;
explain basic select /*+leading(p4,p3,p2,p1)*/ * from p1,p2,p3,p4 where p1.c1 = p2.c1 and p2.c1 = p3.c1 and p3.c1 = p4.c1;
explain basic select /*+leading(p2,p1,p3,p4)*/ * from p1,p2,p3,p4 where p1.c1 = p2.c1 and p2.c1 = p3.c1 and p3.c1 = p4.c1;

# 测试disable parallel query：只能进行单DFO调度
set _enable_parallel_query = false;
explain basic select /*+leading(p2,p1,p3,p4)*/ * from p1,p2,p3,p4 where p1.c1 = p2.c1 and p2.c1 = p3.c1 and p3.c1 = p4.c1;
set _enable_parallel_query = true;

## PW情况下的处理
create table t1(c1 int primary key, c2 int) parallel 3 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
create table t2(c1 int primary key, c2 int) parallel 5 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
explain basic select * from t1,t2 where t1.c1 = t2.c1;

set _enable_parallel_query = false;
explain basic select * from t1,t2 where t1.c1 = t2.c1;
set _enable_parallel_query = true;

## 测试DML
explain delete /*+use_px*/ from t1;
explain update /*+use_px*/ t1 set c2 = 20;
# t1，t2是PW，table dop不相同，选择较大的dop
explain insert /*+use_px*/ into t2 select * from t1;
explain insert /*+use_px*/ into t1 select * from t2;

set _enable_parallel_query = false;
explain insert /*+use_px*/ into t2 select * from t1;
set _enable_parallel_query = true;

## 测试索引的dop
create index t1_i1 on t1(c2) global parallel 10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
explain select /*+index (t1 t1_i1)*/ c2 from t1;
set _enable_parallel_query = false;
explain select /*+index (t1 t1_i1)*/ c2 from t1;
set _enable_parallel_query = true;
alter table t1 alter index t1_i1 parallel 7;
explain select /*+index (t1 t1_i1)*/ c2 from t1;
alter table t1 alter index t1_i1 parallel 10;
create index t2_i1 on t2(c2) global;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
explain select /*+index (t2 t2_i1)*/ c2 from t2;

## 测试修改不存在索引的dop
--error 1176
alter table t1 alter index phantom_index parallel 1;

--disable_warnings
drop table if exists p1,p2,p3,p4,t1,t2;
