#owner group: SQL Executor
# tags: optimizer
# desc: test partition join filter pushdown to the GI above the table scan operator which is the right child of NLJ

#       HJ
#     /   \
#  JFC     ...
#   |       |
#  ...      NLJ
#         /   \
#      ...     GI (PARTITION FILTER GI)
#               |
#              TSC

# case 1, see issue 
--disable_warnings
drop table if exists table10_smallint_autoinc, table100_tinyint_autoinc, table1_key_pk_parts_16_double;
--enable_warnings

CREATE TABLE table10_smallint_autoinc (
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_char_20_index char(20),
col_char_20 char(20),
col_bigint bigint,
col_bigint_index bigint,
col_timestamp_6_index timestamp(6) NULL DEFAULT NULL,
pk smallint auto_increment,
/*Indices*/
index idx3(pk, col_char_20_index ),
index idx1(pk, col_bigint_index ),
index idx5(pk, col_timestamp_6_index ),
primary key (pk) );

CREATE TABLE table100_tinyint_autoinc (
col_char_20 char(20),
col_bigint bigint,
col_char_20_index char(20),
col_timestamp_6_index timestamp(6) NULL DEFAULT NULL,
col_bigint_index bigint,
pk tinyint auto_increment,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
/*Indices*/
index idx3(pk, col_char_20_index ),
index idx5(pk, col_timestamp_6_index ),
index idx1(pk, col_bigint_index ),
primary key (pk) );

CREATE TABLE table1_key_pk_parts_16_double (
col_bigint_unsigned_key bigint unsigned,
col_char_20_unique_key char(20),
col_bigint_unique_key bigint,
col_bigint_unsigned bigint unsigned,
col_bigint bigint,
col_char_20_key char(20),
col_bigint_signed_key bigint signed,
pk double,
col_decimal_20_0_unsigned_uniq decimal(20,0) unsigned,
col_decimal_20_0 decimal(20,0),
col_decimal_20_0_unique_key decimal(20,0),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_decimal_20_0_key decimal(20,0),
col_decimal_20_0_signed_key decimal(20,0) signed,
col_bigint_unsigned_unique_key bigint unsigned,
col_bigint_key bigint,
col_decimal_20_0_signed_unique decimal(20,0) signed,
col_decimal_20_0_signed decimal(20,0) signed,
col_decimal_20_0_unsigned decimal(20,0) unsigned,
col_bigint_signed_unique_key bigint signed,
col_char_20 char(20),
col_timestamp_6_unique_key timestamp(6) NULL DEFAULT NULL,
col_decimal_20_0_unsigned_key decimal(20,0) unsigned,
col_timestamp_6_key timestamp(6) NULL DEFAULT NULL,
col_bigint_signed bigint signed,
/*Indices*/
key idx6(pk, col_bigint_unsigned_key ),
unique key idx19(pk, col_char_20_unique_key ),
unique key idx1(pk, col_bigint_unique_key ),
key idx18(pk, col_char_20_key ),
key idx3(pk, col_bigint_signed_key ),
primary key (pk) ,
unique key idx16(pk, col_decimal_20_0_unsigned_uniq ),
unique key idx10(pk, col_decimal_20_0_unique_key ),
key idx9(pk, col_decimal_20_0_key ),
key idx12(pk, col_decimal_20_0_signed_key ),
unique key idx7(pk, col_bigint_unsigned_unique_key ),
key idx0(pk, col_bigint_key ),
unique key idx13(pk, col_decimal_20_0_signed_unique ),
unique key idx4(pk, col_bigint_signed_unique_key ),
unique key idx22(pk, col_timestamp_6_unique_key ),
key idx15(pk, col_decimal_20_0_unsigned_key ),
key idx21(pk, col_timestamp_6_key ))  PARTITION BY key (pk) partitions 16;

insert into table10_smallint_autoinc(pk) values(1),(2),(3),(4),(5),(6),(7),(8),(9);
insert into table100_tinyint_autoinc(pk) values(1),(2),(3),(4),(5),(6),(7),(8),(9);
insert into table1_key_pk_parts_16_double(pk) values(1),(2),(3),(4),(5),(6),(7),(8),(9);

explain basic DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3) leading(table100_tinyint_autoinc) semi_to_inner(view1) pq_distribute(view1 bc2host none) */
FROM table100_tinyint_autoinc
WHERE PK IN 
    (SELECT PK
    FROM 
        (SELECT /*+ leading(table2 table1) use_nl(table2 table1) pq_distribute(table1 partition none)*/ table1 . pk
        FROM table1_key_pk_parts_16_double AS table1
        INNER JOIN table10_smallint_autoinc AS table2
        USING ( pk )
        ORDER BY  col_char_20_index DESC , pk ASC ,1 )TC1);

DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3) leading(table100_tinyint_autoinc) semi_to_inner(view1) pq_distribute(view1 bc2host none) */
FROM table100_tinyint_autoinc
WHERE PK IN 
    (SELECT PK
    FROM 
        (SELECT /*+ leading(table2 table1) use_nl(table2 table1) pq_distribute(table1 partition none)*/ table1 . pk
        FROM table1_key_pk_parts_16_double AS table1
        INNER JOIN table10_smallint_autoinc AS table2
        USING ( pk )
        ORDER BY  col_char_20_index DESC , pk ASC ,1 )TC1);

--disable_warnings
drop table if exists table10_smallint_autoinc, table100_tinyint_autoinc, table1_key_pk_parts_16_double, t1, t2;
--enable_warnings
