insert into t2_var select null from t2_var;
insert into t2_var select null from t2_var;
insert into t2_var select null from t2_var;
commit;

select /*+ use_px parallel(2) use_merge_aggregate */ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t1_var a)a join t2_var b on a.c00=b.c0 where a.c0 + sleep(0.1) >=b.c0 limit 1;
select /*+ use_px parallel(2) use_merge_aggregate */ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t1_var a)a join t2_var b on a.c00=b.c0 where a.c0 >=b.c0 limit 1;
select /*+ no_use_px parallel(2) use_merge_aggregate */ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t1_var a)a join t2_var b on a.c00=b.c0 where a.c0 + sleep(0.1) >=b.c0 limit 1;
select /*+ no_use_px parallel(2) use_merge_aggregate */ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t1_var a)a join t2_var b on a.c00=b.c0 where a.c0 >=b.c0 limit 1;


drop table t1_var;
drop table t2_var;


