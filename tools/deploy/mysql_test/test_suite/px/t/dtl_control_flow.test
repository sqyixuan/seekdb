--disable_warnings
--error 0,1051
drop table t111_var;
--error 0,1051
drop table t222_var;
--enable_warnings

create table t111_var(c0 bigint primary key,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext)
partition by hash(c0) partitions 10;
insert into t111_var values(1,repeat('ab',200),repeat('ab',200),repeat('ab',200),repeat('ab',200),repeat('ab',200),repeat('ab',200),repeat('abcdefghij',400));
insert into t111_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
commit;


create table t222_var(c0 bigint);
insert into t222_var values(0);
insert into t222_var select c0+1 from t222_var;
insert into t222_var select c0+10 from t222_var;
insert into t222_var select c0+100 from t222_var;
insert into t222_var select c0+1000  from t222_var;
insert into t222_var select c0+10000  from t222_var;
insert into t222_var select c0+100000  from t222_var;
insert into t222_var select c0+1000000 from t222_var;
insert into t222_var select c0+10000000  from t222_var;
insert into t222_var select c0+100000000  from t222_var;
insert into t222_var select c0+1000000000  from t222_var;
insert into t222_var select c0+10000000000  from t222_var;
insert into t222_var select c0+100000000000  from t222_var;
commit;

select /*+ use_px parallel(2)  use_merge(a,b)*/ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t111_var a)a join t222_var b on a.c00=b.c0 where a.c0 + sleep(0.01) >=b.c0 order by a.c0 limit 1;
select /*+ no_use_px parallel(2)  use_merge(a,b)*/ SQL_CALC_FOUND_ROWS count(*) from (select a.c0 as c00, a.* from t111_var a)a join t222_var b on a.c00=b.c0 where a.c0 + sleep(0.01) >=b.c0 order by a.c0 limit 1;


drop table t111_var;
drop table t222_var;

