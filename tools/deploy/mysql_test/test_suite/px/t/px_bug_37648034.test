#owner: dachuan.sdc
#owner group: sql2
# tags: optimizer,dml

--disable_warnings
drop database if exists yishentest;
drop table if exists test;
drop table if exists tt;
create database yishentest;
use yishentest;
--enable_warnings


CREATE TABLE `biz_calendar` (
  `PLACE_ID` char(1) NOT NULL,
  `PHYSICAL_DATE` int(11) NOT NULL,
  `DATE_FLAG` char(1) NOT NULL,
  `ALLOW_MODIFY` char(1) NOT NULL DEFAULT '1',
  UNIQUE KEY `BIZ_CALENDAR_UI1` (`PLACE_ID`, `PHYSICAL_DATE`) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `bf_params` (
  `PARAM_KEY` varchar(32) NOT NULL,
  `PARAM_CHANNEL` int(11) NOT NULL,
  `PARAM_VALUE` varchar(128) NOT NULL,
  `PARAM_DESC` varchar(256) NOT NULL,
  `PARAM_CLASS` varchar(512) NOT NULL,
  `IN_DATE` int(11) NOT NULL,
  `LM_DATE` int(11) NOT NULL,
  UNIQUE KEY `BF_PARAMS_UIDX1` (`PARAM_KEY`, `PARAM_CHANNEL`) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `subsys_pvt_cfg` (
  `SUBSYS` smallint(6) NOT NULL DEFAULT '0',
  `SUBSYS_ID` varbinary(16) NOT NULL,
  `SUBSYS_SN` smallint(6) NOT NULL DEFAULT '0',
  `LAST_SYS_DATE` int(11) NOT NULL,
  `LAST_BIZ_DATE` int(11) NOT NULL,
  `SYS_DATE` int(11) NOT NULL,
  `BIZ_DATE` int(11) NOT NULL,
  `BIZ_STATUS` char(1) NOT NULL,
  `AUTH_CHNL` varbinary(32) NOT NULL,
  UNIQUE KEY `SUBSYSPVTCFG_UI1` (`SUBSYS`) BLOCK_SIZE 16384 GLOBAL
);

--disable_result_log
--sleep 2
insert into biz_calendar values(0, 20211231, 1, 1);
insert into biz_calendar values(0, 20211230, 1, 1);
insert into biz_calendar values(0, 20211030, 1, 1);
insert into subsys_pvt_cfg values(1, 'UAP', 1, 20211029, 20211029, 20211101, 20211101,0, '');
select count(*) from biz_calendar;
select count(*) from subsys_pvt_cfg;
--enable_result_log

--result_format 4
--explain_protocol 2

INSERT /*+ enable_parallel_dml parallel(4)  */ INTO BF_PARAMS (PARAM_KEY, PARAM_CHANNEL, PARAM_VALUE, PARAM_DESC, PARAM_CLASS, IN_DATE, LM_DATE)
SELECT '@AGENT_ID' AS PARAM_KEY,   0 AS PARAM_CHANNEL, '''''' AS PARAM_VALUE,                               '@AGENT_ID' AS PARAM_DESC,        '@AGENT_ID' AS PARAM_CLASS, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'ED_FILE_DIR' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/UAPDataShare' AS PARAM_VALUE,                      '日终文件目录' AS PARAM_DESC,      'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'TO_HKEX' AS PARAM_KEY,     0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/to_hkex' AS PARAM_VALUE,      '港交所发送文件路径' AS PARAM_DESC, 'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'FROM_HKEX' AS PARAM_KEY,   0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/from_hkex' AS PARAM_VALUE,    '港交所接收文件路径' AS PARAM_DESC, 'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'PFX_CSDCKEY' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/UAPDataShare/csdcuap/pfxdata/NULL' AS PARAM_VALUE, '密钥路径' AS PARAM_DESC,          'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION
SELECT 'PROGRAM_DIR' AS PARAM_KEY, 0 AS PARAM_CHANNEL, '/home/kcbp/kcbp/bin64/fileconv' AS PARAM_VALUE,     '外部程序路径' AS PARAM_DESC,       'Dir' AS PARAM_CLASS,       DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS IN_DATE, DATE_FORMAT(CURRENT_DATE,'%Y%m%d') AS LM_DATE
UNION ALL
SELECT
    'PFX_BACKUP_DIR'                   AS PARAM_KEY
    ,0                                   AS PARAM_CHANNEL
                ,CONCAT('backup/',A.BIZ_DATE,'/')    AS PARAM_VALUE
    ,'PFX发送文件监控路径'             AS PARAM_DESC
    ,'Dir'                             AS PARAM_CLASS
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS IN_DATE
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS LM_DATE
FROM SUBSYS_PVT_CFG A
UNION ALL
SELECT
    '@T-1'                               AS PARAM_KEY
    ,0                                   AS PARAM_CHANNEL
    ,CAST(A.LAST_BIZ_DATE AS CHAR(8))    AS PARAM_VALUE
    ,'T-1业务日期'                        AS PARAM_DESC
    ,'date'                              AS PARAM_CLASS
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS IN_DATE
    ,DATE_FORMAT(CURRENT_DATE,'%Y%m%d')           AS LM_DATE
FROM SUBSYS_PVT_CFG A;

--explain_protocol 0

select count(*) from BF_PARAMS;


