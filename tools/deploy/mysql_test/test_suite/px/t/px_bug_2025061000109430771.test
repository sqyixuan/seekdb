# owner: cuiyuntian.cyt
# owner group: storage
# tags: px
# desc: test adaptive gi resplit task with inc data
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(col0 bigint, col1 bigint) organization heap with column group(each column);
insert into t1 select random(1), random(2) from table(generator(100000));

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_query_log
connection obsys;
--enable_query_log
alter system major freeze tenant sys;

alter system set px_task_size='1K';
alter system set_tp tp_name=GIForcePause, error_code=4013, frequency=10;
alter system set_tp tp_name=GIForcePauseInterval, error_code=1024, frequency=1;
alter system set_tp tp_name=ENABLE_PX_TASK_REBALANCE, error_code=1, frequency=1;
--source mysql_test/include/wait_daily_merge.inc
connect (obmysql, $OBMYSQL_MS0, root, , test, $OBMYSQL_PORT);
--disable_query_log
connection obmysql;
--enable_query_log

delete from t1 where col0 in (
    select col0 from (
        select col0 from t1 order by random(3) limit 20000
    ) as temp
);

update t1 set
    col0 = col1 + 1,
    col1 = col0 + 1
where col0 in (
    select col0 from (
        select col0 from t1 order by random(4) limit 20000
    )
);

alter system set _enable_px_task_rebalance='True';
alter system set _px_task_rebalance_trigger_time='1us';
update /*+parallel(4)*/ t1 set col1 = col1+100;
alter system set _enable_px_task_rebalance='False';
alter system set _px_task_rebalance_trigger_time='10ms';

--disable_query_log
connection obsys;
--enable_query_log
alter system set px_task_size='2M';
alter system set_tp tp_name=GIForcePause, error_code=4013, frequency=0;
alter system set_tp tp_name=GIForcePauseInterval, error_code=1024, frequency=0;
alter system set_tp tp_name=ENABLE_PX_TASK_REBALANCE, error_code=1, frequency=0;
--disable_query_log
connection obmysql;
--enable_query_log
