SELECT  GRANDPARENT1 . col_varchar_20_key AS G1 FROM u AS GRANDPARENT1 LEFT JOIN hh AS GRANDPARENT2 USING ( col_varchar_20_key ) WHERE GRANDPARENT1 . `col_varchar_20` IN ( SELECT DISTINCT PARENT1 . `col_varchar_10` AS P1 FROM aa AS PARENT1 LEFT JOIN table10_key_pk_parts_1_bigint AS PARENT2 ON ( PARENT1 . `col_int_key` >= PARENT2 . `pk` ) WHERE ( ( PARENT1 . `col_date_key` < GRANDPARENT1 . `col_datetime` ) OR NOT ( GRANDPARENT1 . col_varchar_20_key IS UNKNOWN OR NOT GRANDPARENT1 . col_varchar_20_key IS UNKNOWN ) )  ) AND GRANDPARENT1 . `col_varchar_20` > 'e' GROUP BY GRANDPARENT1 . col_varchar_20_key HAVING G1 >= '2005-06-02' ORDER BY GRANDPARENT1 . col_varchar_20_key ;

