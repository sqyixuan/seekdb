create table dept2(
  DEPTNO integer,
  DNAME char(45),
  loc varchar(10)
) ;

insert into dept2 values (0, 'A', 'xx');
insert into dept2 values (1, 'B', 'yy');
insert into dept2 values (2, 'C', 'zz');
insert into dept2 values (3, 'D', 'mm');
insert into dept2 values (4, 'E', 'nn');
insert into dept2 values (5, 'F', 'oo');

--sleep 1
select /*+ use_px   parallel(2) */ *
from
    (select /*+push_pred(wn) */dname
     from dept2 d1,
               (select deptno,
                       row_number() over (partition by deptno
                                          order by deptno),
                       ename
                from emp
               ) wn
     where (dname ='A' or dname='D')
     union all
     select dname from dept2 d2 where deptno=99
    ) uv, dept2 d
where d.loc='mm' and d.dname=uv.dname;




