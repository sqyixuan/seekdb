--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: dachuan.sdc
#owner group: sql3


--disable_warnings
drop database if exists muhangtest;
create database muhangtest;
use muhangtest;
--enable_warnings

--result_format 4


create table emp (
  EMPno  number,
  ENAME varchar(30),
  JOB varchar(30),
  MGR number(4),
  HIREDATE date,
  SAL number(7,2),
  COMM number(7,2),
  DEPTNO number(2)
) ;

