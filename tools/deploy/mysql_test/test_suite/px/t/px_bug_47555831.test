# owner: zhouhaiyu.zhy
# owner group: sql2
# description: px
--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);


connection default;

--disable_warnings
drop table if exists px_t1;
drop table if exists px_t2;
--enable_warnings

create table px_t1(c1 int, c2 int) partition by hash (c2) partitions 4;
create table px_t2(c1 int, c2 int) partition by hash (c2) partitions 4;
insert into px_t1 values(1,1);


connection con;
alter system set _rowsets_enabled = false tenant=sys;
alter system set _rowsets_enabled = false tenant=all_user;
alter system set _rowsets_enabled = false tenant=all_meta;
--sleep 3


connection default;

alter system flush plan cache;
explain (select (select c1 from px_t1 limit 1) as c1 from px_t1) minus (select/*+no_rewrite*/ c1 from px_t2 group by c1);
(select (select c1 from px_t1 limit 1) as c1 from px_t1) minus (select/*+no_rewrite*/ c1 from px_t2 group by c1);


connection con;
alter system set _rowsets_enabled = true tenant=sys;
alter system set _rowsets_enabled = true tenant=all_user;
alter system set _rowsets_enabled = true tenant=all_meta;
--sleep 3


connection default;

alter system flush plan cache;
explain (select (select c1 from px_t1 limit 1) as c1 from px_t1) minus (select/*+no_rewrite*/ c1 from px_t2 group by c1);
(select (select c1 from px_t1 limit 1) as c1 from px_t1) minus (select/*+no_rewrite*/ c1 from px_t2 group by c1);

--disable_warnings
drop table if exists px_t1;
drop table if exists px_t2;
--enable_warnings
