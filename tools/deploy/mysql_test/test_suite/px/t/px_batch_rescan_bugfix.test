# owner: dachuan.sdc
# owner group: sql2
# 测试 px batch rescan
# tags: px,optimizer
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

--disable_query_log
--disable_warnings
call oceanbase.drop_tenant_force('px_batch_rescan');
--enable_warnings

#eval call oceanbase.create_mysql_tenant_1c2g('px_batch_rescan');

connect (conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--disable_warnings
DROP TABLE IF EXISTS t1,t7,t8,t9;
--enable_warnings
CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` decimal(10,5) DEFAULT NULL,
  `c3` decimal(10,5) DEFAULT NULL,
  `c4` decimal(10,5) DEFAULT NULL,
  PRIMARY KEY (`c1`),
  KEY `t1_c2_index` (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `t1_c3_index` (`c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `t1_c1_index` (`c1`) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `t7` (
  `c1` int(11) DEFAULT NULL,
  `c2` smallint(6) NOT NULL,
  `c3` int(11) NOT NULL,
  PRIMARY KEY (`c2`, `c3`),
  KEY `t7_c1_index` (`c1`) BLOCK_SIZE 16384 LOCAL,
  KEY `t7_c3_index` (`c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `t7_c2_index` (`c2`) BLOCK_SIZE 16384 LOCAL
)
 partition by hash(c2+c3)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);

CREATE TABLE `t8` (
  `c1` bigint(20) NOT NULL,
  `c2` int(11) NOT NULL,
  `c3` decimal(10,5) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`),
  KEY `t8_c3_index` (`c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `t8_c1_index` (`c1`) BLOCK_SIZE 16384 LOCAL
)
 partition by hash(c1+c2)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);


CREATE TABLE `t9` (
  `c1` decimal(10,5) NOT NULL,
  `c2` decimal(10,5) NOT NULL,
  `c3` bigint(20) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`),
  KEY `t9_c3_index` (`c3`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE =0;

let $i = 0;
while ($i < 10000)
{
  eval insert into t1 values($i, $i, $i, $i);
  inc $i;
}

let $i = 0;
while ($i < 1000)
{
  eval insert into t7 values($i, $i, $i);
  eval insert into t8 values($i, $i, $i);
  eval insert into t9 values($i, $i, $i);
  inc $i;
}

--disable_query_log
--disable_result_log
select count(*) from t1;
select count(*) from t7;
select count(*) from t8;
select count(*) from t9;
--enable_query_log
--enable_result_log

--enable_query_log
explain select c1,c2,c3,(select t9.c3 from t9 where t9.c1=t1.c1 and t9.c2 < t1.c2),c4 in (select t8.c3 from t8 where t8.c1=t1.c2 and t8.c2 < t1.c3),exists(select t7.c3 from t7 where t7.c2>t1.c3 and t7.c1 > t1.c2) from t1 ;
set ob_query_timeout = 3600000000;
--disable_result_log
select c1,c2,c3,(select t9.c3 from t9 where t9.c1=t1.c1 and t9.c2 < t1.c2),c4 in (select t8.c3 from t8 where t8.c1=t1.c2 and t8.c2 < t1.c3),exists(select t7.c3 from t7 where t7.c2>t1.c3 and t7.c1 > t1.c2) from t1 ;
--enable_result_log
select count(*) from oceanbase.__all_virtual_dtl_interm_result_monitor;
drop table t1;

--disable_warnings
DROP TABLE IF EXISTS t1bnoquj;
--enable_warnings
create table if not exists `t1bnoquj` (
	`id` int(11) not null,
	`fname` varchar(30),
	`lname` varchar(30),
	`hired` date not null default '1970-01-01',
	`separated` date not null default '9999-12-31',
	`job_code` int(11),
	`store_id` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (year(hired))
(
	PARTITION `p0`,
	PARTITION `p1`,
	PARTITION `p2`,
	PARTITION `p3`
);
create index `gidx_t1g9qzyh` on `t1bnoquj` (`hired` ASC) GLOBAL;

CREATE TABLE if not exists `sub_listkey` (
  `userid` int(11) NOT NULL,
  `usertype` int(11) NOT NULL,
  PRIMARY KEY (`userid`,
`usertype`)
) DEFAULT CHARSET = utf8mb4 
 partition by list(usertype) subpartition by key(`userid`) subpartition template (
subpartition p0,
subpartition p1,
subpartition p2)
(partition p1 values in (1),
partition p2 values in (2),
partition p3 values in (3));


CREATE TABLE t1 (f1 INT, CONSTRAINT CAFE CHECK (f1 < 10));
insert into t1 values(null);

--disable_warnings
DROP TABLE IF EXISTS list_default_test_npk;
--enable_warnings
CREATE TABLE `list_default_test_npk` (
  `id` int(11) NOT NULL,
  `name` varchar(10) NOT NULL
) DEFAULT CHARSET = utf8mb4 
 partition by list(id)
(partition p0 values in (1,3,5,7,9),
partition p1 values in (2,4,6,8));


create table if not exists `t15xvnef` (
	`c1` varchar(1),
	`c2` varchar(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
insert into t15xvnef values (null,null,32);

--disable_warnings
DROP TABLE IF EXISTS no_pk002;
--enable_warnings
create table `no_pk002`(
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`),
  KEY `agent_id_idx1` (`agent_id`) USING BTREE
) AUTO_INCREMENT=2055454 DEFAULT CHARSET=utf8;

select distinct  subq_0.c0 as c0,  subq_0.c0 as c1 from (test.no_pk002 as ref_0 inner join (select   ref_1.c3 as c0 from  test.t15xvnef as ref_1 where EXISTS ( select   ref_2.f1 as c0,  ref_1.c3 as c1,  ref_1.c1 as c2,  19 as c3,  (select group_concat(name) from test.list_default_test_npk)  as c4,   ref_1.c1 as c5,  ref_2.f1 as c6,  ref_1.c3 as c7,  ref_1.c3 as c8,  ref_2.f1 as c9,  ref_1.c1 as c10,  ref_1.c2 as c11,  ref_2.f1 as c12  from  test.t1 as ref_2 where (EXISTS ( select   ref_3.lname as c0,  ref_2.f1 as c1,  73 as c2 from  test.t1bnoquj as ref_3 where ref_2.f1 <> 71 limit 99))  or ((0)  or  ((select userid from test.sub_listkey limit 1 offset 4)  + ref_1.c3)) limit 146) limit 71)  as subq_0 on (ref_0.channel_id = subq_0.c0 )) where subq_0.c0 <> ref_0.channel_id limit 35;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(c1 int);
insert into t1 values(1),(2),(3),(4);
create table t2(c1 int, c2 int) partition by hash(c1) partitions 128;
create index idx on t2(c1, c2) local;
insert into t2 values(1, 1);
insert into t2 values(2, 2);
insert into t2 values(3, 3);
insert into t2 values(4, 4);
explain basic select /*+ monitor use_nl(t2) leading(t1 t2) no_use_das(t2) pq_distribute(t2 local local) */ * from t1, t2 where t1.c1 = t2.c1;
select /*+ monitor use_nl(t2) leading(t1 t2) no_use_das(t2) pq_distribute(t2 local local) */ * from t1, t2 where t1.c1 = t2.c1;
select plan_line_id, plan_operation, starts from oceanbase.gv$sql_plan_monitor where trace_id = last_trace_id() order by 1;

connection sys;
call oceanbase.drop_tenant_force('px_batch_rescan');
connection default;
