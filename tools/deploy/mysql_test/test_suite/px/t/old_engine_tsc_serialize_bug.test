--disable_warnings

drop table if exists t0;
CREATE TABLE IF NOT EXISTS t0(c0 MEDIUMINT(123) ZEROFILL  COMMENT 'asdf', unique key (c0) global)  PARTITION BY KEY (c0) partitions 17;
insert into t0 values (1),(2),(3),(0);
explain select  /*+parallel(5) */ * from t0 x where x.c0 not in (select * FROM t0 WHERE ( EXISTS (SELECT 1)) AND (( EXISTS (SELECT 1)) IN (t0.c0)));
select  /*+parallel(5) */ * from t0 x where x.c0 not in (select * FROM t0 WHERE ( EXISTS (SELECT 1)) AND (( EXISTS (SELECT 1)) IN (t0.c0)));


