CREATE TABLE CC (
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`,`col_varchar_key`),
  KEY `idx5` (`pk`,`col_varchar_10_key`),
  KEY `idx1` (`pk`,`col_int_key`),
  KEY `idx7` (`pk`,`col_varchar_20_key`)
);

INSERT INTO `CC` VALUES ('r','z',NULL,6,2,'h','x','h',1),('j','t','q',2,1,'i','x','n',2),('e','q','h',4,9,'e','m','b',3),(NULL,'x','z',NULL,NULL,'r','l','i',4),('b','y','o',5,7,'l','a','g',5),('l','b',NULL,6,NULL,NULL,'m',NULL,6),(NULL,'g','r',1,3,'k',NULL,'y',7),('u',NULL,'x',8,7,'o','f',NULL,8),(NULL,'u','k',0,5,'i','i','j',9),('z','c',NULL,4,4,'h','e','l',10),('l','f','c',7,8,'w','q','c',11),('u','t','c',4,9,NULL,'m','f',12),(NULL,'k','l',7,2,'s',NULL,NULL,13),('t',NULL,'o',6,0,'j','c','t',14),('u','e',NULL,6,6,'f','b','h',15),('g','l','k',NULL,1,'f',NULL,'f',16),('x','x','w',9,6,'o',NULL,'v',17),('x','m','f',5,9,'a','n',NULL,18),('y',NULL,'t',0,3,'n','g','i',19),('j','c','p',1,NULL,'c','l','x',20),('x','b','i',9,3,NULL,'s',NULL,21),('a','w','q',4,6,'k','g','r',22),('v','h','k',NULL,5,'c','s','p',23),(NULL,'g','m',3,4,'q',NULL,'g',24),(NULL,'q','u',7,5,'o','g','g',25),('w','x','c',5,2,NULL,'q','r',26),('i',NULL,'k',7,7,NULL,'r','y',27),('p',NULL,'j',0,6,'b',NULL,'w',28),('k',NULL,'x',7,1,'h','w','v',29);


SELECT table2 . `col_varchar_20_key` AS field1,
       table2 . col_varchar_key AS field2,
       table1 . col_varchar_20_key AS field3,
       table1 . col_varchar_20_key AS field4
FROM (BB AS table1
      RIGHT OUTER JOIN C AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_20`))
WHERE (table1 . `col_int` NOT IN
         (SELECT SUBQUERY1_t1 . `col_int` AS SUBQUERY1_field1
          FROM (BB AS SUBQUERY1_t1
                INNER JOIN (CC AS SUBQUERY1_t2
                            INNER JOIN BB AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `col_int` = SUBQUERY1_t2 . `col_int_key`)) ON (SUBQUERY1_t3 . `col_int_key` = SUBQUERY1_t2 . `col_int_key`))
          WHERE SUBQUERY1_t2 . `col_int_key` <> table1 . `col_int` ))
  OR (table1 . `col_varchar_20_key` != table1 . `col_varchar_20_key`
      AND table1 . `col_varchar_20_key` >= SOME
        (SELECT SUBQUERY2_t1 . `col_varchar_20` AS SUBQUERY2_field1
         FROM (B AS SUBQUERY2_t1
               RIGHT  JOIN (A AS SUBQUERY2_t2
                            INNER JOIN CC AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_int_key` = SUBQUERY2_t2 . `pk`)) ON (SUBQUERY2_t3 . `col_varchar_10` = SUBQUERY2_t2 . `col_varchar_key`))
         GROUP BY SUBQUERY2_field1))
GROUP BY field1,
         field2,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4
LIMIT 10;
