--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
#tags: optimizer
# owner group: sql2
# tags: px, for update
--result_format 4

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings

create table t1 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C1_RAND) partitions 4;
create table t2 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C1_RAND) partitions 4;
create table t3 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C1_RAND) partitions 4;
create table t4 (C1_RAND int, C2_RAND int, C3_RAND int, C4_RAND int, C5_RAND int) partition by hash(C1_RAND) partitions 4;

insert into t1 values(0,0,0,0,0);
insert into t1 values(1,1,1,1,1);
insert into t1 values(2,2,2,2,2);
insert into t1 values(3,3,3,3,3);
insert into t1 values(4,4,4,4,4);
insert into t1 values(5,5,5,5,5);
insert into t1 values(6,6,6,6,6);
insert into t1 values(7,7,7,7,7);

insert into t2 select * from t1;
insert into t3 select * from t1;
insert into t4 select * from t1;

insert into t1 values(1,2,3,4,5);
insert into t2 values(2,3,4,5,6);
insert into t3 values(3,4,5,6,7);
insert into t4 values(7,6,5,4,3);

set ob_query_timeout = 20000000;

insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;
insert into t2 select * from t2;

explain basic select /*+leading(((a b) c) d) parallel(3) use_hash(b) use_hash(c) use_hash(d) px_join_filter(d) px_join_filter(c) PQ_DISTRIBUTE(d none BROADCAST )  PQ_DISTRIBUTE(c none BROADCAST)*/ count(*) from t1 a, t2 b, t3 c, t4 d where a.C1_RAND = b.C1_RAND and a.C2_RAND = c.C2_RAND and a.C3_RAND = d.C3_RAND;

select /*+leading(((a b) c) d) parallel(3) use_hash(b) use_hash(c) use_hash(d) px_join_filter(d) px_join_filter(c) PQ_DISTRIBUTE(d none BROADCAST )  PQ_DISTRIBUTE(c none BROADCAST)*/ count(*) from t1 a, t2 b, t3 c, t4 d where a.C1_RAND = b.C1_RAND and a.C2_RAND = c.C2_RAND and a.C3_RAND = d.C3_RAND;

select count(*) from t1 a, t2 b, t3 c, t4 d where a.C1_RAND = b.C1_RAND and a.C2_RAND = c.C2_RAND and a.C3_RAND = d.C3_RAND;

# root dfo won't have bloom filter
explain basic select /*+ leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) px_join_filter(b) */ count(*) from t1, t2 where t1.c1_rand=t2.c2_rand;

select /*+ leading(t1 t2) use_hash(t2) pq_distribute(t2 local local) px_join_filter(b) */ count(*) from t1, t2 where t1.c1_rand=t2.c2_rand;

select count(*) from t1, t2 where t1.c1_rand=t2.c2_rand;

#clean environment
set ob_query_timeout = 10000000;
--disable_warnings
drop table if exists t1, t2, t3, t4;
