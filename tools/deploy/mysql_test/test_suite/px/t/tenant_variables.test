#owner: zhouhaiyu.zhy
#owner group: SQL3
#tags: px, optimizer

--enable_sorted_result
--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
create table t1 (i int primary key, j int) partition by hash(i) partitions 3;
insert into t1 values (1,1);
insert into t1 values (2,2);
insert into t1 values (3,3);

explain basic select /*+ parallel(21) */ * from t1 a, t1 b;

set ob_query_timeout = 2000000;

# 场景：
# 系统内没有运行中的 px query，会根据计划计算出 worker_count，
# 然后让 query 中 dfo 来瓜分这个 worker_count 来运行
# 所以，当 parallel_servers_target 比较小时，它能够让 query 的 dop 比指定的小（一般来说
# 小2到3倍，取决于计划中是否有 dependence dfo）。所以，将 target 设置得比较大时，
# 能够出现线程不足的情况（把 query 放进去了，结果没有线程来执行）

set global parallel_servers_target = 18;

sleep 11; # 等待生效

select /*+ parallel(20) */ * from t1 a, t1 b;
select /*+ parallel(11) */ * from t1 a, t1 b;
select /*+ parallel(10) */ * from t1 a, t1 b;


set global parallel_servers_target = 20;

sleep 11; # 等待生效

select /*+ parallel(41) */ * from t1 a, t1 b;
select /*+ parallel(11) */ * from t1 a, t1 b;
select /*+ parallel(10) */ * from t1 a, t1 b;
# dfo0=9,dfo1=1，可以运行
select /*+ parallel(9) */ * from t1 a, t1 b;



set global parallel_servers_target = 20;

sleep 11; # 等待生效

select /*+ parallel(3) */ * from t1 a, t1 b;
select /*+ parallel(5) */ * from t1 a, t1 b;
select /*+ should_fail log_level('trace') parallel(6) */ * from t1 a, t1 b;
select /*+ fail_again parallel(7) */ * from t1 a, t1 b;

--disable_query_log

set global parallel_servers_target = 10;
sleep 11; # 等待生效
--enable_query_log

