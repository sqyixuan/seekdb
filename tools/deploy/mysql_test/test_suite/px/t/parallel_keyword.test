#owner: dachuan.sdc
#tags: optimizer
#owner group: sql2
# tags: px
--result_format 4


## 以parallel作为列名
--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings


create table t1(parallel int);
create table t2(parallel int) parallel 4;
create table t3(parallel int) noparallel;

insert into t1 values (1);
insert into t2 values (2);
insert into t3 values (3);

update t1 set parallel=10 where parallel=1;
update t2 set parallel=20 where parallel=2;
update t3 set parallel=30 where parallel=3;

select parallel from t1;

select /*+ parallel(4) */ parallel from t2;

select /*+ noparallel */ parallel from t3;

explain basic select /*+ no_parallel */ parallel from t3;
set _force_parallel_query_dop = 4;
explain basic select parallel from t3;
explain basic select /*+ parallel(4) */ parallel from t3;
explain basic select /*+ no_parallel */ parallel from t3;


drop table if exists t1,t2,t3;
