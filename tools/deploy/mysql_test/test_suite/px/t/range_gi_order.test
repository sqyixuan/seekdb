#owner: zhouhaiyu.zhy
#owner group: sql2
#tags: px,optimizer
--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings


create table t1(a int, b int, primary key(a,b), index i1 (b) local) partition by range columns(b) (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than (30)
);

insert into t1 values (1,1);
alter table t1 truncate partition p0;

insert into t1 values (4,4);
insert into t1 values (6,6);
insert into t1 values (15,15);


explain basic select  * from t1 order by b asc;
select * from t1 order by b asc;

explain basic select  * from t1 order by b desc;
select * from t1 order by b desc;

