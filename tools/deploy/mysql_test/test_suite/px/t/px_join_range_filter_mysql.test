--result_format 4
--sorted_result
SELECT  A.COL_MEDIUMINT_KEY,B.COL_VARCHAR_10_KEY FROM table10_hash_pk_parts_4_bigint A,table10_hash_pk_parts_4_bigint B,table30_bigint C WHERE A.COL_VARCHAR_10 = B.COL_VARCHAR_10 AND B.COL_VARCHAR_10 = C.COL_VARCHAR_10_KEY;
--sorted_result
SELECT /*+ parallel(8)*/  A.COL_MEDIUMINT_KEY,B.COL_VARCHAR_10_KEY, A.COL_VARCHAR_10, C.COL_VARCHAR_10_KEY FROM table10_hash_pk_parts_4_bigint A,table10_hash_pk_parts_4_bigint B,table30_bigint C WHERE A.COL_VARCHAR_10 <=> B.COL_VARCHAR_10 AND B.COL_VARCHAR_10 <=> C.COL_VARCHAR_10_KEY;

DROP TABLE /*! IF EXISTS*/ table10_hash_pk_parts_4_bigint;
DROP TABLE /*! IF EXISTS*/ table30_bigint;

DROP TABLE /*! IF EXISTS*/ t1;
DROP TABLE /*! IF EXISTS*/ t2;
create table t1(c1 int, c2 int) partition by hash(c2) partitions 4;
create table t2(c1 int, c2 int, primary key(c1, c2)) partition by hash(c2) partitions 6;
explain basic select /*+leading(t1 t2) parallel(4) use_hash(t2) PQ_DISTRIBUTE(t2 bc2host none)  px_join_filter(t2)*/ *from t1 join t2 on t1.c1=t2.c1;
select /*+leading(t1 t2) parallel(4) use_hash(t2) PQ_DISTRIBUTE(t2 bc2host none)  px_join_filter(t2)*/ *from t1 join t2 on t1.c1=t2.c1;
DROP TABLE /*! IF EXISTS*/ t1;
DROP TABLE /*! IF EXISTS*/ t2;

--enable_warnings

--disable_warnings
DROP TABLE /*! IF EXISTS*/ t1;
DROP TABLE /*! IF EXISTS*/ t2;
create table t1(pk int primary key, c1 int, c2 int, c3 int, key idx_c1_c2(c1, c2));
create table t2(pk int primary key, c1 int, c2 int, c3 int, key idx_c1_c2(c1, c2));
--enable_warnings

insert into t1 values(0, 2, 0, 1);
insert into t1 values(1, 1, 1, 1);
insert into t1 values(2, 2, 1, 1);
insert into t1 values(3, 2, 1, 1);
insert into t1 values(4, 4, 0, 1);
insert into t2 values(0, 2, 0, 1);
insert into t2 values(1, 1, 1, 1);
insert into t2 values(2, 2, 1, 5);
insert into t2 values(3, 2, 1, 4);
insert into t2 values(4, 4, 0, 3);
explain basic select /*+parallel(2) px_join_filter(t2) leading(t1 t2) use_hash(t1 t2)*/ * from t1 join t2 on t1.c1=t2.c1;
-- sorted_result
select /*+parallel(2) px_join_filter(t2) leading(t1 t2) use_hash(t1 t2)*/ * from t1 join t2 on t1.c1=t2.c1;

DROP TABLE /*! IF EXISTS*/ t1;
DROP TABLE /*! IF EXISTS*/ t2;

create table t1(c1 int(127));
create table t2(c1 int(127) DEFAULT NULL, c2 int(127) DEFAULT NULL, c3 int(127) GENERATED ALWAYS AS ((c1 + c2)) VIRTUAL, UNIQUE KEY k2 (c3) BLOCK_SIZE 16384 LOCAL);
insert into t1 select random(123) % 1000 from table(generator(100));
insert into t2(c1, c2) select random(123) % 1000, random(456) % 100 from table(generator(100));
explain basic  select /*+parallel(2) px_join_filter(t2) use_hash(t1 t2) leading(t1 t2) index(t2 k2)*/ * from t1 join t2 on t1.c1=t2.c3;
--sorted_result
select /*+parallel(2) px_join_filter(t2) use_hash(t1 t2) leading(t1 t2) index(t2 k2)*/ * from t1 join t2 on t1.c1=t2.c3;
DROP TABLE /*! IF EXISTS*/ t1;
DROP TABLE /*! IF EXISTS*/ t2;
