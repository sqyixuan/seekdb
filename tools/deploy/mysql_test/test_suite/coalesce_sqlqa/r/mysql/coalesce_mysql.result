coalesce-1-1  0个参数
select coalesce()  FROM   dual;
ERROR 42000: Incorrect parameter count in the call to native function 'coalesce'
coalesce-2-1  1个参数       
SELECT   coalesce(500) FROM dual;
coalesce(500)
500
SELECT   coalesce('') FROM dual;
coalesce('')

SELECT   coalesce(null) FROM dual;
coalesce(null)
NULL
SELECT   coalesce('gkkk') FROM dual;
coalesce('gkkk')
gkkk
coalesce-1-3-1   参数类型不相同
select coalesce('HelloWorld',1) value from dual;
value
HelloWorld
coalesce-1-3-2   参数类型都是 字符 
select coalesce('HelloWorld','1') value from dual;
value
HelloWorld
coalesce-1-3-3   参数类型都是数字
select coalesce(1,2) value from dual;
value
1
select coalesce(-1,2) value from dual;
value
-1
select coalesce(1,-2) value from dual;
value
1
select coalesce(1.1,2.1) value from dual;
value
1.1
select coalesce(0,2.1) value from dual;
value
0.0
coalesce-1-3-4  参数类型都是空
select coalesce(' ','') value from dual;
value
 
coalesce-1-3-5 参数类型都是null
select coalesce(NULL,null) value from dual;
value
NULL
coalesce-1-3-6  参数类型一个字符一个null
select coalesce('HelloWorld',null) value from dual;
value
HelloWorld
coalesce-1-3-7  参数类型一个数字一个null
select coalesce(100,null) value from dual;
value
100
coalesce-1-3-8 参数类型都是日期
select coalesce(null,date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;
coalesce(null,date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))
20080808222301
select coalesce(date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'),date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;
coalesce(date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'),date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))
20080808222301
select coalesce('',date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;
coalesce('',date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))

