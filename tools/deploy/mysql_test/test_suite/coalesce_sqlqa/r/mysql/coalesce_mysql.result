coalesce-7-1-4     包含 inout 参数的存储过程
drop procedure if exists myproc4;
create procedure myproc4(inout a char(10))
begin
SELECT     coalesce(a,'l')  eee     FROM emp  e;	
end
//
--  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num ='helloworld';
call  myproc4(@num);
eee
