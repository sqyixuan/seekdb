select  *    FROM    EMP001    e   WHERE   e.EMPNO=9000;



--echo     coalesce-4-1-2-2    根据表插入
insert into EMP001 values (8000, 'SMITH', 'CLERK', 7902,  (select coalesce(date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'),date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual),(select length(concat('Hello',coalesce(50,'HelloWorld',1,4)))), null, coalesce(60,'helloworld','l'),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=8000;


--echo     coalesce-4-1-2-3    插入语句中使用嵌套
insert into EMP001 values (7000, 'SMITH', 'CLERK', length(length(concat('Hello',coalesce('HelloWorld',1,4)))),  '1980-12-17', 800, null, coalesce('90','helloworld', CAST(coalesce('helloworld','l') AS CHAR)),1);
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7000;


--echo     coalesce-4-1-3-1   单列              
UPDATE    EMP001  e  SET    e.DEPTNO =length(concat('Hello',coalesce('HelloWorld',1,4)))  WHERE   e.EMPNO = 7369;
select  *    FROM    EMP001    e   WHERE   e.EMPNO=7369;


--echo     coalesce-4-1-3-2  多列      
UPDATE    EMP001  e  SET    e.DEPTNO = length(concat('Hello',coalesce('HelloWorld',1,4)));
select  *    FROM    EMP001    e   ORDER  BY e.EMPNO,e.TNO;


