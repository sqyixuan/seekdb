--echo   coalesce-4-2-1     内连接
SELECT length(concat('Hello',coalesce('HelloWorld',1,4)))  from emp e  join dept d  on e.deptno = d.deptno;

--echo   coalesce-4-2-2
###左连接  左外连接
select     length(concat('Hello',coalesce(1,'HelloWorld',1,4)))  eee  from emp e left  join  dept d on e.deptno = d.deptno   ORDER BY  eee; 
select     length(concat('Hello',coalesce('HelloWorld',1,4)))  eee  from emp e left outer join  dept d on e.deptno = d.deptno   ORDER BY  eee; 


--echo  coalesce-4-2-3
###右连接  右外连接
select      length(concat('Hello',coalesce(null,'HelloWorld',1,4)))    eee   from emp e right join dept d on e.deptno = d.deptno  ORDER BY  eee; 
select     length(concat('Hello',coalesce(9,'HelloWorld',1,4)))   eee  from emp e right outer join  dept d on e.deptno = d.deptno  ORDER BY  eee; 


#mysql不支持ob支持
--echo   coalesce-4-2-4    全连接full join
select   length(concat('Hello',coalesce('99','HelloWorld',1,4)))  eee  from emp e full join dept d on e.DEPTNO=d.DEPTNO    ORDER BY  eee;  




--echo     coalesce-4-3-1  
SELECT empno,ename,job    FROM emp     WHERE deptno  in(SELECT length(concat('Hello',coalesce('HelloWorld',1,4))) FROM  emp);

--echo    coalesce-4-3-2
SELECT empno,ename,job    FROM emp  e    WHERE deptno  NOT  in(SELECT length(concat('Hello',coalesce('HelloWorld',1,4))) FROM  emp)   ORDER BY  e.empno;


--echo   coalesce-5-1-1                    
select  coalesce(e.ename,2, coalesce(e.ename, 'S')) eee from emp e  ORDER BY  eee;                           
                        
 
--echo   coalesce-5-1-2
SELECT   replace(e.ename,'SMITH',coalesce(e.ename,length(concat('Hello',coalesce('HelloWorld',1,4))), coalesce(e.ename, 'S')))   eee  FROM   emp e  ORDER BY  eee;                
                                    

--echo   coalesce-5-1-3
SELECT   ABS(length(concat('Hello',coalesce('HelloWorld',1,4))))   eee  FROM   emp e  ORDER BY  eee;                   
                        
                        
 
--echo   coalesce-5-1-4
SELECT   CEIL(length(concat('Hello',coalesce('HelloWorld',1,4))))   eee  FROM   emp e  ORDER BY  eee;                                  
                        
                                    
                       
--echo   coalesce-5-1-5
SELECT   FLOOR(length(concat('Hello',coalesce('HelloWorld',1,4))))  eee   FROM   emp e   ORDER BY  eee;                           
                        
                        
 
--echo   coalesce-5-1-6
SELECT   MOD(coalesce(sal,ename, 'S'),length(concat('Hello',coalesce(sal,'HelloWorld',1,4))))   eee  FROM   emp e   ORDER BY  eee;      

                      
--echo   coalesce-5-1-7
SELECT   char(length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee  FROM   emp e  ORDER BY  eee;                       


--echo   coalesce-5-1-8
SELECT   LENGTH(concat(e.ename,coalesce('HelloWorld',1,4)))   FROM   emp e;   

--echo   coalesce-5-1-9
SELECT  MOD(length(concat(e.ename,coalesce('HelloWorld',1,4))),1)   eee FROM  emp e    ORDER BY  eee;       
                                      
                        

--echo   coalesce-5-1-10
#SELECT   LOG(length(concat(e.ename,coalesce('HelloWorld',1,4))),1000)   eee  FROM   emp e   ORDER BY  eee;                               
     

--echo   coalesce-5-1-11
SELECT   POWER(1,length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee  FROM   emp e   ORDER BY  eee;               
                        
                

--echo   coalesce-5-1-12
SELECT   SQRT(MOD(e.empno,length(concat(e.ename,coalesce('HelloWorld',1,4)))))   eee  FROM   emp e   ORDER BY  eee;  

                                           
--echo   coalesce-5-1-13
SELECT   round(MOD(e.empno,e.sal),length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee  FROM   emp e   ORDER BY  eee;   
                        


--echo   coalesce-5-1-14
SELECT ENAME,JOB,SAL,IFNULL(length(concat(e.ename,coalesce('HelloWorld',1,4))),MOD(e.empno,e.sal)) FROM EMP e WHERE SAL<2000   ORDER  BY   sal;            



--echo   coalesce-5-1-15
SELECT   COALESCE (coalesce(e.ename, 'S'),length(concat(e.ename,coalesce('HelloWorld',1,4))))  eee    FROM   emp e   ORDER BY  eee;                       

  
                        
--echo   coalesce-5-1-16
SELECT   GREATEST(length(concat(e.ename,coalesce('HelloWorld',1,4))),MOD(e.empno,e.sal))   FROM   emp   e;    


--echo   coalesce-5-1-17
select cast(length(concat(e.ename,coalesce('HelloWorld',1,4))) as char) as eee    from emp e   ORDER  BY   eee;  
                        
                                             
--echo     coalesce-5-2
SELECT     hex(CONCAT(CHAR(length(concat(e.ename,coalesce('HelloWorld',1,4)))),CHAR(e.empno)))  eee    from emp e   ORDER  BY   eee;          

SELECT   CASE if(coalesce(null,IFNULL(null,99))>100,101,102) WHEN '102' THEN "one" WHEN 2 THEN "two" ELSE "more" END;
SELECT   COALESCE ((SELECT CASE if(coalesce(null,IFNULL(null,99))>100,101,102) WHEN 109 THEN "one" WHEN 2 THEN "two"  end),88);



--echo   coalesce-6-1-1
SELECT   MOD(e.empno,e.sal)+length(concat(e.ename,coalesce('HelloWorld',1,4))) eee    from emp e   ORDER  BY   eee;   


--echo   coalesce-6-1-2
SELECT   MOD(e.empno,e.sal)-length(concat(e.ename,coalesce('HelloWorld',1,4)))   eee    from emp e   ORDER  BY   eee;   

--echo   coalesce-6-1-3
SELECT   MOD(e.empno,e.sal)*length(concat(e.ename,coalesce('HelloWorld',1,4)))    eee    from emp e   ORDER  BY   eee;  

--echo   coalesce-6-1-4
SELECT   MOD(e.empno,e.sal)/length(concat(e.ename,coalesce('HelloWorld',1,4)))    eee    from emp e   ORDER  BY   eee; 

--echo   coalesce-6-2-1
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal) NOT IN(select  length(concat(e.ename,coalesce('HelloWorld',1,4)))    FROM emp)   ORDER BY empno;       

--echo   coalesce-6-2-2
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal)<sal  AND length(concat(e.ename,coalesce('HelloWorld',1,4)))>tno  ORDER BY empno;            

--echo   coalesce-6-2-3    
SELECT   *    FROM   emp e  WHERE  MOD(e.empno,e.sal)<sal  or length(concat(e.ename,coalesce('HelloWorld',1,4))) >tno  ORDER BY empno;            


--echo   coalesce-6-3-1
SELECT   *   FROM   emp e   WHERE   e.sal =length(concat(e.ename,coalesce('HelloWorld',1,4)))   ORDER BY e.EMPNO,e.sal;              


--echo   coalesce-6-3-2
SELECT   *   FROM   emp e   WHERE   e.sal >= length(concat(e.ename,coalesce('HelloWorld',1,4)))  ORDER BY e.EMPNO,e.sal;          


--echo   coalesce-6-3-3
SELECT   *   FROM   emp e   WHERE   e.sal < length(concat(e.ename,coalesce('HelloWorld',1,4)))  ORDER BY e.EMPNO,e.sal;          


--echo   coalesce-6-3-4
SELECT   *   FROM   emp e   WHERE   e.sal <=length(concat(e.ename,coalesce('HelloWorld',1,4)))   ORDER BY e.EMPNO,e.sal;          


--echo   coalesce-6-3-5
SELECT   *   FROM   emp e   WHERE   e.sal !=length(concat(e.ename,coalesce('HelloWorld',1,4)))  ORDER BY e.EMPNO,e.sal;          


--echo   coalesce-6-3-6
SELECT   *   FROM   emp e   WHERE   e.sal <>length(concat(e.ename,coalesce('HelloWorld',1,4)))   ORDER BY e.EMPNO,e.sal;          



drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);


--echo  coalesce-7-1-1  无参数的存储过程
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7369, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, coalesce(80,'helloworld','l'),1);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7370, 'SMITH002', 'CLERK002', 7902, '7980-12-07',  900, 15, length(coalesce('helloworld','o')),2);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7371, 'SMITH003', 'CLERK003', 7902, '7980-12-07',  250, 25, length(coalesce('helloworld','w')),3);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7372, 'SMITH004', 'CLERK004', 7902, '7980-12-07',  100, 35, length(coalesce('helloworld','d')),4);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7373, 'SMITH005', 'CLERK005', 7902, '7980-12-07',  200, 45, coalesce(900,'helloworld','e'),5);
end 
//
DELIMITER ;//
call myproc1();
select  *  from   emp e order by  e.empno;




--echo  coalesce-7-1-2    只有一个 in 参数的存储过程 
drop procedure if exists myproc2;
delimiter //;
create procedure myproc2(in userId int)
begin
    SELECT    coalesce(e.ename,userId/10, coalesce(e.ename, 'S'))      FROM emp  e;
end
//
DELIMITER ;//
set @dum =10;
call myproc2(@dum);
SELECT    coalesce(e.ename,@dum/10, coalesce(e.ename, 'S'))      FROM emp  e;


--echo  coalesce-7-1-3    :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username 
drop procedure if exists myproc3;
delimiter //;
create procedure myproc3(in userId int, out username varchar(20))
begin
set username= userId;	
SELECT *  FROM emp d where  d.DEPTNO> username;		
end
//
DELIMITER ;//
-- echo --  调用时，传入查询的userid 和 全局变量 @username
call myproc3(coalesce(100,'helloworld','l'),@username);
select  *  from   emp e order by  e.empno;



--echo  coalesce-7-1-4     包含 inout 参数的存储过程
drop procedure if exists myproc4;
delimiter //;
create procedure myproc4(inout a char(10))
begin
SELECT     coalesce(a,'l')  eee     FROM emp  e;	
end
//

DELIMITER ;//
-- echo --  用户变量 （全局的变量）作用域： 用户变量: 在当前连接（即当前会话）中都有效
set @num ='helloworld';
call  myproc4(@num);
SELECT     coalesce(@num,'l')     FROM emp  e;	


--echo   coalesce-7-2-1 无参数的自定义函数
drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  sum(coalesce('helloworld','l'))  INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO=d.DEPTNO where  e.sal >saller001 GROUP BY d.DEPTNO having d.DEPTNO>1;
RETURN ag;
end
//
DELIMITER ;//
SELECT salemp001(100);


--echo   coalesce-7-2-2  自定义函数  有参数

drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT    coalesce(9999,coalesce(90,'helloworld','l')) INTO ag #为局部变量赋值
FROM emp e INNER JOIN dept d ON e.DEPTNO!=d.DEPTNO where  e.sal <saller001 GROUP BY d.DEPTNO having d.DEPTNO>10;
RETURN ag;
end
//
DELIMITER ;//
SELECT   coalesce(999+(SELECT salemp001(100)),888)  from  dual;


--echo   coalesce-7-2-3   自定义函数使用循环 
drop function  IF EXISTS salemp001;
DELIMITER //;
CREATE FUNCTION salemp001(saller001 int) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;
DECLARE i INT DEFAULT 1;
WHILE i<=1000 DO
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (saller001+i*10, 'SMITH001', 'CLERK001', 7902, '7980-12-07',  800, null, coalesce(90,'helloworld','l'),1);
SET i = i+1;
END WHILE;
SELECT  count(*)  into  ag   from   EMP;
RETURN ag + coalesce(90,'helloworld','l');
end
