--echo   coalesce-3-1-1-1  select   
SELECT coalesce(e.job, e.ename)   eee FROM EMP e   ORDER  BY   eee  desc;


--echo   coalesce-3-1-1-2  select嵌套 
SELECT coalesce(coalesce(coalesce(coalesce(coalesce(coalesce(coalesce(coalesce(coalesce(coalesce(
coalesce(coalesce(coalesce(100,e.ename,10,coalesce(e.ename, 'M'))))))))))))))   eee FROM EMP e   ORDER  BY   eee  desc;

--echo   coalesce-3-1-1-3    some,any,all
SELECT   sum(length(coalesce(e.ename,coalesce(e.ename, 'M'))))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT   min(length(coalesce(e.ename,coalesce(e.ename, 'M'))))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT   max(length(coalesce(e.ename,coalesce(e.ename, 'M'))))   eee FROM EMP e   ORDER  BY   eee  desc;
SELECT   avg(length(coalesce(e.ename,coalesce(e.ename, 'M'))))   eee FROM EMP e   ORDER  BY   eee  desc;


--echo   coalesce-3-1-1-4    create as        
drop   table  if  exists   EMP001;
DROP VIEW  if  exists   EMP001;
create TABLE    EMP001   as  SELECT length(coalesce(e.ename,coalesce(e.ename, 'M')))   eee FROM EMP e   ORDER  BY   eee  desc;
select  *    FROM    EMP001   ORDER BY  eee;


--echo   coalesce-3-1-2   where  语句    
select      length(coalesce(e.ename,coalesce(e.ename, 'M')))   eee   from    emp e  WHERE  e.sal > 2000    ORDER  BY   eee;


--echo   coalesce-3-1-3     order by 子句
select       length(coalesce(e.ename,coalesce(e.ename, 'M')))  eee   from    emp e  WHERE  e.sal > 2000  OR   e.sal <1000     ORDER  BY   eee;




--echo   coalesce-3-1-4     group by   子句
select       length(coalesce(e.ename,coalesce(e.ename, 'M')))   eee    from    emp e    GROUP  BY   e.ename   ORDER BY eee;



--echo   coalesce-3-1-5     group by  having   子句
select       length(coalesce(e.ename,coalesce(e.ename, 'M')))    eee    from    emp e    GROUP  BY   e.ename   HAVING   coalesce(e.ename, 'S')>0   ORDER BY eee;




--echo     coalesce-3-2-1   根据字段插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, concat(1,coalesce('World',0,2)), 'CLERK003', 7902, '7980-12-07',  700, null, length(coalesce('helloworld','l')),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (9000, concat(1,coalesce('World',1,2)), 'CLERK003', 7902, '7980-12-07',  700, null, length(coalesce('helloworld','l')),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=9000;


--echo     coalesce-3-2-2    根据表插入
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, concat('9',coalesce('World',1,3)), 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(999,coalesce('helloworld','l')),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=8000;


--echo     coalesce-3-2-3    插入语句中使用嵌套
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (7000, concat('SMITH',coalesce('World',1,4)), 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(' 99',null,coalesce('helloworld','l')),11);
select  *    FROM    EMP    e   WHERE   e.EMPNO=7000;


--echo     coalesce-3-3-1   单列              
UPDATE    EMP  e  SET    e.DEPTNO = length(concat('SMITH',coalesce('HelloWorld',1,4)))  WHERE   e.EMPNO = 7369;
select  *    FROM    EMP    e   WHERE   e.EMPNO=7369;


--echo     coalesce-3-3-2  多列      
UPDATE    EMP  e  SET    e.DEPTNO =length(concat('SMITH',coalesce('HelloWorld',1,4)));
select  *    FROM    EMP    e   ORDER  BY e.EMPNO,e.TNO;


--echo     coalesce-3-4-1   单列              
DELETE  FROM     EMP      WHERE   EMPNO = 7369  and  DEPTNO = length(concat('SMITH',coalesce('HelloWorld',1,4)));
select  *    FROM    EMP       WHERE   EMPNO=7369;


--echo     coalesce-3-4-2  多列      
DELETE  FROM     EMP      WHERE    DEPTNO = length(concat('SMITH',coalesce('HelloWorld',1,4)));
select      count(*)     FROM    EMP;

--echo    coalesce-3-5    多列
with e as (SELECT   length(concat('SMITH',coalesce('HelloWorld',1,4)))  from    emp e)  select * from e;


insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(18,'helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(19,'helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(20,'helloworld','l'),11);
insert into EMP (empno, ename, job, mgr, hiredate, sal, comm, deptno,tno)values (8000, 'SMITH011', 'CLERK003', 7902, '7980-12-07',  700, null, coalesce(21,'helloworld','l'),11);


--echo    coalesce-3-6     CASE WHEN语句
SELECT   sum(empno),  length(CASE WHEN  length(concat('SMITH',coalesce('HelloWorld',1,4)))= 1 THEN 1 
                         ELSE       NULL      END) 数据A,         
                         length(CASE WHEN length(concat('SMITH',coalesce('HelloWorld',1,4))) = 2 THEN 1                      
                         ELSE       NULL       END) 数据B   
                         FROM EMP e   ORDER  BY MOD(e.empno,e.sal);
   

                        

drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno int,tno int);
