#description: coalesce函数
#tags: pl, sql,数据类型,常用函数，存储过程
#author: wb-mcl707228

drop database  IF EXISTS  ob100x;
create database ob100x  character set utf8;
use ob100x;
select database();
--disable_warnings


--echo     coalesce-1-1  0个参数
--error    1582
select coalesce()  FROM   dual;

--echo     coalesce-2-1  1个参数       
SELECT   coalesce(500) FROM dual;
SELECT   coalesce('') FROM dual;
SELECT   coalesce(null) FROM dual;
SELECT   coalesce('gkkk') FROM dual;

--echo    coalesce-1-3-1   参数类型不相同
select coalesce('HelloWorld',1) value from dual;


--echo    coalesce-1-3-2   参数类型都是 字符 
select coalesce('HelloWorld','1') value from dual;

--echo    coalesce-1-3-3   参数类型都是数字
select coalesce(1,2) value from dual;
select coalesce(-1,2) value from dual;
select coalesce(1,-2) value from dual;
select coalesce(1.1,2.1) value from dual;
select coalesce(0,2.1) value from dual;


--echo    coalesce-1-3-4  参数类型都是空
select coalesce(' ','') value from dual;


--echo    coalesce-1-3-5 参数类型都是null
select coalesce(NULL,null) value from dual;

--echo    coalesce-1-3-6  参数类型一个字符一个null
select coalesce('HelloWorld',null) value from dual;


--echo    coalesce-1-3-7  参数类型一个数字一个null
select coalesce(100,null) value from dual;

--echo    coalesce-1-3-8 参数类型都是日期
select coalesce(null,date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;
select coalesce(date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'),date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;
select coalesce('',date_format('2008-08-08 22:23:01', '%Y%m%d%H%i%s'))from dual;

--echo    coalesce-1-3-9  参数类型一个数字一个null
select coalesce(100,' ') value from dual;
select coalesce(' ',100) value from dual;

--echo    coalesce-1-3-10  参数类型一个字符一个null
select coalesce('hello',' ') value from dual;
select coalesce(' ','hello',' ') value from dual;


 

--echo    coalesce-1-4-1  普通的三个参数
select coalesce('HelloWorld','1','2') value from dual; 
select coalesce(1,2,3) value from dual; 
select coalesce('','','  ') value from dual; 
select coalesce(null,null,null) value from dual; 


--echo    coalesce-1-4-2  字符和空                
select coalesce('HelloWorld',' ','2') value from dual; 
select coalesce(' ','HelloWorld',' ','2') value from dual; 
select coalesce(' ','HelloWorld',' ',' ') value from dual; 


--echo    coalesce-1-4-3    字符和数字
select coalesce(3,1,' ') value from dual; 
select coalesce(3,'',6) value from dual; 


--echo    coalesce-1-4-4  数字和null       
select coalesce(3,1,null) value from dual; 
select coalesce(null,1,null) value from dual; 

--echo    coalesce-1-4-5  字符和null        
select coalesce(NULL,'hello',null) value from dual; 

--echo    coalesce-1-4-6  空和null        
select coalesce(NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,'') value from dual; 
select coalesce('  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ','  ',null) value from dual; 


--echo    coalesce-1-4-7 null和日期     
select coalesce(date_format('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),NULL,date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),null)from dual;


--echo    coalesce-1-4-8  空和日期        
select coalesce('',date_format('2004-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),date_format('2006-05-07 13:23:44','yyyy-mm-dd hh24:mi:ss'),'')from dual;



--echo    coalesce-1-4-9    其他              
drop   table  if  exists   emp;
create   TABLE   EMP (empno int,ename VARCHAR(10),job VARCHAR(9),mgr int,hiredate DATE,
sal FLOAT(7,0),comm FLOAT(7,0),deptno binary,tno BLOB);
insert into EMP (empno )values (7369 );
insert into EMP (ename)values ( 'SMITH002');
insert into EMP (job)values ('CLERK003');
insert into EMP (mgr)values (7902);
insert into EMP (hiredate)values ('7980-12-07');
insert into EMP (sal)values (300);
insert into EMP (comm)values (65);
insert into EMP (deptno)values (2);
insert into EMP (tno)values (90);

SELECT coalesce(empno,e.ename,job,mgr,hiredate,sal,comm,deptno,tno)   eee FROM EMP e   ORDER  BY   eee  desc;

