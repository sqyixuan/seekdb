drop   table  if  exists   EMP001;                     
CREATE OR  REPLACE  VIEW EMP001 AS   SELECT  *    FROM   emp;

--echo   coalesce-4-1-1-1-1  select   
SELECT coalesce(e.ename, 2,1)   eee   FROM EMP001 e   ORDER BY  eee;


--echo   coalesce-4-1-1-1-2  select嵌套 
select    length(concat(e.ename,coalesce('HelloWorld',1,4)))  eee   from    EMP001 e   ORDER BY  eee;


--echo   coalesce-4-1-1-1-3    聚合函数
SELECT sum(length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT min(length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT max(length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee FROM EMP001 e   ORDER  BY   eee  desc;
SELECT avg(length(concat(e.ename,coalesce('HelloWorld',1,4))))   eee FROM EMP001 e   ORDER  BY   eee  desc;


--echo   coalesce-4-1-1-1-4    create as        
drop   table  if  exists   EMP002;
create TABLE    EMP002   as   SELECT  length(concat(e.ename,coalesce('HelloWorld',1,4)))  eee   from    EMP001 e;
select  *    FROM    EMP002;


--echo   coalesce-4-1-1-2   where  语句    
select     length(concat(e.ename,coalesce('HelloWorld',1,4)))   eee  from    EMP001 e  WHERE  e.sal > 200  ORDER BY  eee;


--echo   coalesce-4-1-1-3     order by 子句
select      length(concat(e.ename,coalesce('HelloWorld',1,4))) eee   from    EMP001 e        ORDER BY  eee;  




--echo   coalesce-4-1-1-4     group by   子句
select    length(concat(e.ename,coalesce('HelloWorld',1,4)))  eee    from    EMP001 e    GROUP  BY   e.ename    ORDER BY  eee;


--echo   coalesce-4-1-1-5     group by  having   子句
select     length(concat(e.ename,coalesce('HelloWorld',1,4)))  eee    from    EMP001 e    GROUP  BY   e.ename    HAVING   LENGTH(e.ename)>0   ORDER BY  eee;


--echo     coalesce-4-1-2-1   根据字段插入
