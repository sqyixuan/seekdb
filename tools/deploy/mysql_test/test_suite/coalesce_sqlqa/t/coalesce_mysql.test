--echo    coalesce-2-1-1    char               
drop   table  if  exists   emp;
create table EMP(a char(20),b char(20),c char(20));
insert into EMP values('helloworld','2','');
select coalesce(a,b,c) from EMP;



--echo    coalesce-2-1-2   varchar    
drop   table  if  exists   emp;
create table EMP(a VARCHAR(20),b VARCHAR(20),c VARCHAR(20));
insert into EMP values('helloworld','null','');
select coalesce(a,b,c) from EMP;


--echo  coalesce-2-1-3   TEXT               
drop   table  if  exists   emp;
create table EMP(a  TEXT,b  TEXT,c  TEXT);
insert into EMP values('helloworld','null','   ');
select coalesce(a,b,c) from EMP;

