DELETE  FROM     EMP001       WHERE   EMPNO = 7369   and   DEPTNO =length(concat('Hello',coalesce('HelloWorld',1,4)));
select  *    FROM    EMP001        WHERE   EMPNO=7369;


--echo     coalesce-4-1-4-2  多列      
