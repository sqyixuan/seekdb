exp-7-1-2  只有一个 in 参数的存储过程  :  ---begin 里面使用的变量必须在begin上面定义过。
call studentwbmlc();//
drop procedure if exists pl_test;//
create  procedure pl_test (in numb int)
begin
declare  i BIGINT;
declare  a BIGINT;
declare  b BIGINT;
declare  c BIGINT;
SELECT   EXP(e.age)  INTO a FROM student e WHERE  e.NAME='Kebi';
SELECT   EXP(e.SALARY/1000)    INTO b FROM   student  e WHERE  e.NAME='Kebi';
SELECT   EXP(e.mon/900)    INTO c FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
REPEAT
INSERT INTO student  VALUES('Kebi',a,20,3000,100);
INSERT INTO student  VALUES('James','2000',21,b,100);
INSERT INTO student  VALUES('Denglun','3000',22,c,100);
set i := i + 1;
until  i >= 100 END REPEAT;
end;
//
call   pl_test(100);//
SELECT   DISTINCT(EXP(e.age))  FROM student e WHERE  e.NAME='Kebi';//
(EXP(e.age))
485165195.4097903
