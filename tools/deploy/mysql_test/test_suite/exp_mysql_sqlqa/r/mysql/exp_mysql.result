create table invbasdoc(monkey00   int not null,monkey01   INTEGER not null,monkey02   int,monkey03   decimal(8,4) not null,monkey04   FLOAT,monkey05   DOUBLE,monkey06   NUMERIC(6,2),
monkey07   SMALLINT,monkey08   FLOAT(20),monkey09   int,monkey10   char(50),monkey11   varchar(100),monkey12   varchar(100),GRADE int);
