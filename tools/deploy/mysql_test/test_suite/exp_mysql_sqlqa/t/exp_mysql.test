delimiter //;
drop procedure if exists mayitest;//
create procedure mayitest()
begin
declare tablename001 varchar(100);
declare dropname002 varchar(100);
declare tablename003 varchar(100);
declare dropname004 varchar(100);
set  @dropname002= 'DROP  TABLE if exists  EMP001;';
set  @tablename001= 'create table EMP001 as select * from EMP where 1=1;';
set  @dropname004= 'DROP  TABLE if exists  invbasdoc001;';
set  @tablename003= 'create table invbasdoc001 as select * from invbasdoc where 1=1;';
prepare step001 from @dropname002;
execute step001;
prepare step002 from @tablename001;
execute step002;
prepare step003 from @dropname004;
execute step003;
prepare step004 from @tablename003;
execute step004;
end
//
DELIMITER  ;//
call mayitest();

-- echo     exp-3-1-1  select
SELECT  EXP(e.monkey00/EXP(10))   FROM   invbasdoc001 e;
SELECT  EXP(e.DEPTNO)   FROM   emp001  e;

SELECT  EXP(e.sal/100000)+EXP(e.comm/999)   FROM   emp001  e;

-- echo     exp-3-1-2  select嵌套                    
SELECT  EXP(EXP(e.DEPTNO/99)),exp(EXP(EXP(e.DEPTNO/99))/9)  FROM   emp001  e;


-- echo     exp-3-1-3   别名                     
SELECT  EXP(EXP(e.DEPTNO/99))   hello   FROM   emp001  e;
SELECT  EXP(EXP(e.DEPTNO/99))   hello你好世界   FROM   emp001  e;


-- echo     exp-3-1-4   where 子句
SELECT  EXP(e.DEPTNO)   FROM   emp001  e  WHERE  e.SAL<1000;

-- echo     exp-3-1-5   order by 子句  GROUP BY和ORDER BY 的字段要统一
SELECT  EXP(e.DEPTNO)   FROM   emp001  e ORDER BY e.sal;
SELECT  EXP(e.DEPTNO)   FROM   emp001  e GROUP BY DEPTNO   ORDER BY e.DEPTNO;

-- echo     exp-3-1-6   having子句   having要放在order by前面
SELECT  EXP(e.DEPTNO)   FROM   emp001  e GROUP BY DEPTNO HAVING e.DEPTNO>20   ORDER BY e.DEPTNO ;

-- echo     exp-3-1-7   insert into的values         
INSERT INTO EMP001 VALUES(EXP(3),'MILLER','CLERK',EXP(4),'1983-11-23 00:00:00',EXP(5),NULL,EXP(10));
SELECT  *    FROM   emp001  e   WHERE e.EMPNO=floor(EXP(3));

-- echo     exp-3-1-8   update的set                   
UPDATE   EMP001  SET   sal = EXP(30);  
SELECT  sal   FROM   emp001  e;

-- echo     exp-3-1-9        聚合函数                       
SELECT max(EXP(e.mgr/88))    FROM   emp001  e;
SELECT EXP(e.mgr/88)  FROM   emp001  e;

--echo   exp-3-2-1   select            
#SELECT EXP(r.DEPTNO/100005),exp(r.COMM/5000)   FROM   emp001  r   WHERE   sal > (SELECT  exp(sal/1000)    FROM   emp001   e   WHERE    e.EMPNO=1) ;
CALL mayitest();
SELECT EXP(r.DEPTNO/100005),exp(r.COMM/5000)   FROM   emp001  r   WHERE   sal > (SELECT  exp(sal/1000)    FROM   emp001   e   WHERE    e.EMPNO=2) ;

SELECT EXP(r.DEPTNO/100005),exp(r.COMM/5000)   FROM   emp001  r   WHERE   sal < (SELECT  exp(sal/1000)    FROM   emp001   e   WHERE    e.EMPNO=3) ;
CALL mayitest();
SELECT EXP(r.DEPTNO/100005),exp(r.COMM/5000)   FROM   emp001  r   WHERE   sal < (SELECT  exp(sal/1000)    FROM   emp001   e   WHERE    e.EMPNO=4) ;


--echo   exp-3-2-2   exists，any，all
select    *   from   emp001 e  WHERE   exists(select  exp(sal/100)   from emp001 r where  exp(r.sal/100)>exp(e.COMM/100)) ;

SELECT *  FROM emp001 e  WHERE  EXP(e.DEPTNO)  > any(select exp(r.COMM/5) from emp001 r where r.DEPTNO>10);

SELECT *  FROM emp001 e  WHERE  EXP(e.DEPTNO)  > some(select exp(r.COMM/5) from emp001 r where r.DEPTNO>10);


--echo   exp-3-2-3   create as                   

DROP TABLE   if exists   test001;
create table test001  as select * from EMP001;

DROP TABLE   if exists   test001;
create TABLE  test001  as    SELECT   *   from   EMP001  e  WHERE   e.DEPTNO IN(SELECT  DEPTNO from   EMP001 r  WHERE r.SAL>EXP(5));
SELECT count(*)  FROM  test001;  

--echo   exp-3-2-4    insert into as                              
INSERT    INTO   test001   SELECT   *   from   EMP001  e  WHERE   e.DEPTNO IN(SELECT  DEPTNO from   EMP001 r  WHERE r.SAL>EXP(5));
SELECT  count(*) FROM  test001;  

--echo   exp-3-2-5   update set                          
UPDATE   test001   e   SET  e.COMM=exp(10)  WHERE   e.DEPTNO  IN(SELECT  DEPTNO from   EMP001 r  WHERE r.SAL>EXP(5));
SELECT  * FROM  test001;  

--echo   exp-3-2-6   with as的select        

#with e as  (SELECT   *    from   EMP001  ee  WHERE   ee.DEPTNO IN(SELECT  r.DEPTNO  from   EMP001 r  WHERE r.SAL>EXP(10)/100)),
#f as  (SELECT    *   from    EMP001  ff   WHERE   ff.DEPTNO   IN(SELECT  y.DEPTNO from   EMP001 y  WHERE y.SAL>3000-EXP(10)))
#select * from e, f where e.deptno = f.deptno;


-- echo    exp-4-1   算术运算符               
SELECT    exp(e.deptno/10)+exp(comm/10)  FROM   emp001  e;
SELECT    exp(e.deptno/10)-exp(comm/10)  FROM   emp001  e;
SELECT    exp(e.deptno/10)*exp(comm/10)  FROM   emp001  e;
SELECT    exp(e.deptno/10)/exp(comm/10)  FROM   emp001  e;

-- echo    exp-4-2   比较运算符              
select ename,job,sal,comm from emp where job = 'SALESMAN' or sal > exp(comm/10);
select ename,job,sal,comm from emp where job = 'SALESMAN' or sal < exp(comm/10);
select ename,job,sal,comm from emp where job = 'SALESMAN' or job = 'PRESIDENT' and sal <>exp(comm/10);



-- echo    exp-4-3  逻辑运算符              
select ename,job,sal,comm from emp where job = 'SALESMAN' AND  sal > exp(comm/10);
select ename,job,sal,comm from emp where comm < exp(10)  AND  sal > exp(comm/10);

-- echo    exp-4-4   位运算符                               
#select bitand(exp(10),exp(5)) from dual;


-- echo    exp-4-5   连接运算符               
SELECT    exp(e.deptno/10)||exp(comm/10)  FROM   emp001  e;
select  exp(10)||exp(5) from dual;


-- echo   常用函数
-- echo    exp-5-1   concat
select EXP(concat('1','1')) from dual;
SELECT  EXP(concat(e.empno,sal)/10000000)   from    emp001 e;


-- echo    exp-5-2   instr
select  EXP(instr('Hello World!','o')) from dual;
#select  EXP(instr('Hello World!','o',6)) from dual;
#select  EXP(instr('Hello World!','o',1,2)) from dual;


-- echo    exp-5-3   length
select    EXP(length('Hello World!')) from dual;
SELECT  EXP(length('张三')) from dual;
SELECT  EXP(length(e.ename)) from emp001 e  WHERE sal <1000;


-- echo    exp-5-4   nvl
#select   EXP(nvl(null,'100')) from dual;
#select   EXP(nvl(e.comm,'100')/10) from emp001 e;

-- echo    exp-5-5   replace
select EXP(replace('1','1','10')) from dual;


-- echo    exp-5-6  abs(value)
select EXP(abs(-10)) from dual;


-- echo    exp-5-7  ceil(value)
select EXP(ceil(2.3)) from dual;


-- echo    exp-5-8  floor(value)
select  EXP(floor(2.3)) from dual;


-- echo    exp-5-9  trunc
#select EXP(trunc(555.666)/100) from dual; 
#select  EXP(trunc(555.666,2)/100) from dual;
#select EXP(trunc(555.666,-2)/100) from dual;

-- echo    exp-5-10  round
select  EXP(round(555.666)/5) from dual;
select EXP(round(555.666,2)/5) from dual;
select EXP(round(555.666,-2)/5) from dual;


-- echo    exp-5-11  to_char
#select  EXP(to_char('12345.67')/100) from dual; 


-- echo    exp-5-12  to_number
#select  EXP((to_number('970.13') + 25.5)/100)  from dual;
#select  EXP(to_number('-$12,345.67', '$99,999.99')/99) from dual;

-- echo    exp-5-13  cast
#select  EXP(cast(125.67 as varchar2(10))/90),  EXP(cast(12.678 as number(10,2))/90) from dual;



-- echo    视图和同义词
CALL mayitest();
create or replace view    view_emp   AS  select   *    from    emp001;
#CREATE  or REPLACE    synonym  synonym_emp     FOR       emp001;

-- echo    exp-6-1-1  select语句
SELECT   EXP(e.empno/100)  FROM   view_emp e;
#SELECT   EXP(e.empno/100)  FROM   synonym_emp e;


SELECT   EXP(EXP(EXP(e.empno/10000)))  FROM   view_emp e;
#SELECT   EXP(EXP(EXP(e.empno/10000)))  FROM   synonym_emp e;

  
-- echo    exp-6-1-2  group by having子句   查询字段不是group字段   则要是聚合函数修饰的字段。
SELECT   EXP(sum(e.comm)/100)  FROM   view_emp e  GROUP BY e.deptno HAVING  e.deptno>10;
#SELECT   EXP(min(e.comm)/100)  FROM   synonym_emp e  GROUP BY e.deptno HAVING  e.deptno>10;


-- echo    exp-6-1-3  order by子句
SELECT   EXP(sum(e.comm)/100)  FROM   view_emp e  GROUP BY e.deptno HAVING e.deptno>10  ORDER BY EXP(e.deptno);
#SELECT   EXP(sum(e.comm)/100)  FROM   synonym_emp e  GROUP BY e.deptno HAVING e.deptno>20  ORDER BY EXP(e.deptno);


-- echo    exp-6-1-4    case when
SELECT  CASE  WHEN sal<1000 THEN exp(comm/100)  WHEN sal<2000 THEN exp(comm/100)  WHEN sal<3000 THEN exp(sal/100)
ELSE  exp(comm/100+10)   END sal    FROM view_emp;

#SELECT  CASE  WHEN sal<3000 THEN exp(comm/100)  WHEN sal<2000 THEN exp(comm/100)  WHEN sal<3000 THEN exp(sal/100) ELSE  exp(comm/100+10)   END sal    FROM synonym_emp;


SELECT  CASE  WHEN sal<1000 THEN exp(comm/100)  WHEN sal<2000 THEN exp(comm/100)  WHEN sal<3000 THEN exp(sal/100) ELSE  exp(comm/100+10)   END sal    FROM view_emp e  group BY e.sal ;


-- echo    exp-6-1-5    case when
SELECT  EXP(COUNT(DISTINCT(e.deptno)))  FROM    view_emp e;
#SELECT  EXP(COUNT(DISTINCT(e.deptno)))  FROM    synonym_emp e;

-- echo  exp-6-1-6   with as          
#with f  as (select e.empno,e.sal from view_emp e), g as (select r.empno,r.comm from view_emp r) select exp(f.sal/100),exp(g.comm/100) from f, g where  f.EMPNO = g.EMPNO;
#with f  as (select e.empno,e.sal from synonym_emp e), g as (select r.empno,r.comm from synonym_emp r) select exp(f.sal/100),exp(g.comm/100) from f, g where  f.EMPNO = g.EMPNO;


-- echo    exp-6-2
INSERT INTO view_emp VALUES(EXP(10),'MILLER','CLERK',7782,'2009-06-08 23:53:17',1300,NULL,EXP(10));
SELECT  EXP(e.empno/EXP(20))  FROM    view_emp e WHERE e.job='CLERK';
#SELECT  EXP(e.empno/EXP(20))  FROM    synonym_emp e  WHERE e.job='CLERK';


-- echo    exp-6-3-1
UPDATE  view_emp e   SET  e.COMM=exp(9)   WHERE  e.EMPNO=7369;
SELECT   COMM  FROM    view_emp;

-- echo  exp-6-3-2-1
create or replace view    view_emp   AS  select   *    from    emp001;
--error 0 , 1093
UPDATE  view_emp   SET  COMM=exp((SELECT  sum(sal)     FROM  view_emp    GROUP BY DEPTNO   HAVING  DEPTNO>30)/10000)    WHERE  EMPNO=1;         
SELECT   COMM  FROM    view_emp;
-- echo  exp-6-3-2-2
#UPDATE  synonym_emp e   SET  e.COMM=exp((SELECT   sum(aaa)   FROM    (SELECT  sum(sal)  aaa    FROM  view_emp    GROUP BY  DEPTNO   ORDER BY deptno))/100000) WHERE  e.EMPNO=7369;         
SELECT   COMM  FROM    view_emp;

CALL mayitest();
create or replace view    view_emp   AS  select   *    from    emp001;
#CREATE  or REPLACE    synonym  synonym_emp     FOR       emp001;

-- echo  exp-6-4-1
DELETE   FROM   view_emp   WHERE   deptno< exp(1)+10;
#DELETE   FROM   synonym_emp   WHERE   deptno< exp(1)+10;

-- echo  exp-6-4-2-1  嵌套group by having子句
DELETE   FROM   view_emp   WHERE   deptno< exp((SELECT   sum(ggg.aaa)   FROM    (SELECT  sum(t.sal)  aaa    FROM  view_emp t    GROUP BY  DEPTNO) ggg)/1000);  
create or replace view    view_emp   AS  select   *    from    emp001;


-- echo  exp-6-4-2-2   嵌套order by子句
CALL mayitest();
create or replace view    view_emp   AS  select   *    from    emp001;
#CREATE  or REPLACE    synonym  synonym_emp     FOR       emp001;
DELETE   FROM   view_emp   WHERE   deptno< exp((SELECT   sum(ggg.aaa)   FROM    (SELECT  sum(t.sal)  aaa    FROM  view_emp t    GROUP BY  DEPTNO ORDER BY deptno) ggg)/1000);  
--echo    exp-7   pl/sql                 


DROP TABLE if exists  student001;
create table  student001(name varchar(200),city varchar(200),age BIGINT,salary BIGINT,mon BIGINT);
INSERT INTO student001  VALUES('Kebi','1000',20,3000,100);
INSERT INTO student001  VALUES('James','2000',21,4000,100);
INSERT INTO student001  VALUES('Denglun','3000',22,5000,100);
INSERT INTO student001  VALUES('Yangmi','4000',21,2500,100);
