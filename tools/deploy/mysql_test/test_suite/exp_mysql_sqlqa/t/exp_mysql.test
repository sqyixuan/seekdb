--disable_warnings
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf8;
use ob100x;
select database();

-- echo  exp-1参数
-- echo  exp-1-1-1   一个参数
select    exp(3)    from dual;
select    exp(0)   from dual;
select    exp(-3)  from dual;
select    exp('')  from dual;
select    exp('   ')  from dual;
select    exp(null)  from dual;
select    exp(3-3)  from dual;
select    exp(3+3)  from dual;
select    exp(10/3)  from dual;
select    exp(0/3)  from dual;
select    exp(3/0)  from dual;
select    exp(291)    from dual;


select    exp(-100)    from dual;
select    exp(-20091)    from dual;

-- echo  exp-1-1-2   两个参数
--error 0, 1582
select    exp(0,-3)  from dual;
--error 0, 1582
select    exp(0,0)  from dual;

-- echo  exp-1-1-3   0个参数
--error 0, 1582
select    exp()    from dual;



-- echo  exp-1-1-4   边界值
select    exp(709)    from dual;
--error 0, 1690
select    exp(710)     from dual;
select    exp(710/0)  from dual;
select    exp(0)        from dual;
select    exp(0)/0     from dual;
select    exp(-710)    from dual;
select    exp(-7100)  from dual;
select    exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(exp(2)/10))/3000)/3000)/3000)/3000)/2.71)/3000)/3000)))/9000))/8000))    from dual;
select    exp(exp(e.aa))  from   (select    exp(exp(0)/exp(0))  aa   from dual)e;
select    exp(0.123456789123456789)/exp(10)*exp(1.999)   from dual;




