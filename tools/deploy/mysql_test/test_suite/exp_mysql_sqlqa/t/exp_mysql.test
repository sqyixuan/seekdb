delimiter //;
drop procedure if exists studentwbmlc;//
create procedure studentwbmlc()
begin
declare tablename001 varchar(100);
declare dropname002 varchar(100);
set  @dropname002= 'DROP  TABLE if exists  student;';
set  @tablename001= 'create table student as select * from  student001  where  1=1;';
prepare step001 from @dropname002;
execute step001;
prepare step002 from @tablename001;
execute step002;
end
//

call studentwbmlc();//
SELECT  *  FROM  student;//

--echo  exp-7-1-1  无参数的存储过程

drop procedure if exists pl_test;//
create  procedure pl_test()  
begin
declare  i  BIGINT;              
declare  a BIGINT;
declare  b BIGINT;
declare  c BIGINT;
SELECT   EXP(e.age)  into  a FROM student e WHERE  e.NAME='Kebi';
SELECT   EXP(e.SALARY/1000)   into  b FROM   student  e WHERE  e.NAME='Kebi';
SELECT   EXP(e.mon/10000)  into  c FROM   student  e WHERE  e.NAME='Kebi';
set i=0;
loop_label:loop
INSERT INTO student  VALUES('Kebi',a,20,3000,100);
INSERT INTO student  VALUES('James','2000',21,b,100);
INSERT INTO student  VALUES('Denglun','3000',22,c,100);
set i=i+1;
if  i>=100 then
         leave loop_label;
end if;
end loop;
end;
// 
select  count(*)  from student;//
call  pl_test();//
select  count(*)  from student;//
SELECT   DISTINCT(EXP(e.age))  FROM student e WHERE  e.NAME='Kebi';//


--echo exp-7-1-2  只有一个 in 参数的存储过程  :  ---begin 里面使用的变量必须在begin上面定义过。
call studentwbmlc();//
drop procedure if exists pl_test;//
create  procedure pl_test (in numb int)
begin
declare  i BIGINT;
declare  a BIGINT;
declare  b BIGINT;
declare  c BIGINT;
SELECT   EXP(e.age)  INTO a FROM student e WHERE  e.NAME='Kebi';
SELECT   EXP(e.SALARY/1000)    INTO b FROM   student  e WHERE  e.NAME='Kebi';
SELECT   EXP(e.mon/900)    INTO c FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
REPEAT
INSERT INTO student  VALUES('Kebi',a,20,3000,100);
INSERT INTO student  VALUES('James','2000',21,b,100);
INSERT INTO student  VALUES('Denglun','3000',22,c,100);
set i := i + 1;
until  i >= 100 END REPEAT;
end;
//
call   pl_test(100);//
SELECT   DISTINCT(EXP(e.age))  FROM student e WHERE  e.NAME='Kebi';//


--echo exp-7-1-3   包含 out 
CALL studentwbmlc();//
drop procedure if exists pl_test;//
CREATE   PROCEDURE pl_test( OUT p1  int,OUT p2  int, OUT p3  int)
BEGIN
declare  i BIGINT;
SELECT   EXP(e.age)  INTO p1 FROM student e WHERE  e.NAME='Kebi';
SELECT   EXP(e.SALARY/1000)    INTO p2 FROM   student  e WHERE  e.NAME='Kebi';
SELECT   EXP(e.mon/50)    INTO p3 FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
WHILE i <= 5 DO
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p2+i,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p3+i,100);
set i := i + 1;
END WHILE;
END;
//

call pl_test(@p1,@p2,@p3);//

SELECT count(*) FROM   student;//
SELECT   DISTINCT(EXP(e.age))  FROM student e WHERE  e.NAME='Kebi';//


--echo exp-7-1-4 包含 inout 参数的存储过程,in需要穿参数   out的传变量，in  out 的作in使用就按照in处理 作out使用就按照out处理   
###in out作out使用

CALL studentwbmlc();//
drop procedure if exists pl_test;//
CREATE  PROCEDURE pl_test(OUT p1   int ,in  p2   int, inout p3 int)
BEGIN	
declare  i BIGINT;
SELECT   EXP(e.age)  INTO p1 FROM student e WHERE  e.NAME='Kebi';
SELECT   EXP(e.mon/100)    INTO p3 FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
WHILE i <= 10 DO
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p2,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p3+i,100);
set i := i + 1;
END WHILE;
END;
//
call pl_test(@p1,100,@p3);//

SELECT count(*) FROM   student;//
SELECT   DISTINCT(EXP(e.age))  FROM student e WHERE  e.NAME='Kebi';//


--echo  exp-7-1-5    存储过程用循环      
CALL studentwbmlc();//
drop procedure if exists pl_test;//
CREATE PROCEDURE pl_test(in p1 int)
BEGIN	
declare  i BIGINT;
set i:=1;
while i <= 100 do
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p1,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p1+i,100);
set i := i + 1;
END WHILE;
END;
//
CALL  pl_test(EXP(10));//
SELECT count(*) FROM   student;//
SELECT   DISTINCT(EXP(e.age/10))  FROM student e WHERE  e.NAME='Kebi';//
SELECT   DISTINCT(EXP(e.age/-1000))  FROM student e WHERE  e.NAME='Kebi';//

