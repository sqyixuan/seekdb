mysql
drop database if exists format_db;
create database format_db;
use format_db;
create table t1(c1 int primary key, c2 int, c3 int);
create index idx_t1 on t1(c2);
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);
set autocommit = 0;
CREATE FORMAT OUTLINE FOL_1 ON select /*+index(t1 idx_t1)*/c1,c2 from t1 where c1 in (1);
select c1,c2 from t1 where c1 in (2,1);
c1	c2
1	2
2	2
select c1,c2 from t1 where c1 in (2,1);
c1	c2
1	2
2	2
