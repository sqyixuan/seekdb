set ob_trx_timeout=1000000000;
select effective_tenant();
effective_tenant()
sys
drop database if exists format_comment_db;
create database format_comment_db;
use format_comment_db;
set ob_enable_plan_cache = 'ON';
create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);
create index idx_t1 on t1(c2);
set autocommit = 0;
alter system flush plan cache global;
CREATE OUTLINE FCOL_1 ON 'EF4AA51F0311641C160D48EFEED9E960' using hint /*+index(t1 idx_t1)*/;
/*abcde*/select c1 from t1 where c2 in (3);
c1
