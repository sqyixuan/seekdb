hit_count	a.outline_id != -1	outline_data
0	1	/*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "format_comment_db"."t1"@"SEL$1" "idx_t1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/
