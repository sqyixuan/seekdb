drop database if exists inexpr_db;
create database inexpr_db;
use inexpr_db;
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);
create table t2 (c1 int primary key, c2 varchar(100), c3 varchar(100), key(c2), key(c3));
insert into t2 value(1,'2','4'), (2,'2','3'), (3,'2','2'), (4,'2','1');
insert into t2 value(11,'3', '4'), (12,'3','3'), (13,'3','2'), (14,'3','1');
