#tags: format_outline
##
## Test Name: format outline datatype
## Description: to handle more in datatype conditions 
## Date: 2024-02-22
##

--disable_warnings
drop database if exists fol_db;
create database fol_db;
--enable_warnings

use fol_db;

create table t (
  id        int auto_increment primary key,
  col_type  varchar(10),
  col_int   bigint,
  col_uint  bigint unsigned,
  col_flt   float,
  col_dbl   double,
  col_nmb   decimal(30, 6),
  col_dttm  datetime(1),
  col_dt    date,
  col_tm    time(3),
  col_yr    year,
  col_str   varchar(100),
  col_bool  bool,
  col_null  int,
  key(col_int),
  key(col_uint),
  key(col_flt),
  key(col_dbl),
  key(col_nmb),
  key(col_dttm),
  key(col_dt),
  key(col_tm),
  key(col_yr),
  key(col_str)
) character set binary;
# test data.
set sql_mode='';
insert into t (col_type, col_int) values
  ('int', -9223372036854775808),
