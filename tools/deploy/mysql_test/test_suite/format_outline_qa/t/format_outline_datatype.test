  ('bool', 'false');

# check data.
select * from t order by id;

#### 1. concurrent limit ####
--error 5267
create format outline fol_int on select /*+max_concurrent(0)*/ id from t where col_int in (0) and col_type in (?);
--error 5267
create format outline fol_uint on select /*+max_concurrent(0)*/ id from t where col_uint in (1) and col_type in (?);
--error 5267
create format outline fol_flt on select /*+max_concurrent(0)*/ id from t where col_flt in (2.0) and col_type in (?);
--error 5267
create format outline fol_dbl on select /*+max_concurrent(0)*/ id from t where col_dbl in (2.0) and col_type in (?);
--error 5267
create format outline fol_nmb on select /*+max_concurrent(0)*/ id from t where col_nmb in (9223372036854775807.4) and col_type in (?);
--error 5267
create format outline fol_dttm on select /*+max_concurrent(0)*/ id from t where col_dttm in (TIMESTAMP'1970-01-01 00:00:00') and col_type in (?);
--error 5267
create format outline fol_dt on select /*+max_concurrent(0)*/ id from t where col_dt in (DATE'1970-01-01') and col_type in (?);
--error 5267
create format outline fol_tm on select /*+max_concurrent(0)*/ id from t where col_tm in (TIME'00:00:00') and col_type in (?);
--error 5267
create format outline fol_yr on select /*+max_concurrent(0)*/ id from t where col_yr in (0) and col_type in (?);
--error 5267
create format outline fol_str on select /*+max_concurrent(0)*/ id from t where col_str in ('2') and col_type in (?);
--error 5267
create format outline fol_bool on select /*+max_concurrent(0)*/ id from t where col_bool in (false) and col_type in (?);
--error 5267
create format outline fol_null on select /*+max_concurrent(0)*/ id from t where col_null in (NULL) and col_type in (?);

## 1.1 int
select   id   from t where col_int in ( 0 ) and col_type in ( 'int' );
--sorted_result
select   id   from t where col_int in ( true ) and col_type in ( 'int' );

## 1.2 uint
select   id   from  t   where   col_uint in ( 1 ) and col_type in ( 'uint' );
--sorted_result
select   id   from  t   where   col_uint in ( '1' ) and col_type in ( 'uint' );

## 1.3 float
select  id from t where col_flt in (2.0) and col_type in ( 'num' );
select  id from t where col_flt in (2.0000000) and col_type in ( 'num' );
--sorted_result
select  id from t where col_flt in (2) and col_type in ( 'num' );

## 1.4 double
select  id from t where col_dbl in (2.0000000) and col_type in ('num');

## 1.5 nmb
select  id from t where col_nmb in (9223372036854775807.4 ) and col_type in ('num');
select  id from t where col_nmb in (13 ) and col_type in ('num');

## 1.6 dttm
select  id from t where col_dttm in (TIMESTAMP'1970-01-01 00:00:00') and col_type in 
(
  'dttm'
);

## 1.7 dt
select  id from t where col_dt in (DATE'1970-01-01') and col_type in ('dttm');

## 1.8 tm
select  id from t where col_tm in (TIME'00:00:00') and col_type in ('tm');

## 1.9 yr
select  id from t where col_yr in ('1970-01-01 00:00:02') and col_type in ('yr');

## 1.10 varchar
select  id from t where col_str in ('2') and col_type in ('str_en');

create format outline fol_int on select /*+parallel(2)*/ id from t where col_int in (0) and col_type in ('int');
create format outline fol_uint on select /*+parallel(2)*/ id from t where col_uint in (1) and col_type in ('uint');
create format outline fol_flt on select /*+parallel(2)*/ id from t where col_flt in (2.0) and col_type in ('flt');
create format outline fol_dbl on select /*+parallel(2)*/ id from t where col_dbl in (2.0) and col_type in ('dbl');
create format outline fol_nmb on select /*+parallel(2)*/ id from t where col_nmb in (9223372036854775807.4) and col_type in ('nmb');
create format outline fol_dttm on select /*+parallel(2)*/ id from t where col_dttm in (TIMESTAMP'1970-01-01 00:00:00') and col_type in ('dttm');
create format outline fol_dt on select /*+parallel(2)*/ id from t where col_dt in (DATE'1970-01-01') and col_type in ('dt');
create format outline fol_tm on select /*+parallel(2)*/ id from t where col_tm in (TIME'00:00:00') and col_type in ('tm');
create format outline fol_yr on select /*+parallel(2)*/ id from t where col_yr in (0) and col_type in ('yr');
create format outline fol_str on select /*+parallel(2)*/ id from t where col_str in ('2') and col_type in ('str');
create format outline fol_bool on select /*+parallel(2)*/ id from t where col_bool in (false) and col_type in ('bool');
create format outline fol_null on select /*+parallel(2)*/ id from t where col_null in (NULL) and col_type in ('null');

select   id   from t where col_int in ( 0 ) and col_type in ( 'int' );
--sorted_result
select   id   from t where col_int in ( true ) and col_type in ( 'int' );

## 1.2 uint
select   id   from  t   where   col_uint in ( 1 ) and col_type in ( 'uint' );
--sorted_result
select   id   from  t   where   col_uint in ( '1' ) and col_type in ( 'uint' );

## 1.3 float
select  id from t where col_flt in (2.0) and col_type in ( 'num' );
select  id from t where col_flt in (2.0000000) and col_type in ( 'num' );
--sorted_result
select  id from t where col_flt in (2) and col_type in ( 'num' );

## 1.4 double
select  id from t where col_dbl in (2.0000000) and col_type in ('num');

## 1.5 nmb
select  id from t where col_nmb in (9223372036854775807.4 ) and col_type in ('num');
select  id from t where col_nmb in (13 ) and col_type in ('num');

## 1.6 dttm
select  id from t where col_dttm in (TIMESTAMP'1970-01-01 00:00:00') and col_type in
(
  'dttm'
  );

## 1.7 dt
select  id from t where col_dt in (DATE'1970-01-01') and col_type in ('dttm');

## 1.8 tm
select  id from t where col_tm in (TIME'00:00:00') and col_type in ('tm');

## 1.9 yr
select  id from t where col_yr in ('1970-01-01 00:00:02') and col_type in ('yr');

## 1.10 varchar
select  id from t where col_str in ('2') and col_type in ('str_en');



drop format outline fol_int;
drop format outline fol_uint;
drop format outline fol_flt;
drop format outline fol_dbl;
drop format outline fol_nmb;
drop format outline fol_dttm;
drop format outline fol_dt;
drop format outline fol_tm;
drop format outline fol_yr;
drop format outline fol_str;
drop format outline fol_bool;
drop format outline fol_null;


### create invalid format outline
--error 5267
create format outline fol2_int on select /*+max_concurrent(1)*/ id from t where col_int in (0) to select /*+trace_log*/ id from t where col_int in (0) ;
