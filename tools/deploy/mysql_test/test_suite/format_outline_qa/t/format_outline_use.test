select a.outline_id != -1, a.outline_data from oceanbase.v$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select * from t_recycle where (c1,c2,c3) in ((?,?,?), (?, ?,  ?))' and a.outline_id=b.outline_id and b.outline_name='fotl_5';


