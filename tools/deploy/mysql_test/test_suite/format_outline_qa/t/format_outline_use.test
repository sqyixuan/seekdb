select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1);
select sql_id, format_sql_id from oceanbase.v$ob_sql_audit where query_sql like 'select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1)';
create format outline fol_s3 on select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1);
