connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;
START TRANSACTION;
--disable_warnings
drop database if exists fol_db;
create database fol_db;

use fol_db;
connection conn_admin;
alter system flush plan cache global;

connection default;
create table t1(c1 int primary key, c2 int, c3 int);
create index idx_t1 on t1(c2);
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);

create format outline fol_s1 on select /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "fol_db"."t1"@"SEL$1" "idx_t1") END_OUTLINE_DATA*/ c2,c1 from t1 where c2 in (2);

##scene 1:test correction when schema version changes

alter table t1 add column c4 int;
select  c2,c1 from t1 where c2 in (2);
select  c2,c1 from t1 where c2 in (3);
select hit_count,outline_id != -1,outline_data from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a where a.statement = "select  c2,c1 from t1 where c2 in (?)";

drop format outline fol_s1;
sleep 2;


##scene 2:check create format outline on view
create view v1 as select c1,c2, c3 from t1;
create format outline fol_s2 on select /*+index(t1 idx_t1) yyyy*/ c2,c1 from v1 where c2 in (2) order by 1;
sleep 2;
select c2,c1 from v1 where c2 in (2) order by 1;
select c2,c1 from v1 where c2 in (2) order by 1;
select hit_count,outline_id != -1, outline_data from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select c2,c1 from v1 where c2 in (?) order by 1";
drop format outline fol_s2;


