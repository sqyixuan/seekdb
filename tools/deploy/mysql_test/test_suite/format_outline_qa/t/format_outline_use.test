alter system flush sql audit;
create table test_format_otl(c1 int, c2 char, c3 varchar(4000), c4 timestamp,
                            index test_format_otl_idx1(c1));
insert into test_format_otl(c1,c2,c3,c4) values(0,'0','00000',now(6));      
