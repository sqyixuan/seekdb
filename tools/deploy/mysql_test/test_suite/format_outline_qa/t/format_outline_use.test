## 
alter system flush plan cache global;
create table t1(c1 bigint primary key, c2 bigint, c3 varchar(2048),
    index idx1(c2),
    index idx2(c1,c2),
    index idx3(c1,c3));

## 
create or replace outline otl_1 on select /*+index(t1 idx2)*/* from t1 where c1 in (1,2,3) and c2 in (2,3,4);
create or replace format outline fotl_1 on select /*+index(t1 idx1)*/* from t1 where c1 in (1,2,3) and c2 in (2,3,4);
select * from t1 where c1 in (1,2,3) and c2 in (2,3,4);
select a.outline_id != -1, a.outline_data from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_outlines b where a.statement = 'select * from t1 where c1 in (?,?,?) and c2 in (?,?,?)' and a.outline_id=b.outline_id and b.outline_name='otl_1';
drop outline otl_1;
select * from t1 where c1 in (1,2,3) and c2 in (2,3,4);
select a.outline_id != -1, a.outline_data from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select * from t1 where c1 in (?,?,?) and c2 in (?,?,?)' and a.outline_id=b.outline_id and b.outline_name='fotl_1';
drop format outline fotl_1;
select * from t1 where c1 in (1,2,3) and c2 in (2,3,4);
select outline_id from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t1 where c1 in (?,?,?) and c2 in (?,?,?)';


##scene : conflict format outline and its error message
#
create format outline fotl_1 on select /*+index(t1 idx1)*/* from t1 where c1 in (1,2,3) and c2 in (2,3,4);
--error 5264
create format outline fotl_1 on select /*+index(t1 idx1)*/* from t1 where c1 in (1) and c2 in (2);
--error 5264
create format outline fotl_2 on select * from t1 where c1 in (1) and c2 in (2);
drop format outline fotl_1;

