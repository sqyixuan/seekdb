##scene :test format outline with drop table and then create table with same name
create table t_6(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
insert into t_6 values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
create format outline fotl_3 on select /*+log_level("trace")*/c1,c2 from t_6 where (c1,c2) in ((1,'2'));
# format sql id: 879FF24C1AC51BEF12330288E8611C6B = select c1,c2 from t_6 where (c1,c2) in ((1,'2'));
create format outline fotl_4 on '879FF24C1AC51BEF12330288E8611C6B' using hint /*+max_concurrent(0)*/;
select c1,c2 from t_6 where (c1,c2) in ((1,'2'));
#scene: format outline created by format sql text is premier
select a.outline_id != -1, a.outline_data from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select c1,c2 from t_6 where (c1,c2) in ((?,?))' and a.outline_id=b.outline_id and b.outline_name='fotl_3';

sleep 2;
drop table t_6;
create table t_6(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
insert into t_6 values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
select c1,c2 from t_6 where (c1,c2) in ((1,'2'));
select a.outline_id != -1, a.outline_data from oceanbase.v$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select c1,c2 from t_6 where (c1,c2) in ((?,?))' and a.outline_id=b.outline_id and b.outline_name='fotl_3';

drop format outline fotl_4;
select c1,c2 from t_6 where (c1,c2) in ((1,'2'));
select a.outline_id != -1, a.outline_data from oceanbase.v$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select c1,c2 from t_6 where (c1,c2) in ((?,?))' and a.outline_id=b.outline_id and b.outline_name='fotl_3';

drop format outline fotl_3;
drop table t_6;


##scene 7:test format outline with recycled table
create table t_recycle(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
insert into t_recycle values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
select * from t_recycle where (c1,c2,c3) in ((1,'2',9.0));
# format sql id: A532C2C383364297F3C4BEC94BF9862C = select * from t_recycle where (c1,c2,c3) in ((1,'2',9.0));
create format outline fotl_5 on 'A532C2C383364297F3C4BEC94BF9862C' using hint /*+max_concurrent(0) log_level('trace')*/;
--error 5268
select * from t_recycle where (c1,c2,c3) in ((1,'2',9.0), (2, '4',  8.0));
select a.outline_id != -1, a.outline_data from oceanbase.v$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select * from t_recycle where (c1,c2,c3) in ((?,?,?), (?, ?,  ?))' and a.outline_id=b.outline_id and b.outline_name='fotl_5';

set recyclebin = 'ON';
sleep 2;
drop table t_recycle;
sleep 2;
--error 1146
select c1, c2 from t_recycle;
select database_name,outline_name,format_sql_id,outline_content from oceanbase.DBA_OB_FORMAT_OUTLINES where outline_name = 'fotl_5';

--disable_query_log
FLASHBACK TABLE t_recycle TO BEFORE DROP;
--enable_query_log
sleep 2;
--error 5268
select * from t_recycle where (c1,c2,c3) in ((1,'2',9.0), (2, '4',  8.0));
select a.outline_id != -1, a.outline_data from oceanbase.v$OB_PLAN_CACHE_PLAN_STAT a, oceanbase.dba_ob_format_outlines b where a.statement = 'select * from t_recycle where (c1,c2,c3) in ((?,?,?), (?, ?,  ?))' and a.outline_id=b.outline_id and b.outline_name='fotl_5';
select database_name,outline_name,format_sql_id,outline_content from oceanbase.DBA_OB_FORMAT_OUTLINES where outline_name = 'fotl_5';



##scene 8:test format outline with recycled database
