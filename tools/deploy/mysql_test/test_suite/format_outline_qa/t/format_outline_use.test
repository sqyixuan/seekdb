insert into test_format_otl(c1,c2,c3,c4) values(2,'0','00000',now(6));
insert into test_format_otl(c1,c2,c3,c4) values(3,'0','00000',now(6)); 
select c1,c2,c3 from test_format_otl where c1 in (0,1,2,3);
