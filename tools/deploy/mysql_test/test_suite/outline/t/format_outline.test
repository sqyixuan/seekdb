### create format outline with no parameterized sql
select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1);
create format outline fol_s3 on select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1);
select OUTLINE_NAME,VISIBLE_SIGNATURE,FORMAT_SQL_TEXT from oceanbase.dba_ob_format_outlines where outline_name = 'fol_s3';
DROP FORMAT OUTLINE fol_s3;

