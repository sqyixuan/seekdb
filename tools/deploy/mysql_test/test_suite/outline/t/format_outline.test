--error 0,5265
DROP FORMAT OUTLINE otl2;
CREATE FORMAT OUTLINE otl2 ON SELECT /*+ INDEX(t1 c2_asc) */ * FROM t1 where c3 in (1);

###创建普通outline
--error 0,5265
DROP OUTLINE otl3;
CREATE OUTLINE otl3 ON SELECT /*+ FULL(t1) */ * FROM t1 where c3 in (1);

SELECT * FROM t1 where c3 in (1);

--disable_result_log
SELECT * FROM OceanBase.GV$OB_PLAN_CACHE_PLAN_STAT
    WHERE SQL_ID IN (
        SELECT SQL_ID FROM OceanBase.GV$OB_SQL_AUDIT 
        WHERE QUERY_SQL LIKE "SELECT * FROM t1 where c3 in (1)%"
    );
--enable_result_log

EXPLAIN OUTLINE SELECT * FROM t1 where c3 in (1);


DROP FORMAT OUTLINE otl2;
DROP OUTLINE otl3;

