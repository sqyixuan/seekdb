--error 0,1008
drop database ykk;
create database ykk;
use ykk;

SET global ob_sql_audit_percentage = 80;

--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
    c1 INT primary key,
    c2 INT,
    c3 INT,
    c4 INT,
    c5 INT,
    c6 VARCHAR(20),
    c7 VARCHAR(20)
);

CREATE INDEX c1_asc on t1(c1 asc);
CREATE INDEX c2_asc on t1(c2 asc);

INSERT INTO t1 values(1,2,33,49,51,'aaaa','babb');
INSERT INTO t1 values(2,3,32,48,52,'ccac','addd');
INSERT INTO t1 values(3,1,31,47,53,'eeae','ffaf');
INSERT INTO t1 values(4,5,322,46,54,'ggag','hahh');
INSERT INTO t1 values(5,6,333,45,55,'iiai','fsdag');
INSERT INTO t1 values(6,7,3445,44,56,'asdaadsa','rfacc');
INSERT INTO t1 values(7,9,3565,43,57,'adaadxzc','aadsa');
INSERT INTO t1 values(8,7,34324,42,58,'dvvax','xcxvaxc');
INSERT INTO t1 values(9,8,366,41,59,'aaaaaa','dddadd');

