 CREATE TABLE MINI_ACCOUNT_LOG_MSG
   (  MINI_TRANS_LOG_ID VARCHAR(32) NOT NULL ,
  TRANS_DATE VARCHAR(8),
  TRANS_CODE VARCHAR(4),
  SUB_TRANS_CODE VARCHAR(6),
  OUT_DATE VARCHAR(8),
  TRANS_DT TIMESTAMP (6),
  TRANS_AMOUNT BIGINT(15),
