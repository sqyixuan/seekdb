  TRANS_CURRENCY VARCHAR(3),
  ACCOUNT_TYPE VARCHAR(1),
  ACCOUNT_NO VARCHAR(20),
  OTHER_ACCOUNT_TYPE VARCHAR(1),
  OTHER_ACCOUNT_NO VARCHAR(20),
