  PRIMARY KEY (MINI_TRANS_LOG_ID)
   ) ;
  CREATE INDEX MN_ACC_LOG_SUMACN_IND ON MINI_ACCOUNT_LOG_SUMMARY (ACCOUNT_NO, TRANS_DT) ;

  CREATE TABLE MINI_ACCOUNT_LOG_CACHE
   (  TRANS_DATE VARCHAR(8) NOT NULL ,
  TRANS_CODE VARCHAR(4) NOT NULL ,
  SUB_TRANS_CODE VARCHAR(6) NOT NULL ,
