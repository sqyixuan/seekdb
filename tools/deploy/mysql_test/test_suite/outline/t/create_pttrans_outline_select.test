--disable_query_log
eval select a.name as name, a.outline_content as outline_content, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='pttrans00' and a.name like "%pttrans%";
--enable_query_log
disconnect obsys;
connection default;
