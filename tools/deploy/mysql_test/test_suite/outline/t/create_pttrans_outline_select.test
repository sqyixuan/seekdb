   )  ;
CREATE TABLE MINI_ACCOUNT_LOG
   (  MINI_TRANS_LOG_ID VARCHAR(32) NOT NULL ,
  TRANS_DATE VARCHAR(8) NOT NULL ,
  TRANS_CODE VARCHAR(4) NOT NULL ,
