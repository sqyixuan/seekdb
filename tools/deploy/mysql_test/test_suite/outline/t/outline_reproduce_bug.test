#owner: guohanyun.ghy
#owner group: SQL1
#tags: outline, optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);

explain outline select /*+tracing(2)*/ * from t1, t2;
explain outline select /*+parallel(2) tracing(5)*/ distinct * from t1;
explain outline select /*+LEADING(t1 t2), NO_USE_NL_MATERIALIZATION(t2), BLOCKING('all')*/ * from t1, t2;

drop table t1, t2;