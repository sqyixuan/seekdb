#owner: xiaoyi.xy
#owner group: SQL1
#description: 该case是为了验证alter outline的语法
#tags: outline
#

--enable_sorted_result
let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;

connection default;

set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;

START TRANSACTION;
--disable_warnings
drop database if exists ol_db;
create database ol_db;
use ol_db;

create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
select statement, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ?";
select statement, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1  from t1 where c2 = ?";
select statement, hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ?" and outline_id >0;
select statement, hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1  from t1 where c2 = ?" and outline_id >0;

##alter outline 必须基于已存在的outline
--error 5265
alter outline olt_1 add select /*+trace_log*/ c2,c1 from t1 where c2 = 2;
--error 5265
alter outline olt_2 add select /*+max_concurrent(1)*/ c2,c1  from t1 where c2 = 2;

create outline olt_1 on select /*+max_concurrent(5)*/ c2,c1 from t1 where c2 = 2;
create outline olt_2 on select /*+index(t1 c3)*/ c2,c1  from t1 where c2 = 2;

connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;

sleep 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
connection obsys;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1  from t1 where c2 = ?" and b.name = "olt_2";
connection default;
use ol_db;

--error 5272
alter outline olt_1 add select /*+trace_log*/ c2,c1 from t1 where c2 = 2;
drop outline olt_1;
##alter outline 新增outline_content时，原outline已有outline_content则报错
--error 5272
alter outline olt_2 add select /*+index(t1 c3)*/ c2,c1  from t1 where c2 = 2;
alter outline olt_2 add select /*+no_rewrite max_concurrent(6)*/ c2,c1  from t1 where c2 = 2;
##outline content 已存在,新增限流无限制,不影响outline_content
#
alter outline olt_2 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c2 = ?;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;
sleep 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
connection obsys;
select statement, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";
select statement, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1  from t1 where c2 = ?" and b.name = "olt_2";
connection default;
use ol_db;

#create or replace outline 会替换掉outline的所有内容，生成一个全新的outline
create or replace outline olt_2 on select /*+index(t1 c2)*/ c2,c1  from t1 where c2 = 3;

connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;
sleep 4;
select  c2,c1  from t1 where c2 = 2;
select  c2,c1  from t1 where c2 = 2;
connection obsys;
select statement, hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1  from t1 where c2 = ?" and b.name = "olt_2";
connection default;
use ol_db;

--error 5272
alter outline olt_2 add select  c2,c1  from t1 where c2 = 3;
##sql_text will not be overide in this situation
alter outline olt_2 add select /*+max_concurrent(1)*/ c2,c1  from t1 where c2 = 3;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;
drop outline olt_2;

##check if sql_text if correct
create or replace outline olt_2 on select /*+max_concurrent(1)*/ c2,c1  from t1 where c2 = 3;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;

--error 5272
alter outline olt_2 add select  c2,c1  from t1 where c2 = 3;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;

drop outline olt_2;
##test alter outline add max_concurrent
create or replace outline olt_3 on select /*+max_concurrent(1)*/ c2,c1  from t1 where c1 > 3 and c2 = 1;
##同一个signature可以创建多条限流语句
alter outline olt_3 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 1;
alter outline olt_3 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 2;
alter outline olt_3 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 3;
sleep  5;

--error 5273
alter outline olt_3 add select /*+max_concurrent(1)*/ c2,c1  from t1 where c1 > ? and c2 = 3;

#限流是否生效
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 3;
--error 5268
select  c2,c1  from t1 where c1 > 0 and c2 = 3;
--error 5268
select  c2,c1  from t1 where c1 > 2 and c2 = 3;
select  c2,c1  from t1 where c1 > 2 and c2 = 2;

#当一条查询同时符合多个限流条件，则取限流数最小的那个
alter outline olt_3 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > 1 and c2 = 1;
sleep  5;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 1;

alter outline olt_3 add select /*+max_concurrent(1)*/ c2,c1  from t1 where c1 > 1 and c2 = ?;
sleep  5;
select  c2,c1  from t1 where c1 > 1 and c2 = 4;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 1;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 3;

--error 5267
alter outline olt_3 add select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 1 and c2 = ?;

--error 5267
alter outline olt_3 add select /*+max_concurrent(4)*/ c2,c1  from t1 where c2 = 3;
--error 5272
alter outline olt_3 add select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 1 and c2 = 2;
sleep  5;
select  c2,c1  from t1 where c1 > 1 and c2 = 2;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 3;

alter outline olt_3 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = ?;
sleep  5;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 2;
--error 5268
select  c2,c1  from t1 where c1 > 1 and c2 = 4;
--error 5268
select  c2,c1  from t1 where c1 > 8 and c2 = 9;

##drop outline 之后重建
drop outline olt_3;
create or replace outline olt_3 on select /*+max_concurrent(1)*/ c2,c1  from t1 where c1 > 3 and c2 = 1;
alter outline olt_3 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 1;
alter outline olt_3 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 2;
--error 5272
alter outline olt_3 add select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 0 and c2 = 2;
sleep  5;
select  c2,c1  from t1 where c1 > -1 and c2 = 2;

drop outline olt_3;
##test alter outline with to_clause
##.0 to clause with no hint and create outline first
create or replace outline olt_4 on select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 3 and c2 = 1;
--error 5267
alter outline olt_4 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select  c2,c1  from t1 where c1 > 3 and c2 = 1;
--error 5267
alter outline olt_4 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select  c2,c1  from t1 where c1 > ? and c2 = 3;
alter outline olt_4 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select  c2,c1  from t1 where c1 > ? and c2 = 1;
alter outline olt_4 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > 2 and c2 = 1 to select  c2,c1  from t1 where c1 > 2 and c2 = 1;
alter outline olt_4 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 3;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;
sleep  5;
--error 5268
select  c2,c1  from t1 where c1 > 2 and c2 = 1;
--error 5268
select  c2,c1  from t1 where c1 > 3 and c2 = 3;
--error 5268
select  c2,c1  from t1 where c1 > 0 and c2 = 3;

select  c2,c1  from t1 where c1 > 3 and c2 = 1;
select  c2,c1  from t1 where c1 > 3 and c2 = 2;

##.1 to clause with no hint and create sql concurrent first
drop outline olt_4;
create or replace outline olt_5 on select /*+max_concurrent(1)*/ c2,c1  from t1 where c1 > 3 and c2 = 2;
--error 5267
alter outline olt_5 add select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select  c2,c1  from t1 where c1 > 3 and c2 = 1;
--error 5272
alter outline olt_5 add select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 2 and c2 = 1 to select  c2,c1  from t1 where c1 > 3 and c2 = 1;
alter outline olt_5 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 1;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;

sleep  5;
--error 5268
select  c2,c1  from t1 where c1 > 2 and c2 = 1;
--error 5268
select /**fadfa*/ c2,c1  from t1 where c1 > 2 and c2 = 1;
select  c2,c1  from t1 where c1 > 2 and c2 = 2;
drop outline olt_5;

##.2 to clause with hint and create sql concurrent first
create outline olt_6 on select /*+index(t1 c3)*/ c2,c1  from t1 where c1 > 2 and c2 = 1 to select /*+no_rewrite*/ c2,c1  from t1 where c1 > 3 and c2 = 1;
--error 5267
alter outline olt_6 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select /*+no_rewrite*/ c2,c1  from t1 where c1 > 3 and c2 = 1;
--error 5267
alter outline olt_6 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select  c2,c1  from t1 where c1 > ? and c2 = 1;

alter outline olt_6 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > ? and c2 = 1 to select /*+no_rewrite*/ c2,c1  from t1 where c1 > ? and c2 = 1;
alter outline olt_6 add select /*+max_concurrent(2)*/ c2,c1  from t1 where c1 > ? and c2 = 2 to select /*+no_rewrite*/ c2,c1  from t1 where c1 > ? and c2 = 2;
alter outline olt_6 add select /*+max_concurrent(0)*/ c2,c1  from t1 where c1 > 3 and c2 = 2 to select /*+no_rewrite*/ c2,c1  from t1 where c1 > 3 and c2 = 2;

connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
connection default;
use ol_db;
sleep  5;
--error 5268
select /*+no_rewrite*/ c2,c1  from t1 where c1 > 2 and c2 = 1;
--error 5268
select /*+no_rewrite*/ c2,c1  from t1 where c1 > 3 and c2 = 2;
select /*+no_rewrite*/ c2,c1  from t1 where c1 > 2 and c2 = 2;

drop outline olt_6;
##end
drop database ol_db;
sleep 5;
use oceanbase;
connection obsys;
--disable_query_log
--replace_column 1 tenant_id
eval select a.tenant_id as tenant_id, a.name as name, hex(a.signature) as hex_signatrue, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db';
--enable_query_log
commit;

disconnect obsys;
