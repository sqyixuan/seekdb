# owner: xiaoyi.xy
# owner group: sql1
# tags: optimizer

# 给定任意长度的sql_id，需要检查sql_id是否合法
# 创建过的sql_id，需要报重复创建。如果加上replace，需要能覆盖
# 通过sql来创建outline，和用sql_id来创建outline，需要报重复
# 测试hint不合法的情况
# 通过V$OB_PLAN_CACHE_PLAN_EXPLAIN来看计划是否正确，删除outline是否正确。
# 通过outline限流的功能是否能正常工作
# 测试更新语句，看看outline是否能正常工作
# explain语句，看看outline是否能正常工作
# 考虑limit和order by 1这种语句

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);


use test;
--disable_warnings
drop table if exists t1;
--error 0, 5265
drop outline o1;
--error 0, 5265
drop outline o2;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
delete from oceanbase.__all_outline;
sleep 3;
connection default;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;

create table t1 (c1 int primary key, c2 int, c3 int, index i1 (c2));
insert into t1 values(1,5,0);
insert into t1 values(2,4,0);
insert into t1 values(3,3,0);

--error 1210
create outline o1 on 'abc' using hint /*+ index(t1 i1) */;
--error 1210
create outline o1 on 'ABC' using hint /*+ index(t1 i1) */;
--error 1210
create outline o1 on '6Z85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
--error 1210
create outline o1 on '6f85afbfa98a19d78ab7fd9d46ed3c0c' using hint /*+ index(t1 i1) */;
create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
--error 5264
create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
drop outline o1;


create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
--error 5264
create outline o2 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
--error 5264
create or replace outline o2 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
create or replace outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
drop outline o1;


create outline o1 on select /*+ index(t1 i1) */ * from t1;
create outline o2 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
drop outline o1;
drop outline o2;

--error 5267
create outline o2 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ kkwhioewhoiohge */;


select * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
connection default;
--enable_query_log
create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
select * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

drop outline o1;
select * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
--error 5267
create or replace outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ kkwhioewhoiohge */;
select * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

drop outline o1;

create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ index(t1 i1) */;
create outline o2 on select/*+ index(t1 primary) */ * from t1;
select * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;


drop outline o1;
drop outline o2;


select * from t1 limit 1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1 limit ?'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

create outline o1 on '618B4EC07497439E24BE9321D1067E7D' using hint /*+ index(t1 i1) */;
select * from t1 limit 1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1 limit ?'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

drop outline o1;

select * from t1 limit 1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select * from t1 limit ?'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;



select /*+index(t1 primary) */ * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select /*+index(t1 primary) */ * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
connection default;

create outline o1 on '666E79F95F195546AFCD0815F5F146C1' using hint /*+ index(t1 i1) */;
select /*+index(t1 primary) */ * from t1;
connection obsys;
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where statement = 'select /*+index(t1 primary) */ * from t1'", plan_id, 1);
--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE plan_id = $plan_id;
--enable_query_log
