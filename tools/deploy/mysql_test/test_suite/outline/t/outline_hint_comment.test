--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL1
# tags: outline
# description: 

--result_format 4
--enable_sorted_result
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
disconnect obsys;
connection default;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;

--disable_warnings
--error 0,5265
drop outline ol1;
--error 0,5265
drop outline o2;
--error 0,5265
drop outline o3;
--enable_warnings
##### test normal outline
create table t1(a int primary key, b int, c int, key id1(a), key id2(b));
insert into t1 values(1, 3, 1), (2, 2, 2), (3, 1, 3);
create outline ol1 on select/*+index(t1 id2)*/ * from t1;
### use outline, use index id2
select * from t1;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t1';
### use outline, use index id2
select/*comment1*/ * from t1;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t1';
### can not use outline, use primary key
select/*+index(t1 id2)*/ * from t1;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select/*+index_(t1 id2)*/ * from t1';
### can not use outline, use primary key
select/*comment1*/ /*+index(t1 primary)*/ * from t1;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select /*+index(t1 id2)*/ * from t1';

##### test outline with hint
create table t2(a int primary key, b int, c int, key id1(a), key id2(b));
insert into t2 values (1, 3, 1), (2, 2, 2), (3, 1, 3);
create outline o2 on select/*+index(t2 primary)*/ * from t2 to select/*+index(t2 id2)*/ * from t2;
## can not use outline, use primary key
select * from t2;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t2';
### can not use outline, use primary key
select/*comment1*/ * from t2;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t2';
## can use outline, use primary key
select/*+index(t2 id2)*/ * from t2;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select/*+index(t2 id2)*/ * from t2';
## can not use outline, use index id2
select/*comment1*/ /*+index(t2 id2)*/ * from t2;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select/*+index(t2 id2)*/ * from t2';

##### test outline with hint and comment
create table t3(a int primary key, b int, c int, key id1(a), key id2(b));
insert into t3 values (1, 3, 1), (2, 2, 2), (3, 1, 3);
create outline o3 on select/*+index(t3 primary)*/ * from t3 to select/*comment1*/ /*+index(t3 id2)*/ * from t3;
## can not use outline, use primary key
select * from t3;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t3';
### can not use outline, use primary key
select/*comment1*/ * from t3;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t3';
## can not use outline, use index id2
select/*+index(t3 id2)*/ * from t3;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select/*+index(t3 id2)*/ * from t3';
## can use outline, use primary key
select/*comment1*/ /*+index(t3 id2)*/ * from t3;
select statement, hit_count, outline_data, outline_id != -1 from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = 'select/*+index(t3 id2)*/ * from t3';

drop outline ol1;
drop outline o2;
drop outline o3;
