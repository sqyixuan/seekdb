#owner: xiaoyi.xy
#owner group: SQL1
#tags: pl, outline
##
## Test Name: outline_no_hint_check_right
##
## Scope: Test  whether match the right plan with outline
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2016-6-12
##

--disable_info
--disable_metadata

--disable_query_log
--disable_result_log
--error 0,5157
let $session = 64;

set ob_trx_timeout=1000000000;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache;
delete from oceanbase.__all_outline;
sleep 5;
connection default;

set ob_trx_timeout=1000000000;

select effective_tenant();
let $tenant_id=query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);

set autocommit = 0;

# --echo
--disable_warnings
drop database if exists yyy_db;
--enable_warnings
create database yyy_db;
use yyy_db;

 --disable_result_log
SET NAMES 'utf8mb4' COLLATE 'utf8mb4_general_ci';
set @@ob_enable_plan_cache = 0;
--sleep 1
source mysql_test/test_suite/outline/t/outline_table_init.sql;
--enable_query_log
--enable_result_log
--disable_warnings
source mysql_test/test_suite/outline/t/./outline_no_hint_change_param.sql;
--enable_warnings
set @@ob_enable_plan_cache = 1;
--disable_result_log
--disable_query_log
--disable_warnings
source mysql_test/test_suite/outline/t/./outline_no_hint.sql;
--enable_warnings
--enable_result_log
--enable_query_log
#####attention: 利用空格使得同样语义的sql命中不同的plan
#####如select c1 from t1;和select c1  from t1;将命中不同的plan

