create outline  ol_247 on select * from  t1  for update wait 1;

create outline  ol_248 on select * from  t1  a  for update wait 1;

create outline  ol_249 on select * from  t1  where c1 <100 for update wait 1;

create outline  ol_250 on select * from  t1  where c1 <100  and c2 < 100 for update wait 1;

create outline  ol_251 on select * from  t1  where c1 in (1,2,3,4,5,6) for update wait 1;

create outline  ol_252 on select * from  t1  where (c1,c2) in ((1,2), (2,3),(3,4)) for update wait 1;

create outline  ol_253 on select * from t1 t where t.c2 = 1 and t.c1 = 2 for update nowait;

create outline  ol_254 on select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 0 for update;

connection obsys;
--disable_query_log
eval select /*+read_consistency(weak)*/ count(*) from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= $tenant_id and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'yyy_db';
--enable_query_log
connection default;

sleep 5;
--disable_result_log
--disable_query_log
source mysql_test/test_suite/outline/t/./outline_no_hint.sql;
--enable_query_log
--enable_result_log
--disable_warnings
source mysql_test/test_suite/outline/t/./outline_no_hint_change_param.sql;
--disable_query_log
--disable_result_log
--enable_warnings

commit;
set autocommit = 1;
--disable_warnings
drop database if exists yyy_db;
--enable_warnings

