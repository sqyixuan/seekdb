select  id from t where col_uint > 9223372036854775807.4 and col_type = 'uint';
select  id from t where col_uint > '1970-01-01 00:00:01' and col_type = 'uint';
select  id from t where col_uint > '1970-00-01' and col_type = 'uint';
--sorted_result
select  id from t where col_uint > '00:00:01' and col_type = 'uint';
select  id from t where col_uint > '1' and col_type = 'uint';
select  id from t where col_uint > '1' and col_type = 'uint';
select  id from t where col_uint > true and col_type = 'uint';
select  id from t where col_uint > null and col_type = 'uint';

