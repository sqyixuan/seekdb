####################################### test for create outine #######################################

# test int
create outline ol2_int on select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > 0 ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > 0.0 ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > 9223372036854775807.4 ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > TIMESTAMP'1970-01-01 00:00:00' ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > DATE'1970-01-01' ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > TIME'00:00:00' ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > '0' ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > false ;
--error 5267
alter outline ol2_int add select /*+max_concurrent(1)*/ id from t where col_int > 0 to select /*+trace_log*/ id from t where col_int > NULL ;

# test float
create outline ol2_flt on select /*+max_concurrent(1)*/ id from t where col_flt > 0.0 to select /*+trace_log*/ id from t where col_flt > 0.0 ;
--error 5267
alter outline ol2_flt add select /*+max_concurrent(1)*/ id from t where col_flt > 0.0 to select /*+trace_log*/ id from t where col_flt > 0 ;
--error 5267
alter outline ol2_flt add select /*+max_concurrent(1)*/ id from t where col_flt > 0.0 to select /*+trace_log*/ id from t where col_flt > 9223372036854775807.4 ;
--error 5267
alter outline ol2_flt add select /*+max_concurrent(1)*/ id from t where col_flt > 0.0 to select /*+trace_log*/ id from t where col_flt > TIMESTAMP'1970-01-01 00:00:00' ;
--error 5267
alter outline ol2_flt add select /*+max_concurrent(1)*/ id from t where col_flt > 0.0 to select /*+trace_log*/ id from t where col_flt > DATE'1970-01-01' ;
--error 5267
