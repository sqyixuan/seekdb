####################################### test for limit 1 #######################################


create outline ol1_int on select /*+max_concurrent(1)*/ id from t where col_int > 0 ;
create outline ol1_uint on select /*+max_concurrent(1)*/ id from t where col_uint > 1 ;
create outline ol1_flt on select /*+max_concurrent(1)*/ id from t where col_flt > 2.0 ;
create outline ol1_dbl on select /*+max_concurrent(1)*/ id from t where col_dbl = 2.0 ;
create outline ol1_nmb on select /*+max_concurrent(1)*/ id from t where col_nmb = 2.0 ;
create outline ol1_dttm on select /*+max_concurrent(1)*/ id from t where col_dttm > TIMESTAMP'1970-01-01 00:00:00' ;
create outline ol1_dt on select /*+max_concurrent(1)*/ id from t where col_dt > DATE'1970-01-01' ;
create outline ol1_tm on select /*+max_concurrent(1)*/ id from t where col_tm > TIME'00:00:00' ;
create outline ol1_yr on select /*+max_concurrent(1)*/ id from t where col_yr = 0 ;
create outline ol1_str on select /*+max_concurrent(1)*/ id from t where col_str = '2' ;
create outline ol1_bool on select /*+max_concurrent(1)*/ id from t where col_bool = false ;
create outline ol1_null on select /*+max_concurrent(1)*/ id from t where col_null = NULL ;

sleep 2;

