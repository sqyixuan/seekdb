#owner: xiaoyi.xy
#owner group: SQL4
#description: 该case是为了验证outline 和不同数据类型的结合使用
##tags: outline
--disable_warnings
drop database if exists ol_db;
create database ol_db;

let $def_plan_cache_percentage = query_get_value(show variables like 'ob_plan_cache_percentage', Value, 1);
set global ob_plan_cache_percentage = 10;
use ol_db;
# data table.
create table t (
  id        int auto_increment primary key,
  col_type  varchar(10),
  col_int   bigint,
  col_uint  bigint unsigned,
  col_flt   float,
  col_dbl   double,
  col_nmb   decimal(30, 6),
  col_dttm  datetime(1),
  col_dt    date,
  col_tm    time(3),
  col_yr    year,
  col_str   varchar(100),
  col_bool  bool,
  col_null  int,
  key(col_int),
  key(col_uint),
  key(col_flt),
  key(col_dbl),
  key(col_nmb),
  key(col_dttm),
  key(col_dt),
  key(col_tm),
  key(col_yr),
  key(col_str)
) character set binary;

# test data.
set sql_mode='';
insert into t (col_type, col_int) values
  ('int', -9223372036854775808),
  ('int', -9223372036854775807),
  ('int', 8),
  ('int', 7),
  ('int', 6),
  ('int', 1000000000),
  ('int', 9223372036854775806),
