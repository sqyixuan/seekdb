# owner: xiaoyi.xy
# owner group: sql1
# tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;

--echo
--echo //**** test create outline on sql which start with comment ***
create table t1 (c1 int primary key, c2 int, c3 int, index i1 (c2));
insert into t1 values(1,5,0);

--echo //**** case 1: test select
--disable_warnings
--error 0, 5265
drop outline o1;
--enable_warnings
create outline o1 on '3358337D43B55D768BDA75B076F3EF47' using hint /*+ index(t1 i1) */;
/*abcd ef*/ select * from t1;
--echo // expected 1,  use index i1
select query_sql, outline_id != -1, outline_data from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '3358337D43B55D768BDA75B076F3EF47' order by 1;
drop outline o1;


--echo
--echo //**** case 2: test space is \r\n
--disable_warnings
--error 0, 5265
drop outline o2;
--enable_warnings
create outline o2 on 'B0296E1AA1CFDBDA04331B202985A7CF' using hint /*+ index(t1 i1) */;
/*abcd ef*/

select
 * from t1;
--echo // expected 1,  use index i1
select query_sql, outline_id != -1, outline_data from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'B0296E1AA1CFDBDA04331B202985A7CF' order by 1;
drop outline o2;

--echo
drop table t1;
