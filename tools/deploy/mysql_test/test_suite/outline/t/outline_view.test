#owner: xiaoyi.xy
#owner group: SQL1
#tags: outline
##
## Test Name: outline_view
##
## Scope: Test view related to outline in database information_schema
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2016-6-12
##

START TRANSACTION;
--disable_info
--disable_metadata

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--error 0,5157
connection default;

--enable_query_log
--enable_result_log
desc oceanbase.DBA_OB_OUTLINES;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
sleep 1;
select outline_name, hex(visible_signature), substr(visible_signature, 1, conv(hex(substr(visible_signature, 1, 1)), 16,10)), sql_text from oceanbase.DBA_OB_OUTLINES where outline_name like '%olt_1%';
let $sys_outline_name = query_get_value(select outline_name from oceanbase.DBA_OB_OUTLINES where outline_name like '%olt_1%', outline_name, 1);
eval drop outline $sys_outline_name;
drop table t1;

connection obsys;
--disable_query_log
--disable_warnings
#eval create resource unit if not exists yyy_box_1 max_cpu 3, memory_size '2G';
--enable_warnings
#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
--enable_query_log

#let $obs_num = query_get_value(select count(1) as cnt from oceanbase.__all_server group by zone asc limit 1,cnt, 1);
--disable_query_log
--disable_warnings
sleep 10;
#eval create resource pool if not exists yyy_pool_1 unit = 'yyy_box_1', unit_num = $obs_num;
--enable_warnings
--enable_query_log
--disable_warnings
#eval create tenant if not exists yyy_tenant_1 primary_zone='$zone_name', resource_pool_list('yyy_pool_1') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings
connection default;
connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
#select effective_tenant_id();
--disable_warnings
drop database if exists yyy_db;
--enable_warnings
create database yyy_db;
use yyy_db;

desc oceanbase.DBA_OB_OUTLINES;
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
connection conn1;
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
sleep 1;
select outline_name, hex(visible_signature), substr(visible_signature, 1, conv(hex(substr(visible_signature, 1, 1)), 16,10)), sql_text from oceanbase.DBA_OB_OUTLINES;

--disable_warnings
drop database if exists yyy_db;
--enable_warnings

connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
#drop tenant yyy_tenant_1 force;
#drop resource pool yyy_pool_1;
#drop resource unit yyy_box_1;
commit;
