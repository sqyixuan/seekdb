select mini_account_no, account_type, currency, balance, status, system_amount, system_bu_amount, gmt_create, gmt_modified, previous_balance, previous_trans_date, gmt_last_trans, category_code, biz_type, mini_freeze_amount, last_biz_date, mini_main_account_no, recon_inst, migration_status , busi_extra_sign from mini_account where (mini_account_no = ?) ;
select tx_id, status, gmt_create, system_transaction_id from ft_tranaction_info where (tx_id = ?) ;
select tx_id, account_no, type, amount from ft_system_money_manager where ((tx_id = ?) and (account_no = ?));
select 1;
select tx_id, status, gmt_create, system_transaction_id from ft_tranaction_info where (tx_id = ?);
delete from ft_system_money_manager where ((tx_id = ?) and (account_no = ?));
select mini_account_no, account_type, currency, balance, status, system_amount, system_bu_amount, gmt_create, gmt_modified, previous_balance, previous_trans_date, gmt_last_trans, category_code, biz_type, mini_freeze_amount, last_biz_date, mini_main_account_no, recon_inst, migration_status , busi_extra_sign from mini_account where (mini_account_no = ?);
select tx_id, trans_code, sub_trans_code, trans_amount, in_account, out_account, order_no, out_biz_no, in_memo, out_memo, out_date, trans_date, voucher_id, trans_dt, gmt_create, mini_freeze_type, unique_id, recon_inst, context,biz_pd_code, biz_ev_code, cnl_pd_code, cnl_ev_code, cnl_no, pd_code, ev_code from ft_trans_info where (tx_id = ?) order by gmt_create asc;
delete from ft_trans_info where (tx_id = ?);
