#owner: xiaoyi.xy
#owner group: SQL1
#description: 该case是为了验证outline的使用
#tags: outline

START TRANSACTION;
--disable_warnings
drop database if exists ol_db;
create database ol_db;
--disable_warnings

use ol_db;
##test create outline with to clause
create table t1(c1 int, c2 int, c3 int, key(c2), key(c3));
create table t2(c1 int, c2 int, c3 int, key(c2), key(c3));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

## test for string param stmt
create outline olstr on select * from t1 where c1 = 'aaa' to select /*+trace_log*/* from t1 where c1 = 'aaa';
select /*+trace_log*/* from t1 where c1 = 'aaa';
select /*+trace_log*/* from t1 where c1 = 'aaa';
select hit_count, outline_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a join oceanbase.DBA_OB_OUTLINES as b on a.outline_id = b.outline_id  where b.outline_name = "olstr";
create outline olstr_2 on select  * from t1 where c1 = '''' to select  /*+trace_log*/* from t1 where c1 = '''';
select  /*+trace_log*/* from t1 where c1 = '''';
select  /*+trace_log*/* from t1 where c1 = '''';
select hit_count, outline_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a join oceanbase.DBA_OB_OUTLINES as b on a.outline_id = b.outline_id  where b.outline_name = "olstr_2";
create outline olstr_3 on select   * from t1 where c1 = '\n' to select   /*+trace_log*/* from t1 where c1 = '\n';
select   /*+trace_log*/* from t1 where c1 = '\n';
select   /*+trace_log*/* from t1 where c1 = '\n';
select hit_count, outline_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a join oceanbase.DBA_OB_OUTLINES as b on a.outline_id = b.outline_id  where b.outline_name = "olstr_3";
create outline olstr_4 on select    * from t1 where c1 = '  ' to select    /*+trace_log*/* from t1 where c1 = '  ';
select    /*+trace_log*/* from t1 where c1 = '  ';
select    /*+trace_log*/* from t1 where c1 = '  ';
select hit_count, outline_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a join oceanbase.DBA_OB_OUTLINES as b on a.outline_id = b.outline_id  where b.outline_name = "olstr_4";

--echo ## clear test data ##
drop outline olstr;
drop outline olstr_2;
drop outline olstr_3;
drop outline olstr_4;
drop database ol_db;
commit;
