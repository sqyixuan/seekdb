#owner: xiaoyi.xy
#owner group: SQL1
#description: 该case是为了测试drop outline
#tags: outline

--disable_warnings
drop database if exists ol_db;

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

--echo ## prepare test data ##
create database ol_db;
use ol_db;
create table t1(c1 int primary key, c2 int, key(c2));
create table t2(c1 int primary key, c2 int, key(c2));
create outline olt_1 on select * from t1;
create outline olt_2 on select * from t1, t2;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--sorted_result
--disable_query_log
eval select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
--enable_query_log
disconnect obsys;
connection default;

--echo ## test simply drop ##
drop outline olt_1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
eval select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
--enable_query_log
disconnect obsys;
connection default;

--echo ## test not select database drop ##
select database();
drop outline ol_db.olt_2;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
eval select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = $default_tenant_id and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
--enable_query_log
disconnect obsys;
connection default;

--echo ## test drop error ##
--error 5265
drop outline ol_db.olt_1;
--error 5265
drop outline olt_1;

--echo ## clear test data ##
drop database ol_db;
