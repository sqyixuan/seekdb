#owner: xiaoyi.xy
#owner group: SQL1
#tags: pl, outline
##
## Test Name: outline_basic
##
## Scope: Test basic function of outline match
##
## INFO:  if you want to add case; you should read ../README.md;
#         don't use sys tenant, because when parallel run on obfarm, the hit_count can't be expected;
#         so we use new tenant, new plan cache will be  used for this case only;
##
##
## Date: 2016-6-12
##

--disable_info
--disable_metadata

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

set ob_trx_timeout=1000000000;
select effective_tenant();



--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 5
connection default;

# --echo
let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);
--disable_warnings
drop database if exists yyy_db;
--enable_warnings
create database yyy_db;
use yyy_db;
source mysql_test/test_suite/outline/t/outline_table_init.sql;
--enable_result_log

set autocommit = 0;
sleep 1;

##select
--echo
--echo **********************select  c2,c1 from t1 where c2 = 2****************
--echo ********************** Outline:create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2****************
--echo **********************select  c2,c1 from t1 where c2 = 3****************
select  c2,c1 from t1 where c2 = 2;
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
select outline_name, visible_signature, outline_target, sql_text, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name='olt_1';

select  c2,c1 from t1 where c2 = 2;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1" order by hit_count;

connection default;
select  c2,c1 from t1 where c2 = 3;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1" order by hit_count;
connection default;

--echo
--echo **********************select  c2,c1 from t1 where c2 = 2 order by 1****************
--echo ********************** Outline:create outline olt_2 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2 order by 1****************
--echo **********************select  c2,c1 from t1 where c2 = 2 order by 2****************
select  c2,c1 from t1 where c2 = 2 order by 1;
create outline olt_2 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2 order by 1;
select outline_name, visible_signature, outline_target, sql_text, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name='olt_2';

select  c2,c1 from t1 where c2 = 2 order by 1;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ? order by 1" and b.name = "olt_2" order by hit_count;

connection default;
select  c2,c1 from t1 where c2 = 2 order by 2;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ? order by 2" and b.name = "olt_2" order by hit_count;
connection default;

--echo
--echo **********************select * from (select c2,c1 from t1 where c1 >1) as tt****************
--echo ********************** Outline:create outline olt_3 on select /*+INDEX(@"SEL$2" "t1"@"SEL$2" "c3")*/* from (select c2,c1 from t1 where c1 >1) as tt****************
--echo **********************select * from (select c2,c1 from t1 where c1 >2) as tt****************
select * from (select c2,c1 from t1 where c1 >1) as tt;
create outline olt_3 on select /*+INDEX(@"SEL$2" "t1"@"SEL$2" "c3")*/* from (select c2,c1 from t1 where c1 >1) as tt;
select outline_name, visible_signature, outline_target, sql_text, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name='olt_3';

select * from (select c2,c1 from t1 where c1 >1) as tt;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select * from (select c2,c1 from t1 where c1 >?) as tt" and b.name = "olt_3" order by hit_count;

connection default;
select * from (select c2,c1 from t1 where c1 >2) as tt;
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select * from (select c2,c1 from t1 where c1 >?) as tt" and b.name = "olt_3" order by hit_count;
connection default;

--echo
--echo **********************select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >1)****************
--echo ********************** Outline:create outline olt_4 on select /*+index(t1 c3) trace_log*/ c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >1)****************
--echo **********************select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >2)****************
select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >1);
create outline olt_4 on select /*+index(t1 c3) trace_log*/ c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >1);
select outline_name, visible_signature, outline_target, sql_text, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name='olt_4';

select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >1);
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >?)" and b.name = "olt_4" order by hit_count;

connection default;
select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >2);
connection obsys;
eval select hit_count from oceanbase.__all_virtual_plan_stat as a, oceanbase.__all_virtual_outline as b where a.tenant_id = $default_tenant_id and a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c1 < any(select c1 from t1 where c1 >?)" and b.name = "olt_4" order by hit_count;
connection default;

--disable_query_log
--disable_result_log

commit;
set autocommit = 1;
--disable_warnings
drop database if exists yyy_db;
--enable_warnings
