#owner: xiaoyi.xy
#owner group: SQL1
#description: 该case是为了验证outline的限流功能
#tags: outline, optimizer

use test;

--disable_warnings
drop table if exists t1;
--error 0, 5265
drop outline o1;
--enable_warnings

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

create table t1 (c1 int, c2 varchar(1000));
select * from t1;
create outline o1 on '6F85AFBFA98A19D78AB7FD9D46ED3C0C' using hint /*+ max_concurrent(0) */;
--error 5268
select * from t1;

drop table t1;
drop outline o1;


create table t1 (c1 int primary key, c2 int, key i1(c2));
create outline o1 on 'EC102CB006383D732BC98797601D9B3B' using hint /*+ max_concurrent(5) */;

select /*+index(t1 i1) */ * from t1;

--sleep 5
let $plan_id = query_get_value("select plan_id from oceanbase.__all_virtual_plan_stat where svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and (tenant_id = $default_tenant_id or $default_tenant_id = 1) and statement = 'select /*+index(t1 i1) */ * from t1'", plan_id, 1);

--disable_query_log
eval select operator, name FROM oceanbase.__all_virtual_plan_cache_plan_explain WHERE svr_ip=HOST_IP() AND svr_port=RPC_PORT() and is_serving_tenant(svr_ip, svr_port, $default_tenant_id) and ($default_tenant_id=1 or TENANT_ID=$default_tenant_id) and plan_id = $plan_id and tenant_id = $default_tenant_id;
--enable_query_log

