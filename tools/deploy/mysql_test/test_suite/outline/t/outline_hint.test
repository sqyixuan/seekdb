#owner: xiaoyi.xy
#owner group: SQL1
#tags: pl, outline
##
## Test Name: outline_basic
##
## Scope: Test basic function of outline match
##
## INFO:  test outline use with hint;
##
## Date: 2016-8-29
##

--disable_info
--disable_metadata

--disable_query_log
--disable_result_log

set ob_trx_timeout=1000000000;
select effective_tenant();

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache;
disconnect obsys;
connection default;

set autocommit = 0;
set ob_read_consistency = 'weak';

# --echo
--disable_warnings
drop database if exists ol_hint_db;
--enable_warnings
create database ol_hint_db;
use ol_hint_db;

set @@recyclebin = off;
drop table if exists t1, t2, t3;
drop tablegroup if exists group_outline_hint;
create tablegroup group_outline_hint;
sleep 1;
create table t1 (c1 int primary key, c2 varchar(10), c3 decimal(30, 6), c4 int, key(c2), key(c3,c2)) tablegroup='group_outline_hint';
create table t2 (c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2)) tablegroup='group_outline_hint';
create table t3 (c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2)) tablegroup='group_outline_hint';

insert into t1 values (1, 'c', 6.0, 3), (2, 'b', 4.0, 2), (3, 'a', 2.0, 1);
insert into t2 values (1, 11, 6), (2, 12, 4), (3, 13, 2);
insert into t3 values (1, 31, 6), (2, 32, 4), (3, 33, 2);

start transaction;
##queries before creating outlines
 select t1.c1, t2.c2 from t1, t2;
 select * from t1, t2 where c4 > 0;
 select * from t1, t2, t1 as t3 where t2.c3 > 2;
 select * from t1, t2 where t1.c1 = t2.c1;
 select * from t1, t2, t1 as t3 where t2.c3 >= 2;
 select  * from t1 as ta, t2 as tb , t1 as tc, t2 as td where ta.c1 = tc.c1 and ta.c1 = tb.c1 and tb.c1 = td.c1;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3 where t2.c1 = t3.c1) v;
 (select  c1 from t1) union (select  c1 from t2);
 select  * from t1 where c1 in (select c1 from t3);
 select  * from t1 , (select c1 from t3 t_a) t where t.c1 = t1.c1;
 select t1.c1 from t1, t2 where t1.c1 = t2.c1 union select c1 from t2;
 select t1.c1 from t1 where t1.c1 in (select t3.c1 from t3 group by t3.c2);
 select t1.c1 from t1 where t1.c1 in (select t2.c1 from t2, (select t3.c1 from t3) t_a where t2.c2 > 1 and t2.c2 < 3 and t_a.c1 = t2.c1 group by t2.c2);
 select    * from t1 where c1 in (select * from (select max(t1.c1) from t1, t2) as tt);
 select  t1.c1 from t1, (select t2.c1 from t2, (select t5.c1 from t3 t5 group by t5.c2) t_a where t_a.c1 = t2.c1) t_a1 where t_a1.c1 = t1.c1 and t1.c1 in (select t2.c1 from t2);
 select  * from t1, t2, t1 as ha, t2 as hb where t1.c1 = t2.c1 and t1.c1 = ha.c1 and t2.c3 = hb.c3;
 select  * from t1, t2 where t1.c1 = t2.c1;
 (select  t1.c1 from t1 , (select c1 from t2) t where t.c1 = t1.c1) union select c1 from t3;
 select t1.c1 from t1 where t1.c1 in (select t2.c1 from t2, (select t3.c1 from t3) t_a where t_a.c1 = t2.c1 group by t2.c2);

##create outlines
--disable_result_log
create outline ol_1 on select/*+full(t1) use_merge(t1 t2)*/ t1.c1, t2.c2 from t1, t2;
create outline ol_2 on select/*+index(t1, c3)*/ * from t1, t2 where c4 > 0;
create outline ol_3 on select/*+leading(t2)*/ * from t1, t2, t1 as t3 where t2.c3 > 2;
create outline ol_4 on select/*+use_nl(t1)*/ * from t1, t2 where t1.c1 = t2.c1;
create outline ol_5 on select/*+ordered use_nl(t2 t3)*/ * from t1, t2, t1 as t3 where t2.c3 >= 2;
create outline ol_6 on select /*+ ordered use_merge(ta,tb,tc,td)*/ * from t1 as ta, t2 as tb , t1 as tc, t2 as td where ta.c1 = tc.c1 and ta.c1 = tb.c1 and tb.c1 = td.c1;
create outline ol_7 on select/*+leading (t1, t2, t3) use_nl(t1 t2)*/ t1.c1, v.c1 from t1, (select/*+index(t2 primary)*/ t2.c1 from t2, t3) v;
create outline ol_9 on select/*+leading (t1, t2, t3) use_nl(t1 t2)*/   t1.c1, v.c1 from t1, (select/*+read_consistency(weak)*/ t2.c1 from t2, t3) v;
create outline ol_10 on select t1.c1, v.c1 from t1, (select/*+use_nl(t2, t3)*/ t2.c1 from t2, t3 where t2.c1 = t3.c1) v;
create outline ol_11 on (select /*+read_consistency(weak)*/ c1 from t1) union (select /*+read_consistency(strong)*/ c1 from t2);
create outline ol_12 on select /*+ index(@SEL$1 t3  c3)*/ * from t1 where c1 in (select/*+qb_name(yz)*/ c1 from t3);
create outline ol_13 on select /*+ leading(@SEL$1 t_a@YZ  t1@SEL$1)*/ * from t1 , (select/*+qb_name(yz)*/ c1 from t3 t_a) t where t.c1 = t1.c1;
create outline ol_14 on select/*+leading(@SEL$1 t2 t1)*/ t1.c1 from t1, t2 where t1.c1 = t2.c1 union select/*+leading(@SEL$1 t1 t2) use_merge(@SEL1 t2@SEL$1)*/ c1 from t2;
create outline ol_15 on select/*+index(@SEL$1 t3 c3) */ t1.c1 from t1 where t1.c1 in (select t3.c1 from t3 group by t3.c2);
create outline ol_16 on select/*+index(@SEL$2 t2 c3) */ t1.c1 from t1 where t1.c1 in (select/*+index(t2 c3)*/ t2.c1 from t2, (select t3.c1 from t3) t_a where t2.c2 > 1 and t2.c2 < 3 and t_a.c1 = t2.c1 group by t2.c2);
create outline ol_17 on select   /*+ BEGIN_OUTLINE_DATA USE_NL(@"SEL$3" "t2"@"SEL$3") LEADING(@"SEL$3" "t2"@"SEL$3" "t1"@"SEL$3") END_OUTLINE_DATA */ * from t1 where c1 in (select * from (select max(t1.c1) from t1, t2) as tt);
create outline ol_18 on select /*+index(@SEL$3 t5@SEL$3 c3) index(@SEL$4 t2 c3)*/ t1.c1 from t1, (select t2.c1 from t2, (select t5.c1 from t3 t5 group by t5.c2) t_a where t_a.c1 = t2.c1) t_a1 where t_a1.c1 = t1.c1 and t1.c1 in (select t2.c1 from t2);
create outline ol_19 on select /*+ leading(t1 t2 ha hb) use_bnl(ha t1 t2 hb)*/ * from t1, t2, t1 as ha, t2 as hb where t1.c1 = t2.c1 and t1.c1 = ha.c1 and t2.c3 = hb.c3;
create outline ol_20 on select /*+ full(t1 t2) use_merge(test), use_bnl(t1)*/ * from t1, t2 where t1.c1 = t2.c1;
create outline ol_21 on (select /*+ leading(@SEL$1 t2@YZ  t1@SEL$1) */ t1.c1 from t1 , (select/*+qb_name(yz) use_merge(@SEL$1 t1@SEL$1)*/ c1 from t2) t where t.c1 = t1.c1) union select c1 from t3;
create outline ol_22 on select/*+index(@SEL$2 t2 c3) leading(@SEL$2 t3@SEL$3 t2@SEL$2)*/ t1.c1 from t1 where t1.c1 in (select t2.c1 from t2, (select t3.c1 from t3) t_a where t_a.c1 = t2.c1 group by t2.c2);
--enable_result_log
##check if outlines generated are right
sleep 10;
select outline_name, visible_signature, sql_text, outline_sql from oceanbase.DBA_OB_OUTLINES;

##queries after creating outlines
--disable_result_log
 select t1.c1, t2.c2 from t1, t2;
 select * from t1, t2 where c4 > 0;
 select * from t1, t2, t1 as t3 where t2.c3 > 2;
 select * from t1, t2 where t1.c1 = t2.c1;
 select * from t1, t2, t1 as t3 where t2.c3 >= 2;
 select  * from t1 as ta, t2 as tb , t1 as tc, t2 as td where ta.c1 = tc.c1 and ta.c1 = tb.c1 and tb.c1 = td.c1;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select  t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select   t1.c1, v.c1 from t1, (select t2.c1 from t2, t3) v;
 select t1.c1, v.c1 from t1, (select t2.c1 from t2, t3 where t2.c1 = t3.c1) v;
 (select  c1 from t1) union (select  c1 from t2);
 select  * from t1 where c1 in (select c1 from t3);
 select  * from t1 , (select c1 from t3 t_a) t where t.c1 = t1.c1;
 select t1.c1 from t1, t2 where t1.c1 = t2.c1 union select c1 from t2;
 select t1.c1 from t1 where t1.c1 in (select t3.c1 from t3 group by t3.c2);
 select t1.c1 from t1 where t1.c1 in (select t2.c1 from t2, (select t3.c1 from t3) t_a where t2.c2 > 1 and t2.c2 < 3 and t_a.c1 = t2.c1 group by t2.c2);
 select    * from t1 where c1 in (select * from (select max(t1.c1) from t1, t2) as tt);
 select  t1.c1 from t1, (select t2.c1 from t2, (select t5.c1 from t3 t5 group by t5.c2) t_a where t_a.c1 = t2.c1) t_a1 where t_a1.c1 = t1.c1 and t1.c1 in (select t2.c1 from t2);
 select  * from t1, t2, t1 as ha, t2 as hb where t1.c1 = t2.c1 and t1.c1 = ha.c1 and t2.c3 = hb.c3;
 select  * from t1, t2 where t1.c1 = t2.c1;
 (select  t1.c1 from t1 , (select c1 from t2) t where t.c1 = t1.c1) union select c1 from t3;
 select t1.c1 from t1 where t1.c1 in (select t2.c1 from t2, (select t3.c1 from t3) t_a where t_a.c1 = t2.c1 group by t2.c2);

 ##check if query use the outline
eval select a.hit_count, a.outline_id != -1, a.statement from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.DBA_OB_OUTLINES as b where a.outline_id = b.outline_id;

commit;
set autocommit = 1;
--disable_warnings
drop database if exists ol_hint_db;
--enable_warnings
