--disable_result_log
select * from  t1  where (c1,c2) in ((2,2), (2,3),(3,4)) for update wait 1;
--enable_result_log
select hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select * from  t1  where (c1,c2) in ((?,?), (?,?),(?,?)) for update wait ?" and special_params = "1";

--echo
--echo **********************select * from t1 t where t.c2 = 1 and t.c1 = 2 for update nowait****************
--echo **********************select * from t1 t where t.c2 = 3 and t.c1 = 2 for update nowait****************
create outline  ol_253 on select * from t1 t where t.c2 = 1 and t.c1 = 2 for update nowait;
sleep 1;
--disable_query_log
--disable_result_log
select * from t1 t where t.c2 = 1 and t.c1 = 2 for update nowait;
--enable_result_log
select hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select * from t1 t where t.c2 = ? and t.c1 = ? for update ?" and special_params = 'nowait';
--disable_query_log
--disable_result_log
select * from t1 t where t.c2 = 3 and t.c1 = 2 for update nowait;
--enable_result_log
select hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select * from t1 t where t.c2 = ? and t.c1 = ? for update ?" and special_params = 'nowait';

--echo
--echo **********************select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 0 for update****************
--echo **********************select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 1 for update****************
create outline  ol_254 on select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 0 for update;
sleep 1;
--disable_query_log
--disable_result_log
select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 0 for update;
--enable_result_log
select hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > ? for update";
--disable_query_log
--disable_result_log
select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > 1 for update;
--enable_result_log
select hit_count, outline_id from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select abs(c1) , sum(c2) from t1 group by abs(c2) having sum(sign(c1)) > ? for update";

connection conn_admin;
eval select /*+read_consistency(weak)*/ count(*) from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= $tenant_id and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'yyy_db';
connection conn1;

--disable_query_log
--disable_result_log

commit;
set autocommit = 1;
--disable_warnings
drop database if exists yyy_db;
--enable_warnings

# login using admin acount
connection conn_admin;
drop tenant yyy_tenant_1 force;
drop resource pool yyy_pool_1;
drop resource unit yyy_box_1;

