### 创建限流和绑定outline时，不指定参数（含有通配符?）
--error 5267
create outline otl2 on select/*+ INDEX (t1 c1_inx) no_rewrite max_concurrent(1) +*/ * from t1 where c1=?; 
--error 5267
create outline otl2 on select/*+ leading(t2 t1) no_rewrite max_concurrent(1) +*/ * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = ?;

###SQL_ID
--error 0,5265
drop outline otl2;
create outline otl2 ON "1DC27B6D9DFE0392856970651AF09AC8" USING HINT /*+ no_rewrite max_concurrent(1) */ ;

select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 1 ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 1 ORDER BY t1.t1_id;


select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 2 ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 2 ORDER BY t1.t1_id;


select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 3 ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = 3 ORDER BY t1.t1_id;


select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;


select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id in (select t1_id from t1) ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id in (select t1_id from t1) ORDER BY t1.t1_id;


select * from t1, t2 where t1.t1_id = t2.t2_id and t2.t2_id in (select t2_id from t2) ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 where t1.t1_id = t2.t2_id and t2.t2_id in (select t2_id from t2) ORDER BY t1.t1_id;


### /*+ leading */
--error 0,5265
drop outline otl;
create outline otl on select/*+ leading(t2 t1) no_rewrite max_concurrent(1) +*/ * from t1, t2;

select * from t1, t2 ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1, t2 ORDER BY t1.t1_id;


### /*+ INDEX */
drop outline otl;
create outline otl on select/*+ INDEX (t1 c1_inx) no_rewrite max_concurrent(1) +*/ * from t1 where c1 = 'a';

SELECT * FROM t1 where c1 = 'a' ORDER BY t1.t1_id;
EXPLAIN OUTLINE select * from t1 where c1 = 'a' ORDER BY t1.t1_id;


### /*+USE_MERGE */
drop outline otl;
create outline otl on select/*+ USE_MERGE(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2 where t1.t1_id = t2.t2_id;

SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;


### /*+NO_USE_MERGE */
drop outline otl;
create outline otl on select/*+ NO_USE_MERGE(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2 where t1.t1_id = t2.t2_id;

SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;


### /*+ USE_HASH(t2 t1) */
drop outline otl;
create outline otl on select/*+ USE_HASH(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4);

SELECT * FROM t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;


### /*+ NO_USE_HASH(t2 t1) */
drop outline otl;
create outline otl on select/*+ NO_USE_HASH(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;

SELECT * FROM t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 WHERE t1.t1_id = t2.t2_id AND t1.t1_id in (1,2,3,4) ORDER BY t1.t1_id;


### /*+ USE_NL(t2 t1) */
drop outline otl;
create outline otl on select/*+ USE_NL(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2 where t1.t1_id = t2.t2_id;

SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;


### /*+ NO_USE_NL(t2 t1) */
drop outline otl;
create outline otl on select/*+ NO_USE_NL(t2 t1) no_rewrite max_concurrent(1)*/ * from t1,t2;

SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1,t2 where t1.t1_id = t2.t2_id ORDER BY t1.t1_id;

### /*+ PARALLEL(tablename n) */
drop outline otl;
create outline otl on select/*+ PARALLEL(t1 5) no_rewrite max_concurrent(1)*/ t1_id from t1;

SELECT t1_id from t1 ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT t1_id from t1 ORDER BY t1.t1_id;


### /*+ NO_PARALLEL(tablename n) */
drop outline otl;
create outline otl on select/*+ NO_PARALLEL(t1 5) no_rewrite max_concurrent(1)*/ t1_id from t1;

SELECT t1_id from t1 ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT t1_id from t1 ORDER BY t1.t1_id;


### /*+ NO_REWRITE */
drop outline otl;
create outline otl on SELECT /*+ NO_REWRITE no_rewrite max_concurrent(1)*/ sum(t1.c1) AS tc1 FROM t1, t2 WHERE t1.t1_id = t2.t2_id GROUP BY t1.t1_id;

SELECT sum(t1.c1) AS tc1 FROM t1, t2 WHERE t1.t1_id = t2.t2_id GROUP BY t1.t1_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT sum(t1.c1) AS tc1 FROM t1, t2 WHERE t1.t1_id = t2.t2_id GROUP BY t1.t1_id ORDER BY t1.t1_id;


### /*+ NO_EXPAND */
drop outline otl;
create outline otl on SELECT /*+ NO_EXPAND no_rewrite max_concurrent(1)*/ * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1;

SELECT * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1 ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1 ORDER BY t1.t1_id;



### /*+ use_concat */
drop outline otl;
create outline otl on SELECT /*+ use_concat no_rewrite max_concurrent(1)*/ * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1;

SELECT * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1 ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT * FROM t1, t2 WHERE t1.t1_id = 2 or t2.t2_id = 1 ORDER BY t1.t1_id;


### /*+UNNEST */
drop outline otl;
create outline otl on SELECT AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT /*+UNNEST max_concurrent(1)*/ AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id);

SELECT AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id) ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id) ORDER BY t1.t1_id;


### /*+NO_UNNEST */
drop outline otl;
create outline otl on SELECT /*+ NO_UNNEST(@qb1) max_concurrent(1)*/ AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT /*+qb_name(qb1)*/ AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id);

SELECT AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id) ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT AVG(t1.t1_id) FROM t1 WHERE t1.t1_id >= (SELECT AVG(t2.t2_id) FROM t2 WHERE t1.t1_id = t2.t2_id) ORDER BY t1.t1_id;


CREATE TABLE employees (
    employee_id INT PRIMARY KEY,
    last_name VARCHAR(50),
    salary DECIMAL(10, 2),
    department_id INT
);
INSERT INTO employees (employee_id, last_name, salary, department_id) VALUES (1, 'Smith', 5000.00, 1);
INSERT INTO employees (employee_id, last_name, salary, department_id) VALUES (2, 'Johnson', 6000.00, 1);
INSERT INTO employees (employee_id, last_name, salary, department_id) VALUES (3, 'Williams', 7000.00, 2);
INSERT INTO employees (employee_id, last_name, salary, department_id) VALUES (4, 'Brown', 5500.00, 2);
INSERT INTO employees (employee_id, last_name, salary, department_id) VALUES (5, 'Jones', 8000.00, 3);

### /*+ MERGE(v) */
drop outline otl;
create outline otl on 
SELECT /*+ MERGE(v) max_concurrent(1)*/ e1.last_name, e1.salary, v.avg_salary FROM employees e1,
    (SELECT department_id, avg(salary) avg_salary 
        FROM employees e2 GROUP BY department_id) v 
    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;

SELECT e1.last_name, e1.salary, v.avg_salary FROM employees e1,
    (SELECT department_id, avg(salary) avg_salary 
        FROM employees e2 GROUP BY department_id) v 
    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;
EXPLAIN OUTLINE SELECT e1.last_name, e1.salary, v.avg_salary FROM employees e1,
                    (SELECT department_id, avg(salary) avg_salary 
                        FROM employees e2 GROUP BY department_id) v 
                    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;


### /*+ NO_MERGE(v) */
drop outline otl;
create outline otl on 
SELECT /*+ NO_MERGE(v) max_concurrent(1)*/ e1.last_name, e1.salary, v.avg_salary FROM employees e1,
    (SELECT department_id, avg(salary) avg_salary 
        FROM employees e2 GROUP BY department_id) v 
    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;

SELECT e1.last_name, e1.salary, v.avg_salary FROM employees e1,
    (SELECT department_id, avg(salary) avg_salary 
        FROM employees e2 GROUP BY department_id) v 
    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;
EXPLAIN OUTLINE SELECT e1.last_name, e1.salary, v.avg_salary FROM employees e1,
                    (SELECT department_id, avg(salary) avg_salary 
                        FROM employees e2 GROUP BY department_id) v 
                    WHERE e1.department_id = v.department_id AND e1.salary > v.avg_salary ORDER BY e1.last_name;


### /*+PLACE_GROUP_BY */
drop outline otl;
create outline otl on SELECT /*+PLACE_GROUP_BY max_concurrent(1)*/SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id;

SELECT /*+PLACE_GROUP_BY max_concurrent(1)*/SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT /*+PLACE_GROUP_BY max_concurrent(1)*/SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id ORDER BY t1.t1_id;


### /*+NO_PLACE_GROUP_BY */
drop outline otl;
create outline otl on SELECT /*+NO_PLACE_GROUP_BY max_concurrent(1)*/SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id;

SELECT SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id ORDER BY t1.t1_id;
EXPLAIN OUTLINE SELECT SUM(t1.c2),SUM(t2.c3) FROM t1, t2 WHERE t1.t1_id = t2.t2_id AND t1.c2 > 10 AND t2.c3 > 1 GROUP BY t1.t1_id ORDER BY t1.t1_id;


### /*+NO_PRED_DEDUCE(@qb1) */
drop outline otl;
create outline otl on SELECT /*+NO_PRED_DEDUCE(@qb1) max_concurrent(1)*/ * FROM (SELECT /*+no_merge qb_name(qb1)*/ t1.t1_id, t2.c2 FROM t1, t2 WHERE t1.t1_id = t2.t2_id) v, t3 WHERE t3.t3_id = 1 AND t3.t3_id = v.t1_id;

SELECT * FROM (SELECT t1.t1_id, t2.c2 FROM t1, t2 WHERE t1.t1_id = t2.t2_id) v, t3 WHERE t3.t3_id = 1 AND t3.t3_id = v.t1_id ORDER BY v.t1_id;
EXPLAIN OUTLINE SELECT * FROM (SELECT t1.t1_id, t2.c2 FROM t1, t2 WHERE t1.t1_id = t2.t2_id) v, t3 WHERE t3.t3_id = 1 AND t3.t3_id = v.t1_id ORDER BY v.t1_id;
