# owner: luofan.zp
# owner group: sql2
# tags: outline
--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connect (syscon_non, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, , $OBMYSQL_PORT);
connection syscon;
alter system flush plan cache global;

--sleep 1
connection default;
set ob_enable_plan_cache = on;
--disable_warnings
drop table if exists t_sql_text, t_sql_id;
--enable_warnings


######################################## SQL_TEXT #################################################

CREATE TABLE t_sql_text (c1 int primary key, c2 int, c3 int, index idx_c2(c2));
INSERT INTO t_sql_text values(1, 1, 1), (2, 2, 2), (3, 3, 3);
SELECT * FROM t_sql_text WHERE c2 = 1;

CREATE OUTLINE otl_text_idx_c2 ON SELECT/*+ index(t_sql_text idx_c2)*/ * FROM t_sql_text WHERE c2 = 1;

SELECT * FROM t_sql_text WHERE c2 = 1;

select outline_name, outline_sql, sql_id, outline_content from oceanbase.DBA_OB_OUTLINES where outline_name = 'otl_text_idx_c2';

select sql_id, statement, outline_data
from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT
where statement like '%SELECT * FROM t_sql_text WHERE c2 =%';

select ta.outline_name, tb.sql_id
from oceanbase.DBA_OB_OUTLINES as ta, oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT as tb
where ta.outline_id = tb.outline_id;

DROP OUTLINE otl_text_idx_c2;
drop table t_sql_text;



######################################### SQL_ID ##################################################

CREATE TABLE t_sql_id (c1 int primary key, c2 int, c3 int, index idx_c2(c2));
INSERT INTO t_sql_id values(1, 1, 1), (2, 2, 2), (3, 3, 3);
SELECT * FROM t_sql_id WHERE c2 = 1;

select sql_id, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'SELECT * FROM t_sql_id WHERE c2 = ?';

CREATE OUTLINE otl_id_idx_c2 ON '4E3361ADC9C39190A288E0993340A653' USING HINT /*+ index(t_sql_id idx_c2)*/ ;

SELECT * FROM t_sql_id WHERE c2 = 1;

select outline_name, outline_sql, sql_id, outline_content from oceanbase.DBA_OB_OUTLINES where outline_name = 'otl_id_idx_c2';

select sql_id, statement, outline_data
from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT
where statement like '%SELECT * FROM t_sql_id WHERE c2 = %';

select ta.outline_name, tb.sql_id
from oceanbase.DBA_OB_OUTLINES as ta, oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT as tb
where ta.outline_id = tb.outline_id;

DROP OUTLINE otl_id_idx_c2;
drop table t_sql_id;

connection syscon_non;
CREATE OR REPLACE OUTLINE cure_hit_trafficlimit1 ON 'B2FD215564A613E27B321C64B690F933' USING HINT  /*+max_concurrent(1)*/;
select OUTLINE_NAME, OUTLINE_CONTENT from oceanbase.DBA_OB_CONCURRENT_LIMIT_SQL;

connection syscon;
alter system flush plan cache global;
