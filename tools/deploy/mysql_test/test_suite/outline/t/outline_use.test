--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group: SQL1
#description: 该case是为了验证outline的使用
#tags: outline, optimizer

--source mysql_test/include/index_quick_major.inc

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

connection default;
START TRANSACTION;
--disable_warnings
drop database if exists ol_db;
create database ol_db;

use ol_db;
connection conn_admin;
alter system flush plan cache global;

connection default;
##scene 1:basic test: check if outline is used
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
insert into t1 value(11, 3, 4), (12,3,3), (13,3,2), (14,3,1);
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 3;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ?";
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";

--echo ## simply test ##
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
sleep 2;
select a.tenant_id as tenant_id, a.name as name, hex(substr(a.signature, 1, 1)) as signatrue_len, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = effective_tenant_id() and b.database_name='ol_db';
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 3;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";

##scene 2:test correction when schema version changes
alter table t1 add column c4 int;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 3;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a where a.statement = "select  c2,c1 from t1 where c2 = ?";
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";

drop outline olt_1;
sleep 2;
select count(*) from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= effective_tenant_id() and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db';

select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 2;
select  c2,c1 from t1 where c2 = 3;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ?";
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ?" and b.name = "olt_1";

##scene 4: test correction when params changes
create outline olt_2 on select /*+index(t1 c3) */ c2,c1 from t1 where c2 = 2 order by 1;
sleep 2;
select a.tenant_id as tenant_id, a.name as name, hex(substr(a.signature, 1, 1)) as signatrue_len, substr(a.signature, 2, conv(hex(substr(a.signature, 1, 1)), 16,10)) as signature, a.outline_content as outline_content, a.outline_target as outline_target, a.sql_text as sql_text, a.owner as owner, hex(a.outline_params) as outline_params from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = effective_tenant_id() and b.database_name='ol_db';
select  c2,c1 from t1 where c2 = 2 order by 1;
select  c2,c1 from t1 where c2 = 2 order by 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ? order by 1" and special_params = '1';
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ? order by 1" and a.special_params = '1' and b.name = "olt_2";

select  c2,c1 from t1 where c2 = 2 order by 2;
select  c2,c1 from t1 where c2 = 2 order by 2;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ? order by 1" and special_params = '1';
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from t1 where c2 = ? order by 2" and special_params = '2';
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ? order by 1" and a.special_params = '1' and b.name = "olt_2";
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from t1 where c2 = ? order by 1" and a.special_params = '1' and b.name = "olt_2";
drop outline olt_2;
select count(*) from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= effective_tenant_id() and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db';

##scene 5:check create outline on view
create view v1 as select c1,c2, c3 from t1;
create outline olt_3 on select /*+index(t1 c3) yyyy*/ c2,c1 from v1 where c2 = 2 order by 1;
sleep 2;
select  c2,c1 from v1 where c2 = 2 order by 1;
select  c2,c1 from v1 where c2 = 2 order by 1;
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement = "select  c2,c1 from v1 where c2 = ? order by 1" and special_params = '1';
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a, oceanbase.__all_virtual_outline as b where a.outline_id = b.outline_id and  a.statement = "select  c2,c1 from v1 where c2 = ? order by 1" and a.special_params = '1' and b.name = "olt_3";
drop outline olt_3;
select count(*) from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id= effective_tenant_id() and a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db';

##bug:
drop table t1;
create table t1(c1 int key);
create outline o1 on select min(t2 . c1 ) from t1 t2 where t2.c1 in (select c1 from t1);


##scene 6:test outline with drop table and then create table with same name
create table t_6(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
insert into t_6 values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
select c1, c2 from t_6;
create outline olt_4 on select/*+index(t_6 c3)*/ c1, c2 from t_6;
sleep 2;
select c1, c2 from t_6;
drop table t_6;
create table t_6(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
sleep 2;
insert into t_6 values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
select c1, c2 from t_6;
drop outline olt_4;

##scene 7:test outline with recycled table
create table t_recycle(c1 int, c2 varchar(16), c3 decimal, key(c2), key(c3,c2));
insert into t_recycle values (1, '2', 9.0), (2, '4', 8.0), (3, '6', 7.0);
select c1, c2 from t_recycle;
create outline olt_5 on select/*+index(t_recycle c3)*/ c1, c2 from t_recycle;
sleep 2;
select c1, c2 from t_recycle;
drop table t_recycle;
sleep 2;
--error 1146
select c1, c2 from t_recycle;
select database_name, outline_name, visible_signature, sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'olt_5';
connection conn_admin;
let $recycle_tname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = 1 and original_name = 't_recycle' order by gmt_create desc, object_name, 1);
connection default;
--disable_query_log
eval FLASHBACK TABLE $recycle_tname TO BEFORE DROP;
--enable_query_log
sleep 2;
select c1, c2 from t_recycle;
select database_name, outline_name, visible_signature, sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'olt_5';


##scene 8:test outline with recycled database
drop database ol_db;
sleep 2;
select database_name, outline_name, visible_signature, sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'olt_5';
--error 1046
select c1, c2 from t_recycle;
connection conn_admin;
let $recycle_dbname = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = 1 and original_name = 'ol_db' order by gmt_create desc, object_name, 1);
connection default;
--disable_query_log
eval FLASHBACK DATABASE $recycle_dbname TO BEFORE DROP;
--enable_query_log
sleep 2;
use ol_db;
select database_name, outline_name, visible_signature, sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'olt_5';
select c1, c2 from t_recycle;

##scene 9:test outline with truncate table
create table t_truncate(c1 int, c2 varchar(10), c3 int, key(c2), key(c3,c2));
insert into t_truncate value(1, 'c', 3), (2, 'b', 2), (3, 'a', 1);
select c1 ,c2 from t_truncate;
create outline ol_truncate on select/*+index(t_truncate c3)*/ c1 ,c2 from t_truncate;
sleep 2;
select c1 ,c2 from t_truncate;
truncate table t_truncate;
sleep 2;
select c1 ,c2 from t_truncate;
insert into t_truncate value(1, 'c', 3), (2, 'b', 2), (3, 'a', 1);
select c1 ,c2 from t_truncate;


##just for  coverity  accept 函数
--disable_result_log
select operator, name from oceanbase.V$OB_PLAN_CACHE_PLAN_EXPLAIN where tenant_id = 1 and plan_id = 1;
--enable_result_log

## test for bug : project/81079/issue/11664228##
CREATE TABLE `CC` (
  `pk` int(11) NOT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384,
  KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384,
  KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384,
  KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384,
  KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 ;

CREATE TABLE `B` (
  `col_date` date DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384,
  KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384,
  KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384,
  KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384,
  KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

SELECT  COUNT(DISTINCT OUTR . `col_datetime` ) AS X FROM B AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_int_key` < OUTR . `col_int_key` ) WHERE OUTR . `col_int_key` IN ( SELECT  INNR . `col_int` AS Y FROM CC AS INNR2 LEFT JOIN CC AS INNR ON ( INNR2 . `col_varchar_10` <> INNR . `col_varchar_20_key` ) WHERE INNR . `col_datetime` < '2003-11-09' AND NOT INNR . `col_datetime_key` > INNR . `col_date_key`  ) AND ( OUTR . `col_int_key` = 8 AND OUTR . `col_int` >= 3 )  ORDER BY OUTR . `col_varchar_10_key` , OUTR . `pk`;
alter system flush plan cache;
drop database ol_db;
COMMIT;
