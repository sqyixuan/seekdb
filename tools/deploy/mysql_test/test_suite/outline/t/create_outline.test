#owner: xiaoyi.xy
#owner group: SQL4
#description: 该case是为了测试create outline
#tags: outline
--disable_warnings
drop database if exists ol_db;
create database ol_db;

let $default_tenant_id = query_get_value(select effective_tenant_id(), effective_tenant_id(), 1);

use ol_db;
create table t1(c1 int primary key, c2 int, key(c2));
create table t2(c1 int primary key, c2 int, key(c2));
create table t3(c1 int primary key, c2 int, key(c2));
create table t4(c1 int primary key, c2 int, key(c2));
create table t5(c1 int primary key, c2 int);

--echo ## simply test ##
create outline olt_1 on select * from t1;
create outline olt_2 on select * from t1,t2;
create outline olt_3 on select * from (select max(c1) from t1) as tt;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection obsys;
--sorted_result
eval select a.name as name from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name like '%olt%';
connection default;

--echo ## test different hint ##
create outline olt_4 on select /*+no_rewrite trace_log*/* from (select max(c1) from t2) as tt;
create outline olt_5 on select /*+no_rewrite trace_log*/* from t1 where c1 > any(select c1 from t2);
create outline olt_6 on select /*+index(t1 c2)*/* from t1 where c1=1;

connection obsys;
--sorted_result
eval select a.name as name from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name like '%olt%';
connection default;
--echo ## test diffrent dml ##
create outline olt_t7 on insert into t1 values(1,1);
create outline olt_t8 on delete from t1 where c1 = 1;
create outline olt_t9 on update t1 set c1 = 100 where c1 = 1;
connection obsys;
--sorted_result
eval select a.name as name from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name like '%olt%';
connection default;

--echo ## test diferent ? ##
create outline olt_0 on select c1 from t1 order by 1;

--echo ## test error (parser/resolver stage) ##
--error 1064
create outline ol_3 on select * frm t1;
--error 1064
create outlne ol_3 on select * from t1;
--error 1146
create outline ol_3 on select * from not_exist_table;
--error 1064
create outline not_exist_db.ol_3 on select * from t1;

--echo ## test no database selected ##
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,*NO-ONE*,$OBMYSQL_PORT);
connection conn1;
select database();
--error 1046
create outline ol_1 on select * from t1;
--error 1064
create outline ol_db.ol_3 on select * from ol_db.t2, ol_db.t1;
connection default;

--echo ## test for already exists ##
#test same outline_name
--error 5264
create outline olt_1 on select * from t2;
#test same signature
--error 5264
create outline ol_11 on select * from t1;
--error 5264
create outline ol_12 on select /*+no_rewrite*/* from t1;
create outline ol_13 on select /*+no_rewrite*/* from t1 where c1 = 2 and c2 = 3;
--error 5264
create outline ol_14 on select /*+no_rewrite*/* from t1 where c1 = 4 and c2 = 6;
create outline ol_15 on select /*+no_rewrite*/* from t1 where c1 = 4 and c2 = 6 order by 1;
create outline ol_16 on select /*+no_rewrite*/* from t1 where c1 = 4 and c2 = 6 order by 2;

--echo ## test for create or replace outline ##
## replace outline name only
--error 5264
create or replace outline cr_1 on select * from t1;
## replace sql only
--error 5264
create or replace outline olt_1 on select * from t1,t2,t3;
## repalce outline content
connection obsys;
eval select a.name as name, a.outline_content as outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name = 'olt_1';
connection default;
create or replace outline olt_1 on select * from t1;
connection obsys;
eval select a.name as name, a.sql_text as sql_text, a.outline_content as outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name = 'olt_1';
connection default;
create or replace outline olt_1 on select /*+sssssss*/* from t1;
connection obsys;
eval select a.name as name, a.sql_text as sql_text, a.outline_content as outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name = 'olt_1';
connection default;
create or replace outline olt_1 on select /*+ BEGIN_OUTLINE_DATA FULL(@"SEL$1" "t1"@"SEL$1") READ_CONSISTENCY("WEAK") HOTSPOT TOPK(1 100) QUERY_TIMEOUT(100) FROZEN_VERSION(1) USE_PLAN_CACHE("DEFAULT") ACTIVATE_BURIED_POINT(1, FIX_MODE, 1, 1) NO_REWRITE TRACE_LOG LOG_LEVEL('info') END_OUTLINE_DATA */* from t1;
connection obsys;
eval select a.name as name, a.sql_text as sql_text, a.outline_content as outline_content from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name = 'olt_1';
connection default;

--error 5267
create or replace outline olt_1 on select /*+trace_log*/* from t1 where c1 = 4 and c2 = 6;

## test for bug
create outline olt_20 on select * from t1 where c1 = 1+ 1;
create outline olt_21 on delete from t1 where c1 in (select c1 from t1);
create outline olt_22 on select * from t5 group by c2 order by c2 limit 1, 2;
sleep 2;
select visible_signature, database_name, outline_name, sql_text, outline_target, outline_sql from oceanbase.__tenant_virtual_outline where outline_name = 'olt_22';

##test create or replace a outline with sql concurrent
create or replace outline olt_22 on select/*+max_concurrent(0)*/ * from t5 group by c2 order by c2 limit 1, 2;
select outline_name, visible_signature, outline_content, concurrent_num, limit_target, sql_text from oceanbase.__tenant_virtual_concurrent_limit_sql where outline_name = "olt_22";
sleep 2;
--error 5268
select * from t5 group by c2 order by c2 limit 1, 2;
##outline and max concurrent should not appear at the sam time
#
create outline olt_23 on select/*+no_rewrite max_concurrent(1)*/ * from t1 where c1  = 1+ 1;
create or replace outline olt_23 on select/*+no_rewrite max_concurrent(1)*/ * from t1 where c1  = 1+ 1;
create outline olt_25 on select 1 from t1 inner join t1 t2 using(c1) where t1.c1 < (select 1);

--error 1064
create outline on create table tt (c1 int);

##test replay_log_reversely when major freeze with outline-related ddl
create table t_replay_log(c1 int, c2 varchar(10), c3 int);
insert into t_replay_log value(1, 'c', 3), (2, 'b', 2), (3, 'a', 1);
create outline ol_replay_log on select/*+index(t_replay_log c3)*/ c1 ,c2 from t_replay_log where c1 =1;
sleep 2;
connection obsys;
alter system suspend merge;
connection default;
sleep 2;
alter outline ol_replay_log add select/*+max_concurrent(1)*/ c1 ,c2 from t_replay_log where c1 =1;
alter outline ol_replay_log add select/*+max_concurrent(0)*/ c1 ,c2 from t_replay_log where c1 =2;
sleep 2;
connection obsys;
alter system resume merge;
connection default;
sleep 2;
select c1 ,c2 from t_replay_log where c1 =1;
--error 5268
select c1 ,c2 from t_replay_log where c1 =2;

