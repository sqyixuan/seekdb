# bug: 
create table t_tab(c1 int, c2 int, c3 int, primary key(c1), index idx1(c2), index idx2(c3));
--result_format 4
## test SQL with tab
select		* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'CBD544A9650010BE863FBCD7082E050A' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');
create outline olt_tab on 'CBD544A9650010BE863FBCD7082E050A' using hint	/*+index(t_tab idx1)*/;
select		* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'CBD544A9650010BE863FBCD7082E050A' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');

drop outline olt_tab;
create outline olt_tab_text on select	/*+index(t_tab idx2)*/	* from t_tab;
select		* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'CBD544A9650010BE863FBCD7082E050A' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');

## test SQL with enter
select
* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = '2537D67B3F4AC0A088280ED2CC73539F' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');
create outline olt_enter on '2537D67B3F4AC0A088280ED2CC73539F' using hint	/*+index(t_tab idx1)*/;
select
* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = '2537D67B3F4AC0A088280ED2CC73539F' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');

drop outline olt_enter;
create outline olt_enter_text on select
/*+index(t_tab idx2)*/* from t_tab;
select
* from t_tab;
eval select outline_id != -1, outline_data from oceanbase.V\$OB_PLAN_CACHE_PLAN_STAT where sql_id = '2537D67B3F4AC0A088280ED2CC73539F' and db_id in (select database_id from oceanbase.__all_database where database_name = 'ol_db');

