drop database if exists ol_db;
## prepare test data ##
create database ol_db;
use ol_db;
create table t1(c1 int primary key, c2 int, key(c2));
create table t2(c1 int primary key, c2 int, key(c2));
create outline olt_1 on select * from t1;
create outline olt_2 on select * from t1, t2;
select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = 1001 and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
name	sql_text
olt_1	select * from t1
olt_2	select * from t1, t2
## test simply drop ##
drop outline olt_1;
select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = 1001 and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
name	sql_text
olt_2	select * from t1, t2
## test not select database drop ##
select database();
database()
ol_db
drop outline ol_db.olt_2;
select a.name as name, a.sql_text as sql_text from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.tenant_id = b.tenant_id and a.database_id = b.database_id and b.in_recyclebin = false and a.tenant_id = 1001 and b.database_name='ol_db' and (a.name like "olt_1" or a.name like "olt_2");
name	sql_text
## test drop error ##
drop outline ol_db.olt_1;
ERROR HY000: Outline 'ol_db.olt_1' doesn't exist
drop outline olt_1;
ERROR HY000: Outline 'ol_db.olt_1' doesn't exist
## clear test data ##
drop database ol_db;
