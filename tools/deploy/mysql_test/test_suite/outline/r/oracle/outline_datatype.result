create outline ol_int on select /*+max_concurrent(0)*/ id from t where col_int > 0 and col_type = ?;
create outline ol_uint on select /*+max_concurrent(0)*/ id from t where col_uint > 1 and col_type = ?;
create outline ol_flt on select /*+max_concurrent(0)*/ id from t where col_flt > 2.0 and col_type = ?;
create outline ol_dbl on select /*+max_concurrent(0)*/ id from t where col_dbl = 2.0 and col_type = ?;
create outline ol_nmb on select /*+max_concurrent(0)*/ id from t where col_nmb = 9223372036854775807.4 and col_type = ?;
create outline ol_dttm on select /*+max_concurrent(0)*/ id from t where col_dttm > TIMESTAMP'1970-01-01 00:00:00' and col_type = ?;
create outline ol_dt on select /*+max_concurrent(0)*/ id from t where col_dt > DATE'1970-01-01' and col_type = ?;
create outline ol_tm on select /*+max_concurrent(0)*/ id from t where col_tm > TIME'00:00:00' and col_type = ?;
create outline ol_yr on select /*+max_concurrent(0)*/ id from t where col_yr = 0 and col_type = ?;
create outline ol_str on select /*+max_concurrent(0)*/ id from t where col_str = '2' and col_type = ?;
create outline ol_bool on select /*+max_concurrent(0)*/ id from t where col_bool = false and col_type = ?;
create outline ol_null on select /*+max_concurrent(0)*/ id from t where col_null = NULL and col_type = ?;
