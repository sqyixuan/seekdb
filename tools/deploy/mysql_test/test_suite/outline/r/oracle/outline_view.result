START TRANSACTION;
desc oceanbase.DBA_OB_OUTLINES;
Field	Type	Null	Key	Default	Extra
NAME	varchar(128)	NO			
OWNER	varchar(32)	NO			
DB_NAME	varchar(128)	NO			
CATEGORY	null	NO			
USED	bigint(20)	NO			
TIMESTAMP	timestamp(6)	YES			
VERSION	varchar(256)	NO			
SQL_TEXT	varchar(65536)	NO			
SIGNATURE	varbinary(65536)	NO			
COMPATIBLE	bigint(20)	NO			
ENABLED	bigint(20)	NO			
FORMAT	bigint(20)	NO			
OUTLINE_CONTENT	varchar(65536)	NO			
OUTLINE_TARGET	varchar(65536)	NO			
OWNER_ID	bigint(20)	YES		NULL	
drop table if exists t1;
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
select name, hex(signature), substr(signature, 2, conv(hex(substr(signature, 1, 1)), 16,10)), sql_text from oceanbase.DBA_OB_OUTLINES;
name	hex(signature)	substr(signature, 2, conv(hex(substr(signature, 1, 1)), 16,10))	sql_text
olt_1	2273656C656374202063322C63312066726F6D207431207768657265206332203D203F00	select  c2,c1 from t1 where c2 = ?	select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2
drop outline olt_1;
drop table t1;
create resource unit if not exists yyy_box_1 max_cpu 3, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU= 2, MIN_MEMORY=1073741824, MIN_IOPS=128;
create tenant if not exists yyy_tenant_1 primary_zone='zone1', resource_pool_list('yyy_pool_1') set ob_tcp_invited_nodes='%';
drop database if exists yyy_db;
create database yyy_db;
use yyy_db;
