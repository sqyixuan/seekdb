drop database if exists pttrans00;
create database pttrans00;
use pttrans00;
CREATE TABLE FT_ROLLBACK_INFO
(  SYS_TRANS_ID VARCHAR(128) NOT NULL ,
GMT_CREATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL ,
GMT_MODIFIED TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL ,
TX_ID VARCHAR(128) NOT NULL ,
PRIMARY KEY (SYS_TRANS_ID)
) ;
CREATE INDEX FT_ROLLBACK_INFO_INDEX ON FT_ROLLBACK_INFO (SYS_TRANS_ID, TX_ID) ;
