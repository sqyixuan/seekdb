result_format: 4
drop table t1;
alter system flush plan cache global;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;


//**** test create outline on sql which start with comment ***
create table t1 (c1 int primary key, c2 int, c3 int);
create index i1 on t1(c2);
insert into t1 values(1,5,0);

//**** case 1: test select
drop outline o1;
create outline o1 on '3358337D43B55D768BDA75B076F3EF47' using hint /*+ index(t1 i1) */;
/*abcd ef*/ select * from t1;
+----+------+------+
| C1 | C2   | C3   |
+----+------+------+
|  1 |    5 |    0 |
+----+------+------+
// expected 1,  use index i1
select to_char(query_sql), case when outline_id != -1 then 1 else 0 end, outline_data from sys.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '3358337D43B55D768BDA75B076F3EF47' order by 1;
+------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
| TO_CHAR(QUERY_SQL)           | CASEWHENOUTLINE_ID!=-1THEN1ELSE0END | OUTLINE_DATA                                                                                                    |
+------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
|  select * from t1            |                                   1 | /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "TEST"."T1"@"SEL$1" "I1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
| /*abcd ef*/ select * from t1 |                                   1 | /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "TEST"."T1"@"SEL$1" "I1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
drop outline o1;


//**** case 2: test space is \r\n
drop outline o2;
create outline o2 on 'B0296E1AA1CFDBDA04331B202985A7CF' using hint /*+ index(t1 i1) */;
/*abcd ef*/

select
 * from t1;
+----+------+------+
| C1 | C2   | C3   |
+----+------+------+
|  1 |    5 |    0 |
+----+------+------+
// expected 1,  use index i1
select to_char(query_sql), case when outline_id != -1 then 1 else 0 end, outline_data from sys.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = 'B0296E1AA1CFDBDA04331B202985A7CF' order by 1;
+--------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
| TO_CHAR(QUERY_SQL)             | CASEWHENOUTLINE_ID!=-1THEN1ELSE0END | OUTLINE_DATA                                                                                                    |
+--------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
| 

select
 * from t1            |                                   1 | /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "TEST"."T1"@"SEL$1" "I1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
| /*abcd ef*/

select
 * from t1 |                                   1 | /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "TEST"."T1"@"SEL$1" "I1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |
+--------------------------------+-------------------------------------+-----------------------------------------------------------------------------------------------------------------+
drop outline o2;


drop table t1;
