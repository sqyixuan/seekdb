drop database if exists ol_db;
create database ol_db;
use ol_db;
create table t1(c1 int primary key, c2 int, key(c2));
create table t2(c1 int primary key, c2 int, key(c2));
create table t3(c1 int primary key, c2 int, key(c2));
create table t4(c1 int primary key, c2 int, key(c2));
create table t5(c1 int primary key, c2 int);
## simply test ##
create outline olt_1 on select * from t1;
create outline olt_2 on select * from t1,t2;
create outline olt_3 on select * from (select max(c1) from t1) as tt;
select a.name as name from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name like '%olt%';
name
olt_1
olt_2
olt_3
## test different hint ##
create outline olt_4 on select /*+no_rewrite trace_log*/* from (select max(c1) from t2) as tt;
create outline olt_5 on select /*+no_rewrite trace_log*/* from t1 where c1 > any(select c1 from t2);
create outline olt_6 on select /*+index(t1 c2)*/* from t1 where c1=1;
select a.name as name from oceanbase.__all_virtual_outline a, oceanbase.__all_virtual_database b where a.database_id = b.database_id and b.in_recyclebin = false and b.database_name = 'ol_db' and a.name like '%olt%';
