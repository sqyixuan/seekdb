drop database ykk;
create database ykk;
use ykk;
SET global ob_sql_audit_percentage = 80;
DROP TABLE t1;
CREATE TABLE t1(
c1 INT primary key,
c2 INT,
c3 INT,
c4 INT,
c5 INT,
c6 VARCHAR(20),
c7 VARCHAR(20)
);
CREATE INDEX c1_asc on t1(c1 asc);
CREATE INDEX c2_asc on t1(c2 asc);
