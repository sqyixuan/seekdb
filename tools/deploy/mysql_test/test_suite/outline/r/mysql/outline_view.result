START TRANSACTION;
desc oceanbase.DBA_OB_OUTLINES;
Field	Type	Null	Key	Default	Extra
CREATE_TIME	timestamp(6)	YES			
MODIFY_TIME	timestamp(6)	YES			
DATABASE_ID	bigint(20)	NO		NULL	
OUTLINE_ID	bigint(20)	NO		NULL	
DATABASE_NAME	varchar(128)	NO			
OUTLINE_NAME	varchar(128)	NO			
VISIBLE_SIGNATURE	longtext	NO		NULL	
SQL_TEXT	longtext	NO		NULL	
OUTLINE_TARGET	longtext	NO		NULL	
OUTLINE_SQL	longtext	NO		NULL	
SQL_ID	varchar(32)	NO			
OUTLINE_CONTENT	longtext	NO		NULL	
drop table if exists t1;
create table t1(c1 int primary key, c2 int, c3 int, key(c2), key(c3,c2));
insert into t1 value(1, 2, 4), (2,2,3), (3,2,2), (4,2,1);
create outline olt_1 on select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2;
select outline_name, hex(visible_signature), substr(visible_signature, 1, conv(hex(substr(visible_signature, 1, 1)), 16,10)), sql_text from oceanbase.DBA_OB_OUTLINES where outline_name like '%olt_1%';
outline_name	hex(visible_signature)	substr(visible_signature, 1, conv(hex(substr(visible_signature, 1, 1)), 16,10))	sql_text
olt_1	73656C656374202063322C63312066726F6D207431207768657265206332203D203F	select  c2,c1 from t1 where c2 = ?	select /*+index(t1 c3) lalalala*/ c2,c1 from t1 where c2 = 2
drop outline olt_1;
drop table t1;
drop database if exists yyy_db;
create database yyy_db;
use yyy_db;
