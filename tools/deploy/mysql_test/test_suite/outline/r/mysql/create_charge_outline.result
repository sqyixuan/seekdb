drop database if exists CHARGE00;
create database CHARGE00;
USE CHARGE00;
CREATE TABLE `GP_FUND_DETAIL_BUFF_00` (
`FUND_NO` VARCHAR(64) NOT NULL,
`EVENT_NO` VARCHAR(64) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`PAY_AMOUNT` DECIMAL(20,4) NOT NULL,
`REFUND_AMOUNT` DECIMAL(20,4) NOT NULL,
`OTHER_SUB_AMOUNT` DECIMAL(20,4) NOT NULL,
`FUND_CHANNEL_TYPE` VARCHAR(32),
`CHARGE_CHANNEL_TYPE` VARCHAR(32),
`INST_ID` VARCHAR(32),
`PAY_CHANNEL_API` VARCHAR(32),
`PAYMENT_ID` VARCHAR(64),
`PROPERTIES` VARCHAR(1024),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
KEY IDX_EVENT_NO (EVENT_NO),
PRIMARY KEY (`FUND_NO`)
);
CREATE TABLE `GP_MAIN_TRANSACTION_00` (
`TX_ID` VARCHAR(256) NOT NULL,
`STATUS` VARCHAR(1) NOT NULL,
`SERVICE_TARGET` VARCHAR(64),
`MAPPING_NO` VARCHAR(64),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
KEY IDX_SERVICE_TARGET(SERVICE_TARGET),
PRIMARY KEY (`TX_ID`)
);
CREATE TABLE `GP_SERVICE_EVENT_BUFF_00` (
`EVENT_NO` VARCHAR(64) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`SERVICE_TARGET` VARCHAR(64) NOT NULL,
`STATUS` VARCHAR(1) NOT NULL,
`CREATOR` VARCHAR(64),
`LAST_MODIFIER` VARCHAR(64),
`GMT_SERVICE` TIMESTAMP (6),
`GMT_CHARGE` TIMESTAMP (6),
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4),
`PRODUCT` VARCHAR(64),
`MARKET` VARCHAR(40),
`CHANNEL` VARCHAR(64),
`CUSTOMER` VARCHAR(32),
`PROFESSION` VARCHAR(32),
`SECOND_CUSTOMER` VARCHAR(32),
`RELATIVE_NO` VARCHAR(64),
`FUNDS` VARCHAR(200),
`LOGIN` VARCHAR(32),
`PRIORITY` DECIMAL(1,0),
`FAIL_NUM` DECIMAL(2,0),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_RECOVER` TIMESTAMP (6),
`CHARGE_TYPE` VARCHAR(1),
`CONSULT_NO` VARCHAR(64),
`APP_ID` VARCHAR(32),
`CHARGE_RESULT` VARCHAR(1),
KEY IDX_GMTRECOVER_STATUS_PRIORITY (GMT_RECOVER, STATUS, PRIORITY),
KEY IDX_SERVICE_TARGET_TYPE (SERVICE_TARGET, SERVICE_TYPE),
PRIMARY KEY (`EVENT_NO`)
);
CREATE TABLE `GP_SERVICE_EVT_EXT_BUFF_00` (
`EVENT_NO` VARCHAR(64) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`PROPERTIES` VARCHAR(1000),
PRIMARY KEY (`EVENT_NO`)
);
CREATE TABLE `GP_CHARGE_DIFF_00` (
`DIFF_NO` VARCHAR(64) NOT NULL,
`EVENT_NO` VARCHAR(64) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`SERVICE_TARGET` VARCHAR(64) NOT NULL,
`TYPE` DECIMAL(1,0) NOT NULL,
`CONSULT_AMOUNT` DECIMAL(15,4),
`CALC_AMOUNT` DECIMAL(15,4) NOT NULL,
`CHARGE_AMOUNT` DECIMAL(15,4) NOT NULL,
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
PRIMARY KEY (`DIFF_NO`)
);
CREATE TABLE `GP_REFUND_USE_AMOUNT_00` (
`USE_AMOUNT_NO` VARCHAR(64) NOT NULL,
`REFUND_AMOUNT` DECIMAL(15,4),
`REFUND_SERVICE_AMOUNT` DECIMAL(20,4),
`BILL_NO` VARCHAR(64) NOT NULL,
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SECOND_CURRENCY` VARCHAR(3),
`SECOND_REFUND_AMOUNT` DECIMAL(15,4),
UNIQUE KEY UK_BILL_NO (BILL_NO),
PRIMARY KEY (`USE_AMOUNT_NO`)
);
CREATE TABLE `GP_REFUND_INFO_00` (
`REFUND_INFO_NO` VARCHAR(64) NOT NULL,
`TX_ID` VARCHAR(128) NOT NULL,
`SERVICE_TARGET` VARCHAR(64) NOT NULL,
`REFUND_ID` VARCHAR(128) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`REFUND_SERVICE_AMOUNT` DECIMAL(20,4),
`REFUND_AMOUNT` DECIMAL(15,4),
`REFUND_ACCOUNT` VARCHAR(20),
`EXTRA_INFO` VARCHAR(100),
`REAL_AMOUNT` DECIMAL(15,4),
`MEMO` VARCHAR(100),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`TRANS_LOG_ID` DECIMAL(15,0),
`TRANS_DATE` TIMESTAMP (6),
`BILL_NO` VARCHAR(64),
UNIQUE KEY UK_BILL_NO(BILL_NO),
KEY IDX_TXID_SERVICE_TARGET_TYPE (TX_ID, SERVICE_TARGET, SERVICE_TYPE),
PRIMARY KEY (`REFUND_INFO_NO`)
);
CREATE TABLE GP_SEQUENCE_00 (
`name` VARCHAR(512),
`value` INT,
`min_value` INT,
`max_value` INT,
`step` INT,
`gmt_create` TIMESTAMP,
`gmt_modified` TIMESTAMP,
PRIMARY KEY(name)
);
create table BUSINESS_ACTIVITY_00 (
`TX_ID`              VARCHAR(256) not null COMMENT '业务活动Id',
`STATE`              VARCHAR(1) not null COMMENT '业务活动状态 (I: 初始状态; C: 提交中状态; S: 成功状态; R: 回滚中状态; A: 放弃状态)',
`ACCOUNT_TRANS_STATE`VARCHAR(1) not null COMMENT '账务处理状态 (N: 无状态; I: 初始状态; S: 成功状态; A: 放弃状态)',
`GMT_CREATE`         TIMESTAMP(6) not null COMMENT '创建时间',
`GMT_MODIFIED`       TIMESTAMP(6) not null COMMENT '最近修改时间',
`PROPAGATION`        VARCHAR(1) COMMENT '业务活动传播属性 (0: 新建事务; 1: 嵌套事务; )',
`CONTEXT`            VARCHAR(2048) COMMENT '业务请求上下文',
PRIMARY KEY(TX_ID)
);
create table BUSINESS_ACTION_00 (
`ACTION_ID`   BIGINT(20) not null COMMENT '原子业务活动Id，seq',
`TX_ID`       VARCHAR(256) not null COMMENT '业务活动Id',
`NAME`        VARCHAR(64) not null COMMENT '原子业务活动名称',
`STATE`       VARCHAR(1) not null COMMENT '原子业务活动状态 账务处理状态 (N: 无状态; I: 初始状态; S: 成功状态; A: 放弃状态)',
`GMT_CREATE`  TIMESTAMP(6) not null COMMENT '创建时间',
`GMT_MODIFIED`TIMESTAMP(6) not null COMMENT '最后修改时间',
`CONTEXT`     VARCHAR(2048) COMMENT '业务活动参数, 以key/value对表示',
KEY `BYD_BUSINESS_ACTION_TXID_IND` (`TX_ID`),
PRIMARY KEY(ACTION_ID,TX_ID)
);
CREATE TABLE GP_CONSULT_EVENT_00_00 (
`CONSULT_NO` VARCHAR(32) NOT NULL,
`SERVICE_TARGET` VARCHAR(64),
`SERVICE_TYPE` VARCHAR(8),
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(15,4),
`PRODUCT` VARCHAR(64),
`MARKET` VARCHAR(40),
`CHANNEL` VARCHAR(64),
`CUSTOMER` VARCHAR(32),
`PROFESSION` VARCHAR(32),
`SECOND_CUSTOMER` VARCHAR(32),
`FUNDS` VARCHAR(200),
`LOGIN` VARCHAR(32),
`CONSULT_USER_ID` VARCHAR(32),
`CONSULT_AMOUNT` DECIMAL(15,4),
`PROPERTIES` VARCHAR(1000),
`GMT_CONSULT` TIMESTAMP (6),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
PRIMARY KEY (`CONSULT_NO`)
);
CREATE TABLE `GP_SERVICE_EVENT_00_00` (
`EVENT_NO` VARCHAR(64) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`SERVICE_TARGET` VARCHAR(64) NOT NULL,
`STATUS` VARCHAR(1) NOT NULL,
`CHARGE_TYPE` VARCHAR(1),
`CREATOR` VARCHAR(64) NOT NULL,
`LAST_MODIFIER` VARCHAR(64) NOT NULL,
`GMT_SERVICE` TIMESTAMP (6) NOT NULL,
`GMT_CHARGE` TIMESTAMP (6) NOT NULL,
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`PRODUCT` VARCHAR(64),
`MARKET` VARCHAR(40),
`CHANNEL` VARCHAR(64),
`CUSTOMER` VARCHAR(32),
`PROFESSION` VARCHAR(32),
`SECOND_CUSTOMER` VARCHAR(32),
`RELATIVE_NO` VARCHAR(64),
`FUNDS` VARCHAR(200),
`LOGIN` VARCHAR(32),
`CONSULT_NO` VARCHAR(64),
`APP_ID` VARCHAR(32),
`CHARGE_RESULT` VARCHAR(1),
KEY IDX_SERVICE_TARGET_TYPE(SERVICE_TARGET, SERVICE_TYPE),
KEY IDX_RELATIVENO_STATUE(RELATIVE_NO, STATUS),
PRIMARY KEY (`EVENT_NO`)
);
CREATE TABLE `GP_SERVICE_EVENT_EXT_00_00` (
`EVENT_NO` VARCHAR(64) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`PROPERTIES` VARCHAR(1000),
PRIMARY KEY (`EVENT_NO`)
);
CREATE TABLE `GP_CLIENTBILL_00_00` (
`BILL_NO` VARCHAR(64) NOT NULL,
`CREATOR` VARCHAR(16) NOT NULL,
`LAST_MODIFIER` VARCHAR(16) NOT NULL,
`EVENT_NO` VARCHAR(64) NOT NULL,
`RATE_ORIGIN` VARCHAR(2) NOT NULL,
`RATE_ID` DECIMAL(11,0) NOT NULL,
`RATE_ORIGIN_ID` VARCHAR(32),
`ORIGIN_OWN_TYPE` VARCHAR(2),
`ORIGIN_OWN_ID` DECIMAL(11,0) NOT NULL,
`CHARGE_TYPE` VARCHAR(32) NOT NULL,
`BILL_TYPE` VARCHAR(3) NOT NULL,
`STATUS` VARCHAR(3) NOT NULL,
`PRODUCT_NAME` VARCHAR(32),
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`BILL_AMOUNT` DECIMAL(15,4) NOT NULL,
`REAL_AMOUNT` DECIMAL(15,4) NOT NULL,
`NONPAYMENT_AMOUNT` DECIMAL(15,4) NOT NULL,
`OTHER_AMOUNT` DECIMAL(15,4),
`PAYMENT_WAY` VARCHAR(3),
`SERVICE_TARGET` VARCHAR(128) NOT NULL,
`RELATIVE_NO` VARCHAR(64),
`PAYMENT_NO` VARCHAR(64),
`MEMO` VARCHAR(512),
`GMT_PAY` TIMESTAMP (6),
`GMT_VALID` TIMESTAMP (6) NOT NULL,
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`PAY_USER_ID` VARCHAR(16),
`PAY_PARTNER_ID` VARCHAR(32),
`BD_PRODUCT_CODE` VARCHAR(128),
`RATE` DECIMAL(9,6),
`FLAG_REWARD` VARCHAR(4),
`ORDER_LINK_ID` DECIMAL(11,0),
`MERCHANT_ID` DECIMAL(11,0),
`BILL_STATUS` VARCHAR(3),
`TYPE` VARCHAR(3),
`GAAP_AMOUNT` DECIMAL(15,4),
`ORDER_CARD_NO` VARCHAR(16),
`CREDIT_ACCOUNT` VARCHAR(20),
`GMT_RECORD` TIMESTAMP (6),
`PAY_ORIGIN` VARCHAR(3),
`PROPERTIES` VARCHAR(1024),
`DEBIT_ACCOUNT` VARCHAR(20),
KEY IDX_STATUS_GMTCREATE (STATUS, GMT_CREATE),
KEY IDX_GMT_MODIFIED_CREATE (GMT_MODIFIED, GMT_CREATE),
KEY IDX_SERVICE_TARGET_TYPE (SERVICE_TARGET, SERVICE_TYPE),
KEY IDX_EVENT_NO (EVENT_NO),
KEY IDX_RELATIVENO_BILLSTATUS (RELATIVE_NO, BILL_STATUS),
PRIMARY KEY (`BILL_NO`)
);
CREATE TABLE `GP_PAYMENT_BILL_00_00` (
`PAYMENT_NO` VARCHAR(64) NOT NULL,
`CHARGE_TYPE` VARCHAR(32),
`SERVICE_TARGET` VARCHAR(128),
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`CREATOR` VARCHAR(16) NOT NULL,
`LAST_MODIFIER` VARCHAR(16) NOT NULL,
`STATUS` VARCHAR(1) NOT NULL,
`BILL_AMOUNT` DECIMAL(15,0) NOT NULL,
`REAL_AMOUNT` DECIMAL(15,0),
`GMT_PAY` TIMESTAMP (6),
`DEBIT_ACCOUNT` VARCHAR(20),
`CREDIT_ACCOUNT` VARCHAR(20),
`TRANS_LOG_ID` DECIMAL(16,0),
`SERVICE_TYPE` VARCHAR(8),
`RATE_ID` DECIMAL(11,0),
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`MEMO` VARCHAR(512),
`PARTNER_ID` VARCHAR(30),
`GMT_CHARGE` TIMESTAMP (6) NOT NULL,
`GMT_SERVICE` TIMESTAMP (6),
`DIGEST_TYPE` VARCHAR(1),
`RATE` DECIMAL(9,6),
`REFUND_ID` VARCHAR(128),
`REFUND_AMOUNT` DECIMAL(15,0),
`BILL_NO` VARCHAR(64),
`BILL_TYPE` VARCHAR(3),
`RATE_ORIGIN_ID` VARCHAR(32),
`PAY_ORIGIN` VARCHAR(1),
`ACCOUNT_LOG_ID` VARCHAR(20),
PRIMARY KEY (`PAYMENT_NO`)
);
CREATE TABLE `GP_FUND_DETAIL_00_00` (
`FUND_NO` VARCHAR(64) NOT NULL,
`EVENT_NO` VARCHAR(63) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`PAY_AMOUNT` DECIMAL(20,4) NOT NULL,
`REFUND_AMOUNT` DECIMAL(20,4) NOT NULL,
`OTHER_SUB_AMOUNT` DECIMAL(20,4) NOT NULL,
`FUND_CHANNEL_TYPE` VARCHAR(32),
`CHARGE_CHANNEL_TYPE` VARCHAR(32),
`INST_ID` VARCHAR(32),
`PAY_CHANNEL_API` VARCHAR(32),
`PAYMENT_ID` VARCHAR(64),
`PROPERTIES` VARCHAR(1024),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
PRIMARY KEY (`FUND_NO`)
);
CREATE TABLE `GP_CHECKBILL_00_00` (
`BILL_NO` VARCHAR(64) NOT NULL,
`CREATOR` VARCHAR(16) NOT NULL,
`LAST_MODIFIER` VARCHAR(16) NOT NULL,
`EVENT_NO` VARCHAR(64) NOT NULL,
`RATE_ORIGIN` VARCHAR(2) NOT NULL,
`RATE_ID` DECIMAL(11,0) NOT NULL,
`RATE_ORIGIN_ID` VARCHAR(32),
`ORIGIN_OWN_TYPE` VARCHAR(2),
`ORIGIN_OWN_ID` DECIMAL(11,0) NOT NULL,
`CHARGE_TYPE` VARCHAR(32) NOT NULL,
`BILL_TYPE` VARCHAR(3) NOT NULL,
`STATUS` VARCHAR(3) NOT NULL,
`PRODUCT_NAME` VARCHAR(32),
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`BILL_AMOUNT` DECIMAL(15,4) NOT NULL,
`REAL_AMOUNT` DECIMAL(15,4) NOT NULL,
`NONPAYMENT_AMOUNT` DECIMAL(15,4) NOT NULL,
`OTHER_AMOUNT` DECIMAL(15,4),
`PAYMENT_WAY` VARCHAR(3),
`SERVICE_TARGET` VARCHAR(128) NOT NULL,
`RELATIVE_NO` VARCHAR(64),
`PAYMENT_NO` VARCHAR(64),
`MEMO` VARCHAR(512),
`GMT_PAY` TIMESTAMP (6),
`GMT_VALID` TIMESTAMP (6) NOT NULL,
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`SERVICE_TYPE` VARCHAR(8) NOT NULL,
`PAY_USER_ID` VARCHAR(16),
`PAY_PARTNER_ID` VARCHAR(32),
`BD_PRODUCT_CODE` VARCHAR(128),
`RATE` DECIMAL(9,6),
`FLAG_REWARD` VARCHAR(4),
`ORDER_LINK_ID` DECIMAL(11,0),
`MERCHANT_ID` DECIMAL(11,0),
`BILL_STATUS` VARCHAR(3),
`TYPE` VARCHAR(3),
`GAAP_AMOUNT` DECIMAL(15,4),
`ORDER_CARD_NO` VARCHAR(16),
`CREDIT_ACCOUNT` VARCHAR(20),
`GMT_RECORD` TIMESTAMP (6),
`PAY_ORIGIN` VARCHAR(3),
`PROPERTIES` VARCHAR(1024),
PRIMARY KEY (`BILL_NO`)
);
CREATE TABLE `GP_REFUND_EVENT_00_00` (
`REFUND_EVENT_NO` VARCHAR(64) NOT NULL,
`SERVICE_TARGET` VARCHAR(64),
`SERVICE_TYPE` VARCHAR(8),
`REFUND_NO` VARCHAR(128) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4),
`REFUND_AMOUNT` DECIMAL(15,4),
`CONSULT_NO` VARCHAR(32),
`FREEZE_CODE` VARCHAR(64),
`STATUS` VARCHAR(1) NOT NULL,
`GMT_SERVICE` TIMESTAMP (6),
`GMT_CREATE` TIMESTAMP (6) NOT NULL,
`GMT_MODIFIED` TIMESTAMP (6) NOT NULL,
`REFUND_TYPE` VARCHAR(1) NOT NULL,
`PROPERTIES` VARCHAR(1000),
KEY IDX_STATUS_GMTMODIFIED_TYPE(STATUS, GMT_MODIFIED, REFUND_TYPE),
KEY IDX_SERVICE_TARGET_TYPE(SERVICE_TARGET, SERVICE_TYPE),
PRIMARY KEY (`REFUND_EVENT_NO`)
);
alter system flush plan cache global;

##### test #####
create outline charge_ol_1 on delete from gp_refund_info_00 where (tx_id = '0000000100');
delete from gp_refund_info_00 where (tx_id = '0000000100');
delete from gp_refund_info_00 where (tx_id = '0000000100');
select hit_count, outline_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT as a join oceanbase.DBA_OB_OUTLINES as b on a.outline_id = b.outline_id where b.outline_name = "charge_ol_1";
hit_count	outline_sql
1	delete /*+BEGIN_OUTLINE_DATA INDEX(@"DEL$1" "charge00"."gp_refund_info_00"@"DEL$1" "IDX_TXID_SERVICE_TARGET_TYPE") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/from gp_refund_info_00 where (tx_id = '0000000100')

