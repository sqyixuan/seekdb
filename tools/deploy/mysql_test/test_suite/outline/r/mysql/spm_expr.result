set global optimizer_use_sql_plan_baselines = true;
set global optimizer_capture_sql_plan_baselines = true;
alter system set plan_cache_evict_interval = '5s';
alter system flush plan cache global;
drop database if exists spm_pkg_db;
create database spm_pkg_db;
use spm_pkg_db;
select spm_drop_baseline('529F6E6454EF579C7CC265D1F6131D70', NULL) ret;
ret
0
CREATE TABLE t1(c1 INT, c2 INT, c3 INT, key idx(c2, c1));
select * from t1 where c1 = 1;
c1	c2	c3
select * from t1 where c1 = '1';
c1	c2	c3
//expected 2
select count(*) from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(*)
2
set @sql_id := '529F6E6454EF579C7CC265D1F6131D70';

# DBMS_SPM.DROP_SQL_PLAN_BASELINE (
#    sql_handle     IN VARCHAR2 := NULL,
#    plan_name      IN VARCHAR2 := NULL)
# RETURN PLS_INTEGER;


# function: spm_drop_baseline:
#         arg0: sql_id varchar
#         arg1: plan_hash_value uint

***************** case 1 test drop baseline*********
// case 1.1: 按sql_id, plan_hash_value进行drop
select spm_drop_baseline(@sql_id, @plan_hash_value_1) ret;
ret
0
// expected 1
select plan_hash_value = @plan_hash_value_2 from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_2
1

// case 1.2: 按NULL, plan_hash_value进行drop
select spm_drop_baseline(NULL, @plan_hash_value_2) ret;
ret
0
// expected 0
select count(0) from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(0)
0

//load baseline
select spm_load_plans_from_plan_cache(@sql_id, NULL, false, true) ret;
ret
0
// expected 2
select count(*)  from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(*)
2

// case 1.3: 按529F6E6454EF579C7CC265D1F6131D70, NULL进行drop
select spm_drop_baseline(@sql_id, NULL) ret;
ret
0
// expected 0
select count(0) from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(0)
0

// case 1.4: error case
# sql_id 和plan_hash_value均为NULL
select spm_drop_baseline(NULL, NULL) ret;
ERROR HY000: Invalid argument

# DBMS_SPM.ALTER_SQL_PLAN_BASELINE (
#    sql_handle        IN VARCHAR2 := NULL,
#    plan_name         IN VARCHAR2 := NULL,
#    attribute_name    IN VARCHAR2,
#    attribute_value   IN VARCHAR2)
#  RETURN PLS_INTEGER;

# function: spm_alter_baseline:
#         arg0: sql_id varchar
#         arg1: plan_hash_value uint
#         arg2: attribute_name varchar
#         arg3: attribute_value varchar

***************** case 2 test alter baseline ***************

//load baseline
select spm_load_plans_from_plan_cache(@sql_id, NULL, false, true) ret;
ret
0
// expected 2 rows, fixed = 0, enabled = 1;
select sql_id, fixed, enabled, outline_data from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	fixed	enabled	outline_data
529F6E6454EF579C7CC265D1F6131D70	0	1	/*+ BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "spm_pkg_db.t1"@"SEL$1" "idx") END_OUTLINE_DATA*/
529F6E6454EF579C7CC265D1F6131D70	0	1	/*+ BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "spm_pkg_db.t1"@"SEL$1" "idx") END_OUTLINE_DATA*/

// case 2.1: 按sql_id, NULL进行alter fixed
select spm_alter_baseline(@sql_id, NULL, 'fixed', 'YES') ret;
ret
0
// expected 2 rows, fixed = 1, enabled = 1;
select sql_id, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	fixed	enabled
529F6E6454EF579C7CC265D1F6131D70	1	1
529F6E6454EF579C7CC265D1F6131D70	1	1

// case 2.2: 按sql_id, NULL进行alter enabled
select spm_alter_baseline(@sql_id, NULL, 'enabled', 'NO') ret;
ret
0
// expected 2 rows, fixed = 1, enabled = 0;
select sql_id, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	fixed	enabled
529F6E6454EF579C7CC265D1F6131D70	1	0
529F6E6454EF579C7CC265D1F6131D70	1	0

// case 2.3: 按sql_id, NULL进行alter outline_data
select spm_alter_baseline(@sql_id, NULL, 'outline_data', '/*+ index(t1 primary)*/') ret;
ret
0
// expected 2 rows, fixed = 1, enabled = 0;
select sql_id, fixed, enabled, outline_data from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	fixed	enabled	outline_data
529F6E6454EF579C7CC265D1F6131D70	1	0	/*+ index(t1 primary)*/
529F6E6454EF579C7CC265D1F6131D70	1	0	/*+ index(t1 primary)*/

// case 2.4: 按sql_id, plan_hash_value进行alter fixed
select spm_alter_baseline(@sql_id, @plan_hash_value_1, 'fixed', 'NO') ret;
ret
0
// expected 2 rows  1, 0, 0; 0, 1, 0;
select plan_hash_value = @plan_hash_value_1, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	fixed	enabled
1	0	0
0	1	0

// case 2.5: 按sql_id, plan_hash_value进行alter enabled
select spm_alter_baseline(@sql_id, @plan_hash_value_1, 'enabled', 'YES') ret;
ret
0
// expected 2 rows  1, 0, 1; 0, 1, 0;
select plan_hash_value = @plan_hash_value_1, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	fixed	enabled
1	0	1
0	1	0
// case 2.6: 按sql_id, plan_hash_value进行alter outline_data
select spm_alter_baseline(@sql_id, @plan_hash_value_1, 'outline_data', 'OUTLINE_DATA') ret;
ret
0
// expected 2 rows  1, 'OUTLINE_DATA'; 0, '/*+ index(t1 primary)*/';
select plan_hash_value = @plan_hash_value_1, outline_data from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	outline_data
1	OUTLINE_DATA
0	/*+ index(t1 primary)*/

// case 2.7: 按NULL, plan_hash_value进行alter fixed
select spm_alter_baseline(NULL, @plan_hash_value_1, 'fixed', 'YES') ret;
ret
0
// expected 2 rows  1, 1, 1; 0, 1, 0;
select plan_hash_value = @plan_hash_value_1, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	fixed	enabled
1	1	1
0	1	0

// case 2.8: 按NULL, plan_hash_value进行alter enabled
select spm_alter_baseline(NULL, @plan_hash_value_1, 'enabled', 'NO') ret;
ret
0
// expected 2 rows  1, 1, 0; 0, 1, 0;
select plan_hash_value = @plan_hash_value_1, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	fixed	enabled
1	1	0
0	1	0

// case 2.9: 按NULL, plan_hash_value进行alter outline
select spm_alter_baseline(NULL, @plan_hash_value_1, 'outline_data', '/*+ index(t1 primary)*/') ret;
ret
0
// expected 2 rows  1, '/*+ index(t1 primary)*/'; 0, '/*+ index(t1 primary)*/';
select plan_hash_value = @plan_hash_value_1,outline_data from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
plan_hash_value = @plan_hash_value_1	outline_data
1	/*+ index(t1 primary)*/
0	/*+ index(t1 primary)*/

// case 2.10: error case
# sql_id 和plan_hash_value均为NULL
select spm_alter_baseline(NULL, NULL, 'fixed', 'YES') ret;
ERROR HY000: Invalid argument

# DBMS_SPM.LOAD_PLANS_FROM_CURSOR_CACHE (
#    sql_id            IN  VARCHAR2,
#    plan_hash_value   IN  NUMBER   := NULL,
#    fixed             IN  VARCHAR2 := 'NO',
#    enabled           IN  VARCHAR2 := 'YES')
#  RETURN PLS_INTEGER;


# function: spm_load_plans_from_plan_cache:
#         arg0: sql_id varchar
#         arg1: plan_hash_value uint
#         arg2: fixed bool
#         arg3: enabled bool

******************* case 3 : load baseline
//drop baseline
select spm_drop_baseline(@sql_id, NULL) ret;
ret
0
// expected 0
select count(0) from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(0)
0

// case 3.1: 按sql_id, NULL 进行load;
select spm_load_plans_from_plan_cache(@sql_id, NULL, false, true) ret;
ret
0
// expected 2 rows, fixed = 0, enabled = 1;
select sql_id, fixed, enabled, outline_data from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	fixed	enabled	outline_data
529F6E6454EF579C7CC265D1F6131D70	0	1	/*+ BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "spm_pkg_db.t1"@"SEL$1" "idx") END_OUTLINE_DATA*/
529F6E6454EF579C7CC265D1F6131D70	0	1	/*+ BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "spm_pkg_db.t1"@"SEL$1" "idx") END_OUTLINE_DATA*/

//drop baseline
select spm_drop_baseline(@sql_id, NULL) ret;
ret
0
// expected 0
select count(0) from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
count(0)
0

// case 3.2: 按sql_id, plan_hash_value进行load;
select spm_load_plans_from_plan_cache(@sql_id, @plan_hash_value_1, true, false) ret;
ret
0
// expected 2 rows, 1, 1, 0; 0, 1, 0;
select sql_id, plan_hash_value = @plan_hash_value_1, fixed, enabled from oceanbase.__all_virtual_tenant_plan_baseline where tenant_id = 1002 and sql_text = 'select * from t1 where c1 = ?';
sql_id	plan_hash_value = @plan_hash_value_1	fixed	enabled
529F6E6454EF579C7CC265D1F6131D70	1	1	0
529F6E6454EF579C7CC265D1F6131D70	0	1	0

