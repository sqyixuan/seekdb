create outline ol_16 on select refund_event_no from(select refund_event_no from gp_refund_event_00_00 where(status ='i' ) and(gmt_modified <(now() - 0.0007 ) ) and(refund_type ='a' or refund_type ='p' ) order by gmt_modified asc ) as a where(1=1) limit 0,100;
