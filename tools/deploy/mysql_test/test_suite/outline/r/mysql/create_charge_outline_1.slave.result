create outline ol_1 on select bill_no , gmt_create , gmt_modified , gmt_valid , creator , last_modifier , event_no , memo , rate_origin , gmt_pay , rate_id , rate_origin_id , origin_own_type , origin_own_id , charge_type , bill_type , status , product_name , service_amount , bill_amount , real_amount , nonpayment_amount , other_amount , payment_way , service_target , relative_no , payment_no , service_type , pay_user_id , pay_partner_id , bd_product_code , rate , order_link_id , merchant_id , bill_status , type , gaap_amount , order_card_no , credit_account , debit_account , gmt_record , pay_origin , flag_reward , properties from gp_clientbill_00_00 where bill_no = '0000000100';
create outline ol_2 on select bill_no from gp_clientbill_00_00 where bill_no = '0000000100';
create outline ol_3 on select bill_no , gmt_create , gmt_modified , gmt_valid , creator , last_modifier , event_no , memo , rate_origin , gmt_pay , rate_id , rate_origin_id , origin_own_type , origin_own_id , charge_type , bill_type , status , product_name , service_amount , bill_amount , real_amount , nonpayment_amount , other_amount , payment_way , service_target , relative_no , payment_no , service_type , pay_user_id , pay_partner_id , bd_product_code , rate , order_link_id , merchant_id , bill_status , type , gaap_amount , order_card_no , credit_account , debit_account , gmt_record , pay_origin , flag_reward , properties from gp_clientbill_00_00 where event_no = '0000000100';
create outline ol_4 on select bill_no , gmt_create , gmt_modified , gmt_valid , creator , last_modifier , event_no , memo , rate_origin , gmt_pay , rate_id , rate_origin_id , origin_own_type , origin_own_id , charge_type , bill_type , status , product_name , service_amount , bill_amount , real_amount , nonpayment_amount , other_amount , payment_way , service_target , relative_no , payment_no , service_type , pay_user_id , pay_partner_id , bd_product_code , rate , order_link_id , merchant_id , bill_status , type , gaap_amount , order_card_no , credit_account , debit_account , gmt_record , pay_origin , flag_reward , properties from gp_clientbill_00_00 where bill_no = '0000000100' for update nowait;
