| statement        | hit_count | outline_data                                                                                              | outline_id != -1 |
+------------------+-----------+-----------------------------------------------------------------------------------------------------------+------------------+
| select * from t2 |         0 | /*+BEGIN_OUTLINE_DATA FULL(@"SEL$1" "test"."t2"@"SEL$1") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/ |                0 |
+------------------+-----------+-----------------------------------------------------------------------------------------------------------+------------------+
### can not use outline, use primary key
select/*comment1*/ * from t2;
