PRIMARY KEY (`REFUND_EVENT_NO`)
);

## IDX_GMTRECOVER_STATUS_PRIORITY
create outline charge_ol_8 on select /*+index(gp_service_event_buff_00 IDX_GMTRECOVER_STATUS_PRIORITY)*/event_no,service_type,service_target,status,creator,last_modifier,gmt_service,gmt_charge,gmt_modified,service_amount,product,market,channel,customer,profession,second_customer,relative_no,funds,login,priority,fail_num,gmt_create,gmt_recover,charge_type,consult_no,app_id,charge_result from gp_service_event_buff_00 where event_no = '0000000100' for update nowait;
select event_no,service_type,service_target,status,creator,last_modifier,gmt_service,gmt_charge,gmt_modified,service_amount,product,market,channel,customer,profession,second_customer,relative_no,funds,login,priority,fail_num,gmt_create,gmt_recover,charge_type,consult_no,app_id,charge_result from gp_service_event_buff_00 where event_no = '0000000100' for update nowait;
