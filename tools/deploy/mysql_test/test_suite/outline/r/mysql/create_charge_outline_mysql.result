`BILL_AMOUNT` DECIMAL(15,0) NOT NULL,
`REAL_AMOUNT` DECIMAL(15,0),
`GMT_PAY` TIMESTAMP (6),
`DEBIT_ACCOUNT` VARCHAR(20),
`CREDIT_ACCOUNT` VARCHAR(20),
`TRANS_LOG_ID` DECIMAL(16,0),
`SERVICE_TYPE` VARCHAR(8),
`RATE_ID` DECIMAL(11,0),
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`MEMO` VARCHAR(512),
`PARTNER_ID` VARCHAR(30),
`GMT_CHARGE` TIMESTAMP (6) NOT NULL,
`GMT_SERVICE` TIMESTAMP (6),
`DIGEST_TYPE` VARCHAR(1),
`RATE` DECIMAL(9,6),
`REFUND_ID` VARCHAR(128),
`REFUND_AMOUNT` DECIMAL(15,0),
`BILL_NO` VARCHAR(64),
`BILL_TYPE` VARCHAR(3),
`RATE_ORIGIN_ID` VARCHAR(32),
`PAY_ORIGIN` VARCHAR(1),
`ACCOUNT_LOG_ID` VARCHAR(20),
PRIMARY KEY (`PAYMENT_NO`)
);
CREATE TABLE `GP_FUND_DETAIL_00_00` (
`FUND_NO` VARCHAR(64) NOT NULL,
`EVENT_NO` VARCHAR(63) NOT NULL,
`SERVICE_AMOUNT` DECIMAL(20,4) NOT NULL,
`PAY_AMOUNT` DECIMAL(20,4) NOT NULL,
`REFUND_AMOUNT` DECIMAL(20,4) NOT NULL,
