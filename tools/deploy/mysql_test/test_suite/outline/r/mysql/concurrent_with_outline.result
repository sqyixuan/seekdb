drop database ykk;
create database ykk;
use ykk;
drop table t1;
create table t1(t1_id int,c1 varchar(20),c2 int,c3 int);
insert into t1 values(1,'a',22,33);
insert into t1 values(2,'b',323,2425);
insert into t1 values(3,'c',213,76767);
insert into t1 values(4,'d',2342,444);
insert into t1 values(5,'e',11,2);
insert into t1 values(6,'f',34,55);
insert into t1 values(7,'g',123,2);
drop table t2;
create table t2(t2_id int,c2 varchar(20),c3 int);
insert into t2 values(1,'A',2);
insert into t2 values(2,'B',3);
insert into t2 values(3,'C',4);
insert into t2 values(4,'D',5);
insert into t2 values(5,'E',6);
insert into t2 values(6,'F',7);
insert into t2 values(7,'G',8);
drop table t3;
create table t3(t3_id int,c1 int);
insert into t3 values(1,2);
insert into t3 values(2,3);
insert into t3 values(3,4);
CREATE UNIQUE INDEX c1_inx ON t1 (c1);
create outline otl2 on select/*+ INDEX (t1 c1_inx) no_rewrite max_concurrent(1) +*/ * from t1 where c1=?;
ERROR HY000: invalid outline ,error info:sql text should have no ? when there is no concurrent limit
create outline otl2 on select/*+ leading(t2 t1) no_rewrite max_concurrent(1) +*/ * from t1, t2 where t1.t1_id = t2.t2_id and t1.t1_id = ?;
ERROR HY000: invalid outline ,error info:sql text should have no ? when there is no concurrent limit
