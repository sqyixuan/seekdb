drop database if exists pttrans00;
create database pttrans00;
use pttrans00;
CREATE TABLE FT_ROLLBACK_INFO
(  SYS_TRANS_ID VARCHAR(128) NOT NULL ,
GMT_CREATE TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL ,
GMT_MODIFIED TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL ,
TX_ID VARCHAR(128) NOT NULL ,
PRIMARY KEY (SYS_TRANS_ID)
) ;
CREATE INDEX FT_ROLLBACK_INFO_INDEX ON FT_ROLLBACK_INFO (SYS_TRANS_ID, TX_ID) ;
CREATE TABLE FT_SYSTEM_MONEY_MANAGER
(  TX_ID VARCHAR(128) NOT NULL ,
ACCOUNT_NO VARCHAR(20) NOT NULL ,
TYPE VARCHAR(7) NOT NULL ,
AMOUNT BIGINT(15) NOT NULL
) ;
CREATE UNIQUE INDEX FT_SYS_MONEY_MAN_PK ON FT_SYSTEM_MONEY_MANAGER (ACCOUNT_NO, TX_ID, TYPE);
CREATE TABLE FT_TRANACTION_INFO
(  TX_ID VARCHAR(128) NOT NULL ,
STATUS VARCHAR(1) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL ,
SYSTEM_TRANSACTION_ID VARCHAR(128),
PRIMARY KEY (TX_ID)
) ;
CREATE TABLE FT_TRANS_INFO
(  TX_ID VARCHAR(128) NOT NULL ,
TRANS_CODE VARCHAR(4) NOT NULL ,
SUB_TRANS_CODE VARCHAR(6) NOT NULL ,
TRANS_AMOUNT BIGINT(15) NOT NULL ,
IN_ACCOUNT VARCHAR(20) NOT NULL ,
OUT_ACCOUNT VARCHAR(20) NOT NULL ,
ORDER_NO VARCHAR(128),
OUT_BIZ_NO VARCHAR(128),
IN_MEMO VARCHAR(256),
OUT_MEMO VARCHAR(256),
OUT_DATE VARCHAR(8),
TRANS_DATE VARCHAR(8) NOT NULL ,
VOUCHER_ID VARCHAR(32),
TRANS_DT TIMESTAMP (6) NOT NULL ,
GMT_CREATE TIMESTAMP (6),
MINI_FREEZE_TYPE VARCHAR(5),
UNIQUE_ID VARCHAR(128),
RECON_INST VARCHAR(32),
CONTEXT VARCHAR(200),
biz_pd_code varchar(21),
biz_ev_code varchar(8),
cnl_pd_code varchar(21),
cnl_ev_code varchar(8),
cnl_no varchar(64),
pd_code varchar(21),
ev_code varchar(8)
) ;
CREATE UNIQUE INDEX FT_TRANS_INFO_UK ON FT_TRANS_INFO (TX_ID, SUB_TRANS_CODE);
CREATE INDEX FT_TRANS_IF_TXID_IND ON FT_TRANS_INFO (TX_ID) ;
CREATE UNIQUE INDEX FT_TRANS_INFO_UID_UK ON FT_TRANS_INFO (UNIQUE_ID) ;
