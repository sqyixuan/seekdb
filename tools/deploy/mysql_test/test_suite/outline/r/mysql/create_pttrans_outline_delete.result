GMT_CREATE TIMESTAMP (6) NOT NULL ,
GMT_MODIFIED TIMESTAMP (6) NOT NULL ,
PRIMARY KEY (TABLE_INDEX)
)  ;
CREATE TABLE MINI_BLACKLIST
(  MINI_ACCOUNT_NO VARCHAR(20) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL ,
GMT_MODIFIED TIMESTAMP (6) NOT NULL ,
PRIMARY KEY (MINI_ACCOUNT_NO)
) ;
CREATE TABLE MINI_FAILOVER_RECORD
(  MINI_ACCOUNT_NO VARCHAR(20) NOT NULL ,
ACCOUNT_SNAPSHOT VARCHAR(4000) NOT NULL ,
STATUS VARCHAR(1) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL ,
GMT_MODIFIED TIMESTAMP (6) NOT NULL ,
CONTEXT VARCHAR(1000),
ERROR_CODE VARCHAR(64),
BACKUP_FLAG VARCHAR(1),
PRIMARY KEY (MINI_ACCOUNT_NO)
)  ;
CREATE TABLE MINI_SNAPSHOT_MSG
(  ID VARCHAR(20) NOT NULL ,
BUSINESS_ID VARCHAR(256) NOT NULL ,
ACTION_TYPE VARCHAR(32) NOT NULL ,
MINI_ACCOUNT_NO VARCHAR(20) NOT NULL ,
ACCOUNT_SNAPSHOT VARCHAR(2048),
DAILY_SNAPSHOT VARCHAR(2048),
FREEZE_SNAPSHOT VARCHAR(2048),
GMT_CREATE TIMESTAMP (6) NOT NULL ,
GMT_MODIFIED TIMESTAMP (6) NOT NULL ,
PRIMARY KEY (ID)
) ;
CREATE TABLE MINI_FREEZE_LOG_MSG
(  ID VARCHAR(32) NOT NULL ,
MINI_ACCOUNT_NO VARCHAR(20) NOT NULL ,
ACTION_TYPE VARCHAR(1) NOT NULL ,
AMOUNT BIGINT(15) NOT NULL ,
MINI_FREEZE_TYPE VARCHAR(5) NOT NULL ,
TOTAL_FREEZE_AMOUNT BIGINT(15) NOT NULL ,
TYPE_FREEZE_AMOUNT BIGINT(15) NOT NULL ,
TRANS_DT TIMESTAMP (6),
ORDER_NO VARCHAR(128),
OUT_BIZ_NO VARCHAR(128),
TRANS_MEMO VARCHAR(256),
VOUCHER_ID VARCHAR(32),
OPERATOR VARCHAR(8),
GMT_CREATE TIMESTAMP (6) NOT NULL
) ;
CREATE UNIQUE INDEX MN_ACN_FRZ_LOG_MSG_UK ON MINI_FREEZE_LOG_MSG (ID, TRANS_DT);
CREATE TABLE SNAPSHOT_MSG_RECORD
(  ID VARCHAR(32) NOT NULL ,
ACCOUNT_NO VARCHAR(20) NOT NULL ,
BALANCE BIGINT(15) NOT NULL ,
freeze_amout BIGINT(15) NOT NULL ,
system_amout BIGINT(15) NOT NULL ,
check_status  VARCHAR(1) NOT NULL ,
tx_id VARCHAR(128) NOT NULL ,
db_source VARCHAR(20) NOT NULL ,
status VARCHAR(1) NOT NULL ,
system_bu_amount BIGINT(15) NOT NULL ,
gmt_last_trans TIMESTAMP (6) NOT NULL ,
gmt_modified TIMESTAMP (6) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL ,
PRIMARY KEY (ID)
) ;
CREATE  INDEX hist_snaps_task_acco_ind ON SNAPSHOT_MSG_RECORD (ACCOUNT_NO,check_status,db_source);
CREATE  INDEX hist_snaps_task_db_ind ON SNAPSHOT_MSG_RECORD (db_source,check_status);
CREATE TABLE minitrans_sequence_pt
(  name VARCHAR(20) NOT NULL ,
value BIGINT(15) NOT NULL ,
min_value BIGINT(15) NOT NULL ,
max_value BIGINT(15) NOT NULL ,
step  VARCHAR(1) NOT NULL ,
gmt_modified TIMESTAMP (6) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL
) ;
CREATE TABLE history_snapshot_task
(  ID VARCHAR(20) NOT NULL ,
start_time TIMESTAMP (6) NOT NULL ,
end_time TIMESTAMP (6) NOT NULL ,
table_index VARCHAR(2) NOT NULL ,
task_version VARCHAR(20) NOT NULL ,
migrate_time  TIMESTAMP (6) NOT NULL ,
source_db VARCHAR(20) NOT NULL ,
target_db VARCHAR(20) NOT NULL ,
gmt_modified TIMESTAMP (6) NOT NULL ,
GMT_CREATE TIMESTAMP (6) NOT NULL ,
PRIMARY KEY (ID)
) ;
CREATE UNIQUE INDEX hist_snaps_task_uk ON history_snapshot_task (start_time,end_time,task_version);
