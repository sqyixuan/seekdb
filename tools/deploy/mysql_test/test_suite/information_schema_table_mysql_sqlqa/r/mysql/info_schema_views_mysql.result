SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
TABLE_NAME	VIEW_DEFINITION
obwmj_t9_view	select `obwmjtest`.`obwmj_t1`.`id` AS `id`,`obwmjtest`.`obwmj_t9`.`brand` AS `brand`,`obwmjtest`.`obwmj_t9`.`color` AS `color` from `obwmjtest`.`obwmj_t9`,`obwmjtest`.`obwmj_t1` order by 1
