def	obwmjtest	obwmj_t1_view	select `obwmjtest`.`obwmj_t1`.`c1` AS `c1`,`obwmjtest`.`obwmj_t1`.`c2` AS `c2`,`obwmjtest`.`obwmj_t1`.`c3` AS `c3` from `obwmjtest`.`obwmj_t1`
