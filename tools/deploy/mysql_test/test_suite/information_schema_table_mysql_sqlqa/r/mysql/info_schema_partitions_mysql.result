DROP TABLE obwmj_t1;
CREATE TABLE obwmj_t4(
a bigint,
b date
)partition by range columns(b) 
( 
partition part_1 values less than ('2016-09-01'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
CREATE TABLE obwmj_t5(
a bigint not null AUTO_INCREMENT key,
b date
)partition by range columns(a) 
( 
partition part_1 values less than (20),
partition part_2 values less than (50),
partition part_3 values less than (100)
);
