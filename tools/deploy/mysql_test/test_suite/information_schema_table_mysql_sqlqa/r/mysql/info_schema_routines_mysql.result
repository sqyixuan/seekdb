CREATE FUNCTION obwmj_f_test()
returns varchar(200)
begin
declare a varchar(200);
SELECT sign(sal) FROM obwmj_t1 e WHERE sign(sal)=0 INTO a;
return a;
END;
//
SELECT SPECIFIC_NAME,ROUTINE_CATALOG,ROUTINE_SCHEMA,ROUTINE_NAME FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='obwmjtest' ;
SPECIFIC_NAME	ROUTINE_CATALOG	ROUTINE_SCHEMA	ROUTINE_NAME
obwmj_f_test	def	obwmjtest	obwmj_f_test
DROP FUNCTION obwmj_f_test;
CREATE PROCEDURE obwmj_p_test(in samplename  varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into a;
SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into b;
END;
//
SELECT SPECIFIC_NAME,ROUTINE_CATALOG,ROUTINE_SCHEMA,ROUTINE_NAME FROM INFORMATION_SCHEMA.ROUTINES WHERE ROUTINE_SCHEMA='obwmjtest' ;
SPECIFIC_NAME	ROUTINE_CATALOG	ROUTINE_SCHEMA	ROUTINE_NAME
obwmj_p_test	def	obwmjtest	obwmj_p_test
