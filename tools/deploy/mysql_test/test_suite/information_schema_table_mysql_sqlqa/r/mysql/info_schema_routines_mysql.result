CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
CREATE USER TEST_AC IDENTIFIED BY 'WMJ456';
GRANT ALL ON *.* TO TEST_AC WITH GRANT OPTION;
DROP TABLE obwmj_t1;
DROP FUNCTION obwmj_f_test;
DROP PROCEDURE obwmj_p_test;
CREATE TABLE `obwmj_t1` (
`id` int NOT NULL,
`consumer` char(20) DEFAULT NULL,
`price` varchar(20) DEFAULT NULL,
`sal` int DEFAULT NULL,
`datetime1` DATE,
`datetime2` bigint
);
