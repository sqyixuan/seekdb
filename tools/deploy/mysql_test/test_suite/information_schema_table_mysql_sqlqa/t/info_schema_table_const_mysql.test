## TABLE_NAME,CONSTRAINT_CATALOG,CONSTRAINT_SCHEMA,CONSTRAINT_NAME,TABLE_SCHEMA,CONSTRAINT_TYPE,ENFORCED

#主键约束
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,
     brand VARCHAR(255) NOT NULL,
     color int
);
SELECT TABLE_NAME,CONSTRAINT_CATALOG,CONSTRAINT_SCHEMA,CONSTRAINT_NAME,TABLE_SCHEMA,CONSTRAINT_TYPE FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS WHERE TABLE_NAME='obwmj_t1';
