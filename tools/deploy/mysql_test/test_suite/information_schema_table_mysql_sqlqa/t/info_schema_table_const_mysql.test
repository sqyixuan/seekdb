## TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME

--echo #主键约束
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,
     brand VARCHAR(255) NOT NULL,
     color int
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #唯一约束
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED,
     brand VARCHAR(255) NOT NULL,
     color int unique
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #普通索引
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED,
     brand VARCHAR(255) NOT NULL,
     color int,
	 INDEX(color)
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #无主键，多列唯一索引
CREATE TABLE obwmj_t1 (
    id BIGINT UNSIGNED,
    brand VARCHAR(255) ,
    color int,
	unique key unique_brand(id,brand)
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #无主键，多列索引
CREATE TABLE obwmj_t1 (
    id BIGINT UNSIGNED,
    brand VARCHAR(255) ,
    color int,
	key unique_brand(id,brand)
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #单列索引
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED,
     brand VARCHAR(255) NOT NULL,
     color int,
	 INDEX obwmj_t1_idx (brand(20))
);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #自定义唯一索引名
CREATE TABLE obwmj_t1 (
     id BIGINT UNSIGNED ,
     brand VARCHAR(255),
     color int
);
CREATE UNIQUE INDEX obwmj_t1_idx USING BTREE ON obwmj_t1(brand);
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,NON_UNIQUE,INDEX_SCHEMA,INDEX_NAME FROM INFORMATION_SCHEMA.STATISTICS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


--echo #全文索引
