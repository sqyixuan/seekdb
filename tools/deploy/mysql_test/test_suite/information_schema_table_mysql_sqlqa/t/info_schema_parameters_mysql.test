# 存储过程，参数 date 类型
DELIMITER //;
CREATE PROCEDURE obwmj_p_test( out wb varchar(200),inout wb1 date)
begin
	declare i int;
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = 0 into wb;
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = -1 into wb1;
END;
//
DELIMITER ;//
SELECT CHARACTER_SET_NAME,COLLATION_NAME,DTD_IDENTIFIER,ROUTINE_TYPE FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA='obwmjtest' ;
DROP PROCEDURE obwmj_p_test;


