	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename1 into b;
	return a+b;
END;
//
DELIMITER ;//
SELECT SPECIFIC_SCHEMA,SPECIFIC_NAME,ORDINAL_POSITION,PARAMETER_MODE,PARAMETER_NAME,DATA_TYPE FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA='obwmjtest' ;
DROP FUNCTION obwmj_f_test;


