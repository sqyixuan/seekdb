--echo #Environmental cleaning
--disable_warnings
--error 0,1396
DROP USER wmj456@'%';
--error 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
--enable_warnings
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############
--error 0,1051
DROP TABLE obwmj_t1;
--error 0,1305
DROP FUNCTION obwmj_f_test;
--error 0,1305
DROP PROCEDURE obwmj_p_test;



CREATE TABLE `obwmj_t1` (
  `id` int NOT NULL,
  `consumer` char(20) DEFAULT NULL,
  `price` varchar(20) DEFAULT NULL,
  `sal` int DEFAULT NULL,
  `datetime1` DATE,
  `datetime2` bigint
);
INSERT INTO obwmj_t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO obwmj_t1 VALUES(2,'微山','3000',-4000,'2020-09-21',20200921101159);
INSERT INTO obwmj_t1 VALUES(3,'深咖','5000',0,'2020-08-21',20190821101159);
INSERT INTO obwmj_t1 VALUES(4,'流苏','0',NULL,'2020-02-29',20200228101159);
INSERT INTO obwmj_t1 VALUES(5,'玻璃','3200',6000,'2020-02-29',20200228101159);
INSERT INTO obwmj_t1 VALUES(6,'钛钢',NULL,8000,'2020-02-29',20200228101159);
INSERT INTO obwmj_t1 VALUES(7,'合金','VIVO',3500,'2020-02-29',20200228101159);


############################## TEST CASES  ##############################
## SPECIFIC_SCHEMA,SPECIFIC_NAME,ORDINAL_POSITION,PARAMETER_MODE,PARAMETER_NAME,DATA_TYPE

# 定义一个无参的函数，返回 varchar 类型

DELIMITER //;
CREATE FUNCTION obwmj_f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(sal)=0 INTO a;
	return a;
END;
//
DELIMITER ;//

SELECT obwmj_f_test();
SELECT SPECIFIC_SCHEMA,SPECIFIC_NAME,ORDINAL_POSITION,PARAMETER_MODE,PARAMETER_NAME,DATA_TYPE FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA='obwmjtest' ;
DROP FUNCTION obwmj_f_test;



# 定义一个有参的函数，返回 varchar 类型
DELIMITER //;
CREATE FUNCTION obwmj_f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT  sign(samplename) FROM obwmj_t1 e WHERE sign(sal)=0 INTO a ;
	return a;
END;
//
DELIMITER ;//
SELECT SPECIFIC_SCHEMA,SPECIFIC_NAME,ORDINAL_POSITION,PARAMETER_MODE,PARAMETER_NAME,DATA_TYPE FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA='obwmjtest' ;
DROP FUNCTION obwmj_f_test;


# 定义两个参数的函数，返回int类型
DELIMITER //;
CREATE FUNCTION obwmj_f_test(samplename varchar(200), samplename1 varchar(200))
returns int
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename into a;
	SELECT sign(sal) FROM obwmj_t1 e WHERE sign(e.sal) = samplename1 into b;
	return a+b;
END;
//
DELIMITER ;//
SELECT SPECIFIC_SCHEMA,SPECIFIC_NAME,ORDINAL_POSITION,PARAMETER_MODE,PARAMETER_NAME,DATA_TYPE FROM INFORMATION_SCHEMA.PARAMETERS WHERE SPECIFIC_SCHEMA='obwmjtest' ;
DROP FUNCTION obwmj_f_test;


