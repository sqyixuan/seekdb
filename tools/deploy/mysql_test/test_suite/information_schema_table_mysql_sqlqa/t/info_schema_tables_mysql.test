## TABLE_COLLATION / CHECKSUM

# 更改表列 gbk / utf8 / gb18030 字符集排序，查看 TABLE_COLLATION / CHECKSUM 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20));
INSERT INTO obwmj_t1 VALUES (1,'t1a');
INSERT INTO obwmj_t1 VALUES (2,'t1b');
ALTER TABLE obwmj_t1 change name name varchar(255) character set utf8 collate utf8_general_ci not null;
# SELECT TABLE_NAME, CREATE_TIME, UPDATE_TIME, CHECK_TIME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
ALTER TABLE obwmj_t1 change name name varchar(255) character set gbk collate gbk_chinese_ci not null;
# SELECT TABLE_NAME, CREATE_TIME, UPDATE_TIME, CHECK_TIME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
ALTER TABLE obwmj_t1 change name name varchar(255) character set gb18030 collate gb18030_chinese_ci not null;
# SELECT TABLE_NAME, CREATE_TIME, UPDATE_TIME, CHECK_TIME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t1;


# 建表设置 gb18030，查看 TABLE_COLLATION / CHECKSUM 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20)) character set gb18030 collate gb18030_chinese_ci;
