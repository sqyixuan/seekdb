## INDEX_LENGTH

# 普通表设置 key，查看 INDEX_LENGTH 字段
CREATE TABLE obwmj_t2 (  
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,  
     brand VARCHAR(255) NOT NULL,  
     color ENUM('RED','GREEN','BLUE')
);
INSERT INTO obwmj_t2 VALUES(1, 'vivo', 'GREEN');
INSERT INTO obwmj_t2 VALUES(2,  'OPPO', 'RED');
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t2;


# 普通表设置 unique，查看 INDEX_LENGTH 字段
CREATE TABLE obwmj_t2 (  
     id BIGINT UNSIGNED  unique KEY,  
     brand VARCHAR(255) NOT NULL,  
     color ENUM('RED','GREEN','BLUE')
);
INSERT INTO obwmj_t2 VALUES(1, 'vivo', 'GREEN');
INSERT INTO obwmj_t2 VALUES(2,  'OPPO', 'RED');
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t2;


# 分区表设置 unique，查看 INDEX_LENGTH 字段
CREATE TABLE obwmj_t4(
    a bigint not null unique key,
	b date
)partition by range columns(a) 
( 
	partition part_1 values less than (20),
	partition part_2 values less than (50),
	partition part_3 values less than (100)
);
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t4;


# 视图查看 INDEX_LENGTH 字段
CREATE TABLE obwmj_t55 (a INT UNIQUE KEY , b SET('abc', '中国人民'));
CREATE VIEW obwmj_t55_view AS SELECT * FROM obwmj_t55;
INSERT INTO obwmj_t55 VALUES(1,  'abc');
INSERT INTO obwmj_t55 VALUES(2,  '中国人民');
INSERT INTO obwmj_t55 VALUES(3,  'abc,中国人民');
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, INDEX_LENGTH FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';

DROP TABLE obwmj_t55;
DROP VIEW obwmj_t55_view;



