# 创建视图，更改基础表字符集，查看 TABLE_COLLATION / CHECKSUM 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20)) character set gb18030 collate gb18030_chinese_ci;
CREATE VIEW obwmj_t55_view AS SELECT * FROM obwmj_t1;
# SELECT TABLE_NAME, CREATE_TIME, UPDATE_TIME, CHECK_TIME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
ALTER TABLE obwmj_t1 character set gbk collate gbk_chinese_ci ;
# SELECT TABLE_NAME, CREATE_TIME, UPDATE_TIME, CHECK_TIME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, TABLE_COLLATION, CHECKSUM FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t1;
DROP VIEW obwmj_t55_view;


############################## TEST CASES  ##############################
## CREATE_OPTIONS

# 普通表查看 CREATE_OPTIONS 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20)) ROW_FORMAT DYNAMIC;
INSERT INTO obwmj_t1 VALUES (1,'t1a');
INSERT INTO obwmj_t1 VALUES (2,'t1b');
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t1;


# 分区表查看 CREATE_OPTIONS 字段
CREATE TABLE obwmj_t4(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t4;

CREATE TABLE obwmj_t5(
    a bigint,
	b date
)ROW_FORMAT Compressed partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t5;


# 视图查看 CREATE_OPTIONS 字段
CREATE TABLE obwmj_t55 (a INT, b SET('abc', '中国人民'))COMMENT 'www.baidu.com';
CREATE VIEW obwmj_t55_view AS SELECT * FROM obwmj_t55;
INSERT INTO obwmj_t55 VALUES(1,  'abc');
INSERT INTO obwmj_t55 VALUES(2,  '中国人民');
INSERT INTO obwmj_t55 VALUES(3,  'abc,中国人民');
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t55;
DROP VIEW obwmj_t55_view;



############################## TEST CASES  ##############################
## TABLE_COMMENT

# 普通表，表描述，查看 TABLE_COMMENT 字段
CREATE TABLE obwmj_t1(
	a INT, 
	b VARCHAR(50) 
)comment='表描述';
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t1;


# 普通表，使用段描述，查看 TABLE_COMMENT 字段
CREATE TABLE obwmj_t1(
	a INT, 
	b VARCHAR(50) comment '段描述' 
);
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t1;


# 分区表查看 TABLE_COMMENT 字段
CREATE TABLE obwmj_t4(
    a bigint,
	b date
)comment='www.baidu.com' partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t4;


# 视图查看 TABLE_COMMENT 字段
CREATE TABLE obwmj_t55 (a INT, b SET('abc', '中国人民'))COMMENT 'www.baidu.com';
CREATE VIEW obwmj_t55_view AS SELECT * FROM obwmj_t55;
INSERT INTO obwmj_t55 VALUES(1,  'abc');
INSERT INTO obwmj_t55 VALUES(2,  '中国人民');
INSERT INTO obwmj_t55 VALUES(3,  'abc,中国人民');
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, TABLE_COMMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t55;
DROP VIEW obwmj_t55_view;



############################## TEST CASES  ##############################
## AUTO_INCREMENT

# 普通表设置 AUTO_INCREMENT 约束，查看 AUTO_INCREMENT 字段
CREATE TABLE obwmj_t2 (  
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,  
     brand VARCHAR(255) NOT NULL,  
     color ENUM('RED','GREEN','BLUE')
);
INSERT INTO obwmj_t2 VALUES(1, 'vivo', 'GREEN');
INSERT INTO obwmj_t2 VALUES(2,  'OPPO', 'RED');
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t2;


# 分区表设置 AUTO_INCREMENT 约束，查看 AUTO_INCREMENT 字段
CREATE TABLE obwmj_t4(
    a bigint not null AUTO_INCREMENT key,
	b date
)partition by range columns(a) 
( 
	partition part_1 values less than (20),
	partition part_2 values less than (50),
	partition part_3 values less than (100)
);
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t4;


# 视图查看 AUTO_INCREMENT 字段
CREATE TABLE obwmj_t55 (a INT PRIMARY KEY AUTO_INCREMENT, b SET('abc', '中国人民'));
CREATE VIEW obwmj_t55_view AS SELECT * FROM obwmj_t55;
INSERT INTO obwmj_t55 VALUES(1,  'abc');
INSERT INTO obwmj_t55 VALUES(2,  '中国人民');
INSERT INTO obwmj_t55 VALUES(3,  'abc,中国人民');
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA='obwmjtest' ORDER BY TABLE_NAME;
SELECT TABLE_NAME, CREATE_OPTIONS, AUTO_INCREMENT FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME='TABLES';
DROP TABLE obwmj_t55;
DROP VIEW obwmj_t55_view;



