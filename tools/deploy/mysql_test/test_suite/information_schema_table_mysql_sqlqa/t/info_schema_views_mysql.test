--echo #Environmental cleaning
--disable_warnings
--error 0,1396
DROP USER wmj456@'%';
--ERROR 0,1396
DROP USER TEST_AC@'%';
--error 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
--enable_warnings
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
CREATE USER TEST_AC IDENTIFIED BY 'WMJ456';
GRANT ALL ON *.* TO TEST_AC WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############
--error 0,1051
DROP TABLE obwmj_t1;
--error 0,1051
DROP TABLE obwmj_t9;
--error 0,1051
DROP VIEW obwmj_t1_view;
--error 0,1051
DROP VIEW obwmj_t9_view;
--error 0,1051
DROP VIEW obwmj_t9_view2;
