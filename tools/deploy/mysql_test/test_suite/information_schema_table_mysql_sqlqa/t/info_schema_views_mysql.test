# 视图 + 视图
CREATE TABLE obwmj_t1(
    dd INT,
    name VARCHAR(20)
) PARTITION BY KEY(dd) PARTITIONS 2;
CREATE VIEW obwmj_t1_view AS SELECT * FROM obwmj_t1;
CREATE TABLE obwmj_t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW obwmj_t9_view AS SELECT * FROM obwmj_t9;
CREATE VIEW obwmj_t9_view2 AS SELECT * FROM obwmj_t9_view RIGHT JOIN obwmj_t1_view ON obwmj_t1_view.dd=obwmj_t9_view.id;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view2';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view2';
DROP TABLE obwmj_t1;
DROP TABLE obwmj_t9;
DROP VIEW obwmj_t1_view;
DROP VIEW obwmj_t9_view;
DROP VIEW obwmj_t9_view2;


# 其他视图 + 分区表
CREATE TABLE obwmj_t1(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
CREATE VIEW obwmj_t1_view AS SELECT * FROM obwmj_t1;
CREATE TABLE obwmj_t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW obwmj_t9_view AS SELECT * FROM obwmj_t1_view CROSS JOIN obwmj_t9;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
DROP TABLE obwmj_t1;
