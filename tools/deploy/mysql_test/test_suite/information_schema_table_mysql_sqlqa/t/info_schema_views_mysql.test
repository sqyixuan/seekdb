# 修改表列属性，查看视图
CREATE TABLE obwmj_t9 (  
    id BIGINT UNSIGNED comment 'id number',  
    brand VARCHAR(255) DEFAULT '中国',  
    color int NOT NULL,
	primary key (id,brand)
);
