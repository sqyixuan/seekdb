DROP TEMPORARY TABLE obwmj_t1;




############################## TEST CASES  ##############################
## TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,VIEW_DEFINITION
## TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE
# 普通表视图
CREATE TABLE obwmj_t1(c1 blob(20), c2 LONGBLOB, c3 LONGTEXT);
INSERT INTO obwmj_t1 VALUES('JJII889','XISIDIDIDI','FFFF9909090');
INSERT INTO obwmj_t1 VALUES('998822J','7897979JJJ','9092UUUUIII');
CREATE VIEW obwmj_t1_view AS SELECT * FROM obwmj_t1; 
SELECT TABLE_CATALOG,TABLE_SCHEMA,TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t1_view';
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t1_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t1_view';
DROP TABLE obwmj_t1;
DROP VIEW obwmj_t1_view;


# 普通表 + 普通表
CREATE TABLE obwmj_t1(
    id INT,
    name VARCHAR(20)
) PARTITION BY KEY(id) PARTITIONS 2;
CREATE TABLE obwmj_t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW obwmj_t9_view AS SELECT obwmj_t1.id, obwmj_t9.brand, obwmj_t9.color FROM obwmj_t9,obwmj_t1 ORDER BY obwmj_t1.id;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
DROP TABLE obwmj_t1;
DROP TABLE obwmj_t9;
DROP VIEW obwmj_t9_view;


# 普通表 + 分区表
CREATE TABLE obwmj_t1(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
CREATE TABLE obwmj_t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW obwmj_t9_view AS SELECT * FROM obwmj_t9,obwmj_t1 WHERE obwmj_t1.a=obwmj_t9.id ORDER BY obwmj_t1.a;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
DROP TABLE obwmj_t1;
DROP TABLE obwmj_t9;
DROP VIEW obwmj_t9_view;


# 普通表 + 外键表
CREATE TABLE obwmj_t1(
    a INT AUTO_INCREMENT PRIMARY KEY,
	c_time timestamp,
    d_time varchar(101) GENERATED ALWAYS AS (time_format(c_time,'%k:%i:%s.%f')) 
);
CREATE TABLE obwmj_t9 (  
    id BIGINT UNSIGNED comment 'id number',  
    brand VARCHAR(255) DEFAULT '中国',  
    color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW obwmj_t9_view AS SELECT * FROM obwmj_t1 LEFT JOIN obwmj_t9 ON obwmj_t1.a=obwmj_t9.id;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t9_view';
DROP TABLE obwmj_t1;
DROP TABLE obwmj_t9;
DROP VIEW obwmj_t9_view;


# 不可更新表
CREATE TABLE obwmj_t1( STU_ID INT, LESSON VARCHAR(30), NAME VARCHAR(30), SCORE INT);
INSERT INTO obwmj_t1 VALUES (1,'L1001','小明',90);
INSERT INTO obwmj_t1 VALUES (2,'L1001','小红',50);
INSERT INTO obwmj_t1 VALUES (3,'L1002','小紫',92);
CREATE VIEW obwmj_t1_view AS SELECT DISTINCT STU_ID,LESSON FROM obwmj_t1 GROUP BY LESSON HAVING STU_ID<10;
SELECT TABLE_NAME,VIEW_DEFINITION FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t1_view';
SELECT TABLE_NAME,CHECK_OPTION,IS_UPDATABLE,DEFINER,SECURITY_TYPE FROM INFORMATION_SCHEMA.VIEWS WHERE TABLE_NAME='obwmj_t1_view';
DROP TABLE obwmj_t1;
DROP VIEW obwmj_t1_view;


