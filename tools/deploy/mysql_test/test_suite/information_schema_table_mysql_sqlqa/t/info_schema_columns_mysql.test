## 分区表：验证 CHARACTER_SET_NAME/COLLATION_NAME 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20))PARTITION BY KEY(id) PARTITIONS 2;
INSERT INTO obwmj_t1 VALUES (1,'t1a');
INSERT INTO obwmj_t1 VALUES (2,'t1b');
ALTER TABLE obwmj_t1 change name name varchar(255) character set utf8 collate utf8_general_ci not null;
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,CHARACTER_SET_NAME,COLLATION_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


## 分区表：验证 EXTRA 字段
CREATE TABLE obwmj_t1 (  
     id INT UNSIGNED AUTO_INCREMENT primary key comment 'id number',
     brand VARCHAR(255) NOT NULL,  
     color ENUM('RED','GREEN','BLUE'),
	 b date,
	 d SET('abc', '中国人民'),
	 c_time timestamp(4),
	 d_time varchar(101) GENERATED ALWAYS AS (time_format(c_time,'%k:%i:%s.%f'))
)PARTITION BY KEY(id) PARTITIONS 2;
SELECT TABLE_NAME,COLUMN_NAME,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


