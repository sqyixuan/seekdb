## 分区表，创建不同数据类型表
CREATE TABLE obwmj_t4(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME t_name,COLUMN_NAME c_name,COLUMN_TYPE c_type,DATA_TYPE d_type,CHARACTER_MAXIMUM_LENGTH C_MAX_L,CHARACTER_OCTET_LENGTH C_OCT_L,NUMERIC_PRECISION NUM_P,NUMERIC_SCALE NUM_S,DATETIME_PRECISION DATE_P FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t4';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t4';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,DATA_TYPE,ORDINAL_POSITION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t4';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t4';
DROP TABLE obwmj_t4;


