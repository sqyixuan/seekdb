## 创建不同数据类型表 / 查看 information 表 
CREATE TABLE obwmj_t1(c1 blob(20), c2 LONGBLOB, c3 LONGTEXT);
INSERT INTO obwmj_t1 VALUES('JJII889','XISIDIDIDI','FFFF9909090');
INSERT INTO obwmj_t1 VALUES('998822J','7897979JJJ','9092UUUUIII');
SELECT TABLE_CATALOG, TABLE_SCHEMA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1' ;
SELECT TABLE_SCHEMA, TABLE_NAME,COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME t_name,COLUMN_NAME c_name,COLUMN_TYPE c_type,DATA_TYPE d_type,CHARACTER_MAXIMUM_LENGTH C_MAX_L,CHARACTER_OCTET_LENGTH C_OCT_L,NUMERIC_PRECISION NUM_P,NUMERIC_SCALE NUM_S,DATETIME_PRECISION DATE_P FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,DATA_TYPE,ORDINAL_POSITION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME,COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='COLUMNS';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,DATA_TYPE,CHARACTER_MAXIMUM_LENGTH C_MAX_L,CHARACTER_OCTET_LENGTH C_OCT_L,NUMERIC_PRECISION NUM_P,NUMERIC_SCALE NUM_S,DATETIME_PRECISION DATE_P FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='COLUMNS';
DROP TABLE obwmj_t1;


