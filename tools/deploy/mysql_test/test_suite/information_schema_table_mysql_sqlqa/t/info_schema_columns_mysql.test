SELECT TABLE_NAME,COLUMN_NAME,COLUMN_COMMENT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


## 无主键，多列索引
CREATE TABLE obwmj_t1 (  
    id BIGINT UNSIGNED,  
    brand VARCHAR(255) ,  
    color int,
	unique key unique_brand(id,brand)
);
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_TYPE,CHARACTER_SET_NAME,COLLATION_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_KEY,IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,PRIVILEGES FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_COMMENT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
SELECT TABLE_NAME,COLUMN_NAME,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


