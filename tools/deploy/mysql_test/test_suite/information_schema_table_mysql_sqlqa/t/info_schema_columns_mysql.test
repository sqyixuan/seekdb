## 分区表：验证 COLUMN_KEY 字段
CREATE TABLE obwmj_t1(a INT , b VARCHAR(50) primary key ) PARTITION BY LIST columns(b)(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_KEY,IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


CREATE TABLE obwmj_t1 (  
    id BIGINT UNSIGNED DEFAULT 0,  
    brand VARCHAR(255) DEFAULT 33,  
    color int(7) NOT NULL,
	unique key unique_brand(id,brand)
)PARTITION BY KEY(id) PARTITIONS 2;
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_KEY,IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


CREATE TABLE obwmj_t1(
    a bigint,
	b date unique
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME,COLUMN_NAME,COLUMN_KEY,IS_NULLABLE FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='obwmj_t1';
DROP TABLE obwmj_t1;


