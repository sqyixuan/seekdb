SELECT TRIGGER_NAME,TRIGGER_SCHEMA,EVENT_MANIPULATION,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
SELECT TRIGGER_NAME,TRIGGER_SCHEMA,EVENT_MANIPULATION,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo2';
