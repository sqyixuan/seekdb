--echo #Environmental cleaning
--disable_warnings
--error 0,1396
DROP USER wmj456@'%';
--ERROR 0,1396
DROP USER TEST_AC@'%';
--error 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;

--error 0,1008
DROP DATABASE obwmj_ac;
CREATE DATABASE obwmj_ac;

--enable_warnings
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
CREATE USER TEST_AC IDENTIFIED BY 'WMJ456';
GRANT ALL ON *.* TO TEST_AC WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############
--error 0,1051
DROP TABLE obwmj_t2;
--error 0,1051
DROP TABLE obwmj_t3;
--error 0,1051
DROP TABLE `obwmj_ac`.`obwmj_t2`;

CREATE TABLE obwmj_t2(c3 timestamp);
INSERT INTO obwmj_t2 VALUES('2020-01-13 21:29:31');
CREATE TABLE obwmj_t3(d1 varchar(20));


############################## TEST CASES  ##############################
## TRIGGER_CATALOG,TRIGGER_SCHEMA,TRIGGER_NAME,EVENT_MANIPULATION,EVENT_OBJECT_CATALOG,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER

# INSERT 触发器
DELIMITER //;
CREATE TRIGGER obwmj_demo BEFORE INSERT ON obwmj_t2 FOR EACH ROW
BEGIN
	INSERT INTO obwmj_t3 VALUES(new.c3);
END;
//
DELIMITER ;//
INSERT INTO obwmj_t2 VALUES ('1990-03-23 21:29:31');
SELECT * FROM obwmj_t3;
SELECT TRIGGER_CATALOG,TRIGGER_SCHEMA,TRIGGER_NAME,EVENT_MANIPULATION,EVENT_OBJECT_CATALOG,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
DROP TRIGGER obwmj_demo;


# UPDATE 触发器
DELIMITER //;
CREATE TRIGGER obwmj_demo BEFORE UPDATE ON obwmj_t2 FOR EACH ROW
BEGIN
	SET NEW.C3='2022-01-13 21:29:31';
END;
//
DELIMITER ;//
TRUNCATE TABLE obwmj_t2;
INSERT INTO obwmj_t2 VALUES ('1990-03-23 21:29:31');
INSERT INTO obwmj_t2 VALUES ('1991-03-23 21:29:31');
UPDATE obwmj_t2 SET C3='2000-03-23 21:29:31' WHERE C3='1991-03-23 21:29:31';
SELECT * FROM obwmj_t2;
SELECT TRIGGER_CATALOG,TRIGGER_SCHEMA,TRIGGER_NAME,EVENT_MANIPULATION,EVENT_OBJECT_CATALOG,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
DROP TRIGGER obwmj_demo;


# DELETE 触发器
DELIMITER //;
CREATE TRIGGER obwmj_demo BEFORE DELETE ON obwmj_t2 FOR EACH ROW
BEGIN
	INSERT INTO obwmj_t3 VALUES(old.c3);
END;
//
DELIMITER ;//
TRUNCATE TABLE obwmj_t2;
INSERT INTO obwmj_t2 VALUES ('1990-03-23 21:29:31');
INSERT INTO obwmj_t2 VALUES ('1991-03-23 21:29:31');
DELETE FROM obwmj_t2 WHERE C3='1991-03-23 21:29:31';
SELECT * FROM obwmj_t2;
SELECT * FROM obwmj_t3;
TRUNCATE TABLE obwmj_t3;
SELECT TRIGGER_CATALOG,TRIGGER_SCHEMA,TRIGGER_NAME,EVENT_MANIPULATION,EVENT_OBJECT_CATALOG,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
DROP TRIGGER obwmj_demo;
DROP TABLE `obwmj_t2`;
DROP TABLE obwmj_t3;


# 不同数据库
# DELETE 触发器
CREATE TABLE `obwmj_ac`.`obwmj_t2`(c3 timestamp);
INSERT INTO `obwmj_ac`.`obwmj_t2` VALUES('2020-01-13 21:29:31');
CREATE TABLE `obwmj_ac`.obwmj_t3(d1 varchar(20));
DELIMITER //;
CREATE TRIGGER `obwmj_ac`.obwmj_demo BEFORE DELETE ON `obwmj_ac`.`obwmj_t2` FOR EACH ROW
BEGIN
	INSERT INTO `obwmj_ac`.obwmj_t3 VALUES(old.c3);
END;
//
DELIMITER ;//
TRUNCATE TABLE `obwmj_ac`.`obwmj_t2`;
INSERT INTO `obwmj_ac`.`obwmj_t2` VALUES ('1990-03-23 21:29:31');
INSERT INTO `obwmj_ac`.`obwmj_t2` VALUES ('1991-03-23 21:29:31');
DELETE FROM `obwmj_ac`.`obwmj_t2` WHERE C3='1991-03-23 21:29:31';
SELECT * FROM `obwmj_ac`.`obwmj_t2`;
SELECT * FROM `obwmj_ac`.obwmj_t3;
TRUNCATE TABLE `obwmj_ac`.obwmj_t3;

SELECT TRIGGER_NAME,TRIGGER_SCHEMA,EVENT_MANIPULATION,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
DROP TRIGGER `obwmj_ac`.obwmj_demo;
DROP TABLE `obwmj_ac`.`obwmj_t2`;
DROP TABLE `obwmj_ac`.obwmj_t3;


# 触发器内使用不同数据库表
# DELETE 触发器
CREATE TABLE `obwmj_t2`(c3 timestamp);
INSERT INTO `obwmj_t2` VALUES('2020-01-13 21:29:31');
CREATE TABLE `obwmj_ac`.obwmj_t3(d1 varchar(20));
DELIMITER //;
CREATE TRIGGER obwmj_demo BEFORE DELETE ON `obwmj_t2` FOR EACH ROW
BEGIN
	INSERT INTO `obwmj_ac`.obwmj_t3 VALUES(old.c3);
END;
//
DELIMITER ;//
TRUNCATE TABLE `obwmj_t2`;
INSERT INTO `obwmj_t2` VALUES ('1990-03-23 21:29:31');
INSERT INTO `obwmj_t2` VALUES ('1991-03-23 21:29:31');
DELETE FROM `obwmj_t2` WHERE C3='1991-03-23 21:29:31';

SELECT * FROM `obwmj_t2`;
SELECT * FROM `obwmj_ac`.obwmj_t3;
TRUNCATE TABLE `obwmj_ac`.obwmj_t3;
SELECT TRIGGER_NAME,TRIGGER_SCHEMA,EVENT_MANIPULATION,EVENT_OBJECT_SCHEMA,EVENT_OBJECT_TABLE,ACTION_ORDER FROM INFORMATION_SCHEMA.TRIGGERS WHERE TRIGGER_NAME='obwmj_demo';
DROP TRIGGER obwmj_demo;
DROP TABLE `obwmj_t2`;
DROP TABLE `obwmj_ac`.obwmj_t3;


# ACTION_ORDER
# INSERT 触发器 BEFORE
CREATE TABLE obwmj_t2(c3 timestamp);
