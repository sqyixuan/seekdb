CREATE TABLE obwmj_t3(d1 varchar(20));
INSERT INTO obwmj_t3 VALUES('第一行');
INSERT INTO obwmj_t3 VALUES('第二行');

DELIMITER //;
CREATE TRIGGER obwmj_demo BEFORE INSERT ON obwmj_t2 FOR EACH ROW
BEGIN
	INSERT INTO obwmj_t3 VALUES(new.c3);
END;
//

--ERROR 0,1235
CREATE TRIGGER obwmj_demo2 BEFORE INSERT ON obwmj_t2 FOR EACH ROW
BEGIN
	INSERT INTO obwmj_t3 VALUES(new.c3);
END;
//
DELIMITER ;//

INSERT INTO obwmj_t2 VALUES ('1990-03-23 21:29:31');
