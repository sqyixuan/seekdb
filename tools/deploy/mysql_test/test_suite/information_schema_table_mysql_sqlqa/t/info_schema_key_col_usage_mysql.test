## CONSTRAINT_CATALOG,CONSTRAINT_SCHEMA,CONSTRAINT_NAME

--echo #主键，非空，唯一
CREATE TABLE obwmj_t1 (  
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,  
     brand VARCHAR(255) NOT NULL,  
     color int unique
);
SELECT CONSTRAINT_CATALOG,CONSTRAINT_SCHEMA,CONSTRAINT_NAME FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE WHERE TABLE_NAME='obwmj_t1'; 
DROP TABLE obwmj_t1;


--echo #无主键，非空，唯一
CREATE TABLE obwmj_t1 (  
     id BIGINT UNSIGNED,  
     brand VARCHAR(255) NOT NULL,  
     color int unique
);
SELECT CONSTRAINT_CATALOG,CONSTRAINT_SCHEMA,CONSTRAINT_NAME FROM INFORMATION_SCHEMA.KEY_COLUMN_USAGE WHERE TABLE_NAME='obwmj_t1'; 
DROP TABLE obwmj_t1;


--echo #无主键，非空唯一
