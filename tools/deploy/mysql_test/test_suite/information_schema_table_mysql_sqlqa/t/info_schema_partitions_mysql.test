## DATA_FREE / CREATE_TIME / UPDATE_TIME / CHECK_TIME / CHECKSUM

# 创建 LIST 分区表，查看 CREATE_TIME / UPDATE_TIME / CHECK_TIME 时间
CREATE TABLE obwmj_t5(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
INSERT INTO obwmj_t5 VALUES(1,'中国\人民');
