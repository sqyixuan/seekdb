# DML操作后，查看 CREATE_TIME / UPDATE_TIME / CHECK_TIME 时间
CREATE TABLE obwmj_t5(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_NAME SUB_NAME, DATA_FREE,UPDATE_TIME,CHECK_TIME,CHECKSUM FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_NAME, SUBPARTITION_NAME SUB_NAME, TABLE_ROWS T_ROWS, AVG_ROW_LENGTH A_R_LEN, DATA_LENGTH D_L, MAX_DATA_LENGTH M_D_L, INDEX_LENGTH IDX_L FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_NAME='PARTITIONS';

