############################## TEST CASES  ##############################
## TABLE_CATALOG / TABLE_SCHEMA / TABLE_NAME / PARTITION_NAME / SUBPARTITION_NAME

# 普通表，查看 TABLE_CATALOG / TABLE_SCHEMA / TABLE_NAME 字段
CREATE TABLE obwmj_t1 (id int NOT NULL, name varchar(20));
INSERT INTO obwmj_t1 VALUES (1,'t1a');
INSERT INTO obwmj_t1 VALUES (2,'t1b');
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t1;


# 创建 RANGE 分区表，查看 TABLE_CATALOG / TABLE_SCHEMA / TABLE_NAME / PARTITION_NAME / SUBPARTITION_NAME 字段
CREATE TABLE obwmj_t4(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
# 创建 RANGE 分区表
CREATE TABLE obwmj_t5(
    a bigint not null AUTO_INCREMENT key,
	b date
)partition by range columns(a) 
( 
	partition part_1 values less than (20),
	partition part_2 values less than (50),
	partition part_3 values less than (100)
);
INSERT INTO obwmj_t5 VALUES(1,'2013-08-01');
INSERT INTO obwmj_t5 VALUES(2,'2019-10-11');
# 创建 RANGE - HASH 分区表
CREATE TABLE obwmj_t6(
    a bigint,
	b datetime
)partition by range columns(b) SUBPARTITION by HASH(a) subpartitions 2
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t4;
DROP TABLE obwmj_t5;
DROP TABLE obwmj_t6;


# 创建 LIST 分区 / HASH 分区 / KEY 分区
CREATE TABLE obwmj_t4(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
CREATE TABLE obwmj_t5 (col1 INT, col2 CHAR(5), col3 DATE) PARTITION BY HASH( YEAR(col3)) PARTITIONS 4;
CREATE TABLE obwmj_t6 ( id INT, name VARCHAR(20)) PARTITION BY KEY(id) PARTITIONS 2;
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t4;
DROP TABLE obwmj_t5;
DROP TABLE obwmj_t6;


# LIST - HASH /  LIST - KEY 
CREATE TABLE obwmj_t4(
  JOB CHAR(9),
  SAL int(7)
)PARTITION BY LIST COLUMNS(JOB) SUBPARTITION BY hash (SAL) SUBPARTITIONS 2(
  PARTITION p1 VALUES IN('ABC')
);
CREATE TABLE obwmj_t5(
	a INT , 
	b VARCHAR(50) PRIMARY KEY, 
	c VARCHAR(50) 
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
	PARTITION p0 VALUES IN ('abc\def','中国\人民')
);
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t4;
DROP TABLE obwmj_t5;


