## SUBPARTITION_METHOD / PARTITION_EXPRESSION / SUBPARTITION_EXPRESSION / PARTITION_DESCRIPTION
# LIST - HASH /  LIST - KEY 
CREATE TABLE obwmj_t4(
  JOB int,
  SAL date
)PARTITION BY LIST (ABS(JOB)) SUBPARTITION BY hash (TO_DAYS(SAL)) SUBPARTITIONS 2(
  PARTITION p1 VALUES IN(1000,2000,3000,4000)
);
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t4;


CREATE TABLE obwmj_t5(
	a INT PRIMARY KEY, 
	b VARCHAR(50) , 
	c VARCHAR(50) 
)PARTITION BY LIST(ABS(A)) SUBPARTITION BY KEY (A) SUBPARTITIONS 2(
	PARTITION p0 VALUES IN (1,2,3,4)
);
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t5;


# 创建 RANGE - HASH 分区表
CREATE TABLE obwmj_t6(
    a bigint,
	b datetime
)partition by RANGE (YEAR(b)) SUBPARTITION by HASH(ABS(a)) subpartitions 2
( 
	partition part_1 values less than (2016),
	partition part_2 values less than (2020),
	partition part_3 values less than (2021)
);
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t6;


# 创建 RANGE - KEY 分区表
CREATE TABLE obwmj_t4(
	a bigint,
	b datetime
)PARTITION BY RANGE(YEAR(b)) SUBPARTITION BY key(a) subpartitions 2
( 
	partition part_1 values less than (2016),
	partition part_2 values less than (2020),
	partition part_3 values less than (2021)
);
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_SCHEMA='obwmjtest' ORDER BY 1,2,3,4,5;
SELECT TABLE_NAME, PARTITION_NAME p_name, SUBPARTITION_METHOD sub_mth, PARTITION_EXPRESSION p_ep, SUBPARTITION_EXPRESSION sub_ep, PARTITION_DESCRIPTION p_desc FROM INFORMATION_SCHEMA.PARTITIONS  WHERE TABLE_NAME='PARTITIONS';
DROP TABLE obwmj_t4;


