grant Index on obwmjtest.obwmj_t8 to wmj456;
grant Insert on obwmjtest.obwmj_t9 to wmj456;
grant Select on obwmjtest.obwmj_t11 to wmj456;
grant Update on `obwmj_ac`.`obwmj_t12` to obwmj_ac;

SELECT * FROM INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA='obwmjtest';
SELECT * FROM INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA='obwmj_ac';

DROP TABLE obwmjtest.obwmj_t1;
DROP TABLE obwmjtest.obwmj_t2;
