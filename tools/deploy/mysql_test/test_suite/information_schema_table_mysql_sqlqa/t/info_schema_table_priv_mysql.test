drop user obwmj_ac@'%';
--error 0,1008
DROP DATABASE obwmjtest;
CREATE DATABASE obwmjtest;
--error 0,1008
DROP DATABASE obwmj_ac;
CREATE DATABASE obwmj_ac;
--enable_warnings

CREATE USER wmj456 IDENTIFIED BY 'wmj456';
CREATE USER obwmj_ac IDENTIFIED BY 'obwmj_ac';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
CREATE USER TEST_AC IDENTIFIED BY 'WMJ456';
GRANT ALL ON *.* TO TEST_AC WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


