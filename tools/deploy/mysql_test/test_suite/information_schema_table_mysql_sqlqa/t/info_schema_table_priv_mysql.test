############################## TEST CASES  ##############################
## INFORMATION_SCHEMA.TABLE_PRIVILEGES：TABLE_NAME,TABLE_SCHEMA,TABLE_CATALOG,PRIVILEGE_TYPE
# 连接普通用户
create table obwmj_t1(a int, b int, c int, d varchar(20));
create table obwmj_t2(a int, b int, c int, d varchar(20));
create table obwmj_t3(a int, b int, c int, d varchar(20));
create table obwmj_t4(a int, b int, c int, d varchar(20));
create table obwmj_t5(a int, b int, c int, d varchar(20));
create table obwmj_t6(a int, b int, c int, d varchar(20));
create table obwmj_t7(a int, b int, c int, d varchar(20));
create table obwmj_t8(a int, b int, c int, d varchar(20));
create table obwmj_t9(a int, b int, c int, d varchar(20));
create table obwmj_t10(a int, b int, c int, d varchar(20));
create table obwmj_t11(a int, b int, c int, d varchar(20));
create table `obwmj_ac`.`obwmj_t12`(a int, b int, c int, d varchar(20));

grant Alter on obwmjtest.obwmj_t1 to wmj456;
grant Create on obwmjtest.obwmj_t2 to wmj456;
grant CREATE VIEW on obwmjtest.obwmj_t3 to wmj456;
grant Delete on obwmjtest.obwmj_t5 to wmj456;
grant Drop on obwmjtest.obwmj_t6 to wmj456;
