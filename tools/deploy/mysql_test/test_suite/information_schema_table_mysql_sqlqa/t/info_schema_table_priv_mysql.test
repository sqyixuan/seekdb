## INFORMATION_SCHEMA.TABLE_PRIVILEGES：IS_GRANTABLE,GRANTEE
# 连接普通用户
REVOKE Alter on obwmjtest.obwmj_t1 from wmj456;
REVOKE Create on obwmjtest.obwmj_t2 from wmj456;
REVOKE CREATE VIEW on obwmjtest.obwmj_t3 from wmj456;
REVOKE Delete on obwmjtest.obwmj_t5 from wmj456;
REVOKE Drop on obwmjtest.obwmj_t6 from wmj456;
REVOKE Grant option on obwmjtest.obwmj_t7 from wmj456;
REVOKE Index on obwmjtest.obwmj_t8 from wmj456;
REVOKE Insert on obwmjtest.obwmj_t9 from wmj456;
REVOKE Select on obwmjtest.obwmj_t11 from wmj456;
REVOKE Update on `obwmj_ac`.`obwmj_t12` from obwmj_ac;

create table obwmjtest.obwmj_t1(a int, b int, c int, d varchar(20));
create table obwmjtest.obwmj_t2(a int, b int, c int, d varchar(20));
create table obwmjtest.obwmj_t3(a int, b int, c int, d varchar(20));
grant Alter on obwmjtest.obwmj_t1 to wmj456 WITH GRANT OPTION;
grant Insert on obwmjtest.obwmj_t2 to wmj456 WITH GRANT OPTION;
grant Update on obwmjtest.obwmj_t3 to wmj456 WITH GRANT OPTION;
SELECT * FROM INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA='obwmjtest';
REVOKE Alter on obwmjtest.obwmj_t1 from wmj456;
REVOKE Insert on obwmjtest.obwmj_t2 from wmj456;
REVOKE Update on obwmjtest.obwmj_t3 from wmj456;
DROP TABLE obwmjtest.obwmj_t1;
DROP TABLE obwmjtest.obwmj_t2;
DROP TABLE obwmjtest.obwmj_t3;


############################## TEST CASES  ##############################
## INFORMATION_SCHEMA.TABLE_PRIVILEGES：GRANTEE
# 连接root账户
sleep 3;
connection default;
sleep 2;

DROP USER wmj456@'%';
DROP USER TEST_AC@'%';

CREATE USER wmj456@'localhost' IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456@'localhost' WITH GRANT OPTION;
create table obwmjtest.obwmj_t1(a int, b int, c int, d varchar(20));
grant Insert on obwmjtest.obwmj_t1 to wmj456@'localhost' WITH GRANT OPTION;
SELECT * FROM INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA='obwmjtest';
revoke Insert on  obwmjtest.obwmj_t1 from wmj456@'localhost';
DROP TABLE obwmjtest.obwmj_t1;


DROP USER wmj456@'localhost';
CREATE USER wmj456@'192.168._%' IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456@'192.168._%' WITH GRANT OPTION;
create table obwmjtest.obwmj_t1(a int, b int, c int, d varchar(20));
grant Insert on obwmjtest.obwmj_t1 to wmj456@'192.168._%' WITH GRANT OPTION;
SELECT * FROM INFORMATION_SCHEMA.TABLE_PRIVILEGES WHERE TABLE_SCHEMA='obwmjtest';
revoke Insert on  obwmjtest.obwmj_t1 from wmj456@'192.168._%';
DROP TABLE obwmjtest.obwmj_t1;


DROP USER wmj456@'192.168._%';
--ERROR 0,1396
CREATE USER ''@'%' IDENTIFIED BY 'WMJ456';
--ERROR 0,1064
CREATE USER 'wmj456'@'*' IDENTIFIED BY 'WMJ456';



############################## TEST CASES  ##############################
## INFORMATION_SCHEMA.USER_PRIVILEGES：PRIVILEGE_TYPE
# 连接root账户
CREATE USER wmj456@'%' IDENTIFIED BY 'wmj456';

GRANT SELECT ON *.* TO wmj456@'%' WITH GRANT OPTION;
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE SELECT ON *.* FROM wmj456@'%';
REVOKE GRANT OPTION ON *.* FROM wmj456@'%';

GRANT ALTER ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE ALTER ON *.* FROM wmj456@'%';

GRANT CREATE ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE CREATE ON *.* FROM wmj456@'%';

GRANT CREATE VIEW ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE CREATE VIEW ON *.* FROM wmj456@'%';

GRANT UPDATE ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE UPDATE ON *.* FROM wmj456@'%';

GRANT INDEX ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE INDEX ON *.* FROM wmj456@'%';

GRANT INSERT ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE INSERT ON *.* FROM wmj456@'%';

GRANT DROP ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE DROP ON *.* FROM wmj456@'%';

GRANT DELETE ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE DELETE ON *.* FROM wmj456@'%';

GRANT CREATE USER ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE CREATE USER ON *.* FROM wmj456@'%';

GRANT Process ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE Process ON *.* FROM wmj456@'%';

GRANT Show databases ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE Show databases ON *.* FROM wmj456@'%';

GRANT Show view ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE Show view ON *.* FROM wmj456@'%';

GRANT Super ON *.* TO wmj456@'%';
SELECT * FROM INFORMATION_SCHEMA.USER_PRIVILEGES WHERE GRANTEE LIKE '%wmj456%';
REVOKE Super ON *.* FROM wmj456@'%';


