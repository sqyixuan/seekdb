drop database if exists db_diff_heap;
drop database if exists db_diff_heap2;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. HEAP 表基本 DIFF - 冲突、current独有、incoming独有
============================================
create database db_diff_heap;
use db_diff_heap;
create table t_cur (
id int primary key,
name varchar(20),
score int
) ORGANIZATION = HEAP;
create table t_inc (
id int primary key,
name varchar(20),
score int
) ORGANIZATION = HEAP;
insert into t_cur values (1, 'Alice', 80);
insert into t_cur values (2, 'Bob', 90);
insert into t_cur values (3, 'Charlie', 70);
insert into t_inc values (1, 'Alice', 85);
insert into t_inc values (3, 'Charlie', 70);
insert into t_inc values (4, 'David', 95);
# id=1: 冲突(score 80 vs 85); id=2: current独有; id=3: 相同不输出; id=4: incoming独有
diff table db_diff_heap.t_inc against db_diff_heap.t_cur;
__table	__flag	id	name	score
db_diff_heap.t_cur	INSERT	1	Alice	80
db_diff_heap.t_inc	INSERT	1	Alice	85
db_diff_heap.t_cur	INSERT	2	Bob	90
db_diff_heap.t_inc	INSERT	4	David	95
============================================
2. HEAP 表完全相同 - 无输出行
============================================
create table t_same1 (id int primary key, v int) ORGANIZATION = HEAP;
create table t_same2 (id int primary key, v int) ORGANIZATION = HEAP;
insert into t_same1 values (1, 100), (2, 200);
insert into t_same2 values (1, 100), (2, 200);
diff table db_diff_heap.t_same1 against db_diff_heap.t_same2;
__table	__flag	id	v
============================================
3. HEAP 表空表 DIFF
============================================
create table t_empty1 (id int primary key, x int) ORGANIZATION = HEAP;
create table t_empty2 (id int primary key, x int) ORGANIZATION = HEAP;
diff table db_diff_heap.t_empty1 against db_diff_heap.t_empty2;
__table	__flag	id	x
============================================
4. HEAP 表 NULL 值处理
============================================
create table t_null1 (id int primary key, v1 int, v2 varchar(20)) ORGANIZATION = HEAP;
create table t_null2 (id int primary key, v1 int, v2 varchar(20)) ORGANIZATION = HEAP;
insert into t_null1 values (1, NULL, 'a'), (2, 10, NULL), (3, NULL, NULL);
insert into t_null2 values (1, NULL, 'a'), (2, 10, 'b'), (3, NULL, NULL);
# id=1: 相同不输出; id=2: 冲突(NULL vs 'b'); id=3: 相同不输出
diff table db_diff_heap.t_null2 against db_diff_heap.t_null1;
__table	__flag	id	v1	v2
db_diff_heap.t_null1	INSERT	2	10	NULL
db_diff_heap.t_null2	INSERT	2	10	b
============================================
5. HEAP 表复合主键
============================================
create table t_cpk1 (a int, b int, v int, primary key(a, b)) ORGANIZATION = HEAP;
create table t_cpk2 (a int, b int, v int, primary key(a, b)) ORGANIZATION = HEAP;
insert into t_cpk1 values (1, 1, 100), (1, 2, 200), (2, 1, 300);
insert into t_cpk2 values (1, 1, 100), (1, 2, 999), (2, 2, 400);
# (1,1): 相同; (1,2): 冲突; (2,1): current独有; (2,2): incoming独有
diff table db_diff_heap.t_cpk2 against db_diff_heap.t_cpk1;
__table	__flag	a	b	v
db_diff_heap.t_cpk1	INSERT	1	2	200
db_diff_heap.t_cpk2	INSERT	1	2	999
db_diff_heap.t_cpk1	INSERT	2	1	300
db_diff_heap.t_cpk2	INSERT	2	2	400
============================================
6. HEAP 表跨库 DIFF
============================================
create database db_diff_heap2;
use db_diff_heap2;
create table t_cross (id int primary key, name varchar(20), score int) ORGANIZATION = HEAP;
insert into t_cross values (1, 'Alice', 80), (5, 'Eve', 88);
use db_diff_heap;
diff table db_diff_heap.t_inc against db_diff_heap2.t_cross;
__table	__flag	id	name	score
db_diff_heap.t_inc	INSERT	1	Alice	85
db_diff_heap2.t_cross	INSERT	1	Alice	80
db_diff_heap.t_inc	INSERT	3	Charlie	70
db_diff_heap.t_inc	INSERT	4	David	95
db_diff_heap2.t_cross	INSERT	5	Eve	88
============================================
7. HEAP 表自引用 DIFF - 同表应返回空结果
============================================
diff table db_diff_heap.t_cur against db_diff_heap.t_cur;
__table	__flag	id	name	score
============================================
8. 清理
============================================
drop database if exists db_diff_heap;
drop database if exists db_diff_heap2;
