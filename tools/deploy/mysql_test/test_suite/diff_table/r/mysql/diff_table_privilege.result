drop database if exists db_diff_priv;
drop user if exists diff_nopriv;
drop user if exists diff_sel_inc;
drop user if exists diff_sel_cur;
drop user if exists diff_sel_both;
drop user if exists diff_insupd;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
Setup - 创建测试库、表和数据
============================================
create database db_diff_priv;
use db_diff_priv;
create table t_cur (id int primary key, v int);
create table t_inc (id int primary key, v int);
insert into t_cur values (1, 10), (2, 20);
insert into t_inc values (1, 11), (3, 30);
============================================
1. 无权限用户执行 DIFF TABLE - 预期失败
============================================
create user diff_nopriv identified by 'test123';
grant create on db_diff_priv.* to diff_nopriv;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
ERROR 42000: SELECT command denied
============================================
2. 仅对 incoming 表有 SELECT 权限 - 预期失败
============================================
create user diff_sel_inc identified by 'test123';
grant select on db_diff_priv.t_inc to diff_sel_inc;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
ERROR 42000: SELECT command denied
============================================
3. 仅对 current 表有 SELECT 权限 - 预期失败
============================================
create user diff_sel_cur identified by 'test123';
grant select on db_diff_priv.t_cur to diff_sel_cur;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
ERROR 42000: SELECT command denied
============================================
4. 两表均有 SELECT 权限 - 预期成功
============================================
create user diff_sel_both identified by 'test123';
grant select on db_diff_priv.t_cur to diff_sel_both;
grant select on db_diff_priv.t_inc to diff_sel_both;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
__table	__flag	id	v
db_diff_priv.t_cur	INSERT	1	10
db_diff_priv.t_inc	INSERT	1	11
db_diff_priv.t_cur	INSERT	2	20
db_diff_priv.t_inc	INSERT	3	30
============================================
5. 仅 INSERT+UPDATE 权限（无 SELECT）- 预期失败
============================================
create user diff_insupd identified by 'test123';
grant insert, update on db_diff_priv.t_cur to diff_insupd;
grant insert, update on db_diff_priv.t_inc to diff_insupd;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
ERROR 42000: SELECT command denied
============================================
6. 补授 SELECT 权限后立即生效 - 预期成功
============================================
grant select on db_diff_priv.t_cur to diff_insupd;
grant select on db_diff_priv.t_inc to diff_insupd;
diff table db_diff_priv.t_inc against db_diff_priv.t_cur;
__table	__flag	id	v
db_diff_priv.t_cur	INSERT	1	10
db_diff_priv.t_inc	INSERT	1	11
db_diff_priv.t_cur	INSERT	2	20
db_diff_priv.t_inc	INSERT	3	30
============================================
7. 清理
============================================
drop user diff_nopriv;
drop user diff_sel_inc;
drop user diff_sel_cur;
drop user diff_sel_both;
drop user diff_insupd;
drop database if exists db_diff_priv;
