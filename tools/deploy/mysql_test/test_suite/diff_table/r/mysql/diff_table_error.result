drop database if exists db_diff_err;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 错误场景 - incoming 表不存在
============================================
create database db_diff_err;
use db_diff_err;
create table t_inc (id int primary key, v int);
diff table db_diff_err.non_existent_t against db_diff_err.t_inc;
ERROR 42S02: Table doesn't exist
============================================
2. 错误场景 - current 表不存在
============================================
create table t_cur (id int primary key, v int);
diff table db_diff_err.t_cur against db_diff_err.non_existent_t;
ERROR 42S02: Table doesn't exist
============================================
3. 错误场景 - 数据库不存在
============================================
diff table no_such_db.t_cur against db_diff_err.t_inc;
ERROR 42S02: Table doesn't exist
============================================
4. 错误场景 - 无主键表
============================================
create table t_no_pk (id int, v int);
create table t_has_pk (id int primary key, v int);
insert into t_no_pk values (1, 1);
insert into t_has_pk values (1, 1);
diff table db_diff_err.t_no_pk against db_diff_err.t_has_pk;
ERROR HY000: Schema error
============================================
5. 错误场景 - 列定义不一致（列数不同）
============================================
create table t_col3 (id int primary key, a int, b int);
create table t_col4 (id int primary key, a int, b int, c int);
insert into t_col3 values (1, 10, 20);
insert into t_col4 values (1, 10, 20, 30);
diff table db_diff_err.t_col3 against db_diff_err.t_col4;
ERROR HY000: Schema error
============================================
6. 错误场景 - 列名不一致
============================================
create table t_name1 (id int primary key, a int);
create table t_name2 (id int primary key, b int);
diff table db_diff_err.t_name2 against db_diff_err.t_name1;
ERROR HY000: Schema error
============================================
7. 错误场景 - 列类型不一致
============================================
create table t_type1 (id int primary key, v int);
create table t_type2 (id int primary key, v varchar(20));
diff table db_diff_err.t_type2 against db_diff_err.t_type1;
ERROR HY000: Schema error
============================================
8. 错误场景 - 列长度不一致
============================================
create table t_len1 (id int primary key, v varchar(20));
create table t_len2 (id int primary key, v varchar(30));
diff table db_diff_err.t_len2 against db_diff_err.t_len1;
ERROR HY000: Schema error
============================================
9. 清理
============================================
drop database if exists db_diff_err;
