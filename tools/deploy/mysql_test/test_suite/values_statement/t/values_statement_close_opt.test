##########################################################################################################
##
##test values statement in view
##
##########################################################################################################

--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10);

create or replace view v1 as values row(1,2), row(3,3), row(4,4);

select * from v1;

create or replace view v1 as select t1.c1, t2.c2 from t1, (values row(1,2,3), row(4,5,6), row(100, 100, 100)) AS t2(c1,c2,c3) where t1.c1=t2.c1;

select * from v1;

create or replace view v1 as values row(1, -2, 'oceanbase'), row('a', 5, '蚂蚁集团'), row('222asda', 8, date'2020-12-01');

select * from v1;

create or replace view v1 as VALUES ROW("q", 42, '2019-12-18'), ROW(23, "abc", 98.6), ROW(27.0002, "Mary Smith", '{"a": 10, "b": 25}');

select * from v1;

drop table t1;
drop view v1;
##########################################################################################################
##
##test values statement with PL
##
##########################################################################################################

--disable_warnings
drop table if exists t1;
drop procedure if exists test_proc;
--enable_warnings

create table t1(c1 int, c2 varchar(10));

delimiter //;

create procedure test_proc(x int, y char(10))
begin
  insert into t1 values ROW(100, y), ROW(x, 'zzz'), ROW(x, y);
  insert into t1 values ROW(1000, y), ROW(x, 'zzzz'), ROW(x, y) limit 2;
end
//

call test_proc(1, 'a')//
select/**/ * from t1//
delete/**/ from t1//

delimiter ;//
drop table t1;
drop procedure test_proc;
##########################################################################################################
##
##test invalid values statement
##
##########################################################################################################

--disable_warnings
drop table if exists test1, test2;
--enable_warnings

create table test1(c1 int, c2 varchar(20), c3 varchar(20) default 'abc');
create table test2(c1 int default -1, c2 int default -1, c3 int GENERATED ALWAYS AS(c1 + c2));

--error 1136
values row(1), row(2), row(3,4);
--error 3942
values row(1), row(2), row();
--error 3943
values row(1), row(2), row(default);
--error 1054
VALUES ROW(1,-2,3), ROW(5,7,9), ROW(4,6,8) ORDER BY c1;
--error 1136
insert into test1(c1) values row(), row(4), row(5);
--error 3105
insert into test2 values row(1,1,2);
--error 1242
select (values row(1), row(2), row(3)) from test1;

drop table test1, test2;

--disable_warnings
drop table if exists v1;
--enable_warnings

create view v1 as values row(1), row(2), row(3);
desc v1;
--error 1471
insert into v1 value (4);
--error 1288
update v1 set v1.column_0 = 4 where v1.column_0 = 1;
--error 1288
delete from v1 where v1.column_0 = 1;

drop view v1;

connection obsys;
alter system set _enable_values_table_folding=true;
sleep 10;
select distinct name, value from __all_virtual_sys_parameter_stat where name like '%enable_values_table_folding%';

connection default;