select/**/ * from test2;
delete/**/ from test2;

insert into test2 values row(1,2,default), row(2,3,default), row(3,4,default);
select/**/ * from test2;
delete/**/ from test2;

insert into test2 values row(1,2,default), row(2,3,default), row(3,4,default) limit 1;
select/**/ * from test2;
delete/**/ from test2;

insert into test3 values row(), row(), row();
select/**/ * from test3;
delete/**/ from test3;

insert into test3 values row(), row(), row() limit 1;
select/**/ * from test3;
delete/**/ from test3;

insert into test3 values row(default,2,2), row(default,3,3), row(default,4,4);
