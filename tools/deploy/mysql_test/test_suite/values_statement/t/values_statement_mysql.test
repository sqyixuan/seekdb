delete/**/ from test4;

insert into test4 values row(default,4), row(default,5), row(default,6) limit 1;
select/**/ * from test4;
delete/**/ from test4;

--explain_protocol 0
insert into test4(c2) values row(4), row(5);
insert into test4(c2) values row(4), row(5);
insert into test4(c2) values row(4), row(5);
insert into test4(c2) values row(4), row(5) union all values row(6), row(7);
insert into test4(c2) values row(4), row(5) union all values row(6), row(7);
insert into test4(c2) values row(4), row(5) union all values row(6), row(7);
select/**/ * from test4;
delete/**/ from test4;

insert into test4(c2) values row(4), row(5), row(6), row(7) limit 2;
