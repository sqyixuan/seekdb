--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhuangyifeng.zyf
#owner group: sql1
## test values statement for compatible mysql8.0
## https://dev.mysql.com/doc/refman/8.0/en/values.html

--result_format 4

##########################################################################################################
##
##test values statement basic
##
##########################################################################################################
connect (obsys, $OBMYSQL_MS0, root@sys, ,oceanbase, $OBMYSQL_PORT);
connection obsys;
alter system set _enable_values_table_folding=true;
sleep 10;
select distinct name, value from __all_virtual_sys_parameter_stat where name like '%enable_values_table_folding%';

connection default;

alter system flush plan cache global;

values row(1);

values row('a');

values row(1), row(2), row(3);

values row('a'), row('b'), row('c');

values row('a', 2), row('cc', 3), row('dd', 4);

values row(1, -2, 3), row(5, 7, 9), row(4, 6, 8);

values row(1, 2, 3), row(4, 5, 6), row(7, 8, 9);

explain values row(1, -2, 3), row(4, 5, -6), row(-7, 8, 9);
values row(1, -2, 3), row(4, 5, -6), row(-7, 8, 9);

values row(1, -2, 'oceanbase'), row('a', 5, '蚂蚁集团'), row('222asda', 8, date'2020-12-01');

VALUES ROW("q", 42, '2019-12-18'), ROW(23, "abc", 98.6), ROW(27.0002, "Mary Smith", '{"a": 10, "b": 25}');
explain VALUES ROW("q", 42, '2019-12-18'), ROW(23, "abc", 98.6), ROW(27.0002, "Mary Smith", '{"a": 10, "b": 25}');

VALUES ROW(1,-2,3), ROW(5,7,9), ROW(4,6,8) ORDER BY column_0, column_1, column_2;

VALUES ROW(1,-2,3), ROW(5,7,9), ROW(4,6,8) limit 2;

explain VALUES ROW(1,-2,3), ROW(5,7,9), ROW(4,6,8) ORDER BY column_0 desc limit 1;
VALUES ROW(1,-2,3), ROW(5,7,9), ROW(4,6,8) ORDER BY column_0 desc limit 1;

explain VALUES ROW(1,2) UNION VALUES ROW(10,15);
VALUES ROW(1,2) UNION VALUES ROW(10,15);

explain VALUES ROW(1,2), ROW(3,4), ROW(5,6) UNION VALUES ROW(10,15),ROW(20,25);
VALUES ROW(1,2), ROW(3,4), ROW(5,6) UNION VALUES ROW(10,15),ROW(20,25);

explain VALUES ROW(1,2), ROW(3,4), ROW(5,6) INTERSECT VALUES ROW(10,15), ROW(20,25), ROW(3,4);
VALUES ROW(1,2), ROW(3,4), ROW(5,6) INTERSECT VALUES ROW(10,15), ROW(20,25), ROW(3,4);

explain VALUES ROW(1,2), ROW(3,4), ROW(5,6) EXCEPT VALUES ROW(10,15), ROW(20,25), ROW(3,4);
VALUES ROW(1,2), ROW(3,4), ROW(5,6) EXCEPT VALUES ROW(10,15), ROW(20,25), ROW(3,4);

--echo 检查计划形态
select hit_count, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%values row%';

##########################################################################################################
##
##test values plan cache hit
##
##########################################################################################################

alter system flush plan cache global;

values row(1, 2, 3), row(4, 5, 6), row(7, 8, 9);
values row(-1, 2, 3), row(-4, 5, 6), row(7, -8, 9);
values row(11, 2, 3), row(-4, 15, 6), row(7, -18, 9);
select hit_count, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%values row%';

--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(c1 int, c2 varchar(20));
insert into test1 values row(1,'a'), row(2,'b');
insert into test1 values row(3,3), row(4,4);
insert into test1 values row(5,'e'), row(6,'f');
insert into test1 values row(7,'g'), row(8,'h') order by column_0 limit 1;
insert into test1 values row(9,9), row(10,10) order by column_0 limit 1;
insert into test1 values row(11,'k'), row(12,'k') order by column_0 limit 1;
--sorted_result
select hit_count, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%insert into test1 values%';

drop table test1;
##########################################################################################################
##
##test values statement with subquery
##
##########################################################################################################

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 varchar(10), c2 varchar(10), c3 varchar(10));

insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10);
insert into t2 values('a','a','a'),('b','b','b'),('c','c','c'),('d','d','d'),('e','e','e'),('f','f','f'),('g','g','g'),('h','h','h'),('i','i','i'),('j','j','j');

--explain_protocol 2

VALUES ROW((select 1));

VALUES ROW((VALUES ROW(1)));

VALUES ROW((VALUES ROW((VALUES ROW((VALUES ROW(1)))))));

select (VALUES ROW(c1)) from t1;

select column_0 from (VALUES ROW('q', 42, '2019-12-18', 23, 'abc', 98.6, 27.0002, 'Mary Smith', '{\"a\": 10, \"b\": 25}'));

select 1,1,1 from (values row(1,1,1), row(2,2,2), row(3,3,3));

select column_0+column_1+column_2 from (values row(1,1,1), row(2,2,2), row(3,3,3));

select column_0+column_1 from (values row(1,1,1), row(2,2,2), row(3,3,3));

SELECT * FROM (VALUES ROW(1, 2), ROW(2, 2)) AS l(MailID, AttachFlag);

SELECT * FROM (values row(1,2,3), row(4,5,6)) v1 where column_0 > 1;

SELECT * FROM (values row(1,2,3), row(4,5,6), row(7,8,9)) AS t2(c1,c2,c3) where t2.c1 = 1 or t2.c1 = 4;

SELECT * FROM (values row(1,2,3), row(4,5,6), row(7,8,9)) AS t2(c1,c2,c3) where t2.c1 = 1 or t2.c2 = 5;

select * from t1 where 1 in (VALUES row(2),row(2),row(3));

select * from t1 where 1 in (VALUES row(1),row(2),row(3));

select * from t1 where c1 in (VALUES row(1),row(2),row(3),row(100));

# values table be rescaned 
select /*+LEADING(t1 t2),USE_NL(t2),no_USE_NL_MATERIALIZATION(VALUES_TABLE1)*/* from t1, (values row(1,2,3), row(4,5,6), row(100, 100, 100)) AS t2(c1,c2,c3) where t1.c1=t2.c1;

select * from t1, (values row(1,2,3), row(4,5,6), row(100, 100, 100)) AS t2(c1,c2,c3) where t1.c1=t2.c1;

--explain_protocol 0
drop table t1, t2;
##########################################################################################################
##
##test values statement with other DML statement
##
##########################################################################################################

--disable_warnings
drop table if exists test1, test2, test3, test4, test5, test6;
--enable_warnings

create table test1(c1 int, c2 varchar(20), c3 varchar(20) default 'abc');
create table test2(c1 int default -1, c2 int default -1, c3 int GENERATED ALWAYS AS(c1 + c2));
create table test3(c1 int GENERATED ALWAYS AS(c3 - c2), c2 int default -1 , c3 int default -1);
create table test4(c1 int primary key AUTO_INCREMENT, c2 int);
CREATE TABLE test5 (
col_datetime datetime,
col_float_10_5 float(10,5),
pk int not null,
col_double double,
col_varchar_20 varchar(20),
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
/*Indices*/
primary key (pk) ) PARTITION BY range(pk)(partition p1 values less than(50),partition p2 values less than(maxvalue));
create table test6 (
  c1 int,
  c2 int AUTO_INCREMENT,
  primary key(c2)
) PARTITION BY range(c2)(partition p1 values less than(5),partition p2 values less than(maxvalue));
--explain_protocol 2

insert into test1 values row(), row(), row();
