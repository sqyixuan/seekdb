insert into test4(c2) values row(4), row(5), row(6), row(7) limit 2;
insert into test4(c2) values row(4), row(5), row(6), row(7) union all values row(6), row(7) limit 2;
insert into test4(c2) values row(4), row(5), row(6), row(7) union all values row(6), row(7) limit 2;
insert into test4(c2) values row(4), row(5), row(6), row(7) union all values row(6), row(7) limit 2;
select/**/ * from test4;
delete/**/ from test4;
--explain_protocol 2

insert/**/ into test1 values row(1,2,default), row(3,4,default), row(5,6,default);
insert/**/ into test2 values row(1,2,default), row(2,3,default), row(3,4,default);
insert/**/ into test3 values row(default,2,3), row(default,3,3), row(default,4,6);

update test1 set c1 = (VALUES ROW(1));
update test2 set c2 = (VALUES ROW(100)) where c1 in (VALUES ROW(1), ROW(2), ROW(100));
update test3 set c2 = (VALUES ROW(1000)) where c1 in (VALUES ROW(1), ROW(2), ROW(1000));

select/**/ * from test1;
select/**/ * from test2;
select/**/ * from test3;

delete from test1 where c1 > (VALUES ROW(0), ROW(1), ROW(2) order by column_0 limit 1);
delete from test2 where c3 > any(VALUES ROW(100), ROW(101), ROW(102));
delete from test3 where c1 < ALL(VALUES ROW(0), ROW(1), ROW(2));

select/**/ * from test1;
select/**/ * from test2;
select/**/ * from test3;

