--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhuangyifeng.zyf
#owner group: sql1
#tags: optimizer
## test values statement for compatible mysql8.0
## https://dev.mysql.com/doc/refman/8.0/en/values.html

connect (obsys, $OBMYSQL_MS0, root@sys, ,oceanbase, $OBMYSQL_PORT);
connection obsys;
alter system set _enable_values_table_folding=true;
sleep 10;
select distinct name, value from __all_virtual_sys_parameter_stat where name like '%enable_values_table_folding%';

connection default;

--result_format 4
# 1. single values row
alter system flush plan cache global;

values row(1);
values row('a');

values row(1), row(2), row(3);
values row('a'), row('b'), row('c');

values row('a',   -2), row('cc',   3), row('dd', 4);
values row(2, 'a'), row(3, 'cc'), row(4, 'dd');

values row('a',   -2), row('cc',   3), row('dd', 4) order by 1;

values row(1, -2, date'2000-12-01'), row(5, 7, date'2019-12-01'), row(4, 6, date'2020-11-01');
values row(1, -2, date'2000-12-01'), row(5, 7, date'2019-12-01'), row(4, 6, date'2020-11-01') limit 1;
values row(1, -2, date'2000-12-01'), row(5, 7, date'2019-12-01'), row(4, 6, date'2020-11-01') order by 1 limit 1;

values row(1, -2, 'oceanbase'), row('a', 5, '蚂蚁集团'), row('222asda', 8, date'2020-12-01');

select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%values row%';

values row('a',   2), row('caaac',3), row('ddaaaaaa', 4), row('112', 5);
values row('a',   2), row('caaac',3), row('ddaaaaaa', 4), row('112', 5) order by 1;

values row(1, 2, date'2000-11-01'), row(4, 5, date'2011-12-01'), row(7, 8, date'2000-12-21');
values row(1, 2, date'2000-11-01'), row(4, 5, date'2011-12-01'), row(7, 8, date'2000-12-21') limit 1;
values row(1, 2, date'2000-11-01'), row(4, 5, date'2011-12-01'), row(7, 8, date'2000-12-21') order by 1 limit 1;

select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%values row%';


# 2.  values row
alter system flush plan cache global;
select 1 from (values row(2)) v1 union all select 3 from (values row(4,5,6), row(7,8,1000)) v2 order by 1;
select 3 from (values row(44)) v1 union all select 55 from (values row(66,77,88), row(99,100,111)) v2 order by 1;

select 1 from (values row(77,   88 , 99), row(0,-1,-2)) v1 union all select 3 from (values row(4,5,6), row(7,8,1000)) v2 order by 1;
select 3 from (values row(111,   1 , 2), row(-1, -2, 0)) v1 union all select 55 from (values row(66,77,88), row(99,100,111)) v2 order by 1;

select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%values row%';

# 3. insert/update

--disable_warnings
drop table if exists test1, t1, test2;
--enable_warnings

create table test1(c1 int, c2 varchar(20));
insert into test1 values row(1,'a'), row(2,'b');
insert into test1 values row(3,3), row(4,4);
insert into test1 values row(5,'e'), row(6,'f');
insert into test1 values row(7,'g'), row(8,'h') order by column_0 limit 1;
insert into test1 values row(9,9), row(10,10) order by column_0 limit 1;
insert into test1 values row(11,'k'), row(12,'k') order by column_0 limit 1;
--sorted_result
select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%insert into test1 values%';
select * from test1;

update test1 set c1 = (VALUES ROW(1));
update test1 set c2 = (VALUES ROW(100)) where c1 in (VALUES ROW(1), ROW(2), ROW(100));
update test1 set c2 = (VALUES ROW(1000)) where c1 in (VALUES ROW('1'), ROW('2'), ROW('1000'));

CREATE TABLE test2 (
col_datetime datetime,
col_float_10_5 float(10,5),
pk int not null,
col_double double,
col_varchar_20 varchar(20),
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
/*Indices*/
primary key (pk) ) PARTITION BY range(pk)(partition p1 values less than(50),partition p2 values less than(maxvalue));

INSERT INTO test2 VALUES
('2007-06-14 20:46:11', 0, 1, NULL, '', 0, 7164382582216327168),
('2003-10-18 14:12:04', NULL, 2, 0, 'h',8, 0),
('2009-06-19 08:53:38', 0, 3, 0, 'yeah', 9, 0),
(NULL, 0, 4, NULL, 'c', 0, 20588),
(NULL, 0, 5, 0, 'mubhvq', 0, NULL),
('2007-02-07 04:14:59', -123, 6, 7, 'p', 0, 8),
(NULL, 91, 7, 5, 'v', -19473, 0),
('2002-07-21 22:27:07', -4328, 8, 0, 'x', 3, 11795),
('2002-02-23 08:12:44', NULL, 9, 9, 'amubhvqxrmkfnkwngd', 0, NULL),
(NULL, 1, 10, NULL, 'got', 25301, 124);

--sorted_result
SELECT * FROM test2, (VALUES ROW(9,9,4,2,4,0), ROW(0,9,5,0,3,9), ROW(7,6,3,0,6,4)) AS t2(c1,c2,c3,c4,c5,c6) where test2.pk=t2.c3;
--sorted_result
SELECT * FROM test2, (VALUES ROW(9,9,4,2,4,0), ROW(0,9,5,0,3,9)) AS t2(c1,c2,c3,c4,c5,c6) where test2.pk=t2.c3;
--sorted_result
SELECT * FROM test2, (VALUES ROW(9,9,4,2,4,0), ROW(0,9,5,0,3,9), ROW(7,6,3,0,6,4), ROW(7,6,3,0,6,4)) AS t2(c1,c2,c3,c4,c5,c6) where test2.pk=t2.c3;

--sorted_result
select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%update test1 set c2%';

select * from test1;
drop table test1, test2;

# 4. in table not support fold params
create table t1 as values row(1, 2, 3), row(100, 200, 300);
select * from t1;
drop table t1;

CREATE TABLE t1 (
  `col_timestamp` timestamp NULL DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_double` double DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `in_expr_idx7` (`pk`, `col_decimal_20_0`, `col_timestamp`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by hash(pk)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);
insert into t1 (col_bigint, col_double, pk) value(7, -35, 1);
insert into t1 (col_bigint, col_double, pk) value(8, -39, 2);
insert into t1 (col_bigint, col_double, pk) value(6, -66, 3);
SELECT * FROM t1 WHERE 1 IS NOT NULL AND col_bigint BETWEEN 5 AND 10 AND '2003-09-05 11:04:05.019431' IN (values row('2006-09-05 20:20:37'),row('2003-09-05 11:04:05.019431'),row('2007-12-27 00:58:45')) AND col_double NOT BETWEEN -30 AND -2585347661087375360 order by 1,2,3,4,5,6;
SELECT * FROM t1 WHERE 1 IS NOT NULL AND col_bigint BETWEEN 5 AND 10 AND '2007-12-27 00:58:45' IN (values row('2006-09-05 20:20:37'),row('2003-09-05 11:04:05.019431'),row('2007-12-27 00:58:45')) AND col_double NOT BETWEEN -30 AND -2585347661087375360 order by 1,2,3,4,5,6;
SELECT * FROM t1 WHERE 1 IS NOT NULL AND col_bigint BETWEEN 5 AND 10 AND '2007-12-27 00:58:60' IN (values row('2006-09-05 20:20:37'),row('2003-09-05 11:04:05.019431'),row('2007-12-27 00:58:45')) AND col_double NOT BETWEEN -30 AND -2585347661087375360 order by 1,2,3,4,5,6;
select distinct statement, sql_id, param_infos from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like '%AND col_bigint BETWEEN%';
DROP TABLE t1;

CREATE TABLE t1 (
col_varchar_20 varchar(20),
col_decimal_20_0 decimal(20,0),
col_timestamp timestamp NULL DEFAULT NULL,
pk int not null,
col_double double,
col_bigint bigint,
/*Indices*/
primary key (pk) )    PARTITION BY hash(pk) partitions 4 ;
