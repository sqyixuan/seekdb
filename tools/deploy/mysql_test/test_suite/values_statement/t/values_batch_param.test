create index in_expr_idx15 on t1 (pk,col_bigint);
SELECT * FROM t1 WHERE ((col_timestamp,col_timestamp) IN (('2020-03-08 00:00:00','2021-03-08 00:00:00'),('2022-03-0800:00:00','2023-03-08 00:00:00')) AND 2 IS NOT NULL) OR (col_varchar_20 NOT IN (values row('been'),row('m'),row('mgupbom')) OR floor(PK /2 * 4) NOT BETWEEN 3 AND 10) order by 1,2,3,4,5,6;
