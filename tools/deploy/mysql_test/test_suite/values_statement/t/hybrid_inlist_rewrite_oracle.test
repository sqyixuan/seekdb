#owner: sean.yyj
#owner group: sql1
#tags: optimizer

--disable_warnings
--error 0, 942
drop table t1;
--enable_warnings

create table t1(c1 number, c2 varchar(100), c3 number(10,1), c4 date, c5 timestamp);

insert into t1 values(1, '1', 1.1, date'2025-01-01', timestamp'2025-01-01 01:01:01');
insert into t1 values(null, null, null, null, null);
insert into t1 values(3, '3', 3.0, date'2025-03-03', timestamp'2025-03-03 03:03:03');
insert into t1 values(5, '5', 5.5, date'2025-05-05', timestamp'2025-05-05 05:05:05');

alter system set "_inlist_rewrite_threshold" = 1;
sleep 5;
select distinct name, value from GV$OB_PARAMETERS where name like '%inlist_rewrite_threshold%';

--result_format 4
select * from t1;

--explain_protocol 1

--echo # number in number
select c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
select c1 from t1 where c1 in (null, 0, null, 1, null, 2, 3, 4);
select c1 from t1 where c1 in (null, null, null);

--echo # varchar in char
select c2 from t1 where c2 in ('0', null, '1', null, '2', '3', '4');

--echo # decint in decint
select c3 from t1 where c3 in (0.0, null, 1.1, null, 2.2, 3.3, 4.4);
select c3 from t1 where c3 in (0.0, null, 1.10, null, 2.2, 3.3, 4.4);
select c3 from t1 where c3 in (0.0, null, 1.11, null, 2.2, 3.00, 4.4);

--echo # date in date
select c4 from t1 where c4 in (date'2024-01-01', null, date'2025-01-01', null, date'2025-02-02', date'2025-03-03', date'2025-04-04');

--echo # timestamp in timestamp
select c5 from t1 where c5 in (timestamp'2024-01-01 01:01:01', null, timestamp'2025-01-01 01:01:01', null, timestamp'2025-02-02 02:02:02', timestamp'2025-03-03 03:03:03', timestamp'2025-04-04 04:04:04');

--echo # number in char
select c1 from t1 where c1 in ('0', null, '1', null, '2', '3', '4');

--echo # char in number
select c2 from t1 where c2 in (0, null, 1, null, 2, 3, 4);

--echo # number in decint
select c1 from t1 where c1 in (0.0, null, 1.0, null, 2.0, 3.0, 4.0);
select c1 from t1 where c1 in (0.0, null, 1.01, null, 2.0, 3.0, 4.0);
select c1 from t1 where c1 in (0.0, null, 1.0, null, 2.0, 3.00, 4.0);

--echo # decint in number
select c3 from t1 where c3 in (0, null, 1, null, 2, 3, 4);

--echo # char in decint
select c2 from t1 where c2 in (0.0, null, 1.0, null, 2.0, 3.0, 4.0);
select c2 from t1 where c2 in (0.0, null, 1.01, null, 2.0, 3.0, 4.0);
select c2 from t1 where c2 in (0.0, null, 1.0, null, 2.0, 3.00, 4.0);

--echo # decint in char
select c3 from t1 where c3 in ('0', null, '1', null, '2', '3', '4');

--echo # version control
set optimizer_features_enable = '4.3.5.2';
select c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
select /*+optimizer_features_enable('4.3.5.3')*/ c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
set optimizer_features_enable = '4.3.5.3';
select c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
select /*+optimizer_features_enable('4.3.5.2')*/ c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);

--echo # multi in
select c1, c3 from t1 where (c1, c3) in ((null, 0.000), (1, null), (3, 3.0), (null, 5.5), (null, null), (5, 5.5));

alter system set "_inlist_rewrite_threshold" = 1000;
drop table t1;
