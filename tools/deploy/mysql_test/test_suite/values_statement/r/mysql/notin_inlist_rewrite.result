drop table if exists t1, t2;
create table t1(c1 int);
insert into t1 values(1),(1),(2),(100),(null),(null),(1000000000);
create table t2(c1 int, c2 char(10));
insert into t2 values(1, '1'), (2, '2'), (3, null), (null, '4'), (null, null), (6, '');
alter system set _inlist_rewrite_threshold = 1;
alter system flush plan cache;
