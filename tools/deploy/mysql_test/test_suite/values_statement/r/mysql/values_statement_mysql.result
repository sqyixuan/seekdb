| c1   | c2   |
+------+------+
|  100 | a    |
|    1 | zzz  |
|    1 | a    |
| 1000 | a    |
|    1 | zzzz |
+------+------+
delete/**/ from t1//

drop table t1;
drop procedure test_proc;
