##########################################################################################################
##
##test values statement with other DML statement
##
##########################################################################################################
drop table if exists test1, test2, test3, test4, test5, test6;
create table test1(c1 int, c2 varchar(20), c3 varchar(20) default 'abc');
create table test2(c1 int default -1, c2 int default -1, c3 int GENERATED ALWAYS AS(c1 + c2));
create table test3(c1 int GENERATED ALWAYS AS(c3 - c2), c2 int default -1 , c3 int default -1);
create table test4(c1 int primary key AUTO_INCREMENT, c2 int);
CREATE TABLE test5 (
col_datetime datetime,
col_float_10_5 float(10,5),
pk int not null,
col_double double,
col_varchar_20 varchar(20),
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
/*Indices*/
primary key (pk) ) PARTITION BY range(pk)(partition p1 values less than(50),partition p2 values less than(maxvalue));
create table test6 (
  c1 int,
  c2 int AUTO_INCREMENT,
  primary key(c2)
) PARTITION BY range(c2)(partition p1 values less than(5),partition p2 values less than(maxvalue));
