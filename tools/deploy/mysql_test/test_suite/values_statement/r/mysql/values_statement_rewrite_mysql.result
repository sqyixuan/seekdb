CREATE TABLE table100_key_pk_parts_2_int_not_null (
col_decimal_20_0 decimal(20,0),
col_timestamp timestamp NULL DEFAULT NULL,
col_double double,
col_bigint bigint,
pk int not null,
col_varchar_20 varchar(20),
