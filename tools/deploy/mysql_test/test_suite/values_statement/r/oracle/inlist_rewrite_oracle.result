drop table t1;
drop table t2;
drop index idx1;
drop index idx2;
create table t1 (c1 int, c2 varchar(20), c3 int, c4 varchar(20));
create table t2 (c1 int);
create index idx1 on t1(c1);
create index idx2 on t1(c2);
select count(*) from t1;
COUNT(*)
1002
alter system set "_inlist_rewrite_threshold" = 1;
