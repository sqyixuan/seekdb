DROP TABLE table2_hash_pk_parts_1_bigint;
drop index idx1;
drop index idx2;
CREATE TABLE table2_hash_pk_parts_1_bigint (
  col_char_12 char(12),
  pk int,
  col_bigint int,
  col_bigint_key int,
  col_char_12_key char(12),
  /*Indices*/
  primary key (pk)
) PARTITION BY hash (pk) partitions 3;
create index idx1 on table2_hash_pk_parts_1_bigint(pk, col_bigint_key);
create index idx2 on table2_hash_pk_parts_1_bigint(pk, col_char_12_key);

