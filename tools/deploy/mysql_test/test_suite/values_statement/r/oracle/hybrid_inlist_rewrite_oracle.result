drop table t1;
create table t1(c1 number, c2 varchar(100), c3 number(10,1), c4 date, c5 timestamp);
insert into t1 values(1, '1', 1.1, date'2025-01-01', timestamp'2025-01-01 01:01:01');
insert into t1 values(null, null, null, null, null);
insert into t1 values(3, '3', 3.0, date'2025-03-03', timestamp'2025-03-03 03:03:03');
insert into t1 values(5, '5', 5.5, date'2025-05-05', timestamp'2025-05-05 05:05:05');
alter system set "_inlist_rewrite_threshold" = 1;
select distinct name, value from GV$OB_PARAMETERS where name like '%inlist_rewrite_threshold%';
NAME	VALUE
_inlist_rewrite_threshold	1
result_format: 4
select * from t1;
+------+------+------+---------------------+----------------------------+
| C1   | C2   | C3   | C4                  | C5                         |
+------+------+------+---------------------+----------------------------+
|    1 | 1    |  1.1 | 2025-01-01 00:00:00 | 2025-01-01 01:01:01.000000 |
| NULL | NULL | NULL | NULL                | NULL                       |
|    3 | 3    |    3 | 2025-03-03 00:00:00 | 2025-03-03 03:03:03.000000 |
|    5 | 5    |  5.5 | 2025-05-05 00:00:00 | 2025-05-05 05:05:05.000000 |
+------+------+------+---------------------+----------------------------+

explain_protocol: 1
# number in number
EXPLAIN BASIC select c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
Query Plan
============================================
|ID|OPERATOR                 |NAME         |
--------------------------------------------
|0 |HASH JOIN                |             |
|1 |├─TABLE FULL SCAN        |T1           |
|2 |└─SUBPLAN SCAN           |VIEW2        |
|3 |  └─HASH DISTINCT        |             |
|4 |    └─VALUES TABLE ACCESS|VALUES_TABLE1|
============================================
Outputs & filters:
-------------------------------------
  0 - output([T1.C1]), filter(nil), rowset=16
      equal_conds([T1.C1 = VIEW2.column_0]), other_conds(nil)
  1 - output([T1.C1]), filter(nil), rowset=16
      access([T1.C1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([VIEW2.column_0]), filter(nil), rowset=16
      access([VIEW2.column_0])
  3 - output([VALUES_TABLE1.column_0]), filter(nil), rowset=16
      distinct([VALUES_TABLE1.column_0])
  4 - output([VALUES_TABLE1.column_0]), filter(nil)
      access([VALUES_TABLE1.column_0])
select c1 from t1 where c1 in (0, null, 1, null, 2, 3, 4);
