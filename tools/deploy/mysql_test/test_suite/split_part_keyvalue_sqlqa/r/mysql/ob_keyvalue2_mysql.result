drop PROCEDURE if exists type_test;
CREATE PROCEDURE type_test(OUT res VARCHAR(10))
BEGIN
  SET res = keyvalue('in:proc', 'in');
END;//
CALL type_test(@res);
SELECT @res;
+------+
| @res |
+------+
| proc |
+------+
