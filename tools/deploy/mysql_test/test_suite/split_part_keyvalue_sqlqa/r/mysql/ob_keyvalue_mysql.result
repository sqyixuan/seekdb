drop table if exists test_table;
CREATE TABLE test_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT
);
CREATE TRIGGER before_insert_trigger
BEFORE INSERT ON test_table
FOR EACH ROW
BEGIN
    DECLARE key_value VARCHAR(255);
    SET key_value = keyvalue(NEW.data, ';', ':', 'a');
    IF key_value IS NULL THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Insert failed: key "a" not found.';
    END IF;
END;
//
CREATE TRIGGER before_update_trigger
BEFORE UPDATE ON test_table
FOR EACH ROW
BEGIN
    DECLARE key_value VARCHAR(255);
    SET key_value = keyvalue(NEW.data, ';', ':', 'b');
    IF key_value IS NULL THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Update failed: key "b" not found.';
    END IF;
END;
//
CREATE TRIGGER before_delete_trigger
BEFORE DELETE ON test_table
FOR EACH ROW
BEGIN
    DECLARE key_value VARCHAR(255);
    SET key_value = keyvalue(OLD.data, ';', ':', 'c');
    IF key_value IS NULL THEN
        SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'Delete failed: key "c" not found.';
    END IF;
END;
//
INSERT INTO test_table (data) VALUES ('a:b;c:d');
UPDATE test_table SET data = 'b:e;f:g' WHERE id = 1;
DELETE FROM test_table WHERE id = 1;
ERROR 45000: Delete failed: key "c" not found.
SELECT * FROM test_table;
+----+---------+
| id | data    |
+----+---------+
|  1 | b:e;f:g |
+----+---------+
