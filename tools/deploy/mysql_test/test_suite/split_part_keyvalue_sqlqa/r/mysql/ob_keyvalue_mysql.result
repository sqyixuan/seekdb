SELECT ADDDATE(CURDATE(), INTERVAL 1 DAY) AS next_date,
       keyvalue(CONCAT('key1:', DATE(ADDDATE(CURDATE(), INTERVAL 1 DAY)),
                       ';key2:', DATE(CURDATE()), ';key3:2023-10-01'), ';', ':', 'key1') AS keyvalue_test1;
SELECT ADDTIME(CURDATE(), '10:00:00') AS next_time,
       keyvalue(CONCAT('key1:', DATE(ADDTIME(CURDATE(), '10:00:00')),
                       ';key2:', DATE(CURDATE()), ';key3:2023-10-01'), ';', ':', 'key2') AS keyvalue_test2;
SELECT DATE(CURDATE()) AS current_static_date,
       keyvalue(CONCAT('now:', DATE(CURDATE()), ';static:', '2023-10-01'), ';', ':', 'now') AS keyvalue_test4;
SELECT DATEDIFF(CURDATE(), '2023-01-01') AS days_diff,
       keyvalue(CONCAT('days:', DATEDIFF(CURDATE(), '2023-01-01'), ';weeks:', DATEDIFF(CURDATE(), '2023-01-01') / 7), ';', ':', 'weeks') AS keyvalue_test5;
