drop FUNCTION if exists no_param_func;
drop FUNCTION if exists param_func;
drop FUNCTION if exists repeat_loop_func;
drop FUNCTION if exists while_loop_func;
drop FUNCTION if exists loop_func;
CREATE FUNCTION no_param_func()
RETURNS VARCHAR(255)
BEGIN
    RETURN 'No parameter function executed';
END $$
CREATE FUNCTION param_func(value VARCHAR(255))
RETURNS VARCHAR(255)
BEGIN
    RETURN CONCAT('Value received: ', value);
END $$
CREATE FUNCTION repeat_loop_func(value VARCHAR(255))
RETURNS VARCHAR(255)
BEGIN
    DECLARE result VARCHAR(255) DEFAULT '';
    DECLARE counter INT DEFAULT 0;
    
    REPEAT
        SET result = CONCAT(result, value, ' ');
        SET counter = counter + 1;
    UNTIL counter >= 3
    END REPEAT;
    
    RETURN result;
END $$
CREATE FUNCTION while_loop_func(value VARCHAR(255))
RETURNS VARCHAR(255)
BEGIN
    DECLARE result VARCHAR(255) DEFAULT '';
    DECLARE counter INT DEFAULT 0;

    WHILE counter < 3 DO
        SET result = CONCAT(result, value, ' ');
        SET counter = counter + 1;
    END WHILE;

    RETURN result;
END $$
CREATE FUNCTION loop_func(value VARCHAR(255))
RETURNS VARCHAR(255)
BEGIN
    DECLARE result VARCHAR(255) DEFAULT '';
    DECLARE counter INT DEFAULT 0;

    label_loop: LOOP
        SET result = CONCAT(result, value, ' ');
        SET counter = counter + 1;

        IF counter >= 3 THEN
            LEAVE label_loop;
        END IF;
    END LOOP;

    RETURN result;
END $$
SELECT no_param_func();
+--------------------------------+
| no_param_func()                |
+--------------------------------+
| No parameter function executed |
+--------------------------------+
SELECT param_func('Test');
+----------------------+
| param_func('Test')   |
+----------------------+
| Value received: Test |
+----------------------+
SELECT repeat_loop_func('Repeat');
+----------------------------+
| repeat_loop_func('Repeat') |
+----------------------------+
| Repeat Repeat Repeat       |
+----------------------------+
SELECT while_loop_func('While');
+--------------------------+
| while_loop_func('While') |
+--------------------------+
| While While While        |
+--------------------------+
SELECT loop_func('Loop');
+-------------------+
| loop_func('Loop') |
+-------------------+
| Loop Loop Loop    |
+-------------------+
