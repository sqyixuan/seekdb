drop table if exists test_keyvalue;
CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    varchar_col VARCHAR(255),
    tinytext_col TINYTEXT,
    text_col TEXT,
    longtext_col LONGTEXT,
    int_col INT,
    float_col FLOAT
);
