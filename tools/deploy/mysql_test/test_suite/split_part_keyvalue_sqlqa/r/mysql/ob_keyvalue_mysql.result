### еҸӮж•°зұ»еһӢе…ЁиҰҶзӣ–
SELECT keyvalue('', ';', ':', 'a') AS result_1;
+----------+
| result_1 |
+----------+
| NULL     |
+----------+
SELECT keyvalue('a:b', ';', ':', 'a') AS result_2;
+----------+
| result_2 |
+----------+
| b        |
+----------+
SELECT keyvalue('   ', ';', ':', 'a') AS result_3;
+----------+
| result_3 |
+----------+
| NULL     |
+----------+
SELECT keyvalue('0:0;1:1', ';', ':', '0') AS result_4;
+----------+
| result_4 |
+----------+
| 0        |
+----------+
SELECT keyvalue('1:apple;2:banana', ';', ':', '1') AS result_5;
+----------+
| result_5 |
+----------+
| apple    |
+----------+
SELECT keyvalue('-1:negative;0:zero', ';', ':', '-1') AS result_6;
+----------+
| result_6 |
+----------+
| negative |
+----------+
SELECT keyvalue('3.14:pai;2.71:e', ';', ':', '3.14') AS result_7;
+----------+
| result_7 |
+----------+
| pai      |
+----------+
SELECT keyvalue('true:yes;false:no', ';', ':', 'true') AS result_8;
+----------+
| result_8 |
+----------+
| yes      |
+----------+
SELECT keyvalue('true:yes;false:no', ';', ':', 'false') AS result_9;
+----------+
| result_9 |
+----------+
| no       |
+----------+
SELECT keyvalue('0:zero;1:one', ';', ':', '0') AS result_10;
+-----------+
| result_10 |
+-----------+
| zero      |
+-----------+
SELECT keyvalue('3.14:pi;true:is_true', ';', ':', 'true') AS result_11;
+-----------+
| result_11 |
+-----------+
| is_true   |
+-----------+
SELECT keyvalue('-1:negative_value;1:positive_value', ';', ':', '-1') AS result_12;
+----------------+
| result_12      |
+----------------+
| negative_value |
+----------------+
SELECT keyvalue('a1:b1;a2:b2;a3:b3;a4:b4;a5:b5', ';', ':', 'a3') AS result_13;
+-----------+
| result_13 |
+-----------+
| b3        |
+-----------+
SELECT keyvalue('large_value:1;small_value:0;negative_value:-1', ';', ':', 'large_value') AS result_14;
+-----------+
| result_14 |
+-----------+
| 1         |
+-----------+
SELECT keyvalue('single_key:only_value', ';', ':', 'single_key') AS result_15;
+------------+
| result_15  |
+------------+
| only_value |
+------------+
