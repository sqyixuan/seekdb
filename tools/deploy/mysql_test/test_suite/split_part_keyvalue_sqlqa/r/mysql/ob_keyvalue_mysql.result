HAVING 
    cnt > 1;
+--------+------+
| result | cnt  |
+--------+------+
| NULL   |    4 |
+--------+------+
SELECT DISTINCT 
    keyvalue(data_text, ';', ':', 'name1') AS result 
FROM 
    test_keyvalue;
