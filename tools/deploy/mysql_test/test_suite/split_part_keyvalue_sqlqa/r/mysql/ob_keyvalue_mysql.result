drop table if exists table4;
CREATE TABLE table1 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    data1 VARCHAR(255)
);
CREATE TABLE table2 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    data2 TINYTEXT
);
CREATE TABLE table3 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    data3 TEXT
);
CREATE TABLE table4 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    data4 LONGTEXT
);
INSERT INTO table1 (data1) VALUES 
('a:b;c:d'), 
('e:f;g:h');
INSERT INTO table2 (data2) VALUES 
('1:2;3:4'), 
('5:6;7:8');
INSERT INTO table3 (data3) VALUES 
('x:y;z:w'), 
('u:v;s:t');
INSERT INTO table4 (data4) VALUES 
('key1:value1;key2:value2'), 
('key3:value3;key4:value4');
SELECT 
    t1.id AS t1_id,
    keyvalue(t1.data1, ';', ':', 'a') AS value_from_t1,
    keyvalue(t2.data2, ';', ':', '3') AS value_from_t2
FROM 
    table1 t1, 
    table2 t2
WHERE 
    t1.id = 1 AND t2.id = 1;
+-------+---------------+---------------+
| t1_id | value_from_t1 | value_from_t2 |
+-------+---------------+---------------+
|     1 | b             | 4             |
+-------+---------------+---------------+
SELECT 
    t1.id AS t1_id,
    keyvalue(t1.data1, ';', ':', 'e') AS value_from_t1,
    keyvalue(t2.data2, ';', ':', '1') AS value_from_t2
FROM 
    table1 t1
LEFT JOIN 
    table2 t2 ON t1.id = 1;
+-------+---------------+---------------+
| t1_id | value_from_t1 | value_from_t2 |
+-------+---------------+---------------+
|     1 | NULL          | 2             |
|     1 | NULL          | NULL          |
|     2 | f             | NULL          |
+-------+---------------+---------------+
SELECT 
    t1.id AS t1_id,
    keyvalue(t1.data1, ';', ':', 'a') AS value_from_t1,
    keyvalue(t2.data2, ';', ':', '5') AS value_from_t2
FROM 
    table1 t1
RIGHT JOIN 
    table2 t2 ON t1.id = 2;
+-------+---------------+---------------+
| t1_id | value_from_t1 | value_from_t2 |
+-------+---------------+---------------+
|     2 | NULL          | 6             |
|     2 | NULL          | NULL          |
+-------+---------------+---------------+
SELECT 
    t1.id AS t1_id,
    keyvalue(t1.data1, ';', ':', 'g') AS value_from_t1,
    keyvalue(t2.data2, ';', ':', '4') AS value_from_t2
FROM 
    table1 t1
INNER JOIN 
    table2 t2 ON t1.id = 1 AND t2.id = 2;
+-------+---------------+---------------+
| t1_id | value_from_t1 | value_from_t2 |
+-------+---------------+---------------+
|     1 | NULL          | NULL          |
+-------+---------------+---------------+
SELECT 
    t1.id AS t1_id,
    keyvalue(t1.data1, ';', ':', 'b') AS value_from_t1,
    keyvalue(t2.data2, ';', ':', '7') AS value_from_t2
FROM 
    table1 t1
CROSS JOIN 
    table2 t2;
+-------+---------------+---------------+
| t1_id | value_from_t1 | value_from_t2 |
+-------+---------------+---------------+
|     1 | NULL          | 8             |
|     1 | NULL          | NULL          |
|     2 | NULL          | 8             |
|     2 | NULL          | NULL          |
+-------+---------------+---------------+
### PLзӣёе…іеңәжҷҜиҰҶзӣ–
drop table if exists test_data;
CREATE TABLE test_data (
    id INT AUTO_INCREMENT PRIMARY KEY,
    key_value_pairs TEXT NOT NULL
);
INSERT INTO test_data (key_value_pairs) VALUES
('a:b;c:d'),
('1:apple;2:banana;3:cherry'),
('x:10;y:20;z:30'),
('p:Red;q:Blue;r:Green');
CREATE PROCEDURE test_while_loop()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE v_result VARCHAR(255);
    DECLARE v_key_value_pairs TEXT;

    DECLARE cursor_data CURSOR FOR SELECT key_value_pairs FROM test_data;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    OPEN cursor_data;

    read_loop: LOOP
        FETCH cursor_data INTO v_key_value_pairs;
        IF done THEN
            LEAVE read_loop;
        END IF;

        SET v_result = keyvalue(v_key_value_pairs, ';', ':', '1');
        SELECT CONCAT('Using WHILE loop, key: 1, value: ', v_result);
    END LOOP;

    CLOSE cursor_data;
END;$$
CREATE PROCEDURE test_repeat_loop()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE v_result VARCHAR(255);
    DECLARE v_key_value_pairs TEXT;

    DECLARE cursor_data CURSOR FOR SELECT key_value_pairs FROM test_data;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    OPEN cursor_data;

    repeat_loop: LOOP
        FETCH cursor_data INTO v_key_value_pairs;

        SET v_result = keyvalue(v_key_value_pairs, ';', ':', 'p');
        SELECT CONCAT('Using REPEAT loop, key: p, value: ', v_result);

        IF done THEN
            LEAVE repeat_loop;
        END IF;
    END LOOP;

    CLOSE cursor_data;
END;$$
CREATE PROCEDURE test_loop()
BEGIN
    DECLARE v_result VARCHAR(255);
    DECLARE v_key_value_pairs TEXT;
    DECLARE counter INT DEFAULT 0;

    WHILE counter < 3 DO
        SET v_key_value_pairs = (SELECT key_value_pairs FROM test_data LIMIT 1 OFFSET counter);
        SET v_result = keyvalue(v_key_value_pairs, ';', ':', 'x');
        SELECT CONCAT('Using LOOP, key: x, value: ', v_result);
        SET counter = counter + 1;
    END WHILE;
END;$$
