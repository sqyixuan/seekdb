### SELECT+DMLдҪҝз”ЁиҰҶзӣ–
drop table if exists test_keyvalue;
CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data VARCHAR(255)
);
INSERT INTO test_keyvalue (data) VALUES
('a:b;c:d'),
('e:f;g:h'),
('i:j;k:l');
SELECT id, keyvalue(data, 'a') AS value FROM test_keyvalue WHERE id = 1;
+----+-------+
| id | value |
+----+-------+
|  1 | b     |
+----+-------+
SELECT id, keyvalue(data, ';', ':', 'a') AS value FROM test_keyvalue WHERE id = 1;
+----+-------+
| id | value |
+----+-------+
|  1 | b     |
+----+-------+
UPDATE test_keyvalue SET data = 'q:r;s:t' WHERE id = 1 AND keyvalue(data, 'a') IS NOT NULL;
DELETE FROM test_keyvalue WHERE id = 2 AND keyvalue(data, 'e') IS NULL;
INSERT INTO test_keyvalue (id, data) VALUES (4, 'm:n;o:p')
ON DUPLICATE KEY UPDATE data = CONCAT(data, ';', VALUES(data));
INSERT INTO test_keyvalue (data) VALUES (CONCAT('x:y;z:w', ';', keyvalue('a:b;c:d', 'a')));
UPDATE test_keyvalue SET data = CONCAT(data, ';', keyvalue(data, 'i')) WHERE id = 3;
DELETE FROM test_keyvalue WHERE keyvalue(data, 'm') IS NOT NULL;
drop table if exists test_keyvalue;
CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,  
    data_text TEXT,                     
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
INSERT INTO test_keyvalue (data_text) VALUES
('a:b;c:d'),
('x:y;z:w'),
('name1:value1;name2:value2;name3:value3'),
('key1:value1;key2:value2;key3:value3'),
('k1:v1;k2:v2;k3:v3;k4:v4');
SELECT 
    keyvalue(data_text, ';', ':', 'name2') AS result 
FROM 
    test_keyvalue 
WHERE 
    data_text LIKE '%name1:value1;name2:value2;name3:value3%';
+--------+
| result |
+--------+
| value2 |
+--------+
INSERT INTO test_keyvalue (data_text) 
SELECT 
    CONCAT('new_key:', keyvalue(data_text, ';', ':', 'key2')) 
FROM 
    test_keyvalue 
WHERE 
    id = 1;
UPDATE test_keyvalue 
SET data_text = CONCAT(data_text, ';new_key:new_value') 
WHERE 
    keyvalue(data_text, ';', ':', 'k2') IS NOT NULL;
DELETE FROM test_keyvalue 
WHERE 
    keyvalue(data_text, ';', ':', 'x') IS NOT NULL;
SELECT keyvalue(data_text, ';', ':', 'key3') AS result 
FROM test_keyvalue 
WHERE 
    data_text LIKE '%key1:value1%' 
    OR keyvalue(data_text, ';', ':', 'key2') = 'value2';
