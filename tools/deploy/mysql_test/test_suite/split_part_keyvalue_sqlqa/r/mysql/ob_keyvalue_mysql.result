| result |
+--------+
| NULL   |
| NULL   |
| NULL   |
| NULL   |
| v1     |
+--------+
SELECT 
    keyvalue(data_text, ';', ':', 'name3') AS result, 
    COUNT(*) AS cnt 
FROM 
    test_keyvalue 
GROUP BY 
