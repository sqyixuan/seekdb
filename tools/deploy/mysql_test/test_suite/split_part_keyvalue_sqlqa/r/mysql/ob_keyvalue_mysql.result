### еҲҶеҢәиЎЁ/и§Ҷеӣҫ/зҙўеј•/зәҰжқҹ/з”ҹжҲҗеҲ—зӯүзӣёе…іеңәжҷҜиҰҶзӣ–
drop table if exists partitioned_keyvalue;
CREATE TABLE partitioned_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    kv_data VARCHAR(255),
    kv_key VARCHAR(255),
    kv_value  VARCHAR(255)  GENERATED ALWAYS AS (keyvalue(kv_data, kv_key))
)
PARTITION BY RANGE (id) (
    PARTITION p0 VALUES LESS THAN (1000),
    PARTITION p1 VALUES LESS THAN (2000),
    PARTITION p2 VALUES LESS THAN (MAXVALUE)
);
CREATE UNIQUE INDEX idx_kv_key ON partitioned_keyvalue (id);
CREATE OR REPLACE VIEW view_keyvalue AS
SELECT id, kv_data, kv_key, kv_value
FROM partitioned_keyvalue;
ALTER TABLE partitioned_keyvalue
ADD CONSTRAINT chk_kv_key_not_null CHECK (kv_key IS NOT NULL);
