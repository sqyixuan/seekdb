+--------------------------+
| keyvalue('a:b;c:d', 'a') |
+--------------------------+
| b                        |
+--------------------------+
SELECT keyvalue('a:b;c:d', 'd');
+--------------------------+
| keyvalue('a:b;c:d', 'd') |
+--------------------------+
| NULL                     |
+--------------------------+
SELECT keyvalue('a:b;c:d', ';', ':', 'a');
+------------------------------------+
| keyvalue('a:b;c:d', ';', ':', 'a') |
+------------------------------------+
| b                                  |
+------------------------------------+
SELECT keyvalue(CONCAT(repeat_loop_func('NestedKey:Value'), 'a:b;c:d'), ';', ':', 'a');
+---------------------------------------------------------------------------------+
| keyvalue(CONCAT(repeat_loop_func('NestedKey:Value'), 'a:b;c:d'), ';', ':', 'a') |
+---------------------------------------------------------------------------------+
| NULL                                                                            |
+---------------------------------------------------------------------------------+
