drop table if exists test_table;
CREATE TABLE test_table (
    varchar_col VARCHAR(255),
    tinytext_col TINYTEXT,
    text_col TEXT,
    longtext_col LONGTEXT,
    int_col INT
);
INSERT INTO test_table (varchar_col, tinytext_col, text_col, longtext_col, int_col) 
VALUES ('a,b,c,d', 'a,b,c,d', 'a,b,c,d', 'a,b,c,d', 3);
SELECT split_part(varchar_col, ',', int_col) FROM test_table;
+---------------------------------------+
| split_part(varchar_col, ',', int_col) |
+---------------------------------------+
| c                                     |
+---------------------------------------+
SELECT split_part(tinytext_col, ',', int_col) FROM test_table;
+----------------------------------------+
| split_part(tinytext_col, ',', int_col) |
+----------------------------------------+
| c                                      |
+----------------------------------------+
SELECT split_part(text_col, ',', int_col) FROM test_table;
+------------------------------------+
| split_part(text_col, ',', int_col) |
+------------------------------------+
| c                                  |
+------------------------------------+
SELECT split_part(longtext_col, ',', int_col) FROM test_table;
+----------------------------------------+
| split_part(longtext_col, ',', int_col) |
+----------------------------------------+
| c                                      |
+----------------------------------------+
SELECT split_part(NULL, ',', int_col) FROM test_table;
+--------------------------------+
| split_part(NULL, ',', int_col) |
+--------------------------------+
| NULL                           |
+--------------------------------+
SELECT split_part(varchar_col, NULL, int_col) FROM test_table;
+----------------------------------------+
| split_part(varchar_col, NULL, int_col) |
+----------------------------------------+
| NULL                                   |
+----------------------------------------+
SELECT split_part(varchar_col, ',', NULL) FROM test_table;
+------------------------------------+
| split_part(varchar_col, ',', NULL) |
+------------------------------------+
| NULL                               |
+------------------------------------+
SELECT split_part(varchar_col, ',', 1, NULL) FROM test_table;
+---------------------------------------+
| split_part(varchar_col, ',', 1, NULL) |
+---------------------------------------+
| NULL                                  |
+---------------------------------------+
UPDATE test_table SET varchar_col = '' WHERE int_col = 3;
SELECT split_part(varchar_col, ',', int_col) FROM test_table;
+---------------------------------------+
| split_part(varchar_col, ',', int_col) |
+---------------------------------------+
|                                       |
+---------------------------------------+
SELECT split_part(varchar_col, '', int_col) FROM test_table;
+--------------------------------------+
| split_part(varchar_col, '', int_col) |
+--------------------------------------+
|                                      |
+--------------------------------------+
SELECT split_part(varchar_col, ',', 0) FROM test_table;
+---------------------------------+
| split_part(varchar_col, ',', 0) |
+---------------------------------+
|                                 |
+---------------------------------+
SELECT split_part(varchar_col, ',', -int_col) FROM test_table;
+----------------------------------------+
| split_part(varchar_col, ',', -int_col) |
+----------------------------------------+
|                                        |
+----------------------------------------+
SELECT split_part(varchar_col, ',', -int_col, -int_col + 1) FROM test_table;
+------------------------------------------------------+
| split_part(varchar_col, ',', -int_col, -int_col + 1) |
+------------------------------------------------------+
|                                                      |
+------------------------------------------------------+
SELECT split_part(varchar_col, 'x', 1) FROM test_table;
+---------------------------------+
| split_part(varchar_col, 'x', 1) |
+---------------------------------+
|                                 |
+---------------------------------+
