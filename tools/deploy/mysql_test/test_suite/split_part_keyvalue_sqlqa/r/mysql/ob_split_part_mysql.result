| split_part(keyvalue('a:b;c:d', ';', ':', 'c'), ':', 2) |
+--------------------------------------------------------+
|                                                        |
+--------------------------------------------------------+
SELECT split_part(keyvalue('x:y;z:w', ';', ':', 'x'), ':', 2);
+--------------------------------------------------------+
| split_part(keyvalue('x:y;z:w', ';', ':', 'x'), ':', 2) |
+--------------------------------------------------------+
|                                                        |
+--------------------------------------------------------+
SELECT split_part(keyvalue('x:y;z:w', ';', ':', 'notfound'), ':', 2);
+---------------------------------------------------------------+
| split_part(keyvalue('x:y;z:w', ';', ':', 'notfound'), ':', 2) |
+---------------------------------------------------------------+
| NULL                                                          |
