drop table if exists range_key_partitioned_table;
CREATE TABLE range_key_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY RANGE(id) SUBPARTITION BY KEY(id) (
    PARTITION p0 VALUES LESS THAN (10) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES LESS THAN (20) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);
