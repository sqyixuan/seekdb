### PLńøĖÕģ│Õ£║µÖ»Ķ”åńø¢
drop table if exists test_table;
CREATE TABLE test_table (
    id SERIAL PRIMARY KEY,
    string_col VARCHAR(255),
    delimiter_col VARCHAR(10),
    position_col INT,
    end_position_col INT
);
DROP PROCEDURE test_split_part_procedure;
CREATE PROCEDURE test_split_part_procedure()
BEGIN
    DECLARE v_string VARCHAR(255);
    DECLARE v_delimiter VARCHAR(10);
    DECLARE v_position INT;
    DECLARE v_result VARCHAR(255);
    DECLARE v_index INT DEFAULT 1;

    SET v_string = 'a,b,c,d';
    SET v_delimiter = ',';
    TRUNCATE TABLE test_table;

    WHILE v_index <= 4 DO
        INSERT INTO test_table (string_col, delimiter_col, position_col)
        VALUES (v_string, v_delimiter, v_index);
        SET v_index = v_index + 1;
    END WHILE;

    SET v_index = 1;

    WHILE v_index <= 4 DO
        SET v_result = split_part(v_string, v_delimiter, v_index);
        SELECT v_index, v_result;
        SET v_index = v_index + 1;
    END WHILE;
END;
//
CALL test_split_part_procedure();
+---------+----------+
| v_index | v_result |
+---------+----------+
+---------+----------+
| v_index | v_result |
+---------+----------+
+---------+----------+
| v_index | v_result |
+---------+----------+
+---------+----------+
| v_index | v_result |
+---------+----------+
|       1 | a        |
|       2 | b        |
|       3 | c        |
|       4 | d        |
+---------+----------+
+---------+----------+
+---------+----------+
+---------+----------+
drop table if exists test_table;
CREATE TABLE test_table (
    id SERIAL PRIMARY KEY,
    string_col VARCHAR(255),
    delimiter_col VARCHAR(10),
    position_col INT,
    result_col VARCHAR(255)
);
DROP TRIGGER IF EXISTS before_insert_test_table;
CREATE TRIGGER before_insert_test_table
BEFORE INSERT ON test_table
FOR EACH ROW
BEGIN
    DECLARE v_result VARCHAR(255);
   
    SET v_result = split_part(NEW.string_col, NEW.delimiter_col, NEW.position_col);

    SET NEW.result_col = v_result;
END;
//
INSERT INTO test_table (string_col, delimiter_col, position_col) VALUES ('a,b,c,d', ',', 1);
INSERT INTO test_table (string_col, delimiter_col, position_col) VALUES ('a,b,c,d', ',', 2);
INSERT INTO test_table (string_col, delimiter_col, position_col) VALUES ('a,b,c,d', ',', 3);
INSERT INTO test_table (string_col, delimiter_col, position_col) VALUES ('a,b,c,d', ',', 4);
SELECT * FROM test_table;
+----+------------+---------------+--------------+------------+
| id | string_col | delimiter_col | position_col | result_col |
+----+------------+---------------+--------------+------------+
|  1 | a,b,c,d    | ,             |            1 | a          |
|  2 | a,b,c,d    | ,             |            2 | b          |
|  3 | a,b,c,d    | ,             |            3 | c          |
|  4 | a,b,c,d    | ,             |            4 | d          |
+----+------------+---------------+--------------+------------+
DROP FUNCTION IF EXISTS my_split_part;
CREATE FUNCTION my_split_part(
    str1 VARCHAR(255),
    separator1 VARCHAR(10),
    start1 BIGINT,
    end1 BIGINT
) RETURNS VARCHAR(255)
BEGIN
    RETURN split_part(str1, separator1, start1, end1);
END;
//
SELECT my_split_part('a,b,c,d', ',', 1,2) AS part1;
