CREATE PROCEDURE test_split_part_loop()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE total INT;

    SELECT COUNT(*) INTO total FROM test_split_part;

    loop_label: LOOP
        IF i > total THEN
            LEAVE loop_label;
        END IF;

        SELECT 
            input_string, 
            delimiter, 
            index_return, 
            count_param, 
            split_part(input_string, delimiter, index_return, count_param) AS result
        FROM test_split_part
        WHERE id = i;

        SET i = i + 1;
    END LOOP;
END ;//
CALL test_split_part_loop();
