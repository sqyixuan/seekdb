drop table if exists range_hash_partitioned_table;
CREATE TABLE range_hash_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY RANGE(id) SUBPARTITION BY HASH(id) (
    PARTITION p0 VALUES LESS THAN (10) (
        SUBPARTITION sp0,
        SUBPARTITION sp1
    ),
    PARTITION p1 VALUES LESS THAN (20) (
        SUBPARTITION sp2,
        SUBPARTITION sp3
    )
);
