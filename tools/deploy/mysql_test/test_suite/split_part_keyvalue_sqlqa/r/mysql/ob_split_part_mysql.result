+---------+
| example |
+---------+
SELECT 
    split_part(
        split_part('cat,dog,fish', ',', 1, 2), 
        ',', 
        -1
    ) AS result;
+--------+
| result |
+--------+
| dog    |
+--------+
SELECT 
    split_part(
        'Monday,Tuesday,Wednesday', 
        ',', 
        split_part('1,2,3', ',', -1)
    ) AS result;
+-----------+
| result    |
+-----------+
| Wednesday |
+-----------+
SELECT 
    split_part(
        split_part('', ',', 1), 
        ',', 
        1
    ) AS result;
+--------+
| result |
+--------+
|        |
+--------+
SELECT 
    split_part(
        split_part(NULL, ',', 1), 
        ',', 
        NULL
    ) AS result;
+--------+
| result |
+--------+
| NULL   |
+--------+
SELECT 
    split_part(
        split_part('x,y,z', '|', 1), 
        '|', 
        1
    ) AS result;
+--------+
| result |
+--------+
| x,y,z  |
+--------+
SELECT split_part(keyvalue('a:b;c:d', ';'), ':', 1);
