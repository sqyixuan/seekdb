    id SERIAL PRIMARY KEY,
    string_col VARCHAR(255),
    delimiter_col VARCHAR(10),
    position_col INT,
    end_position_col INT,
    split_result VARCHAR(255) GENERATED ALWAYS AS (split_part(string_col, delimiter_col, position_col, end_position_col)) STORED
);
ALTER TABLE test_table ADD CONSTRAINT unique_split_result UNIQUE (split_result);
CREATE INDEX idx_split_result ON test_table (split_result);
CREATE VIEW test_view AS
SELECT id, string_col, delimiter_col, position_col, split_part(string_col, delimiter_col, position_col) AS view_split_result
FROM test_table;
