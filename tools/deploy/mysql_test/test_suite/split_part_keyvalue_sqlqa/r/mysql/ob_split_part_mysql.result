###  µ»öĶŠāĶ┐Éń«Śń¼”
###  >, >=, <, <=, =, !=
SELECT
    split_part('a,b,c,d', ',', 1) > split_part('a,b,c,d', ',', 2) AS greater_than,
    split_part('a,b,c,d', ',', 1) >= split_part('a,b,c,d', ',', 1) AS greater_equal,
    split_part('a,b,c,d', ',', 3) < split_part('a,b,c,d', ',', 4) AS less_than,
    split_part('a,b,c,d', ',', 3) <= split_part('a,b,c,d', ',', 3) AS less_equal,
    split_part('a,b,c,d', ',', 2) = split_part('a,b,c,d', ',', 2) AS equal,
    split_part('a,b,c,d', ',', 1) != split_part('a,b,c,d', ',', 3) AS not_equal;
+--------------+---------------+-----------+------------+-------+-----------+
| greater_than | greater_equal | less_than | less_equal | equal | not_equal |
+--------------+---------------+-----------+------------+-------+-----------+
|            0 |             1 |         1 |          1 |     1 |         1 |
+--------------+---------------+-----------+------------+-------+-----------+
### IN / NOT IN
SELECT 
    split_part('a,b,c,d', ',', 1) IN ('a', 'b', 'c', 'd') AS in_set,
    split_part('a,b,c,d', ',', 2) NOT IN ('x', 'y', 'z') AS not_in_set;
+--------+------------+
| in_set | not_in_set |
+--------+------------+
|      1 |          1 |
+--------+------------+
### IS NULL / IS NOT NULL
SELECT 
    split_part(NULL, ',', 1) IS NULL AS is_null_test,
    split_part('a,b,c,d', ',', 1) IS NOT NULL AS is_not_null_test;
+--------------+------------------+
| is_null_test | is_not_null_test |
+--------------+------------------+
|            1 |                1 |
+--------------+------------------+
### BETWEEN AND / NOT BETWEEN AND
SELECT 
    split_part('1,2,3,4', ',', 2) BETWEEN '1' AND '3' AS between_test,
    split_part('1,2,3,4', ',', 4) NOT BETWEEN '1' AND '3' AS not_between_test;
+--------------+------------------+
| between_test | not_between_test |
+--------------+------------------+
|            1 |                1 |
+--------------+------------------+
### LIKE
