DROP TABLE IF EXISTS test_split_part;
CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    input_str TEXT,
    delimiter VARCHAR(10),
    part_index INT,
    part_index2 INT,
    expected_output TEXT
);
INSERT INTO test_split_part (input_str, delimiter, part_index, part_index2, expected_output) VALUES
('a,b,c,d', ',', 1, NULL, 'a'),
('a,b,c,d', ',', 0, NULL, 'a'),
('a,b,c,d', ',', -1, NULL, 'd'),
('a,b,c,d', ',', 10, NULL, ''),
('a,b,c,d', ',', 1, 2, 'a,b'),
('a,b,c,d', ',', 1, 3, 'a,b,c'),
