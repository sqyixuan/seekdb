CREATE FUNCTION my_split_part(input VARCHAR(255), delimiter VARCHAR(1), position INT)
RETURNS VARCHAR(255) 
DETERMINISTIC
BEGIN
    RETURN split_part(input, delimiter, position);
END; $$
