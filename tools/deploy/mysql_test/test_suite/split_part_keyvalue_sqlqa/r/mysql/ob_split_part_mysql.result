drop table if exists users;
drop table if exists orders;
CREATE TABLE users (
    user_id INT PRIMARY KEY,
    user_name VARCHAR(100),
    user_info TEXT
);
CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    user_id INT,
    product VARCHAR(100),
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);
INSERT INTO users (user_id, user_name, user_info)
VALUES 
(1, 'Alice', 'Alice,birthday,single'),
(2, 'Bob', 'Bob,age,30'),
(3, 'Charlie', 'Charlie,age,25');
