DROP PROCEDURE IF EXISTS test_split_part_proc;
CREATE PROCEDURE test_split_part_proc()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE current_input_str TEXT;
    DECLARE current_delimiter VARCHAR(10);
    DECLARE current_part_index INT;
    DECLARE current_part_index2 INT;
    DECLARE current_expected_output TEXT;
    DECLARE current_output TEXT;

    DECLARE split_part_cursor CURSOR FOR
        SELECT input_str, delimiter, part_index, part_index2, expected_output FROM test_split_part;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN split_part_cursor;

    read_loop: LOOP
        FETCH split_part_cursor INTO current_input_str, current_delimiter, current_part_index, current_part_index2, current_expected_output;

        IF done THEN
            LEAVE read_loop;
        END IF;

        IF current_part_index2 IS NULL THEN
            SET current_output = split_part(current_input_str, current_delimiter, current_part_index);
        ELSE
            SET current_output = split_part(current_input_str, current_delimiter, current_part_index, current_part_index2);
        END IF;

        SELECT current_input_str AS input_str,
               current_delimiter AS delimiter,
               current_part_index AS part_index,
               current_part_index2 AS part_index2,
               current_expected_output AS expected,
               current_output AS actual;
    END LOOP;

    CLOSE split_part_cursor;
END;$$
CALL test_split_part_proc();
