SET NAMES 'utf8mb4';
drop table if exists split_part_test;
CREATE TABLE split_part_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    test_string VARCHAR(255) CHARACTER SET utf8mb4,
    binary_string BINARY(255),
    gbk_string VARCHAR(255) CHARACTER SET gbk,
    gb18030_string VARCHAR(255) CHARACTER SET gb18030,
    latin1_string VARCHAR(255) CHARACTER SET latin1
);
INSERT INTO split_part_test (test_string, binary_string, gbk_string, gb18030_string, latin1_string) VALUES
('a,b,c,d', _binary 'a,b,c,d', 'a,b,c,d', 'a,b,c,d' , 'a,b,c,d' );
SELECT split_part(test_string, ',', 1) FROM split_part_test;
+---------------------------------+
| split_part(test_string, ',', 1) |
+---------------------------------+
| a                               |
+---------------------------------+
SELECT split_part(test_string, ',', 2) FROM split_part_test;
+---------------------------------+
| split_part(test_string, ',', 2) |
+---------------------------------+
| b                               |
+---------------------------------+
SELECT split_part(test_string, ',', 3) FROM split_part_test;
+---------------------------------+
| split_part(test_string, ',', 3) |
+---------------------------------+
| c                               |
+---------------------------------+
SELECT split_part(test_string, ',', -1) FROM split_part_test;
+----------------------------------+
| split_part(test_string, ',', -1) |
+----------------------------------+
| d                                |
+----------------------------------+
SELECT split_part(test_string, ',', 10) FROM split_part_test;
+----------------------------------+
| split_part(test_string, ',', 10) |
+----------------------------------+
