drop table if exists test_split_part;
CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    date_col DATE,
    time_col TIME,
    year_col YEAR,
    datetime_col TIMESTAMP,
    timestamp_col TIMESTAMP,
    text_col TEXT
);
INSERT INTO test_split_part (date_col, time_col, year_col, datetime_col, timestamp_col, text_col) VALUES
('2023-01-01', '12:34:56', 2023, '2023-01-01 12:34:56', '20230101', 'a,b,c,d'),
('2023-12-31', '23:59:59', 2023, '2023-12-31 23:59:59', '20231231', 'apple,banana,carrot,date');
SELECT split_part(date_col, '-', 1) AS Year FROM test_split_part;
+------+
| Year |
+------+
| 2023 |
| 2023 |
+------+
SELECT split_part(time_col, ':', 1) AS Hours FROM test_split_part;
+-------+
| Hours |
+-------+
| 12    |
| 23    |
+-------+
SELECT split_part(CONVERT(year_col USING utf8), '', 1) AS Year_Value FROM test_split_part;
+------------+
| Year_Value |
+------------+
| 2023       |
| 2023       |
+------------+
SELECT split_part(datetime_col, ' ', 1) AS Date_Part FROM test_split_part;
+------------+
| Date_Part  |
+------------+
| 2023-01-01 |
| 2023-12-31 |
+------------+
SELECT split_part(timestamp_col, ' ', 1) AS Timestamp_Part FROM test_split_part;
+----------------+
| Timestamp_Part |
+----------------+
| 2023-01-01     |
| 2023-12-31     |
+----------------+
SELECT split_part(text_col, ',', 1) AS First_Part FROM test_split_part;
+------------+
| First_Part |
+------------+
| a          |
| apple      |
+------------+
SELECT split_part(text_col, ',', -1) AS Last_Part FROM test_split_part;
+-----------+
| Last_Part |
+-----------+
| d         |
| date      |
+-----------+
SELECT split_part(text_col, ',', 1, 2) AS First_Two FROM test_split_part;
+--------------+
| First_Two    |
+--------------+
| a,b          |
| apple,banana |
+--------------+
SELECT split_part(text_col, ',', -4, -2) AS Negative_Example FROM test_split_part;
