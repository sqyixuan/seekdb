drop table if exists split_part_test;
CREATE TABLE split_part_test (
id INT,
test_string TINYTEXT,
separator1 VARCHAR(10),
expected_output VARCHAR(255));
INSERT INTO split_part_test (test_string, separator1, expected_output) VALUES 
('a,b,c,d', ',', 'a'),
('a,b,c,d', ',', 'a'),
('a,b,c,d', ',', 'd'),
('a,b,c,d', ',', ''), 
('a,b,c,d', NULL, 'a,b,c,d'), 
(NULL, ',', NULL),  
('a,b,c,d', ',', 'a,b'),  
('a,b,c,d', ',', 'a,b,c'),  
('a,b,c,d', ',', 'a,b,c'), 
('a,b,c,d', ',', 'a,b,c,d'),
('a,b,c,d', ',', NULL), 
('test', ',', 'test'), 
('a', ',', 'a'), 
('a,,b,c,d', ',', 'b') 
;
SELECT test_string, separator1, 
       split_part(test_string, separator1, 1) AS result1, 
       split_part(test_string, separator1, 0) AS result0, 
       split_part(test_string, separator1, -1) AS resultNeg1, 
       split_part(test_string, separator1, 1, 2) AS result12, 
       split_part(test_string, separator1, 1, 3) AS result13, 
       split_part(test_string, separator1, -4, -2) AS resultNeg42, 
       split_part(test_string, separator1, 1, 10) AS result110 
FROM split_part_test;
+-------------+------------+---------+---------+------------+----------+----------+-------------+-----------+
| test_string | separator1 | result1 | result0 | resultNeg1 | result12 | result13 | resultNeg42 | result110 |
+-------------+------------+---------+---------+------------+----------+----------+-------------+-----------+
| NULL        | ,          | NULL    | NULL    | NULL       | NULL     | NULL     | NULL        | NULL      |
| a           | ,          | a       | a       | a          | a        | a        |             | a         |
| a,,b,c,d    | ,          | a       | a       | d          | a,       | a,,b     | ,b,c        | a,,b,c,d  |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | ,          | a       | a       | d          | a,b      | a,b,c    | a,b,c       | a,b,c,d   |
| a,b,c,d     | NULL       | NULL    | NULL    | NULL       | NULL     | NULL     | NULL        | NULL      |
| test        | ,          | test    | test    | test       | test     | test     |             | test      |
