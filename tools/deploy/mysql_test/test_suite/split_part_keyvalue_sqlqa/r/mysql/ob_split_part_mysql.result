    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY LIST(id) SUBPARTITION BY HASH(id) (
    PARTITION p0 VALUES IN (1, 2) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES IN (3, 4) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);
INSERT INTO list_hash_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', 1, 3) FROM list_hash_partitioned_table WHERE id = 1;
+-----------------------------+
| split_part(data, ',', 1, 3) |
+-----------------------------+
| a,b,c                       |
+-----------------------------+
drop table if exists list_key_partitioned_table;
CREATE TABLE list_key_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY LIST(id) SUBPARTITION BY KEY(id) (
    PARTITION p0 VALUES IN (1, 2) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES IN (3, 4) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);
INSERT INTO list_key_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', -4, -2) FROM list_key_partitioned_table WHERE id = 1;
+-------------------------------+
| split_part(data, ',', -4, -2) |
+-------------------------------+
| a,b,c                         |
+-------------------------------+
drop table if exists test_strings;
CREATE TABLE test_strings (
    id INT AUTO_INCREMENT PRIMARY KEY,
    str TEXT
);
INSERT INTO test_strings (str) VALUES 
('a,b,c,d'), 
('1,2,3,4,5'),
('apple,banana,cherry'),
(NULL),
('only_one_part');
CREATE OR REPLACE VIEW string_parts AS 
SELECT 
    id,
    str,
    split_part(str, ',', 1) AS part1,
    split_part(str, ',', 2) AS part2,
    split_part(str, ',', 3) AS part3
FROM 
    test_strings;
SELECT * FROM string_parts;
+----+---------------------+---------------+--------+--------+
| id | str                 | part1         | part2  | part3  |
+----+---------------------+---------------+--------+--------+
|  1 | a,b,c,d             | a             | b      | c      |
|  2 | 1,2,3,4,5           | 1             | 2      | 3      |
|  3 | apple,banana,cherry | apple         | banana | cherry |
|  4 | NULL                | NULL          | NULL   | NULL   |
|  5 | only_one_part       | only_one_part |        |        |
+----+---------------------+---------------+--------+--------+
INSERT INTO test_strings (str) VALUES ('x,y,z');
SELECT * FROM string_parts;
+----+---------------------+---------------+--------+--------+
| id | str                 | part1         | part2  | part3  |
+----+---------------------+---------------+--------+--------+
|  1 | a,b,c,d             | a             | b      | c      |
|  2 | 1,2,3,4,5           | 1             | 2      | 3      |
|  3 | apple,banana,cherry | apple         | banana | cherry |
|  4 | NULL                | NULL          | NULL   | NULL   |
|  5 | only_one_part       | only_one_part |        |        |
|  6 | x,y,z               | x             | y      | z      |
+----+---------------------+---------------+--------+--------+
UPDATE test_strings SET str = 'update,test,case' WHERE id = 1;
SELECT * FROM string_parts;
+----+---------------------+---------------+--------+--------+
| id | str                 | part1         | part2  | part3  |
+----+---------------------+---------------+--------+--------+
|  1 | update,test,case    | update        | test   | case   |
|  2 | 1,2,3,4,5           | 1             | 2      | 3      |
|  3 | apple,banana,cherry | apple         | banana | cherry |
|  4 | NULL                | NULL          | NULL   | NULL   |
|  5 | only_one_part       | only_one_part |        |        |
|  6 | x,y,z               | x             | y      | z      |
+----+---------------------+---------------+--------+--------+
DELETE FROM test_strings WHERE id = 2;
SELECT * FROM string_parts;
