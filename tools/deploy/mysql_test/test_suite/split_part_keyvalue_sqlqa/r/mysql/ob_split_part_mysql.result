drop table if exists test_split_part;
CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    part_string TEXT,          
    part_delimiter VARCHAR(100),
    index (part_delimiter)
);
INSERT INTO test_split_part (part_string, part_delimiter) VALUES ('apple,banana,cherry', ',');
SELECT split_part(part_string, part_delimiter, 1) FROM test_split_part;
+--------------------------------------------+
| split_part(part_string, part_delimiter, 1) |
+--------------------------------------------+
| apple                                      |
+--------------------------------------------+
INSERT INTO test_split_part (part_string, part_delimiter) VALUES ('orange,grape', 'unique_delimiter');
SELECT split_part(part_string, 'unique_delimiter', 1) FROM test_split_part;
+------------------------------------------------+
| split_part(part_string, 'unique_delimiter', 1) |
+------------------------------------------------+
| apple,banana,cherry                            |
| orange,grape                                   |
+------------------------------------------------+
INSERT INTO test_split_part (part_string, part_delimiter) VALUES ('mango,pineapple,lemon', '|');
SELECT split_part(part_string, '|', 2) FROM test_split_part WHERE part_delimiter = '|';
+---------------------------------+
| split_part(part_string, '|', 2) |
+---------------------------------+
|                                 |
+---------------------------------+
drop table if exists test_split_part;
CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    original_string VARCHAR(255),
    delimiter VARCHAR(10),
    split_part_1 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 1)) STORED,
    split_part_2 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 2)) STORED,
    split_part_3 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 3)) STORED,
    split_part_4 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 4)) STORED,
    split_part_neg_1 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, -1)) STORED,
    split_part_1_2 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 1, 2)) STORED,
    split_part_1_3 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, 1, 3)) STORED,
    split_part_neg_4_neg_2 VARCHAR(255) GENERATED ALWAYS AS (split_part(original_string, delimiter, -4, -2)) STORED
);
INSERT INTO test_split_part (original_string, delimiter) VALUES
('a,b,c,d', ','),
('abc', NULL),
('1;2;3;4', ';'),
(NULL, ','),
('foo', '|');
SELECT id, original_string, delimiter,
       split_part_1, split_part_2, split_part_3, split_part_4,
       split_part_neg_1, split_part_1_2, split_part_1_3,
       split_part_neg_4_neg_2
FROM test_split_part;
+----+-----------------+-----------+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
| id | original_string | delimiter | split_part_1 | split_part_2 | split_part_3 | split_part_4 | split_part_neg_1 | split_part_1_2 | split_part_1_3 | split_part_neg_4_neg_2 |
+----+-----------------+-----------+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
|  1 | a,b,c,d         | ,         | a            | b            | c            | d            | d                | a,b            | a,b,c          | a,b,c                  |
|  2 | abc             | NULL      | NULL         | NULL         | NULL         | NULL         | NULL             | NULL           | NULL           | NULL                   |
|  3 | 1;2;3;4         | ;         | 1            | 2            | 3            | 4            | 4                | 1;2            | 1;2;3          | 1;2;3                  |
|  4 | NULL            | ,         | NULL         | NULL         | NULL         | NULL         | NULL             | NULL           | NULL           | NULL                   |
|  5 | foo             | |         | foo          |              |              |              | foo              | foo            | foo            |                        |
+----+-----------------+-----------+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
SELECT 
       split_part_1, split_part_2, split_part_3, split_part_4,
       split_part_neg_1, split_part_1_2, split_part_1_3,
       split_part_neg_4_neg_2
FROM test_split_part;
+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
| split_part_1 | split_part_2 | split_part_3 | split_part_4 | split_part_neg_1 | split_part_1_2 | split_part_1_3 | split_part_neg_4_neg_2 |
+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
| 1            | 2            | 3            | 4            | 4                | 1;2            | 1;2;3          | 1;2;3                  |
| NULL         | NULL         | NULL         | NULL         | NULL             | NULL           | NULL           | NULL                   |
| NULL         | NULL         | NULL         | NULL         | NULL             | NULL           | NULL           | NULL                   |
| a            | b            | c            | d            | d                | a,b            | a,b,c          | a,b,c                  |
| foo          |              |              |              | foo              | foo            | foo            |                        |
+--------------+--------------+--------------+--------------+------------------+----------------+----------------+------------------------+
SELECT split_part_1 FROM test_split_part;
+--------------+
| split_part_1 |
+--------------+
| 1            |
| NULL         |
| NULL         |
| a            |
| foo          |
+--------------+
SELECT split_part_2 FROM test_split_part;
+--------------+
| split_part_2 |
+--------------+
|              |
| 2            |
| NULL         |
| NULL         |
| b            |
+--------------+
SELECT split_part_neg_1 FROM test_split_part;
+------------------+
| split_part_neg_1 |
+------------------+
| 4                |
| NULL             |
| NULL             |
| d                |
| foo              |
+------------------+
SELECT split_part_1_3 FROM test_split_part;
