CREATE PROCEDURE test_split_part_while()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE total INT;
    
    SELECT COUNT(*) INTO total FROM test_split_part;

    WHILE i <= total DO
        SELECT 
            input_string, 
            delimiter, 
            index_return, 
            count_param, 
            split_part(input_string, delimiter, index_return, count_param) AS result
        FROM test_split_part
        WHERE id = i;
        SET i = i + 1;
    END WHILE;
END; //
CALL test_split_part_while();
