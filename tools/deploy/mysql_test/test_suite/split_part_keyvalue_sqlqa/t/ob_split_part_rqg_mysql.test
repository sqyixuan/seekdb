purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;

--echo ### 基础case
set sql_mode='';
SELECT REPEAT(SPLIT_PART('foo,bar', ',', 1), 3) NOT LIKE '01245%' AS NEW_ALIAS4;
SELECT INT2IP(SPLIT_PART('19216801,19216802', ',', 1)) > SPLIT_PART('a,b,c,d', '', '') AS NEW_ALIAS1;
SELECT MD5(SPLIT_PART('abc,def', ',', 2)) IS NOT NULL;
SELECT POSITION(SPLIT_PART('apple,banana,cherry', ',', 2) IN 'banana');
SELECT POSITION(SPLIT_PART('apple,banana,cherry', ',', 2) IN 'banana') LIKE ' a b%';
SELECT IP2INT(SPLIT_PART('192.168.1.1,192.168.1.2', ',', 1));
SELECT LOWER(SPLIT_PART('HELLO, World', ',', 2));

SELECT ORA_DECODE(SPLIT_PART('cat,dog,bird', ',', 3), 'bird', 'Found a bird', 'No match') LIKE '%F%' AS NEW_ALIAS4;
SELECT LENGTH(SPLIT_PART('a,b,c,d', ',', 3)) = ORA_DECODE(SPLIT_PART('cat,dog,bird', ',', 3), 'bird', 'Found a bird', 'No match') AS NEW_ALIAS1;
SELECT LTRIM(SPLIT_PART(' leftTrim, rightTrim', ',', 1)) < UPPER(SPLIT_PART('hello,world', ',', 2)) AS NEW_ALIAS1;
SELECT LTRIM(SPLIT_PART(' leftTrim, rightTrim', ',', 1)) = REPLACE(SPLIT_PART('apple,banana,cherry', ',', 2), 'banana', 'grape') AS NEW_ALIAS1;
SELECT LTRIM(SPLIT_PART(' leftTrim, rightTrim', ',', 1));
SELECT REPLACE(SPLIT_PART('apple,banana,cherry', ',', 2), 'banana', 'grape');
SELECT MD5(SPLIT_PART('abc,def', ',', 2)) != RPAD(SPLIT_PART('1234,5678', ',', 1), 10, '0') AS NEW_ALIAS1;
SELECT LOWER(SPLIT_PART('HELLO, World', ',', 2)) > CHAR_LENGTH(SPLIT_PART('a,b,c,d', ',', 2)) AS NEW_ALIAS1;
SELECT SUBSTRING_INDEX(SPLIT_PART('a,b,c,d', ',', 2), ',', -1) < HEX(SPLIT_PART('abc,def', ',', 1)) AS NEW_ALIAS1;
SELECT INSTR(SPLIT_PART('apple,banana,cherry', ',', 3), 'e') < IP2INT(SPLIT_PART('192.168.1.1,192.168.1.2', ',', 1)) AS NEW_ALIAS1;

SELECT NULLIF(SPLIT_PART('1,2,3', ',', 2), '2') & NULLIF(SPLIT_PART('1,2,3', ',', 2), '2') AS NEW_ALIAS1;
SELECT SPLIT_PART('a,b,c,d', '', '');
SELECT IP2INT(SPLIT_PART('192.168.1.1,192.168.1.2', ',', 1));
SELECT TRIM(SPLIT_PART(' space1, space2 ', ',', 2));
SELECT TRIM(SPLIT_PART(' space1, space2 ', ',', 2)) IS NULL;
SELECT INSTR(SPLIT_PART('apple,banana,cherry', ',', 3), 'e');
SELECT TRIM(SPLIT_PART(' space1, space2 ', ',', 2)) IS NOT NULL AS NEW_ALIAS3;
SELECT ORA_DECODE(SPLIT_PART('cat,dog,bird', ',', 3), 'bird', 'Found a bird', 'No match') REGEXP '^[a-zA-Z]+' AS REGEXP_TEST;
SELECT UNHEX(SPLIT_PART('616263,646566', ',', 1)) IS NOT NULL;
SELECT QUOTE(SPLIT_PART('my_string,another_string', ',', 1)) <= NULLIF(SPLIT_PART('1,2,3', ',', 2), '2') AS NEW_ALIAS1;

