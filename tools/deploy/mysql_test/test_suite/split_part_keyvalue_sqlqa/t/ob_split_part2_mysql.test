--echo ### DML
--disable_warnings
drop table if exists test_split;
--enable_warnings

CREATE TABLE test_split (
    id INT PRIMARY KEY,
    data TEXT,
    part1 VARCHAR(20) GENERATED ALWAYS AS (split_part(data, ',', 1))
);

INSERT INTO test_split(id, data) VALUES(1, split_part('a;b;c', ';', 2));
UPDATE test_split SET data = split_part(data, ',', 1) WHERE id = 1;
DELETE FROM test_split WHERE split_part(data, ',', 1) = 'a';

--echo ### PROCEDURE

--disable_warnings
drop PROCEDURE if exists test_split_proc;
--enable_warnings

DELIMITER //;
CREATE PROCEDURE test_split_proc()
BEGIN
    DECLARE v_str VARCHAR(100);
    DECLARE i INT DEFAULT -3;
    WHILE i <= 3 DO
        SELECT split_part('a,b,c,d', ',', i) INTO v_str;
        SET i = i + 1;
    END WHILE;
   
    SELECT split_part(data, ',', 1) FROM test_split;
END//
DELIMITER ;//
call test_split_proc();

--echo ### VIEW

CREATE OR REPLACE VIEW split_view AS
SELECT split_part(data, ',', 1) AS part1 FROM test_split;

ALTER TABLE test_split ADD COLUMN part2 VARCHAR(20) 
GENERATED ALWAYS AS (split_part(data, ',', 2)) VIRTUAL;

--disable_warnings
drop TABLE if exists partitioned_table;
--enable_warnings

--error 1564
CREATE TABLE partitioned_table (
    id INT,
    data VARCHAR(100)
) PARTITION BY RANGE (split_part(data, ',', 1)) (
    PARTITION p0 VALUES LESS THAN ('c'),
    PARTITION p1 VALUES LESS THAN (MAXVALUE)
);

