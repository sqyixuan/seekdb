--disable_warnings
drop TABLE if exists data_table;
--enable_warnings

CREATE TABLE data_table (
    id INT PRIMARY KEY,
    full_path VARCHAR(255),
    first_part VARCHAR(50) GENERATED ALWAYS AS (split_part(full_path, '/', 1))
);

INSERT INTO data_table(id,full_path) VALUES (1,'2');
SELECT * FROM data_table;

CREATE OR REPLACE VIEW type_mix_view AS 
SELECT split_part(CAST(id AS CHAR), '5', 2) FROM data_table;
SELECT split_part('2023-02-30', '-', 3);
SELECT split_part('127.0.0.1', '.', 256);

--disable_warnings
drop TABLE if exists partitioned_table;
--enable_warnings

--ERROR 1064
CREATE TABLE partitioned_table (
    id INT,
    ip VARCHAR(15)
) PARTITION BY KEY(split_part(ip, '.', 1));

--disable_warnings
drop TABLE if exists gsi_table;
--enable_warnings

--ERROR 1064
CREATE TABLE gsi_table (
    uuid VARCHAR(36),
    parts VARCHAR(100),
    INDEX idx_part (split_part(parts, '-', 2))
);

