#--ERROR 4016
WITH RECURSIVE split_cte AS (
    SELECT 1 AS pos, split_part('a,b,c,d', ',', 1) AS element
    UNION ALL
    SELECT pos+1, split_part('a,b,c,d', ',', pos+1)
    FROM split_cte
    WHERE pos < LENGTH('a,b,c,d') - LENGTH(REPLACE('a,b,c,d', ',', '')) +1
)
SELECT * FROM split_cte;

SELECT split_part(
    split_part(
        split_part('level1:level2:level3', ':', 3),
        'l', 
        -1
    ),
    'e',
    2
);

