DELIMITER //;
CREATE PROCEDURE type_test_proc()
BEGIN
    DECLARE v1 BLOB;
    SET v1 = 'a,b,c';
    SELECT split_part(v1, ',', 2);
END;//
DELIMITER ;//

CALL type_test_proc();

