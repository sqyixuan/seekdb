PREPARE stmt FROM 
'SELECT split_part(?, ?, ?)';
SET @s='a,b,c', @d=',', @n=2;
EXECUTE stmt USING @s, @d, @n;

SET @var1 = 'key1:value1;key2:value2';
SELECT split_part(
    split_part(@var1, ';', 2),
    ':',
    2
);

SELECT split_part(
    BINARY 'A,B,C',
    BINARY ',',
    2
);

SELECT split_part(
    ST_AsText(POINT(1,2)),
    ' ',
    2
);

SELECT split_part(
    split_part(
        split_part(
            split_part(
                split_part('a|b|c|d|e', '|', 3),
                'b',
                2
            ),
            'c',
            1
        ),
        'd',
        -1
    ),
    'e',
    0
);

SELECT split_part(
    REPEAT(
        CONCAT(split_part('a,b,c', ',', 2), ','),
        1000
    ), 
    ',', 
    500
);

SELECT split_part(
    split_part(NULL, ',', 1),
    ';',
    2
);

SELECT split_part(
    split_part('a,b,c', ',', 'invalid'),
    'b',
    1
);

SELECT BENCHMARK(100, 
    split_part(
        split_part('a,b,c', ',', 2),
        'b',
        1
    )
);

--disable_warnings
drop PROCEDURE if exists nested_split;
--enable_warnings

DELIMITER //;
CREATE PROCEDURE nested_split()
BEGIN
    DECLARE res TEXT;
    SET res = split_part(split_part('a;b;c', ';', 2), 'b', 1);
    SELECT split_part(res, ';', 1);
END//
DELIMITER ;//

call nested_split();

SELECT CAST(split_part(CAST('a,b,c' AS CHAR), ',', 2) AS CHAR) AS result;
SELECT split_part(REPEAT(CONCAT('data', ',', 'test'), 1000), ',', 500);
SELECT split_part(b'011000010110001001100011', b'01100010', 2);
SELECT split_part(123456, '3', 2); 
SELECT split_part(3.1415926, '.', 2); 

SELECT split_part(true, 'ru', 1); 
SELECT split_part(false, 'al', 2); 
### SELECT split_part(CURDATE(), '-', 2);
### SELECT split_part(NOW(6), ':', 3);
SELECT split_part(JSON_UNQUOTE(JSON_EXTRACT('{"path":"a/b/c"}', '$.path')), '/', 3);

