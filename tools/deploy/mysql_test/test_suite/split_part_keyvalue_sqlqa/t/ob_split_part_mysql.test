--ERROR 0,1305
DROP PROCEDURE test_split_part_procedure;
delimiter //;
CREATE PROCEDURE test_split_part_procedure()
BEGIN
    DECLARE v_string VARCHAR(255);
    DECLARE v_delimiter VARCHAR(10);
    DECLARE v_position INT;
    DECLARE v_result VARCHAR(255);
    DECLARE v_index INT DEFAULT 1;

    SET v_string = 'a,b,c,d';
    SET v_delimiter = ',';
    TRUNCATE TABLE test_table;

    WHILE v_index <= 4 DO
        INSERT INTO test_table (string_col, delimiter_col, position_col)
        VALUES (v_string, v_delimiter, v_index);
        SET v_index = v_index + 1;
    END WHILE;

    SET v_index = 1;

    WHILE v_index <= 4 DO
        SET v_result = split_part(v_string, v_delimiter, v_index);
        SELECT v_index, v_result;
        SET v_index = v_index + 1;
    END WHILE;
END;
//

delimiter ;//
CALL test_split_part_procedure();

