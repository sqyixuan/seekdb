DROP FUNCTION IF EXISTS my_split_part;
--enable_warnings

DELIMITER $$;
CREATE FUNCTION my_split_part(input VARCHAR(255), delimiter VARCHAR(1), position INT)
RETURNS VARCHAR(255) 
DETERMINISTIC
BEGIN
    RETURN split_part(input, delimiter, position);
END; $$

DELIMITER ;$$
SELECT my_split_part(NULL, NULL, NULL);
SELECT my_split_part('hello,world', ',', 1);
SELECT my_split_part('a,b,c,d', ',', 2);
SELECT my_split_part('a,b,c,d', ',', -1);
### SELECT my_split_part(CONCAT('1,2,3,4,5', RAND()), ',', 1);
