--echo ###  覆盖PL

--disable_warnings
DROP TABLE IF EXISTS test_split_part;
DROP PROCEDURE IF EXISTS test_split_part_procedure;
DROP PROCEDURE IF EXISTS test_split_part_while;
DROP PROCEDURE IF EXISTS test_split_part_repeat;
DROP PROCEDURE IF EXISTS test_split_part_loop;
--enable_warnings

CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    input_string TEXT,
    delimiter VARCHAR(10),
    index_return INT,
    count_param INT
);

INSERT INTO test_split_part (input_string, delimiter, index_return, count_param) VALUES
('a,b,c,d', ',', 1, 2),
('a,b,c,d', ',', 2, 3),
('a,b,c,d', ',', 1, NULL),
('a,b,c,d', ',', 0, 2),
('a,b,c,d', ',', -1, 2),
('a,b,c,d', ',', 10, 2),
('a,b,c,d', '|', 1, 2),   
('a,b,c,d', ',', -4, -2), 
(NULL, ',', 1, 2),        
('a,b,c,d', ',', NULL, NULL); 

DELIMITER //;
CREATE PROCEDURE test_split_part_procedure()
BEGIN
    DECLARE done INT DEFAULT FALSE;
    DECLARE str TEXT;
    DECLARE del VARCHAR(10);
    DECLARE index_ret INT;
    DECLARE cnt INT;
    
    DECLARE cur CURSOR FOR SELECT input_string, delimiter, index_return, count_param FROM test_split_part;
    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;

    OPEN cur;

    read_loop: LOOP
        FETCH cur INTO str, del, index_ret, cnt;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT str AS input_string, del AS delimiter, index_ret AS index_return, cnt AS count_param,
               split_part(str, del, index_ret, cnt) AS result;
    END LOOP;

    CLOSE cur;
END;
//

--ERROR 1210
CALL test_split_part_procedure();
//

CREATE PROCEDURE test_split_part_while()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE total INT;
    
    SELECT COUNT(*) INTO total FROM test_split_part;

    WHILE i <= total DO
        SELECT 
            input_string, 
            delimiter, 
            index_return, 
            count_param, 
            split_part(input_string, delimiter, index_return, count_param) AS result
        FROM test_split_part
        WHERE id = i;
        SET i = i + 1;
    END WHILE;
END; //

--ERROR 1210
CALL test_split_part_while();
//

CREATE PROCEDURE test_split_part_repeat()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE total INT;

    SELECT COUNT(*) INTO total FROM test_split_part;

    REPEAT
        SELECT 
            input_string, 
            delimiter, 
            index_return, 
            count_param, 
            split_part(input_string, delimiter, index_return, count_param) AS result
        FROM test_split_part
        WHERE id = i;
        SET i = i + 1;
    UNTIL i > total
    END REPEAT;
END ;//
--ERROR 1210
CALL test_split_part_repeat();
//

CREATE PROCEDURE test_split_part_loop()
BEGIN
    DECLARE i INT DEFAULT 1;
    DECLARE total INT;

    SELECT COUNT(*) INTO total FROM test_split_part;

    loop_label: LOOP
        IF i > total THEN
            LEAVE loop_label;
        END IF;

        SELECT 
            input_string, 
            delimiter, 
            index_return, 
            count_param, 
            split_part(input_string, delimiter, index_return, count_param) AS result
        FROM test_split_part
        WHERE id = i;

        SET i = i + 1;
    END LOOP;
END ;//

--ERROR 1210
CALL test_split_part_loop();
//
DELIMITER ;//

--disable_warnings
DROP TABLE IF EXISTS test_split_part;
--enable_warnings

CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT
);

DELIMITER $$;

--error 1415
CREATE TRIGGER before_insert_test_split_part 
BEFORE INSERT ON test_split_part
FOR EACH ROW 
BEGIN
    DECLARE result VARCHAR(255);
    SET result = split_part(NEW.data, ',', 1);
    SELECT CONCAT('Insert Trigger: First part is ', result);
END ; 
$$

CREATE TRIGGER before_insert_test_split_part 
BEFORE INSERT ON test_split_part
FOR EACH ROW 
BEGIN
    DECLARE result VARCHAR(255);
    SET result = split_part(NEW.data, ',', 1);
END ; 
$$

CREATE TRIGGER before_update_test_split_part 
BEFORE UPDATE ON test_split_part
FOR EACH ROW 
BEGIN
    DECLARE result VARCHAR(255);
    SET result = split_part(NEW.data, ',', 1);
END; $$

CREATE TRIGGER before_delete_test_split_part 
BEFORE DELETE ON test_split_part
FOR EACH ROW 
BEGIN
    DECLARE result VARCHAR(255);
    SET result = split_part(OLD.data, ',', 1);
END; $$

DELIMITER ;$$

