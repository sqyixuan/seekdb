--disable_warnings
drop table if exists hash_partitioned_table;
--enable_warnings

CREATE TABLE hash_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY HASH(id) PARTITIONS 4;

INSERT INTO hash_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', 1) FROM hash_partitioned_table WHERE id = 1;

--disable_warnings
drop table if exists key_partitioned_table;
--enable_warnings

CREATE TABLE key_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY KEY(id) PARTITIONS 4;

INSERT INTO key_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', 2) FROM key_partitioned_table WHERE id = 1;

--disable_warnings
drop table if exists list_partitioned_table;
--enable_warnings

CREATE TABLE list_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY LIST(id) (
    PARTITION p0 VALUES IN (1, 2),
    PARTITION p1 VALUES IN (3, 4)
);

INSERT INTO list_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', 1) FROM list_partitioned_table WHERE id = 1;

--disable_warnings
drop table if exists range_partitioned_table;
--enable_warnings

CREATE TABLE range_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY RANGE(id) (
    PARTITION p0 VALUES LESS THAN (10),
    PARTITION p1 VALUES LESS THAN (20)
);

INSERT INTO range_partitioned_table (id, data) VALUES (5, 'a,b,c,d');
SELECT split_part(data, ',', 3) FROM range_partitioned_table WHERE id = 5;

--disable_warnings
drop table if exists range_hash_partitioned_table;
--enable_warnings

CREATE TABLE range_hash_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY RANGE(id) SUBPARTITION BY HASH(id) (
    PARTITION p0 VALUES LESS THAN (10) (
        SUBPARTITION sp0,
        SUBPARTITION sp1
    ),
    PARTITION p1 VALUES LESS THAN (20) (
        SUBPARTITION sp2,
        SUBPARTITION sp3
    )
);

INSERT INTO range_hash_partitioned_table (id, data) VALUES (5, 'a,b,c,d');
SELECT split_part(data, ',', -1) FROM range_hash_partitioned_table WHERE id = 5;

--disable_warnings
drop table if exists range_key_partitioned_table;
--enable_warnings

CREATE TABLE range_key_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY RANGE(id) SUBPARTITION BY KEY(id) (
    PARTITION p0 VALUES LESS THAN (10) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES LESS THAN (20) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);

INSERT INTO range_key_partitioned_table (id, data) VALUES (5, 'a,b,c,d');
SELECT split_part(data, ',', 1, 2) FROM range_key_partitioned_table WHERE id = 5;

--disable_warnings
drop table if exists list_hash_partitioned_table;
--enable_warnings

CREATE TABLE list_hash_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY LIST(id) SUBPARTITION BY HASH(id) (
    PARTITION p0 VALUES IN (1, 2) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES IN (3, 4) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);

INSERT INTO list_hash_partitioned_table (id, data) VALUES (1, 'a,b,c,d');
SELECT split_part(data, ',', 1, 3) FROM list_hash_partitioned_table WHERE id = 1;

--disable_warnings
drop table if exists list_key_partitioned_table;
--enable_warnings

CREATE TABLE list_key_partitioned_table (
    id INT PRIMARY KEY,
    data VARCHAR(255)
) PARTITION BY LIST(id) SUBPARTITION BY KEY(id) (
    PARTITION p0 VALUES IN (1, 2) (
        SUBPARTITION sp1,
        SUBPARTITION sp2
    ),
    PARTITION p1 VALUES IN (3, 4) (
        SUBPARTITION sp3,
        SUBPARTITION sp4
    )
);

