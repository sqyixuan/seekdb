CREATE FUNCTION my_split_part(
    str1 VARCHAR(255),
    separator1 VARCHAR(10),
    start1 BIGINT,
    end1 BIGINT
) RETURNS VARCHAR(255)
BEGIN
    RETURN split_part(str1, separator1, start1, end1);
END;
//

