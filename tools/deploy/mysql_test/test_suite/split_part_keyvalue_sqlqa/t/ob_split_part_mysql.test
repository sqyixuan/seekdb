--disable_warnings
drop table if exists partitioned_table;
--enable_warnings

CREATE TABLE partitioned_table (
    id INT PRIMARY KEY,
    string_col VARCHAR(255),
    delimiter_col VARCHAR(10),
    position_col INT,
    partition_key INT
) PARTITION BY RANGE (id);
INSERT INTO partitioned_table (id,string_col, delimiter_col, position_col, partition_key) VALUES (1,'a,b,c,d', ',', 1, 500);
INSERT INTO partitioned_table (id,string_col, delimiter_col, position_col, partition_key) VALUES (2,'e,f,g,h', ',', 2, 1500);

SELECT id, split_part(string_col, delimiter_col, position_col) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1 AND 1000;
SELECT id, split_part(string_col, delimiter_col, 0) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1001 AND 2000;
SELECT id, split_part(string_col, delimiter_col, -1) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1 AND 1000;
SELECT id, split_part(string_col, delimiter_col, 10) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1001 AND 2000;
SELECT id, split_part(string_col, delimiter_col, 1, 3) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1 AND 1000;
SELECT id, split_part(string_col, delimiter_col, 1, 10) AS split_result
FROM partitioned_table
WHERE partition_key BETWEEN 1001 AND 2000;

