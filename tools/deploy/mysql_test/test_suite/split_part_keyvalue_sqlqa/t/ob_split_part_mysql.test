--echo ### SELECT+DML全量覆盖

--disable_warnings
drop table if exists test_split;
--enable_warnings

CREATE TABLE test_split (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data_column TINYTEXT,
    another_column VARCHAR(255)
);

INSERT INTO test_split (data_column, another_column) VALUES 
('a,b,c,d', 'Alpha'),
('e,f,g,h', 'Beta'),
(NULL, 'Gamma');
INSERT INTO test_split (data_column, another_column)
SELECT 'i,j,k,l', 'Delta';
REPLACE INTO test_split (id, data_column, another_column) VALUES (1, 'm,n,o,p', 'Epsilon');

--echo ### 基本选择和 where
SELECT id, split_part(data_column, ',', 1) AS first_part 
FROM test_split 
WHERE another_column = 'Epsilon';

--echo ### 使用 OR 和 AND
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 2) = 'b' OR another_column LIKE 'G%';

--echo ### 使用 LIKE
SELECT * 
FROM test_split 
WHERE another_column LIKE '%ta%';

--echo ### 使用 ORDER BY
SELECT * 
FROM test_split 
ORDER BY split_part(data_column, ',', 1);

--echo ### 使用 GROUP BY 和 HAVING
SELECT another_column, COUNT(*) AS count
FROM test_split 
GROUP BY another_column HAVING count > 1;

--echo ### 使用 DISTINCT
SELECT DISTINCT split_part(data_column, ',', 1) 
FROM test_split;

--echo ### 使用 CASE WHEN
SELECT id, 
       CASE 
           WHEN split_part(data_column, ',', 2) IS NOT NULL THEN 'Exists' 
           ELSE 'Not Exists' 
       END AS part_existence 
FROM test_split;

--echo ### 使用 WITH AS 和子查询
WITH split_data AS (
    SELECT id, split_part(data_column, ',', 1) AS first_part 
    FROM test_split 
)
SELECT * FROM split_data WHERE first_part IS NOT NULL;

--echo ### 子查询中的 EXISTS
SELECT * 
FROM test_split t 
WHERE EXISTS (
    SELECT 1 
    FROM test_split 
    WHERE split_part(data_column, ',', 2) = 'b'
);

--echo ### 使用 ANY
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 1) = ANY (SELECT split_part(data_column, ',', 1) FROM test_split);

--echo ### 使用 SOME（MySQL 中和 ANY 是相同的）
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 1) = SOME (SELECT split_part(data_column, ',', 1) FROM test_split);

--echo ### 使用 ALL
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 1) = ALL (SELECT split_part(data_column, ',', 1) FROM test_split);

--echo ### 使用 NOT IN
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 1) NOT IN (SELECT split_part(data_column, ',', 1) FROM test_split);

--echo ### 使用比较运算符
SELECT * 
FROM test_split 
WHERE id >= 1 AND id <= 2;

--echo ### 使用 AND, OR, LIKE, NOT LIKE
SELECT * 
FROM test_split 
WHERE split_part(data_column, ',', 1) LIKE 'a%' AND another_column NOT LIKE 'Gamma';

--echo ### 更新
UPDATE test_split 
SET data_column = split_part(data_column, ',', 1) 
WHERE id = 1;

--echo ### 使用 UPDATE ... SELECT
UPDATE test_split 
SET another_column = (SELECT 'Updated' FROM dual)
WHERE id = 2;

--echo ### 删除
DELETE FROM test_split 
WHERE id = 3;

--echo ### 删除来自子查询的行
DELETE FROM test_split 
WHERE id IN (SELECT id FROM test_split WHERE another_column = 'Beta');

--disable_warnings
drop table if exists users;
drop table if exists orders;
--enable_warnings
CREATE TABLE users (
    user_id INT PRIMARY KEY,
    user_name VARCHAR(100),
    user_info TEXT
);

CREATE TABLE orders (
    order_id INT PRIMARY KEY,
    user_id INT,
    product VARCHAR(100),
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);
INSERT INTO users (user_id, user_name, user_info)
VALUES 
(1, 'Alice', 'Alice,birthday,single'),
(2, 'Bob', 'Bob,age,30'),
(3, 'Charlie', 'Charlie,age,25');
INSERT INTO orders (order_id, user_id, product)
VALUES 
(1, 1, 'Product1'),
(2, 2, 'Product2'),
(3, 1, 'Product3'),
(4, 3, 'Product4');

SELECT users.user_id, users.user_name, split_part(users.user_info, ',', 1) as split_info
FROM users, orders
WHERE users.user_id = orders.user_id;

SELECT users.user_id, users.user_name, split_part(users.user_info, ',', 1) as split_info
FROM users
LEFT JOIN orders ON users.user_id = orders.user_id;

SELECT users.user_id, users.user_name, split_part(users.user_info, ',', 1) as split_info
FROM users
RIGHT JOIN orders ON users.user_id = orders.user_id;

SELECT users.user_id, users.user_name, split_part(users.user_info, ',', 2) as split_info
FROM users
INNER JOIN orders ON users.user_id = orders.user_id;

SELECT users.user_id, users.user_name, split_part(users.user_info, ',', 1) as split_info
FROM users
CROSS JOIN orders;

SELECT users.user_id, users.user_name,
       split_part(users.user_info, ',', 1, 2) as split_info_range
FROM users
INNER JOIN orders ON users.user_id = orders.user_id;

SELECT users.user_id, users.user_name, 
       split_part(users.user_info, '-', 1) as split_info_not_found
FROM users;

SELECT users.user_id, users.user_name, 
       split_part(users.user_info, ',', -2) as split_info_negative
FROM users;

SELECT users.user_id, users.user_name, 
       split_part(users.user_info, ',', 10) as split_info_out_of_bounds
FROM users;

