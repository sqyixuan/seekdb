CREATE TABLE split_part_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    big_int_col BIGINT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    medium_int_col MEDIUMINT,
    float_col FLOAT,
    double_col DOUBLE,
    decimal_col DECIMAL(10, 2),
    string_col VARCHAR(255)
);

INSERT INTO split_part_test (big_int_col, tiny_int_col, small_int_col, medium_int_col, float_col, double_col, decimal_col, string_col) VALUES
(12345678901234, 127, 32767, 8388607, 123.45, 123456.78, 12345.67, 'a,b,c,d'),
(98765432109876, -128, -32768, -8388607, 987.65, 987654.32, -12345.67, 'e,f,g,h'),
(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL); 

SELECT split_part(string_col, ',', 1) AS result1 FROM split_part_test; 
SELECT split_part(string_col, ',', 0) AS result2 FROM split_part_test; 
SELECT split_part(string_col, ',', -1) AS result3 FROM split_part_test;
SELECT split_part(string_col, ',', 10) AS result4 FROM split_part_test;

SELECT split_part(string_col, ',', 1, 2) AS result5 FROM split_part_test;  
SELECT split_part(string_col, ',', 1, 3) AS result6 FROM split_part_test;  
SELECT split_part(string_col, ',', -4, -2) AS result7 FROM split_part_test;
SELECT split_part(string_col, ',', 1, 10) AS result8 FROM split_part_test; 

SELECT split_part(CAST(big_int_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(tiny_int_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(small_int_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(medium_int_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(float_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(double_col AS CHAR), ',', 1) FROM split_part_test;
SELECT split_part(CAST(decimal_col AS CHAR), ',', 1) FROM split_part_test;

--disable_warnings
drop table if exists test_split_part;
--enable_warnings

CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    date_col DATE,
    time_col TIME,
    year_col YEAR,
    datetime_col TIMESTAMP,
    timestamp_col TIMESTAMP,
    text_col TEXT
);

INSERT INTO test_split_part (date_col, time_col, year_col, datetime_col, timestamp_col, text_col) VALUES
('2023-01-01', '12:34:56', 2023, '2023-01-01 12:34:56', '20230101', 'a,b,c,d'),
('2023-12-31', '23:59:59', 2023, '2023-12-31 23:59:59', '20231231', 'apple,banana,carrot,date');

SELECT split_part(date_col, '-', 1) AS Year FROM test_split_part;
SELECT split_part(time_col, ':', 1) AS Hours FROM test_split_part;
SELECT split_part(CONVERT(year_col USING utf8), '', 1) AS Year_Value FROM test_split_part;
SELECT split_part(datetime_col, ' ', 1) AS Date_Part FROM test_split_part;
SELECT split_part(timestamp_col, ' ', 1) AS Timestamp_Part FROM test_split_part;

SELECT split_part(text_col, ',', 1) AS First_Part FROM test_split_part;  
SELECT split_part(text_col, ',', -1) AS Last_Part FROM test_split_part;  
SELECT split_part(text_col, ',', 1, 2) AS First_Two FROM test_split_part;
SELECT split_part(text_col, ',', -4, -2) AS Negative_Example FROM test_split_part;  
SELECT split_part(text_col, ',', 1, 10) AS Out_Of_Bounds FROM test_split_part;  
SELECT split_part(text_col, 'x', 1) AS No_Split_Return_Original FROM test_split_part;

--disable_warnings
drop table if exists test_split_part;
--enable_warnings

CREATE TABLE test_split_part (
    id INT AUTO_INCREMENT PRIMARY KEY,
    json_data JSON
);

INSERT INTO test_split_part (json_data) VALUES
('{"key": "a,b,c,d"}'),  
('{"key": "e,f,g"}'),   
(NULL);           

SELECT split_part(json_unquote(json_data->'$.key'), ',', 1) AS result_1,
       split_part(json_unquote(json_data->'$.key'), ',', 2) AS result_2,
       split_part(json_unquote(json_data->'$.key'), ',', 3) AS result_3,
       split_part(json_unquote(json_data->'$.key'), ',', 4) AS result_4
FROM test_split_part
WHERE json_data IS NOT NULL;

SELECT split_part(json_unquote(json_data->'$.key'), ',', -1) AS result,
       split_part(json_unquote(json_data->'$.key'), ',', -2) AS result_reverse
FROM test_split_part
WHERE json_data IS NOT NULL;

SELECT split_part(json_unquote(json_data->'$.key'), ',', 10) AS out_of_bounds_1,
       split_part(json_unquote(json_data->'$.key'), ',', -10) AS out_of_bounds_reverse
FROM test_split_part
WHERE json_data IS NOT NULL;

SELECT split_part(json_unquote(json_data->'$.key'), ',', 1, 2) AS first_two,
       split_part(json_unquote(json_data->'$.key'), ',', 1, 3) AS first_three,
       split_part(json_unquote(json_data->'$.key'), ',', -4, -2) AS reverse_range,
       split_part(json_unquote(json_data->'$.key'), ',', 1, 10) AS out_of_bounds_four
FROM test_split_part
WHERE json_data IS NOT NULL;

SELECT split_part(NULL, ',', 1) AS null_case_1,
       split_part(json_unquote(json_data->'$.key'), NULL, 1) AS null_case_2
FROM test_split_part;


