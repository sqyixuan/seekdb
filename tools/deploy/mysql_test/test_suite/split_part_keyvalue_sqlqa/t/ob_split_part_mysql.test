(NULL, ','),
('foo', '|');

SELECT id, original_string, delimiter,
       split_part_1, split_part_2, split_part_3, split_part_4,
       split_part_neg_1, split_part_1_2, split_part_1_3,
       split_part_neg_4_neg_2
FROM test_split_part;

SELECT 
       split_part_1, split_part_2, split_part_3, split_part_4,
       split_part_neg_1, split_part_1_2, split_part_1_3,
       split_part_neg_4_neg_2
FROM test_split_part;

SELECT split_part_1 FROM test_split_part;
SELECT split_part_2 FROM test_split_part;
SELECT split_part_neg_1 FROM test_split_part;
SELECT split_part_1_3 FROM test_split_part;
SELECT split_part_neg_4_neg_2 FROM test_split_part;

