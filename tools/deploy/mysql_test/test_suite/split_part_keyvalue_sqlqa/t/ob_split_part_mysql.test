purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;

--echo ### 基础case
#### OB结果与ODPS不一致。
select split_part('a,b,c,d', '', '') ;

### arg3 = 0时，将0按照1处理；
select split_part('a,b,c,d', ',', 0) ;
### arg3 < 0时，按照逆序处理。
select split_part('a,b,c,d', ',', -1) ;

select split_part('a,b,c,d', ',', 1) ;
select split_part('a,b,c,d', ':', 2) ;
select split_part('a,b,c,d', '', 1) ;

#### OB结果与ODPS不一致。
select split_part('a,b,c,d', '', 2) ;
select split_part('a,b,c,d', ',', 10) ;

### arg3 < 0时，按照逆序处理。
select split_part('a,b,c,d', ',', -10) ;
### arg3 = 0时，将0按照1处理；
SELECT split_part('abcdabcdabc', 'abc', 0) ;
SELECT split_part('abcdabcdabc', 'abc', 1) ;
SELECT split_part('abcdabcdabc', 'abc', -1) ;

#### OB结果与ODPS不一致。
SELECT split_part(1.414, 1, '2') ;
SELECT split_part(1.414, 1, '-4') ;

### arg3 = 0时，将0按照1处理；
SELECT split_part('', '', 0) ;
SELECT split_part('', '', 1) ;
select split_part('', ',', 1) ;

select split_part('a,b,c,d', ',', 1, 2) ;
select split_part('a,b,c,d', ',', 2, 6) ;
select split_part('a,b,c,d', '', 1, 2) ;
select split_part('a,b,c,d', ',', 1, 3) ;
### arg3 < 0时，按照逆序处理。
select split_part('a,b,c,d', ',', -4, -2) ;
select split_part('a,b,c,d', ',', 1, 10) ;
select split_part('a,b,c,d', ',', -2, -1) ;

SELECT split_part('abcdabcdabc', 'abc', '1','2') ;
--ERROR 1210
SELECT split_part('abcdabcdabc', 'abc', '-1','-4') ;

# NULL
select split_part(NULL, ',', 10) ;
select split_part('a,b,c,d', NULL, 1) ;
select split_part('a,b,c,d', ':', NULL) ;
select split_part('a,b,c,d', ',', null) ;

select split_part(NULL,NULL,NULL) ;
select split_part(NULL,NULL,NULL,NULL) ;
SELECT split_part('abcdabcdabc', NULL, NULL) ;
SELECT split_part('abcdabcdabc', NULL, 0, NULL) ;
SELECT split_part('abcdabcdabc', NULL, 0, 0) ;
SELECT split_part('abcdabcdabc', NULL, 1, NULL) ;
SELECT split_part('abcdabcdabc', NULL, -1, NULL) ;
SELECT split_part('abcdabcdabc', NULL, NULL, 0) ;

# special args
select split_part( 'mysql.col','.', 9223372036854775806) ;
select split_part( 'mysql.col','.', 9223372036854775807) ;

#### OB结果与ODPS不一致。
select split_part( 'mysql.col','.', 9223372036854775808) ;
select split_part( 'mysql.col','.', 9223372036854775809) ;
select split_part( 'mysql.col','.', 9223372036854775810) ;
select split_part( 'mysql.col','.', 9223372036854775811) ;
select split_part( 'mysql.col','.', -9223372036854775806) ;
select split_part( 'mysql.col','.', -9223372036854775807) ;
select split_part( 'mysql.col','.', -9223372036854775808) ;
select split_part( 'mysql.col','.', -9223372036854775809) ;

--echo ### 参数个数，边界值覆盖

SELECT split_part('a,b,c,d', ',', 1) ;
SELECT split_part('a,b,c,d', ',', 1, 2) ;
--ERROR 1582
SELECT split_part('a,b,c,d', ',') ;
--ERROR 1582
SELECT split_part('a,b,c,d') ;
--ERROR 1582
SELECT split_part() ;
--ERROR 1582
SELECT split_part('a,b,c,d', ',', 1, 2, 3) ;
--ERROR 1582
SELECT split_part('a,b,c,d', ',', 1, 2, 3, 4) ;
SELECT split_part('a,b,c,d', NULL, 1) ;
SELECT split_part('a,b,c,d', ',', NULL, 2) ;
SELECT split_part(NULL, NULL, NULL) ;
SELECT split_part(NULL, NULL, NULL, NULL) ;

--echo ### 参数类型，包含常用字符、特殊字符以及使用变量等覆盖

SELECT split_part('a,b,c,d', ',', 1) ;

SELECT split_part('a,b,c,d', ',', 0) ;
SELECT split_part('a,b,c,d', ',', -1) ;
SELECT split_part('a,b,c,d', ',', 10) ;
SELECT split_part('a,b,c,d', ';', 1) ;
SELECT split_part('a,b,c,d', ';', 0) ;
SELECT split_part('a,b,c,d', ';', -1) ;
SELECT split_part('a,b,c,d', ',', 1, 2) ;
SELECT split_part('a,b,c,d', ',', -4, -2) ;
SELECT split_part('a,b,c,d', ',', 1, 10) ;
SELECT split_part('a,b,c,d', ';', 1, 2) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', 1, -2) ;
SELECT split_part(NULL, NULL, NULL) ;
SELECT split_part(NULL, NULL, NULL, NULL) ;
SELECT split_part(NULL, ',', 1) ;
SELECT split_part(NULL, ',', 1, 2) ;
SELECT split_part('a,b,c,d', NULL, 1) ;
SELECT split_part('a,b,c,d', NULL, 1, 2) ;
SELECT split_part('a,b,c,d', ',', NULL) ;
SELECT split_part('a,b,c,d', ',', NULL, 2) ;
SELECT split_part('a,b,c,d', ',', 1, NULL) ;

SELECT split_part('a,b,c,d', ',', 1) ;
SELECT split_part('a,b,c,d', ',', 0) ;
SELECT split_part('a,b,c,d', ',', -1) ;
SELECT split_part('a,b,c,d', ',', 10) ;
SELECT split_part('abcd', ',', 1) ;
--ERROR 1064
SELECT split_part(CAST('a,b,c,d' AS tinytext), ',', 1) ;
--ERROR 1064
SELECT split_part(CAST('a,b,c,d' AS text), ',', 1) ;
--ERROR 1064
SELECT split_part(CAST('a,b,c,d' AS longtext), ',', 1) ;
SELECT split_part(NULL, ',', 1) ;
SELECT split_part('a,b,c,d', NULL, 1) ;
SELECT split_part('a,b,c,d', ',', NULL) ;
SELECT split_part('a,b,c,d', ',', 1, NULL) ;

SELECT split_part('a|b|c|d', '|', 2) ;
SELECT split_part('abcd', '', 1) ;
SELECT split_part('a,,b,c', ',', 2) ;
SELECT split_part('', ',', 1) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', -1, 2) ;
SELECT split_part('a,b,c,d', ',', 1, 3) ;
SELECT split_part('a,,b,,c', ',', 3) ;
SELECT split_part('', '', 1) ;

SELECT split_part('a,b,c,d', ',', 1) WHERE LENGTH('a,b,c,d') < 255 ;
SELECT split_part('a,b,c,d', ',', 1) WHERE LENGTH('a,b,c,d') > 255 AND LENGTH('a,b,c,d') < 65535 ;
SELECT split_part('a,b,c,d', ',', 1) WHERE LENGTH('a,b,c,d') > 65535 ;

### 覆盖全量参数类型：

SELECT split_part('a,b,c,d', ',', 0); 
SELECT split_part('a,b,c,d', ',', 1); 
SELECT split_part('a,b,c,d', ',', -1); 
SELECT split_part('1.0,2.0,3.0', ',', 1);

### OB结果不一致
SELECT split_part('a,b,c,d', ',', true);
SELECT split_part('a,b,c,d', ',', false);

SELECT split_part('A,B,C,D', ',', 1);
SELECT split_part('a,b,c,d', ',', 1);
SELECT split_part('Ab,cD,eF', ',', 1);
SELECT split_part('abc', ',', 0);
SELECT split_part('abc', ',', 1);
SELECT split_part('汉字,测试,示例', ',', 1);
SELECT split_part('⚽,🏀,篮球', ',', 1);
SELECT split_part('汉字', ',', 0);
SELECT split_part('汉字', ',', 1);
SELECT split_part(NULL, ',', 1);
SELECT split_part('a,b,c', NULL, 1);
SELECT split_part('a,b,c', ',', NULL);
SELECT split_part(NULL, NULL, NULL);
SELECT split_part('~！？@#￥%&*（）、{}【】=/。， ·', '，', 1);
SELECT split_part('~！？@#￥%', '!', 1);

SET @arg1 = 'a,b,c,d';
SET @arg2 = ',';
SET @arg3 = 2;
SELECT split_part(@arg1, @arg2, @arg3);

--echo ### 使用运算符对参数计算的结果覆盖

SELECT split_part('a,b,c,d', ',', 1 + 0) ;
SELECT split_part('a,b,c,d', ',', 3 - 2) ;

### #### OB结果与ODPS不一致。
SELECT split_part('a,b,c,d', ',', 2 * 2 / 2) ;
SELECT split_part('a,b,c,d', ',', 1 + 2 / 2) ;
SELECT split_part('a,b,c,d', ',', (2 + 3) * (4 - 2) / 2) ;
SELECT split_part('a,b,c,d', ',', 1, (2 + 3) * (4 - 2) / 2) ;

SELECT split_part('a,b,c,d', ',', LENGTH('abc') - 2) ;
SELECT split_part('a,b,c,d', ',', 1, LENGTH('abcd') - 3) ;
SELECT split_part('a,b,c,d', ',', -ABS(-2)) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', 1, -ABS(-3)) ;
SELECT split_part('a,b,c,d', ',', 5 - 5) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', 1, 5 - 5) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', -1, 2) ;
--ERROR 1210
SELECT split_part('a,b,c,d', ',', -1, -2) ;
SELECT split_part('a,b,c,d', ',', NULLIF(1, 1)) ;
SELECT split_part('a,b,c,d', ',', 1, NULLIF(1, 1)) ;

### 覆盖全量运算符：

--echo  ###  比较运算符
--echo  ###  >, >=, <, <=, =, !=
SELECT
    split_part('a,b,c,d', ',', 1) > split_part('a,b,c,d', ',', 2) AS greater_than,
    split_part('a,b,c,d', ',', 1) >= split_part('a,b,c,d', ',', 1) AS greater_equal,
    split_part('a,b,c,d', ',', 3) < split_part('a,b,c,d', ',', 4) AS less_than,
    split_part('a,b,c,d', ',', 3) <= split_part('a,b,c,d', ',', 3) AS less_equal,
    split_part('a,b,c,d', ',', 2) = split_part('a,b,c,d', ',', 2) AS equal,
    split_part('a,b,c,d', ',', 1) != split_part('a,b,c,d', ',', 3) AS not_equal;

--echo  ### IN / NOT IN
SELECT 
    split_part('a,b,c,d', ',', 1) IN ('a', 'b', 'c', 'd') AS in_set,
    split_part('a,b,c,d', ',', 2) NOT IN ('x', 'y', 'z') AS not_in_set;

--echo  ### IS NULL / IS NOT NULL
SELECT 
    split_part(NULL, ',', 1) IS NULL AS is_null_test,
    split_part('a,b,c,d', ',', 1) IS NOT NULL AS is_not_null_test;

--echo  ### BETWEEN AND / NOT BETWEEN AND
SELECT 
    split_part('1,2,3,4', ',', 2) BETWEEN '1' AND '3' AS between_test,
    split_part('1,2,3,4', ',', 4) NOT BETWEEN '1' AND '3' AS not_between_test;

--echo  ### LIKE
SELECT 
    split_part('apple,banana,orange', ',', 2) LIKE 'ban%' AS like_test;

--echo  ###  REGEXP 或 RLIKE
SELECT 
    split_part('apple,banana,orange', ',', 1) REGEXP '^[a-z]+' AS regexp_test;

--echo  ###  计算运算符
--echo  ###  +, -, *, /, %, DIV, MOD
SELECT 
    split_part('1,2,3', ',', 1) + split_part('1,2,3', ',', 2) AS addition,
    split_part('5,3,2', ',', 1) - split_part('5,3,2', ',', 2) AS subtraction,
    split_part('2,3,4', ',', 1) * split_part('2,3,4', ',', 2) AS multiplication;

### OB结果正常无报错，返回结果为数值类型，非STRING类型。ODPS报错ODPS-0130071
SELECT 
    floor(split_part('10,3', ',', 1) DIV split_part('10,3', ',', 2)) AS div_test;
SELECT 
    split_part('10,3', ',', 1) MOD split_part('10,3', ',', 2) AS mod_operation;
        
SELECT 
    split_part('6,3', ',', 1) / split_part('6,3', ',', 2) AS division,
    split_part('5,2', ',', 1) % split_part('5,2', ',', 2) AS mod_test;

--echo  ### 多层计算
SELECT 
    (split_part('5,3', ',', 1) + split_part('5,3', ',', 2)) * 2 AS multi_layer_calculation;

--echo  ### 逻辑运算符
SELECT 
    (split_part('a,b,c', ',', 1) = 'a' AND split_part('a,b,c', ',', 2) = 'b') AS and_test,
    (split_part('a,b,c', ',', 1) = 'a' OR split_part('a,b,c', ',', 3) = 'd') AS or_test,
    NOT (split_part('a,b,c', ',', 1) = 'x') AS not_test,
    (1 = 1 XOR 2 = 2) AS xor_test;
    
SELECT 
    (split_part('a,b,c', ',', 1) = 'a' AND split_part('a,b,c', ',', 2) = 'b') AS and_test,
    (split_part('a,b,c', ',', 1) = 'a' OR split_part('a,b,c', ',', 3) = 'd') AS or_test;

### OB结果正常无报错,ODPS不支持。
SELECT 
    (split_part('a,b,c', ',', 1) = 'x' XOR split_part('a,b,c', ',', 1) = 'x') AS xor_test;
SELECT 
    NOT (split_part('a,b,c', ',', 1) = 'x') AS not_test;
    
--echo  ### 连接符
SELECT 
    split_part('Hello,World', ',', 1)  AS concat_test;
SELECT 
    split_part('Hello,World', ',', 2) AS concat_test;
SELECT 
    split_part('Hello,World', ',', 1) || ' ' || split_part('Hello,World', ',', 2) AS concat_test;

--echo  ### 位运算符

### OB结果正常无报错,ODPS不支持。主要ODPS返回STRING类型
SELECT split_part('a,b,c,d', ',', 1) & split_part('1,2,3', ',', 2) AS bitwise_and; 
SELECT split_part('a,b,c,d', ',', 1) | split_part('1,2,3', ',', 2) AS bitwise_or;
SELECT split_part('a,b,c,d', ',', 1) ^ split_part('1,2,3', ',', 2) AS bitwise_xor;
SELECT !split_part('1,2,3,4', ',', 2) AS bitwise_not;
SELECT split_part('1,2,3,4', ',', 2) << 1 AS left_shift;
SELECT split_part('1,2,3,4', ',', 3) >> 1 AS right_shift;
SELECT 
    (split_part('1,2,3', ',', 1) & split_part('2,3,4', ',', 2)) | 
    (split_part('3,4,5', ',', 1) ^ split_part('1,2,3', ',', 2)) AS complex_bitwise_operation;
SELECT 
    split_part(NULL, ',', 1) & split_part('1,2,3', ',', 2) AS null_case_and,
    split_part('a,b,c,d', ',', NULL) | split_part('1,2,3', ',', 2) AS null_case_or;
SELECT 
    split_part('a,b,c,d', ',', 10) & split_part('1,2,3', ',', 2) AS out_of_bounds_and,
    split_part('a,b,c,d', ',', 1, 10) | split_part('1,2,3', ',', -10) AS out_of_bounds_or;

--echo  ### 赋值运算符
SET @result := split_part('a,b,c,d', ',', 2);
SELECT @result AS assignment_test;

--echo ### 函数嵌套，包含常用函数与SPLIT_PART/KEYVALUE的嵌套，以及SPLIT_PART/KEYVALUE自身的嵌套使用

SELECT split_part(UPPER('a,b,c,d'), ',', 1) ;
SELECT split_part('a,b,c,d', LEFT('abc-', 2), 1) ;
SELECT split_part('a,b,c,d', ',', LENGTH('abc') - 2) ;
SELECT split_part('a,b,c,d', ',', 1, LENGTH('abcd') - 3) ;
SELECT split_part(split_part('a,b,c,d', ',', 1), ',', 1) ;
SELECT split_part('a,b,c,d', split_part('x,y,z', ',', 1), 1) ;
--ERROR 1064
SELECT split_part('a,b,c,d', ',', split_part('1,2,3', ',', 1)::int) ;

### #### OB结果与ODPS不一致。
SELECT split_part('a,b,c,d', ',', 1, split_part('1,2,3', ',', 2)) ;
SELECT split_part('a,b,c,d', ',', 1, CAST(123 AS CHAR(2))) ;

SELECT split_part(UPPER(SUBSTRING('a,b,c,d,e', 1, 5)), ',', 2) ;
SELECT split_part('a,b,c,d', SUBSTRING(UPPER('abc-'), 1, 2), 2) ;
SELECT split_part('a,b,c,d', ',', LENGTH(SUBSTRING('abcdef', 1, 3)) + 1) ;
SELECT split_part('a,b,c,d', ',', 1, LENGTH(SUBSTRING('abcdef', 1, 4)) - 2) ;
SELECT split_part(split_part(split_part('a,b,c,d', ',', 1), ',', 1), ',', 1) ;
SELECT split_part('a,b,c,d', split_part(split_part('x,y,z', ',', 1), ',', 1), 1) ;
SELECT split_part('a,b,c,d', ',', split_part(split_part('1,2,3', ',', 1), ',', 1)) ;
SELECT split_part('a,b,c,d', ',', 1, split_part(split_part('1,2,3', ',', 2), ',', 1)) ;

--echo ### 函数嵌套全量覆盖

SELECT MAX(split_part('a,b,c,d', ',', 1)) AS max_value ;
SELECT MAX(split_part('1,2,3,4', ',', 1)) AS max_value ;
SELECT MAX(split_part('1,5,3,4', ',', 2)) AS max_value ;
SELECT MAX(split_part('1,2,3,4', ',', 1, 2)) AS max_value ;
SELECT MIN(split_part('a,b,c,d', ',', 1)) AS min_value ;
SELECT MIN(split_part('4,2,3,1', ',', 1)) AS min_value ;
SELECT MIN(split_part('1,5,3,4', ',', 3)) AS min_value ;
SELECT MIN(split_part('1,2,3,4', ',', 1, 2)) AS min_value ;
### #### OB结果与ODPS不一致。ODPS不支持。
SELECT AVG(CAST(split_part('1,2,3,4', ',', 1) AS UNSIGNED)) AS avg_value ;
SELECT AVG(CAST(split_part('10,20,30,40', ',', 2) AS UNSIGNED)) AS avg_value ;
SELECT AVG(CAST(split_part('10,20,30,40', ',', 1, 4) AS UNSIGNED)) AS avg_value ;
SELECT SUM(CAST(split_part('1,2,3,4', ',', 1) AS UNSIGNED)) AS sum_value ;
SELECT SUM(CAST(split_part('1,2,3,4', ',', 3) AS UNSIGNED)) AS sum_value ;
SELECT SUM(CAST(split_part('1,2,3,4', ',', 1, 3) AS UNSIGNED)) AS sum_value ;
SELECT COUNT(split_part('a,b,c,d', ',', 1)) AS count_value ;
SELECT COUNT(split_part('1,2,3,4', ',', 2)) AS count_value ;
SELECT COUNT(split_part('a,b,c,d', ',', 1, 2)) AS count_value ;

SELECT ROUND(CAST(split_part('10.5,20.7,30.1', ',', 1) AS DECIMAL(10, 2))); 
SELECT CEIL(CAST(split_part('10.5,20.7,30.1', ',', 2) AS DECIMAL(10, 2))); 
SELECT FLOOR(CAST(split_part('10.5,20.7,30.1', ',', 3) AS DECIMAL(10, 2)));  
SELECT ABS(CAST(split_part('10,-20,30', ',', 2) AS SIGNED)); 
SELECT NEG(CAST(split_part('5,10,15', ',', 1) AS SIGNED)); 
SELECT SIGN(CAST(split_part('0,-20,30', ',', 1) AS SIGNED)); 
SELECT CONV(CAST(split_part('1010,2,10', ',', 1) AS UNSIGNED), 2, 10);
SELECT MOD(CAST(split_part('10,3,4', ',', 1) AS SIGNED), CAST(split_part('10,3,4', ',', 2) AS SIGNED)); 
SELECT POW(CAST(split_part('2,3', ',', 1) AS SIGNED), CAST(split_part('2,3', ',', 2) AS SIGNED));
SELECT POWER(CAST(split_part('2,4', ',', 1) AS SIGNED), CAST(split_part('2,4', ',', 2) AS SIGNED));
### SELECT RAND(CAST(split_part('0.5,0.5', ',', 1) AS DECIMAL(10,2))); 

SELECT split_part(CONCAT('apple', ',', 'banana', ',', 'cherry'), ',', 2);
SELECT split_part(CONCAT_WS(',', 'grape', 'orange', 'pear'), ',', 3);
SELECT FORMAT(split_part('1000,2000,3000', ',', 2), 0);
SELECT SUBSTR(split_part('a,b,c,d', ',', 3), 1, 1);
SELECT SUBSTRING(split_part('foo|bar|baz', '|', 1), 1, 1);
SELECT TRIM(split_part('   space1,   space2   ', ',', 2));
SELECT LTRIM(split_part('   leftTrim, rightTrim', ',', 1));
SELECT RTRIM(split_part('leftTrim, rightTrim   ', ',', 2));
SELECT ASCII(split_part('a,b,c,d', ',', 1));
SELECT ORD(split_part('apple', ',', 1));
SELECT LENGTH(split_part('a,b,c,d', ',', 3));
SELECT CHAR_LENGTH(split_part('a,b,c,d', ',', 2));
SELECT UPPER(split_part('hello,world', ',', 2));
SELECT LOWER(split_part('HELLO, World', ',', 2));
SELECT HEX(split_part('abc,def', ',', 1));
SELECT UNHEX(split_part('616263,646566', ',', 1));
SELECT MD5(split_part('abc,def', ',', 2));
SELECT INT2IP(split_part('19216801,19216802', ',', 1));
SELECT IP2INT(split_part('192.168.1.1,192.168.1.2', ',', 1));
SELECT split_part('apple,banana,cherry', ',', 1) LIKE 'a%';
SELECT split_part('dog,cat,mouse', ',', 2) REGEXP 'c.t';
SELECT REPEAT(split_part('foo,bar', ',', 1), 3);

### #### OB结果与ODPS不一致。OB结果为0，ODPS结果为NULL
SELECT SPACE(2);
SELECT split_part('first,second', ',', 2);
SELECT '  '+'second';
SELECT SPACE(2) + split_part('first,second', ',', 2);

SELECT SUBSTRING_INDEX(split_part('a,b,c,d', ',', 2), ',', -1);
SELECT LOCATE(split_part('apple,banana,cherry', ',', 2), 'banana');
SELECT POSITION(split_part('apple,banana,cherry', ',', 2) IN 'banana');
SELECT INSTR(split_part('apple,banana,cherry', ',', 3), 'e');
SELECT REPLACE(split_part('apple,banana,cherry', ',', 2), 'banana', 'grape');
SELECT FIELD(split_part('apple,banana,cherry', ',', 3), 'banana', 'apple', 'cherry');
SELECT ELT(2, split_part('first,second,third', ',', 2));
SELECT INSERT(split_part('The quick brown fox', ' ', 3), 1, 3, 'red');
SELECT LPAD(split_part('1234,5678', ',', 2), 10, '0'); 
SELECT RPAD(split_part('1234,5678', ',', 1), 10, '0');
### SELECT split_part(uuid(), '-', 1);
SELECT BIN(split_part('2,3', ',', 2));
SELECT quote(split_part('my_string,another_string', ',', 1));
SELECT REGEXP_SUBSTR(split_part('match1,match2', ',', 2), 'match[0-9]+');

--disable_result_log
SELECT split_part(CONCAT(CURDATE(), ',2023-12-25'), ',', 1);
SELECT split_part(CONCAT(DATEDIFF('2023-12-25', CURDATE()), ',days'), ',', 1);
SELECT split_part(CONCAT(ADDDATE(CURDATE(), INTERVAL 3 DAY), ',future_date'), ',', 1);
SELECT split_part(CONCAT(DATE(NOW()), ',2023-01-01'), ',', 1);
SELECT split_part(CONCAT(ADDTIME(NOW(), '02:00:00'), ',future_time'), ',', 1);
SELECT ADDDATE(DATE('2023-12-25'), INTERVAL split_part('1,2,3', ',', 1) DAY);
SELECT DATEDIFF(CURDATE(), '2023-12-25') + split_part('5,10,15', ',', 1);
SELECT CURDATE() + INTERVAL (select split_part('1,2,3', ',', 1)) DAY;
SELECT DATE(NOW()) + INTERVAL (SELECT split_part('3,4', ',', 2)) DAY;
SELECT ADDTIME(NOW(), split_part('00:30:00,01:00:00', ',', 1));
SELECT ADDDATE(CURDATE(), INTERVAL split_part(CONCAT('3,4'), ',', 1) DAY);
SELECT DATEDIFF(NOW(), ADDDATE(CURDATE(), INTERVAL split_part('5,7', ',', 1) DAY));
SELECT split_part(CONCAT(ADDDATE(NOW(), INTERVAL 1 MONTH), ',', DATE(NOW())), ',', 1);
--enable_result_log

SELECT CAST(split_part('1,2,3', ',', 1) AS CHAR);
SELECT CONVERT(split_part('a,b,c,d', ',', 2) USING utf8);
SELECT CAST(split_part('10,20,30', ',', 2) AS SIGNED);
SELECT split_part(CAST('1,2,3' AS CHAR), ',', 1);
SELECT CAST(split_part('1.1,2.2,3.3', ',', 2) AS DECIMAL(10,2));
SELECT CAST(split_part('10.5,20.5,30.5', ',', 3) AS FLOAT);
SELECT CAST(split_part('12:00:00,13:30:00,14:00:00', ',', 2) AS TIME);
SELECT split_part('12:00:00,13:30:00', ',', 1);
SELECT CAST(split_part('2023-01-01,2023-02-01,2023-03-01', ',', 2) AS DATE);
SELECT split_part('2023-01-01,2023-02-01', ',', 1);
SELECT CAST(split_part('2023-01-01 12:00:00,2023-01-02 12:00:00', ',', 2) AS DATETIME);
SELECT split_part('2023-01-01 12:00:00,2023-01-02 12:00:00', ',', 1);
SELECT CAST(split_part('1.1,2.2,3.3', ',', 1) AS DECIMAL(10,2));
SELECT CAST(split_part(CAST('2023-01-01,2023-01-02' AS CHAR), ',', 2) AS DATE);
SELECT split_part(CAST('apple,banana,cherry' AS CHAR), ',', 2);
SELECT split_part(CAST(123.456 AS CHAR), '.', 2);

SELECT JSON_OBJECT('name', 'John Doe', 'age', 30, 'city', 'New York');
--error 5343
SELECT split_part(
    JSON_OBJECT('name', 'John Doe', 'age', 30, 'city', 'New York'),
    ',', 1
) AS first_part;
--error 5343
SELECT split_part(
    JSON_ARRAY('Apple', 'Banana', 'Cherry'),
    ',', 2
) AS second_fruit;
--error 5343
SELECT split_part(
    JSON_MERGE(
        JSON_OBJECT('key1', 'value1'),
        JSON_OBJECT('key2', 'value2')
    ),
    ',', 1
) AS first_key_value;

SELECT split_part(
    JSON_UNQUOTE(JSON_EXTRACT('{"a":"apple","b":"banana","c":"cherry"}', '$.b')),
    ' ', 1
) AS extracted_value;

SELECT split_part(
    JSON_UNQUOTE('["a, b, c", "d, e, f"]'),
    ',', 2
) AS second_value;
--error 5343
SELECT split_part(
    JSON_SET('{"name":"Alice"}', '$.age', 25), 
    ',', 1
) AS updated_value;
--error 5343
SELECT split_part(
    JSON_REPLACE('{"name":"Alice", "age":25}', '$.age', 30),
    ',', 1
) AS replaced_value;
--error 5343
SELECT split_part(
    JSON_INSERT('{"name":"Alice"}', '$.city', 'New York'),
    ',', 1
) AS inserted_value;

SELECT 
    CASE 
        WHEN split_part('a,b,c,d', ',', 1) = 'a' THEN 'Start with A'
        ELSE 'Does not start with A'
    END as result;
SELECT IF(split_part('apple,banana,cherry', ',', 2) = 'banana', 'It is Banana', 'Not Banana') as check_fruit;
SELECT IFNULL(split_part(NULL, ',', 1), 'No value found') as result;
SELECT NULLIF(split_part('1,2,3', ',', 2), '2') as result;
SELECT ORA_DECODE(split_part('cat,dog,bird', ',', 3), 'bird', 'Found a bird', 'No match') as animal_check;
SELECT CASE WHEN IFNULL(NULLIF(split_part('x,y,z', ',', 2), 'y'), 'default') = 'default' THEN CONCAT('Value was not found, returning: ', split_part('default', 'd', 1)) ELSE CONCAT('Found value: ', IF(split_part('x,y,z', ',', 2) = 'y', 'It is y!', 'Not y')) END as final_result;

select 
    GREATEST(split_part('a,b,c,d', ',', 1), split_part('a,b,c,d', ',', 2)) as result;
    
###  OB GREATEST判断NULL和'd'，结果为NULL；OB结果与MYSQL保持一致。
select 
    GREATEST(IFNULL(NULL, NULL), 'd') as result; 
select 
    GREATEST(NULL, 'd') as result; 
select split_part('a,b,c,d', ',', NULL);
select 
    GREATEST(split_part('a,b,c,d', ',', NULL), 'd') as result;
    
select 
    GREATEST(split_part('a,b,c,d', ',', 1), split_part('a,b,c,d', ',', 10)) as result;
select 
    LEAST(split_part('z,y,x,w', ',', 1), split_part('z,y,x,w', ',', 2)) as result;
select 
    LEAST(split_part('z,y,x,w', ',', NULL), 'y') as result;
select 
    LEAST(split_part('a,b,c,d', ',', -2), split_part('a,b,c,d', ',', -4)) as result;
select 
    ISNULL(split_part('a,b,c,d', ',', NULL)) as result;
select 
    ISNULL(split_part(NULL, ',', 1)) as result;
    
### OB结果为1，ODPS结果为false，因为OB GREATEST判断NULL和'd'，结果为NULL；OB结果与MYSQL保持一致。
select 
    ISNULL(GREATEST(split_part('a,b,c,d', ',', 1), NULL)) as result;
    
select 
    GREATEST(split_part(split_part('a,b,c,d', ',', 1), 'a', 1), split_part('a,b,c,d', ',', 2)) as result;
select 
    LEAST(split_part(split_part('z,y,x,w', ',', 1), 'y', 1), split_part('z,y,x,w', ',', 3)) as result;

SELECT 
    split_part(
        split_part('a,b,c,d', ',', 1), 
        'a', 
        1
    ) AS result; 
SELECT 
    split_part(
        '1,2,3,4,5', 
        ',', 
        split_part('1,2,3,4,5', ',', 2)
    ) AS result; 
SELECT 
    split_part(
        split_part('a,b,c,d', ',', -2), 
        ',', 
        1
    ) AS result; 
SELECT 
    split_part(
        split_part(
            'apple,banana,cherry', 
            ',', 
            split_part('0,1,2', ',', 1)
        ), 
        'a', 
        1
    ) AS result; 
SELECT 
    split_part(
        'hello|world|example', 
        '|', 
        split_part('1|2|3', '|', 3)
    ) AS result; 
SELECT 
    split_part(
        split_part('cat,dog,fish', ',', 1, 2), 
        ',', 
        -1
    ) AS result;
SELECT 
    split_part(
        'Monday,Tuesday,Wednesday', 
        ',', 
        split_part('1,2,3', ',', -1)
    ) AS result; 
SELECT 
    split_part(
        split_part('', ',', 1), 
        ',', 
        1
    ) AS result; 
SELECT 
    split_part(
        split_part(NULL, ',', 1), 
        ',', 
        NULL
    ) AS result; 
SELECT 
    split_part(
        split_part('x,y,z', '|', 1), 
        '|', 
        1
    ) AS result; 

SELECT split_part(keyvalue('a:b;c:d', ';'), ':', 1);
SELECT split_part(keyvalue('a:b;c:d', ';', ':', 'e'), ':', 1);
SELECT split_part(keyvalue('a:b;c:d', ';', ':', 'a'), ':', 2);
SELECT split_part(keyvalue('a:b;c:d', ';', ':', 'c'), ':', 2);
SELECT split_part(keyvalue('x:y;z:w', ';', ':', 'x'), ':', 2);
SELECT split_part(keyvalue('x:y;z:w', ';', ':', 'notfound'), ':', 2);
SELECT split_part(keyvalue('a:b;c:d', ';'), ':', 1);

--ERROR 1582
SELECT keyvalue(split_part('user1:info1;user2:info2', ';', 1), ':', 'user1');
SELECT keyvalue('user1:value1;user2:value2;user3:value3', ';', ':', split_part('user1:value1;user2:value2', ';', 2)); 
--ERROR 1582
SELECT keyvalue(split_part('key1:value1;key2:value2;key3:value3', ';', 2), ':', 'key2'); 
--ERROR 1582
SELECT keyvalue(split_part(NULL, ';', 1), ':', 'k1');
SELECT keyvalue('k1:v1;k2:v2;', ';', ':', 'k1');

