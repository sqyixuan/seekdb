SELECT id, split_part(string_col, delimiter_col, position_col) AS result FROM test_table WHERE id = 1;
UPDATE test_table SET position_col = 2 WHERE id = 1;
SELECT id, split_part(string_col, delimiter_col, position_col) AS result FROM test_table WHERE id = 1;
DELETE FROM test_table WHERE id = 1;
SELECT * FROM test_table WHERE id = 1;

--ERROR 1064
MERGE INTO test_table AS target
USING (SELECT 2 AS id, 'e,f,g,h' AS string_col, ',' AS delimiter_col, 1 AS position_col) AS source
ON (target.id = source.id)
WHEN MATCHED THEN
    UPDATE SET target.string_col = source.string_col, target.delimiter_col = source.delimiter_col, target.position_col = source.position_col
WHEN NOT MATCHED THEN
    INSERT (id, string_col, delimiter_col, position_col) VALUES (source.id, source.string_col, source.delimiter_col, source.position_col);
SELECT id, split_part(string_col, delimiter_col, position_col) AS result FROM test_table WHERE id = 2;

