SELECT 
  REGEXP_REPLACE(
    'dirty:data;clean:value',
    'dirty|data',
    ''
  );
## OBу╗ЊТъюСИјODPSСИЇСИђУЄ┤сђѓ
SELECT keyvalue(
  REGEXP_REPLACE(
    'dirty:data;clean:value',
    'dirty|data',
    ''
  ),
  'clean'
);

SELECT keyvalue(
  (SELECT GROUP_CONCAT(CONCAT(rn, ':', val))
   FROM (SELECT ROW_NUMBER() OVER() rn, val 
         FROM (SELECT 'first' val UNION SELECT 'second') t) t2),
  '1'
);

SELECT keyvalue(
  CONCAT('error:', 1/(LENGTH(keyvalue('a:0', 'a'))-1)),
  'error'
);

SELECT keyvalue(
  CONCAT('max:', POW(2, 64)),
  keyvalue(CONCAT('max:', CAST(POW(2,64) AS UNSIGNED)), 'max')
);

SELECT keyvalue(
  CONCAT('point:', ST_GeomFromText('POINT(1 1)')),
  'point'
);

SELECT keyvalue('a\0:b;c:d', BINARY 'a');
