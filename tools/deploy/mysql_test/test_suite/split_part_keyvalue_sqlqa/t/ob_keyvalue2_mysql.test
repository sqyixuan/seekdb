--disable_warnings
drop PROCEDURE if exists type_test;
--enable_warnings

DELIMITER //;
CREATE PROCEDURE type_test(OUT res VARCHAR(10))
BEGIN
  SET res = keyvalue('in:proc', 'in');
END;//
DELIMITER ;//

CALL type_test(@res);
SELECT @res;

--disable_warnings
drop TABLE if exists tmp;
--enable_warnings

CREATE TABLE tmp AS SELECT 'key:dynamic' AS data;
SELECT keyvalue(data, 'key') FROM tmp;

--disable_warnings
drop VIEW if exists v_test;
--enable_warnings

CREATE VIEW v_test AS SELECT 'a:view' AS col;
SELECT keyvalue(col, 'a') FROM v_test;

