  CONCAT(UNIX_TIMESTAMP()-3600, ':success'),
  UNIX_TIMESTAMP()
);
--disable_result_log
SELECT keyvalue(
  CONCAT('2023-10-01', DATE_ADD(NOW(), INTERVAL 1 DAY), 'ok'),
  DATE_ADD(NOW(), INTERVAL 1 DAY),
  '2023-10-01',
  'ok'
);
--enable_result_log

SELECT keyvalue(REVERSE(SUBSTR(';a:val;b:test', 2)), REVERSE('a'));
SELECT keyvalue(CONCAT(FLOOR(PI()), ':success'), LOG(10, 100));

--ERROR 1582
SELECT keyvalue(
  keyvalue(
    keyvalue('level1:data;level2:level3:final', 'level2'),
    ':',
    'level3'
  ),
  'data'
);

PREPARE stmt FROM 'SELECT keyvalue(SUBSTRING_INDEX(?, ";", 2), ?)';
SET @a='a:dynamic;b:test', @b='a';
EXECUTE stmt USING @a, @b;

SELECT keyvalue(
  'data1|data2|key=>ok',
  REPEAT('|', 1),
  CONCAT('=', '>'),
  'key'
);
SELECT keyvalue(
  GROUP_CONCAT(CONCAT_WS(':', id, salary) SEPARATOR ';'),
  'total'
) FROM (
  SELECT 'total' id, 30 salary UNION ALL
  SELECT 'avg', 20
) t;

SELECT keyvalue(
  REPLACE(JSON_OBJECT('name', 'Bob', 'age', 30), ',', ';'),
  ';',
  ':',
  'name'
);

SELECT keyvalue(
  keyvalue(
    CONCAT('key:', keyvalue('a:b', 'a')),
    'key'
  ),
  'b'
);
SELECT keyvalue(
  COALESCE(keyvalue(NULL, 'test'), 'fallback:k'),
  'fallback'
);
SELECT keyvalue(
  CAST('key:value' AS BINARY),
  CONVERT('key' USING latin1)
);

