--disable_warnings
drop PROCEDURE if exists test_keyvalue;
--enable_warnings

DELIMITER //;
CREATE PROCEDURE test_keyvalue()
BEGIN
  DECLARE v1 VARCHAR(100);
  SET v1 = keyvalue('a:b', 'a');
  SELECT v1;
END;//
DELIMITER ;//
CALL test_keyvalue();

