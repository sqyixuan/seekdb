PREPARE stmt FROM 'SELECT keyvalue(?, ?, ?, ?)';
SET @a='a+b:тіеТђЂтђ╝;c-d:тЁХС╗ќтђ╝', @b=';', @c=':', @d='a+b';
EXECUTE stmt USING @a, @b, @c, @d;

SELECT keyvalue(
  CASE 
    WHEN 1>2 THEN 'k1:v1' 
    ELSE CONCAT('k',2,':','case2') 
  END,
  'k2'
);

SELECT keyvalue(data, 'k') FROM (
  SELECT 'k:v1' AS data UNION ALL
  SELECT 'k:v2' UNION ALL
  SELECT 'k:v3'
) t;
SELECT keyvalue(GROUP_CONCAT(CONCAT_WS(':', id, name)), 'total')
FROM (SELECT 1 id, 'a' name UNION SELECT 2, 'b') t;

SELECT keyvalue(CONCAT('err:', 1/0), 'err');

