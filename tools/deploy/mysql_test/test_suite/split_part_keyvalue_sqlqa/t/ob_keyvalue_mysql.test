SELECT keyvalue(CONVERT('key1:value1;key2:value2' USING binary), ';', ':', 'key1') AS result_binary; 
SELECT keyvalue(CONVERT('key1:value1;key2:value2' USING utf8mb4), ';', ':', 'key2') AS result_utf8mb4;
SELECT keyvalue(CONVERT('键1:值1;键2:值2' USING gbk), ';', ':', '键2') AS result_gbk; 
SELECT keyvalue(CONVERT('键1:值1;键2:值2' USING gb18030), ';', ':', '键1') AS result_gb18030; 
SELECT keyvalue(CONVERT('key1:value1;key2:value2' USING latin1), ';', ':', 'key1') AS result_latin1; 
SELECT keyvalue(CONVERT(CONVERT('key_a:value_a;key_b:value_b' USING binary) USING utf8mb4), ';', ':', 'key_b') AS result_utf8mb4_binary; 
SELECT keyvalue(CONVERT(CONVERT('key_1:value_1;key_2:value_2' USING gbk) USING latin1), ';', ':', 'key_2') AS result_gbk_latin1; 

