SELECT 
    CASE 
        WHEN keyvalue('a:b;c:d', 'a') IS NOT NULL THEN keyvalue('a:b;c:d', 'a') 
        ELSE 'Key not found' 
    END AS result_case;
SELECT 
    IF(keyvalue('e:f;g:h', ';', ':', 'e') IS NULL, 'Key does not exist', keyvalue('e:f;g:h', ';', ':', 'e')) AS result_if;
SELECT 
    IFNULL(keyvalue('i:j;k:l', ';', ':', 'k'), 'No value found') AS result_ifnull;
SELECT 
    NULLIF(keyvalue('m:n;o:p', ';', ':', 'n'), 'n') AS result_nullif;
SELECT 
    ORA_DECODE(keyvalue('q:r;s:t', ';', ':', 's'), 't', 'Found value', 'Not found') AS result_or_decode;
SELECT 
    keyvalue(
        CONCAT(
            CASE 
                WHEN keyvalue('a:b;c:d', 'a') IS NOT NULL THEN 'Found value: ' 
                ELSE 'Key a not found: ' 
            END, 
            keyvalue('a:b;c:d', 'a')
        ),
        ';',
        ':',
        'a'
    ) AS nested_case;
SELECT 
    IF(
        keyvalue('u:v;x:y', ';', ':', 'x') IS NOT NULL, 
        CONCAT('Value for x is: ', keyvalue('u:v;x:y', ';', ':', 'x')), 
        'No value for x'
    ) AS nested_if;
SELECT 
    IFNULL(
        keyvalue('z:1;2:3', ';', ':', '1'), 
        keyvalue('z:1;2:3', ';', ':', 'nonexistent')
    ) AS nested_ifnull;
SELECT 
    NULLIF(
        keyvalue('a:b;c:d', ';', ':', 'c'), 
        'c'
    ) AS nested_nullif;
SELECT 
    ORA_DECODE(
        keyvalue('abc:def;ghi:jkl', ';', ':', 'ghi'), 
        'jkl', 
        'Value exists', 
        'Value does not exist'
    ) AS nested_or_decode;

SELECT GREATEST(keyvalue('a:b;c:d', ';', ':', 'a'), 'c') AS result_a;

### OB结果同MYSQL，与ODPS不一致。
SELECT GREATEST(keyvalue('a:b;c:d', ';', ':', 'd'), 'b') AS result_b;
SELECT LEAST(keyvalue('a:b;c:d', ';', ':', 'a'), 'b') AS result_a;
SELECT LEAST(keyvalue('a:b;c:d', ';', ':', 'd'), 'c') AS result_b;
SELECT IF(ISNULL(keyvalue('a:b;c:d', ';', ':', 'a')), 'null', 'not null') AS result_a;
SELECT IF(ISNULL(keyvalue('a:b;c:d', ';', ':', 'd')), 'null', 'not null') AS result_b;
SELECT GREATEST(keyvalue('a:b;c:d', ';', ':', 'a'), IF(ISNULL(keyvalue('a:b;c:d', ';', ':', 'c')), 'default', keyvalue('a:b;c:d', ';', ':', 'c'))) AS result_a;
SELECT LEAST(keyvalue('a:b;c:d', ';', ':', 'd'), IF(ISNULL(keyvalue('a:b;c:d', ';', ':', 'c')), 'default', keyvalue('a:b;c:d', ';', ':', 'c'))) AS result_b;

SELECT keyvalue('a:b;c:d', 'a');
SELECT keyvalue('a:b;c:d', 'd');
SELECT keyvalue('a:b;c:d', ';', ':', 'a');
SELECT keyvalue('a:b;c:d', ';', ':', 'd');
SELECT keyvalue(keyvalue('k1:v1;k2:v2', ';', ':', 'k2'), NULL, NULL, 'k2');
### OB结果与ODPS不一致。
SELECT keyvalue('k1:value1;k2:' || keyvalue('m1:n1;m2:n2', ';', ':', 'm2'), ';', ':', 'k2');
SELECT keyvalue(keyvalue(keyvalue('k1:v1;k2:v2;k3:v3', ';', ':', 'k3'), NULL, NULL, 'k3'), NULL, NULL, 'k3'); 
SELECT keyvalue('x:y;z:w', ';', ':', keyvalue('a:b;x:y;z:w', ';', ':', 'x'));
### OB结果与ODPS不一致。
SELECT keyvalue('a:b;c:' || keyvalue('x:y;z:w', ';', ':', 'x'), ';', ':', 'c');
SELECT keyvalue(keyvalue('level1:key1:value1;level1:key2:value2', ';', ':', 'key1'), ';', ':', 'level1');
SELECT keyvalue(NULL, NULL, NULL, NULL);
SELECT keyvalue('key:value', NULL, NULL, NULL);
SELECT keyvalue('', ';', ':', 'a');
SELECT keyvalue('outer1:inner1:innerValue1;outer2:inner2:innerValue2', ';', ':', keyvalue('outer1:inner1:innerValue1;outer2:inner2:innerValue2', ';', ':', 'outer2'));

--echo ### 参数使用表列时，覆盖各种数据类型

--disable_warnings
drop table if exists funcs_test;
--enable_warnings
create table funcs_test(
    dict_str varchar(512) CHARACTER SET utf8mb4,
    dict_text longtext CHARACTER SET gbk,
    delimiter_str varchar(512) CHARACTER SET utf16
);

insert into funcs_test values ('组别:sql;姓名:xx;年龄:20;', '组别:sql;姓名:xx;年龄:20;', ';');
select keyvalue(dict_str, '年龄') from funcs_test;
select keyvalue(dict_str, ';', ':', '年龄') from funcs_test;
select keyvalue(dict_str, ';', ':', '性别') from funcs_test;
select keyvalue(dict_str, '', '', '年龄') from funcs_test;
select keyvalue(dict_str, '', '', '性别') from funcs_test;
select keyvalue(dict_text, '年龄') from funcs_test;
select keyvalue(dict_text, ';', ':', '年龄') from funcs_test;
select keyvalue(dict_text, ';', ':', '性别') from funcs_test;
select keyvalue(dict_text, NULL, '', '年龄') from funcs_test;
select keyvalue(dict_text, '', '', '年龄') from funcs_test;
select keyvalue(dict_text, '', '', '性别') from funcs_test;

--disable_warnings
drop table if exists test_keyvalue;
--enable_warnings
CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    varchar_col VARCHAR(255),
    tinytext_col TINYTEXT,
    text_col TEXT,
    longtext_col LONGTEXT,
    int_col INT,
    float_col FLOAT
);

INSERT INTO test_keyvalue (varchar_col, tinytext_col, text_col, longtext_col, int_col, float_col) VALUES
('a:b;c:d', 'e:f;g:h', 'i:j;k:l', 'm:n;o:p', 123, 456.789),
('q:r;s:t', 'u:v;w:x', 'y:z;a:b', 'c:d;e:f', 789, 123.456);

SELECT keyvalue(varchar_col, 'a') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(tinytext_col, 'e') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(text_col, 'i') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(longtext_col, 'm') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(CAST(int_col AS CHAR), '1') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(CAST(float_col AS CHAR), '4') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(NULL, 'a') FROM test_keyvalue WHERE id = 1;
SELECT keyvalue(varchar_col, ';', ':', 'a') FROM test_keyvalue WHERE id = 1;

--echo ### 数据类型全覆盖

--disable_warnings
drop table if exists test_keyvalue;
--enable_warnings

CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_col CHAR(100),
    varchar_col VARCHAR(500),
    tinyblob_col TINYBLOB,
    tinytext_col TINYTEXT,
    blob_col BLOB,
    text_col TEXT,
    mediumblob_col MEDIUMBLOB,
    mediumtext_col MEDIUMTEXT,
    longblob_col LONGBLOB,
    longtext_col LONGTEXT
);

INSERT INTO test_keyvalue (char_col, varchar_col, tinyblob_col, tinytext_col, blob_col, text_col, mediumblob_col, mediumtext_col, longblob_col, longtext_col) VALUES
('key1:value1', 'key2:value2', 'key3:value3', 'key4:value4', 'key5:value5', 'key6:value6', 'key7:value7', 'key8:value8', 'key9:value9', 'key10:value10');

SELECT keyvalue(char_col, ';', ':', 'key1') AS result_char FROM test_keyvalue;
SELECT keyvalue(varchar_col, ';', ':', 'key2') AS result_varchar FROM test_keyvalue;
SELECT keyvalue(CONVERT(tinyblob_col USING utf8), ';', ':', 'key3') AS result_tinyblob FROM test_keyvalue;
SELECT keyvalue(tinytext_col, ';', ':', 'key4') AS result_tinytext FROM test_keyvalue;
SELECT keyvalue(CONVERT(blob_col USING utf8), ';', ':', 'key5') AS result_blob FROM test_keyvalue;
SELECT keyvalue(text_col, ';', ':', 'key6') AS result_text FROM test_keyvalue;
SELECT keyvalue(CONVERT(mediumblob_col USING utf8), ';', ':', 'key7') AS result_mediumblob FROM test_keyvalue;
SELECT keyvalue(mediumtext_col, ';', ':', 'key8') AS result_mediumtext FROM test_keyvalue;
SELECT keyvalue(CONVERT(longblob_col USING utf8), ';', ':', 'key9') AS result_longblob FROM test_keyvalue;
SELECT keyvalue(longtext_col, ';', ':', 'key10') AS result_longtext FROM test_keyvalue;

--disable_warnings
drop table if exists test_keyvalue;
--enable_warnings

CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    bigint_value BIGINT,
    tinyint_value TINYINT,
    smallint_value SMALLINT,
    mediumint_value MEDIUMINT,
    float_value FLOAT,
    double_value DOUBLE,
    decimal_value DECIMAL(10, 2)
);

INSERT INTO test_keyvalue (bigint_value, tinyint_value, smallint_value, mediumint_value, float_value, double_value, decimal_value) VALUES
(12345678901234, 10, 200, 30000, 3.14, 3.141592653589793, 12345.67);
SELECT keyvalue(CONCAT('big1:', bigint_value), ':', NULL, 'big1') AS result_bigint 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('tiny1:', tinyint_value), ':', NULL, 'tiny1') AS result_tinyint 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('small1:', smallint_value), ':', NULL, 'small1') AS result_smallint 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('medium1:', mediumint_value), ':', NULL, 'medium1') AS result_mediumint 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('float1:', float_value), ':', NULL, 'float1') AS result_float 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('double1:', double_value), ':', NULL, 'double1') AS result_double 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('decimal1:', decimal_value), ':', NULL, 'decimal1') AS result_decimal 
FROM test_keyvalue;
SELECT keyvalue(CONCAT('big1:', bigint_value, ';tiny1:', tinyint_value), ';', NULL, 'big1') AS result_combined_2
FROM test_keyvalue;
SELECT keyvalue(CONCAT('big1:', bigint_value, ';tiny1:', tinyint_value), ';', NULL, 'tiny1') AS result_combined_2_tiny
FROM test_keyvalue;
SELECT keyvalue(CONCAT('big1:', bigint_value, ';small1:', smallint_value), ';', ':', 'big1') AS result_combined_4
FROM test_keyvalue;
SELECT keyvalue(CONCAT('big1:', bigint_value, ';small1:', smallint_value), ';', ':', 'small1') AS result_combined_4_small
FROM test_keyvalue;

