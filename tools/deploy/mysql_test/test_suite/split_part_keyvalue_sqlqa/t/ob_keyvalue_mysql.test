SELECT keyvalue('a:b;c:d', ';', ':', 'a', 'extra');
SELECT keyvalue(12345, 'a');

### OB与ODPS结果不一致。
SELECT keyvalue('a:b;c:d', ',', ':', 'a');

### 中文字符,OB结果和ODPS一致为空。
SELECT keyvalue('a:b;c:d', ',', '：', 'a');

SELECT keyvalue('a:b;c:d', ';', '.', 'a');
SELECT keyvalue('a:b;c:d', ';', ':', 'e');

