--disable_warnings
drop table if exists test_keyvalue;
--enable_warnings

CREATE TABLE test_keyvalue (value TEXT);
INSERT INTO test_keyvalue (value) VALUES
('a:b;c:d'),
('foo:bar;baz:qux'),
('name:John;age:30;city:New York'),
(NULL),
('key1:value1;key2:value2;key3:value3');

SET @arg1_1 = 'a:b;c:d';
SET @arg1_2 = 'foo:bar;baz:qux';
SET @arg1_3 = 'name:John;age:30;city:New York';
SET @arg1_4 = NULL;
SET @arg1_5 = 'key1:value1;key2:value2;key3:value3';

SET @arg2_1 = ';';
SET @arg2_2 = NULL;

SET @arg3_1 = ':';
SET @arg3_2 = NULL;

SET @arg4_1 = 'a';
SET @arg4_2 = 'd';
SET @arg4_3 = 'foo';
SET @arg4_4 = 'baz';
SET @arg4_5 = 'name';
SET @arg4_6 = NULL;

SELECT keyvalue(@arg1_1, @arg4_1);
SELECT keyvalue(@arg1_1, @arg4_2);

SELECT keyvalue(@arg1_2, @arg2_1, @arg3_1, @arg4_3); 
SELECT keyvalue(@arg1_2, @arg2_1, @arg3_1, @arg4_4); 
SELECT keyvalue(@arg1_3, @arg2_1, @arg3_1, @arg4_5); 
SELECT keyvalue(@arg1_3, @arg2_1, @arg3_1, @arg4_6); 

SELECT keyvalue(@arg1_4, @arg4_1); 
SELECT keyvalue(@arg1_4, @arg4_2); 
SELECT keyvalue(@arg1_4, @arg2_1, @arg3_1, @arg4_1); 

SELECT keyvalue(@arg1_1, NULL, NULL, @arg4_1);
SELECT keyvalue(@arg1_1, NULL, NULL, @arg4_2);
SELECT keyvalue(@arg1_2, NULL, NULL, @arg4_3);
SELECT keyvalue(@arg1_2, NULL, NULL, @arg4_4);
SELECT keyvalue(@arg1_3, NULL, NULL, @arg4_5);
SELECT keyvalue(@arg1_3, NULL, NULL, @arg4_6);

SELECT keyvalue(@arg1_5, ';', ':', 'key2'); 
SELECT keyvalue(@arg1_5, ';', ':', 'key3'); 
SELECT keyvalue(@arg1_5, ';', ':', 'key4'); 


--echo ### 使用运算符对参数计算的结果覆盖

SELECT keyvalue('a:b;c:d', 'a');
SELECT keyvalue('a:b;c:d', ';', ':', 'c');
SELECT keyvalue(CONCAT('a:', 'b;c:d'), 'a');
SELECT keyvalue('a:b;c:d', CONCAT(';', ';'), ':', 'c');
SELECT keyvalue('a:b;c:d', ';', CONCAT(':', ':'), 'c');
SELECT keyvalue('a:b;c:d', CONCAT('a', 'a'));
SELECT keyvalue(REPLACE(CONCAT('a:', 'b;c:d'), 'b', 'e'), 'a');
SELECT keyvalue('a:b;c:d', REPLACE(CONCAT(';', ';'), ';', ','), ':', 'c');
SELECT keyvalue('a:b;c:d', ';', REPLACE(CONCAT(':', ':'), ':', '='), 'c');
SELECT keyvalue('a:b;c:d', REPLACE(CONCAT('a', 'a'), 'aa', 'a'));

--echo ### 使用运算符全覆盖

SELECT keyvalue('a:b;c:d', ';', ':', 'a') > 'b'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') >= 'b';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') < 'd'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') <= 'b';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') = 'b'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') != 'd';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') IN ('a', 'b');
SELECT keyvalue('a:b;c:d', ';', ':', 'a') NOT IN ('c', 'd'); 
SELECT keyvalue(NULL, ';', ':', 'a') IS NULL; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') IS NOT NULL; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') BETWEEN 'a' AND 'z'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') NOT BETWEEN 'c' AND 'd';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') LIKE 'b%';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') REGEXP '^a$'; 
SELECT keyvalue('a:1;b:2;c:3', ';', ':', 'a') + keyvalue('a:1;b:2;c:3', ';', ':', 'b'); 
SELECT keyvalue('a:5;b:3', ';', ':', 'a') - keyvalue('a:5;b:3', ';', ':', 'b'); 
SELECT keyvalue('a:2;b:3', ';', ':', 'a') * keyvalue('a:2;b:3', ';', ':', 'b'); 
SELECT keyvalue('a:6;b:2', ';', ':', 'a') / keyvalue('a:6;b:2', ';', ':', 'b'); 
SELECT keyvalue('a:5;b:2', ';', ':', 'a') MOD keyvalue('a:5;b:2', ';', ':', 'b');
SELECT (keyvalue('a:1;b:2;c:3', ';', ':', 'a') + keyvalue('a:1;b:2;c:3', ';', ':', 'b')) * keyvalue('a:1;b:2;c:3', ';', ':', 'c'); 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') = 'b' AND keyvalue('a:b;c:d', ';', ':', 'b') = 'd'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') = 'b' OR keyvalue('a:b;c:d', ';', ':', 'b') = 'd'; 
SELECT NOT keyvalue('a:b;c:d', ';', ':', 'a') = 'b'; 
SELECT keyvalue('a:b;c:d', ';', ':', 'a') = 'b' XOR keyvalue('a:b;c:d', ';', ':', 'b') = 'd';
SELECT keyvalue('a:b;c:d', ';', ':', 'a') || 'test'; 
SELECT keyvalue('a:1;b:3', ';', ':', 'a') & keyvalue('a:1;b:3', ';', ':', 'b'); 
SELECT keyvalue('a:1;b:3', ';', ':', 'a') | keyvalue('a:1;b:3', ';', ':', 'b'); 
SELECT keyvalue('a:1;b:3', ';', ':', 'a') ^ keyvalue('a:1;b:3', ';', ':', 'b'); 
SELECT !keyvalue('a:1;b:3', ';', ':', 'a'); 
SELECT keyvalue('a:1;b:3', ';', ':', 'a') << 1; 
SELECT keyvalue('a:2;b:3', ';', ':', 'a') >> 1; 
SET @val = keyvalue('a:b;c:d', ';', ':', 'a');
SELECT @val;

--echo ### 函数嵌套，包含常用函数与SPLIT_PART/KEYVALUE的嵌套，以及SPLIT_PART/KEYVALUE自身的嵌套使用

SELECT keyvalue('a:b;c:d', 'a');
SELECT keyvalue('a:b;c:d', ';', ':', 'c');
SELECT keyvalue(LOWER('A:B;C:D'), 'a');

### OB结果为b，ODPS结果为空。
SELECT keyvalue('a:b;c:d', ';', ':', UPPER('a'));

SELECT keyvalue(CONCAT('a:', 'b;c:d'), 'a');
SELECT keyvalue(REPLACE('a:b;c:d', 'b', 'e'), 'a');
SELECT keyvalue(keyvalue('a:b;c:d', 'a'), 'b');
SELECT keyvalue('a:b;c:d', keyvalue('a:b;c:d', ';', ':', 'a'), ':', 'c');
SELECT keyvalue('a:b;c:d', ';', keyvalue('a:b;c:d', ';', ':', 'a'), 'c');
SELECT keyvalue(CONCAT('a:', keyvalue('a:b;c:d', 'a')), keyvalue('a:b;c:d', ';', ':', 'a'));

--echo ### 函数嵌套全覆盖

SELECT MAX(keyvalue(data, ';', ':', 'a')) AS max_value
FROM (SELECT 'a:10;b:20;c:30' AS data) AS subquery;
SELECT MIN(keyvalue(data, ';', ':', 'b')) AS min_value
FROM (SELECT 'a:10;b:5;c:15' AS data) AS subquery;
SELECT AVG(CAST(keyvalue(data, ';', ':', 'c') AS UNSIGNED)) AS avg_value
FROM (SELECT 'a:10;b:20;c:30' AS data) AS subquery;
SELECT SUM(CAST(keyvalue(data, ';', ':', 'a') AS UNSIGNED)) AS sum_value
FROM (SELECT 'a:10;b:20;c:30' AS data) AS subquery;
SELECT COUNT(keyvalue(data, ';', ':', 'b')) AS count_value
FROM (SELECT 'a:10;b:20;b:5' AS data) AS subquery
WHERE keyvalue(data, ';', ':', 'b') IS NOT NULL;

SELECT ROUND(keyvalue('a:1.5;b:3.5', ';', ':', 'a')) AS result1;
SELECT CEIL(keyvalue('x:1.3;y:2.8', ';', ':', 'y')) AS result2;
SELECT FLOOR(keyvalue('m:5.7;n:8.3', ';', ':', 'm')) AS result3;
SELECT ABS(keyvalue('p:-3.2;q:4.5', ';', ':', 'p')) AS result4;
SELECT NEG(keyvalue('r:9;s:-2', ';', ':', 's')) AS result5;
SELECT SIGN(keyvalue('u:-7;v:3', ';', ':', 'u')) AS result6;
SELECT CONV(keyvalue('base2:101;base3:10', ';', ':', 'base2'), 2, 10) AS result7;
SELECT MOD(keyvalue('a:10;b:3', ';', ':', 'a'), keyvalue('x:2;y:5', ';', ':', 'x')) AS result8;
SELECT POW(keyvalue('a:2;b:3', ';', ':', 'a'), keyvalue('x:3;y:2', ';', ':', 'y')) AS result9;
SELECT POWER(keyvalue('base:2;exp:5', ';', ':', 'base'), keyvalue('base:2;exp:5', ';', ':', 'exp')) AS result10;
### SELECT RAND(keyvalue('seed:5', ';', ':', 'seed')) AS result11;

SELECT keyvalue(CONCAT('a:', 'b', ';', 'c:', 'd'), 'a');
SELECT keyvalue(CONCAT_WS(';', 'a:b', 'c:d'), 'c'); 
SELECT keyvalue(SUBSTR('a:b;c:d', 1, 5), 'b'); 
SELECT keyvalue(TRIM(' a:b;c:d '), 'a'); 
SELECT LENGTH(keyvalue('a:b;c:d', 'a')); 
SELECT UPPER(keyvalue('a:b;c:d', 'a')); 
### OB与ODPS结果不一致。
SELECT LOWER(keyvalue('A:B;C:D', 'a')); 
SELECT keyvalue(REPLACE('a:b;c:d', 'a', 'e'), 'e'); 
SELECT keyvalue(MD5('a:b;c:d'), 'a'); 
SELECT LOCATE('b', keyvalue('a:b;c:d', 'a')); 
SELECT keyvalue('a:b;c:d', 'c') REGEXP 'd'; 
SELECT keyvalue(REPEAT('a:b;', 2), 'a'); 
SELECT keyvalue(CONCAT('   ', 'a:b;c:d'), 'a');
SELECT keyvalue(SUBSTRING_INDEX('a:b;c:d', ';', 1), 'a'); 

SELECT keyvalue(CONCAT('key1:value1', ';', 'key2:', keyvalue('key3:value3', ';', ':', 'key3')), ';', ':', 'key2');
SELECT keyvalue(CONCAT_WS(';', 'key1:value1', 'key2:', keyvalue('key3:value3', ';', ':', 'key3')), ';', ':', 'key2');
SELECT FORMAT(1.23456, 2) AS formatted_value, keyvalue(CONCAT('key1:', FORMAT(1.23456, 2)), ';', ':', 'key1');
SELECT SUBSTR(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 1, 5) AS sub_value;
SELECT TRIM(keyvalue('   key1: value1; key2: value2  ', ';', ':', 'key1')) AS trimmed_value;
SELECT ASCII(SUBSTR(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 1, 1)) AS ascii_value;
SELECT LENGTH(keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS length_value;
SELECT UPPER(keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS upper_value;
SELECT HEX(keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS hex_value,
       UNHEX(HEX(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'))) AS unhex_value;
SELECT MD5(keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS md5_value;
SELECT IP2INT('192.168.0.1') AS ip_to_int,
       INT2IP(3232235521) AS int_to_ip;
SELECT keyvalue('key1:value1;key2:value2', ';', ':', 'key1') LIKE 'value%';
SELECT REPLACE(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 'value', 'new_value') AS replaced_value;
SELECT SUBSTRING_INDEX(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), ':', 1) AS substring_value;
SELECT INSTR(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 'value') AS instr_value;
SELECT INSERT(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 1, 5, 'new') AS insert_value;
SELECT LPAD(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 10, '0') AS lpad_value,
       RPAD(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 10, '0') AS rpad_value;
SELECT bin(10) AS binary_value,
       keyvalue(CONCAT('key1:', bin(10)), ';', ':', 'key1') AS bin_keyvalue;
SELECT quote(keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS quoted_value;
SELECT REGEXP_SUBSTR(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 'value[0-9]', 1, 1) AS regexp_substr_value;
SELECT REPEAT(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 2) AS repeated_value;
SELECT CONCAT(SPACE(5), keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS spaced_value;
SELECT LOCATE('value', keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS locate_value;
SELECT POSITION('value' IN keyvalue('key1:value1;key2:value2', ';', ':', 'key1')) AS position_value;
SELECT FIELD(keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 'value1', 'value2') AS field_value;
SELECT ELT(2, keyvalue('key1:value1;key2:value2', ';', ':', 'key1'), 'value1', 'value2') AS elt_value;

--disable_result_log
SELECT ADDDATE(CURDATE(), INTERVAL 1 DAY) AS next_date,
       keyvalue(CONCAT('key1:', DATE(ADDDATE(CURDATE(), INTERVAL 1 DAY)),
                       ';key2:', DATE(CURDATE()), ';key3:2023-10-01'), ';', ':', 'key1') AS keyvalue_test1;
SELECT ADDTIME(CURDATE(), '10:00:00') AS next_time,
       keyvalue(CONCAT('key1:', DATE(ADDTIME(CURDATE(), '10:00:00')),
                       ';key2:', DATE(CURDATE()), ';key3:2023-10-01'), ';', ':', 'key2') AS keyvalue_test2;
SELECT DATE(CURDATE()) AS current_static_date,
       keyvalue(CONCAT('now:', DATE(CURDATE()), ';static:', '2023-10-01'), ';', ':', 'now') AS keyvalue_test4;
SELECT DATEDIFF(CURDATE(), '2023-01-01') AS days_diff,
       keyvalue(CONCAT('days:', DATEDIFF(CURDATE(), '2023-01-01'), ';weeks:', DATEDIFF(CURDATE(), '2023-01-01') / 7), ';', ':', 'weeks') AS keyvalue_test5;
--enable_result_log

SELECT keyvalue(CONVERT('a:1;b:2;d:3', CHAR), ';', ':', 'a'); 
SELECT keyvalue(CONVERT('name:b;age:30;dob:1990-01-01', CHAR), ';', ':', 'name');

SELECT keyvalue(CONVERT('a:1;b:2;c:3', UNSIGNED), ';', ':', 'b'); 
SELECT keyvalue(CONVERT('pi:3.14;three:3', DECIMAL), ';', ':', 'pi'); 

SELECT keyvalue(CONVERT('a:1;b:2;c:3', SIGNED), ';', ':', 'c'); 
SELECT keyvalue(CONVERT('x:10;y:20;z:30', SIGNED), ';', ':', 'y'); 

SELECT keyvalue(CONVERT('e:2.718;pi:3.14;phi:1.618', DECIMAL), ';', ':', 'phi');
SELECT keyvalue(CONVERT('a:0.9;b:1.1;c:2.2', DECIMAL), ';', ':', 'a'); 

SELECT keyvalue(CONVERT('event:2023-01-01;location:park', DATE), ';', ':', 'event');
SELECT keyvalue(CONVERT('birth:1990-05-20;age:30', DATE), ';', ':', 'birth'); 

SELECT keyvalue(CONVERT('start:12:00;end:14:00', TIME), ';', ':', 'start'); 
SELECT keyvalue(CONVERT('break:10:30;resume:11:00', TIME), ';', ':', 'resume'); 

SELECT keyvalue(CONVERT('meeting:2023-10-01 10:00:00;venue:room1', DATETIME), ';', ':', 'meeting'); 
SELECT keyvalue(CONVERT('appointment:2023-12-10 15:30:00;doctor:Smith', DATETIME), ';', ':', 'doctor');

SET @json_data = '{"a":"b", "c":"d"}';
SET @key_values = 'a:1;b:2;c:3;d:4';

SELECT JSON_OBJECT(
    'key_a', keyvalue(@key_values, ';', ':', 'a'),
    'key_c', keyvalue(@key_values, ';', ':', 'c')
) AS json_output_1;

