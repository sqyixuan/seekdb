CREATE TABLE test_keyvalue (
    id INT AUTO_INCREMENT PRIMARY KEY,
    arg1 VARCHAR(255) NOT NULL, 
    arg2 VARCHAR(10) DEFAULT ';', 
    arg3 VARCHAR(10) DEFAULT ':', 
    value_a VARCHAR(255) GENERATED ALWAYS AS (keyvalue(arg1, 'a')) STORED,
    value_b VARCHAR(255) GENERATED ALWAYS AS (keyvalue(arg1, 'b')) STORED,
    value_a_custom_separated VARCHAR(255) GENERATED ALWAYS AS (keyvalue(arg1, arg2, arg3, 'a')) STORED,
    value_b_custom_separated VARCHAR(255) GENERATED ALWAYS AS (keyvalue(arg1, arg2, arg3, 'b')) STORED,
    value_d_custom_separated VARCHAR(255) GENERATED ALWAYS AS (keyvalue(arg1, arg2, arg3, 'd')) STORED
);

