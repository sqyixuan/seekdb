--enable_warnings

CREATE TABLE hash_partitioned_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT
) 
PARTITION BY HASH(id) 
PARTITIONS 4;

CREATE TABLE key_partitioned_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT
) 
PARTITION BY KEY(id) 
PARTITIONS 4;

