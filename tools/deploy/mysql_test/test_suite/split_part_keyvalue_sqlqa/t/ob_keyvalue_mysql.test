CREATE TABLE test_keyvalue_json (
    id INT AUTO_INCREMENT PRIMARY KEY,
    json_data JSON NOT NULL,
    varchar_data VARCHAR(255) NOT NULL,
    tinytext_data TINYTEXT NOT NULL,
    text_data TEXT NOT NULL,
    longtext_data LONGTEXT NOT NULL
);

INSERT INTO test_keyvalue_json (json_data, varchar_data, tinytext_data, text_data, longtext_data) VALUES
('{"a": "b", "c": "d"}', 'example varchar', 'example tinytext', 'example text', 'example longtext');

SELECT keyvalue('a:b;c:d', 'a') AS value1;
SELECT keyvalue('a:b;c:d', 'd') AS value2;

SELECT keyvalue('a:b;c:d', ';', ':', 'a') AS value3; 
SELECT keyvalue('a:b;c:d', ';', ':', 'd') AS value4;

SELECT keyvalue(JSON_UNQUOTE(json_data), ';', ':', 'a') AS json_value1
FROM test_keyvalue_json; 

SELECT keyvalue(JSON_UNQUOTE(json_data), ';', ':', 'c') AS json_value2
FROM test_keyvalue_json;

SELECT keyvalue(JSON_UNQUOTE(json_data), ';', ':', 'e') AS json_value3
FROM test_keyvalue_json;

