purge recyclebin;
--echo #Environmental cleaning
--result_format 4

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--enable_sorted_result

--echo ###root用户
connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;

--echo ### 基础case

select keyvalue('a:b;c:d', 'a');
select keyvalue('a:b;c:d', 'd');
select keyvalue('a:b;c:d', ';', ':', 'a');

select keyvalue('0:1;1:2', 1) ;
select keyvalue('0:1;1:2', 2) ;
select keyvalue('0:1;1:2', ';', '=', 0) ;
select keyvalue('name=Li;age=1;', ';', '=', 'age') ;

### OB结果为NULL，ODPS结果为空。
select keyvalue('name=Li;age=1;', '', '=', 'age') ;

select keyvalue('name=Li;age=1;', ';', '', 'age') ;
select keyvalue('name=Li;age=1;', ';', '=', '') ;
select keyvalue('name=Li;age=1;', ' ', '=', 'age') ;
select keyvalue(NULL, ';', '=', 'age') ;
select keyvalue('name=Li;age=1;', NULL, '=', 'age') ;
select keyvalue('name=Li;age=1;', ';', NULL, 'age') ;
select keyvalue('name=Li;age=1;', ';', '=', NULL) ;

# special
select keyvalue(NULL,NULL);
select keyvalue(NULL,NULL,NULL,NULL);
SELECT keyvalue('abcdabcdabc', NULL);
SELECT keyvalue('abcdabcdabc', NULL, NULL, NULL);
SELECT keyvalue('abcdabcdabc', 'b', 'c', NULL );
SELECT keyvalue('abcdabcdabc', 'd', 'b', 'a'); 
SELECT keyvalue('','');
SELECT keyvalue('','','','');
--error 1210
SELECT keyvalue('               ',' ', ' ', ' ');
SELECT keyvalue('\;decreaseStore:1\;xcard:1\;isB2C:1\;tf:21910\;cart:1\;shipping:2\;pf:0\;market:shoes\;instPayAmount:0\;tt:',"\;",":","tf");
SELECT keyvalue('\;decreaseStore:1\;xcard:1\;isB2C:1\;tf:21910\;cart:1\;shipping:2\;pf:0\;market:shoes\;instPayAmount:0\;tt:',"\;",":","tt");

# dup key-values
select keyvalue('name=Li;name=Zhao;name=Sun;name=Wang;name=NULL;', ';', '=', 'name');

