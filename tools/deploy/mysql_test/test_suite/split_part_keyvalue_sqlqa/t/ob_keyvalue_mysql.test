SELECT keyvalue('0:zero;1:one', ';', ':', '0') AS result_10;
SELECT keyvalue('3.14:pi;true:is_true', ';', ':', 'true') AS result_11;
SELECT keyvalue('-1:negative_value;1:positive_value', ';', ':', '-1') AS result_12;
SELECT keyvalue('a1:b1;a2:b2;a3:b3;a4:b4;a5:b5', ';', ':', 'a3') AS result_13;
SELECT keyvalue('large_value:1;small_value:0;negative_value:-1', ';', ':', 'large_value') AS result_14;
SELECT keyvalue('single_key:only_value', ';', ':', 'single_key') AS result_15;

