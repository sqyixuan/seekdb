CREATE TABLE test_binary (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data BLOB,
    CHARSET binary
);

CREATE TABLE test_utf8mb4 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT CHARACTER SET utf8mb4
);

CREATE TABLE test_gbk (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT CHARACTER SET gbk
);

CREATE TABLE test_gb18030 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT CHARACTER SET gb18030
);

CREATE TABLE test_latin1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data TEXT CHARACTER SET latin1
);

