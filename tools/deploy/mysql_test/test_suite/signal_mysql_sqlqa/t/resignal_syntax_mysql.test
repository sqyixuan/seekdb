      RESIGNAL SET MESSAGE_TEXT=@@character_set_system, MYSQL_ERRNO=@@wait_timeout;
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=@@character_set_system, MYSQL_ERRNO=@@wait_timeout;
    END IF;
  END;
  SELECT id into @temp FROM  xxx;
