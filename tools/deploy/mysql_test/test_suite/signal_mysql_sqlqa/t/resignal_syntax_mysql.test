--echo ###########################################################################################
--echo #### ****************标签：resignal-1-1-1 ，resignal-1-1-1-2			  *************** ####
--echo #### ****************功能：错误值 - 命名错误条件的名称(condition_name) *************** ####
--echo ## 命名错误条件的名称存在
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE cond1 CONDITION FOR SQLSTATE '45000';
    DECLARE cond2 CONDITION FOR SQLSTATE '99999';
    IF pval = 0 THEN
      RESIGNAL cond1 SET MESSAGE_TEXT = '【RESIGNAL】An cond1 occurred',MYSQL_ERRNO=1002;
    ELSE
      RESIGNAL cond2 SET MESSAGE_TEXT = '【RESIGNAL】An cond2 occurred',MYSQL_ERRNO=1003;
    END IF;
  END;
  DROP TABLE xxx;
END;
//

--error 1002
CALL pro1(0)//
--error 1003
CALL pro1(2)//

--echo ## 命名错误条件的名称不存在
DROP PROCEDURE IF EXISTS pro1;//
--error 1319
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE cond1 CONDITION FOR SQLSTATE '45000';
    RESIGNAL cond2 SET MESSAGE_TEXT = '【RESIGNAL】An cond2 occurred',MYSQL_ERRNO=1003;
  END;
  DROP TABLE xxx;
END;
