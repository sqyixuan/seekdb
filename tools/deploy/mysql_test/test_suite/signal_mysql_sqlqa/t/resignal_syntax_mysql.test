# owner: hr351303
# owner group: sql4
# description: Mysql SIGNAL/RESIGNAL 语句 - 基本语法 - RESIGNAL 语句
# tags: pl,dml,auto_increment
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

delimiter //;

--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
--echo ###### 标签：signal-1,resignal-1-1 基本语法 - RESIGNAL 语句
--echo -----------------------------------------------------------------------------------------------------------------

--echo #########################################################################################
--echo #### **************** 标签：resignal-1-1-1 ，resignal-1-1-1-1          ************* ####
--echo #### **************** 功能：错误值 - SQLSTATE值(5 个字符的字符串文字)     ********** ####
--echo #### 函数参数
DROP FUNCTION IF EXISTS fun1;//
--error 1064
CREATE FUNCTION fun1 (sqlstate_value VARCHAR(64)) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE sqlstate_value SET MESSAGE_TEXT='【RESIGNAL】通过函数参数指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  SELECT a INTO @p FROM notable; 
  RETURN '通过函数参数指定SQLSTATE值';
END;
//

--echo #### 存储过程参数（in/inout）
DROP PROCEDURE IF EXISTS pro1;//
--error 1064
CREATE PROCEDURE pro1 (sqlstate_value VARCHAR(64))
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE sqlstate_value SET  MESSAGE_TEXT='【RESIGNAL】通过存储过程参数指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//


--echo #### 系统变量
DROP PROCEDURE IF EXISTS pro1;//
--error 1064
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE @@wait_timeout SET  MESSAGE_TEXT='【RESIGNAL】通过系统变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//


--echo #### 用户定义的变量
DROP PROCEDURE IF EXISTS pro1;//
--error 1064
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE @val SET  MESSAGE_TEXT='【RESIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//


--echo #### DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
--error 1064
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE val VARCHAR(64) DEFAULT '45000';
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE val SET  MESSAGE_TEXT='【RESIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx;
END;
//

--echo #### 字面量
--echo #### ①5 个字符的字符串文字
--echo ## '00xxx'（成功）
DROP PROCEDURE IF EXISTS pro1;//
--error 1407
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE '00111' SET MESSAGE_TEXT = '【RESIGNAL】An 00xxx occurred';
	END IF;
  END;
  DROP TABLE xxx;
END;
//


--echo ## '01xxx'（警告）
--echo # bug9:【resignal】带有条件值和可选新信号信息的 resignal语句，条件区域数，mysql与ob不一致。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	RESIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【RESIGNAL】An 01xxx occurred';
	GET DIAGNOSTICS @num = NUMBER;
	SELECT @num 'NUMBER';
  END;
  DROP TABLE xxx;
END;
//

CALL pro1();//
SHOW warnings;//


--echo ## '02xxx'（未找到）, >'02xxx'（例外）- 全是数字的SQLSTATE值'03000'、'45000'、'99999'……
--echo # bug10:【resignal】在PL中使用resignal语句，下列格式修改SQLSTATE值，mysql成功，ob修改失效。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	DECLARE specialty CONDITION FOR SQLSTATE '45000';
	IF pval = 0 THEN
      RESIGNAL;
	ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '03000';
	ELSEIF pval = 2 THEN
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An 45000 occurred';
	ELSEIF pval = 3 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
	ELSE
      RESIGNAL SQLSTATE '99999' SET MESSAGE_TEXT = '【RESIGNAL】An 99999 occurred', MYSQL_ERRNO = 1001;
	END IF;    
  END;
  DROP TABLE xxx;
END;
//

--error 1051
CALL pro1(0)//
--error 1644
CALL pro1(1)//
--error 1644
CALL pro1(2)//
--error 1644
CALL pro1(3)//
--error 1001
CALL pro1(4)//


--echo ## >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 大写字母场合
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '2D521';
    IF pval = 0 THEN
      RESIGNAL SQLSTATE '0A001' SET MESSAGE_TEXT = '【RESIGNAL】An 0A001 occurred', MYSQL_ERRNO = 9999;
    ELSEIF pval = 1 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An 2D521 occurred', MYSQL_ERRNO = 9999;
	ELSE
      RESIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【RESIGNAL】A warning occurred', MYSQL_ERRNO = 1000;
      RESIGNAL SQLSTATE '0K000' SET MESSAGE_TEXT = '【RESIGNAL】An 0K000 occurred', MYSQL_ERRNO = 1002;
	END IF;
  END;
  DROP TABLE xxx;
END;
//

--error 9999
CALL pro1(0)//

--error 9999
CALL pro1(1)//

--error 1002
CALL pro1(2)//


--echo ##  >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 小写字母场合
DROP PROCEDURE IF EXISTS pro1;//
--error 1407
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '2D521';
    IF pval = 0 THEN
      RESIGNAL SQLSTATE '0a001' SET MESSAGE_TEXT = '【RESIGNAL】An 0a001 occurred';
    ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '2d521' SET MESSAGE_TEXT = '【RESIGNAL】An 2d521 occurred', MYSQL_ERRNO = 1001;
	ELSE
      RESIGNAL SQLSTATE '0k000' SET MESSAGE_TEXT = '【RESIGNAL】An 0k000 occurred', MYSQL_ERRNO = 1001;
	 END IF;
  END;
  DROP TABLE xxx;
END;
//


