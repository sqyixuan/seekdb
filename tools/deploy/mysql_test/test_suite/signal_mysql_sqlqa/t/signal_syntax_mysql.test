--echo ## 数字
--echo # 测试条件信息项：MESSAGE_TEXT
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=123456, MYSQL_ERRNO=1111;
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=1.23456, MYSQL_ERRNO=2222;
  ELSEIF pval = 2 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=1.2E+10, MYSQL_ERRNO=3333;
  ELSE
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=1234567890000, MYSQL_ERRNO=4444;
  END IF;
END;
//

