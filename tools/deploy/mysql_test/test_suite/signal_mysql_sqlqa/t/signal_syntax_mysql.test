BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '99999' SET MESSAGE_TEXT=@n1, MYSQL_ERRNO=@n2;
  END;
  SELECT id into @temp FROM  xxx;
END;
//

