--echo ###########################################################################################
--echo #### ****************标签：signal-1-1-1 ，signal-1-1-1-2			     **************** ####
--echo #### ****************功能：错误值 - 命名错误条件的名称(condition_name)**************** ####
--echo ## 命名错误条件的名称存在
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE cond1 CONDITION FOR SQLSTATE '45000';
  DECLARE cond2 CONDITION FOR SQLSTATE '99999';
  IF pval = 0 THEN
    SIGNAL cond1 SET MESSAGE_TEXT = '【SIGNAL】An cond1 occurred';
  ELSE
    SIGNAL cond2 SET MESSAGE_TEXT = '【SIGNAL】An cond2 occurred';
  END IF;
END;
//

--error 1644
CALL pro1(0)//
--error 1644
CALL pro1(2)//

--echo ## 命名错误条件的名称不存在
DROP PROCEDURE IF EXISTS pro1;//
--error 1319
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE cond1 CONDITION FOR SQLSTATE '45000';
  SIGNAL cond2 SET MESSAGE_TEXT = '【SIGNAL】An cond2 occurred';
END;
//


--echo ##############################################################################################
--echo #### ****************标签：signal-1-1-2 ，signal-1-1-2-1，signal-1-1-2-2 **************** ####
--echo #### ****************功能：信号信息项 - 条件信息项 ，信号值规范          **************** ####
--echo #### 函数参数
--echo # bug2:【signal】signal语句的信号值(simple_value_specification)由函数/存储过程参数指定，mysql设置成功，ob部分项没设置成功。
SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL, @p5=NULL, @p6=NULL, @p7=NULL, @p8=NULL, @p9=NULL, @p10=NULL;//
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (n1 VARCHAR(64),n2 VARCHAR(64),n3 VARCHAR(64),n4 VARCHAR(64),n5 VARCHAR(64),n6 VARCHAR(64),n7 VARCHAR(64),n8 VARCHAR(64),n9 VARCHAR(64),n10 VARCHAR(64),n11 VARCHAR(64),n12 SMALLINT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME=n7, TABLE_NAME=n8, COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
  RETURN '通过函数参数指定信号值';
END;
//

--error 1001
SELECT fun1('class_origin_value','iso subclass_origin_value','constraint_catalog_value','constraint_schema_value','constraint_name_value','catalog_name_value','schema_name_value','table_name_value','column_name_value','cursor_name_value','[SIGNAL] An error occurred in function',1001)//
GET DIAGNOSTICS CONDITION 1 @p1 = CLASS_ORIGIN, @p2 = SUBCLASS_ORIGIN, @p3 = CONSTRAINT_CATALOG, @p4 = CONSTRAINT_SCHEMA, @p5 = CONSTRAINT_NAME, @p6 = CATALOG_NAME, @p7 = SCHEMA_NAME, @p8 = TABLE_NAME, @p9 = COLUMN_NAME, @p10 = CURSOR_NAME, @p11 = MESSAGE_TEXT,@p12 = MYSQL_ERRNO;//
SELECT @p1 'CLASS_ORIGIN', @p2 'SUBCLASS_ORIGIN', @p3 'CONSTRAINT_CATALOG', @p4 'CONSTRAINT_SCHEMA', @p5 'CONSTRAINT_NAME', @p6 'CATALOG_NAME';//
SELECT @p7 'SCHEMA_NAME', @p8 'TABLE_NAME', @p9 'COLUMN_NAME', @p10 'CURSOR_NAME', @p11 'MESSAGE_TEXT', @p12 'MYSQL_ERRNO';//


--echo #### 存储过程参数（in/inout）
--echo ## in
SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL, @p5=NULL, @p6=NULL, @p7=NULL, @p8=NULL, @p9=NULL, @p10=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (IN n1 VARCHAR(64),IN n2 VARCHAR(64),IN n3 VARCHAR(64),IN n4 VARCHAR(64),IN n5 VARCHAR(64),IN n6 VARCHAR(64),IN n7 VARCHAR(64),IN n8 VARCHAR(64),IN n9 VARCHAR(64),IN n10 VARCHAR(64),IN n11 VARCHAR(64),IN n12 SMALLINT) DETERMINISTIC 
BEGIN  
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME=n7, TABLE_NAME=n8, COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
END;
//

--error 1002
CALL pro1('class_origin_value','iso subclass_origin_value','constraint_catalog_value','constraint_schema_value','constraint_name_value','catalog_name_value','schema_name_value','table_name_value','column_name_value','cursor_name_value','[SIGNAL] An error occurred in procedure1',1002)//
GET DIAGNOSTICS CONDITION 1 @p1 = CLASS_ORIGIN, @p2 = SUBCLASS_ORIGIN, @p3 = CONSTRAINT_CATALOG, @p4 = CONSTRAINT_SCHEMA, @p5 = CONSTRAINT_NAME, @p6 = CATALOG_NAME, @p7 = SCHEMA_NAME, @p8 = TABLE_NAME, @p9 = COLUMN_NAME, @p10 = CURSOR_NAME, @p11 = MESSAGE_TEXT,@p12 = MYSQL_ERRNO;//
SELECT @p1 'CLASS_ORIGIN', @p2 'SUBCLASS_ORIGIN', @p3 'CONSTRAINT_CATALOG', @p4 'CONSTRAINT_SCHEMA', @p5 'CONSTRAINT_NAME', @p6 'CATALOG_NAME';//
SELECT @p7 'SCHEMA_NAME', @p8 'TABLE_NAME', @p9 'COLUMN_NAME', @p10 'CURSOR_NAME', @p11 'MESSAGE_TEXT', @p12 'MYSQL_ERRNO';//

--echo ## inout
SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL, @p5=NULL, @p6=NULL, @p7=NULL, @p8=NULL, @p9=NULL, @p10=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (INOUT n1 VARCHAR(64),INOUT n2 VARCHAR(64),INOUT n3 VARCHAR(64),INOUT n4 VARCHAR(64),INOUT n5 VARCHAR(64),INOUT n6 VARCHAR(64),INOUT n7 VARCHAR(64),INOUT n8 VARCHAR(64),INOUT n9 VARCHAR(64),INOUT n10 VARCHAR(64),INOUT n11 VARCHAR(64),INOUT n12 SMALLINT) DETERMINISTIC 
BEGIN  
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME=n7, TABLE_NAME=n8, COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
END;
