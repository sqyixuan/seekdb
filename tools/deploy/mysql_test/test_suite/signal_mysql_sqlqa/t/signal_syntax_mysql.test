SET @n5 = 'CONSTRAINT_NAME_value1';//
SET @n6 = 'CATALOG_NAME_value1';//
SET @n7 = 'SCHEMA_NAME_value1';//
SET @n8 = 'TABLE_NAME_value1';//
SET @n9 = 'COLUMN_NAME_value1';//
SET @n10 ='CURSOR_NAME_value1';//
SET @n11 ='[SIGNAL] An error occurred in procedure2';//
SET @n12 =1003;//

--error 1003
