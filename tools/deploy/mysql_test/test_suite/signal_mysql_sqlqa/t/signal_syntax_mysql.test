DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN
  DECLARE n1 CHAR(64) DEFAULT 'CLASS_ORIGIN_value2';
  DECLARE n2 VARCHAR(64) DEFAULT 'SUBCLASS_ORIGIN_value2';
  DECLARE n3 BLOB DEFAULT 'CONSTRAINT_CATALOG_value2';
  DECLARE n4 TEXT DEFAULT 'CONSTRAINT_SCHEMA_value2';
  DECLARE n5 BINARY(64) DEFAULT 'CONSTRAINT_NAME_value2';
  DECLARE n6 VARBINARY(64) DEFAULT 'CATALOG_NAME_value2';
  DECLARE n7 ENUM ('enum1','enum2');
  DECLARE n8 SET('set1','set2');
  DECLARE n9 json DEFAULT '{"key":"json"}';
  DECLARE n10 TEXT DEFAULT 'CURSOR_NAME_value2';
  DECLARE n11 BINARY(64)DEFAULT '[SIGNAL] 信息项值是字符串类型';
  DECLARE n12 SMALLINT DEFAULT 9999;
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME='enum1', TABLE_NAME='set1', COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
  RETURN 'DECLARE声明的局部变量';
END;
//

