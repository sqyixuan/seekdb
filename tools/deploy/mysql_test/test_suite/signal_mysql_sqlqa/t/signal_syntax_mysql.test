CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE n1 tinyint DEFAULT 1;
  DECLARE n2 smallint DEFAULT 2;
  DECLARE n3 mediumint DEFAULT 3;
  DECLARE n4 int DEFAULT 4;
  DECLARE n5 bigint DEFAULT 5;
  DECLARE n6 float DEFAULT 6;
  DECLARE n7 double DEFAULT 7;
  DECLARE n8 decimal DEFAULT 8;
  DECLARE n9 bit DEFAULT b'1';
  DECLARE n10 tinyint DEFAULT 10;
  DECLARE n11 mediumint DEFAULT 11;
  DECLARE n12 SMALLINT DEFAULT 1005;
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME=n7, TABLE_NAME=n8, COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
END;
//

