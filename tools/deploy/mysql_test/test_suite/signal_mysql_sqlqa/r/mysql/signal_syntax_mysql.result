CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN
  DECLARE n11 BINARY(64)DEFAULT '[SIGNAL] An error occurred in function3';
  DECLARE n12 datetime DEFAULT '2022-02-25 12:00:00';
  SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
  RETURN 'DECLARE声明的局部变量,MYSQL_ERRNO 日期时间类型';
END;
//
SELECT fun1()//
