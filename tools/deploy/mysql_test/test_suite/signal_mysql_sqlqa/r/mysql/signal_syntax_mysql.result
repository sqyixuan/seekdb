#### 用户定义的变量
# bug11:【signal/resignal】在PL中使用signal/resignal语句,使用用户自定义变量修改错误信息（MESSAGE_TEXT/MYSQL_ERRNO），mysql成功，ob失败。
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '99999' SET MESSAGE_TEXT=@n1, MYSQL_ERRNO=@n2;
  END;
  SELECT id into @temp FROM  xxx;
  RETURN '用户定义的变量修改错误信息';
END;
//
SET @n1 ='[SIGNAL] An error occurred in function';//
SET @n2 =1111;//
SELECT fun1()//
ERROR 99999: [SIGNAL] An error occurred in function
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '99999' SET MESSAGE_TEXT=@n1, MYSQL_ERRNO=@n2;
  END;
  SELECT id into @temp FROM  xxx;
END;
//
SET @n1 ='[SIGNAL] An error occurred in procedure';//
SET @n2 =2222;//
CALL pro1()//
ERROR 99999: [SIGNAL] An error occurred in procedure
#### 函数返回值
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS INT
BEGIN
  RETURN 5555;
END;
//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = fun1;
  END;
  SELECT a INTO @p FROM notable;
END;
//
CALL pro1();//
ERROR 45000: 【SIGNAL】An error occurred
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200)
BEGIN
  RETURN '【SIGNAL】An error occurred';
END;
//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = fun1, MYSQL_ERRNO = 5555;
  END;
  SELECT a INTO @p FROM notable;
END;
//
CALL pro1();//
