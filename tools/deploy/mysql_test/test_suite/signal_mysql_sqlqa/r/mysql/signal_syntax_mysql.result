BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=FALSE, MYSQL_ERRNO = 9999;
  ELSE
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=TRUE, MYSQL_ERRNO = 9999;
  END IF;
END;
