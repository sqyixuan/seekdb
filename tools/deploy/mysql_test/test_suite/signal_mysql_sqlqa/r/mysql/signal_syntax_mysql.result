## null
# bug4:【signal/resignal】在PL中使用signal/resignal语句，将错误信息（MESSAGE_TEXT）赋值为null，mysql失败，ob成功。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '45000' SET  MESSAGE_TEXT=null, MYSQL_ERRNO=9999;
  ELSE
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT='[SIGNAL]MYSQL_ERRNO为null', MYSQL_ERRNO=null;
  END IF;	
END;
//
CALL pro1(0)//
ERROR 42000: Variable 'MESSAGE_TEXT' can't be set to the value of 'NULL'
CALL pro1(1)//
ERROR 42000: Variable 'MYSQL_ERRNO' can't be set to the value of 'NULL'
