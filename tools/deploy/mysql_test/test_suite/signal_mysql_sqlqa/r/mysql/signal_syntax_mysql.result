###########################################################################################
#### ****************标签：signal-1-1-1 ，signal-1-1-1-2			     **************** ####
#### ****************功能：错误值 - 命名错误条件的名称(condition_name)**************** ####
## 命名错误条件的名称存在
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE cond1 CONDITION FOR SQLSTATE '45000';
  DECLARE cond2 CONDITION FOR SQLSTATE '99999';
  IF pval = 0 THEN
    SIGNAL cond1 SET MESSAGE_TEXT = '【SIGNAL】An cond1 occurred';
  ELSE
    SIGNAL cond2 SET MESSAGE_TEXT = '【SIGNAL】An cond2 occurred';
  END IF;
END;
//
CALL pro1(0)//
ERROR 45000: 【SIGNAL】An cond1 occurred
CALL pro1(2)//
ERROR 99999: 【SIGNAL】An cond2 occurred
## 命名错误条件的名称不存在
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE cond1 CONDITION FOR SQLSTATE '45000';
  SIGNAL cond2 SET MESSAGE_TEXT = '【SIGNAL】An cond2 occurred';
END;
//
ERROR 42000: Undefined CONDITION: cond2
##############################################################################################
#### ****************标签：signal-1-1-2 ，signal-1-1-2-1，signal-1-1-2-2 **************** ####
#### ****************功能：信号信息项 - 条件信息项 ，信号值规范          **************** ####
#### 函数参数
# bug2:【signal】signal语句的信号值(simple_value_specification)由函数/存储过程参数指定，mysql设置成功，ob部分项没设置成功。
SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL, @p5=NULL, @p6=NULL, @p7=NULL, @p8=NULL, @p9=NULL, @p10=NULL;//
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (n1 VARCHAR(64),n2 VARCHAR(64),n3 VARCHAR(64),n4 VARCHAR(64),n5 VARCHAR(64),n6 VARCHAR(64),n7 VARCHAR(64),n8 VARCHAR(64),n9 VARCHAR(64),n10 VARCHAR(64),n11 VARCHAR(64),n12 SMALLINT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=n1, SUBCLASS_ORIGIN=n2, CONSTRAINT_CATALOG=n3, CONSTRAINT_SCHEMA=n4, CONSTRAINT_NAME=n5, CATALOG_NAME=n6, SCHEMA_NAME=n7, TABLE_NAME=n8, COLUMN_NAME=n9, CURSOR_NAME=n10, MESSAGE_TEXT=n11, MYSQL_ERRNO=n12;
  RETURN '通过函数参数指定信号值';
END;
//
SELECT fun1('class_origin_value','iso subclass_origin_value','constraint_catalog_value','constraint_schema_value','constraint_name_value','catalog_name_value','schema_name_value','table_name_value','column_name_value','cursor_name_value','[SIGNAL] An error occurred in function',1001)//
ERROR 45000: [SIGNAL] An error occurred in function
