purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
###### 标签：signal-1,signal-1-1 基本语法 - SIGNAL 语句
-----------------------------------------------------------------------------------------------------------------
#########################################################################################
#### ****************标签：signal-1-1-1 ，signal-1-1-1-1			   **************** ####
#### ****************功能：错误值 - SQLSTATE值(5 个字符的字符串文字)**************** ####
#### 函数参数
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (sqlstate_value VARCHAR(64)) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE sqlstate_value SET  MESSAGE_TEXT='【SIGNAL】通过函数参数指定SQLSTATE值', MYSQL_ERRNO=9999;
  RETURN '通过函数参数指定SQLSTATE值';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'sqlstate_value' at line 3
#### 存储过程参数
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (sqlstate_value VARCHAR(64))
BEGIN 
  SIGNAL SQLSTATE sqlstate_value SET  MESSAGE_TEXT='【SIGNAL】通过存储过程参数指定SQLSTATE值', MYSQL_ERRNO=9999;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'sqlstate_value' at line 3
#### 系统变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN 
  SIGNAL SQLSTATE @@wait_timeout SET  MESSAGE_TEXT='【SIGNAL】通过系统变量指定SQLSTATE值', MYSQL_ERRNO=9999;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '@@wait_timeout' at line 3
#### 用户定义的变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN 
  SIGNAL SQLSTATE @val SET  MESSAGE_TEXT='【SIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '@val' at line 3
#### DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE val VARCHAR(64) DEFAULT '45000';
  SIGNAL SQLSTATE val SET  MESSAGE_TEXT='【SIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'val' at line 4
#### 字面量
#### ①5 个字符的字符串文字
## '00xxx'（成功）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '00111' SET MESSAGE_TEXT = '【SIGNAL】An 00xxx occurred';
  END IF;
END;
//
ERROR 42000: Bad SQLSTATE: '00111'
## '01xxx'（警告）
# bug1:【signal】SQLSTATE值‘01xxx’的signal语句发出警告信息，show warnings查看警告信息，mysql可以查看，ob中查看结果空。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '01000';
  END IF;
END;
//
CALL pro1(0)//
Warnings:
Warning	1642	Unhandled user-defined exception condition
SHOW warnings;//
Level	Code	Message
Warning	1642	Unhandled user-defined exception condition
## '02xxx'（未找到）, >'02xxx'（例外）- 全是数字的SQLSTATE值'03000'、'45000'、'99999'……
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '02111' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
  ELSEIF pval = 2 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【SIGNAL】An 45000 occurred';
  ELSEIF pval = 3 THEN
    SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An error occurred';
  ELSE
    SIGNAL SQLSTATE '99999' SET MESSAGE_TEXT = '【SIGNAL】An 99999 occurred', MYSQL_ERRNO = 1001;
  END IF;
END;
//
CALL pro1(0)//
ERROR 02111: 【SIGNAL】An 02xxx occurred
CALL pro1(1)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
CALL pro1(2)//
ERROR 45000: 【SIGNAL】An 45000 occurred
CALL pro1(3)//
ERROR 45000: 【SIGNAL】An error occurred
CALL pro1(4)//
ERROR 99999: 【SIGNAL】An 99999 occurred
## >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 大写字母场合
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '2D521';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '0A001' SET MESSAGE_TEXT = '【SIGNAL】An 0A001 occurred';
  ELSEIF pval = 1 THEN
    SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An 2D521 occurred';
  ELSE
    SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【SIGNAL】A warning occurred', MYSQL_ERRNO = 1000;
    SIGNAL SQLSTATE '0K000' SET MESSAGE_TEXT = '【SIGNAL】An 0K000 occurred', MYSQL_ERRNO = 1001;
  END IF;
END;
//
CALL pro1(0)//
ERROR 0A001: 【SIGNAL】An 0A001 occurred
CALL pro1(1)//
ERROR 2D521: 【SIGNAL】An 2D521 occurred
CALL pro1(2)//
ERROR 0K000: 【SIGNAL】An 0K000 occurred
##  >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 小写字母场合
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  IF pval = 0 THEN
    SIGNAL SQLSTATE '0a001' SET MESSAGE_TEXT = '【SIGNAL】An 0a001 occurred';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '2d521' SET MESSAGE_TEXT = '【SIGNAL】An 2d521 occurred', MYSQL_ERRNO = 1001;
  ELSE
    SIGNAL SQLSTATE '0k000' SET MESSAGE_TEXT = '【SIGNAL】An 0k000 occurred', MYSQL_ERRNO = 1001;
  END IF;
END;
//
ERROR 42000: Bad SQLSTATE: '0a001'
