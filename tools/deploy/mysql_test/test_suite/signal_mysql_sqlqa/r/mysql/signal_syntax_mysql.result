CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN
  SIGNAL SQLSTATE '45000' SET CLASS_ORIGIN=@@character_set_system, SUBCLASS_ORIGIN=@@character_set_system, CONSTRAINT_CATALOG=@@character_set_system, CONSTRAINT_SCHEMA=@@character_set_system, CONSTRAINT_NAME=@@character_set_system, CATALOG_NAME=@@character_set_system, SCHEMA_NAME=@@character_set_system, TABLE_NAME=@@character_set_system, COLUMN_NAME=@@character_set_system, CURSOR_NAME=@@character_set_system, MESSAGE_TEXT=@@character_set_system, MYSQL_ERRNO=@@wait_timeout;
  RETURN '系统变量';
END;
