purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


#### 测试前表准备
DROP TABLE signal_table1;//
CREATE TABLE signal_table1( 
  c1 int, 
  c2 VARCHAR(200),
  c3 VARCHAR(200)
);//
INSERT INTO signal_table1 VALUES(1,'mysql','5.6');//
INSERT INTO signal_table1 VALUES(2,'oracle','--');//
INSERT INTO signal_table1 VALUES(3,'ob','master');//
DROP TABLE signal_table2;//
CREATE TABLE signal_table2( 
  id int primary key auto_increment,
  message varchar(200),
  errno varchar(200)
);//
-----------------------------------------------------------------------------------------------------------------
------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
###### 标签：signal-2 使用场景
-----------------------------------------------------------------------------------------------------------------
######################### 标签:signal-2-1 使用场景 - 函数  #########################
#### 无参数 （SIGNAL 语句）
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred', MYSQL_ERRNO = 1111;
  RETURN '场景：函数 - SIGNAL 语句使用';
END;
//
SELECT fun1()//
ERROR 03000: 【SIGNAL】An 03xxx occurred
#### 无参数 （RESIGNAL 语句）
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
 DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN  
    RESIGNAL SQLSTATE '04000' SET MESSAGE_TEXT = '【RESIGNAL】An 04xxx occurred', MYSQL_ERRNO = 2222;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '场景：函数 - RESIGNAL 语句使用';
END;
//
SELECT fun1()//
ERROR 04000: 【RESIGNAL】An 04xxx occurred
#### 有参数 （SIGNAL 语句）
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '02000';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
  ELSE    
    SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 3333;
  END IF;
  RETURN '场景：函数 - SIGNAL 语句使用';
END;
//
SELECT fun1(0)//
ERROR 02000: Unhandled user-defined not found condition
SELECT fun1(1)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
SELECT fun1(2)//
ERROR 45000: 【SIGNAL】An error occurred
#### 有参数 （RESIGNAL 语句）
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '45000';
    IF pval = 0 THEN
      RESIGNAL;
    ELSEIF pval = 1 THEN
      RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
	ELSEIF pval = 2 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 5555;
    ELSE    
      RESIGNAL SQLSTATE '55000' SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
    END IF;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '场景：函数 - RESIGNAL 语句使用';
END;
//
SELECT fun1(0)//
ERROR 42S02: Table 'test.notable' doesn't exist
SELECT fun1(1)//
ERROR 42S02: 【RESIGNAL】An error occurred
SELECT fun1(2)//
ERROR 45000: 【RESIGNAL】An error occurred
SELECT fun1(3)//
ERROR 55000: 【RESIGNAL】An error occurred
######################### 标签:signal-2-2 使用场景 - 事件  #########################
#### SIGNAL 语句
SET @p1=NULL, @p2=NULL;//
DROP EVENT IF EXISTS e_totals;//
CREATE EVENT e_totals ON SCHEDULE AT CURRENT_TIMESTAMP + INTERVAL 1 MINUTE 
DO 
BEGIN
  SIGNAL SQLSTATE '07000' SET MESSAGE_TEXT = '【SIGNAL】An 07xxx occurred', MYSQL_ERRNO = 7777;
  GET DIAGNOSTICS CONDITION 1 @p1 = MESSAGE_TEXT, @p2 = MYSQL_ERRNO;
  INSERT INTO signal_table2 VALUES(1,@p1,@p2);
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'SIGNAL' at line 4
SELECT * FROM signal_table2 ORDER BY id;//
+----+---------+-------+
| id | message | errno |
+----+---------+-------+
+----+---------+-------+
#### RESIGNAL 语句
SET @p1=NULL, @p2=NULL;//
DROP EVENT IF EXISTS e_totals;//
CREATE EVENT e_totals ON SCHEDULE AT CURRENT_TIMESTAMP + INTERVAL 1 MINUTE 
DO 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN  
    RESIGNAL SQLSTATE '08000' SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 8888;
    GET DIAGNOSTICS CONDITION 1 @p1 = MESSAGE_TEXT, @p2 = MYSQL_ERRNO;
    INSERT INTO signal_table2 VALUES(2,@p1,@p2);
  END;
  SELECT a INTO @p FROM notable;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'DECLARE' at line 4
SELECT * FROM signal_table2 ORDER BY id;//
+----+---------+-------+
| id | message | errno |
+----+---------+-------+
+----+---------+-------+
######################### 标签:signal-2-3 使用场景 - 触发器  #########################
#### SIGNAL 语句
SET @p1=NULL, @p2=NULL;//
DROP TRIGGER IF EXISTS tri1;//
Warnings:
Note	1360	Trigger does not exist
CREATE TRIGGER tri1 BEFORE INSERT 
ON signal_table1 FOR EACH ROW
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '09000' SET MESSAGE_TEXT = '【SIGNAL】An 09xxx occurred', MYSQL_ERRNO = 9999;
  END;  
  SELECT id into @p FROM no_such_table2;
END;
//
INSERT INTO signal_table1 VALUES(4,'oceanbase','4.0.0');//
ERROR 09000: 【SIGNAL】An 09xxx occurred
#### RESIGNAL 语句
SET @p1=NULL, @p2=NULL;//
DROP TRIGGER IF EXISTS tri1;//
CREATE TRIGGER tri1 BEFORE INSERT 
ON signal_table1 FOR EACH ROW
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【RESIGNAL】An 02xxx occurred', MYSQL_ERRNO = 1111;
  END;  
  SELECT id into @p FROM no_such_table2;
END;
//
INSERT INTO signal_table1 VALUES(5,'test','RESIGNAL');//
ERROR 02000: 【RESIGNAL】An 02xxx occurred
######################### 标签:signal-2-4 使用场景 - mysql客户端程序  #########################
#### SIGNAL 语句
SIGNAL SQLSTATE '02000'//
ERROR 02000: Unhandled user-defined not found condition
SIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【SIGNAL】An 02xxx occurred', MYSQL_ERRNO = 2222//
ERROR 02000: 【SIGNAL】An 02xxx occurred
#### RESIGNAL 语句
RESIGNAL//
ERROR 0K000: RESIGNAL when handler not active
RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 1111//
ERROR 0K000: RESIGNAL when handler not active
RESIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【RESIGNAL】An 02xxx occurred', MYSQL_ERRNO = 1111//
ERROR 0K000: RESIGNAL when handler not active
######################### 标签:signal-2-5 使用场景 - 存储过程  #########################
#### 无参数 （SIGNAL 语句）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred', MYSQL_ERRNO = 3333;
END;
//
CALL pro1()//
ERROR 03000: 【SIGNAL】An 03xxx occurred
#### 无参数 （RESIGNAL 语句）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '04000' SET MESSAGE_TEXT = '【RESIGNAL】An 04xxx occurred', MYSQL_ERRNO = 4444;
  END;  
  SELECT id into @p FROM no_such_table2;
END;
//
CALL pro1()//
ERROR 04000: 【RESIGNAL】An 04xxx occurred
#### 有参数(in/inout/out) （SIGNAL 语句）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (IN pval INT,INOUT mess varchar(200),out errno INT)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '02000';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
  ELSE
    SET mess = '【SIGNAL】An 45000 occurred';
	SET errno = 5555;
    SIGNAL specialty SET MESSAGE_TEXT = mess, MYSQL_ERRNO = errno;
  END IF;
END;
//
SET @mess = null;//
SET @errno = null;//
CALL pro1(0,@mess,@errno)//
ERROR 02000: Unhandled user-defined not found condition
CALL pro1(1,@mess,@errno)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
CALL pro1(2,@mess,@errno)//
ERROR 45000: 【SIGNAL】An 45000 occurred
SELECT @mess,@errno;//
+-------+--------+
| @mess | @errno |
+-------+--------+
| NULL  | NULL   |
+-------+--------+
#### 有参数(in/inout/out) （RESIGNAL 语句）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (IN pval INT,INOUT mess varchar(200),out errno INT)
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '45000';
    IF pval = 0 THEN
      RESIGNAL;
    ELSEIF pval = 1 THEN
      RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An 03xxx occurred';
    ELSE
      SET mess = '【RESIGNAL】An 45000 occurred';
      SET errno = 5555;
      RESIGNAL specialty SET MESSAGE_TEXT = mess, MYSQL_ERRNO = errno;
    END IF;
  END;  
  SELECT id into @p FROM no_such_table2;
END;
//
SET @mess = null;//
SET @errno = null;//
CALL pro1(0,@mess,@errno)//
ERROR 42S02: Table 'test.no_such_table2' doesn't exist
CALL pro1(1,@mess,@errno)//
ERROR 42S02: 【RESIGNAL】An 03xxx occurred
CALL pro1(2,@mess,@errno)//
ERROR 45000: 【RESIGNAL】An 45000 occurred
SELECT @mess,@errno;//
+-------+--------+
| @mess | @errno |
+-------+--------+
| NULL  | NULL   |
+-------+--------+
