------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
###### 标签：signal-3 测试点
-----------------------------------------------------------------------------------------------------------------
######################### 标签:signal-3-1 SIGNAL 语句 - 场景  #########################
#### 无命名错误条件
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  IF pval = 0 THEN
    SIGNAL SQLSTATE '02000';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
  END IF;
  RETURN '场景：无命名错误条件';
END;
//
SELECT fun1(0)//
ERROR 02000: Unhandled user-defined not found condition
SELECT fun1(1)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
#### 声明一个命名错误条件
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 3333;
END;
//
CALL pro1()//
ERROR 45000: 【SIGNAL】An error occurred
#### 不同范围内声明多个命名错误条件
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (divisor INT)
BEGIN
  DECLARE my_error CONDITION FOR SQLSTATE '45000';
  IF divisor = 0 THEN
    BEGIN
      DECLARE my_error CONDITION FOR SQLSTATE '22012';
	  BEGIN
	    DECLARE my_error CONDITION FOR SQLSTATE '11111';
	    SIGNAL my_error;
	  END;
      SIGNAL my_error;
    END;
  END IF;
  SIGNAL my_error;
END;
//
CALL pro1(0)//
ERROR 11111: Unhandled user-defined exception condition
CALL pro1(1)//
ERROR 45000: Unhandled user-defined exception condition
#### 条件处理程序中
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (IN pval INT)
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '45000';
    IF pval = 0 THEN
      SIGNAL SQLSTATE '02000';
    ELSEIF pval = 1 THEN
      SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
    ELSE
      SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 3333;
    END IF;
  END;
  SELECT id into @p FROM no_such_table2;
END;
//
CALL pro1(0)//
ERROR 02000: Unhandled user-defined not found condition
CALL pro1(1)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
CALL pro1(2)//
ERROR 45000: 【SIGNAL】An error occurred
#### 条件处理程序上下文之外
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '02000';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred';
  ELSE    
    SIGNAL specialty SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 3333;
  END IF;
  RETURN '场景：条件处理程序上下文之外';
END;
//
SELECT fun1(0)//
ERROR 02000: Unhandled user-defined not found condition
SELECT fun1(1)//
ERROR 03000: 【SIGNAL】An 03xxx occurred
SELECT fun1(2)//
ERROR 45000: 【SIGNAL】An error occurred
######################### 标签:signal-3-2 RESIGNAL 语句 - 场景  #########################
#### 无命名错误条件
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL;
    ELSEIF pval = 1 THEN
      RESIGNAL SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
    ELSE    
      RESIGNAL SQLSTATE '55000' SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
    END IF;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '场景：无命名错误条件';
END;
//
SELECT fun1(0)//
ERROR 42S02: Table 'test.notable' doesn't exist
SELECT fun1(1)//
ERROR 42S02: 【RESIGNAL】An error occurred
SELECT fun1(2)//
ERROR 55000: 【RESIGNAL】An error occurred
#### 声明一个命名错误条件
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '45000';
    RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '场景：声明一个命名错误条件';
END;
//
SELECT fun1()//
ERROR 45000: 【RESIGNAL】An error occurred
#### 不同范围内声明多个命名错误条件,条件处理程序中
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (divisor INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE my_error CONDITION FOR SQLSTATE '33333';
    IF divisor = 0 THEN
      BEGIN
        DECLARE my_error CONDITION FOR SQLSTATE '22222';
	    BEGIN
	      DECLARE my_error CONDITION FOR SQLSTATE '11111';
	      RESIGNAL my_error SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 7777;
	    END;
        SIGNAL my_error;
      END;
    END IF;
    SIGNAL my_error;
  END;
  SELECT a INTO @p FROM notable;
END;
//
CALL pro1(0)//
ERROR 11111: 【RESIGNAL】An error occurred
CALL pro1(1)//
ERROR 33333: Unhandled user-defined exception condition
#### 条件处理程序中-在条件处理程序中
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 7777;
  END;
  SELECT a INTO @p FROM notable;
END;
//
CALL pro1()//
ERROR 45000: 【RESIGNAL】An error occurred
#### 条件处理程序中-嵌套在条件处理程序中
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS INT
BEGIN
  RESIGNAL;
  RETURN 5;
END;
//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION SET @a=fun1();
  SIGNAL SQLSTATE '55555';
END;
//
CALL pro1();//
ERROR 0K000: RESIGNAL when handler not active
-----------------------------------------------------------------------------------------------------------------
------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
###### 标签：signal-4 异常场景
-----------------------------------------------------------------------------------------------------------------
######################### 标签:signal-4-1 SIGNAL 语句  #########################
#### 单独执行SIGNAL；（忽略所有属性或SQLSTATE值）
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL;
  RETURN '单独执行SIGNAL';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ';' at line 3
#### 条件信息项(condition_information_item_name)在SET子句中指定多次
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An error occurred',MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred', MYSQL_ERRNO = 1111;
  RETURN '在SET子句中指定多次';
END;
//
ERROR 42000: Duplicate condition information item 'MESSAGE_TEXT'
#### 条件信息项(signal_information_item)在赋值列表中，用逗号以外符号分隔
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  SIGNAL SQLSTATE '03000' SET MESSAGE_TEXT = '【SIGNAL】An 03xxx occurred'、 MYSQL_ERRNO = 1111;
  RETURN '在SET子句中用逗号以外符号分隔';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '、' at line 3
#### SIGNAL语句使用命名错误条件，命名条件不在同一作用域范围内
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (divisor INT)
BEGIN
  BEGIN
    DECLARE my_error CONDITION FOR SQLSTATE '45000';
	SIGNAL my_error SET MESSAGE_TEXT = '【SIGNAL】An error occurred',MYSQL_ERRNO = 1111;
  END;
  IF divisor = 0 THEN
    BEGIN
      SIGNAL my_error;
    END;
  END IF;
END;
//
ERROR 42000: Undefined CONDITION: my_error
#### SIGNAL语句使用命名错误条件名称，命名条件使用 MySQL 错误号（不是SQLSTATE值）进行定义
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE my_error CONDITION FOR 1051;
  SIGNAL my_error SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 1111;
END;
//
ERROR HY000: SIGNAL/RESIGNAL can only use a CONDITION defined with SQLSTATE
#### SIGNAL语句错误值(condition_value)使用 MySQL 错误号
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  SIGNAL 1051 SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 1111;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '1051' at line 3
#### SIGNAL语句错误值(condition_value)使用无效的SQLSTATE值
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  SIGNAL SQLSTATE '00000' SET MESSAGE_TEXT = '【SIGNAL】An error occurred', MYSQL_ERRNO = 1111;
END;
//
ERROR 42000: Bad SQLSTATE: '00000'
######################### 标签:signal-4-2 RESIGNAL 语句  #########################
#### 条件信息项(condition_information_item_name)在SET子句中指定多次
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL  SQLSTATE '45000'  SET MESSAGE_TEXT = '【RESIGNAL】',MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '在SET子句中指定多次';
END;
//
ERROR 42000: Duplicate condition information item 'MESSAGE_TEXT'
#### 条件信息项(signal_information_item)在赋值列表中，用逗号以外符号分隔
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL  SQLSTATE '45000'  SET MESSAGE_TEXT = '【RESIGNAL】An error occurred': MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '在SET子句中指定多次';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ':' at line 5
#### RESIGNAL语句在条件处理程序上下文之外执行
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 1111;
END;
//
CALL pro1();//
ERROR 0K000: RESIGNAL when handler not active
#### RESIGNAL语句使用命名错误条件名称，命名条件不在同一作用域范围内
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (divisor INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    BEGIN
      DECLARE my_error CONDITION FOR SQLSTATE '45000';
    END;
    RESIGNAL my_error SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
END;
//
ERROR 42000: Undefined CONDITION: my_error
#### RESIGNAL语句使用命名错误条件名称，命名条件使用 MySQL 错误号（不是SQLSTATE值）进行定义
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE my_error CONDITION FOR 1051;
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL my_error SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '命名条件使用 MySQL 错误号';
END;
//
ERROR HY000: SIGNAL/RESIGNAL can only use a CONDITION defined with SQLSTATE
#### RESIGNAL语句错误值(condition_value)使用MySQL 错误号
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL 1501 SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '错误值(condition_value)使用MySQL 错误号';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '1501' at line 5
#### RESIGNAL语句错误值(condition_value)使用无效的SQLSTATE值
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 () RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '00000'  SET MESSAGE_TEXT = '【RESIGNAL】An error occurred', MYSQL_ERRNO = 6666;
  END;
  SELECT a INTO @p FROM notable;
  RETURN '无效的SQLSTATE值';
END;
//
ERROR 42000: Bad SQLSTATE: '00000'
