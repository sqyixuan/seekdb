BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN    
      RESIGNAL SQLSTATE '02000' SET MESSAGE_TEXT = '【RESIGNAL】An 02000 occurred', MYSQL_ERRNO = 9999;
    ELSE
      RESIGNAL SQLSTATE "03000" SET MESSAGE_TEXT = '【RESIGNAL】An 03000 occurred', MYSQL_ERRNO = 9999;
    END IF;
  END;
  DROP TABLE xxx;
END;
//
CALL pro1(0)//
ERROR 02000: 【RESIGNAL】An 02000 occurred
CALL pro1(1)//
ERROR 03000: 【RESIGNAL】An 03000 occurred
