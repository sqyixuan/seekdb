purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- SIGNAL/RESIGNAL 语句 ------------------------------------------------------------------
###### 标签：signal-1,resignal-1-1 基本语法 - RESIGNAL 语句
-----------------------------------------------------------------------------------------------------------------
#########################################################################################
#### **************** 标签：resignal-1-1-1 ，resignal-1-1-1-1          ************* ####
#### **************** 功能：错误值 - SQLSTATE值(5 个字符的字符串文字)     ********** ####
#### 函数参数
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (sqlstate_value VARCHAR(64)) RETURNS varchar(200) DETERMINISTIC 
BEGIN 
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE sqlstate_value SET MESSAGE_TEXT='【RESIGNAL】通过函数参数指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  SELECT a INTO @p FROM notable; 
  RETURN '通过函数参数指定SQLSTATE值';
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'sqlstate_value' at line 6
#### 存储过程参数（in/inout）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (sqlstate_value VARCHAR(64))
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE sqlstate_value SET  MESSAGE_TEXT='【RESIGNAL】通过存储过程参数指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'sqlstate_value' at line 6
#### 系统变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE @@wait_timeout SET  MESSAGE_TEXT='【RESIGNAL】通过系统变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '@@wait_timeout' at line 6
#### 用户定义的变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE @val SET  MESSAGE_TEXT='【RESIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx; 
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '@val' at line 6
#### DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE val VARCHAR(64) DEFAULT '45000';
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE val SET  MESSAGE_TEXT='【RESIGNAL】通过用户定义的变量指定SQLSTATE值', MYSQL_ERRNO=9999;
	END IF;
  END;
  DROP TABLE xxx;
END;
//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'val' at line 7
#### 字面量
#### ①5 个字符的字符串文字
## '00xxx'（成功）
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF @a = 0 THEN 
	  RESIGNAL SQLSTATE '00111' SET MESSAGE_TEXT = '【RESIGNAL】An 00xxx occurred';
	END IF;
  END;
  DROP TABLE xxx;
END;
//
ERROR 42000: Bad SQLSTATE: '00111'
## '01xxx'（警告）
# bug9:【resignal】带有条件值和可选新信号信息的 resignal语句，条件区域数，mysql与ob不一致。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	RESIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【RESIGNAL】An 01xxx occurred';
	GET DIAGNOSTICS @num = NUMBER;
	SELECT @num 'NUMBER';
  END;
  DROP TABLE xxx;
END;
//
CALL pro1();//
+--------+
| NUMBER |
+--------+
|      2 |
+--------+
SHOW warnings;//
Level	Code	Message
## '02xxx'（未找到）, >'02xxx'（例外）- 全是数字的SQLSTATE值'03000'、'45000'、'99999'……
# bug10:【resignal】在PL中使用resignal语句，下列格式修改SQLSTATE值，mysql成功，ob修改失效。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
	DECLARE specialty CONDITION FOR SQLSTATE '45000';
	IF pval = 0 THEN
      RESIGNAL;
	ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '03000';
	ELSEIF pval = 2 THEN
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '【RESIGNAL】An 45000 occurred';
	ELSEIF pval = 3 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An error occurred';
	ELSE
      RESIGNAL SQLSTATE '99999' SET MESSAGE_TEXT = '【RESIGNAL】An 99999 occurred', MYSQL_ERRNO = 1001;
	END IF;    
  END;
  DROP TABLE xxx;
END;
//
CALL pro1(0)//
ERROR 42S02: Unknown table 'test.xxx'
CALL pro1(1)//
ERROR 03000: Unknown table 'test.xxx'
CALL pro1(2)//
ERROR 45000: 【RESIGNAL】An 45000 occurred
CALL pro1(3)//
ERROR 45000: 【RESIGNAL】An error occurred
CALL pro1(4)//
ERROR 99999: 【RESIGNAL】An 99999 occurred
## >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 大写字母场合
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '2D521';
    IF pval = 0 THEN
      RESIGNAL SQLSTATE '0A001' SET MESSAGE_TEXT = '【RESIGNAL】An 0A001 occurred', MYSQL_ERRNO = 9999;
    ELSEIF pval = 1 THEN
      RESIGNAL specialty SET MESSAGE_TEXT = '【RESIGNAL】An 2D521 occurred', MYSQL_ERRNO = 9999;
	ELSE
      RESIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = '【RESIGNAL】A warning occurred', MYSQL_ERRNO = 1000;
      RESIGNAL SQLSTATE '0K000' SET MESSAGE_TEXT = '【RESIGNAL】An 0K000 occurred', MYSQL_ERRNO = 1002;
	END IF;
  END;
  DROP TABLE xxx;
END;
//
CALL pro1(0)//
ERROR 0A001: 【RESIGNAL】An 0A001 occurred
CALL pro1(1)//
ERROR 2D521: 【RESIGNAL】An 2D521 occurred
CALL pro1(2)//
ERROR 0K000: 【RESIGNAL】An 0K000 occurred
##  >'02xxx'（例外）- 含字母的SQLSTATE值('0Axxx'、'0Dxxx'、'0Kxxx'……) - 小写字母场合
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (pval INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE specialty CONDITION FOR SQLSTATE '2D521';
    IF pval = 0 THEN
      RESIGNAL SQLSTATE '0a001' SET MESSAGE_TEXT = '【RESIGNAL】An 0a001 occurred';
    ELSEIF pval = 1 THEN
      RESIGNAL SQLSTATE '2d521' SET MESSAGE_TEXT = '【RESIGNAL】An 2d521 occurred', MYSQL_ERRNO = 1001;
	ELSE
      RESIGNAL SQLSTATE '0k000' SET MESSAGE_TEXT = '【RESIGNAL】An 0k000 occurred', MYSQL_ERRNO = 1001;
	 END IF;
  END;
  DROP TABLE xxx;
END;
//
ERROR 42000: Bad SQLSTATE: '0a001'
##  >'02xxx'（例外）- 含制表符'02	000'
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '02	000' SET MESSAGE_TEXT = '【SIGNAL】An 02	000 occurred', MYSQL_ERRNO = 1001;
  END;
  DROP TABLE xxx;
END;
//
ERROR 42000: Bad SQLSTATE: '02	000'
## >'02xxx'（例外）- 含特殊字符（！@#￥%^&*（）_+-=：;) 如'02&*#'
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    RESIGNAL SQLSTATE '￥%&*#' SET MESSAGE_TEXT = '【SIGNAL】An 02&*# occurred';
  END;
  DROP TABLE xxx;
END;
//
ERROR 42000: Bad SQLSTATE: '￥%&*#'
## >'02xxx'（例外）- 字符串加单引号，双引号
