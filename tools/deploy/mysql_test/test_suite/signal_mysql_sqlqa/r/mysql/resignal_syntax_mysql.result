CREATE PROCEDURE pro1 (IN pval INT,IN n1 VARCHAR(64),IN n2 SMALLINT) 
BEGIN  
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    END IF;
  END;
  SELECT id into @temp FROM  xxx;
END;
//
CALL pro1(1,'[RESIGNAL] An error occurred in procedure',1111)//
ERROR 45000: [RESIGNAL] An error occurred in procedure
CALL pro1(2,'[RESIGNAL] An error occurred in procedure',2222)//
ERROR 45000: [RESIGNAL] An error occurred in procedure
## inout
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (IN pval INT,INOUT n1 VARCHAR(64),INOUT n2 SMALLINT) 
BEGIN  
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    END IF;
  END;
  SELECT id into @temp FROM  xxx;
END;
