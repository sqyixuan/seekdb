##############################################################################################
#### ****************标签：resignal-1-1-2 ，resignal-1-1-2-1，resignal-1-1-2-2 ********** ####
#### ****************功能：信号信息项 - 条件信息项 ，信号值规范          **************** ####
#### 函数参数
DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (pval INT,n1 VARCHAR(64),n2 SMALLINT) RETURNS varchar(200) DETERMINISTIC 
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    IF pval = 0 THEN
      RESIGNAL SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    ELSE
      RESIGNAL SQLSTATE '45000' SET MESSAGE_TEXT=n1, MYSQL_ERRNO=n2;
    END IF;
  END;
  SELECT id into @temp FROM  xxx;
  RETURN '通过函数参数指定信号值';
END;
//
SELECT fun1(1,'[RESIGNAL] An error occurred in function',1111)//
ERROR 45000: [RESIGNAL] An error occurred in function
SELECT fun1(2,'[RESIGNAL] An error occurred in function',2222)//
ERROR 45000: [RESIGNAL] An error occurred in function
#### 存储过程参数（in/inout）
## in
