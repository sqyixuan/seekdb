insert into stu values(6,'北京','中国');
insert into stu values(7,'首尔','韩国');
insert into stu values(8,'朝阳区','北京');
create index stu_parent on stu(parent);
with stu1 as (
select level, t.* from (
select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with upper(t.parent) in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle upper(t.parent) = prior upper(t.child) order siblings by t.s1,t.child
) t
start with abs(t.lev) = 1
connect by nocycle prior upper(t.child) = upper(t.parent) order siblings by t.child, t.parent
) select * from stu1;
