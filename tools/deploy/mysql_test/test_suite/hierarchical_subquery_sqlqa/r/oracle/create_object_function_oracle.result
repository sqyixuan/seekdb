select * from stu1 where s1 not in (
select t.s1 from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent < 50)
connect by nocycle t.parent = prior t.child group by t.s1);
