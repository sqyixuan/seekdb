select trunc(level) lev1, trunc(t.lev) lev, length(t.child) len, lengthb(t.parent) lenb from
(select trunc(level) lev, lower(t.child) child, lower(t.parent) parent from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with nvl2(t.parent,t.parent,t.parent) in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle lower(t.parent) = prior t.child group by level,child,parent having child <> (select '0' from dual)) t
start with nvl2(t.lev,t.lev,t.lev) = '2'
connect by nocycle prior t.child = upper(t.parent) order siblings by t.child, t.parent;
