##################################子查询的形式##################################
######使用子查询创建table######
drop table stu;
drop table stu1;
drop view stu_view;
drop view stu1_view;
drop synonym stu1_syn;
drop synonym stu_syn;
drop table stu_cp;
drop table stu1_cp;
create table stu(s1 number, child nvarchar2(6), parent nvarchar2(6));
insert into stu values(0,0,0);
insert into stu values(1,'中国','亚太');
insert into stu values(2,'北京','中国');
insert into stu values(3,'浙江','中国');
insert into stu values(4,'余杭区','浙江');
insert into stu values(5,'西湖区','浙江');
insert into stu values(6,'北京','中国');
insert into stu values(7,'首尔','韩国');
insert into stu values(8,'朝阳区','北京');
create index stu_parent on stu(parent);
# 不支持使用层次查询来create table
create table stu1 as select level lev, t.* from stu t
start with t.parent in ('亚太', '中国')
connect by nocycle t.parent = prior t.child order siblings by t.s1,t.child;
drop table stu1;
# 不支持使用层次查询来create table
create table stu1 as select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle prior t.parent = t.child order siblings by t.s1,t.child;
drop table stu1;
create table stu1 as select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle t.parent = prior t.child order siblings by t.s1,t.child;
drop table stu1;
create table stu1 as select level, t.child, t.parent from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle t.parent = prior t.child group by level,child,parent having child <> (select '0' from dual);
ERROR HY000: must name LEVEL with a column alias
drop table stu1;
create table stu1 as select level, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
connect by nocycle t.parent = prior t.child order siblings by t.s1,t.child;
ERROR HY000: must name LEVEL with a column alias
drop table stu1;
drop view stu_view;
# 使用层次查询来create view
# 不支持使用层次查询来create view
create view stu_view as select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle prior t.parent = t.child order siblings by t.s1,t.child;
drop view stu_view;
create view stu_view as select level, t.child, t.parent from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle t.parent = prior t.child group by level,child,parent having child <> (select '0' from dual);
ERROR 0A000: internal error code, arguments: -4007, expression without a column alias not supported
drop view stu_view;
create view stu_view as select level, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
connect by nocycle t.parent = prior t.child order siblings by t.s1,t.child;
ERROR 0A000: internal error code, arguments: -4007, expression without a column alias not supported
drop table stu1;
drop view stu_view;
# create synonym 后只能是对象，不能为子查询，预期失败。
create synonym stu_view for (select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle prior t.parent = t.child order siblings by t.s1,t.child);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent f' at line 1
######子查询和层次查询的嵌套使用######
drop table stu1;
drop table stu;
drop view stu_view;
drop synonym stu_syn;
create table stu(s1 number, child nvarchar2(6), parent nvarchar2(6));
insert into stu values(0,0,0);
insert into stu values(1,'中国','亚太');
insert into stu values(2,'北京','中国');
insert into stu values(3,'浙江','中国');
insert into stu values(4,'余杭区','浙江');
insert into stu values(5,'西湖区','浙江');
insert into stu values(6,'北京','中国');
insert into stu values(7,'首尔','韩国');
insert into stu values(8,'朝阳区','北京');
create index stu_parent on stu(parent);
select level, t.* from
(select level lev, t.* from stu t
start with t.parent in ('亚太', '中国')
connect by nocycle t.parent = prior t.child order siblings by t.s1,t.child) t
start with t.lev = '1'
connect by nocycle prior t.child = t.parent order siblings by t.child,t.parent;
