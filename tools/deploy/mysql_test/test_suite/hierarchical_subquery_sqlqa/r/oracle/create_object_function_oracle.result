# dml条件中使用层次查询, 暂不支持
update stu set s1=66 where s1 in (
select t.s1 from stu t
start with t.parent in (0, 1)
connect by nocycle t.parent = prior t.child and t.s1 < 5);
delete from stu where s1 not in (
select t.s1 from stu t
start with t.parent in (0, 1)
connect by nocycle t.parent = prior t.child and t.s1 < 5);
drop table stu;
drop table stu1;
drop view stu_view;
drop view stu1_view;
drop synonym stu1_syn;
drop synonym stu_syn;
drop table stu_cp;
