with stu1 as (
select level,t.* from
(select level lev, t.child, t.parent from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle t.parent = prior t.child group by level,child,parent having child <> (select '0' from dual)) t
start with t.lev = '2'
connect by nocycle prior t.child = t.parent order siblings by t.child, t.parent
) select * from stu1;
