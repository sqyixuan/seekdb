drop table stu;
drop table stu1;
create table stu(s1 number, child number(6), parent number(6));
create table stu1(s1 number);
insert into stu values(0,0,0);
insert into stu values(1,10,1);
insert into stu values(2,20,10);
insert into stu values(3,30,10);
insert into stu values(4,40,30);
insert into stu values(5,50,30);
insert into stu values(6,60,10);
insert into stu values(7,70,200);
insert into stu values(8,80,60);
create index stu_parent on stu(parent);
insert into stu1 values(0);
insert into stu1 values(1);
insert into stu1 values(2);
insert into stu1 values(3);
insert into stu1 values(4);
insert into stu1 values(5);
insert into stu1 values(6);
insert into stu1 values(7);
insert into stu1 values(8);
insert into stu1 values(9);
select * from stu1 where s1 in (
select t.s1 from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent < 50)
connect by nocycle prior t.parent = t.child group by t.s1);
