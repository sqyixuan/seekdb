# nvarchar2作为节点及connect的条件, 使用order siblings by(子查询含层次查询)
select level, t.* from 
(select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with t.parent in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle prior t.parent = t.child order siblings by t.s1,t.child) t
start with t.lev <> 1
connect by nocycle prior t.child = t.parent order siblings by t.child, t.parent;
