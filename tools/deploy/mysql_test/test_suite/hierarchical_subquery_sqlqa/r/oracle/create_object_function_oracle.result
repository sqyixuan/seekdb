with stu1 as (
select to_char(level) lev1, to_number(t.lev) lev, nvl(t.s1,66) s1, length(t.child) len, lengthb(t.parent) lenb from 
(select level lev, t.* from (select t1.s1 s1, t1.child child, t2.parent parent from stu t1, stu t2 where t1.child = t2.child) t
start with to_char(t.parent) in (select parent from stu where parent not in ('浙江','北京','韩国'))
connect by nocycle prior nvl(t.parent,'aa') = nvl(t.child,'a') order siblings by t.s1,t.child) t
start with to_char(t.lev) <> to_char(1)
connect by nocycle prior nvl(t.child,'aa') = nvl(t.parent,'aa') order siblings by t.child, t.parent 
) select * from stu1;
