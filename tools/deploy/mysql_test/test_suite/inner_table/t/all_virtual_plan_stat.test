--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : xiaoyi.xy
#owner group : SQL1
#description : 测试虚拟表__all_virtual_plan_stat

--disable_abort_on_error
--disable_warnings

#普通租户
--echo
--enable_query_log
--enable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--sleep 3
#检查表结构
desc oceanbase.__all_virtual_plan_stat;

alter system flush plan cache global;
--sleep 3

connection default;
set autocommit = 0;
--echo //connect not system tenant
drop database if exists plan_stat_db;
create database plan_stat_db;
use plan_stat_db;
create table xy_tb(c1 int primary key, c2 int);

let $default_tenant = query_get_value(select effective_tenant() as tenant_name, tenant_name, 1);

--echo
--echo //测试sql_id

--echo //test error sql
select abc;
connection obsys;
eval select sql_id, query_sql from oceanbase.GV\$OB_SQL_AUDIT where query_sql = 'select abc' and tenant_name = '$default_tenant' order by request_id desc limit 1;

--echo //test correct sql
connection default;
select 1+1 as xy_sum;
connection obsys;
let $id = query_get_value(select sql_id from oceanbase.__all_virtual_sql_audit where query_sql = 'select 1+1 as xy_sum' and tenant_name = '$default_tenant', sql_id, 1);
eval select query_sql from oceanbase.GV\$OB_SQL_AUDIT where sql_id = '$id' and tenant_name = '$default_tenant' order by request_id desc limit 1;
connection default;
eval select '$id';
eval select statement from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where sql_id = '$id';

--echo
connection default;
select * from xy_tb;
--echo // expect HIT_COUNT = 0
--enable_result_log
select STATEMENT,HIT_COUNT from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where STATEMENT = 'select * from xy_tb';

--disable_result_log
drop table xy_tb;
drop database plan_stat_db;
commit;
set autocommit = 1;

#系统租户
#login using admin acount
connection obsys;
set autocommit = 0;

--echo //connect system tenant
drop database if exists plan_stat_sys_db;
create database plan_stat_sys_db;
use plan_stat_sys_db;
create table xy_sys_tb(c1 int primary key, c2 int);
select * from xy_sys_tb;

--enable_query_log
--enable_result_log
--echo // expect HIT_COUNT = 0
eval select type, statement,hit_count from oceanbase.__all_virtual_plan_stat where statement = 'select * from xy_tb';
commit;

select /*+query_timeout(1000000)*/ sleep(20) from dual;
select query_sql, executions, timeout_count from oceanbase.__all_virtual_plan_stat where query_sql = 'select /*+query_timeout(1000000)*/ sleep(20) from dual';

set autocommit = 1;
--disable_query_log
--disable_result_log

disconnect obsys;
