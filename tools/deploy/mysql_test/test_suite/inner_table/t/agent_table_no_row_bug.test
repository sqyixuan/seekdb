# owner: bin.lb
# owner group: sql2

--disable_warnings
drop table if exists t_should_not_exists___;
create table t_should_not_exists___ (c1 int);
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;

--disable_query_log
use oceanbase;
let $tenant_id = query_get_value(select tenant_id as x from __all_virtual_table_history where table_name = 't_should_not_exists___', x, 1);
let $table_id = query_get_value(select table_id as x from __all_virtual_table_history where table_name = 't_should_not_exists___', x, 1);
let $schema_version = query_get_value(select schema_version as x from __all_virtual_table_history where table_name = 't_should_not_exists___', x, 1);

eval select count(*) from __all_virtual_table_history where tenant_id = $tenant_id and table_id = $table_id and schema_version <= $schema_version;
