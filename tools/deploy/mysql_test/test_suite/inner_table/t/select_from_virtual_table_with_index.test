--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: jiajingzhe.jjz
# owner group: IMF
# fix __all_virtual_sysstat使用tenant_id过滤结果不一致，影响dooba使用  
# 
connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
use oceanbase;

# In the regression environment, there will be two observer, 
# and the number of repetitions of `name` will be 2 
# (except that the number of repetitions of `standby cutdata task count` is 4).
# If the number of repetitions is not 2, then the same Bug may have occurred.

select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 1 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);
select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 897892227897352123 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);

alter system set_tp tp_no=400, error_code=10, frequency=1;

select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 1 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);
select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 897892227897352123 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);

alter system set_tp tp_no=400, error_code=10000, frequency=1;

select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 1 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);
select name, repeat_num from (
  select name, count(1) as repeat_num from __all_virtual_sysstat where tenant_id = 897892227897352123 group by name
) where repeat_num !=2 and !(name = "standby cutdata task count" and repeat_num = 4);

# virtual table`s index schemas
select column_id, column_name, column_flags from __all_column where table_id = 14993;
select column_id, column_name, column_flags from __all_column where table_id = 14998;

## use virtual table index as always false query range
SELECT /*+no_rewrite*/ CON_ID FROM OCEANBASE.V$SYSSTAT
WHERE CON_ID < 1 and CON_ID = (select 10 from dual);

SELECT /*+no_pred_deduce leading(b) use_nl(a)*/ A.CON_ID
FROM (SELECT CON_ID FROM OCEANBASE.V$SYSSTAT GROUP BY CON_ID ) AS A,
    OCEANBASE.__ALL_TENANT B
WHERE A.CON_ID = B.TENANT_ID and A.CON_ID < 1;

disconnect sysc;
