--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : muwei.ym
#owner group : storage
#description : __all_virtusession_event;__all_virtual_session_wait;__all_virtual_session_wait_history;__all_virtual_system_event;__all_virtual_sesstat;__all_virtual_sysstat;__avirtual_storage_stat;__all_virtual_disk_stat;gv$session_event;gv&session_wait;gv$session_wait_history;gv$system_event;gv$sesstat;gv$sysstat

--disable_abort_on_error
--disable_warnings

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
use oceanbase;
desc __all_virtual_session_event;
desc __all_virtual_session_wait;
desc __all_virtual_session_wait_history;
desc __all_virtual_system_event;
desc __all_virtual_sesstat;
desc __all_virtual_sysstat;
desc __all_virtual_disk_stat;

desc gv$session_event;
desc gv$session_wait;
desc gv$session_wait_history;
desc gv$system_event;
desc gv$sesstat;
desc gv$sysstat;

desc v$session_event;
desc v$session_wait;
desc v$session_wait_history;
desc v$system_event;
desc v$sesstat;
desc v$sysstat;

# test monitor virtual table
select count(*) >= 1 from oceanbase.__all_virtual_session_event;
select count(*) >= 1 from oceanbase.__all_virtual_session_wait;
select count(*) >= 1 from oceanbase.__all_virtual_session_wait_history;
select count(*) >= 1 from oceanbase.__all_virtual_system_event;
select count(*) >= 1 from oceanbase.__all_virtual_sesstat;
select count(*) >= 1 from oceanbase.__all_virtual_sysstat;
select count(*) >= 1 from oceanbase.__all_virtual_disk_stat;

# test view
select count(*) >= 1 from gv$session_event;
select count(*) >= 1 from gv$session_wait;
select count(*) >= 1 from gv$session_wait_history;
select count(*) >= 1 from gv$system_event;
select count(*) >= 1 from gv$sesstat;
select count(*) >= 1 from gv$sysstat;


disconnect obsys1;
--enable_abort_on_error
--enable_warnings

