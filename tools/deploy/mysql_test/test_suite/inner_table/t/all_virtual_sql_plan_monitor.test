# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试oceanbase.__all_virtual_sql_plan_monitor的去重功能；

--disable_warnings
drop table if exists test_monitor;
--enable_warnings
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set ob_enable_trace_log = 1;
sleep 3; ##need wait ob_log_level
create table test_monitor(c1 int primary key);
insert into test_monitor values(1);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
let $plan_id = query_get_value(select plan_id from  oceanbase.__all_virtual_plan_stat where statement like 'insert into test_monitor values%', plan_id, 1);
--disable_query_log
eval select count(*) from oceanbase.__all_virtual_sql_monitor where plan_id=$plan_id;
connection default;

insert into test_monitor values(2);
insert into test_monitor values(3);
select * from test_monitor;
sleep 1;
connection obsys;
eval select count(*) from oceanbase.__all_virtual_sql_monitor where plan_id=$plan_id;
connection default;

sleep 12;
insert into test_monitor values(5);
connection obsys;
eval select count(*) from oceanbase.__all_virtual_sql_monitor where plan_id=$plan_id;
disconnect obsys;
connection default;

--enable_query_log
