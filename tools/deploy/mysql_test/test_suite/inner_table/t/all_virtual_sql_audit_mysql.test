--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group : SQL1
# tags: optimizer
#description : 测试SQL审计表 sys.GV$OB_SQL_AUDIT

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;

connection default;
DESC OCEANBASE.V$OB_SQL_AUDIT;
--echo
DESC OCEANBASE.GV$OB_SQL_AUDIT;

connection obsys;

alter system flush sql audit global;
alter system flush plan cache global;

connection default;

--disable_result_log
select 1 from dual;

select * from oceanbase.GV$OB_SQL_AUDIT where sql_id is NULL limit 1;

--enable_result_log
select sql_id, 1 as tenant_id, query_sql from oceanbase.V$OB_SQL_AUDIT where sql_id = 'A0B3A8D4AEFC34DE2BF681CA942DDEBB';

select sql_id, 1 as tenant_id, query_sql from oceanbase.GV$OB_SQL_AUDIT where sql_id = 'A0B3A8D4AEFC34DE2BF681CA942DDEBB';

connect(default2,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection default2;
set global ob_enable_sql_audit = false;
--sleep 3
disconnect default2;

connection obsys;
alter system flush sql audit global;

connect (default2,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection default2;

--disable_warnings
drop table if exists t_sql_audit;
--enable_warnings

create table t_sql_audit (a int);

insert into t_sql_audit values (1);
insert into t_sql_audit values (2);
insert into t_sql_audit values (3);

select * from t_sql_audit;
select * from t_sql_audit;
select * from t_sql_audit;

select count(*) = 0 from oceanbase.V$OB_SQL_AUDIT where query_sql = 'select * from t_sql_audit';
select count(*) = 0 from oceanbase.V$OB_SQL_AUDIT where query_sql = 'insert into t_sql_audit values (1)';
select count(*) = 0 from oceanbase.V$OB_SQL_AUDIT where query_sql = 'insert into t_sql_audit values (2)';
select count(*) = 0 from oceanbase.V$OB_SQL_AUDIT where query_sql = 'insert into t_sql_audit values (3)';

select elapsed_time > 0, cpu_time > 0, avg_exe_usec > 0, slowest_exe_time > 0, slowest_exe_usec > 0, cpu_time > 0 from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'insert into t_sql_audit values (?)' limit 1;
select elapsed_time > 0, cpu_time > 0, avg_exe_usec > 0, slowest_exe_time > 0, slowest_exe_usec > 0, cpu_time > 0 from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t_sql_audit' limit 1;

drop table t_sql_audit;

set global ob_enable_sql_audit = true;
disconnect default2;
