--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : gongyusen.gys
#owner group : sql2
#description : test the consistency of db_id displayed by SQL audit and plan stat.
#tags: __all_virtual_plan_stat, __all_virtual_sql_audit
connect (sys,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connection sys;
alter system flush sql audit global;
alter system flush plan cache global;
disconnect sys;

connect (sys,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connection sys;
select 'db_id_consistent_test' from dual;

select
  audit.db_id,
  audit.query_sql,
  stat.db_id,
  stat.query_sql
from
  (
    select
      distinct sql_id,
      db_id,
      query_sql
    from
      oceanbase.__all_virtual_sql_audit
    where
      query_sql = 'select \'db_id_consistent_test\' from dual' limit 1
  ) audit
  inner join (
    select
      distinct sql_id,
      db_id,
      query_sql
    from
      oceanbase.__all_virtual_plan_stat
    where
      query_sql = 'select \'db_id_consistent_test\' from dual' limit 1
  ) stat on audit.db_id = stat.db_id
  and audit.sql_id = stat.sql_id;