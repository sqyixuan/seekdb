#owner: xiaoyi.xy
#owner group: SQL4
#tags: outline
##
## Test Name: tenant_virtual_outline
##

## 测试目的：测试__tenant_virtual_outline虚拟表和DBA_OB_OUTLINES的有效性
## 测试方案
## 1.测试outline_sql的正确性
## 测试outline_content分别为1)空 2)非空 的情况
## 测试sql_text分别为1)有hint 2)无hint的情况

## 2.测试visible_signature的正确性
## 测试select 后面只有一个空格的情况
## 测试select后面有多个空格的情况

## 3.测试to_clause时，FP_NO_PARAMERIZE_AND_FILTER_HINT_MODE模式的正确性

## 4.测试plan_cache开启时，outline的创建与删除

##################################### create tenant #####################################
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_warnings
--disable_query_log
--disable_result_log
#call oceanbase.drop_tenant_force('yts_tt');
#call oceanbase.create_mysql_tenant_1c2g('yts_tt');
#--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log
--enable_warnings

connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
--enable_query_log
--enable_result_log
select effective_tenant();
connection conn1;

start transaction;

##################################### test __tenant_virtual_outline  #####################################
--disable_warnings
drop database if exists ol_db;
--enable_warnings
create database ol_db;
use ol_db;

select * from oceanbase.__tenant_virtual_outline;
select * from oceanbase.DBA_OB_OUTLINES;

create table t1(c1 int, c2 int);
connection conn1;
create table t2(c1 int, c2 int);
connection conn1;

create outline ol_1 on select * from t1;
create outline ol_2 on select /*+use_nl(t1) leading(t1 t2)*/* from t2,t1 where t1.c1 > 1;
create outline ol_3 on select /*+max_concurrent(1)*/* from t1 where t1.c1 = 1;

create outline ol_4 on select * from t1 to select /*+full(t1)*/* from t1;
create outline ol_5 on select /*+use_nl(t1) leading(t1 t2)*/* from t2,t1 where t1.c1 > 1 to select /*+use_nl(t2)*/* from t2,t1 where t1.c1 > 1;
create outline ol_6 on select /*+max_concurrent(1)*/* from t1 where t1.c1 = 1 to select /*+use_nl(t2)*/* from t1 where t1.c1 = 1;
create outline ol_7 on select /*+trace_log*/  * from t1 where t1.c1 > 1;

select visible_signature, database_name, outline_name,	sql_text, outline_target, outline_sql from oceanbase.__tenant_virtual_outline;
select visible_signature, database_name, outline_name,	sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES;
select visible_signature, database_name, outline_name,	sql_text, outline_target, outline_sql from oceanbase.__tenant_virtual_outline where outline_name = 'ol_7';
select visible_signature from oceanbase.DBA_OB_OUTLINES where outline_name = 'ol_7';

## 3.测试to_clause时，FP_NO_PARAMERIZE_AND_FILTER_HINT_MODE模式的正确性
create outline ol3 on select * from t1 where c1 = 'aaa' to select /*+trace_log*/* from t1 where c1 = 'aaa';
create outline ol3_2 on select  * from t1 where c1 = '''' to select  /*+trace_log*/* from t1 where c1 = '''';
create outline ol3_3 on select   * from t1 where c1 = '\n' to select   /*+trace_log*/* from t1 where c1 = '\n';
create outline ol3_4 on select    * from t1 where c1 = '  ' to select    /*+trace_log*/* from t1 where c1 = '  ';
select visible_signature, database_name, outline_name,	sql_text, outline_target, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name like "ol3%";

--disable_warnings
drop database if exists ol_db;
--enable_warnings




##################################### delete tenant #####################################
# login using admin acount
connection conn_admin;
--disable_query_log
call oceanbase.drop_tenant_force('yts_tt');
--enable_query_log

--disable_query_log
--disable_result_log
sleep 20;
--enable_result_log
--enable_query_log

commit;



##################################### plan cache #####################################

--disable_abort_on_error

connection obsys;

set ob_enable_plan_cache = off;
--disable_warnings
drop table if exists transform_outline_t;
--enable_warnings

create table transform_outline_t (c1 int primary key, c2 int, c3 int, index idx_c2(c2));
insert into transform_outline_t values(1, 1, 1), (2, 2, 2), (3, 3, 3);

create outline otl_idx_c2 on select/*+ index(transform_outline_t idx_c2)*/ * from transform_outline_t where c2 = 1;

select * from transform_outline_t where c2 = 1;

select outline_name, outline_sql from oceanbase.DBA_OB_OUTLINES where outline_name = 'otl_idx_c2';

drop outline otl_idx_c2;

drop table transform_outline_t;


