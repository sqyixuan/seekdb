##################################### create tenant #####################################
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_warnings
--disable_query_log
--disable_result_log
#call oceanbase.drop_tenant_force('sj_tt');
#call oceanbase.create_mysql_tenant_1c2g('sj_tt');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log
--enable_warnings

#####  bug
connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
--enable_query_log
--enable_result_log
connection conn1;
select effective_tenant();

create database ol_db;
use ol_db;

create table t1(c_1 int);
--disable_query_log
--disable_warnings
let $cnt=1500;
let $idx=1;
while ($idx <= $cnt)
{
  eval create outline ol5_$idx on select /*+use_nl(t1) leading(t1 t2)*/c_$idx from t1;
  inc $idx;
  eval alter table t1 add column c_$idx int;
}
set @@recyclebin = on;
use oceanbase;
drop database if exists ol_db;
--enable_warnings
--enable_query_log

select /*+QUERY_TIMEOUT(1000000000)*/ outline_name from oceanbase.__tenant_virtual_outline;

##################################### delete tenant #####################################
# login using admin acount
connection conn_admin;
--disable_query_log
#call oceanbase.drop_tenant_force('sj_tt');
--enable_query_log

--disable_query_log
--disable_result_log
sleep 10;
--enable_result_log
--enable_query_log

commit;
