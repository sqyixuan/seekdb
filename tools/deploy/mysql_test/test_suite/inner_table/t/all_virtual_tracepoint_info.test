connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,OCEANBASE,$OBMYSQL_PORT);
connection obsys1;

alter system set_tp tp_no = 2304, error_code = 4016, frequency = 1;
select tp_no, tp_name, tp_describe, tp_frequency, tp_error_code, tp_occur, tp_match from __all_virtual_tracepoint_info where tp_no = 2304 limit 1;

alter system set_tp tp_no = 2304, error_code = 4017, frequency = 1;
