--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: muwei.ym
# owner group: storage
# description: test virtual table __all_virtual_macro_block_marker_status

--disable_warnings
drop table if exists test;
--enable_warnings
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
disconnect obsys1;
connection default;

create table test (c1 int primary key, c2 int);
insert into test values(1,1);
insert into test values(2,2);
insert into test values(3,3);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--real_sleep 15
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

let $retry_cnt = 5;
while ($retry_cnt)
{
 let $macro_count = query_get_value(select /*+ QUERY_TIMEOUT (10000000000000) */ count(distinct(macro_block_idx)) as c from oceanbase.__all_virtual_tablet_sstable_macro_info where macro_block_type = 'data_block', c, 1);
 let $data_count = query_get_value(select sum(data_block_count) + sum(shared_data_block_count) as total_count from oceanbase.__all_virtual_macro_block_marker_status, total_count, 1);

  if ($macro_count != $data_count)
  {
    --real_sleep 60
    dec $retry_cnt;
  }
  if ($macro_count == $data_count)
  {
    let $retry_cnt = 0;
  }
}

if ($macro_count != $data_count)
{
  --echo $data_count
  --echo $macro_count
  --echo data macro count is not equal
}
disconnect obsys1;
