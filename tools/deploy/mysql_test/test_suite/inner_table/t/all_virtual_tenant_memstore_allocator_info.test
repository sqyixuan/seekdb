--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : yaoying.yyy
#owner group : transaction
#description : 测试虚拟表__all_virtual_tenant_memstore_allocator_info

##修改配置
--disable_abort_on_error
--disable_warnings

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
##数据准备
--disable_query_log
call oceanbase.drop_tenant_force('tenant_memstore_info_t1');
call oceanbase.drop_tenant_force('tenant_memstore_info_t2');
call oceanbase.create_mysql_tenant_mini('tenant_memstore_info_t1');
call oceanbase.create_mysql_tenant_mini('tenant_memstore_info_t2');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

let $svr_ip_1 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 1);
--disable_result_log
## case:检查表结构
set global recyclebin = 'off';
use oceanbase;
eval select tenant_id,table_id,table_name from __all_virtual_table where table_name="__all_virtual_tenant_memstore_allocator_info";
desc __all_virtual_tenant_memstore_allocator_info;

--disable_query_log
eval select tenant_id, table_id, partition_id, mt_base_version, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";
eval select tenant_id, table_id, partition_id, mt_base_version, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";
--enable_query_log

#case: 建表插入数据，查询虚拟表数据
connect(conn1,$OBMYSQL_MS0,root@tenant_memstore_info_t1,,*NO-ONE*,$OBMYSQL_PORT);
set global recyclebin = 'off';
drop database if exists test;
create database test;
use test;
create table test1(c1 int primary key, c2 int);
insert into test1 values (1,1),(2,2);
create table test2(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into test2 values (1,1);
insert into test2 values (2,2);
--disable_query_log
eval select tenant_id, table_id, partition_id, mt_base_version, retire_clock, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";
eval select tenant_id, table_id, partition_id, mt_base_version, retire_clock, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";
--enable_query_log

connect (conn_admin,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
--disable_query_log
eval select tenant_id, table_id, partition_id, mt_base_version, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1" order by tenant_id, table_id, partition_id, mt_base_version;
--enable_query_log

sleep 1;
connection conn_admin;
use test;
set @@recyclebin = 'off';
drop table test1;
##等待memtable的回收
sleep 20;
--disable_query_log
eval select tenant_id, table_id, partition_id, mt_base_version, retire_clock, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";
eval select tenant_id, table_id, partition_id, mt_base_version, retire_clock, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1";

connection conn_admin;
eval select tenant_id, table_id, partition_id, mt_base_version, mt_is_frozen, mt_snapshot_version from oceanbase.__all_virtual_tenant_memstore_allocator_info where svr_ip="$svr_ip_1" order by tenant_id, table_id, partition_id, mt_base_version;
--enable_query_log
##清理数据
#清理视图
#清理租户资源
--disable_query_log
call oceanbase.drop_tenant_force('tenant_memstore_info_t1');
call oceanbase.drop_tenant_force('tenant_memstore_info_t2');
--enable_query_log

--disable_query_log
--disable_result_log
sleep 20;
--enable_result_log
--enable_query_log
