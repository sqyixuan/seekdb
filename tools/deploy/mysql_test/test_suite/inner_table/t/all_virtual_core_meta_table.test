--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : zhenjiang.xzj
#owner group : STORAGE
#description : 测试虚拟表__all_virtual_core_meta_table

--disable_abort_on_error
--disable_warnings
#检查表结构
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
desc oceanbase.__all_virtual_core_meta_table;

--disable_result_log

#get observer count
let $obs_num_1 = query_get_value(select count(distinct zone) as cnt from oceanbase.__all_zone where zone != '', cnt, 1);
let $obs_num_2 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_core_meta_table, cnt, 1);

--enable_result_log
if ($obs_num_1 == $obs_num_2)
{
--echo server count in __all_virtual_core_meta_table is ok;
}

