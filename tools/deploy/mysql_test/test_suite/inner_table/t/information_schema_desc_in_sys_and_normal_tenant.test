--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: shouju.zyp 
#tag: RS
#description: information_schema desc for information_schema
#备注: 测试系统租户, 普通租户对information_schema下的表执行desc 操作是否能成功
# 包括客户端连接普通租户以及change effective tenant 两种方式
# 这个case主要测试case是否能正确执行不报错

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

#
## create tenant
#
--disable_query_log
--disable_result_log
#call oceanbase.drop_tenant_force('t1');
#call oceanbase.create_mysql_tenant_mini_with_arg('t1', "charset='utf8mb4'");
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log

disconnect obsys1;

