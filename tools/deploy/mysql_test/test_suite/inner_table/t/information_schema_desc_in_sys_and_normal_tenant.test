#
## 客户端方式连接系统租户
#
connect(conn_sys1,$OBMYSQL_MS0,root@sys,,information_schema,$OBMYSQL_PORT);

use information_schema;
--disable_result_log
desc columns;
desc session_variables;
desc table_privileges;
desc key_column_usage;
desc processlist;
desc collation_character_set_applicability;
desc global_status;
desc partitions;
desc session_status;
desc table_constraints;
desc schema_privileges;
desc user_privileges;
desc schemata;
desc character_sets;
desc global_variables;
desc statistics;
desc views;
desc tables;
desc collations;
--enable_result_log


#
## 客户端方式连接普通租户
#
sleep 3;
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect(conn_normal,$TE_SERVER_IP,root,,information_schema,$TE_SERVER_PORT);

use information_schema;
--disable_result_log
desc columns;
desc session_variables;
desc table_privileges;
desc key_column_usage;
desc processlist;
desc collation_character_set_applicability;
desc global_status;
desc partitions;
desc session_status;
desc table_constraints;
desc schema_privileges;
desc user_privileges;
desc schemata;
desc character_sets;
desc global_variables;
desc statistics;
desc views;
desc tables;
desc collations;
--enable_result_log


