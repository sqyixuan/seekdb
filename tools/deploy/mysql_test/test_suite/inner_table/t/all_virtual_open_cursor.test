#description : test __all_virtual_open_cursor

### show in all_virtual_table
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

select tenant_id, table_name from oceanbase.__all_virtual_table where table_name = '__all_virtual_open_cursor' and tenant_id = 1;


### show all_virtual_open_cursor
use oceanbase;
desc __all_virtual_open_cursor;

### select all_virtual_open_cursor
select tenant_id, sql_text from __all_virtual_open_cursor where sql_text like '%all_virtual_open_cursor%' && tenant_id = 1;
