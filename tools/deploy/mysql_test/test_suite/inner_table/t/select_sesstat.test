#owner:zhangyiqiang.zyq
#owner group: imf
# 测试sesstat指定session_id时走索引查询是否能查询到数据

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
use oceanbase;

let $stat_no = query_get_value(select * from __all_virtual_sysstat where tenant_id=1 and name="query count", statistic#, 1);
let $session_id = `select CONNECTION_ID() from DUAL`;
--disable_query_log
eval select count(*) from __all_virtual_sesstat where tenant_id=1 and `STATISTIC#`=$stat_no and session_id = $session_id;
--enable_query_log

disconnect obsys1;