--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : rongxuan.lc
#owner group : rs
#description : 测试虚拟表__all_virtual_core_root_table;__all_virtual_core_all_table;__all_virtual_core_column_table

--disable_abort_on_error
--disable_warnings

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection sysc;

#检查表结构
use oceanbase;
desc __all_virtual_core_all_table;
desc __all_virtual_core_column_table;

#查询
select tenant_id, table_id,table_name from __all_virtual_core_all_table where table_name like '%column%' and tenant_id <= 1004 group by tenant_id, table_id order by tenant_id, table_id;
select tenant_id, table_id,count(*) from __all_virtual_core_column_table group by tenant_id, table_id order by tenant_id, table_id;

--enable_abort_on_error
--enable_warnings

