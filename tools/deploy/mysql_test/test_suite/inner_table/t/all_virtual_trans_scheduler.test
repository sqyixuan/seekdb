--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : wuyuefei.wyf
#owner group : transaction
#description : 测试虚拟表__all_virtual_trans_scheduler

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys;

--disable_abort_on_error


## case 0: 检查表结构
desc __all_virtual_trans_scheduler;

## 数据插入

connection mysql;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table if not exists t1(col1 int primary key auto_increment, col2 varchar(1));

## 在事务结束之前，查询__all_virtual_trans_scheduler之前
begin;
insert into t1 values(NULL, 'a');

## case 1: sys租户查询
connection sys;

## mysql租户对应的事务状态应为EXPLICIT_ACTIVE(2)
select count(1) > 0 from __all_virtual_trans_scheduler;

select count(1) > 0 from (select * from __all_virtual_trans_scheduler limit 10) as t;

select count(1) > 0 from __all_virtual_trans_scheduler;

## case 2: mysql租户查询
connection mysql;

select count(1) > 0 from oceanbase.__all_virtual_trans_scheduler;

## commit and clean data
commit;
drop table if exists t1;

connection sys;

##还原配置
--enable_abort_on_error
