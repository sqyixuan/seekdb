#owner : dachuan.sdc
#owner group : SQL2
#description : test show table status
#tags: inner_table

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) (partition p0 values less than(0), partition p1 values less than(100));
insert into t1 values(-1, 0, 3);
insert into t1 values(10, 1000, 3);

create table t2 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
insert into t2 values(-1, 0, 3);
insert into t2 values(10, 1000, 3);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc
connection default;

## 测试 show table status 能否正确展示分区表的 row_count 字段
--replace_column 3 # 6 # 7 # 10 # 12 # 13 # 17 #
show table status like 't1';

--replace_column 3 # 6 # 7 # 10 # 12 # 13 # 17 #
show table status like 't2';

## clean up
drop table t2;
drop table t1;
