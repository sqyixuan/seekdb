--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : nijia.nj
#owner group : sql2
#description : test information_schema.columns

use information_schema;

#basic
#select column_name from columns where table_schema = 'oceanbase' and table_name = '__all_table';

--disable_warnings
drop table if exists test.t1;
--enable_warnings
create table test.t1(c1 int, c2 int);
select column_name from columns where table_schema = 'test' and table_name = 't1';

#show
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table columns;
desc columns;

#drop
--disable_warnings
drop table test.t1;
--enable_warnings

# bugfix#
select * from information_schema.columns where table_schema = 'test' and table_name = '';
