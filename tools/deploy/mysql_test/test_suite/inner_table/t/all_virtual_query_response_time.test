--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : wangzelin.wzl
#owner group : OPENSOURCE
#description : 测试虚拟表__all_virtual_query_response_time

--disable_abort_on_error
--disable_warnings

#检查表结构
#login into the sys tenant
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

alter system set query_response_time_stats = false;
--sleep 5
alter system set query_response_time_flush = true;
--sleep 3
desc oceanbase.__all_virtual_query_response_time;

--enable_result_log
let $num_1 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_query_response_time where count > 0 and tenant_id = effective_tenant_id(), cnt, 1);
if ($num_1 == 0)
{
--echo variable count in __all_virtual_query_response_time is ok when query_response_time_stats is false;
}
#test show cmd

show QUERY_RESPONSE_TIME;

alter system set query_response_time_stats = true;
--real_sleep 1
let $num_2 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_query_response_time  where count > 0 and tenant_id = effective_tenant_id(),cnt, 1);
if ($num_2 > 0)
{
--echo variable count in __all_virtual_query_response_time is ok when query_response_time_stats is true;
}

alter system set query_response_time_stats = false;
--sleep 5
alter system set query_response_time_flush = true;
--real_sleep 3
let $num_3 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_query_response_time  where count > 0 and tenant_id = effective_tenant_id(),cnt, 1);
if ($num_3 == 0)
{
--echo variable count in __all_virtual_query_response_time is ok;
}

# 检查视图
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;
select tenant_id, response_time from gv$ob_query_response_time_histogram group by tenant_id, response_time;
select tenant_id, response_time from v$ob_query_response_time_histogram group by tenant_id, response_time;

connect(mysql_conn,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection mysql_conn;
select tenant_id, response_time from gv$ob_query_response_time_histogram group by tenant_id, response_time;
select tenant_id, response_time from v$ob_query_response_time_histogram group by tenant_id, response_time;
