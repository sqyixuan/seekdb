--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: buming.lj
#### owner group: ddl
#### description: information_schema.referential_constraints
#### tags: ddl

--disable_warnings
drop database if exists xiaofeng_db;
create database xiaofeng_db;
use xiaofeng_db;
--enable_warnings

desc information_schema.referential_constraints;

create table t1(c1 int unique key, c2 int, c4 int, primary key(c2, c4), c3 int, index t1c3(c3));
create table t2(c1 int, CONSTRAINT xiaofeng_db_t2_fk1 FOREIGN KEY (c1) REFERENCES t1(c1) on update restrict on delete no action);
create table t3(c1 int, CONSTRAINT xiaofeng_db_t3_fk1 FOREIGN KEY (c1) REFERENCES t1(c2) on update no action on delete cascade);
create table t4(c1 int, CONSTRAINT xiaofeng_db_t4_fk1 FOREIGN KEY (c1) REFERENCES t1(c3) on update cascade on delete restrict);
create table t5(c2 int, c4 int, CONSTRAINT xiaofeng_db_t5_fk1 FOREIGN KEY (c2, c4) REFERENCES t1(c2, c4));
create unique index t1u on t1(c4, c3, c1);
create table t6(c4 int, c3 int, c1 int, CONSTRAINT xiaofeng_db_t6_fk1 FOREIGN KEY (c4, c3, c1) REFERENCES t1(c4, c3, c1));
create table t7(c4 int, c3 int, CONSTRAINT xiaofeng_db_t7_fk1 FOREIGN KEY (c4, c3) REFERENCES t1(c4, c3));
create index t1i on t1(c1, c2, c3);
create table t8(c1 int, c2 int, c3 int, CONSTRAINT xiaofeng_db_t8_fk1 FOREIGN KEY (c1, c2, c3) REFERENCES t1(c1, c2, c3));
create table t9(c1 int, CONSTRAINT xiaofeng_db_t9_fk1 FOREIGN KEY (c1) REFERENCES t1(c1) on update set null on delete set null);
select * from information_schema.referential_constraints where CONSTRAINT_SCHEMA = 'xiaofeng_db' order by CONSTRAINT_NAME;

# clean up
drop table t9,t8,t7,t6,t5,t4,t3,t2,t1;
drop database xiaofeng_db;
