#owner       : wangyunlai.wyl
#owner group : sys
#description : test oceanbase.__all_virtual_plugin_info

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys;
use oceanbase;

#basic
desc __all_virtual_plugin_info;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from __all_virtual_plugin_info order by name,library_version;

#views
desc gv$ob_plugins;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from gv$ob_plugins order by name,library_version;

desc v$ob_plugins;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from v$ob_plugins order by name,library_version;

#normal user
connect (obsys,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

use oceanbase;

#basic
desc __all_virtual_plugin_info;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from __all_virtual_plugin_info order by name,library_version;

#views
desc gv$ob_plugins;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from gv$ob_plugins order by name,library_version;

desc v$ob_plugins;
select distinct name,status,type,library,library_version,library_revision,interface_version,author,license,description from v$ob_plugins order by name,library_version;

connection default;
