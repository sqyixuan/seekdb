#owner       : wuguangxin.wgx
#owner group : shenzhen

--disable_abort_on_error
--disable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#检查表结构
desc oceanbase.__all_virtual_kv_group_commit_status;

desc oceanbase.GV$OB_KV_GROUP_COMMIT_STATUS;

desc oceanbase.V$OB_KV_GROUP_COMMIT_STATUS;

--enable_query_log

--echo
#tenant_id是变化的，为保证结果稳定，查询语句不能显示，
--disable_query_log
--enable_result_log
--echo //expect 2;

#sys tenant can see all tenant's content
--echo //expect 2;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.__all_virtual_kv_group_commit_status where group_type='FAIL' limit 1;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS where group_type='FAIL' limit 1;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.V\$OB_KV_GROUP_COMMIT_STATUS where group_type='FAIL' limit 1;

disconnect obsys;

#mysql租户
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_result_log
show parameters like "kv_group_commit_batch_size";
--enable_result_log

#检查表结构
desc oceanbase.__all_virtual_kv_group_commit_status;

desc oceanbase.GV$OB_KV_GROUP_COMMIT_STATUS;

desc oceanbase.V$OB_KV_GROUP_COMMIT_STATUS;

--echo
#tenant_id是变化的，为保证结果稳定，查询语句不能显示，
--disable_query_log
--enable_result_log
--echo //expect 1;

#mysql tenant cannot see all tenant's content
--echo //expect 1;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.__all_virtual_kv_group_commit_status limit 1;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS limit 1;

eval select group_type, table_id, schema_version, queue_size, batch_size from oceanbase.V\$OB_KV_GROUP_COMMIT_STATUS limit 1;

disconnect conn1;
