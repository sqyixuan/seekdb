#owner       : wuguangxin.wgx
#owner group : shenzhen

--disable_abort_on_error
--disable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#检查表结构
desc oceanbase.__all_virtual_kv_group_commit_status;

desc oceanbase.GV$OB_KV_GROUP_COMMIT_STATUS;

desc oceanbase.V$OB_KV_GROUP_COMMIT_STATUS;

--enable_query_log
let $sys_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);

--echo
#tenant_id是变化的，为保证结果稳定，查询语句不能显示，
--disable_query_log
--enable_result_log
--echo //expect 2;
eval select count(1) from (select tenant_id from oceanbase.__all_virtual_kv_group_commit_status where tenant_id in ($sys_id, $mysql_tenant_id) group by tenant_id) as t;

#sys tenant can see all tenant's content
--echo //expect 2;
eval select count(1) from (select tenant_id from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS where tenant_id in ($sys_id, $mysql_tenant_id) group by tenant_id) as t;

eval select tenant_id, group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.__all_virtual_kv_group_commit_status where tenant_id = $sys_id and group_type='FAIL' limit 1;

eval select tenant_id, group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS where tenant_id = $sys_id and group_type='FAIL' limit 1;

eval select tenant_id, group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.V\$OB_KV_GROUP_COMMIT_STATUS where tenant_id = $sys_id and group_type='FAIL' limit 1;

disconnect obsys;

#mysql租户
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_result_log
show parameters like "kv_group_commit_batch_size";
--enable_result_log

#检查表结构
desc oceanbase.__all_virtual_kv_group_commit_status;

desc oceanbase.GV$OB_KV_GROUP_COMMIT_STATUS;

desc oceanbase.V$OB_KV_GROUP_COMMIT_STATUS;

--echo
#tenant_id是变化的，为保证结果稳定，查询语句不能显示，
--disable_query_log
--enable_result_log
--echo //expect 1;
eval select count(1) from (select tenant_id from oceanbase.__all_virtual_kv_group_commit_status group by tenant_id) as t;

#mysql tenant cannot see all tenant's content
--echo //expect 1;
eval select count(1) from (select tenant_id from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS group by tenant_id) as t;

eval select group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.__all_virtual_kv_group_commit_status where tenant_id = $mysql_tenant_id limit 1;

eval select group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.GV\$OB_KV_GROUP_COMMIT_STATUS where tenant_id = $mysql_tenant_id limit 1;

eval select group_type, ls_id, table_id, schema_version, queue_size, batch_size from oceanbase.V\$OB_KV_GROUP_COMMIT_STATUS where tenant_id = $mysql_tenant_id limit 1;

disconnect conn1;