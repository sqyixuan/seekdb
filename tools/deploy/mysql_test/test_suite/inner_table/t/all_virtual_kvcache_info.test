--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group : storage
#description : __all_virtual_kvcache_info

--disable_abort_on_error
--disable_warnings

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

use oceanbase;
desc __all_virtual_kvcache_info;

--disable_result_log
let $idx1 = query_get_value(select count(*) from oceanbase.__all_virtual_kvcache_info,count(*),1);
--enable_result_log
if($idx1)
{
--echo succeed
}

disconnect obsys1;
--enable_abort_on_error
--enable_warnings

