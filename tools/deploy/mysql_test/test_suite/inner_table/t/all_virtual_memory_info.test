--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : bin.lb
#owner group : SQL1
#description : 测试虚拟表__all_virtual_memory_info

##修改配置
--disable_abort_on_error
--disable_warnings
##数据准备
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
call oceanbase.drop_tenant_force('tenant_memory_info_t1');
call oceanbase.drop_tenant_force('tenant_memory_info_t2');
call oceanbase.create_mysql_tenant_mini('tenant_memory_info_t1');
call oceanbase.create_mysql_tenant_mini('tenant_memory_info_t2');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

## case:检查表结构
use oceanbase;
desc __all_virtual_memory_info;
## case:普通查询
select count(1)>0 from __all_virtual_memory_info;
select count(1) from (select * from __all_virtual_memory_info order by used desc limit 10) as t;
select count(1)>0 from __all_virtual_memory_info group by tenant_id order by tenant_id desc limit 3;
select count(*)>1 from __all_virtual_memory_info where mod_type='user';
## case:子查询
--sorted_result
select count(1)>0 from (select tenant_id>0,sum(used)>=0 from __all_virtual_memory_info group by tenant_id) as t;
--sorted_result
select tenant_id,tenant_name,info from __all_tenant where tenant_id in (select tenant_id from __all_virtual_memory_info group by tenant_id) and tenant_name='sys';
--sorted_result
select tenant_name from __all_tenant where tenant_id in (select tenant_id from __all_virtual_memory_info group by tenant_id) and tenant_name in ('sys','tenant_memory_info_t1','tenant_memory_info_t2');
--sorted_result
select count(1)>0 from __all_server as lt left join (select svr_ip,svr_port from __all_virtual_memory_info group by svr_ip,svr_port) as rt on lt.svr_ip=rt.svr_ip and lt.svr_port=rt.svr_port;

#清理租户资源
--disable_query_log
call oceanbase.drop_tenant_force('tenant_memory_info_t1');
call oceanbase.drop_tenant_force('tenant_memory_info_t2');
--enable_query_log

--disable_query_log
--disable_result_log
sleep 20;
--enable_result_log
--enable_query_log

####case: 验证虚拟表不存在删除的租户信息(cannot be done)
##sleep 10;
##select distinct tenant_id from __all_virtual_memory_info where tenant_id not in (select tenant_id from __all_tenant) and tenant_id>1000;

## test calculation
# expect 10 lines of all 1's
select svr_ip = host_ip(), svr_port=rpc_port(), hold/1024/1024 > 0 from __all_virtual_memory_info where svr_ip = host_ip() and  svr_port = rpc_port() and hold > 0 limit 10;

# fix bug:
# 《虚拟表指定不存在的svr_ip, svr_port 查询报错 -4018》
select * from gv$ob_memory where svr_ip = "111.222.111.222" and svr_port = 12345;
explain select * from gv$ob_memory where svr_ip = "111.222.111.222" and svr_port = 12345;
select * from __all_virtual_memory_info where svr_ip = "111.222.111.222" and svr_port = 12345;
explain select * from __all_virtual_memory_info where svr_ip = "111.222.111.222" and svr_port = 12345;

##还原配置
--enable_abort_on_error
--enable_warnings
