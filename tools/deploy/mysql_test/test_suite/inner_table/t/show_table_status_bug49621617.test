#owner : dingjincheng.djc
#owner group : SQL1
#description : test show table status
#tags: inner_table

--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int);
insert into t1 values(1,2),(2,2),(3,3);
create table t2(c1 int, c2 int);
call dbms_stats.gather_table_stats('TEST','T1');
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status;

## clean up
drop table t1;
drop table t2;
