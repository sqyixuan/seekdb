--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : bin.lb
#owner group : PROXY
#description : 测试虚拟表__all_virtual_proxy_sys_variable

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_abort_on_error
--disable_warnings
#检查表结构
desc oceanbase.__all_virtual_proxy_sys_variable;

--disable_result_log

#login into the sys tenant
#connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);

#get variable count
let $obs_num_1 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_sys_variable where tenant_id = 1,cnt, 1);
let $obs_num_2 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_proxy_sys_variable,cnt, 1);

--enable_result_log
if ($obs_num_1 == $obs_num_2)
{
--echo variable count in __all_virtual_proxy_sys_variable is ok;
}

# value compare
let $old_v = query_get_value(select value from oceanbase.__all_virtual_sys_variable where name like 'ob_trx_timeout' and tenant_id = 1, value,1);

set ob_trx_timeout=200000000;
let $v = query_get_value(select value from oceanbase.__all_virtual_proxy_sys_variable where name='ob_trx_timeout', value,1);
if ($v == 200000000)
{
--echo variable value is ok after set;
}

#recover
eval set ob_trx_timeout=$old_v;
--enable_abort_on_error
--enable_warnings





