# owner: dingjincheng.djc
# owner group: sql1
# description: test parameter default value
--result_format 4
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
#connect (oracle,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);

--echo connect sys tenant
connection sys; 

--echo -------------------test new column: default_value, isdfault-------------------
desc oceanbase.__all_virtual_sys_parameter_stat;
desc oceanbase.__all_virtual_tenant_parameter_stat;
desc oceanbase.gv$ob_parameters;
desc oceanbase.v$ob_parameters;
select name, value,default_value,isdefault from oceanbase.__all_virtual_sys_parameter_stat where name = '_obkv_feature_mode';
select name, value,default_value,isdefault from oceanbase.__all_virtual_tenant_parameter_stat where name = '_obkv_feature_mode';
select name, value,default_value,isdefault from oceanbase.__all_virtual_sys_parameter_stat where name = '_obkv_feature_mode';
select name, value,default_value,isdefault from oceanbase.__all_virtual_tenant_parameter_stat where name = '_obkv_feature_mode';

--echo -------------------test invisible parameter can be shown when is not default value-------------------
alter system set _parallel_min_message_pool = "32M";#32M is not default value
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters like "_parallel_min_message_pool";
alter system set _parallel_min_message_pool = "16M";#16M is not default value
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters like "_parallel_min_message_pool";

--echo -------------------test v\$ob_parameters-------------------
let $sys_pm = '7s';
eval alter system set max_stale_time_for_weak_consistency = $sys_pm tenant = sys;
while($v1_sys != 1)
{
  sleep 1;

  let $v1_sys = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = 1 and VALUE= $sys_pm) T2", v, 1);
}
eval select distinct value, default_value,isdefault from V\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;

--echo -------------------test gv\$ob_parameters-------------------
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='sys', tenant_id, 1);
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='sys', tenant_id, 1);
let $mysql_pm = '9s';
eval alter system set max_stale_time_for_weak_consistency = $mysql_pm tenant = sys;
let $oracle_pm = '8s';
eval alter system set max_stale_time_for_weak_consistency = $oracle_pm tenant = sys;
let $sys_pm = '7s';
eval alter system set max_stale_time_for_weak_consistency = $sys_pm tenant = sys;

--echo to ensure max_stale_time_for_weak_consistency fresh on every observer
let $v1_mysql=0;
let $v1_oracle=0;
let $v1_sys=0;
while($v1_mysql != 1)
{
  sleep 1;

  let $v1_mysql = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = $mysql_tenant_id and VALUE= $mysql_pm) T2", v, 1);
}
while($v1_oracle != 1)
{
  sleep 1;

  let $v1_oracle = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = $oracle_tenant_id and VALUE= $oracle_pm) T2", v, 1);

}
while($v1_sys != 1)
{
  sleep 1;

  let $v1_sys = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = 1 and VALUE= $sys_pm) T2", v, 1);
}
eval select distinct value, default_value,isdefault from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;
eval select distinct value, default_value,isdefault from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = $mysql_tenant_id;
eval select distinct value, default_value,isdefault from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = $oracle_tenant_id;

