--echo
--echo // check index
explain select trace_id from oceanbase.__all_virtual_sql_audit where tenant_id = 1002 and request_id = 1;

##打开审计开关
alter system set enable_sql_audit=false;
sleep 1;
alter system flush sql audit global;
## alter system set_tp tp_name = ERRSIM_BEGIN_COMMIT_OPT, error_code = 1234, frequency = 1;
alter system set enable_sql_audit=true;
sleep 1;

##测试 begin、commit、rollback 语句统计功能
begin;
commit;
rollback;
/*+ QUERY_TIMEOUT(100000000) */ BEGIN;
/*+ QUERY_TIMEOUT(100000000) */ COMMIT;
/*+ QUERY_TIMEOUT(100000000) */ ROLLBACK;
select sql_id, stmt_type, ret_code, expected_worker_count, used_worker_count, query_sql from oceanbase.__all_virtual_sql_audit where is_inner_sql = 0 limit 10;
