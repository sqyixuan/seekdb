--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : xiaoyi.xy
#owner group : SQL1
# tags: optimizer
#description : 测试SQL审计表 __all_virtual_sql_audit


##修改配置
--disable_abort_on_error
--disable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

##检查表结构
desc oceanbase.__all_virtual_sql_audit;

##check plan

## this is the SQL for OCP
explain select /*+QUERY_TIMEOUT(100000000)*/request_id, concat(client_ip, ':', client_port) as client_port, user_name, sql_id, query_sql, request_time, elapsed_time, tenant_name, affected_rows, tenant_id, is_inner_sql, ret_code, EVENT, P1TEXT, P1, P2TEXT, P2, P3TEXT, P3, WAIT_CLASS_ID, WAIT_CLASS, STATE, WAIT_TIME_MICRO, TOTAL_WAIT_TIME_MICRO, TOTAL_WAITS from oceanbase.GV$OB_SQL_AUDIT where request_id > '1000' limit 20000;

## expect to do reverse scan
explain select max(request_id) from oceanbase.__all_virtual_sql_audit where tenant_id=1002;
explain select min(request_id) from oceanbase.__all_virtual_sql_audit where tenant_id=1002;

