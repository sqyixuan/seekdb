--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : peihan.dph
#owner group : sql3 
#description : 测试虚拟表__all_virtual_dtl_channel;__all_virtual_dtl_memory;

--disable_abort_on_error
--disable_warnings

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection sysc;

#检查表结构
use oceanbase;
desc __all_virtual_dtl_channel;
desc __all_virtual_dtl_memory;

#查询
select case when  count(*) > 0 then 0 else 0 end c0 from __all_virtual_dtl_channel;
select case when  count(*) > 0 then 0 else 0 end c1 from __all_virtual_dtl_memory;

--enable_abort_on_error
--enable_warnings

