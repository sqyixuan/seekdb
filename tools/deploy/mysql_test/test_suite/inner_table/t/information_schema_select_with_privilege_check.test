--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhuangyifeng.zyf
# owner group: SQL1
# description: user needs proper privileges to retrieve data from information_schema
# 备注: information_schema 的某些表中的数据需要用户有相应的库、表级权限才能访问, 否则可能产生信息泄露

--disable_query_log
--disable_result_log
drop database if exists test_0;
create database test_0;
drop database if exists test;
create database test;
use test;
drop user if exists foo;
create user foo;

grant all on test_0.* to foo;
--enable_query_log
--enable_result_log

--result_format 4

# === PARAMETERS ===
connection default;
--disable_warnings
drop function if exists my_function;
drop function if exists my_function2;
--enable_warnings
DELIMITER $$;
CREATE FUNCTION my_function (func_args_1 INT) RETURNS INT DETERMINISTIC 
BEGIN
RETURN 1;
END
$$
DELIMITER ;$$
DELIMITER $$;
CREATE FUNCTION my_function2 (func_args_1 INT) RETURNS INT DETERMINISTIC 
BEGIN
RETURN 1;
END
$$
DELIMITER ;$$
# 当前用户可以查询到 my_function
SELECT SPECIFIC_NAME, PARAMETER_NAME, DATA_TYPE FROM information_schema.PARAMETERS WHERE SPECIFIC_SCHEMA = 'test';
# foo 用户无法查询到 my_function
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT SPECIFIC_NAME, PARAMETER_NAME, DATA_TYPE FROM information_schema.PARAMETERS WHERE SPECIFIC_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户赋予 my_function 的执行权限, 则 foo 用户可以查看 my_function 函数, 但是仍然看不到 my_function2
connection default;
grant execute on procedure test.my_function to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT SPECIFIC_NAME, PARAMETER_NAME, DATA_TYPE FROM information_schema.PARAMETERS WHERE SPECIFIC_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke execute on *.* from foo;
drop function my_function;
drop function my_function2;

# === ROUTINE ===
connection default;
--disable_warnings
DROP FUNCTION IF EXISTS my_function;
DROP FUNCTION IF EXISTS my_function2;
--enable_warnings
DELIMITER $$;
CREATE FUNCTION my_function (func_args_1 INT) RETURNS INT DETERMINISTIC 
BEGIN
RETURN 1;
END
$$
DELIMITER ;$$
DELIMITER $$;
CREATE FUNCTION my_function2 (func_args_1 INT) RETURNS INT DETERMINISTIC 
BEGIN
RETURN 1;
END
$$
DELIMITER ;$$
# 当前用户可以查到 my_function, my_function2 函数
SELECT ROUTINE_NAME, ROUTINE_TYPE, ROUTINE_DEFINITION FROM information_schema.ROUTINES WHERE ROUTINE_SCHEMA = 'test';
# foo 用户不能查到任何函数
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT ROUTINE_NAME, ROUTINE_TYPE, ROUTINE_DEFINITION FROM information_schema.ROUTINES WHERE ROUTINE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户赋予 my_function 的执行权限, 则 foo 用户可以查看 my_function 函数, 但是仍然看不到 my_function2
connection default;
grant execute on procedure test.my_function to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT ROUTINE_NAME, ROUTINE_TYPE, ROUTINE_DEFINITION FROM information_schema.ROUTINES WHERE ROUTINE_SCHEMA = 'test';
disconnect conn_foo;
connection default;
revoke execute on *.* from foo;
DROP FUNCTION my_function;
DROP FUNCTION my_function2;

# === VIEW_TABLE_USAGE ===
connection default;
--disable_warnings
drop table if exists tbl2;
drop view if exists my_view;
drop view if exists my_view2;
--enable_warnings
CREATE TABLE tbl2(my_2_col VARCHAR(255));
CREATE VIEW my_view AS SELECT * FROM tbl2;
CREATE VIEW my_view2 AS SELECT * FROM tbl2;
# 当前用户可以查询到 my_view, my_view2
SELECT VIEW_NAME, TABLE_NAME FROM information_schema.VIEW_TABLE_USAGE WHERE TABLE_SCHEMA = 'test';
# foo 用户无法查询到 my_view, my_view2
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT VIEW_NAME, TABLE_NAME FROM information_schema.VIEW_TABLE_USAGE WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户赋予 my_view 的查询权限，则 foo 用户可以看到 my_view
connection default;
grant select on test.my_view to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT VIEW_NAME, TABLE_NAME FROM information_schema.VIEW_TABLE_USAGE WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.my_view from foo;
drop view my_view;
drop view my_view2;
drop table tbl2;

# === STATISTICS ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
--enable_warnings
CREATE TABLE tbl1 ( my_1_col INT, my_2_col VARCHAR(255) );
CREATE INDEX my_index ON tbl1 (my_1_col);
CREATE TABLE tbl2 ( my_1_col INT, my_2_col VARCHAR(255) );
CREATE INDEX my_index2 ON tbl2 (my_1_col);
# 当前用户可以查询到 my_index, my_index2
SELECT TABLE_NAME, INDEX_NAME FROM information_schema.STATISTICS WHERE TABLE_SCHEMA = 'test';
# foo 用户无法查询到 my_index, my_index2
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, INDEX_NAME FROM information_schema.STATISTICS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以看到 my_index
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, INDEX_NAME FROM information_schema.STATISTICS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.tbl1 from foo;
drop table tbl1;
drop table tbl2;

# === PARTITIONS ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
--enable_warnings
CREATE TABLE tbl1 ( my_1_col INT, my_2_col VARCHAR(255) );
CREATE TABLE tbl2 ( my_2_col VARCHAR(255) );
# 当前用户可以查询到 tbl1, tbl2
SELECT TABLE_SCHEMA, TABLE_NAME FROM information_schema.PARTITIONS WHERE TABLE_SCHEMA = 'test';
# foo 用户无法查询到 tbl1, tbl2
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_SCHEMA, TABLE_NAME FROM information_schema.PARTITIONS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以看到 tbl1
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_SCHEMA, TABLE_NAME FROM information_schema.PARTITIONS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl2 的查询权限, 则 foo 用户可以看到 tbl2
connection default;
grant select on test.tbl2 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_SCHEMA, TABLE_NAME FROM information_schema.PARTITIONS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.tbl1 from foo;
revoke all on test.tbl2 from foo;
drop table tbl1;
drop table tbl2;

# === TABLE_CONSTRAINTS ===
connection default;
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (c1 int primary key, c2 int unique);
create table tbl2 (c1 int primary key, c2 int unique);
# 当前用户可以查询到 tbl1, tbl2 的表约束
SELECT TABLE_NAME, CONSTRAINT_TYPE FROM information_schema.TABLE_CONSTRAINTS WHERE TABLE_SCHEMA = 'test';
# foo 用户无法查询到 tbl1, tbl2 的表约束
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, CONSTRAINT_TYPE FROM information_schema.TABLE_CONSTRAINTS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以看到 tbl1 的表约束
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, CONSTRAINT_TYPE FROM information_schema.TABLE_CONSTRAINTS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.tbl1 from foo;
drop table tbl1;
drop table tbl2;

# === COLUMN_PRIVILEGES ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
drop user if exists bar;
--enable_warnings
create user bar identified by '';
create table tbl1(c1 int, c2 int);
create table tbl2(c1 int, c2 int);
grant select(c1) on test.tbl1 to bar;
grant select(c1) on test.tbl2 to bar;
# 当前用户可以查到 bar 用户在 tbl1, tbl2 上的列权限
SELECT GRANTEE, TABLE_NAME, COLUMN_NAME, PRIVILEGE_TYPE, IS_GRANTABLE FROM information_schema.COLUMN_PRIVILEGES WHERE TABLE_SCHEMA = 'test';
# foo 用户不能查到 bar 用户在 tbl1 上的列权限
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT GRANTEE, TABLE_NAME, COLUMN_NAME, PRIVILEGE_TYPE, IS_GRANTABLE FROM information_schema.COLUMN_PRIVILEGES WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, foo 用户仍然不能看到 bar 用户在 tbl1, tbl2 上的列权限
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT GRANTEE, TABLE_NAME, COLUMN_NAME, PRIVILEGE_TYPE, IS_GRANTABLE FROM information_schema.COLUMN_PRIVILEGES WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户级的查询权限, 则 foo 用户可以查到 bar 用户在 tbl1, tbl2 上的列权限
connection default;
grant select on *.* to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT GRANTEE, TABLE_NAME, COLUMN_NAME, PRIVILEGE_TYPE, IS_GRANTABLE FROM information_schema.COLUMN_PRIVILEGES WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on *.* from foo;
revoke all on test.tbl1 from foo;
drop table tbl1;
drop user bar;

# === REFERENTIAL_CONSTRAINTS ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
drop table if exists tbl3;
--enable_warnings
create table tbl1(c1 int primary key);
create table tbl2(c3 int, c4 int, foreign key (c3) references tbl1(c1));
create table tbl3(c5 int, c6 int, foreign key (c6) references tbl1(c1));
# 当前用户可以查到 tbl2, tbl3 上的外键约束
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_SCHEMA = 'test';
# foo 用户不能查到 tbl2, tbl3 上的外键约束
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl2 的查询权限, 则 foo 用户可以查到 tbl2 上的外键约束
connection default;
grant select on test.tbl2 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.REFERENTIAL_CONSTRAINTS WHERE CONSTRAINT_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.tbl2 from foo;
drop table tbl2;
drop table tbl3;
drop table tbl1;

# === CHECK_CONSTRAINTS ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
--enable_warnings
create table tbl1(c1 int, c2 int, check (c2 > 0));
create table tbl2(c1 int, c2 int, check (c2 > 0));
# 当前用户可以查到 tbl1, tbl2 上的 check 约束
SELECT CHECK_CLAUSE FROM information_schema.CHECK_CONSTRAINTS WHERE CONSTRAINT_NAME LIKE 'tbl1_%' or CONSTRAINT_NAME LIKE 'tbl2_%';
# foo 用户不能查到 tbl1, tbl2 上的 check 约束
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT CHECK_CLAUSE FROM information_schema.CHECK_CONSTRAINTS WHERE CONSTRAINT_NAME LIKE 'tbl1_%' or CONSTRAINT_NAME LIKE 'tbl2_%';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以查到 tbl1 上的 check 约束
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT CHECK_CLAUSE FROM information_schema.CHECK_CONSTRAINTS WHERE CONSTRAINT_NAME LIKE 'tbl1_%' or CONSTRAINT_NAME LIKE 'tbl2_%';
disconnect conn_foo;

connection default;
revoke all on test.tbl1 from foo;
drop table tbl1;
drop table tbl2;

# === KEY_COLUMN_USAGE ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
drop table if exists tbl3;
--enable_warnings
create table tbl1(c1 int primary key);
create table tbl2(c3 int, c4 int, foreign key (c3) references tbl1(c1));
create table tbl3(c3 int, c4 int, foreign key (c3) references tbl1(c1));
# 当前用户可以查到 tbl1 上的主键的约束
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.KEY_COLUMN_USAGE WHERE CONSTRAINT_SCHEMA = 'test';
show grants for foo;
# foo 用户不能查到 tbl1 上的主键的约束
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.KEY_COLUMN_USAGE WHERE CONSTRAINT_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl2 的查询权限, 则 foo 用户可以查到 tbl2 上的外键约束
connection default;
grant select on test.tbl2 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.KEY_COLUMN_USAGE WHERE CONSTRAINT_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以查到 tbl1 上的主键约束
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, REFERENCED_TABLE_NAME FROM information_schema.KEY_COLUMN_USAGE WHERE CONSTRAINT_SCHEMA = 'test';
disconnect conn_foo;


connection default;
revoke all on test.tbl1 from foo;
revoke all on test.tbl2 from foo;
drop table tbl2;
drop table tbl3;
drop table tbl1;

# === ST_GEOMETRY_COLUMNS ===
connection default;
--disable_warnings
drop table if exists tbl1;
drop table if exists tbl2;
--enable_warnings
create table tbl1(id int primary key auto_increment, g1 geometry);
create table tbl2(id int primary key auto_increment, g1 geometry);
# 当前用户可以查到 tbl1, tbl2 上的 geometry 列
SELECT TABLE_NAME, COLUMN_NAME FROM information_schema.ST_GEOMETRY_COLUMNS WHERE TABLE_SCHEMA = 'test';
# foo 用户不能查到 tbl1, tbl2 上的 geometry 列
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, COLUMN_NAME FROM information_schema.ST_GEOMETRY_COLUMNS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;
# 给 foo 用户 tbl1 的查询权限, 则 foo 用户可以查到 tbl1 上的 geometry 列
connection default;
grant select on test.tbl1 to foo;
show grants for foo;
connect (conn_foo,$OBMYSQL_MS0,foo,,test_0,$OBMYSQL_PORT);
SELECT TABLE_NAME, COLUMN_NAME FROM information_schema.ST_GEOMETRY_COLUMNS WHERE TABLE_SCHEMA = 'test';
disconnect conn_foo;

connection default;
revoke all on test.tbl1 from foo;
drop table tbl1;
drop table tbl2;


connection default;
drop database test_0;
drop user foo;
