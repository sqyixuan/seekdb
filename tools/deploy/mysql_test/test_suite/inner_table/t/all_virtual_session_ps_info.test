--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: gongyusen.gys
#owner group : SQL2
# tags: inner_table
#description : test oceanbase.__all_virtual_session_ps_info
 
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush ps cache global;
 
connection default;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
 
create table t1(a int, b int);
 
PREPARE q FROM 'select * from t1 where a=? and b>?';
 
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.__all_virtual_session_ps_info where CHECKSUM = 3179570918;
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.GV$OB_SESSION_PS_INFO where CHECKSUM = 3179570918;
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.V$OB_SESSION_PS_INFO where CHECKSUM = 3179570918;
 
DEALLOCATE PREPARE q;
 
select * from oceanbase.__all_virtual_session_ps_info;
select * from oceanbase.GV$OB_SESSION_PS_INFO;
select * from oceanbase.V$OB_SESSION_PS_INFO;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
 
disconnect default;
