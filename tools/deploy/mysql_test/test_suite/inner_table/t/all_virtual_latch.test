--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : link.zt
#owner group : SQL1
#description : 测试虚拟表__all_virtual_latch

##修改配置
--disable_abort_on_error
--disable_warnings
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_obsys;

use oceanbase;
desc __all_virtual_latch;
--disable_result_log
select * from __all_virtual_latch;
--enable_result_log

select latch_id>=0, name is not null from __all_virtual_latch limit 1;
select count(1)>0 from __all_virtual_latch;
select NAME is not null from gv$latch limit 1;
select NAME is not null from v$latch limit 1;
##还原配置
--enable_abort_on_error
--enable_warnings
disconnect my_obsys;
