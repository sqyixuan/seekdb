# owner: dingjincheng.djc
# owner group: sql1
# description: test sys_var default value
--result_format 4
 
 
--echo -------------------test normal tenant-------------------
connect (conn_admin,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
connection conn_admin;
--echo ------check new schema
desc oceanbase.__all_virtual_sys_variable_default_value;
desc oceanbase.DBA_OB_SYS_VARIABLES;

--echo ------check __all_virtual_sys_variable_default_value/DBA_OB_SYS_VARIABLES is consistent with __all_sys_variable
let $count1 = query_get_value(select count(1) as cnt from oceanbase.__all_sys_variable,cnt,1);
let $count2 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_sys_variable_default_value,cnt,1);
if ($count1 == $count2)
{
  select "__all_sys_variable is the same count as __all_virtual_sys_variable_default_value" as result;
}
let $count3 = query_get_value(select count(1) as cnt from oceanbase.DBA_OB_SYS_VARIABLES,cnt,1);
if ($count1 == $count3)
{
  select "__all_sys_variable is the same count as DBA_OB_SYS_VARIABLES" as result;
}

--echo ------test isdefault value
--echo ----bool type:autocommit 
select name,value from oceanbase.__all_sys_variable where name = 'autocommit';
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'autocommit';
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'autocommit';#isdefault=YES
set global autocommit = 0;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'autocommit';#isdefault=NO
set global autocommit = 1;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'autocommit';#isdefault=YES

--echo ----int type:character_set_client 
select name,value from oceanbase.__all_sys_variable where name = 'character_set_client';
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'character_set_client';
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'character_set_client';#isdefault=YES
set global character_set_client = 8;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'character_set_client';#isdefault=NO
set global character_set_client = 45;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'character_set_client';#isdefault=YES

--echo ----varchar type:transaction_isolation 
select name,value from oceanbase.__all_sys_variable where name = 'transaction_isolation';
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'transaction_isolation';
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'transaction_isolation';#isdefault=YES
set global transaction_isolation = 'REPEATABLE-READ';
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'transaction_isolation';#isdefault=NO
set global transaction_isolation = 'READ-COMMITTED';
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'transaction_isolation';#isdefault=YES

--echo ----numeric type:sql_throttle_rt 
select name,value from oceanbase.__all_sys_variable where name = 'sql_throttle_rt';
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'sql_throttle_rt';
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'sql_throttle_rt';#isdefault=YES
set global sql_throttle_rt = 1;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'sql_throttle_rt';#isdefault=NO
set global sql_throttle_rt = -1;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'sql_throttle_rt';#isdefault=YES

--echo ----enum type:ob_read_consistency 
select name,value from oceanbase.__all_sys_variable where name = 'ob_read_consistency';
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'ob_read_consistency';
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'ob_read_consistency';#isdefault=YES
set global ob_read_consistency = 'WEAK';
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'ob_read_consistency';#isdefault=NO
set global ob_read_consistency = 'STRONG';
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'ob_read_consistency';#isdefault=YES

--echo connect sys tenant
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys; 
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='oracle', tenant_id, 1);

--echo -------------------test sys tenant-------------------
--echo ------check new schema
desc oceanbase.__all_virtual_sys_variable_default_value;
desc oceanbase.DBA_OB_SYS_VARIABLES;
desc oceanbase.CDB_OB_SYS_VARIABLES;

--echo ------test DBA_OB_SYS_VARIABLES

let $count3 = query_get_value(select count(1) as cnt from oceanbase.__all_sys_variable,cnt,1);
let $count4 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_sys_variable_default_value,cnt,1);
if ($count3 == $count4)
{
  select "__all_sys_variable is the same count as __all_virtual_sys_variable_default_value" as result;
}
let $count5 = query_get_value(select count(1) as cnt from oceanbase.DBA_OB_SYS_VARIABLES,cnt,1);
if ($count3 == $count5)
{
  select "__all_sys_variable is the same count as DBA_OB_SYS_VARIABLES" as result;
}

--echo ------test CDB_OB_SYS_VARIABLES

--echo ----bool type:autocommit 
--replace_column 1 tenant_id
eval select tenant_id,name,value from oceanbase.CDB_OB_SYS_VARIABLES where name = 'autocommit' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);
set global autocommit = 0;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'autocommit' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=NO
set global autocommit = 1;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'autocommit'  and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=YES

--echo ----int type:character_set_client 
--replace_column 1 tenant_id
eval select tenant_id,name,value from oceanbase.CDB_OB_SYS_VARIABLES where name = 'character_set_client' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);
set global character_set_client = 8;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'character_set_client' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=NO
set global character_set_client = 45;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'character_set_client' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=YES

--echo ----varchar type:transaction_isolation 
--replace_column 1 tenant_id
eval select tenant_id,name,value from oceanbase.CDB_OB_SYS_VARIABLES where name = 'transaction_isolation' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);
set global transaction_isolation = 'REPEATABLE-READ';
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'transaction_isolation' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=NO
set global transaction_isolation = 'READ-COMMITTED';
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'transaction_isolation' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=YES

--echo ----numeric type:sql_throttle_rt 
--replace_column 1 tenant_id
eval select tenant_id,name,value from oceanbase.CDB_OB_SYS_VARIABLES where name = 'sql_throttle_rt' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);
set global sql_throttle_rt = 1;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'sql_throttle_rt' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=NO
set global sql_throttle_rt = -1;
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'sql_throttle_rt' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=YES

--echo ----enum type:ob_read_consistency 
--replace_column 1 tenant_id
eval select tenant_id,name,value from oceanbase.CDB_OB_SYS_VARIABLES where name = 'ob_read_consistency' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);
set global ob_read_consistency = 'WEAK';
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'ob_read_consistency' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=NO
set global ob_read_consistency = 'STRONG';
--replace_column 1 tenant_id
eval select tenant_id,name,value,default_value,isdefault from oceanbase.CDB_OB_SYS_VARIABLES where name = 'ob_read_consistency' and tenant_id in (1, $mysql_tenant_id, $oracle_tenant_id);#isdefault=YES

disconnect sys;