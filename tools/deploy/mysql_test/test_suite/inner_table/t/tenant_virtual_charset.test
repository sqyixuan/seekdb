#owner group: SQL4
#tags: virtual table
##
## description:测试tenant_virutal_charset & tenant_virtual_collation
##
##################################### create tenant #####################################
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_warnings
--disable_query_log
--disable_result_log
#call oceanbase.drop_tenant_force('yts_tt');
#call oceanbase.create_mysql_tenant_mini('yts_tt');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log
--enable_warnings

disconnect obsys;
connection default;
connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);

##################### test for query ####################
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select * from oceanbase.__tenant_virtual_collation;
select * from oceanbase.__tenant_virtual_charset;
select collation, charset from oceanbase.__tenant_virtual_collation where collation like "%utf%";
select charset, default_collation from oceanbase.__tenant_virtual_charset where charset like "%utf%";
disconnect obsys;
connection default;

##################### test for show ####################
show collation;
show charset;
show collation like "%utf%";
show charset like "%utf%";

##################### test for view ####################
select * from information_schema.CHARACTER_SETS;
select * from information_schema.COLLATIONS;
select * from information_schema.COLLATION_CHARACTER_SET_APPLICABILITY;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
#call oceanbase.drop_tenant_force('yts_tt');
--enable_query_log
disconnect obsys;
