--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : jingyan.kfy
#owner group : transaction
#description : test all_virtual_tenant_memstore_info

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

select 1 as tenant_id, table_name from oceanbase.__all_virtual_table where table_name = '__all_virtual_tenant_memstore_info';
desc oceanbase.__all_virtual_tenant_memstore_info;
select active_span>0,memstore_used>0,freeze_trigger>0,memstore_limit>0 from oceanbase.__all_virtual_tenant_memstore_info limit 1;
select count(1)>0 from oceanbase.__all_virtual_tenant_memstore_info;

disconnect obsys;
connection default;

