--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : bin.lb
#owner group : proxy
#description : 测试虚拟表__all_virtual_proxy_server_stat

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_abort_on_error
--disable_warnings

#检查表结构
desc oceanbase.__all_virtual_proxy_server_stat;

--disable_result_log

#server count
let $server_num_1 = query_get_value(select count(1) as cnt from oceanbase.__all_server, cnt, 1);
let $server_num_2 = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_proxy_server_stat, cnt, 1);

if ($server_num_1 == $server_num_2)
{
--echo server count in __all_virtual_proxy_server_stat is ok;
}

#各种查询方式
select svr_ip,svr_port,zone,start_service_time,status from oceanbase.__all_virtual_proxy_server_stat where role=;
select zone,status from oceanbase.__all_virtual_proxy_server_stat where status like '%active%';
select zone,count(*) from oceanbase.__all_virtual_proxy_server_stat group by zone;

#还原配置
--enable_abort_on_error
--enable_warnings
