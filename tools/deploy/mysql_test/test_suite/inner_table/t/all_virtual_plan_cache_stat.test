--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner       : xiaoyi.xy
#owner group : SQL1
# tags: optimizer
#description : 测试虚拟表__all_virtual_plan_cache_stat

--disable_abort_on_error
--disable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#检查表结构
desc oceanbase.__all_virtual_plan_cache_stat;

--enable_query_log
alter system flush plan cache;

#let $sys_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
#let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);

--echo
#tenant_id是变化的，为保证结果稳定，查询语句不能显示，
--disable_query_log
--enable_result_log
--echo //expect 2;
#eval select count(1) from (select tenant_id from oceanbase.__all_virtual_plan_cache_stat where tenant_id in ($sys_id, $mysql_tenant_id) group by tenant_id) as t;

#sys tenant can see all tenant's content
--echo //expect 2;
#eval select count(1) from (select tenant_id from oceanbase.GV\$OB_PLAN_CACHE_STAT where tenant_id in ($sys_id, $mysql_tenant_id) group by tenant_id) as t;

--enable_query_log
--enable_result_log
# index
--echo //expect using i1
explain basic select * from oceanbase.__all_virtual_plan_cache_stat;

--echo //expect using primary
# explain basic select * from oceanbase.__all_virtual_plan_cache_stat where svr_ip=host_ip() and svr_port=rpc_port() and tenant_id > 1;

# check if we can select at least one line without giving any predicates
select count(1) from (select * from oceanbase.__all_virtual_plan_cache_stat limit 1) t;

--disable_query_log
--disable_result_log

