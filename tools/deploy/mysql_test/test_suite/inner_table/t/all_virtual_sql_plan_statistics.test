# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试虚拟表__all_virtual_sql_plan_statistics

--disable_warnings
drop table if exists test;
--enable_warnings
##多个连接session。 访问同一个plan;

create table test(c1 int, c2 int);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
select * from test limit 5;
select * from test limit 6;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
let $plan_id = query_get_value(select plan_id from  oceanbase.__all_virtual_plan_stat where statement like 'insert into test values%', plan_id, 1);
disconnect obsys;
connection default;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
select * from test limit 5;
select * from test limit 6;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
select * from test limit 5;
select * from test limit 6;

connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
select * from test limit 5;
select * from test limit 6;

connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
insert into test values(1,2),(3,4),(4,5);
select * from test limit 5;
select * from test limit 6;

--disable_query_log

--enable_query_log


