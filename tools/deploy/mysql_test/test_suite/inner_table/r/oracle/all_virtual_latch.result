use oceanbase;
desc __all_virtual_latch;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO	PRI	NULL	
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
latch_id	bigint(20)	NO	PRI	NULL	
name	varchar(256)	NO		NULL	
addr	varchar(256)	NO		NULL	
level	bigint(20)	NO		NULL	
hash	bigint(20)	NO		NULL	
gets	bigint(20)	NO		NULL	
misses	bigint(20)	NO		NULL	
sleeps	bigint(20)	NO		NULL	
immediate_gets	bigint(20)	NO		NULL	
immediate_misses	bigint(20)	NO		NULL	
spin_gets	bigint(20)	NO		NULL	
wait_time	bigint(20)	NO		NULL	
select * from __all_virtual_latch;
select tenant_id=1, length(svr_ip)>4, svr_port>0, latch_id>=0, name is not null from __all_virtual_latch where tenant_id=1 limit 1;
tenant_id=1	length(svr_ip)>4	svr_port>0	latch_id>=0	name is not null
1	1	1	1	1
select tenant_id=1, length(svr_ip)>4, svr_port>0, latch_id>=0, name is not null from __all_virtual_latch where tenant_id=1 order by svr_ip desc limit 1;
tenant_id=1	length(svr_ip)>4	svr_port>0	latch_id>=0	name is not null
1	1	1	1	1
select count(1)>0 from __all_virtual_latch where svr_ip=host_ip();
count(1)>0
1
select length(SVR_IP)>4,SVR_PORT>0,NAME is not null from gv$latch limit 1;
length(SVR_IP)>4	SVR_PORT>0	NAME is not null
1	1	1
select length(SVR_IP)>4,SVR_PORT>0,NAME is not null from v$latch limit 1;
length(SVR_IP)>4	SVR_PORT>0	NAME is not null
1	1	1
