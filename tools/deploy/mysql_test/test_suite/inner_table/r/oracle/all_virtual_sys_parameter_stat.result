select section,info from oceanbase.__all_virtual_sys_parameter_stat where name like '%major%' group by name;
section	info
daily_merge	the maximum number of kept major versions Range: [1, 16] in integer
daily_merge	the start time of system daily merge procedure. Range: [00:00, 24:00)
observer	post global major freeze when observer memsotre free memory(plus memory hold by frozen memstore and blockcache) reach this limit. Rang:(0，100)limit calc by memory_limit * (1 - system_memory_percentage/100) * global_major_freeze_residual_memory/100
rootservice	specifies whether major_freeze function is turned on. Value:  True:turned on;  False: turned off
show parameters;
show parameters like '%log%';
