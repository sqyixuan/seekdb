sql_text
select 1+1 as xy_sum

select * from xy_tb;
c1	c2
// expect HIT_COUNT = 0
select STATEMENT,HIT_COUNT from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where STATEMENT = 'select * from xy_tb';
STATEMENT	HIT_COUNT
select * from xy_tb	0
drop table xy_tb;
drop database plan_stat_db;
commit;
set autocommit = 1;
set autocommit = 0;
//connect system tenant
drop database if exists plan_stat_sys_db;
create database plan_stat_sys_db;
use plan_stat_sys_db;
create table xy_sys_tb(c1 int primary key, c2 int);
select * from xy_sys_tb;
// expect HIT_COUNT = 0
select statement,hit_count from oceanbase.__all_virtual_plan_stat where statement = 'select * from xy_tb' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = "oracle");
statement	hit_count
select * from xy_tb	0
commit;
set autocommit = 1;
