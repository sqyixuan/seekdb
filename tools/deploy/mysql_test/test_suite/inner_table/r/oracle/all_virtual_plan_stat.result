alter system flush plan cache;
set autocommit = 0;
//connect not system tenant
drop database if exists plan_stat_db;
create database plan_stat_db;
use plan_stat_db;
create table xy_tb(c1 int primary key, c2 int);

//测试sql_id
//test error sql
select abc;
