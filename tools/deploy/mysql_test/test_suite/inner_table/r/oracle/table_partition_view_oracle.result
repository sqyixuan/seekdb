create table t1(v1 int, v2 int) partition by hash(v1) subpartition by range (v2) subpartition template
(
  subpartition p0 values less than(20),
  subpartition p1 values less than(50),
  subpartition p2 values less than(90)
) partitions 5;

create table t2(c1 raw(10), c2 raw(10)) partition by hash(c1) subpartition by list(c2) subpartition template
(
  subpartition p0 values('10', '11', '12'),
  subpartition p1 values('13', '14', '15'),
  subpartition p2 values('16', '17', '18')
) partitions 3;

