drop user yishen_view2 cascade;
create user yishen_view2 identified by 123;

grant all on *.* to yishen_view2 with grant option;
grant dba to yishen_view2;



create table t1(v1 int, v2 int) partition by hash(v1) subpartition by range (v2) subpartition template
(
  subpartition p0 values less than(20),
  subpartition p1 values less than(50),
  subpartition p2 values less than(90)
) partitions 5;

create table t2(c1 raw(10), c2 raw(10)) partition by hash(c1) subpartition by list(c2) subpartition template
(
  subpartition p0 values('10', '11', '12'),
  subpartition p1 values('13', '14', '15'),
  subpartition p2 values('16', '17', '18')
) partitions 3;

create table t_6C(c number, c2 int, c3 varchar(10))
partition by range(c,c2,c3)
(
      partition p1 values less than(10.2, 10, 'AAAA'),
      partition p2 values less than(20.2, 20, 'DDDD'),
      partition p3 values less than(120.2, 120, 'M'),
      partition p4 values less than(520.2, 520, 'ZZZ')
);

create table hp777(c1 varchar(100), c2 varchar(100)) 
partition by list(c1)
(
      partition p1 values ('A', 'B', 'C '),
      partition p2 values ('a', 'A ', 'b ', 'C')
);

create table t_5B (c1 date, c2 timestamp)
partition by list(c1)
subpartition by range(c2)
      subpartition template
      (
            subpartition p0 values less than (TO_DATE('2018-11-13 11:00:01', 'YYYY-MM-DD HH24:MI:SS')),
            subpartition p1 values less than (maxvalue)
      )
(
      partition p0 values (null),
      partition p1 values (TO_DATE('2018-2-2 2:2:2', 'YYYY-MM-DD HH24:MI:SS'))
);

create table hp7(c1 int, c2 int) partition by hash(c1,c2) partitions 2;

