drop user zll_view cascade;
create user zll_view identified by 123;
grant all on *.* to zll_view with grant option;
grant dba to zll_view;



drop table T_RANGE_RANGE;
CREATE TABLE T_RANGE_RANGE (
    C1 NUMBER NOT NULL, 
    C2 NUMBER NOT NULL,
    C3 NUMBER NOT NULL
) 
PARTITION BY RANGE (C2)
SUBPARTITION BY RANGE (C3)
(
    PARTITION P1 VALUES LESS THAN (10)
    (
        SUBPARTITION P1SUB1 VALUES LESS THAN (5),
        SUBPARTITION P1SUB2 VALUES LESS THAN (10)
    ),
    PARTITION P2 VALUES LESS THAN (20)
    (
        SUBPARTITION P2SUB1 VALUES LESS THAN (5),
        SUBPARTITION P2SUB2 VALUES LESS THAN (10)
    ),
    PARTITION P3 VALUES LESS THAN (30)
    (
        SUBPARTITION P3SUB1 VALUES LESS THAN (5),
        SUBPARTITION P3SUB2 VALUES LESS THAN (10)
    )
);
