create table t_hash_list(c1 int, c2 int) partition by hash(c1) subpartition by list(c1)
subpartition template
(
  subpartition p0 values('10', '11', '12'),
  subpartition p1 values('13', '14', '15'),
  subpartition p2 values('16', '17', '18')
) partitions 3;

