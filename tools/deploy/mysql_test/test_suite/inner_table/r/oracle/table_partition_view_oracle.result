drop user renqing_view cascade;
create user renqing_view identified by 123;

grant all on *.* to renqing_view with grant option;
grant dba to renqing_view;



create table t_range (c1 int, c2 int)
partition by range (c1)
(
  partition p0 values less than (6),
  partition p1 values less than (54),
  partition p2 values less than (321)
);

create table t_list (c1 int, c2 int)
partition by list (c1)
(
  partition p0 values (1,2,3),
  partition p1 values (4,5),
  partition p2 values (6)
);

create table t_range_list(c1 int, c2 int)
partition by range(c1)
  subpartition by list (c2) subpartition template
  (
    subpartition p0 values (1,2,3),
    subpartition p1 values (4,5),
    subpartition p2 values (6)
  )
(
  partition p0 values less than (6),
  partition p1 values less than (54),
  partition p2 values less than (321)
);
