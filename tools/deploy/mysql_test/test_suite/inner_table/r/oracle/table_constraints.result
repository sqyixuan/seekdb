drop database if exists hualong;
create database hualong;
use hualong;
create table tc1 (c1 int primary key, c2 int, unique (c1), index idx (c1, c2));
create view v1 as select * from tc1;
create view v2 as select c2 from tc1;
select * from information_schema.table_constraints where table_name = 'tc1';
CONSTRAINT_CATALOG	CONSTRAINT_SCHEMA	CONSTRAINT_NAME	TABLE_SCHEMA	TABLE_NAME	CONSTRAINT_TYPE
def	hualong	PRIMARY	hualong	tc1	PRIMARY KEY
def	hualong	c1	hualong	tc1	UNIQUE
select table_name, constraint_name from information_schema.table_constraints where table_name = 'tc1' ;
table_name	constraint_name
tc1	PRIMARY
tc1	c1
desc information_schema.table_constraints;
Field	Type	Null	Key	Default	Extra
CONSTRAINT_CATALOG	varchar(4096)	NO			
CONSTRAINT_SCHEMA	varchar(128)	NO			
CONSTRAINT_NAME	varchar(128)	NO			
TABLE_SCHEMA	varchar(128)	NO			
TABLE_NAME	varchar(128)	NO			
CONSTRAINT_TYPE	varchar(128)	NO			
alter table tc1 add unique index idx2(c1);
select table_name, constraint_name from information_schema.table_constraints where table_name = 'tc1' ;
table_name	constraint_name
tc1	PRIMARY
tc1	c1
tc1	idx2
create table tc2 (c1 int);
select table_name, constraint_name from information_schema.table_constraints where table_name = 'tc2' ;
table_name	constraint_name
select * from information_schema.table_constraints where CONSTRAINT_SCHEMA = 'hualong';
CONSTRAINT_CATALOG	CONSTRAINT_SCHEMA	CONSTRAINT_NAME	TABLE_SCHEMA	TABLE_NAME	CONSTRAINT_TYPE
def	hualong	PRIMARY	hualong	tc1	PRIMARY KEY
def	hualong	c1	hualong	tc1	UNIQUE
def	hualong	idx2	hualong	tc1	UNIQUE
drop table tc1, tc2;
drop database hualong;
