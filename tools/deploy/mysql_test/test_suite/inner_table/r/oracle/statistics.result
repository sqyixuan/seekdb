COLLATION	varchar(128)	YES		NULL	
CARDINALITY	bigint(20)	YES		NULL	
SUB_PART	varchar(256)	YES		NULL	
PACKED	varchar(256)	YES		NULL	
NULLABLE	varchar(128)	NO			
