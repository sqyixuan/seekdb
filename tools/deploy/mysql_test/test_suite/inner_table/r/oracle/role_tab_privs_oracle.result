result_format: 4
drop user ruoshi1 cascade;
create user ruoshi1 identified by 123;
grant create, drop, alter, select, insert, index on *.* to ruoshi1@'%' with grant option;

drop user ruoshi2 cascade;
create user ruoshi2 identified by 123;
grant select on SYS.* to ruoshi2@'%';
grant all on ruoshi2.* to ruoshi2;



