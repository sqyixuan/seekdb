A
1
2
3
select case when count(*) = 0 then 1 else 0 end from sys.V$OB_SQL_AUDIT where to_char(query_sql) = 'select * from t_sql_audit';
CASEWHENCOUNT(*)=0THEN1ELSE0END
1
select case when count(*) = 0 then 1 else 0 end from sys.V$OB_SQL_AUDIT where to_char(query_sql) = 'insert into t_sql_audit values (1)';
CASEWHENCOUNT(*)=0THEN1ELSE0END
1
select case when count(*) = 0 then 1 else 0 end from sys.V$OB_SQL_AUDIT where to_char(query_sql) = 'insert into t_sql_audit values (2)';
CASEWHENCOUNT(*)=0THEN1ELSE0END
1
select case when count(*) = 0 then 1 else 0 end from sys.V$OB_SQL_AUDIT where to_char(query_sql) = 'insert into t_sql_audit values (3)';
CASEWHENCOUNT(*)=0THEN1ELSE0END
1
select case when elapsed_time > 0 then 1 else 0 end,
case when cpu_time > 0 then 1 else 0 end,
case when avg_exe_usec > 0 then 1 else 0 end,
case when slowest_exe_usec > 0 then 1 else 0 end,
case when cpu_time > 0 then 1 else 0 end from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into t_sql_audit values (?)';
CASEWHENELAPSED_TIME>0THEN1ELSE0END	CASEWHENCPU_TIME>0THEN1ELSE0END	CASEWHENAVG_EXE_USEC>0THEN1ELSE0END	CASEWHENSLOWEST_EXE_USEC>0THEN1ELSE0END	CASEWHENCPU_TIME>0THEN1ELSE0END
1	1	1	1	1
select case when elapsed_time > 0 then 1 else 0 end,
case when cpu_time > 0 then 1 else 0 end,
case when avg_exe_usec > 0 then 1 else 0 end,
case when slowest_exe_usec > 0 then 1 else 0 end,
case when cpu_time > 0 then 1 else 0 end from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from t_sql_audit';
CASEWHENELAPSED_TIME>0THEN1ELSE0END	CASEWHENCPU_TIME>0THEN1ELSE0END	CASEWHENAVG_EXE_USEC>0THEN1ELSE0END	CASEWHENSLOWEST_EXE_USEC>0THEN1ELSE0END	CASEWHENCPU_TIME>0THEN1ELSE0END
1	1	1	1	1
drop table t_sql_audit;
set global ob_enable_sql_audit = true;
