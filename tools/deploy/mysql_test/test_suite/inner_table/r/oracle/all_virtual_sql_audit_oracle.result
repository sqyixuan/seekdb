alter system flush plan cache global;
set global ob_enable_sql_audit = false;
drop table t_sql_audit;
create table t_sql_audit (a int);
insert into t_sql_audit values (1);
insert into t_sql_audit values (2);
insert into t_sql_audit values (3);
select * from t_sql_audit;
