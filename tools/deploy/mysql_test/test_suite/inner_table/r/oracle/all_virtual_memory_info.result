create resource unit if not exists tenant_memory_info_unit max_cpu=1,min_memory='1G',max_memory='1G',max_disk_size='1G',max_iops=1000,max_session_num=1000;
create resource pool if not exists tenant_memory_info_pool1 unit='tenant_memory_info_unit', unit_num=1;
create resource pool if not exists tenant_memory_info_pool2 unit='tenant_memory_info_unit', unit_num=1;
create tenant if not exists tenant_memory_info_t1 RESOURCE_POOL_LIST=('tenant_memory_info_pool1') set ob_tcp_invited_nodes='%';
create tenant if not exists tenant_memory_info_t2 RESOURCE_POOL_LIST=('tenant_memory_info_pool2') set ob_tcp_invited_nodes='%';
use oceanbase;
select tenant_id,table_id,table_name from __all_virtual_table where table_name='__all_virtual_memory_info';
tenant_id	table_id	table_name
1	1099511638813	__all_virtual_memory_info
desc __all_virtual_memory_info;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO	PRI	NULL	
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
mod_id	bigint(20)	NO	PRI	NULL	
mod_type	varchar(256)	NO		NULL	
mod_name	varchar(256)	NO		NULL	
zone	varchar(256)	NO		NULL	
hold	bigint(20)	NO		NULL	
used	bigint(20)	NO		NULL	
count	bigint(20)	NO		NULL	
alloc_count	bigint(20)	NO		NULL	
free_count	bigint(20)	NO		NULL	
