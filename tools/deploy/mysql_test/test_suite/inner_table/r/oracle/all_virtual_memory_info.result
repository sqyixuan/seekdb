count(1)>0
1
select tenant_id,tenant_name,info from __all_tenant where tenant_id in (select tenant_id from __all_virtual_memory_info group by tenant_id) and tenant_name='sys';
tenant_id	tenant_name	info
1	sys	system tenant
select tenant_name from __all_tenant where tenant_id in (select tenant_id from __all_virtual_memory_info group by tenant_id) and tenant_name in ('sys','tenant_memory_info_t1','tenant_memory_info_t2');
tenant_name
sys
tenant_memory_info_t1
tenant_memory_info_t2
select count(1)>0 from __all_server as lt left join (select svr_ip,svr_port from __all_virtual_memory_info group by svr_ip,svr_port) as rt on lt.svr_ip=rt.svr_ip and lt.svr_port=rt.svr_port;
count(1)>0
1
drop view if exists view_tenant_memory_info_1;
create view view_tenant_memory_info_1 as (select tenant_id from __all_virtual_memory_info where mod_type='user' group by tenant_id);
select tenant_id>1 from view_tenant_memory_info_1 order by tenant_id desc limit 2;
tenant_id>1
1
1
drop view if exists view_tenant_memory_info_1;
drop tenant tenant_memory_info_t1 force;
drop tenant tenant_memory_info_t2 force;
drop resource pool tenant_memory_info_pool1;
drop resource pool tenant_memory_info_pool2;
drop resource unit tenant_memory_info_unit;
