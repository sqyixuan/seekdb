use oceanbase;
select count(1) > 0 as result from __all_virtual_obrpc_stat;
result
1
select name_count = index_count, index_count = pcode_count from (select count (distinct pcode_name) as name_count,count (distinct `index`) as index_count,count (distinct pcode) as pcode_count from __all_virtual_obrpc_stat) T;
name_count = index_count	index_count = pcode_count
1	1
select count (distinct pcode) - count (distinct pcode_name, pcode, `index`) as result from __all_virtual_obrpc_stat;
result
0
select count(1) > 0 as result from GV$OB_RPC_OUTGOING;
result
1
select count (distinct pcode) - count (distinct pcode_name, pcode) as result from GV$OB_RPC_OUTGOING;
result
0
select count(1) > 0 as result from v$obrpc_incoming;
result
1
select count (distinct pcode) - count (distinct pcode_name, pcode) as result from v$obrpc_incoming;
result
0
