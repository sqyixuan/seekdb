show create table information_schema.schema_privileges;
Table	Create Table
SCHEMA_PRIVILEGES	CREATE TABLE `SCHEMA_PRIVILEGES` (
  `GRANTEE` varchar(81) NOT NULL DEFAULT '',
  `TABLE_CATALOG` varchar(4096) NOT NULL DEFAULT '',
  `TABLE_SCHEMA` varchar(128) NOT NULL DEFAULT '',
  `PRIVILEGE_TYPE` varchar(64) NOT NULL DEFAULT '',
  `IS_GRANTABLE` varchar(3) NOT NULL DEFAULT ''
) DEFAULT CHARSET = utf8mb4 REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 TABLEGROUP = 'oceanbase'
desc information_schema.schema_privileges;
Field	Type	Null	Key	Default	Extra
GRANTEE	varchar(81)	NO			
TABLE_CATALOG	varchar(4096)	NO			
TABLE_SCHEMA	varchar(128)	NO			
PRIVILEGE_TYPE	varchar(64)	NO			
IS_GRANTABLE	varchar(3)	NO			
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
create user tmp_user_test_user_priv identified by '123';
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
grant select on oceanbase.* to tmp_user_test_user_priv;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
'tmp_user_test_user_priv'@'%'	def	oceanbase	SELECT	NO
revoke select on oceanbase.* from tmp_user_test_user_priv;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
grant select on oceanbase.* to tmp_user_test_user_priv with grant option;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
'tmp_user_test_user_priv'@'%'	def	oceanbase	SELECT	YES
revoke grant option on oceanbase.* from tmp_user_test_user_priv;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
'tmp_user_test_user_priv'@'%'	def	oceanbase	SELECT	NO
revoke all on oceanbase.* from tmp_user_test_user_priv;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
drop user tmp_user_test_user_priv;
select * from information_schema.schema_privileges where grantee like '%tmp_user_test_user_priv%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	PRIVILEGE_TYPE	IS_GRANTABLE
