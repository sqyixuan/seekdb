D3B7A4993928ED7EFBBCE6212D0FAA0B	1
D3B7A4993928ED7EFBBCE6212D0FAA0B	1

// expect same as GV
select sql_id, hit_count from SYS.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from xy_tb';
