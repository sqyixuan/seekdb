
alter system flush plan cache global;
set autocommit = 0;

>>>>>>>>>>>>>>>>>>>>>>>>>>>>DESC GV
desc SYS.GV$OB_PLAN_CACHE_PLAN_STAT;
FIELD	TYPE	NULL	KEY	DEFAULT	EXTRA
TENANT_ID	NUMBER(38)	NO	NULL	NULL	NULL
SVR_IP	VARCHAR2(46)	NO	NULL	NULL	NULL
SVR_PORT	NUMBER(38)	NO	NULL	NULL	NULL
