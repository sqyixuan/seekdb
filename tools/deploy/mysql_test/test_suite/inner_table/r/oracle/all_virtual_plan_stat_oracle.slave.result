insert into xy_tb values (1, 1), (2, 2), (3, 3);
// expect hit_count to be 1
select sql_id, hit_count from SYS.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into xy_tb values (?, ?)';
SQL_ID	HIT_COUNT
027C1C2BEE9F7A01A3E4192AF8A76EBE	0

// expect same as GV
select sql_id, hit_count from SYS.V$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'insert into xy_tb values (?, ?)';
SQL_ID	HIT_COUNT
027C1C2BEE9F7A01A3E4192AF8A76EBE	0

// test select
select * from xy_tb;
select * from xy_tb;

// expect hit_count to be 1
select sql_id, hit_count from SYS.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select * from xy_tb';
