select tenant_id, table_name from oceanbase.__all_virtual_table where table_name = '__all_virtual_tenant_memstore_info';
tenant_id	table_name
1	__all_virtual_tenant_memstore_info
desc oceanbase.__all_virtual_tenant_memstore_info;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO	PRI	NULL	
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
active_memstore_used	bigint(20)	NO		NULL	
total_memstore_used	bigint(20)	NO		NULL	
major_freeze_trigger	bigint(20)	NO		NULL	
memstore_limit	bigint(20)	NO		NULL	
freeze_cnt	bigint(20)	NO		NULL	
select tenant_id>0,svr_ip is not null,svr_port>0,active_memstore_used>0,total_memstore_used>0,major_freeze_trigger>0,memstore_limit>0 from oceanbase.__all_virtual_tenant_memstore_info group by tenant_id asc limit 1;
tenant_id>0	svr_ip is not null	svr_port>0	active_memstore_used>0	total_memstore_used>0	major_freeze_trigger>0	memstore_limit>0
1	1	1	1	1	1	1
select count(1)>0 from oceanbase.__all_virtual_tenant_memstore_info;
count(1)>0
1
