create resource unit if not exists all_virtual_trans_stat_unit max_cpu=1, min_memory='1G',max_memory='1G',max_disk_size='1G',max_iops=1000,max_session_num=1000;
create resource pool if not exists all_virtual_trans_stat_pool1 unit='all_virtual_trans_stat_unit', unit_num=1;
create tenant if not exists all_virtual_trans_stat_tenant1 RESOURCE_POOL_LIST=('all_virtual_trans_stat_pool1') set ob_tcp_invited_nodes='%';
use oceanbase;
desc __all_virtual_trans_stat;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO	PRI	NULL	
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
inc_num	bigint(20)	NO	PRI	NULL	
session_id	bigint(20)	NO		NULL	
proxy_id	varchar(512)	NO		NULL	
trans_type	bigint(20)	NO		NULL	
trans_id	varchar(512)	NO		NULL	
is_exiting	bigint(20)	NO		NULL	
is_readonly	bigint(20)	NO		NULL	
is_decided	bigint(20)	NO		NULL	
active_memstore_version	varchar(64)	NO		NULL	
partition	varchar(64)	NO		NULL	
participants	varchar(1024)	NO		NULL	
autocommit	bigint(20)	NO		NULL	
trans_consistency	bigint(20)	NO		NULL	
ctx_create_time	timestamp(6)	YES		NULL	
expired_time	timestamp(6)	YES		NULL	
refer	bigint(20)	NO		NULL	
sql_no	bigint(20)	NO		NULL	
state	bigint(20)	NO		NULL	
part_trans_action	bigint(20)	NO		NULL	
lock_for_read_retry_count	bigint(20)	NO		NULL	
ctx_addr	bigint(20)	NO		NULL	
set autocommit = 0;
drop table if exists stu;
create table if not exists stu(stu_no int primary key auto_increment, gendar varchar(1));
insert into stu values(NULL, 'm');
insert into stu values(NULL, 'f');
select count(1) > 0 from __all_virtual_trans_stat;
count(1) > 0
1
select count(1) > 0 from (select * from __all_virtual_trans_stat order by inc_num limit 10) as t;
count(1) > 0
1
select count(1) > 0 from __all_virtual_trans_stat where svr_ip in (select svr_ip from __all_server);
count(1) > 0
1
drop view if exists view_trans_stat_1;
create view view_trans_stat_1 as (select * from __all_virtual_trans_stat);
select count(1) >= 0 from view_trans_stat_1 order by inc_num limit 10;
count(1) >= 0
1
commit;
drop table if exists stu;
drop view view_trans_stat_1;
drop tenant all_virtual_trans_stat_tenant1 force;
drop resource pool all_virtual_trans_stat_pool1;
drop resource unit all_virtual_trans_stat_unit;
