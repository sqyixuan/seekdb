create resource unit if not exists gv_election_mem_stat_unit max_cpu=1, min_memory='1G',max_memory='1G',max_disk_size='1G',max_iops=1000,max_session_num=1000;
create resource pool if not exists gv_election_mem_stat_pool unit='gv_election_mem_stat_unit', unit_num=1;
create tenant if not exists gv_election_mem_stat_tenant RESOURCE_POOL_LIST=('gv_election_mem_stat_pool') set ob_tcp_invited_nodes='%';
use oceanbase;
desc __all_virtual_election_mem_stat;
Field	Type	Null	Key	Default	Extra
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
type	varchar(64)	NO	PRI	NULL	
alloc_count	bigint(20)	NO		NULL	
release_count	bigint(20)	NO		NULL	
select count(1) > 0 from __all_virtual_election_mem_stat;
count(1) > 0
1
select count(1) > 0 from (select * from __all_virtual_election_mem_stat order by type limit 10) as t;
count(1) > 0
1
drop view if exists view_election_mem_stat_1;
create view view_election_mem_stat_1 as (select * from __all_virtual_election_mem_stat);
select count(1) > 0 from view_election_mem_stat_1 order by type limit 10;
count(1) > 0
1
commit;
drop view view_election_mem_stat_1;
drop tenant gv_election_mem_stat_tenant force;
drop resource pool gv_election_mem_stat_pool;
drop resource unit gv_election_mem_stat_unit;
