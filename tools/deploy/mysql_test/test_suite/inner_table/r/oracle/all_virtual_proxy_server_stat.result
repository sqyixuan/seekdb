desc oceanbase.__all_virtual_proxy_server_stat;
Field	Type	Null	Key	Default	Extra
svr_ip	varchar(46)	NO	PRI	NULL	
svr_port	bigint(20)	NO	PRI	NULL	
zone	varchar(128)	NO		NULL	
start_service_time	bigint(20)	NO		NULL	
stop_time	bigint(20)	NO		NULL	
status	varchar(64)	NO		NULL	
server count in __all_virtual_proxy_server_stat is ok;
select svr_ip,svr_port,zone,start_service_time,status from oceanbase.__all_virtual_proxy_server_stat where role=;
select zone,status from oceanbase.__all_virtual_proxy_server_stat where status like '%active%';
select zone,count(*) from oceanbase.__all_virtual_proxy_server_stat group by zone;
