select count(*) from oceanbase.__all_virtual_table where table_name = '__all_virtual_concurrency_object_pool';
count(*)
1
use oceanbase;
desc __all_virtual_concurrency_object_pool;
Field	Type	Null	Key	Default	Extra
free_list_name	varchar(1024)	NO		NULL	
allocated	bigint(20)	NO		NULL	
in_use	bigint(20)	NO		NULL	
count	bigint(20)	NO		NULL	
type_size	bigint(20)	NO		NULL	
chunk_count	bigint(20)	NO		NULL	
chunk_byte_size	bigint(20)	NO		NULL	
select free_list_name from __all_virtual_concurrency_object_pool where chunk_byte_size < 0 or chunk_count < 0;
free_list_name
select (select svr_ip from oceanbase.__all_virtual_server_stat limit 1) as svr_ip, (select svr_port from oceanbase.__all_virtual_server_stat limit 1) as svr_port, count from __all_virtual_concurrency_object_pool where allocated < in_use;
svr_ip	svr_port	count
select count(*) from __all_virtual_concurrency_object_pool;
select * from __all_virtual_concurrency_object_pool;
select count(*) from oceanbase.__all_virtual_concurrency_object_pool where in_use != count*type_size;
count(*)
