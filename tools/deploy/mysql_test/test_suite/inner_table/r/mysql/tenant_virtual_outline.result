otl_idx_c2	select /*+BEGIN_OUTLINE_DATA INDEX(@"SEL$1" "test"."transform_outline_t"@"SEL$1" "idx_c2") OPTIMIZER_FEATURES_ENABLE('') END_OUTLINE_DATA*/* from transform_outline_t where c2 = 1
