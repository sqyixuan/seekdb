| name                  | value           | default_value  | isdefault |
+-----------------------+-----------------+----------------+-----------+
| transaction_isolation | REPEATABLE-READ | READ-COMMITTED | NO        |
+-----------------------+-----------------+----------------+-----------+
set global transaction_isolation = 'READ-COMMITTED';
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'transaction_isolation';
