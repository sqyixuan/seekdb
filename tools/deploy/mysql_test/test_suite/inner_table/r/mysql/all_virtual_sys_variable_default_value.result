result_format: 4
-------------------test normal tenant-------------------
------check new schema
desc oceanbase.__all_virtual_sys_variable_default_value;
+---------------+----------------+------+-----+---------+-------+
| Field         | Type           | Null | Key | Default | Extra |
+---------------+----------------+------+-----+---------+-------+
| variable_name | varchar(128)   | NO   |     |         |       |
| default_value | varchar(65536) | YES  |     | NULL    |       |
+---------------+----------------+------+-----+---------+-------+
desc oceanbase.DBA_OB_SYS_VARIABLES;
+---------------+----------------+------+-----+---------+-------+
| Field         | Type           | Null | Key | Default | Extra |
+---------------+----------------+------+-----+---------+-------+
| CREATE_TIME   | timestamp(6)   | YES  |     |         |       |
| MODIFY_TIME   | timestamp(6)   | YES  |     |         |       |
| NAME          | varchar(128)   | NO   |     |         |       |
| VALUE         | varchar(65536) | YES  |     | NULL    |       |
| MIN_VALUE     | varchar(65536) | NO   |     |         |       |
| MAX_VALUE     | varchar(65536) | NO   |     |         |       |
| SCOPE         | varchar(16)    | NO   |     |         |       |
| INFO          | varchar(4096)  | NO   |     | NULL    |       |
| DEFAULT_VALUE | varchar(65536) | YES  |     | NULL    |       |
| ISDEFAULT     | varchar(3)     | NO   |     |         |       |
+---------------+----------------+------+-----+---------+-------+

------check __all_virtual_sys_variable_default_value/DBA_OB_SYS_VARIABLES is consistent with __all_sys_variable
select "__all_sys_variable is the same count as __all_virtual_sys_variable_default_value" as result;
+----------------------------------------------------------------------------------+
| result                                                                           |
+----------------------------------------------------------------------------------+
| __all_sys_variable is the same count as __all_virtual_sys_variable_default_value |
+----------------------------------------------------------------------------------+
select "__all_sys_variable is the same count as DBA_OB_SYS_VARIABLES" as result;
+--------------------------------------------------------------+
| result                                                       |
+--------------------------------------------------------------+
| __all_sys_variable is the same count as DBA_OB_SYS_VARIABLES |
+--------------------------------------------------------------+

------test isdefault value
----bool type:autocommit 
select name,value from oceanbase.__all_sys_variable where name = 'autocommit';
+------------+-------+
| name       | value |
+------------+-------+
| autocommit | 1     |
+------------+-------+
select variable_name,default_value from oceanbase.__all_virtual_sys_variable_default_value where variable_name = 'autocommit';
+---------------+---------------+
| variable_name | default_value |
+---------------+---------------+
| autocommit    | 1             |
+---------------+---------------+
select name,value,default_value,isdefault from oceanbase.dba_ob_sys_variables where name = 'autocommit';
+------------+-------+---------------+-----------+
| name       | value | default_value | isdefault |
+------------+-------+---------------+-----------+
| autocommit | 1     | 1             | YES       |
+------------+-------+---------------+-----------+
set global autocommit = 0;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'autocommit';
+------------+-------+---------------+-----------+
| name       | value | default_value | isdefault |
+------------+-------+---------------+-----------+
| autocommit | 0     | 1             | NO        |
+------------+-------+---------------+-----------+
set global autocommit = 1;
select name,value,default_value,isdefault from oceanbase.DBA_OB_SYS_VARIABLES where name = 'autocommit';
+------------+-------+---------------+-----------+
| name       | value | default_value | isdefault |
+------------+-------+---------------+-----------+
| autocommit | 1     | 1             | YES       |
+------------+-------+---------------+-----------+
