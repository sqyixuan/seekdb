================  [10] check data_tpye for show parameters  =================
show parameters where name = 'enable_sql_audit';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	True	specifies whether SQL audit is turned on. The default value is TRUE. Value: TRUE: turned on FALSE: turned off	value	info	DEFAULT	DYNAMIC_EFFECTIVE	true	1
show parameters where name = 'max_string_print_length';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	500	truncate very long string when printing to log file. Range:[0,]	value	info	DEFAULT	DYNAMIC_EFFECTIVE	500	1
show parameters where name = 'location_cache_cpu_quota';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	5	the number of vCPUs allocated for the requests regarding location info of the core tables. Range: [0,10] in integer	value	info	DEFAULT	DYNAMIC_EFFECTIVE	5	1
show parameters where name = 'default_row_format';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	dynamic	default row format in mysql mode	value	info	DEFAULT	DYNAMIC_EFFECTIVE	dynamic	1
show parameters where name = 'log_disk_size';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	0M	the size of disk space used by the log files. Range: [0, +∞)	value	info	DEFAULT	DYNAMIC_EFFECTIVE	0M	1
show parameters where name = 'rpc_timeout';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	2s	the time during which a RPC request is permitted to execute before it is terminated	value	info	DEFAULT	DYNAMIC_EFFECTIVE	2s	1
show parameters where name = 'plsql_debug' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	False	specifies whether or not PL/SQL library units will be compiled for debugging	value	info	DEFAULT	DYNAMIC_EFFECTIVE	False	1
show parameters where name = 'open_cursors' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	50	specifies the maximum number of open cursors a session can have at once.can use this parameter to prevent a session from opening an excessive number of cursors.Range: [0, 65535] in integer	value	info	DEFAULT	DYNAMIC_EFFECTIVE	50	1
show parameters where name = 'cpu_quota_concurrency' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	10	max allowed concurrency for 1 CPU quota. Range: [1,20]	value	info	DEFAULT	DYNAMIC_EFFECTIVE	4	0
show parameters where name = 'plsql_code_type' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	native	specifies the compilation mode for PL/SQL library units	value	info	DEFAULT	DYNAMIC_EFFECTIVE	native	1
show parameters where name = 'range_optimizer_max_mem_size' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	128M	to limit the memory consumption for the query range optimizer. Range: [0M,+∞), 0 stands for unlimited	value	info	DEFAULT	DYNAMIC_EFFECTIVE	128M	1
show parameters where name = 'merger_check_interval' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	10s	the time interval between the schedules of the task that checks on the progress of MERGE for each zone. Range: [10s, 60m]	value	info	DEFAULT	DYNAMIC_EFFECTIVE	10m	0
show parameters where name = 'major_freeze_duty_time' tenant = sys;
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	02:00	the start time of system daily merge procedure. Range: [00:00, 24:00)	value	info	DEFAULT	DYNAMIC_EFFECTIVE	02:00	1
