alter system flush sql audit global;
alter system flush plan cache global;
select 'db_id_consistent_test' from dual;
db_id_consistent_test
db_id_consistent_test
select
audit.db_id,
audit.query_sql,
stat.db_id,
stat.query_sql
from
(
select
distinct sql_id,
db_id,
query_sql
from
oceanbase.__all_virtual_sql_audit
where
query_sql = 'select \'db_id_consistent_test\' from dual' limit 1
) audit
inner join (
select
distinct sql_id,
db_id,
query_sql
from
oceanbase.__all_virtual_plan_stat
where
query_sql = 'select \'db_id_consistent_test\' from dual' limit 1
) stat on audit.db_id = stat.db_id
and audit.sql_id = stat.sql_id;
db_id	query_sql	db_id	query_sql
201009	select 'db_id_consistent_test' from dual	201009	select 'db_id_consistent_test' from dual
