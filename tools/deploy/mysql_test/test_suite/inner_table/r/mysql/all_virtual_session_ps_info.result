alter system flush ps cache global;
drop table if exists t1;
create table t1(a int, b int);
PREPARE q FROM 'select * from t1 where a=? and b>?';
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.__all_virtual_session_ps_info where CHECKSUM = 3179570918;
tenant_id	STMT_TYPE	PARAM_COUNT	PARAM_TYPES	REF_COUNT	CHECKSUM
1	T_SELECT	2	6, 6	1	3179570918
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.GV$OB_SESSION_PS_INFO where CHECKSUM = 3179570918;
tenant_id	STMT_TYPE	PARAM_COUNT	PARAM_TYPES	REF_COUNT	CHECKSUM
1	T_SELECT	2	6, 6	1	3179570918
select 1 as tenant_id, STMT_TYPE, PARAM_COUNT, PARAM_TYPES, REF_COUNT, CHECKSUM from oceanbase.V$OB_SESSION_PS_INFO where CHECKSUM = 3179570918;
tenant_id	STMT_TYPE	PARAM_COUNT	PARAM_TYPES	REF_COUNT	CHECKSUM
1	T_SELECT	2	6, 6	1	3179570918
