drop database if exists hualong;
create database hualong;
use hualong;
drop table if exists tc1, tc2;
create table tc1 (c1 int primary key, c2 int, unique (c1), index idx (c1, c2));
select * from information_schema.statistics where table_name = 'tc1';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	NON_UNIQUE	INDEX_SCHEMA	INDEX_NAME	SEQ_IN_INDEX	COLUMN_NAME	COLLATION	CARDINALITY	SUB_PART	PACKED	NULLABLE	INDEX_TYPE	COMMENT	INDEX_COMMENT	IS_VISIBLE	EXPRESSION
def	hualong	tc1	0	hualong	c1	1	c1	A	NULL	NULL	NULL		BTREE	VALID		YES	NULL
def	hualong	tc1	1	hualong	idx	1	c1	A	NULL	NULL	NULL		BTREE	VALID		YES	NULL
def	hualong	tc1	1	hualong	idx	2	c2	A	NULL	NULL	NULL	YES	BTREE	VALID		YES	NULL
def	hualong	tc1	0	hualong	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	VALID		YES	NULL
select table_name, index_name from information_schema.statistics where table_name = 'tc1' order by 1, 2;
table_name	index_name
tc1	c1
tc1	idx
tc1	idx
tc1	PRIMARY
desc information_schema.statistics;
Field	Type	Null	Key	Default	Extra
TABLE_CATALOG	varchar(512)	NO			
TABLE_SCHEMA	varchar(128)	NO			
TABLE_NAME	varchar(256)	NO			
NON_UNIQUE	bigint(20)	NO			
INDEX_SCHEMA	varchar(128)	NO			
INDEX_NAME	varchar(256)	NO			
SEQ_IN_INDEX	bigint(20) unsigned	NO			
COLUMN_NAME	varchar(128)	NO			
COLLATION	varchar(1)	NO			
CARDINALITY	bigint(0)	NO			
SUB_PART	bigint(20)	NO			
PACKED	varchar(10)	NO			
NULLABLE	varchar(3)	NO			
INDEX_TYPE	varchar(16)	NO			
COMMENT	varchar(16)	NO			
INDEX_COMMENT	text	NO			
IS_VISIBLE	varchar(3)	NO			
EXPRESSION	varbinary(262144)	NO			
alter table tc1 add unique index idx2(c1);
select table_name, index_name from information_schema.statistics where table_name = 'tc1' order by 1, 2;
table_name	index_name
tc1	c1
tc1	idx
tc1	idx
tc1	idx2
tc1	PRIMARY
create table tc2 (c1 int);
select table_name, index_name from information_schema.statistics where table_name = 'tc2' ;
table_name	index_name
create table hidden_t1(c1 int,c2 int,c3 int, unique index (c1));
create table hidden_t4(c4 int, index(c4));
select * from information_schema.statistics where table_name = 'hidden_t1';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	NON_UNIQUE	INDEX_SCHEMA	INDEX_NAME	SEQ_IN_INDEX	COLUMN_NAME	COLLATION	CARDINALITY	SUB_PART	PACKED	NULLABLE	INDEX_TYPE	COMMENT	INDEX_COMMENT	IS_VISIBLE	EXPRESSION
def	hualong	hidden_t1	0	hualong	c1	1	c1	A	NULL	NULL	NULL	YES	BTREE	VALID		YES	NULL
select * from information_schema.statistics where table_name = 'hidden_t4';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	NON_UNIQUE	INDEX_SCHEMA	INDEX_NAME	SEQ_IN_INDEX	COLUMN_NAME	COLLATION	CARDINALITY	SUB_PART	PACKED	NULLABLE	INDEX_TYPE	COMMENT	INDEX_COMMENT	IS_VISIBLE	EXPRESSION
def	hualong	hidden_t4	1	hualong	c4	1	c4	A	NULL	NULL	NULL	YES	BTREE	VALID		YES	NULL
drop table tc1, tc2, hidden_t1, hidden_t4;
desc information_schema.statistics;
Field	Type	Null	Key	Default	Extra
TABLE_CATALOG	varchar(512)	NO			
TABLE_SCHEMA	varchar(128)	NO			
TABLE_NAME	varchar(256)	NO			
NON_UNIQUE	bigint(20)	NO			
INDEX_SCHEMA	varchar(128)	NO			
INDEX_NAME	varchar(256)	NO			
SEQ_IN_INDEX	bigint(20) unsigned	NO			
COLUMN_NAME	varchar(128)	NO			
COLLATION	varchar(1)	NO			
CARDINALITY	bigint(0)	NO			
SUB_PART	bigint(20)	NO			
PACKED	varchar(10)	NO			
NULLABLE	varchar(3)	NO			
INDEX_TYPE	varchar(16)	NO			
COMMENT	varchar(16)	NO			
INDEX_COMMENT	text	NO			
IS_VISIBLE	varchar(3)	NO			
EXPRESSION	varbinary(262144)	NO			
drop database hualong;
