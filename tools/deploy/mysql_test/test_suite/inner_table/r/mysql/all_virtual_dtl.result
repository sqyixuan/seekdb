use oceanbase;
desc __all_virtual_dtl_channel;
Field	Type	Null	Key	Default	Extra
channel_id	bigint(20)	NO		NULL	
op_id	bigint(20)	NO		NULL	
peer_id	bigint(20)	NO		NULL	
is_local	tinyint(4)	NO		NULL	
is_data	tinyint(4)	NO		NULL	
is_transmit	tinyint(4)	NO		NULL	
alloc_buffer_cnt	bigint(20)	NO		NULL	
free_buffer_cnt	bigint(20)	NO		NULL	
send_buffer_cnt	bigint(20)	NO		NULL	
recv_buffer_cnt	bigint(20)	NO		NULL	
processed_buffer_cnt	bigint(20)	NO		NULL	
send_buffer_size	bigint(20)	NO		NULL	
hash_val	bigint(20)	NO		NULL	
buffer_pool_id	bigint(20)	NO		NULL	
pins	bigint(20)	NO		NULL	
first_in_ts	timestamp(6)	NO		NULL	
first_out_ts	timestamp(6)	NO		NULL	
last_in_ts	timestamp(6)	NO		NULL	
last_out_ts	timestamp(6)	NO		NULL	
status	bigint(20)	NO		NULL	
thread_id	bigint(20)	NO		NULL	
owner_mod	bigint(20)	NO		NULL	
peer_ip	varchar(46)	NO		NULL	
peer_port	bigint(20)	NO		NULL	
eof	tinyint(4)	NO		NULL	
desc __all_virtual_dtl_memory;
Field	Type	Null	Key	Default	Extra
channel_total_cnt	bigint(20)	NO		NULL	
channel_block_cnt	bigint(20)	NO		NULL	
max_parallel_cnt	bigint(20)	NO		NULL	
max_blocked_buffer_size	bigint(20)	NO		NULL	
accumulated_blocked_cnt	bigint(20)	NO		NULL	
current_buffer_used	bigint(20)	NO		NULL	
seqno	bigint(20)	NO		NULL	
alloc_cnt	bigint(20)	NO		NULL	
free_cnt	bigint(20)	NO		NULL	
free_queue_len	bigint(20)	NO		NULL	
total_memory_size	bigint(20)	NO		NULL	
real_alloc_cnt	bigint(20)	NO		NULL	
real_free_cnt	bigint(20)	NO		NULL	
select case when  count(*) > 0 then 0 else 0 end c0 from __all_virtual_dtl_channel;
c0
0
select case when  count(*) > 0 then 0 else 0 end c1 from __all_virtual_dtl_memory;
c1
0
