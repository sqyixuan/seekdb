alter system set _ob_ash_enable = false;
with reverse_scan_ash(sample_time) as (select /*+ index_desc(__all_virtual_ash all_virtual_ash_i1)*/ max(sample_time) from oceanbase.__all_virtual_ash where sample_time > 0),
forward_scan_ash(sample_time) as (select /*+ index(__all_virtual_ash all_virtual_ash_i1) NO_FAST_MINMAX*/ max(sample_time) from oceanbase.__all_virtual_ash where sample_time > 1)
select reverse_scan_ash.sample_time = forward_scan_ash.sample_time as result from reverse_scan_ash join forward_scan_ash on reverse_scan_ash.sample_time = forward_scan_ash.sample_time;
result
1
with reverse_scan_ash(sample_time) as (select /*+ index_desc(__all_virtual_ash all_virtual_ash_i1)*/ max(sample_time) from oceanbase.__all_virtual_ash where sample_time > 0),
forward_scan_ash(sample_time) as (select /*+ full(__all_virtual_ash) NO_FAST_MINMAX*/ max(sample_time) from oceanbase.__all_virtual_ash where sample_time > 1)
select reverse_scan_ash.sample_time = forward_scan_ash.sample_time as result from reverse_scan_ash join forward_scan_ash on reverse_scan_ash.sample_time = forward_scan_ash.sample_time;
result
1
with reverse_scan_ash(svr_ip, svr_port, sample_id) as (select /*+ index_desc(__all_virtual_ash all_virtual_ash_i1)*/ svr_ip, svr_port, sample_id from oceanbase.__all_virtual_ash where sample_time > 0),
forward_scan_ash(svr_ip, svr_port, sample_id) as (select /*+ full(__all_virtual_ash) NO_FAST_MINMAX*/ svr_ip, svr_port, sample_id from oceanbase.__all_virtual_ash where sample_time > 1)
select * from reverse_scan_ash left join forward_scan_ash on reverse_scan_ash.svr_ip = forward_scan_ash.svr_ip and reverse_scan_ash.svr_port = forward_scan_ash.svr_port and reverse_scan_ash.sample_id = forward_scan_ash.sample_id where forward_scan_ash.sample_id is null;
svr_ip	svr_port	sample_id	svr_ip	svr_port	sample_id
check ash index validation 0
explain select sample_time from oceanbase.__all_virtual_ash where sample_time > usec_to_time(0) and tenant_id = effective_tenant_id() and svr_ip = host_ip() and svr_port = rpc_port();
