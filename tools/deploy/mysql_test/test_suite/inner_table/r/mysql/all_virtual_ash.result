-------------------------------------
  0 - output([__all_virtual_ash.SAMPLE_TIME]), filter([__all_virtual_ash.SAMPLE_TIME > usec_to_time(0)], [__all_virtual_ash.TENANT_ID = effective_tenant_id()],
       [__all_virtual_ash.SVR_IP = host_ip()], [__all_virtual_ash.SVR_PORT = rpc_port()])
      access([__all_virtual_ash.SVR_IP], [__all_virtual_ash.SVR_PORT], [__all_virtual_ash.SAMPLE_TIME], [__all_virtual_ash.TENANT_ID]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false,false], 
      range_key([__all_virtual_ash.SAMPLE_TIME]), range(1970-01-01 00:00:00.000000 ; MAX)
