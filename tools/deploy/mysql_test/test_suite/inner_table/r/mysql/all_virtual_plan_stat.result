enable_bf_cache	tinyint(4)	NO		NULL	
bf_filter_cnt	bigint(20)	NO		NULL	
bf_access_cnt	bigint(20)	NO		NULL	
enable_row_cache	tinyint(4)	NO		NULL	
row_cache_hit_cnt	bigint(20)	NO		NULL	
row_cache_miss_cnt	bigint(20)	NO		NULL	
