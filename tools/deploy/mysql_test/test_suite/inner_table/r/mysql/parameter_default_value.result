-------------------test invisible parameter can be shown when is not default value-------------------
alter system set _parallel_min_message_pool = "32M";
show parameters like "_parallel_min_message_pool";
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	_parallel_min_message_pool	CAPACITY	32M	DTL message buffer pool reserve the mininum size after extend the size. Range: [16M,8G]	TENANT	TENANT	DEFAULT	DYNAMIC_EFFECTIVE	16M	0
alter system set _parallel_min_message_pool = "16M";
show parameters like "_parallel_min_message_pool";
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault

-------------------test v$ob_parameters-------------------
alter system set max_stale_time_for_weak_consistency = '7s' tenant = sys;

select distinct value, default_value,isdefault from V$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;
+-------+---------------+-----------+
| value | default_value | isdefault |
+-------+---------------+-----------+
| 7s    | 5s            | NO        |
+-------+---------------+-----------+

-------------------test gv$ob_parameters-------------------
alter system set max_stale_time_for_weak_consistency = '9s' tenant = mysql;
alter system set max_stale_time_for_weak_consistency = '8s' tenant = oracle;
alter system set max_stale_time_for_weak_consistency = '7s' tenant = sys;

to ensure max_stale_time_for_weak_consistency fresh on every observer




select distinct value, default_value,isdefault from GV$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;
