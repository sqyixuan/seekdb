use oceanbase;
desc __all_virtual_trans_stat;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO		NULL	
svr_ip	varchar(46)	NO		NULL	
svr_port	bigint(20)	NO		NULL	
trans_type	bigint(20)	NO		NULL	
trans_id	bigint(20)	NO		NULL	
session_id	bigint(20)	NO		NULL	
scheduler_addr	varchar(64)	NO		NULL	
is_decided	tinyint(4)	NO		NULL	
ls_id	bigint(20)	NO		NULL	
participants	varchar(1024)	NO		NULL	
ctx_create_time	timestamp(6)	YES		NULL	
expired_time	timestamp(6)	YES		NULL	
ref_cnt	bigint(20)	NO		NULL	
last_op_sn	bigint(20)	NO		NULL	
pending_write	bigint(20)	NO		NULL	
state	bigint(20)	NO		NULL	
part_trans_action	bigint(20)	NO		NULL	
trans_ctx_addr	varchar(20)	NO		NULL	
mem_ctx_id	bigint(20)	NO		NULL	
pending_log_size	bigint(20)	NO		NULL	
flushed_log_size	bigint(20)	NO		NULL	
role	bigint(20)	NO		NULL	
is_exiting	bigint(20)	NO		NULL	
coordinator	bigint(20)	NO		NULL	
last_request_time	timestamp(6)	YES		NULL	
gtrid	varbinary(128)	NO		NULL	
bqual	varbinary(128)	NO		NULL	
format_id	bigint(20)	NO		1	
start_scn	bigint(20) unsigned	NO		NULL	
end_scn	bigint(20) unsigned	NO		NULL	
rec_scn	bigint(20) unsigned	NO		NULL	
transfer_blocking	tinyint(4)	NO		NULL	
busy_cbs	bigint(20)	NO		NULL	
replay_complete	bigint(20)	NO		NULL	
serial_log_final_scn	bigint(20)	NO		NULL	
callback_list_stats	longtext	NO		NULL	
set autocommit = 0;
drop table if exists stu;
create table if not exists stu(stu_no int primary key auto_increment, gendar varchar(1));
insert into stu values(NULL, 'm');
insert into stu values(NULL, 'f');
select count(1) > 0 from __all_virtual_trans_stat;
count(1) > 0
1
select count(1) > 0 from (select * from __all_virtual_trans_stat limit 10) as t;
count(1) > 0
1
select count(1) > 0 from __all_virtual_trans_stat where svr_ip in (select svr_ip from __all_server);
count(1) > 0
1
