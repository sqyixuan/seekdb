case 1: verify columns of the virtual table
create table vt_tx_stat_t1(id int, v varchar(128));
begin;
insert into vt_tx_stat_t1 values(NULL, 'hello,world');
insert rows to trigger flush redo
commit;
drop table vt_tx_stat_t1;
case2: pdml, verify columns of virtual table
create table vt_tx_stat_test (id int, v int);
insert into vt_tx_stat_test values(1,1);
select count(1) from vt_tx_stat_test;
count(1)
1024
commit;
alter system set _parallel_redo_logging_trigger='1B';
begin;
insert into vt_tx_stat_test values(1000001, 200001);
insert/*+enable_parallel_dml parallel(16)*/ into vt_tx_stat_test select id + 100000, v + 200000 from vt_tx_stat_test;
insert one row, pending_log_size should be changed
insert into vt_tx_stat_test values(1111111,222222);
select count(1) from vt_tx_stat_test;
count(1)
2051
rollback;
drop table if exists vt_tx_stat_test;
drop table if exists stu;
alter system set _parallel_redo_logging_trigger='16MB';
