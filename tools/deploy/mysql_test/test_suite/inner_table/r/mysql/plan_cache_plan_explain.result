drop table if exists t1;
drop table if exists t2;
alter system flush plan cache;
create table t1(sid int, course varchar(20), grade int);
create table t2(sid int, name varchar(20), age int);
insert into t1 values(1, 'math', 80);
insert into t1 values(1, 'physics', 90);
insert into t1 values(1, 'compute', 90);
insert into t1 values(2, 'math', 79);
insert into t1 values(2, 'physics', 85);
insert into t1 values(2, 'compute', 86);
insert into t1 values(3, 'math', 90);
insert into t1 values(3, 'physics', 93);
insert into t1 values(3, 'compute', 95);
insert into t2 values(1, 'li', 18);
insert into t2 values(2, 'wang', 17);
insert into t2 values(3, 'zhang', 19);
select t2.name, t1.grade from t1 join t2 on t1.sid = t2.sid where course = 'math' order by t1.grade desc;
name	grade
zhang	90
li	80
wang	79
select t2.name, sum(t1.grade) as total_grade from t1 join t2 on t1.sid = t2.sid group by t1.sid order by t1.grade desc;
name	total_grade
zhang	278
li	260
wang	250
select case when count(*)>0 then 'OK' else 'ERROR' end from oceanbase.GV$OB_PLAN_CACHE_PLAN_EXPLAIN;
case when count(*)>0 then 'OK' else 'ERROR' end
OK
select PLAN_DEPTH, PLAN_LINE_ID, OPERATOR, NAME, ROWS, PROPERTY from oceanbase.GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id = (select plan_id from oceanbase.__all_virtual_plan_stat where sql_id = '6F01BADCE93176A74ED0E69103FB88AF' limit 1);
PLAN_DEPTH	PLAN_LINE_ID	OPERATOR	NAME	ROWS	PROPERTY
0	0	PHY_SORT	NULL	3	NULL
1	1	 PHY_VEC_HASH_JOIN	NULL	3	NULL
