2	3	  PHY_VEC_TABLE_SCAN	t1	3	table_rows:9, physical_range_rows:9, logical_range_rows:9, index_back_rows:0, output_rows:3, avaiable_index_name[t1]
select PLAN_DEPTH, PLAN_LINE_ID, OPERATOR, NAME, ROWS, PROPERTY from oceanbase.GV$OB_PLAN_CACHE_PLAN_EXPLAIN where plan_id = (select plan_id from oceanbase.__all_virtual_plan_stat where sql_id = '20CE999E01B0C90559A3F5A3E9E58EC4' limit 1);
PLAN_DEPTH	PLAN_LINE_ID	OPERATOR	NAME	ROWS	PROPERTY
0	0	PHY_SORT	NULL	3	NULL
1	1	 PHY_VEC_HASH_GROUP_BY	NULL	3	NULL
2	2	  PHY_VEC_HASH_JOIN	NULL	9	NULL
3	3	   PHY_VEC_TABLE_SCAN	t2	3	table_rows:3, physical_range_rows:3, logical_range_rows:3, index_back_rows:0, output_rows:3, avaiable_index_name[t2]
3	4	   PHY_VEC_TABLE_SCAN	t1	9	table_rows:9, physical_range_rows:9, logical_range_rows:9, index_back_rows:0, output_rows:9, avaiable_index_name[t1]
drop table t1;
