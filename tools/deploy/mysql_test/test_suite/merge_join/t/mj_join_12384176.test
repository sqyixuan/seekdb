--source mysql_test/test_suite/executor/include/cleanup.inc
--source mysql_test/test_suite/executor/include/load_data.inc
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 'tt');
call dbms_stats.gather_table_stats('TEST', 't_r4_01_20');
call dbms_stats.gather_table_stats('TEST', 't_h5_09_28');
call dbms_stats.gather_table_stats('TEST', 't_r4_h3_date_int');
call dbms_stats.gather_table_stats('TEST', 't_h3_01_20');
call dbms_stats.gather_table_stats('TEST', 't_r5_01_20');
call dbms_stats.gather_table_stats('TEST', 't_r4_h2_date_int');
--sleep 3
--result_format 4
--explain_protocol 2
##两表join的情况下，何时可以下降相关条件
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from tt t1 inner join t_r4_01_20 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from tt t1 inner join t_r4_01_20 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
