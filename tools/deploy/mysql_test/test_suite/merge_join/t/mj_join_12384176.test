#----二级分区的表------#
select /*+leading(ta tb) use_merge(ta tb)*/ * from (select   a, b, c from t_r4_h2_date_int group by a, c ) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.c = tb.c;
select /*+leading(ta tb) use_merge(ta tb)*/ * from  (select   a, b, c from t_r4_h2_date_int group by a, c ) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.c;
select /*+leading(tb ta) use_merge(ta tb)*/ * from  (select   a, b, c from t_r4_h2_date_int group by a, c ) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.c;
select /*+leading(ta tb) use_merge(ta tb)*/ * from (select  a+b as c, a, b from t_r4_h2_date_int limit 10) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b;
select /*+leading(ta tb) use_merge(ta tb)*/ * from (select  a+b as c, a, b from t_r4_h2_date_int limit 10) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b;
select /*+leading(tb ta) use_merge(ta tb)*/ * from (select  a+b as c, a, b from t_r4_h2_date_int limit 10) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b;
select /*+leading(tb ta) use_merge(ta tb)*/ * from (select  a+b as c, a, b from t_r4_h2_date_int limit 10) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b;
select /*+use_merge(ta tb)*/ * from t_r4_h2_date_int as  ta left join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b;
select /*+use_merge(ta tb)*/ * from t_r4_h3_date_int  as tb left join t_r4_h2_date_int as ta on ta.a = tb.a and ta.b = tb.b;

##三表join的情况，最右边的join不会错误的下降
select /*+leading(ta tb tc) read_consistency(weak) use_merge(ta tb) use_merge(tb tc) */ * from (select  a, b from t_r4_h2_date_int where a = '20161114' and b = 14) as ta join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b and  tb.a = '20161114' and tb.b = 14 join t_r4_h3_date_bigint as tc on ta.a = tc.a and ta.b = tc.b and  tc.a = '20161114' and tc.b = 14;
select /*+ read_consistency(weak) use_merge(ta taa) use_merge(tb tc) */ * from  t_r4_h3_date_int as ta left join (select tc.a as a, tc.b as b , tb.a as aa, tb.b as bb from (select   a, b from t_r4_h2_date_int limit 30) as tb left join t_r4_h3_date_bigint as tc on tb.a = tc.a and tb.b = tc.b and  tb.a = '20161114') as taa on ta.a = taa.a and ta.b = taa.b and  ta.a = '20161114' ;

##三表join的情况， A join B 之后再join C   B和C可以做智能连接，此处也不会做智能连接
select /*+leading(ta tb tc) read_consistency(weak) use_merge(ta tb) use_merge(tb tc) */ * from (select   a, b from t_r4_h2_date_int where a = '20161114'  and b > 14 and b < 20 limit 10) as ta left join t_r4_h3_date_int as tb on ta.a = tb.a and ta.b = tb.b and  tb.a = '20161114' and tb.b > 14 and tb.b < 20 left join t_r4_h3_date_int as tc on ta.a = tc.a and ta.b = tc.b and  tc.a = '20161114'  and tc.b > 14 and tc.b < 20;
--sorted_result
select /*+ read_consistency(weak) use_merge(ta taa) use_merge(tb tc) */ * from  t_r4_h3_date_int as ta left join (select tc.a as a, tc.b as b , tb.a as aa, tb.b as bb from (select  c as c, a, b from t_r4_h2_date_int limit 10 ) as tb left join t_r4_h3_date_int as tc on tb.a = tc.a and tb.c = tc.b and  tb.a = '20161114') as taa on ta.a = taa.a and ta.b = taa.b and  ta.a = '20161114' ;

--source mysql_test/test_suite/executor/include/cleanup.inc
