select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from tt t1 inner join t_h5_09_28 t2 on t1.a = t2.a order by t1.a desc, t2.a desc;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from tt t1 inner join t_r4_01_20 t2 on t1.a = t2.a order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from tt t1 inner join t_r4_01_20 t2 on t1.a = t2.a order by t1.a desc, t2.a desc;
select /*+leading(ta tb) use_merge(ta tb)*/ * from tt as ta join t_r4_h3_date_int as tb on ta.c = tb.a and ta.a = tb.c;
select /*+leading(tb ta) use_merge(ta tb)*/ * from tt as ta join t_r4_h3_date_int as tb on ta.c = tb.a and ta.a = tb.c;
select /*+leading(ta tb) use_merge(ta tb)*/ * from tt as ta join t_r4_h3_date_int as tb on ta.c = tb.a and ta.a = tb.b;
select /*+leading(tb ta) use_merge(ta tb)*/ * from tt as ta join t_r4_h3_date_int as tb on ta.c = tb.a and ta.a = tb.b;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.b = t2.a order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.b = t2.a order by t1.a desc, t2.a desc;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.b = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 inner join t_h5_09_28 t2 on t1.b = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from t_r4_01_20 t1 inner join t_h5_09_28 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from t_r4_01_20 t1 inner join t_h5_09_28 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t1 t2) use_merge(t1 t2)*/ t1.a, t2.a from t_r4_01_20 t1 inner join t_r5_01_20 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
select /*+leading(t2 t1) use_merge(t1 t2)*/ t1.a, t2.a from t_r4_01_20 t1 inner join t_r5_01_20 t2 on t1.a = t2.b order by t1.a desc, t2.a desc;
