#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--disable_result_log
create table t1(a int primary key, b int, c int);
create table t2(a int primary key, b int, c int) partition by hash(a) partitions 3;
insert into t1 values (1,1,1),(2,2,2),(3,3,3);
insert into t2 values (1,1,1),(2,2,2),(3,3,3);
--disable_query_log
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

## 非分区表
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all left join t1 on t1.a = t_all.a;
select /*+use_merge(t1 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all left join t1 on t1.a = t_all.a;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all right join t1 on t1.a = t_all.a order by t1.b;
select /*+use_merge(t1 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all right join t1 on t1.a = t_all.a order by t1.b;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all join t1 on t1.a = t_all.a;
select /*+use_merge(t1 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all join t1 on t1.a = t_all.a;

## 分区表 连接键为分区键
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all left join t2 on t2.a = t_all.a;
select /*+use_merge(t2 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all left join t2 on t2.a = t_all.a;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all right join t2 on t2.a = t_all.a order by t2.b;
select /*+use_merge(t2 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all right join t2 on t2.a = t_all.a order by t2.b;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all join t2 on t2.a = t_all.a;
select /*+use_merge(t2 t_all) parallel(2)*/ * from (select 1 as a from dual) as t_all join t2 on t2.a = t_all.a;

## 分区表 连接键为非分区键
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all left join t2 on t2.b = t_all.a;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all right join t2 on t2.b = t_all.a order by t2.b;
select /*+parallel(2)*/ * from (select 1 as a from dual) as t_all join t2 on t2.b = t_all.a;


drop table t1,t2;
