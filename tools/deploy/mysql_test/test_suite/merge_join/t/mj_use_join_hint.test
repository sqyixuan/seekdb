--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer
# description: expand the use_merge, use_merge, use_merge, use_bnl function.
# e.g. select /*+leading(t1, (t2,t3)) use_merge((t2,t3))*/* from t1,t2,t3 where t1.a = t2.a and t2.a = t3.a;
# in the upper sql, (t2,t3) can be joined by using MJ when (t2,t3) is the right child tree.
#

--explain_protocol 2

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
drop table if exists t8;
drop table if exists t9;
drop table if exists t10;
drop table if exists t11;
drop table if exists t12;
--enable_warnings

###扩展use_merge, use_merge, use_merge, use_bnl的功能
create table t1(a int, b int, c int);
create table t2(a int, b int, c int);
create table t3(a int, b int, c int, d int, primary key(a,b));
create table t4(a int, b int, c int);
create table t5(a int, b int, c int);
create table t6(a int, b int, c int);
create table t7(a int, b int, c int);
create table t8(a int, b int, c int);
create table t9(a int, b int, c int);
create table t10(a int, b int, c int);
create table t11(a int primary key, b int, c int, d int) partition by hash(a) partitions 2;
create table t12(a int primary key, b int, c int, d int);

#no_use测试
explain select /*+leading(t1,(t2,t3)) */* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a; 
explain select /*+leading(t1,(t2,t3)) no_use_merge((t2,t3))*/* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a; 

##不支持的语法，随后是正确的
explain select /*+leading(t3,((t4,t5),t6)) use_merge(t3,((t4,t5),t6))*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;
explain select /*+leading(t3,((t4,t5),t6)) use_merge(t3,(t4,t5,t6))*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;

##leading单个表的指定
explain select /*+leading(t3,(t4,t5)) use_merge(t4,t5)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
explain select /*+leading(t3,(t4,t5)) use_merge(t4,t5)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
explain select /*+leading(t3,(t4,t5)) use_merge(t4,t5)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;

##+leading内部嵌套
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t6,t7)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t6,t7) use_merge(t4,t5)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t4,t5)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t4,t5) use_merge(t6,t7)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t6,t7)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_merge(t6,t7) use_merge(t4,t5)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+leading(t5,(t6,t7)) use_merge((t6,t7))*/* from t5,t6,t7 where t5.a = t6.a and t6.a = t7.a; 
explain select /*+leading(t5,(t6,t7)) use_merge((t6,t7))*/* from t5,t6,t7 where t5.a = t6.a and t6.a = t7.a;
explain select /*+leading(t5,(t6,t7),(t8,t9)) use_merge((t6,t7)) use_merge((t8,t9))*/* from t5,t6,t7,t8,t9 where t5.a=t6.a and t6.a=t7.a and t7.a=t8.a and t8.a=t9.a;
explain select /*+leading(t5,((t6,t7),(t8,t9))) use_merge((t6,t7)) use_merge((t6,t7,t8,t9))*/* from t5,t6,t7,t8,t9 where t5.a=t6.a and t6.a=t7.a and t7.a=t8.a and t8.a=t9.a;
explain select /*+leading(t5,((t6,t7),(t8,t9)),t4) use_merge((t6,t7),t4) use_merge((t6,t7,t8,t9))*/* from t4,t5,t6,t7,t8,t9 where t4.a=t5.a and t5.a=t6.a and t6.a=t7.a and t7.a=t8.a and t8.a=t9.a; 

##含有qb_name的情况
explain select /*+ leading(@SEL$1 t4  t5)*/ * from t5 , (select/*+qb_name(yz)*/ a from t4) t where t.a = t5.a;
explain select /*+ leading(@SEL$1 t5@SEL$1  t4@YZ)*/ * from t5 , (select/*+qb_name(yz)*/ a from t4) t where t.a = t5.a;

##含有内部生成标志的情况
explain select /*+ leading(((t3,t4),t5),t6)*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;
explain select /*+ BEGIN_OUTLINE_DATA USE_MERGE(@"SEL$1" "TEST"."T6"@"SEL$1") USE_MERGE(@"SEL$1" "TEST"."T5"@"SEL$1") USE_MERGE(@"SEL$1" "TEST"."T4"@"SEL$1") LEADING(@"SEL$1" "TEST"."T3"@"SEL$1" "TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1") FULL(@"SEL$1" "TEST"."T3"@"SEL$1") FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T6"@"SEL$1") END_OUTLINE_DATA */* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;

explain select /*+ leading(t3,(t4,t5)) use_merge((t4,t5))*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
explain select /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T3"@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" ))) USE_MERGE(@"SEL$1" ( "TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1")) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") USE_MERGE(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") END_OUTLINE_DATA*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;

explain select /*+ leading(t3,(t4,(t5,t6)))*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;
explain select /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T3"@"SEL$1" ("TEST"."T4"@"SEL$1" ("TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1" )))) USE_MERGE(@"SEL$1" ( "TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1")) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") USE_MERGE(@"SEL$1" ( "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1")) FULL(@"SEL$1" "TEST"."T4"@"SEL$1") USE_MERGE(@"SEL$1" "TEST"."T6"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T6"@"SEL$1") END_OUTLINE_DATA*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;

explain select /*+ leading(t3,(t4,t5),(t6,t7)) use_merge((t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" (("TEST"."T3"@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" ))("TEST"."T6"@"SEL$1" "TEST"."T7"@"SEL$1" ))) use_merge(@"SEL$1" ( "TEST"."T6"@"SEL$1" "TEST"."T7"@"SEL$1")) use_merge(@"SEL$1" ( "TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1")) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") use_merge(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") use_merge(@"SEL$1" "TEST"."T7"@"SEL$1") FULL(@"SEL$1" "TEST"."T6"@"SEL$1") FULL(@"SEL$1" "TEST"."T7"@"SEL$1") END_OUTLINE_DATA*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;

explain select /*+ leading(t3,((t4,t5),(t6,t7))) use_merge((t4,t5,t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
explain select /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T3"@"SEL$1" (("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" )("TEST"."T6"@"SEL$1" "TEST"."T7"@"SEL$1" )))) use_merge(@"SEL$1" ( "TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1" "TEST"."T7"@"SEL$1")) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") USE_MERGE(@"SEL$1" ( "TEST"."T6"@"SEL$1" "TEST"."T7"@"SEL$1")) USE_MERGE(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") USE_MERGE(@"SEL$1" "TEST"."T7"@"SEL$1") FULL(@"SEL$1" "TEST"."T6"@"SEL$1") FULL(@"SEL$1" "TEST"."T7"@"SEL$1") END_OUTLINE_DATA*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;

explain select /*+use_px parallel(4) leading(t3,(t4,t5)) pq_distribute((t4,t5) broadcast none)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
explain select /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T3"@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" ))) PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" ) BROADCAST NONE) USE_MERGE(@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T5"@"SEL$1" ) HASH HASH) USE_MERGE(@"SEL$1" ("TEST"."T5"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") PARALLEL(4) USE_PX END_OUTLINE_DATA*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;

explain select /*+use_px parallel(4) leading(t3,((t4,t5),t6)) pq_distribute((t4,t5,t6) broadcast none) pq_distribute(t6 broadcast none)*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;
explain select  /*+ BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T3"@"SEL$1" (("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" )"TEST"."T6"@"SEL$1" ))) PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1" ) BROADCAST NONE) USE_MERGE(@"SEL$1" ("TEST"."T4"@"SEL$1" "TEST"."T5"@"SEL$1" "TEST"."T6"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T3"@"SEL$1") PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T6"@"SEL$1" ) BROADCAST NONE) USE_MERGE(@"SEL$1" ("TEST"."T6"@"SEL$1" )) PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T5"@"SEL$1" ) HASH HASH) USE_MERGE(@"SEL$1" ("TEST"."T5"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T4"@"SEL$1") FULL(@"SEL$1" "TEST"."T5"@"SEL$1") FULL(@"SEL$1" "TEST"."T6"@"SEL$1") PARALLEL(4) USE_PX END_OUTLINE_DATA*/* from t3,t4,t5,t6 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a;

#加入px后的测试
explain select /*+use_px parallel(2) leading(t3,(t4,t5)) use_merge(t4,t5)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;

#use material nl 的测试
explain select /*+use_merge(t1,t2)*/* from t1,t2 where t1.a=t2.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" "TEST"."T2"@"SEL$1" )) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" )) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") FULL(@"SEL$1" "TEST"."T2"@"SEL$1") END_OUTLINE_DATA*/* from t1,t2 where t1.a=t2.a;
explain select /*+use_merge(t1,t2) no_use_merge_materialization(t1,t2)*/* from t1,t2 where t1.a=t2.a; 
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" "TEST"."T2"@"SEL$1" )) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" )) NO_use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") FULL(@"SEL$1" "TEST"."T2"@"SEL$1") END_OUTLINE_DATA*/* from t1,t2 where t1.a=t2.a;

explain select /*+leading(t1,(t2,t3)) use_merge((t2,t3))*/* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ))) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") use_merge(@"SEL$1" ("TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T2"@"SEL$1") FULL(@"SEL$1" "TEST"."T3"@"SEL$1") END_OUTLINE_DATA*/* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a;
explain select /*+leading(t1,(t2,t3)) use_merge((t2,t3)) no_use_merge_materialization((t2,t3))*/* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ))) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) NO_use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") use_merge(@"SEL$1" ("TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T2"@"SEL$1") FULL(@"SEL$1" "TEST"."T3"@"SEL$1") END_OUTLINE_DATA*/* from t1,t2,t3 where t1.a=t2.a and t2.a=t3.a;

explain select /*+leading(t11,(t2,t3)) use_merge(t2,t3,(t2,t3))*/* from t11,t2,t3 where t2.a=t3.a and t3.a=t11.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T11"@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ))) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ) NONE PARTITION) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T11"@"SEL$1") use_merge(@"SEL$1" ("TEST"."T3"@"SEL$1" )) NO_use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T2"@"SEL$1") FULL(@"SEL$1" "TEST"."T3"@"SEL$1") END_OUTLINE_DATA*/* from t11,t2,t3 where t2.a=t3.a and t3.a=t11.a;
explain select /*+leading(t11,(t2,t3)) use_merge(t2,t3,(t2,t3)) use_merge_materialization(t2,t3)*/* from t11,t2,t3 where t2.a=t3.a and t3.a=t11.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T11"@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ))) use_merge(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) PQ_DISTRIBUTE(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" ) NONE PARTITION) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T2"@"SEL$1" "TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T11"@"SEL$1") use_merge(@"SEL$1" ("TEST"."T3"@"SEL$1" )) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T3"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T2"@"SEL$1") FULL(@"SEL$1" "TEST"."T3"@"SEL$1") END_OUTLINE_DATA */* from t11,t2,t3 where t2.a=t3.a and t3.a=t11.a;

explain select /*+leading(t1,t12) use_merge(t1,t12)*/* from t1,t12 where t1.a=t12.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" "TEST"."T12"@"SEL$1" )) use_merge(@"SEL$1" ("TEST"."T12"@"SEL$1" )) NO_use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T12"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") FULL(@"SEL$1" "TEST"."T12"@"SEL$1") END_OUTLINE_DATA*/* from t1,t12 where t1.a=t12.a;
explain select /*+leading(t1,t12) use_merge(t1,t12) use_merge_materialization(t12)*/* from t1,t12 where t1.a=t12.a;
explain select /*+BEGIN_OUTLINE_DATA LEADING(@"SEL$1" ("TEST"."T1"@"SEL$1" "TEST"."T12"@"SEL$1" )) use_merge(@"SEL$1" ("TEST"."T12"@"SEL$1" )) use_merge_MATERIALIZATION(@"SEL$1" ("TEST"."T12"@"SEL$1" )) FULL(@"SEL$1" "TEST"."T1"@"SEL$1") FULL(@"SEL$1" "TEST"."T12"@"SEL$1") END_OUTLINE_DATA*/* from t1,t12 where t1.a=t12.a;

## hint with query block, bug: 
--disable_warnings
drop table if exists bmsql_district;
drop table if exists bmsql_stock;
drop table if exists bmsql_order_line;
--disable_warnings
create table bmsql_district (
d_w_id       INTEGER       NOT NULL,
d_id         INTEGER       NOT NULL,
d_ytd        DECIMAL(12,2),
d_tax        DECIMAL(4,4),
d_next_o_id  INTEGER,
d_name       VARCHAR(10),
d_street_1   VARCHAR(20),
d_street_2   VARCHAR(20),
d_city       VARCHAR(20),
d_state      CHAR(2),
d_zip        CHAR(9),
PRIMARY KEY (d_w_id, d_id)
);

create table bmsql_stock (
s_w_id       INTEGER       NOT NULL,
s_i_id       INTEGER       NOT NULL,
s_quantity   DECIMAL(4,0),
s_ytd        DECIMAL(8,2),
s_order_cnt  INTEGER,
s_remote_cnt INTEGER,
s_data       VARCHAR(50),
s_dist_01    CHAR(24),
s_dist_02    CHAR(24),
s_dist_03    CHAR(24),
s_dist_04    CHAR(24),
s_dist_05    CHAR(24),
s_dist_06    CHAR(24),
s_dist_07    CHAR(24),
s_dist_08    CHAR(24),
s_dist_09    CHAR(24),
s_dist_10    CHAR(24),
PRIMARY KEY (s_w_id, s_i_id)
);

create table bmsql_order_line (
ol_w_id         INTEGER   NOT NULL,
ol_d_id         INTEGER   NOT NULL,
ol_o_id         INTEGER   NOT NULL,
ol_number       INTEGER   NOT NULL,
ol_i_id         INTEGER   NOT NULL,
ol_delivery_d   TIMESTAMP,
ol_amount       DECIMAL(6,2),
ol_supply_w_id  INTEGER,
ol_quantity     DECIMAL(2,0),
ol_dist_info    CHAR(24),
PRIMARY KEY (ol_w_id, ol_d_id, ol_o_id, ol_number)
);

explain
SELECT
/*+
USE_MERGE(@"SEL$2" ("VIEW1"@"SEL$2"))
LEADING(@"SEL$2" ("test"."bmsql_stock"@"SEL$2" ))
*/
count(*) AS low_stock
FROM
(SELECT s_w_id, s_i_id, s_quantity
 FROM bmsql_stock
 WHERE s_w_id = 117
 AND s_quantity < 10
 AND s_i_id IN
 (SELECT ol_i_id
  FROM bmsql_district
  JOIN bmsql_order_line ON ol_w_id = d_w_id
  AND ol_d_id = d_id
  AND ol_o_id >= d_next_o_id - 20
  AND ol_o_id < d_next_o_id
  WHERE d_w_id = 117
  AND d_id = 1));

explain
SELECT
/*+
LEADING(@"SEL$2" ("VIEW1"@"SEL$2"))
USE_MERGE(@"SEL$2" ("test"."bmsql_stock"@"SEL$2" ))
*/
count(*) AS low_stock
FROM
(SELECT s_w_id, s_i_id, s_quantity
 FROM bmsql_stock
 WHERE s_w_id = 117
 AND s_quantity < 10
 AND s_i_id IN
 (SELECT ol_i_id
  FROM bmsql_district
  JOIN bmsql_order_line ON ol_w_id = d_w_id
  AND ol_d_id = d_id
  AND ol_o_id >= d_next_o_id - 20
  AND ol_o_id < d_next_o_id
  WHERE d_w_id = 117
  AND d_id = 1));

