set recyclebin = off;
drop database if exists muhangtest_slave_mapping;
purge recyclebin;
drop tablegroup if exists pq_map_pwj;
create database muhangtest_slave_mapping;
use muhangtest_slave_mapping;
set recyclebin = on;
create tablegroup pq_map_pwj;
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      number(10,2) NOT NULL ,
l_discount           number(10,2) NOT NULL ,
l_tax                number(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER),
index
i_l_orderkey(l_orderkey)
local
) tablegroup = pq_map_pwj partition by hash(L_ORDERKEY) partitions 5;
create table part(
p_partkey            bigint NOT NULL ,
p_name               varchar(55) ,
p_mfgr               char(25) ,
p_brand              char(10) ,
p_type               varchar(25) ,
p_size               bigint ,
p_container          char(10) ,
p_retailprice        number(10,2) ,
p_comment            varchar(23) ,
primary key (P_PARTKEY)
) tablegroup = pq_map_pwj partition by hash(P_PARTKEY) partitions 5;
create table customer(
c_custkey            bigint NOT NULL ,
c_name               varchar(25) ,
c_address            varchar(40) ,
c_nationkey          bigint ,
c_phone              char(15) ,
c_acctbal            number(10,2) ,
c_mktsegment         char(10) ,
c_comment            varchar(117),
primary key(C_CUSTKEY),
unique index i_c_custkey(c_custkey) local
) tablegroup = pq_map_pwj partition by hash(C_CUSTKEY) partitions 5;
create table orders(
o_orderkey           bigint NOT NULL ,
o_custkey            bigint NOT NULL ,
o_orderstatus        char(1) ,
o_totalprice         number(10,2) ,
o_orderdate          date ,
o_orderpriority      char(15) ,
o_clerk              char(15) ,
o_shippriority       bigint ,
o_comment            varchar(79),
primary key(o_orderkey),
index(o_orderkey) local
) tablegroup = pq_map_pwj partition by hash(o_orderkey) partitions 5;
explain select /*TPC-H Q18 parallel(2) pq_map(orders)*/ c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice, sum(l_quantity) from customer, orders, lineitem where o_orderkey in ( select l_orderkey from lineitem group by l_orderkey having sum(l_quantity) > 314 ) and c_custkey = o_custkey and o_orderkey = l_orderkey group by c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice order by o_totalprice desc, o_orderdate limit 100;
Query Plan
=============================================================================
|ID|OPERATOR                                 |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------------
|0 |LIMIT                                    |        |1       |43          |
|1 |└─PX COORDINATOR MERGE SORT              |        |1       |43          |
|2 |  └─EXCHANGE OUT DISTR                   |:EX10001|1       |43          |
|3 |    └─TOP-N SORT                         |        |1       |43          |
|4 |      └─HASH GROUP BY                    |        |1       |43          |
|5 |        └─HASH JOIN                      |        |1       |43          |
|6 |          ├─EXCHANGE IN DISTR            |        |1       |32          |
|7 |          │ └─EXCHANGE OUT DISTR (PKEY)  |:EX10000|1       |32          |
|8 |          │   └─PX PARTITION ITERATOR    |        |1       |32          |
|9 |          │     └─MERGE JOIN             |        |1       |32          |
|10|          │       ├─MERGE JOIN           |        |1       |22          |
|11|          │       │ ├─SUBPLAN SCAN       |VIEW1   |1       |11          |
|12|          │       │ │ └─MERGE GROUP BY   |        |1       |11          |
|13|          │       │ │   └─TABLE FULL SCAN|lineitem|1       |11          |
|14|          │       │ └─TABLE FULL SCAN    |lineitem|1       |11          |
|15|          │       └─TABLE FULL SCAN      |orders  |1       |11          |
|16|          └─PX PARTITION ITERATOR        |        |1       |11          |
|17|            └─TABLE FULL SCAN            |customer|1       |11          |
=============================================================================
