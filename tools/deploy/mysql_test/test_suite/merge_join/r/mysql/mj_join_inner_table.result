set @@recyclebin = off;
drop database if exists xy_db;
create database xy_db;
use xy_db;
set collation_connection='utf8mb4_general_ci';
drop table if exists t100_1, t200_2;
use test;
drop table if exists t100_1, t200_2;
set @@ob_read_consistency='weak';
use xy_db;
create table t100_1(c1 int, c2 int);
use test;
create table t200_2(c1 int, c2 int);
use oceanbase;
select /*+ use_merge(a b)*/ a.table_name from oceanbase.__all_virtual_table as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_name order by a.table_name;
table_name
t100_1
t200_2
