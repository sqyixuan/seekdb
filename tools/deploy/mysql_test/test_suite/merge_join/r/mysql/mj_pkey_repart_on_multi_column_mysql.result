      dop=1
  2 - output([t1.c1], [t2.pk], [t1.pk], [t1.c2], [t2.c1], [t2.c2]), filter(nil), rowset=16
      equal_conds([t1.c1 + t1.c1 = t2.pk]), other_conds(nil)
      merge_directions([ASC])
