      sort_keys([t1.c1 + t1.c1, ASC])
  4 - output([t1.c1], [t1.c1 + t1.c1], [t1.pk], [t1.c2]), filter(nil), rowset=16
  5 - output([t1.c1], [t1.c1 + t1.c1], [t1.pk], [t1.c2]), filter(nil), rowset=16
      (#keys=1, [t1.c1 + t1.c1]), dop=1
  6 - output([t1.pk], [t1.c1], [t1.c2]), filter(nil), rowset=16
      force partition granule
  7 - output([t1.pk], [t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.pk], [t1.c1], [t1.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.pk]), range(MIN ; MAX)always true
  8 - output([t2.pk], [t2.c1], [t2.c2]), filter(nil), rowset=16
