explain basic select * from t1 join t2 on t1.c2=t2.c2 and t1.c3=t2.c3 order by t1.c2;
Query Plan
=================================================
|ID|OPERATOR                           |NAME    |
-------------------------------------------------
|0 |PX COORDINATOR MERGE SORT          |        |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|
|2 |  └─SORT                           |        |
|3 |    └─HASH JOIN                    |        |
|4 |      ├─EXCHANGE IN DISTR          |        |
|5 |      │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|
|6 |      │   └─PX PARTITION ITERATOR  |        |
|7 |      │     └─TABLE FULL SCAN      |t1      |
|8 |      └─PX PARTITION ITERATOR      |        |
|9 |        └─TABLE FULL SCAN          |t2      |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      sort_keys([t1.c2, ASC])
  1 - output([t1.c2], [INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      dop=1
  2 - output([t1.c2], [t2.c2], [t1.c3], [t2.c3], [t1.c1], [t2.c1]), filter(nil), rowset=256
      sort_keys([t1.c2, ASC])
  3 - output([t1.c2], [t2.c2], [t1.c3], [t2.c3], [t1.c1], [t2.c1]), filter(nil), rowset=256
      equal_conds([t1.c2 = t2.c2], [t1.c3 = t2.c3]), other_conds(nil)
  4 - output([t1.c2], [t1.c3], [t1.c1]), filter(nil), rowset=256
  5 - output([t1.c2], [t1.c3], [t1.c1]), filter(nil), rowset=256
      (#keys=2, [t1.c2], [t1.c3]), dop=1
  6 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      force partition granule
  7 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0sp[0-1], p1sp[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2], [t1.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  8 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      affinitize, force partition granule
  9 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p0sp[0-3], p1sp[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
