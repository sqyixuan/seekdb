drop table t1;
drop table t2;

##  5.9两个都是一级key的分区表，key分区为两个列，二级list columns 。
create table t1 (c1 int, c2 int, c3 varchar(32)) partition by key(c1,c3) subpartition by list columns(c2) subpartition template(subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 3;
create table t2 (c1 int, c2 int, c3 varchar(32)) partition by key(c1,c3) subpartition by list columns(c2) subpartition template(subpartition p0 values in (1,3), subpartition p1 values in (default)) partitions 2;

