## part five key分区条件为两个列
## 5.1非分区表与一级key分区，分区条件两个列。
create table t1(c1 int primary key, c2 int, c3 int, c4 date);
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1, c2) partitions 16;

