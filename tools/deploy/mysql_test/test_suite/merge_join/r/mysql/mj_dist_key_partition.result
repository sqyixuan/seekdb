explain basic select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 order by t2.c2;
Query Plan
=================================================
|ID|OPERATOR                           |NAME    |
-------------------------------------------------
|0 |PX COORDINATOR MERGE SORT          |        |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|
|2 |  └─SORT                           |        |
|3 |    └─HASH JOIN                    |        |
|4 |      ├─PX PARTITION ITERATOR      |        |
|5 |      │ └─TABLE FULL SCAN          |t2      |
|6 |      └─EXCHANGE IN DISTR          |        |
|7 |        └─EXCHANGE OUT DISTR (PKEY)|:EX10000|
|8 |          └─TABLE FULL SCAN        |t1      |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      sort_keys([t2.c2, ASC])
  1 - output([t2.c2], [INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=256
      dop=1
  2 - output([t2.c2], [t1.c1], [t2.c1], [t1.c2], [t2.c3], [t1.c3], [t1.c4]), filter(nil), rowset=256
      sort_keys([t2.c2, ASC])
  3 - output([t2.c2], [t1.c1], [t2.c1], [t1.c2], [t2.c3], [t1.c3], [t1.c4]), filter(nil), rowset=256
      equal_conds([t1.c1 = t2.c1], [t1.c2 = t2.c2]), other_conds(nil)
  4 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      affinitize, force partition granule
  5 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[0-15])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  6 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
  7 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      (#keys=2, [t1.c1], [t1.c2]), is_single, dop=1
  8 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
select * from t1 join t2 on t1.c1=t2.c1 and t1.c2=t2.c2 order by t2.c2;
+----+------+------+------+----+----+----+
| c1 | c2   | c3   | c4   | c1 | c2 | c3 |
+----+------+------+------+----+----+----+
|  1 |    1 |   31 | NULL |  1 |  1 | 31 |
+----+------+------+------+----+----+----+
explain basic select * from t1 join t2 on (t1.c1, t2.c1)=(t2.c1, t2.c2) order by t2.c2;
Query Plan
===========================================
|ID|OPERATOR                     |NAME    |
-------------------------------------------
|0 |SORT                         |        |
|1 |└─NESTED-LOOP JOIN           |        |
|2 |  ├─PX COORDINATOR           |        |
|3 |  │ └─EXCHANGE OUT DISTR     |:EX10000|
|4 |  │   └─PX PARTITION ITERATOR|        |
|5 |  │     └─TABLE FULL SCAN    |t2      |
|6 |  └─TABLE GET                |t1      |
===========================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      sort_keys([t2.c2, ASC]), local merge sort
  1 - output([t2.c2], [t1.c1], [t1.c2], [t1.c3], [t1.c4], [t2.c1], [t2.c3]), filter(nil), rowset=16
      conds(nil), nl_params_([t2.c1(:0)]), use_batch=true
  2 - output([t2.c2], [t2.c1], [t2.c3]), filter(nil), rowset=16
  3 - output([t2.c2], [t2.c1], [t2.c3]), filter(nil), rowset=16
      dop=1
  4 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      force partition granule
  5 - output([t2.c1], [t2.c2], [t2.c3]), filter([t2.c1 = t2.c2]), rowset=16
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[0-15])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.c1], [t2.c2], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  6 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      access([GROUP_ID], [t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX), 
      range_cond([t1.c1 = :0])
select * from t1 join t2 on (t1.c1, t2.c1)=(t2.c1, t2.c2) order by t2.c2;
+----+------+------+------+----+----+----+
| c1 | c2   | c3   | c4   | c1 | c2 | c3 |
+----+------+------+------+----+----+----+
|  1 |    1 |   31 | NULL |  1 |  1 | 31 |
+----+------+------+------+----+----+----+
drop table t1;
drop table t2;

##  5.2两个都是一级range column 二级key的分区表，key分区为两个列。
create table t1(c1 int, c2 int, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c1,c3) subpartitions 2 (partition p0 values less than (15),partition p1 values less than (50));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c1,c3) subpartitions 4 (partition p0 values less than (15),partition p1 values less than (50));

