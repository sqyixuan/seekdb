create table t1(c1 int, c2 int, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by list columns(c2) subpartition by key(c1,c3) subpartitions 2 (partition p0 values in (1,2,3), partition p1 values in (default));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by list columns(c2) subpartition by key(c1,c3) subpartitions 4 (partition p0 values in (1,2,3),partition p1 values in (default));

