  7 - output([t1.c2], [t1.c4], [t1.c1], [t1.c3]), filter(nil), rowset=256
      access([t1.c2], [t1.c4], [t1.c1], [t1.c3]), partitions(p0sp[0-1], p1sp[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  8 - output([t2.c2], [t2.c4], [t2.c1], [t2.c3]), filter(nil), rowset=256
      affinitize, force partition granule
  9 - output([t2.c2], [t2.c4], [t2.c1], [t2.c3]), filter(nil), rowset=256
      access([t2.c2], [t2.c4], [t2.c1], [t2.c3]), partitions(p0sp[0-3], p1sp[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
