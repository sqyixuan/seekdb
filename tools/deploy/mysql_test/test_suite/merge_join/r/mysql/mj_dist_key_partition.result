##  6.4两个都是一级range columns二级key的分区表，key分区为两个列。
create table t1(c1 int, c2 int, c3 varchar(32) not null, c4 int) partition by range columns(c2, c4) subpartition by key(c1,c3) subpartitions 2 (partition p0 values less than (5,43), partition p1 values less than (MAXVALUE, MAXVALUE));
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, c4 int) partition by range columns(c2, c4) subpartition by key(c1,c3) subpartitions 4 (partition p0 values less than (3,43), partition p1 values less than (MAXVALUE, MAXVALUE));

