## part six key+range columns分区条件为两个列
##  6.1两个都是一级key的分区表，key分区为两个列，二级range columns。
create table t1 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by range columns(c2, c4) subpartition template(subpartition p0 values less than (3, 40), subpartition p1 values less than (MAXVALUE, MAXVALUE)) partitions 3;
create table t2 (c1 int, c2 int, c3 varchar(32), c4 int) partition by key(c1,c3) subpartition by range columns(c2, c4) subpartition template(subpartition p0 values less than (14, 40), subpartition p1 values less than (MAXVALUE, MAXVALUE)) partitions 2;

