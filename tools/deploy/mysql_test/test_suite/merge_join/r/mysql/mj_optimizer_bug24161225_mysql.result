drop table if exists t1, t2, t3;
create table t1 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk) partitions 4;
create table t2 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk) partitions 5;
create table t3 (pk int primary key, c1 int, c2 int, c3 int, index idx (c1) local) partition by hash(pk) partitions 5;
alter system set ob_enable_batched_multi_statement = true;
result_format: 4
explain_protocol: 2
EXPLAIN insert into t1 select /*+use_merge(t1,t2)*/ t1.* from t1, t2 where t1.pk = t2.pk;
Query Plan
=================================================================================
