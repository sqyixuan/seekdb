CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(13)  
begin
IF samplename IS NOT NULL then
CALL p_test(3);
END IF;
RETURN 0;
END;
//
CREATE PROCEDURE p_test(in p_in int)
begin
update t1 set id=p_in;
END;
//
