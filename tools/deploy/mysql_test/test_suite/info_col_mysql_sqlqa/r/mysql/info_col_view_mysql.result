CREATE VIEW t9_view as WITH
cte1 AS (SELECT 1 as a, 2 as b FROM dual),
cte2 AS (SELECT 1 as c, 4 as d FROM dual)
SELECT b, d FROM cte1 JOIN cte2
WHERE cte1.a = cte2.c;
