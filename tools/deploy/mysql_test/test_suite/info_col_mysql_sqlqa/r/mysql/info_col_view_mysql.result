CREATE TABLE t1(
a bigint,
b date
)partition by range columns(b) 
( 
partition part_1 values less than ('2016-09-01'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
CREATE VIEW t1_view AS SELECT * FROM t1;
CREATE TABLE t9(
id BIGINT,
brand VARCHAR(255) DEFAULT '中国',
color int NOT NULL,
primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9,t1_view WHERE t1_view.a=t9.id ORDER BY t1_view.a;
