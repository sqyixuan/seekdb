## 约束 ob_mysql_2
## 主键，非空，唯一
CREATE TABLE t9 (  
     id BIGINT UNSIGNED  PRIMARY KEY AUTO_INCREMENT,  
     brand VARCHAR(255) NOT NULL,  
     color int unique
);
CREATE VIEW t9_view AS SELECT * FROM t9;
SELECT TABLE_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP VIEW t9_view;

# 无主键，非空，唯一
CREATE TABLE t9 (  
     id BIGINT UNSIGNED,  
     brand VARCHAR(255) NOT NULL,  
     color int unique
);
CREATE VIEW t9_view AS SELECT * FROM t9;
SELECT TABLE_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP VIEW t9_view;

#  无主键，非空唯一
CREATE TABLE t9 (  
     id BIGINT UNSIGNED,  
     brand VARCHAR(255) NOT NULL unique,  
     color int unique	 
);
CREATE VIEW t9_view AS SELECT * FROM t9;
SELECT TABLE_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP VIEW t9_view;

#  无主键，唯一索引
CREATE TABLE t9 (  
    id BIGINT UNSIGNED,  
    brand VARCHAR(255) not null,  
    color int,
	unique key unique_brand(brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9;
SELECT TABLE_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP VIEW t9_view;


# 无主键，多列索引
CREATE TABLE t9 (  
    id BIGINT UNSIGNED,  
    brand VARCHAR(255) ,  
    color int,
	unique key unique_brand(id,brand)
);
