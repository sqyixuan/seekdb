## 普通表 + 其他表 ob_mysql_3

CREATE TABLE t1(
    id INT,
    name VARCHAR(20)
) PARTITION BY KEY(id) PARTITIONS 2;
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT t1.id, t9.brand, t9.color FROM t9,t1 ORDER BY t1.id;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_NAME,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t1(
    a bigint,
	b date
)partition by range columns(b) 
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9,t1 WHERE t1.a=t9.id ORDER BY t1.a;
# CREATE VIEW t9_view AS SELECT * FROM t1,t9 WHERE t1.a=t9.id ORDER BY t1.a;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_NAME,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t1(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t1,t9 WHERE t1.a=t9.id ORDER BY t1.a;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_NAME,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t1(a INT , b VARCHAR(50)) PARTITION BY LIST columns(b)(
	PARTITION p0 VALUES IN ('abc\def','中国\人民'),
	PARTITION p1 VALUES IN ('hig\多多','klm \ \ ')
);
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t1,t9 WHERE t1.a=t9.id ORDER BY t1.a;
ALTER TABLE t9 DROP PRIMARY KEY;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
