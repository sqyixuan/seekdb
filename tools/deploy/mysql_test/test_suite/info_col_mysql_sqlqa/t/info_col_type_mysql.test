SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t1(
    a bigint,
	b datetime
)partition by range columns(b) SUBPARTITION by hash(a) subpartitions 2
( 
	partition part_1 values less than ('2016-09-01'),
	partition part_2 values less than ('2020-09-01'),
	partition part_3 values less than ('2021-09-01')
);
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9,t1 WHERE t1.a=t9.id ORDER BY t1.a;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_NAME,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t1(
	a INT , 
	b VARCHAR(50) PRIMARY KEY, 
	c VARCHAR(50) 
) PARTITION BY LIST columns(b) SUBPARTITION BY KEY(B) SUBPARTITIONS 2(
	PARTITION p0 VALUES IN ('abc\def','中国\人民')
);
CREATE TABLE t9(
	id BIGINT,
	brand VARCHAR(255) DEFAULT '中国',
	color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9,t1 WHERE t1.a=t9.id ORDER BY t1.a;
SELECT TABLE_NAME,COLUMN_NAME,ORDINAL_POSITION,COLUMN_DEFAULT FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_NAME,IS_NULLABLE,COLUMN_KEY,EXTRA FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT COLUMN_TYPE,COLUMN_COMMENT,GENERATION_EXPRESSION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
SELECT CHARACTER_MAXIMUM_LENGTH,CHARACTER_OCTET_LENGTH,NUMERIC_PRECISION,NUMERIC_SCALE,DATETIME_PRECISION FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='t9_view' AND TABLE_SCHEMA='obwmjtest';
DROP TABLE t9;
DROP TABLE t1;
DROP VIEW t9_view;


CREATE TABLE t9 (  
    id BIGINT UNSIGNED comment 'id number',  
    brand VARCHAR(255) DEFAULT '中国',  
    color int NOT NULL,
	primary key (id,brand)
);
CREATE VIEW t9_view AS SELECT * FROM t9;
ALTER TABLE t9 modify column color set ('123') ;
