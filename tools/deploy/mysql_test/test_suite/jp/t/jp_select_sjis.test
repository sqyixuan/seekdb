# owner: sanquan.qz
# owner group: sql1
# tags: charset, sjis


--source mysql_test/test_suite/jp/include/copy_data_for_direct_load.inc

connection default;

SET NAMES sjis;
SET character_set_database = sjis;

--character_set sjis
--disable_warnings
drop table if exists `굎괦`;
drop table if exists `굎괧`;
drop table if exists `굎괨`;
drop table if exists `굎괪`;
drop table if exists `굎괫`;
drop table if exists `굎괮`;
drop table if exists `굎괯`;
drop table if exists `굎괰`;
drop table if exists `굎괱`;
--enable_warnings

#
# Test Displaying Japanese charact in sjis encoding
#

CREATE TABLE `굎괦` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괧` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괨` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `굎괪` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괫` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괮` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `굎괯` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `굎괰` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `굎괱` (`괷괦` char(20), INDEX(`괷괦`)) DEFAULT CHARSET = sjis engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data
# jisx0212 supplemental character data

 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `굎괦` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `굎괧` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `굎괨` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `굎괪` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `굎괫` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `굎괮` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `굎괯` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `굎괰` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `굎괱`CHARACTER SET SJIS;

#InnoDB
SELECT * FROM `굎괦`;
SELECT * FROM `굎괧`;
SELECT * FROM `굎괨`;
#MyISAM
SELECT * FROM `굎괪`;
SELECT * FROM `굎괫`;
SELECT * FROM `굎괮`;
#MEMORY
SELECT * FROM `굎괯`;
SELECT * FROM `굎괰`;
SELECT * FROM `굎괱`;

drop table `굎괦`;
drop table `굎괧`;
drop table `굎괨`;
drop table `굎괪`;
drop table `굎괫`;
drop table `굎괮`;
drop table `굎괯`;
drop table `굎괰`;
drop table `굎괱`;
