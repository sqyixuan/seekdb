#InnoDB
SELECT DISTINCT CHARSET(`俠侾`) FROM `俿侾`;
SELECT DISTINCT CHARSET(`俠侾`) FROM `俿俀`;
SELECT DISTINCT CHARSET(`俠侾`) FROM `俿俁`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING utf8)) FROM `俿侾`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING sjis)) FROM `俿侾`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING utf8)) FROM `俿俀`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING sjis)) FROM `俿俀`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING utf8)) FROM `俿俁`;
SELECT DISTINCT CHARSET(CONVERT(`俠侾` USING sjis)) FROM `俿俁`;

