--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sanquan.qz
# owner group: sql1
# tags: charset, sjis

--source mysql_test/test_suite/jp/include/copy_data_for_direct_load.inc

connection default;

SET NAMES sjis;
SET character_set_database = sjis;


--character_set sjis
--disable_warnings
drop table if exists `俿侾`;
drop table if exists `俿俀`;
drop table if exists `俿俁`;
drop table if exists `俿係`;
drop table if exists `俿俆`;
drop table if exists `俿俇`;
drop table if exists `俿俈`;
drop table if exists `俿俉`;
drop table if exists `俿俋`;
--enable_warnings

#
# Test CHARSET() function with Japanese characters in sjis encoding
#

CREATE TABLE `俿侾` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `俿俀` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `俿俁` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `俿係` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `俿俆` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `俿俇` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `俿俈` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `俿俉` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `俿俋` (`俠侾` char(20)) DEFAULT CHARSET = sjis engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data

--disable_query_log
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `俿侾` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `俿俀` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `俿俁` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `俿係` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `俿俆` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `俿俇` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `俿俈` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `俿俉` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `俿俋`CHARACTER SET SJIS;
--enable_query_log

