# tags: charset, sjis


--source mysql_test/test_suite/jp/include/copy_data_for_direct_load.inc

connection default;

SET NAMES sjis;
SET character_set_database = sjis;
--character_set sjis
--disable_warnings
drop table if exists `²s²P`;
drop table if exists `²s²Q`;
drop table if exists `²s²R`;
drop table if exists `²s²S`;
drop table if exists `²s²T`;
drop table if exists `²s²U`;
drop table if exists `²s²V`;
drop table if exists `²s²W`;
drop table if exists `²s²X`;
--enable_warnings

#
# Test Displaying Japanese charact using WHERE condtion in sjis encoding
#

SET NAMES sjis;
SET character_set_database = sjis;

CREATE TABLE `²s²P` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `²s²Q` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `²s²R` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = innodb;
CREATE TABLE `²s²S` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `²s²T` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `²s²U` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = myisam;
CREATE TABLE `²s²V` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `²s²W` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = MEMORY;
CREATE TABLE `²s²X` (`²b²P` char(20), INDEX(`²b²P`)) DEFAULT CHARSET = sjis engine = MEMORY;

#Load the following data in each table
# jisx0201 hankaku-katakana data
# jisx0208 data
# jisx0212 supplemental character data

--disable_query_log
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `²s²P` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `²s²Q` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `²s²R` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `²s²S` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `²s²T` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `²s²U` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0201_sjis.dat' INTO TABLE `²s²V` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis.dat' INTO TABLE `²s²W` CHARACTER SET SJIS;
 LOAD DATA INFILE 'data_for_mysqltest_direct_loaddata/jisx0208_sjis2.dat' INTO TABLE `²s²X`CHARACTER SET SJIS;
--enable_query_log


