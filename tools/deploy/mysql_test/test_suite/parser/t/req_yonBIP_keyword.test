--echo "keyword"

--error 0,1051
drop table `order`;
create table `order` (`add` int, `check` int);

insert into `order`(order.add, order.check) values (1,1);
select order.add, `order`.check from `order`;
update `order` set order.add = 2;
update `order` set order.check = 3;
select `order`.`add`, `order`.check from `order`;
