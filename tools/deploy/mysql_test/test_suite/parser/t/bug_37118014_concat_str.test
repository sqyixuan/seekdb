--echo --bugfix:
SELECT abs('世界人民' "中国人民") from dual;
SELECT crc32('世界人民' "中国人民") from dual;
SELECT crc32('' """""") from dual;

select "a" 'b' "c" 'd';
select "a" "b" "c" "d";
select "a" 'b' "c" as "d";
--error 1064
select "a" 'b' "c" as "d" 'e' 'f';

--error 0,1051
drop table t1;
create table t1 (c1 varchar(100));
insert into t1 values ("a" "b" 'c' "d");
select * from t1;

delete from t1 where c1 like "%" 'b' "%";
select * from t1;
drop table t1;
