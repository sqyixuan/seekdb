--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int) partition by range(c1) (partition p0 values less than (0));
--error 1064
alter table t1 add partition (partition p1 values less than (1)), add partition (partition p2 values less than (2));
alter table t1 add partition (partition p1 values less than (1), partition p2 values less than (2));
--error 1064
alter table t1 drop partition p0, drop partition p1;
alter table t1 drop partition p0, p1;

drop table t1;