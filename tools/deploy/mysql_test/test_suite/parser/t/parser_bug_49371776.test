--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# tags: fast parser
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 1170, error_code = 4001, frequency = 1;
connection default;
--error 1054
select 0x0G from dual;
select 0x0A from dual;
select 0x0F from dual;
select 0x0F+1 from dual;
select 0x0F,1 from dual;
select 0x0F , 1 from dual;
select 0x0F-1 from dual;
--error 1064
select 0x0F( from dual;
--error 1064
select 0x0F) from dual;
--error 1054
select 0x0FG from dual;
connection conn_admin;
alter system set_tp tp_no = 1170, error_code = 0, frequency = 1;
connection default;


