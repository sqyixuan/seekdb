--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# description: 
# tags: parser
#
#

--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
sleep 2;
connection default;
alter system set _rowsets_enabled=false;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
--enable_result_log
--enable_query_log
sleep 6;

connection default;

delimiter //;
select 1 -- 
; select 2 -- 
; select 3 -- 
;//
delimiter ;//
commit;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

