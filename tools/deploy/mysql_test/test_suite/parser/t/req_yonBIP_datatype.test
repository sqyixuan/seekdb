# tags: parser, data_type

--echo "data type"
--error 0,1051
drop table t1;
create table t1 (c1 bool, c2 boolean, c3 character varying(1), c4 fixed, c5 float4, c6 float8, c7 int1, c8 int2, c9 int3, c10 int4, c11 int8, c12 long varbinary, c13 long varchar, c14 long, c16 numeric);
desc t1;
alter table t1 add column c15 middleint after c14;
desc t1;
alter table t1 add column `int2` middleint before c16;
desc t1;
select t1.int2 from t1;
