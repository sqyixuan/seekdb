--result_format 4

delimiter //;

--echo #末尾多个分号，不报错
select 1 from dual;;//
select 1 from dual; ;//
select 1 from dual
;;//
select 1 from dual;
;;//
select 1 from dual
;
; //
select 1 from dual;
;
; //

select 1 from dual; /*abc*/;//
select 1 from dual; /*abc*/; ;//
select 1 from dual; /*abc*/;
; ;//
select 1 from dual; /*abc*/
;//
select 1 from dual -- a
; ; //
select 1 from dual -- a
; -- b
; //

--echo #查询内多个分号，报错
--error 1065
select 1 from dual;;select 1 from dual;//
--error 1065
select 1 from dual;;select 1 from dual//
--error 1065
select 1 from dual; ;select 1 from dual;//
--error 1065
select 1 from dual; ;select 1 from dual//
--error 1065
select 1 from dual;
;select 1 from dual;//
--error 1065
select 1 from dual;
;select 1 from dual//
--error 1065
select 1 from dual; ;/*abc*/; //
--error 1065
select 1 from dual; ;/*abc*/ //

--echo #查询内有多个分号但分号之间有注释分隔，ob不报错mysql报语法错
select 1 from dual; /*abc*/; /*abd*/;//
select 1 from dual; /*abc*/
; /*abd*/;//
select 1 from dual; /*abc*/
; /*abd*/
//
select 1 from dual; -- a
; -- b
; //
select 1 from dual; -- a
; /*abc*/
; //

delimiter ;//