result_format: 4

#末尾多个分号，不报错
select 1 from dual;;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; ;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual
;;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual;
;;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual
;
; //
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual;
;
; //
+---+
| 1 |
+---+
| 1 |
+---+

select 1 from dual; /*abc*/;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; /*abc*/; ;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; /*abc*/;
; ;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; /*abc*/
;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual -- a
; ; //
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual -- a
; -- b
; //
+---+
| 1 |
+---+
| 1 |
+---+

#查询内多个分号，报错
select 1 from dual;;select 1 from dual;//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual;;select 1 from dual//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual; ;select 1 from dual;//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual; ;select 1 from dual//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual;
;select 1 from dual;//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual;
;select 1 from dual//
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual; ;/*abc*/; //
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty
select 1 from dual; ;/*abc*/ //
+---+
| 1 |
+---+
| 1 |
+---+
ERROR 42000: Query was empty

#查询内有多个分号但分号之间有注释分隔，ob不报错mysql报语法错
select 1 from dual; /*abc*/; /*abd*/;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; /*abc*/
; /*abd*/;//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; /*abc*/
; /*abd*/
//
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; -- a
; -- b
; //
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from dual; -- a
; /*abc*/
; //
+---+
| 1 |
+---+
| 1 |
+---+

