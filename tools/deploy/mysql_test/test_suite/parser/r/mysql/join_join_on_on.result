drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1 (c1 int, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int);
create table t3 (c1 int, c2 int, c3 int, c4 int);
create table t4 (c1 int, c2 int, c3 int, c4 int);
select * from t1 left join t2 left join t3 on t2.c2 = t3.c2 on t1.c3 = t2.c3 left join t4 on t4.c1 = t1.c1;
select * from t1 left join t2 left join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 inner join t2 left outer join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 left join t2 right join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 full join t2 right outer join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 left join t2 inner join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 left join t2 full join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
select * from t1 inner join t2 full outer join t3 left join t4 on t3.c1 = t4.c1 on t2.c2 = t3.c2 on t1.c3 = t2.c3;
drop table t1;
drop table t2;
drop table t3;
drop table t4;
