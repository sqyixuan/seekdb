--echo obmysql-cast-2
--error 0,1051
drop table cast_table;
create table cast_table(a char(50))  default character set = 'utf16';
insert into cast_table values('kebi'),('科比'),('565656');

select a,cast(a as CHAR(2) CHARACTER set utf16)  from cast_table;
--error 1064
select a,cast(a as CHAR(2) CHARACTER set utf16 collate utf16_bin)  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf16) collate utf16_bin from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf16) collate utf16_general_ci from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf16) collate utf16_unicode_ci from cast_table;

select a,cast(a as CHAR(2) CHARACTER set utf8mb4)  from cast_table;
--error 1064
select a,cast(a as CHAR(2) CHARACTER set utf8mb4 collate utf8mb4_bin)  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf8mb4) collate utf8mb4_bin  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf8mb4) collate utf8mb4_general_ci  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set utf8mb4) collate utf8mb4_unicode_ci  from cast_table;

select a,cast(a as CHAR(2) CHARACTER set gbk)  from cast_table;
--error 1064
select a,cast(a as CHAR(2) CHARACTER set gbk collate gbk_bin)  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set gbk) collate gbk_bin from cast_table;
select a,cast(a as CHAR(2) CHARACTER set gbk) collate gbk_chinese_ci from cast_table;

select a,cast(a as CHAR(2) CHARACTER set binary)  from cast_table;

select a,cast(a as CHAR(2) CHARACTER set gb18030)  from cast_table;
--error 1064
select a,cast(a as CHAR(2) CHARACTER set gb18030 collate gb18030_bin)  from cast_table;
select a,cast(a as CHAR(2) CHARACTER set gb18030) collate gb18030_bin from cast_table;
select a,cast(a as CHAR(2) CHARACTER set gb18030) collate gb18030_chinese_ci from cast_table;






