#owner:luofan.zp
#owner group:sql3
#description:函数嵌套 约束  索引


--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);


--error 0,1051
drop table cast_table;

create table cast_table(id int, sal double, name varchar(40),date_time datetime);
insert into cast_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#函数嵌套
select e.id,e.name,cast(cast(e.sal as signed)as char(10)) from cast_table e order by e.id desc;

select e.id,e.name,cast(sum(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,sum(cast(e.sal as signed)) from cast_table e group by 1,2 having sum(cast(e.sal as signed)) > 2000 order by id desc;

select e.id,e.name,cast(max(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,max(cast(e.sal as signed)) from cast_table e group by 1,2 having sum(cast(e.sal as signed)) > 2000 order by id desc;


select e.id,e.name,cast(min(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,min(cast(e.sal as signed)) from cast_table e group by 1,2 having sum(cast(e.sal as signed)) > 2000 order by id desc;

select e.id,e.name,cast(avg(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,avg(cast(e.sal as signed)) from cast_table e group by 1,2 having avg(cast(e.sal as signed)) > 2000 order by id desc;


select e.id,e.name,cast(abs(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,abs(cast(e.sal as signed)) from cast_table e group by 1,2  order by id desc limit 2;

select e.id,e.name,cast(ceil(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,ceil(cast(e.sal as signed)) from cast_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,cast(floor(e.sal) as signed) from cast_table e order by e.id desc;
select e.id,e.name,floor(cast(e.sal as signed)) from cast_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,cast(mod(e.sal,7.8) as signed) from cast_table e order by e.id desc;
select e.id,e.name,mod(cast(e.sal as signed),7.8) from cast_table e group by 1,2  order by id desc;


select e.id,e.name,cast(length(e.sal) as char(10)) from cast_table e order by e.id desc;
select e.id,e.name,length(cast(e.sal as char(10))) from cast_table e group by 1,2  order by id desc;

select e.id,instr(cast(e.name as char(4)),'i'),e.sal from cast_table e order by id desc;
select e.id,cast(instr(e.name,'i') as char(4)),e.sal from cast_table e order by id desc;




#算数运算符
select e.id,e.name,cast(e.sal as signed)+100 from cast_table e ;
select e.id,e.name,cast(e.sal as signed)-100 from cast_table e ;
select e.id,e.name,cast(e.sal as signed)*100 from cast_table e ;
select e.id,e.name,cast(e.sal as signed)/100 from cast_table e ;


#逻辑运算符
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) > 1500 and cast(e.sal as signed) < 3000;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) > 2000 or e.id >20;
select e.id,e.name,e.sal from cast_table e where not(cast(e.sal as signed)) < 1500;
select e.id,e.name,e.sal from cast_table e where not(cast(e.sal as signed)) > 2000;


#比较预算符
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) >= 2000;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) <= 2000;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed)  = 1501;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed)  > 1501;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed)  < 1502;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) <> 1501;
select e.id,e.name,e.sal from cast_table e where cast(e.sal as signed) != 1501;



#索引
create index cast_name on cast_table(id);

#select
select cast(e.id as char(2)) from cast_table e;
select e.name,e.sal from cast_table e where cast(e.id as char(2)) = '10';
select e.name,e.sal from cast_table e where cast(e.id as char(2)) > '10' order by e.sal desc; 

#insert
insert into cast_table  select * from cast_table e where cast(e.id as char(2)) = '10';
select * from cast_table;


#update
update cast_table e set name = 'zanms' where cast(e.id as char(2)) = '10';
select * from cast_table;


#delete
delete from cast_table  where cast(id as char(2)) = '10' ;
select * from cast_table;




#约束
--error 0,1051
drop table cast_table;
create table cast_table(id int primary key, sal double unique, name varchar(40) not null,date_time datetime);
insert into cast_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#select
select cast(id as char(20)),cast(sal as signed),cast(name as char(20)) from cast_table;
select cast(id as char(20)),cast(sal as signed),cast(name as char(20)) from cast_table where cast(sal as signed) = 3000;
select cast(id as char(20)),cast(sal as signed),cast(name as char(20)) from cast_table where cast(sal as signed) = 3000 order by id;


#insert
insert into cast_table  select cast(id+1 as signed)id,cast(e.sal as signed),cast(e.name as char(20)),e.date_time from cast_table e where cast(e.sal as signed) = 3000 ;
select count(*) from cast_table;


#update
update cast_table  set name = 'zanms' where cast(sal as signed) = 3000;
select * from cast_table;


##delete
delete from cast_table  where cast(sal as signed) = 3000 ;
select count(*) from cast_table;




--error 0,1051
drop table cast_table;



--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings
