#description:视图 常用sql


--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);




--echo obmysql-cast-5
--echo obmysql-cast-5-1
--error  0,1051
drop table cast_table2;
--error 0,1051
drop table cast_table;
--error 0,1051
drop view cast_view;
create table cast_table(id int, order_id double, name varchar(40),date_time datetime);
insert into cast_table values(10,15.59,'kebi','2020-05-01 12:01:35'),(15,14.29,'maidi','2020-05-17 18:02:30'),(29,12.32,'yaoming','2020-05-23 23:59:59');

create table cast_table2(id int, sal double, order_number varchar(40),date_time datetime);
insert into cast_table2 values(10,3000.265 ,'10','2020-05-01 12:01:35'),(15,2100.25,'15.29','2020-05-17 18:02:30'),(29,1500.69,'12.32','2020-05-23 23:59:59');

#select 
select cast(e.order_id as char(4)) a,cast(e.name as char(4)) b from cast_table e;
select p.a,p.b from (select cast(e.order_id as char(4)) a,cast(e.name as char(4)) b from cast_table e ) p ;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_table e left join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_table e right join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_table e inner join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;



#别名
select cast(e.order_id as char(4)) a,cast(e.name as char(4)) 姓名 from cast_table e;
select cast(e.name as char(4)) collate utf8mb4_general_ci as 姓名 from cast_table e;
select cast(e.name as char(4)) collate utf8mb4_general_ci  姓名 from cast_table e;


#exists
select e.id,e.name from cast_table e where exists(select * from cast_table2 p where cast(p.order_number as signed) = e.id ) order by 1 desc;
select e.id,e.name from cast_table e where not exists(select * from cast_table2 p where cast(p.order_number as signed) = e.id ) order by 1 desc;
select e.id,e.name from cast_table e where exists(select * from cast_table2 p where p.order_number = cast(e.id as char(20))) order by 1 desc;
select e.id,e.name from cast_table e where not exists(select * from cast_table2 p where p.order_number = cast(e.id as char(20)))order by 1 desc;


#any 
select e.id,e.name from cast_table e where e.id > any(select avg(cast(p.order_number as signed )) from cast_table2 p);
select e.id,e.name from cast_table e where e.id < any(select avg(cast(p.order_number as signed )) from cast_table2 p );
select e.id,e.name from cast_table e where e.id = any(select cast(p.order_number as signed ) from cast_table2 p );


#all
select e.id,e.name from cast_table e where e.id > all(select cast(p.order_number as signed ) from cast_table2 p where p.id = 29);
select e.id,e.name from cast_table e where e.id < all(select cast(p.order_number as signed ) from cast_table2 p where p.id = 29);
select e.id,e.name from cast_table e where e.id = all(select cast(p.order_number as signed ) from cast_table2 p where p.id = 10);

#like
select *  from cast_table a  where cast(a.order_id as char(20)) like '%5%';
select cast(a.name as  char(10))  from cast_table a where name like '%k%';


#别名
select cast(e.sal as signed) aab from cast_table2 e;
select cast(e.sal as signed) aab工资 from cast_table2 e;


#where
select e.id,e.sal from cast_table2 e where cast(e.sal as signed) > 2000 order by e.id;
select e.id,e.sal from cast_table2 e where cast(e.sal as signed) > 2000  and cast(e.sal as signed) < 3000 order by e.id;
select e.id,e.sal from cast_table2 e where cast(e.sal as signed) > 2000  or cast(e.order_number as signed) > 15 order by e.id;
select cast(e.sal as signed) from cast_table2 e where e.id>20 order by e.id desc;


#order by 
select e.id,e.name,p.sal from cast_table e left join cast_table2 p on e.id = p.id where cast(p.sal as signed) > 2000 order by cast(p.sal as signed) limit 2;
select e.id,e.name,p.sal from cast_table e left join cast_table2 p on e.id = p.id where cast(p.sal as signed) > 2000 order by cast(p.sal as signed)desc limit 2;


#group by having
select e.id,sum(e.sal) from cast_table2 e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from cast_table2 e where e.sal > 1000 group by 1 having sum(e.sal) > 2000 order by 1 desc;



#cast when
select e.id 编号,case when cast(e.sal as signed) < 2000 then '低' when cast(e.sal as signed) < 3000 then '一般' else '高' end '工资' from cast_table2 e ;
select e.id 编号,case cast(e.sal as signed)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from cast_table2 e;


#insert into as 
insert into cast_table select *  from cast_table2 p where cast(p.sal as signed)  = 3000;
select *  from cast_table;
--error 0,1292
insert into cast_table select *  from cast_table2 p where cast(p.order_number as signed)  = 10;


#update as 
select *  from cast_table;
update cast_table set name = 'zanms' where cast(order_id as signed) = 3000;
select *  from cast_table where name = 'zanms';



#delete
delete from cast_table2 where cast(sal as signed) = 3000 ;
select cast(sal as signed) from cast_table2;


#视图
create view cast_view as select e.id,e.name,p.sal,p.date_time from cast_table e left join cast_table2 p on e.id = p.id order by e.id desc;
select *  from cast_view;



#select 
select cast(e.sal as char(4)) a,cast(e.name as char(3)) b from cast_view e;
select p.a,p.b from (select cast(e.sal as char(4)) a,cast(e.name as char(4)) b from cast_view e ) p ;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_view e left join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_view e right join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;
select e.id,e.name,cast(p.sal as signed),p.date_time from cast_view e inner join cast_table2 p on cast(p.order_number as signed) = e.id order by 1 desc;


#别名
select cast(e.name as char(4)) a,cast(e.sal as char(4)) 姓名 from cast_view e;
select cast(e.date_time as char(4)) collate utf8mb4_general_ci as 时间 from cast_view e;
select cast(e.date_time as char(4)) collate utf8mb4_general_ci  时间 from cast_view e;


# exists
select e.id,e.name from cast_table e where exists(select * from cast_view p where cast(p.id as signed) = e.id ) order by 1 desc;
select e.id,e.name from cast_table e where not exists(select * from cast_view p where cast(p.id as signed) = e.order_id ) order by 1 desc;
select e.id,e.name from cast_table e where exists(select * from cast_view p where p.id = cast(e.id as char(20))) order by 1 desc;
select e.id,e.name from cast_table e where not exists(select * from cast_view p where p.id = cast(e.order_id as char(20)))order by 1 desc;



# any 
select e.id,e.name from cast_table e where e.order_id > any(select cast(p.id as signed ) from cast_view p);
select e.id,e.name from cast_table e where e.order_id < any(select cast(p.id as signed ) from cast_view p);
select e.id,e.name from cast_table e where e.id = any(select cast(p.id as signed ) from cast_view p);



# all
select e.id,e.order_number from cast_table2 e where e.sal > all(select cast(p.sal as signed ) from cast_view p where p.id = 29);
select e.id,e.order_number from cast_table2 e where e.sal < all(select cast(p.sal as signed ) from cast_view p where p.id = 29);
select e.id,e.order_number from cast_table2 e where cast(e.sal as signed) = all(select cast(p.sal as signed ) from cast_view p where p.id = 10);



# like
select *  from cast_view a  where cast(a.name as char(20)) like '%m%';
select cast(a.name as char(10))  from cast_view a where name like '%k%';



# 别名
select cast(e.sal as signed) aab from cast_view e;
select cast(e.sal as signed) aab工资 from cast_view e;
 

# where
select e.id,e.sal from cast_view e where cast(e.sal as signed) > 2000 order by e.id;
select e.id,e.sal from cast_view e where cast(e.sal as signed) > 2000  and cast(e.sal as signed) < 3000 order by e.id;
select e.id,e.sal from cast_view e where cast(e.sal as signed) > 2000  or cast(e.id as signed) > 15 order by e.id;
select cast(e.sal as signed) from cast_view e where e.id>20 order by e.id desc;
 

# order by 
select e.id,e.name,p.sal from cast_table e left join cast_view p on e.id = p.id where cast(p.sal as signed) > 2000 order by cast(p.sal as signed) limit 2;
select e.id,e.name,p.sal from cast_table e left join cast_view p on e.id = p.id where cast(p.sal as signed) > 2000 order by cast(p.sal as signed)desc limit 2;
 
 
# group by having
select e.id,sum(e.sal) from cast_view e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from cast_view e where e.sal > 1000 group by 1 having sum(e.sal) > 2000 order by 1 desc;



# cast when
select e.id 编号,case when cast(e.sal as signed) < 2000 then '低' when cast(e.sal as signed) < 3000 then '一般' else '高' end '工资' from cast_view e ;
select e.id 编号,case cast(e.sal as signed)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from cast_view e;



--error 0,1051
drop table cast_table;
--error 0,1051
drop table cast_table2;
--error 0,1051
drop view cast_view;

create or replace  view v2 as select cast(1 as char(512)) from dual;
desc v2;
create or replace  view v2 as select cast(1 as char(513)) from dual;
desc v2;
create or replace  view v2 as select cast(1 as char(16383)) from dual;
desc v2;
create or replace  view v2 as select cast(1 as char(16384)) from dual;
desc v2;
create or replace  view v2 as select cast(1 as char(4194303)) from dual;
desc v2;
create or replace  view v2 as select cast(1 as char(4194304)) from dual;
desc v2;
drop view v2;

