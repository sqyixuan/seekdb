#owner: luofan.zp
#owner group: sql1
#description: test math function
--enable_metadata

--disable_warnings
drop table if exists t_int;
drop table if exists t_float;
drop table if exists t_date;
drop table if exists t_time;
drop table if exists t_string;
--enable_warnings

create table t_int(
c_tinyint tinyint,
c_utinyint tinyint unsigned,
c_smallint smallint,
c_usmallint smallint unsigned,
c_medium mediumint,
c_int int,c_int5 int(15),
c_uint int unsigned,
c_big bigint,
c_ubig bigint unsigned
);
select cast(c_tinyint as binary), cast(c_smallint as binary), cast(c_int as binary), cast(c_int5 as binary), cast(c_uint as binary),cast(c_big as binary) from t_int;

select cast(c_tinyint as unsigned), cast(c_smallint as unsigned), cast(c_int as unsigned), cast(c_int5 as unsigned), cast(c_uint as unsigned),cast(c_big as unsigned) from t_int;

create table t_float(
c_float float,
c_ufloat float unsigned,
c_double double,
c_udouble double unsigned,
c_dec decimal,
c_dec1 decimal(3),
c_dec2 decimal(5,3)
);
select cast(c_float as binary), cast(c_ufloat as binary), cast(c_double as binary), cast(c_udouble as binary),cast(c_dec as binary),cast( c_dec1 as binary), cast(c_dec2 as binary) from t_float;

select cast(c_float as unsigned), cast(c_ufloat as unsigned), cast(c_double as unsigned), cast(c_udouble as unsigned),cast(c_dec as unsigned),cast( c_dec1 as unsigned), cast(c_dec2 as unsigned) from t_float;

create table t_date(
c_dtt datetime,
c_dtt1 datetime(3),
c_dt date,
c_ts timestamp,
c_ts1 timestamp(3)
);
select cast(c_dtt as binary), cast(c_dtt1 as binary), cast(c_dt as binary), cast(c_ts as binary), cast(c_ts1 as binary) from t_date;

select cast(c_dtt as unsigned), cast(c_dtt1 as unsigned), cast(c_dt as unsigned), cast(c_ts as unsigned), cast(c_ts1 as unsigned) from t_date;

create table t_time(
c_time time,
c_time1 time(6),
c_year year,
c_year1 year(3)
);
select cast(c_time as binary), cast(c_time1 as binary), cast(c_year as binary), cast(c_year1 as binary) from t_time;

select cast(c_time as unsigned), cast(c_time1 as unsigned), cast(c_year as unsigned), cast(c_year1 as unsigned) from t_time;

--disable_warnings
drop table if exists t_int;
drop table if exists t_float;
drop table if exists t_date;
drop table if exists t_time;
drop table if exists t_string;
--enable_warnings

select cast(1 as binary);
select cast(11 as binary);
select cast(1.1 as binary);
select cast('11' as binary);
select cast(-1 as binary);
select cast(-1.1 as binary);
select cast(1.0 as binary);

select cast("1" as char);
select cast("我爱你" as char);

select cast(1.23 as unsigned);
select cast(1 as unsigned);
select cast("1" as unsigned);
select cast("1.23" as unsigned);
