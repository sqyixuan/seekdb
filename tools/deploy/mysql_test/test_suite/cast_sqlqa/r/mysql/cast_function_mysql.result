#Environmental cleaning
drop user longpy@'%';
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
drop table cast_table;
create table cast_table(id int, sal double, name varchar(40),date_time datetime);
insert into cast_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');
drop procedure mycast;
create procedure mycast()
begin
declare i int;
declare a int;
select cast(e.sal as signed) into a from cast_table e where e.name = 'kebi';
set i = 0;
loop_label:loop
insert into cast_table values(10,a,'kuli','2020-05-01 12:01:35');
set i = i + 1;
if i >= 10 then leave loop_label;
end if;
end loop;
end;//
select count(*) from cast_table;//
count(*)
3
call mycast();//
select count(*) from cast_table;//
count(*)
13
drop procedure mycast;//
create procedure mycast(in castname varchar(10) )
begin
declare i int;
declare a int;
select cast(e.sal as signed) into a from cast_table e where e.name = castname;	
set i := 1;
repeat
insert into cast_table values(10,2600.66,a,'2020-05-01 12:01:35');
set i := i + 1;
until i >= 10 end repeat;
end;//
select count(*) from cast_table;//
count(*)
13
call mycast('kebi');//
select count(*) from cast_table;//
count(*)
22
drop procedure mycast;//
create procedure mycast(out castsal int )
begin
declare i int;
select cast(e.sal as signed) into castsal from cast_table e where e.name = 'maidd';	
set i := 1;
while i <= 10 do
insert into cast_table values(10,castsal,'dulante','2020-05-01 12:01:35');
set i := i + 1;
end while;
end;//
select count(*) from cast_table;//
count(*)
22
call mycast(@castsal);//
select count(*) from cast_table;//
count(*)
32
drop procedure mycast;//
create procedure mycast(out castsal int, in castname varchar(10),inout p3 int )
begin
declare i int;
select cast(e.sal as signed) into castsal from cast_table e where e.name = 'maidd';	
select cast(e.sal as signed) into p3 from cast_table e where e.name = castname;	
set i := 1;
while i <= 10 do
insert into cast_table values(10,castsal,castname,'2020-05-01 12:01:35');
insert into cast_table values(10,p3,castname,'2020-05-01 12:01:35');
set i := i + 1;
end while;
end;//
select count(*) from cast_table;//
count(*)
32
call mycast(@castsal,'yaoming',@p3);//
select count(*) from cast_table;//
count(*)
52
drop function mycast;//
create function mycast() 
returns int
begin
declare a int;
select cast(e.sal as signed) from cast_table e where e.id = 15 into a;
return a;
end;//
select mycast();//
mycast()
2100
drop function mycast;//
create function mycast(castname  varchar(20)) 
returns int 
begin
declare a int;
select cast(e.sal as signed) into a from cast_table e where e.name = castname;
return a;
end;//
select mycast('kebi');//
mycast('kebi')
3000
drop function mycast;//
create function mycast(castname varchar(10))
returns int 
begin
declare a int;
declare i int DEFAULT 0;
select cast(e.sal as signed) into a from cast_table e where e.name = castname;
while i <= 10 do
insert into cast_table values(10,a,'kuli','2020-05-01 12:01:35');
set i := i + 1 ;	
end while;
return a;
end;//
select mycast('kebi');//
mycast('kebi')
3000
drop procedure mycast;
drop function mycast;
drop table cast_table;
# Clean up users
drop user longpy@'%' ;
