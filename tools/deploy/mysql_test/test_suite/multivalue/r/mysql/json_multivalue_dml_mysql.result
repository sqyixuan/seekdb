drop table if exists t_multivalue;
drop table if exists articles;
CREATE TABLE `t_multivalue` (
`c1` int(11) NOT NULL,
`id` bigint(20) NOT NULL,
`modified` bigint(20) NOT NULL,
`custinfo` json DEFAULT NULL,
PRIMARY KEY (`c1`),
INDEX `multi_zips` ((cast(`custinfo`->'$.zipcode' AS unsigned ARRAY)))
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`);
CREATE TABLE `articles` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT,
`tid` int(11) NOT NULL,
`title` varchar(200) DEFAULT NULL,
`content` text DEFAULT NULL,
PRIMARY KEY (`id`, `tid`),
FULLTEXT KEY `ctx1` (`title`, `content`) WITH PARSER space BLOCK_SIZE 16384,
FULLTEXT KEY `ctx2` (`title`, `content`) WITH PARSER space BLOCK_SIZE 16384,
FULLTEXT KEY `ctx3` (`title`, `content`) WITH PARSER space BLOCK_SIZE 16384,
KEY `idx1` (`title`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx2` (`title`, `id`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 4 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by hash(id) subpartition by hash(tid) subpartition template (
subpartition `p0`,
subpartition `p1`)
(partition `p0`,
partition `p1`,
partition `p2`);
