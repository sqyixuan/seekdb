delete from customers where JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94582]' AS JSON));
drop table if exists customers;
drop table if exists tt1;
create table tt1(id int , a varchar(50),j json,j1 json,  index index_1(id,(CAST(j->'$[*]' AS unsigned ARRAY))));
insert into tt1 values(1,'test','[1,3,4,6]','{}');
insert into tt1 values(1,'test','[1,3,4,6,7]','{}');
replace into tt1 values(1,'test','[1,3,4,6,7]','{}');
replace into tt1 values(2,'test2','{"key":[90,567]}','[1,2,3,5]');
update tt1  set j='[90,3,4]' ,id=3,a='test1',j1='[10,30,40]' where id=1;
drop table if exists tt1;
drop table if exists tt2;
create table tt2(id int,a varchar(50),j json, INDEX index_1( (CAST(j->'$[*]' AS DECIMAL ARRAY)))) ;
insert into tt2 values(1,'test','{"key":[23]}');
delete from tt2;
drop table tt2;
create table tt2(id int,a varchar(50),j json, UNIQUE INDEX index_1(a, (CAST(j->'$[*]' AS DECIMAL ARRAY))) );
insert into tt2 values(1,'test','{"key":[11]}');
delete from tt2;
drop table if exists tt2;
