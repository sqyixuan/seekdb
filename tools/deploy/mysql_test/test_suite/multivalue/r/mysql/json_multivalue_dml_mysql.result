CREATE TABLE `adb_tb_sycm_grd_kw_ext_algo_1d_new` (
`auto_id` bigint(20) NOT NULL COMMENT '自增列',
`se_keyword` varchar(2000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'key.搜索词',
`keyword_list` json DEFAULT NULL,
`is_lgt_keyword` text COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'prp.是否长尾词',
`cate_id` bigint(20) DEFAULT NULL COMMENT 'prp.类目ID',
`cate_level1_id` bigint(20) DEFAULT NULL COMMENT 'prp.一级类目ID',
`cate_level2_id` bigint(20) DEFAULT NULL COMMENT 'prp.二级类目ID',
`pay_ord_amt_1d_038` double DEFAULT NULL COMMENT 'met.最近1天全引导支付金额',
`pay_ord_byr_cnt_1d_037` bigint(20) DEFAULT NULL COMMENT 'met.最近1天全引导支付买家数',
`se_spv_1d_021` bigint(20) DEFAULT NULL COMMENT 'met.最近1天搜索SPV',
`se_ipv_uv_1d_003` bigint(20) DEFAULT NULL COMMENT 'met.最近1天搜索L-I的IPV_UV',
`se_ipv_1d_010` bigint(20) DEFAULT NULL COMMENT 'met.最近1天搜索L-I的IPV ',
`se_ipv_1d_028` bigint(20) DEFAULT NULL COMMENT 'met.最近1天天猫商城搜索全引导搜索IPV',
`pay_ord_amt_1d_034` double DEFAULT NULL COMMENT 'met.最近1天pc端全引导支付金额',
`pay_ord_byr_cnt_1d_750` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC全引导支付买家数',
`se_spv_pc_1d_006` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端搜索SPV',
`se_ipv_uv_pc_1d_010` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端搜索引导IPV_UV',
`se_ipv_pc_1d_005` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端搜索引导IPV',
`se_ipv_pc_1d_028` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端天猫商城搜索全引导IPV_PC',
`pay_ord_amt_1d_059` double DEFAULT NULL COMMENT 'met.最近1天无线端全引导支付金额',
`pay_ord_byr_cnt_1d_053` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端全引导支付买家数',
`se_spv_1d_005` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端搜索SPV',
`se_ipv_uv_1d_015` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端搜索引导IPV_UV',
`se_ipv_1d_013` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端搜索引导IPV',
`se_ipv_1d_029` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端天猫商城全引导搜索IPV',
`adm_ppc_1d_001` double DEFAULT NULL COMMENT 'met.最近1天P4P广告每点击消耗',
`se_uv_1d_005` bigint(20) DEFAULT NULL COMMENT 'met.最近1天搜索UV',
`se_uv_pc_1d_003` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端搜索UV',
`se_uv_1d_007` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端搜索UV',
`se_uv_1d_042` bigint(20) DEFAULT NULL COMMENT 'met.最近1天搜索UV上1天变化量',
`se_uv_pc_1d_021` bigint(20) DEFAULT NULL COMMENT 'met.最近1天PC端搜索UV上1天变化量',
`se_uv_1d_008` bigint(20) DEFAULT NULL COMMENT 'met.最近1天无线端搜索UV上1天变化',
`se_uv_ex_1w_001` bigint(20) DEFAULT NULL COMMENT 'met.最近7天较上7天搜索UV变化量',
`se_uv_ex_1w_002` bigint(20) DEFAULT NULL COMMENT 'met.最近7天PC端较上7天搜索UV变化量',
`se_uv_ex_1w_003` bigint(20) DEFAULT NULL COMMENT 'met.最近7天无线端较上7天搜索UV变化量',
`stat_date` bigint(20) NOT NULL DEFAULT '0' COMMENT '统计日期',
PRIMARY KEY (`auto_id`, `stat_date`),
index index_t101(stat_date, (CAST(keyword_list->'$' as char(256) ARRAY)), se_keyword)
);
