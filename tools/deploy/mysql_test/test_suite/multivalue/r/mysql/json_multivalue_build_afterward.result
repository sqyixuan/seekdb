drop table if exists tt4;
create table tt4(id int , a varchar(50),j json) partition by list columns (id)(
PARTITION p0 VALUES in(10),
PARTITION p1 VALUES in(50)
);
insert into tt4 values(10,'test','[1,2,3]');
insert into tt4 values(10,'test','{"key":["test"]}');
create index index_01 on tt4((CAST(j->'$[*]' AS UNSIGNED ARRAY)));
drop table tt4;
create table tt4(id int UNIQUE , a varchar(50),j json ,j1 json);
insert into tt4 values(1,'test','[1,2,3,5]','{}');
insert into tt4 values(2,'test','{"key":[90,10]}','{}');
ALTER TABLE tt4 ADD  UNIQUE INDEX index_2 ((CAST(j1->'$.key' AS char(50) ARRAY)));
