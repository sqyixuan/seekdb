'[{
    "name": "支付宝钱包",
    "currencyList": [
      {"type": "USD", "amount": 999.19},
        {"type": "RMB", "amount": 1000.19}
    ]
},
{
    "name": "微信钱包",
    "currencyList": [
        {"type": "USD", "amount": 888.18, "userId": 2},
        {"type": "RMB", "amount": 1000.18, "userId": 1}
    ]
}]',
'{"sex": "男", "city": "南京", "user_id": 1}');
