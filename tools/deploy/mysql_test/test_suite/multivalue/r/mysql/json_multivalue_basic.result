drop table if exists customers_unique;
CREATE TABLE customers_unique (
id BIGINT not null primary key,
modified  BIGINT not null,
custinfo JSON,
UNIQUE INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);
