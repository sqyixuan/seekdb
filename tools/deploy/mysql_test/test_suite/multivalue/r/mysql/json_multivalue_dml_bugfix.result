CREATE TABLE tt2 (id int , d date, j json,UNIQUE index index_1(id,d))
PARTITION BY RANGE COLUMNS(d) SUBPARTITION BY HASH(id)
(
PARTITION P0 VALUES LESS THAN ('2010-10-10')(
SUBPARTITION S1,
SUBPARTITION S2
)
,
PARTITION P1 VALUES LESS THAN ('2020-10-10')(
SUBPARTITION S3,
SUBPARTITION S4
)
)
;
create UNIQUE index index_01 on tt2(id,(CAST(j->'$.*' AS SIGNED ARRAY)),d);
