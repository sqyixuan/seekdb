drop table jemp;
CREATE TABLE jemp (
c JSON,
g INT GENERATED ALWAYS AS ( c -> "$.id" ),
INDEX `jump_node_code_index`( (CAST(c->"$.id" AS CHAR(50) ARRAY)) ),
INDEX i ( g )
);
INSERT INTO jemp (c) VALUES
('{"id": "1", "name": "Fred"}'), 
('{"id": "2", "name": "Wilma"}'),
('{"id": "3", "name": "Barney"}'),
('{"id": "4", "name": "Betty"}');
select /*+read_consistency(weak) */ c->>"$.name" from jemp where 1 MEMBER of (c->'$.id');
c->>"$.name"
select c->>"$.name" from jemp where 1 MEMBER of (c->'$.id');
c->>"$.name"
select c->>"$.name" from jemp where "1" MEMBER of (c->'$.id');
c->>"$.name"
Fred
drop table jemp;
