alter system set _enable_add_fulltext_index_to_existing_table = true;

--disable_warnings
drop table if exists customers;
--enable_warnings

CREATE TABLE customers (
    id BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    data JSON,
    INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) ),
    INDEX zips2( (CAST(data->'$.id' AS UNSIGNED ARRAY)) )
);

--replace_regex /_[0-9]+/_xxx/
SHOW INDEX FROM customers;

ALTER TABLE customers ADD INDEX multi_zips((CAST(custinfo->'$.id' AS UNSIGNED ARRAY)) );
--replace_regex /_[0-9]+/_xxx/
SHOW INDEX FROM customers;

--disable_warnings
drop table if exists create_test2;
--enable_warnings

CREATE TABLE create_test2 (
    id BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    json_data JSON,
    index multi_zips( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);

--replace_regex /_[0-9]+/_xxx/
SHOW INDEX FROM create_test2;

--disable_warnings
drop table if exists customers3;
--enable_warnings

CREATE TABLE customers3 (
    id BIGINT not null,
    val1 BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    INDEX json_multivalue( (CAST(custinfo->'$.zipcode' AS double ARRAY)) )
);

drop table customers;
drop table create_test2;
drop table customers3;


CREATE TABLE customers (
    id BIGINT NOT NULL PRIMARY KEY,
    modified BIGINT,
    custinfo JSON,
    index comp(modified, (CAST(custinfo->'$.zipcode' AS char(16) ARRAY)) )
);

--replace_regex /_[0-9]+/_xxx/
SHOW INDEX FROM customers;

drop table customers;


CREATE TABLE customers (
    id BIGINT not null primary key,
    modified  BIGINT not null,
    custinfo JSON,
    UNIQUE INDEX zips1( (CAST(custinfo->'$.zipcode' AS float ARRAY)) )
);

--replace_regex /_[0-9]+/_xxx/
SHOW INDEX FROM customers;

drop table customers;

