--disable_warnings
drop table  if exists recordgroup2;
--enable_warnings
CREATE TABLE `recordgroup2` (
  `splitid` varchar(36) NOT NULL COMMENT '分账流水号',
  `date1` date NOT NULL COMMENT '记录年份',
  `ordernum` varchar(36) NOT NULL COMMENT '支付订单号',
  `shopid` int(11) NOT NULL COMMENT '店铺id',
  `shopname` varchar(128) DEFAULT NULL COMMENT '商户名称',
  `originalamount` decimal(18, 2) DEFAULT NULL COMMENT '原支付金额',
  `payamount` decimal(18, 2) DEFAULT NULL COMMENT '实际支付金额',
  `payfee` decimal(18, 2) DEFAULT NULL COMMENT '交易结算手续费（实际支付）',
  `rebatepayment` decimal(18, 2) DEFAULT NULL COMMENT '返利金金额',
  `merid` varchar(64) DEFAULT NULL COMMENT '商户号',
  `paysuccesstime` datetime DEFAULT NULL COMMENT '支付成功时间',
  `acctname` varchar(64) DEFAULT NULL COMMENT '转入账户名称',
  `transfercard` varchar(64) DEFAULT NULL COMMENT '转入卡号',
  `prebehalfdate` date DEFAULT NULL COMMENT '预代付日期',
  `behalfpayaddtime` datetime DEFAULT NULL COMMENT '代付发起时间',
  `behalfpayrequestid` varchar(36) DEFAULT NULL COMMENT '代付流水号',
  `behalfpaystatus` varchar(2) DEFAULT NULL COMMENT '入账状态',
  `behalfpaydate` datetime DEFAULT NULL COMMENT '入账时间',
  `behalfretmsg` varchar(255) DEFAULT NULL COMMENT '入账失败原因',
  `updatetime` datetime DEFAULT NULL COMMENT '更新日期',
  `groupid` varchar(32) DEFAULT NULL COMMENT '管理方编号',
  `groupname` varchar(80) DEFAULT NULL COMMENT '管理方名称',
  `charger` decimal(18, 2) DEFAULT NULL COMMENT '手续费承担方',
  `group_profit_percent` decimal(8, 6) DEFAULT NULL COMMENT '管理方分润比例',
  `group_profit_amount` decimal(18, 2) DEFAULT NULL COMMENT '管理方分润金额',
  `groupbehalftype` varchar(2) DEFAULT NULL COMMENT '管理方到账模式',
  `groupbehalfamount` decimal(18, 2) DEFAULT NULL COMMENT '管理方入账金额',
  `shopsplitscale` decimal(8, 6) DEFAULT NULL COMMENT '商户分账比例',
  `shop_behalf_type` varchar(2) DEFAULT NULL COMMENT '商户代付模式',
  `shopsplitamount` decimal(18, 2) DEFAULT NULL COMMENT '商户分账金额',
  `splitplatformreduce` decimal(18, 2) DEFAULT NULL COMMENT '平台补贴分账金额',
  `splitshopreduce` decimal(18, 2) DEFAULT NULL COMMENT '商户优惠分账金额',
  `templateid` varchar(36) DEFAULT NULL COMMENT '券模版id',
  `addtime` datetime DEFAULT NULL COMMENT '添加时间',
  `group_split_percent` decimal(8, 6) DEFAULT NULL COMMENT '管理方分帐比例',
  `group_split_amount` decimal(18, 2) DEFAULT NULL COMMENT '管理方分帐金额',
  `behalfOperator` varchar(64) DEFAULT NULL COMMENT '代付处理人',
  json_multivalue1 json,
  json_multivalue2 json,
  qujie1 json,
  qujie2 json,
  PRIMARY KEY (`splitid`, `date1`),
  KEY `tx_traderecordgroup_idx_01` (`ordernum`) BLOCK_SIZE 16384 LOCAL,
  KEY `tx_traderecordgroup_idx_02` (`shopid`) BLOCK_SIZE 16384 LOCAL,
  KEY `tx_traderecordgroup_idx_03` (`paysuccesstime`) BLOCK_SIZE 16384 LOCAL,
  KEY `tx_traderecordgroup_idx_04` (`groupid`) BLOCK_SIZE 16384 LOCAL,
  KEY `tx_traderecordgroup_idx_05` (`addtime`) BLOCK_SIZE 16384 LOCAL,
  KEY `tx_traderecordgroup_idx_06` (`ordernum`, `paysuccesstime`, `groupid`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '集群分账明细' 
partition by range columns(date1) (
  partition `P2022`
  values less than ('2023-01-01'),
    partition `P2023`
  values less than ('2024-01-01'),
    partition `P2024`
  values less than ('2025-01-01'),
  partition `P2025`
  values less than ('2026-01-01')
);

 alter table recordgroup2  add index scores4 ((cast(json_multivalue2->'$.score' as unsigned array)));

 drop table  if exists recordgroup2;

