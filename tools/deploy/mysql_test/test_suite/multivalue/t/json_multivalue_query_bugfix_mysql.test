SELECT * FROM test  WHERE JSON_CONTAINS(j->>'$[*]', '[1]');


SELECT * FROM test  WHERE JSON_OVERLAPS(j->>'$[*]', '[true]');
SELECT * FROM test  WHERE JSON_OVERLAPS(j->>'$[*]', '[1]');

