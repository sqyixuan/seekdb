insert into test values(1,'test','{"key":["2020-10-10 23:59:59"]}',"[]");
select * from test where '2020-10-10 23:59:59' MEMBER OF(j->'$.key');
SELECT * FROM test  WHERE JSON_CONTAINS(j->'$.key', '["2020-10-10 23:59:59"]');
SELECT * FROM test  WHERE JSON_OVERLAPS(j->'$.key', '["2020-10-10 23:59:59"]');
drop table test;

--error 0,1051
drop table jemp;

CREATE TABLE jemp (
 c JSON,
 g INT GENERATED ALWAYS AS ( c -> "$.id" ),
 INDEX `jump_node_code_index`( (CAST(c->"$.id" AS CHAR(50) ARRAY)) ),
 INDEX i ( g )
);


INSERT INTO jemp (c) VALUES
  ('{"id": "1", "name": "Fred"}'), 
  ('{"id": "2", "name": "Wilma"}'),
  ('{"id": "3", "name": "Barney"}'),
  ('{"id": "4", "name": "Betty"}');

select /*+read_consistency(weak) */ c->>"$.name" from jemp where 1 MEMBER of (c->'$.id');

select c->>"$.name" from jemp where 1 MEMBER of (c->'$.id');

select c->>"$.name" from jemp where "1" MEMBER of (c->'$.id');
drop table jemp;

