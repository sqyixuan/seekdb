drop table test;
create table test(id int,a varchar(50),j json, j1 json,INDEX index_1( (CAST(j->>'$[*]' AS UNSIGNED ARRAY))) );
insert into test values(1,'test','[true,false]',"[]");
insert into test values(1,'test','[1]',"[]");
insert into test values(1,'test','[0]',"[]");

SELECT * from test where true MEMBER OF(j->>'$[*]');
SELECT * from test where 1 MEMBER OF(j->>'$[*]');

