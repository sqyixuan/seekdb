connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

alter system set _enable_add_fulltext_index_to_existing_table = true;

--disable_warnings
drop table if exists customers;
--enable_warnings

CREATE TABLE customers (
    id BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);

INSERT INTO customers VALUES 
  (10, 21, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}'),
  (11, 22, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}'),
  (12, 23, '{"user":"Bob","user_id":31,"zipcode":[94477,94507]}'),
  (13, 24, '{"user":"Mary","user_id":72,"zipcode":[94536]}'),
  (14, 25, '{"user":"Ted","user_id":56,"zipcode":[94507,94582]}');

update customers set custinfo = '{"user":"Jack","user_id":37,"zipcode":[32668,82468]}' where id = 10;

SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode');

SELECT * FROM customers 
  WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

SELECT * FROM customers
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

SELECT * FROM customers 
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', 
                      CAST('[94507,94582,34723,23014,10739,21732,94573,27320,28230,29273,82392]' AS JSON));

drop index zips1 on customers;
drop table customers;

--disable_warnings
drop table if exists customers_unique;
--enable_warnings

CREATE TABLE customers_unique (
    id BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    UNIQUE INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);

INSERT INTO customers_unique VALUES 
  (10, 21, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}');

SELECT * FROM customers_unique 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode');
SELECT * FROM customers_unique 
  WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));
SELECT * FROM customers_unique 
  WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94582,94536]' AS JSON));
SELECT * FROM customers_unique
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

--error 1062
INSERT INTO customers_unique VALUES 
  (11, 22, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}');

drop table customers_unique;

--disable_warnings
drop table if exists customers5;
--enable_warnings
CREATE TABLE customers5 (
    id BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    UNIQUE INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
) ;

INSERT INTO customers5 VALUES
  (10, 21, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}');
INSERT INTO customers5 VALUES
  (1, 21, '{"user":"Jack","user_id":37,"zipcode":[9458,1]}');
--error 1062
INSERT INTO customers5 VALUES
  (11, 22, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}');

SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON)) =0 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON)) =1 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', '[94507,94582]') =1 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', '[94507,94582]') =0 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', '[94507]') =1 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', '[94507]') =0 order by id;
SELECT id FROM customers5 WHERE JSON_CONTAINS(custinfo->'$.zipcode', '94507') =0 order by id;

drop table customers5;

--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1(id int , a varchar(50),j json,j1 json,index index_1((CAST(j AS SIGNED ARRAY))));

insert into tt1 values(1,'test','[1,2,3,45,6,7]','[1,2,5]');
insert into tt1 values(1,'test','[1,2,3,45,-6,-7]','[1,2,5]');
insert into tt1 values(1,'test','[4521,-989877]','[1,2,5]');
insert into tt1 values(4,'test','[1,2,3,45,6,7]','[1,2,5]');
insert into tt1 values(3,'test','[1,2,3,45,-6,-7]','[1,2,5]');
insert into tt1 values(6,'test','[1,2,3,45,-6,-7]','[1,2,5]');
SELECT  * FROM tt1  WHERE    JSON_OVERLAPS( j, '[1]');
SELECT /*+ index(tt1 index_1)*/  * FROM tt1 WHERE  JSON_OVERLAPS( j, '[1,23]');
SELECT  * FROM tt1  WHERE    JSON_CONTAINS( j, '[1]');
SELECT * FROM tt1  WHERE 1 MEMBER OF(j);
drop table tt1;

create table tt1(id int , a varchar(50),j json,j1 json, index index_1((CAST(j AS SIGNED ARRAY))));

replace into tt1 values(1,'test','[1]','[1,2,5]');
replace into tt1 values(1,'test','1','[1,2,5]');
replace into tt1 values(2,'test',null,'[1,2,5]');

update tt1 set j='[1,2,344]';
update tt1 set j='[1,2,34]' limit 1;
delete from tt1;
--error 3903
insert into tt1 values(1,'test','["test"]','[1,2,5]');
update tt1 set j='[1,2,344]';
delete from tt1;
drop table tt1;

alter system set _enable_add_fulltext_index_to_existing_table = false;
