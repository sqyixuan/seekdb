--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1(id int,a varchar(50),j json, j1 json,INDEX index_1( (CAST(j->'$.key' AS TIME ARRAY))) );
insert into tt1 values(1,'test','{"key":[0,1,25]}',"[]");
insert into tt1 values(1,'test','{"key":[1.256]}',"[]");
insert into tt1 values(1,'test','{"key":254245}','[]');

select * from tt1 where 1.256 MEMBER OF(j->'$.key');
select * from tt1 where 1 MEMBER OF(j->'$.key');
drop table tt1;

--disable_warnings
drop table if exists tt2;
--enable_warnings
CREATE TABLE tt2 (id int, a varchar(20), j json, INDEX index_1 ((CAST(j->'$[*]' AS  TIME ARRAY))));
insert into tt2 values(4,'test','["10:12:12.59563"]');

select * from tt2 where  '10:12:12.59563' member of (j->'$[*]') ;

DROP TABLE tt2;

CREATE TABLE tt2 (id int, c1 char(50), c2 JSON, primary key (id, c1), INDEX zips1( (CAST(c2->'$.key' AS UNSIGNED ARRAY))));
INSERT INTO tt2 VALUES  (1, 'abcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcd', '{"key":[1,2,3,4,5,6]}');
SELECT * FROM tt2 WHERE JSON_OVERLAPS(c2->'$.key', CAST('[1,2]' AS JSON));

drop table if exists tt2;
CREATE TABLE tt2 (c1 char(50), c2 JSON, primary key (c1), INDEX zips1( (CAST(c2->'$.key' AS UNSIGNED ARRAY))));
INSERT INTO tt2 VALUES  ('abcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcd', '{"key":[1,2,3,4,5,6]}');
SELECT * FROM tt2 WHERE JSON_OVERLAPS(c2->'$.key', CAST('[1]' AS JSON));

drop table if exists tt2;
CREATE TABLE tt2 (id int primary key, c1 char(5), c2 JSON, INDEX zips1(c1, (CAST(c2->'$.key' AS UNSIGNED ARRAY))));
INSERT INTO tt2 VALUES (1, 'a', '{"key":[1,2]}');
INSERT INTO tt2 VALUES (2, 'd', '{"key":[1,4]}');
INSERT INTO tt2 VALUES (3, 'c', '{"key":[1,5]}');
--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM tt2 WHERE c1 >= 'a' order by c1 desc;
SELECT * FROM tt2 WHERE c1 >= 'a' order by c1 desc;
SELECT id FROM tt2 WHERE c1 >= 'a';
SELECT c1 FROM tt2 WHERE c1 >= 'a';
SELECT id, c1 FROM tt2 WHERE c1 >= 'a';
SELECT c1, id FROM tt2 WHERE c1 >= 'a';
SELECT c1 FROM tt2 WHERE c1 = 'd';
SELECT * FROM tt2 WHERE c1 >= 'a';

drop table if exists tt2;
CREATE TABLE tt2 (c1 char(50), c2 int, c3 JSON, primary key (c1), INDEX zips1(c2,  (CAST(c3->'$.key' AS UNSIGNED ARRAY))));
INSERT INTO tt2 VALUES  ('abc', 1, '{"key":[1,2,3,4,5,6]}');
INSERT INTO tt2 VALUES  ('abcd', 4, '{"key":[1,2,3,4,5,6]}');
INSERT INTO tt2 VALUES  ('fbcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcdabcd', 2, '{"key":[1,2,3,4,5,6]}');
INSERT INTO tt2 VALUES  ('fbcdabcdefabcdabcdabcdabcdabcdabcdabcdabcdabcdabcd', 6,  '{"key":[1,2,3,4,5,6,7,8,9]}');
INSERT INTO tt2 VALUES  ('def', 8,  '{"key":[1,2,3,4,5,6,7,8,9]}');

SELECT c2 FROM tt2 WHERE c2 > 0;
SELECT c1 FROM tt2 WHERE c2 > 0;
SELECT c1,c2 FROM tt2 WHERE c2 > 0;
SELECT c2,c1 FROM tt2 WHERE c2 > 0;
SELECT * FROM tt2 WHERE c2 > 0;

drop table if exists tt2;
CREATE TABLE tt2 (id int, c1 char(50), c2 int, c3 JSON, primary key (id, c1), INDEX zips1(c2,  (CAST(c3->'$.key' AS UNSIGNED ARRAY))));
