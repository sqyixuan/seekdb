INSERT INTO tt2 VALUES  (4, 'fbcdabcdefabcdabcdabcdabcdabcdabcdabcdabcdabcdabcd', 6,  '{"key":[1,2,3,4,5,6,7,8,9]}');
INSERT INTO tt2 VALUES  (5, 'def', 8,  '{"key":[1,2,3,4,5,6,7,8,9]}');

SELECT c2 FROM tt2 WHERE c2 > 0;
SELECT id FROM tt2 WHERE c2 > 0;
SELECT c1 FROM tt2 WHERE c2 > 0;
SELECT c1,c2 FROM tt2 WHERE c2 > 0;
SELECT id,c2,c1 FROM tt2 WHERE c2 > 0;
SELECT * FROM tt2 WHERE c2 > 0;

