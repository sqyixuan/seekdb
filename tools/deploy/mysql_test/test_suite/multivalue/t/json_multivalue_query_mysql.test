--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM test
  WHERE JSON_OVERLAPS(json_unquote(json_value(custinfo, '$.zipcode')), CAST('[2]' AS JSON));
SELECT * FROM test
  WHERE JSON_OVERLAPS(json_unquote(json_value(custinfo, '$.zipcode')), CAST('[2]' AS JSON));

drop table test;

create table test(
  id int,
  a varchar(50),
  custinfo json, 
  INDEX index_1((CAST(custinfo AS UNSIGNED ARRAY))) 
);

