--disable_warnings
drop table if exists tag_table11;
--enable_warnings

create table tag_table11(tag_id varchar(1024), tag_value json, INDEX zips( (CAST(tag_value->'$' AS char(500) ARRAY)) ));

INSERT INTO tag_table11 (tag_id, tag_value) VALUES ('tag_id_xxx', '["1:洗衣液","0:散装其他米"]');

select * from tag_table11 where json_overlaps(tag_value->'$', '["1:洗衣液"]');
select * from tag_table11 where json_contains(tag_value->'$', '["1:洗衣液"]');


select * from tag_table11 where json_overlaps(tag_value->'$[*]', '["1:洗衣液"]');
select * from tag_table11 where json_contains(tag_value->'$[*]', '["1:洗衣液"]');

