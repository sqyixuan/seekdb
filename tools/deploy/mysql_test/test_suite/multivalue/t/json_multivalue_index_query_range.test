--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (
  company_id int not NULL, extra varchar(512) DEFAULT NULL,
  KEY idx1 ((cast(json_extract(extra,'$.KA') as char(512) array)))
);

INSERT INTO t1(company_id, extra) VALUES (125834, '{"A":"A,C","KA":["A","C"]}');


