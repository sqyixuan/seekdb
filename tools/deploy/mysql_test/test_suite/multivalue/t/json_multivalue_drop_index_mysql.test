--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1(id int , a varchar(50),j json,j1 json);
create index index_01 on tt1((CAST(j->'$.key' AS SIGNED ARRAY)));
create  index index_02 on tt1((CAST(j->'$[*]' AS UNSIGNED ARRAY)));

alter table tt1 drop index index_01;
replace into  tt1 values(1,'test','{"key":[-1,"test"]}','{"key":["test","test1"]}');
replace into  tt1 values(2,'test1','{"key":[-1,"test"]}','{"key":["test","test1"]}');
drop index index_02 on tt1;

insert into  tt1 values(1,'test','[-11,2,3,4]','{"key":["test","test1"]}');
update tt1 set j='[-3,-4]';

drop table if exists tt1;
alter system set _enable_add_fulltext_index_to_existing_table = false;
