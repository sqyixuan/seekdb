replace into tt2 values(2,'test','[12,3,7]','[]');
INSERT into tt2 values(2,'test1','[8,8,9,10]','[1,4]') ON DUPLICATE KEY UPDATE a='test1',j='[9,8]',j1='[10]';

drop table tt2;
create table tt2(id int UNIQUE, a varchar(50),j json,j1 json);
create UNIQUE index index_01 on tt2(id,(CAST(j->>'$[*]' AS UNSIGNED ARRAY)));
insert into tt2 values(2,'test','[12,3,7]','[]');
replace into tt2 values(2,'test','[12,3,7]','[]');
INSERT into tt2 values(2,'test1','[8,8,9,10]','[1,4]') ON DUPLICATE KEY UPDATE a='test1',j='[9,8]',j1='[10]';

DROP TABLE tt2;
CREATE TABLE tt2 (id int , d date, j json,UNIQUE index index_1(id,d))
PARTITION BY RANGE COLUMNS(d) SUBPARTITION BY HASH(id)
(
PARTITION P0 VALUES LESS THAN ('2010-10-10')(
SUBPARTITION S1,
SUBPARTITION S2
)
,
PARTITION P1 VALUES LESS THAN ('2020-10-10')(
SUBPARTITION S3,
SUBPARTITION S4
)
)
;
create UNIQUE index index_01 on tt2(id,(CAST(j->'$.*' AS SIGNED ARRAY)),d);

