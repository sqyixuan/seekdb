obmysql-length-4
drop table length_table;
create table length_table(id int, sal double, name varchar(40),date_time datetime);
insert into length_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');
drop procedure mylength;
create procedure mylength()
begin
declare i int;
declare a int;
select length(e.sal) into a from length_table e where e.name = 'kebi';
set i = 0;
loop_label:loop
insert into length_table values(10,a,'kuli','2020-05-01 12:01:35');
set i = i + 1;
if i >= 10 then leave loop_label;
end if;
end loop;
end;//
select count(*) from length_table;//
count(*)
3
call mylength();//
select count(*) from length_table;//
count(*)
13
drop procedure mylength;//
create procedure mylength(in lengthname varchar(10) )
begin
declare i int;
declare a int;
select length(e.sal) into a from length_table e where e.name = lengthname;	
set i := 1;
repeat
insert into length_table values(10,2600.66,a,'2020-05-01 12:01:35');
set i := i + 1;
until i >= 10 end repeat;
end;//
select count(*) from length_table;//
count(*)
13
call mylength('kebi');//
select count(*) from length_table;//
count(*)
22
drop procedure mylength;//
create procedure mylength(out lengthsal int )
begin
declare i int;
select length(e.sal) into lengthsal from length_table e where e.name = 'maidd';	
set i := 1;
while i <= 10 do
insert into length_table values(10,lengthsal,'dulante','2020-05-01 12:01:35');
set i := i + 1;
end while;
end;//
select count(*) from length_table;//
count(*)
22
call mylength(@lengthsal);//
select count(*) from length_table;//
count(*)
32
drop procedure mylength;//
create procedure mylength(out lengthsal int, in lengthname varchar(10),inout p3 int )
begin
declare i int;
select length(e.sal) into lengthsal from length_table e where e.name = 'maidd';	
select length(e.sal) into p3 from length_table e where e.name = lengthname;	
set i := 1;
while i <= 10 do
insert into length_table values(10,lengthsal,lengthname,'2020-05-01 12:01:35');
insert into length_table values(10,p3,lengthname,'2020-05-01 12:01:35');
set i := i + 1;
end while;
end;//
select count(*) from length_table;//
count(*)
32
call mylength(@lengthsal,'yaoming',@p3);//
select count(*) from length_table;//
count(*)
52
drop function mylength;//
create function mylength() 
returns int
begin
declare a int;
select length(e.sal) from length_table e where e.id = 15 into a;
return a;
end;//
select mylength();//
mylength()
7
drop function mylength;//
create function mylength(lengthname  varchar(20)) 
returns int 
begin
declare a int;
select length(e.sal) into a from length_table e where e.name = lengthname;
return a;
end;//
select mylength('kebi');//
mylength('kebi')
8
drop function mylength;//
create function mylength(lengthname varchar(10))
returns int 
begin
declare a int;
declare i int DEFAULT 0;
select length(e.sal) into a from length_table e where e.name = lengthname;
while i <= 10 do
insert into length_table values(10,a,'kuli','2020-05-01 12:01:35');
set i := i + 1 ;	
end while;
return a;
end;//
select mylength('kebi');//
mylength('kebi')
8
drop procedure mylength;
drop function mylength;
drop table length_table;
