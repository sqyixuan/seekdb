#owner:dachuan.sdc
#owner group:sql3
#description:视图 常用sql


--echo obmysql-length-3 及obmysql-length-5
 
--error  0,1051
drop table length_table2;
--error 0,1051
drop table length_table;
--error 0,1051
drop view length_view;
create table length_table(id int, order_id double, name varchar(40),date_time datetime);
insert into length_table values(10,15.59,'kebi','2020-05-01 12:01:35'),(15,14.29,'maidi','2020-05-17 18:02:30'),(29,12.32,'yaoming','2020-05-23 23:59:59');

create table length_table2(id int, sal double, order_number varchar(40),date_time datetime);
insert into length_table2 values(10,3000.265 ,'10','2020-05-01 12:01:35'),(15,2100.25,'15.29','2020-05-17 18:02:30'),(29,1500.69,'12.32','2020-05-23 23:59:59');

#select 
select length(e.order_id) a,length(e.name) b from length_table e;
select p.a,p.b from (select length(e.order_id) a,length(e.name) b from length_table e ) p ;
select e.id,e.name,length(p.sal),p.date_time from length_table e left join length_table2 p on length(p.order_number) = e.id order by 1 desc;
select e.id,e.name,length(p.sal),p.date_time from length_table e right join length_table2 p on length(p.order_number) = e.id order by 1 desc;
select e.id,e.name,length(p.sal),p.date_time from length_table e inner join length_table2 p on length(p.order_number) = e.id order by 1 desc;



#别名
select length(e.order_id) a,length(e.name) 姓名 from length_table e;
select length(e.name collate utf8mb4_general_ci) as 姓名 from length_table e;
select length(e.name collate utf8mb4_general_ci) 姓名 from length_table e;


#exists
select e.id,e.name from length_table e where exists(select * from length_table2 p where length(p.order_number) = e.id ) order by 1 desc;
select e.id,e.name from length_table e where not exists(select * from length_table2 p where length(p.order_number) = e.id ) order by 1 desc;
select e.id,e.name from length_table e where exists(select * from length_table2 p where p.order_number = length(e.id)) order by 1 desc;
select e.id,e.name from length_table e where not exists(select * from length_table2 p where p.order_number = length(e.id))order by 1 desc;


#any 
select e.id,e.name from length_table e where e.id > any(select avg(length(p.order_number)) from length_table2 p);
select e.id,e.name from length_table e where e.id < any(select avg(length(p.order_number)) from length_table2 p );
select e.id,e.name from length_table e where e.id = any(select length(p.order_number) from length_table2 p );


#all
select e.id,e.name from length_table e where e.id > all(select length(p.order_number) from length_table2 p where p.id = 29);
select e.id,e.name from length_table e where e.id < all(select length(p.order_number) from length_table2 p where p.id = 29);
select e.id,e.name from length_table e where e.id = all(select length(p.order_number) from length_table2 p where p.id = 10);

#like
select *  from length_table a  where length(a.order_id) like '%5%';
select length(a.name)  from length_table a where name like '%k%';


#别名
select length(e.sal) aab from length_table2 e;
select length(e.sal) aab工资 from length_table2 e;


#where
select e.id,e.sal from length_table2 e where length(e.sal) > 2000 order by e.id;
select e.id,e.sal from length_table2 e where length(e.sal) > 2000  and length(e.sal) < 3000 order by e.id;
select e.id,e.sal from length_table2 e where length(e.sal) > 2000  or length(e.order_number) > 15 order by e.id;
select length(e.sal) from length_table2 e where e.id>20 order by e.id desc;


#order by 
select e.id,e.name,p.sal from length_table e left join length_table2 p on e.id = p.id where length(p.sal) > 2000 order by length(p.sal) limit 2;
select e.id,e.name,p.sal from length_table e left join length_table2 p on e.id = p.id where length(p.sal) > 2000 order by length(p.sal) desc limit 2;


#group by having
select e.id,sum(e.sal) from length_table2 e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from length_table2 e where e.sal > 1000 group by 1 having sum(length(e.sal)) > 2000 order by 1 desc;



#cast when
select e.id 编号,case when length(e.sal) < 2000 then '低' when length(e.sal) < 3000 then '一般' else '高' end '工资' from length_table2 e ;
select e.id 编号,case length(e.sal)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from length_table2 e;


#insert into as 
insert into length_table select *  from length_table2 p where length(p.sal)  = 8;
select *  from length_table;
--error 0,1292
insert into length_table select *  from length_table2 p where length(p.order_number)  = 2;


#update as 
select *  from length_table;
update length_table set name = 'zanms' where length(order_id) = 5;
select *  from length_table where name = 'zanms';



#delete
delete from length_table2 where length(sal) = 4 ;
select length(sal) from length_table2;


#视图
create view length_view as select e.id,e.name,p.sal,p.date_time from length_table e left join length_table2 p on e.id = p.id order by e.id desc;
--sorted_result
select *  from length_view;



#select 
select length(e.sal) a,length(e.name) b from length_view e;
select p.a,p.b from (select length(e.sal) a,length(e.name) b from length_view e ) p ;
select e.id,e.name,length(p.sal),p.date_time from length_view e left join length_table2 p on length(p.order_number) = e.id order by 1 desc;
select e.id,e.name,length(p.sal),p.date_time from length_view e right join length_table2 p on length(p.order_number) = e.id order by 1 desc;
select e.id,e.name,length(p.sal),p.date_time from length_view e inner join length_table2 p on length(p.order_number) = e.id order by 1 desc;


#别名
select length(e.name) a,length(e.sal) 姓名 from length_view e;
select length(e.date_time) as 时间 from length_view e;
select length(e.date_time) 时间 from length_view e;


# exists
select e.id,e.name from length_table e where exists(select * from length_view p where length(p.id) = e.id ) order by 1 desc;
select e.id,e.name from length_table e where not exists(select * from length_view p where length(p.id) = e.order_id ) order by 1 desc;
select e.id,e.name from length_table e where exists(select * from length_view p where p.id = length(e.id)) order by 1 desc;
select e.id,e.name from length_table e where not exists(select * from length_view p where p.id = length(e.order_id))order by 1 desc;



# any 
select e.id,e.name from length_table e where e.order_id > any(select length(p.id) from length_view p);
select e.id,e.name from length_table e where e.order_id < any(select length(p.id) from length_view p);
select e.id,e.name from length_table e where e.id = any(select length(p.id) from length_view p);



# all
select e.id,e.order_number from length_table2 e where e.sal > all(select length(p.sal) from length_view p where p.id = 29);
select e.id,e.order_number from length_table2 e where e.sal < all(select length(p.sal) from length_view p where p.id = 29);
select e.id,e.order_number from length_table2 e where length(e.sal) = all(select length(p.sal) from length_view p where p.id = 10);



# like
select *  from length_view a  where length(a.name) like '%m%';
select length(a.name)  from length_view a where name like '%k%';



# 别名
select length(e.sal) aab from length_view e;
select length(e.sal) aab工资 from length_view e;
 

# where
select e.id,e.sal from length_view e where length(e.sal) > 2000 order by e.id;
select e.id,e.sal from length_view e where length(e.sal) > 2000  and length(e.sal) < 3000 order by e.id;
select e.id,e.sal from length_view e where length(e.sal) > 2000  or length(e.id) > 15 order by e.id;
select length(e.sal) from length_view e where e.id>20 order by e.id desc;
 

# order by 
select e.id,e.name,p.sal from length_table e left join length_view p on e.id = p.id where length(p.sal) > 2000 order by length(p.sal) limit 2;
select e.id,e.name,p.sal from length_table e left join length_view p on e.id = p.id where length(p.sal) > 2000 order by length(p.sal)desc limit 2;
 
 
# group by having
select e.id,sum(e.sal) from length_view e where e.sal > 2000 group by 1 order by 1 desc;
select e.id,sum(e.sal) from length_view e where e.sal > 1000 group by 1 having sum(length(e.sal)) > 2000 order by 1 desc;



# cast when
select e.id 编号,case when length(e.sal) < 2000 then '低' when length(e.sal) < 3000 then '一般' else '高' end '工资' from length_view e ;
select e.id 编号,case length(e.sal)  when  1501 then '低' when 2100 then '一般' else '高' end '工资' from length_view e;


--disable_warnings
--error 0,1051
drop table length_table;
--error 0,1051
drop table length_table2;
--error 0,1051
drop view length_view;
--enable_warnings

