--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: foobar

#
# char_pad test
#

--disable_warnings
use test;
drop table if exists tt;
--enable_warnings

create table tt (x char(7));
insert into tt values (null), (''), ('中国'), ('China'), ('中China国'), ('中华人民共和国'), ('Chinese');
select x from tt;
select length(x) from tt;
set sql_mode='pad_char_to_full_length';
select x from tt;
select length(x) from tt;
drop table tt;

create table tt(c1 char(4), c5 char(6));
insert into tt values (1, 2);
set sql_mode='pad_char_to_full_length';
update tt set c1='中国', c5=concat(c1, '4');
select * from tt;
select length(c1) from tt;
drop table tt;
