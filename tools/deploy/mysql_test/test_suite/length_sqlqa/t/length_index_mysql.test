#owner:dachuan.sdc
#owner group:sql3
#description:函数嵌套 约束  索引 运算符


--echo obmysql-length-5 及obmysql-length-6 及obmysql-length-7

--error 0,1051
drop table length_table;

create table length_table(id int, sal double, name varchar(40),date_time datetime);
insert into length_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#函数嵌套
select e.id,e.name,length(length(e.sal)) from length_table e order by e.id desc;

select e.id,e.name,length(sum(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,sum(length(e.sal)) from length_table e group by 1,2 having sum(length(e.sal)) >= 4 order by id desc;

select e.id,e.name,length(max(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,max(length(e.sal)) from length_table e group by 1,2 having sum(length(e.sal)) > 4 order by id desc;


select e.id,e.name,length(min(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,min(length(e.sal)) from length_table e group by 1,2 having sum(length(e.sal)) > 4 order by id desc;

select e.id,e.name,length(avg(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,avg(length(e.sal)) from length_table e group by 1,2 having avg(length(e.sal)) > 4 order by id desc;


select e.id,e.name,length(abs(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,abs(length(e.sal)) from length_table e group by 1,2  order by id desc limit 2;

select e.id,e.name,length(ceil(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,ceil(length(e.sal)) from length_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,length(floor(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,floor(length(e.sal)) from length_table e group by 1,2  order by id desc limit 2;


select e.id,e.name,length(mod(e.sal,7.8)) from length_table e order by e.id desc;
select e.id,e.name,mod(length(e.sal),7.8) from length_table e group by 1,2  order by id desc;


select e.id,e.name,length(length(e.sal)) from length_table e order by e.id desc;
select e.id,e.name,length(length(e.sal)) from length_table e group by 1,2  order by id desc;

select e.id,instr(length(e.name),'i'),e.sal from length_table e order by id desc;
select e.id,length(instr(e.name,'i')),e.sal from length_table e order by id desc;




#算数运算符
select e.id,e.name,length(e.sal)+100 from length_table e ;
select e.id,e.name,length(e.sal)-100 from length_table e ;
select e.id,e.name,length(e.sal)*100 from length_table e ;
select e.id,e.name,length(e.sal)/100 from length_table e ;


#逻辑运算符
select e.id,e.name,e.sal from length_table e where length(e.sal) > 1500 and length(e.sal) < 3000;
select e.id,e.name,e.sal from length_table e where length(e.sal) > 2000 or e.id >20;
select e.id,e.name,e.sal from length_table e where not(length(e.sal)) < 1500;
select e.id,e.name,e.sal from length_table e where not(length(e.sal)) > 2000;


#比较运算符
select e.id,e.name,e.sal from length_table e where length(e.sal) >= 2000;
select e.id,e.name,e.sal from length_table e where length(e.sal) <= 2000;
select e.id,e.name,e.sal from length_table e where length(e.sal)  = 1501;
select e.id,e.name,e.sal from length_table e where length(e.sal)  > 1501;
select e.id,e.name,e.sal from length_table e where length(e.sal)  < 1502;
select e.id,e.name,e.sal from length_table e where length(e.sal) <> 1501;
select e.id,e.name,e.sal from length_table e where length(e.sal) != 1501;



#索引
create index length_name on length_table(id);

#select
select length(e.id) from length_table e;
select e.name,e.sal from length_table e where length(e.id) = '10';
select e.name,e.sal from length_table e where length(e.id) > '10' order by e.sal desc; 

#insert
insert into length_table  select * from length_table e where length(e.id) = '10';
select * from length_table;


#update
update length_table e set name = 'zanms' where length(e.id) = '10';
select * from length_table;


#delete
delete from length_table  where length(id) = '10' ;
select * from length_table;




#约束
--error 0,1051
drop table length_table;
create table length_table(id int primary key, sal double unique, name varchar(40) not null,date_time datetime);
insert into length_table values(10,3000.265 ,'kebi','2020-05-01 12:01:35'),(15,2100.25,'maidd','2020-05-17 18:02:30'),(29,1500.69,'yaoming','2020-05-23 23:59:59');

#select
select length(id),length(sal),length(name) from length_table;
select length(id),length(sal),length(name) from length_table where length(sal) = 6;
select length(id),length(sal),length(name) from length_table where length(sal) = 8 order by id;


#insert
insert into length_table  select length(id+1)id,length(e.sal),length(e.name),e.date_time from length_table e where length(e.sal) = 8 ;
select count(*) from length_table;


#update
update length_table  set name = 'zanms' where length(sal) = 8;
select * from length_table;


##delete
delete from length_table  where length(sal) = 8 ;
select count(*) from length_table;



--disable_warnings
--error 0,1051
drop table length_table;
--enable_warnings


