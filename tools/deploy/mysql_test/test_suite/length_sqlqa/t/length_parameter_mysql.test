--echo obmysql-length-1


SELECT length('电话') FROM dual;
SELECT length('abc') FROM dual;
SELECT length('ABC') FROM dual;
SELECT length('123') FROM dual;
SELECT length(123) FROM dual;
SELECT length(-123) FROM dual;
SELECT length('!@#$%^') FROM dual;
SELECT length('') FROM dual;
SELECT length(null) FROM dual;
SELECT length(1+9) FROM dual;
SELECT length(11-6) FROM dual;
SELECT length(4*5) FROM dual;
SELECT length(20/4) FROM dual;
SELECT length(abs(-10)) FROM dual;
SELECT length(4||5) FROM dual;
SELECT length('2020-10-10 10:10:10') FROM dual;
SELECT length(length('2020-10-10 10:10:10')) FROM dual;
SELECT length('电话123abcABC!@#$%') FROM dual;



