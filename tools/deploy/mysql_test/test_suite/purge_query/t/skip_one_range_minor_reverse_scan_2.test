--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj
# owner group: STORAGE
# description: test purge query

--disable_warnings
drop table if exists t1;
--enable_warnings

create table test.t1(c1 int, c2 varchar(4096), primary key(c1, c2)) compression 'none';

--disable_query_log
--disable_result_log

let $cnt=10000;
while($cnt <= 10260)
{
  eval insert into test.t1 values($cnt, repeat(rand() * 10000000000000000, 100));
  inc $cnt;
}


--disable_query_log
--disable_result_log
delete from test.t1 where c1 <= 10260;
let $cnt=10261;
while($cnt < 10278)
{
  eval insert into test.t1 values($cnt, repeat(rand() * 10000000000000000, 100));
  inc $cnt;
}

--source mysql_test/include/minorfreeze.inc
sleep 120;

--enable_query_log
--enable_result_log
select count(*) from test.t1;
select c1 from test.t1 where c1 < 18000 order by c1 desc;

drop table if exists t1;
