--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yht146439
# owner group: STORAGE
# description: test purge query

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
set ob_trx_idle_timeout=1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(id int, primary key(id)) block_size = 1024;

--disable_query_log
--disable_result_log

let $cnt=1;
while($cnt < 1001)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}
let $cnt=1100;
while($cnt < 10001)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}

connection conn1;
begin;
let $cnt=1001;
while($cnt < 1100)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}

## minor freeze
connection obsys;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
delete from t1 where 1=1;
select * from t1 where id >= 1 and id <= 1200;

connection conn1;
commit;

connection conn2;
select * from t1 where id >= 1 and id <= 1200;

connection conn1;
drop table if exists t1;
