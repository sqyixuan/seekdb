--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj
# owner group: STORAGE
# description: test purge query

--disable_warnings
drop table if exists t1;
--enable_warnings

create table test.t1(c1 int, c2 varchar(4096), primary key(c1, c2)) compression 'none';

--disable_query_log
--disable_result_log

let $cnt=10000;
while($cnt < 12000)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $cnt=12000;
while($cnt < 13000)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

delete from test.t1 where c1 > 10600 and c1 < 10925;
--source mysql_test/include/minorfreeze.inc
sleep 60;
delete from test.t1 where c1 > 100 and c1 < 10400;
delete from test.t1 where c1 > 12008 and c1 < 12399;
let $cnt=13000;
while($cnt < 13500)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

--enable_query_log
--enable_result_log
select count(*) from test.t1;
# 测试只跳memtable的一部分
select c1 from test.t1 where c1 > 50 and c1 < 10235 or c1 > 10500 and c1 < 12500;
# 测试跳memtable的全部
select c1 from test.t1 where c1 > 50 and c1 < 10500 or c1 > 11000 and c1 < 11500;
# 测试跳memtable的全部和minor sstable的一部分
select c1 from test.t1 where c1 > 50 and c1 < 10700 or c1 > 11500 and c1 < 12500;
# 测试跳memtable的全部和minor sstable的全部
select c1 from test.t1 where c1 > 50 and c1 < 11000 or c1 > 11200 and c1 < 11300;
# 测试跳memtable的全部，minor sstable全部，并且从minor sstable中要查询出数据
select c1 from test.t1 where c1 > 50 and c1 < 13500 or c1 > 13560 and c1 < 13600;

drop table if exists t1;
