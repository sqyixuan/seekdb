--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj
# owner group: STORAGE
# description: test purge query

--disable_warnings
drop table if exists t1;
--enable_warnings

create table test.t1(c1 int, c2 varchar(4096), primary key(c1, c2)) compression 'none';

--disable_query_log
--disable_result_log

let $cnt=10000;
while($cnt < 12000)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $cnt=12000;
while($cnt < 13000)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

delete from test.t1 where c1 > 100 and c1 < 10400;

--enable_query_log
--enable_result_log
select count(*) from test.t1;
# 测试跳过memtable一部分数据
select c1 from test.t1 where c1 > 50 and c1 < 10235;
# 测试跳过memtable的全部数据
select c1 from test.t1 where c1 > 50 and c1 < 10500;
# 测试跳过memtable的全部数据，并查询其后面一部分数据
select c1 from test.t1 where c1 > 50 and c1 < 12500;

drop table if exists t1;
