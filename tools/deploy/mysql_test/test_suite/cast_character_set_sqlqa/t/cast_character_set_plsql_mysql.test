delimiter //;

drop function if exists t_f;//

create function t_f()
returns varchar(20)
begin
	declare a varchar(20) character set utf8mb4;
	select cast(ename as char character set utf8mb4) from t1 where cast(loc as char(2) character set gbk) = '苏州' into a;
	return a;
end;
//

select t_f();//


drop function if exists t_f;//

create function t_f(t_dname varchar(20))
returns varchar(20)
begin
	declare a varchar(20) character set binary;
	select cast(job as char character set binary) from t1 where cast(dname as char(2) character set utf16) = t_dname into a;
	return a;
end;
//

select t_f('联盟');//


drop function if exists t_f;//

create function t_f(t_note varchar(20))
returns varchar(20)
begin
	declare a varchar(20) character set gbk;
	select cast(dname as char character set utf16) from t1 where cast(note as char(3) character set gb18030) = t_note into a; 
	return a;
end;
//

select t_f('爱生活');//



drop function if exists t_f;//

create function t_f(t_dname varchar(20))
returns varchar(20)
begin
	declare a varchar(20) character set gb18030;
	select cast(note as char character set gb18030) from t1 where cast(dname as char(2) character set utf16) = t_dname into a;
	return a;
end;
//

select t_f('联盟');//


drop function if exists t_f;//

create function t_f(t_dname varchar(20)) 
returns varchar(20)
begin 
	declare a varchar(20) character set utf8mb4;
	select cast(note as char character set gb18030) from t1 where cast(dname as char(2) character set utf16) = t_dname into a;
	return a;
end;
//

select t_f('联盟');//



drop function if exists t_f;//

create function t_f(t_empno int)
returns varchar(100)
begin
	declare a varchar(20) character set utf8mb4;
	declare b varchar(20) character set binary;
	declare c varchar(50) character set gbk;
	declare d varchar(60) character set utf16;
	declare e varchar(50) character set gb18030;
	declare i int default 0;
	select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where empno = t_empno into a,b,c,d,e;
	while i < 10 do
	insert into t1(ename,job,loc,dname,note) values(a,b,c,d,e);
	set i := i + 1;
	end while;
	return concat(a,b,c,d,e);
end;
//
 
