--echo ob_cast_2_2
--echo ob_cast_2_2_1

delimiter //;

drop procedure if exists t_p;//

create procedure t_p()
begin
	declare a varchar(20) character set utf8mb4;
	declare b varchar(20) character set binary;
	declare c varchar(50) character set gbk;
	declare d varchar(50) character set utf16;
	declare e varchar(50) character set gb18030;
	declare i int default 0;
	select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where empno = 7900 into a,b,c,d,e;
	while i < 10 do
	insert into t1(ename,job,loc,dname,note) values(a,b,c,d,e);
	set i := i + 1;
	end while;
end;
//

select count(*) from t1;//
call t_p();//
select count(*) from t1;//


drop procedure if exists t_p;//

create procedure t_p(in t_dname varchar(20))
begin 
	declare a varchar(20) character set utf8mb4;
	declare b varchar(20) character set binary;
	declare c varchar(50) character set gbk;
	declare d varchar(50) character set utf16;
	declare e varchar(50) character set gb18030;
	declare i int default 0;
	select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where cast(dname as char(2) character set utf16) = t_dname into a,b,c,d,e;
	repeat 
	insert into t1(ename,job,loc,dname,note) values(a,b,c,d,e);
	set i := i + 1;
	until i >= 10
	end repeat;
end;
//

select count(*) from t1;//
call t_p('联盟');//
select count(*) from t1;//


drop procedure if exists t_p;//

create procedure t_p(out t_ename varchar(20),out t_job varchar(20),out t_loc varchar(50),out t_dname varchar(50),out t_note varchar(100))
begin
	declare i int default 0;
	select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where empno = 7900 into t_ename,t_job,t_loc,t_dname,t_note;
	loop_lable:loop
	insert into t1(ename,job,dname,note) values(t_ename,t_job,t_dname,t_note);
	set i := i + 1;
	if i >= 10 then leave loop_lable;
	end if;
	end loop;
end;
//

select count(*) from t1;//
call t_p(@t_ename,@t_job,@t_loc,@t_dname,@t_note);//
select count(*) from t1;//

drop procedure if exists t_p;//

create procedure t_p(out t_ename varchar(20),out t_job varchar(20),out t_loc varchar(50),out t_dname varchar(50),out t_note varchar(50))
begin
	declare i int default 0;
	select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where empno = 7900 into t_ename,t_job,t_loc,t_dname,t_note;
end;
//

select count(*) from t1;//
call t_p(@t_ename,@t_job,@t_loc,@t_dname,@t_note);
select count(*) from t1;//

delimiter ;//

drop procedure if exists t_p;
drop table if exists t1;





