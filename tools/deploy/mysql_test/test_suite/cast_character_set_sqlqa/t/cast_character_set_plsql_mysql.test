delimiter //;

drop procedure if exists p1;//

create procedure p1()
begin
	declare a varchar(20) character set utf8mb4;
	declare b varchar(20) character set binary;
	declare c varchar(20) character set gbk;
	declare d varchar(20) character set utf16;
	declare e varchar(20) character set gb18030;
	declare msg varchar(20);
	declare done int default 0;
	declare mc cursor for select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char(2) character set utf16)dname,cast(note as char(7) character set gb18030)note from t1 where cast(job as char character set binary) = '运动员';
	declare continue handler for not found set done = 1;
	open mc;
	while done != 1 do
		set msg = '';
		fetch mc into a,b,c,d,e;
		if done != 1 then
			if (a = '韦德') then 
			set msg = concat('1:',(select a),(select b));
			select msg;
			elseif(c = '中国') then 
			set msg = concat('2:',(select c),(select d));
			select msg;
			elseif(d = '百里') then 
			set msg = concat('3:',(select a),(select c));
			select msg;
			elseif(e = '知名篮球运动员') then 
			set msg = concat('4:',(select a),(select e));
			select msg;
			else 
			set msg = concat('5:',(select a),(select d));
			select msg;
		end if;
	end if;
end while;
close mc;
end;
//

