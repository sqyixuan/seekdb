delimiter //;

drop trigger if exists p1;//

create trigger p1 before insert on t2 for each row
begin
	if new.deptno = 50 then
	insert into t1(ename,job,loc,dname,note) values(cast('科比' as char character set utf8mb4),cast('运动员' as char character set binary),
	cast('洛杉矶' as char character set gbk),cast('湖人' as char character set utf16),cast('知名运动员' as char character set gb18030));
	elseif new.deptno = 60 then
	insert into t1(ename,job,loc,dname,note) values(cast('韦德' as char character set utf8mb4),cast('运动员' as char character set binary),
	cast('洛杉矶' as char character set gbk),cast('湖人' as char character set utf16),cast('知名运动员' as char character set gb18030));	
	elseif new.deptno = 70 then
	insert into t1(ename,job,loc,dname,note) select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
	cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 where cast(job as char character set binary) = '运动员';
	else
	update t1 set loc = cast('南京' as char character set gbk) where empno = 7934;
	end if;
end;
//

insert into t2(deptno) values(50),(60),(70),(80);//
select * from t2 order by 1;//
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
cast(dname as char(2) character set utf16)dname,cast(note as char(7) character set gb18030)note from t1  order by empno;//
 

drop trigger if exists p1;//

create trigger p1 after update on t2 for each row
begin
	if old.deptno = 50 then
	update t1 set loc = cast('中国' as char character set gbk) where cast(ename as char character set utf8) = '马丁';
	elseif old.deptno = 60 then 
	delete from t1 where cast(ename as char character set utf8) = '君王';
	elseif old.deptno = 70 then 
	insert into t1(ename,job,loc,dname,note) values(cast('艾弗森' as char character set utf8mb4),cast('运动员' as char character set binary),cast('北京' as char character set gbk),
	cast('英文' as char character set utf16),cast('达人' as char character set gb18030));
	else
	delete from t1 where cast(note as char character set gb18030) = '吃苦耐劳';
	end if;
end;
//

update t2 set deptno = 51 where deptno = 50;//
update t2 set deptno = 61 where deptno = 60;//
update t2 set deptno = 71 where deptno = 70;//
update t2 set deptno = 81 where deptno = 80;//
select * from t2 order by 1;//
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
cast(dname as char(2) character set utf16)dname,cast(note as char(7) character set gb18030)note from t1 order by empno;//


drop trigger if exists p1;//

create trigger p1 before delete on t2 for each row
begin
	if old.deptno = 51 then
	delete from t1 where cast(job as char character set binary) = '运动员';
	elseif old.deptno = 61 then
	insert into t1(ename,job,loc,dname,note) values(cast('德文' as char character set utf8mb4),cast('运动员' as char character set binary),cast('天津' as char character set gbk),
	cast('英文' as char character set utf16),cast('恰恰恰' as char character set gb18030));
	elseif old.deptno = 71 then
	delete from t1 where cast(ename as char character set utf8) = '马丁';
	else 
	update t1 set note = cast('中文涵涵涵' as char character set gb18030) where cast(ename as char character set gbk) = '詹姆斯';
	end if;
end;
//

delete from t2 where deptno in (51,61,71,81);//
select * from t2 order by 1;//
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
cast(dname as char(2) character set utf16)dname,cast(note as char(7) character set gb18030)note from t1 order by empno;//

delimiter ;//

drop table if exists t1;
drop table if exists t2;
drop trigger if exists p1;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user longpy@'%' ;
--enable_warnings
