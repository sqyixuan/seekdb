update t1 partition(p1) set loc = (select cast(loc as char character set gbk) from t2 where cast(dname as char character set utf16) = 'OperaTions') where empno in (7566,7654);
select loc from t1 partition(p1) where empno in (7566,7654) order by empno;

delete from t1 partition(p1) where cast(ename as char character set utf8mb4) = '史密斯';
select count(*) from t1 partition(p1);

delete from t1 partition(p1) where cast(job as char character set binary) = '记者';
select count(*) from t1 partition(p1);

