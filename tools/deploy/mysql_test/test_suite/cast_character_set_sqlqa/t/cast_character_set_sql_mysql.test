alter table t1 add t_ename varchar(20) generated always as (cast(ename as char character set utf8)) virtual comment '名称生成列';
create index t_ename_index on t1(t_ename);
select t_ename from t1 order by 1;
explain select t_ename from t1 where t_ename = '詹姆斯' order by 1;

alter table t1 add t_ename1 varchar(20) generated always as (cast(ename as char character set utf8mb4) collate utf8mb4_general_ci ) virtual comment '名称1生成列';
select t_ename1 from t1;

alter table t1 add t_ename2 varchar(20) generated always as (cast(ename as char character set utf8mb4) collate utf8mb4_bin ) virtual comment '名称1生成列';
select t_ename2 from t1;

alter table t1 add t_ename3 varchar(20) generated always as (cast(ename as char character set utf8mb4) collate utf8mb4_unicode_ci ) virtual comment '名称1生成列';
select t_ename3 from t1;

alter table t1 add t_job varchar(20) generated always as (cast(job as char character set binary)) virtual comment '工作生成列';
create index t_job_index on t1(t_job);
select t_job from t1 order by empno;
explain select t_job from t1 where t_job = '运动员' order by 1;

alter table t1 add t_loc varchar(100) generated always as (cast(loc as char character set gbk)) virtual comment '城市生成列';
create index t_loc_index on t1(t_loc);
select cast(t_loc as char character set gbk) from t1 order by 1;
explain select cast(t_loc as char character set gbk) from t1 where cast(t_loc as char(2) character set gbk) = '中国' order by 1;

alter table t1 add t_loc1 varchar(20) generated always as (cast(loc as char character set gbk) collate gbk_bin) virtual comment '城市1生成列';
select cast(t_loc1 as char character set gbk) from t1 order by 1;

alter table t1 add t_loc2 varchar(20) generated always as (cast(loc as char character set gbk) collate gbk_chinese_ci) virtual comment '城市2生成列';
select cast(t_loc2 as char character set gbk) from t1 order by 1;

alter table t1 add t_dname varchar(20) generated always as (cast(dname as char character set utf16)) virtual comment '领导生成列';
create index t_dname_index on t1(t_dname);
select cast(t_dname as char character set utf16) from t1 order by 1;
explain select cast(t_dname as char character set utf16) from t1 order by 1;

alter table t1 add t_dname1 varchar(20) generated always as (cast(dname as char character set utf16) collate utf16_bin) virtual comment '领导1生成列';
select cast(t_dname1 as char character set utf16) from t1 order by 1;

alter table t1 add t_dname2 varchar(20) generated always as (cast(dname as char character set utf16) collate utf16_unicode_ci) virtual comment '领导2生成列';
select cast(t_dname2 as char character set utf16) from t1 order by 1;

alter table t1 add t_dname3 varchar(20) generated always as (cast(dname as char character set utf16) collate utf16_general_ci) virtual comment '领导3生成列';
select cast(t_dname3 as char character set utf16) from t1 order by 1;

alter table t1 add t_note varchar(20) generated always as (cast(note as char character set gb18030)) virtual comment '备注生成列';
create index t_note_index on t1(t_note);
select cast(t_note as char character set gb18030) from t1 order by 1;

alter table t1 add t_note1 varchar(20) generated always as (cast(note as char character set gb18030) collate gb18030_bin) virtual comment '备注1生成列';
select cast(t_note1 as char character set gb18030) from t1 order by 1;

alter table t1 add t_note2 varchar(20) generated always as (cast(note as char character set gb18030) collate gb18030_chinese_ci) virtual comment '备注2生成列';
select cast(t_note2 as char character set gb18030) from t1 order by 1;

drop table if exists t1;


