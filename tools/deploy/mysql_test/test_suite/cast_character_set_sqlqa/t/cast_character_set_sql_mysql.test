cast(note as char character set gb18030)note from t1 partition(p1) where cast(note as char(7) character set gb18030) = '知名篮球运动员' order by empno;

select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 partition(p1) order by empno;
select ename,job,loc,dname,note from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1 partition(p1) order by empno) e;
select * from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk) loc,cast(e.dname as char character set utf16) dname,cast(note as char character set gb18030) note,cast(p.loc as char character set utf8mb4) collate utf8mb4_bin loc1 
from t1 partition(p1) e left join t2 p on e.deptno = p.deptno where cast(p.dname as char character set gbk) in('AccounTing','SaLeS','OperaTions') order by empno)e;
select * from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk) loc,cast(e.dname as char character set utf16) dname,cast(note as char character set gb18030) note,cast(p.loc as char character set utf8mb4) collate utf8mb4_bin loc1 
from t1 partition(p1) e inner join t2 p on e.deptno = p.deptno where cast(p.dname as char character set gbk) in('AccounTing','SaLeS','OperaTions') order by empno)e;
