select cast(dname as char character set utf16)dname1,count(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(dname as char character set utf16) order by 1,2;
select cast(note as char character set gb18030)note1,sum(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) order by 1,2;
select cast(note as char character set gb18030)note1,avg(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) order by 1,2;
select cast(note as char character set gb18030)note1,count(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) order by 1,2;
select cast(ename as char character set utf8mb4)ename1,sum(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(ename as char character set utf8mb4) having sum(sal) > 2000 order by 1,2;
select count(cast(ename as char character set utf8mb4))ename1,cast(job as char character set binary)job1 from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(job as char character set binary) having count(cast(ename as char character set utf8mb4)) > 2 order by 1,2;
select cast(job as char character set binary)job1,sum(sal) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(job as char character set binary) having sum(sal) > 5000 order by 1,2;
select count(cast(job as char character set binary))job1,cast(ename as char character set utf8mb4) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(job as char character set binary) having count(cast(job as char character set binary)) > 2 order by empno;

select cast(loc as char character set gbk)loc1,sum(sal) from t1 partition(p2) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(loc as char character set gbk) having sum(sal) > 2500 order by 1,2;
select count(cast(loc as char character set gbk))loc1,cast(dname as char character set utf16)dname1 from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(dname as char character set utf16) having count(cast(loc as char character set gbk)) > 1 order by 1,2;
select cast(dname as char character set utf16)dname1,sum(sal) from t1 partition(p2) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(dname as char character set utf16) having sum(sal) > 2500 order by 1,2;
select count(cast(dname as char character set utf16))dname1,cast(loc as char character set gbk) from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(loc as char character set gbk) having count(cast(dname as char character set utf16)) = 1 order by 1,2;
select cast(note as char character set gb18030)note1,sum(sal) from t1 partition(p2) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) having sum(sal) > 2600 order by 1,2;
select count(cast(note as char character set gb18030))note1,cast(note as char character set gb18030)note1 from t1 partition(p1) where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) having count(cast(note as char character set gb18030)) > 1 order by 1,2;

select (case cast(ename as char character set utf8mb4) when '米勒' then 1 when '詹姆斯' then 2 when '特纳' then 3 when '克拉克' then 4 else 5 end) ename from t1 partition(p1) order by 1; 
select (case cast(job as char character set binary) when '记者' then 1 when '职员' then 2 when '运动员' then 3 when '作家' then 4 else 5 end) job from t1 partition(p1) order by 1;
select (case cast(loc as char(2) character set gbk) when '中国' then 1 when '英国' then 2 when '德国' then 3 when '巴黎' then 4 else 5 end) loc from t1 partition(p1) order by 1;
select (case cast(dname as char(2) character set utf16) when '百里' then 1 when '澳特' then 2 when '位图' then 3 when '联盟' then 4 else 5 end) dname from t1 partition(p1) order by 1;
select (case cast(note as char(4) character set gb18030) when '帅气小伙' then 1 when '吃苦耐劳' then 2 when '兢兢业业' then 3 when '爱生活' then 4 else 5 end) dname from t1 partition(p1) order by 1;


update t1 partition(p1) set ename = cast('科比' as char character set utf8mb4) where empno = 7934;
select cast(ename as char character set utf8mb4) from t1 partition(p1) where empno = 7934;

update t1 partition(p1) set ename = cast('勒布朗' as char character set utf8mb4) where cast(job as char character set binary) = '运动员';
