select distinct cast(ename as char character set utf8mb4) ename from t1 partition(p1) order by empno;
#select distinct cast(job as char character set binary)job from t1 partition(p1) order by empno;
select distinct cast(loc as char character set gbk) loc from t1 partition(p1) order by empno;
select distinct cast(dname as char character set utf16) dname from t1 partition(p1) order by empno;
select distinct cast(note as char character set gb18030) note from t1 partition(p1) order by empno;

