select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where not exists(select * from t1_v where cast(note as char character set gb18030) = '知名篮球运动员') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;


select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
