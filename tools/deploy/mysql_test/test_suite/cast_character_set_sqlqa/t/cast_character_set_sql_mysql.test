select cast(ename as char character set utf8mb4) from t1 order by 1;
explain select cast(ename as char character set utf8mb4) from t1 order by 1;

select cast(loc as char character set gbk) from t1 where cast(loc as char(2) character set gbk) = '中国' order by 1;
explain select cast(loc as char character set gbk) from t1 where cast(loc as char(2) character set gbk) = '中国' order by 1;

select cast(job as char character set binary) from t1 where cast(job as char character set binary) = '记者' order by 1;
explain select cast(job as char character set binary) from t1 where cast(job as char character set binary) = '记者' order by 1;

select cast(job as char character set binary),cast(dname as char character set utf16) from t1 where cast(job as char character set binary) = '记者' and cast(dname as char(2) character set utf16) = '联盟' order by 1;
explain select cast(job as char character set binary),cast(dname as char character set utf16) from t1 where cast(job as char character set binary) = '记者' and cast(dname as char(2) character set utf16) = '联盟' order by 1;

select cast(job as char character set binary),cast(dname as char character set utf16),cast(note as char character set gb18030) from t1 where cast(job as char character set binary) = '记者' 
and cast(dname as char(2) character set utf16) = '联盟' and cast(note as char(5) character set gb18030) = '说话很讲究' order by 1;
explain select cast(job as char character set binary),cast(dname as char character set utf16),cast(note as char character set gb18030) from t1 where cast(job as char character set binary) = '记者' 
and cast(dname as char(2) character set utf16) = '联盟' and cast(note as char(5) character set gb18030) = '说话很讲究' order by 1;

