select cast(ename as char character set utf8mb4) from t1_v where cast(job as char character set binary) = '运动员';

update t1_v set loc = (select cast(loc as char character set gbk) from t2_v where cast(dname as char character set utf16) = 'OperaTions') where empno in (7566,7654);
select loc from t1_v where empno in (7566,7654) order by empno;

