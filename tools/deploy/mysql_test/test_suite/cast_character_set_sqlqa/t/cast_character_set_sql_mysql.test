create view t_v as select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1; 

select * from t_v order by 1;

create view t1_v as select * from t1 order by 1;
create view t2_v as select * from t2 order by 1;


select distinct cast(ename as char character set utf8mb4) ename from t1_v order by empno;
#select distinct cast(job as char character set binary)job from t1_v order by empno;
select distinct cast(loc as char character set gbk) loc from t1_v order by empno;
select distinct cast(dname as char character set utf16) dname from t1_v order by empno;
select distinct cast(note as char character set gb18030) note from t1_v order by empno;

select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(ename as char character set utf8mb4) = '詹姆斯' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(job as char character set binary) = '运动员' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(loc as char character set gbk) = '中国' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(loc as char(2) character set gbk) = '中国' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(dname as char character set utf16) = '百里' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(dname as char(2) character set utf16) = '百里' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(note as char character set gb18030) = '知名篮球运动员' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,
cast(note as char character set gb18030)note from t1_v where cast(note as char(7) character set gb18030) = '知名篮球运动员' order by empno;

select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v order by empno;
select ename,job,loc,dname,note from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v order by empno) e;
select * from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk) loc,cast(e.dname as char character set utf16) dname,cast(note as char character set gb18030) note,cast(p.loc as char character set utf8mb4) collate utf8mb4_bin loc1 
from t1_v e left join t2_v p on e.deptno = p.deptno where cast(p.dname as char character set gbk) in('AccounTing','SaLeS','OperaTions') order by empno)e;
select * from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk) loc,cast(e.dname as char character set utf16) dname,cast(note as char character set gb18030) note,cast(p.loc as char character set utf8mb4) collate utf8mb4_bin loc1 
from t1_v e inner join t2_v p on e.deptno = p.deptno where cast(p.dname as char character set gbk) in('AccounTing','SaLeS','OperaTions') order by empno)e;
select * from (select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk) loc,cast(e.dname as char character set utf16) dname,cast(note as char character set gb18030) note,cast(p.loc as char character set utf8mb4) collate utf8mb4_bin loc1 
from t1_v e right join t2_v p on e.deptno = p.deptno where cast(p.dname as char character set gbk) in('AccounTing','SaLeS','OperaTions') order by empno)e;

select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where exists(select * from t1_v where cast(ename as char character set utf8mb4) = '詹姆斯') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where not exists(select * from t1_v where cast(ename as char character set utf8mb4) = '勒布朗') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where exists(select * from t1_v where cast(job as char character set binary) = '运动员') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where not exists(select * from t1_v where cast(ename as char character set utf8mb4) = '职业运动员') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where exists(select * from t1_v where cast(loc as char(2) character set gbk) = '中国') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where not exists(select * from t1_v where cast(loc as char character set gbk) = '中国') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
where exists(select * from t1_v where cast(dname as char(2) character set utf16) = '百里') and cast(loc as char(2) character set gbk) in ('阿克伦','中国','上海','苏州') order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,cast(dname as char character set utf16)dname,cast(note as char character set gb18030)note from t1_v 
