select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(loc as char character set gbk)loc,
cast(sal as char character set utf8mb4)sal,cast(deptno as char character set utf8mb4)deptno from t1 order by empno;

select cast(job as char character set binary) from t1 where cast(job as char character set binary) is not null order by empno;
select cast(loc as char character set gbk) from t1 where cast(loc as char(2) character set gbk) = '中国' order by empno;
select cast(sal as char character set utf8) from t1 where sal > 500 order by empno;
select cast(sal as char character set utf8) from t1 where cast(sal as char character set utf8) > '500' order by empno;
select cast(ename as char character set utf8mb4)ename,cast(job as char character set binary)job,cast(e.loc as char character set gbk)loc,
cast(sal as char character set utf8mb4)sal,cast(p.deptno as char character set utf8mb4)deptno from t1 e,t2 p where 
cast(e.deptno as char character set utf8) = cast(p.deptno as char character set utf8) and cast(job as char character set binary) is not null and cast(e.loc as char(2) character set gbk) = '中国' order by empno; 

