select count(cast(note as char character set gb18030))note1,cast(note as char character set gb18030)note1 from t1 where cast(ename as char character set utf8mb4) in ('韦德','詹姆斯','米勒','琼斯') or cast(job as char character set binary) not in ('记者','职员') group by cast(note as char character set gb18030) having count(cast(note as char character set gb18030)) > 1 order by 1,2;

select (case cast(ename as char character set utf8mb4) when '米勒' then 1 when '詹姆斯' then 2 when '特纳' then 3 when '克拉克' then 4 else 5 end) ename from t1 order by 1; 
select (case cast(job as char character set binary) when '记者' then 1 when '职员' then 2 when '运动员' then 3 when '作家' then 4 else 5 end) job from t1 order by 1;
select (case cast(loc as char(2) character set gbk) when '中国' then 1 when '英国' then 2 when '德国' then 3 when '巴黎' then 4 else 5 end) loc from t1 order by 1;
select (case cast(dname as char(2) character set utf16) when '百里' then 1 when '澳特' then 2 when '位图' then 3 when '联盟' then 4 else 5 end) dname from t1 order by 1;
select (case cast(note as char(4) character set gb18030) when '帅气小伙' then 1 when '吃苦耐劳' then 2 when '兢兢业业' then 3 when '爱生活' then 4 else 5 end) dname from t1 order by 1;


--echo ob_cast_2_1_3

update t1 set ename = cast('科比' as char character set utf8mb4) where empno = 7934;
select cast(ename as char character set utf8mb4) from t1 where empno = 7934;

update t1 set ename = cast('勒布朗' as char character set utf8mb4) where cast(job as char character set binary) = '运动员';
select cast(ename as char character set utf8mb4) from t1 where cast(job as char character set binary) = '运动员';

update t1 set loc = (select cast(loc as char character set gbk) from t2 where cast(dname as char character set utf16) = 'OperaTions') where empno in (7566,7654);
select loc from t1 where empno in (7566,7654) order by empno;

--echo ob_cast_2_1_4

delete from t1 where cast(ename as char character set utf8mb4) = '史密斯';
select count(*) from t1;

delete from t1 where cast(job as char character set binary) = '记者';
select count(*) from t1;

delete from t1 where cast(loc as char character set gbk) = 'BoSton';
select count(*) from t1;

--error 0,1292
delete from t1 where cast(loc as char(2) character set gbk) = 'BoSton';
select count(*) from t1;

--error 0,1292
delete from t1 where cast(dname as char(2) character set utf16) = '百里';
select count(*) from t1;

--error 0,1292
delete from t1 where cast(note as char character set gb18030) = '帅气小伙';
select count(*) from t1;

--error 0,1292
delete from t1 where cast(note as char(4) character set gb18030) = '帅气小伙';
select count(*) from t1;

drop table if exists t1;
drop table if exists t2;

--echo ob_cast_2_3

drop table if exists t1;
drop table if exists t2;


create table t2(DEPTNO int primary key,DNAME varchar(14),LOC varchar(13));
create table t1(empno decimal(6,2),ename varchar(10),job varchar(9),loc char(10),dname char(10),sal int,note char(20),deptno decimal(2))character set binary partition by range(sal) 
(partition  p1 values  less than(2500),partition  p2 values  less than(5000));
