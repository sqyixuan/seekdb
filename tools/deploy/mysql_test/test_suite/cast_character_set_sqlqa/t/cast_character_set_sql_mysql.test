drop table if exists t1;
drop table if exists t2;
drop view if exists t_v;
drop view if exists t1_v;
drop view if exists t2_v;

create table t2(DEPTNO int primary key,DNAME varchar(14),LOC varchar(13));
create table t1(empno decimal(6,2),ename varchar(10),job varchar(9),loc char(10),dname char(10),sal int,note char(20),deptno decimal(2))character set binary;
