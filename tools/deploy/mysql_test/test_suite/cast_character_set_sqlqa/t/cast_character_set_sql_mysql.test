--error 0,1292
delete from t1 partition(p1) where cast(note as char character set gb18030) = '帅气小伙';
select count(*) from t1 partition(p1);

--error 0,1292
delete from t1 partition(p1) where cast(note as char(4) character set gb18030) = '帅气小伙';
