select (case cast(ename as char character set utf8mb4) when '米勒' then 1 when '詹姆斯' then 2 when '特纳' then 3 when '克拉克' then 4 else 5 end) ename from t1_v order by 1; 
select (case cast(job as char character set binary) when '记者' then 1 when '职员' then 2 when '运动员' then 3 when '作家' then 4 else 5 end) job from t1_v order by 1;
select (case cast(loc as char(2) character set gbk) when '中国' then 1 when '英国' then 2 when '德国' then 3 when '巴黎' then 4 else 5 end) loc from t1_v order by 1;
select (case cast(dname as char(2) character set utf16) when '百里' then 1 when '澳特' then 2 when '位图' then 3 when '联盟' then 4 else 5 end) dname from t1_v order by 1;
select (case cast(note as char(4) character set gb18030) when '帅气小伙' then 1 when '吃苦耐劳' then 2 when '兢兢业业' then 3 when '爱生活' then 4 else 5 end) dname from t1_v order by 1;


update t1_v set ename = cast('科比' as char character set utf8mb4) where empno = 7934;
select cast(ename as char character set utf8mb4) from t1_v where empno = 7934;

