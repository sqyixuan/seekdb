#owner:dachuan.sdc
##owner group:sql1
##description:数据类型、CTAS
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);

--echo ob_cast_1
--echo ob_cast_1_1
--echo ob_cast_1_1_1_1

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a tinyint,b tinyint);
insert into t1 values(0,127),(null,null),(10,-15),(20,-30);

select cast(a as char character set utf8mb4),cast(b as char character set utf8mb4) from t1;
select cast(a as char(1) character set utf8mb4),cast(b as char(1) character set utf8mb4) from t1;
select cast(a as char(2) character set utf8mb4),cast(b as char(3) character set utf8mb4) from t1;

#select cast(a as char character set binary),cast(b as char character set binary) from t1;
#select cast(a as char(1) character set binary),cast(b as char(1) character set binary) from t1;
#select cast(a as char(2) character set binary),cast(b as char(3) character set binary) from t1;

select cast(a as char character set gbk),cast(b as char character set gbk) from t1;
select cast(a as char(1) character set gbk),cast(b as char(1) character set gbk) from t1;
select cast(a as char(2) character set gbk),cast(b as char(3) character set gbk) from t1;

select cast(a as char character set utf16),cast(b as char character set utf16) from t1;
select cast(a as char(1) character set utf16),cast(b as char(1) character set utf16) from t1;
select cast(a as char(2) character set utf16),cast(b as char(3) character set utf16) from t1;

select cast(a as char character set gb18030),cast(b as char character set gb18030) from t1;
select cast(a as char(1) character set gb18030),cast(b as char(1) character set gb18030) from t1;
select cast(a as char(2) character set gb18030),cast(b as char(3) character set gb18030) from t1;


select cast(a as char character set utf8mb4) collate utf8mb4_bin as a,cast(b as char character set utf8mb4) collate utf8mb4_bin as b from t1;
select cast(a as char character set utf8mb4) collate utf8mb4_general_ci as a,cast(b as char character set utf8mb4) collate utf8mb4_general_ci as b from t1;
select cast(a as char character set utf8mb4) collate utf8mb4_unicode_ci as a,cast(b as char character set utf8mb4) collate utf8mb4_unicode_ci as b from t1;

select cast(a as char character set gbk) collate gbk_bin as a,cast(b as char character set gbk) collate gbk_bin as b from t1;
select cast(a as char character set gbk) collate gbk_chinese_ci as a,cast(b as char character set gbk) collate gbk_chinese_ci as b from t1;

select cast(a as char character set utf16) collate utf16_bin as a,cast(b as char character set utf16) collate utf16_bin as b from t1;
select cast(a as char character set utf16) collate utf16_general_ci as a,cast(b as char character set utf16) collate utf16_general_ci as b from t1;
select cast(a as char character set utf16) collate utf16_unicode_ci as a,cast(b as char character set utf16) collate utf16_unicode_ci as b from t1;

select cast(a as char character set gb18030) collate gb18030_bin as a,cast(b as char character set gb18030) collate gb18030_bin as b from t1;
select cast(a as char character set gb18030) collate gb18030_chinese_ci as a,cast(b as char character set gb18030) collate gb18030_chinese_ci as b from t1;



