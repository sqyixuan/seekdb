select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 'null' collate  gb18030_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

--echo #符号
set @s = _utf8mb4 '（）' collate  utf8mb4_general_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s =  cast('（）' as binary);
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk '（）' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf16 '（）' collate  utf16_general_ci;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 '（）' collate  gb18030_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf8mb4 '=' collate  utf8mb4_general_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s =  cast('=' as binary);
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk '=' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf16 '+' collate  utf16_general_ci;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 '=' collate  gb18030_chinese_ci ;
