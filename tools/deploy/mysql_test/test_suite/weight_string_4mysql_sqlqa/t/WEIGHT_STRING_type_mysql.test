--echo #子查询

set names 'utf8mb4';
drop table typy_set;
create table typy_set 
(tt tinyint, st smallint,mt mediumint,it integer,bt bigint,ft float,dle double,dl decimal(10,7),bi bit(5),
yr year,te time,de date,dae datetime,tp timestamp,
cr char(30),vr varchar(30),tet tinytext,txt text,mxt mediumtext,lxt  longtext,
em enum('春','11'),se set('1','2','3'),bry binary,bb blob)default charset=gbk collate=gbk_chinese_ci;

insert into typy_set values
(127,32767,1677215,2147483647,1,9.345,12.34526,35.2984,b'1111',
1998,121212,0707,20200423121212,20211123121259,
'1','天下攘攘皆为利往','三十年河','三十六年蝉','落花寒食东风雨','凉席打折买俩',
'春','4',2,9992222);



select weight_string((select tt from typy_set)),hex(weight_string((select tt from typy_set))) from typy_set;
select weight_string((select st from typy_set)),hex(weight_string((select st from typy_set))) from typy_set;
select weight_string((select mt from typy_set)),hex(weight_string((select mt from typy_set))) from typy_set;
select weight_string((select it from typy_set)),hex(weight_string((select it from typy_set))) from typy_set;
select weight_string((select bt from typy_set)),hex(weight_string((select bt from typy_set))) from typy_set;
select weight_string((select ft from typy_set)),hex(weight_string((select ft from typy_set))) from typy_set;
select weight_string((select dle from typy_set)),hex(weight_string((select dle from typy_set))) from typy_set;
select weight_string((select dl from typy_set)),hex(weight_string((select dl from typy_set))) from typy_set;
select weight_string((select bi from typy_set)),hex(weight_string((select bi from typy_set))) from typy_set;

select weight_string((select yr from typy_set)),hex(weight_string((select yr from typy_set))) from typy_set;
select weight_string((select te from typy_set)),hex(weight_string((select te from typy_set))) from typy_set;
select weight_string((select de from typy_set)),hex(weight_string((select de from typy_set))) from typy_set;
select weight_string((select dae from typy_set)),hex(weight_string((select dae from typy_set))) from typy_set;
select weight_string((select tp from typy_set)),hex(weight_string((select tp from typy_set))) from typy_set;

select weight_string((select cr from typy_set)),hex(weight_string((select cr from typy_set))) from typy_set;
select weight_string((select vr from typy_set)),hex(weight_string((select vr from typy_set))) from typy_set;
select weight_string((select tet from typy_set)),hex(weight_string((select tet from typy_set))) from typy_set;
select weight_string((select txt from typy_set)),hex(weight_string((select txt from typy_set))) from typy_set;
select weight_string((select mxt from typy_set)),hex(weight_string((select mxt from typy_set))) from typy_set;
select weight_string((select lxt from typy_set)),hex(weight_string((select lxt from typy_set))) from typy_set;

select weight_string((select em from typy_set)),hex(weight_string((select em from typy_set))) from typy_set;
select weight_string((select se from typy_set)),hex(weight_string((select se from typy_set))) from typy_set;
select weight_string((select bry from typy_set)),hex(weight_string((select bry from typy_set))) from typy_set;
select weight_string((select bb from typy_set)),hex(weight_string((select bb from typy_set))) from typy_set;


select weight_string((select tt from typy_set limit 1)),hex(weight_string((select tt from typy_set limit 1))) from typy_set;



set @a = _utf8mb4 'ab' collate  utf8mb4_general_ci ;
set @b =  cast('ab' as binary);
set @c = _gbk 'ab' collate  gbk_chinese_ci ;
set @d = _utf16 'ab' collate  utf16_general_ci;
set @s = _gb18030 'ab' collate  gb18030_chinese_ci ;
set @a = _utf8mb4 'ab' collate  utf8mb4_general_ci ;

select weight_string((select @a from dual)),hex(weight_string((select @a from dual)));
select weight_string((select @b from dual)),hex(weight_string((select @b from dual)));
select weight_string((select @c from dual)),hex(weight_string((select @c from dual)));
select weight_string((select @d from dual)),hex(weight_string((select @d from dual)));
select weight_string((select @s from dual)),hex(weight_string((select @s from dual)));


