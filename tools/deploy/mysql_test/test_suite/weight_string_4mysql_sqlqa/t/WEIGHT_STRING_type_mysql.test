select hex(weight_string(@s)),weight_string(@s);

set @s =  cast('来来' as binary);
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk '来来' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf16 '来来' collate  utf16_general_ci;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 '来来' collate  gb18030_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);


