#description: obmysql模式, weight_string表达式测试
#tags:dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4


--echo #type
--echo #输入字母
set @s = _utf8mb4 'ab' collate  utf8mb4_general_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s =  cast('ab' as binary);
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk 'ab' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf16 'ab' collate  utf16_general_ci;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 'ab' collate  gb18030_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);



--echo #输入数字
set @s = _utf8mb4 '0001' collate  utf8mb4_general_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s =  cast('0001' as binary);
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk '0001' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _utf16 '0001' collate  utf16_general_ci;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gb18030 '0001' collate  gb18030_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);

set @s = _gbk '1.233' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);


set @s = _gbk '-999' collate  gbk_chinese_ci ;
select @s, hex(@s), hex(weight_string(@s)),weight_string(@s);



--echo # utf8mb4输入中文ob和mysql不一致
