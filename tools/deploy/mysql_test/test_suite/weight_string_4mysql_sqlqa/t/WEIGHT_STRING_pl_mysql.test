drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = weight_string(binary 1) ;
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/

insert into t1(s2) values(weight_string(null));
--sorted_result
