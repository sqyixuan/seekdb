--echo #update
drop table t1 ;
create table t1 (s2 char(20),s3 binary(10));
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before update on t1 for each row
begin
if new.s2 =1 then
set new.s2 =  weight_string(old.s2 level 1) ;
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
update t1 set s2=weight_string(binary 1) where s2=2;
--sorted_result
select * from t1;


--echo #delete
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before delete on t1 for each row
begin
set @aa= weight_string(old.s2 level 1 desc) ;

end/
delimiter ;/
delete from  t1  where s2=1;
--sorted_result
select * from t1;
select @aa;



--echo #游标
set @dd = _gbk '0' collate  gbk_chinese_ci ;
drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);
insert into t2 values(4,'2',1,1,1);
insert into t2 values(4,'5',1,1,3);
--error 1305
drop procedure processorders;
delimiter /;
create procedure processorders()
begin
declare aa int;
declare rc int;
declare i int default 1;
declare cur cursor for select weight_string(s4) from t2 ;
select count(*)  into rc from t2;
open cur;
 while i < rc do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;

end/
delimiter ;/
call processorders();



--echo #动态sql

drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);
insert into t2 values(4,'2',1,1,1);
insert into t2 values(4,'5',1,1,3);
--error 1305
drop procedure agm;

delimiter /;
create procedure agm(in func char(20),in order_param varchar(10),in anchor int,in size int)
begin
	set @s = concat("select " ,func, "from t2 order by ",order_param," limit ",anchor,",",size);
	prepare stmt from @s;
	execute stmt;
	deallocate prepare stmt;
end/
delimiter ;/
--sorted_result
call agm('weight_string(s1)','s1',1,5);
--sorted_result
call agm('weight_string(s2)','s1',1,5);
--sorted_result
call agm('weight_string(s3)','s1',1,5);
--sorted_result
call agm('weight_string(s4)','s1',1,5);
--sorted_result
call agm('weight_string(s5)','s1',1,5);



