--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4



--error 1051
drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);
insert into t2 values(4,'2',1,1,1);
insert into t2 values(4,'5',1,1,3);


--echo #无参函数

set @dd = _gbk '0x007fff' collate  gbk_chinese_ci ;
--error 1305
drop function n_1;
delimiter /;
create function n_1() returns char(20) 
begin
  declare a char(20);
  set a=weight_string(@dd);
  select weight_string(s1) into @a from t2 limit 1;
  select weight_string(s2) into @b from t2 limit 1;
  select weight_string(s3) into @c from t2 limit 1;
  select weight_string(s4) into @d from t2 limit 1;
  select weight_string(s5) into @s from t2 limit 1;
  return concat(weight_string(binary 1 level 1 ),a);
end/
delimiter ;/

select n_1();
select @a;
select @b;
select @c;
select @d;
select @s;

--echo #有参

set @dd = _gbk '12' collate  gbk_chinese_ci ;
drop function n_1;
delimiter /;
create function n_1(a int) returns int 
begin
  select weight_string(s3) into @a from t2 limit 1;
  return a;
end/
delimiter ;/

select @dd,n_1(weight_string(@dd)),weight_string(n_1(1)),weight_string(@a);

--echo #case when
--echo #45040820 case when 结果不稳定
set @dd = _gbk '12' collate  gbk_chinese_ci ;
set @ss = _gbk '1' collate  gbk_chinese_ci ;
drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);

drop function n_1;
delimiter /;
create function n_1(a int) 
returns int
begin
declare week int;
case a
when 2 then set week=weight_string(@dd);

else set week=weight_string(@ss);
end case;
return week;
end/
delimiter ;/
--disable_result_log
select n_1(s1) from t2;
--enable_result_log
############
set @dd = _gbk '12' collate  gbk_chinese_ci ;
set @ss = _gbk '1' collate  gbk_chinese_ci ;
drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);

drop function n_1;
delimiter /;
create function n_1(a int) 
returns int
begin
declare week int;
case weight_string(@dd)
when 12 then set week=a;

else set week=weight_string(@ss);
end case;
return week;
end/
delimiter ;/
--disable_result_log
select n_1(s1) from t2;
--enable_result_log

--echo #if
--error 1051
drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,132);
insert into t1 values (534534,132);
drop function n_1;
delimiter /;
create function n_1(a char(20),b char(20))
returns int
begin
if a<weight_string(b) then 
set @aa=999;
else 
set @aa=111;
end if;
return 6;
end/
delimiter ;/
--sorted_result
select n_1(s2,s3) from t1  ;
select @aa;


--echo #while循环

drop table t2;
create table t2(s1 binary,s2 int,s3 int);
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i binary default 0;
while i<5 do
set i=i+1;
  insert into t2 values(weight_string(i),0,i);
  end while ;
  return 0;
end/
delimiter ;/
select n_1() ;
select * from t2;
#########
drop table t2;
create table t2(s1 binary,s2 int,s3 int);
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i binary default 0;
while weight_string(i)<5 do
set i=weight_string(i)+1;
  insert into t2 values(weight_string(i),0,i);
  end while ;
  return weight_string(i);
end/
delimiter ;/
--sorted_result
select n_1() ;
--sorted_result
select * from t2;

--echo #repeat
drop table t2;
create table t2(s1 binary,s2 int,s3 int);
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i binary default 0;
 repeat
 insert into t2 values(weight_string(i),0,i);
   set i = weight_string(i) +1;
until weight_string(i) >= 3
  end repeat;
  return weight_string(i);
end/
delimiter ;/
--sorted_result
select n_1() ;
--sorted_result
select * from t2;

--echo #loop
set @dd = _gbk '4' collate  gbk_chinese_ci ;
drop table t2;
create table t2(s1 binary,s2 int,s3 int);
drop function n_1;
delimiter /;
create function n_1() returns int
begin
declare i binary default 0;
 loop_label:loop
  insert into t2 values(weight_string(i),0,1);
   set i = i +1;
if i >= weight_string(@dd) then
   leave loop_label;
  end if;
  end loop;
  return 0;
end/
delimiter ;/
--sorted_result
select n_1() ;
--sorted_result
select * from t2;






--echo #procedure
--echo #in
set @dd = _gbk '12' collate  gbk_chinese_ci ;
set @aa = _gb18030 '6' collate  gb18030_chinese_ci ;
--error 1305
drop procedure prre;
delimiter /;
create procedure prre(in a int,in b int)
begin
declare aa int;
  set @aa=9;
  set aa=9;
    if a >= b then
      set @aa =  weight_string(@dd);
      set aa=  weight_string(@dd);
    else
      set @aa = 0;
    end if;
select aa;
end/
delimiter ;/

call prre(weight_string(@hh),weight_string(@aa));

--echo #out
set @dd = _gbk '12' collate  gbk_chinese_ci ;
drop procedure if exists p1;
delimiter /;
create procedure p1(out ia int) 
BEGIN
	select weight_string(@dd) into ia ;
END/
delimiter ;/
call p1(@bb);
select @bb;


--echo #inout
set @dd = _gbk '12' collate  gbk_chinese_ci ;
drop procedure if exists p1;
delimiter /;
create procedure p1(inout ia int,inout ib char(20)) 
BEGIN
	select weight_string(@dd) into ia ;
	select ib;
END/
delimiter ;/
set @hh = weight_string(@dd);
call p1(@qq,@hh);
select @qq;


--echo #trigger
--echo #insert
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select max(s2) from t1);
elseif new.s2 > 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
insert into t1(s2) values(weight_string(binary 9));
--sorted_result
select * from t1;




drop table t2 ;
create table t2 (s2 char(20),s3 binary);
insert into t2 values (1,2);
insert into t2 values (2,3);

drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select weight_string(s3) from t2 limit 1);
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/

insert into t1(s2) values(weight_string(1));
