#owner:jiajingzhe.jjz 
#owner group: 创新研发
#description: obmysql模式, weight_string表达式测试
#tags:dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4



--echo #索引
--error 1305
drop procedure initData;
delimiter /;
create procedure initData()
begin
declare ct int default 1;
while ct <= 20 DO
 insert into t1 (id,s1,s2) values (ct,ct,ct); 
 set ct = ct +1;
end while;
end;
/
delimiter ;/


--echo #普通索引
--error 1051
drop table t1;
create table t1(id binary(20),s1 char(20), s2 blob);
call initData();
create index t1_id on t1(id);
create index t1_s1 on t1(s1);
--sorted_result 
select weight_string(id) from t1 where weight_string(s1)=15;

--echo #unique

drop table t1;
create table t1(id binary(20),s1 char(20), s2 blob);
call initData();
create unique index t1_id on t1(id);
create unique index t1_s1 on t1(s1);
--sorted_result 
select weight_string(id) from t1 where weight_string(s1)=15;
--echo #组合索引
drop table t1;
create table t1(id binary(20),s1 char(20), s2 binary(33),s3 blob);
call initData();
create  index t1_id on t1(id,s1,s2);

--sorted_result 
select weight_string(id) from t1 where weight_string(s1)=15;


--echo #约束
--echo #虚拟列
drop table t1;
create table t1(id binary(20),s1 char(20), bao char(20) GENERATED ALWAYS AS (id) VIRTUAL);
insert into t1(id,s1) values (1,1),(5,1);
--sorted_result 
select weight_string(bao) from t1;


drop table t1;
create table t1(id binary(20),s1 char(20), bao char(20) GENERATED ALWAYS AS (weight_string (id as char(6) level 1 )) VIRTUAL);



--echo #存储列
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id binary(20),s1 char(20), bao char(20) GENERATED ALWAYS AS (id) STORED);
insert into t1(id,s1) values (1,1),(5,1);
--sorted_result 
select weight_string(bao) from t1;


drop table t1;
#--error 3102
create table t1(id binary(20),s1 char(20), bao char(20) GENERATED ALWAYS AS (weight_string (id as char(6) level 1 )) stored);


--echo #unsigned zerofill
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (s1 int unsigned zerofill) 
default charset=gbk collate=gbk_chinese_ci;

insert into t1 values (1);
insert into t1 values (10);
insert into t1 values (100);
--sorted_result 
select weight_string(binary s1) from t1;


drop table t1;
create table t1 (s1 int unsigned zerofill) 
default charset=gbk collate=gbk_chinese_ci;
--echo #44823852  binary ob可以插入，mysql截断
--error 1265
insert into t1 values (weight_string (11 as binary(3)));
insert into t1 values (weight_string (11 as char(3)));
insert into t1 values (weight_string (11 level 1));
insert into t1 values (weight_string (11 level 1 desc));
insert into t1 values (weight_string (19 level 1 desc reverse ));
--sorted_result 
select * from t1;

drop table t1;
create table t1 (s1 binary(100) ) 
default charset=gbk collate=gbk_chinese_ci;
--echo #44823852 asbinary插入binary ob可以插入，mysql为null
insert into t1 values (weight_string (11 as binary(100)));

--sorted_result 
select * from t1;

--echo #unique
drop table t1;
create table t1 (s1 binary(20) unique,s2 int) 
default charset=gbk collate=gbk_chinese_ci;

insert into t1(s1) values (weight_string (binary 11));
--error 1062
insert into t1(s1) values (weight_string (binary 11));

--echo #not null
drop table t1;
create table t1 (s1 binary(20) not null,s2 int) 
default charset=gbk collate=gbk_chinese_ci;

insert into t1(s1) values (weight_string (binary 11));
--error 1048
insert into t1(s1) values (weight_string (11));

--echo #check
drop table t1;
create table t1 (s1 binary(20)  check( s1 >10) ,s2 int) 
default charset=gbk collate=gbk_chinese_ci;
--error 3819
insert into t1(s1) values (weight_string (binary 111011));
--sorted_result 
select * from t1;
--error 3819
insert into t1(s1) values (weight_string (binary 15));
--error 3819
insert into t1(s1) values (weight_string (binary 10));



drop table t1;
create table t1 (s1 int  check(weight_string(binary s1) >10) ,s2 int) 
default charset=gbk collate=gbk_chinese_ci;

insert into t1(s1) values (11);
--error 3819
insert into t1(s1) values (10);
--sorted_result 
select * from t1;


drop table t1;
create table t1 (s1 int  check(s1 <weight_string(binary 10)) ,s2 int) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1(s1) values (9);
--error 3819
insert into t1(s1) values (11);
--sorted_result 
select * from t1;

--echo #default

drop table t1;
create table t1 (s1 int default 10 ,s2 binary(20) default 10 ) 
default charset=gbk collate=gbk_chinese_ci;


insert into t1(s1) values (weight_string (binary 15));
insert into t1(s2) values (weight_string (binary 15));
--sorted_result 
select weight_string(s1),weight_string(s2) from t1;
--sorted_result 
select * from t1;

--echo #外键
--error 1051
drop table t3;
drop table t1;
create table t1(id int primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);

create table t3(bid int ,s1 int, s2 int,foreign key (bid) references t1(id));
INSERT INTO t3 VALUES(3,1,3),(1,6,0),(1,6,0),(2,7,0);

insert into t1(id) values (weight_string (binary 15));
--sorted_result 
select * from t1;
--sorted_result 
select weight_string(id) from t1;

insert into t3(bid) values (weight_string (binary 15));
--sorted_result 
select * from t1;
--sorted_result 
select weight_string(bid) from t3;
--error 1452
insert into t3(bid) values (weight_string (binary 12));
drop table t3;


--echo #视图

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2','19980526')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,4);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'-2',1,1,1);
insert into t1 values(19980526,'19980526',19980526,19980526,1);
--error 1051
drop view v1;
create view v1 as 
select *,weight_string(s3) dd from t1;
--sorted_result 
select * from v1;

--echo #select 
--sorted_result 
select hex(weight_string(dd)),hex(weight_string(s2)) from v1;


--echo #insert
--error 1348
insert into v1 values (1,1,1,1,1,1);

drop view v1;
create view v1 as 
select * from t1;
--sorted_result 
select * from v1;

insert into v1 values (1,1,1,weight_string(s3),1);
--sorted_result 
select * from v1;
--sorted_result 
select * from t1;


set @s = _utf8mb4 '11' collate  utf8mb4_general_ci ;
insert into v1 values (1,1,1,weight_string(@s),1);
--sorted_result 
select * from v1;
--sorted_result 
select * from t1;

--echo #delete
drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2','19980526')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,4);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'-2',1,1,1);
insert into t1 values(19980526,'19980526',19980526,19980526,1);

drop view v1;
create view v1 as
select *,weight_string(s3) dd from t1;
--sorted_result 
select * from v1;
delete from v1 where weight_string(s4)=2; 
--sorted_result 
select * from v1;
--sorted_result 
select * from t1;

--echo #update
drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2','19980526')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,4);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'-2',1,1,1);
insert into t1 values(19980526,'19980526',19980526,19980526,1);

--echo #多列
drop view v1;
create view v1 as
select *,weight_string(s3) dd from t1;
--sorted_result 
select * from v1;
update v1 set s3= weight_string(s4); 
--sorted_result 
select * from v1;
--sorted_result 
select * from t1;

--echo #单列
drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2','19980526')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,4);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'-2',1,1,1);
insert into t1 values(19980526,'19980526',19980526,19980526,1);

drop view v1;
create view v1 as 
select *,weight_string(s3) dd from t1;
--sorted_result 
select * from v1;
update v1 set s4= weight_string(s3) where  weight_string(s4)=1124 ; 
--sorted_result 
select * from v1;
--sorted_result 
select * from t1;


--echo #分区
--echo #range
drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30))default charset=gbk collate=gbk_chinese_ci
  partition by range(s1)(
  partition p1 values less than(2) ,
  partition p2 values less than(10) ,
  partition p3 values less than(maxvalue)
);
insert into t1 values (1,'李华',11,112545);
insert into t1 values (2,'西郊',12,1124);
insert into t1 values(11,'2',2,2);
insert into t1 values(4,'-2',1,1);
insert into t1 values(19980526,'19980526',19980526,19980526);
insert into t1(s3) values(weight_string(binary 11));
--sorted_result 
select * from t1;


--sorted_result 
select weight_string(binary s1) from t1;




--echo  #list

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30))default charset=gbk collate=gbk_chinese_ci
  partition by list(s1)(
  partition p1 values in (1,2),
  partition p2 values in (4,11),
  partition p3 values in (3000)
);
insert into t1 values (1,'李华',11,112545);
insert into t1 values (2,'西郊',12,1124);
insert into t1 values(11,'2',2,2);
insert into t1 values(4,'-2',1,1);

insert into t1(s1,s3) values(weight_string(binary 4),weight_string(binary 4));
--sorted_result 
select * from t1;

--sorted_result 
select weight_string(binary s1) from t1;



--echo  #hash

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30))default charset=gbk collate=gbk_chinese_ci
partition by hash(s1)
partitions 4;
insert into t1 values (1,'李华',11,112545);
insert into t1 values (2,'西郊',12,1124);
insert into t1 values(11,'2',2,2);
insert into t1 values(4,'-2',1,1);

insert into t1(s1,s3) values(weight_string(binary 5),weight_string(binary 4));
--sorted_result 
select s3 from t1;

--sorted_result 
select weight_string(binary s1) from t1;




