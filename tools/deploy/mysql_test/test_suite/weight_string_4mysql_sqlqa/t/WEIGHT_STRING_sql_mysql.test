--echo #exists

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'2',1,1,1);
--sorted_result
select * from t1 where exists (select weight_string(s1),weight_string(s3));
--sorted_result
select * from t1 where exists (select weight_string(s1)  where weight_string(s1) is not null);
--sorted_result
select * from t1 where exists (select weight_string(s1)  where weight_string(s3)=2);
--sorted_result
select * from t1 where exists (select weight_string(s2) from t1 limit 1,1);


--echo #any

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'2',1,1,1);
--sorted_result
select * from t1 where weight_string(s4) >=any(select weight_string(s1) from t1) ;
--sorted_result
select * from t1 where weight_string(s4) >=any(select weight_string(s2) from t1) ;
--sorted_result
select * from t1 where weight_string(s4) >=any(select weight_string(s3) from t1) ;
