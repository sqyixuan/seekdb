(select weight_string(s1) from t1 )union (select weight_string(s2) from t1);
--sorted_result
(select weight_string(s2) from t1 )union (select s3 from t1);
--sorted_result
(select weight_string(s3) from t1 )union (select 13333 from t1);

--sorted_result
(select weight_string(s1) from t1 )union all (select weight_string(s2) from t1);
--sorted_result
(select weight_string(s2) from t1 )union all (select s3 from t1);
--sorted_result
(select weight_string(s3) from t1 )union all (select 13333 from t1);

--echo #insert
