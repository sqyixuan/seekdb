#owner group: 创新研发
#description: obmysql模式, weight_string表达式测试
#tags:dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4



--error 1051
drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 varbinary(10),s4 blob(30),s5 set('1','2')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'李华',12,1124,1);


--echo #运算
--sorted_result 
select weight_string(s1)+weight_string(s1) from t1;

--sorted_result 
select weight_string(s1)+weight_string(s2) from t1;

--sorted_result 
select weight_string(s3)+weight_string(s4) from t1;

--sorted_result 
select weight_string(s3)+s4 from t1;
--sorted_result 
select weight_string(s3)+s1 from t1;
--sorted_result 
select weight_string(s3)+s5 from t1;
--sorted_result 
select weight_string(s3) from t1;
--sorted_result 
select weight_string(s5) from t1;
--sorted_result 
select weight_string(s3)+weight_string(s5) from t1;

--sorted_result 
select weight_string(s1+s3) from t1;
--sorted_result 
select weight_string(s3+s4) from t1;
--sorted_result 
select weight_string(s3+s3/s3-s3) from t1;

--sorted_result 
select weight_string(3+s1) from t1;
--sorted_result 
select weight_string(3+s3) from t1;


insert into t1(s3) values(11),(12),(11),(14);
--echo #distinct
--sorted_result 
select distinct weight_string(s3) from t1;
--sorted_result 
select distinct weight_string(s1) from t1;
--sorted_result 
select distinct hex(weight_string(s3)) from t1;
--sorted_result 
select distinct weight_string(s3) from t1;

--echo #concat
--sorted_result 
select concat(weight_string(s3),weight_string(s4)) from t1;
--sorted_result 
select concat(weight_string(s1),weight_string(s2)) from t1;
--sorted_result 
select concat(weight_string(s2),weight_string(s3)) from t1;
--echo #select 
--error 1051
drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2'))
default charset=gbk collate=gbk_chinese_ci;
insert into t2 values (1,'李华',11,112545,3);
insert into t2 values (2,'西郊',12,1124,1);
insert into t2 values(11,'2',2,2,2);
insert into t2 values(4,'2',1,1,1);
insert into t2 values(4,'5',1,1,3);

--sorted_result 
select hex(weight_string(s1 as char(5))) from t2;
--sorted_result 
select hex(weight_string(s2 as char(5))) from t2;
--sorted_result 
select hex(weight_string(s3 as char(5))) from t2;
--sorted_result 
select hex(weight_string(s4 as char(5))) from t2;
--sorted_result 
select hex(weight_string(s5 as char(5))) from t2;
--echo #44823852 int类型在weight_string(s1 as binary(5))后mysql显示结果，ob为null
--sorted_result 
select hex(weight_string(s1 as binary(5))) from t2;
--sorted_result 
select hex(weight_string(s2 as binary(5))) from t2;
--sorted_result 
select hex(weight_string(s3 as binary(5))) from t2;
--sorted_result 
select hex(weight_string(s4 as binary(5))) from t2;
--sorted_result 
select hex(weight_string(s5 as binary(5))) from t2;


