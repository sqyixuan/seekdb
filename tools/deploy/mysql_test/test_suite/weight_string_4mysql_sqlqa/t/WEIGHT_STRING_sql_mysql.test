--echo #case when


drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'2',1,1,1);
insert into t1 values (1,'李华',11,112545,3);

--sorted_result 
select case when s3=11 then weight_string(s5) else 0 end from t1 order by s1;
--sorted_result 
select case when weight_string(s3)=1 then 9.99 else weight_string(s3) end from t1 order by s1;
--sorted_result 
select case when weight_string(s3)=concat(weight_string(s3),weight_string(s3)) then 0.75 else weight_string(s3) end from t1 order by s1;
--sorted_result 
select (case weight_string(s3) when 11 then 0.29 when 1 then 9 else 0 end) from t1;
--sorted_result 
select (case s4 when weight_string(s3) then 0.02 when 1 then 'a' else 0 end) from t1;
--sorted_result 
select (case weight_string(s3) when 11 then 0.29 when 1 then 9 else 0 end) from t1 group by (case weight_string(s3) when 11 then 0.29 when 1 then 9 else 0 end) order by s1;         


--echo #join

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'2',1,1,1);
insert into t1 values (1,'李华',11,112545,3);

drop table t2;
create table t2 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) 
default charset=gb18030 collate=gb18030_chinese_ci;
insert into t2 values (3,'李华',11,112545,3);
insert into t2 values (2,'外链',12,1136,2);
insert into t2 values(11,'2',2,2,2);
insert into t2 values(4,'2',1,1,1);
--disable_warnings
--sorted_result 
select weight_string(t1.s1),weight_string(t1.s2),weight_string(t1.s3)+weight_string(t2.s3),weight_string(t1.s5)
 from t1 join t2 on t1.s1=t2.s1 where weight_string(t1.s2)=2;

--sorted_result 
select weight_string(t1.s1),weight_string(t1.s2),weight_string(t1.s3)+weight_string(t2.s3),weight_string(t1.s5)
 from t1 left join t2 on t1.s1=t2.s1;

--sorted_result 
select weight_string(t1.s1),weight_string(t1.s2),weight_string(t1.s3)+weight_string(t2.s3),weight_string(t1.s5)
 from t1 right join t2 on t1.s1=t2.s1;

--sorted_result 

select weight_string(t1.s1),weight_string(t1.s2),weight_string(t1.s3)+weight_string(t2.s3),weight_string(t1.s5)
 from t1 cross join t2 on t1.s1=t2.s1;
--enable_warnings

--echo #嵌套

drop table t1;
create table t1 (s1 int,s2 char(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'2',2,2,2);
insert into t1 values(4,'2',1,1,1);
--sorted_result
select * from t1 where s1 in(select weight_string(s2)from t1 );
--sorted_result
select * from t1 where s1 in(select weight_string(s3)from t1 );
--sorted_result
select * from t1 where s2 in(select weight_string(s3)from t1 );
--sorted_result
select * from (select weight_string(s1)from t1 )bb;
--sorted_result
select * from (select weight_string(s2)from t1 )bb;
--sorted_result
select * from (select weight_string(s3)from t1 )bb;
--sorted_result
select * from (select weight_string(s4)from t1 )bb;
--sorted_result
select * from (select weight_string(s5)from t1 )bb;
--sorted_result
with a as (select weight_string(s2) b from t1) select weight_string(b) from a;

--echo #union
drop table t1;
