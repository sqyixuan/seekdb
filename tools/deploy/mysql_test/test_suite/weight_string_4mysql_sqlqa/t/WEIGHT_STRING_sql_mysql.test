--echo #where子句

drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
--sorted_result 
select * from t1 where weight_string(s3)=11;
--sorted_result 
select * from t1 where weight_string(s1)=1;
--sorted_result 
select * from t1 where weight_string(s2)='李华';
--sorted_result 
select * from t1 where weight_string(s5)=1;
--sorted_result 
select * from t1 where weight_string(s5)=0;
--sorted_result 
select * from t1 where weight_string(s3)!=11;
--sorted_result 
select * from t1 where weight_string(s3)>=11;
--sorted_result 
select * from t1 where weight_string(s3)<=11;
--sorted_result 
select * from t1 where weight_string(s3)>11;
--sorted_result 
select * from t1 where weight_string(s3)<11;



drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 binary(10),s4 blob(30),s5 set('1','2')) 
default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1(s1) values (0);
insert into t1(s3) values (1);
--sorted_result 
select * from t1;
--sorted_result 
select * from t1 where s1=weight_string(s5);
--sorted_result 
select * from t1 where s1=weight_string(s3);



--echo #between and
drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1(s1) values(50);
--sorted_result 
select * from t1 where weight_string(s3) between 1 and 11;
--sorted_result 
select * from t1 where weight_string(s1) between 1 and 5;
--sorted_result 
select * from t1 where weight_string(s4) between 1124 and 1124;
--sorted_result 
select * from t1 where s1 between weight_string(s3) and weight_string(s4);
--sorted_result 
select * from t1 where 112 between weight_string(s3) and weight_string(s4);

--echo #in
drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'',2,2,2);
--sorted_result 
select * from t1 where weight_string(s3) in (11);
--sorted_result 
select * from t1 where weight_string(s1) in (1);
--sorted_result 
select weight_string(s3) from t1;
--sorted_result 
select * from t1 where s1 in (weight_string(s3));
--sorted_result 
select * from t1 where s1 in (weight_string(s1),2,3);
--sorted_result 
select * from t1 where s1 in (weight_string(s3),2,3);

--sorted_result 
select * from t1 where s4 in (weight_string(s3));
--sorted_result 
select * from t1 where s4 in (weight_string(s1),2,3);
--sorted_result 
select * from t1 where s4 in (weight_string(s3),2,3);

--sorted_result 
select * from t1 where s1 not in (weight_string(s3));
--sorted_result 
select * from t1 where s1 not in (weight_string(s1),2,3);
--sorted_result 
select * from t1 where s1 not in  (weight_string(s3),2,3);

--sorted_result 
select * from t1 where s4 not in (weight_string(s3));
--sorted_result 
select * from t1 where s4 not in (weight_string(s1),2,3);
--sorted_result 
select * from t1 where s4 not in  (weight_string(s3),2,3);

--echo #and
drop table t1;
create table t1 (s1 int,s2 varchar(20),s3 binary(10),s4 blob(30),s5 set('1','2')) default charset=gbk collate=gbk_chinese_ci;
insert into t1 values (1,'李华',11,112545,3);
insert into t1 values (2,'西郊',12,1124,1);
insert into t1 values(11,'',2,2,2);
--sorted_result 
