create function n_1() returns char(20) 
begin
  declare a char(20);
  set a=weight_string(@dd);
  select weight_string(s1) into @a from t2 limit 1;
  select weight_string(s2) into @b from t2 limit 1;
  select weight_string(s3) into @c from t2 limit 1;
  select weight_string(s4) into @d from t2 limit 1;
  select weight_string(s5) into @s from t2 limit 1;
  return concat(weight_string(binary 1 level 1 ),a);
end/
