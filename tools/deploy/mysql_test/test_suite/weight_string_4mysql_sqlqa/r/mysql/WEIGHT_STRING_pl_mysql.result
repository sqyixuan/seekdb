create procedure processorders()
begin
declare aa int;
declare rc int;
declare i int default 1;
declare cur cursor for select weight_string(s4) from t2 ;
select count(*)  into rc from t2;
open cur;
 while i < rc do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;

end/
