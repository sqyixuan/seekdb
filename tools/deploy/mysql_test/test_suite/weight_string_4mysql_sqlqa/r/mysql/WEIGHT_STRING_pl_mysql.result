#repeat
drop table t2;
create table t2(s1 binary,s2 int,s3 int);
drop function n_1;
create function n_1() returns int
begin
declare i binary default 0;
 repeat
 insert into t2 values(weight_string(i),0,i);
   set i = weight_string(i) +1;
until weight_string(i) >= 3
  end repeat;
  return weight_string(i);
end/
