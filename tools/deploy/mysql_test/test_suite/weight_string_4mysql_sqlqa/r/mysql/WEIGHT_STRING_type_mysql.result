set names 'utf8mb4';
drop table typy_set;
create table typy_set 
(tt tinyint, st smallint,mt mediumint,it integer,bt bigint,ft float,dle double,dl decimal(10,7),bi bit(5),
yr year,te time,de date,dae datetime,tp timestamp,
cr char(30),vr varchar(30),tet tinytext,txt text,mxt mediumtext,lxt  longtext,
em enum('жҳҘ','11'),se set('1','2','3'),bry binary,bb blob)default charset=gbk collate=gbk_chinese_ci;
