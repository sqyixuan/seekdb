#json
select weight_string( (SELECT JSON_ARRAY(1,'ture'))),hex(weight_string( (SELECT JSON_ARRAY(1,'ture'))));
+-----------------------------------------------+--------------------------------------------------------------------+
| weight_string( (SELECT JSON_ARRAY(1,'ture'))) | hex(weight_string( (SELECT JSON_ARRAY(1,'ture'))))                 |
+-----------------------------------------------+--------------------------------------------------------------------+
|   [  1  ,     "  t  u  r  e  "  ]             | 00005B00003100002C00002000002200007400007500007200006500002200005D |
+-----------------------------------------------+--------------------------------------------------------------------+
select weight_string( JSON_QUOTE('[1, 2, 3]'));
+-----------------------------------------+
| weight_string( JSON_QUOTE('[1, 2, 3]')) |
+-----------------------------------------+
|   "  [  1  ,     2  ,     3  ]  "       |
+-----------------------------------------+
