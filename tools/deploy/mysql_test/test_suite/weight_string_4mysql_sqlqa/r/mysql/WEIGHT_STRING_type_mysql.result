set names 'utf8mb4';
select weight_string('ab');
+---------------------+
| weight_string('ab') |
+---------------------+
|  A B                |
+---------------------+
select weight_string('%');
+--------------------+
| weight_string('%') |
+--------------------+
|  %                 |
+--------------------+
select weight_string('!');
+--------------------+
| weight_string('!') |
+--------------------+
|  !                 |
+--------------------+
select weight_string('пҝҘ');
+----------------------+
| weight_string('пҝҘ')  |
+----------------------+
| яе                     |
+----------------------+
select weight_string('$');
+--------------------+
| weight_string('$') |
+--------------------+
|  $                 |
+--------------------+
select weight_string('^');
+--------------------+
| weight_string('^') |
+--------------------+
|  ^                 |
+--------------------+
select weight_string('*');
+--------------------+
| weight_string('*') |
+--------------------+
|  *                 |
+--------------------+
select weight_string('дёӯ');
+----------------------+
| weight_string('дёӯ')  |
+----------------------+
| N-                   |
+----------------------+
