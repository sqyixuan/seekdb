result_format: 4
SET NAMES utf8mb4;
create external table ex_t1 (
id CHAR(10)  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir VARCHAR(50) as (metadata$filecol6)
)
location='#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';
select * from ex_t1;
+------+------+----------+------+-------------+---------------+
| id   | name | mon      | age  | tel_number  | bir           |
+------+------+----------+------+-------------+---------------+
| NULL | NULL | NULL     | NULL | NULL        | NULL          |
| 1    | wxm  | 3500.00  | 25   | 13000000000 | 1990.01.01    |
| 2    | ldp  | 3000.01  | 30   | 13000000001 | 1991.02.02    |
| 3    | zhx  | 6000.05  | 28   | 13000000002 | 1992.03.03    |
| NULL | NULL | NULL     | NULL | NULL        | NULL          |
| 4    | zff  | 4500.123 | 35   | 13000000003 | 1993.04.04    |
| 5    | dyl  | -4000    | 40   | 13000000004 | 1994.05.05 11 |
+------+------+----------+------+-------------+---------------+
drop table T1;
CREATE TABLE T1 AS SELECT * FROM EX_T1;
