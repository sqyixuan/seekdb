DROP FUNCTION IF EXISTS EX_FUN;
CREATE FUNCTION EX_FUN() RETURNS VARCHAR(10)
BEGIN
  DECLARE A VARCHAR(10);
  SELECT  NAME INTO A FROM EX_T1 WHERE ID = 1;
  RETURN A;
END
