| id   | name | mon      | age  | tel_number  | bir        |
+------+------+----------+------+-------------+------------+
| NULL | NULL | NULL     | NULL | NULL        | NULL       |
|    1 | wxm  | 3500.00  | 25   | 13000000000 | 1990-01-01 |
|    2 | ldp  | 3000.01  | 30   | 13000000001 | 1991-02-02 |
|    3 | zhx  | 6000.05  | 28   | 13000000002 | 1992-03-03 |
| NULL | NULL | NULL     | NULL | NULL        | NULL       |
|    4 | zff  | 4500.123 | 35   | 13000000003 | 1993-04-04 |
|    5 | dyl  | -4000    | 40   | 13000000004 | 1994-05-05 |
+------+------+----------+------+-------------+------------+
DROP PROCEDURE IF EXISTS EX_PRO;
CREATE PROCEDURE EX_PRO(IN TABLE_NAME VARCHAR(50))
BEGIN
  SET @SQL = CONCAT('SELECT * FROM ',TABLE_NAME);
  PREPARE stmt FROM @sql;
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;
END
//
CALL EX_PRO('EX_T1');
