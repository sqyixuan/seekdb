##PREPARE##
DROP TABLE IF EXISTS EX_T1;
PREPARE STMT1 FROM 'create external table EX_T1 (
id NUMBER  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir date as (metadata$filecol6)
)
location=\'#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/\'
format (
    type = \'csv\'
	FIELD_DELIMITER = \',\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = \'UTF8MB4\'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = \'test05.csv\'';
EXECUTE STMT1 ;
DEALLOCATE PREPARE STMT1;
PREPARE STMT2 FROM 'SELECT * FROM EX_T1 WHERE ID = ?';
SET @A = 2;
EXECUTE STMT2 USING @A ;
