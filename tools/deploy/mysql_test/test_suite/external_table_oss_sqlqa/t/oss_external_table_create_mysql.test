##FIELD_DELIMITER列分割##
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t5 (
FIELD_NAME VARCHAR(100),
FUN_NAME varchar(100),
PRO_NAME VARCHAR (100),
PAC_NAME VARCHAR (100),
PAC_NOBO_NAME VARCHAR (100),
TYP_NAME VARCHAR(100)
)
location= 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	ignore_last_empty_column=false
)
pattern = '.*\.dat'
;
select * from ex_t5 limit 10;

