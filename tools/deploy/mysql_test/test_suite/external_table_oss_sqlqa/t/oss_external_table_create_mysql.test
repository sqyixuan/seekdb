# tags: external_table
# description: test create external table oss

--result_format 4
--source mysql_test/include/oss_config_for_import.inc

connection default;
SET NAMES utf8mb4;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--error 0,1051
drop table ex_t5;
--error 0,1051
drop table ex_t6;
--error 0,1051
drop table ex_t7;
--error 0,1051
drop table ex_t8;
--error 0,1051
drop table ex_t9;
--error 0,1051
drop table ex_t10;
--error 0,1051
drop table ex_t11;

--enable_query_log

##location##
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t1 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50)
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'test.csv'
;

select * from ex_t1;

##可以查看外表的信息

#select * from  oceanbase.__all_external_table_file;


##指定不存在的location##
#空表#
create external table ex_t2 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number CHAR (20)
)
location='/external_table_sqlqa/data1'
format (
    type = 'csv'
)
;

select * from ex_t2;

