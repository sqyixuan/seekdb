##嵌套表达式##
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
id NUMBER  as (metadata\$filecol1),
name VARCHAR(50) as (concat(metadata\$filecol2,metadata\$filecol1)),
mon FLOAT as (metadata\$filecol3),
age DOUBLE as (metadata\$filecol4),
tel_number VARCHAR(50) as (metadata\$filecol5),
bir DATE as (metadata\$filecol6)
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select * from ex_t11;

drop table ex_t11;

#trim#
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
id VARCHAR(10)  as (trim(metadata\$filecol1)),
name VARCHAR(20) as (concat(metadata\$filecol2,metadata\$filecol1)),
mon VARCHAR(20) as (metadata\$filecol3),
age VARCHAR(20) as (metadata\$filecol4),
tel_number VARCHAR(20) as (metadata\$filecol5)
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
