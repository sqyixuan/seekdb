#其他表达式#
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
FIELD_NAME VARCHAR(100) AS (UPPER(METADATA\$FILECOL1)),
FUN_NAME varchar(100) AS (LOWER(METADATA\$FILECOL2)),
PRO_NAME VARCHAR (100) AS (LOWER(METADATA\$FILECOL3)),
PAC_NAME VARCHAR (100) AS (SUBSTR(METADATA\$FILECOL4,0,3)),
PAC_NOBO_NAME VARCHAR (100) AS (LENGTH(METADATA\$FILECOL5)),
TYP_NAME VARCHAR(100) AS (REPLACE(METADATA\$FILECOL6,METADATA\$FILECOL6,'TYPE'))
)
location= 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	ignore_last_empty_column=false
)
pattern = '.*\.dat'
;

select * from ex_t11 limit 10;

drop table ex_t11;

#其他表达式#
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
id NUMBER  as (metadata\$filecol1+0),
name varchar(50) as (cast(metadata\$filecol2 as char(10))),
mon VARCHAR(50) as (round(metadata\$filecol3,1)),
age VARCHAR(50) as (metadata\$filecol2||metadata\$filecol4),
tel_number VARCHAR(50) as (cast(metadata\$filecol5 as DECIMAL(15))),
bir date as (cast(metadata\$filecol6 as date))
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select ID,NAME,MON,AGE,BIR from ex_t11;

drop table ex_t11;

#条件表达式#
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
mon VARCHAR(50) as (case when metadata\$filecol3 > 4000 then 'Y' else 'N' end)
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
)
PATTERN = 'test05.csv';

select * from ex_t11;

drop table ex_t11;

##外表处理空字符串与表处理空串的逻辑不一致##
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t11 (
mon VARCHAR(50) as (nvl(metadata\$filecol3,'kong')))
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select * from ex_t11;

drop table ex_t11;








