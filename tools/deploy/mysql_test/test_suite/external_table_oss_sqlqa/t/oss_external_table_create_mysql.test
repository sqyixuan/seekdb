drop table ex_t10;

##双引号无法查询，用test建外表##
--source mysql_test/test_suite/external_table_oss_sqlqa/include/replace_oss_info.inc

eval create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)

	ENCODING = 'UTF8MB4'
	NULL_IF = ('工号','姓名','工资','年龄','手机号','')
)
PATTERN = 'test.csv';

select * from ex_t10;

