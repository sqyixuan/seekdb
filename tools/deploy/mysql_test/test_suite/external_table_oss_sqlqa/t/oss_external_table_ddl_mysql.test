##直接update##
--error 3105
UPDATE EX_T1 SET ID = 6 WHERE EX_T1.BIR IS NULL;

##子查询UPDATE##
--error 3105
UPDATE EX_T1 SET ID = 6 WHERE NAME IN (SELECT NAME FROM EX_T1 WHERE ID IS NULL);
--error 3105
UPDATE T1,EX_T1 SET T1.ID = 100, EX_T1.ID = 200 WHERE T1.NAME = EX_T1.NAME;

UPDATE T1 SET ID = 6 WHERE NAME IN (SELECT NAME FROM EX_T1 WHERE ID IS NULL);


##直接delete##
--error 1235
DELETE FROM EX_T1;

##子查询delete##
--error 1235
DELETE FROM EX_T1 WHERE ID IN (SELECT ID FROM T1 WHERE NAME IS NULL);

DELETE FROM T1 WHERE ID IN (SELECT ID FROM EX_T1 WHERE NAME IS NOT NULL);

