# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test external table ddl oss

--result_format 4
--source mysql_test/include/oss_config_for_import.inc

#connection default;
--disable_query_log
--disable_warnings

DROP TABLE IF EXISTS EX_T1;

DROP TABLE IF EXISTS T1;

DROP VIEW IF EXISTS EX_V1;
--enable_query_log
--enable_warnings

SET NAMES utf8mb4;

##根据外表来创建table，view##
--source mysql_test/include/external_table/replace_oss_config_info.inc

eval create external table ex_t1 (
id NUMBER  as (metadata\$filecol1),
name VARCHAR(50) as (metadata\$filecol2),
mon FLOAT as (metadata\$filecol3),
age VARCHAR(50) as (metadata\$filecol4),
tel_number VARCHAR(50) as (metadata\$filecol5),
bir DATE as (metadata\$filecol6))
location='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
format (
    type = 'csv'
	ENCODING = 'UTF8MB4'
	FIELD_DELIMITER = ','
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test06.csv';
##RENAME##
RENAME TABLE EX_t1 TO EX_T2;
RENAME TABLE EX_t2 TO EX_T1;

select ID,NAME,MON,AGE,TEL_NUMBER from ex_t1;

CREATE TABLE T1 AS SELECT ID,NAME,MON FROM EX_T1;
SELECT * FROM T1;

CREATE VIEW EX_V1 AS SELECT ID,NAME,TEL_NUMBER FROM EX_T1;
SELECT * FROM EX_V1;

##对table进行dml，预期不影响外表##
#insert#
INSERT INTO T1 VALUES (6,'TEST',6666);
SELECT * FROM T1;
#UPDATE#
UPDATE T1 SET MON = 0 WHERE ID = 6;
SELECT * FROM T1;
#DELETE#
DELETE FROM T1 ;
SELECT * FROM T1;
#MERGE#
#修改版本后不支持了，要问一下#
##已修复##
