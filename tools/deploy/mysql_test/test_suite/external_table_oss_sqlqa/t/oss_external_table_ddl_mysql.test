#SELECT * FROM T1;

##对view进行dml，预期无法进行##
--error 3105
INSERT INTO EX_V1 VALUES (6,'TEST',133);
--error 3105
update EX_V1 set tel_number = 133 where id = 1;
--error 1235
DELETE FROM EX_V1;
