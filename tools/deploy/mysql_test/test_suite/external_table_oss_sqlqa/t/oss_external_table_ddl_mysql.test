DROP TABLE IF EXISTS T1;
DROP VIEW IF EXISTS EX_V1;
drop table IF EXISTS ex_t1;




##外表分区##
##本期不支持##
#以外表为基础创建分区表#
--source mysql_test/include/external_table/replace_oss_config_info.inc

eval CREATE EXTERNAL TABLE EX_T1(
ID CHAR(10) AS (METADATA\$FILECOL1),
NAME VARCHAR(10) AS (METADATA\$FILECOL2),
MON CHAR(10) AS (METADATA\$FILECOL3),
AGE CHAR(10) AS (METADATA\$FILECOL4),
PHONE VARCHAR(15) AS (METADATA\$FILECOL5)
)
LOCATION='oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@$OSS_HOST/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/basic_data/'
FORMAT (
	TYPE = 'CSV'
	ENCODING = 'UTF8MB4'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	SKIP_HEADER = 1
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test0[3-5].csv';

CREATE TABLE P_T1 PARTITION BY KEY(ID) PARTITIONS 3 AS SELECT * FROM EX_T1;


SELECT * FROM P_T1 PARTITION(P0);
SELECT * FROM P_T1 PARTITION(P1);
SELECT * FROM P_T1 PARTITION(P2);

DROP TABLE EX_T1;
DROP TABLE P_T1;

