DROP PROCEDURE pro3;
CREATE PROCEDURE pro3(in a varchar(20))
begin
declare i int;
set i=20220910;
while i <=20220914  DO
if i > a then
select day(i);
end if;
insert into t1 values(i,day(i));
set i = i + 1;
end WHILE;
end;
//
CALL pro3(20220920);
DROP PROCEDURE pro3;
drop table t1;
create table t1(c1 int,c2 varchar(30));
DROP PROCEDURE pro4;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=20220910;
while i <=20220914  DO
if a =20220920 then
select day(a);
end if;
insert into t1 values(a ,day(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
CALL pro4(20220920);
day(a)
day(a)
day(a)
day(a)
day(a)
