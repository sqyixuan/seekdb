end //
update t2 set a2=day('2022-09-15') where a1=1;
##delete型触发器
drop table t1;
drop table t2;
drop trigger t1_trigger;
create table t1 (c1 int ,c2 varchar(20),c3 date);
insert into t1 values(1,'test01','20220907');
insert into t1 values(2,'test02','20220909');
insert into t1 values(3,'test03','2022-08-20');
insert into t1 values(4,'test04','2022-09-15');
insert into t1 values(5,'test05','2022-09-16');
select * from t1;
c1	c2	c3
1	test01	2022-09-07
2	test02	2022-09-09
3	test03	2022-08-20
4	test04	2022-09-15
5	test05	2022-09-16
create table t2 (a1 int ,a2 varchar(20));
insert into t2 values(1,'test08');
insert into t2 values(2,'test09');
select * from t2;
a1	a2
1	test08
2	test09
create trigger t1_trigger after delete on  t2
for each row
begin 
update t1 set c2=day('2022-09-16') where c3="2022-09-16";
end //
delete from t2 where a1=2;
drop table t1;
drop table t2;
drop trigger t1_trigger;
##约束
drop table t1;
create table t1(c1 varchar(20) primary key,c2 varchar(20) default '10');
drop table t2;
create table t2(a1 varchar(20) unique key ,a2 varchar(20),a3 varchar(20),CONSTRAINT for_key FOREIGN KEY (a3) REFERENCES  t1 (c1));
drop table t3;
create table t3(b1 varchar(20) not null ,b2 varchar(20));
insert into t1 values(day('2022-09-14'),day('2022-09-15'));
insert into t1(c1) values(day('2022-09-16'));
update t1 set c1=day('2022-09-17'),c2=day('2022-09-18') where c2='10';
select * from t1;
c1	c2
14	15
17	18
insert into t2 values(day('2022-09-14'),'test',day('2022-09-15'));
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
insert into t2 values('test',day('2022-09-18'),day('2022-09-17'));
select * from t2;
a1	a2	a3
test	18	17
update t2 set a1=day('2022-09-18') where a3=day('2022-09-17');
update t2 set a3=day('2022-09-19');
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
insert into t3 values(day('2022-09-18'),day('2022-09-16'));
select * from t3;
b1	b2
18	16
##索引
CREATE INDEX indexName ON t1 (c1);
insert into t1 values(day('2022-09-18'),day('2022-09-19'));
update t1 set c2=('2022-09-20')  where c2=day('2022-09-19');
select * from t1 ;
c1	c2
14	15
17	18
18	2022-09-20
