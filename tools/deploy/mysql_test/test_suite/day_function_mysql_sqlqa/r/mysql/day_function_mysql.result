## TIME,date,DATETIME,TIMESTAMP,YEAR
CREATE TABLE t1(c1 TIME ,
c2 date ,
c3 DATETIME ,
c4 TIMESTAMP DEFAULT '2000-01-01 00:00:00',
c5 YEAR ) ;
