drop trigger t1_trigger;
create table t1 (c1 int ,c2 varchar(20),c3 date);
insert into t1 values(1,'test01','20220907');
insert into t1 values(2,'test02','20220909');
insert into t1 values(3,'test03','2022-08-20');
insert into t1 values(4,'test04','2022-09-15');
