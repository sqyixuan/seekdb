--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##参数验证

--error 1064
select day();
select day(" ");
select day("null");
select day(0);
select day(1);
select day("0000-00-00");
select day('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;
select day('0000-02-29');

--error 1064
select day(current_time(),current_timestamp());
#select day(current_timestamp());

select day('monday'), day('Tuesday'), day('Wednesday'),day('Sunday'),day('Thursday'),day('Friday'),day('Saturday');
select day('0.01.01');
select day('9999.12.31');
select day(+"2022-09-05");
select day(-"2022-09-05");
select day('a');
select day('@@@');
select day('#');
select day('""');
select day('_');
select day('false');
select day('true');
select day('2022-09-05')+4;
select day('2022-09-05')+false;
select day('2022-09-05')+true;
select day('星期一');
select day('星期一1999-12-31');
select day('星期一@#');
select day('1999-12-31星期一');
select day(1.175494351E-38) From dual;
select day('-1970-12-31');
select day('にににににににに');
select day('천구백구십칠년 일월 오일');
select day('一九九九零二二六');
select day('壹玖玖捌零伍贰贰');
select day('2022-09-07')<'monday';
select day('2022-09-07')>'monday';
select day('2022-09-07') != 'Wednesday';
select day('2022-09-07') >= 'Wednesday';
select day('2022-09-07') <= 'Wednesday';
select day('2022-09-07') = 'Wednesday';
select day(date '2022-09-15');
--error 1525
select day(date '0000-00-00');
select day(date '9999-12-31');
#select day(time '17:01:00');

--echo OB会显示系统时间,MySQL5.7直接报错;
#select day(time '17:01:-1');

--error 1525
select day(time '17:01:60');
#select day(time '00:00:00');
#select day(time '23:59:59');
#select day(time '23:59:59');

select day('2022-09-15 23:59:59');
select day('2022-09-15 00:00:00');
select day('2022-09-15 00:59:59');



--echo ##ob和MySQL5.7结果不一致;
select day('1999-12-31星期1999-12-30');

select day('1995.02.28')+2000000000000000;
select day('9999-12-31 23:59:59.999999')+0;
select day('9999-12-31 23:59:59.999999')-0;
select day('9999-12-31 23:59:59.999999')*1;
select day('9999-12-31 23:59:59.999999')/1;

--echo 表字符集测试

