create table t4(a varchar2(20));
insert all when ename > 70 then into t3(a) values(ename) else into t4(a) values(ename) select ascii(ename)ename from t1 where sal > 1500;
insert all when ascii(job) > 70 then into t3(a) values(ename) else into t4(a) values(ename) select ascii(ename)ename,job from t1 where sal > 1500;
insert all when ascii(job) > 70 then into t3(a,b) values(ename,ascii(job)) else into t4(a) values(ename) select ascii(ename)ename,job from t1 where sal > 1500;
