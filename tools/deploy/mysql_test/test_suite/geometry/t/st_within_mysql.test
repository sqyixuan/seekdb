  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_line_horizontal, 4326),ST_GEOMFROMTEXT('POLYGON((11 15,19 15,19 10,11 15))', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_line_horizontal, 4326),ST_GEOMFROMTEXT(@star_elem_horizontal, 4326));
  
