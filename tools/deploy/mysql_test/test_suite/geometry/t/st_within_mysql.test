  --echo #====================================================================================
  --echo # point,point
  --echo #====================================================================================
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_center, 4326),ST_GEOMFROMTEXT(@star_center, 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_top, 4326),ST_GEOMFROMTEXT(@star_center, 4326));
  
  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_center, 4326)) FROM gis_geometrycollection WHERE fid=105;
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(0 0)', 4326),ST_GEOMFROMTEXT('POINT(0 0)', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(0 0)', 4326),ST_GEOMFROMTEXT('POINT(10 0)', 4326));
  
  --echo #====================================================================================
  --echo # point,multipoint
  --echo #====================================================================================
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_bottom_left, 4326),ST_GEOMFROMTEXT(@star_bottom_points, 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_top, 4326),ST_GEOMFROMTEXT(@star_bottom_points, 4326));
  
