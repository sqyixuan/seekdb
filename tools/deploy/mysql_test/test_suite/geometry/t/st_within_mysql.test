  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(0 0)', 4326),ST_GEOMFROMTEXT('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)))', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(20 20)', 4326),ST_GEOMFROMTEXT('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)),((10 10,10 20,20 20,20 10,10 10)))', 4326));
  
