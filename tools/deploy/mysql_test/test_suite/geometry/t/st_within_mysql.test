  SELECT ST_WITHIN(ST_GEOMFROMTEXT('MULTIPOINT(0 0,0 30,30 25)', 4326),ST_GEOMFROMTEXT(@star_of_elems, 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_all_points, 4326),ST_GEOMFROMTEXT(@star_of_elems, 4326));
  
