  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_line_horizontal, 4326),ST_GEOMFROMTEXT(@star_lines_near_horizontal, 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_line_horizontal, 4326),ST_GEOMFROMTEXT(@star_lines_near_vertical, 4326));
  
  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_lines_near_horizontal, 4326)) FROM gis_geometrycollection WHERE fid=110;
  
