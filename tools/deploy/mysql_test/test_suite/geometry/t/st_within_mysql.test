  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(20 0)', 4326),ST_GEOMFROMTEXT('MULTIPOINT(0 0,5 0,10 0)', 4326));
  
  --echo #====================================================================================
  --echo # point,linestring
  --echo #====================================================================================
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_top, 4326),ST_GEOMFROMTEXT(@star_top_to_center, 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_top, 4326),ST_GEOMFROMTEXT(@star_line_horizontal, 4326));
  
