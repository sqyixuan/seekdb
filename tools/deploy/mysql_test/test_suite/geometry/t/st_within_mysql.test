  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(5 0)', 4326),ST_GEOMFROMTEXT('POLYGON((0 0,10 0,10 10,0 10,0 0))', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(5 5)', 4326),ST_GEOMFROMTEXT('POLYGON((0 0,10 0,10 10,0 10,0 0))', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(5 5)', 4326),ST_GEOMFROMTEXT('POLYGON((0 0,10 0,10 10,0 10,0 0),(4 4,4 6,6 6,6 4,4 4))', 4326));
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT('POINT(20 20)', 4326),ST_GEOMFROMTEXT('POLYGON((0 0,10 0,10 10,0 10,0 0))', 4326));
  
  --echo #====================================================================================
