  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_of_elems, 4326)) FROM gis_geometrycollection WHERE fid=209;
  
  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_of_elems, 4326)) FROM gis_geometrycollection WHERE fid=309;
  
  --echo #====================================================================================
