  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_collection_elems, 4326)) FROM gis_geometrycollection WHERE fid=209;
  
  SELECT ST_WITHIN(g,ST_GEOMFROMTEXT(@star_collection_elems, 4326)) FROM gis_geometrycollection WHERE fid=309;
  
  SELECT ST_WITHIN(ST_GEOMFROMTEXT(@star_all_points, 4326),ST_GEOMFROMTEXT(@star_collection_multilinestr, 4326));
  
  --echo #====================================================================================
  --echo # linestring,point
