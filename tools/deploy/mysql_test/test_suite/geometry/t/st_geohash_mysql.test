#owner: xuqijia.xqj
#owner group: shenzhen
#description: test for geometry _ST_GeoHash(geometry geom [, int precision])

--source mysql_test/test_suite/geometry/t/import_default_srs_data_mysql.inc
--echo #####################################################################################
--echo # _ST_GeoHash(geometry geom [, int precision])
--echo #####################################################################################
--echo
--echo #====================================================================================
--echo # param input
--echo #====================================================================================
--error 1582
SELECT _ST_GeoHash();
SELECT _ST_GeoHash(NULL);
SELECT _ST_GeoHash(NULL, 20);
SELECT _ST_GeoHash('');
SELECT _ST_GeoHash('', 20);
SELECT _ST_GeoHash(Point(-126.002,48.348), 0);
SELECT _ST_GeoHash(Point(-126.002,48.348), 5);
SELECT _ST_GeoHash(Point(-126.002,48.348), 24);
SELECT _ST_GeoHash(Point(-126.002,48.348), -2);
SELECT _ST_GeoHash(x'000000000101000000E3A59BC420805FC0068195438B2C4840');
--error 1366
SELECT _ST_GeoHash(Point(-126.002,48.348), 'a12');
SELECT _ST_GeoHash(Point(-126.002,48.348), '12');
SELECT _ST_GeoHash(Point(-126.002,48.348), '0');
SELECT _ST_GeoHash(Point(-126.002,48.348), '-10');

--echo #====================================================================================
--echo # point
--echo #====================================================================================
SELECT _ST_GeoHash(Point(-126.002,48.348)) as RESULT;
SELECT _ST_GeoHash(Point(126.002,-48.348)) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-126.002 48.348)')) as RESULT;
--error 1690
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-200.002 48.348)')) as RESULT;
--error 1690
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(200.002 48.348)')) as RESULT;
--error 1690
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-126.002 148.348)')) as RESULT;
--error 1690
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-126.002 -148.348)')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-126.002 48.348 10)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('point(-126.002 48.348 -200)')) as RESULT;

--echo #====================================================================================
--echo # linestring
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.003 48.348)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.0021 48.348)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.0021 48.348)'), 20) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.002 48.4)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.002 48.3481)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, -126.002 48.4)'), 20) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, 126.002 -48.3481)')) as RESULT;
--error 1690
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348, 200.002 -48.3481)')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('linestring(-126.002 48.348 -200, -126.003 48.348 10)')) as RESULT;

--echo #====================================================================================
--echo # polygon
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('POLYGON((120.25 20.0,120.0 20.15,120.30 20.15,120.22 20.10,120.25 20.0))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('POLYGON((80.5 5.0,80.15 5.25,80.25 5.0,80.15 5.5,80.5 5.0))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('POLYGON((6.65 10.80,6.67 10.810,6.60 10.815,6.610 10.815,6.615 10.825,6.620 10.815,6.630 10.815,6.622 10.810,6.625 10.80,6.615 10.85,6.65 10.80))')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('POLYGON((80.5 5.0 20,80.15 5.25 30,80.25 5.0 -5,80.15 5.5 89,80.5 5.0 88))')) as RESULT;

--echo #====================================================================================
--echo # multipoint
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('multipoint(-126.002 48.348, -126.003 48.348)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('multipoint(-126.002 48.348, -126.003 48.348, -126.004 48.358)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('multipoint(-126.002 48.348, -126.003 48.348, -126.002 48.348)')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('multipoint(-126.002 48.348 11, -126.003 48.348 11, -126.002 48.348 11)'));
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTILINESTRING((88.80 -60.85,88.815 -60.825,88.80 -60.825), (88.825 -60.80,88.80 -60.815,88.815 -60.830,88.80 -60.85))')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('multipoint(-126.002 48.348 10, -126.003 48.348 -10)')) as RESULT;

--echo #====================================================================================
--echo # multilinestring
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTILINESTRING((99.925 -78.990,99.90 -78.9915,99.915 -78.9930,99.90 -78.995))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTILINESTRING((123.40 43.25,123.415 43.225,123.40 43.225))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTILINESTRING((-20.90 30.55,-20.915 30.525,-20.90 30.525), (-20.925 30.50,-20.90 30.515,-20.915 30.530,-20.90 30.55))')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTILINESTRING((99.925 -78.990 10,99.90 -78.9915 -10,99.915 -78.9930 20 ,99.90 -78.995 -20))')) as RESULT;

--echo #====================================================================================
--echo # multipolygon
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTIPOLYGON(((88.85 55.50,88.815 55.525,88.825 55.50,88.815 55.55,88.85 55.50)),((88.825 55.50,88.80 55.515,88.830 55.515,88.822 55.510,88.825 55.50)))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTIPOLYGON(((66.615 11.120,66.625 11.1225,66.635 11.120,66.625 11.125,66.615 11.120)),((66.635 11.120,66.610 11.1215,66.640 11.1215,66.632 11.1210,66.635 11.120)))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTIPOLYGON(((-123.465 -32.10,-123.475 -32.125,-123.485 -32.10,-123.475 -32.15,-123.465 -32.10)),((-123.485 -32.10,-123.460 -32.115,-123.490 -32.115,-123.482 -32.110,-123.485 -32.10)))')) as RESULT;
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('MULTIPOLYGON(((88.85 55.50 10,88.815 55.525 10,88.825 55.50 10,88.815 55.55 10,88.85 55.50 10)),((88.825 55.50 10,88.80 55.515 10,88.830 55.515 10,88.822 55.510 10,88.825 55.50 10)))')) as RESULT;

--echo #====================================================================================
--echo # collection
--echo #====================================================================================
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION(
    MULTIPOLYGON(((11.115 22.20,11.1115 22.225,11.1125 22.20,11.1115 22.25,11.115 22.20)),((11.1125 22.20,11.110 22.215,11.1130 22.215,11.1122 22.210,11.1125 22.20))),
    POLYGON((11.115 22.20,11.117 22.210,11.110 22.215,11.1110 22.215,11.1115 22.225,11.1120 22.215,11.1130 22.215,11.1122 22.210,11.1125 22.20,11.1115 22.25,11.115 22.20)),
    LINESTRING(11.1115 22.225,11.1115 22.210),
    MULTIPOINT(11.115 22.20,11.1125 22.20),
    POINT(11.1115 22.225))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION(
    MULTIPOLYGON(((11.115 22.20,11.1115 22.225,11.1125 22.20,11.1115 22.25,11.115 22.20)),((11.1125 22.20,11.110 22.215,11.1130 22.215,11.1122 22.210,11.1125 22.20))),
    POLYGON((11.115 22.20,11.117 22.210,11.110 22.215,11.1110 22.215,11.1115 22.225,11.1120 22.215,11.1130 22.215,11.1122 22.210,11.1125 22.20,11.1115 22.25,11.115 22.20)),
    LINESTRING(11.1115 22.225,11.1115 22.210),
    MULTIPOINT(11.115 22.20,11.1125 22.20),
    GEOMETRYCOLLECTION(POINT(11.1115 22.225)))')) as RESULT;
select _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION()')) as RESULT;
select _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION EMPTY')) as RESULT;
select _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION())')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION EMPTY'));
# 3D
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION(
    MULTIPOLYGON(((11.115 22.20 10,11.1115 22.225 10,11.1125 22.20 10,11.1115 22.25 10,11.115 22.20 10)),((11.1125 22.20 10,11.110 22.215 10,11.1130 22.215 10,11.1122 22.210 10,11.1125 22.20 10))),
    POLYGON((11.115 22.20 10,11.117 22.210 10,11.110 22.215 10,11.1110 22.215 10,11.1115 22.225 10,11.1120 22.215 10,11.1130 22.215 10,11.1122 22.210 10,11.1125 22.20 10,11.1115 22.25 10,11.115 22.20 10)),
    LINESTRING(11.1115 22.225 10,11.1115 22.210 10),
    MULTIPOINT(11.115 22.20 10,11.1125 22.20 10),
    POINT(11.1115 22.225 10))')) as RESULT;
SELECT _ST_GeoHash(_ST_GEOMFROMEWKT('GEOMETRYCOLLECTION Z EMPTY'));

--echo bugfix: 55292702
--error 1690
SELECT _ST_GeoHash(Point(-126.002,48.348), 2147483648);
--error 1690
SELECT _ST_GeoHash(Point(-126.002,48.348), -2147483649);
SELECT _ST_GeoHash(Point(-126.002,48.348), -2147483648);
--error 1690
SELECT _ST_GeoHash(Point(-126.002,48.348), 21474836489999);

--echo bugfix: 55302231
--error 3064
SELECT _ST_GeoHash(Point(-126.002,48.348), true);
--error 3064
SELECT _ST_GeoHash(Point(-126.002,48.348), false);

--echo bugfix: 55323984
SELECT _ST_GeoHash(_ST_GeomFromEWKT('SRID=4326;point(-90 5.45566587879889878)'),0);
SELECT _ST_GeoHash(_ST_GeomFromEWKT('SRID=0;point(-90 5.45566587879889878)'),0);
