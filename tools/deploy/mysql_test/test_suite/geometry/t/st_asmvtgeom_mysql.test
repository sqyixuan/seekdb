# Geometry type change
SELECT 'PG44', _ST_AsEWKT(_ST_AsMVTGeom(
	_st_geomfromewkt('SRID=3857;MULTIPOLYGON(((-8238038.43842083 4974073.00356281,-8238058.59985694 4974035.91194892,-8238046.74211362 4974077.68076013,-8238038.43842083 4974073.00356281)))'),
	_st_geomfromewkt('SRID=3857;POLYGON((-8242969.13027341 4975133.29702555,-8242969.13027341 4970241.3272153,-8238077.16046316 4970241.3272153,-8238077.16046316 4975133.29702555,-8242969.13027341 4975133.29702555))'),
	4096,
	16,
	true));

# Invalid geometry after simplification with invalid clipping
# different from PG, PG will merge polygon
SELECT 'PG45', _ST_AsEWKT(_ST_AsMVTGeom(
	_st_geomfromewkt('SRID=3857;MULTIPOLYGON(((-8231365.02893734 4980355.83678553,-8231394.82332406 4980186.31880185,-8231367.43081065 4979982.17443372,-8231396.69199339 4980227.59327083,-8231365.02893734 4980355.83678553)))'),
	_st_geomfromewkt('SRID=3857;POLYGON((-8238115.3789773 4970203.10870116,-8238115.3789773 4980063.48534995,-8228255.00232851 4980063.48534995,-8228255.00232851 4970203.10870116,-8238115.3789773 4970203.10870116))'),
	4096,
	16,
	true));

# Geometry type change of one geometry of the multipolygon used to fallback to multilinestring
