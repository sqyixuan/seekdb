--source mysql_test/test_suite/geometry/t/import_default_srs_data_mysql.inc
--echo # ----------------------------------------------------------------------
--echo # Test from PG
--echo # ----------------------------------------------------------------------
# Input validation
select 'I1', _ST_AsMVTGeom(NULL, ST_GeomFromText('POLYGON((10 10,10 20,20 20,20 10,10 10))'), 4096);
--error 5471
select 'I2', _ST_AsMVTGeom(_ST_Point(1, 2), NULL, 4096);
--error 3037
select 'I3', _ST_AsMVTGeom(_ST_Point(1, 2), ST_GeomFromText('POINT(0 0)'));
--error 1690
select 'I4', _ST_AsMVTGeom(_ST_Point(1, 2), ST_GeomFromText('POLYGON((10 10,10 20,20 20,20 10,10 10))'), -10);
--error 1690
select 'I5', _ST_AsMVTGeom(_ST_Point(1, 2), ST_GeomFromText('POLYGON((10 10,10 20,20 20,20 10,10 10))'), 0);

# geometry preprocessing tests
select 'PG1', ST_AsText(_ST_AsMVTGeom(
	_ST_Point(1, 2),
	ST_GeomFromText('POLYGON((0 0,0 4096,4096 4096,4096 0,0 0))'),
	4096, 0, false));
select 'PG2', ST_AsText(_ST_AsMVTGeom(
	_ST_Point(1, 2),
	ST_GeomFromText('POLYGON((0 0,0 8192,8192 8192,8192 0,0 0))'),
	4096, 0, false));
select 'PG3', ST_AsText(_ST_AsMVTGeom(
	_ST_Point(1, 2),
	ST_GeomFromText('POLYGON((0 0,0 2048,2048 2048,2048 0,0 0))'),
	4096, 0, false));
select 'PG4', ST_AsText(_ST_AsMVTGeom(
	ST_GeomFromText('POLYGON ((0 0, 10 0, 10 5, 0 -5, 0 0))'),
	ST_GeomFromText('POLYGON((0 0,0 4096,4096 4096,4096 0,0 0))'),
	4096, 0, false));
select 'PG5', ST_AsText(_ST_AsMVTGeom(
	ST_GeomFromText('POLYGON ((0 0, 10 0, 10 5, 0 -5, 0 0))'),
	ST_GeomFromText('POLYGON((0 0,0 16777216,16777216 16777216,16777216 0,0 0))'),
	4096, 0, false));
select 'PG6', ST_AsText(_ST_AsMVTGeom(
	ST_GeomFromText('POLYGON ((1052826 6797045, 762780 6474467, 717821 6797045, 1052826 6797045))'),
	ST_GeomFromText('POLYGON((626172.135625 6261721.35625,626172.135625 6887893.49188,1252344.27125 6887893.49188,1252344.27125 6261721.35625,626172.135625 6261721.35625))'),
	4096, 0, false));

