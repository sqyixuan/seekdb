#select g, st_astext(_st_makevalid(st_geomfromtext(g)))	from (select st_astext(st_geomfromwkb(0x0103000000020000000500000000000000008040C00000000000002C4000000000008040C000000000000031400000000000003EC000000000000031400000000000003EC00000000000002C4000000000008040C00000000000002C400300000000000000000040C00000000000002E400000000000003FC0000000000000304000000000000040C00000000000002E40)) as g) as tmp;
