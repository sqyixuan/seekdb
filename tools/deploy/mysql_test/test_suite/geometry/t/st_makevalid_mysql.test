--source mysql_test/test_suite/geometry/t/import_default_srs_data_mysql.inc

select st_astext(_st_makevalid(st_geomfromtext('POLYGON((2 2,6 -2,10 2,10 -2,6 2,2 -2,2 2))')));
select g, st_astext(_st_makevalid(st_geomfromtext(g)))	from (select st_astext(st_geomfromwkb(0x0103000000010000000700000000000000000000400000000000000040000000000000184000000000000000C000000000000024400000000000000040000000000000244000000000000000C000000000000018400000000000000040000000000000004000000000000000C000000000000000400000000000000040)) as g) as tmp;
select g, st_astext(_st_makevalid(st_geomfromtext(g)))	from (select st_astext(st_geomfromwkb(0x01030000000100000007000000000000000000284000000000000000C000000000000028400000000000000040000000000000304000000000000000000000000000002C40000000000000000000000000000032400000000000000040000000000000324000000000000000C0000000000000284000000000000000C0)) as g) as tmp;
