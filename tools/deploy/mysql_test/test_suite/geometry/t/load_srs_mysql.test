connect (obsys, $OBMYSQL_MS0, root@sys,,oceanbase,$OBMYSQL_PORT);
connect (obmysql, $OBMYSQL_MS0, root, , oceanbase, $OBMYSQL_PORT);
connection obsys;

let $cpu = 1;
let $memory = '2G';

--disable_query_log
--disable_warnings
#drop tenant if exists test_gis force;
#DROP RESOURCE POOL IF EXISTS gis_pool;
#DROP RESOURCE UNIT IF EXISTS gis_unit;
#--enable_warnings

#eval CREATE RESOURCE UNIT gis_unit MAX_CPU=$cpu, MEMORY_SIZE=$memory;
#eval CREATE RESOURCE POOL gis_pool UNIT='gis_unit', UNIT_NUM=1;
#CREATE TENANT test_gis REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('gis_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql', lower_case_table_names = 0;
--enable_query_log

alter system load module data module=gis tenant=sys infile = 'etc/';
alter system load module data module=gis tenant=sys infile = 'etc/';
alter system load module data module=gis tenant=sys infile = 'etc/';

connect (con1, $OBMYSQL_MS0, root, , oceanbase, $OBMYSQL_PORT);

connection obmysql;
select count(*) from oceanbase.__all_spatial_reference_systems;

