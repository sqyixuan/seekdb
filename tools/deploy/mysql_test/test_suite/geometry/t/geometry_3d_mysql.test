SELECT type_name,ST_ASText(geo_value), ST_ASWKT(geo_value), _ST_ASEWKT(geo_value) FROM geo_3d ORDER BY id;
DELETE FROM geo_3d;
DROP table geo_3d;

SET @wkb_pt = ST_GeomFromText('POINT Z(0 1 1)');
SET @wkb_ln = ST_GeomFromText('LINESTRING Z(0 1 1,2 3 3,4 5 3,6 7 9,8 9 10,10 11 12)');
SET @wkb_py = ST_GeomFromText('POLYGON Z((0 0 1,0 10 12,10 10 11,10 0 34,0 0 1),(4 4 1,4 6 3,6 6 5,6 4 6,4 4 1))');
SET @wkb_mpt = ST_GeomFromText('MULTIPOINT Z(0 1 2,2 3 4,4 5 5,6 7 1)');
SET @wkb_mln = ST_GeomFromText('MULTILINESTRING Z((0 1 2,2 3 3,4 5 4),(6 7 1,8 9 2,10 11 3))');
SET @wkb_mpy = ST_GeomFromText('MULTIPOLYGON Z(((0 1 1,0 10 2,10 11 3,10 0 3,0 1 1),(4 5 1,4 6 3,6 7 2,6 4 3,4 5 1)),'
                                                     '((10 11 1,10 12 2,12 13 4,12 10 5,10 11 1)))');
SET @wkb_gc = ST_GeomFromText('GEOMETRYCOLLECTION Z('
                                'POINT Z(0 1 1),'
                                'LINESTRING Z(0 1 1,10 11 2),'
                                'POLYGON Z((0 0 2,0 10 1,10 10 2,10 0 3, 0 0 2)),'
                                'MULTIPOINT Z(0 1 1,2 3 3,4 5 4,6 7 5,8 9 1,10 11 4),'
                                'MULTILINESTRING Z((0 1 12,10 11 23),(0 10 12,10 0 32)),'
                                'MULTIPOLYGON Z(((0 1 1,0 5 3,5 6 2,5 0 3,0 1 1)),((5 4 1,5 10 3,10 11 21,10 5 23,5 4 1))))');
# ST_GeomFromWKB/ST_AsWKB
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_pt)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_ln)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_py)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_mpt)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_mln)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_mpy)));
SELECT ST_AsText(ST_GeomFromWKB(st_aswkb(@wkb_gc)));
# ST_GeometryFromWKB/ST_AsBinary
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_pt)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_ln)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_py)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_mpt)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_mln)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_mpy)));
SELECT ST_AsText(ST_GeometryFromWKB(ST_AsBinary(@wkb_gc)));
# _st_GeomFromEWKB/_st_asewkb
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_pt)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_ln)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_py)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_mpt)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_mln)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_mpy)));
SELECT ST_ASTEXT(_st_GeomFromEWKB(_ST_ASEWKB(@wkb_gc)));

# use the first 2 dimension to calculate
--echo ###################################
--echo # ST_DISTANCE(g1,g2)
--echo ###################################
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(0 0 0)'),ST_GEOMFROMTEXT('POINT(3 4 5)'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(0 0 1)'),ST_GEOMFROMTEXT('MULTIPOINT(3 4 5, 6 8 10)'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(0 0 0)'),ST_GEOMFROMTEXT('LINESTRING(10 10 1,10 0 2)'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(0 0 10)'),ST_GEOMFROMTEXT('MULTILINESTRING((10 10 1,1 0 2))'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(5 5 5)'),ST_GEOMFROMTEXT('POLYGON((0 0 1,0 10 2,10 10 10,10 0 3,0 0 1))'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(1 1 1)'),ST_GEOMFROMTEXT('MULTIPOLYGON(((0 0 1,0 10 2,10 10 10,10 0 3,0 0 1)))'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('POINT(5 5 1)'),ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POINT(5 5 10)))'));
SELECT ST_DISTANCE(ST_GEOMFROMTEXT('MULTIPOINT(0 0 1,9 0 1)'),ST_GEOMFROMTEXT('POINT(5 0 2)'));
