select 'dwithin_poly_pt_2', _st_dwithin(ST_GeomFromText('POLYGON((0 0 1, 10 0 2, 10 10 3, 0 10 4, 0 0 1))', 4326), ST_GeomFromText('POINT(5 10.01 3)', 4326), 1000);
select 'dwithin_poly_pt_3', _st_dwithin(ST_GeomFromText('POLYGON((0 0 1, 10 0 2, 10 10 3, 0 10 4, 0 0 1))', 4326), ST_GeomFromText('POINT(5 10.01 3)', 4326), 3000);
select 'dwithin_line_poly_1', _st_dwithin(ST_GeomFromText('LINESTRING(-1 -1 1, 0 0 2)', 4326), ST_GeomFromText('POLYGON((1 1 2, 2 2 2, 3 0 3, 1 1 2))', 4326), 300000);
select 'dwithin_poly_line_1', _st_dwithin(ST_GeomFromText('POLYGON((1 1 1, 2 2 3, 3 0 1, 1 1 1))', 4326), ST_GeomFromText('LINESTRING(-1 -1 2, 0 0 1)', 4326), 300000);
