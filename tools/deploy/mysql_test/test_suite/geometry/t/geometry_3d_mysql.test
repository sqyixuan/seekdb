# basic dml


# st_astext/st_geomfromtext
SELECT ST_ASText(ST_GeomFromText('POINT Z (0 0 0)'));  
SELECT ST_ASText(ST_GeomFromText('POINT Z (-1234 +5678 +91011)'));  
SELECT ST_ASText(ST_GeomFromText('POINT Z (25.416666666666668 25.416666666666668 26.6666666666666)'));  
SELECT ST_ASText(ST_GeomFromText('POINT Z (1e8 -23e4 +2e8)')); 

SELECT ST_ASText(ST_GeomFromText('LINESTRING Z(0 0 0,10 10 10)'));
SELECT ST_ASText(ST_GeomFromText('LINESTRING Z(0 0 10,-4 8 -3, 2000 2000 1000)'));

SELECT ST_ASText(ST_GeomFromText('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))'));

SELECT ST_ASText(ST_GeomFromText('MULTIPOINT Z(1 1 1, 11 11 12, 11 21 13, 21 21 14)'));
SELECT ST_ASText(ST_GeomFromText('MULTIPOINT Z((0 0 1),(10 10 2),(10 20 3),(20 20 4))'));

SELECT ST_ASText(ST_GeomFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))'));

SELECT ST_ASText(ST_GeomFromText('MULTIPOLYGON Z(((28 26 1,28 0 2,84 0 3,84 42 4,28 26 1),(52 18 34,66 23 54,73 9 67,48 6 65,52 18 34)),((59 18 11,67 18 34,67 13 23,59 13 56,59 18 11)))'));

SELECT ST_ASText(ST_GeomFromText('GEOMETRYCOLLECTION Z EMPTY'));
SELECT ST_ASText(ST_GeomFromText('GEOMETRYCOLLECTION Z ()'));
SELECT ST_ASText(ST_GeomFromText('GEOMETRYCOLLECTION Z (Point(9 9 9),LINESTRING(1 5 1,0 0 2),POLYGON((2 2 2,2 8 1,8 8 3,8 2 4,2 2 2)))'));
SELECT ST_ASText(ST_GeomFromText('GEOMETRYCOLLECTION Z(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1 3)), MULTILINESTRING((10 48 3,10 21 3,10 0 1),(16 0 3,16 23 4,16 48 5)), MULTIPOLYGON(((28 26 23,28 0 1,84 0 2,84 42 4,28 26 23),(52 18 13,66 23 25,73 9 12,48 6 34,52 18 13)),((59 18 1,67 18 12,67 13 23,59 13 45,59 18 1))), MULTIPOINT((0 0 1),(10 10 3),(10 20 4),(20 20 5)), MULTIPOINT(1 1 1, 11 11 11, 11 21 22, 21 21 23), GEOMETRYCOLLECTION(LINESTRING(1 1 1,2 2 3)), GEOMETRYCOLLECTION(POLYGON((0 0 1,50 45 23,40 50 34,0 0 1)),LINESTRING(-10 -10 1,0 0 2),LINESTRING(46.666666666666664 46.666666666666664 46.666666666666664,200 200 12,199 201 23,45.333333333333336 47.333333333333336 47.333333333333336),LINESTRING(8 10 1,-11 -9 -3)))'));

# _st_asewkt/_ST_GeogFromText/_st_geographyfromtext
--echo bugfix: 53548581
select _ST_ASEWKT(_ST_GeogFromText('point(181 91 183)'));
SELECT _ST_ASEWKT(_ST_GEOGRAPHYFROMTEXT('SRID=4326;point(300 300 500)'));

SELECT _ST_ASEWKT(_ST_GeogFromText('POINT Z (0 0 0)'));  
SELECT _ST_ASEWKT(_ST_GeogFromText('POINT Z (-1234 +5678 +91011)'));  
SELECT _ST_ASEWKT(_ST_GeogFromText('POINT Z (25.416666666666668 25.416666666666668 26.6666666666666)'));  
SELECT _ST_ASEWKT(_ST_GeogFromText('POINT Z (1e8 -23e4 +2e8)')); 
SELECT _ST_ASEWKT(_st_geographyfromtext('POINT Z (0 0 0)'));  
SELECT _ST_ASEWKT(_st_geographyfromtext('POINT Z (-1234 +5678 +91011)'));  
SELECT _ST_ASEWKT(_st_geographyfromtext('POINT Z (25.416666666666668 25.416666666666668 26.6666666666666)'));  
SELECT _ST_ASEWKT(_st_geographyfromtext('POINT Z (1e8 -23e4 +2e8)')); 


SELECT _ST_ASEWKT(_ST_GeogFromText('LINESTRING Z(0 0 0,10 10 10)'));
SELECT _ST_ASEWKT(_ST_GeogFromText('LINESTRING Z(0 0 10,-4 8 -3, 2000 2000 1000)'));
SELECT _ST_ASEWKT(_st_geographyfromtext('LINESTRING Z(0 0 0,10 10 10)'));
SELECT _ST_ASEWKT(_st_geographyfromtext('LINESTRING Z(0 0 10,-4 8 -3, 2000 2000 1000)'));

SELECT _ST_ASEWKT(_ST_GeogFromText('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))'));

SELECT _ST_ASEWKT(_ST_GeogFromText('MULTIPOINT Z(1 1 1, 11 11 12, 11 21 13, 21 21 14)'));
SELECT _ST_ASEWKT(_ST_GeogFromText('MULTIPOINT Z((0 0 1),(10 10 2),(10 20 3),(20 20 4))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('MULTIPOINT Z(1 1 1, 11 11 12, 11 21 13, 21 21 14)'));
SELECT _ST_ASEWKT(_st_geographyfromtext('MULTIPOINT Z((0 0 1),(10 10 2),(10 20 3),(20 20 4))'));

SELECT _ST_ASEWKT(_ST_GeogFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))'));

SELECT _ST_ASEWKT(_ST_GeogFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))'));

SELECT _ST_ASEWKT(_ST_GeogFromText('GEOMETRYCOLLECTION Z EMPTY'));
SELECT _ST_ASEWKT(_ST_GeogFromText('GEOMETRYCOLLECTION Z ()'));
SELECT _ST_ASEWKT(_ST_GeogFromText('GEOMETRYCOLLECTION Z (Point(9 9 9),LINESTRING(1 5 1,0 0 2),POLYGON((2 2 2,2 8 1,8 8 3,8 2 4,2 2 2)))'));
SELECT _ST_ASEWKT(_ST_GeogFromText('GEOMETRYCOLLECTION Z(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1 3)), MULTILINESTRING((10 48 3,10 21 3,10 0 1),(16 0 3,16 23 4,16 48 5)), MULTIPOLYGON(((28 26 23,28 0 1,84 0 2,84 42 4,28 26 23),(52 18 13,66 23 25,73 9 12,48 6 34,52 18 13)),((59 18 1,67 18 12,67 13 23,59 13 45,59 18 1))), MULTIPOINT((0 0 1),(10 10 3),(10 20 4),(20 20 5)), MULTIPOINT(1 1 1, 11 11 11, 11 21 22, 21 21 23), GEOMETRYCOLLECTION(LINESTRING(1 1 1,2 2 3)), GEOMETRYCOLLECTION(POLYGON((0 0 1,50 45 23,40 50 34,0 0 1)),LINESTRING(-10 -10 1,0 0 2),LINESTRING(46.666666666666664 46.666666666666664 46.666666666666664,200 200 12,199 201 23,45.333333333333336 47.333333333333336 47.333333333333336),LINESTRING(8 10 1,-11 -9 -3)))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('GEOMETRYCOLLECTION Z EMPTY'));
SELECT _ST_ASEWKT(_st_geographyfromtext('GEOMETRYCOLLECTION Z ()'));
SELECT _ST_ASEWKT(_st_geographyfromtext('GEOMETRYCOLLECTION Z (Point(9 9 9),LINESTRING(1 5 1,0 0 2),POLYGON((2 2 2,2 8 1,8 8 3,8 2 4,2 2 2)))'));
SELECT _ST_ASEWKT(_st_geographyfromtext('GEOMETRYCOLLECTION Z(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1 3)), MULTILINESTRING((10 48 3,10 21 3,10 0 1),(16 0 3,16 23 4,16 48 5)), MULTIPOLYGON(((28 26 23,28 0 1,84 0 2,84 42 4,28 26 23),(52 18 13,66 23 25,73 9 12,48 6 34,52 18 13)),((59 18 1,67 18 12,67 13 23,59 13 45,59 18 1))), MULTIPOINT((0 0 1),(10 10 3),(10 20 4),(20 20 5)), MULTIPOINT(1 1 1, 11 11 11, 11 21 22, 21 21 23), GEOMETRYCOLLECTION(LINESTRING(1 1 1,2 2 3)), GEOMETRYCOLLECTION(POLYGON((0 0 1,50 45 23,40 50 34,0 0 1)),LINESTRING(-10 -10 1,0 0 2),LINESTRING(46.666666666666664 46.666666666666664 46.666666666666664,200 200 12,199 201 23,45.333333333333336 47.333333333333336 47.333333333333336),LINESTRING(8 10 1,-11 -9 -3)))'));

--disable_warnings
drop table if exists geo_3d;
--enable_warnings
CREATE TABLE geo_3d (
  id INT PRIMARY KEY AUTO_INCREMENT,
  type_name TEXT,
  geo_value GEOMETRY
);

# ST_GeomFromText
INSERT INTO geo_3d (type_name,geo_value) VALUES
  ('POINTZ', ST_GeomFromText('POINT Z (0 0 0)')),
  ('POINTZ', ST_GeomFromText('POINT Z (-1234 +5678 +91011)')),
  ('POINTZ', ST_GeomFromText('POINT Z (25.416666666666668 25.416666666666668 26.6666666666666)')),
  ('POINTZ', ST_GeomFromText('POINT Z (1e8 -23e4 +2e8)')),
  ('LINESTRINGZ', ST_GeomFromText('LINESTRING Z(0 0 0,10 10 10)')),
  ('LINESTRINGZ', ST_GeomFromText('LINESTRING Z(0 0 10,-4 8 -3, 2000 2000 1000)')),
  ('POLYGONZ', ST_GeomFromText('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))')),
  ('MULTIPOINTZ', ST_GeomFromText('MULTIPOINT Z(1 1 1, 11 11 12, 11 21 13, 21 21 14)')),
  ('MULTILINESTRINGZ', ST_GeomFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))')),
  ('MULTIPOLYGONZ', ST_GeomFromText('MULTIPOLYGON Z(((28 26 1,28 0 2,84 0 3,84 42 4,28 26 1),(52 18 34,66 23 54,73 9 67,48 6 65,52 18 34)),((59 18 11,67 18 34,67 13 23,59 13 56,59 18 11)))')),
  ('GEOMETRYCOLLECTIONZ', ST_GeomFromText('GEOMETRYCOLLECTION Z(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1 3)), MULTILINESTRING((10 48 3,10 21 3,10 0 1),(16 0 3,16 23 4,16 48 5)), MULTIPOLYGON(((28 26 23,28 0 1,84 0 2,84 42 4,28 26 23),(52 18 13,66 23 25,73 9 12,48 6 34,52 18 13)),((59 18 1,67 18 12,67 13 23,59 13 45,59 18 1))), MULTIPOINT((0 0 1),(10 10 3),(10 20 4),(20 20 5)), MULTIPOINT(1 1 1, 11 11 11, 11 21 22, 21 21 23), GEOMETRYCOLLECTION(LINESTRING(1 1 1,2 2 3)), GEOMETRYCOLLECTION(POLYGON((0 0 1,50 45 23,40 50 34,0 0 1)),LINESTRING(-10 -10 1,0 0 2),LINESTRING(46.666666666666664 46.666666666666664 46.666666666666664,200 200 12,199 201 23,45.333333333333336 47.333333333333336 47.333333333333336),LINESTRING(8 10 1,-11 -9 -3)))'));

SELECT type_name,ST_ASText(geo_value), ST_ASWKT(geo_value), _ST_ASEWKT(geo_value) FROM geo_3d ORDER BY id;

UPDATE geo_3d SET geo_value = ST_GeomFromText('POINT Z (0 0 0)') WHERE type_name='POINTZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('LINESTRING Z(0 0 1,10 10 10)') WHERE type_name='LINESTRINGZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))') WHERE type_name='POLYGONZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('MULTIPOINT Z(1 1 1, 11 11 12)') WHERE type_name='MULTIPOINTZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34))') WHERE type_name='MULTILINESTRINGZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('MULTIPOLYGON Z(((28 26 1,28 0 2,84 0 3,84 42 4,28 26 1)))') WHERE type_name='MULTIPOLYGONZ';
UPDATE geo_3d SET geo_value = ST_GeomFromText('GEOMETRYCOLLECTION Z(GEOMETRYCOLLECTION())') WHERE type_name='GEOMETRYCOLLECTIONZ';

SELECT type_name,ST_ASText(geo_value), ST_ASWKT(geo_value), _ST_ASEWKT(geo_value) FROM geo_3d ORDER BY id;

DELETE FROM geo_3d;

