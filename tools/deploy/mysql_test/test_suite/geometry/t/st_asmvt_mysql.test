##
## Basic test
##
--source mysql_test/test_suite/geometry/t/import_default_srs_data_mysql.inc

 --disable_warnings
  drop table if exists test, all_type_tt, tt2;
 --enable_warnings

create table test(geo geometry);
insert into test values(st_geomfromtext('point(2 3)'));
insert into test values(st_geomfromtext('LINESTRING(130 150,220 150,220 240)'));
insert into test values(st_geomfromtext('POLYGON((40 60,160 60,160 180,40 180,40 60))'));
insert into test values(ST_GeomFromText('MULTIPOINT(80 260,140 260,180 260)'));
insert into test values(ST_GeomFromText('MULTILINESTRING((20 110,200 110),(60 180,60 110,160 110,110 110))'));
insert into test values(ST_GeomFromText('MULTIPOLYGON(((80 40,120 40,120 80,80 80,80 40)),((120 80,160 80,160 120,120 120,120 80)),((80 120,120 120,120 160,80 160,80 120)),((40 80,80 80,80 120,40 120,40 80)))'));

select hex(_ST_AsMVT(test.*)) from test;
drop table test;

--error 1149
SELECT 'TG1', hex(_ST_AsMVT(q)) FROM (SELECT 1 AS c1, ST_GeomFromText('POINT(25 17)')AS geom) AS q;

# geometry encoding tests
SELECT 'TG1', hex(_ST_AsMVT(q.*)) FROM (SELECT 1 AS c1, ST_GeomFromText('POINT(25 17)')AS geom) AS q;

# bug to fix
#SELECT 'TG1', hex(_ST_AsMVT(q, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, ST_GeomFromText('POINT(25 17)')AS geom) AS q;

SELECT 'TG2', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, ST_GeomFromText('MULTIPOINT(25 17, 26 18)') AS geom) AS q;
SELECT 'TG3', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, ST_GeomFromText('LINESTRING(0 0, 1000 1000)') AS geom) AS q;
SELECT 'TG4', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, ST_GeomFromText('LINESTRING(0 0, 500 500, 1000 1000)') AS geom) AS q;
SELECT 'TG5', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, ST_GeomFromText('MULTILINESTRING((1 1, 501 501, 1001 1001),(2 2, 502 502, 1002 1002))') AS geom) AS q;
SELECT 'TG6', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1,
                                                             ST_GeomFromText('POLYGON ((45 45, 15 40, 10 20, 35 10, 45 45), (35 35, 30 20, 20 30, 35 35))') AS geom) AS q;

SELECT 'TG7', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1,
                                                             ST_GeomFromText('MULTIPOLYGON(((20 35, 10 30, 10 10, 30 5, 45 20, 20 35), (20 25, 30 20, 20 15, 20 25)), ((20 45, 45 30, 40 40, 20 45)))') AS geom) AS q;

SELECT 'TG8', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1,
                                                             ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'TG9', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1,
                                                             ST_GeomFromText('MULTIPOINT(25 17, -26 -18)') AS geom) AS q;


# attribute encoding tests
SELECT 'TA1', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, 'abcd' AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'TA2', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1.1 AS c1,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'TA3', hex(_ST_AsMVT(q.*, 'test',  4096, 'geom')) FROM (SELECT NULL AS c1,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'TA4', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1,
  ST_GeomFromText('POINT(25 17)') AS geom
	UNION
	SELECT 2 AS c1, ST_GeomFromText('POINT(25 17)') AS geom ORDER BY c1) AS q;
SELECT 'TA5', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT
	ST_GeomFromText('POINT(25 17)') AS geom, 1 AS c1, 'abcd' AS c2) AS q;
SELECT 'TA6', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, -1 AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'TA7', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 'test' AS c1, 1 AS c2,
  ST_GeomFromText('POINT(25 17)') AS geom
	UNION
	SELECT 'test' AS c1, 2 AS c2, ST_GeomFromText('POINT(26 18)') AS geom
	UNION
	SELECT 'othertest' AS c1, 3 AS c2, ST_GeomFromText('POINT(26 18)') AS geom ORDER BY c2) AS q;
SELECT 'TA8', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT cast(1 as signed) AS c1, 1 AS c2, ST_GeomFromText('POINT(25 17)') AS geom
	UNION
	SELECT cast(1 as signed) AS c1, 2 AS c2, ST_GeomFromText('POINT(26 18)') AS geom
	UNION
	SELECT cast(2 as signed) AS c1, 3 AS c2, ST_GeomFromText('POINT(26 18)') AS geom ORDER BY c2) AS q;

SELECT 'TA9', hex(_ST_AsMVT(q.*))
FROM (
	SELECT 1 AS c1, -1 AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom
) AS q;

SELECT 'TA9', length(_ST_AsMVT(q.*))
FROM (
	SELECT 1 AS c1, -1 AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom
) AS q;

#string and text
SELECT 'TA10', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT 'AbcDfg' AS cstring,
	       'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus sed nulla augue. Pellentesque ut vulputate ex. Nunc et odio placerat, lacinia lectus sed, fermentum sapien. Sed massa velit, ullamcorper et est quis, congue rhoncus orci. Suspendisse in ante varius, convallis enim ut, fermentum amet.' as ctext,
	       ST_GeomFromText('POINT(25 17)') AS geom
) AS q;

# Check null attributes
SELECT 'TA11', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT 1 AS c1, cast(NULL as double) AS c2, ST_GeomFromText('POINT(25 17)') AS geom
	UNION
	SELECT NULL AS c1, 2.0 AS c2, ST_GeomFromText('POINT(26 18)') AS geom order by c1
) AS q;


SELECT 'TA12', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT 1 AS c1, cast(NULL as double) AS c2, ST_GeomFromText('POINT(25 17)') AS geom
	UNION
	SELECT 5 AS c1, 2.0 AS c2, null AS geom
) AS q;

# Extra geometry as parameter (swkb casted as string which is different from pg)
SELECT 'TA13', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM
(
	SELECT ST_GeomFromText('POINT(25 17)') as geom,
	       st_geomfromtext('LINESTRING(130 150,220 150,220 240)') as other_geom 
) AS q;

SELECT 'TA13', hex(_ST_AsMVT(q.*, 'test', 4096, 'other_geom')) FROM
(
	SELECT ST_GeomFromText('POINT(25 17)') as geom,
	       st_geomfromtext('LINESTRING(130 150,220 150,220 240)') as other_geom 
) AS q;

# default param

SELECT 'D1', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT 1 AS c1, 'abcd' AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;

SELECT 'D2', hex(_ST_AsMVT(q.*, 'test', 4096)) FROM (SELECT 1 AS c1, 'abcd' AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;

SELECT 'D3', hex(_ST_AsMVT(q.*, 'test')) FROM (SELECT 1 AS c1, 'abcd' AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'D4', hex(_ST_AsMVT(q.*)) FROM (SELECT 1 AS c1, 'abcd' AS c2,
	ST_GeomFromText('POINT(25 17)') AS geom) AS q;


SELECT 'J1', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT '{"c1":1,"c2":"abcd", "c3":true, "c4":3.14}' as json,
    ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'J2', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT cast('{"c1":1,"c2":"abcd", "c3":true, "c4":3.14}' as json) as jsonb,
                                                            ST_GeomFromText('POINT(25 17)') AS geom) AS q;
SELECT 'J3', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
    SELECT cast('{"c1":"abcd", "c2":"abcd"}' as json) as jsonb,
            ST_GeomFromText('POINT(25 17)') AS geom
    UNION ALL
    SELECT cast('{"c3":"abasdadcd", "c1":5}' as json) as jsonb,
            ST_GeomFromText('POINT(25 17)') AS geom
) AS q;
SELECT 'J4', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT cast(1.25 as double) AS c1,
	ST_GeomFromText('POINT (0 0)') AS geom,
	cast('{"test":1.75}' as json) as properties
) AS q;

SELECT 'J5', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (
	SELECT cast(1.75 as double) AS c1,
	ST_GeomFromText('POINT (0 0)') AS geom,
	cast('{"test":1.75}' as json) as properties
) AS q;

SELECT 'J6', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT cast('{"c1":1,"c2":"abcd", "c3":true, "c4":3.14, "c5": "2000-06-24 20:27:45.013867"}' as json) as jsonb,
    ST_GeomFromText('POINT(25 17)') AS geom) AS q;

SELECT 'J7', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT cast('{"c1":1,"c2":"abcd", "c3":true, "c4":3.14, "c5": {"d1": 2}}' as json) as jsonb,
    ST_GeomFromText('POINT(25 17)') AS geom) AS q;

SELECT 'J8', hex(_ST_AsMVT(q.*, 'test', 4096, 'geom')) FROM (SELECT cast('[1,2,3]' as json) as jsonb,
    ST_GeomFromText('POINT(25 17)') AS geom) AS q;


create table all_type_tt(c1 smallint, c2 int, c3 bigint, c4 bool, c5 float, c6 decimal(10, 5),
                         c7 date, c8 time, c9 timestamp, c10 char, c11 varchar(10), c12 text, c13 json, c14 geometry);

insert into all_type_tt values(8, 16, 4294967298, true, 3.14, 3.14158268877888, '2017-08-21', '11:00:00', '2015-06-25 15:18:00',
                               'm', 'mvt_test', 'it is text', '{"key1": "value1", "key2": "value2"}', st_geomfromtext('point(2 3)'));

insert into all_type_tt values(9, 26, 4294967298, false, 3.14, 5.444444, '2022-08-21', '20:00:00', '2023-06-25 15:18:00',
                               'g', 'mvt_test', 'it is text2', '{"key3": "value3", "key4": "value4"}', st_geomfromtext('LINESTRING(0 0, 500 500, 1000 1000)'));

select hex(_ST_AsMVT(all_type_tt.*)) from all_type_tt;
drop table all_type_tt;

 --disable_warnings
  drop view if exists vtt2, vtt3;
  drop table if exists tt3;
 --enable_warnings

create table tt2(id int, g GEOMETRY ,a varchar(100));
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),'test1');
create table tt3 as select _ST_AsMVT(tt2.*) a from tt2; 
select hex(a) from tt3;
desc tt3;
create view vtt3 as select _ST_AsMVT(tt2.*) a from tt2;
select hex(a) from vtt3;
desc vtt3;
drop table tt3;
drop view vtt3;
drop table tt2;

create table tt2(id int, g GEOMETRY , g1 GEOMETRY, a varchar(100));
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),ST_GeomFromText('POINT(30 100)'),'test1');
select hex(_ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'g1')) from tt2;
--error 5915
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'g','a') from tt2;
drop table tt2;

create table tt2(g GEOMETRY,b BIGINT);
insert into tt2 values(ST_GeomFromText('POINT(-15 -20)'),0);
select hex(_ST_AsMVT(tt2.*,'test',4096,'g','b')) from tt2;
--error 5915
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'g','d') from tt2;
drop table tt2;


create table tt2(id int, g GEOMETRY , g1 GEOMETRY, a varchar(100));
insert into tt2 values(-1,ST_GeomFromText('POINT(15 20)'),ST_GeomFromText('POINT(30 100)'),'test1');
select hex(_ST_AsMVT(tt2.*,'test',4096,'g','id')) from tt2;
truncate table tt2;
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),ST_GeomFromText('POINT(30 100)'),'test1');
select hex(_ST_AsMVT(tt2.*,'test',4096,'g','id')) from tt2;
truncate table tt2;
insert into tt2(g,g1,a) values(ST_GeomFromText('POINT(15 20)'),ST_GeomFromText('POINT(30 100)'),'test1');
select hex(_ST_AsMVT(tt2.*,'test',4096,'g','id')) from tt2;
drop table tt2;

create table tt2(id int, g GEOMETRY, d geometry);
insert into tt2 values(8,ST_GeomFromText('POINT(15 20 15)'), ST_GeomFromText('LINESTRING(0 0 0, 10 10 11, 20 25 -20, 50 60 -60)'));
select hex(_ST_AsMVT(tt2.*, 'test', 4096, 'g')) from tt2;
select hex(_ST_AsMVT(tt2.*, 'test', 4096, 'd')) from tt2;

drop table tt2;
create table tt2(id int, g GEOMETRY , g1 GEOMETRY, a varchar(100));
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),ST_GeomFromText('POINT(30 100)'),'test1');
select hex(_ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',1)) from tt2;
drop table tt2;

create table tt2(id int, g GEOMETRY ,a varchar(100));
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),'test1');
create view vtt2 as select * from tt2;
select hex(_ST_AsMVT(tt2.*,a)) from tt2;
select hex(_ST_AsMVT(tt2.*,null)) from tt2;
select hex(_ST_AsMVT(tt2.*,a,id)) from tt2;
select hex(_ST_AsMVT(tt2.*,a,id,'g')) from tt2;
select hex(_ST_AsMVT(tt2.*,a,id,'g','id')) from tt2;
select hex(_ST_AsMVT(tt2.*,tt2.a)) from tt2;
select hex(_ST_AsMVT(t.*,t.a)) from tt2 t;
select hex(_ST_AsMVT(tt2.*,'test',tt2.id)) from tt2;
select hex(_ST_AsMVT(vtt2.*,vtt2.a)) from vtt2;
select hex(_ST_AsMVT(t.*,t.a)) from vtt2 t;

--error 5915
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'g','g') from tt2;
drop table tt2;

create table tt2(g GEOMETRY,b ENUM('1','2'), c SET('1','2'));
insert into tt2 values(ST_GeomFromText('LINESTRING(0 0, 10 10, 20 25, 50 60)'),1, 2);
select hex(_ST_AsMVT(tt2.*)) from tt2;
drop table tt2;

 --disable_warnings
  drop view if exists vtt3;
  drop table if exists tt3;
 --enable_warnings

create table tt2(id int, g GEOMETRY ,a varchar(100));
insert into tt2 values(1,ST_GeomFromText('POINT(15 20)'),'test1');
--error 3034
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'id') from tt2;
--error 1054
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'') from tt2;
--error 3034
select _ST_AsMVT(tt2.*,'uyuyuyuyuiuyyuyuyutest',4096,'b') from tt2;
create table tt3 as select _ST_AsMVT(tt2.*) a from tt2;
insert into tt3 values((select _ST_AsMVT(tt2.*) from tt2));
replace into tt3 values((select _ST_AsMVT(tt2.*) from tt2));
update tt3 set a =(select _ST_AsMVT(tt2.*) from tt2);
select hex(a) from tt3;

create view vtt3 as select _ST_AsMVT(tt2.*) a from tt2;
select hex(a) from vtt3;
--error 1288
update vtt3 set a =(select _ST_AsMVT(tt2.*) from tt2);

