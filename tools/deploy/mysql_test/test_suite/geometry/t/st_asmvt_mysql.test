 --disable_warnings
  drop view if exists vtest1;
  drop table if exists test1;
 --enable_warnings

create table test1(id int,g GEOMETRY,g1 longblob);
insert into test1 values(1,ST_GeomFromText('LINESTRING(0 0, 10 10, 20 25, 50 60)'),'test');
create view vtest1 as select * from test1;

insert into test1(id,g1) values(2,(select _ST_AsMVT(test1.*) from test1));
insert into vtest1(id,g1) values(2,(select _ST_AsMVT(vtest1.*) from vtest1));
replace into test1(id,g1) values(2,(select _ST_AsMVT(test1.*) from test1));
replace into vtest1(id,g1) values(2,(select _ST_AsMVT(vtest1.*) from vtest1));
update test1 set g1=(select _ST_AsMVT(test1.*, 'test') from test1);
update vtest1 set g1=(select _ST_AsMVT(vtest1.*,'1') from vtest1);
drop table test1;
drop view vtest1;
