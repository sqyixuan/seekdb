
#owner: ht353245
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Base test of spatial index extern sorter.
--echo # ----------------------------------------------------------------------
--source mysql_test/test_suite/geometry/t/import_default_srs_data_mysql.inc


--disable_warnings
DROP TABLE IF EXISTS t;
--enable_warnings
CREATE TABLE t (id int auto_increment primary key, g GEOMETRY NOT NULL SRID 0);
CREATE INDEX idx ON t (g) local;

# 一行只有主键是200Byte，落盘限制大小是32M，所以需要写32M/200B条数据，大约17w，这个case会跑的时间比较长，有300s
--disable_warnings
drop procedure if exists insert_test;
--enable_warnings
delimiter //;
create procedure insert_test()
begin
  set @i=0;
  w:while @i<170000 do
    INSERT INTO t (g) VALUES (POINT(1,1));
    set @i=@i+1;
  end while w;
end; //
delimiter ;//
call insert_test();

set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
SELECT /*+index(t idx)*/ count(*) FROM t where st_intersects(g, st_geomfromtext('point(1 1)'));
DROP TABLE t;
