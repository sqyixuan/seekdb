--enable_warnings

CREATE TABLE gis_geometrycollection_2 SELECT fid as fid2,g as g2 FROM gis_geometrycollection;

--echo #####################################################################################
--echo # _ST_ClipByBox2d(g1,g2)
--echo #####################################################################################

--echo #====================================================================================
--echo # point,point
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_center)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_center))) FROM gis_geometrycollection WHERE fid=105;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('POINT(0 0)')));

--echo #====================================================================================
--echo # point,multipoint
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_bottom_points)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_bottom_points))) FROM gis_geometrycollection WHERE fid=106;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('MULTIPOINT(0 0)')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('MULTIPOINT(0 0,10 10)')));

--echo #====================================================================================
--echo # point,linestring
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_top_to_center)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_line_horizontal)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_top_to_center))) FROM gis_geometrycollection WHERE fid=104;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 0)'),ST_GeomFromText('LINESTRING(0 0,10 0)')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 0)'),ST_GeomFromText('LINESTRING(0 0,10 10)')));

--echo #====================================================================================
--echo # point,multilinestring
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_lines_near_vertical)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_lines_near_horizontal)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_lines_near_vertical))) FROM gis_geometrycollection WHERE fid=104;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('MULTILINESTRING((0 0,10 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(10 0)'),ST_GeomFromText('MULTILINESTRING((0 0,5 0),(5 0,10 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 0)'),ST_GeomFromText('MULTILINESTRING((0 0,5 0,10 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(20 0)'),ST_GeomFromText('MULTILINESTRING((0 0,5 0),(5 0,10 0))')));

--echo #====================================================================================
--echo # point,polygon
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_center),ST_GeomFromText(@star)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_elem_horizontal)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_elem_vertical)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star))) FROM gis_geometrycollection WHERE fid=104;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 0)'),ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0),(4 4,4 6,6 6,6 4,4 4))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(20 20)'),ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0))')));

--echo #====================================================================================
--echo # point,multipolygon
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_of_elems)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(-0.01 0)'),ST_GeomFromText(@star_of_elems)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_of_elems))) FROM gis_geometrycollection WHERE fid=104;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(20 20)'),ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)),((10 10,10 20,20 20,20 10,10 10)))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0)))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0),(4 4,4 6,6 6,6 4,4 4)))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(20 20)'),ST_GeomFromText('MULTIPOLYGON(((0 0,10 0,10 10,0 10,0 0),(4 4,4 6,6 6,6 4,4 4)))')));

--echo #====================================================================================
--echo # point,geometrycollection
--echo #====================================================================================
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_collection_elems)));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(-0.01 0)'),ST_GeomFromText(@star_collection_elems)));

SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_collection_elems))) FROM gis_geometrycollection WHERE fid=104;

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_collection_multilinestr)));
--echo pg not support 'GEOMETRYCOLLECTION(GEOMETRYCOLLECTION())'
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION())')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('GEOMETRYCOLLECTION(POINT(5 5))')));
--echo pg not support 'GEOMETRYCOLLECTION(GEOMETRYCOLLECTION())'
SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(5 5)'),ST_GeomFromText('GEOMETRYCOLLECTION(MULTIPOINT(0 0,5 5,10 10),GEOMETRYCOLLECTION())')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(0 0)'),ST_GeomFromText('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POLYGON((0 0,10 0,10 10,0 10,0 0))))')));

SELECT ST_AsText(_ST_ClipByBox2d(ST_GeomFromText('POINT(20 20)'),ST_GeomFromText('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POLYGON((0 0,10 0,10 10,0 10,0 0))))')));

