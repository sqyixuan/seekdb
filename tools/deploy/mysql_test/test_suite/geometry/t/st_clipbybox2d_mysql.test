--echo #INSERT separate star
--disable_warnings
INSERT INTO gis_geometrycollection VALUES
  (400,ST_GeomFromText(@star_3)),
  (401,ST_GeomFromText(@star_elem_vertical_3)),
  (402,ST_GeomFromText(@star_elem_horizontal_3)),
