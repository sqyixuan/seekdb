# use every srs item in __all_spatial_reference_systems
select srs_id, ST_AREA(ST_GEOMFROMTEXT('POLYGON((2 2,2 8,8 8,8 2,2 2))', srs_id)) from oceanbase.__all_spatial_reference_systems where srs_id < 13001000;
select srs_id, ST_INTERSECTS(ST_GEOMFROMTEXT('POLYGON((11 15,19 15,19 10,11 15))', srs_id), ST_GEOMFROMTEXT('LINESTRING(10 15,20 15)', srs_id)) from oceanbase.__all_spatial_reference_systems where srs_id < 13001000;
select srs_id, _st_covers(ST_GEOMFROMTEXT('POLYGON((11 15,19 15,19 10,11 15))', srs_id), ST_GEOMFROMTEXT('LINESTRING(10 15,20 15)', srs_id)) from oceanbase.__all_spatial_reference_systems where srs_id < 13001000;

