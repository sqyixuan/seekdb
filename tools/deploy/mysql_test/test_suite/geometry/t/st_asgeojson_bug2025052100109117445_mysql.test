--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#tags: view resolver

--result_format 4

--disable_warnings
drop table if exists xxx_fence;
--enable_warnings

CREATE TABLE xxx_fence (
    id BIGINT NOT NULL AUTO_INCREMENT,
    fence POLYGON NOT NULL,
    geojson TEXT GENERATED ALWAYS AS (ST_AsGeoJSON(fence)) VIRTUAL,
    PRIMARY KEY (id)
);

INSERT INTO xxx_fence (fence)
VALUES 
(ST_GeomFromText('POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))'));

INSERT INTO xxx_fence (fence)
VALUES 
(ST_GeomFromText('POLYGON((1 1, 2 1, 2 2, 1 2, 1 1))'));

SELECT id, ST_AsText(fence) AS wkt, geojson FROM xxx_fence;

UPDATE xxx_fence
SET fence = ST_GeomFromText('POLYGON((2 2, 3 2, 3 3, 2 3, 2 2))')
WHERE id = 1;

SELECT id, ST_AsText(fence) AS wkt, geojson FROM xxx_fence WHERE id = 1;

drop table xxx_fence;
