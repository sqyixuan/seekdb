drop table if exists gis_line;
CREATE TABLE gis_line(fid INTEGER NOT NULL PRIMARY KEY, g geometry);
INSERT INTO gis_line VALUES
(105, ST_GeomFromText('LINESTRING(0 0,0 10,10 0)')),
(106, ST_GeomFromText('LINESTRING(10 10,20 10,20 20,10 20,10 10)')),
(107, ST_GEOMFROMWKB(ST_AsWKB(ST_GeomFromText('LINESTRING(10 10, 40 10)'))));
SELECT fid, ST_Length(g) FROM gis_line;
fid	ST_Length(g)
105	24.14213562373095
106	40
107	30
