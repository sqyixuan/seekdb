drop table if exists test, all_type_tt, tt2;
create table test(geo geometry);
insert into test values(st_geomfromtext('point(2 3)'));
insert into test values(st_geomfromtext('LINESTRING(130 150,220 150,220 240)'));
insert into test values(st_geomfromtext('POLYGON((40 60,160 60,160 180,40 180,40 60))'));
