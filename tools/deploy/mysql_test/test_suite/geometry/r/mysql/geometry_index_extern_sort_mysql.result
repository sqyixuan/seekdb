# ----------------------------------------------------------------------
# Base test of spatial index extern sorter.
# ----------------------------------------------------------------------
DROP TABLE IF EXISTS t;
CREATE TABLE t (id int auto_increment primary key, g GEOMETRY NOT NULL SRID 0);
CREATE INDEX idx ON t (g) local;
drop procedure if exists insert_test;
create procedure insert_test()
begin
set @i=0;
w:while @i<170000 do
INSERT INTO t (g) VALUES (POINT(1,1));
set @i=@i+1;
end while w;
end; //
call insert_test();
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
SELECT /*+index(t idx)*/ count(*) FROM t where st_intersects(g, st_geomfromtext('point(1 1)'));
count(*)
170000
DROP TABLE t;
