Empty Geometry
SELECT 'geojson_empty_geom', ST_AsGeoJSON(_ST_GeomFromEWKT(NULL));
geojson_empty_geom	ST_AsGeoJSON(_ST_GeomFromEWKT(NULL))
geojson_empty_geom	NULL
Precision
