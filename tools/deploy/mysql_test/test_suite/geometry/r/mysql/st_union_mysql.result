CREATE TABLE gis_geometrycollection_2 SELECT fid as fid2,g as g2 FROM gis_geometrycollection;
#Checking the integrity of the above create/insert statements 
#64 rows. 
SELECT count(ST_ASTEXT(g) != 'NULL') FROM gis_geometrycollection;
count(ST_ASTEXT(g) != 'NULL')
64
#64 rows. 
SELECT count(ST_ASTEXT(g2) != 'NULL') FROM gis_geometrycollection_2;
count(ST_ASTEXT(g2) != 'NULL')
64
#####################################################################################
# ST_Union(g1,g2)
#####################################################################################
#====================================================================================
# point,point
#====================================================================================
SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_center),ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('POINT(15 10)'));
ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_center),ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('POINT(15 10)'))
1
SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_top),ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('MULTIPOINT((15 10),(15 25))'));
ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_top),ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('MULTIPOINT((15 10),(15 25))'))
1
SELECT ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('POINT(15 10)')) FROM gis_geometrycollection WHERE fid=105;
ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star_center)),ST_GEOMFROMTEXT('POINT(15 10)'))
1
#====================================================================================
# point,multipoint
#====================================================================================
SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_bottom_left),ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(25 0))'));
ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_bottom_left),ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(25 0))'))
1
SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_center),ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(15 10),(25 0))'));
ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_center),ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(15 10),(25 0))'))
1
SELECT ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(25 0))')) FROM gis_geometrycollection WHERE fid=106;
ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star_bottom_points)),ST_GEOMFROMTEXT('MULTIPOINT((5 0),(25 0))'))
1
