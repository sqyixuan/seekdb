ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_top),ST_GEOMFROMTEXT(@star_top_to_center)),ST_GEOMFROMTEXT('LINESTRING(15 25,15 10)'))
1
SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_bottom_left),ST_GEOMFROMTEXT(@star_top_to_center)),ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(LINESTRING(15 25,15 10),POINT(5 0))'));
ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_bottom_left),ST_GEOMFROMTEXT(@star_top_to_center)),ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(LINESTRING(15 25,15 10),POINT(5 0))'))
1
