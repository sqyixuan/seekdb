# 3D Test
###################################
select ST_ASTEXT(ST_UNION(ST_GeomFromText('GEOMETRYCOLLECTION(Point(1 2 3),LINESTRING(1 2 2, 3 4 1),POLYGON((2 2 1,2 8 5,8 8 7,8 2 4,2 2 1)))'), ST_GeomFromText('LINESTRING(1 2 3, 3 4 5)')));
