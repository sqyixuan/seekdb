SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_center),ST_GEOMFROMTEXT(@star_lines_near_vertical)),ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(MULTILINESTRING((0 5,15 25,0 25)),POINT(15 10))'));
