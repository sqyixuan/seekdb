select ST_Astext(ST_Union(geom, geom)) from ( 
select st_geomfromtext('POLYGON((-7 4.2 2,-7.1 4.2 3,-7.1 4.3 2, -7 4.2 2))') geom 
union all select st_geomfromtext('POINT(5 5 5)') geom 
union all select st_geomfromtext('POINT(-2 3 1)') geom 
union all select st_geomfromtext('LINESTRING(5 5 5, 10 10 10)') geom ) as foo;
ST_Astext(ST_Union(geom, geom))
POLYGON Z ((-7.1 4.2 3,-7 4.2 2,-7.1 4.3 2,-7.1 4.2 3))
POINT Z (5 5 5)
POINT Z (-2 3 1)
LINESTRING Z (5 5 5,10 10 10)
bugfix: 53240606
