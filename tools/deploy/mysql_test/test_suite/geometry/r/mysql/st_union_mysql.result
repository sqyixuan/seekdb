1
SELECT ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star)),ST_GEOMFROMTEXT('POLYGON((5 0,15 5,25 0,22 10,30 15,20 15,15 25,10 15,0 15,7 10,5 0))')) FROM gis_geometrycollection WHERE fid=104;
ST_Equals(ST_UNION(g,ST_GEOMFROMTEXT(@star)),ST_GEOMFROMTEXT('POLYGON((5 0,15 5,25 0,22 10,30 15,20 15,15 25,10 15,0 15,7 10,5 0))'))
1
