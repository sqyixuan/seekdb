#
# WL#8579 Spatial Reference Systems
#
# SRID 0 (should pass)
SELECT ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 0),
ST_GEOMFROMTEXT('POINT(0 0)', 0)
));
ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 0),
ST_GEOMFROMTEXT('POINT(0 0)', 0)
))
POINT(0 0)
# Projected SRS (should pass)
SELECT ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 2000),
ST_GEOMFROMTEXT('POINT(0 0)', 2000)
));
ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 2000),
ST_GEOMFROMTEXT('POINT(0 0)', 2000)
))
POINT(0 0)
# Geographic SRS (should pass)
SELECT ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 4326),
ST_GEOMFROMTEXT('POINT(0 0)', 4326)
));
ST_ASTEXT(ST_UNION(
ST_GEOMFROMTEXT('POINT(0 0)', 4326),
ST_GEOMFROMTEXT('POINT(0 0)', 4326)
))
POINT(0 0)
#
# Bug #25510403 SRID OF RESULT OF SET OPERATION IS DIFFERENT FROM INPUT
# GEOMETRIES
#
SELECT ST_SRID(ST_Union(
ST_GeomFromText("MULTIPOLYGON(((0 0, 0 1, 1 1, 0 0)))", 2000),
ST_GeomFromText("MULTILINESTRING((1 1, 2 2))", 2000)
)) AS result;
result
2000
SELECT ST_SRID(ST_Union(
ST_GeomFromText("LINESTRING(1 1, 2 2)", 2000),
ST_GeomFromText("MULTIPOLYGON(((0 0, 0 1, 1 1, 0 0)))", 2000)
)) AS result;
result
2000
SELECT ST_SRID(ST_Union(
ST_GeomFromText("MULTIPOLYGON(((0 0, 0 1, 1 1, 0 0)))", 2000),
ST_GeomFromText("LINESTRING(1 1, 2 2)", 2000)
)) AS result;
result
2000
SELECT ST_SRID(ST_Union(
ST_GeomFromText("MULTILINESTRING((1 1, 2 2))", 2000),
ST_GeomFromText("MULTIPOLYGON(((0 0, 0 1, 1 1, 0 0)))", 2000)
)) AS result;
result
2000
#
# WL#11096 Don't do Cartesian computations on geographic geometries
#
# Assume SRID 10 is not defined.
