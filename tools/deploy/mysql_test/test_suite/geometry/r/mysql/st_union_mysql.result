SELECT ST_Equals(ST_UNION(ST_GEOMFROMTEXT(@star_top_3),ST_GEOMFROMTEXT(@star)),ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(POLYGON((5 0,15 5,25 0,22 10,30 15,20 15,15 25,10 15,0 15,7 10,5 0)),POINT(75 25))'));
