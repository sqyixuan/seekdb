drop table if exists geo_clip;
create table geo_clip(id int primary key auto_increment, g geometry not null);
insert into geo_clip(g) values(ST_GeomFromText('POLYGON((41 20,41 0,21 0,1 20,1 40,21 40,41 20))', 3857));
SELECT '8', _ST_AsEWKT(_ST_ClipByBox2d(g, _ST_MakeEnvelope(-20,-20,-10,-10))) FROM geo_clip;
