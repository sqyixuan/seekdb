ST_AsText(_ST_ClipByBox2d(ST_GeomFromText(@star_top),ST_GeomFromText(@star_center)))
GEOMETRYCOLLECTION EMPTY
SELECT ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_center))) FROM gis_geometrycollection WHERE fid=105;
ST_AsText(_ST_ClipByBox2d(g,ST_GeomFromText(@star_center)))
