#####################################################################################
# _ST_MAKEPOINT(double x, double y [, double z])
#####################################################################################

drop table type_test;
create table type_test(boolean_c bool,
int_c INT,
smallint_c SMALLINT,
integer_c INTEGER,
float_c float,
double_c double,
decimal_c DECIMAL(6,3),
number_float_c float(21),
char_c CHAR(100),
varchar_c VARCHAR(100),
binary_c char(100),
date_c DATE,
time_c TIMESTAMP);
INSERT into type_test values(true, 1, -4, 8, 0.1, 2.88, 100.999, 10.99,'1.99', '2.56', '888', '2015-02-01 02:02:02', '1970-01-01 08:00:00.000002');
INSERT into type_test values(false, -1, -4, -8, -0.1, -2.88, -100.999, -10.99,'-1.99', '-2.56', '-888', '2019-02-01 02:02:02', '1990-01-01 08:00:00.000002');
#====================================================================================
# param input
#====================================================================================
SELECT ST_ASTEXT(_ST_MAKEPOINT());
ERROR 42000: Incorrect parameter count in the call to native function '_ST_MAKEPOINT'
SELECT ST_ASTEXT(_ST_MAKEPOINT(NULL));
ERROR 42000: Incorrect parameter count in the call to native function '_ST_MAKEPOINT'
SELECT ST_ASTEXT(_ST_MAKEPOINT(1, 2, 3, 4));
ERROR 42000: Incorrect parameter count in the call to native function '_ST_MAKEPOINT'
SELECT ST_ASTEXT(_ST_MAKEPOINT(NULL, 1));
ST_ASTEXT(_ST_MAKEPOINT(NULL, 1))
NULL
SELECT ST_ASTEXT(_ST_MAKEPOINT(NULL, NULL));
ST_ASTEXT(_ST_MAKEPOINT(NULL, NULL))
NULL
SELECT ST_ASTEXT(_ST_MAKEPOINT(NULL, 'NULL'));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT(NULL, ''));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT(1, NULL));
ST_ASTEXT(_ST_MAKEPOINT(1, NULL))
NULL
SELECT ST_ASTEXT(_ST_MAKEPOINT(1, 2, NULL));
ST_ASTEXT(_ST_MAKEPOINT(1, 2, NULL))
NULL
SELECT ST_ASTEXT(_ST_MAKEPOINT('', 1));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT('NULL', 1));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT(' ', 1));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT('2a', 1));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT(' -2 ', 1));
ST_ASTEXT(_ST_MAKEPOINT(' -2 ', 1))
POINT(-2 1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(' - 2 ', 1));
ERROR 01000: Truncated incorrect DOUBLE value
SELECT ST_ASTEXT(_ST_MAKEPOINT(' -0 ', 1));
ST_ASTEXT(_ST_MAKEPOINT(' -0 ', 1))
POINT(-0 1)
#====================================================================================
# 2D Point
#====================================================================================
SELECT ST_ASTEXT(_ST_MAKEPOINT(true, false));
ERROR 22000: Invalid data type for the operation
SELECT ST_ASTEXT(_ST_MAKEPOINT(1, -2));
ST_ASTEXT(_ST_MAKEPOINT(1, -2))
POINT(1 -2)
SELECT ST_ASTEXT(_ST_MAKEPOINT('-1', '2'));
ST_ASTEXT(_ST_MAKEPOINT('-1', '2'))
POINT(-1 2)
SELECT ST_ASTEXT(_ST_MAKEPOINT(1E-324,1E-324));
ST_ASTEXT(_ST_MAKEPOINT(1E-324,1E-324))
POINT(0 0)
SELECT ST_ASTEXT(_ST_MAKEPOINT(boolean_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(boolean_c, int_c))
POINT(5e-324 1)
POINT(0 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(int_c, int_c))
POINT(1 1)
POINT(-1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(smallint_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(smallint_c, int_c))
POINT(-4 1)
POINT(-4 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(integer_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(integer_c, int_c))
POINT(8 1)
POINT(-8 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(float_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(float_c, int_c))
POINT(0.10000000149011612 1)
POINT(-0.10000000149011612 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(number_float_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(number_float_c, int_c))
POINT(10.989999771118164 1)
POINT(-10.989999771118164 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(char_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(char_c, int_c))
POINT(1.99 1)
POINT(-1.99 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c))
POINT(2.56 1)
POINT(-2.56 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(binary_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(binary_c, int_c))
POINT(888 1)
POINT(-888 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c))
POINT(2.56 1)
POINT(-2.56 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(date_c, int_c)) from type_Test;
ERROR 22000: Invalid data type for the operation
SELECT ST_ASTEXT(_ST_MAKEPOINT(time_c, int_c)) from type_Test;
ERROR 22000: Invalid data type for the operation
#====================================================================================
# 3D Point
#====================================================================================
SELECT ST_ASTEXT(_ST_MAKEPOINT(true, false, 1));
ERROR 22000: Invalid data type for the operation
SELECT ST_ASTEXT(_ST_MAKEPOINT(1, -2, 3));
ST_ASTEXT(_ST_MAKEPOINT(1, -2, 3))
POINT Z (1 -2 3)
SELECT ST_ASTEXT(_ST_MAKEPOINT('-1', '2', 3));
ST_ASTEXT(_ST_MAKEPOINT('-1', '2', 3))
POINT Z (-1 2 3)
SELECT ST_ASTEXT(_ST_MAKEPOINT(1E-324, 1E-324, 1E-324));
ST_ASTEXT(_ST_MAKEPOINT(1E-324, 1E-324, 1E-324))
POINT Z (0 0 0)
SELECT ST_ASTEXT(_ST_MAKEPOINT(boolean_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(boolean_c, int_c, int_c))
POINT Z (5e-324 1 1)
POINT Z (0 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(int_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(int_c, int_c, int_c))
POINT Z (1 1 1)
POINT Z (-1 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(smallint_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(smallint_c, int_c, int_c))
POINT Z (-4 1 1)
POINT Z (-4 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(integer_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(integer_c, int_c, int_c))
POINT Z (8 1 1)
POINT Z (-8 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(float_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(float_c, int_c, int_c))
POINT Z (0.10000000149011612 1 1)
POINT Z (-0.10000000149011612 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(number_float_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(number_float_c, int_c, int_c))
POINT Z (10.989999771118164 1 1)
POINT Z (-10.989999771118164 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(char_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(char_c, int_c, int_c))
POINT Z (1.99 1 1)
POINT Z (-1.99 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c, int_c))
POINT Z (2.56 1 1)
POINT Z (-2.56 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(binary_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(binary_c, int_c, int_c))
POINT Z (888 1 1)
POINT Z (-888 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c, int_c)) from type_Test;
ST_ASTEXT(_ST_MAKEPOINT(varchar_c, int_c, int_c))
POINT Z (2.56 1 1)
POINT Z (-2.56 -1 -1)
SELECT ST_ASTEXT(_ST_MAKEPOINT(date_c, int_c, int_c)) from type_Test;
ERROR 22000: Invalid data type for the operation
SELECT ST_ASTEXT(_ST_MAKEPOINT(time_c, int_c, int_c)) from type_Test;
