drop table if exists geo_3d;
CREATE TABLE geo_3d (
id INT PRIMARY KEY AUTO_INCREMENT,
type_name TEXT,
geo_value GEOMETRY
);
INSERT INTO geo_3d (type_name,geo_value) VALUES
('POINTZ', ST_GeomFromText('POINT Z (0 0 0)')),
