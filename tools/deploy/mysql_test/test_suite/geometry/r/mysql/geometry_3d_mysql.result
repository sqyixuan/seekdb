###################################
# spatial index
###################################
drop table tt1;
create table tt1(id int , g geometry not null srid 0);
CREATE SPATIAL INDEX g_idx ON tt1(g);
insert into tt1 values(1,ST_GeomFromText('point(10 20)'));
insert into tt1 values(2,ST_GeomFromText('point(10 20 5)'));
insert into tt1 values(3,ST_GeomFromText('POLYGON((0 0,10 0,10 10,0 10,0 0))'));
insert into tt1 values(4,ST_GeomFromText('POLYGON((0 0 1,10 0 2,10 10 2,0 10 3,0 0 1))'));
insert into tt1 values(5,ST_GeomFromText('LINESTRING(10 10, 20 20)',0));
insert into tt1 values(6,ST_GeomFromText('LINESTRING(10 10 2, 20 20 3)',0));
select id ,st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(10 20)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(10 20)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
select id ,st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(2 1)'),g);
id	st_astext(g)
3	POLYGON((0 0,10 0,10 10,0 10,0 0))
4	POLYGON Z ((0 0 1,10 0 2,10 10 2,0 10 3,0 0 1))
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(2 1)'),g);
id	st_astext(g)
3	POLYGON((0 0,10 0,10 10,0 10,0 0))
4	POLYGON Z ((0 0 1,10 0 2,10 10 2,0 10 3,0 0 1))
select id ,st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(10 20 5)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(10 20)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
select id ,st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(2 1 2)'),g);
id	st_astext(g)
3	POLYGON((0 0,10 0,10 10,0 10,0 0))
4	POLYGON Z ((0 0 1,10 0 2,10 10 2,0 10 3,0 0 1))
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('point(2 1)'),g);
id	st_astext(g)
3	POLYGON((0 0,10 0,10 10,0 10,0 0))
4	POLYGON Z ((0 0 1,10 0 2,10 10 2,0 10 3,0 0 1))
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('linestring(10 20, 20 10)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
5	LINESTRING(10 10,20 20)
6	LINESTRING Z (10 10 2,20 20 3)
select id ,/*+INDEX(tt1 g_idx)*/ st_astext(g) from tt1 where ST_Intersects(ST_GeomFromText('linestring(10 20 2, 20 10 3)'),g);
id	st_astext(g)
1	POINT(10 20)
2	POINT Z (10 20 5)
5	LINESTRING(10 10,20 20)
6	LINESTRING Z (10 10 2,20 20 3)
DROP INDEX g_idx ON tt1;
drop table tt1;
