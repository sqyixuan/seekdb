('POINTZ', ST_GeomFromText('POINT Z (1e8 -23e4 +2e8)')),
('LINESTRINGZ', ST_GeomFromText('LINESTRING Z(0 0 0,10 10 10)')),
('LINESTRINGZ', ST_GeomFromText('LINESTRING Z(0 0 10,-4 8 -3, 2000 2000 1000)')),
('POLYGONZ', ST_GeomFromText('Polygon Z((0 0 0, 0 8 1, 8 8 2, 8 10 3, -10 10 4, -10 0 5, 0 0 0))')),
('MULTIPOINTZ', ST_GeomFromText('MULTIPOINT Z(1 1 1, 11 11 12, 11 21 13, 21 21 14)')),
('MULTILINESTRINGZ', ST_GeomFromText('MULTILINESTRING Z((10 48 23,10 21 12,10 0 34),(16 0 12,16 23 23,16 48 32))')),
