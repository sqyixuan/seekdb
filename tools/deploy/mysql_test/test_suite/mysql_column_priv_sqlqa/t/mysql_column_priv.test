# 使用ykk_db1数据库
use ykk_db1;

--error 0,1051
DROP TABLE t_com1;
CREATE TABLE t_com1(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_com2;
CREATE TABLE t_com2(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_com3;
CREATE TABLE t_com3(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--echo # 授权单列/多列 SELECT+INSERT 权限
# 单列
GRANT SELECT(c1), INSERT(c1) ON ykk_db1.t_com1 TO ykk1;
# 多列
GRANT SELECT(c2,c3,c4), INSERT(c2,c3,c4) ON ykk_db1.t_com2 TO ykk1;

# 查询授权语法
SHOW GRANTS FOR ykk1;
# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk1';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk1'@'%'" ORDER BY TABLE_NAME,Column_name;


--echo # 授权单列/多列 SELECT+UPDATE 权限
# 单列
GRANT SELECT(c1), UPDATE(c1) ON ykk_db1.t_com1 TO ykk2;
# 多列
GRANT SELECT(c2,c3,c4), UPDATE(c2,c3,c4) ON ykk_db1.t_com2 TO ykk2;

# 查询授权语法
SHOW GRANTS FOR ykk2;
# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk2';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk2'@'%'" ORDER BY TABLE_NAME,Column_name;


--echo # 授权单列/多列 INSERT+UPDATE 权限
# 单列
GRANT INSERT(c1), UPDATE(c1) ON ykk_db1.t_com1 TO ykk3;
# 多列
GRANT INSERT(c2,c3,c4), UPDATE(c2,c3,c4) ON ykk_db1.t_com2 TO ykk3;

# 查询授权语法
SHOW GRANTS FOR ykk3;
# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk3';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk3'@'%'" ORDER BY TABLE_NAME,Column_name;


--echo # 分别给不同的列授不同的权限
# 单列
GRANT SELECT(c1), INSERT(c2), UPDATE(c3) ON ykk_db1.t_com1 TO ykk4;
# 多列
GRANT SELECT(c1,c2), INSERT(c2,c3), UPDATE(c3,c4) ON ykk_db1.t_com2 TO ykk4;

# 查询授权语法
