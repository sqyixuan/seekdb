SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk4';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk4'@'%'" ORDER BY TABLE_NAME,Column_name;


