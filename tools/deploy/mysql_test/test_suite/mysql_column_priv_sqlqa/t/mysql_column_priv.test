--error 1142
INSERT INTO t3 (c1, c2, c3, c4) VALUES (1, 'Value A', 'Value B', 'Value C') ON DUPLICATE KEY UPDATE c2 = VALUES(c2), c3 = VALUES(c3), c4 = VALUES(c4);

INSERT IGNORE INTO t1 (c1, c2) VALUES (1, 'A');

INSERT IGNORE INTO t3 (c1, c2, c3, c4) VALUES (1, 'A', 'B', 'C');

--error 1142
REPLACE INTO t1 (c1, c2) VALUES (1, 'A');

--error 1142
REPLACE INTO t2 VALUES (1, 'A', 'B', 'C');




