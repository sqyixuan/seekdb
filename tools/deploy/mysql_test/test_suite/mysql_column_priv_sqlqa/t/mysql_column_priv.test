--echo # 环境清理
purge recyclebin;
--enable_sorted_result
--disable_warnings
--error 0,1396
drop user ykk@'%';
--enable_warnings
create user ykk IDENTIFIED BY 'ykk';
grant all on *.* to ykk WITH GRANT OPTION;
connect (conn1,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn1;


############################################# 语法验证 #############################################

# 创建数据库
--error 0,1008
DROP DATABASE ykk_db1;
CREATE DATABASE ykk_db1;

--error 0,1008
DROP DATABASE ykk;
CREATE DATABASE ykk;


USE ykk_db1;

# 创建测试表
--error 1051
DROP TABLE t1;
CREATE TABLE t1(
    c1 int,
    c2 int,
    c3 int
);

--error 1051
DROP TABLE t2;
CREATE TABLE t2(
    c1 int
);



# 创建用户
--error 0,1396
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';

--error 0,1396
DROP USER ykk2;
CREATE USER 'ykk2'@'%' IDENTIFIED BY 'ykk123';

--error 0,1396
DROP USER ykk3;
CREATE USER 'ykk3'@'%' IDENTIFIED BY 'ykk123';

### 创建用户时将列权限授权给用户
--error 0,1396
DROP USER ykk4;
CREATE USER 'ykk4'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk_db1.t1 TO ykk4 WITH GRANT OPTION;

--error 0,1396
DROP USER ykk5;
CREATE USER 'ykk5'@'%' IDENTIFIED BY 'ykk123';



### 授权：
### 将列权限授权给没有列权限的用户

# 给ykk1授权SELECT（不带 WITH GRANT OPTION）
GRANT SELECT ON ykk_db1.t1 TO ykk1;
GRANT SELECT ON ykk_db1.t2 TO ykk1;

# 给ykk3授权SELECT（带 WITH GRANT OPTION）
GRANT SELECT ON ykk_db1.t1 TO ykk3 WITH GRANT OPTION;


###
# 登录ykk1
connect (conn2,$OBMYSQL_MS0,ykk1,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn2;
###
--echo # ykk1授权给ykk2，预期失败
--error 1142
GRANT SELECT ON ykk_db1.t1 TO ykk2;

# 验证ykk1用户是否拥有ykk_db1.t1表的SELECT权限
SELECT * FROM t1;


###
# 登录ykk3
connect (conn3,$OBMYSQL_MS0,ykk3,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn3;
###
--echo # ykk3授权给ykk2
GRANT SELECT ON ykk_db1.t1 TO ykk2;


###
# 登录ykk2
connect (conn4,$OBMYSQL_MS0,ykk2,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn4;
###
--echo #  查询t1，验证SELECT权限
USE ykk_db1;

# 验证ykk2用户是否拥有ykk_db1.t1表的SELECT权限
SELECT * FROM t1;



### 撤销授权：

###
# 登录root
connect (conn5,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn5;
###


# 撤销ykk1的SELECT权限（不带 WITH GRANT OPTION）
REVOKE SELECT ON ykk_db1.t1 FROM ykk1;


###
# 登录ykk1
connect (conn6,$OBMYSQL_MS0,ykk1,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn6;
###
--echo #  查询t1，验证SELECT权限
USE ykk_db1;
--error 1142
SELECT * FROM ykk_db1.t1;


###
# 登录ykk2
connect (conn7,$OBMYSQL_MS0,ykk2,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn7;
###
--echo #  查询t1，验证SELECT权限
USE ykk_db1;
SELECT * FROM t1;

###
# 登录root
connect (conn8,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn8;
###


# 撤销ykk3的SELECT权限（带 WITH GRANT OPTION）
--error 1064
REVOKE SELECT ON ykk_db1.t1 FROM ykk3 WITH GRANT OPTION;


### 将列权限授权给已有列权限的用户
--echo # 再次执行用户ykk4的SELECT授权语句
GRANT SELECT ON ykk_db1.t1 TO ykk4;

# 再次执行授权语句时，携带 WITH GRANT OPTION
GRANT SELECT ON ykk_db1.t1 TO ykk4 WITH GRANT OPTION;


### 已有列权限的用户授权给没有列权限的用户
# 使用ykk4用户给其他用户授权
###
# 登录ykk4
connect (conn9,$OBMYSQL_MS0,ykk4,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn9;
###
GRANT SELECT ON ykk_db1.t1 TO ykk2;


### 已有列权限的用户授权给已有列权限的用户
GRANT SELECT ON ykk_db1.t1 TO ykk2;


###
# 登录root
connect (conn10,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn10;
###

### 用户没有列权限时撤销用户的列权限
# 表列没有 SELECT、INSERT、UPDATE 权限时，撤销 SELECT/INSERT/UPDATE
--error 5362,1147
REVOKE SELECT ON ykk_db1.t1 FROM ykk1;
--error 5362,1147
REVOKE INSERT ON ykk_db1.t1 FROM ykk1;
--error 5362,1147
REVOKE UPDATE ON ykk_db1.t1 FROM ykk1;

# 表列拥有SELECT权限时，撤销INSERT、UPDATE权限
--echo # 给用户ykk1授权SELECT
GRANT SELECT ON ykk_db1.t1 TO ykk1;
--echo # 撤销用户ykk1的UPDATE/INSERT权限
REVOKE INSERT ON ykk_db1.t1 FROM ykk1;
REVOKE UPDATE ON ykk_db1.t1 FROM ykk1;

# 表列拥有INSERT权限时，撤销SELECT、UPDATE权限
--echo # 给用户ykk1授权INSERT
GRANT INSERT ON ykk_db1.t1 TO ykk1;
--echo # 撤销用户ykk1的UPDATE/SELECT权限
REVOKE SELECT ON ykk_db1.t1 FROM ykk1;
REVOKE UPDATE ON ykk_db1.t1 FROM ykk1;

# 表列拥有UPDATE权限时，撤销SELECT、INSERT权限
--echo # 给用户ykk1授权UPDATE
GRANT UPDATE ON ykk_db1.t1 TO ykk1;
--echo # 撤销用户ykk1的INSERT/SELECT权限
REVOKE SELECT ON ykk_db1.t1 FROM ykk1;
REVOKE INSERT ON ykk_db1.t1 FROM ykk1;



############################################# 列级权限场景 #############################################
### 授权权限 
# 单一权限授权
# 登录root
connect (conn11,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn11;

# 创建用户
--error 0,1396
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';

# 创建表
use ykk_db1;
--error 0,1051
DROP TABLE t_sel;
CREATE TABLE t_sel(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_ins;
CREATE TABLE t_ins(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_upd;
CREATE TABLE t_upd(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);


--echo # 授权单列/多列 SELECT 权限
# 单列
GRANT SELECT(c1) ON ykk_db1.t_sel TO ykk1;
# 多列
GRANT SELECT(c2,c3,c4) ON ykk_db1.t_sel TO ykk1;

--echo # 授权单列/多列 INSERT 权限
# 单列
GRANT INSERT(c1) ON ykk_db1.t_ins TO ykk1;
# 多列
GRANT INSERT(c2,c3,c4) ON ykk_db1.t_ins TO ykk1;

--echo # 授权单列/多列 UPDATE 权限
# 单列
GRANT UPDATE(c1) ON ykk_db1.t_upd TO ykk1;
# 多列
GRANT UPDATE(c2,c3,c4) ON ykk_db1.t_upd TO ykk1;


### 权限验证
--echo # 查询授权语法
SHOW GRANTS FOR ykk1;
--echo # 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv ORDER BY user,Column_name;
--echo # 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE TABLE_SCHEMA = 'ykk_db1' ORDER BY GRANTEE,TABLE_NAME,Column_name;



# 执行DML验证
# 登录ykk1
connect (conn12,$OBMYSQL_MS0,ykk1,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn12;

use ykk_db1;

# t_sel表SELECT权限验证
SELECT c1 FROM t_sel;
SELECT c2,c3,c4 FROM t_sel;
SELECT c1,c2,c3,c4 FROM t_sel;
SELECT * FROM t_sel;

# t_ins表INSERT权限验证
INSERT t_ins(c1) VALUES(1);
INSERT t_ins(c2,c3,c4) VALUES('a','b','c');
INSERT t_ins(c1,c2,c3,c4) VALUES(2,'x','y','z');
INSERT t_ins VALUES(3,'x','y','z');

# t_upd表UPDATE权限验证
UPDATE t_upd SET c1 = 1;
UPDATE t_upd SET c2 = 'h', c3 = 'j', c4 = 'k';
UPDATE t_upd SET c1 = 2, c2 = 'h', c3 = 'j', c4 = 'k';


# 组合权限授权

# 登录root
connect (conn13,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn13;

# 创建用户
