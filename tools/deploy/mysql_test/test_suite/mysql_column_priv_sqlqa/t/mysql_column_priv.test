--error 1143
SELECT c2,c3 FROM t1;


# 表中字段都有SELECT权限时 使用SELECT *
SELECT * FROM t2;


# 表中有无SELECT权限的字段时 使用SELECT *
--error 1143
SELECT * FROM t1;


# WHERE后使用有SELECT权限字段做为控制条件
SELECT c1,c2 FROM t1 WHERE c1 = 1;


# WHERE后使用无SELECT权限字段做为控制条件
--error 1143
SELECT c1,c2 FROM t1 WHERE c3 = '1';


# 在GROUP BY时 使用有SELECT权限的字段
SELECT c1,c2 FROM t1 GROUP BY c1;


# 在GROUP BY时 使用无SELECT权限的字段
--error 1143
SELECT c1,c2 FROM t1 GROUP BY c3;


# 在ORDER BY时 使用有SELECT权限的字段
SELECT c1,c2 FROM t1 ORDER BY c1;


# 在ORDER BY时 使用无SELECT权限的字段
--error 1143
SELECT c1,c2 FROM t1 ORDER BY c3;


# 多表联合查询时 多个表的列都有SELECT权限
SELECT t1.c1, t1.c2, t2.c1, t2.c2, t2.c3, t2.c4 FROM t1 LEFT JOIN t2 ON t1.c1 = t2.c1;


# 多表联合查询时 多个表的部分列没有SELECT权限
--error 1143
SELECT * FROM t1 LEFT JOIN t2 ON t1.c1 = t2.c1;
--error 1143
SELECT t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3, t2.c4 FROM t1 LEFT JOIN t2 ON t1.c1 = t2.c1;


# SELECT...INTO
SELECT c1, c2 INTO @var1,@var2 FROM t1 LIMIT 1;
SELECT c1, c2 INTO @var1,@var2 FROM t2 WHERE c1 = 4;

--error 1143
SELECT * INTO @var1,@var2,@var3,@var4 FROM t1;
--error 1143
SELECT c1, c2, c3, c4 INTO @var1,@var2,@var3,@var4 FROM t1;
--error 1143
SELECT c1, c2 INTO @var1,@var2 FROM t1 WHERE c3 = '4';


# CTAS
--error 1142
CREATE TABLE t4 AS SELECT c1,c2 FROM t1;
--error 1142
CREATE TABLE t5 AS SELECT * FROM t2;
--error 1142
CREATE TABLE tt4 AS SELECT * FROM t1;
--error 1142
CREATE TABLE tt4 AS SELECT c1,c2,c3 FROM t1;
--error 1142
CREATE TABLE tt4 AS SELECT c1,c2 FROM t1 WHERE c3 IS NULL;


# UNION
SELECT c1 FROM t1 UNION ALL SELECT c1 FROM t2;
--error 1143
SELECT * FROM t1 UNION ALL SELECT * FROM t2;





