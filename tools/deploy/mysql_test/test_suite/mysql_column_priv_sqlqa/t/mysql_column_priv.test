# 登录root
connect (conn56,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection conn56;

# 创建用户
--error 0,1396
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';

--error 0,1396
DROP USER ykk2;
CREATE USER 'ykk2'@'%' IDENTIFIED BY 'ykk123';

--error 0,1396
DROP USER ykk3;
CREATE USER 'ykk3'@'%' IDENTIFIED BY 'ykk123';

--error 0,1396
DROP USER ykk4;
CREATE USER 'ykk4'@'%' IDENTIFIED BY 'ykk123';


USE data1;

# 普通表
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
    c1 INT NOT NULL,
    c2 VARCHAR(100) NOT NULL,
    c3 VARCHAR(100) NOT NULL,
    c4 VARCHAR(200) AS (CONCAT(c1, c2)) STORED,
    c5 VARCHAR(200) AS (CONCAT(c2, c3)) VIRTUAL,
    PRIMARY KEY (c1) 
);
INSERT INTO t1(c1,c2,c3) VALUES(1001, 'AAAA', 'AAAAAAAA');
INSERT INTO t1(c1,c2,c3) VALUES(2001, 'BBBB', 'BBBBBBBB');
INSERT INTO t1(c1,c2,c3) VALUES(3001, 'CCCC', 'CCCCCCCC');


# 视图
CREATE VIEW v1 AS SELECT * FROM t1;


# 分区表
--error 0,1051
DROP TABLE tt1;
CREATE TABLE tt1 (
    c1 INT NOT NULL,
    c2 VARCHAR(100) NOT NULL,
    c3 VARCHAR(100) NOT NULL,
    c4 VARCHAR(200) AS (CONCAT(c1, c2)) STORED,
    c5 VARCHAR(200) AS (CONCAT(c2, c3)) VIRTUAL,
    PRIMARY KEY (c1)
) PARTITION BY RANGE (c1) (
    PARTITION p0 VALUES LESS THAN (1000),
    PARTITION p1 VALUES LESS THAN (2000),
    PARTITION p2 VALUES LESS THAN (3000),
    PARTITION p3 VALUES LESS THAN MAXVALUE
);
INSERT INTO tt1(c1,c2,c3) VALUES(1001, 'AAAA', 'AAAAAAAA');
INSERT INTO tt1(c1,c2,c3) VALUES(2001, 'BBBB', 'BBBBBBBB');
INSERT INTO tt1(c1,c2,c3) VALUES(3001, 'CCCC', 'CCCCCCCC');



# 授权
GRANT SELECT(c1,c2,c3,c4,c5), INSERT(c1,c2,c3,c4), UPDATE(c1,c2,c3,c4) ON data1.t1 TO ykk1;
GRANT SELECT(c1,c2,c3,c4,c5), INSERT(c1,c2,c3,c4), UPDATE(c1,c2,c3,c4) ON data1.v1 TO ykk1;
GRANT SELECT(c1,c2,c3,c4,c5), INSERT(c1,c2,c3,c4), UPDATE(c1,c2,c3,c4) ON data1.tt1 TO ykk1;

# 授权
GRANT SELECT, INSERT, UPDATE ON data1.t1 TO ykk2;
GRANT SELECT, INSERT, UPDATE ON data1.v1 TO ykk2;
GRANT SELECT, INSERT, UPDATE ON data1.tt1 TO ykk2;

