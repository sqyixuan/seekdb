connection default;

USE ykk_db1;

DROP TABLE t1;
DROP DATABASE ykk_db1;
DROP USER ykk1;
DROP USER ykk2;
DROP USER ykk3;
DROP USER ykk4;
DROP USER ykk5;
DROP USER ykk6;
