############################################# 列级权限场景 #############################################
### 授权权限 
# 登录root
#connect (conn11,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection default;

# 创建用户
--error 0,1396
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';
--error 0,1396
DROP USER ykk2;
CREATE USER 'ykk2'@'%' IDENTIFIED BY 'ykk123';
--error 0,1396
DROP USER ykk3;
CREATE USER 'ykk3'@'%' IDENTIFIED BY 'ykk123';
--error 0,1396
DROP USER ykk4;
CREATE USER 'ykk4'@'%' IDENTIFIED BY 'ykk123';
--error 0,1396
DROP USER ykk5;
CREATE USER 'ykk5'@'%' IDENTIFIED BY 'ykk123';


# 使用ykk_db1数据库
use ykk_db1;

--error 0,1051
DROP TABLE t_com1;
CREATE TABLE t_com1(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_com2;
CREATE TABLE t_com2(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);

--error 0,1051
DROP TABLE t_com3;
CREATE TABLE t_com3(
    c1 int,
    c2 varchar(50),
    c3 varchar(50),
    c4 varchar(50)
);


--echo # 分别给不同的列授不同的权限
# 单列
--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT(c1), INSERT(c2), UPDATE(c3) ON ykk_db1.t_com1 TO ykk4';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL GrantSelectPriv();

# 查询授权语法
SHOW GRANTS FOR ykk4;
# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk4';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk4'@'%'" ORDER BY TABLE_NAME;


# 多列
--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT(c1,c2), INSERT(c2,c3), UPDATE(c3,c4) ON ykk_db1.t_com2 TO ykk4';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL GrantSelectPriv();

# 查询授权语法
SHOW GRANTS FOR ykk4;
# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk4';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk4'@'%'" ORDER BY TABLE_NAME;




--echo # 撤销分别给不同的不同的权限
# 单列
--error 0,1305
DROP PROCEDURE RevokeSelectPriv;
DELIMITER //;
CREATE PROCEDURE RevokeSelectPriv()
BEGIN
    SET @grantQuery = 'REVOKE SELECT(c1), INSERT(c2), UPDATE(c3) ON ykk_db1.t_com1 FROM ykk4';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL RevokeSelectPriv();

# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk4';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk4'@'%'" ORDER BY TABLE_NAME;


# 多列
--error 0,1305
DROP PROCEDURE RevokeSelectPriv;
DELIMITER //;
CREATE PROCEDURE RevokeSelectPriv()
BEGIN
    SET @grantQuery = 'REVOKE SELECT(c1,c2), INSERT(c2,c3), UPDATE(c3,c4) ON ykk_db1.t_com2 FROM ykk4';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL RevokeSelectPriv();

# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE USER = 'ykk4';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk4'@'%'" ORDER BY TABLE_NAME;




#################### REVOKEALL权限时，表列的权限也会被撤销 ####################

# 授权表列
GRANT SELECT(c1,c2,c3,c4), INSERT(c1,c2,c3,c4), UPDATE(c1,c2,c3,c4) ON ykk_db1.t_com3 TO ykk5;

# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE user = 'ykk5';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk5'@'%'" ORDER BY GRANTEE,TABLE_NAME;

# 撤销表所有权限
--error 0,1305
DROP PROCEDURE RevokeSAllPriv;
DELIMITER //;
CREATE PROCEDURE RevokeSAllPriv()
BEGIN
    SET @grantQuery = 'REVOKE ALL ON ykk_db1.t_com3 FROM ykk5';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL RevokeSAllPriv();

# 查询列权限表
SELECT Host,Db,User,Table_name,Column_name,Column_priv FROM mysql.columns_priv WHERE user = 'ykk5';
# 查询权限视图
SELECT * FROM information_schema.COLUMN_PRIVILEGES WHERE GRANTEE = "'ykk5'@'%'" ORDER BY TABLE_NAME;






##################################DEFINER拥有不同的权限##################################

--disable_warnings
--error 0,1396
DROP USER ykk6;
CREATE USER 'ykk6'@'%' IDENTIFIED BY 'ykk123';
GRANT CREATE ROUTINE, ALTER ROUTINE, EXECUTE ON *.* TO ykk6;
--enable_warnings
# 创建存储过程，指定definer为ykk6
--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE DEFINER = 'ykk6'@'%' PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT ON ykk_db1.t1 TO ykk1';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

# ykk6没有任何权限时调用
#--error 1142
CALL GrantSelectPriv();


# 为ykk6授权SELECT权限（不带 WITH GRANT OPTION）
GRANT SELECT ON ykk_db1.t1 TO ykk6;
#--error 1142
CALL GrantSelectPriv();


# 为ykk6授权SELECT权限（带 WITH GRANT OPTION）
GRANT SELECT ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
CALL GrantSelectPriv();


# 撤销ykk6的SELECT权限
REVOKE SELECT ON ykk_db1.t1 FROM ykk6;
#--error 1142
CALL GrantSelectPriv();


# 为ykk6授权INSERT权限
GRANT INSERT,UPDATE ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
#--error 1142
CALL GrantSelectPriv();


# 撤销ykk6的INSERT权限
REVOKE INSERT,UPDATE ON ykk_db1.t1 FROM ykk6;
#--error 1142
CALL GrantSelectPriv();


# 为ykk6授权某个列SELECT权限
GRANT SELECT(c1) ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
#--error 1142
CALL GrantSelectPriv();

GRANT SELECT(c1,c2,c3) ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
#--error 1142
CALL GrantSelectPriv();


REVOKE ALL ON ykk_db1.t1 FROM ykk6;


# 创建存储过程，指定definer为ykk6
--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE DEFINER = 'ykk6'@'%' PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT(c1,c2) ON ykk_db1.t1 TO ykk1';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//


# 为ykk6授权单个列SELECT权限
GRANT SELECT(c1) ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
#--error 1143
CALL GrantSelectPriv();

REVOKE ALL ON ykk_db1.t1 FROM ykk6;


# 为ykk6授权多个列SELECT权限
GRANT SELECT(c2,c3) ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
#--error 1143
CALL GrantSelectPriv();

REVOKE ALL ON ykk_db1.t1 FROM ykk6;


# 为ykk6授权所有列SELECT权限
GRANT SELECT(c1,c2,c3) ON ykk_db1.t1 TO ykk6 WITH GRANT OPTION;
CALL GrantSelectPriv();





