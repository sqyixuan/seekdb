--enable_sorted_result
--echo # 环境清理
--disable_warnings
--error 0,1396
drop user ykkpl@'%';
--enable_warnings
create user ykkpl IDENTIFIED BY 'ykkpl';
grant all on *.* to ykkpl WITH GRANT OPTION;
connect (conn1,$OBMYSQL_MS0,ykkpl,ykkpl,,$OBMYSQL_PORT);
connection conn1;




############################################# 语法验证 #############################################


# 创建数据库
--error 0,1008
DROP DATABASE ykk_db1;
CREATE DATABASE ykk_db1;

--error 0,1008
DROP DATABASE ykk;
CREATE DATABASE ykk;

USE ykk_db1;

--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
    c1 int,
    c2 int,
    c3 int
);

--error 0,1051
DROP TABLE t2;
CREATE TABLE t2(
    c1 int
);

# 创建用户
--error 0,1396
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk1;

--error 0,1396
DROP USER ykk2;
CREATE USER 'ykk2'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk2;

--error 0,1396
DROP USER ykk3;
CREATE USER 'ykk3'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk3;

### 创建用户时将列权限授权给用户
--error 0,1396
DROP USER ykk4;
CREATE USER 'ykk4'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk_db1.t1 TO ykk4 WITH GRANT OPTION;
GRANT CREATE ROUTINE, ALTER ROUTINE, EXECUTE ON *.* TO ykk4;



--error 0,1396
DROP USER ykk5;
CREATE USER 'ykk5'@'%' IDENTIFIED BY 'ykk123';



### 授权：
### 将列权限授权给没有列权限的用户

# 给ykk1授权SELECT（不带 WITH GRANT OPTION）
--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT ON ykk_db1.t1 TO ykk1';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL GrantSelectPriv();



# 给ykk3授权SELECT（带 WITH GRANT OPTION）

--error 0,1305
DROP PROCEDURE GrantSelectPriv;
DELIMITER //;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
    SET @grantQuery = 'GRANT SELECT ON ykk_db1.t1 TO ykk3 WITH GRANT OPTION';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL GrantSelectPriv();




###
# 登录ykk1
connect (conn2,$OBMYSQL_MS0,ykk1,ykk123,ykk_db1,$OBMYSQL_PORT);
connection conn2;
###
