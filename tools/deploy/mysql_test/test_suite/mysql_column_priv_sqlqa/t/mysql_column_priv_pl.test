### 撤销授权：

###
# 登录root
#connect (conn5,$OBMYSQL_MS0,ykk,ykk,,$OBMYSQL_PORT);
connection default;
###


# 撤销ykk1的SELECT权限（不带 WITH GRANT OPTION）

--error 0,1305
DROP PROCEDURE RevokeSelectPriv;
DELIMITER //;
CREATE PROCEDURE RevokeSelectPriv()
BEGIN
    SET @grantQuery = 'REVOKE SELECT ON ykk_db1.t1 FROM ykk1';
    PREPARE stmt FROM @grantQuery;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END;

//
DELIMITER ;//

CALL RevokeSelectPriv();




