c1 INT NOT NULL,
c2 VARCHAR(100) NOT NULL,
c3 VARCHAR(100) NOT NULL,
c4 VARCHAR(200) AS (CONCAT(c1, c2)) STORED,
c5 VARCHAR(200) AS (CONCAT(c2, c3)) VIRTUAL,
PRIMARY KEY (c1)
) PARTITION BY RANGE (c1) (
PARTITION p0 VALUES LESS THAN (1000),
PARTITION p1 VALUES LESS THAN (2000),
PARTITION p2 VALUES LESS THAN (3000),
PARTITION p3 VALUES LESS THAN MAXVALUE
);
INSERT INTO tt1(c1,c2,c3) VALUES(1001, 'AAAA', 'AAAAAAAA');
INSERT INTO tt1(c1,c2,c3) VALUES(2001, 'BBBB', 'BBBBBBBB');
INSERT INTO tt1(c1,c2,c3) VALUES(3001, 'CCCC', 'CCCCCCCC');
