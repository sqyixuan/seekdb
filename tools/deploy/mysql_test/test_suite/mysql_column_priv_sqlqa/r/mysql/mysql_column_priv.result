# 环境清理
purge recyclebin;
drop user ykk@'%';
create user ykk IDENTIFIED BY 'ykk';
grant all on *.* to ykk WITH GRANT OPTION;
DROP DATABASE ykk_db1;
CREATE DATABASE ykk_db1;
DROP DATABASE ykk;
CREATE DATABASE ykk;
USE ykk_db1;
DROP TABLE t1;
ERROR 42S02: Unknown table 'ykk_db1.t1'
CREATE TABLE t1(
c1 int,
c2 int,
c3 int
);
DROP TABLE t2;
ERROR 42S02: Unknown table 'ykk_db1.t2'
