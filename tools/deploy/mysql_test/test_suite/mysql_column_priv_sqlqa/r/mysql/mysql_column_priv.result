GRANT SELECT ON ykk_db1.t2 TO ykk1;
GRANT SELECT ON ykk_db1.t1 TO ykk3 WITH GRANT OPTION;
# ykk1授权给ykk2，预期失败
GRANT SELECT ON ykk_db1.t1 TO ykk2;
ERROR 42000: GRANT command denied to user 'ykk1'@'%' for table 't1'
SELECT * FROM t1;
c1	c2	c3
# ykk3授权给ykk2
GRANT SELECT ON ykk_db1.t1 TO ykk2;
#  查询t1，验证SELECT权限
USE ykk_db1;
SELECT * FROM t1;
c1	c2	c3
REVOKE SELECT ON ykk_db1.t1 FROM ykk1;
#  查询t1，验证SELECT权限
