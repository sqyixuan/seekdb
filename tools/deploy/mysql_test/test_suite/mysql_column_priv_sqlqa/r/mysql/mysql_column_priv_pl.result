# 环境清理
drop user ykkpl@'%';
create user ykkpl IDENTIFIED BY 'ykkpl';
grant all on *.* to ykkpl WITH GRANT OPTION;
DROP DATABASE ykk_db1;
CREATE DATABASE ykk_db1;
DROP DATABASE ykk;
CREATE DATABASE ykk;
USE ykk_db1;
DROP TABLE t1;
CREATE TABLE t1(
c1 int,
c2 int,
c3 int
);
DROP TABLE t2;
CREATE TABLE t2(
c1 int
);
DROP USER ykk1;
CREATE USER 'ykk1'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk1;
DROP USER ykk2;
CREATE USER 'ykk2'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk2;
DROP USER ykk3;
CREATE USER 'ykk3'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk.* TO ykk3;
DROP USER ykk4;
CREATE USER 'ykk4'@'%' IDENTIFIED BY 'ykk123';
GRANT SELECT ON ykk_db1.t1 TO ykk4 WITH GRANT OPTION;
GRANT CREATE ROUTINE, ALTER ROUTINE, EXECUTE ON *.* TO ykk4;
DROP USER ykk5;
CREATE USER 'ykk5'@'%' IDENTIFIED BY 'ykk123';
DROP PROCEDURE GrantSelectPriv;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
SET @grantQuery = 'GRANT SELECT ON ykk_db1.t1 TO ykk1';
PREPARE stmt FROM @grantQuery;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END;
//
CALL GrantSelectPriv();
DROP PROCEDURE GrantSelectPriv;
CREATE PROCEDURE GrantSelectPriv()
BEGIN
SET @grantQuery = 'GRANT SELECT ON ykk_db1.t1 TO ykk3 WITH GRANT OPTION';
PREPARE stmt FROM @grantQuery;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END;
//
CALL GrantSelectPriv();
# ykk1授权给ykk2，预期失败
GRANT SELECT ON ykk_db1.t1 TO ykk2;
ERROR 42000: GRANT command denied to user 'ykk1'@'%' for table 't1'
SELECT * FROM t1;
c1	c2	c3
SELECT * FROM t2;
ERROR 42000: SELECT command denied to user 'ykk1'@'%' for table 't2'
# ykk3授权给ykk2
GRANT SELECT ON ykk_db1.t1 TO ykk2;
#  查询t1，验证SELECT权限
USE ykk_db1;
SELECT * FROM t1;
c1	c2	c3
SELECT * FROM t2;
ERROR 42000: SELECT command denied to user 'ykk1'@'%' for table 't2'
DROP PROCEDURE RevokeSelectPriv;
CREATE PROCEDURE RevokeSelectPriv()
BEGIN
SET @grantQuery = 'REVOKE SELECT ON ykk_db1.t1 FROM ykk1';
PREPARE stmt FROM @grantQuery;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END;
//
CALL RevokeSelectPriv();
#  查询t1，验证SELECT权限
USE ykk_db1;
ERROR 42000: Access denied for user 'ykk1'@'%' to database 'ykk_db1'
SELECT * FROM ykk_db1.t1;
ERROR 42000: SELECT command denied to user 'ykk1'@'%' for table 't1'
#  查询t1，验证SELECT权限
USE ykk_db1;
SELECT * FROM t1;
c1	c2	c3
