# owner: jianyun.sjy
# owner group: storage
# description: 测试基本的快速迁移逻辑
# tags: fast_migrate

--echo fast_migrate_basic.test start

connection default;
# create table
--disable_warnings
drop table if exists tt;
--enable_warnings

# insert some data and read it
create table tt(a int primary key);
insert into tt values(1);
select * from tt;

# get table_id
connect (obsys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection obsys;
let $table_id = query_get_value(select * from __all_virtual_table where table_name='tt', table_id, 1);

# trigger migrate
--source same_zone_migrate.inc

# read data again
connection default;
select * from tt;

--echo fast_migrate_basic.test finished
