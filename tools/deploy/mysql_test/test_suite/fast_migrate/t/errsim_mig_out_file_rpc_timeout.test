# owner: jianyun.sjy
# owner group: storage
# description: 测试创建migrate_out文件成功但rpc响应超时的异常处理
# tags: fast_migrate

connect (conn1,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection default;
# create table
--disable_warnings
drop table if exists tt;
--enable_warnings
create table tt(a int primary key);
insert into tt values(1);
select * from tt;

# get table_id
connection conn1;
let $table_id = query_get_value(select * from __all_virtual_table where table_name='tt', table_id, 1);

# enable debug_sync
connection conn1;
alter system set debug_sync_timeout = '100000s';
sleep 5;
set ob_global_debug_sync = 'FAST_MIGRATE_AFTER_MIGRATE_OUT_CREATED wait_for continue_signal';
sleep 5;

# trigger migrate
let $timeout = 300;
--source same_zone_migrate.inc

# disable debug_sync
connection conn1;
set ob_global_debug_sync = 'now signal continue_signal';
sleep 5;

# read data again
connection default;
select * from tt;

