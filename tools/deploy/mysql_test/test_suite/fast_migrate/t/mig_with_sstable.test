# owner: jianyun.sjy
# owner group: storage
# description: 测试带有sstable的快速迁移
# tags: fast_migrate

connect (conn1,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

# create table
--disable_warnings
connection default;
drop table if exists tt;
--enable_warnings
create table tt(a int);

# get table_id
connection conn1;
let $table_id = query_get_value(select * from __all_virtual_table where table_name='tt', table_id, 1);

# 测试只有minor sstable的迁移
connection default;
--disable_query_log
let $i = 0;
while ($i < 100) {
  eval insert into tt values($i);
  inc $i;
}
--enable_query_log
select count(*) from tt;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
--source same_zone_migrate.inc
connection default;
select count(*) from tt;

# 测试只有major sstable的迁移
connection default;
--disable_query_log
let $i = 300;
while ($i < 400) {
  eval insert into tt values($i);
  inc $i;
}
--enable_query_log
select count(*) from tt;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source same_zone_migrate.inc
connection default;
select count(*) from tt;

# 测试同时有minor sstable和major sstable的迁移
connection default;
--disable_query_log
let $i = 1000;
while ($i < 1100) {
  eval insert into tt values($i);
  inc $i;
}
--enable_query_log
select count(*) from tt;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
--source same_zone_migrate.inc
connection default;
select count(*) from tt;

# 测试同时有minor sstable和major sstable以及memtable的迁移
connection default;
--disable_query_log
let $i = 2000;
while ($i < 2100) {
  eval insert into tt values($i);
  inc $i;
}
--enable_query_log
select count(*) from tt;
--source same_zone_migrate.inc
connection default;
select count(*) from tt;

# 最后读一遍数据
connection default;
select * from tt;