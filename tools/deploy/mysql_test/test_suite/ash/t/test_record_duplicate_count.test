
#owner:zhangyiqiang.zyq
#owner group: imf
# 测试insert on duplicate key或者replace into时sql_audit当中记录的重复行数是否正确
# 测试sesstat当中记录的insert update和replace into第一次try insert时出现重复的次数是否正确

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
use oceanbase;

# 测试建表是否成功
--disable_warnings
drop table if exists t1;
create table t1(a int primary key, b int, c int);
--enable_warnings
select * from t1;

let $sql_audit=oceanbase.__all_virtual_sql_audit;

# 测试insert on duplicate key未出现冲突时是否错误记录
insert into t1 (a, b, c) values(1, 1, 1);
insert into t1 (a, b, c) values(2, 2, 2) on duplicate key update b = b + 1;
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试insert on duplicate key出现重复但是实际没有更新时的情况。
insert into t1 (a, b, c) values(1, 1, 1) on duplicate key update a = 1, b = 1, c = 1;
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试insert on duplicate key时单行出现冲突是否正确记录
insert into t1 (a, b, c) values(1, 1, 1) on duplicate key update b = b + 1;
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试insert on duplicate key时多行出现冲突是否正确记录
insert into t1 (a, b, c) values(1, 1, 1), (2, 2, 2) on duplicate key update b = b + 1;
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试replace into未出现冲突时是否错误记录
replace into t1 (a, b, c) values(3, 3, 3), (4, 4, 4);
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试replace into主键出现冲突，但是实际没有更新时的情况
replace into t1 (a, b, c) values(3, 3, 3);
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试replace into单行主键出现冲突
replace into t1 (a, b, c) values(3, 3, 1);
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

# 测试replace into多行主键出现冲突
replace into t1 (a, b, c) values(3, 3, 0), (4, 4, 0);
--let $last_trace_id = `select last_trace_id() from DUAL`
--disable_query_log
eval select insert_duplicate_row_count from $sql_audit where trace_id='$last_trace_id';
--enable_query_log

#测试sesstat是否记录了insert update和replace into第一次try insert时出现重复的次数
let $stat_no = query_get_value(select * from __all_virtual_sysstat where name="try insert duplicate count", statistic#, 1);
let $session_id = `select CONNECTION_ID() from DUAL`;
--disable_query_log
eval select value from __all_virtual_sesstat where `STATISTIC#`=$stat_no and session_id = $session_id;
--enable_query_log

disconnect obsys1;