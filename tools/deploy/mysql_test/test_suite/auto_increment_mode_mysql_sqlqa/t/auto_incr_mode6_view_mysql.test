--echo ##混合插入
--echo ##INSERT ... ON DUPLICATE KEY UPDATE 语句
insert into v1_default (a,b,txt) values (1,1,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into v1_default(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from v1_default order by a;
insert into v1_default (a,b,txt) values (150,1,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into v1_default(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from v1_default order by a;

insert into  v2_order (a,b,txt) values (1,2,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
