# owner: zuojiao.hzj
# owner group: sql2
# description: 【Mysql 指定自增列自增模式】 复制表/视图 自增模式，测试场景-DML操作，异常场景
# tags: ddl,dml,auto_increment
# author: whh01047778


purge recyclebin;
--result_format 4
--disable_warnings
--error 0,1396
drop user whh@'%';
drop database if exists whh ;
--enable_warnings
create user whh identified by 'whh';
create database whh ;
grant all on *.* to whh with grant option;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$obmysql_ms0,whh,whh,whh,$obmysql_port);

--echo ##测试每种场合时，起始条件可能不同，可以删除再重新创建表
set sql_mode='strict_all_tables,no_zero_in_date';
alter system set default_auto_increment_mode = 'order';
sleep 4;
--echo ##########################################################################################################################
--echo ###### 标签：auto_incre_1-1，auto_incre_1-5，auto_incre_2，auto_incre_3-1
--echo ###### 功能：数据类型（INT），复制表，自增模式，DML操作 
--echo ########################################################################################################################## 
--echo ##建表
--error 0,1051
drop table table0_date;
create table table0_date (
  a int,
  b int default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(110),(111),(112),(210),(211),(212);

--error 0,1051
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  unique index(a)
);

--error 0,1051
drop table table2_order;
create table table2_order (
  a int not null auto_increment primary key,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a int not null auto_increment primary key,
  b int default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  unique index(a)
) auto_increment_mode = 'noorder';

--echo ############ 复制表 CREATE TABLE ... LIKE 语句
--error 0,1051
drop table like_t1_default;
create table like_t1_default like table1_default;

--error 0,1051
drop table like_t2_order;
create table like_t2_order like table2_order;

--error 0,1051
drop table like_t3_noorder;
create table like_t3_noorder like table3_noorder;

--echo ############ auto_incre_3-1 DML操作 ############
--echo ###### auto_incre_3-1-1 ①INSERT操作 
--echo ##简单插入
--echo ##INSERT 语句
--echo ##like_t1_default
insert into like_t1_default(a) values(null);
insert into like_t1_default(a) values(null),(null),(null);
select txt,a incre_col,b from like_t1_default order by a;

insert into like_t1_default(a) values(10);
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t1_default order by a;

--echo ## like_t2_order
insert into like_t2_order(a) values(null);
insert into like_t2_order(a) values(null),(null),(null);
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t2_order(a) values(10);
insert into  like_t2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t2_order order by a;

--echo ##like_t3_noorder
insert into like_t3_noorder(a) values(null);
insert into like_t3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from like_t3_noorder order by a;

insert into like_t3_noorder(a) values(10);
insert into like_t3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;

--echo ##REPLACE 语句
replace into like_t1_default(a) values(0),(0),(0);
select txt,a incre_col,b from like_t1_default order by a;

replace into  like_t2_order(a) values(0),(0),(0);
select txt,a incre_col,b from like_t2_order order by a;

replace into like_t3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from like_t3_noorder order by a;


--echo ##测试点 - 将任何其他值插入 AUTO_INCREMENT列
--echo ##INSERT 语句
insert into like_t1_default(a) values(15),(-25),(35),(45.5);
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t1_default order by a;

insert into like_t2_order(a) values(15),(-25),(35),(45.5);
insert into  like_t2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t3_noorder(a) values(15),(-25),(35),(45.5);
insert into like_t3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;


--echo ##批量插入
--echo ##INSERT ... SELECT语句
insert into like_t1_default select a,b,txt from table0_date where a <= 200;
select txt,a incre_col,b from like_t1_default order by a;
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t1_default order by a;

insert into  like_t2_order select a,b,txt from table0_date where a <= 200;
select txt,a incre_col,b from like_t2_order order by a;
insert into  like_t2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t3_noorder select a,b,txt from table0_date where a <= 200;
select txt,a incre_col,b from like_t3_noorder order by a;
insert into like_t3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;


--echo ##混合插入
--echo ##INSERT ... ON DUPLICATE KEY UPDATE 语句
insert into like_t1_default (a,b,txt) values (1,1,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into like_t1_default(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t1_default order by a;
insert into like_t1_default (a,b,txt) values (150,1,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into like_t1_default(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t1_default order by a;

insert into  like_t2_order (a,b,txt) values (1,2,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into  like_t2_order(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t2_order order by a;
insert into  like_t2_order (a,b,txt) values (150,2,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into  like_t2_order(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t3_noorder (a,b,txt) values (1,3,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into like_t3_noorder(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t3_noorder order by a;
insert into like_t3_noorder (a,b,txt) values (2000001,3,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into like_t3_noorder(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t3_noorder order by a;


--echo ##将NULL和任何其他值混合插入 AUTO_INCREMENT列
--echo ##INSERT 语句
--error 0,1051
drop table like_t1_default;
create table like_t1_default like table1_default;

--error 0,1051
drop table like_t2_order;
create table like_t2_order like table2_order;

--error 0,1051
drop table like_t3_noorder;
create table like_t3_noorder like table3_noorder;

insert into like_t1_default(a) values(null),(15),(null),(null),(25);
insert into like_t1_default(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t1_default order by a;
insert into like_t1_default(a) values(null),(null),(null),(35);
insert into like_t1_default(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t1_default order by a;

insert into like_t2_order(a) values(null),(15),(null),(null),(25);
insert into  like_t2_order(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t2_order order by a;
insert into like_t2_order(a) values(null),(null),(null),(35);
insert into  like_t2_order(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t3_noorder(a) values(null),(15),(null),(null),(25);
insert into like_t3_noorder(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from like_t3_noorder order by a;
insert into like_t3_noorder(a) values(null),(null),(null),(35);
insert into like_t3_noorder(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from like_t3_noorder order by a;


--echo ###### auto_incre_3-1-2 ②DELETE操作
insert into like_t1_default(a,b) values(null,11);
insert into like_t1_default(a,b) values(null,11);
select txt,a incre_col,b from like_t1_default order by a;
delete from like_t1_default where b=11;
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t1_default order by a;

insert into  like_t2_order(a,b) values(null,22);
insert into  like_t2_order(a,b) values(null,22);
select txt,a incre_col,b from like_t2_order order by a;
delete from  like_t2_order where b=22;
insert into  like_t2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t2_order order by a;

insert into like_t3_noorder(a,b) values(null,33);
insert into like_t3_noorder(a,b) values(null,33);
select txt,a incre_col,b from like_t3_noorder order by a;
delete from like_t3_noorder where b=33;
insert into like_t3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;

--echo ###### auto_incre_3-1-3 ③UPDATE操作
--echo # mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
--echo ##更新现有AUTO_INCREMENT列值
insert into like_t1_default(a,b) values(null,111);
select txt,a incre_col,b from like_t1_default order by a;
update like_t1_default set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 111;
insert into like_t1_default values(null,11,'1当前自增值=>');
select txt,a incre_col,b from like_t1_default order by a;

update like_t1_default set a = 60 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 111;
insert into like_t1_default values(null,11,'2当前自增值=>');
select txt,a incre_col,b from like_t1_default order by a;


insert into  like_t2_order(a,b) values(null,222);
select txt,a incre_col,b from like_t2_order order by a;
update  like_t2_order set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 222;
insert into  like_t2_order values(null,22,'1当前自增值=>');
select txt,a incre_col,b from like_t2_order order by a;

update  like_t2_order set a = 60 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 222;
insert into  like_t2_order values(null,22,'2当前自增值=>');
select txt,a incre_col,b from like_t2_order order by a;


insert into like_t3_noorder(a,b) values(null,333);
select txt,a incre_col,b from like_t3_noorder order by a;
update like_t3_noorder set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 333;
insert into like_t3_noorder values(null,33,'1当前自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;

update like_t3_noorder set a = 1000022 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 333;
insert into like_t3_noorder values(null,33,'2当前自增值=>');
select txt,a incre_col,b from like_t3_noorder order by a;

--echo ##更新其他列值时引用AUTO_INCREMENT列
delete from like_t1_default;
insert into like_t1_default(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from like_t1_default order by a;
update like_t1_default set b = a+1 where txt = 'update';
insert into like_t1_default values(null,11,'当前自增值==>');
select txt,a incre_col,b from like_t1_default order by a;

delete from  like_t2_order;
insert into  like_t2_order(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from like_t2_order order by a;
update  like_t2_order set b = a+2 where txt = 'update';
insert into  like_t2_order values(null,22,'当前自增值==>');
select txt,a incre_col,b from like_t2_order order by a;

delete from like_t3_noorder;
insert into like_t3_noorder(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from like_t3_noorder order by a;
update like_t3_noorder set b = a+3 where txt = 'update';
insert into like_t3_noorder values(null,33,'当前自增值==>');
select txt,a incre_col,b from like_t3_noorder order by a;

--echo ###### auto_incre_3-1-4 ④SELECT操作
select a incre_col from like_t1_default order by a;
select abs(a) from like_t1_default order by a;
select a+b from like_t1_default order by a;

select a incre_col from like_t2_order order by a;
select abs(a) from like_t2_order order by a;
select a+b from like_t2_order order by a;

select a incre_col from like_t3_noorder order by a;
select abs(a) from like_t3_noorder order by a;
select a+b from like_t3_noorder order by a;


--echo ############ auto_incre_2-4 ④模式切换 ############
--echo ##建表
--echo ###### INT 类型，索引 - 唯一索引
set auto_increment_increment=1;
alter system set default_auto_increment_mode = 'order';

--error 0,1051
drop table like_t1_default;
create table like_t1_default like table1_default;

--echo ## ORDER==>ORDER
insert into like_t1_default(a) values(0),(0),(0),(0),(0);
select txt,a incre_col, b from like_t1_default order by a;

alter table like_t1_default auto_increment_mode = 'ORDER';

insert into like_t1_default values(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER');
select txt,a incre_col, b from like_t1_default order by a;

--echo ## ORDER==>NOORDER
alter table like_t1_default auto_increment_mode = 'NOORDER';

insert into like_t1_default values(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER');
select txt,a incre_col, b from like_t1_default order by a;

--echo ## NOORDER==>NOORDER
alter table like_t1_default auto_increment_mode = 'NOORDER';

insert into like_t1_default values(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER');
select txt,a incre_col, b from like_t1_default order by a;

--echo ## NOORDER==>ORDER
alter table like_t1_default auto_increment_mode = 'ORDER';

insert into like_t1_default values(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER');
select txt,a incre_col, b from like_t1_default order by a;

insert into like_t1_default values(0,6,'NOORDER==>ORDER test');
select txt,a incre_col, b from like_t1_default order by a;
update like_t1_default set a = 10 where b = 6;
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col, b from like_t1_default order by a;


--echo ############ 复制表 CREATE TABLE ... AS 语句
--error 0,1051
drop table as_t1_default;
create table as_t1_default as select * from table1_default;
insert into as_t1_default(a) values(0),(0),(0);
select txt,a incre_col,b from as_t1_default order by a;

--error 0,1051
drop table as_t2_order;
create table as_t2_order as select * from table2_order;
insert into as_t2_order(a) values(0),(0),(0);
select txt,a incre_col,b from as_t2_order order by a;

--error 0,1051
drop table as_t3_noorder;
create table as_t3_noorder as select * from table3_noorder;
insert into as_t3_noorder(a) values(0),(0),(0);
select txt,a incre_col,b from as_t3_noorder order by a;


--echo ##########################################################################################################################
--echo ###### 标签：auto_incre_1-1，auto_incre_1-6，auto_incre_2，auto_incre_3-1
--echo ###### 功能：数据类型（INT），视图，自增模式，DML操作 
--echo ########################################################################################################################## 
--echo ##建表
--error 0,1051
drop table table0_date;
create table table0_date (
  a int,
  b int default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(110),(111),(112),(210),(211),(212);

--error 0,1051
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  unique index(a)
);

--error 0,1051
drop table table2_order;
create table table2_order (
  a int not null auto_increment primary key,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a int not null auto_increment primary key,
  b int default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  unique index(a)
) auto_increment_mode = 'noorder';

--echo #单基表视图
--error 0,1051
drop view v1_default;
create view v1_default as select * from table1_default;

--error 0,1051
drop view v2_order;
create view v2_order as select * from table2_order;

--error 0,1051
drop view v3_noorder;
create view v3_noorder as select * from table3_noorder;

