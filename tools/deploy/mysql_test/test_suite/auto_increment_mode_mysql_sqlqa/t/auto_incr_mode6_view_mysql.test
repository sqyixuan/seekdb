insert into  v2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from v2_order order by a;

insert into v3_noorder(a) values(15),(-25),(35),(45.5);
insert into v3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from v3_noorder order by a;

--echo ##批量插入
--echo ##INSERT ... SELECT语句
insert into v1_default select a,b,txt from table0_date where a <= 200;
select txt,a incre_col,b from v1_default order by a;
insert into v1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from v1_default order by a;

insert into  v2_order select a,b,txt from table0_date where a <= 200;
select txt,a incre_col,b from v2_order order by a;
insert into  v2_order(a,txt) values(0,'最新自增值=>');
