--echo #多基表视图
--error 0,1051
drop table table2_order;
create table table2_order (
  a1 int not null auto_increment primary key,
  b1 int default 2,
  txt1 varchar(64) default 'table2_order order模式',
  unique index(a1)
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a2 int not null auto_increment primary key,
  b2 int default 3,
  txt2 varchar(64) default 'table3_noorder noorder模式',
  unique index(a2)
) auto_increment_mode = 'noorder';

--error 0,1051
drop view v1_order;
create view v1_order as select t1.a1,t1.b1,t2.txt1 from table2_order t1 join table2_order t2 on t1.a1=t2.a1;

--error 0,1051
drop view v2_noorder;
create view v2_noorder as select t1.a2,t1.b2,t2.txt2 from table3_noorder t1 join table3_noorder t2 on t1.a2=t2.a2;

--error 0,1051
drop view v3_order_noorder;
create view v3_order_noorder as select t1.a1,t1.b1,t1.txt1,t2.a2,t2.b2,t2.txt2 from table2_order t1 join table3_noorder t2 on t1.a1=t2.a2;


