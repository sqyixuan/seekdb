replace into  v2_order(a) values(0),(0),(0);
select txt,a incre_col,b from v2_order order by a;

replace into v3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from v3_noorder order by a;

--echo ##测试点 - 将任何其他值插入 AUTO_INCREMENT列
--echo ##INSERT 语句
insert into v1_default(a) values(15),(-25),(35),(45.5);
insert into v1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from v1_default order by a;

