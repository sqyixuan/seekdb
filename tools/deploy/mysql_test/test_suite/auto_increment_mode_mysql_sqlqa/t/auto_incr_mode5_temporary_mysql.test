 partition by range(a) 
 subpartition by hash(a) subpartitions 4  
(partition p0 values less than (10),  
 partition p1 values less than (20),  
 partition p2 values less than maxvalue); 

--echo ## ORDER==>ORDER
insert into table2_order(a) values(0),(0),(0),(0);
select txt,a incre_col, b from table2_order order by a;
insert into table2_order values(0,11,'ORDER test1');
update table2_order set a = 4 where b = 11;
insert into table2_order values(null,0,'当前自增值1==>');
select txt,a incre_col, b from table2_order order by a;

alter table table2_order auto_increment_mode = 'ORDER';

insert into table2_order values(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER');
select txt,a incre_col, b from table2_order order by a;
insert into table2_order values(0,22,'ORDER==>ORDER test2');
update table2_order set a = 4 where b = 22;
insert into table2_order values(null,0,'当前自增值2==>');
select txt,a incre_col, b from table2_order order by a;

--echo ## ORDER==>NOORDER
alter table table2_order auto_increment_mode = 'NOORDER';

insert into table2_order values(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER');
select txt,a incre_col, b from table2_order order by a;
insert into table2_order values(0,33,'ORDER==>NOORDE test3');
update table2_order set a = 4 where b = 33;
insert into table2_order values(null,0,'当前自增值3==>');
select txt,a incre_col, b from table2_order order by a;

--echo ## NOORDER==>NOORDER
alter table table2_order auto_increment_mode = 'NOORDER';

insert into table2_order values(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER');
select txt,a incre_col, b from table2_order order by a;
insert into table2_order values(0,44,'NOORDER==>NOORDER test4');
update table2_order set a = 4 where b = 44;
insert into table2_order values(null,0,'当前自增值4==>');
select txt,a incre_col, b from table2_order order by a;

--echo ## NOORDER==>ORDER
alter table table2_order auto_increment_mode = 'ORDER';

insert into table2_order values(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER');
