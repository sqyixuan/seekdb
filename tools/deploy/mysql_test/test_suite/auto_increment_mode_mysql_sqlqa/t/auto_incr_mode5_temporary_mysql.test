insert into table2_order(a) values(null),(null),(null),(null);
select txt,a incre_col,b from table2_order order by a;

insert into table2_order(a) values(6);
insert into table2_order(a,txt) values(0,'1最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

