--echo # mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
--echo ##更新现有AUTO_INCREMENT列值
truncate table table1_default;
insert into table1_default(a) values(0);
insert into table1_default(a,b) values(null,111);
