--source mysql_test/include/backup_spm_var.inc
# owner: zuojiao.hzj
# owner group: sql2
# description: 【Mysql 指定自增列自增模式】 普通表（普通索引，复合索引），自增模式，测试场景-DML操作
# tags: ddl,dml,auto_increment
# author: whh01047778


purge recyclebin;
--result_format 4
--disable_warnings
--error 0,1396
drop user whh@'%';
drop database if exists whh ;
--enable_warnings
create user whh identified by 'whh';
create database whh ;
grant all on *.* to whh with grant option;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$obmysql_ms0,whh,whh,whh,$obmysql_port);

--echo ##测试每种场合时，起始条件可能不同，可以删除再重新创建表
set sql_mode='strict_all_tables,no_zero_in_date';
alter system set default_auto_increment_mode = 'noorder';
sleep 4;
--echo ##########################################################################################################################
--echo ###### 标签：auto_incre_1-1，auto_incre_1-2，auto_incre_2-1，auto_incre_2-2，auto_incre_2-3，auto_incre_3-1
--echo ###### 功能：数据类型（BIGINT、TINYINT），普通表（普通索引，复合索引），自增模式，DML操作 
--echo ########################################################################################################################## 

--echo ############ auto_incre_1-2-1，auto_incre_1-2-2 
--echo ############ 索引 - 普通索引，约束 - 唯一约束
--echo ############ BIGINT 类型 
--echo ##建表
--error 0,1051
drop table table1_default;
--error 0,1051
drop table table2_order;
--error 0,1051
drop table table3_noorder;
--error 0,1051
drop table table0_date;
create table table0_date (
  a bigint unique auto_increment,
  b bigint default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(100),(101),(102),(103),(104),(105);

--error 0,1051
drop table table1_default;
create table table1_default (
  a bigint unique auto_increment,
  b bigint default 1,
  txt varchar(64) default 'table1_default 默认noorder模式',
  index(a)
);

--error 0,1051
drop table table2_order;
create table table2_order (
  a bigint unique auto_increment,
  b bigint default 2,
  txt varchar(64) default 'table2_order order模式',
 index(a)
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a bigint unique auto_increment,
  b bigint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
 index(a)
) auto_increment_mode = 'noorder';


--echo ############ auto_incre_3-1 DML操作 ############
--echo ###### auto_incre_3-1-1 ①INSERT操作 
--echo ##简单插入
--echo ##INSERT 语句
--echo ##table1_default
insert into table1_default(a) values(null);
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a) values(null),(null),(null);
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a) values(10);
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

--echo ##table2_order
insert into table2_order(a) values(null);
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a) values(null),(null),(null);
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a) values(10);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

--echo ##table3_noorder
insert into table3_noorder(a) values(null);
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a) values(10);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;

--echo ##REPLACE 语句
replace into table1_default(a) values(0),(0),(0);
select txt,a incre_col,b from table1_default order by a;
replace into table1_default values(5,22,'replace');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

replace into table2_order(a) values(0),(0),(0);
select txt,a incre_col,b from table2_order order by a;
replace into table2_order values(5,22,'replace');
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

replace into table3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from table3_noorder order by a;
replace into table3_noorder values(5,22,'replace');
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##测试点 - 将任何其他值插入 AUTO_INCREMENT列
--echo ##INSERT 语句
truncate table table1_default;
insert into table1_default(a) values(15),(-25),(35),(45.5);
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

truncate table table2_order;
insert into table2_order(a) values(15),(-25),(35),(45.5);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

truncate table table3_noorder;
insert into table3_noorder(a) values(15),(-25),(35),(45.5);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;

--echo ##REPLACE 语句
replace into table1_default(a,txt) values(3,'new-3'),(-5,'new--5'),(10,'new-10'),(15.5,'new-15.5');
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


replace into table2_order(a,txt) values(3,'new-3'),(-5,'new--5'),(10,'new-10'),(15.5,'new-15.5');
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


replace into table3_noorder(a,txt) values(3,'new-3'),(-5,'new--5'),(10,'new-10'),(15.5,'new-15.5');
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##测试点 - 给AUTO_INCREMENT列插入下一个自增值（当前最大自增值+1），再查看最新自增值
--echo ##INSERT 语句
truncate table table1_default;
insert into table1_default(a) values(0);
insert into table1_default(a,txt) values(2,'插入下一个自增值2（当前最大自增值+1）');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

truncate table table2_order;
insert into table2_order(a) values(0);
insert into table2_order(a,txt) values(2,'插入下一个自增值2（当前最大自增值+1）');
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

truncate table table3_noorder;
insert into table3_noorder(a) values(0);
insert into table3_noorder(a,txt) values(2,'插入下一个自增值2（当前最大自增值+1）');
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;

--echo ##REPLACE 语句
replace into table1_default(a,txt) values(4,'插入下一个自增值4（当前最大自增值+1）');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


replace into table2_order(a,txt) values(4,'插入下一个自增值4（当前最大自增值+1）');
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


replace into table3_noorder(a,txt) values(1000002,'插入下一个自增值2（当前最大自增值+1）');
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##测试点 - 给表插入数据时引用AUTO_INCREMENT列的值
--echo ##INSERT 语句
insert into table1_default values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


insert into table2_order values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


insert into table3_noorder values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##REPLACE 语句
replace into table1_default values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


replace into table2_order values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


replace into table3_noorder values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##批量插入
--echo ##INSERT ... SELECT语句
insert into table1_default select a,b,txt from table0_date where a <= 102;
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


insert into table2_order select a,b,txt from table0_date where a <= 102;
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


insert into table3_noorder select a,b,txt from table0_date where a <= 102;
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##REPLACE ... SELECT语句
replace into table1_default select a,b,txt from table0_date where a >= 102;
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


replace into table2_order select a,b,txt from table0_date where a >= 102;
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


replace into table3_noorder select a,b,txt from table0_date where a >= 102;
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##混合插入
--echo ##INSERT ... ON DUPLICATE KEY UPDATE 语句
insert into table1_default (a,b,txt) values (1,1,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;
insert into table1_default (a,b,txt) values (50,1,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

insert into table2_order (a,b,txt) values (1,2,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;
insert into table2_order (a,b,txt) values (50,2,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

insert into table3_noorder (a,b,txt) values (1,3,'重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder (a,b,txt) values (50,3,'不重复场合') on duplicate key update b=b+1,txt='insert...on duplicate key update 语句';
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##将NULL和任何其他值混合插入 AUTO_INCREMENT列
--echo ##INSERT 语句
insert into table1_default(a) values(null),(10),(null),(20);
insert into table1_default(a,txt) values(0,'最新自增值1=>');
select txt,a incre_col,b from table1_default order by a;


insert into table2_order(a) values(null),(10),(null),(20);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


insert into table3_noorder(a) values(null),(10),(null),(20);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;

--echo ##REPLACE 语句
replace into table1_default(a) values(null),(30),(null),(40);
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


replace into table2_order(a) values(null),(30),(null),(40);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


replace into table3_noorder(a) values(null),(30),(null),(40);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ###### auto_incre_3-1-2 ②DELETE操作
insert into table1_default(a,b) values(null,11);
insert into table1_default(a,b) values(null,11);
select txt,a incre_col,b from table1_default order by a;
delete from table1_default where b=11;

insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

insert into table2_order(a,b) values(null,22);
insert into table2_order(a,b) values(null,22);
select txt,a incre_col,b from table2_order order by a;
delete from table2_order where b=22;

insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

insert into table3_noorder(a,b) values(null,33);
insert into table3_noorder(a,b) values(null,33);
select txt,a incre_col,b from table3_noorder order by a;
delete from table3_noorder where b=33;

insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ###### auto_incre_3-1-3 ③UPDATE操作
--echo # mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
--echo ##更新现有AUTO_INCREMENT列值
truncate table table1_default;
insert into table1_default(a,b) values(null,111);
select txt,a incre_col,b from table1_default order by a;

update table1_default set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 111;

insert into table1_default values(null,11,'1当前自增值=>');
select txt,a incre_col,b from table1_default order by a;


update table1_default set a = 1111111 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 111;
insert into table1_default values(null,11,'2当前自增值=>');
select txt,a incre_col,b from table1_default order by a;

truncate table table2_order;
insert into table2_order(a,b) values(null,222);
select txt,a incre_col,b from table2_order order by a;

update table2_order set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 222;

insert into table2_order values(null,22,'1当前自增值=>');
select txt,a incre_col,b from table2_order order by a;


update table2_order set a = 20 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 222;
insert into table2_order values(null,22,'2当前自增值=>');
select txt,a incre_col,b from table2_order order by a;

truncate table table3_noorder;
insert into table3_noorder(a,b) values(null,333);
select txt,a incre_col,b from table3_noorder order by a;

update table3_noorder set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 333;

insert into table3_noorder values(null,33,'1当前自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


update table3_noorder set a = 20 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 333;
insert into table3_noorder values(null,33,'2当前自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##更新其他列值时引用AUTO_INCREMENT列
delete from table1_default;
insert into table1_default(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from table1_default order by a;

update table1_default set b = a+1 where txt = 'update';
insert into table1_default values(null,11,'当前自增值==>');
select txt,a incre_col,b from table1_default order by a;

delete from table2_order;
insert into table2_order(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from table2_order order by a;

update table2_order set b = a+2 where txt = 'update';
insert into table2_order values(null,22,'当前自增值==>');
select txt,a incre_col,b from table2_order order by a;

delete from table3_noorder;
insert into table3_noorder(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from table3_noorder order by a;

update table3_noorder set b = a+3 where txt = 'update';
insert into table3_noorder values(null,33,'当前自增值==>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ###### auto_incre_3-1-4 ④SELECT操作

select a incre_col from table1_default order by a;
select abs(a) from table1_default order by a;
select a+b from table1_default order by a;



select a incre_col from table2_order order by a;
select abs(a) from table2_order order by a;
select a+b from table2_order order by a;



select a incre_col from table3_noorder order by a;
select abs(a) from table3_noorder order by a;
select a+b from table3_noorder order by a;


--echo ########################################################################################################################## 
--echo ############ auto_incre_1-2-1，auto_incre_1-2-2 
--echo ############ 索引 - 复合索引，约束 - 默认约束 
--echo ############ TINYINT 类型 
alter system set default_auto_increment_mode = 'order';
sleep 4;
--echo ##建表
--error 0,1051
drop table table0_date;
create table table0_date (
  a tinyint not null,
  b tinyint default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(100),(101),(102),(103),(104),(105);
 
--error 0,1051
drop table table1_default;
create table table1_default (
  a tinyint auto_increment,
  b tinyint default 1,
  txt varchar(64) default 'table1_default 默认noorder模式',
  index index_name (a,b)
);

--error 0,1051
drop table table2_order;
create table table2_order (
  a tinyint auto_increment,
  b tinyint default 2,
  txt varchar(64) default 'table2_order order模式',
  index index_name (a,b)
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a tinyint auto_increment,
  b tinyint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  index index_name (a,b)
) auto_increment_mode = 'noorder';

--echo ############ auto_incre_3-1 DML操作 ############
--echo ###### auto_incre_3-1-1 ①INSERT操作 
--echo ##简单插入
--echo ##INSERT 语句
--echo ##table1_default
insert into table1_default(a) values(null);
select txt,a incre_col,b from table1_default order by a;
alter table table1_default AUTO_INCREMENT = 127;
insert into table1_default(a) values(null);
insert into table1_default(a) values(null),(null),(null);
select txt,a incre_col,b from table1_default order by a;
insert into table1_default(a) values(10);
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

--echo ##table2_order
insert into table2_order(a) values(null);
select txt,a incre_col,b from table2_order order by a;
alter table table2_order AUTO_INCREMENT = 127;
insert into table2_order(a) values(null),(null),(null),(null);
select txt,a incre_col,b from table2_order order by a;
insert into table2_order(a) values(10);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

--echo ##table3_noorder
insert into table3_noorder(a) values(null);
select txt,a incre_col,b from table3_noorder order by a;
alter table table3_noorder AUTO_INCREMENT = 127;
insert into table3_noorder(a) values(null),(null),(null),(null);
select txt,a incre_col,b from table3_noorder order by a;
insert into table3_noorder(a) values(10);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ##REPLACE 语句
replace into table1_default(a) values(0),(0),(0);
