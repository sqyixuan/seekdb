--echo ##将NULL和任何其他值混合插入 AUTO_INCREMENT列
--echo ##INSERT 语句
--error 0,1051
drop table table1_default;
create table table1_default (
  a bigint unique auto_increment,
  b bigint default 1,
  txt varchar(64) default 'table1_default 默认noorder模式',
  index(a),
  constraint fk1 foreign key (a) references table0_date(a)on delete cascade
);

--error 0,1051
drop table table2_order;
create table table2_order (
  a bigint unique auto_increment,
  b bigint default 2,
  txt varchar(64) default 'table2_order order模式',
  index(a),
  constraint fk2 foreign key (a) references table0_date(a)on delete cascade
) auto_increment_mode = 'order';

--error 0,1051
drop table table3_noorder;
create table table3_noorder (
  a bigint unique auto_increment,
  b bigint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  index(a),
  constraint fk3 foreign key (a) references table0_date(a)on delete cascade
) auto_increment_mode = 'noorder';


insert into table1_default(a) values(null),(-10),(null),(3);
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;


insert into table2_order(a) values(null),(-10),(null),(3);
insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;


insert into table3_noorder(a) values(null),(-10),(null),(3);
insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ###### auto_incre_3-1-2 ②DELETE操作
insert into table1_default(a,b) values(null,11);
select txt,a incre_col,b from table1_default order by a;
delete from table1_default where b=11;

insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;

insert into table2_order(a,b) values(null,22);
insert into table2_order(a,b) values(null,22);
select txt,a incre_col,b from table2_order order by a;
delete from table2_order where b=22;

insert into table2_order(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table2_order order by a;

insert into table3_noorder(a,b) values(null,33);
insert into table3_noorder(a,b) values(null,33);
select txt,a incre_col,b from table3_noorder order by a;
delete from table3_noorder where b=33;

insert into table3_noorder(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table3_noorder order by a;

--echo ###### auto_incre_3-1-3 ③UPDATE操作
--echo # mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
--echo ##更新现有AUTO_INCREMENT列值
truncate table table1_default;
insert into table1_default(a,b) values(null,111);
update table1_default set a = -10,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 111;
select txt,a incre_col,b from table1_default order by a;
insert into table1_default values(null,11,'1当前自增值=>');
select txt,a incre_col,b from table1_default order by a;
update table1_default set a = 10 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 111;
insert into table1_default values(null,11,'2当前自增值=>');
select txt,a incre_col,b from table1_default order by a;


truncate table table2_order;
insert into table2_order(a,b) values(null,222);
select txt,a incre_col,b from table2_order order by a;
update table2_order set a = -10,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 222;
insert into table2_order values(null,22,'1当前自增值=>');
select txt,a incre_col,b from table2_order order by a;
update table2_order set a = 10 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 222;
insert into table2_order values(null,22,'2当前自增值=>');
select txt,a incre_col,b from table2_order order by a;


truncate table table3_noorder;
insert into table3_noorder(a,b) values(null,333);
select txt,a incre_col,b from table3_noorder order by a;
update table3_noorder set a = -10,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 333;
insert into table3_noorder values(null,33,'1当前自增值=>');
select txt,a incre_col,b from table3_noorder order by a;
update table3_noorder set a = 10 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 333;
insert into table3_noorder values(null,33,'2当前自增值=>');
select txt,a incre_col,b from table3_noorder order by a;


--echo ############ auto_incre_2-4 ④模式切换 ############
--error 0,1051
drop table table1_default;
create table table1_default (
  a bigint auto_increment,
  b bigint default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  index(a),
  constraint fk1 foreign key (a) references table0_date(a)on delete cascade
);

--echo ## ORDER

insert into table1_default(a) values(0),(0),(0);
select txt,a incre_col, b from table1_default order by a;

insert into table1_default values(0,11,'update test');
update table1_default set a = -10 where b = 11;
insert into table1_default values(null,11,'当前自增值1==>');
select txt,a incre_col, b from table1_default order by a;

--echo ## ORDER==>ORDER
alter table table1_default auto_increment_mode = 'ORDER';


insert into table1_default values(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER');
select txt,a incre_col, b from table1_default order by a;

insert into table1_default values(0,22,'update test');
update table1_default set a = -10 where b = 22;
insert into table1_default values(null,22,'当前自增值1==>');
select txt,a incre_col, b from table1_default order by a;

--echo ## ORDER==>NOORDER
alter table table1_default auto_increment_mode = 'NOORDER';


insert into table1_default values(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER');
select txt,a incre_col, b from table1_default order by a;

insert into table1_default values(0,33,'update test');
update table1_default set a = -10 where b = 33;
insert into table1_default values(null,33,'当前自增值1==>');
select txt,a incre_col, b from table1_default order by a;

--echo ## NOORDER==>NOORDER
alter table table1_default auto_increment_mode = 'NOORDER';


insert into table1_default values(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER');
select txt,a incre_col, b from table1_default order by a;

--echo ## NOORDER==>ORDER
alter table table1_default auto_increment_mode = 'ORDER';


insert into table1_default values(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER'),(0,5,'NOORDER==>ORDER');
select txt,a incre_col, b from table1_default order by a;

insert into table1_default values(0,6,'NOORDER==>ORDER test');
select txt,a incre_col, b from table1_default order by a;
update table1_default set a = -10 where b = 6;
insert into table1_default values(null,55,'当前自增值1==>');
select txt,a incre_col, b from table1_default order by a;

