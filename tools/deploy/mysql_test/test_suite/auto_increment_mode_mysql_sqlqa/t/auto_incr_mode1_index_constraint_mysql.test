--echo ###### 设置SAVEPOINT，给AUTO_INCREMENT列插入值后再回滚
--echo ##table1_default
--error 0,1051
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default',
  unique index(a)
);

insert into table1_default(a) values(0),(0),(0),(0),(0);
select txt,a incre_col, b from table1_default order by a;

begin;
  savepoint s1;
  insert into table1_default values(null,100,'s1'),(null,101,'s1'),(null,102,'s1'),(null,103,'s1');
  savepoint s2;
  insert into table1_default values(null,104,'s2'),(null,105,'s2');
  rollback to s2;
  select txt,a incre_col, b from table1_default order by a;
commit;

begin;
  savepoint s11;
  insert into table1_default values(null,110,'s11'),(null,111,'s11'),(null,112,'s11'),(null,113,'s11');
  savepoint s22;
  insert into table1_default values(null,114,'s22'),(null,115,'s22');
  rollback to s11;
  select txt,a incre_col, b from table1_default order by a;
commit;

insert into table1_default values(0,11,'当前自增值==>');
select txt,a incre_col, b from table1_default order by a;

