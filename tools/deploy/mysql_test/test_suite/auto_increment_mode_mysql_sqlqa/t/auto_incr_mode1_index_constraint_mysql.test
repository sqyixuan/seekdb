  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default2',
  unique index(a)
);//


--error 0,1360
drop trigger trg_insert;//
create trigger trg_insert after insert on table1_default2 for each row
begin
  if new.a >2 then
    insert into table1_default1 values(0,new.a,'触发器中insert');
  else
    update table1_default1 set txt = '触发器中update' where a = new.a;
  end if;
end;
//

insert into table1_default2 (a) values(null),(null),(null);//

