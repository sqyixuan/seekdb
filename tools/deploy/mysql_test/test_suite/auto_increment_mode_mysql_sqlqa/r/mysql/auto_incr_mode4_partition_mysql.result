############ auto_incre_2-4 ④模式切换 ############
##建表
drop table table2_order;
create table table2_order (
  a int not null auto_increment,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  index(a)
) auto_increment_mode = 'order' 
partition by hash(a) partitions 4;
## ORDER==>ORDER
insert into table2_order(a) values(0),(0),(0),(0);
select txt,a incre_col, b from table2_order order by a;
+--------------------------+-----------+------+
| txt                      | incre_col | b    |
+--------------------------+-----------+------+
| table2_order order模式   |         1 |    2 |
| table2_order order模式   |         2 |    2 |
| table2_order order模式   |         3 |    2 |
| table2_order order模式   |         4 |    2 |
+--------------------------+-----------+------+
insert into table2_order values(0,11,'update test1');
update table2_order set a = 0 where b = 11;
insert into table2_order values(null,0,'当前自增值1==>');
select txt,a incre_col, b from table2_order order by a;
+--------------------------+-----------+------+
| txt                      | incre_col | b    |
+--------------------------+-----------+------+
| update test1             |         0 |   11 |
| table2_order order模式   |         1 |    2 |
| table2_order order模式   |         2 |    2 |
| table2_order order模式   |         3 |    2 |
| table2_order order模式   |         4 |    2 |
| 当前自增值1==>           |         6 |    0 |
+--------------------------+-----------+------+
alter table table2_order auto_increment_mode = 'ORDER';
insert into table2_order values(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER');
select txt,a incre_col, b from table2_order order by a;
