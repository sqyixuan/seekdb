############ auto_incre_2-4 ④模式切换 ############
##建表
drop table table2_order;
create table table2_order (
  a int auto_increment,
  b int default 2,
  txt varchar(64) default 'table2_order'
) auto_increment_mode = 'order'
 partition by list(a)( 
 partition p0 values in (0,1,2,3,4,5,24,25,27,29),
 partition p1 values in (6,7,8,9,10,23,26,30,32),
 partition p2 values in (11,12,13,14,15,22,31,33),
 partition p3 values in (16,17,18,19,20,21,28,34),
 partition p4 values in (1000001,1000002,1000003,1000004,1000005,1000006,1000007,1000008,1000009,1000010),
 partition p5 values in (1000011,1000012,1000013,1000014,2000001,2000002,2000003,2000004),
 partition p6 values in (2000005,2000006,2000007,2000008,3000001,3000002,3000003,3000004)
);
## ORDER==>ORDER
insert into table2_order(a) values(0),(0),(0),(0);
select txt,a incre_col, b from table2_order order by a;
+--------------+-----------+------+
| txt          | incre_col | b    |
+--------------+-----------+------+
| table2_order |         1 |    2 |
| table2_order |         2 |    2 |
| table2_order |         3 |    2 |
| table2_order |         4 |    2 |
+--------------+-----------+------+
insert into table2_order values(0,11,'update test1');
update table2_order set a = 0 where b = 11;
insert into table2_order values(null,0,'当前自增值1==>');
select txt,a incre_col, b from table2_order order by a;
+---------------------+-----------+------+
| txt                 | incre_col | b    |
+---------------------+-----------+------+
| update test1        |         0 |   11 |
| table2_order        |         1 |    2 |
| table2_order        |         2 |    2 |
| table2_order        |         3 |    2 |
| table2_order        |         4 |    2 |
| 当前自增值1==>      |         6 |    0 |
+---------------------+-----------+------+
