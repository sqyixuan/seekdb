##########################################################################################################################
###### 标签：auto_incre_5
###### 功能：补充场景
##########################################################################################################################
###### 先修改自增列初始值，然后truncate table删除数据，查看自增值
# issue: 42512437 bug2:【auto_increment】order/noorder模式，自增值达到数据类型极限值后，truncate table删除表数据，mysql自增列从头开始计数，ob没有
drop table table1_default;
create table table1_default (
  a int signed auto_increment,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  index(a)
);
insert into table1_default(a) values(null),(null),(null),(null);
select txt,a incre_col,b from table1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |    1 |
| table1_default 默认order模式     |         2 |    1 |
| table1_default 默认order模式     |         3 |    1 |
| table1_default 默认order模式     |         4 |    1 |
+----------------------------------+-----------+------+
alter table table1_default AUTO_INCREMENT = 12345;
truncate table table1_default;
insert into table1_default(a,txt) values(0,'最新自增值2=>');
select txt,a incre_col,b from table1_default order by a;
+--------------------+-----------+------+
| txt                | incre_col | b    |
+--------------------+-----------+------+
| 最新自增值2=>      |         1 |    1 |
+--------------------+-----------+------+
###### 先删除当前最大自增值x，然后修改自增值初始值y(y<=x)
# mysql自增值改变，ob正常递增（没法兼容mysql）
drop table table1_default;
create table table1_default (
  a int signed auto_increment,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  index(a)
);
insert into table1_default(a) values(null),(null),(null),(null),(null);
select txt,a incre_col,b from table1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |    1 |
| table1_default 默认order模式     |         2 |    1 |
| table1_default 默认order模式     |         3 |    1 |
| table1_default 默认order模式     |         4 |    1 |
| table1_default 默认order模式     |         5 |    1 |
+----------------------------------+-----------+------+
delete from table1_default where a >=4;
select txt,a incre_col,b from table1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |    1 |
| table1_default 默认order模式     |         2 |    1 |
| table1_default 默认order模式     |         3 |    1 |
+----------------------------------+-----------+------+
alter table table1_default auto_increment = 4;
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |    1 |
| table1_default 默认order模式     |         2 |    1 |
| table1_default 默认order模式     |         3 |    1 |
| 最新自增值=>                     |         4 |    1 |
+----------------------------------+-----------+------+
###### 事务中先插入数据，更新自增值大于当前自增值，然后回滚事务，查看自增值
SET @@AUTOCOMMIT=0;
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default',
  unique index(a)
);
insert into table1_default(a) values(0),(0),(0);
select txt,a incre_col, b from table1_default order by a;
+----------------+-----------+------+
| txt            | incre_col | b    |
+----------------+-----------+------+
| table1_default |         1 |    1 |
| table1_default |         2 |    1 |
| table1_default |         3 |    1 |
+----------------+-----------+------+
begin;
insert into table1_default values(0,11,'事务中插入数据'),(0,22,'事务中插入数据'),(0,33,'事务中插入数据');
update table1_default set a=10 ,txt = '事务中修改数据' where b=33;
select txt,a incre_col, b from table1_default order by a;
+-----------------------+-----------+------+
| txt                   | incre_col | b    |
+-----------------------+-----------+------+
| table1_default        |         1 |    1 |
| table1_default        |         2 |    1 |
| table1_default        |         3 |    1 |
| 事务中插入数据        |         4 |   11 |
| 事务中插入数据        |         5 |   22 |
| 事务中修改数据        |        10 |   33 |
+-----------------------+-----------+------+
rollback;
insert into table1_default values(0,11,'当前自增值==>');
select txt,a incre_col, b from table1_default order by a;
+--------------------+-----------+------+
| txt                | incre_col | b    |
+--------------------+-----------+------+
| table1_default     |         1 |    1 |
| table1_default     |         2 |    1 |
| table1_default     |         3 |    1 |
| 当前自增值==>      |         7 |   11 |
+--------------------+-----------+------+
drop table table1_default;
drop table table2_order;
drop table table3_noorder;
drop table table0_date;
# Clean up users
drop user whh@'%';
drop database if exists whh ;
