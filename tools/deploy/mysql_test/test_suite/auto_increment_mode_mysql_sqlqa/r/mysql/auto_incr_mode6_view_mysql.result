############ auto_incre_2-4 ④模式切换 ############
##建表
set auto_increment_increment=1;
alter system set default_auto_increment_mode = 'order';
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  unique index(a)
);
drop view v1_default;
create view v1_default as select * from table1_default;
## ORDER
insert into v1_default(a) values(0),(0),(0),(0),(0);
select txt,a incre_col, b from v1_default order by a;
