##更新其他列值时引用AUTO_INCREMENT列
delete from v1_default;
insert into v1_default(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from v1_default order by a;
+--------+-----------+------+
| txt    | incre_col | b    |
+--------+-----------+------+
| update |        43 |    0 |
+--------+-----------+------+
update v1_default set b = a+1 where txt = 'update';
insert into v1_default values(null,11,'当前自增值==>');
select txt,a incre_col,b from v1_default order by a;
+--------------------+-----------+------+
| txt                | incre_col | b    |
+--------------------+-----------+------+
| update             |        43 |   44 |
| 当前自增值==>      |        44 |   11 |
+--------------------+-----------+------+
delete from  v2_order;
insert into  v2_order(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from v2_order order by a;
+--------+-----------+------+
| txt    | incre_col | b    |
+--------+-----------+------+
| update |        43 |    0 |
+--------+-----------+------+
update  v2_order set b = a+2 where txt = 'update';
insert into  v2_order values(null,22,'当前自增值==>');
select txt,a incre_col,b from v2_order order by a;
