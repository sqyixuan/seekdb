#多基表视图
drop table table2_order;
create table table2_order (
  a1 int not null auto_increment primary key,
  b1 int default 2,
  txt1 varchar(64) default 'table2_order order模式',
  unique index(a1)
) auto_increment_mode = 'order';
drop table table3_noorder;
create table table3_noorder (
  a2 int not null auto_increment primary key,
  b2 int default 3,
  txt2 varchar(64) default 'table3_noorder noorder模式',
  unique index(a2)
) auto_increment_mode = 'noorder';
drop view v1_order;
create view v1_order as select t1.a1,t1.b1,t2.txt1 from table2_order t1 join table2_order t2 on t1.a1=t2.a1;
drop view v2_noorder;
create view v2_noorder as select t1.a2,t1.b2,t2.txt2 from table3_noorder t1 join table3_noorder t2 on t1.a2=t2.a2;
drop view v3_order_noorder;
create view v3_order_noorder as select t1.a1,t1.b1,t1.txt1,t2.a2,t2.b2,t2.txt2 from table2_order t1 join table3_noorder t2 on t1.a1=t2.a2;
##简单插入
##INSERT 语句
# 不能通过连接视图修改多个基表，不能测试
insert into v1_order(a1) values(0),(0),(0);
ERROR HY000: The target table v1_order of the INSERT is not insertable-into
select txt1,a1 incre_col,b1 from v1_order order by a1;
+------+-----------+------+
| txt1 | incre_col | b1   |
+------+-----------+------+
+------+-----------+------+
insert into v2_noorder(a2) values(0),(0),(0);
ERROR HY000: The target table v2_noorder of the INSERT is not insertable-into
select txt2,a2 incre_col,b2 from v2_noorder order by a2;
+------+-----------+------+
| txt2 | incre_col | b2   |
+------+-----------+------+
+------+-----------+------+
insert into v3_order_noorder(a1,a2) values(0),(0),(0);
ERROR HY000: Can not modify more than one base table through a join view 'whh.v3_order_noorder'
select txt1,a1 incre_col1,b1,txt2,a2 incre_col2,b2 from v3_order_noorder order by a1;
+------+------------+------+------+------------+------+
| txt1 | incre_col1 | b1   | txt2 | incre_col2 | b2   |
+------+------------+------+------+------------+------+
+------+------------+------+------+------------+------+
##########################################################################################################################
###### 标签：auto_incre_4
###### 功能：异常场景
##表有多个AUTO_INCREMENT列
drop table table2_order;
create table table2_order (
  a int not null auto_increment primary key,
  b int auto_increment,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order';
ERROR 42000: Incorrect table definition; there can be only one auto column
drop table table3_noorder;
create table table3_noorder (
  a int not null auto_increment primary key,
  b int auto_increment,
  txt varchar(64) default 'table3_noorder noorder模式',
  unique index(a)
) auto_increment_mode = 'noorder';
ERROR 42000: Incorrect table definition; there can be only one auto column
##表中AUTO_INCREMENT列设置 DEFAULT值
drop table table2_order;
create table table2_order (
  a int not null auto_increment default 1,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order';
ERROR 42000: Invalid default value for 'a'
drop table table3_noorder;
create table table3_noorder (
  a int not null auto_increment default 1,
  b int default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  unique index(a)
) auto_increment_mode = 'noorder';
ERROR 42000: Invalid default value for 'a'
##表中AUTO_INCREMENT列定义为某个索引的非第一列
##echo # mysql不支持，ob支持
drop table table1_default;
create table table1_default (
  a tinyint auto_increment,
  b tinyint default 1,
  txt varchar(64) default 'table1_default 默认noorder模式',
  index index_name (b,a)
);
insert into table1_default(a) values(null),(null),(null);
select txt,a incre_col,b from table1_default order by a;
+------------------------------------+-----------+------+
| txt                                | incre_col | b    |
+------------------------------------+-----------+------+
| table1_default 默认noorder模式     |         1 |    1 |
| table1_default 默认noorder模式     |         2 |    1 |
| table1_default 默认noorder模式     |         3 |    1 |
+------------------------------------+-----------+------+
drop table table2_order;
create table table2_order (
  a tinyint auto_increment,
  b tinyint default 2,
  txt varchar(64) default 'table2_order order模式',
  index index_name (b,a)
) auto_increment_mode = 'order';
insert into table2_order(a) values(null),(null),(null);
select txt,a incre_col,b from table2_order order by a;
+--------------------------+-----------+------+
| txt                      | incre_col | b    |
+--------------------------+-----------+------+
| table2_order order模式   |         1 |    2 |
| table2_order order模式   |         2 |    2 |
| table2_order order模式   |         3 |    2 |
+--------------------------+-----------+------+
drop table table3_noorder;
create table table3_noorder (
  a tinyint auto_increment,
  b tinyint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  index index_name (b,a)
) auto_increment_mode = 'noorder';
insert into table3_noorder(a) values(null),(null),(null);
select txt,a incre_col,b from table3_noorder order by a;
+------------------------------+-----------+------+
| txt                          | incre_col | b    |
+------------------------------+-----------+------+
| table3_noorder noorder模式   |         1 |    3 |
| table3_noorder noorder模式   |         2 |    3 |
| table3_noorder noorder模式   |         3 |    3 |
+------------------------------+-----------+------+
##生成列引用AUTO_INCREMENT列
drop table table2_order;
create table table2_order (
  a tinyint auto_increment,
  b tinyint default 2,
  c INT GENERATED ALWAYS AS (a + b) STORED,
  txt varchar(64) default 'table2_order order模式',
  index index_name (a)
) auto_increment_mode = 'order';
ERROR 0A000: generated column refer to auto-increment column not supported
drop table table3_noorder;
create table table3_noorder (
  a tinyint auto_increment,
  b tinyint default 3,
  c INT GENERATED ALWAYS AS (a + b) STORED,
  txt varchar(64) default 'table3_noorder noorder模式',
  index index_name (a)
) auto_increment_mode = 'noorder';
ERROR 0A000: generated column refer to auto-increment column not supported
##检查约束引用AUTO_INCREMENT列
drop table table2_order;
create table table2_order (
  a tinyint auto_increment,
  b tinyint default 2,
  txt varchar(64) default 'table2_order order模式',
  index index_name (a),
  check (a > b)
) auto_increment_mode = 'order';
ERROR HY000: Check constraint cannot refer to an auto-increment column.
drop table table3_noorder;
create table table3_noorder (
  a tinyint auto_increment,
  b tinyint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  index index_name (a),
  check (a > b)
) auto_increment_mode = 'noorder';
ERROR HY000: Check constraint cannot refer to an auto-increment column.
