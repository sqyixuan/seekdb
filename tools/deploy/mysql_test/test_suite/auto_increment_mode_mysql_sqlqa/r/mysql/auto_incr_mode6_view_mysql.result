purge recyclebin;
result_format: 4
drop user whh@'%';
drop database if exists whh ;
create user whh identified by 'whh';
create database whh ;
grant all on *.* to whh with grant option;


##测试每种场合时，起始条件可能不同，可以删除再重新创建表
set sql_mode='strict_all_tables,no_zero_in_date';
alter system set default_auto_increment_mode = 'order';
##########################################################################################################################
###### 标签：auto_incre_1-1，auto_incre_1-5，auto_incre_2，auto_incre_3-1
###### 功能：数据类型（INT），复制表，自增模式，DML操作 
########################################################################################################################## 
##建表
drop table table0_date;
create table table0_date (
  a int,
  b int default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(110),(111),(112),(210),(211),(212);
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  unique index(a)
);
drop table table2_order;
create table table2_order (
  a int not null auto_increment primary key,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order';
drop table table3_noorder;
create table table3_noorder (
  a int not null auto_increment primary key,
  b int default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  unique index(a)
) auto_increment_mode = 'noorder';
############ 复制表 CREATE TABLE ... LIKE 语句
drop table like_t1_default;
create table like_t1_default like table1_default;
drop table like_t2_order;
create table like_t2_order like table2_order;
drop table like_t3_noorder;
create table like_t3_noorder like table3_noorder;
############ auto_incre_3-1 DML操作 ############
###### auto_incre_3-1-1 ①INSERT操作 
##简单插入
##INSERT 语句
##like_t1_default
insert into like_t1_default(a) values(null);
insert into like_t1_default(a) values(null),(null),(null);
select txt,a incre_col,b from like_t1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |    1 |
| table1_default 默认order模式     |         2 |    1 |
| table1_default 默认order模式     |         3 |    1 |
| table1_default 默认order模式     |         4 |    1 |
+----------------------------------+-----------+------+
insert into like_t1_default(a) values(10);
insert into like_t1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from like_t1_default order by a;
