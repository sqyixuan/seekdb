| txt                | incre_col | b    |
+--------------------+-----------+------+
| update             |        43 |   45 |
| 当前自增值==>      |        44 |   22 |
+--------------------+-----------+------+
delete from v3_noorder;
insert into v3_noorder(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from v3_noorder order by a;
+--------+-----------+------+
| txt    | incre_col | b    |
+--------+-----------+------+
| update |   1000016 |    0 |
+--------+-----------+------+
update v3_noorder set b = a+3 where txt = 'update';
insert into v3_noorder values(null,33,'当前自增值==>');
select txt,a incre_col,b from v3_noorder order by a;
+--------------------+-----------+---------+
| txt                | incre_col | b       |
+--------------------+-----------+---------+
| update             |   1000016 | 1000019 |
| 当前自增值==>      |   1000017 |      33 |
+--------------------+-----------+---------+
