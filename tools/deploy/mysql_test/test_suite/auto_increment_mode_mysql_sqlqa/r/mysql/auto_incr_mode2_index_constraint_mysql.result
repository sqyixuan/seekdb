##测试点 - 给表插入数据时引用AUTO_INCREMENT列的值
##INSERT 语句
insert into table1_default values(null,a*2,'引用AUTO_INCREMENT列的值');
insert into table1_default(a,txt) values(0,'最新自增值=>');
select txt,a incre_col,b from table1_default order by a;
+--------------------------------------------------------+-----------+---------+
| txt                                                    | incre_col | b       |
