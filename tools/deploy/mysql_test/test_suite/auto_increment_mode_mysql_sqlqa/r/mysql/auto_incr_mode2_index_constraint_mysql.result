insert into table2_order(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from table2_order order by a;
+--------+-----------+------+
| txt    | incre_col | b    |
+--------+-----------+------+
| update |         4 |    0 |
+--------+-----------+------+
update table2_order set b = a+2 where txt = 'update';
insert into table2_order values(null,22,'当前自增值==>');
select txt,a incre_col,b from table2_order order by a;
+--------------------+-----------+------+
| txt                | incre_col | b    |
+--------------------+-----------+------+
| update             |         4 |    6 |
| 当前自增值==>      |         5 |   22 |
+--------------------+-----------+------+
delete from table3_noorder;
insert into table3_noorder(a,b,txt) values(null,0,'update');
select txt,a incre_col,b from table3_noorder order by a;
+--------+-----------+------+
| txt    | incre_col | b    |
+--------+-----------+------+
| update |         4 |    0 |
+--------+-----------+------+
update table3_noorder set b = a+3 where txt = 'update';
insert into table3_noorder values(null,33,'当前自增值==>');
select txt,a incre_col,b from table3_noorder order by a;
+--------------------+-----------+------+
| txt                | incre_col | b    |
