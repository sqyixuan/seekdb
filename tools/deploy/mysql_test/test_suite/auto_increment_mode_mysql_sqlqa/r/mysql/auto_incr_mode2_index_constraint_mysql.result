+--------+
| abs(a) |
+--------+
|      4 |
|      5 |
+--------+
select a+b from table1_default order by a;
+------+
| a+b  |
+------+
|    9 |
|   16 |
+------+
select a incre_col from table2_order order by a;
+-----------+
| incre_col |
+-----------+
|         4 |
|         5 |
+-----------+
select abs(a) from table2_order order by a;
+--------+
| abs(a) |
+--------+
|      4 |
|      5 |
+--------+
select a+b from table2_order order by a;
+------+
| a+b  |
+------+
|   10 |
|   27 |
+------+
select a incre_col from table3_noorder order by a;
+-----------+
| incre_col |
+-----------+
|         4 |
|         5 |
+-----------+
select abs(a) from table3_noorder order by a;
+--------+
| abs(a) |
+--------+
|      4 |
|      5 |
+--------+
