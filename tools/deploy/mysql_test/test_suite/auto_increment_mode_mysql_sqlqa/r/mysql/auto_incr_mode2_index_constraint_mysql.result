############ auto_incre_1-2-1，auto_incre_1-2-2 
############ 索引 - 普通索引，约束 - 外键约束
############ BIGINT 类型 
##建表
drop table table1_default;
drop table table2_order;
drop table table3_noorder;
drop table table0_date;
create table table0_date (
  a bigint unique auto_increment,
  b bigint default 0,
  txt varchar(64) default 'table0_date'
);
insert into table0_date(a) values(-10),(1),(2),(3),(4),(5),(6),(7),(8),(9);
insert into table0_date(a) values(10),(11),(12),(13),(14),(15),(16),(17),(50),(51);
insert into table0_date(a) values(1000001),(1000002),(1000003),(1000004),(1000005),(1000006),(1000007),(1000008);
insert into table0_date(a) values(2000001),(2000002),(2000003),(2000004),(2000005),(2000006),(2000007),(2000008);
insert into table0_date(a) values(3000001),(3000002),(3000003),(3000004),(3000005),(3000006),(3000007),(3000008);
drop table table1_default;
create table table1_default (
  a bigint unique auto_increment,
  b bigint default 1,
  txt varchar(64) default 'table1_default 默认noorder模式',
  index(a),
  constraint fk1 foreign key (a) references table0_date(a)on delete cascade
);
drop table table2_order;
create table table2_order (
  a bigint unique auto_increment,
  b bigint default 2,
  txt varchar(64) default 'table2_order order模式',
  index(a),
  constraint fk2 foreign key (a) references table0_date(a)on delete cascade
) auto_increment_mode = 'order';
drop table table3_noorder;
create table table3_noorder (
  a bigint unique auto_increment,
  b bigint default 3,
  txt varchar(64) default 'table3_noorder noorder模式',
  index(a),
  constraint fk3 foreign key (a) references table0_date(a)on delete cascade
) auto_increment_mode = 'noorder';
############ auto_incre_3-1 DML操作 ############
###### auto_incre_3-1-1 ①INSERT操作 
##简单插入
##INSERT 语句 
##table1_default
insert into table1_default(a) values(null),(null),(null);
