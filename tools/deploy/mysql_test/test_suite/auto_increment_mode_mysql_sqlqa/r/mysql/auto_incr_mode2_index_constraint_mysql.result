###### auto_incre_3-1-3 ③UPDATE操作
# mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
##更新现有AUTO_INCREMENT列值
truncate table table1_default;
insert into table1_default(a,b) values(null,111);
update table1_default set a = -10,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 111;
select txt,a incre_col,b from table1_default order by a;
+--------------------------------------------------------------------------+-----------+------+
| txt                                                                      | incre_col | b    |
+--------------------------------------------------------------------------+-----------+------+
| 将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值                    |       -10 |  111 |
+--------------------------------------------------------------------------+-----------+------+
insert into table1_default values(null,11,'1当前自增值=>');
select txt,a incre_col,b from table1_default order by a;
+--------------------------------------------------------------------------+-----------+------+
| txt                                                                      | incre_col | b    |
+--------------------------------------------------------------------------+-----------+------+
| 将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值                    |       -10 |  111 |
| 1当前自增值=>                                                            |         2 |   11 |
+--------------------------------------------------------------------------+-----------+------+
update table1_default set a = 10 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 111;
insert into table1_default values(null,11,'2当前自增值=>');
select txt,a incre_col,b from table1_default order by a;
+-------------------------------------------------------------------+-----------+------+
| txt                                                               | incre_col | b    |
+-------------------------------------------------------------------+-----------+------+
| 1当前自增值=>                                                     |         2 |   11 |
| 2当前自增值=>                                                     |         3 |   11 |
| 将AUTO_INCREMENT列值设置为大于当前最大自增值的值                  |        10 |  111 |
+-------------------------------------------------------------------+-----------+------+
