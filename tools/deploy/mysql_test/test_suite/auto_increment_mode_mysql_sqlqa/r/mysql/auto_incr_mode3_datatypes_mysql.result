############ auto_incre_2-4 в‘ЈжЁЎејҸеҲҮжҚў ############
##е»әиЎЁ
drop table table2_order;
create table table2_order (
  a smallint auto_increment primary key,
  b smallint default 2,
  txt varchar(64) default 'table2_order'
) auto_increment_mode = 'order';
## ORDER==>ORDER
insert into table2_order(a) values(0),(0),(0),(0),(0);
select txt,a incre_col, b from table2_order order by a;
+--------------+-----------+------+
| txt          | incre_col | b    |
+--------------+-----------+------+
| table2_order |         1 |    2 |
| table2_order |         2 |    2 |
| table2_order |         3 |    2 |
| table2_order |         4 |    2 |
| table2_order |         5 |    2 |
+--------------+-----------+------+
alter table table2_order auto_increment_mode = 'ORDER';
insert into table2_order values(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER'),(0,2,'ORDER==>ORDER');
select txt,a incre_col, b from table2_order order by a;
+---------------+-----------+------+
| txt           | incre_col | b    |
+---------------+-----------+------+
| table2_order  |         1 |    2 |
| table2_order  |         2 |    2 |
| table2_order  |         3 |    2 |
| table2_order  |         4 |    2 |
| table2_order  |         5 |    2 |
| ORDER==>ORDER |         6 |    2 |
| ORDER==>ORDER |         7 |    2 |
| ORDER==>ORDER |         8 |    2 |
| ORDER==>ORDER |         9 |    2 |
+---------------+-----------+------+
## ORDER==>NOORDER
alter table table2_order auto_increment_mode = 'NOORDER';
insert into table2_order values(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER'),(0,3,'ORDER==>NOORDER');
ERROR 23000: Duplicate entry '32767' for key 'PRIMARY'
