| txt           | incre_col | b    |
+---------------+-----------+------+
| table2_order  |         1 |    2 |
| table2_order  |         2 |    2 |
| table2_order  |         3 |    2 |
| table2_order  |         4 |    2 |
| table2_order  |         5 |    2 |
| ORDER==>ORDER |         6 |    2 |
| ORDER==>ORDER |         7 |    2 |
| ORDER==>ORDER |         8 |    2 |
| ORDER==>ORDER |         9 |    2 |
+---------------+-----------+------+
## NOORDER==>NOORDER
alter table table2_order auto_increment_mode = 'NOORDER';
insert into table2_order values(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER'),(0,4,'NOORDER==>NOORDER');
ERROR 23000: Duplicate entry '32767' for key 'PRIMARY'
