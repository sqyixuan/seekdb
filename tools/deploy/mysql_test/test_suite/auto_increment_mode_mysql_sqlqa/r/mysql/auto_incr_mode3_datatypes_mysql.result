##INSERT ... ON DUPLICATE KEY UPDATE иҜӯеҸҘ
drop table table1_default;
create table table1_default (
  a mediumint auto_increment,
  b mediumint default 1,
  txt varchar(64) default 'table1_default',
  index (a)
);
insert into table1_default (a) values (0);
drop table table2_order;
create table table2_order (
  a mediumint auto_increment,
  b mediumint default 2,
  txt varchar(64) default 'table2_order',
  index (a)
) auto_increment_mode = 'order';
insert into table2_order (a) values (0);
drop table table3_noorder;
create table table3_noorder (
  a mediumint auto_increment,
  b mediumint default 3,
  txt varchar(64) default 'table3_noorder',
  index (a)
) auto_increment_mode = 'noorder';
insert into table3_noorder (a) values (0);
insert into table1_default (a,b,txt) values (1,1,'йҮҚеӨҚеңәеҗҲ') on duplicate key update b=b+1,txt='insert...on duplicate key update иҜӯеҸҘ';
insert into table1_default(a,txt) values(0,'жңҖж–°иҮӘеўһеҖј=>');
