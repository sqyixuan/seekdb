| table1_default |         1 |  111 |
+----------------+-----------+------+
update table1_default set a = 0,txt = 'е°ҶAUTO_INCREMENTеҲ—еҖји®ҫзҪ®дёәе°ҸдәҺ/зӯүдәҺеҪ“еүҚжңҖеӨ§иҮӘеўһеҖјзҡ„еҖј' where b = 111;
