###### auto_incre_3-1-3 в‘ўUPDATEж“ҚдҪң
# mysql 5.x updateжІЎжңүжҺЁй«ҳиҝҷдёӘиҮӘеўһеҖјпјҢе’ҢжҲ‘д»¬зҺ°еңЁжҳҜе…је®№зҡ„пјӣ8.x updateдјҡжҺЁй«ҳ
##жӣҙж–°зҺ°жңүAUTO_INCREMENTеҲ—еҖј
##table1_default
truncate table table1_default;
