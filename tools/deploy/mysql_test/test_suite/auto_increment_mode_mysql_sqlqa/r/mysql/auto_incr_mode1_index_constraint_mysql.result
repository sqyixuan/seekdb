############ auto_incre_3-3 PL/SQL操作 ############
###### auto_incre_3-3-1 函数 
##table1_default
drop table table1_default;//
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default',
  unique index(a)
);//
DROP FUNCTION fun1;//
CREATE FUNCTION fun1() RETURNS VARCHAR(100)
BEGIN  
  insert into table1_default values(null,1,'函数 insert1'),(null,2,'函数 insert1'),(null,3,'函数 insert1');
  
  delete from table1_default where b = 2;
  insert into table1_default values(null,11,'delete后当前自增值1==>');

  update table1_default set txt = '函数 update' where b = 3;
  insert into table1_default values(null,11,'update后当前自增值2==>');
  RETURN 'fun1 ok';
END;
//
select txt,a incre_col,b from table1_default order by a;//
+------+-----------+------+
| txt  | incre_col | b    |
+------+-----------+------+
+------+-----------+------+
SELECT fun1();//
+---------+
| fun1()  |
+---------+
| fun1 ok |
+---------+
select txt,a incre_col, b from table1_default order by a;//
+------------------------------+-----------+------+
| txt                          | incre_col | b    |
+------------------------------+-----------+------+
| 函数 insert1                 |         1 |    1 |
| 函数 update                  |         3 |    3 |
| delete后当前自增值1==>       |         4 |   11 |
| update后当前自增值2==>       |         5 |   11 |
+------------------------------+-----------+------+
