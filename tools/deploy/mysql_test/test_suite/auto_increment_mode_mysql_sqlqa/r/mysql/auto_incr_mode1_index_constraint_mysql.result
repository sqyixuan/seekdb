############ auto_incre_2-4 ④模式切换 ############
##建表
###### INT 类型，索引 - 唯一索引
set auto_increment_increment=1;
alter system set default_auto_increment_mode = 'order';
drop table table1_default;
create table table1_default (
  a int not null auto_increment,
  b int default 1,
  txt varchar(64) default 'table1_default',
  index(a)
);
## ORDER
insert into table1_default(a) values(0),(0),(0),(0),(0);
select txt,a incre_col, b from table1_default order by a;
+----------------+-----------+------+
| txt            | incre_col | b    |
+----------------+-----------+------+
| table1_default |         1 |    1 |
| table1_default |         2 |    1 |
| table1_default |         3 |    1 |
| table1_default |         4 |    1 |
| table1_default |         5 |    1 |
+----------------+-----------+------+
insert into table1_default values(0,11,'update test');
update table1_default set a = 0 where b = 11;
insert into table1_default values(null,11,'当前自增值1==>');
select txt,a incre_col, b from table1_default order by a;
+---------------------+-----------+------+
| txt                 | incre_col | b    |
+---------------------+-----------+------+
| update test         |         0 |   11 |
| table1_default      |         1 |    1 |
| table1_default      |         2 |    1 |
| table1_default      |         3 |    1 |
| table1_default      |         4 |    1 |
| table1_default      |         5 |    1 |
| 当前自增值1==>      |         7 |   11 |
+---------------------+-----------+------+
