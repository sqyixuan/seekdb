###### auto_incre_3-3-3 存储过程 
##table1_default
drop table table1_default;//
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default',
  unique index(a)
);//
DROP PROCEDURE pro1;//
CREATE PROCEDURE pro1()
BEGIN
   insert into table1_default(a,b) values(0,1),(0,1),(0,11),(0,22),(0,1);
   delete from table1_default where b=11;
   update table1_default set txt = '存储过程中update' where b=22;
   insert into table1_default values(0,1,'最新自增值');
END;
//
call pro1()//
select txt,a incre_col, b from table1_default order by a;//
+-----------------------+-----------+------+
| txt                   | incre_col | b    |
+-----------------------+-----------+------+
| table1_default        |         1 |    1 |
| table1_default        |         2 |    1 |
| 存储过程中update      |         4 |   22 |
| table1_default        |         5 |    1 |
| 最新自增值            |         6 |    1 |
+-----------------------+-----------+------+
