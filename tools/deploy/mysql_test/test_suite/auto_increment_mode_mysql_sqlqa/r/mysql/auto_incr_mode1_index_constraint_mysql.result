###### auto_incre_3-3-2 触发器 
##table1_default1
drop table table1_default1;//
create table table1_default1 (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default1',
  unique index(a)
);//
insert into table1_default1(a) values(0),(0),(0),(0),(0);//
drop table table1_default2;//
create table table1_default2 (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default2',
  unique index(a)
);//
drop trigger trg_insert;//
create trigger trg_insert after insert on table1_default2 for each row
begin
  if new.a >2 then
    insert into table1_default1 values(0,new.a,'触发器中insert');
  else
    update table1_default1 set txt = '触发器中update' where a = new.a;
  end if;
end;
//
insert into table1_default2 (a) values(null),(null),(null);//
select txt,a incre_col, b from table1_default1 order by a;//
+--------------------+-----------+------+
| txt                | incre_col | b    |
+--------------------+-----------+------+
| 触发器中update     |         1 |    1 |
| 触发器中update     |         2 |    1 |
| table1_default1    |         3 |    1 |
| table1_default1    |         4 |    1 |
| table1_default1    |         5 |    1 |
| 触发器中insert     |         6 |    3 |
+--------------------+-----------+------+
select txt,a incre_col, b from table1_default2 order by a;//
+-----------------+-----------+------+
| txt             | incre_col | b    |
+-----------------+-----------+------+
| table1_default2 |         1 |    1 |
| table1_default2 |         2 |    1 |
| table1_default2 |         3 |    1 |
+-----------------+-----------+------+
