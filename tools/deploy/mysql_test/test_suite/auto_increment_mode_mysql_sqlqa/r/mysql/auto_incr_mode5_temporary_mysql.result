###### auto_incre_3-1-3 ③UPDATE操作
# mysql 5.x update没有推高这个自增值，和我们现在是兼容的；8.x update会推高
##更新现有AUTO_INCREMENT列值
drop table table1_default;
create table table1_default (
  a int not null auto_increment primary key,
  b int default 1,
  txt varchar(64) default 'table1_default 默认order模式',
  unique index(a)
) partition by range(a) 
 subpartition by hash(a) subpartitions 4  
(partition p0 values less than (10),  
 partition p1 values less than (20),  
 partition p2 values less than maxvalue);
insert into table1_default(a,b) values(null,111);
select txt,a incre_col,b from table1_default order by a;
+----------------------------------+-----------+------+
| txt                              | incre_col | b    |
+----------------------------------+-----------+------+
| table1_default 默认order模式     |         1 |  111 |
+----------------------------------+-----------+------+
update table1_default set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 111;
insert into table1_default values(null,11,'1当前自增值=>');
select txt,a incre_col,b from table1_default order by a;
+--------------------------------------------------------------------------+-----------+------+
| txt                                                                      | incre_col | b    |
+--------------------------------------------------------------------------+-----------+------+
| 将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值                    |         0 |  111 |
| 1当前自增值=>                                                            |         2 |   11 |
+--------------------------------------------------------------------------+-----------+------+
update table1_default set a = 30 ,txt = '将AUTO_INCREMENT列值设置为大于当前最大自增值的值' where b = 111;
insert into table1_default values(null,11,'2当前自增值=>');
select txt,a incre_col,b from table1_default order by a;
+-------------------------------------------------------------------+-----------+------+
| txt                                                               | incre_col | b    |
+-------------------------------------------------------------------+-----------+------+
| 1当前自增值=>                                                     |         2 |   11 |
| 2当前自增值=>                                                     |         3 |   11 |
| 将AUTO_INCREMENT列值设置为大于当前最大自增值的值                  |        30 |  111 |
+-------------------------------------------------------------------+-----------+------+
drop table table2_order;
create table table2_order (
  a int not null auto_increment primary key,
  b int default 2,
  txt varchar(64) default 'table2_order order模式',
  unique index(a)
) auto_increment_mode = 'order' 
 partition by range(a) 
 subpartition by hash(a) subpartitions 4  
(partition p0 values less than (10),  
 partition p1 values less than (20),  
 partition p2 values less than maxvalue);
insert into table2_order(a,b) values(null,222);
select txt,a incre_col,b from table2_order order by a;
+--------------------------+-----------+------+
| txt                      | incre_col | b    |
+--------------------------+-----------+------+
| table2_order order模式   |         1 |  222 |
+--------------------------+-----------+------+
update table2_order set a = 0,txt = '将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值' where b = 222;
insert into table2_order values(null,22,'1当前自增值=>');
select txt,a incre_col,b from table2_order order by a;
+--------------------------------------------------------------------------+-----------+------+
| txt                                                                      | incre_col | b    |
+--------------------------------------------------------------------------+-----------+------+
| 将AUTO_INCREMENT列值设置为小于/等于当前最大自增值的值                    |         0 |  222 |
| 1当前自增值=>                                                            |         2 |   22 |
