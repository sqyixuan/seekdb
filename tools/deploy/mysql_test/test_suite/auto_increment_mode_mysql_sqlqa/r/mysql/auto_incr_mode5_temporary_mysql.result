| txt                 | incre_col | b    |
+---------------------+-----------+------+
| table2_order        |         1 |    2 |
| table2_order        |         2 |    2 |
| table2_order        |         3 |    2 |
| table2_order        |         4 |    2 |
| ORDER test1         |         4 |   11 |
| 当前自增值1==>      |         6 |    0 |
+---------------------+-----------+------+
alter table table2_order auto_increment_mode = 'ORDER';
