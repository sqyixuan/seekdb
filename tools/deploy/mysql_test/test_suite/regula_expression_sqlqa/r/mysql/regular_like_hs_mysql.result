#
# 子查询
select * from t1 where t1.b in ( select b from t1_duplicate where regexp_like(t1_duplicate.b,'^gh.*l$','n'));
a	b
2	ghijkl
#
# pl/sql
# 无参函数
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test()
RETURNS varchar(200)
BEGIN
DECLARE RESULT varchar(200);
SELECT b INTO RESULT FROM t1_duplicate WHERE regexp_like(b,'^gh.*l$','n');
RETURN(RESULT);
END;
//
SELECT f_test() FROM dual;
f_test()
ghijkl
#
# 有一个 in 参数的函数
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test(samplename VARCHAR(200)) 
RETURNS varchar(200)
BEGIN
DECLARE RESULT VARCHAR(200);
SELECT b INTO RESULT FROM t1_duplicate  WHERE regexp_like(b, samplename, 'n');
RETURN(RESULT);
END;
//
SELECT f_test('^gh.*l$') FROM dual;
f_test('^gh.*l$')
ghijkl
SELECT f_test('ffxfoxing') FROM dual;
f_test('ffxfoxing')
ffxfoxing
drop function f_test;
#
# 无参数存储过程
drop procedure p_test;//
CREATE PROCEDURE p_test()
BEGIN
declare a varchar(200);
declare b varchar(200);
SELECT b into a FROM t1_duplicate e WHERE regexp_like(b, '^gh.*l$','n');
SELECT b into b FROM t1_duplicate e WHERE regexp_like(b, 'ffxfoxing', 'm');
END;
//
CALL p_test();
#
# out参数存储过程
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(100),OUT  wb1 varchar(200)) 
BEGIN
SELECT b into wb FROM t1_duplicate e WHERE regexp_like(b, '^gh.*l$','n');
SELECT b into wb1 FROM t1_duplicate e WHERE regexp_like(b, 'ffxfoxing', 'm');
END ;
//
call p_test(@wb,@wb1);
drop procedure p_test;
# Clean up users
drop user wmj456@'%';
alter system set _regex_engine = 'icu';
alter system flush plan cache global;
