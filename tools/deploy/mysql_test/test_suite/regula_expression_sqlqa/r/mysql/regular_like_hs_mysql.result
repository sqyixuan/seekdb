drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'ab cd ef');
insert into t1 values(2,'ghijkl');
insert into t1 values(3,'fo\r\nfo');
insert into t1 values(4,'opq \r');
insert into t1 values(5,'abc\ndef');
insert into t1 values(6,'ghi\rjkl');
insert into t1 values(7,'12/31/2020');
insert into t1 values(8,'cfddns');
insert into t1 values(9,'MM');
