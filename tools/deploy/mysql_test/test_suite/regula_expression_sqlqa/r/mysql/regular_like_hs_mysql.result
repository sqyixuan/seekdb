#Environmental cleaning
drop user wmj456@'%';
drop database obwmjtest;
create database obwmjtest;
create user wmj456 identified by 'wmj456';
grant all on *.* to wmj456 WITH GRANT OPTION;
alter system set _regex_engine = 'hyperscan';
alter system flush plan cache global;
mysql_regexp_like-1
REGEXP_LIKE

SELECT '1' RLIKE RPAD('1', 10000, '(');
ERROR HY000: Incorrect arguments to hyperscan regex engine, supported pattern's maximum length is 2000
SELECT '1' RLIKE RPAD('1', 2001, '(');
ERROR HY000: Incorrect arguments to hyperscan regex engine, supported pattern's maximum length is 2000
SELECT regexp_like('1', RPAD('1', 10000, '('), 'm');
ERROR HY000: Incorrect arguments to hyperscan regex engine, supported pattern's maximum length is 2000
SELECT '1' RLIKE RPAD('1', 1000, '(');
ERROR HY000: Missing close parenthesis for group started at index 999.
SELECT '1' RLIKE RPAD('1', 2000, '(');
ERROR HY000: Missing close parenthesis for group started at index 1999.
# 数字，字符串，符号，特殊符号，号码，日期，中文，邮箱
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'A7007');
insert into t1 values(6,'001517729C28');
insert into t1 values(7,'人民日报');
insert into t1 values(8,'DNF*cf（QQ华夏');
insert into t1 values(9,'12345678cc');
insert into t1 values(10,'14844887@sina.com');
insert into t1 values(11,'http');
insert into t1 values(12,'ftp');
insert into t1 values(13,'https');
insert into t1 values(14,'ftps');
insert into t1 values(15,'qqq fff 223XO酱');
insert into t1 values(16,'，……；');
insert into t1 values(17,'\n');
insert into t1 values(18,'ab 12 cd');
insert into t1 values(19,'ab\ncd');

# 忽略大小写查找含有‘d’的字符
select * from t1 where REGEXP_LIKE(b,'d','i');
a	b
1	qqqqqqqdqqqqq
8	DNF*cf（QQ华夏
18	ab 12 cd
19	ab
cd

# 匹配中文 / 内部模式修饰符
select * from t1 where regexp_like(b,'人民','m');
a	b
7	人民日报
select * from t1 where regexp_like(ascii(b),'149','m');
a	b
select * from t1 where regexp_like(b,'149','m');
a	b
select * from t1 where regexp_like(b,'(?m)^ab.*$');
a	b
18	ab 12 cd
19	ab
cd

# 区分大小写查找含有‘D’的字符
select * from t1 where REGEXP_LIKE(b,'D','c');
a	b
8	DNF*cf（QQ华夏

# 1开头，匹配3次
select * from t1 where regexp_like(b,'^1{1,3}');
a	b
3	192.168.0.1
4	123a34cc
9	12345678cc
10	14844887@sina.com
# 开发回复：正常
# 无匹配项，匹配2次
select * from t1 where regexp_like(b,'^{0,2}');
ERROR HY000: Invalid repeat at index 1.

# 匹配 cc 末尾,最少0次 最多3次
select * from t1 where regexp_like(b,'.*cc{0,3}$');
a	b
4	123a34cc
9	12345678cc

