# 中文
select regexp_substr('Hello,大家好！greeting', '[大家好]+',3) from dual;
regexp_substr('Hello,大家好！greeting', '[大家好]+',3)
大家好
select regexp_substr('Hello,大家好！greeting', '[家]+',3) from dual;
regexp_substr('Hello,大家好！greeting', '[家]+',3)
家

# 匹配空格
select regexp_substr('Hello, 大家好！greeting', '[[:space:]]+',3) from dual;
regexp_substr('Hello, 大家好！greeting', '[[:space:]]+',3)
 

# 匹配标点符号
select regexp_substr('Hello, 大家好！greeting', '[[:punct:]]+',3,1) from dual;
regexp_substr('Hello, 大家好！greeting', '[[:punct:]]+',3,1)
,
select regexp_substr('Hello, 大家好！greeting', '[[:punct:]]+',3,2) from dual;
regexp_substr('Hello, 大家好！greeting', '[[:punct:]]+',3,2)
NULL
# 
# 忽略空格匹配数字字母
select regexp_substr('Hello, 大家好！greeting, 666', '[A-Za-z0-9]',3,1) from dual;
regexp_substr('Hello, 大家好！greeting, 666', '[A-Za-z0-9]',3,1)
l
select regexp_substr('Hello, 大家好！greeting, 666', '[A-Za-z0-9].*(666)',3,1,'m') from dual;
regexp_substr('Hello, 大家好！greeting, 666', '[A-Za-z0-9].*(666)',3,1,'m')
llo, 大家好！greeting, 666
