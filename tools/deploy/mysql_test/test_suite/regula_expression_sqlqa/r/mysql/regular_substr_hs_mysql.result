# unicode 转换
drop table t6;
CREATE TABLE t6(a int,b varchar(300));
insert into t6 values(1,'\u82f1\u56fd\u738b\u5ba4\u9996\u6b21\u56de\u5e94');
insert into t6 values(2,'\u65cf\u95ee\u9898\u5c06\u5f97\u5230\u89e3\u51b3');
insert into t6 values(3,'\u54c8\u91cc\u6885\u6839\u7206\u6599\uff1a\u79cd');

# ob正则表达式不支持
select a, REGEXP_SUBSTR(b,'\\u5{1,3}+')  "REGEXPR_SUBSTR" from t6;
ERROR HY000: '\u' at index 0 not supported.
