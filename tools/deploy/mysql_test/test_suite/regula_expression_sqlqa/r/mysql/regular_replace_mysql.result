#Environmental cleaning
drop user wmj456@'%';
drop database obwmjtest;
create database obwmjtest;
create user wmj456 identified by 'wmj456';
grant all on *.* to wmj456 WITH GRANT OPTION;
mysql_regular_replace-4
REGEXP_replace

# 数字，字符串，符号，特殊符号，号码，日期，中文，邮箱
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'DNF*cf（QQ华夏');
insert into t1 values(6,'\n换行符');
insert into t1 values(7,'  (⊙o⊙)？');
insert into t1 values(8,'http');
insert into t1 values(9,'ftp');
insert into t1 values(10,'https');
insert into t1 values(11,'ftps');
# 
# 数字
select a,REGEXP_REPLACE(b,'[1-9]','[1-9]',1,1,'m') "REGEXP_REPLACE"  from t1 where a=1;
a	REGEXP_REPLACE
1	qqqqqqqdqqqqq
select a,REGEXP_REPLACE(b, '[1-9]{1,5}','[1-9]',1,2) "REGEXP_REPLACE"  from t1 where a=4;
a	REGEXP_REPLACE
4	123a[1-9]cc
select REGEXP_REPLACE('1,2,3','[^,]','?',2,2) "REGEXP_REPLACE" from dual;
REGEXP_REPLACE
1,2,?
select REGEXP_REPLACE('1,2,3','[^,]','NULL',1,1) "REGEXP_REPLACE" from dual;
REGEXP_REPLACE
NULL,2,3
# bug:33269398
select REGEXP_REPLACE(b||CHAR(10),'a.','我',1,1) "REGEXP_REPLACE" from t1;
REGEXP_REPLACE
