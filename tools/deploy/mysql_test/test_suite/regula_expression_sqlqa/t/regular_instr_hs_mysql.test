--echo mysql_regular_instr-3
--echo REGEXP_INSTR
--echo 
--echo # 数字，字符串，符号，特殊符号，号码，日期，中文，邮箱
--error 0,1051
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'DNF*cf（QQ华夏');
insert into t1 values(6,'\n换行符');
insert into t1 values(7,'  (⊙o⊙)？');
insert into t1 values(8,'http');
insert into t1 values(9,'ftp');
insert into t1 values(10,'https');
insert into t1 values(11,'ftps');


--echo # 
--echo # 数字
--error 4016
select a,REGEXP_INSTR(b,'[1-9]*$',1,1,1,'m') "REGEXP_INSTR"  from t1 where a=1;
select a,REGEXP_INSTR(b, '[1-9]{1,5}') "REGEXP_INSTR"  from t1 where a=4;
select REGEXP_INSTR('1,2,3','[^,]',2,2) "REGEXP_INSTR" ;
select REGEXP_INSTR('1,2,3','[^,]',1,1) "REGEXP_INSTR" ;
--echo # bug:33269398
select REGEXP_INSTR(b||CHAR(10),'^a.*$',1,1,1) "REGEXP_INSTR" from t1;


--echo #
--echo # 字符串 / 标点符号/ 不匹配大小写
--error 4016
select a, REGEXP_INSTR(b, '[d-f]*$',1,1,1) "REGEXP_INSTR" from t1;
select a, REGEXP_INSTR(b, '[D-F]',1,1,1,'i') "REGEXP_INSTR" from t1;
select a, REGEXP_INSTR(b, '[d-n]',1,1,1,'im') "REGEXP_INSTR" from t1;
select a, REGEXP_INSTR(b, '[d-n]',1,1,1,'i') "REGEXP_INSTR" from t1;
select a, REGEXP_INSTR(b, '[d-n.]',1,1,0,'mn') "REGEXP_INSTR" from t1;
select REGEXP_INSTR(Null, '[d-n.]',1,1,0,'mn') "REGEXP_INSTR";
select REGEXP_INSTR(b, NULL,1,1,0,'mn') "REGEXP_INSTR" from t1;

--echo # 
--echo # position / occurrence 匹配
select REGEXP_INSTR(b,'[1-9]+',1,1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1210
select REGEXP_INSTR(b,'[1-9]+',-3,1) "REGEXP_INSTR" from t1 where a=4;
select REGEXP_INSTR(b,'[1-9]+',10,1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1210
select REGEXP_INSTR(b,'[1-9]+','m',1) "REGEXP_INSTR" from t1 where a=4;
select REGEXP_INSTR(b,'[1-9]+',NULL,1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1064
select REGEXP_INSTR(b,'[1-9]+', ,1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1064
select REGEXP_INSTR(b,'[1-9]+',[,1) "REGEXP_INSTR" from t1 where a=4;
select REGEXP_INSTR(b,'[1-9]',1,2) "REGEXP_INSTR" from t1 where a=4;
