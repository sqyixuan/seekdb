--echo # 
--echo # aisii码
select a, REGEXP_INSTR(ascii(b),'99',1,1) "REGEXP_INSTR"  from t1;
select a, REGEXP_INSTR(ascii(b),'\d',1,1) "REGEXP_INSTR"  from t1;

--echo # 
--echo # lower函数
select a, REGEXP_INSTR(LOWER(b),'mm',1,1) "REGEXP_INSTR"  from t1;

--echo # 
--echo # 匹配'fo\r\nfo'
select a, REGEXP_INSTR(b,'^f.*$',1,1) "REGEXP_INSTR"  from t1;

--echo # 
--echo # 匹配日期
select a, REGEXP_INSTR(b,'^([0-9]{2})/([0-9]{2})/([0-9]{4})$',1,1) "REGEXP_INSTR"  from t1;

--echo # 
--echo # 忽略换行符
