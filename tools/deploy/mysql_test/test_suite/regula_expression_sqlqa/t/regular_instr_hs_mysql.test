--error 0,1210
select REGEXP_INSTR(b,'[1-9]',1,0) "REGEXP_INSTR" from t1 where a=4;
select REGEXP_INSTR(b,'[hh]',1,1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1210
select REGEXP_INSTR(b,'[1-9]',1,-1) "REGEXP_INSTR" from t1 where a=4;
--error 0,1210
select REGEXP_INSTR(b,'[1-9]',1,'v') "REGEXP_INSTR" from t1 where a=4;
select REGEXP_INSTR(b,'[1-9]',1,NULL) "REGEXP_INSTR" from t1 where a=4;
--error 0,1064
select REGEXP_INSTR(b,'[1-9]',1, ) "REGEXP_INSTR" from t1 where a=4;
--error 0,1210
select REGEXP_INSTR(b,'[1-9]',1,' ') "REGEXP_INSTR" from t1 where a=4;


