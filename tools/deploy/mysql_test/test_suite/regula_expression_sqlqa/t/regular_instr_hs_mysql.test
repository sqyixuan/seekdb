--echo #
--echo # 左右组合连接查询
--error 0,1051
drop table t1_duplicate;
create table t1_duplicate(a int ,b varchar(50));
insert into t1_duplicate values(1,'ffxfoxing');
insert into t1_duplicate values(2,'luozhixiang');
insert into t1_duplicate values(3,'ghijkl');
insert into t1_duplicate values(4,'(0991)8477 7755');
insert into t1_duplicate values(5,'abc');
insert into t1_duplicate values(6,'2020');

select a, REGEXP_INSTR(b,'^gh.*l$') from t1_duplicate;
select t1.a, REGEXP_INSTR(t1.b,'gh.') from t1 left join t1_duplicate on t1.b='ghijkl' order by t1.a;
select t1.a, REGEXP_INSTR(t1.b,'^gh.*$') from t1 right join t1_duplicate on t1_duplicate.b='ghijkl' order by t1.a;
--error 0,1722
select * from t1,t1_duplicate where t1.b in (REGEXP_INSTR(t1.b,'ab')) order by t1.a;


--echo #
--echo # 嵌套子查询
--error 0,1722
select * from t1 where t1.b in ( select b from t1_duplicate where t1_duplicate.b in (REGEXP_INSTR(t1_duplicate.b,'gh.*l',1,1,0,'n')));


--echo #
--echo # pl/sql
--echo # 无参函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE  FUNCTION f_test()
RETURNS varchar(200)
BEGIN
	declare RESULT varchar(200);
	SELECT b INTO RESULT FROM t1_duplicate WHERE t1_duplicate.a in (REGEXP_INSTR(t1_duplicate.b,'ffxfoxing',1,1));
	RETURN RESULT;
END;
//
DELIMITER ;//

SELECT f_test() ;


--echo #
--echo # 有一个 in 参数的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test(samplename VARCHAR(200)) 
RETURNS varchar(200)
BEGIN
	DECLARE RESULT VARCHAR(200);
	SELECT b INTO RESULT FROM t1_duplicate WHERE t1_duplicate.a in (REGEXP_INSTR(b, samplename));
	RETURN(RESULT);
END;
//
DELIMITER ;//

SELECT f_test('^gh.*l$') ;
SELECT f_test('ffxfoxing') ;

drop function f_test;

--echo #
--echo # 无参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test()
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	SELECT b into a FROM t1_duplicate WHERE t1_duplicate.a in (REGEXP_INSTR(b,'^gh.*l$',1,1));
	SELECT b into b FROM t1_duplicate WHERE t1_duplicate.a in (REGEXP_INSTR(b, 'ffxfoxing',1,1));
END;
//

DELIMITER ;//

CALL p_test();

--echo #
--echo # out参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(100), OUT wb1 varchar(100))
BEGIN
	SELECT b into wb FROM t1_duplicate e WHERE e.a in (REGEXP_INSTR(b, 'ffxfoxing',1,1,0,'n'));
	SELECT b into wb1 FROM t1_duplicate e WHERE e.a in (REGEXP_INSTR(b,'ffxfoxing',1,1,0,'mn'));
END;
//
delimiter ;//

call p_test(@wb,@wb1);

drop procedure p_test;


