--echo #
--echo # 视图数据
--error 0,1051
drop view t1_view;
create view t1_view as select * from t1;

--echo # 忽略空格字符
select a, REGEXP_INSTR(b,'gh ij kl',1,1) "REGEXP_INSTR" from t1_view;

--echo # 匹配'fo\r\nfo'
select a, REGEXP_INSTR(b,'^f.*$') "REGEXP_INSTR" from t1_view;

--echo # 匹配 'abcdef'
--echo # 列名过长引起得显示不完整bug
select a, REGEXP_INSTR(b,'^a.*$') "REGEXP_INSTR" from t1_view;

--echo # 匹配ghi开头
select a, REGEXP_INSTR(b,'[ghi]+',1,1,1,'n') "REGEXP_INSTR" from t1_view;

--echo #
--echo # 值类型匹配
--error 0,1051
drop table t4;
CREATE TABLE t4(a bigint,b float, c double);
INSERT INTO t4 VALUES(0,10.12,-11.21);
INSERT INTO t4 VALUES(NULL,0,43.565656);
INSERT INTO t4 VALUES(100,12.12654,0);
INSERT INTO t4 VALUES(120,120.1111111,121.000000001);

--echo 匹配数值类型，函数，空，NULL
select A, REGEXP_INSTR(a,'\\d',2,1) "REGEXP_INSTR" from t4;
select b, REGEXP_INSTR(b,'^[+]{0,1}(\\d+)$') "REGEXP_INSTR" from t4;
select c, REGEXP_INSTR(c,'^[^\-].*$') "REGEXP_INSTR" from t4;
select a, REGEXP_INSTR(a,'\\d\d\d\d\d') "REGEXP_INSTR" from t4;
select a, REGEXP_INSTR(a,'\\d\\d\\d') "REGEXP_INSTR" from t4;
select a, REGEXP_INSTR(sign(a),'0') "REGEXP_INSTR" from t4;
select b, REGEXP_INSTR(sign(b),'0') "REGEXP_INSTR" from t4;
select c, REGEXP_INSTR(abs(c),'\d') "REGEXP_INSTR" from t4;
select c, REGEXP_INSTR(round(c,2),'11.21') "REGEXP_INSTR" from t4;
select a, REGEXP_INSTR(a,' ') "REGEXP_INSTR" from t4;
--error 0,1139
select a, REGEXP_INSTR(a,'') "REGEXP_INSTR" from t4;
--error 4016
select a, REGEXP_INSTR(a,'[=NULL=]') "REGEXP_INSTR" from t4;
--error 4016
select a, REGEXP_INSTR(a,'[= =]') "REGEXP_INSTR" from t4;
--error 4016
select a, REGEXP_INSTR(a,'[.NULL.]') "REGEXP_INSTR" from t4;
select a, REGEXP_INSTR(a,'NULL') "REGEXP_INSTR" from t4;

