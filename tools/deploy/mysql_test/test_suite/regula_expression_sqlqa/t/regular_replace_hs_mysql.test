--echo #
--echo # 左右组合连接查询
--error 0,1051
drop table t1_duplicate;
create table t1_duplicate(a int ,b varchar(50));
insert into t1_duplicate values(1,'ffxfoxing');
insert into t1_duplicate values(2,'luozhixiang');
insert into t1_duplicate values(3,'ghijkl');
insert into t1_duplicate values(4,'(0991)8477 7755');
insert into t1_duplicate values(5,'abc');
insert into t1_duplicate values(6,'2020');

select a, REGEXP_REPLACE(b,'^gh.*l$','爱丽丝') from t1_duplicate;
select t1.a, REGEXP_REPLACE(t1.b,'gh.','爱丽丝') from t1 left join t1_duplicate on t1.b='ghijkl' order by t1.a;
select t1.a, REGEXP_REPLACE(t1.b,'^gh.*$','爱丽丝') from t1 right join t1_duplicate on t1_duplicate.b='ghijkl' order by t1.a;
--error 0,1722
select * from t1,t1_duplicate where t1.b in (REGEXP_REPLACE(t1.b,'ab','爱丽丝')) order by t1.a;

--echo # 
--echo # replace_string 函数
select REGEXP_REPLACE('1,2,3','[^,]',sign(15),2,2) "REGEXP_REPLACE" from dual;
select a, REGEXP_REPLACE(sign(a),'0','谢耳朵') "REGEXPR_SUBSTR" from t4;
select a, b, REGEXP_REPLACE(sign(b),'0','谢耳朵') "REGEXPR_SUBSTR" from t4;
select a,c, REGEXP_REPLACE(abs(c),'\\d','谢耳朵') "REGEXPR_SUBSTR" from t4;
select a,c, REGEXP_REPLACE(round(c,2),'11.21','谢耳朵') "REGEXPR_SUBSTR" from t4;

--echo # 查找替换NULL数据
--error 4016
select regexp_replace(a, '[.NULL.]+',666) "REGEXPR_REPLACE" from t4;
--error 4016
select regexp_replace(a, '[. .]+',666) "REGEXPR_REPLACE" from t4;
select regexp_replace(a, 'NULL',666) "REGEXPR_REPLACE" from t4;

--echo #
--echo # 嵌套子查询
--error 0,1722
select * from t1 where t1.b in (select b from t1_duplicate where t1_duplicate.b in (REGEXP_REPLACE(t1_duplicate.b,'ffxfoxing','刘备')));


--echo #
--echo # pl/sql
--echo # 无参函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test()
RETURNS varchar(200)
BEGIN
	DECLARE RESULT varchar(200);
	SELECT b INTO RESULT FROM t1_duplicate WHERE a=3 and t1_duplicate.b in (REGEXP_REPLACE(t1_duplicate.b,'^gh.*l$','ghijkl'));
	RETURN(RESULT);
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;

--echo #
--echo # 有一个 in 参数的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test(samplename VARCHAR(200)) 
RETURNS varchar(200)
BEGIN
	DECLARE RESULT VARCHAR(200);
	SELECT b INTO RESULT FROM t1_duplicate WHERE a=3 and t1_duplicate.b in (REGEXP_REPLACE(b, samplename,'ghijkl'));
	RETURN(RESULT);
END;
//
DELIMITER ;//

SELECT f_test('^gh.*l$') FROM dual;
SELECT f_test('ffxfoxing') FROM dual;

drop function f_test;

--echo #
--echo # 无参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test()
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	SELECT b into a FROM t1_duplicate WHERE a=3 and t1_duplicate.b in (REGEXP_REPLACE(b,'^gh.*l$','ghijkl'));
	SELECT b into b FROM t1_duplicate WHERE a=3 and t1_duplicate.b in (REGEXP_REPLACE(b, 'ffxfoxing','ghijkl'));
END;
//

DELIMITER ;//

CALL p_test();

--echo #
--echo # out参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(100),OUT  wb1 varchar(200)) 
BEGIN
	SELECT b into wb FROM t1_duplicate e WHERE e.a=3 and e.b in (REGEXP_REPLACE(b, 'ffxfoxing','ghijkl'));
	SELECT b into wb1 FROM t1_duplicate e WHERE e.a=3 and e.b in (REGEXP_REPLACE(b,'ffxfoxing','ghijkl'));
END;
//
delimiter ;//

call p_test(@wb,@wb1);

drop procedure p_test;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user wmj456@'%';
--enable_warnings
alter system set _regex_engine = 'icu';
alter system flush plan cache global;
sleep 2;