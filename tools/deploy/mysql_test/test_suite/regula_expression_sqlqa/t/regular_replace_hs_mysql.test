#description: regexp_replace

--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user wmj456@'%';
--enable_warnings
--error 0,1008
drop database obwmjtest;
create database obwmjtest;
--enable_warnings
create user wmj456 identified by 'wmj456';
grant all on *.* to wmj456 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc

connection default;
alter system set _regex_engine = 'hyperscan';
alter system flush plan cache global;
sleep 2;

connect (conn,$OBMYSQL_MS0,wmj456,wmj456,test,$OBMYSQL_PORT);
connection conn;


--echo mysql_regular_replace-4
--echo REGEXP_replace
--echo 
--echo # 数字，字符串，符号，特殊符号，号码，日期，中文，邮箱
--error 0,1051
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'DNF*cf（QQ华夏');
insert into t1 values(6,'\n换行符');
insert into t1 values(7,'  (⊙o⊙)？');
insert into t1 values(8,'http');
insert into t1 values(9,'ftp');
insert into t1 values(10,'https');
insert into t1 values(11,'ftps');

--echo # 
--echo # 数字
select a,REGEXP_REPLACE(b,'[1-9]','[1-9]',1,1,'m') "REGEXP_REPLACE"  from t1 where a=1;
select a,REGEXP_REPLACE(b, '[1-9]{1,5}','[1-9]',1,2) "REGEXP_REPLACE"  from t1 where a=4;
select REGEXP_REPLACE('1,2,3','[^,]','?',2,2) "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('1,2,3','[^,]','NULL',1,1) "REGEXP_REPLACE" from dual;
--echo # bug:33269398
select REGEXP_REPLACE(b||CHAR(10),'a.','我',1,1) "REGEXP_REPLACE" from t1;
--error 3995
select b,REGEXP_REPLACE(b,'a.',CHAR(13),1,1) "REGEXP_REPLACE" from t1;
select REGEXP_REPLACE('1,2,3','[^,]',sign(15),2,2) "REGEXP_REPLACE" from dual;

--echo # 
--echo # 匹配非数字和空白字符
select regexp_replace('我爱你中国232、。，我爱你895', '[^\\d\s]+','m') "REGEXPR_REPLACE" from dual;
select regexp_replace('我爱你中国232、。，我爱你895', '[^\\d\s]+','m',3,2) "REGEXPR_REPLACE" from dual;
select regexp_replace('我爱你中国232、。，我爱你895', '[^\\d\s]+','mm',3,1) "REGEXPR_REPLACE" from dual;
select regexp_replace('我爱你中国232、。，我爱你895', '\d','mm豆',1,1) "REGEXPR_REPLACE" from dual;
select regexp_replace('我爱你中国232、。，我爱你895', '\d','mm豆',1,1) "REGEXPR_REPLACE" from dual;

--echo # 匹配空格
select regexp_replace('Hello, 大家好！greeting','[[:space:]]+','m') from dual;
select regexp_replace('Hello, 大家好！ greeting','( ){1,}','m') from dual;
select regexp_replace('Hello, 大家好！ greeting',' {1,}','m') from dual;

--echo # 
--echo # replace_string 字符，数字，中文，空，空格，null，函数，正则表达式，子表达分组
select a,b,REGEXP_REPLACE(b,'[1-9]','[1-9]',1,1,'m') "REGEXP_REPLACE"  from t1 where a=1;
select a,b,REGEXP_REPLACE(b, '[1-9]{1,5}','[1-9]',1,2) "REGEXP_REPLACE"  from t1 where a=4;
select a,b,REGEXP_REPLACE(b, '[1-9]{1,2}',' ',1,2) "REGEXP_REPLACE"  from t1 where a=4;
select a,b,REGEXP_REPLACE(b, '[1-9]{1,2}','',1,1) "REGEXP_REPLACE"  from t1 where a=4;
--error 0,1064
select a,b,REGEXP_REPLACE(b, '[1-9]{1,2}', ,1,2) "REGEXP_REPLACE"  from t1 where a=4;
select a,b,REGEXP_REPLACE(b, '[1-9]{1,2}',999,1,2) "REGEXP_REPLACE"  from t1 where a=4;
select a,b,REGEXP_REPLACE(b, '[1-9]{1,2}',999,1,4) "REGEXP_REPLACE"  from t1 where a=4;
select REGEXP_REPLACE('1,2,3','[^,]','?',2,2) "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('1,2,3','[^,]','NULL',1,1) "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('1,2,3','[^,]',NULL,1,1) "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('1,2,3','[^,]',NULL,1,2) "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE(b||CHAR(10),'a.','我',1,1) "REGEXP_REPLACE" from t1;
select REGEXP_REPLACE(b,'[1-9]{1,2}',' {1}',1,1) "REGEXP_REPLACE" from t1 where a=4;
select REGEXP_REPLACE(b,'[1-9]{1,2}','\d',1,1) "REGEXP_REPLACE" from t1 where a=4;
select REGEXP_REPLACE('09/29/2008', '^([0-9]{2})/([0-9]{2})/([0-9]{4})$', '\3-\1-\2') "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('09/29/2008', '^([0-9]{2})/([0-9]{2})/([0-9]{4})$', '\3-999') "REGEXP_REPLACE" from dual;
select REGEXP_REPLACE('🍣🍣111', '🍣', '蛋糕',1,1) "REGEXP_REPLACE" from dual;


--echo # 
--echo # position / occurrence / match_param
select b,REGEXP_REPLACE(b,'[1-9]+',1,1) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1210
select b,REGEXP_REPLACE(b,'[1-9]+',-3,1) "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'[1-9]+',10,1) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1722
select b,REGEXP_REPLACE(b,'[1-9]+','m',1) "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'[1-9]+',NULL,1) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1064
select b,REGEXP_REPLACE(b,'[1-9]+', ,1) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1064
select b,REGEXP_REPLACE(b,'[1-9]+',[,1) "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'[1-9]',1,2) "REGEXP_REPLACE" from t1 where a=4;
--echo # 开发特意设计如此
--error 1210
select b,REGEXP_REPLACE(b,'[1-9]',1,0) "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'[hh]','T',1,0) "REGEXP_REPLACE" from t1 where a=4;
--error 1210
select b,REGEXP_REPLACE(b,'[1-9]',1,0,-1) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1722
select b,REGEXP_REPLACE(b,'[1-9]',1,1,'v') "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'[1-9]',1,0,NULL) "REGEXP_REPLACE" from t1 where a=4;
--error 0,1064
select b,REGEXP_REPLACE(b,'[1-9]',1,0, ) "REGEXP_REPLACE" from t1 where a=4;
--error 1210
select REGEXP_REPLACE(b,'[1-9]',1,0,' ') "REGEXP_REPLACE" from t1 where a=4;
select b,REGEXP_REPLACE(b,'d',5,1,0,'i') "REGEXP_REPLACE" from t1 where a=5;
--error 1210
select b,REGEXP_REPLACE(b,'d',5,0,0,'i') "REGEXP_REPLACE" from t1 where a=5;
select a, REGEXP_REPLACE(b,'[d-n]',1,1,0,'im') "REGEXP_REPLACE" from t1 where a=4;
select REGEXP_REPLACE('qqÀqq','À',2,1,0,'c') "REGEXP_REPLACE" from dual;
--error 1210
select REGEXP_REPLACE('qqÀqq','À',2,0,0,'C') "REGEXP_REPLACE" from dual;
--error 4016
select REGEXP_REPLACE(b,'ht tp',1,1,0,'x') "REGEXP_REPLACE" from t1;
--echo # 字符串 / 标点符号/ 不匹配大小写 
--error 4016
select a,b,REGEXP_REPLACE(b, '[d-f]*$','痘痘',1,0) "REGEXP_REPLACE" from t1 where a=5;
select a,b,REGEXP_REPLACE(b, '[D-F]','痘痘',1,0,'i') "REGEXP_REPLACE" from t1 where a=5;
select a,b,REGEXP_REPLACE(b, '[d-n]','痘痘',1,0,'im') "REGEXP_REPLACE" from t1 where a=5;
select a,b,REGEXP_REPLACE(b, '[d-n]','痘痘',1,0,'i') "REGEXP_REPLACE" from t1 where a=5;
select a,b,REGEXP_REPLACE(b, '[d-n.]','痘痘',1,0,'mn') "REGEXP_REPLACE" from t1 where a=5;

--echo # 以下不兼容5.7mysql
--disable_parsing
WITH strings as (  
  SELECT 'AddressLine1' s FROM dual union all   
  SELECT 'ZipCode' s FROM dual union all   
  SELECT 'Country' s FROM dual   
) SELECT s "STRING",  
    lower(regexp_replace(s, '([A-Z0-9])', '_\\1', 2)) "MODIFIED_STRING"  
  FROM strings;
--echo # wit as 表达式
WITH strings as (   
  SELECT 'NEW YORK' s FROM dual union all   
  SELECT 'New York' s FROM dual union all   
  SELECT 'new york' s FROM dual   
)   
  SELECT s "STRING",  
        regexp_replace(s, '[a-z]', '1', 1, 0, 'i') "CASE_1",  
        regexp_replace(s, '[a-z]', '1', 1, 0, 'c') "CASE_2",  
        regexp_replace(s, '[a-zA-Z]', '1', 1, 0, 'c') "CASE_3", 
		regexp_replace(s, '[a-zA-Z]', '1', 1, 1, 'c') "CASE_4", 
		regexp_replace(s, '[a-zA-Z]', '1', 1, 1, 'c') "CASE_5",
		regexp_replace(s, '[a-zA-Z]', '1', 1, 2, 'c') "CASE_6"  
  FROM  strings;
--enable_parsing

