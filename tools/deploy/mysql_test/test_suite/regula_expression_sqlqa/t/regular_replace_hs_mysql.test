--echo #
--echo # 视图数据
--error 0,1051
drop view t1_view;
create view t1_view as select * from t1;

--echo # 忽略空格字符
select a, REGEXP_REPLACE(b,'gh ij kl',1) "REGEXP_REPLACE" from t1_view;

--echo # 匹配'fo\r\nfo'
select a, REGEXP_REPLACE(b,'^f.*$','道长请留步') "REGEXP_REPLACE" from t1_view;

--echo # 
--echo # 匹配 'abcdef'
select a, REGEXP_REPLACE(b,'^a.*$','道长请留步') "REGEXP_REPLACE" from t1_view;

--echo # 匹配ghi开头
select a, REGEXP_REPLACE(b,'[ghi]+','道长请留步') "REGEXP_REPLACE" from t1_view;

--echo #
--echo # 值类型匹配
--error 0,1051
drop table t4;
CREATE TABLE t4(a bigint,b float, c double);
INSERT INTO t4 VALUES(0,10.12,-11.21);
INSERT INTO t4 VALUES(NULL,0,43.565656);
INSERT INTO t4 VALUES(100,12.12654,0);
INSERT INTO t4 VALUES(120,120.1111111,121.000000001);

--echo 匹配数值类型，函数，空，NULL
select a,REGEXP_REPLACE(a,'\\d','阿波罗') "REGEXP_REPLACE" from t4;
select a,b,REGEXP_REPLACE(b,'^[+]{0,1}(\\d+)$','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(c,'^[^\-].*$','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(a,'\\d','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(a,'\\d\d\d','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(sign(a),'0','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(sign(b),'0','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(abs(c),'\d','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(round(c,2),'11.21','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(a,' ','阿波罗') "REGEXP_REPLACE" from t4;
--error 0,1139
select a, REGEXP_REPLACE(a,'','阿波罗') "REGEXP_REPLACE" from t4;
--error 4016
select a, REGEXP_REPLACE(a,'[=NULL=]','阿波罗') "REGEXP_REPLACE" from t4;
--error 4016
select a, REGEXP_REPLACE(a,'[= =]','阿波罗') "REGEXP_REPLACE" from t4;
--error 4016
select a, REGEXP_REPLACE(a,'[.NULL.]','阿波罗') "REGEXP_REPLACE" from t4;
select a, REGEXP_REPLACE(a,'NULL','阿波罗') "REGEXP_REPLACE" from t4;

