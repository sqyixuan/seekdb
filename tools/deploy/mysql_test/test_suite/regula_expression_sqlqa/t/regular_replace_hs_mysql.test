select a, REGEXP_REPLACE(LOWER(b),'mm','中国') "REGEXP_REPLACE"  from t1;
select a, sign(REGEXP_REPLACE(LOWER(b),'ghijkl','123')) "SIGN_FUNC"  from t1 where a=2;

