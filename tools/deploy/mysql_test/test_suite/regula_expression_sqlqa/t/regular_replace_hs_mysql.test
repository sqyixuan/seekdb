--echo # 
--echo # aisii码
select a, b, REGEXP_REPLACE(ascii(b),'99','豆豆') "REGEXP_REPLACE"  from t1;
select a, b, REGEXP_REPLACE(ascii(b),'\d','豆豆') "REGEXP_REPLACE"  from t1;

