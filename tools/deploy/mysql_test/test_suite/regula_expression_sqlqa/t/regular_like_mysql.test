--echo #
--echo # 视图数据
--error 0,1051
drop view t1_view;
create view t1_view as select * from t1;

--echo # 忽略空格字符
select * from t1_view where regexp_like(b,'gh ij kl','m');

--echo # 匹配'fo\r\nfo'
select * from t1_view where regexp_like(b,'^f.*$','m');

--echo # 匹配 'abcdef'
select * from t1_view where regexp_like(b,'^a.*$','m');  

--echo # 匹配ghi开头
