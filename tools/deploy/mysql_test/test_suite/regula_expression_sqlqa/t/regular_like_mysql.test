--echo #
--echo # 左右组合连接查询
--error 0,1051
drop table t1_duplicate;
create table t1_duplicate(a int ,b varchar(50));
insert into t1_duplicate values(1,'ffxfoxing');
insert into t1_duplicate values(2,'luozhixiang');
insert into t1_duplicate values(3,'ghijkl');
insert into t1_duplicate values(4,'(0991)8477 7755');
insert into t1_duplicate values(5,'abc');
insert into t1_duplicate values(6,'2020');

select * from t1_duplicate where regexp_like(b,'^gh.*l$','n');
select * from t1 left join t1_duplicate on regexp_like(t1.b,'ghijkl','n') order by t1.a;
select * from t1 right join t1_duplicate on regexp_like(t1_duplicate.b,'^gh.*$','n') order by t1.a;
select * from t1,t1_duplicate where regexp_like(t1.b,'^ab.*$','m') order by t1.a;

--echo #
--echo # 子查询
select * from t1 where t1.b in ( select b from t1_duplicate where regexp_like(t1_duplicate.b,'^gh.*l$','n'));

--echo #
--echo # pl/sql
--echo # 无参函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test()
RETURNS varchar(200)
BEGIN
	DECLARE RESULT varchar(200);
	SELECT b INTO RESULT FROM t1_duplicate WHERE regexp_like(b,'^gh.*l$','n');
	RETURN(RESULT);
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;

--echo #
--echo # 有一个 in 参数的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_test ;//
CREATE FUNCTION f_test(samplename VARCHAR(200)) 
RETURNS varchar(200)
BEGIN
	DECLARE RESULT VARCHAR(200);
	SELECT b INTO RESULT FROM t1_duplicate  WHERE regexp_like(b, samplename, 'n');
	RETURN(RESULT);
END;
//
DELIMITER ;//

SELECT f_test('^gh.*l$') FROM dual;
SELECT f_test('ffxfoxing') FROM dual;

--echo #
--echo # 无参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test()
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	SELECT b into a FROM t1_duplicate e WHERE regexp_like(b, '^gh.*l$','n');
	SELECT b into b FROM t1_duplicate e WHERE regexp_like(b, 'ffxfoxing', 'm');
END;
//

DELIMITER ;//

CALL p_test();

--echo #
--echo # out参数存储过程
DELIMITER //;
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(100),OUT  wb1 varchar(200)) 
BEGIN
	SELECT b into wb FROM t1_duplicate e WHERE regexp_like(b, '^gh.*l$','n');
	SELECT b into wb1 FROM t1_duplicate e WHERE regexp_like(b, 'ffxfoxing', 'm');
END ;
//
delimiter ;//

call p_test(@wb,@wb1);


