--echo #
--echo # 值类型匹配
--error 0,1051
drop table t4;
CREATE TABLE t4(a bigint,b float, c double);
INSERT INTO t4 VALUES(0,10.12,-11.21);
INSERT INTO t4 VALUES(NULL,0,43.565656);
INSERT INTO t4 VALUES(100,12.12654,0);
INSERT INTO t4 VALUES(120,120.1111111,121.000000001);

select * from t4 where regexp_like(a,'\\d','m');
select * from t4 where regexp_like(b,'^[+]{0,1}(\\d+)$','m');
select * from t4 where regexp_like(c,'^[^\-].*$','m');
select * from t4 where regexp_like(a,'\\d\d\d\d\d','m');
select * from t4 where regexp_like(a,'\\d\\d','m');
select * from t4 where regexp_like(sign(a),'0','m');
select * from t4 where regexp_like(sign(b),'0','m');
select * from t4 where regexp_like(abs(c),'\d','m');
select * from t4 where regexp_like(round(c,2),'11.21','m');
select * from t4 where regexp_like(a,' ','m');
--error 0,1139
select * from t4 where regexp_like(a,'','m');
select * from t4 where regexp_like(a,'[=NULL=]','m');
select * from t4 where regexp_like(a,'[= =]','m');
select * from t4 where regexp_like(a,'[.NULL.]','m');
select * from t4 where regexp_like(a,'NULL','m');

