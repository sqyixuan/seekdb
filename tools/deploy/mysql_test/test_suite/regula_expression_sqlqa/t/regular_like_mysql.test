--echo mysql_regexp_like-1
--echo REGEXP_LIKE
--echo 
--echo # 数字，字符串，符号，特殊符号，号码，日期，中文，邮箱
--error 0,1051
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'A7007');
insert into t1 values(6,'001517729C28');
insert into t1 values(7,'人民日报');
insert into t1 values(8,'DNF*cf（QQ华夏');
insert into t1 values(9,'12345678cc');
insert into t1 values(10,'14844887@sina.com');
insert into t1 values(11,'http');
insert into t1 values(12,'ftp');
insert into t1 values(13,'https');
insert into t1 values(14,'ftps');
insert into t1 values(15,'qqq fff 223XO酱');
insert into t1 values(16,'，……；');
insert into t1 values(17,'\n');
insert into t1 values(18,'ab 12 cd');
insert into t1 values(19,'ab\ncd');

--echo 
--echo # 忽略大小写查找含有‘d’的字符
select * from t1 where REGEXP_LIKE(b,'d','i');

--echo 
--echo # 匹配中文 / 内部模式修饰符
select * from t1 where regexp_like(b,'人民','m');
select * from t1 where regexp_like(ascii(b),'149','m');
select * from t1 where regexp_like(b,'149','m');
select * from t1 where regexp_like(b,'(?m)^ab.*$');

--echo 
--echo # 区分大小写查找含有‘D’的字符
select * from t1 where REGEXP_LIKE(b,'D','c');

--echo 
--echo # 1开头，匹配3次
select * from t1 where regexp_like(b,'^1{1,3}');

--echo # 开发回复：正常
--echo # 无匹配项，匹配2次
--error 0,5820
select * from t1 where regexp_like(b,'^{0,2}');

--echo 
--echo # 匹配 cc 末尾,最少0次 最多3次
select * from t1 where regexp_like(b,'.*cc{0,3}$');

--echo 
--echo # 匹配 c 末尾, 匹配一次 / 多次
select * from t1 where regexp_like(b,'.*c+$');

--echo 
--echo # 匹配 cc 末尾, 匹配一次
select * from t1 where regexp_like(b,'.*cc{1}$');

--echo 
--echo # 匹配 c 
select * from t1 where regexp_like(b,'.*c');

--echo 
--echo # a 开头，7结尾，忽略大小写
select * from t1 where regexp_like(b,'^a.*7$','i');

--echo 
--echo # 匹配 cc 0或1 次，忽略大小写
select * from t1 where regexp_like(b,'cc?','i');

--echo 
--echo # 匹配 cc 0或1 次，区分大小写
select * from t1 where regexp_like(b,'cc?','c');

--echo 
--echo # 元字符匹配
select * from t1 where regexp_like(b,'(f|ht)tps?');

--echo # 
--echo # 匹配小写，数字，不区分大小写
select * from t1 where regexp_like(b,'^[[:lower:][:digit:]]','i');

--echo 
--echo # 小写，数字，区分大小写
select * from t1 where regexp_like(b,'^[[:lower:].[:digit:]]','c');

--echo # 
--echo # 大写，数字，不区分大小写
select * from t1 where regexp_like(b,'^[[:upper:],[:digit:]]','i');

--echo # 
--echo # 大写，数字，区分大小写
select * from t1 where regexp_like(b,'^[[:upper:],[:digit:]]','c');

--echo # 
--echo # 大写，数字
select * from t1 where regexp_like(b,'[[:upper:],[:digit:]]');

--echo # 
--echo # 非 大写，任意数字字母
select * from t1 where regexp_like(b,'[^[:upper:][:alnum:]]');

--echo # 
--echo # 不匹配 abcdefghigklmnopqrst 
select * from t1 where regexp_like(b,'[^abcdefghigklmnopqrst]+$');

--echo # 开发回复正则表达式引擎没有抛出错误则正常
--echo # 错误的匹配模式，表达式
--error 5812
select * from t1 where regexp_like(b,'\d[[^a-z],[A-Z]+$','i');
--error 0,5813
select * from t1 where regexp_like(b,'^(ab].*$','m');
--error 0,5812
select * from t1 where regexp_like(b,'[ab,{NULL}*$','m');
--error 0,1064
select * from t1 where regexp_like(b,'[ab,{NULL}*$',);

--echo #
--echo # 不匹配字母
select * from t1 where regexp_like(b,'^[^a-zA-Z]{1,}$','m');

--echo #
--echo # 匹配空格
select * from t1 where regexp_like(b,'[[:space:]]','m');

--echo #
--echo # 匹配任意字母
select * from t1 where regexp_like(b,'^[[:alpha:]]+$','m');

--echo #
--echo # 匹配16进制数字
select * from t1 where regexp_like(b,'^[[:xdigit:]]+$','m');

--echo #
--echo # 匹配标点符号
select * from t1 where regexp_like(b,'^[[:punct:]]+$','m');

--echo #
--echo # 匹配标点符号
select * from t1 where regexp_like(b,'[[:punct:]]+','m');

--echo # 
--echo # 忽略空格匹配数字字母
select * from t1 where regexp_like(b,'^[A-Za-z0-9]+$','n');
select * from t1 where regexp_like(b,'^[A-Za-z0-9]+$','m');

--echo #
--echo # 匹配空白字符
select * from t1 where regexp_like(b,'\s');

--echo #
--echo # 匹配非\f\n\r\t\v空白字符
select * from t1 where regexp_like(b,'^[^\f\n\r\t\v[:space:]]+$','m');

--echo # bug n 字符未生效。开发备注：已知问题，等待合并分支修复
--echo # 匹配换行符
select * from t1 where regexp_like(b,'^ab.cd+$','n');

--error 0,1051
drop table t1;
create table t1(a int, b varchar(50));
insert into t1 values(1,'ab cd ef');
insert into t1 values(2,'ghijkl');
insert into t1 values(3,'fo\r\nfo');
insert into t1 values(4,'opq \r');
insert into t1 values(5,'abc\ndef');
insert into t1 values(6,'ghi\rjkl');
insert into t1 values(7,'12/31/2020');
insert into t1 values(8,'cfddns');
insert into t1 values(9,'MM');

--echo # 
--echo # 忽略空格字符
--error 0,1210
select * from t1 where regexp_like(b,'gh ij kl','x');

--echo # 
--echo # aisii码
select * from t1 where regexp_like(ascii(b),'99','m');
select * from t1 where regexp_like(ascii(b),'\d','m');

--echo # 
--echo # lower函数
select * from t1 where regexp_like(LOWER(b),'mm','m');

--echo # 
--echo # 匹配'fo\r\nfo'
select * from t1 where regexp_like(b,'^f.*$','m');

--echo # 
--echo # 匹配 'abcdef'
select * from t1 where regexp_like(b,'^a.*$','m');  

--echo # 
--echo # 匹配ghi开头 / n 参数示例
select * from t1 where regexp_like(b,'^ghi.jkl$','n');
select * from t1 where regexp_like(b,'^ghi.jkl$');

--echo # 
--echo # 匹配 'ghi'||chr(10)||'jkl'
select * from t1 where regexp_like(b,'.*i$','m');

--echo # 
--echo # 不支持回车，只支持换行
select * from t1 where regexp_like(b,'^d.*$','m');

--echo # 
--echo # 匹配日期
select * from t1 where regexp_like(b,'^([0-9]{2})/([0-9]{2})/([0-9]{4})$');
select * from t1 where regexp_like(b,'^1{1,3}');

--echo # 
--echo # 匹配 fo\r\nfo 和 opq \r
select * from t1 where regexp_like(b,'o{1,3}');

--echo # 
--echo # 匹配 ghijkl
select * from t1 where regexp_like(b,'[.ij.]');

--echo # 
--echo # 忽略换行符
select * from t1 where regexp_like(b,'[.cd.]');

--echo # 
--echo # 匹配fo字符
select * from t1 where regexp_like(b,'[=fo=]');
select * from t1 where regexp_like(b,'[=fo1=]');

--echo # 
--echo # 匹配日期
select * from t1 where regexp_like(b,'^[^a-zA-Z]+?','m');

--echo # 
--echo # 除日期外匹配
select * from t1 where regexp_like(b,'^[^0-9]{1,}$');

