SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
UPDATE Z0CASE SET T1=123 WHERE T1='亚洲';
SELECT * FROM Z0CASE WHERE T1='123';

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) DEFAULT 'NON',T2 INT) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
