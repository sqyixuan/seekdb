#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 表级修改--创建表时含有约束和索引，然后修改普通表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connect(conn_sys, $OBMYSQL_MS0, root@sys, , *NO-ONE*, $OBMYSQL_PORT);
connection conn_sys;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 0,01051
DROP TABLE Z0CASE;
--error 0,01051
DROP TABLE Z1CASE;
--enable_warnings

--echo Indexes and Constraint

--echo char

CREATE TABLE Z0CASE(T1 CHAR(20) PRIMARY KEY) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'binary' COLLATE 'binary';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT INSTR(T1,'a') FROM Z0CASE ORDER BY T1*1;

--echo insert
--error 01062
INSERT INTO Z0CASE VALUES(123);
--error 01062
INSERT INTO Z0CASE VALUES(123);
--error 01048
INSERT INTO Z0CASE VALUES(null);
INSERT INTO Z0CASE VALUES(UPPER('abc'));
REPLACE INTO Z0CASE VALUES(123);
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

--echo update
--error 01062
UPDATE Z0CASE SET T1=REPLACE(T1,'abc',NULL);
UPDATE Z0CASE SET T1=NULL WHERE T1='abc';
UPDATE Z0CASE SET T1='中文' WHERE T1='123';
UPDATE Z0CASE SET T1=UPPER('abc') WHERE T1='中文';
SELECT * FROM Z0CASE WHERE T1 IN('中文');

UPDATE Z0CASE SET T1=b'0101101' WHERE T1='abc';
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) UNIQUE) DEFAULT charset='binary' DEFAULT collate='binary';
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES(NULL);
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

--error 01062
INSERT INTO Z0CASE VALUES(123);
--error 01062
INSERT INTO Z0CASE VALUES(123);
SELECT * FROM Z0CASE WHERE T1 IN('123');
UPDATE Z0CASE SET T1='abc' WHERE T1='123';
SELECT * FROM Z0CASE WHERE T1 IN('abc');

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20),T2 VARCHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
INSERT INTO Z0CASE VALUES(123,'122');
INSERT INTO Z0CASE VALUES('%^&*[];//\\','20:22:32');
INSERT INTO Z0CASE VALUES(NULL,NULL);
INSERT INTO Z0CASE VALUES('abc','ABC');
INSERT INTO Z0CASE VALUES('中文',b'1100101');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
CREATE INDEX ind ON Z0CASE(T1,T2);
SHOW INDEX FROM Z0CASE;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

INSERT INTO Z0CASE VALUES(123,'122');
INSERT INTO Z0CASE VALUES(123,'122');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT * FROM Z0CASE WHERE T1 ='123';
UPDATE Z0CASE SET T1='abc' WHERE T2='20:22:32';
UPDATE Z0CASE SET T1='abc' WHERE T2='ABC';
SELECT * FROM Z0CASE WHERE T1 ='abc';

DROP TABLE Z0CASE;
CREATE TABLE Z1CASE(T2 CHAR(20) PRIMARY KEY) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
CREATE TABLE Z0CASE(T1 CHAR(20),CONSTRAINT fk_t1_t2 FOREIGN KEY(T1) REFERENCES Z1CASE(T2)) DEFAULT charset= 'binary' DEFAULT collate = 'binary';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SHOW INDEX FROM Z0CASE;

DROP TABLE Z0CASE;
DROP TABLE Z1CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) NOT NULL) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
