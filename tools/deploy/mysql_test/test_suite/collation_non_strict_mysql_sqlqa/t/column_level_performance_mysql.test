#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 严格模式下，列级修改--通过PL/SQL创建大量数据，然后修改列的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
#--error 01396
DROP USER if exists zhang;
drop database IF  EXISTS charset_test;
--enable_warnings
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo #设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;


--echo Create data
--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1
(c0 CHAR(10) CHARACTER SET 'binary' COLLATE 'binary' PRIMARY KEY ,
c1 VARCHAR(50) CHARACTER SET 'gbk' DEFAULT 'NON',
c2 TEXT CHARACTER SET 'utf8mb4',
c3 ENUM('2020-12-11','2021-11-01','2020-10-21','2022-01-31','2023-06-26','2024-12-07') CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
c4 SET('101101','11011','111001','0111011','1100101','') CHARACTER SET 'utf16');
                
CREATE TABLE t2(c0 BINARY(10) ,c1 VARBINARY(50) ,c2 LONGBLOB ,c3 TEXT ,c4 BLOB );


DELIMITER //;

CREATE PROCEDURE p1()
BEGIN
    DECLARE i INT DEFAULT 1;
    wh1:WHILE i <= 50000 DO
        IF i < 5000 THEN
            INSERT INTO t1 VALUES(i,i||'AB',10.235,'2020-12-11','101101');
        ELSEIF i < 10000 THEN
            INSERT INTO t1 VALUES(i,i+1,0.225,'2021-11-01','11011');
        ELSEIF i < 20000 THEN
            INSERT INTO t1 VALUES(i,'@ % *',110.352,'2020-10-21','111001');
        ELSEIF i < 30000 THEN
            INSERT INTO t1 VALUES(i,'',210.5,'2022-01-31','0111011');
        ELSEIF i < 40000 THEN
            INSERT INTO t1 VALUES(i,NULL,10,'2023-06-26','1100101');
        ELSE
            INSERT INTO t1 VALUES(i,'中文',1023.567,'2024-12-07','');
        END IF;
        SET i = i + 1;
    END WHILE wh1;
END;
//


CREATE PROCEDURE p2()
BEGIN
    DECLARE j INT DEFAULT 1;
    wh2:WHILE j <= 50000 DO
        IF MOD(j,11) = 0 THEN
            INSERT INTO t2 VALUES(j,j||'AB',123.567,'2024-12-07 17:45:57.357','测试数据类型 & Test big data type');
        ELSEIF MOD(j,7) = 0 THEN
            INSERT INTO t2 VALUES(j,j+1,13.67,'2023-12-07 12:15:47.3547','测试 %!* & Test big data type');
        ELSEIF MOD(j,5) = 0 THEN
            INSERT INTO t2 VALUES(j,'@%*',113.5627,'2022-12-07 16:05:37.1543','(数据类型) & Test big data type');
        ELSEIF MOD(j,3) = 0 THEN
            INSERT INTO t2 VALUES(j,'',23.543,'2021-12-07 14:35:27.054','测试|数据|[类型] & Test big data type');
        ELSEIF MOD(j,2) = 0 THEN
            INSERT INTO t2 VALUES(j,NULL,0.537,'2022-12-07 02:15:19.004','<测试>{数据类型} & Test big data type');
        ELSE
            INSERT INTO t2 VALUES(j,'中',3.267,'2024-12-07 15:55:17.0004','测试~数据~类型 & Test big data type');
        END IF;
        SET j = j + 1;
    END WHILE wh2;
END;
//
DELIMITER ;//


CALL p1();
CALL p2();

--echo #DQL

SELECT COUNT(1) FROM t1;
SELECT COUNT(1) FROM t2;
SHOW CREATE TABLE t1;
SHOW CREATE TABLE t2;

--echo #相同数据类型相同character，修改collate

ALTER TABLE t1 MODIFY c0 CHAR(10) CHARACTER SET 'binary';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c1 VARCHAR(50) CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c2 TEXT CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_unicode_ci';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c3 ENUM('2020-12-11','2021-11-01','2020-10-21','2022-01-31','2023-06-26','2024-12-07') CHARACTER SET 'gb18030' COLLATE 'gb18030_chinese_ci';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c4 SET('101101','11011','111001','0111011','1100101','') CHARACTER SET 'utf16' COLLATE 'utf16_bin';
SHOW CREATE TABLE t1;

--echo #无定义charset类型，添加character和collate

--error 01064
ALTER TABLE t2 MODIFY c0 BINARY(10) CHARACTER SET 'binary';
--error 01064
ALTER TABLE t2 MODIFY c1 VARBINARY(50) CHARACTER SET 'binary';
--error 01064
ALTER TABLE t2 MODIFY c2 LONGBLOB CHARACTER SET 'utf16';

ALTER TABLE t2 MODIFY c3 TEXT CHARACTER SET 'utf16';
SHOW CREATE TABLE t2;

--error 01064
ALTER TABLE t2 MODIFY c4 BLOB CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';

--echo #修改数据类型和charset

ALTER TABLE t1 MODIFY c0 VARCHAR(10) CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_unicode_ci';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c1 TEXT CHARACTER SET 'gb18030' COLLATE 'gb18030_bin';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c2 CHAR(50) CHARACTER SET 'binary';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c3 TEXT CHARACTER SET 'utf16' COLLATE 'utf16_bin';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c4 ENUM('101101','11011','111001','0111011','1100101','') CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c0 VARCHAR(10);
SHOW CREATE TABLE t1;

ALTER TABLE t1 MODIFY c1 BLOB;
SHOW CREATE TABLE t1;


DROP TABLE t1;
DROP TABLE t2;

DROP PROCEDURE p1;
DROP PROCEDURE p2;

--enable_warnings

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

DROP USER 'zhang'@'%';
DROP DATABASE charset_test;

disconnect zhang;
disconnect conn_charset_test_sys_mysql;

--echo  ########Empty recycle bin, delete test database, tables, etc ##########
#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/drop_tenant_mysql.inc
#purge recyclebin;
