SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--echo update
UPDATE Z0CASE SET T1=NULL WHERE T1='2001';
UPDATE Z0CASE SET T1='12:31:56' WHERE T1='2011';
UPDATE Z0CASE SET T1=1221.34 WHERE T1='2011';
UPDATE Z0CASE SET T1='Aa1$< >中文' WHERE T1='2000';
UPDATE Z0CASE SET T1=b'0101101' WHERE T1='2000';
