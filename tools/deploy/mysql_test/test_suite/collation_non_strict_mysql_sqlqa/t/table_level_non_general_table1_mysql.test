#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 表级修改--创建表时未指定字符集和字符序，然后修改普通表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 01051
DROP TABLE Z0CASE;
--enable_warnings

--echo general_list_update  utf8mb4/utf8mb4_general_ci --> binary/binary

--echo char
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'binary';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'gbk_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'gb18030_chinese_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'utf16_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'utf8mb4_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'utf16_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'gbk_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'gb18030_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf16' DEFAULT collate = 'gb18030_chinese_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf16' DEFAULT collate = 'gbk_chinese_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf16' DEFAULT collate = 'utf8mb4_unicode_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'utf16' DEFAULT collate = 'binary';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gbk' DEFAULT collate = 'gb18030_chinese_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gbk' DEFAULT collate = 'utf16_general_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gbk' DEFAULT collate = 'utf8mb4_unicode_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gbk' DEFAULT collate = 'binary';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gb18030' DEFAULT collate = 'gbk_chinese_ci';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gb18030' DEFAULT collate = 'utf16_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gb18030' DEFAULT collate = 'utf8mb4_bin';
--error 01253
CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= 'gb18030' DEFAULT collate = 'binary';

CREATE TABLE Z0CASE(T1 CHAR(20)) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES(NULL);
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT * FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'binary' COLLATE 'binary';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1*1;

--echo insert
INSERT INTO Z0CASE VALUES(111);
INSERT INTO Z0CASE VALUES('2001');
INSERT INTO Z0CASE VALUES('!*?< >aB12 中文');
INSERT INTO Z0CASE VALUES(b'0101101');
INSERT INTO Z0CASE VALUES('2011-11-01');
INSERT INTO Z0CASE VALUES('22:22:35');
INSERT INTO Z0CASE VALUES(12.345);
INSERT INTO Z0CASE VALUES(null);

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1*1;

--echo update
UPDATE Z0CASE SET T1=NULL WHERE T1='111';
UPDATE Z0CASE SET T1='12:31:56' WHERE T1=2001;
UPDATE Z0CASE SET T1=1221.34 WHERE T1='2011-11-01';
UPDATE Z0CASE SET T1='Aa1$< >中文' WHERE T1='12.345';
UPDATE Z0CASE SET T1=b'0101101' WHERE T1='abc';

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1*1;

--echo delete

DELETE FROM Z0CASE WHERE T1=1221.34;
DELETE FROM Z0CASE WHERE T1='2021-10-01 12:23:35.54';
DELETE FROM Z0CASE WHERE T1 IS NULL;
DELETE FROM Z0CASE WHERE T1=b'0101101';
SELECT * FROM Z0CASE ORDER BY T1*1;

