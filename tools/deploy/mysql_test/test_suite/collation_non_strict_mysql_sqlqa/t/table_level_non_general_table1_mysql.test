CREATE TABLE Z0CASE(T1 TIME) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES('2020-11-21');
INSERT INTO Z0CASE VALUES('2021-01-21 11:58:39.456');
INSERT INTO Z0CASE VALUES('21:28:33.556');
INSERT INTO Z0CASE VALUES('2001');
INSERT INTO Z0CASE VALUES(NULL);
SELECT * FROM Z0CASE ORDER BY T1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'binary' COLLATE 'binary';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--echo insert

INSERT INTO Z0CASE VALUES(71);
INSERT INTO Z0CASE VALUES('2001');
INSERT INTO Z0CASE VALUES('!*?< >aB12 中文');
INSERT INTO Z0CASE VALUES(b'0101101');
INSERT INTO Z0CASE VALUES('2021-10-01 12:23:35.54');
INSERT INTO Z0CASE VALUES('2011-11-01');
INSERT INTO Z0CASE VALUES('22:22:35');
INSERT INTO Z0CASE VALUES(72.7476);
INSERT INTO Z0CASE VALUES(null);

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--echo update
UPDATE Z0CASE SET T1=NULL WHERE T1='22:22:35';
UPDATE Z0CASE SET T1='12:31:56' WHERE T1='21:28:34';
UPDATE Z0CASE SET T1=1221.34 WHERE T1='12:31:56';
UPDATE Z0CASE SET T1='Aa1$< >中文' WHERE T1='12:31:56';
UPDATE Z0CASE SET T1=b'0101101' WHERE T1='12:31:56';
UPDATE Z0CASE SET T1='2011-11-11' WHERE T1='12:31:56';
UPDATE Z0CASE SET T1='2012-12-21 09:10:21' WHERE T1='12:31:56';

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--echo delete
DELETE FROM Z0CASE WHERE T1='09:10:21';
DELETE FROM Z0CASE WHERE T1 IS NULL;
SELECT * FROM Z0CASE ORDER BY T1;

