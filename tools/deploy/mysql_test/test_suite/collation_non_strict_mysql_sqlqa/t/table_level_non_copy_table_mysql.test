#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 表级修改--创建复制表，修改表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 01051
DROP TABLE Z0CASE;
--error 01051
DROP TABLE Z1CASE;
--error 01051
DROP TABLE Z2CASE;
--enable_warnings

--echo copy table

CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10)) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('abc','abc');
INSERT INTO  Z0CASE VALUES('ABC','ABC');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
SELECT * FROM Z0CASE ORDER BY T2*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T2*1;
SHOW CREATE TABLE Z0CASE;

CREATE TABLE Z1CASE LIKE Z0CASE;
INSERT INTO Z1CASE SELECT * FROM Z0CASE;
SHOW CREATE TABLE Z1CASE;
SELECT * FROM Z1CASE ORDER BY T2*1;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z1CASE';
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z1CASE';

INSERT INTO Z1CASE VALUES('1@A b哈&','1@A b哈&');
SELECT * FROM Z1CASE ORDER BY T2*1;
UPDATE Z1CASE SET T1='AABBCC' WHERE T2='ABC';
SELECT * FROM Z1CASE ORDER BY T2*1;

ALTER TABLE Z1CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_bin';
SHOW CREATE TABLE Z1CASE;
SELECT * FROM Z1CASE ORDER BY T2*1;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z1CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z1CASE';

CREATE TABLE Z2CASE LIKE Z1CASE;
INSERT INTO Z2CASE SELECT * FROM Z1CASE;
SHOW CREATE TABLE Z2CASE;
SELECT * FROM Z2CASE ORDER BY T2*1;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z2CASE';
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z2CASE';

INSERT INTO Z2CASE VALUES('1 %A b哈*','1 %A b哈*');
SELECT * FROM Z2CASE ORDER BY T2*1;
UPDATE Z2CASE SET T1='aabbcc' WHERE T2='abc';
SELECT * FROM Z2CASE ORDER BY T2*1;
SELECT T1,HEX(T1),T2 FROM Z1CASE ORDER BY T2;
SELECT T1,HEX(T1),T2 FROM Z0CASE ORDER BY T2;

DROP TABLE Z2CASE;
DROP TABLE Z1CASE;
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10)) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
