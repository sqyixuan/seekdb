DROP TABLE Z2CASE;
DROP TABLE Z1CASE;
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (T1 TEXT,T2 INT) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'utf8mb4_bin';
