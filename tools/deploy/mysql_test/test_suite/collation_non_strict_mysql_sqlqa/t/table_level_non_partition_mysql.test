#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 表级修改--创建普通表，带有分区，然后修改表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

#--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 0,01051
DROP TABLE Z0CASE;
--error 0,01051
DROP TABLE Z1CASE;
--enable_warnings

--echo First create the partition table, and then modify the table level charset and collation.

--echo key partition

--echo Modify charset and collation

CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10)) DEFAULT charset= 'binary' DEFAULT collate = 'binary'
PARTITION BY KEY(T1) PARTITIONS 3 ;
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('abc','abc');
INSERT INTO  Z0CASE VALUES('ABC','ABC');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
SELECT * FROM Z0CASE ORDER BY T2;

SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY PARTITION_NAME;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;
SELECT * FROM Z0CASE WHERE T1='ABC';

INSERT INTO  Z0CASE VALUES('AbC','ABc');
SELECT * FROM Z0CASE WHERE T1='AbC';
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

--error 01062
UPDATE Z0CASE SET T1=NULL WHERE T2='11';
--error 01062
UPDATE Z0CASE SET T1='AbC' WHERE T2='11';
UPDATE Z0CASE SET T1='abC' WHERE T2='11';
SELECT * FROM Z0CASE ORDER BY T1;
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--error 01062
INSERT INTO  Z0CASE VALUES('abC','aBc');
INSERT INTO  Z0CASE VALUES('Abc','aBc');
SELECT * FROM Z0CASE WHERE T1='Abc';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_chinese_ci';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

--echo hash partition

--echo Modify charset and collation

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (T1 INT PRIMARY KEY,T2 VARCHAR(10)) DEFAULT charset= 'gbk' DEFAULT collate = 'gbk_bin'
PARTITION BY HASH(T1) PARTITIONS 3 ;
INSERT INTO  Z0CASE VALUES(0,11);
INSERT INTO  Z0CASE VALUES('12','abc');
INSERT INTO  Z0CASE VALUES('13.45','ABC');
INSERT INTO  Z0CASE VALUES('-55.785','$%^&*()//');
SELECT * FROM Z0CASE ORDER BY T2;

SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY PARTITION_NAME;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;
SELECT * FROM Z0CASE WHERE T1='ABC';

INSERT INTO  Z0CASE VALUES('112','ABc');
SELECT * FROM Z0CASE WHERE T1=112;
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

UPDATE Z0CASE SET T1=NULL WHERE T2='11';
--error 01062
UPDATE Z0CASE SET T1='12' WHERE T2='11';
UPDATE Z0CASE SET T1=-10 WHERE T2='11';
SELECT * FROM Z0CASE ORDER BY T1;
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_bin';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--error 01062
INSERT INTO  Z0CASE VALUES('-10','aBc');
INSERT INTO  Z0CASE VALUES(0,'aBc');
SELECT * FROM Z0CASE WHERE T1=0;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_chinese_ci';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T1;

--error 01062
INSERT INTO  Z0CASE VALUES('-10','aBc');
INSERT INTO  Z0CASE VALUES(100,'Bc');
SELECT * FROM Z0CASE WHERE T1=100;
--error 01062
UPDATE Z0CASE SET T1=12  WHERE T1=0;
UPDATE Z0CASE SET T1=102  WHERE T1=0;
SELECT * FROM Z0CASE WHERE T1=102;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

--error 01062
INSERT INTO  Z0CASE VALUES('-10','aBc');
INSERT INTO  Z0CASE VALUES(56,'AABc');
SELECT * FROM Z0CASE WHERE T1=56;
--error 01062
UPDATE Z0CASE SET T1=12  WHERE T1=13;
UPDATE Z0CASE SET T1=-102  WHERE T1=-10;
SELECT * FROM Z0CASE WHERE T1=-102;

