DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (T1 INT PRIMARY KEY,T2 VARCHAR(10)) DEFAULT charset= 'binary' DEFAULT collate = 'binary'
PARTITION BY KEY(T1) PARTITIONS 3 ;
