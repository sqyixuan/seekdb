#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 列级修改--创建普通表，带有约束，然后修改表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang@tenant_charset_test_mysql,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 01051
DROP TABLE Z0CASE;
--error 01051
DROP TABLE Z1CASE;
--enable_warnings

--echo Charset and collation of columns are not specified with constraints.

--echo not null and default

CREATE TABLE Z0CASE(T1 CHAR(20) NOT NULL,T2 VARCHAR(20) DEFAULT 'NON');
INSERT INTO Z0CASE VALUES(123,123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\','%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc','abc');
INSERT INTO Z0CASE VALUES('中文','中文');
INSERT INTO Z0CASE VALUES('',NULL);
INSERT INTO Z0CASE(T1) VALUES('');
SELECT * FROM Z0CASE ORDER BY T2*1;
SHOW CREATE TABLE Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';

ALTER TABLE Z0CASE MODIFY T1 CHAR(20) CHARACTER SET 'utf16';
SHOW CREATE TABLE Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T2*1;

INSERT INTO Z0CASE(T1) VALUES(NULL);
SELECT * FROM Z0CASE ORDER BY T2*1;

ALTER TABLE Z0CASE MODIFY T2 VARCHAR(20) CHARACTER SET 'utf16';
SHOW CREATE TABLE Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z0CASE';
SELECT * FROM Z0CASE ORDER BY T2*1;

INSERT INTO Z0CASE(T1) VALUES('TEST');
SELECT * FROM Z0CASE ORDER BY T2*1;

