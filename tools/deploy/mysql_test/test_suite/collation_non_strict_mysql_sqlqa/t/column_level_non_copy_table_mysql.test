#owner:zhenjiang.xzj
#owner group: 技术部-存储
#description: 列级修改--创建复制表，然后修改表的charset和collation
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/conn_tenant_mysql.inc

--source mysql_test/test_suite/collation_non_strict_mysql_sqlqa/include/check_schema_sync.inc
connection conn_charset_test_sys_mysql;
sleep 1;

--enable_result_log

--echo # Environmental cleaning
--disable_warnings
--error 01396
DROP USER zhang;
--enable_warnings

CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';

--source mysql_test/include/check_schema_sync.inc
connect (zhang,$OBMYSQL_MS0,zhang@tenant_charset_test_mysql,zhang,*NO-ONE*,$OBMYSQL_PORT);
connection zhang;
sleep 1;

#创建数据库charset_test
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;

#设置SQL为非严格模式
SET sql_mode='';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
--error 01051
DROP TABLE Z0CASE;
--error 01051
DROP TABLE Z1CASE;
--error 01051
DROP TABLE Z2CASE;
--enable_warnings

--echo String type

CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10));
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('abc','abc');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
SELECT * FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

CREATE TABLE Z1CASE LIKE Z0CASE;
INSERT INTO Z1CASE SELECT * FROM Z0CASE;
SHOW CREATE TABLE Z1CASE;
SELECT * FROM Z1CASE ORDER BY T1*1;
SELECT table_name,table_collation FROM information_schema.tables WHERE table_name='Z1CASE';
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z1CASE';

