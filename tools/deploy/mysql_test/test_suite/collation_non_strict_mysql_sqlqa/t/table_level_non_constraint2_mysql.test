SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
UPDATE Z0CASE SET T1='' WHERE T1='123';
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 SET('123','%^&*[];//\\','abc','中文',b'1100101','') DEFAULT 'abc',T2 INT) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
