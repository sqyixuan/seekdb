purge recyclebin;
# Environmental cleaning
DROP USER if exists zhang;
drop database IF  EXISTS charset_test;
CREATE USER 'zhang'@'%' IDENTIFIED BY 'zhang';
GRANT all ON *.* TO 'zhang'@'%';
CREATE DATABASE IF NOT EXISTS charset_test;
USE charset_test;
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
SELECT @@sql_mode;
@@sql_mode
STRICT_TRANS_TABLES,STRICT_ALL_TABLES
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
Create data
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1
(c0 CHAR(10) CHARACTER SET 'binary' COLLATE 'binary' PRIMARY KEY ,
c1 VARCHAR(50) CHARACTER SET 'gbk' DEFAULT 'NON',
c2 TEXT CHARACTER SET 'utf8mb4',
c3 ENUM('2020-12-11','2021-11-01','2020-10-21','2022-01-31','2023-06-26','2024-12-07') CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
c4 SET('101101','11011','111001','0111011','1100101','') CHARACTER SET 'utf16');
CREATE TABLE t2(c0 BINARY(10) ,c1 VARBINARY(50) ,c2 LONGBLOB ,c3 TEXT ,c4 BLOB );
CREATE PROCEDURE p1()
BEGIN
DECLARE i INT DEFAULT 1;
wh1:WHILE i <= 50000 DO
IF i < 5000 THEN
INSERT INTO t1 VALUES(i,i||'AB',10.235,'2020-12-11','101101');
ELSEIF i < 10000 THEN
INSERT INTO t1 VALUES(i,i+1,0.225,'2021-11-01','11011');
ELSEIF i < 20000 THEN
INSERT INTO t1 VALUES(i,'@ % *',110.352,'2020-10-21','111001');
ELSEIF i < 30000 THEN
INSERT INTO t1 VALUES(i,'',210.5,'2022-01-31','0111011');
ELSEIF i < 40000 THEN
INSERT INTO t1 VALUES(i,NULL,10,'2023-06-26','1100101');
ELSE
INSERT INTO t1 VALUES(i,'中文',1023.567,'2024-12-07','');
END IF;
SET i = i + 1;
END WHILE wh1;
END;
//
CREATE PROCEDURE p2()
BEGIN
DECLARE j INT DEFAULT 1;
wh2:WHILE j <= 50000 DO
IF MOD(j,11) = 0 THEN
INSERT INTO t2 VALUES(j,j||'AB',123.567,'2024-12-07 17:45:57.357','测试数据类型 & Test big data type');
ELSEIF MOD(j,7) = 0 THEN
INSERT INTO t2 VALUES(j,j+1,13.67,'2023-12-07 12:15:47.3547','测试 %!* & Test big data type');
ELSEIF MOD(j,5) = 0 THEN
INSERT INTO t2 VALUES(j,'@%*',113.5627,'2022-12-07 16:05:37.1543','(数据类型) & Test big data type');
ELSEIF MOD(j,3) = 0 THEN
INSERT INTO t2 VALUES(j,'',23.543,'2021-12-07 14:35:27.054','测试|数据|[类型] & Test big data type');
ELSEIF MOD(j,2) = 0 THEN
INSERT INTO t2 VALUES(j,NULL,0.537,'2022-12-07 02:15:19.004','<测试>{数据类型} & Test big data type');
ELSE
INSERT INTO t2 VALUES(j,'中',3.267,'2024-12-07 15:55:17.0004','测试~数据~类型 & Test big data type');
END IF;
SET j = j + 1;
END WHILE wh2;
END;
//
CALL p1();
CALL p2();
#DQL
SELECT COUNT(1) FROM t1;
COUNT(1)
50000
SELECT COUNT(1) FROM t2;
COUNT(1)
50000
