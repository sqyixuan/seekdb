| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ COUNT(*), APPROX_COUNT_DISTINCT(`l_orderkey`), SUM(CASE WHEN `l_orderkey` IS NULL THEN 1 ELSE 0 END), APPROX_COUNT_DISTINCT(`l_suppkey`), SUM(CASE WHEN `l_suppkey` IS NULL THEN 1 ELSE 0 END), APPROX_COUNT_DISTINCT(`l_shipdate`), SUM(CASE WHEN `l_shipdate` IS NULL THEN 1 ELSE 0 END), SUM(CASE WHEN  (`l_shipdate` >= '1995-01-01') and (`l_shipdate` <= '1996-12-31') THEN 1 ELSE 0 END) FROM `test`.`lineitem`         |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ COUNT(*), APPROX_COUNT_DISTINCT(`n_nationkey`), SUM(CASE WHEN `n_nationkey` IS NULL THEN 1 ELSE 0 END), APPROX_COUNT_DISTINCT(`n_name`), SUM(CASE WHEN `n_name` IS NULL THEN 1 ELSE 0 END), SUM(CASE WHEN  ((`n_name` = 'FRANCE') or (`n_name` = 'GERMANY')) THEN 1 ELSE 0 END) FROM `test`.`nation`   `n1`                                                                                                                    |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ COUNT(*), APPROX_COUNT_DISTINCT(`o_orderkey`), SUM(CASE WHEN `o_orderkey` IS NULL THEN 1 ELSE 0 END), APPROX_COUNT_DISTINCT(`o_custkey`), SUM(CASE WHEN `o_custkey` IS NULL THEN 1 ELSE 0 END) FROM `test`.`orders`                                                                                                                                                                                                            |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ COUNT(*), APPROX_COUNT_DISTINCT(`s_suppkey`), SUM(CASE WHEN `s_suppkey` IS NULL THEN 1 ELSE 0 END), APPROX_COUNT_DISTINCT(`s_nationkey`), SUM(CASE WHEN `s_nationkey` IS NULL THEN 1 ELSE 0 END) FROM `test`.`supplier`                                                                                                                                                                                                        |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ SUM(CASE WHEN  ((`n_name` = 'GERMANY') or (`n_name` = 'FRANCE')) THEN 1 ELSE 0 END) FROM `test`.`nation`   `n2`                                                                                                                                                                                                                                                                                                                |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ SUM(CASE WHEN  (`n_name` = 'FRANCE') THEN 1 ELSE 0 END) FROM `test`.`nation`   `n1`                                                                                                                                                                                                                                                                                                                                            |
| SELECT /*+ NO_REWRITE PARALLEL(256)  DYNAMIC_SAMPLING(0)  DBMS_STATS  QUERY_TIMEOUT(10000000)  OPT_PARAM('USE_DEFAULT_OPT_STAT','TRUE') */ SUM(CASE WHEN  (`n_name` = 'GERMANY') THEN 1 ELSE 0 END) FROM `test`.`nation`   `n2`                                                                                                                                                                                                                                                                                                                                           |
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

drop table t1,t2,t3,nation,customer,supplier,orders,lineitem;
