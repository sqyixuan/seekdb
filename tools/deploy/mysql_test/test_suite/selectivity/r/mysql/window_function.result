drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int, index i1(c1, c2, c3, c4));
insert into t1 select uniform(1, 10, random(1)), uniform(1, 100, random(2)), uniform(1, 200, random(3)), row_number() over () from table(generator(40000));
alter system minor freeze;
call dbms_stats.gather_table_stats(null, 't1');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 'independent';
alter system set _rowsets_enabled=false;
result_format: 4
select t1.*, count(*) over () from t1 order by 1,2,3,4 limit 10;
+------+------+------+-------+------------------+
| c1   | c2   | c3   | c4    | count(*) over () |
+------+------+------+-------+------------------+
|    1 |    1 |    8 | 35463 |            40000 |
