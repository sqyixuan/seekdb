result_format: 4
## issue: 
set optimizer_dynamic_sampling = 0;

drop table if exists t1;
create table t1(partkey int, c1 int, c2 datetime) partition by 
range(partkey) (partition p0 values less than (500), partition p1 values less than (1000), partition p2 values less than (1500), partition p3 values less than (2000));
insert into t1 select abs(random(1)) % 2000, n, DATE_ADD('2000-01-01', INTERVAL n DAY) from (select row_number() over () - 1 as n from table(generator(1000)));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 1');
insert into t1 select abs(random(2)) % 2000, n, DATE_ADD('2000-01-01', INTERVAL n DAY) from (select row_number() over () + 1000 - 1 as n from table(generator(1000)));
insert into t1 select abs(random(3)) % 2000, -n, DATE_SUB('2000-01-01', INTERVAL n DAY) from (select row_number() over () as n from table(generator(1000)));

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

explain_protocol: 2
