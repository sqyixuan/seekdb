set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = false;
set cardinality_estimation_model = 0;
drop table if exists t1;
create table t1(partkey int, c1 int, c2 int) partition by hash(partkey) partitions 4;
insert into t1 select uniform(1, 100, random(1)), 1, uniform(1, 2, random(2)) from table(generator(20000));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 10');
alter system minor freeze;
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 1 limit 0;
partkey	c1	c2
select dbms_xplan.display_cursor('', 'all');
dbms_xplan.display_cursor('', 'all')
================================================================================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|REAL.ROWS|REAL.TIME(us)|IO TIME(us)|CPU TIME(us)|
----------------------------------------------------------------------------------------------------------------
|0 |LIMIT                      |        |0       |39249       |0        |0            |0          |0           |
|1 |└─PX COORDINATOR           |        |20000   |39196       |20000    |0            |0          |0           |
|2 |  └─EXCHANGE OUT DISTR     |:EX10000|20000   |27798       |20000    |0            |0          |0           |
|3 |    └─PX PARTITION ITERATOR|        |20000   |2201        |20000    |0            |0          |0           |
|4 |      └─TABLE FULL SCAN    |t1      |20000   |2201        |20000    |0            |0          |0           |
================================================================================================================

Outputs & filters:
-------------------------------------
  0 - output([t1.partkey], [t1.c1], [t1.c2]), filter(nil), rowset=256
      limit(0), offset(nil)
  1 - output([t1.partkey], [t1.c1], [t1.c2]), filter(nil), rowset=256
  2 - output([t1.partkey], [t1.c1], [t1.c2]), filter(nil), rowset=256
      dop=1
  3 - output([t1.partkey], [t1.c1], [t1.c2]), filter(nil), rowset=256
      force partition granule
  4 - output([t1.partkey], [t1.c1], [t1.c2]), filter([t1.c1 = 1]), rowset=256
      access([t1.partkey], [t1.c1], [t1.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

