--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: yibo.tyf
# owner group: sql1
# tags: optimizer
# 基表谓词测试选择率估算

--disable_warnings
drop table if exists t_types1;
--enable_warnings

--echo SCHEMA
create table t_types1(c1 tinyint, c2 tinyint, c3 tinyint, c4 smallint, c5 smallint, c6 smallint, 
  c7 mediumint, c8 mediumint, c9 mediumint, c10 int, c11 int, c12 int, c13 bigint, c14 bigint, c15 bigint, 
  c16 timestamp, c17 timestamp, c18 timestamp, c19 date, c20 date, c21 date, 
  c22 float, c23 float, c24 float, c25 double, c26 double, c27 double, c28 decimal(19, 4), c29 decimal(19, 4), c30 decimal(19, 4),
  c31 char(20), c32 char(20), c33 char(20), c34 varchar(20), c35 varchar(20), c36 varchar(20), 
  c37 tinytext, c38 tinytext, c39 tinytext, c40 text, c41 text, c42 text, c43 mediumtext, c44 mediumtext, c45 mediumtext, c46 longtext, c47 longtext, c48 longtext
  );



--disable_query_log

# |t_types1| c1   |  c2  | c3   | c4   |  c5  | c6   | c7   |  c8  | c9   | c10  |  c11 | c12  | c13  |  c14 |  c15 |
# | -----  |------|------|------|------|------|------|------|------|------|------|------|-- ---|------|------|------|
# |  row   |                                               500                                                      |
# |  ndv   | 10   |  50  | 100  |  10  |  50  | 100  | 10   |  50  | 100  |  10  |  50  | 100  |  10  |  50  | 100  |
# | nulls  |                                                   0                                                    |

