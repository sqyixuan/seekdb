--enable_query_log
call dbms_stats.gather_table_stats('test', 't_types1', method_opt=>'for all columns size auto');

# diffrent data type

--echo tinyint

# expect 50 row
explain select * from t_types1  where c1=1; 

# expect 2 row
explain select * from t_types1  where c1=1 and c2=1; 

#!! result 3 row
explain select * from t_types1  where c1=c2; 

# expect 450 row
explain  select * from t_types1  where c1!=1;

# expect 10 row
explain select * from t_types1  where c1!=1 and c2=1;

# expect 250 row
explain select * from t_types1  where c1!=c2;

# expect 500 row
explain select * from t_types1  where c1 between 1 and 10;  

# expect 11 row
explain select * from t_types1  where c2=1 and c1 between 1 and 10;

# expect 490 row
explain select * from t_types1  where c2!=1 and c1 between 1 and 10; 

# expect 495 row
explain select * from t_types1  where c1>1;

# expect 106 row 
explain select * from t_types1  where c1<1;

# expect 500 row
explain select * from t_types1  where c1>=1;

#!! result 156 row
explain select * from t_types1  where c1<=1;

# expect 11 row
explain select * from t_types1  where c1>1 AND c2=1;

# expect 3 row
explain select * from t_types1  where c1<1 AND c2=1;

# expect 11 row
explain select * from t_types1  where c1>=1 AND c2=1;

# expect 4 row
explain select * from t_types1  where c1<=1 AND c2=1; 

# expect 0 row
explain select * from t_types1  where c1 is null; 

# expect 500 row
explain select * from t_types1  where c1 is not null;


