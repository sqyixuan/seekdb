# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

--result_format 4
## issue: 

set optimizer_dynamic_sampling = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(partkey int, c1 int, c2 datetime) partition by 
range(partkey) (partition p0 values less than (500), partition p1 values less than (1000), partition p2 values less than (1500), partition p3 values less than (2000));
insert into t1 select abs(random(1)) % 2000, n, DATE_ADD('2000-01-01', INTERVAL n DAY) from (select row_number() over () - 1 as n from table(generator(1000)));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 1');
insert into t1 select abs(random(2)) % 2000, n, DATE_ADD('2000-01-01', INTERVAL n DAY) from (select row_number() over () + 1000 - 1 as n from table(generator(1000)));
insert into t1 select abs(random(3)) % 2000, -n, DATE_SUB('2000-01-01', INTERVAL n DAY) from (select row_number() over () as n from table(generator(1000)));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--explain_protocol 2
select count(*) from t1 where c1 < 100;
select count(*) from t1 where c1 > 100;
select count(*) from t1 where c1 < -100;
select count(*) from t1 where c1 > 900;
select count(*) from t1 where c1 < 1200;
select count(*) from t1 where c1 between 100 and 800;
select count(*) from t1 where c1 between -100 and 800;
select count(*) from t1 where c1 between 910 and 1080;
select count(*) from t1 where c1 between 910 and '1080';
select count(*) from t1 where c1 between -910 and 1080;
select count(*) from t1 where c1 >= -910 and c1 < -810;
select count(*) from t1 where (c1 > 1010 and c1 < 1080) or (c1 > 1100);
select count(*) from t1 where (c1 > 1010 and c1 < 1880) or (c1 > 2100);
select count(*) from t1 where c2 <= '2001-01-01' and c2 > '1999-08-01';
select count(*) from t1 where c2 < '2001-01-01' and c2 >= '1999-08-01';
select count(*) from t1 where c2 < '2001-01-01' and c2 > '1999-08-01';
select count(*) from t1 where c2 between '2002-01-01' and '2004-01-01';
select count(*) from t1 where c2 between '2003-01-01' and '2004-01-01';
select count(*) from t1 where c2 between '1999-01-01' and '2000-02-01';
select count(*) from t1 where c2 between '1998-01-01' and date'1999-01-01';
select count(*) from t1 where c2 not between '1998-01-01' and date'1999-01-01';
select count(*) from t1 where c2 not between '1998-01-01' and '1999-01-01';
select count(*) from t1 where c2 between '1990-01-01' and '2022-01-01';
select count(*) from t1 where c2 between '2004-01-01' and date'2005-01-01';
select count(*) from t1 where c1 < 100 and partkey < 1000;
select count(*) from t1 where c1 > 1200 and partkey > 1000;
select count(*) from t1 where c1 between -100 and 800 and partkey < 1500;
select count(*) from t1 where c1 between 1010 and 1080 and partkey < 1500 and partkey > 500;
select count(*) from t1 where c1 < 1100 and c1 > 1200;

