--explain_protocol 0
drop table t1;

create table t1(partkey int, c1 int) partition by hash(partkey) partitions 4;
insert into t1 select n, case when n < 10000 then n else null end from (select row_number() over () - 1 as n from table(generator(20000)));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 1');
insert into t1 select n, case when n < 11000 then n else null end from (select row_number() over () + 10000 - 1 as n from table(generator(2000)));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--explain_protocol 2
select count(*) from t1 where c1 < 0;
select count(*) from t1 where c1 between 9000 and 12000;
select count(*) from t1 where c1 between 10000 and 12000;
select count(*) from t1 where c1 between 10000 and 12000 or c1 is null;
select count(*) from t1 where c1 > 20000 or c1 is null;
select count(*) from t1 where c1 < 0 or c1 is null;

--explain_protocol 0
drop table t1;

create table t1(pk int primary key, c1 int);
insert into t1 select n, n from (select row_number() over () - 1 as n from table(generator(10000)));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 1');
insert into t1 select n, n from (select row_number() over () + 10000 - 1 as n from table(generator(1000)));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--explain_protocol 2
select count(*) from t1 where c1 < 0;
select count(*) from t1 where c1 > 10100;
select count(*) from t1 where c1 between 9000 and 12000;
select count(*) from t1 where c1 between 10000 and 12000;
select count(*) from t1 where pk > 5000 and c1 between 10000 and 12000;

drop table t1;