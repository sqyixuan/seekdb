# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = false;
set cardinality_estimation_model = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(partkey int, c1 int, c2 int) partition by hash(partkey) partitions 4;
insert into t1 select uniform(1, 100, random(1)), 1, uniform(1, 2, random(2)) from table(generator(20000));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 10');

--source mysql_test/include/minor_merge_tenant.inc

select SQL_CALC_FOUND_ROWS * from t1 where c1 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 in (1,2) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 in (2,3,4) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 != 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 != 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 not in (0,1) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 not in (2,3,4) limit 0;
--source mysql_test/include/check_rows.inc


select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 in (1,2) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 in (2,3,4) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 != 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 != 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 not in (0,1) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c1 not in (2,3,4) limit 0;
--source mysql_test/include/check_rows.inc

select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 in (1,2) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 in (3,4) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 != 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 != 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 not in (1,2) limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 partition(p0,p1) where c2 not in (3,4,5) limit 0;
--source mysql_test/include/check_rows.inc

insert into t1 select uniform(1, 100, random(1)), 1, uniform(1, 2, random(2)) from table(generator(20000));
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

select SQL_CALC_FOUND_ROWS * from t1 where c1 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 != 2 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 not in (2,3,4) limit 0;
--source mysql_test/include/check_rows.inc

drop table t1;