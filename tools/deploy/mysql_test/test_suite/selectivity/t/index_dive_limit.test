## test empty partitions
--disable_query_log
--explain_protocol 0
create table t1(c1 int, c2 int, c3 int, index i1(c1), index i2(c2)) partition by range(c1)
(
  partition p0 values less than (20),
  partition p1 values less than (40),
  partition p2 values less than (60),
  partition p3 values less than (80),
  partition p4 values less than (100),
  partition p5 values less than (120),
  partition p6 values less than (140),
  partition p7 values less than (160),
  partition p8 values less than (180),
  partition p9 values less than (200),
  partition p10 values less than (220),
  partition p11 values less than (240),
  partition p12 values less than (260))
;
create index i3 on t1(c3) global partition by range(c3)
(
  partition p0 values less than (20),
  partition p1 values less than (40),
  partition p2 values less than (60),
  partition p3 values less than (80),
  partition p4 values less than (100),
  partition p5 values less than (120),
  partition p6 values less than (140),
  partition p7 values less than (160),
  partition p8 values less than (180),
  partition p9 values less than (200),
  partition p10 values less than (220),
  partition p11 values less than (240),
  partition p12 values less than (260))
;
insert into t1 select uniform(21, 39, random(1)), uniform(0, 99, random(2)), uniform(21, 39, random(3)) from table(generator(1000));

