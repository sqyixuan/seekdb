## test partition ranges border flag
--disable_query_log
--explain_protocol 0
create table t0(c1 int, c2 int, c3 int, primary key (c1)) partition by hash(c1) partitions 16;
create table t1(c1 int, c2 int, c3 int, index i1(c1, c2)) partition by hash(c1) partitions 16;
insert into t0 select row_number() over (), abs(random(2)) % 20, abs(random(3)) % 100 from table(generator(10000));
insert into t1 select row_number() over (), 1, abs(random(3)) % 100 from table(generator(10000));

--source mysql_test/include/minor_merge_tenant.inc
