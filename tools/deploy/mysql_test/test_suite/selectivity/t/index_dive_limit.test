select /*+opt_param('partition_index_dive_limit', 1) opt_param('range_index_dive_limit', 1)*/ count(*) from t3 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);

select count(*) from t4 where c1 in (0,1,2,3,4);
select count(*) from t4 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);
select count(*) from t4 partition (p0) where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);
select count(*) from t4 partition (p0, p1) where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);
select /*+opt_param('partition_index_dive_limit', 1)*/ count(*) from t4 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);
select /*+opt_param('partition_index_dive_limit', 1) opt_param('range_index_dive_limit', 1)*/ count(*) from t4 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);

## test partition by generated column
select count(*) from t5 where c1 in (0,1,2,3,4);
