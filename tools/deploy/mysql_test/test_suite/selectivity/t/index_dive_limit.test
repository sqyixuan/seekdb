select /*+opt_param('partition_index_dive_limit', 1)*/ count(*) from t6 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);
select /*+opt_param('partition_index_dive_limit', 1) opt_param('range_index_dive_limit', 1)*/ count(*) from t6 where c1 in (0,1,2,3,4) and c2 in (0,1,2,3,4);

## test non-template level two partition
select /*+opt_param('partition_index_dive_limit', 6)*/ count(*) from t7 where c1 between 0 and 19 or c1 between 30 and 49 or c1 between 50 and 69;
