# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = false;
set cardinality_estimation_model = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(partkey int, c1 int, c2 date) partition by 
range(partkey) (partition p0 values less than (500), partition p1 values less than (1000), partition p2 values less than (1500), partition p3 values less than (2000));
insert into t1 select uniform(0, 1999, random(1)), uniform(1, 20, random(2)), '2000-01-01' from table(generator(1000));
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'FOR ALL COLUMNS SIZE 10');
insert into t1 select uniform(0, 1999, random(3)), uniform(21, 40, random(4)), '2000-01-02' from table(generator(1000));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

select SQL_CALC_FOUND_ROWS * from t1 where c1 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 30 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 1 and partkey < 1000 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 30 and partkey < 1000 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c1 = 0 and partkey < 1000 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c2 = date'2000-01-02' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS * from t1 where c2 = date'2000-01-02' and partkey < 1000 limit 0;
--source mysql_test/include/check_rows.inc

drop table t1;