#!! result 9 rows
explain select avg(c46) from t_types3 group by c46 having c46 like 'z';
#!! result 9 rows
explain select avg(c46) from t_types3 group by c46 having c46 like '%a';
#!! result 9 rows
explain select avg(c46) from t_types3 group by c46 having c46 like 'a%';




