analyze table t_types3 compute statistics for all columns size auto;

# diffrent data type
--echo tinyint
#无having
##单列
# expect 18 rows 
explain select avg(c1) from t_types3 group by c1;
# expect 89 rows 
explain select avg(c1) from t_types3 group by c2;
##多列
# expect 900 rows 
explain select avg(c1) from t_types3 group by c1, c2;
# expect 900 rows 
explain select avg(c1) from t_types3 group by c1, c2, c3;

#有having
##范围比较
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having c1=1;
# expect 18 rows 
explain select avg(c1) from t_types3 group by c1 having c1>1;
# expect 18 rows 
explain select avg(c1) from t_types3 group by c1 having c1<1;
# expect 18 rows
explain select avg(c1) from t_types3 group by c1 having c1>=1;
# expect 18 rows 
explain select avg(c1) from t_types3 group by c1 having c1<=1;
# expect 18 rows
explain select avg(c1) from t_types3 group by c1 having c1!=1;
# expect 18 rows
explain select avg(c1) from t_types3 group by c1 having c1 between 1 and 10;
##聚合比较
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having avg(c1)=1;
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having sum(c1)=1;
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having max(c1)=1;
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having min(c1)=1;
# expect 1 rows 
explain select avg(c1) from t_types3 group by c1 having count(c1)=1;

