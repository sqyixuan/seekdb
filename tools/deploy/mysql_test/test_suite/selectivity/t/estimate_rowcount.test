--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(c0 DECIMAL(36, 27), c1 MEDIUMINT(232));
insert into test1(c0) values (80720.18065461429),(1394774),(NULL);
analyze table test1;

--enable_query_log
--explain_protocol 2
select * from test1 WHERE ! (1 & test1.c1);
select * from test1 WHERE ! (1 & ((-2232871) < (test1.c1)));
select * from test1 WHERE ! (1 & ((-2232871) < (test1.c1))) AND test1.c0 IS NULL;

drop table test1;

# issue : 
--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);
create table t4(c1 int, c2 int, c3 int);
insert into t1 select abs(random(1)) % 1000, abs(random(2)) % 1000, abs(random(3)) % 1000 from table(generator(10000));
insert into t2 select abs(random(4)) % 1000, abs(random(5)) % 1000, abs(random(6)) % 1000 from table(generator(10000));
insert into t3 select abs(random(7)) % 1000, abs(random(8)) % 1000, abs(random(9)) % 1000 from table(generator(10000));
insert into t4 select abs(random(10)) % 1000, abs(random(11)) % 1000, abs(random(12)) % 1000 from table(generator(10000));
call dbms_stats.gather_table_stats(null,'t1');
call dbms_stats.gather_table_stats(null,'t2');
call dbms_stats.gather_table_stats(null,'t3');
call dbms_stats.gather_table_stats(null,'t4');

--enable_query_log
--explain_protocol 2
select /*+leading(t1 ((t2 t3) t4))*/ count(*) from t1,t2,t3,t4 where t2.c1 = t3.c1 and t2.c3 < 10 and t3.c2 = t4.c2 and t1.c1=t4.c1 and t1.c3 < 10;
select /*+leading(t1 ((t2 t3) t4)) parallel(2) no_px_join_filter(t4 (t3 t2)) */ count(*) from t1,t2,t3,t4 where t2.c1 = t3.c1 and t2.c3 < 10 and t3.c2 = t4.c2 and t1.c1=t4.c1 and t1.c3 < 10;

drop table t1,t2,t3,t4;