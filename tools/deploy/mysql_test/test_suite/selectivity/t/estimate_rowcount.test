#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
drop table if exists t1,t2;
drop table if exists d1,d2;

create table t1(pk int, c1 int, c2 decimal(12, 5), c3 varchar(20), c_const int);
create table t2(pk int, c1 int, c2 decimal(12, 5), c3 varchar(20), c_const int);

insert into t1 select n, n % 40, n / 10, n % 10, 20 from (select row_number() over () as n from table(generator(400))); 
insert into t2 select n, n % 30 + 20, n / 30 - 10, n % 10, 10 from (select row_number() over () as n from table(generator(600)));
insert into t1 select row_number() over () + 400, null, null, null, null from table(generator(100));
insert into t2 select row_number() over () + 600, null, null, null, null from table(generator(100));
--enable_warnings

create table d1(a int(11), b int(11));
create table d2(c int(11), d int(11));
insert into d1 select n - 1, 101.0 - n from (select row_number() over () as n from table(generator(1001))); 
insert into d2 select n - 1, 101.0 - n from (select row_number() over () as n from table(generator(101)));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
call dbms_stats.gather_table_stats(null, 'd1');
call dbms_stats.gather_table_stats(null, 'd2');

--enable_query_log

--result_format 4
--explain_protocol 2
#test inequal selectivities
select count(*) from t1,t2 where t1.c1 > t2.c1;
select count(*) from t1,t2 where lnnvl(t1.c1 > t2.c1);
select count(*) from t1,t2 where t1.c1 - t2.c1 > 0;
select count(*) from t1,t2 where t1.c1 < t2.c1;
select count(*) from t1,t2 where t1.c1 >= t2.c1;
