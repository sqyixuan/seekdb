select /*+no_rewrite*/ count(*) from (select /*+no_rewrite*/ * from t1 where c1 < -1000) v1, t1 v2 where v1.c1 > v2.c1;

#test accesspath estimation
--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists t3, tp1, tp2, tp3, t_empty, t_empty_stat, tp_empty;
--enable_warnings
create table tp1(c1 int, c2 int, c3 int, c4 int, c5 char(10)) partition by hash(c1) partitions 4;
create table tp2(c1 int, c2 int, c3 int, c4 int, c5 char(10)) partition by range(c1) (partition p0 values less than(100), partition p1 values less than(200), partition p2 values less than MAXVALUE);
create table tp3(pk int primary key, c1 int, c2 int, c3 int, c4 int, c5 char(10)) partition by hash(pk) partitions 4;
create table t_empty(c1 int);
create table t_empty_stat(c1 int);
create table tp_empty(c1 int, c2 int) partition by hash(c1) partitions 4;
create table t3(c1 int, c2 double, c3 varchar(100));
insert into t3 select t1.c1+t2.c1, t1.c2+t2.c2, t1.c3 + t2.c3 from (select * from t1 where c1 < 20) t1, (select * from t2 where c1 < 30) t2;
call dbms_stats.gather_table_stats(null, 't_empty_stat');
insert into tp1 select n % 40, n / 10, n % 10, n / 30, n % 200 from (select row_number() over () as n from table(generator(4000)));
insert into tp2 select n % 400, n / 10, n % 100, n / 30, n % 200 from (select row_number() over () as n from table(generator(4000)));
insert into tp3 select n, n % 400, n / 10, n % 100, n / 30, n % 200 from (select row_number() over () as n from table(generator(4000)));
insert into t_empty_stat select n % 40 from (select row_number() over () as n from table(generator(400)));
create index tp1_i1 on tp1(c1, c2) local;
create index tp1_i2 on tp1(c3, c4, c2) local;
create index tp2_i1 on tp2(c1, c2) local;
create index tp2_i2 on tp2(c3, c4, c2) local;
create index tp2_i3 on tp2(c5) local;
create index t3_i1 on t3(c1) local;
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 'tp1');
--enable_query_log

--explain_protocol 3
# default estimation
select count(*) from t_empty;
select count(*) from tp_empty;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from t_empty_stat;
select count(*) from tp2 where c5 like '12%';
select count(*) from tp2 where c5 like '%12%';
select count(*) from (select /*+no_rewrite*/ distinct c3 from tp2 where c5 like '12%');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp2 where c5 like '%12%' and c1 = (select 2 from tp1 limit 1);
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select /*+dynamic_sampling_level(1)*/ count(*) from tp2 where c5 like '%12%' and c1 = (select 2 from tp1 limit 1);
select count(*) from tp2 where c1 < 150 and c2 < 3 and c3 > 8 and c4 < 10;
select count(*) from tp3 where pk = 1 and c1 like '%1%';
select count(*) from tp2, tp3 where tp3.pk = 1 and tp3.c1 like '%1%' and tp2.c2=tp3.c2;

# storage estimation
select count(*) from t3;
select count(*) from t3 where c1 < 32;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from t2 where c3 like '9%';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c1 = 10 and c2 < 3 and c3 > 8 and c4 < 10;
select count(*) from tp2 where c1 < 90 and c2 < 3 and c3 > 8 and c4 < 10;

# stats only
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c2 < 3 and c3 > 8 and c4 < 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c5 like '12%';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c5 like '%12%';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from (select /*+no_rewrite*/ distinct c3 from tp1 where c5 like '12%');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c5 like '%12%' and c1 = (select 2 from tp2 limit 1);
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select /*+dynamic_sampling(tp1 1)*/ count(*) from tp1 where c5 like '%12%' and c1 = (select 2 from tp2 limit 1);
CALL dbms_stats.lock_table_stats('TEST','TP1','ALL');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c1 = 10 and c2 < 3 and c3 > 8 and c4 < 10;
CALL dbms_stats.unlock_table_stats('TEST','TP1','ALL');

# dynamic sampling
select count(*) from (select /*+no_rewrite*/ distinct c3 from tp2 where c5 like '%12%');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from (select /*+no_rewrite*/ distinct c3 from tp2 where c5 like '%12%' and c1 = (select 2 from tp1 limit 1));
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1, tp2 where tp1.c1 = tp2.c1;
CALL dbms_stats.lock_table_stats('TEST','TP1','ALL');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select count(*) from tp1 where c1 = 10 and c5 like '%12%';
CALL dbms_stats.unlock_table_stats('TEST','TP1','ALL');

# like '%'
--explain_protocol 2
select count(*) from t1 where c3 like '%';
select count(*) from t1 where c3 like '%%';
select count(*) from t1 where c3 like '%%' escape '%';
select count(*) from t1 where c1 like '%';
select count(*) from t1 where c3 like '_';
select count(*) from t1 where c3 like '%%' escape '_';
select count(*) from t1 where c3 like '%%' escape '/';

# set distinct
select count(*) from (select distinct c1 from t1);
select count(*) from (select c1 from t1 union all select c1 from t1);
select count(*) from (select c1 from t1 union select c1 from t1);
select count(*) from (select c1 from t1 union select c1 from t1 union select c1 from t1);
select count(*) from (select c1 from t1 intersect select c1 from t1);
select count(*) from ((select c1 from t1 intersect select c1 from t1) intersect select c1 from t1);
select count(*) from (select c1 from t1 except select c1 from t1);
select count(*) from (select c1 from t1 except select 1 from dual);
select count(*) from ((select c1 from t1 except select 1 from dual) intersect select c1 from t1);

select 1 from (values row(1,1,1), row(2,2,2), row(3,3,3)) where 1=0;
select 1 from (values row(1,1,1), row(2,2,2), row(3,3,3)) left join t1 on 1=1 where 1=0;

drop table t1, t2, t3, tp1, tp2, tp3, t_empty, t_empty_stat, tp_empty, d1, d2;

# issue : 
--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(a tinyint unsigned, b smallint(5) unsigned, c mediumint unsigned, d int unsigned, e bigint unsigned);
insert into test1 values (255, 65535, 16777215, 4294967295, 18446744073709551615);
insert into test1 values (0, 0 ,0, 0, 0);
analyze table test1;

--enable_query_log
--explain_protocol 2
select * from test1 where a >= b;
select * from test1 where d >= c;
select * from test1 where e >= a;
select * from test1 where b + a > 65536;
select * from test1 where a > 100;
select * from test1 where b > 100;
select * from test1 where c > 100;
select * from test1 where d > 100;
select * from test1 where e > 100;

drop table test1;

