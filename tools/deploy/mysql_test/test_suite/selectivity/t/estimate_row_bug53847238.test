#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer, cross_validation

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int);
insert into t1 
select abs(random(1)) % 1000, abs(random(2)) % 100, abs(random(3)) % 10, abs(random(4)) % 10, abs(random(4)) % 2
from table(generator(10000));

--source mysql_test/include/minor_merge_tenant.inc
create index i1 on t1(c1, c2, c3);
create index i2 on t1(c1, c4);
create index i3 on t1(c5);

call dbms_stats.gather_table_stats(null, 't1');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
set ob_enable_transformation = 0;
alter system set _rowsets_enabled=false;
--enable_query_log

--enable_query_log

--result_format 4


select count(*) from (select /*+use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c1 from t1) group by c1 limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c1 from t1) group by c1 limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_aggregation*/ count(*) from (select /*+full(t1)*/ c1 from t1) group by c1 limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+full(t1)*/ c1 from t1) group by c1 limit 10);
--source mysql_test/include/check_rows.inc

select count(*) from (select /*+use_hash_distinct*/ distinct c1 from (select /*+index(t1 i1)*/ c1 from t1) limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c1 from (select /*+index(t1 i1)*/ c1 from t1) limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c1 from (select /*+full(t1)*/ c1 from t1) limit 10);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c1 from (select /*+full(t1)*/ c1 from t1) limit 10);
--source mysql_test/include/check_rows.inc

select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c1, c3 from t1) group by c1, c3 limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c2, c3 from t1) group by c2, c3 limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c1, c4 from t1) group by c1, c4 limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i2)*/ c1, c4 from t1) group by c1, c4 limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i1)*/ c2, c1 from t1) group by c2, c1 limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+index(t1 i3)*/ c5 from t1) group by c5 limit 1);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_aggregation*/ count(*) from (select /*+full(t1)*/ c5 from t1) group by c5 limit 1);
--source mysql_test/include/check_rows.inc

select count(*) from (select /*+no_use_hash_distinct*/ distinct c1, c3 from (select /*+index(t1 i1)*/ c1, c3 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c2, c3 from (select /*+index(t1 i1)*/ c2, c3 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c1, c4 from (select /*+index(t1 i1)*/ c1, c4 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c1, c4 from (select /*+index(t1 i2)*/ c1, c4 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c2, c1 from (select /*+index(t1 i1)*/ c2, c1 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c5 from (select /*+index(t1 i3)*/ c5 from t1) limit 1);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c5 from (select /*+full(t1)*/ c5 from t1) limit 1);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+no_use_hash_distinct*/ distinct c5 from (select /*+index(t1 i3)*/ c5 from t1) limit 0);
--source mysql_test/include/check_rows.inc

select count(*) from (select /*+use_hash_distinct*/ distinct c1, c3 from (select /*+index(t1 i1)*/ c1, c3 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c2, c3 from (select /*+index(t1 i1)*/ c2, c3 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c1, c4 from (select /*+index(t1 i1)*/ c1, c4 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c1, c4 from (select /*+index(t1 i2)*/ c1, c4 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c2, c1 from (select /*+index(t1 i1)*/ c2, c1 from t1) limit 200);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c5 from (select /*+index(t1 i3)*/ c5 from t1) limit 1);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c5 from (select /*+full(t1)*/ c5 from t1) limit 1);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c5 from (select /*+index(t1 i3)*/ c5 from t1) limit 0);
--source mysql_test/include/check_rows.inc
select count(*) from (select /*+use_hash_distinct*/ distinct c5 from (select /*+full(t1)*/ c5 from t1) limit 0);
--source mysql_test/include/check_rows.inc

drop table t1;
alter system set _rowsets_enabled=true;