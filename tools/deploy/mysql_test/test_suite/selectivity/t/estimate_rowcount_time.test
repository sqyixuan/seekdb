# test time expr range selectivity
select count(*) from t1 where date(c1) between date'2002-01-02' and date'2002-02-03';
select count(*) from t1 where date(c1) between date'2001-01-01' and timestamp'2002-02-02';
select count(*) from t1 where date(c1) not between date'2001-01-01' and timestamp'2002-02-02';
select count(*) from t1 where year(c1) < 2002;
select count(*) from t1 where year(c1) <= 2002;
select count(*) from t1 where year(c1) <= 2002 and year(c1) > 1996;
select count(*) from t1 where month(c1) < 5;
select count(*) from t1 where month(c1) in (1, 2, 3);
select count(*) from t1 where week(c1) > 30;
select count(*) from t1 where weekofyear(c1) > 30;
select count(*) from t1 where yearweek(c1) > 200202;
select count(*) from t1 where dayofyear(c1) > 200;
select count(*) from t1 where dayofmonth(c1) >= 10;
select count(*) from t1 where day(c1) < 13;
select count(*) from t1 where weekday(c1) < 3;
select count(*) from t1 where dayofweek(c1) < 3;
select count(*) from t1 where quarter(c1) < 4;
select count(*) from t1 where hour(c1) < 4;
select count(*) from t1 where minute(c1) < 40;
select count(*) from t1 where second(c1) < 40;
select count(*) from t1 where extract(year from c1) <= 2001;
select count(*) from t1 where extract(year_month from c1) <= 200112;
select count(*) from t1 where extract(month from c1) > 13;
select count(*) from t1 where extract(week from c1) > 13;
select count(*) from t1 where extract(day from c1) > 13;
select count(*) from t1 where extract(quarter from c1) > 2.5;
select count(*) from t1 where year(c1) = 2000 and dayofyear(c1) between 100 and 200;

select count(*) from t1 v1, t1 v2 where date(v1.c1)=date(v2.c1);
select count(*) from t1 v1, t1 v2 where v1.id % 10000 = v2.id % 5000;
select count(*) from t1 v1, t1 v2 where v1.id % 10000 = v2.id % 5000 and v1.id % 10000 = v1.c0;
select count(*) from t1 v1, t1 v2 where v1.id % 10000 = v2.id % 5000 and v1.id % 10000 = v1.c0 % 2;
select count(*) from (select distinct id % 50 from t1 where id % 50 = id % 60);

--explain_protocol 0
--disable_query_log
insert into t1 
select n, n % 100,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second
from (select row_number() over () + 50000 as n, abs(random(1)) % 3600 as m from table(generator(10000)));

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
--enable_query_log
--explain_protocol 2

select count(*) from t1 where date(c1) between date'2001-08-02' and date'2002-01-01';
select count(*) from t1 where date(c1) between date'2005-08-02' and date'2006-01-01';
select count(*) from t1 where date(c1) between date'1999-08-02' and date'2000-01-01';
select count(*) from t1 where date(c1) between date'2005-10-02' and date'2006-01-01';
select count(*) from t1 where date(c1) > '2002-09-01';
select count(*) from t1 where date(c1) > '2005-09-01';
select count(*) from t1 where date(c1) >= '2006-02-01';
select count(*) from t1 where date(c1) < '2001-09-01';
select count(*) from t1 where date(c1) < '1999-09-01';

drop table t1,t2;