#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(id int, c0 int, c1 datetime, c2 date, c3 varchar(20), c4 timestamp, c5 time);
create table t2(id int, c1 varchar(10), c2 int);
insert into t1 
select n, n % 100,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second,
       '2000-01-01' + interval n hour + interval m second
from (select row_number() over () as n, abs(random(1)) % 3600 as m from table(generator(50000)));

insert into t2 select n, lpad(n % 10000, 4, '0'), n % 101 from (select row_number() over () as n from table(generator(50000)));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 'independent';
--enable_query_log

--result_format 4
--explain_protocol 2

# test mod ndv
select count(*) from (select distinct c0 % 3 from t1) v;
select count(*) from (select distinct c0 % 3.5 from t1) v;
select count(*) from (select distinct c0 % 2, c0 % 3 from t1) v;
select count(*) from (select distinct c0 % 3, c0 % 3 as tmp from t1) v;
select count(*) from (select distinct (c0 % 3) + (c0 % 3) from t1) v;
select count(*) from (select distinct c0 % 200 from t1) v;
# bad case
select count(*) from (select distinct c0 % 99, c0 % 98 from t1) v;
select count(*) from (select distinct c0, c0 % 3 from t1) v;
select count(*) from (select distinct c0 % (-3) from t1) v;
select count(*) from (select distinct c0 % 30 + 100 from t1) v;
select count(*) from (select distinct row_number() over () % 30 from t1) v;
select count(*) from (select distinct (row_number() over () + c0) % 29 from t1) v;

# test substr ndv
select count(*) from (select distinct substr(c1, 2) from t2) v;
select count(*) from (select distinct substr(c1, -1) from t2) v;
select count(*) from (select distinct substr(c1, -2) from t2) v;
select count(*) from (select distinct substr(c1, 2, 4) from t2) v;
select count(*) from (select distinct substr(c1, 1, 5) from t2) v;

# test combined special ndv
select count(*) from (select distinct (t1.c0 + t2.c2) % 7 from t1, t2 where t1.id = t2.id) v;
select count(*) from (select distinct t1.c0, t2.c2 % 7 from t1, t2 where t1.id = t2.id) v;
select count(*) from (select distinct t1.c0, t2.c2 % 7, t2.c2 from t1, t2 where t1.id = t2.id) v;
select count(*) from (select distinct t1.c0 % 3, t2.c2 % 7 from t1, t2 where t1.id = t2.id) v;
select count(*) from (select distinct t1.c0 % 7, row_number() over(partition by t1.c0) from t1, t2 where t1.id = t2.id) v;
select count(*) from (select distinct (t1.c0 + t2.c2) % 7, t1.c0, t2.c2 from t1, t2 where t1.id = t2.id) v;

