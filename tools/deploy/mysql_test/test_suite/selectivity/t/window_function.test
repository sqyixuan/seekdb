#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, index i1(c1, c2, c3, c4));
insert into t1 select uniform(1, 10, random(1)), uniform(1, 100, random(2)), uniform(1, 200, random(3)), row_number() over () from table(generator(40000));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 'independent';
alter system set _rowsets_enabled=false;
--sleep 2
--enable_query_log

--result_format 4

select t1.*, count(*) over () from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (order by c1, c2, c3, c4) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1), count(*) over () from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2, c3) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2, c3, c4) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2 order by c3, c4) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2), count(*) over (partition by c1) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1 order by c2, c3, c4 rows between 5 preceding and 5 following) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1 order by c2, c3, c4 rows between unbounded preceding and 5 following) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1 order by c2 range between 5 preceding and 5 following) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc
select t1.*, count(*) over (partition by c1, c2), count(*) over (partition by c3, c4) from t1 order by 1,2,3,4 limit 10;
--source mysql_test/include/check_rows.inc

drop table t1;
alter system set _rowsets_enabled=true;