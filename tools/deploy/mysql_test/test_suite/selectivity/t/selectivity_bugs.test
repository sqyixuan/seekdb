# tags: selectivity, optimizer

--disable_warnings
drop table if exists t15;
--enable_warnings

create table t15 (c4 int, c5 CHAR(142) ,c6 VARCHAR(71) ,c7 INTEGER,c8 NUMERIC(37,9) ,c9 DATE,c10 VARCHAR(71) ,c11 CHAR(69) ,c12 TIMESTAMP(3)  NOT NULL default timestamp'1970-01-01 08:00:01',c13 INTEGER, primary key(c4,c7,c10)) ;

(SELECT T15_9.C4 AS c2 FROM (SELECT (SELECT T15.C4 FROM T15 ) AS C4 FROM T15) T15_9 GROUP BY T15_9.C4 HAVING sum(T15_9.C4) <= 624) INTERSECT (SELECT 3 FROM T15 T17_13);


--disable_warnings
drop table if exists t15;
--enable_warnings
