#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

create table t1(id int, c1 varchar(10), c2 varchar(20));
create table t2(id int, c1 varchar(10), c2 varchar(20));
create table t3(c1 char(10), c2 nchar(10), c3 nvarchar(10), c4 text, c5 date, c6 double, c7 int, c8 decimal, c9 binary(10), c10 varbinary(10));
create table t4(id int, c1 varchar(10));
create table t5(id int, c1 varchar(10) collate gb18030_bin);
create index i1 on t1(c1);
create index i2 on t2(c1);
create index i3 on t1(c2);
create index i4 on t4(c1);
create index i5 on t5(c1);

insert into t1 select n, LPAD(n % 10000, 4, '0'), LPAD(n % 1000, 3, '0') from (select row_number() over () as n from table(generator(50000)));
insert into t2 select n, LPAD(hex(n % conv('1000', 16, 10)), 3, '0'), LPAD(hex(n % conv('100', 16, 10)), 2, '0') from (select row_number() over () as n from table(generator(20480)));
insert into t3 select n, n, n, n, '2000-01-01' + interval n day, n, n, n, n, n from (select row_number() over () % 10000 as n from table(generator(50000)));
insert into t4 select id, c1 from t1 where id <= 20000;
insert into t4 select id + 20000, NULL from t1 where id > 20000 and id <= 40000;
insert into t5 select n, convert(unhex(conv(((129 + floor(n / 63)) * 256 + 64 + n % 63), 10, 16)) using gb18030) from (select row_number() over () % 1000 as n from table(generator(5000)));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
call dbms_stats.gather_table_stats(null, 't3');
call dbms_stats.gather_table_stats(null, 't4');
call dbms_stats.gather_table_stats(null, 't5');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
--enable_query_log

--result_format 4
--explain_protocol 2

# test like with const param
select /*+no_rewrite*/ count(*) from t1 where c1 like '%';
select /*+no_rewrite*/ count(*) from t1 where c1 like '';
select /*+no_rewrite*/ count(*) from t1 where c1 like NULL;
select count(*) from t1 where c1 like '%123';
select count(*) from t1 where c1 like '_123';
select count(*) from t1 where c1 like '%%123';
select count(*) from t1 where c1 like '%123' escape '%';
select count(*) from t1 where c1 like '%123%';
select count(*) from t1 where c1 like '%123_';
select count(*) from t1 where c1 like '%1234_';
select count(*) from t1 where '12345' like concat(c1, '%');

# test like with dynamic param
select count(*) from t1 where c1 like concat((select c2 from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat('1', (select c2 from t1 where id = 872), '%');
select count(*) from t2 where c1 like concat((select c2 from t2 where id = 872), '%');
select count(*) from t1 where c1 like (select concat(c1, '%') from t2 where id = 872);
select (select count(*) from t1 where c1 like concat(v.c1, '%')) from t1 v where id < 10;
select (select count(*) from t2 where c1 like concat(v.c1, '%')) from t2 v where id < 10;
select /*+no_rewrite*/ (select count(*) from t1 where c1 like v.c1) from (select concat(c1, '%') as c1 from t2 where id < 10) v;
select count(*) from t1 where c1 like (select concat(c1, '%') from t1 v2 where v2.id = t1.id) and t1.c2 = '099';

# test like in join condition
select /*+leading(t1 t2)*/ count(*) from t1,t2 where t1.c1 like concat(t2.c1, '%') and t2.id < 10;
select /*+leading(t2 t1) index(t1 i1)*/ count(*) from t1,t2 where t1.c1 like concat(t2.c1, '%') and t2.id < 10;
select /*+no_semi_to_inner*/ count(*) from t2 where exists (select 1 from t1 where t1.c2 like concat(t2.c1, '%'));
select /*+no_semi_to_inner*/ count(*) from t2 where exists (select 1 from t1 where t2.c1 like concat(t1.c2, '%') and id < 100) and id < 100;
select count(*) from t2 where not exists (select 1 from t1 where t1.c2 like concat(t2.c1, '%'));
select count(*) from t2 where not exists (select 1 from t1 where t2.c1 like concat(t1.c2, '%') and id < 100) and id < 100;

# test dynamic param in the inline view
select count(*) from (select /*+no_rewrite*/ * from t1) v where c1 like concat((select c2 from t1 where id = 872), '%');
select count(*) from (select /*+no_rewrite*/ * from (select /*+no_rewrite*/ * from t1) v1) v2 where c1 like concat((select c2 from t1 where id = 872), '%');
select /*+no_rewrite*/ count(*) from t1 v1, lateral(select 1 from t1 where c1 like concat(v1.c1, '%')) v2 where v1.id < 1000;
select /*+no_rewrite*/ count(*) from t1 v1, (select /*+no_rewrite*/ * from t1) v2 where v2.c1 like concat(v1.c1, '%') and v1.id < 1000;

# test substr
select count(*) from t1 where c1 like concat((select substr(c2, 1) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, NULL) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, -2) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, -2, 4) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, 0, 2) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, NULL, 2) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, 1, 2) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, 1, NULL) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, 1.3, 2.5) from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, '1', '2') from t1 where id = 872), '%');
select count(*) from t1 where c1 like concat((select substr(c2, 1, 6) from t1 where id = 872), '%');

# test different type
select count(*) from t3 where c1 like '%123';
select count(*) from t3 where c2 like '%123';
select count(*) from t3 where c3 like '%123';
select count(*) from t3 where c4 like '%123';
select count(*) from t3 where c5 like '%10';
select count(*) from t3 where c6 like '%123';
select count(*) from t3 where c7 like '%123';
select count(*) from t3 where c8 like '%123';
select count(*) from t3 where c9 like '%123';
select count(*) from t3 where c10 like '%123';

# default selectivity
select count(*) from t3 where '12345' like concat(c1, '%');
select count(*) from t3 where '12345' like concat(c2, '%');
select count(*) from t3 where '12345' like concat(c3, '%');
select count(*) from t3 where '12345' like concat(c4, '%');
select count(*) from t3 where '2000-01-02' like concat(c5, '%');
select count(*) from t3 where '12345' like concat(c6, '%');
select count(*) from t3 where '12345' like concat(c7, '%');
select count(*) from t3 where '12345' like concat(c8, '%');
select count(*) from t3 where '12345' like concat(c9, '%');
select count(*) from t3 where '12345' like concat(c10, '%');

# test null
select count(*) from t4 where c1 like '%456';
select count(*) from t4 where c1 like concat((select c2 from t1 where id = 872), '%');
select (select count(*) from t4 where c1 like concat(v.c1, '%')) from t1 v where id < 10;
select /*+leading(t4 t2)*/ count(*) from t4,t2 where t4.c1 like concat(t2.c1, '%') and t2.id < 10;
select /*+no_semi_to_inner*/ count(*) from t1 where exists (select /*+index(t1 i1)*/ 1 from t4 where t4.c1 like concat(t1.c1, '%'));
select count(*) from t1 where not exists (select /*+index(t1 i1)*/ 1 from t4 where t4.c1 like concat(t1.c1, '%'));

# test Chinese character, inaccurate estimation
select count(*) from t5 where c1 like concat((select '丄' from t5 limit 1), '%');
select count(*) from t5 where c1 like concat((select substr('丄丄丄', 3) from t5 limit 1), '%');
select count(*) from t5 where c1 like concat((select substr(c1, 1, 1) from t5 limit 1), '%');
select count(*) from t5 where c1 like _gb18030 0x25815e;
select count(*) from t5 where c1 like _gb18030 0x25815f;
select count(*) from t5 where c1 like _gb18030 0x25815f25;
select count(*) from t5 where c1 like _gb18030 0x255f25;

drop table t1,t2,t3,t4,t5;