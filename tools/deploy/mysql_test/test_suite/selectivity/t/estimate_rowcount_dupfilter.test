#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 varchar(10), index i1(c3));
insert into t1 select abs(random(1)) % 100, abs(random(1)) % 100, abs(random(2)) % 100, abs(random(3)) % 3, lpad(abs(random(4)) % 1000, 3, '0') from table(generator(100000));
update t1 set c4 = NULL where c4 = 2;

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 0;
set ob_enable_transformation = 0;

--enable_query_log

--result_format 4
--explain_protocol 2

# correlated
select count(*) from t1 where c1 = 1 and c1 = 1;
select count(*) from t1 where c1 = 1 and c1 < 50;
select count(*) from t1 where c1 in (1,2,3) and c1 in (1,2,3,4,5);
select count(*) from t1 where c1 in (1,2,3) and c1 in (1,2,3,4,5) and c1 not in (9,8,7);
select count(*) from t1 where c1 in (1,2,3) and c1 not in (99,98,97,96);
select count(*) from t1 where c1 = 1 and c1 = (select 1 from dual);
select count(*) from t1 where c1 = 1 and c1 != 2;
select count(*) from t1 where c1 = 1 and (c1 = 1 or c1 = 2);
select count(*) from t1 where c5 = '123' and c5 like '123%';
select count(*) from t1 where c5 like '1%' and c5 like '123%';
select count(*) from t1 where c5 not like '9%' and c5 like '123%';
select (select count(*) from t1 v2 where c1 = v1.c1 and c1 = 0) from t1 v1 order by c1 limit 1;
select (select count(*) from t1 v2 where c1 = v1.c1 and c1 = v1.c2) from t1 v1 order by c1 limit 1;
select /*+leading(v1 v2) use_nl(v2)*/ count(*) from (select * from t1 where c3 = 0 limit 10) v1, t1 v2 where v2.c3 = v1.c1 and v2.c3 = v1.c2;
select count(*) from t1 where cast(c1 as char) = '1' and c1 = 1;
select count(*) from t1 where c1 = 1 and c1 between '0' and 2;
select count(*) from t1 where c4 is not null and c4 = 1;
select count(*) from t1 where c4 and c4 = 1;
select count(*) from t1 where c1 in (1,2,3) and c1 in (1,2,3,4) or c3 in (1,2,3) and c3 in (1,2,3,4);
select count(*) from t1 where c1 = 1 or c1 = 2 or c1 between 4 and 5;
select count(*) from t1 where c1 in (1,2,3,4,5,6,7,8) or c1 between 20 and 40;
select count(*) from t1 where c1 = 1 and (c1,c2) < (10, 10);
select count(*) from t1 where c1 = 1 and 1 = 1 or c1 = 2 and 1 = 1 or c1 = 1 and 1 = 0 or c1 = 2 and 1 = 0;
select count(*) from t1 where (c1 = 1 and 1 = 1 or c1 = 2 and 1 = 1 or c1 = 1 and 1 = 0 or c1 = 2 and 1 = 0) and c1 = 1;
select count(*) from t1 where (c1 = 1 and 1 = 1 or 1 = 1 and c1 = 2 or c1 = 1 and 1 = 0 or c1 = 2 and 1 = 0) and c1 in (1,2);
select count(*) from t1 where (c1, c4) in ((1,1),(1,2),(1,3)) and (c1, c4) in ((1,1),(1,2));
select count(*) from t1 where c3 = 1 and c3 + 1 = 2;
select count(*) from t1 where c3 - 1 = 0 and c3 + 1 = 2;
select count(*) from t1 where c3 = 1 and c3 + 1 in (1, 2);
select count(*) from t1 where c3 = 1 and (c3, 1) = (1, 1);
select count(*) from t1 where (c3 + 1, 2) in ((2, 2), (3, 2)) and (c3, 1) = (1, 1);

# independent
select count(*) from t1 where c1 % 2 = 0 and c1 % 3 = 0;
select count(*) from t1 where c1 in (1,2,3,4,5,6,7,8) or c3 between 20 and 40;
select count(*) from t1 where (c1 = 1 and c3 > 50) or (c2 = 2 and c4 is null);

drop table t1;