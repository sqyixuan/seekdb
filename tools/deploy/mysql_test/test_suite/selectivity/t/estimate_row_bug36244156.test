--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yht146439
#owner group: sql1
# tags: optimizer
#this file try to verify the output rows estimated from storage engine

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

alter system set undo_retention = 900;

create table t1(a int primary key);
create table t2(a int);

--disable_query_log
--disable_result_log
--let $count = 1
while($count < 10001)
{
  --let $stmt=insert into t2(a) values ($count)
  eval $stmt;
  inc $count;
}
insert into t1 select a from t2;
delete from t1 where a < 8001;
insert into t1 select a from t2 where a < 8001;
delete from t1 where a < 8001;
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');
--result_format 4
explain basic select * from t1 where a > 1 and a < 9999;


