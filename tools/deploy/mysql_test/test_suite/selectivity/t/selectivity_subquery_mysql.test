# group expect 450 rows SEL=0.5
explain select * from t_types3 where exists(select  c1 from t_types3);
explain select * from t_types3 where exists(select distinct c1 from t_types3);
explain select * from t_types3 where exists(select  c2 from t_types3);
explain select * from t_types3 where exists(select distinct c2 from t_types3);

# group expect 450 rows
explain select * from t_types3 where exists(select  c1 from t_types3);
explain select * from t_types3 where exists(select distinct c1 from t_types3);

# result 891 rows
explain select * from t_types3 where c1=ANY(select c1 from t_types3);
# result 891 rows
explain select * from t_types3 where c1=ANY(select distinct c1 from t_types3);

# group result 1369 rows
explain select * from t_types3 where c1=ANY(select  c2 from t_types3);
explain select * from t_types3 where c1=ANY(select distinct c2 from t_types3);

