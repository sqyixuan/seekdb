c2 VARCHAR(10));
insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');

drop trigger if exists trg_delete;

create trigger trg_delete before delete on t2 for each row
delete from t1 where c0=old.c0;

delete from t2 where c0 = 2;
select * from t2 order by 1;
select * from t1 order by 1;

alter table t1 modify c0 int default 0 not null;
alter table t2 modify c0 int default 0 not null;
