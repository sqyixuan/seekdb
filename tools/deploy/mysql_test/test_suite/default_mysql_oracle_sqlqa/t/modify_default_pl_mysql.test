select * from t2 order by 1;
select * from t1 order by 1;


#在触发器中执行修改列为默认非空列

--error 0,1051
drop table t1;
drop table if exists t2;
create table t1(c1 int default null,
c2 int);
create table t2(c1 int default null,
c2 int);

--ERROR 0,1360
drop trigger trg_insert;
delimiter /;
--ERROR 0,1422
create trigger trg_insert
after insert on t1
for each row
begin
alter table t2 modify c1 int default 9999 not null;
end;
/
delimiter ;/
--ERROR 0,1422
drop trigger if exists trg_update;
delimiter /;
--error 0,1422
create trigger trg_update
after update on t1
for each row
begin
alter table t2 modify c1 int default 9999 not null;
end;
/
delimiter ;/

--ERROR 0,1422
drop trigger if exists trg_delete;
delimiter /;
--error 0,1422
create trigger trg_delete
after delete on t1
for each row
begin
alter table t2 modify c1 int default 9999 not null;
end;
/
delimiter ;/

#修改存储过程引用列为非空有默认值列

--error 0,1051
drop table t1;
create table t1(id int primary key auto_increment,
name varchar(20),
pwd int default '123456' not null,
verify varchar(20) default 'qwe123' not null);

insert into t1(id,name,pwd,verify) values(1,'people1',123456,'qwe123');

drop procedure if exists p1;
delimiter /;
create procedure p1(n int)
begin
declare i int default(select count(*) from t1);
declare name varchar(20) default " ";
if i>=n then
select count(*) from t1;
else
while n > i DO
set i = i+1;
set name=(select concat('people',i));
insert into t1(name)values(name);
end while;
select * from t1;
end if;
END;
/
delimiter ;/
call p1(100);

alter table t1 modify name varchar(20) default 'unknow' not null;
insert into t1(verify) values('qwe223'),('qwer23');
select * from t1;


#创建自定义函数，然后修改引用列为有默认值非空列，最后调用函数

--error 0,1051
drop table t1;
create table t1(c0 int,
c1 varchar(10));
insert into t1 values(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E'),(6,'F'),(7,'G');

drop table if exists t2;
create table t2(c0 int,
c1 varchar(10));
insert into t2 values(10,'A'),(20,'B'),(30,'C'),(40,'D'),(50,'E'),(60,'F'),(70,'G');

drop function if exists f1;
delimiter /;
create function f1(d int)
returns varchar(100)
begin
declare d1 int;
declare d2 int;
declare d3 varchar(100);
if d > 10 then
	insert into t1 values(d+100,'test1'),(d+200,'test2'),(d+300,'test3');
	insert into t2 values(d-50,'a'),(d-60,'b'),(d-70,'c');
elseif d <= 10 then
	insert into t1(c0) select c0 FROM t2 WHERE c0 <= 10;
	insert into t2(c1) select c1 FROM t1 WHERE c0 <= 10;
end if;

select count(c1) into d1 from t1;
select count(c0) into d2 from t2;

set d3 = concat('t1表执行函数后条目合计：',d1,',','t2表执行函数后条目合计：',d2);
return d3;

end
/

delimiter ;/
alter table t2 modify c0 int default 9999 not null;
alter table t1 modify c1 varchar(10) default 'unknow' not null;
select f1(11);
select * FROM t1;
select * FROM t2;
select f1(9);
select * FROM t1;
select * FROM t2;

DROP FUNCTION IF EXISTS f1;



--disable_warnings
drop database if exists yx5493;
--enable_warnings
PURGE RECYCLEBIN;