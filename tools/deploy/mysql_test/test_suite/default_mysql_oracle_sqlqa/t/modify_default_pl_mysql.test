#description：mysql模式default 'xxx' not null-在PL中进行对表的增、删、改、查操作，查看改列的值状况
# tags: DDL,DML,PL
#auther：wb-yx01449353

--echo # 环境清理
purge recyclebin;
--result_format 4


let $char_charset = 'UTF8';
--enable_result_log

--disable_warnings
drop DATABASE IF EXISTS yx5493;
--enable_warnings

#创建数据库yx5493
CREATE DATABASE IF NOT EXISTS yx5493;
USE yx5493;


#MySQL-TC-7

#创建事务、触发器、存储过程、自定义函数，修改引用列为非空列，然后再执行

--error 0,1051
drop table t1;
create table t1(c0 float,
c1 int default null,
c2 varchar(10));

insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');
set @@autocommit=0;

#回滚修改普通列为非空列操作，然后插入数据后再回滚，最后提交

BEGIN;
ALTER TABLE t1 MODIFY c1 INT default 0 not null;
ROLLBACK;
show create table t1;

insert into t1 values(8,30,'G'),(9,30,'H'),(10,-50,'I'),(11,28,'G'),(12,40,'K'),(13,50,'L');
select * FROM t1 ORDER BY 1;
rollback;

select * from t1 order by 1;
insert into t1(c0,c2) values(14,'M'),(15,'N');
select * FROM t1 ORDER BY 1;
rollback;

select * from t1 order by 1;
commit;


#在事务中修改列为非空列，并设置savepoint进行回滚

--error 0,1051
drop table t1;
CREATE TABLE t1(c0 FLOAT,
c1 INT,
c2 VARCHAR(10) default null);
insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');

BEGIN;
insert into t1 values(8,21,'H');
SAVEPOINT s1;
ALTER TABLE t1 MODIFY c2 varchar(10) default '空' not null;
SAVEPOINT s2;
insert into t1(c0) values(9),(10),(11);
select * FROM t1 ORDER BY 1;

--ERROR 1305 (42000): savepoint does not exist
ROLLBACK TO s1;

ROLLBACK TO s2;
select * FROM t1 ORDER BY 1;
SHOW CREATE TABLE t1;

COMMIT;

#事务开始前修改列为非空列，在事务中校验非空列的插入和回滚

--error 0,1051
drop table t1;
CREATE TABLE t1(c0 FLOAT,
c1 INT,
c2 VARCHAR(10) default null);
insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');
ALTER TABLE t1 MODIFY c2 varchar(10) default '空' not null;

BEGIN;
insert into t1 values(8,21,'H');
SAVEPOINT s1;
insert into t1(c0) values(9),(10),(11);
select * FROM t1 ORDER BY 1;
SAVEPOINT s2;

rollback to s1;
select * from t1 order by 1;

commit;
insert into t1(c0) values(15),(16);
select * FROM t1 ORDER BY 1;


#回滚到最后一个savepoint

--error 0,1051
drop table t1;
CREATE TABLE t1(c0 FLOAT(5,0),
c1 INT default null,
c2 VARCHAR(10))
PARTITION BY RANGE(c1)
(PARTITION p1 values LESS THAN(15),
PARTITION p2 values LESS THAN(25),
PARTITION p3 values LESS THAN(35)
);

insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');

ALTER TABLE t1 MODIFY c1 INT default -1 not null;
SHOW CREATE TABLE t1;


BEGIN;
SAVEPOINT s1;
insert into t1 values(9,34,'H'),(10,22,'I'),(11,28,'J'),(12,-50,'K'),(13,31,'L'),(14,1,'M');
SAVEPOINT s2;
insert into t1(c0) values(15),(16);

ROLLBACK TO s2;
select * FROM t1 ORDER BY 1;

COMMIT;
insert into t1(c0) values(15),(16);
select * from t1 order by 1;

SET @@AUTOCOMMIT=1;


#修改触发器引用列

#after insert

--error 0,1051
drop table t1;
drop table if exists t2;
create table t1(c1 int,
c2 int);
create table t2(c1 int,
c2 int);

drop trigger if exists trg_insert;
create trigger trg_insert 
after insert on t1
for each ROW
insert into t2
values(new.c1,2*new.c2);

insert into t1 values(1,2);
select * from t1;
select * from t2;

alter table t2 modify c2 int default 0 not null;
show create table t2;

insert into t1 values(10,100);
insert into t2(c1) values (100),(1000);
select * from t1;
select * from t2;

alter table t1 modify c1 int default 1 not null;
insert into t2 values(100,1000);
insert into t1(c2) values(3),(4);
select * from t1;
select * from t2;


#before update

drop table if exists t2;
create table t2(c0 int,
c1 int);
insert into t2 values(1,0),(2,2),(3,4),(4,8),(5,16),(6,18),(7,20);

--error 0,1051
drop table t1;
CREATE TABLE t1(c0 INT,
c1 INT,
c2 VARCHAR(10));
insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,8,'D'),(5,16,'E'),(6,18,'F'),(7,20,'G');

drop trigger if exists trg_update;

delimiter /;

create trigger trg_update before update on t2 for each row
begin
	declare c int;
	select count(c0) into c from t1;
	
	if c >= 20 then
		update t1 set c1=OLD.c0 where c0=OLD.c0;
	else
		insert into t1 values(OLD.c0,null,'AA');
	end if;
end
/
delimiter ;/

update t2 set c1 = 1 where c1 = 0;
select * from t2 order by 1;
select * from t1 order by 1;

alter table t1 modify c0 int default 0 not null;
alter table t2 modify c0 int default 0 not null;
insert into t1(c1) values(24);
insert into t2(c1) values(24);
select * from t2 order by 1;
select * from t1 order by 1;


#after delete

