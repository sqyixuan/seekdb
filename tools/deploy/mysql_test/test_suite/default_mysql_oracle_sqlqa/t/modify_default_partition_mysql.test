#复合分区 range hash
#修改子分区键为非空和有默认值

--error 0,1051
drop table t1;
create table t1(c0 float,
c1 int,
c2 varchar(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 values less than('10'),
partition r2 values less than('20'),
partition r3 values less than('30'),
partition r4 values less than('40'));

insert into t1 values(1,1,'1'),(2,2,'2'),(3,0,'3'),(4,-20,'-5'),(5,6,'-10'),(6,-10,'11'),(7,7,'15');

alter table t1 modify c1 int default 0 not null;
show create table t1;

insert into t1 values(8,18,'28');
delete from t1 where c1 = 0;
insert into t1(c0) values(9),(10);
select * from t1;


#修改主分区键为非空和有默认值

--error 0,1051
drop table t1;
create table t1(c0 float,
c1 int,
c2 varchar(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 values less than('10'),
partition r2 values less than('20'),
partition r3 values less than('30'),
partition r4 values less than('40'));

insert into t1 values(1,1,'1'),(2,2,'2'),(3,0,'3'),(4,-20,'-5'),(5,6,'-10'),(6,-10,'11'),(7,7,'15');

--error 0,4016
alter table t1 modify c2 varchar(10) default '0' not null;

show create table t1;

insert into t1 values(8,18,'28');
delete from t1 where c1 = 0;
insert into t1(c0) values(9),(10);
select * from t1;



--disable_warnings
drop database if exists yx5493;
--enable_warnings
PURGE RECYCLEBIN;