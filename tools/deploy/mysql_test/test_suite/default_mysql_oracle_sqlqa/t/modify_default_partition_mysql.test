PARTITION BY HASH(c1)
(PARTITION p1,PARTITION p2,PARTITION p3);

insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,14,'D'),(5,17,'E'),(6,20,'F'),(7,23,'G');

