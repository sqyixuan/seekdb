#key 分区
#修改分区键为非空和默认值

--error 0,1051
drop table t1;
create table t1(c0 float,
c1 int,
c2 varchar(10))
PARTITION BY KEY(c1) PARTITIONS 3;

insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,14,'D'),(5,17,'E'),(6,20,'F'),(7,23,'G');

alter table t1 modify c1 int default 123 not null;
show create table t1;

insert into t1 values(8,33,'H');
insert into t1(c0) values(9),(10);
select * from t1;


#修改非分区键为非空和默认值

--error 0,1051
drop table t1;
create table t1(c0 float,
c1 int,
c2 varchar(10))
PARTITION BY KEY(c1) PARTITIONS 3;

insert into t1 values(1,0,'A'),(2,2,'B'),(3,4,'C'),(4,14,'D'),(5,17,'E'),(6,20,'F'),(7,23,'G');

alter table t1 modify c2 varchar(10) default 'XX' not null;
