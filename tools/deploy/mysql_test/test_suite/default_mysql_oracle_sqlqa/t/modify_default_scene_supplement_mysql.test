#owner：dachuan.sdc
#owner group：SQL2
#description：mysql模式default 'xxx' not null-场景和补充用例
# tags: DDL,DML
#auther：wb-yx01449353

--echo # 环境清理
purge recyclebin;
--result_format 4


let $char_charset = 'UTF8';
--enable_result_log

--disable_warnings
drop DATABASE IF EXISTS yx5493;
--enable_warnings

#创建数据库yx5493
CREATE DATABASE IF NOT EXISTS yx5493;
USE yx5493;


#MySQL-TC-8
#场景
#MySQL-TC-8-1
#创建表(default null)，创建default 'XXX' not null
--error 0,1051
drop table t1;
create table t1(
c0 int,
c1 varchar(4));
alter table t1 modify c0 int default 0 not null;
show create table t1;

insert into t1(c1) values('a'),('b'),('c');
select * from t1;

#建表时添加default null
--error 0,1051
drop table t1;
create table t1(
c0 int default null,
c1 varchar(4));
alter table t1 modify c0 int default 0 not null;
show create table t1;

insert into t1(c1) values('a'),('b'),('c');
select * from t1;


#MySQL-TC-8-2
#创建表(default null)，插入空值，创建default 'XXX' not null
--error 0,1051
drop table t1;
create table t1(
c0 INT,
c1 FLOAT);
insert into t1 values(1,2),(null,22),(11,222),(null,2222);
--error 1138 (22004)
alter table t1 modify c0 int default 100 not null;


#建表时添加default null
--error 0,1051
drop table t1;
create table t1(
c0 INT default null,
c1 FLOAT);
insert into t1 values(1,2),(null,22),(11,222),(null,2222);
--ERROR 1138 (22004)
alter table t1 modify c0 int default 100 not null;


--error 0,1051
drop table t1;
create table t1(
c0 INT default null,
c1 FLOAT);
insert into t1 values(null,2),(null,22),(null,222),(null,2222);
--ERROR 1067 (42000)
alter table t1 modify c0 int default null not null;


#MySQL-TC-8-3
#创建表(default null)，插入非空值，创建default 'XXX' not null
--error 0,1051
drop table t1;
create table t1(
c0 INT,
c1 int);
insert into t1 values(1,2),(11,22);

alter table t1 modify c0 int default 999 not null;
alter table t1 change c1 c1 int default 9999 not null;
show create table t1;
select c0,c1 FROM t1;

#建表时添加default null
--error 0,1051
drop table t1;
create table t1(
c0 INT default null,
c1 int default null);
insert into t1 values(1,2),(11,22);

alter table t1 modify c0 int default 999 not null;
alter table t1 change c1 c1 int default 9999 not null;
show create table t1;
select c0,c1 FROM t1;

insert into t1(c0) values(111),(1111);
insert into t1(c1) values(222),(2222);
select c0,c1 FROM t1;


#MySQL-TC-8-4
#调整多列default 'XXX' not null
--error 0,1051
drop table t1;

CREATE TABLE t1(c0 INT default null,
c1 FLOAT default null,
c2 DOUBLE);
insert into t1 values(0,1.5,1.12),(-1,2.5,2.23),(5,3.5,3.34),(4,4.5,4.45),(3,5.15,5.56);

# now we can support add not null constraint on two columns
alter table t1 modify c0 int default 100 not null,modify c1 float default 100 not null;
show create table t1;

select c0,c1,c2 FROM t1 ORDER by 1;

insert into t1(c2) values(5.66),(6.55);
select c0,c1,c2 FROM t1 ORDER by 1;


#MySQL-TC-8-5
#不同类型列转换并加默认值约束
--error 0,1051
drop table t1;
create table t1(c0 varchar(10) default null,
c1 varchar(10));
alter table t1 modify c0 char(10) default 'AAA' not null;
alter table t1 modify c0 int default 123 not null;


--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 int);
insert into t1 values(1,0),(101,22),(66,999);

alter table t1 modify c0 char(10) default '00' not null;
select c0,c1 from t1 order by 1;
insert into t1(c1) values(22),(333),(4444);
select c0,c1 from t1 order by 1;


#改列和非空约束分开执行(先改列)
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 int);
insert into t1 values(1,0),(101,22),(66,999);

alter table t1 modify c0 char(10);
alter table t1 modify c0 char(10) default '00' not null;
select c0,c1 from t1 order by 1;

insert into t1(c1) values(22),(333),(4444);
select c0,c1 from t1 order by 1;

#改列和非空约束分开执行(先加约束)
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 int);
insert into t1 values(1,0),(101,22),(66,999);

alter table t1 modify c0 int default '00' not null;
alter table t1 modify c0 char(10) default '00' not null;
select c0,c1 from t1 order by 1;

insert into t1(c1) values(22),(333),(4444);
select c0,c1 from t1 order by 1;




#MySQL-TC-8-6
#字符列的值为混合值，然后修改列为default 'XXX' not null
--error 0,1051
drop table t1;
CREATE TABLE t1(c0 BINARY(10) default null,
c1 VARBINARY(10));

insert into t1 values(5.12,'% '),(10.23,0),('te st','te st'),(4.45,13),('$$',NULL),('',20),('中文','test');

alter table t1 modify c0 binary(10) default '待输入' not null;
select * FROM t1 ORDER by 1;

insert into t1(c1) values(null),(1);
select * from t1 order by 1;


#MySQL-TC-8-7
#default '内置函数（max、min）' not null
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 float not null default 0);
--error 1064
alter table t1 modify c0 int default max(10) not null;


#MySQL-TC-8-8
#default '自定义变量' not null
set @p=1;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float);
--error 1064
alter table t1 modify c0 int default @p not null;


#MySQL-TC-8-9
#default '表达式' not null
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float not null default 0);
alter table t1 modify c0 int default (1+1) not null;

drop table t1;
create table t1(c1 float default null,c2 int);
alter table t1 modify c1 float default (RAND() * RAND()) not null;

drop table t1;
create table t1(c1 BINARY default null,c2 int);
--error 1406
alter table t1 modify c1 BINARY DEFAULT (UUID_TO_BIN(UUID())) not null;

drop table t1;
create table t1(c1 DATE default null,c2 int);
alter table t1 modify c1 DATE  DEFAULT (CURRENT_DATE + INTERVAL 1 YEAR) not null;


#MySQL-TC-8-10
#修改列为生成列
--error 0,1051
drop table t1;
create table t1(c0 int as (2*c1),
c1 int,
c2 int
);
insert into t1(c1) values(0),(1),(2),(4),(6),(7);

--ERROR 3106
alter table t1 modify c0 int default 100 not null;
show create table t1;
select * from t1;



#补充
#默认值为''
drop table t1;
create table t1(c1 int,c2 varchar(10),c3 double);
alter table t1 modify c1 int default -1 not null;
alter table t1 modify c2 varchar(10) default '' not null;
alter table t1 modify c3 double default 0.00 not null;
desc t1;
insert into t1(c1,c2) values(1,'aa');
insert into t1(c3) values(9.99);
select * from t1;


#常量默认值
#drop table t1;
#create table t1(c1 TIMESTAMP,c2 int);
#alter table t1 modify c1 TIMESTAMP DEFAULT CURRENT_TIMESTAMP not null;
