#select * from t1;


#drop table t1;
#create table t1(c1 DATETIME ,c2 int);
#alter table t1 modify c1 DATETIME  DEFAULT CURRENT_TIMESTAMP not null;
#insert into t1(c2) values(1);
#select * from t1;


#blob数据类型
drop table t1;
create table t1(c1 BLOB default null,c2 int);
--error 0,1067
alter table t1 modify c1 BLOB  DEFAULT 'abc' not null;


drop table t1;
create table t1(c1 BLOB,c2 int);
--error 0,1067 
alter table t1 modify c1 BLOB DEFAULT ('abc') not null;


#插入新行时，省略列名
drop table t1;
create table t1(c1 int default 1 not null);
insert into t1() values();
select * from t1;
insert into t1() values(default);
select * from t1;


#修改列名并加约束default 'xxx' not null
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 int);
insert into t1 values(1,1),(2,2),(3,3);

# # now we can support change column name and add not null constraint
alter table t1 change c0 c0_1 int default 123 not null;
show create table t1;


#先修改列名再修改约束为default 'xxx' not null
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 int);
insert into t1 values(1,1),(2,2),(3,3);

alter table t1 change c0 c0_1 int default null;
alter table t1 modify c0_1 int default '123' not null;
show create table t1;

delete from t1 where c1 = 3;
update t1 set c0_1 = 0 where c1 = 2;
select * from t1;


#先修改列为非空列，然后再删除
--error 0,1051
drop table t1;
create table t1(c0 double default null,
c1 float);

insert into t1 values(1,1),(2,2),(3,3);

alter table t1 modify c0 double default 99.99 not null;
show create table t1;

alter table t1 drop c0;
show create table t1;

insert into t1 values(22),(33);
select * from t1;


#修改列为非空有默认值且带上修改列备注和位置
#加约束加备注
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 int);
insert into t1 values(1,1),(2,4),(3,8);

alter table t1 modify c0 int default 99 not null comment '第一列';
show create table t1;

insert into t1(c1) values(16),(32);
select * from t1;
delete from t1 where c1 < 10;
select * from t1;


#加约束改列位置
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 int);
insert into t1 values(1,1),(2,4),(3,8);
alter table t1 modify c0 int default 99 not null after c1;
show create table t1;

insert into t1(c1) values(16),(32);
select * from t1;
delete from t1 where c1 < 10;
select * from t1;


#加约束改列位置分开执行
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 int);
insert into t1 values(1,1),(2,4),(3,8);

alter table t1 modify c0 int default 99 not null;
alter table t1 modify c0 int default 99 not null after c1;
show create table t1;

insert into t1(c1) values(16),(32);
select * from t1;
delete from t1 where c1 < 10;
select * from t1;



--disable_warnings
drop database if exists yx5493;
--enable_warnings
PURGE RECYCLEBIN;