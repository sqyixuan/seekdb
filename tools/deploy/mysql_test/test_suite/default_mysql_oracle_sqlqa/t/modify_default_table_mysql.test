#owner：dachuan.sdc
#owner group：SQL2
#description：mysql模式default 'xxx' not null-在复制表和虚拟表中增加default约束非空列并执行DML操作
# tags: DDL,DML
#auther：wb-yx01449353

--echo # 环境清理
purge recyclebin;
--result_format 4


let $char_charset = 'UTF8';
--enable_result_log

--disable_warnings
drop DATABASE IF EXISTS yx5493;
--enable_warnings

#创建数据库yx5493
CREATE DATABASE IF NOT EXISTS yx5493;
USE yx5493;


#MySQL-TC-5

#对复制表、分区表的普通列修改为非空有默认值列后并执行DML操作

#使用as关键字创建复制表
#修改复制表中的列为非空列，然后校验对复制表以及被复制表的影响

drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 varchar(10),
c3 year);

insert into t1 values(1,1.0,'a','2000'),(2,1.1,'b','2001'),(3,1.2,'c','2002'),(4,1.3,'d','2003');
create index ind_1 on t1(c1);
create index ind_2 on t1(c2,c3);
create table t2 as select * from t1;
select * from t2 order by 1;
show create table t2;

alter table t2 modify c1 float default 1.0 not null;
show create table t2;
show create table t1;
select * from t2 order by 1;
select * from t1 order by 1;

insert into t2(c0,c2) values(13,'ab'),(14,'ac'),(15,'ad');
select * from t2 order by 1;
select * from t1 order by 1;


#修改被复制表的列为非空列，然后校验对复制表以及被复制表的影响

drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 varchar(10),
c3 year);

insert into t1 values(1,1.0,'a','2000'),(2,1.1,'b','2001'),(3,1.2,'c','2002'),(4,1.3,'d','2003');
create index ind_1 on t1(c1);
create index ind_2 on t1(c2,c3);
create table t2 as select * from t1;
select * from t2 order by 1;
show create table t2;

alter table t1 modify c1 float default 1.0 not null;
show create table t2;
show create table t1;
select * from t2 order by 1;
select * from t1 order by 1;

insert into t1(c0,c2) values(13,'ab'),(14,'ac'),(15,'ad');
select * from t2 order by 1;
select * from t1 order by 1;

#修改被复制表的列为非空列后，使用as关键字创建复制表，校验有默认值的非空列对复制表的影响
#不支持复制默认值约束(已知bug)

drop table if exists t2;
create table t2 as select * from t1;
select * from t2 order by 1;
show create table t2;
insert into t2 values(11,2.2,'m','2012'),(22,3.2,'m','2013'),(15,4.4,'n','2014'),(16,5.5,'n','2016');

insert into t2(c0) values(100),(200);
select * from t1 order by 1;
select * from t2 order by 2;


#使用AS关键字创建复制表，修改复制表的默认为空列为非空列，然后引用被复制表数据
drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 double default null);
insert into t1 values(1,11),(2,12),(3,13);

create table t2 as select * from t1;
show create table t2;

alter table t2 modify c1 double default 0 not null;
show create table t2;
insert into t2(c0) values(3),(4);
select * from t2;
select * from t1; 


#使用AS关键字创建复制表，修改被复制表的默认为空列为非空列，然后引用被复制表数据
drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 double default null);
insert into t1 values(1,11),(2,12),(3,13);

create table t2 as select * from t1;
show create table t2;

alter table t1 modify c1 double default 0 not null;
show create table t2;
insert into t2(c0) values(3),(4);
select * from t2;
select * from t1; 


#使用like关键字创建复制表
#修改复制表中的列为非空列，然后校验对复制表以及被复制表的影响

drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 float,
c3 year);
insert into t1 values(1,1.0,'2000'),(2,2.0,'2001'),(3,3.0,'2002');

create table t2 like t1;
insert into t2 select * from t1;
select * from t2;
show create table t2;

alter table t2 modify c0 int default 9999 not null;
show create table t2;

insert into t2(c1) values(4.0),(5.0),(6.0);
select * from t1;
select * from t2;


#修改被复制表中的默认为空列为非空列，然后校验对复制表以及被复制表的影响

drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int default null,
c1 float,
c3 year);
insert into t1 values(1,1.0,'2000'),(2,2.0,'2001'),(3,3.0,'2002');

create table t2 like t1;
insert into t2 select * from t1;
select * from t2;
show create table t2;

alter table t1 modify c0 int default 9999 not null;
show create table t1;
show create table t1;

insert into t1(c1) values(4.0),(5.0),(6.0);
insert into t2(c1) values(4.0),(5.0),(6.0);
select * from t1;
select * from t2;


#修改被复制表的默认为空列为非空列后，使用like关键字创建复制表，校验改列对复制表的影响

--error 0,1051
drop table t1;
drop table if exists t2;
create table t1(c0 int default null,
c1 float,
c3 year);
insert into t1 values(1,1.0,'2000'),(2,2.0,'2001'),(3,3.0,'2002');

alter table t1 modify c0 int default 9999 not null;
show create table t1;

create table t2 like t1;
insert into t2 select * from t1;
show create table t2;
select * from t2;

insert into t1(c1) values(4.0),(5.0),(6.0);
insert into t2(c1) values(4.0),(5.0),(6.0);
select * from t1;
select * from t2;


#使用like关键字创建复制表，修改复制表的默认为空列为非空列，然后引用被复制表数据

--error 0,1051
drop table t1;
drop table if exists t2;
create table t1(c0 int default null,
c1 float,
c3 year);

insert into t1 values(1,1.0,'2000'),(2,2.0,'2001'),(3,3.0,'2002');

create table t2 like t1;
select * from t2;
show create table t2;

alter table t1 modify c0 int default 9999 not null;
show create table t1;
show create table t2;

insert into t2 select * from t1;
select * from t1;
select * from t2;


#使用like关键字创建复制表，修改被复制表的默认为空列为非空列，然后引用被复制表数据

--error 0,1051
drop table t1;
drop table if exists t2;
create table t1(c0 int default null,
c1 float,
c3 year);
insert into t1 values(1,1.0,'2000'),(2,2.0,'2001'),(3,3.0,'2002');

create table t2 like t1;
select * from t2;
show create table t2;

alter table t2 modify c0 int default 9999 not null;
show create table t2;

insert into t2 select * from t1;
select * from t1;
select * from t2;



#MySQL-TC-6
#虚拟表
#视图
#单基表视图

#修改视图列为非空有默认值
drop table if exists t2;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 varchar(10),
c3 year);
insert into t1 values(-1,1.0,'a','2000'),
                     (-2,1.1,'b','2001'),
                     (0,1.2,'c','2002'),
                     (NULL,1.3,'d','2003'),
                     (NULL,1.4,'e','2004'),
                     (16,1.5,'f','2005'),
                     (7,1.6,'g','2006'),
                     (18,1.7,'h','2007'),
                     (-90,1.8,'i','2011'),
                     (NULL,1.9,'j','2012'),
                     (11,2.0,'k','2011'),
                     (NULL,2.1,'l','2012');

drop view if exists v1;
create view v1 as select * from t1;
desc v1;
select * from v1 order by 1;
--error 1064
alter table v1 modify c1 float defauult 1.0 not null;


#修改基表中的列为非空有默认值
alter table t1 modify c1 float default 0 not null;
show create table t1;

select * from t1 order by 1;
select * from v1 order by 1;

insert into v1 values(NULL,2.2,'m','2013'),(NULL,2.3,'n','2014');
select * FROM v1 ORDER BY 1;
select * FROM t1 ORDER BY 1;

insert into v1(c0,c2,c3) values(null,'p','2017'),(null,'q','2018'),(null,'r','2019');
select * from v1 order by 1;
select * from t1 order by 1;


#多基表视图,修改基表中的列为非空有默认值

drop view if exists v1;
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 varchar(10),
c3 year);

insert into t1 values(-1,1.0,'a','2000'),(0,2.0,'b','2001'),(1,3.0,'c','2002');

drop table if exists t2;
create table t2(c0 int,
c1 float,
c2 varchar(10),
c3 year);

insert into t2 values(-10,-1.0,'aa','2000'),(-20,-2.0,'bb','2001'),(-30,-3.0,'cc','2002');

create view v1 as select t1.c0,t2.c1 from t1 join t2 on t1.c3 = t2.c3;

alter table t1 modify c0 int default 0 not null;
show create table t1;
select * from t1;
select * from t2;
select * from v1;

insert into t1 values(2,4.0,'d','2003'),(3,5.0,'e','2004');
select * from t1;
insert into t1(c1,c2,c3) values(6.0,'f','2005');
select * from t1;
select * from v1;
delete from t1 where c0 = 0;
select * from t1;


#先修改普通表中的列为非空有默认值，然后创建视图
#单基表
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 YEAR);
insert into t1 values(1,1.0,'2001'),(2,2.0,'2002'),(3,3.0,'2003');

alter table t1 modify c0 int default 1 not null;
show create table t1;

drop view if exists v1;
create view v1 as select c1,c2 from t1;
select * from v1;

insert into v1 values(4.0,'2004');
select * from v1;
select * from t1;


#多基表
--error 0,1051
drop table t1;
create table t1(c0 int,
c1 float,
c2 YEAR);
insert into t1 values(1,1.0,'2001'),(2,2.0,'2002'),(3,3.0,'2003');

drop table if exists t2;
create table t2(c0_1 int,
c1 float,
c2 YEAR);
insert into t2 values(-1,1.0,'2001'),(-2,2.0,'2002'),(-3,3.0,'2003');

alter table t1 modify c0 int default 1 not null;
alter table t2 modify c0_1 int default -1 not null;
show create table t1;
show create table t2;

drop view if exists v1;
create view v1 as select t1.c0,t2.c0_1 from t1 join t2 on t1.c2 = t2.c2;
select * from v1;
insert into t1(c1,c2) values(4.0,'2004'),(5.0,'2005');
insert into t2(c1,c2) values(4.0,'2004'),(5.0,'2005');
select * from v1;
select * from t1;
select * from t2;



