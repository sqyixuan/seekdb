#owner：dachuan.sdc
#owner group：SQL2
#description：mysql模式default 'xxx' not null-对不同类型的列修改为非空列并执行DML操作
# tags: ddl，dml，datatype,delete,show,default_value
#auther：wb-yx01449353

--echo # 环境清理
purge recyclebin;
--result_format 4


let $char_charset = 'UTF8';
--enable_result_log

--disable_warnings
drop DATABASE IF EXISTS yx5493;
--enable_warnings

#创建数据库yx5493
CREATE DATABASE IF NOT EXISTS yx5493;
USE yx5493;



#MySQL-TC-1
#不同数据类型列修改列为非空列并执行DML操作
#修改int型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 INT default null,
c1 int default null);
insert into t1 values(1,2),(11,22);

alter table t1 modify c0 int default 999 not null;
alter table t1 change c1 c1 int default 9999 not null;
show create table t1;
select c0,c1 FROM t1;

insert into t1(c0) values(111),(1111);
insert into t1(c1) values(222),(2222);
select c0,c1 FROM t1;
delete from t1 where c0 = 1;
delete from t1 where c1 = 22;
select c0,c1 FROM t1;

update t1 set c0 = 11111 where c1 = 222;
update t1 set c1 = 222 where c0 = 111;
select c0,c1 FROM t1;

alter table t1 modify c0 int null;
alter table t1 modify c1 int null;
show create table t1;
select c0,c1 FROM t1;



#修改INTEGER型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 integer default null,
c1 FLOAT);
insert into t1 values(1,2),(3,4);

alter table t1 modify c0 integer(10) default 100 not null;
show create table t1;

select c0,c1 FROM t1 ORDER by 1;

insert into t1(c1) values(5),(6);
select c0,c1 FROM t1 ORDER by 1;


#修改bigint型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 bigint default null,
c1 FLOAT);
insert into t1 values(12345678901,2),(98765432101,4);

alter table t1 modify c0 bigint default 112233445566 not null;
show create table t1;

select c0,c1 FROM t1 ORDER by 1;

insert into t1(c1) values(5),(6);
select c0,c1 FROM t1 ORDER by 1;


#修改SMALLINT型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 SMALLINT default null,
c1 int);
insert into t1 values(345,2),(444,5);

alter table t1 modify c0 SMALLINT default 0 not null;
show create table t1;

select c0,c1 FROM t1 ORDER by 1;

insert into t1(c1) values(55),(61);
select c0,c1 FROM t1 ORDER by 1;


#修改TINYINT型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 tinyint(3) zerofill default null,
c1 int);
insert into t1 values(0,128),(127,-128);

alter table t1 modify c0 tinyint zerofill default 0 not null;
show create table t1;

select c0,c1 FROM t1 ORDER by 1;

insert into t1(c1) values(255),(0);
select c0,c1 FROM t1 ORDER by 1;


#修改mediumint\decimal\float\double\bit型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 mediumint default null,
c1 decimal default null,
c2 float default null,
c3 double default null,
c4 bit default null
);

insert into t1 values(11,222,3,4444,0),(22,111,3.35,4.4,1),(3,6666,7.77,8.9,0);

alter table t1 modify c0 mediumint default 9999 not null;
alter table t1 modify c1 decimal default 9999 not null;
alter table t1 modify c2 float default 9999 not null;
alter table t1 modify c3 double default 9999 not null;
alter table t1 modify c4 bit default 1 not null;
show create table t1;
select * from t1;

insert into t1(c0) values(5555),(234);
insert into t1(c1) values(22),(33);
insert into t1(c2) values(1.23),(9.87);
insert into t1(c3) values(1.234567),(9.876543);
insert into t1(c4) values(''),(1),(0);
select * from t1;


#修改date\datetime\timestamp\time\year型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 date default null,
c1 datetime default null,
c2 timestamp default null,
c3 time default null,
c4 year default null
);

insert into t1 values('2022-06-23','2023-06-23 10:35:00','2023-06-23 10:35:00','10:35:00','2022'),

('2022-06-03','2023-06-11 10:35:00','2023-06-23 10:05:00','08:22:00','2000');
alter table t1 modify c0 date default '0000-00-00' not null;
alter table t1 modify c1 datetime default '0000-00-00 00:00:00' not null;
alter table t1 modify c2 timestamp default '0000-00-00 00:00:00' not null;
alter table t1 modify c3 time default '00:00:00' not null;
alter table t1 modify c4 year default '0000' not null;
show create table t1;
select * from t1;

insert into t1(c0) values('1997-01-01');
insert into t1(c1) values('1998-02-02 01:01:01');
insert into t1(c2) values('1999-03-03 01:02:03');
insert into t1(c3) values('12:12:00');
insert into t1(c4) values('2022');
select * from t1;



#修改char型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 char default null,
c1 char(10) default null);
insert into t1 values('一','二'),('三','四');

alter table t1 modify c0 char default '十' not null;
alter table t1 change c1 c1 char(10) default 'ling' not null;
show create table t1;

select c0,c1 from t1 order by 1;
insert into t1(c0) values('a'),('c');
insert into t1(c1) values('ac'),('bd');
select c0,c1 FROM t1 ORDER by 1;


#修改char\varchar\binary\varbinary型为default 'xxx' not null

--error 0,1051
drop table t1;
create table t1(
c0 char(4) default null,
c1 varchar(4) default null,
c2 binary(10) default null,
c3 varbinary(10) default null
);

insert into t1 values('abc','abcd','100','111'),('ok','okay','onezero','oneone');

alter table t1 modify c0 char(4) default 'abc' not null;
alter table t1 modify c1 varchar(4) default 'abcd' not null;
alter table t1 modify c2 binary(10) default 'zero' not null;
alter table t1 modify c3 varbinary(10) default 'one' not null;
show create table t1;
select * from t1;

insert into t1(c0) values('');
insert into t1(c1) values('');
insert into t1(c2) values('');
insert into t1(c3) values('');
select * from t1;


#修改blob\text\enum\set型为default 'xxx' not null
#BLOB, TEXT, GEOMETRY or JSON column 'c0' can't have a default value
--error 0,1051
drop table t1;
create table t1(
c0 blob(11) default null,
c1 text(11) default null,
c2 enum('0','1','9999') default null,
c3 set('ok','no','fine') default null
);

insert into t1 values('123456','abcdef','0','ok'),('23456','abcd','1','no');

#alter table t1 modify c0 blob(11) default '111111' not null;
#alter table t1 modify c1 text(11) default 'aaaaa' not null;

alter table t1 modify c2 enum('0','1','9999') default '9999' not null;
alter table t1 modify c3 set('ok','no','fine') default 'ok' not null;
show create table t1;


--disable_warnings
drop database if exists yx5493;
--enable_warnings
PURGE RECYCLEBIN;