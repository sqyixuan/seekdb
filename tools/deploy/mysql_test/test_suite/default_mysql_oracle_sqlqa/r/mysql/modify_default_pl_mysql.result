drop table t1;
create table t1(c0 int,
c1 varchar(10));
insert into t1 values(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E'),(6,'F'),(7,'G');
drop table if exists t2;
create table t2(c0 int,
c1 varchar(10));
insert into t2 values(10,'A'),(20,'B'),(30,'C'),(40,'D'),(50,'E'),(60,'F'),(70,'G');
drop function if exists f1;
create function f1(d int)
returns varchar(100)
begin
declare d1 int;
declare d2 int;
declare d3 varchar(100);
if d > 10 then
	insert into t1 values(d+100,'test1'),(d+200,'test2'),(d+300,'test3');
	insert into t2 values(d-50,'a'),(d-60,'b'),(d-70,'c');
elseif d <= 10 then
	insert into t1(c0) select c0 FROM t2 WHERE c0 <= 10;
	insert into t2(c1) select c1 FROM t1 WHERE c0 <= 10;
end if;

select count(c1) into d1 from t1;
select count(c0) into d2 from t2;

set d3 = concat('t1表执行函数后条目合计：',d1,',','t2表执行函数后条目合计：',d2);
return d3;

end
/
alter table t2 modify c0 int default 9999 not null;
alter table t1 modify c1 varchar(10) default 'unknow' not null;
select f1(11);
+-----------------------------------------------------------------------------+
| f1(11)                                                                      |
+-----------------------------------------------------------------------------+
| t1表执行函数后条目合计：10,t2表执行函数后条目合计：10                       |
+-----------------------------------------------------------------------------+
select * FROM t1;
+------+-------+
| c0   | c1    |
+------+-------+
|    1 | A     |
|    2 | B     |
|    3 | C     |
|    4 | D     |
|    5 | E     |
|    6 | F     |
|    7 | G     |
|  111 | test1 |
|  211 | test2 |
|  311 | test3 |
+------+-------+
select * FROM t2;
