drop table t1;
create table t1(id int primary key auto_increment,
name varchar(20),
pwd int default '123456' not null,
verify varchar(20) default 'qwe123' not null);
insert into t1(id,name,pwd,verify) values(1,'people1',123456,'qwe123');
drop procedure if exists p1;
create procedure p1(n int)
begin
declare i int default(select count(*) from t1);
declare name varchar(20) default " ";
if i>=n then
select count(*) from t1;
else
while n > i DO
set i = i+1;
set name=(select concat('people',i));
insert into t1(name)values(name);
end while;
select * from t1;
end if;
END;
/
call p1(100);
