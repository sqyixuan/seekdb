--echo #Environmental cleaning
--disable_warnings

--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);



--echo obmysql-trim-2
--error 0,1051
drop table trim_table;
create table trim_table(name varchar(20),sal varchar(20));
insert into trim_table values(' ku li ','20 48'),(' 科 比 ',' 59 '),(' kebi',' 60 ' ),( null , null ),( ' 0 ', ' 0 ' );



select  trim(sal) + trim(sal) from trim_table;  
select  trim(sal) - trim(sal) from trim_table;
select  trim(sal) * trim(sal) from trim_table;
select  trim(sal) / trim(sal) from trim_table;
select *  from  trim_table where trim(name) = 'kebi';
select *  from  trim_table where trim(' 科 ' from name) = '比';
select *  from  trim_table where trim(sal) > 20;
select *  from  trim_table where trim(sal) >= 20;
select *  from  trim_table where trim(sal) < 20;
select *  from  trim_table where trim(sal) <= 20;
select *  from  trim_table where trim(sal) <> 20;
select *  from  trim_table where trim(sal) != 20;
select *  from  trim_table where trim(name) = '科 比' and trim(sal) > 20;
select *  from  trim_table where trim(name) = '科 比' or trim(name) = 'ku li';
select *  from  trim_table where trim(name) = '科 比' or trim(name) = 'ku li';
select *  from  trim_table where trim(sal) is not null and trim(sal) > 0;



--echo obmysql-trim-3
--error 0,1051
drop view trim_view;
--error 0,1051
drop table trim_table;
--error 0,1051
drop table rtrim_table;
--error 0,1051
drop table ltrim_table;
--error 0,1051
drop table ltrim_view_table;
create table trim_table(id int,name varchar(20),sal varchar(20));
create table rtrim_table(id int,job varchar(20),pst varchar(20));
insert into trim_table values(1,' ke bi ',' 55 00 '),(2,' 库 里   ',' 2500 '),(3,' yao m',' 3500 ');
insert into rtrim_table values(1,' lan qiu ',' s f  '),(2,' 篮 球 ',' p g '),(3,' lan qiu ',' c ');

create view trim_view as select trim(e.id) id,rtrim(e.name) name,ltrim(e.sal)sal,trim(p.job)job,ltrim(p.pst)pst from trim_table e left join rtrim_table p on e.id = p.id;


select e.name,e.sal,e.job,e.pst from (select trim(e.name)name,trim(e.sal)sal,trim(p.job)job,trim(p.pst)pst from trim_table e left join rtrim_table p on e.id = p.id) e;
select trim(e.name),trim(p.pst) from trim_table e inner join rtrim_table p on e.id = p.id where trim(e.sal) > 3000 order by e.id;
select trim(e.name),trim(p.pst) from trim_table e right join rtrim_table p on e.id = p.id where trim(p.job) = 'lan qiu' order by e.id;

select e.name,e.sal,e.job,e.pst from (select rtrim(e.name)name,rtrim(e.sal)sal,rtrim(p.job)job,rtrim(p.pst)pst from trim_table e left join rtrim_table p on e.id = p.id) e;
select rtrim(e.name),rtrim(p.pst) from trim_table e inner join rtrim_table p on e.id = p.id where rtrim(e.sal) > 3000 order by e.id;
select rtrim(e.name),rtrim(p.pst) from trim_table e right join rtrim_table p on e.id = p.id where rtrim(p.job) = ' lan qiu' order by e.id;


select e.name,e.sal,e.job,e.pst from (select ltrim(e.name)name,ltrim(e.sal)sal,rtrim(p.job)job,ltrim(p.pst)pst from trim_table e left join rtrim_table p on e.id = p.id) e;
select ltrim(e.name),ltrim(p.pst) from trim_table e inner join rtrim_table p on e.id = p.id where ltrim(e.sal) > 3000 order by e.id;
select ltrim(e.name),ltrim(p.pst) from trim_table e right join rtrim_table p on e.id = p.id where ltrim(p.job) = 'lan qiu' order by e.id;


select trim(e.name),ltrim(e.sal)  from trim_table e where id in (select id from rtrim_table) and rtrim(e.name) = ' ke bi';
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where exists(select *  from rtrim_table where rtrim(job) = ' lan qiu') order by e.id desc;
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id =  any(select id  from rtrim_table where rtrim(job) = ' lan qiu') order by e.id desc;
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id >  any(select id  from rtrim_table where rtrim(job) = ' lan qiu') order by e.id desc;
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id <  any(select id  from rtrim_table where rtrim(job) = ' lan qiu') order by e.id desc;

select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id =  all(select id  from rtrim_table where rtrim(job) = 'lan qiu') order by e.id desc;
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id >  all(select id  from rtrim_table where rtrim(job) = 'lan qiu') order by e.id desc;
select trim(leading ' ke' from e.name ),ltrim(e.sal) from trim_table e where id <  all(select id  from rtrim_table where rtrim(job) = 'lan qiu') order by e.id desc;


#create as 
create table ltrim_table as select * from trim_table e where trim(e.name) = 'ke bi' or ltrim(e.sal) > 2500;
select count(*) from ltrim_table;


#update set
update ltrim_table set sal = ' 6000 ' where trim(name) = 'ke bi';
select sal  from ltrim_table where trim(sal) = '6000';


#like
select e.name,e.sal from trim_table e where trim(leading 'ke' from e.name) like '%b%';
select trim('ke' from e.name),ltrim(e.sal) from trim_table e where rtrim(e.sal) like '%5%';
select max(trim(sal)),min(trim(sal)) from trim_table;  
  

#where
select rtrim(e.name),e.sal from trim_table e where trim(e.sal) > 2000 order by ltrim(e.id); 
select rtrim(e.name),e.sal from trim_table e where trim(' ke ' from e.name) = 'bi' order by ltrim(e.id); 


#order by 
select rtrim(e.name),ltrim(e.sal) from trim_table e where rtrim(e.sal) > 2000 order by rtrim(e.sal) limit 10;
select rtrim(e.name),ltrim(e.sal) from trim_table e where rtrim(e.sal) > 2000 order by rtrim(e.sal) desc limit 10;


#group by having
select e.id,max(trim(e.sal)),ltrim(e.name) from trim_table e where rtrim(e.sal) > 2000   group by e.id order by e.id;
select e.id,max(trim(e.sal)),ltrim(e.name) from trim_table e where rtrim(e.sal) > 0  group by e.id having max(trim(e.sal)) > 2000 order by e.id;


#case when
select rtrim(e.name),trim(case when trim(e.sal) < 2000  then null else trim(e.sal) end) from trim_table e; 
select ltrim(e.name),trim(case trim(e.sal)  when 2500 then ' 1 ' when 3500 then ' 2 ' else ' 3 ' end) from trim_table e order by e.id desc; 
select ltrim(e.name),rtrim(e.sal) from trim_table e group by trim(case trim(e.sal)  when 2500 then ' 1 ' when 3500 then ' 2 ' else ' 3 ' end) order by e.id desc; 


#insert into

insert into ltrim_table select *  from trim_table e where rtrim(e.name) = ' ke bi';
select count(*) from ltrim_table;

insert into ltrim_table select *  from trim_table e where rtrim(e.name) = ' ke bi' order by trim(e.sal);
select count(*) from ltrim_table;


insert into ltrim_table select e.id,max(ltrim(e.sal)),rtrim(e.name)  from trim_table e where rtrim(e.name) = ' ke bi' group by e.id order by trim(e.sal);
select count(*) from ltrim_table;


#update
update rtrim_table set job = 'lan qiu' where trim(job) = '篮 球';
select * from rtrim_table;

update rtrim_table set job = '篮球' where trim(job) = 'lan qiu';
select * from rtrim_table;

update rtrim_table set job = trim(pst) where id = 1;
select * from rtrim_table;



#delect 
delete from ltrim_table where trim(' ke ' from name) = 'bi';
select count(*) from ltrim_table;


