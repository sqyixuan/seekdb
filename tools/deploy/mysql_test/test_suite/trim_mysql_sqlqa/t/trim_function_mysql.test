#存储过程
--echo obmysql-trim-8
--error 0,1305
drop procedure mytrim;//
create procedure mytrim()
begin
	declare a varchar(20) character set binary;
	declare i int default 0;
	select trim(' ke ' from e.name) from trim_table e where ltrim(e.sal) = 55 into a ;
	loop_lable:loop
	insert into trim_table values(5,'sal',trim(' 1 00'));
	set i := i + 1;
	if  i >= 10 then leave loop_lable;
end if;
end loop;
end;
//

select count(*) from trim_table;//
call mytrim;//
select count(*) from trim_table;//



drop procedure mytrim;//

create procedure mytrim(in trimsal int)
begin
	declare a varchar(20) character set gbk;
	declare i int default 0;
	select trim(' ke ' from e.name) from trim_table e where ltrim(e.sal) = trimsal into a ;
	repeat
	insert into trim_table values (6,a,ltrim(' 2 0 0 '));
	set i := i + 1;
	until i >= 10 end repeat;
end;
//
select count(*) from trim_table;//
call mytrim(2500);//
select count(*) from trim_table;//



drop procedure mytrim;//
create procedure mytrim(out trimname varchar(20))
begin
	declare i int default 0;
	select trim(both 'k' from e.name) into trimname from trim_table e where ltrim(e.sal) = 2500;
	while i <= 10 do
	insert into trim_table values (7,trimname,' 8 0 0 ');
	set i := i + 1;
	end while;
end;
//

select count(*) from trim_table;//
call mytrim(@trimname); //                                    
select count(*) from trim_table;//


drop procedure mytrim;//
create procedure mytrim(in trimid int,out trimname varchar(20),inout trimsal varchar(20))
begin
	declare i int default 0;
	select trim(e.name) into trimname from trim_table e where ltrim(e.id) = trimid;
	select rtrim(e.sal) into trimsal  from trim_table e where ltrim(e.id) = trimid;
	while i <= 10 do
	insert into trim_table values(8,trimname,trimsal);
	set i := i +1;
	end while;
end;
//
select count(*) from trim_table;//
call mytrim(3,@trimname,@trimasal); //                  
select count(*) from trim_table;      //             

