insert into trim_table values(1,' ke bi ',' 55 00 '),(2,' 库 里   ',' 2500 '),(3,' yao m',' 3500 ');


--echo obmysql-trim-4

delimiter //;
create function mytrim()
returns varchar(20)
begin
	declare a varchar(20) character set utf16;
	select trim(e.name) from trim_table e where ltrim(e.sal) = 2500 into a;
	return a;
end;//
select mytrim();//


drop function mytrim;//
create function mytrim(trimname varchar(20))
returns varchar(20)
begin
	declare a varchar(20) character set gb18030;
	select trim(e.sal) from trim_table e where ltrim(e.name) = trimname into a;
	return a;
end;//

select mytrim('库 里');//



drop function mytrim;//
create function mytrim(trimname varchar(20))
returns varchar(20)
begin
	declare a varchar(20) character set gb18030;
	declare i int default 0;
	select trim(e.sal) from trim_table e where ltrim(e.name) = trimname into a;
	while i <= 10 do
	insert into trim_table values(4,a,' 50 25');
	set i := i + 1;
	end while;
	return a;
end;
//
select mytrim('库 里');//
select count(*) from trim_table;//


drop function mytrim;//

