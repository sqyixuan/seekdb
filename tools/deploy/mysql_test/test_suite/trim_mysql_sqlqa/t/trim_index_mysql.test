--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);




--echo obmysql-trim-9
--error 0,1051
drop table trim_table;
create table trim_table(id int,name varchar(20),sal varchar(20));
insert into trim_table values(1,' ke bi ',' 55 00 '),(2,' 库 里   ',' 2500 '),(3,' yao m',' 3500 ');

select trim('ke'from rtrim(ltrim(e.name))) from trim_table e;
select trim(trim('ke'from rtrim(ltrim(e.name)))) from trim_table e;
select trim(leading ' ' from trim('ke'from rtrim(ltrim(e.name)))) from trim_table e;
select trim(both ' m' from trim('ke'from rtrim(ltrim(e.name)))) from trim_table e;
select trim(trailing ' m' from trim('ke'from rtrim(ltrim(e.name)))) from trim_table e;


select trim('ke' from e.name ),sum(trim(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;
select trim('ke' from e.name ),trim(sum(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;

select trim('ke' from e.name ),max(trim(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;
select trim('ke' from e.name ),trim(max(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;

select trim('ke' from e.name ),min(trim(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;
select trim('ke' from e.name ),trim(min(e.sal)) from trim_table e group by trim('ke' from e.name )  order by id;

select trim('ke' from e.name ),avg(trim(e.sal)) from trim_table e group by trim('ke' from e.name )  order by avg(trim(e.sal));
select trim('ke' from e.name ),trim(avg(e.sal)) from trim_table e group by trim('ke' from e.name )  order by avg(trim(e.sal));

select trim('ke' from e.name ),abs(trim(e.sal)) from trim_table e;
select trim('ke' from e.name ),trim(abs(e.sal)) from trim_table e;

select trim('ke' from e.name ),ceil(trim(e.sal)) from trim_table e;
select trim('ke' from e.name ),trim(ceil(e.sal)) from trim_table e;

select ltrim(e.id),rtrim(e.name),trim(floor(e.sal)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),rtrim(e.name),floor(trim(e.sal)) from trim_table e  group by ltrim(e.id) order by e.id;

select ltrim(e.id),rtrim(e.name),trim(mod(e.sal,3)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),rtrim(e.name),mod(trim(e.sal),3) from trim_table e  group by ltrim(e.id) order by e.id;

select ltrim(e.id),rtrim(length(e.name)),trim(mod(e.sal,3)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),length(rtrim(e.name)),mod(trim(e.sal),3) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),trim(length(e.name)),trim(mod(e.sal,3)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),length(trim(' ke ' from e.name)),mod(trim(e.sal),3) from trim_table e  group by ltrim(e.id) order by e.id;

select ltrim(e.id),trim(instr(e.name,'k')),trim(mod(e.sal,3)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),instr(trim(' ke ' from e.name),'b'),mod(trim(e.sal),3) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),rtrim(instr(e.name,'k')),trim(mod(e.sal,3)) from trim_table e  group by ltrim(e.id) order by e.id;
select ltrim(e.id),instr(rtrim(e.name),'k'),mod(trim(e.sal),3) from trim_table e  group by ltrim(e.id) order by e.id;


#索引
--echo obmysql-trim-5
ALTER TABLE trim_table ADD INDEX trim_index (sal);
select trim(e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select ltrim(e.sal),trim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select rtrim(e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(' 3' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(leading ' 3' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(leading '3' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(both '00 ' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(both ' 35' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;
select trim(trailing '00 ' from e.sal),ltrim(e.name) from trim_table e where trim(e.sal) > 1000 order by e.id desc;

insert into trim_table  select * from trim_table e where trim(e.sal) = '55 00';
select *  from trim_table;


update trim_table set name = ' 姚 明 ' where trim(sal) = '3500' ;
select *  from trim_table;
update trim_table set name = ' 科 比 ' where trim(sal) = '55 00' ;
select *  from trim_table;


delete from trim_table where trim(sal) = '55 00';
select count(*) from trim_table;



#约束
--echo  obmysql-trim-6
drop table trim_table;
create table trim_table(id int primary key,name varchar(20) unique,sal varchar(20)not null );
insert into trim_table values(1,' ke bi ',' 55 00 '),(2,' 库 里   ',' 2500 '),(3,' yao m',' 3500 ');

select rtrim(e.id),rtrim(e.name),rtrim(e.sal) from trim_table e order by e.id desc;
select ltrim(e.id),ltrim(e.name),ltrim(e.sal) from trim_table e where trim(e.sal) > 2000 order by e.id desc;
select trim(e.id),trim(leading ' ke' from e.name),trim(both '00 ' from e.sal) from trim_table e order by e.id desc;
select trim(e.id),trim(both ' ke' from e.name),trim(trailing '00 ' from e.sal) from trim_table e order by e.id desc;
select trim(e.id),trim(both ' ke' from e.name),trim(trailing '00 ' from e.sal) from trim_table e order by e.id desc;
select rtrim(e.id),rtrim(e.name),rtrim(e.sal) from trim_table e where rtrim(e.sal) > 1000 group by rtrim(e.name) order by rtrim(e.id) desc;
select ltrim(e.id),ltrim(e.name),ltrim(e.sal) from trim_table e where ltrim(e.sal) > 1000 group by ltrim(e.name) order by ltrim(e.id) desc;
select trim(e.id),trim(leading ' ke' from e.name),trim(both '00 ' from e.sal) from trim_table e where trim(both '00 ' from e.sal) > 10 group by trim(leading ' ke' from e.name) order by trim(e.id) desc;


insert into trim_table select trim(id+3)id,ltrim(e.name)name,rtrim(e.sal)sal from trim_table e where trim(e.name) ='ke bi' ;
select * from trim_table;


update trim_table set name = '科 比'  where trim(name) = '库 里';
select *  from trim_table;

delete from trim_table where trim(name) = 'yao m';
select *  from trim_table;


--error 0,600
drop table trim_table;


