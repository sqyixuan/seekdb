obmysql-trim-6
drop table trim_table;
create table trim_table(id int primary key,name varchar(20) unique,sal varchar(20)not null );
insert into trim_table values(1,' ke bi ',' 55 00 '),(2,' 库 里   ',' 2500 '),(3,' yao m',' 3500 ');
