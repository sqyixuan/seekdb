#description: soundex
#tags: soundex、insert、update、select
#author:wb-zc01071363

--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user zhe123@'%';
drop database if exists zhe123;
create database zhe123;
--enable_warnings
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zhe123,zhe123,test,$OBMYSQL_PORT);
connection conn;

--disable_warnings
--echo #create
DROP TABLE IF EXISTS soundex_t1;

create table soundex_t1 as select soundex('bmnkl') as c1,soundex('xywm') as c2;
DROP TABLE IF EXISTS soundex_t2;

create table soundex_t2 select soundex(repeat('mysql', 5)) as c ;


--echo #insert
create table t_soundex(c1 char(10),c2 VARCHAR(10),c3 VARCHAR(10),c4 VARCHAR(10),c5 int);
insert into t_soundex values('BFPV','CGJKQSXZ','DT','L',12345);
--echo #插入超长
--error 0,1406
insert into t_soundex values(repeat('abcd',1000),'CGJKQSXZ','DT','L',12345);
insert into t_soundex values(soundex('BFPV'),soundex('CGJKQSXZ'),soundex('DT'),soundex('L'),3);
##insert into t_soundex values(soundex('mn')||soundex('abcd'),soundex('abcd'),'a123','ttt',12345);
insert into t_soundex values(soundex('01-JAN-01'),soundex(concat('w','mnkk')),'a','b',123);
insert into t_soundex values(soundex(soundex('01-JAN-01')),soundex(repeat('abcdef',2)),soundex(sysdate()) ,soundex(round(2345)),123);
--disable_warnings
insert into t_soundex (c1) select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000';
##insert into t_soundex values(soundex('BFPV')||soundex('FM')||'af','cc','a','b',123);
insert into t_soundex select soundex('abcdef'),soundex('mbcdk'),soundex('aeiouk'),soundex('gcjp'),333;


--echo #update
--disable_warnings
update t_soundex set c1=soundex(c1),c2=soundex(c2),c3=soundex(c3) where soundex(c1)='B000';
--disable_warnings
update t_soundex set c1=soundex('MMMM'),c2=soundex(222),c3=soundex(replace('weweweoo','0','k')) where soundex(c1)='B000';
--disable_warnings
update t_soundex set c1=(select c1 from soundex_t1 where soundex(c1)=soundex('B524')) where soundex(c1)='M000';
--disable_warnings
#--error 0,1292
#update t_soundex set c1=soundex('mbdl')||soundex('abcdf') where soundex(c4) is null;
--disable_warnings
update t_soundex set c1=soundex(replace('weweweoo','0','k')),c2=soundex(concat('w','mnkk')) where soundex(c4) is null;
--echo #更新超长
--error 0,1406
update t_soundex set c1=soundex((repeat('abcd',1000))) where soundex(c4) is null;


--echo #select 
insert into t_soundex values('wmkb','wmkk','wmkk','wmkk',12345);
insert into t_soundex values('wmkk','wmkb','wmkk','wmkk',12345);
insert into t_soundex values('wmkk','wmbb','wmkk','wmkk',12345);
insert into t_soundex values('wmkk','wlkb','wmkk','wmkk',12345);
insert into t_soundex values('wmkc','tmkpmm','wmkk','wmkk',12345);
insert into t_soundex values('akk','tmkpqq','wmkk','wmkk',12345);

select soundex(c4) from t_soundex order by 1 desc;

select soundex(c1),soundex(c2) from t_soundex where soundex(c4) ='W520' order by 1 desc ;
select soundex(c1),soundex(c2) from t_soundex order by soundex(c2) desc ,soundex(c1) asc ;
select count(soundex(c1)) from t_soundex group by soundex(c1) having count(soundex(c1))>=4 order by soundex(c1) desc ;
select distinct soundex(c1)  from t_soundex order by soundex(c1);
select case soundex(c1) when 'A000' then 'A'  when 'T000' then 'T' else soundex(c1) end from t_soundex order by 1 desc; 
select case when soundex(c1)='A000' then 'A'  when soundex(c1)='T000' then 'T' else soundex(c1) end from t_soundex order by 1 desc; 


delete from t_soundex where soundex(c4)='T000';
delete from t_soundex where soundex(c4)='T000' or soundex(c4) ='W520';



--echo #表关联查询
select * from t_soundex;

select a.c1,b.c1 from t_soundex a left join soundex_t1 b on soundex(a.c1)=soundex(b.c1) order by 1,2 desc ;
select a.c1,b.c1 from t_soundex a right join soundex_t1 b on soundex(a.c1)=soundex(b.c1) order by 1,2;
select count(soundex(a.c1)) from t_soundex a left join soundex_t1 b on soundex(a.c1)=soundex(b.c1)group by soundex(a.c1) order by 1;


--echo #replace into
DROP TABLE IF EXISTS soundex_test1;
DROP TABLE IF EXISTS soundex_test2;
DROP TABLE IF EXISTS t_replace;
--enable_warnings

create table soundex_test1(c1 char(10),c2 char(10),c3 int,c4 int);
create table soundex_test2(c1 char(10),c2 char(10),c3 int,c4 int);

CREATE TABLE t_replace(
     name varchar(10) NOT NULL PRIMARY KEY
     ,remark varchar(10) UNIQUE);

insert into t_replace values('AMNK','BJJKRDT');
insert into t_replace values('AMMMMNK','BJRD');
insert into t_replace values('ANKJJJ','BJR');

replace into t_replace values(soundex('AMNK'),'kk');
replace into t_replace values(soundex('bbbbbbb'),soundex('BJJCCR'));
replace into t_replace values(soundex('baa'),soundex('mm'));
replace into t_replace values(soundex('vfrer'),soundex('mnnn'));
replace into t_replace values(soundex('vbfvvrar'),soundex('rewd'));

select * from t_replace;

--disable_warnings
DROP TABLE IF EXISTS t_soundex;
DROP TABLE IF EXISTS soundex_t1;
DROP TABLE IF EXISTS soundex_t2;
DROP TABLE IF EXISTS soundex_test1;
DROP TABLE IF EXISTS soundex_test2;
DROP TABLE IF EXISTS t_replace;
--enable_warnings



--echo #end释放空间、断开连接、删除库、删除用户
--enable_warnings
purge recyclebin;
connection default;
drop database if exists zhe123;
--error 0,1396
drop user zhe123@'%';
--enable_warnings


