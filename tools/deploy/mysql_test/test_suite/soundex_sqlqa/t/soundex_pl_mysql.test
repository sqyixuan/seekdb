#owner: dachuan.sdc
#owner group: sql2
#description: soundex
#tags: 在存储过程、函数、触发器中执行soundex函数相关的dml语句
#author:wb-zc01071363


--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user zhe123@'%';
--enable_warnings
drop database if exists zhe123;
create database zhe123;
--enable_warnings
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zhe123,zhe123,test,$OBMYSQL_PORT);
connection conn;


--echo #数据准备
drop table if exists test;
create table test(c1 char(10),c2 char(10));

--echo #在存储过程中，insert,select后面跟soundex函数，soundex函数作为变量传入，计算值对比

delete from test;
--error 0,1305
drop procedure proc_test1;

delimiter  //;

CREATE  PROCEDURE proc_test1 (IN s1 CHAR(30), OUT s2 CHAR(30))
       BEGIN
	     insert into test values(soundex('ewewe'),soundex('abcdefgkk'));
         SELECT soundex(c1) INTO s2 FROM test
         WHERE c1 = s1;
       END//
	   
delimiter ;//


CALL proc_test1(soundex('ea'), @s2);
	   

select * from test;


--echo #存储过程，update，where后面跟soundex函数

--error 0,1305
drop procedure proc_test2;

delimiter  //;
create PROCEDURE proc_test2(IN s1 CHAR(30), OUT s2 CHAR(30)) 
   begin
     
	 update test set c2=soundex(s1) where soundex(c1)=soundex((s1));
	 
	 SELECT soundex(c2)
     into s2 FROM test where soundex(c1)=soundex((s1));
end//
delimiter ;//

CALL proc_test2('E', @s2);
select * from test;


--echo #函数，将soundex返回值赋值后返回
--error 0,942
drop table test;
create table test(c1 char(10),c2 char(10));
insert into test values('wmkb','amkk');

select soundex(c2) from test;

drop function IF EXISTS func_test;
delimiter  //;
CREATE FUNCTION func_test (s CHAR(20))  RETURNS CHAR(50) deterministic
begin
    declare s2 char(50);
	select soundex(c2) from test where soundex(c1)=soundex(s) into s2;
	return s2;
end//
delimiter ;//

SELECT func_test('wnnncf');


--echo #触发器，数据准备
drop table if exists test1,test2,test3,test4;

create table test1(a1 char(20));
create table test2(a2 char(20));
create table test3(a3 char(20));
create table test4(a4 char(20), b4 char(20) default 0);

delete from test1;
delete from test2;
delete from test3;
delete from test4;

insert into test2 values('wnmckp');
insert into test3 values('wngxf');
insert into test4 values('wnqzgxfv','a');
select * from test1;
select * from test2;
select * from test3;
select * from test4;
--echo #触发器，where条件中soundex函数值比较，字母不同，结果相同
drop trigger if exists testref;

delimiter |;

create trigger testref before insert on test1
  for each row
  begin
    insert into test2 set a2 = soundex(NEW.a1);
    delete from test3 where soundex(a3) = soundex(NEW.a1);
    update test4 set b4 = soundex(NEW.a1) where soundex(a4) =soundex(NEW.a1);
  end;
|

delimiter ;|



--echo #触发语句
insert into test1 values('wNKCkf');

select soundex('wnqzgxfv');

select * from test1;
select * from test2;
select * from test3;
select * from test4;


drop table if exists test;
drop procedure if exists proc_test1;
drop procedure if exists proc_test2;
drop table if exists  test;
drop function IF EXISTS func_test;
drop trigger if exists testref;
drop table if exists test1,test2,test3,test4;




--echo #end释放空间、断开连接、删除用户
--enable_warnings
purge recyclebin;
connection default;
drop database if exists zhe123;
--error 0,1396
drop user zhe123@'%';
--enable_warnings
