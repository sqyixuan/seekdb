--echo #数据准备
DROP TABLE IF EXISTS t_soundex;
create table t_soundex(c1 char(10),c2 VARCHAR(10),c3 VARCHAR(10),c4 VARCHAR(100),c5 int);
insert into t_soundex values('bfpv','cgjkqsxz','DTbk','Lmpk',12345);
insert into t_soundex values('mncl','lll','bcdl','qqfn',12345);
insert into t_soundex values('rmkt','lpp','vtjk','xyzp',12345);
insert into t_soundex values('rmktt','rnnqqd','rmajoooot','RRRRROOOOMMMMMCCCCAAAAAAAADDDDDDDDD',12345);
insert into t_soundex values('sSpvcdlmr','Sbbpvcdm','sapc','sfxd',12345);

--echo #运算符
select soundex(c1),soundex(c2) from t_soundex where soundex(c1)=soundex(c2) and soundex(c2)=soundex(c4);
select soundex(c1),soundex(c2) from t_soundex where soundex(c1) !=soundex(c2);
select soundex(c1) from t_soundex where soundex(c1) =soundex('bfpv');
select soundex(c1) from t_soundex where soundex(c1) =soundex('bfppppppppv');
select soundex(c1) from t_soundex where soundex(c1) =soundex('bbbbbbbbbbbfppppppppv');
select soundex(c1) from t_soundex where soundex(c1) =soundex('bfffffppppppppv');
select soundex(c1) from t_soundex where soundex(c1) =soundex('mnnnnmmcl');
select soundex(c1) from t_soundex where soundex(c1) =soundex('mmmnccclao');
select soundex(c1) from t_soundex where soundex(c1) =soundex('mgkql');
select soundex(c1) from t_soundex where soundex(c1) =soundex('msl');
select soundex(c1),soundex(c2) from t_soundex where soundex(c1) =soundex('sSpvcdln r') and soundex(c2)=soundex('Sffbfv  bpvk  kkdm');
select soundex(c1) from t_soundex where soundex('msl')< soundex(c1) < soundex('msl');
select soundex(c1) from t_soundex where soundex('msl')<= soundex(c1) and soundex(c1) <= soundex('msl');


select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('aa')=soundex('ae');
select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('aa')=soundex('ai');
select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('aa')=soundex('ao');
select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('ay')=soundex('au');
select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('aw')=soundex('ah');
select c1 from t_soundex where soundex(c1) =soundex('mncl') and soundex('bpfv')=soundex('bvfp');


select soundex('BFPV')||soundex('FM');
select soundex('BFPV')||'dsfaewa233';
select soundex('BFPV'||'wwwabcdscsfdfd');

select soundex('Sbbpvcdm')from dual;

select soundex(c1)||soundex(c2),soundex(c1)||soundex(c2)||soundex(c3)||soundex(c4) from t_soundex where soundex(c3)||soundex(c4)='0';
select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000';
select soundex(c1) from t_soundex where soundex(c1)='B000' or soundex(c2) !=soundex('Bmvv');
select soundex(c1) from t_soundex where soundex(c1)<>'B100';
select soundex(c2) from t_soundex where soundex(c2) >='C000';
select soundex(c2) from t_soundex where soundex(c2) <='C000';
select soundex(c2) from t_soundex where soundex(c2) <'C000';
select soundex(c2) from t_soundex where soundex(c2) >'C000';
select soundex(c1) from t_soundex where soundex(c1)=(select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
select soundex(c1) from t_soundex where soundex(c1) in (select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
select soundex(c1) from t_soundex where soundex(c1) not in (select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
select soundex(c1) from t_soundex where soundex(c1) <=all (select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
select soundex(c1) from t_soundex where soundex(c1) =any (select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
select soundex(c2) from t_soundex where soundex(c2) like '%C%';
select soundex(c2) from t_soundex where soundex(c2) not like '%C%';
select soundex(c5) from t_soundex where soundex(c5) is null;
select soundex(c4) from t_soundex where soundex(c4) is not null;
select soundex(c2) from t_soundex where soundex(c2) between 'C000' and soundex(c3);
select soundex(c2) from t_soundex where soundex(c2) not between 'C100' and soundex(c3);

#select soundex(c1) from t_soundex where soundex(c1) exists (select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000');
#select soundex(c1) from t_soundex where soundex(c1) exists ('B000');
--echo #参数为子查询
select soundex((select c1 from t_soundex where soundex(c1)=soundex('sSpvcdlmr'))) from t_soundex;
select soundex(c1) from t_soundex where soundex((select c1 from t_soundex where soundex(c1) ='B000' and c1 like '%F%')) ='B000';
select soundex((select c1 from t_soundex where soundex(c1) ='B000' and c1 like '%F%')) from t_soundex where soundex((select c1 from t_soundex where soundex(c1) ='B000' and c1 like '%F%')) ='B000';


--echo #函数嵌套
select soundex(concat('w','mnkk'));
select soundex(ascii('ABCD'));
select soundex(substr('abcdefghi',5,5));
select soundex(upper('mmmnndd'));
select soundex(lower('ABCD'));
select substr(soundex(concat('w','mnkk')),2,3)+1;

select soundex('a')||soundex('b');
select soundex(ltrim(' barbar'));
select soundex(rtrim('barbar '));
select soundex(trim(leading 'x' from 'xxxbarxxx'));
select soundex(trim(both 'x' from 'xxxbarxxx'));
select soundex(trim(trailing 'xyz' from 'barxxyz'));
select soundex(space(5));
select soundex(replace('ccc.mysql.com', 'c', 'Dw'));
select soundex('www.mysql.com');
select soundex(repeat('mysql', 5));
select soundex(reverse('abcdef'));
select soundex(elt(2, 'ej', 'heja', 'hej', 'foo'));
select soundex(lcase('QUADRATICALLY'));
select soundex(ucase('Hej'));


select soundex(round(2333));
select soundex(sum(2333));
select soundex(power(2333,3));



DROP TABLE IF EXISTS t_soundex;


