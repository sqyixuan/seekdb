--echo #删除用户、释放空间

--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user zhe123@'%';
--enable_warnings
drop database if exists zhe123;
create database zhe123;
--enable_warnings
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zhe123,zhe123,test,$OBMYSQL_PORT);
connection conn;



