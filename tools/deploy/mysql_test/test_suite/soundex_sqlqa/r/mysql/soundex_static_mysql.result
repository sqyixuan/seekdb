#Environmental cleaning
drop user zhe123@'%';
drop database if exists zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
#create
DROP TABLE IF EXISTS soundex_t1;
create table soundex_t1 as select soundex('bmnkl') as c1,soundex('xywm') as c2;
DROP TABLE IF EXISTS soundex_t2;
create table soundex_t2 select soundex(repeat('mysql', 5)) as c ;
#insert
create table t_soundex(c1 char(10),c2 VARCHAR(10),c3 VARCHAR(10),c4 VARCHAR(10),c5 int);
insert into t_soundex values('BFPV','CGJKQSXZ','DT','L',12345);
#插入超长
insert into t_soundex values(repeat('abcd',1000),'CGJKQSXZ','DT','L',12345);
insert into t_soundex values(soundex('BFPV'),soundex('CGJKQSXZ'),soundex('DT'),soundex('L'),3);
insert into t_soundex values(soundex('01-JAN-01'),soundex(concat('w','mnkk')),'a','b',123);
insert into t_soundex values(soundex(soundex('01-JAN-01')),soundex(repeat('abcdef',2)),soundex(sysdate()) ,soundex(round(2345)),123);
insert into t_soundex (c1) select soundex(c1) from t_soundex where soundex(c1)='B000' and soundex(c2) !='B000';
insert into t_soundex select soundex('abcdef'),soundex('mbcdk'),soundex('aeiouk'),soundex('gcjp'),333;
#update
update t_soundex set c1=soundex(c1),c2=soundex(c2),c3=soundex(c3) where soundex(c1)='B000';
update t_soundex set c1=soundex('MMMM'),c2=soundex(222),c3=soundex(replace('weweweoo','0','k')) where soundex(c1)='B000';
update t_soundex set c1=(select c1 from soundex_t1 where soundex(c1)=soundex('B524')) where soundex(c1)='M000';
update t_soundex set c1=soundex(replace('weweweoo','0','k')),c2=soundex(concat('w','mnkk')) where soundex(c4) is null;
#更新超长
update t_soundex set c1=soundex((repeat('abcd',1000))) where soundex(c4) is null;
#select 
