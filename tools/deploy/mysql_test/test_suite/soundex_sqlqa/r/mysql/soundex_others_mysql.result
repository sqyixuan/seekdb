#Environmental cleaning
drop user zhe123@'%';
drop database if exists zhe123;
Warnings:
Note	1008	Can't drop database 'zhe123'; database doesn't exist
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
DROP TABLE IF EXISTS t_soundex;
Warnings:
Note	1051	Unknown table 'test.t_soundex'
create table t_soundex(c1 char(10),c2 char(10));
insert into t_soundex values('bmkw','fnjj');
insert into t_soundex values('abmkw','afnjj');
insert into t_soundex values('cbmkw','dfcnjj');
insert into t_soundex values('dbmkw','rrrfrnrjj');
#创建视图
create or replace view v_soundex as select * from t_soundex;
#select 视图
select soundex(c1) from v_soundex where soundex(c1)=(select soundex(c1) from v_soundex where soundex(c1)='B520' and soundex(c2) !='B520');
soundex(c1)
B520
select soundex(c1) from v_soundex where soundex(c1) in (select soundex(c1) from v_soundex where soundex(c1)='B520' and soundex(c2) !='B520');
soundex(c1)
B520
select soundex(c1) from v_soundex where soundex(c1) not in (select soundex(c1) from v_soundex where soundex(c1)='B520' and soundex(c2) !='B520');
soundex(c1)
A152
C152
D152
select soundex(c1) from v_soundex where soundex(c1) <=all (select soundex(c1) from v_soundex where soundex(c1)='B520' and soundex(c2) !='B520');
soundex(c1)
B520
A152
select soundex(c1) from v_soundex where soundex(c1) =any (select soundex(c1) from v_soundex where soundex(c1)='B520' and soundex(c2) !='B520');
soundex(c1)
B520
select soundex((select c1 from v_soundex where soundex(c1) ='B520' and c1 like '%b%')) from v_soundex where soundex((select c1 from v_soundex where soundex(c1) ='B520' and c1 like '%b%')) ='B520';
soundex((select c1 from v_soundex where soundex(c1) ='B520' and c1 like '%b%'))
B520
B520
B520
B520
#insert 视图
delete  from t_soundex;
insert into v_soundex values('BFPV','CGJKQSXZ');
insert into v_soundex values(soundex('BFPV'),soundex('CGJKQSXZ'));
insert into v_soundex values(soundex('01-JAN-01'),soundex(concat('w','mnkk')));
insert into v_soundex values(soundex(soundex('01-JAN-01')),soundex(replace('abcdef','f','a')));
insert into v_soundex (c1) select soundex(c1) from v_soundex where soundex(c1)='B000' and soundex(c2) !='B000';
insert into v_soundex select soundex('abcdef'),soundex('mbcdk');
select * from v_soundex;
c1	c2
BFPV	CGJKQSXZ
B000	C000
J500	W520
J000	A123
B000	NULL
B000	NULL
A1231	M1232
#update 视图
update v_soundex set c1=soundex(c1),c2=soundex(c2) where soundex(c2)=soundex('M1232');
update v_soundex set c1=soundex('MMMM'),c2=soundex(222) where soundex(c2)=soundex('CGXZ');
update v_soundex set c1=soundex(replace('abcdef','f','a')),c2=soundex(concat('w','mnkk')) where soundex(c1) is not null;
#边界
update v_soundex set c1=soundex((repeat('abcd',1))) where soundex(c1) is not null;
#表约束-组合
DROP TABLE IF EXISTS t1_soundex;
DROP TABLE IF EXISTS t_soundex;
create table t1_soundex	(c1 varchar(10) primary key,c2 varchar(20) unique);
create table 
t_soundex(c1 varchar(10) primary key,
c2 varchar(20) not null,
c3 varchar(12) unique,
c4 varchar(200),
c5 varchar(199)  ,
key fk_c1(c1),
constraint fk_c1 FOREIGN key(c1)   references  t1_soundex(c1));
insert into t1_soundex(c1,c2)values(soundex('Bemcc'),soundex('Bemcc'));
insert into t1_soundex(c1,c2)values(soundex('BemccD'),soundex('BemccD'));
insert into t1_soundex(c1,c2)values(soundex('Bemccr'),soundex('Bemccr'));
insert into t1_soundex(c1,c2)values(soundex('mkij'),soundex('mkij'));
insert into t1_soundex(c1,c2)values(soundex('mkijp'),soundex('mkijp'));
#insert 外键约束、唯一约束判断
insert into t_soundex(c1,c2,c3,c4)values(soundex('Bemcc'),soundex('afcdeb'),soundex('Bemcc'),soundex('Bemcc'));
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('BemccD'),soundex('abfckkttdeb'),soundex('AA'),soundex('AA'),soundex('AA'));
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('Bankr'),soundex('abfcktdef'),soundex('AAm'),soundex('AA'),soundex('AAm'));
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('mmncok'),soundex('abfcktdef'),soundex(' --'),soundex('AA'),soundex('AAmnl'));
#主键判断
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('mmncok'),soundex('abfcktdef'),soundex(' --'),soundex('AA'),soundex('AAmnl'));
#唯一约束判断
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('mkijp'),soundex('abfcktdef'),soundex(' --'),soundex('AA'),soundex('AAmnl'));
#外键约束判断
insert into t_soundex(c1,c2,c3,c4,c5)values(soundex('mkijprr'),soundex('abfcktdef'),soundex('gfgdre'),soundex('AA'),soundex('AAmnl'));
select * from t1_soundex;
