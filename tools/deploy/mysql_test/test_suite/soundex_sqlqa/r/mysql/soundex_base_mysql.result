#数据准备
DROP TABLE IF EXISTS t_soundex;
Warnings:
Note	1051	Unknown table 'test.t_soundex'
create table t_soundex(c1 char(10),c2 VARCHAR(10),c3 VARCHAR(10),c4 VARCHAR(100),c5 int);
