insert into t_soundex values('mncl','lll','bcdl','qqfn',12345);
insert into t_soundex values('rmkt','lpp','vtjk','xyzp',12345);
insert into t_soundex values('rmktt','rnnqqd','rmajoooot','RRRRROOOOMMMMMCCCCAAAAAAAADDDDDDDDD',12345);
insert into t_soundex values('sSpvcdlmr','Sbbpvcdm','sapc','sfxd',12345);
