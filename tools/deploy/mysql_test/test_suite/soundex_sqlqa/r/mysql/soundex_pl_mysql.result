#Environmental cleaning
drop user zhe123@'%';
drop database if exists zhe123;
Warnings:
Note	1008	Can't drop database 'zhe123'; database doesn't exist
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
#数据准备
drop table if exists test;
Warnings:
Note	1051	Unknown table 'test.test'
create table test(c1 char(10),c2 char(10));
#在存储过程中，insert,select后面跟soundex函数，soundex函数作为变量传入，计算值对比
delete from test;
drop procedure proc_test1;
CREATE  PROCEDURE proc_test1 (IN s1 CHAR(30), OUT s2 CHAR(30))
BEGIN
insert into test values(soundex('ewewe'),soundex('abcdefgkk'));
SELECT soundex(c1) INTO s2 FROM test
WHERE c1 = s1;
END//
CALL proc_test1(soundex('ea'), @s2);
select * from test;
c1	c2
E000	A12312
#存储过程，update，where后面跟soundex函数
drop procedure proc_test2;
create PROCEDURE proc_test2(IN s1 CHAR(30), OUT s2 CHAR(30)) 
begin
update test set c2=soundex(s1) where soundex(c1)=soundex((s1));
SELECT soundex(c2)
into s2 FROM test where soundex(c1)=soundex((s1));
end//
CALL proc_test2('E', @s2);
select * from test;
c1	c2
E000	E000
#函数，将soundex返回值赋值后返回
drop table test;
create table test(c1 char(10),c2 char(10));
insert into test values('wmkb','amkk');
select soundex(c2) from test;
soundex(c2)
A520
drop function IF EXISTS func_test;
CREATE FUNCTION func_test (s CHAR(20))  RETURNS CHAR(50) deterministic
begin
declare s2 char(50);
select soundex(c2) from test where soundex(c1)=soundex(s) into s2;
return s2;
end//
SELECT func_test('wnnncf');
func_test('wnnncf')
A520
#触发器，数据准备
drop table if exists test1,test2,test3,test4;
Warnings:
Note	1051	Unknown table 'test.test1'
Note	1051	Unknown table 'test.test2'
Note	1051	Unknown table 'test.test3'
Note	1051	Unknown table 'test.test4'
create table test1(a1 char(20));
create table test2(a2 char(20));
create table test3(a3 char(20));
