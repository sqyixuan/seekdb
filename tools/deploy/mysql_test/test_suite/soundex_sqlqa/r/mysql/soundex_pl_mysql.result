wnqzgxfv	a
#触发器，where条件中soundex函数值比较，字母不同，结果相同
drop trigger if exists testref;
Warnings:
Note	1360	Trigger does not exist
create trigger testref before insert on test1
for each row
begin
insert into test2 set a2 = soundex(NEW.a1);
delete from test3 where soundex(a3) = soundex(NEW.a1);
update test4 set b4 = soundex(NEW.a1) where soundex(a4) =soundex(NEW.a1);
end;
