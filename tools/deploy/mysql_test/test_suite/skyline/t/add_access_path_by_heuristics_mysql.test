--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer
# description: test add access path by heuristics
# The heuristics used to generate access path is as follows:
# Different with cost-based approach, this function tries to use heuristics to generate access path
# * 1 if search condition cover an unique index key (primary key is treated as unique key), and no need index_back, use that key,
# *   if there is multiple such key, choose the one with the minimum index key count
# * 2 if search condition cover an index key, and no need index_back, use that key
# *   if there is multiple such key, choose the one with the minimal index key count
# * 3 if search condition cover an unique index key, need index_back,
# *   and query range number is less than a threshold, use that key
# *   and follows a refine process to find a better index
# * 4 otherwise generate all the access path and choose access path using cost model
--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t7;
--enable_warnings
create table t1(a int primary key, b int, c int, d int, e int, unique key uk1(b,c), unique key uk2(b,c,d), key k1(c,d), key k2(c,d,e));
--disable_result_log
--disable_query_log
select * from t1;
--enable_query_log
--enable_result_log
# match rule 1: unique key a without indexback
explain select * from t1 where a = 1 or a = 2;
explain update t1 set b = 1, c = 1 where a = 1 or a = 2;
explain delete from t1 where a = 1 or a = 2;
# match rule 1: unique key uk1 without indexback
explain select b, c from t1 where (b = 1 or b = 2) and (c = 1 or c = 2);
# match rule 2: key k1 without indexback
explain select c, d from t1 where (c = 1 or c = 2) and (d = 1 or d = 2);
# match rule 3: unique key uk1 with indexback
explain select * from t1 where (b = 1 or b = 2) and (c = 1 or c = 2);
explain update t1 set b = 5, c = 6 where (b = 1 or b = 2) and (c = 1 or c = 2);
explain delete from t1 where (b = 1 or b = 2) and (c = 1 or c = 2);
# does not match any rule, use cost_based approach
explain select * from t1 where e =1 or e = 2;
explain select * from t1 where b = 1 or b = 2;

#heuristics prefer to unique key than normal key 
create table t2(a int, b int, c int, unique key uk(a,b), key k(a,b));
--disable_result_log
--disable_query_log
select * from t2;
--enable_query_log
--enable_result_log
explain select a, b from t2 where (a = 1 or a = 2) and (b = 1 or b = 2);
explain select * from t2 where (a = 1 or a = 2) and (b = 1 or b = 2);

#for rule 1 and 2, if there is multiple index match, choose the one with the minimal index key count
#for rule 3, if there is multiple index match, choose the one with the minimal range count
create table t3(a int, b int, c int, d int, e int, primary key(a,b), unique key uk(a,b));
--disable_result_log
--disable_query_log
select * from t3;
--enable_query_log
--enable_result_log
explain select a, b from t3 where (a = 1 or a = 2) and (b = 1 or b = 2);
create table t4(a int, b int, c int, d int, e int, unique key ut4_a_b(a,b) storing(c,d,e), unique key ut4_c_d(c,d) storing(a,b));
--disable_result_log
--disable_query_log
select * from t4;
--enable_query_log
--enable_result_log
explain select a, b, c, d from t4 where a = 1 and b = 1 and c = 1 and d = 1;
create table t5(a int, b int, c int, d int, e int, key t5_a_b(a,b) storing(c,d,e), key t5_c(c) storing(a,b));
--disable_result_log
--disable_query_log
select * from t5;
--enable_query_log
--enable_result_log
explain select a, b, c from t5 where a = 1 and b = 1 and c = 1;
explain select * from t1 where (b = 1 or b = 2) and (c = 1 or c = 2) and (d = 1 or d = 2);

# this function try to refine rule 3
# our heuristics sometimes may choose sub-optimal index
# for example: create table t1(a int, b int, c int, unique key t1_b(b), unique key t1_b_c(b,c))
# for query, select b, c from t1 where b = 5 and c > 10,
# our heuristics will choose index t1_b, however, t1_b_c will be a much better choice since it does not need index back
# this, if we meet rule 3, we will search again all other index to find a better one
create table t6(a int, b int, c int, primary key(a,b), unique key t6_a(a), unique key t6_b(b));
--disable_query_log
--disable_result_log
select * from t6;
--enable_query_log
--enable_result_log
create table t7(a int, b int, c int, unique key t7_b(b), unique key t7_a_c_b(a,c,b));
--disable_result_log
--disable_query_log
select * from t7;
--enable_query_log
--enable_result_log
explain select * from t6 where a = 1;
explain select * from t6 where b = 1;
explain select a from t6 where a = 1;
explain select b from t6 where b = 1;
explain select b, c from t7 where b = 5 and c > 10 and a = 1;

drop table t1, t2, t3, t4, t5, t6, t7;

#bug:
# match rule 3: unique index uk_certno_name with indexback
--disable_warnings
drop table if exists cs_customer;
--enable_warnings
CREATE TABLE `cs_customer`(
`customer_id` varchar(24) COLLATE utf8mb4_bin NOT NULL,
`name` varchar(192) COLLATE utf8mb4_bin NOT NULL,
`national` varchar(5) COLLATE utf8mb4_bin NOT NULL,
`cert_type` varchar(30) COLLATE utf8mb4_bin NOT NULL,
`cert_no` varchar(96) COLLATE utf8mb4_bin NOT NULL,
`type` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`cert_from` varchar(30) COLLATE utf8mb4_bin NOT NULL,
`cert_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`open_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`enable_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`gmt_create` timestamp(6) NOT NULL,
`gmt_modified` timestamp(6) NOT NULL,
`memo` varchar(384) COLLATE utf8mb4_bin DEFAULT NULL NULL,
`ext_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
`corp_sub_type` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`customer_id`),
UNIQUE KEY `uk_certno_name` (`cert_no`, `name`),
KEY `idx_name` (`name`)
);
explain select CUSTOMER_ID, NAME, NATIONAL, CERT_TYPE, CERT_NO, TYPE, CERT_FROM, CERT_STATUS, OPEN_STATUS, ENABLE_STATUS, GMT_CREATE, GMT_MODIFIED, MEMO ,EXT_FLAG,CORP_SUB_TYPE
from cs_customer          
where (name = "1" OR name = "2") AND cert_type = "3" AND (cert_no = "4" OR cert_no = "5");

#match rule 3 with refine: unique key with index_back followed by a refine process 
--disable_warnings
drop table if exists astc_asset_balance_fa_00;
--enable_warnings
CREATE TABLE `astc_asset_balance_fa_00` (
  `id` varchar(28) NOT NULL,
  `accounting_id` varchar(28) NOT NULL,
  `accounting_type` varchar(32) NOT NULL,
  `balance_type` varchar(32) NOT NULL,
  `balance` bigint(15) NOT NULL,
  `currency` varchar(8) NOT NULL,
  `freeze_amount` bigint(15) NOT NULL,
  `in_amount` bigint(15) NOT NULL,
  `out_amount` bigint(15) NOT NULL,
  `cancel_amount` bigint(15) NOT NULL,
  `sys_rf_amount` bigint(15) NOT NULL,
  `sys_bu_amount` bigint(15) NOT NULL,
  `prev_balance` bigint(15) NOT NULL,
  `prev_trans_date` varchar(8) NOT NULL,
  `gmt_last_trans` timestamp(6) NOT NULL,
  `gmt_create` timestamp(6) NOT NULL,
  `gmt_modified` timestamp(6) NOT NULL,
  `user_id` varchar(16) NOT NULL,
  `product_channel` varchar(32) DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `IDX_astc_asset_balance_AB_FA_00` (`accounting_id`, `balance_type`) BLOCK_SIZE 16384,
  KEY `idx_astc_asset_balance_ub_fa_00` (`user_id`, `balance_type`, `accounting_id`) BLOCK_SIZE 16384,
  KEY `idx_aid_bt_b` (`accounting_id`, `balance_type`, `balance`) BLOCK_SIZE 16384
);
explain select accounting_id, balance_type, balance from astc_asset_balance_fa_00 
where 1=1 and accounting_id in('2015101900034001767600726113', '2015102000034001767600728075', '2015102000034001767600728285', '2015102000034001767600728291', '2015102000034001767600732082', '2015102000034001767600732085')   
and balance_type in('UNIT', 'P_AMOUNT', 'R_NA_AMOUNT');

--disable_warnings
drop table if exists kg_data;
--enable_warnings
CREATE TABLE `kg_data` (
  `s` bigint(20) NOT NULL,
  `p` varchar(255) NOT NULL,
  `o_type` varchar(255) NOT NULL,
  `o_str` varchar(3800) DEFAULT NULL,
  `o_num` decimal(38,8) DEFAULT NULL,
  `o_str_long` varchar(262143) DEFAULT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  PRIMARY KEY (`s`, `p`),
  KEY `idx_os` (`o_str`) LOCAL  BLOCK_SIZE 16384,
  KEY `idx_on` (`o_num`) LOCAL  BLOCK_SIZE 16384,
  KEY `idx_pos` (`p`, `o_str`) LOCAL  BLOCK_SIZE 16384,
  KEY `idx_pon` (`p`, `o_num`) LOCAL  BLOCK_SIZE 16384
);
explain select /*+read_consistency(weak),parallel(1)*/ t1.s from kg_data t1 where 1=1 and (t1.p='name' and (t1.o_str='xxx')) limit 50001;
