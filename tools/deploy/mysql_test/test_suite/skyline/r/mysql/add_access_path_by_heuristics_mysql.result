      OR cs_customer.cert_no = cast('5', VARCHAR(1048576))])
drop table if exists astc_asset_balance_fa_00;
CREATE TABLE `astc_asset_balance_fa_00` (
`id` varchar(28) NOT NULL,
`accounting_id` varchar(28) NOT NULL,
`accounting_type` varchar(32) NOT NULL,
`balance_type` varchar(32) NOT NULL,
`balance` bigint(15) NOT NULL,
`currency` varchar(8) NOT NULL,
`freeze_amount` bigint(15) NOT NULL,
`in_amount` bigint(15) NOT NULL,
`out_amount` bigint(15) NOT NULL,
`cancel_amount` bigint(15) NOT NULL,
`sys_rf_amount` bigint(15) NOT NULL,
`sys_bu_amount` bigint(15) NOT NULL,
`prev_balance` bigint(15) NOT NULL,
`prev_trans_date` varchar(8) NOT NULL,
`gmt_last_trans` timestamp(6) NOT NULL,
`gmt_create` timestamp(6) NOT NULL,
`gmt_modified` timestamp(6) NOT NULL,
`user_id` varchar(16) NOT NULL,
`product_channel` varchar(32) DEFAULT NULL,
PRIMARY KEY (`id`),
UNIQUE KEY `IDX_astc_asset_balance_AB_FA_00` (`accounting_id`, `balance_type`) BLOCK_SIZE 16384,
KEY `idx_astc_asset_balance_ub_fa_00` (`user_id`, `balance_type`, `accounting_id`) BLOCK_SIZE 16384,
KEY `idx_aid_bt_b` (`accounting_id`, `balance_type`, `balance`) BLOCK_SIZE 16384
);
explain select accounting_id, balance_type, balance from astc_asset_balance_fa_00 
where 1=1 and accounting_id in('2015101900034001767600726113', '2015102000034001767600728075', '2015102000034001767600728285', '2015102000034001767600728291', '2015102000034001767600732082', '2015102000034001767600732085')   
and balance_type in('UNIT', 'P_AMOUNT', 'R_NA_AMOUNT');
