      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([cs_customer.cert_no], [cs_customer.name], [cs_customer.shadow_pk_0]), range[4,1,NULL ; 4,1,NULL], [4,2,NULL ; 4,2,NULL], [5,1,NULL ; 5,
      1,NULL], [5,2,NULL ; 5,2,NULL], 
