drop table if exists kg_data;
CREATE TABLE `kg_data` (
`s` bigint(20) NOT NULL,
`p` varchar(255) NOT NULL,
`o_type` varchar(255) NOT NULL,
`o_str` varchar(3800) DEFAULT NULL,
`o_num` decimal(38,8) DEFAULT NULL,
`o_str_long` varchar(262143) DEFAULT NULL,
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`s`, `p`),
KEY `idx_os` (`o_str`) LOCAL  BLOCK_SIZE 16384,
KEY `idx_on` (`o_num`) LOCAL  BLOCK_SIZE 16384,
KEY `idx_pos` (`p`, `o_str`) LOCAL  BLOCK_SIZE 16384,
KEY `idx_pon` (`p`, `o_num`) LOCAL  BLOCK_SIZE 16384
);
explain select /*+read_consistency(weak),parallel(1)*/ t1.s from kg_data t1 where 1=1 and (t1.p='name' and (t1.o_str='xxx')) limit 50001;
