# owner: guohanyun.ghy
# owner group: SQL1
# description: test for show extended tables, show extended columns and show extended index

--result_format 4

--disable_warnings
drop table if exists t1,t2,t3;
drop view if exists v1,v2,v3;
--enable_warnings

create table t1(a int primary key, b int, c varchar(10), d double);
create table t2(a int, b int, c varchar(10) primary key, d double);
create table t3(a int, b int, c varchar(10), d double, e geometry not null srid 0);

create view v1 as select * from t1;
create view v2 as select * from t2;
create view v3 as select * from t3;

create index i11 on t1(a);
create index i12 on t1(a,b);
create index i13 on t1(b,a);
create index i14 on t1(b,c);
create index i15 on t1(c);
create unique index i1u1 on t1(a);
create unique index i1u2 on t1(b);
create unique index i1u3 on t1(d,a);
create index i21 on t2(a,b);
create index i22 on t2(b,c);
create index i23 on t2(c);
create index i31 on t3(a);
create index i32 on t3(a,b);
create index i33 on t3(b,a,c);
create index i34 on t3(a,b,c,d);
create index i35 on t3(d,c);
create unique index i3u1 on t3(b);
create unique index i3u2 on t3(d,a);
create spatial index i3s on t3(e);


# show table
show tables;
show extended tables;

#show columns
show columns from t1;
show extended columns from t1;
show columns from t2;
show extended columns from t2;
show columns from t3;
show extended columns from t3;
show full columns from t1;
show extended full columns from t1;
show full columns from t3;
show extended full columns from t3;

show columns from v1;
show extended columns from v1;
show columns from v2;
show extended columns from v2;
show columns from v3;
show extended columns from v3;
show full columns from v1;
show extended full columns from v1;
show full columns from v3;
show extended full columns from v3;

#show index
show index from t1;
show extended index from t1;
show index from t2;
show extended index from t2;
show index from t3;
show extended index from t3;

show index from v1;
show extended index from v1;
show index from v2;
show extended index from v2;
show index from v3;
show extended index from v3;

# drop table
drop view v1,v2,v3;
drop table t1,t2,t3;