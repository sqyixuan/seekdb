# owner: huangweixiang.hwx
# owner group: SQL2
# description: test new date type expr.
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists new_date, new_datetime, t1;
--enable_warnings

set @old_mode= @@sql_mode;
select @@sql_mode;
set sql_mode = 'ALLOW_INVALID_DATES';

create table new_date(c1 date, c2 time);
insert into new_date values(111111, '11:11:11'), (111100, '1:00:00'), (110011, '11:11:11.111'), (110230, '23:59:59.999');
create table new_datetime(c1 datetime(6), c2 time);
insert into new_datetime values
    ('2011-11-11 11:11:11', '11:11:11'), 
    ('2011-11-00 11:11:11', '11:11:11'), 
    ('2011-11-00 11:11:11', '23:59:59'), 
    ('2011-11-00 11:11:11', '01:01:01'), 
    ('2011-00-11 11:11:11', '11:11:11'), 
    ('2011-00-11 11:11:11', '23:59:59'), 
    ('2011-00-11 11:11:11', '01:01:01'), 
    ('2011-00-00 11:11:11', '11:11:11'), 
    ('2011-00-00 11:11:11', '23:59:59'), 
    ('2011-00-00 11:11:11', '01:01:01'),
    ('2011-02-30 11:11:11', '11:11:11'),
    ('2011-02-30 11:11:11', '23:59:59'),
    ('2011-02-30 11:11:11', '01:01:01');

select addtime(c1, c2) from new_date;
select addtime(c1, c2) from new_datetime;

select subtime(c1, c2) from new_date;
select subtime(c1, c2) from new_datetime;

select c1, DATE_FORMAT(c1,'%b %d %Y %h:%i %p') from new_date;
select c1, DATE_FORMAT(c1,'%b %d %Y %h:%i %p') from new_datetime;

select format(c1, 0) from new_date;
select format(c1, 1) from new_date;
select format(c1, 0) from new_datetime;
select format(c1, 1) from new_datetime;

select dayofmonth(c1) from new_date;
select dayofmonth(c1) from new_datetime;
select dayofweek(c1) from new_date;
select dayofweek(c1) from new_datetime;
select dayofyear(c1) from new_date;
select dayofyear(c1) from new_datetime;
select timestampadd(day,2,c1) from new_datetime;

drop table new_date;
drop table new_datetime;

set sql_mode = 'NO_ZERO_IN_DATE,NO_ZERO_DATE,ALLOW_INVALID_DATES';
select TIMESTAMP('2001-02-29 21:59:09');

select TIMESTAMP('2001-02-29 21:59:09', '01:00:01.111');

SELECT DATE_ADD('2000-02-31 23:01:59', INTERVAL 1 DAY) AS combined_date;
SELECT DATE_ADD(cast('2000-02-31 23:01:59' as date), INTERVAL 1 DAY) AS combined_date;
SELECT DATE_ADD(cast('2000-02-31 23:01:59' as datetime), INTERVAL 1 DAY) AS combined_date;

SELECT DATE_ADD('2000-02-00 23:01:59', INTERVAL 1 DAY) AS combined_date;
SELECT DATE_ADD(cast('2000-02-00 23:01:59' as date), INTERVAL 1 DAY) AS combined_date;
SELECT DATE_ADD(cast('2000-02-00 23:01:59' as datetime), INTERVAL 1 DAY) AS combined_date;

alter system set _enable_mysql_compatible_dates = false;
set sql_mode = 'ALLOW_INVALID_DATES';
sleep 5;
create table t1(c1 date);
insert into t1 values(0);
insert into t1 values(20200011);
insert into t1 values(20211112);
select c1, date_format(c1, '%Y %y %m %D %d %c %e %f %H %h %I %i %j %k %l %p %r %S %s %T %U %u %V %v %X %x %b') from t1;
drop table t1;
alter system set _enable_mysql_compatible_dates = true;
sleep 5;