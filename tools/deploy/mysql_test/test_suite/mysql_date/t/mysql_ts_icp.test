# owner: huangweixiang.hwx
# owner group: SQL2
# description: date timestamp index condition pushdown
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS T_DATE,T_TIMESTAMP;
--enable_warnings

set sql_mode = 'ALLOW_INVALID_DATES';

CREATE TABLE T_DATE (c1 int primary key, c2 DATE, key I_DATE(c2));
CREATE TABLE T_TIMESTAMP (c1 int primary key, c2 TIMESTAMP, key I_TIMESTAMP(c2));

insert into T_DATE values(1, '2021-02-30');
insert into T_DATE values(2, '2021-03-00');
insert into T_DATE values(3, '2021-00-11');

insert into T_TIMESTAMP values(0, '2021-02-28 00:00:00');
insert into T_TIMESTAMP values(1, '2021-02-28 23:59:59');
insert into T_TIMESTAMP values(2, '2021-03-01 00:00:00');
insert into T_TIMESTAMP values(3, '2021-03-02 00:00:00');
insert into T_TIMESTAMP values(4, '2021-03-03 00:00:00');
insert into T_TIMESTAMP values(5, '2021-03-04 00:00:00');
insert into T_TIMESTAMP values(6, '2020-12-31 00:00:00');
insert into T_TIMESTAMP values(7, '2020-12-31 23:59:59');
insert into T_TIMESTAMP values(8, '2021-01-01 00:00:00');
insert into T_TIMESTAMP values(9, '2021-01-01 23:59:59');
insert into T_TIMESTAMP values(10, '2021-01-02 00:00:00');

SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_TIMESTAMP T1, T_DATE T2 WHERE T1.C2 > T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_DATE T1, T_TIMESTAMP T2 WHERE T1.C2 < T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_TIMESTAMP T1, T_DATE T2 WHERE T1.C2 = T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_DATE T1, T_TIMESTAMP T2 WHERE T1.C2 = T2.C2;

# result is wrong when not use index
DROP TABLE T_DATE;
DROP TABLE T_TIMESTAMP;

CREATE TABLE T_DATE (c1 int primary key, c2 DATE);
CREATE TABLE T_TIMESTAMP (c1 int primary key, c2 TIMESTAMP);

insert into T_DATE values(1, '2021-02-30');
insert into T_DATE values(2, '2021-03-00');
insert into T_DATE values(3, '2021-00-11');

insert into T_TIMESTAMP values(0, '2021-02-28 00:00:00');
insert into T_TIMESTAMP values(1, '2021-02-28 23:59:59');
insert into T_TIMESTAMP values(2, '2021-03-01 00:00:00');
insert into T_TIMESTAMP values(3, '2021-03-02 00:00:00');
insert into T_TIMESTAMP values(4, '2021-03-03 00:00:00');
insert into T_TIMESTAMP values(5, '2021-03-04 00:00:00');
insert into T_TIMESTAMP values(6, '2020-12-31 00:00:00');
insert into T_TIMESTAMP values(7, '2020-12-31 23:59:59');
insert into T_TIMESTAMP values(8, '2021-01-01 00:00:00');
insert into T_TIMESTAMP values(9, '2021-01-01 23:59:59');
insert into T_TIMESTAMP values(10, '2021-01-02 00:00:00');

SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_TIMESTAMP T1, T_DATE T2 WHERE T1.C2 > T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_DATE T1, T_TIMESTAMP T2 WHERE T1.C2 < T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_TIMESTAMP T1, T_DATE T2 WHERE T1.C2 = T2.C2;
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_DATE T1, T_TIMESTAMP T2 WHERE T1.C2 = T2.C2;

DROP TABLE T_DATE;
DROP TABLE T_TIMESTAMP;