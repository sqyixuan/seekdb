# owner: huangweixiang.hwx
# owner group: SQL2
# description: delete time test.
# tags: datatype

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t2,t3;
--enable_warnings

alter system set _enable_mysql_compatible_dates = true;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set sql_mode = '';
sleep 5;

create table t2(c1 date);
insert into t2 values('2011-11-11'), ('2011-11-00'), ('2011-00-11');

### cast between mysql_date and mysql_date
create table t3(c1 date);
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

### cast between mysql_date and mysql_datetime
drop table t3;
create table t3(c1 datetime(6));
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

alter system set _enable_mysql_compatible_dates = false;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
sleep 5;
set sql_mode = '';

### cast between mysql_date and old date
drop table t3;
create table t3(c1 date);
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

### cast between mysql_date and old datetime
drop table t3;
create table t3(c1 datetime(6));
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

alter system set _enable_mysql_compatible_dates = true;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set sql_mode = '';
sleep 5;
drop table t2;
create table t2(c1 datetime(6));
insert into t2 values('2011-11-11 11:11:11.1111'), ('2011-11-00 11:11:11.1111'), ('2011-00-11 11:11:11.1111');

### cast between mysql_datetime and mysql_date
drop table t3;
create table t3(c1 date);
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

### cast between mysql_datetime and mysql_datetime
drop table t3;
create table t3(c1 datetime(6));
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

alter system set _enable_mysql_compatible_dates = false;
sleep 5;

### cast between mysql_datetime and old_date
drop table t3;
create table t3(c1 date);
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

### cast between mysql_datetime and old datetime
drop table t3;
create table t3(c1 datetime(6));
insert into t3(select * from t2 limit 3);
select * from t3;
insert into t2(select * from t3);
select * from t2;

--disable_warnings
DROP TABLE t2,t3;
--enable_warnings

alter system set _enable_mysql_compatible_dates = true;
sleep 5;
