drop table t1;
drop table t2;
create table t2(c1 datetime(6));
create table t1(c1 bigint, c2 bigint unsigned, c3 float, c4 double, c5 number(26, 6), 
      c6 varchar(30), c7 time(6), c8 timestamp, c9 year, c10 text, c11 json);
