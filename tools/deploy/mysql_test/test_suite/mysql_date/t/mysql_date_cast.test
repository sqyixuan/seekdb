### test cast timestamp
--disable_warnings
drop table if exists t_mysql_date;
drop table if exists t_old_date;
drop table if exists t_timestamp;
--enable_warnings

alter system set _enable_mysql_compatible_dates = false;
sleep 5;
create table t_old_date(c1 date, c2 datetime);
alter system set _enable_mysql_compatible_dates = true;
sleep 5;

create table t_mysql_date(id int, c1 date, c2 datetime);
create table t_timestamp(c1 timestamp);

set sql_mode = 'allow_invalid_dates';
insert into t_mysql_date values(1, '0000-00-00', '0000-00-00');
insert into t_mysql_date values(2, '2020-02-00', '2020-02-00');
insert into t_mysql_date values(3, '2020-02-31', '2020-02-31');

insert into t_old_date select c1, c2 from t_mysql_date;
insert into t_old_date select c2, c1 from t_mysql_date;
select * from t_old_date;
delete from t_old_date;

insert into t_timestamp select c1 from t_mysql_date;
insert into t_timestamp select c2 from t_mysql_date;
select * from t_timestamp;
delete from t_timestamp;

set sql_mode = 'no_zero_date';
insert into t_old_date select c1, c2 from t_mysql_date;
insert into t_old_date select c2, c1 from t_mysql_date;
select * from t_old_date;
delete from t_old_date;

insert into t_timestamp select c1 from t_mysql_date;
insert into t_timestamp select c2 from t_mysql_date;
select * from t_timestamp;
delete from t_timestamp;

set sql_mode = 'no_zero_in_date';
insert into t_old_date select c1, c2 from t_mysql_date;
insert into t_old_date select c2, c1 from t_mysql_date;
select * from t_old_date;
delete from t_old_date;

insert into t_timestamp select c1 from t_mysql_date;
insert into t_timestamp select c2 from t_mysql_date;
select * from t_timestamp;
delete from t_timestamp;

set sql_mode = 'strict_all_tables';
insert into t_old_date select c1, c2 from t_mysql_date where id = 1;
insert into t_old_date select c2, c1 from t_mysql_date where id = 1;
--error 1292
insert into t_old_date(c1) select c1 from t_mysql_date where id = 2;
--error 1292
insert into t_old_date(c1) select c1 from t_mysql_date where id = 2;
--error 1292
insert into t_old_date(c1) select c2 from t_mysql_date where id = 2;
--error 1292
insert into t_old_date(c2) select c1 from t_mysql_date where id = 2;
--error 1292
insert into t_old_date(c1) select c1 from t_mysql_date where id = 3;
--error 1292
insert into t_old_date(c1) select c1 from t_mysql_date where id = 3;
--error 1292
insert into t_old_date(c1) select c2 from t_mysql_date where id = 3;
--error 1292
insert into t_old_date(c2) select c1 from t_mysql_date where id = 3;
select * from t_old_date;
delete from t_old_date;

insert into t_timestamp select c1 from t_mysql_date where id = 1;
--error 1292
insert into t_timestamp select c1 from t_mysql_date where id = 2;
--error 1292
insert into t_timestamp select c1 from t_mysql_date where id = 3;
insert into t_timestamp select c2 from t_mysql_date where id = 1;
--error 1292
insert into t_timestamp select c2 from t_mysql_date where id = 2;
--error 1292
insert into t_timestamp select c2 from t_mysql_date where id = 3;
select * from t_timestamp;
delete from t_timestamp;
--disable_warnings
DROP TABLE t1,t2,t_mysql_date,t_old_date,t_timestamp;
--enable_warnings
