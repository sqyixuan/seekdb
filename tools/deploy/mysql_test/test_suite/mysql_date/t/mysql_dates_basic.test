#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: mysql date/datetime basic
#tags: mysql_date, date, datetime
#author: zuojiao.hzj

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
alter system set _enable_mysql_compatible_dates = 1;
--sleep 5
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

set @old_mode= @@sql_mode;
select @@sql_mode;
set sql_mode = 'STRICT_ALL_TABLES';

--echo "allow zero in date"
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
create table t1 (c1 date, c2 datetime, c3 datetime(6));
insert into t1 values (date'2020-00-01', '2021-00-01 01::02::30', '2021-00-01 10::59::00.123456');
insert into t1 values (date'2020-12-00', '2021-10-00 00::00::01', '2021-05-00 10::59::00.999999');
insert into t1 values ('1999-00-00', '2021-00-01 01::02::30', '2021-00-01 10::59::00.123456');
insert into t1 values ('0000-12-00', '2021-00-01', '2021-00-01');
insert into t1 values ('0000-00-00', '0000-00-00', '0000-00-00');

select * from t1;
drop table t1;

--echo "allow invalid dates"
create table t1 (c1 date, c2 datetime, c3 datetime(6));
--error 1525
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');

set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');
insert into t1 values ('2020-02-30', '2024-04-31', '2024-02-31');
insert into t1 values (date'2020-00-30', '2024-11-31', '2024-02-31');
insert into t1 values ('2020-00-30', '2024-11-31', '2024-08-31');
--error 1292
insert into t1 values ('2020-00-31', '2024-11-32', '2024-08-32');
drop table t1;

--echo "default value"
create table t1 (c1 date default '0000-00-00');
create table t2 (c1 date default '2020-00-00');
create table t3 (c1 date default '2020-12-00');
create table t4 (c1 date default '2020-00-15');
create table t5 (c1 date default '2020-02-31');
insert into t1 values (default);
insert into t2 values (default);
insert into t3 values (default);
insert into t4 values (default);
insert into t5 values (default);
select * from t1;
select * from t2;
select * from t3;
select * from t4;
select * from t5;
desc t1;
desc t2;
desc t3;
desc t4;
desc t5;
drop table t1, t2, t3, t4, t5;
create table t1 (c1 date default date'0000-00-00');
create table t2 (c1 date default date'2020-00-00');
create table t3 (c1 date default date'2020-12-00');
create table t4 (c1 date default date'2020-00-15');
create table t5 (c1 date default date'2020-02-31');
insert into t1 values (default);
insert into t2 values (default);
insert into t3 values (default);
insert into t4 values (default);
insert into t5 values (default);
select * from t1;
select * from t2;
select * from t3;
select * from t4;
select * from t5;
desc t1;
desc t2;
desc t3;
desc t4;
desc t5;
drop table t1, t2, t3, t4, t5;

create table t1 (c1 datetime default '0000-00-00 01:02:03');
create table t2 (c1 datetime default '2020-00-00 01:02:03');
create table t3 (c1 datetime default '2020-12-00 01:02:03');
create table t4 (c1 datetime default '2020-00-15 01:02:03');
create table t5 (c1 datetime default '2020-02-31 01:02:03');
insert into t1 values (default);
insert into t2 values (default);
insert into t3 values (default);
insert into t4 values (default);
insert into t5 values (default);
select * from t1;
select * from t2;
select * from t3;
select * from t4;
select * from t5;
desc t1;
desc t2;
desc t3;
desc t4;
desc t5;
drop table t1, t2, t3, t4, t5;

set sql_mode = 'STRICT_ALL_TABLES';
--error 1067
create table t1 (c1 date default '2020-02-30');
--error 1525
create table t1 (c1 date default date'2020-02-30');
--error 1067
create table t1 (c1 datetime default '2020-02-30 00:00:00');

set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';
create table t1 (c1 date default '2020-02-30', c2 date default date'2020-02-30', c3 datetime default '2020-02-30 00:00:00');
insert into t1 values (default, default, default);
select * from t1;
set sql_mode = 'STRICT_ALL_TABLES';
insert into  t1 values (default, default, default);
select * from t1;
drop table t1;
set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';

--echo "datetime round"
create table t1 (c1 datetime);
--error 1441
insert into t1 values ("9999-12-31 23:59:59.9999997");
insert into t1 values ("9999-12-31 23:59:58.9999997");
insert into t1 values ("9999-2-31 23:59:59.9999997");
select * from t1;
drop table t1;

alter system set _enable_mysql_compatible_dates = 0;
--sleep 5
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set sql_mode = 'STRICT_ALL_TABLES';

--echo "allow zero in date"
drop table if exists t1;
create table t1 (c1 date, c2 datetime, c3 datetime(6));
--error 1525
insert into t1 values (date'2020-00-01', '2021-00-01 01::02::30', '2021-00-01 10::59::00.123456');
--error 1525
insert into t1 values (date'2020-12-00', '2021-10-00 00::00::01', '2021-05-00 10::59::00.999999');
--error 1292
insert into t1 values ('1999-00-00', '2021-00-01 01::02::30', '2021-00-01 10::59::00.123456');
--error 1292
insert into t1 values ('0000-12-00', '2021-00-01', '2021-00-01');
insert into t1 values ('0000-00-00', '0000-00-00', '0000-00-00');

select * from t1;
drop table t1;

--echo "allow invalid dates"
create table t1 (c1 date, c2 datetime, c3 datetime(6));
--error 1525
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');

set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');
insert into t1 values ('2020-02-30', '2024-04-31', '2024-02-31');
--error 1525
insert into t1 values (date'2020-00-30', '2024-11-31', '2024-02-31');
--error 1292
insert into t1 values ('2020-00-30', '2024-11-31', '2024-08-31');
--error 1292
insert into t1 values ('2020-00-31', '2024-11-32', '2024-08-32');
select * from t1;
drop table t1;

alter system set _enable_mysql_compatible_dates = 1;
sleep 5;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set sql_mode = 'NO_ZERO_IN_DATE,NO_ZERO_DATE,ALLOW_INVALID_DATES';

DROP TABLE /*! IF EXISTS*/ table10_int_not_null; 
CREATE TABLE table10_int_not_null (pk int)    ; 

ALTER TABLE table10_int_not_null ADD COLUMN add_date_column5 DATE DEFAULT '99880231';
ALTER TABLE table10_int_not_null ADD COLUMN add_datetime_column5 DATETIME DEFAULT '99880231';

ALTER TABLE table10_int_not_null ADD COLUMN add_date_column6 DATE DEFAULT '9966-02-00';
ALTER TABLE table10_int_not_null ADD COLUMN add_datetime_column6 DATETIME DEFAULT '9997-02-00';

ALTER TABLE table10_int_not_null ADD COLUMN add_date_column7 DATE DEFAULT '990022';
ALTER TABLE table10_int_not_null ADD COLUMN add_datetime_column7 DATETIME DEFAULT '990022';

insert into table10_int_not_null(pk) values(1);
select * from table10_int_not_null;
drop table table10_int_not_null;

set sql_mode = ' NO_ZERO_IN_DATE,NO_ZERO_DATE,ALLOW_INVALID_DATES';
drop table if EXISTS sample_dates;
CREATE TABLE sample_dates (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100),
    birth_date DATE,
    appointment_time TIME,
    order_datetime DATETIME,
    registration_year YEAR
);
alter system flush plan cache;

ALTER TABLE sample_dates ADD COLUMN created_at DATETIME DEFAULT NULL;
insert into sample_dates(created_at) values('2021-01-01 11:11:11');
select * from sample_dates;
drop table sample_dates;

set sql_mode= 'NO_ZERO_IN_DATE,NO_ZERO_DATE,ALLOW_INVALID_DATES';
--disable_warnings
drop table if exists tlc1;
--enable_warnings
create table tlc1 (c1 date) partition by list columns(c1) (
partition p0 values in ('2001-01-11'),
partition p1 values in ('2022-01-30'),
partition p3 values in ('2024-02-30'),
partition p2 values in ('2025-02-31')
);

insert into tlc1 values('2001-01-11'); 
insert into tlc1 values('2024-02-30'); 
insert into tlc1 values('2025-02-31'); 
select * from tlc1;

drop table tlc1;
create table tlc1 (c1 date) partition by list columns(c1) (
partition p0 values in (date'2001-01-11'),
partition p1 values in (date'2022-01-30'),
partition p3 values in (date'2024-02-30'),
partition p2 values in (date'2025-02-31')
);

insert into tlc1 values('2001-01-11'); 
insert into tlc1 values('2024-02-30'); 
insert into tlc1 values('2025-02-31'); 
select * from tlc1;
drop table tlc1;

create table tlc1(a int primary key, b timestamp(6));
insert into tlc1 values(1, '2024-09-23 19:17:06.822816');
insert into tlc1 values(2, '2024-09-23 19:17:06.822816');
select cast(b as datetime(6)) from tlc1;

select cast(b as datetime(6)) from tlc1;
ALTER SYSTEM SET _enable_mysql_compatible_dates = false;
alter system flush plan cache global;
sleep 5;
select cast(b as datetime(6)) from tlc1;
ALTER SYSTEM SET _enable_mysql_compatible_dates = true;
sleep 5;
select cast(b as datetime(6)) from tlc1;
alter system flush plan cache;
select cast(b as datetime(6)) from tlc1;

--sleep 5
