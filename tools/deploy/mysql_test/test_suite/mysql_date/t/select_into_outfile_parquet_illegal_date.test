#owner: huangweixiang.hwx
#owner group: sql2
#tags: external table/mysql_date

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile_parquet;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1, t1_ext;
--enable_warnings

--result_format 4

set sql_mode = 'allow_invalid_dates';
create table t1 (c1 date, c2 datetime);
eval create external table t1_ext (c1 date, c2 datetime)
format (type = 'PARQUET') location '$DATA_FOLDER_NAME' auto_refresh = IMMEDIATE;

insert into t1 values('0000-00-00', '0000-00-00');

--source mysql_test/include/select_into_outfile/delete_files.inc
eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data4.parquet'
format = (TYPE = 'PARQUET');
--source mysql_test/include/select_into_outfile/list_dir.inc

select * from t1_ext;

insert into t1 values('2021-10-00', '2021-10-00');

--source mysql_test/include/select_into_outfile/delete_files.inc
eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data4.parquet'
format = (TYPE = 'PARQUET');
--source mysql_test/include/select_into_outfile/list_dir.inc

select * from t1_ext;

insert into t1 values('2021-2-31', '2021-2-31');

--source mysql_test/include/select_into_outfile/delete_files.inc
eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data4.parquet'
format = (TYPE = 'PARQUET');
--source mysql_test/include/select_into_outfile/list_dir.inc

select * from t1_ext;
--source mysql_test/include/select_into_outfile/delete_files.inc

DROP TABLE t1, t1_ext;
