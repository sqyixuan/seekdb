#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: mysql date/datetime basic
#tags: mysql_date, date, datetime
#author: zuojiao.hzj

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
alter system set _enable_mysql_compatible_dates = 1;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--sleep 5
--disable_warnings
drop database if exists mysql_date;
--enable_warnings
create database mysql_date;
use mysql_date;

set @old_mode= @@sql_mode;
select @@sql_mode;
set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';

create table t1 (c1 date, c2 datetime, c3 datetime(6));
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');
insert into t1 values (date'2020-00-30', '2024-11-31', '2024-02-31');
insert into t1 values ('2020-00-30', '2024-11-31', '2024-08-31');
insert into t1 values ('2021-01-03', '1992-11-23', '1996-02-28');

--echo "datediff"
--explain_protocol 2
select datediff('2020-01-03', '2021-11-11');
select datediff(20200103, 20211111);
select datediff(date'2020-01-03', '2021-11-11');
select datediff(date'2020-02-31', '2021-11-11');
select datediff(date'2020-02-31', date'2021-00-11');
select datediff(c1, c2) from t1;
select datediff(c2, c3) from t1;
--explain_protocol 0
drop table t1;
create table t1 (c1 date, c2 date);
insert into t1 values ('2020-01-01', '0-01-01');
insert into t1 values ('2020-01-01', '2020-00-01');
insert into t1 values ('2020-01-01', '2020-01-0');
insert into t1 values ('2020-01-01', '0000-00-0');
insert into t1 values ('0000-00-00', '0000-00-00');
select datediff(c1, c2) from t1;
drop table t1;

--echo "last_day"
create table t1 (c1 date, c2 datetime, c3 datetime(6));
insert into t1 values (date'2020-02-30', '2024-04-31', '2024-02-31');
insert into t1 values (date'2020-00-30', '2024-11-31', '2024-02-31');
insert into t1 values ('2020-05-00', '2024-11-31', '2024-08-31');
insert into t1 values ('2021-01-03', '1992-11-23', '1996-02-28');
select last_day(c1), last_day(c2), last_day(c3) from t1;
select last_day(date'0000-01-01');
select last_day(date'2020-00-01');
select last_day(date'0000-00-00');
select last_day(date'2020-01-00');
drop table t1;

--echo "cast expr"
select cast("2020-00-01" as date);
select cast("0000-01-15" as date);
select cast("2020-00-00" as date);
select cast("2020-12-00" as date);
select cast("2020-02-31" as date);
select cast("0000-00-00" as date);

select cast("2020-00-01" as datetime);
select cast("0000-01-15" as datetime);
select cast("2020-00-00" as datetime);
select cast("2020-12-00" as datetime);
select cast("2020-02-31" as datetime);
select cast("0000-00-00" as datetime);

--echo "date add/sub"
select date_add(date'2020-02-30', INTERVAL 1 month);
select date_add(date'2020-00-01', INTERVAL 2 year);
select date_add(date'2020-12-00', INTERVAL 2 week);
select date_add('2020-02-30', INTERVAL '1 2' minute_second);
select date_add('2020-00-01', INTERVAL '1 2' minute_microsecond);
select date_add('2020-12-00', INTERVAL '1 01:15:30' day_second);

select date_sub(date'2020-02-30', INTERVAL 1 month);
select date_sub(date'2020-00-01', INTERVAL 2 year);
select date_sub(date'2020-12-00', INTERVAL 2 week);
select date_sub('2020-02-30', INTERVAL '1 2' minute_second);
select date_sub('2020-00-01', INTERVAL '1 2' minute_microsecond);
select date_sub('2020-12-00', INTERVAL '1 01:15:30' day_second);

create table t1 (c1 date, c2 datetime);
insert into t1 values (date'2020-00-01', '2020-00-00');
select c1 + INTERVAL 1 month, c2 + INTERVAL 1 month from t1;
select c1 + INTERVAL 2 year, c2 + INTERVAL 2 year from t1;
select c1 + INTERVAL 2 week, c2 + INTERVAL 2 week from t1;
select c1 + INTERVAL '1 2' minute_second, c2 + INTERVAL '1 2' minute_second from t1;
select c1 + INTERVAL '1 2' minute_microsecond, c2 + INTERVAL '1 2' minute_microsecond from t1;
select c1 + INTERVAL '1 01:15:30' day_second, c2 + INTERVAL '1 01:15:30' day_second from t1;

select c1 - INTERVAL 1 month, c2 - INTERVAL 1 month from t1;
select c1 - INTERVAL 2 year, c2 - INTERVAL 2 year from t1;
select c1 - INTERVAL 2 week, c2 - INTERVAL 2 week from t1;
select c1 - INTERVAL '1 2' minute_second, c2 - INTERVAL '1 2' minute_second from t1;
select c1 - INTERVAL '1 2' minute_microsecond, c2 - INTERVAL '1 2' minute_microsecond from t1;
select c1 - INTERVAL '1 01:15:30' day_second, c2 - INTERVAL '1 01:15:30' day_second from t1;

drop table t1;

--echo "str to date"
select str_to_date('202112', '%Y%m');
select str_to_date('20211215', '%Y%m%d');

select str_to_date('202100', '%Y%m');
select str_to_date('20211200', '%Y%m%d');
select str_to_date('20210015', '%Y%m%d');
select str_to_date('00000015', '%Y%m%d');

select str_to_date('20210230', '%Y%m%d');
select str_to_date('20211131', '%Y%m%d');

select str_to_date('2010122010560010', '%Y%m%d%H%i%S%f');
select str_to_date('2010002010560010', '%Y%m%d%H%i%S%f');
select str_to_date('2010120010560010', '%Y%m%d%H%i%S%f');
select str_to_date('2010023010560010', '%Y%m%d%H%i%S%f');


create table t1 (c1 varchar(20), format varchar(20));
insert into t1 values('202112', '%Y%m');
insert into t1 values('20211215', '%Y%m%d');

insert into t1 values('202100', '%Y%m');
insert into t1 values('20211200', '%Y%m%d');
insert into t1 values('20210015', '%Y%m%d');
insert into t1 values('00000015', '%Y%m%d');

insert into t1 values('20210230', '%Y%m%d');
insert into t1 values('20211131', '%Y%m%d');

insert into t1 values('2010122010560010', '%Y%m%d%H%i%S%f');
insert into t1 values('2010002010560010', '%Y%m%d%H%i%S%f');
insert into t1 values('2010120010560010', '%Y%m%d%H%i%S%f');
insert into t1 values('2010023010560010', '%Y%m%d%H%i%S%f');

select str_to_date(c1, format) from t1;
drop table t1;

drop database mysql_date;
