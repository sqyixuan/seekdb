c1	c2	c1	c2
SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ * FROM T_DATE T1, T_TIMESTAMP T2 WHERE T1.C2 = T2.C2;
c1	c2	c1	c2
DROP TABLE T_DATE;
DROP TABLE T_TIMESTAMP;
CREATE TABLE T_DATE (c1 int primary key, c2 DATE);
CREATE TABLE T_TIMESTAMP (c1 int primary key, c2 TIMESTAMP);
