DROP TABLE IF EXISTS t1,t2;
alter system set _enable_mysql_compatible_dates = true;
set sql_mode = 'ALLOW_INVALID_DATES';
create table t2(c1 date);
create table t1(c1 int, c2 int unsigned, c3 float, c4 double, c5 number(26, 6), c6 varchar(30), 
c7 time(6), c8 timestamp, c9 year, c10 text, c11 json);
