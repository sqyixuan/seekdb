drop table if exists t1, t1_ext;
result_format: 4
set sql_mode = 'allow_invalid_dates';
create table t1 (c1 date, c2 datetime);
create external table t1_ext (c1 date, c2 datetime)
format (type = 'PARQUET') location 'data_for_mysqltest_select_into_outfile_parquet' auto_refresh = IMMEDIATE;

insert into t1 values('0000-00-00', '0000-00-00');

SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_parquet/data4.parquet'
format = (TYPE = 'PARQUET');
data4.parquet
select * from t1_ext;
+------------+---------------------+
| c1         | c2                  |
+------------+---------------------+
| 0000-00-00 | 0000-00-00 00:00:00 |
+------------+---------------------+

insert into t1 values('2021-10-00', '2021-10-00');

SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_parquet/data4.parquet'
format = (TYPE = 'PARQUET');
data4.parquet
select * from t1_ext;
+------------+---------------------+
| c1         | c2                  |
+------------+---------------------+
| 0000-00-00 | 0000-00-00 00:00:00 |
| 0000-00-00 | 0000-00-00 00:00:00 |
+------------+---------------------+

insert into t1 values('2021-2-31', '2021-2-31');

SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_parquet/data4.parquet'
format = (TYPE = 'PARQUET');
data4.parquet
select * from t1_ext;
+------------+---------------------+
| c1         | c2                  |
+------------+---------------------+
| 0000-00-00 | 0000-00-00 00:00:00 |
| 0000-00-00 | 0000-00-00 00:00:00 |
| 2021-03-03 | 2021-03-03 00:00:00 |
+------------+---------------------+
DROP TABLE t1, t1_ext;
