alter system set _enable_mysql_compatible_dates = false;
set sql_mode = 'ALLOW_INVALID_DATES';
create table t1(c1 date);
insert into t1 values(0);
insert into t1 values(20200011);
insert into t1 values(20211112);
select c1, date_format(c1, '%Y %y %m %D %d %c %e %f %H %h %I %i %j %k %l %p %r %S %s %T %U %u %V %v %X %x %b') from t1;
