create index idx_1 on t(c4);

# column stored index
drop table if exists t;
create table t(c1 vector(3), c2 vector(3), c3 int, c4 json, c5 char(10));
insert into t values('[1,2,3]', '[4,5,6]', 1, '{}','default');
--error 1235 # ERROR 1235 (0A000): setting vector index storing column is not supported
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw) storing(c2) with column group(each column);
--error 1235 # ERROR 1235 (0A000): setting vector index storing column is not supported
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw) storing(c4) with column group(each column);
# fixed bug
--error 1167 # ERROR 1167 (42000): The used storage engine can't index column 'c1'
create index idx_1 on t(c3) storing(c1) with column group(each column);
create index idx_1 on t(c3) storing(c5) with column group(each column);