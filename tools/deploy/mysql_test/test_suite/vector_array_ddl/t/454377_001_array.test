--echo online ddl
drop table if exists t;
create table t(c1 vector(3), c2 int[], c3 int, primary key(c3));
alter table t add a1 vector(4);
alter table t add a2 array(int);
drop table if exists t;
create table t(c1 vector(3), c2 int[], c3 int, primary key(c3));
alter table t add column a1 vector(3) as (c1 + '[1,1,1]') virtual;
alter table t add column a2 array(int) as (c1 + [2,2,2]) virtual;
alter table t drop column a1;
alter table t drop column a2;
drop table if exists t;
create table t(c1 vector(3), c2 int[], c3 int, primary key(c3));
--error 1138
alter table t modify column c1 vector(3) not null;
--error 1138
alter table t modify column c2 array(int) not null;
alter table t modify column c1 vector(3) null;
alter table t modify column c2 array(int) null;
