alter table t alter c1 set default [1,1,1];
--error 1101
alter table t alter c2 set default '[1,1,1]';
--error 1064
alter table t alter c1 drop default [1,1,1];
--error 1064
alter table t alter c2 drop default '[1,1,1]';
drop table if exists t;
create table t(c1 vector(3), c2 int[], c3 int auto_increment, primary key(c3));
alter table t auto_increment=10;
insert into t(c3) values (default);
select case when 1=(select count(*) from t where c3=10) then '没问题' else '有问题' end as result;
alter table t change column c1 a1 vector(3);
alter table t change column c2 a2 array(int);
alter table t modify column a1 vector(4);
--error 1064
alter table t modify column a2 int[10];
drop table if exists t;
create table t(c1 vector(3), c2 int[], c3 int auto_increment, primary key(c3));
alter table t modify column c1 vector(4), add a1 vector(5), drop column c2;
show create table t;
drop table if exists t;
create table t(c1 vector(3), c2 float[], c3 int auto_increment, primary key(c3));
