--echo add foreign\check\null constraint
drop table if exists t;
drop table if exists t1;
create table t (c1 vector(3), c2 int);
create table t1 (c1 vector(3), c2 int, primary key(c2));
alter table t add constraint fk_1 foreign key(c2) references t1(c2);
alter table t1 add constraint chk_1 check (c2>5);
show create table t;
show create table t1;
select * from information_schema.table_constraints where table_name='t';
--error 1452 # ERROR 1452 (23000): Cannot add or update a child row: a foreign key constraint fails
insert into t values('[1,2,3]', 1);
--error 3819 # ERROR 3819 (HY000): check constraint violated
insert into t1 values('[2,3,4]', 3);
insert into t1 values('[2,3,4]', 6);
insert into t values('[2,3,4]', 6);
alter table t add constraint fk_2 foreign key(c2) references t1(c2);
alter table t1 add constraint chk_2 check (c2>3);
show create table t;
show create table t1;

--echo drop foreign\check\null constraint
alter table t drop constraint fk_1;
alter table t1 drop constraint chk_1;
show create table t;
show create table t1;

