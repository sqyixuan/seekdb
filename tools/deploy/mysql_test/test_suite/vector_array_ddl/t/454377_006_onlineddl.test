--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings

--echo =============================
--echo =  vector index online ddl  =
--echo =============================

alter system ob_vector_memory_limit_percentage=30;
select sleep(5);
create table t(c1 vector(3), c2 int unsigned auto_increment, c3 json, c4 date, c5 varchar(20), index idx_0(c4), primary key(c2));
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw);
insert into t values('[1,2,3]', default, '{}', '2024-05-06', 'tom');
alter table t add c6 vector(3);
alter table t add c7 vector(3) as (c1 + c6) virtual;
alter table t add c8 int as (c5 + 'jarry') virtual;
# fixed bug
create vector index idx_2 on t(c6) with (distance=inner_product, type=hnsw);
select /*+ read_consistency(weak) */ * from t where c4 = '2024-05-06';
select count(*) from t order by l2_distance(c1, '[5,6,7]') approx limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select count(*) from t order by l2_distance(c1, '[5,6,7]') approx limit 1;

drop table if exists t;
create table t(c1 vector(3), c2 vector(3), c3 int, primary key(c3));
alter table t add column c4 vector(3) as (c1 + c2) virtual;
--error 1235 # ERROR 1235 (0A000): Using generate column as vector index column is not supported
create vector index idx_1 on t(c4) with (distance=l2, type=hnsw);
alter table t add column c5 int as (c3 + 5) virtual;
create index idx_2 on t(c5);
alter table t drop column c4;
alter table t drop column c5;
show index from t;
insert into t values('[1,2,3]', '[4,5,6]', 1);
insert into t values('[3,4,5]', '[4,5,7]', 2);
alter table t add column c4 vector(3) as (c1 + c2) virtual;
--error 1235
create vector index idx_1 on t(c4) with (distance=l2, type=hnsw);
create vector index idx_2 on t(c1) with (distance=l2, type=hnsw);
alter table t add column c5 int as (c3 + 5) virtual;
create index idx_3 on t(c5);
select c1 from t order by l2_distance(c1, '[5,6,7]') approx limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select c1 from t order by l2_distance(c1, '[5,6,7]') approx limit 1;
#--error 1235
alter table t drop column c4; # ERROR 1235 (0A000): Run this DDL operation on table with fulltext/multivalue/vector index. not supported
# fixed bug
#--error 1235
alter table t drop column c5; # ERROR 1235 (0A000): Run this DDL operation on table with fulltext/multivalue/vector index. not supported
show index from t;

