--echo drop index
drop table if exists t;
create table t(c1 vector(3), c2 int auto_increment, primary key(c2), vector index idx_1(c1) with (distance=l2, type=hnsw));
alter table t drop index idx_1;
drop table if exists t;
create table t(c1 vector(3), c2 int auto_increment, primary key(c2), vector index idx_1(c1) with (distance=l2, type=hnsw));
insert into t values('[1,1,1]', default);
alter table t drop key idx_1;
drop table if exists t;
create table t(c1 vector(3), c2 int auto_increment, c3 char(10), primary key(c2), vector key idx_1(c1) with (distance=l2, type=hnsw), index idx_2(c3));
alter table t drop index idx_1, drop key idx_2;
drop table if exists t;
create table t(c1 vector(3), c2 int auto_increment, c3 char(10), primary key(c2), vector key idx_1(c1) with (distance=l2, type=hnsw), index idx_2(c3));
alter table t drop key idx_1, drop key idx_2;
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw);
insert into t values('[1,1,1]', default, 'a');
alter table t drop index idx_1;
show create table t;

--echo rename index
