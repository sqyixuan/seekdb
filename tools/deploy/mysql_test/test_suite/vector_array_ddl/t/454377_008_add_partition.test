--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

alter system set ob_vector_memory_limit_percentage=30;
sleep 10;

let $dur=20;

--echo
--echo
--echo "=========================================== range + key partition ==========================================="
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), c4 varchar(50) not null default ' ', primary key(c1, c4), vector index idx1(c2) with (distance=inner_product, type=hnsw))
    partition by range(c1)
    subpartition by key(c4)
    (partition p0 values less than (100)
        (subpartition m0,
        subpartition m1,
        subpartition m2),
     partition p1 values less than (1000)
        (subpartition m3,
        subpartition m4,
        subpartition m5),
     partition p2 values less than (10000)
        (subpartition m6,
        subpartition m7,
        subpartition m8)
    );
