--echo
--echo
--echo "=========================================== key + range template partition ==========================================="
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings

create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
    partition by key (c1)
    subpartition by range (unix_timestamp(c3))
    subpartition template
    (subpartition p0 values less than (unix_timestamp('2024/12/02')),
    subpartition p1 values less than (unix_timestamp('2024/12/03')),
    subpartition p2 values less than (unix_timestamp('2024/12/04'))
    )
    (partition p0,
     partition p1,
     partition p2
    );
