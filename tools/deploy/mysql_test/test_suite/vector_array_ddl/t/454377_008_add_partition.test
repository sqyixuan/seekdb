    partition by range(c1)
    subpartition by list (unix_timestamp(c3))
    subpartition template
    (subpartition m0 values in (unix_timestamp('2024/12/01')),
     subpartition m1 values in (unix_timestamp('2024/12/02')),
     subpartition m2 values in (unix_timestamp('2024/12/03'))
    )
    (partition p0 values less than (10),
     partition p1 values less than (100),
     partition p2 values less than (200)
    );
