--echo
--echo
--echo "=========================================== hash + list template partition ==========================================="
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings

create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
    partition by hash (c1)
    subpartition by list (unix_timestamp(c3))
    subpartition template
    (subpartition p0 values in (unix_timestamp('2024/12/01')),
    subpartition p1 values in (unix_timestamp('2024/12/02')),
    subpartition p2 values in (unix_timestamp('2024/12/03'))
    )
    (partition p0,
     partition p1,
     partition p2
    );
