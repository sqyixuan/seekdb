create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
    partition by hash (c1)
    subpartition by hash (unix_timestamp(c3))
    (partition p0
        (subpartition p0p0,
        subpartition p0p1,
        subpartition p0p2
        ),
     partition p1
        (subpartition p1p0,
        subpartition p1p1,
        subpartition p1p2
        ),
     partition p2
        (subpartition p2p0,
        subpartition p2p1,
        subpartition p2p2
        )
    );
