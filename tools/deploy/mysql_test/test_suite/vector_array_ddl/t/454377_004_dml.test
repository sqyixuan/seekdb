--echo replace into
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
replace into t values ([1,1,100], [1,1,2018], 100, '2018-08-15');
replace into t values ([1,1,101], [1,1,2019], 100, '2018-08-15');
select * from t;
--disable_warnings
drop view if exists v;
--enable_warnings
create view v as select * from t where c3 >30;
replace into v values ([1,1,102], [1,1,2019], 20, '2018-08-15');
replace into v values ([1,1,103], [1,1,2019], 50, '2018-08-15');
--disable_warnings ONCE
drop materialized view if exists m;
--error 1235 # Multi order by item when using vector index is not supported
create materialized view m as select * from t order by l2_distance(c1, [1,1,20]),c3 approx limit 1;
create materialized view m as select * from t order by l2_distance(c1, [1,1,99]) approx limit 1;
select * from m;
