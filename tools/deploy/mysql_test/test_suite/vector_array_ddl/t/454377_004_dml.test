--echo insert
--disable_warnings
drop table if exists t;
--enable_warnings

select sleep(5);
alter system ob_vector_memory_limit_percentage=30;
select sleep(5);
create table t(c1 vector(3), c2 array(float), c3 int auto_increment, primary key(c3), vector index idx_1(c1) with (distance=l2, type=hnsw));
drop procedure if exists pl1;
delimiter //;
create procedure pl1(ll int)
    begin
        set @x=1;
        set @y=1;
        repeat
            insert into t values (concat('[',1,',',1,',',@x,']'), concat('[',1,',',1,',',@y,']'), default);
            set @x=@x+1;
            set @y=@y+1;
        until @x>ll end repeat;
    end //
delimiter ;//
call pl1(100);
--error 1235
create vector index idx_2 on t(c2) with (distance=l2, type=hnsw); # ERROR 1235 (0A000): Not supported feature or function
# won't fixed bug
SELECT
    CASE
        WHEN 8 !=
             (SELECT COUNT(*)
              FROM (
                  SELECT *
                  FROM t
                  ORDER BY l2_distance(c1, [1,8,30]) APPROXIMATE
                  LIMIT 8) AS tmp1
              JOIN
                  (SELECT *
                   FROM t
                   ORDER BY l2_distance(c1, [1,8,30])
                   LIMIT 8) AS tmp2
              ON tmp1.c3 = tmp2.c3)
        THEN '有问题'
        ELSE '没问题'
    END AS result;

insert into t values ([1,1,101],[1,1,101],101),('[1,1,102]',[1,1,102],102),('[1,1,103]','[1,1,103]',103);
select * from t;
