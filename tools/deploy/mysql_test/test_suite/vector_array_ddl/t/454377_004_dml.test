insert into t values('[1,1,1]',1),('[2,2,2]',2);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by negative_inner_product(c1, [0,1,1]) approx limit 1;
select * from t order by negative_inner_product(c1, [0,1,1]) approx limit 1;
drop index idx_1 on t;
create vector index idx_1 on t(c1) with (distance=l2,type=hnsw);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, [0,1,1]) approx limit 1;
select * from t order by l2_distance(c1, [0,1,1]) approx limit 1;
