create table t(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
create table t1(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
create table  t2(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw));
