--echo insert into view
drop table if exists t;
create table t(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
call pl1(100);
--disable_warnings
drop view if exists v;
drop materialized view if exists m;
--enable_warnings
create view v as select * from t order by l2_distance(c1, '[1,2,30]') approx limit 10;
create materialized view m refresh complete on demand as select * from t order by l2_distance(c1, '[1,2,10]') approx limit 10;
--error 1471 # ERROR 1471 (HY000): The target table v of the INSERT is not insertable-into
insert into v values('[1,1,105]', [1,1,1090], default, '2018-9-19');
--error 1235 # ERROR 1235 (0A000): DML operation on materialized view (log) is not supported
insert into m values('[1,1,105]', [1,1,1090], default, '2019-9-18');
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select * from t where c3>100;
insert into v1 values('[1,1,105]', [1,1,1090], default, '2019-9-18');
--disable_warnings
drop materialized view if exists m1;
--enable_warnings
create materialized view m1 refresh complete on demand as select * from t where c3>100;
--error 1235 # ERROR 1235 (0A000): DML operation on materialized view (log) is not supported
insert into m1 values('[1,1,105]', [1,1,1090], default, '2019-9-18');
drop index idx_1 on t;
--error 1235 # ERROR 1235 (0A000): create vector index on view table is not supported
create vector index idx_1 on m1(c1) with(distance=l2, type=hnsw);
create index idx_2 on m1(c3);
select count(*) from m,m1;
--disable_warnings
drop view if exists v2;
--enable_warnings
create view v2 as select * from m1;
insert into v2 values('[1,1,105]', [1,1,1090], default, '2019-9-18');
select * from m1,v2;

