#1. 不指定approximate，表达式非 inner_product / negative_inner_product / L2，报错
drop table if exists t;
create table t(c1 vector(3), c2 int, primary key(c2), vector index idx_1(c1) with (distance=l2,type=hnsw));
insert into t values('[1,1,1]',1),('[2,2,2]',2);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l1_distance(c1, [0,1,1]) limit 1;
select * from t order by l1_distance(c1, [0,1,1]) limit 1;
#2. 不指定approximate，表达式是 inner_product / negative_inner_product / L2，不走索引
drop table if exists t;
create table t(c1 vector(3), c2 int, primary key(c2), vector index idx_1(c1) with (distance=l2,type=hnsw));
insert into t values('[1,1,1]',1),('[2,2,2]',2);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by inner_product(c1, [0,1,1]) limit 1;
select * from t order by inner_product(c1, [0,1,1]) limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by negative_inner_product(c1, [0,1,1]) limit 1;
select * from t order by negative_inner_product(c1, [0,1,1]) limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, [0,1,1]) limit 1;
select * from t order by l2_distance(c1, [0,1,1]) limit 1;
#3. 指定approximate，表达式是 inner_product / negative_inner_product / L2，但和对应的向量索引距离算法不匹配，不报错，不走索引
drop table if exists t;
create table t(c1 vector(3), c2 int, primary key(c2), vector index idx_1(c1) with (distance=l2,type=hnsw));
insert into t values('[1,1,1]',1),('[2,2,2]',2);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by inner_product(c1, [0,1,1]) approx limit 1;
select * from t order by inner_product(c1, [0,1,1]) approx limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by negative_inner_product(c1, [0,1,1]) approx limit 1;
select * from t order by negative_inner_product(c1, [0,1,1]) approx limit 1;
drop index idx_1 on t;
create vector index idx_1 on t(c1) with (distance=inner_product,type=hnsw);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, [0,1,1]) approx limit 1;
select * from t order by l2_distance(c1, [0,1,1]) approx limit 1;
