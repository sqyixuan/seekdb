--error 1235
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw, m=60, ef_construction=50);
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=nsw);
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, lib=sag);
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, m=50, ef_construction=50);
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, m=60, ef_construction=50);

--echo constraint at least two parameters are required distance and type
