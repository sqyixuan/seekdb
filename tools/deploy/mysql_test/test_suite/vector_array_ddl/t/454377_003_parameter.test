create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=true);
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=1);
drop index idx_1 on t;
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=101);
drop index idx_1 on t;
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=1000);
drop index idx_1 on t;
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=1001);
