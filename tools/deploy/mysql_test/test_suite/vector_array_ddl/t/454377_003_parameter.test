create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=-20);
--error 1235
create vector index idx_1 on t(c1) with (distance=inner_product, type=hnsw, ef_search=100.11);

--echo constraint hnsw + vsag + ef_construction > m
--error 1235
create vector index idx_1 on t(c1) with (distance=l2, type=nsw);
--error 1235
create vector index idx_1 on t(c1) with (distance=l2, type=hnsw, lib=sag);
