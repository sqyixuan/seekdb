--error 1235
create vector index idx_1 on t(c1) with (type=hnsw);
--error 1235
create vector index idx_1 on t(c1) with (type=hnsw, lib=vasg, m=50, ef_construction=70, ef_search=50);

--echo create vector index without vector
--error 1235
create index idx_1 on t(c1);
