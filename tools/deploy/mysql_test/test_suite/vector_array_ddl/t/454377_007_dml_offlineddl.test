--echo =============convert to character=============
drop table if exists t;
create table t(c1 int primary key, c2 vector(3), c3 char(10), a1 int as (l2_distance(c2, '[1,1,1]'))) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than maxvalue);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],1);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],2);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],11);
alter table t convert to character set gbk;
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],12);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],21);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],22);
create vector index idx_1 on t(c2) with (distance=l2,type=hnsw);
insert into t partition(p0) values(3,[0.12121,2.2323,2],'a',default);
insert into t partition(p1) values(13,[0.12121,2.2323,2],'a',default);
insert into t partition(p2) values(23,[0.12121,2.2323,2],'a',default);
update t set c3='b' where c1=3;
update t set c3='c' where c1=13;
update t set c3='d' where c1=23;
delete from t where c1=3;
delete from t where c1=13;
delete from t where c1%2=1;
select a.c1,a.c2 from t as a inner join (select * from t where c1<10 order by l2_distance(c2, '[0.12121,0.1212,3]') approx limit 10) b on a.c1=b.c1;
--replace_regex /\(0x.*\)/()/g /__type_\d+_\d+()/__type_1_1()/g /__data_\d+_\d+()/__type_1_1()/g /__vid_\d+/__vid_1/g /\d+\s+\|$/0|/g
explain select a.c1,a.c2 from t as a inner join (select * from t where c1<10 order by l2_distance(c2, '[0.12121,0.1212,3]') approx limit 10) b on a.c1=b.c1;
alter table t drop partition p1;
alter table t truncate partition p0;

--echo =============partition by=============
drop table if exists t;
create table t(c1 int primary key, c2 vector(3), c3 char(10), a1 int as (l2_distance(c2, '[1,1,1]'))) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (20), partition p2 values less than maxvalue);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],1);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],2);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],11);
alter table t partition by hash(c1) partitions 5;
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],12);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],21);
insert into t(c3,c2,c1) values('a',[0.12121,2.2323,2],22);
create vector index idx_1 on t(c2) with (distance=l2,type=hnsw);
insert into t values(3,[0.12121,2.2323,2],'a',default);
insert into t values(13,[0.12121,2.2323,2],'a',default);
insert into t values(23,[0.12121,2.2323,2],'a',default);
update t set c3='b' where c1=3;
update t set c3='c' where c1=13;
update t set c3='d' where c1=23;
delete from t where c1=3;
delete from t where c1=13;
delete from t where c1%2=1;
select a.c1,a.c2 from t as a inner join (select * from t where c1<10 order by l2_distance(c2, '[0.12121,0.1212,3]') approx limit 10) b on a.c1=b.c1;
--replace_regex /\(0x.*\)/()/g /__type_\d+_\d+()/__type_1_1()/g /__data_\d+_\d+()/__type_1_1()/g /__vid_\d+/__vid_1/g /\d+\s+\|$/0|/g /\d+\s+\|$/0|/g
explain select a.c1,a.c2 from t as a inner join (select * from t where c1<10 order by l2_distance(c2, '[0.12121,0.1212,3]') approx limit 10) b on a.c1=b.c1;
