--echo add and drop generated column stored
drop table if exists t;
create table t(c1 vector(3), c2 int, vector index idx_1(c1) with (distance=l2, type=hnsw));
alter table t add column (a1 vector(3) generated always as (c1 + '[1,2,3]') virtual);
alter table t add column (a2 vector(3) generated always as (c1 + '[1,2,3]') virtual);
--error 1235
alter table t add column (a3 int generated always as (c2 + 2) stored); # ERROR 1235 (0A000): Run this DDL operation on table with fulltext/multivalue/vector index. not supported
--error 1235
alter table t add column (a4 int generated always as (c2 + 2) stored); # ERROR 1235 (0A000): Run this DDL operation on table with fulltext/multivalue/vector index. not supported

drop table if exists t;
create table t(c1 vector(3), c2 int, vector index idx_1(c1) with (distance=l2, type=hnsw));
