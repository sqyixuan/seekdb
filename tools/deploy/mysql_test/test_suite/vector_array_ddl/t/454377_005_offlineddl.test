--echo duplicate_cope table
--disable_warnings
drop table if exists t;
drop view if exists v;
drop materialized view if exists m;
--enable_warnings
create table t(c1 vector(3),c2 array(float),c3 int, primary key(c3), vector index idx_1(c1) with (distance=l2,type=hnsw)) duplicate_scope='cluster';
