--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings

--echo ==============================
--echo =  vector index offline ddl  =
--echo ==============================

alter system ob_vector_memory_limit_percentage=30;
select sleep(5);
--echo add before/after/first columns
create table t(c1 vector(3), c2 vector(3), c3 int, primary key (c3), vector index idx_1(c1) with (distance=l2, type=hnsw));
# fixed bug
alter table t add column a1 vector(3) first;
alter table t add column a2 vector(3) after c1;
alter table t add column a3 vector(3) before a2;
alter table t add column a4 json before c3;
show create table t;

drop table if exists t;
create table t(c1 vector(3), c2 vector(3), c3 int, primary key (c3), vector index idx_1(c1) with (distance=l2, type=hnsw));
insert into t values('[1,1,1]', '[2,2,2]',1);
select * from t order by l2_distance(c1, '[1,2,3]') approx limit 1;
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, '[1,2,3]') approx limit 1;
alter table t add column b1 vector(3) first;
alter table t add column b2 vector(3) after c1;
alter table t add column b3 vector(3) before b2;
alter table t add column b4 json before c3;
show create table t;

drop table if exists t;
create table t(c1 vector(3), c2 vector(3), c3 int, primary key (c3), vector index idx_1(c1) with (distance=l2, type=hnsw));
drop index idx_1 on t;
alter table t add column d1 vector(3) first;
alter table t add column d2 vector(3) after c1;
alter table t add column d3 vector(3) before d2;
alter table t add column d4 json before c3;
show create table t;
create vector index idx_1 on t(c1) with(distance=l2, type=hnsw);
insert into t values('[1,1,1]', '[2,2,2]', '[3,3,3]', '[4,4,4]', '[5,5,5]', '{}', 1);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, '[0,0,0]') approx limit 1;
select * from t order by l2_distance(c1, '[0,0,0]') approx limit 1;

drop table if exists t;
