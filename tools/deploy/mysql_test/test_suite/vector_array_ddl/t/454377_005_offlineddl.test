--error 1369
insert into v values('[1,1,1]',[20,20,20],5); # ERROR 1369 (HY000): CHECK OPTION failed
insert into t values('[1,1,1]',[20,20,20],5),('[1,1,1]',[25,25,25],6);
--error 1167
create materialized view m(c1, c2, c3, primary key(c1)) parallel 3 partition by range(c3) (partition p0 values less than (2), partition p1 values less than (6), partition p2 values less than (10)) refresh complete on demand as select * from t where l2_distance(c1, c2) >10;
create materialized view m(c1, c2, c3, primary key(c3)) parallel 3 partition by range(c3) (partition p0 values less than (2), partition p1 values less than (6), partition p2 values less than (10)) refresh complete on demand as select * from t where l2_distance(c1, c2) >10;
--error 1235
create vector index idx_2 on m(c1) with(distance=l2,type=hnsw); # ERROR 1235 (0A000): create vector index on view table is not supported
select * from (select t.c1 as a1, t.c2 as a2, t.c3 as a3, m.c1 as a4, m.c2 as a5, m.c3 as a6 from t join m order by l2_distance(t.c1, '[1,1,1]') limit 6) order by a3,a6;

