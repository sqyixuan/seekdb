create view v as select * from t order by l2_distance(c1, '[1,1,1]') approx limit 2;
--error 1471
insert into v values('[1,1,1]',[2,2,2],3); # ERROR 1471 (HY000): The target table v of the INSERT is not insertable-into
create or replace view v as select * from t where l2_distance(c1, c2) < 10 with local check option;
