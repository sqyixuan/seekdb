alter table t add column (a2 vector(3) generated always as (c1 + '[1,2,3]') virtual);
alter table t add column (a3 int generated always as (c2 + 2) stored);
alter table t add column (a4 int generated always as (c2 + 2) stored);
insert into t(c1, c2) values ('[1,2,4]', 3), ('[2,2,4]', 4);
create vector index idx_1 on t(c1) with (distance=l2,type=hnsw);
--replace_regex /range_key.*always true/123/g /\d+\s+\|$/0|/g
explain select * from t order by l2_distance(c1, '[0,0,0]') approx limit 3;
select * from t order by l2_distance(c1, '[0,0,0]') approx limit 3;
