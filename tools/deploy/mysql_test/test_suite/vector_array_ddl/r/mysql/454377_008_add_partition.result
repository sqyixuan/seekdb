drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 varchar(50), primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
partition by range(c1)
subpartition by list columns (c3)
(partition p0 values less than (10)
(subpartition p0m0 values in ('2024/12/01'),
subpartition p0m1 values in ('2024/12/02'),
subpartition p0m2 values in ('2024/12/03')
),
partition p1 values less than (100)
(subpartition p1m0 values in ('2024/12/01'),
subpartition p1m1 values in ('2024/12/02'),
subpartition p1m2 values in ('2024/12/03')
),
partition p2 values less than (200)
(subpartition p2m0 values in ('2024/12/01'),
subpartition p2m1 values in ('2024/12/02', '2024/12/03')
)
);
