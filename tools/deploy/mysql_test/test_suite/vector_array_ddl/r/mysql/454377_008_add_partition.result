"=========================================== range + range columns partition ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
partition by range(c1)
subpartition by range columns (c3)
(partition p0 values less than (10)
(subpartition p0m0 values less than ('2024/12/02'),
subpartition p0m1 values less than ('2024/12/03'),
subpartition p0m2 values less than ('2024/12/04')),
partition p1 values less than (100)
(subpartition p1m0 values less than ('2024/12/02'),
subpartition p1m1 values less than ('2024/12/03'),
subpartition p1m2 values less than ('2024/12/04')),
partition p2 values less than (200)
(subpartition p2m0 values less than ('2024/12/02'),
subpartition p2m1 values less than ('2024/12/04'))
);
