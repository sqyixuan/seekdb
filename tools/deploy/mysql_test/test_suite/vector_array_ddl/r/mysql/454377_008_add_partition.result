create table t1(a1 int primary key, a2 vector(3), vector index idx1(a2) with(distance=inner_product, type=hnsw))
partition by list(a1)
(partition p1 values in (1,2,3),
partition p2 values in (default));
insert into t1 values(7, '[2,2,2]');
select * from t1 partition(p2) join t partition(p4) on (t1.a1 + t.c1)%2=0 order by l2_distance(t.c2, '[1,1,1]') approx limit 2;
