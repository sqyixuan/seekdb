"=========================================== range columns + range columns template partition ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
partition by range columns(c3)
subpartition by range columns(c1)
subpartition template
(subpartition p0 values less than (10),
subpartition p1 values less than (100),
subpartition p2 values less than (200)
)
(partition p0 values less than ('2024/12/02'),
partition p1 values less than ('2024/12/03'),
partition p2 values less than ('2024/12/04')
);
