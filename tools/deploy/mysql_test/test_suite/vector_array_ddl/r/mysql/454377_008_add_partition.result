"=========================================== list columns + range columns partition ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 timestamp not null default current_timestamp, primary key(c1,c3), vector index idx1(c2) with (distance=l2, type=hnsw))
partition by list columns (c1)
subpartition by range columns (c3)
(partition p0 values in (1,2,3,4,5)
(subpartition p0p0 values less than ('2024/12/02'),
subpartition p0p1 values less than ('2024/12/03'),
subpartition p0p2 values less than ('2024/12/04')
),
partition p1 values in (11,12,13,14,15)
(subpartition p1p0 values less than ('2024/12/02'),
subpartition p1p1 values less than ('2024/12/03'),
subpartition p1p2 values less than ('2024/12/04')
),
partition p2 values in (101,102,103,104,105)
(subpartition p2p0 values less than ('2024/12/02'),
subpartition p2p1 values less than ('2024/12/03'),
subpartition p2p2 values less than ('2024/12/04')
)
);
