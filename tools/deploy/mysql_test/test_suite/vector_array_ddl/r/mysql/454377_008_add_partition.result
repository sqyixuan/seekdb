"=========================================== range columns partition ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 vector(4), c4 varchar(50) not null default ' ', c5 int, primary key(c1, c4, c5), vector index idx1(c2) with (distance=inner_product, type=hnsw))
partition by range columns(c1,c5)
(partition p0 values less than (100,10),
partition p1 values less than (1000,100),
partition p2 values less than (10000,1000)
);
