drop table if exists t;
create table t(c1 vector(3), c2 array(float), c3 int auto_increment, c4 timestamp, primary key(c3, c4), vector index idx_1(c1) with (distance=l2, type=hnsw)) partition by range(unix_timestamp(c4)) (partition p0 values less than (unix_timestamp('2010-01-01')), partition p1 values less than(unix_timestamp('2020-01-01')));
drop procedure if exists pl1;
create procedure pl1(ll int)
begin
set @x=1;
repeat
set @y=floor(2000 + rand() * 20);
set @m=floor(rand() * 12) + 1;
set @n=floor(rand() * 28) + 1;
set @a=floor(rand() * 100) + 1;
set @b=floor(rand() * 100) + 1;
set @c=floor(rand() * 100) + 1;
set @d=floor(rand() * 100) + 1;
set @e=floor(rand() * 100) + 1;
set @f=floor(rand() * 100) + 1;
insert into t values (concat('[',@a,',',@b,',',@c,']'), concat('[',@d,',',@e,',',@f,']'), default, concat(@y,'-', @m,'-', @n));
set @x=@x+1;
until @x>100 end repeat;
end //
