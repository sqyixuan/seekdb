Note	1051	Unknown table 'test.t'
create table t(c1 vector(3), c2 array(float), c3 int auto_increment, primary key(c3), vector index idx_1(c1) with (distance=l2, type=hnsw));
drop procedure if exists pl1;
create procedure pl1(ll int)
begin
set @x=1;
set @y=1;
repeat
insert into t values (concat('[',1,',',1,',',@x,']'), concat('[',1,',',1,',',@y,']'), default);
set @x=@x+1;
set @y=@y+1;
until @x>ll end repeat;
end //
