##VALIDATE_PASSWORD_STRENGTH-02-07,VALIDATE_PASSWORD_STRENGTH-02-07-01,VALIDATE_PASSWORD_STRENGTH-02-07-02
drop table t_validate_TEST;
CREATE TABLE t_validate_TEST SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123') + '1';
SELECT * FROM t_validate_TEST;
VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123') + '1'
101
drop table t_validate_TEST;
无参数的存储过程
drop procedure pl_test;//
create procedure pl_test()
begin  
declare a varchar(32) default '';
select VALIDATE_PASSWORD_STRENGTH(c_varchar) into a  from     t_validate_password1 t where t.c_tinyint =1;
SELECT a;
end;
//
call  pl_test();//
a
0
只有一个 in 参数的存储过程  :  ---begin 里面使用的变量必须在begin上面定义过。
drop procedure pl_test;//
create procedure pl_test(in numbb int)
begin
declare a varchar(32) default '';
select  VALIDATE_PASSWORD_STRENGTH(numbb) into a  from DUAL;
SELECT a;
end;
//
call   pl_test(100);//
a
0
function                  
无参数的自定义函数
drop function fun_test;//
create function fun_test()
returns INT
return VALIDATE_PASSWORD_STRENGTH('aabbcc!#@#@#45641351');
//
select  fun_test()  from  dual;//
fun_test()
50
无参数的自定义函数
drop function fun_test;//
create function fun_test(empname int)
returns INT
begin
declare a varchar(32) default '';
select   VALIDATE_PASSWORD_STRENGTH(c_varchar) into a  from   t_validate_password1     t where t.c_tinyint =1;
return (a + empname);   
end;
//
select  fun_test(100)  from dual;//
fun_test(100)
100
