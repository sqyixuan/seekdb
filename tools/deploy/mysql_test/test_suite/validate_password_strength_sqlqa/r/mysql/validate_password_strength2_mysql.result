purge recyclebin;
drop database IF EXISTS ucharsetmysql;
create database ucharsetmysql  character set utf8;
use ucharsetmysql;
##设置密码强度,基本功能测试 - MEDIUM - validate_password_mixed_case_count = 1 等3个。
set global validate_password_policy = MEDIUM;
set global validate_password_check_user_name = ON;
set global validate_password_mixed_case_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;
set global validate_password_length = 8;
##重启生效
use ucharsetmysql;
SHOW VARIABLES LIKE 'validate_password%';
Variable_name	Value
validate_password_check_user_name	on
validate_password_dictionary_file	
validate_password_length	8
validate_password_mixed_case_count	1
validate_password_number_count	1
validate_password_policy	medium
validate_password_special_char_count	1
SET NAMES 'utf8';
SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123');
VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123')
100
SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak!!!123');
VALIDATE_PASSWORD_STRENGTH('LESSweak!!!123')
100
SELECT VALIDATE_PASSWORD_STRENGTH('lessweak$_@123');
VALIDATE_PASSWORD_STRENGTH('lessweak$_@123')
50
SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak');
VALIDATE_PASSWORD_STRENGTH('LESSweak')
50
SELECT VALIDATE_PASSWORD_STRENGTH('ak!!!123');
VALIDATE_PASSWORD_STRENGTH('ak!!!123')
50
SELECT VALIDATE_PASSWORD_STRENGTH('Lk$_@123');
VALIDATE_PASSWORD_STRENGTH('Lk$_@123')
100
SELECT VALIDATE_PASSWORD_STRENGTH('lessweak');
VALIDATE_PASSWORD_STRENGTH('lessweak')
50
SELECT VALIDATE_PASSWORD_STRENGTH('12345678');
VALIDATE_PASSWORD_STRENGTH('12345678')
50
SELECT VALIDATE_PASSWORD_STRENGTH('LESSWEAK');
VALIDATE_PASSWORD_STRENGTH('LESSWEAK')
50
SELECT VALIDATE_PASSWORD_STRENGTH('$_@$_@$_@');
VALIDATE_PASSWORD_STRENGTH('$_@$_@$_@')
50
SELECT VALIDATE_PASSWORD_STRENGTH('lessweaK');
VALIDATE_PASSWORD_STRENGTH('lessweaK')
50
SELECT VALIDATE_PASSWORD_STRENGTH('lessweK2');
VALIDATE_PASSWORD_STRENGTH('lessweK2')
50
SELECT VALIDATE_PASSWORD_STRENGTH('lesswK2!');
VALIDATE_PASSWORD_STRENGTH('lesswK2!')
100
SELECT VALIDATE_PASSWORD_STRENGTH('lesswk2!');
VALIDATE_PASSWORD_STRENGTH('lesswk2!')
50
SELECT VALIDATE_PASSWORD_STRENGTH('KKKKKK2!');
VALIDATE_PASSWORD_STRENGTH('KKKKKK2!')
50
SELECT VALIDATE_PASSWORD_STRENGTH('lessweK!');
VALIDATE_PASSWORD_STRENGTH('lessweK!')
50
