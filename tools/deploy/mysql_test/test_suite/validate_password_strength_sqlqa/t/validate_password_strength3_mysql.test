--echo  ##VALIDATE_PASSWORD_STRENGTH-02-06,VALIDATE_PASSWORD_STRENGTH-02-06-02,VALIDATE_PASSWORD_STRENGTH-02-06-03,VALIDATE_PASSWORD_STRENGTH-02-06-04,VALIDATE_PASSWORD_STRENGTH-02-06-05

SELECT VALIDATE_PASSWORD_STRENGTH(c_double + 1) 
FROM t_validate_password1 
WHERE c_double > 0;

SELECT VALIDATE_PASSWORD_STRENGTH(c_double + 1) AND VALIDATE_PASSWORD_STRENGTH(c_double + 1)
FROM t_validate_password1 ;

SELECT VALIDATE_PASSWORD_STRENGTH(c_double + 1) && VALIDATE_PASSWORD_STRENGTH(c_double + 1)
FROM t_validate_password1 ;
SELECT NOT VALIDATE_PASSWORD_STRENGTH(c_double + 1)
FROM t_validate_password1 ;
SELECT VALIDATE_PASSWORD_STRENGTH(c_double + 1) FROM t_validate_password1 ;

SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123') || VALIDATE_PASSWORD_STRENGTH('LESS    weak$_@123');

SELECT !VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123');

SELECT NOT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123');

SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123') + '1';

SELECT VALIDATE_PASSWORD_STRENGTH(ASCII('Oceanbase'));

--echo  ##VALIDATE_PASSWORD_STRENGTH-02-07,VALIDATE_PASSWORD_STRENGTH-02-07-01,VALIDATE_PASSWORD_STRENGTH-02-07-02

--disable_warnings
--error 0,1051
drop table t_validate_TEST;
--enable_warnings

CREATE TABLE t_validate_TEST SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123') + '1';
SELECT * FROM t_validate_TEST;

--disable_warnings
--error 0,1051
drop table t_validate_TEST;
--enable_warnings


--echo   无参数的存储过程
DELIMITER //;
--error 0,1305
drop procedure pl_test;//
create procedure pl_test()
begin  
declare a varchar(32) default '';
select VALIDATE_PASSWORD_STRENGTH(c_varchar) into a  from     t_validate_password1 t where t.c_tinyint =1;
SELECT a;
end;
//

call  pl_test();//

--echo 只有一个 in 参数的存储过程  :  ---begin 里面使用的变量必须在begin上面定义过。
--error 0,1305
drop procedure pl_test;//
create procedure pl_test(in numbb int)
begin
declare a varchar(32) default '';
select  VALIDATE_PASSWORD_STRENGTH(numbb) into a  from DUAL;
SELECT a;
end;
//

call   pl_test(100);//


--echo     function                  
--echo   无参数的自定义函数
--error 0,1305
drop function fun_test;//
create function fun_test()
returns INT
return VALIDATE_PASSWORD_STRENGTH('aabbcc!#@#@#45641351');
//

select  fun_test()  from  dual;//

--echo   无参数的自定义函数
--error 0,1305
drop function fun_test;//
create function fun_test(empname int)
returns INT
begin
declare a varchar(32) default '';
select   VALIDATE_PASSWORD_STRENGTH(c_varchar) into a  from   t_validate_password1     t where t.c_tinyint =1;
return (a + empname);   
end;
//
select  fun_test(100)  from dual;//

DELIMITER ;//



--echo  ########清空回收站，删除测试租户用户、数据库，表等 ##########
#--source mysql_test/test_suite/validate_password_strength_sqlqa/include/drop_tenant_mysql.inc
purge recyclebin;
