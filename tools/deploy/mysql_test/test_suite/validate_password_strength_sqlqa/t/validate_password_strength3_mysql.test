#description: VALIDATE_PASSWORD_STRENGTH funciton
#author: wb-sl672505

purge recyclebin;
let $char_charset = 'UTF8';
#--source mysql_test/test_suite/validate_password_strength_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/validate_password_strength_sqlqa/include/conn_tenant_mysql.inc

--disable_warnings
drop database IF EXISTS ucharsetmysql;
--enable_warnings

create database ucharsetmysql  character set UTF8;
use ucharsetmysql;

--echo  ##设置密码强度,基本功能测试 - MEDIUM - validate_password_mixed_case_count = 1 等3个。
set global validate_password_policy = MEDIUM;
set global validate_password_check_user_name = ON;
set global validate_password_mixed_case_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;
set global validate_password_length = 8;

--echo  ##重启生效
--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_charset_test_user_mysql;
sleep 3;
connect(conn_charset_test_user_mysql,$OBMYSQL_MS0,ucharsetmysql,123,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;
use ucharsetmysql;

SHOW VARIABLES LIKE 'validate_password%';

SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123');
SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak!!!123');

