--disable_warnings
--error 0,1051
drop table t_validate_password1;
--enable_warnings

create table t_validate_password1(
	c_tinyint tinyint,
	c_smallint smallint,
	c_mediumint mediumint,
	c_int int,
	c_bigint bigint,
	c_float float,
	c_double double,
	c_decimal decimal,
	c_decimal_c decimal(8,2),
	c_date date,
	c_time time,
	c_year year,
	c_datetime datetime,
	c_timestamp timestamp,
	c_char char(200),
	c_varchar varchar(200),
	c_tinyblob tinyblob,
	c_tinytest tinytext,
	c_blob blob,
	c_text text,
	c_mediumblob mediumblob,
	c_mediumtext mediumtext,
	c_longblob longblob,
	c_longtext longtext
)DEFAULT CHARACTER SET = gbk;
