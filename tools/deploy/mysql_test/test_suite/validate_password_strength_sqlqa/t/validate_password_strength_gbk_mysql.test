select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >=NULL;
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) in (NULL);
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) not in (NULL);
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >=NULL and t.c_varchar <=NULL;
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >=NULL or t.c_varchar <=NULL;
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) like 'NULL%';
