#owner:sean.yyj
#owner group: SQL-SQL3
#tags: string_function
#description: VALIDATE_PASSWORD_STRENGTH funciton
#author: wb-sl672505

purge recyclebin;
let $char_charset = 'GBK';
#--source mysql_test/test_suite/validate_password_strength_sqlqa/include/create_tenant_by_charset_mysql.inc
--source mysql_test/test_suite/validate_password_strength_sqlqa/include/conn_tenant_mysql.inc

--disable_warnings
drop database IF EXISTS ucharsetmysql;
--enable_warnings

create database ucharsetmysql  character set GBK;
use ucharsetmysql;

--echo  ##设置密码强度,基本功能测试 - MEDIUM - validate_password_mixed_case_count = 1 等3个。
--echo  ##VALIDATE_PASSWORD_STRENGTH-02-03,VALIDATE_PASSWORD_STRENGTH-02-03-01
set global validate_password_policy = MEDIUM;
set global validate_password_check_user_name = ON;
set global validate_password_mixed_case_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;
set global validate_password_length = 8;

--echo  ##重启生效
--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_charset_test_user_mysql;
sleep 3;
connect(conn_charset_test_user_mysql,$OBMYSQL_MS0,ucharsetmysql,123,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;
use ucharsetmysql;

SHOW VARIABLES LIKE 'validate_password%';
SET NAMES 'GBK';

SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak$_@123');
SELECT VALIDATE_PASSWORD_STRENGTH('LESSweak!!!123');


SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 BINARY(255) ,c1 VARBINARY(5000) )DEFAULT CHARACTER SET = gbk;
insert into gbk_dml_002 values(' 字
龠 ',' 字
龠 ');

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;
select VALIDATE_PASSWORD_STRENGTH(c0) from gbk_dml_002;
###OB与MYSQL结果不一致
###select VALIDATE_PASSWORD_STRENGTH(c1) from gbk_dml_002;

###--character_set GBK
SET NAMES GBK;

select * from gbk_dml_002;
select VALIDATE_PASSWORD_STRENGTH(c0) from gbk_dml_002;
###OB与MYSQL结果不一致
###select VALIDATE_PASSWORD_STRENGTH(c1) from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings


--echo  ########gbk||time DML datatypes##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 TIME)DEFAULT CHARACTER SET = gbk;
insert into gbk_dml_002(c0) values (now());
insert into gbk_dml_002(c0) values (CURTIME());

###--character_set GBK
SET NAMES GBK;
select VALIDATE_PASSWORD_STRENGTH(c0) from gbk_dml_002;

###--character_set utf8mb4
SET NAMES utf8mb4;
select VALIDATE_PASSWORD_STRENGTH(c0) from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

-- disable_warnings
drop table  IF EXISTS  gbk_pl_varlen1;
drop procedure IF EXISTS  gbk_procedure1;
-- enable_warnings

create table gbk_pl_varlen1(c1 char(20) character set gbk,c2 varchar(20) character set gbk,c3 varchar(20) character set gbk,c4 TINYTEXT character set gbk,c5 decimal(20),c6 date)DEFAULT CHARACTER SET = gbk;
insert into gbk_pl_varlen1 values('哈1','哈1','哈1','哈1',1,'2020-05-21 01:01:01');
insert into gbk_pl_varlen1 values('哈2','哈2','哈2','哈2',0,'2020-05-21 01:01:01');
insert into gbk_pl_varlen1 values('哈3','哈3','哈3','哈3',25,'2020-05-21 01:01:01');
insert into gbk_pl_varlen1 values('哈4','哈4','哈4','哈4',50,'2020-05-21 01:01:01');
insert into gbk_pl_varlen1 values('哈5','哈5','哈5','哈5',75,'2020-05-21 01:01:01');
insert into gbk_pl_varlen1 values('哈6','哈6','哈6','哈6',100,'2020-05-21 01:01:01');
delimiter //; 
CREATE  PROCEDURE  gbk_procedure1(IN c5_id INT, OUT count_num varchar(20))  
         BEGIN  
             SELECT hex(c2) INTO  count_num  
             FROM  gbk_pl_varlen1
             WHERE  c5=c5_id;  
         END; //
delimiter ;//

set @p_out='ABCD';
call gbk_procedure1(1,@p_out);
select @p_out;

###--character_set utf8mb4
SET NAMES utf8mb4;
select * from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c1) from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c2) from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c3) from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c4) from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c5) from gbk_pl_varlen1;
select VALIDATE_PASSWORD_STRENGTH(c6) from gbk_pl_varlen1;

drop procedure IF EXISTS  gbk_procedure1;
drop table  IF EXISTS  gbk_pl_varlen1;


--disable_warnings
--error 0,1051
drop table t_validate_password1;
--enable_warnings

create table t_validate_password1(
	c_tinyint tinyint,
	c_smallint smallint,
	c_mediumint mediumint,
	c_int int,
	c_bigint bigint,
	c_float float,
	c_double double,
	c_decimal decimal,
	c_decimal_c decimal(8,2),
	c_date date,
	c_time time,
	c_year year,
	c_datetime datetime,
	c_timestamp timestamp,
	c_char char(200),
	c_varchar varchar(200),
	c_tinyblob tinyblob,
	c_tinytest tinytext,
	c_blob blob,
	c_text text,
	c_mediumblob mediumblob,
	c_mediumtext mediumtext,
	c_longblob longblob,
	c_longtext longtext
)DEFAULT CHARACTER SET = gbk;
