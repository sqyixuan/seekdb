###--echo  ##判断内容中文+null+空值+其他，方法相等，不等及其他包含关系；VALIDATE_PASSWORD_STRENGTH-02-04-05
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) ='中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) !='中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) <>'中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) <'中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >='中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) in ('中文测试1');
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) not in ('中文测试1');
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >='中文测试1' and t.c_varchar <='中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) >='中文测试1' or t.c_varchar <='中文测试1';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) like'中文测试%';
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) =NULL;
select t.c_varchar as 中文测试ing from t_validate_password1 T where VALIDATE_PASSWORD_STRENGTH(T.c_varchar) !=NULL;
