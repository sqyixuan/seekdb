DELETE FROM t_validate_password1 WHERE c_tinyint = VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c'));
DELETE FROM t_validate_password1 WHERE c_tinyint = VALIDATE_PASSWORD_STRENGTH(ROUND(0.12345678901234567890123456789012345, 35));
