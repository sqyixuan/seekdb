###select t1.* from t1, t2 where t1.c1 = t2.c1 and t2.c3 = '123';
SELECT T1.* FROM t_validate_password1 T1,t_validate_password2 T2 WHERE T1.c_tinyint = T2.c_tinyint AND VALIDATE_PASSWORD_STRENGTH(T2.c_varchar) = 0;
