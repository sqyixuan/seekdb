UPDATE t_validate_password1 SET c_mediumint = VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35));
UPDATE t_validate_password1 SET c_mediumint = VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c'));
UPDATE t_validate_password1 SET c_tinyint = VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c'));
UPDATE t_validate_password1 SET c_tinyint = VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35));

