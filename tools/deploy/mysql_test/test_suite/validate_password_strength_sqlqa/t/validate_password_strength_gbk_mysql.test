select VALIDATE_PASSWORD_STRENGTH(t_validate_password1.c_varchar) from t_validate_password1 where (c_int,c_decimal,c_decimal_c) > (1,1,1) order by c_int,c_decimal,c_decimal_c;

####group by having，VALIDATE_PASSWORD_STRENGTH-02-04-02
select a.c_varchar,VALIDATE_PASSWORD_STRENGTH(a.c_varchar) from t_validate_password1 a join t_validate_password2 b on a.c_int = b.c_int group by a.c_int,b.c_int having VALIDATE_PASSWORD_STRENGTH(a.c_varchar) >0;
select a.c_varchar,VALIDATE_PASSWORD_STRENGTH(a.c_varchar) from t_validate_password1 a join t_validate_password2 b on a.c_int = b.c_int group by a.c_int,b.c_int having VALIDATE_PASSWORD_STRENGTH(a.c_varchar) >20;

select VALIDATE_PASSWORD_STRENGTH(c_tinyint) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_tinyint) = VALIDATE_PASSWORD_STRENGTH(c_smallint);
select VALIDATE_PASSWORD_STRENGTH(c_smallint) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_tinyint) = c_smallint;
select VALIDATE_PASSWORD_STRENGTH(c_mediumint) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_mediumint) = c_mediumint;
select VALIDATE_PASSWORD_STRENGTH(c_int) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(HEX(_binary X'FEDC' ^ X'1111'));
select VALIDATE_PASSWORD_STRENGTH(c_bigint) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(RIGHT('foobarbar', 4));
select VALIDATE_PASSWORD_STRENGTH(c_float) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(COERCIBILITY(USER()));
select VALIDATE_PASSWORD_STRENGTH(c_double) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(USER());
select VALIDATE_PASSWORD_STRENGTH(c_decimal) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(TIMEDIFF('2000:01:01 00:00:00', '2000:01:01 00:00:00.000001'));
select VALIDATE_PASSWORD_STRENGTH(c_decimal_c) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_varchar) >= VALIDATE_PASSWORD_STRENGTH(FROM_UNIXTIME(1447430881));


select VALIDATE_PASSWORD_STRENGTH(c_tinyint) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_tinyint) <> c_char;
select VALIDATE_PASSWORD_STRENGTH(c_date) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_tinyint) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_time) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_time) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_year) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_datetime) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_timestamp) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_char) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_varchar) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_tinyblob) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_blob) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_tinytest) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_blob) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_blob) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_blob) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_text) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_blob) <> c_time;
select VALIDATE_PASSWORD_STRENGTH(c_mediumblob) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_mediumtext) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_longblob) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_tinyint;
select VALIDATE_PASSWORD_STRENGTH(c_longtext) from t_validate_password1 WHERE VALIDATE_PASSWORD_STRENGTH(c_datetime) <> c_time;

####FROM DUAL，VALIDATE_PASSWORD_STRENGTH-02-05，VALIDATE_PASSWORD_STRENGTH-02-05-01

SELECT VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(CEILING(1.23)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(INSTR('foobarbar', 'bar')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(COLLATION(_utf8mb4'abc')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(COERCIBILITY(USER())) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(REVERSE('abc')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(RIGHT('foobarbar', 4)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(SIGN(234)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(HEX(_binary X'FEDC' ^ X'1111')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(SQRT(-16)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(LOG10(-100)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(ROW_COUNT()) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(NULLIF(1,1)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(IFNULL(NULL,10)) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT_WS(',','First name','Second name','Last Name')) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(AES_DECRYPT('text',UNHEX('F3229A0B371ED2D9441B830D21A390C3'))) FROM DUAL;

SELECT VALIDATE_PASSWORD_STRENGTH('ΑΒΓΔΕΖΗΘΙΚ∧ΜΝΞΟ∏Ρ∑ΤΥΦΧΨΩ') FROM DUAL;


####DML，VALIDATE_PASSWORD_STRENGTH-02-05-02及之下所有。

insert into t_validate_password1(c_tinyint) values(VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35)));

SELECT LOG10(-100) FROM DUAL;
SELECT VALIDATE_PASSWORD_STRENGTH(LOG10(-100)) FROM DUAL;
###insert into t_validate_password1(c_smallint) values(VALIDATE_PASSWORD_STRENGTH(LOG10(-100)));

insert into t_validate_password1(c_smallint) values(VALIDATE_PASSWORD_STRENGTH(SQRT(-16)));
insert into t_validate_password1(c_smallint) values(VALIDATE_PASSWORD_STRENGTH(ROW_COUNT()));
insert into t_validate_password1(c_mediumint) values(VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c')));
insert into t_validate_password1(c_mediumint) values(VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(CEILING(1.23))));
insert into t_validate_password1(c_int) values(VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c'))));

UPDATE t_validate_password1 SET c_tinyint = VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35));
###UPDATE t_validate_password1 SET c_smallint = VALIDATE_PASSWORD_STRENGTH(LOG10(-100));
