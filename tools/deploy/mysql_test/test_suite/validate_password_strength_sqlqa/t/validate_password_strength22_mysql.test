--echo  ###全部数据类型

SELECT VALIDATE_PASSWORD_STRENGTH(111);
SELECT VALIDATE_PASSWORD_STRENGTH('abcde');
SELECT VALIDATE_PASSWORD_STRENGTH('0');
SELECT VALIDATE_PASSWORD_STRENGTH(0);
SELECT VALIDATE_PASSWORD_STRENGTH(NULL);
SELECT VALIDATE_PASSWORD_STRENGTH(true);
SELECT VALIDATE_PASSWORD_STRENGTH(FALSE);

SELECT VALIDATE_PASSWORD_STRENGTH('9223372036854775807');
SELECT VALIDATE_PASSWORD_STRENGTH(9223372036854775808);
SELECT VALIDATE_PASSWORD_STRENGTH(-9999);
SELECT VALIDATE_PASSWORD_STRENGTH(1.7976931348623157E+308);
SELECT VALIDATE_PASSWORD_STRENGTH(b'101');
SELECT VALIDATE_PASSWORD_STRENGTH('-838:59:59.000000');
SELECT VALIDATE_PASSWORD_STRENGTH('0000-00-00');
SELECT VALIDATE_PASSWORD_STRENGTH('9999-12-31');
--error 1054
SELECT VALIDATE_PASSWORD_STRENGTH(ABS(a + 1));
SELECT VALIDATE_PASSWORD_STRENGTH(1+'1');
SELECT VALIDATE_PASSWORD_STRENGTH(CAST(31.4 AS TIME));
SELECT VALIDATE_PASSWORD_STRENGTH('1.2E3');
SELECT VALIDATE_PASSWORD_STRENGTH(X'01AF');
SELECT VALIDATE_PASSWORD_STRENGTH(x'01af');
SELECT VALIDATE_PASSWORD_STRENGTH(0x01AF);

SELECT VALIDATE_PASSWORD_STRENGTH(CHARSET(0x5461626c65));
SELECT VALIDATE_PASSWORD_STRENGTH(X''+0);
SELECT VALIDATE_PASSWORD_STRENGTH(HEX('dog'));
SELECT VALIDATE_PASSWORD_STRENGTH(X'646F67');
SELECT VALIDATE_PASSWORD_STRENGTH('2012^12^31');
SELECT VALIDATE_PASSWORD_STRENGTH('00:00:00');
SELECT VALIDATE_PASSWORD_STRENGTH(b'11');
SELECT VALIDATE_PASSWORD_STRENGTH(B'11');
SELECT VALIDATE_PASSWORD_STRENGTH(0b11);

SELECT VALIDATE_PASSWORD_STRENGTH(b'1000001');
SELECT VALIDATE_PASSWORD_STRENGTH(CHARSET(b'1000001'));
SELECT VALIDATE_PASSWORD_STRENGTH(CAST(b'1100001' AS UNSIGNED));
SELECT VALIDATE_PASSWORD_STRENGTH(CAST(X'43' AS UNSIGNED));



