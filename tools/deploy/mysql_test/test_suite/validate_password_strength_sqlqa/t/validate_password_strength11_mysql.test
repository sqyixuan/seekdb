###MYSQL模式
SELECT VALIDATE_PASSWORD_STRENGTH('b' BETWEEN 'a' AND 'c');
SELECT VALIDATE_PASSWORD_STRENGTH(29 & 15);
SELECT VALIDATE_PASSWORD_STRENGTH(HEX(_binary X'FF' & b'11110000'));
SELECT VALIDATE_PASSWORD_STRENGTH(CASE 1 WHEN 1 THEN 'one'  WHEN 2 THEN 'two' ELSE 'more' END);
SELECT VALIDATE_PASSWORD_STRENGTH(CASE WHEN 1>0 THEN 'true' ELSE 'false' END);
SELECT VALIDATE_PASSWORD_STRENGTH(CASE BINARY 'B' WHEN 'a' THEN 1 WHEN 'b' THEN 2 END);
SELECT VALIDATE_PASSWORD_STRENGTH(TIMESTAMPADD(MINUTE,1,'2003-01-02'));
SELECT VALIDATE_PASSWORD_STRENGTH(CONVERT('abc' USING utf8mb4));
SELECT VALIDATE_PASSWORD_STRENGTH(COALESCE(NULL,1));
SELECT VALIDATE_PASSWORD_STRENGTH(COALESCE(NULL,NULL,NULL));
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT('My', 'S', 'QL'));
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT('', '', ''));
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT('My', NULL, 'QL'));
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT(14.3));
SELECT VALIDATE_PASSWORD_STRENGTH(CURRENT_USER());
SELECT VALIDATE_PASSWORD_STRENGTH(YEAR('1987-01-01'));
SELECT VALIDATE_PASSWORD_STRENGTH(3/5);
SELECT VALIDATE_PASSWORD_STRENGTH(102/(1-1));
SELECT VALIDATE_PASSWORD_STRENGTH(NULL = NULL);
SELECT VALIDATE_PASSWORD_STRENGTH(1 = 1);
SELECT VALIDATE_PASSWORD_STRENGTH(1 <=> 1);
SELECT VALIDATE_PASSWORD_STRENGTH(1 <=> NULL);
SELECT VALIDATE_PASSWORD_STRENGTH(2 >= 2);
SELECT VALIDATE_PASSWORD_STRENGTH(2 > 2);
SELECT VALIDATE_PASSWORD_STRENGTH(GREATEST(2,0));
SELECT VALIDATE_PASSWORD_STRENGTH(X'616263');
SELECT VALIDATE_PASSWORD_STRENGTH(HEX(255));
SELECT VALIDATE_PASSWORD_STRENGTH(CONV(HEX(255),16,10));
SELECT VALIDATE_PASSWORD_STRENGTH(INSERT('Quadratic', 3, 4, 'What'));
SELECT VALIDATE_PASSWORD_STRENGTH(0 IS FALSE);
SELECT VALIDATE_PASSWORD_STRENGTH(LENGTH('text'));
SELECT VALIDATE_PASSWORD_STRENGTH('David!' LIKE '%D%v%');
SELECT VALIDATE_PASSWORD_STRENGTH(LOWER('QUADRATICALLY'));
SET @str = BINARY 'New York';
SELECT VALIDATE_PASSWORD_STRENGTH(@str);
SELECT VALIDATE_PASSWORD_STRENGTH(253 % 7);
SELECT VALIDATE_PASSWORD_STRENGTH(TIME('2003-12-31 01:02:03'));
SELECT VALIDATE_PASSWORD_STRENGTH(LPAD('hi',4,'??'));
SELECT VALIDATE_PASSWORD_STRENGTH(18014398509481984*18014398509481984.0);
SELECT VALIDATE_PASSWORD_STRENGTH(FROM_UNIXTIME(1447430881));
SELECT VALIDATE_PASSWORD_STRENGTH(STRCMP('text', 'text2'));
SELECT VALIDATE_PASSWORD_STRENGTH(SUBSTRING('Quadratically',5));
SELECT VALIDATE_PASSWORD_STRENGTH(SUBSTRING_INDEX('www.mysql.com', '.', 2));
SELECT VALIDATE_PASSWORD_STRENGTH(TRIM('  bar   '));
SELECT VALIDATE_PASSWORD_STRENGTH(SPACE(6));
SELECT VALIDATE_PASSWORD_STRENGTH(CONV('a',16,2));
SELECT VALIDATE_PASSWORD_STRENGTH(USER());
SELECT VALIDATE_PASSWORD_STRENGTH(TIMEDIFF('2000:01:01 00:00:00', '2000:01:01 00:00:00.000001'));
SELECT VALIDATE_PASSWORD_STRENGTH(PERIOD_DIFF(200802,200703));
SELECT VALIDATE_PASSWORD_STRENGTH(TO_DAYS(950501));
SELECT VALIDATE_PASSWORD_STRENGTH(DATE_FORMAT('2009-10-04 22:23:00', '%W %M %Y'));
SELECT VALIDATE_PASSWORD_STRENGTH(ROUND(.12345678901234567890123456789012345, 35));
SELECT VALIDATE_PASSWORD_STRENGTH(CEILING(1.23));
SELECT VALIDATE_PASSWORD_STRENGTH(INSTR('foobarbar', 'bar'));
SELECT VALIDATE_PASSWORD_STRENGTH(COLLATION(_utf8mb4'abc'));
SELECT VALIDATE_PASSWORD_STRENGTH(COERCIBILITY(USER()));
SELECT VALIDATE_PASSWORD_STRENGTH(REVERSE('abc'));
SELECT VALIDATE_PASSWORD_STRENGTH(RIGHT('foobarbar', 4));
SELECT VALIDATE_PASSWORD_STRENGTH(SIGN(234));
SELECT VALIDATE_PASSWORD_STRENGTH(HEX(_binary X'FEDC' ^ X'1111'));
SELECT VALIDATE_PASSWORD_STRENGTH(SQRT(-16));
SELECT VALIDATE_PASSWORD_STRENGTH(LOG10(-100));
SELECT VALIDATE_PASSWORD_STRENGTH(ROW_COUNT());
SELECT VALIDATE_PASSWORD_STRENGTH(NULLIF(1,1));
SELECT VALIDATE_PASSWORD_STRENGTH(MAKE_SET(1,'a','b','c'));
SELECT VALIDATE_PASSWORD_STRENGTH(IFNULL(NULL,10));
SELECT VALIDATE_PASSWORD_STRENGTH(CONCAT_WS(',','First name','Second name','Last Name'));
SELECT VALIDATE_PASSWORD_STRENGTH(AES_DECRYPT('text',UNHEX('F3229A0B371ED2D9441B830D21A390C3')));

SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(253 % 7));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(TIME('2003-12-31 01:02:03')));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(LPAD('hi',4,'??')));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(18014398509481984*18014398509481984.0));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(FROM_UNIXTIME(1447430881)));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(STRCMP('text', 'text2')));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(SUBSTRING('Quadratically',5)));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(SUBSTRING_INDEX('www.mysql.com', '.', 2)));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(TRIM('  bar   ')));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(SPACE(6)));
SELECT VALIDATE_PASSWORD_STRENGTH(VALIDATE_PASSWORD_STRENGTH(CONV('a',16,2)));


