grant all on *.* to zhe123 WITH GRANT OPTION;
#cte-2-2 数据截断,递归部分为列生成比非递归部分更宽的值
set sql_mode = "";
WITH RECURSIVE cte AS
(
SELECT 1 AS n, 'abc' AS str
UNION ALL
SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;
n	str
1	abc
2	abc
3	abc
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
#CAST() 在非递归中使用SELECT以使str列变宽
WITH RECURSIVE cte AS
(
SELECT 1 AS n, cast('abc' as char(20))AS str
UNION ALL
SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;
n	str
1	abc
2	abcabc
3	abcabcabcabc
#数据较长时，层次查询
drop table  c;
create table c(id int PRIMARY KEY,ParentID int,name int);
drop procedure test1;
create procedure test1(in i INTEGER)
BEGIN
DECLARE  v_i INTEGER;
set v_i = 0;
while v_i <= i do
insert into c values(v_i+1,v_i,v_i+1000);
set v_i = v_i + 1;
end while;
END;
//
call test1(47);
