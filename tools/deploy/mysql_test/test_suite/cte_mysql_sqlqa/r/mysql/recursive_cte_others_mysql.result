#cte-2-3 限制CTE递归相关配置
set max_execution_time=1;
#error 0,1193
#mysql is 3024
with recursive r as
(
select id,ParentID,name from c where id =11
union all
select r.* from c,r where c.id=r.ParentID
) select * from r order by id;
set max_execution_time=1000;
#error 0,1193
#mysql is 3636
with recursive r as
(
select id,ParentID,name from c where id =11
union all
select r.* from c,r where c.id=r.ParentID
) select * from r order by id;
drop table rockets;
CREATE TABLE rockets
(origin CHAR(20), destination CHAR(20), trip_time INT);
INSERT INTO rockets VALUES 
('地球', '火星', 2),
('火星', '木星', 3),
('木星', '土星', 4);
WITH RECURSIVE all_destinations AS
(
SELECT destination AS planet
FROM rockets
WHERE origin='地球' 
UNION ALL
SELECT r.destination
FROM rockets r, all_destinations d
WHERE r.origin=d.planet
)
SELECT /*+ MAX_EXECUTION_TIME(100) */ * FROM all_destinations;
planet
