#cte-2-7 作为子查询返回值嵌套在sql中
select n from numbers;
n
6
SELECT * FROM rockets;
origin	destination	trip_time
地球	火星	2
火星	木星	3
木星	土星	4
#SELECT
SELECT * FROM rockets
WHERE origin=
(
WITH RECURSIVE descendants AS
(
SELECT origin, 1 as level
FROM rockets
WHERE origin='木星'
	UNION ALL
SELECT t.origin, d.level+1
FROM descendants d, rockets t
WHERE t.destination=d.origin
)
SELECT origin FROM descendants WHERE level=3 ORDER BY level
);
origin	destination	trip_time
地球	火星	2
#UPDATE
UPDATE rockets
SET destination=
(
WITH RECURSIVE descendants AS
(
SELECT origin, CAST(origin AS CHAR(500)) AS path
FROM rockets
WHERE origin='木星'
	UNION ALL
SELECT t.origin, CONCAT(d.path, ',', t.origin)
FROM descendants d, rockets t
WHERE t.destination=d.origin
)
SELECT path FROM descendants WHERE origin='地球' ORDER BY path
)
WHERE origin='地球';
UPDATE rockets
SET destination='木星,火星' WHERE origin=
(
WITH RECURSIVE descendants AS
(
SELECT origin, 1 as level
FROM rockets
WHERE origin='木星'
	UNION ALL
SELECT t.origin, d.level+1
FROM descendants d, rockets t
WHERE t.destination=d.origin
)
SELECT origin FROM descendants WHERE level=2 ORDER BY level
);
UPDATE rockets
SET trip_time=
(
WITH RECURSIVE fibonacci (n, fib_n, next_fib_n) AS
(
SELECT 1, 0, 1
UNION ALL
SELECT n + 1, next_fib_n, fib_n + next_fib_n
FROM fibonacci WHERE n < 10
)
SELECT MAX(next_fib_n) FROM fibonacci
)
WHERE trip_time=
(
WITH RECURSIVE my_cte(n) AS
(
SELECT 1
UNION ALL
SELECT 1+n FROM my_cte WHERE n<3
)
SELECT MAX(n) FROM my_cte
);
