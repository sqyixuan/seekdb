CREATE TABLE t3(C1 DECIMAL(5,2),C2 DECIMAL(5,2),C3 CHAR(1),C4 DECIMAL,C5 VARCHAR(1),C6 VARCHAR(1),C7 DECIMAL,C8 CHAR(1))partition by list(floor(c1))(PARTITION part9 VALUES in(1),PARTITION part10 VALUES in(2),PARTITION part11 VALUES in(3),PARTITION part12 VALUES in(4));
INSERT INTO t3 VALUES  (1, 5, 'e', 8, NULL, 't', NULL, NULL) ;
INSERT INTO t3 VALUES  (2, 3, 'x', 2, 'q', 'k', 0, NULL) ;
