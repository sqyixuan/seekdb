WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(part2) p WHERE e.deptno = p.deptno AND p.sal > (SELECT MIN(sal) FROM t5 WHERE job = 'SALESMAN') ORDER BY e.deptno),
