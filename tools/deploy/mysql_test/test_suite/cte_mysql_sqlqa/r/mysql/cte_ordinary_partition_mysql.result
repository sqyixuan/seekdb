#Environmental cleaning
drop user zhe123@'%';
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
set global parallel_servers_target = 100;
DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;
DROP TABLE t4;
DROP TABLE t5;
DROP TABLE t6;
CREATE TABLE t1(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t1 VALUES(1,'AccounTing','New York');
INSERT INTO t1 VALUES (2,'ReSeaRch','DallAs');
INSERT INTO t1 VALUES(3,'SaLeS','ChiCaGo');
INSERT INTO t1 VALUES(4,'OperaTions','BoSton');
CREATE TABLE t2(EMPNO DECIMAL(4) ,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR DECIMAL(4),HIREDATE DATE,SAL DECIMAL(7,2) UNIQUE,COMM DECIMAL(7,2),DEPTNO INT)
PARTITION BY RANGE(FLOOR(sal))(PARTITION part1 VALUES less than(1000),PARTITION part2 VALUES less than(2000),PARTITION part3 VALUES less than(3000),PARTITION part4 VALUES less than(4000),PARTITION part5 VALUES less than(5000));
