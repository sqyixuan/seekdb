drop table if exists t1,t2;
create table t1(a int primary key, b int, c int, index(b));
create table t2(a int primary key, b int, c int, index(b)) partition by hash(a) partitions 10;
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
select count(*) from (with recursive cte as (select * from t1 union all select cte.a+1, cte.b+1, cte.c+1 from cte, t2 where cte.a < 6) select * from cte) t;
count(*)
4880
drop table t1, t2;
drop table if exists t1,t2;
create table t1(a int);
create table t2(a int);
insert into t1 values (1),(2),(3),(4);
insert into t2 values (1),(2),(3),(4);
select count(*) from (with recursive cte as (select * from t1 union all select cte.a+1 from cte, t2 where cte.a < 6) select * from cte) t;
count(*)
1812
drop table t1, t2;
