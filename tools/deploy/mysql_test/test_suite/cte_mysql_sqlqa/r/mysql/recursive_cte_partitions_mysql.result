WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno from t2_view t
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno from t2_view t ,temp p where t.ename=p.ename and t.ename <>'ALLEN' and p.job =11001 and p.sal != ALL(select sal from t2_view where ename='MARTIN') and p.empno=7369
)select b.job,b.deptno,b.sal,a.empno,a.sal,a.job from  t2_view a left join  temp b on a.deptno=b.deptno and b.sal=800 order by ISNULL(b.job) ,1,2,3,4 limit 5;
