#Environmental cleaning
drop user zhe123@'%';
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
#cte-2-9 cte-2-10 查询对象覆盖分区、视图，索引，多表关联，结合条件谓词
DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;
DROP TABLE t4;
DROP TABLE t5;
DROP TABLE t6;
CREATE TABLE t1(DEPTNO DECIMAL(2) PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t1 VALUES(1,'AccounTing','New York');
INSERT INTO t1 VALUES (2,'ReSeaRch','DallAs');
INSERT INTO t1 VALUES(3,'SaLeS','ChiCaGo');
INSERT INTO t1 VALUES(4,'OperaTions','BoSton');
CREATE TABLE t2(
EMPNO DECIMAL(4) ,
ENAME VARCHAR(10) NOT NULL,
JOB INT,
MGR DECIMAL(4),
HIREDATE DATE,
SAL DECIMAL(7,2),
COMM DECIMAL(7,2),
DEPTNO DECIMAL(2)) 
PARTITION BY RANGE(FLOOR(SAL)) 
SUBPARTITION BY hash(JOB)(
PARTITION p1 VALUES less than(2500)
(
SUBPARTITION p1sub1,
SUBPARTITION p1sub2,
SUBPARTITION p1sub3
),
PARTITION p2 VALUES less than(5000)
(
SUBPARTITION p2sub1,
SUBPARTITION p2sub2,
SUBPARTITION p2sub3
)
);
