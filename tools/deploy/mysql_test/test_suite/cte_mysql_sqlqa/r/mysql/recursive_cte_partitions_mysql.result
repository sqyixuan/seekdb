WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno,t.HIREDATE from t2 PARTITION(p2sub3) t 
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno,t.HIREDATE from t2 PARTITION(p1sub1) t ,temp p where t.HIREDATE=p.HIREDATE and t.empno=7876
)select * from temp;
