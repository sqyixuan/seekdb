WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a inner join temp b where a.empno=b.empno 
)select * from temp c  right join t2 PARTITION(p1sub3) d on c.empno=d.empno;
