WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) as sum_sal from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,b.sum_sal from t2 PARTITION(p1sub1) a right join temp b on a.empno=b.empno where  b.ename in ('ALLEN','BLAKE')
)select * from temp c order by 1,2,3,4;
