select t.job,t.ename,t.deptno,t.sal,t.empno,t.HIREDATE,t.MGR from t2 PARTITION(p2sub1) t where t.empno=7698
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno,t.HIREDATE,t.MGR from t2 PARTITION(p1sub3) t ,temp p where t.empno=p.MGR 
)select * from temp;
