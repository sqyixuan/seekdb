WITH RECURSIVE temp AS (
select m.empno,m.ename,m.job,m.sal from  t2 PARTITION(p1) m where m.sal<1100.00
UNION ALL
select a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a,temp b where a.empno=b.empno and b.sal=1100.00
)select * from temp c  group by c.sal having sum(c.sal) >100;
