WITH
temp AS (SELECT e.deptno,e.dname,p.ename,p.job,p.sal FROM t1 e RIGHT JOIN t2 p ON e.deptno = p.deptno WHERE p.sal > (SELECT AVG(p.sal) FROM t1 e RIGHT JOIN t2 p ON e.deptno = p.deptno WHERE e.loc = 'New York' GROUP BY e.loc)ORDER BY e.deptno),
test1 AS (SELECT e.loc,SUM(p.sal)ssal FROM t4 e RIGHT JOIN t5 p ON e.deptno = p.deptno GROUP BY e.loc HAVING SUM(p.sal) < (SELECT MAX(p.sal) FROM temp p) ORDER BY 1,2)
SELECT e.deptno,e.ename,e.job,e.sal,p.dname,p.loc,c.ssal FROM temp e RIGHT JOIN t1 p ON e.deptno = p.deptno RIGHT JOIN test1 c ON p.loc = c.loc ORDER BY 1,2,3,4;
