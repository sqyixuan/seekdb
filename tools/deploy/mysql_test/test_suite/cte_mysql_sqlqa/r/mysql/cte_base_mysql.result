cte-1-1-6 cte定义列数与子查询中列数比较
WITH cte (col1) AS
(
SELECT 1, 2
UNION ALL
SELECT 3, 4
)
SELECT col1, col2 FROM cte;
WITH cte (col1,col2,col3) AS
(
SELECT 1, 2
UNION ALL
SELECT 3, 4
)
SELECT col1, col2,col3 FROM cte;
WITH cte AS
(
SELECT 1 AS col1, 2 AS col2
UNION ALL
SELECT 3, 4
)
SELECT col1, col2 FROM cte;
col1	col2
1	2
3	4
