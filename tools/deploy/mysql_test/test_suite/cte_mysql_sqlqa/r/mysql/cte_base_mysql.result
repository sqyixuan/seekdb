WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+ ordered use_nl(b) */a.* FROM (SELECT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,(SELECT c.deptno,c.c8,d.c6,d.c4,d.dname FROM test2 c,test3 d WHERE c.deptno = d.deptno)b WHERE a.deptno = b.deptno ORDER BY 1,2,3,4;
