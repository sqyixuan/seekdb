WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job  IN ('CLERK','ANALYST') ORDER BY p.deptno)
update temp1 p set p.job='DOCTOR'  WHERE e.deptno = p.deptno ;
