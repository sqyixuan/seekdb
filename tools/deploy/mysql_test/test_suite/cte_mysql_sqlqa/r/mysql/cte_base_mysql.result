cte-1-4 在INSERT,REPLACE,CREATE,DECLARE,EXPLAIN之后，在SELECT语句之前
insert into t1 
WITH cte(col1, col2,col3) AS
(
SELECT 5 , 'Finance' ,'Los Angeles'
  UNION ALL
SELECT 6, 'Personnel','Seattle'
)
SELECT col1, col2 ,col3 FROM cte;
REPLACE into t1 
WITH cte(col1, col2,col3) AS
(
SELECT 5 , 'Finance' ,'Atlanta'
  UNION ALL
SELECT 6, 'Personnel','Seattle'
)
SELECT col1, col2 ,col3 FROM cte;
DROP TABLE t1_1;
CREATE TABLE  t1_1
WITH cte(col1, col2,col3) AS
(
SELECT 5 ,cast('Finance'as char(50)) ,'Atlanta'
  UNION ALL
SELECT 6, 'Personnel','Seattle'
)
SELECT col1, col2 ,col3 FROM cte;
DROP VIEW t1_v;
CREATE VIEW  t1_v as
WITH cte(col1, col2,col3) AS
(
SELECT 5 , 'Finance' ,'Atlanta'
  UNION ALL
SELECT 6, 'Personnel','Seattle'
)
SELECT col1, col2 ,col3 FROM cte;
DECLARE CURSOR ...
EXPLAIN ...
EXPLAIN
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job  IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno FROM temp e,temp1 p WHERE e.deptno = p.deptno and e.deptno=1;
