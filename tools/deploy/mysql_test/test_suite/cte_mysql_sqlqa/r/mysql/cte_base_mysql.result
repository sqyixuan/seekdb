WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT MAX(sal) FROM t5 WHERE job = 'SALESMAN') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal = (SELECT MIN(sal) FROM temp WHERE job IN ('MANAGER','ANALYST') ) ORDER BY e.deptno),
test2 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal <> (SELECT AVG(sal) FROM test1 WHERE job = 'MANAGER') ORDER BY e.deptno)
SELECT e.deptno,p.loc,p.ename,c.job,c.sal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ORDER BY 1,2,3,4;
deptno	loc	ename	job	sal
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT MAX(sal) FROM t5 WHERE job = 'SALESMAN') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal = (SELECT MIN(sal) FROM temp WHERE job IN ('MANAGER','ANALYST') ) ORDER BY e.deptno),
test2 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal <> (SELECT AVG(sal) FROM test1 WHERE job = 'MANAGER') ORDER BY e.deptno)
SELECT /*+no_rewrite*/e.deptno,p.loc,p.ename,c.job,c.sal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ORDER BY 1,2,3,4;
deptno	loc	ename	job	sal
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal > ANY (SELECT MAX(p.sal) FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('SALESMAN','MANAGER') GROUP BY p.job)ORDER BY p.deptno),
test1 AS (SELECT AVG(e.sal)vsal,p.loc FROM temp e,t4 p WHERE e.loc = p.loc AND e.sal = ANY(SELECT MIN(e.sal) FROM temp e,t5 p WHERE e.deptno = p.deptno AND e.job != 'PRESIDENT' GROUP BY e.job) GROUP BY p.loc ORDER BY p.loc),
test2 AS (SELECT e.deptno,e.ename,e.job,p.vsal,p.loc FROM temp e,test1 p WHERE e.loc = p.loc AND p.vsal > ANY(SELECT AVG(p.sal) FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('SALESMAN','MANAGER') GROUP BY p.job ) )
SELECT e.deptno,e.sal,p.vsal,c.job,c.ename,d.dname FROM temp e,test1 p,t1 d,test2 c WHERE e.loc = p.loc AND p.loc = d.loc AND d.deptno = c.deptno ORDER BY 1,2,3,4,5;
