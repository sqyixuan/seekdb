temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno),
temp2 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e left join temp1 p on e.deptno = p.deptno left join temp2 q on e.deptno=q.deptno ORDER BY 1,2,3;
