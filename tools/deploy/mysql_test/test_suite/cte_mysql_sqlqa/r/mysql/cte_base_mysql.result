WITH 
temp AS (SELECT e.loc,MAX(p.sal)xsal FROM t1 e INNER JOIN t2 p ON e.deptno = p.deptno GROUP BY e.loc ORDER BY e.loc),
test1 AS (SELECT e.c1,AVG(p.sal)gsal FROM t3 e LEFT JOIN t2 p ON e.c1 = p.deptno GROUP BY e.c1 ORDER BY e.c1),
test2 AS (SELECT e.deptno,e.loc,MIN(p.sal)msal FROM t4 e RIGHT JOIN t5 p ON e.deptno = p.deptno GROUP BY e.deptno,e.loc ORDER BY 1,2)
SELECT c.deptno,c.msal,e.loc,e.xsal,p.gsal FROM temp e,test1 p,test2 c WHERE e.loc = c.loc AND c.deptno = p.c1 ORDER BY 1,2,3,4;
