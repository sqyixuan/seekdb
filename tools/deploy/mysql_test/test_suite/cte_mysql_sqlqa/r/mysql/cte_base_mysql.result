test1 AS (SELECT p.deptno,e.ename,e.job,p.sal,p.comm FROM temp e LEFT JOIN  t5 p ON e.deptno = p.deptno WHERE p.sal > 1500 ORDER BY p.deptno),
test2 AS (SELECT e.deptno,e.dname,p.job FROM t4 e LEFT JOIN test1 p ON e.deptno = p.deptno WHERE p.deptno IN (2,3) ORDER BY p.deptno )
