WITH 
temp AS (SELECT e.deptno,e.ename,e.mgr,p.sal,p.job FROM t2 e,t2 p WHERE e.mgr = p.empno AND e.ename IN ('ALLEN','MARTIN','ADAMS','BLAKE','WARD') ORDER BY e.deptno),
test1 AS (SELECT e.mgr,SUM(e.sal) FROM t5 e,t5 p WHERE e.mgr = p.empno GROUP BY e.mgr ORDER BY e.mgr)
SELECT * FROM temp e,test1 p WHERE e.mgr = p.mgr ORDER BY 1,2,3,4;
deptno	ename	mgr	sal	job	mgr	SUM(e.sal)
