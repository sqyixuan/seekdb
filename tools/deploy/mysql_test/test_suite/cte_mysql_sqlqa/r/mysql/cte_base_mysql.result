  1 - output([e.DEPTNO]), filter([e.LOC IN ('New York', 'ChiCaGo')]), rowset=16
      access([e.DEPTNO], [e.LOC]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([e.DEPTNO]), range[1 ; 1], 
      range_cond([e.DEPTNO = cast(1, DECIMAL_INT(2, 0))])
