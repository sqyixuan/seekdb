WITH
temp AS (SELECT e.loc,MAX(p.sal)msal FROM t1 e,t2 p WHERE e.deptno = p.deptno GROUP BY e.loc ORDER BY 1,2),
test1 AS (SELECT e.loc,AVG(p.sal)asal FROM t4 e,t5 p WHERE e.deptno = p.deptno GROUP BY e.loc ORDER BY 1,2)
SELECT e.loc,e.msal,p.asal FROM temp e,test1 p WHERE e.loc = p.loc AND e.msal > p.asal ORDER BY 1,2,3;
