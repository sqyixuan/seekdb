WITH 
temp AS (SELECT * FROM t1 e NATURAL JOIN t2 p WHERE p.ename IS NULL OR p.sal < 5000 OR e.dname IN ('ReSeaRch','ReSeaRch','SaLeS') ORDER BY 1,2,3,4),
test1 AS (SELECT * FROM t3 e NATURAL JOIN t6 p WHERE NOT EXISTS (SELECT * FROM temp e WHERE e.dname = 'AccounTing' AND e.sal > 5000) ORDER BY 1,2,3,4)
SELECT * FROM temp e NATURAL JOIN test1 p WHERE e.sal > (SELECT AVG(c.sal) FROM temp c WHERE c.dname = 'ReSeaRch' GROUP BY c.deptno ) ORDER BY 1,2,3,4;
