WITH
temp(dept,sal) AS (SELECT e.deptno,AVG(e.sal) FROM t2 e GROUP BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e ,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT e.sal FROM temp e WHERE e.dept IN (SELECT p.c1 FROM temp e,t3 p WHERE e.dept = p.c1 AND p.c1  = (SELECT e.deptno FROM t4 e,temp p WHERE e.deptno = p.dept AND e.loc = 'ChiCaGo' AND p.sal < (SELECT MAX(e.sal) FROM temp e WHERE dept = 1))))),
test2 AS (SELECT e.deptno,e.ename,e.job,p.sal FROM t2 e,temp p WHERE e.deptno = p.dept AND p.sal > (SELECT MIN(e.sal) FROM temp e,t5 p WHERE e.dept = p.deptno  GROUP BY p.deptno HAVING MIN(e.sal) > 2000) )
SELECT e.deptno,e.loc,e.job,p.ename,p.sal,c.sal FROM test1 e,test2 p,temp c WHERE e.deptno = c.dept AND c.dept = p.deptno  ORDER BY 1,2,3,4;
