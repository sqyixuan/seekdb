INSERT INTO t4 SELECT * FROM t1 LIMIT 3;
CREATE TABLE t5(EMPNO INT UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMERIC(4),HIREDATE DATE,SAL NUMERIC(7,2),COMM NUMERIC(7,2),DEPTNO INT)PARTITION BY HASH(FLOOR(EMPNO))(PARTITION part6,PARTITION part7,PARTITION part8);
INSERT INTO t5 SELECT * FROM(SELECT * FROM t2 ORDER BY empno) as a order by 1,2,3,6 LIMIT 6 ;
CREATE TABLE t6(C1 NUMERIC(5,2),C2 NUMERIC(5,2),C3 CHAR(1),C4 NUMERIC,C5 VARCHAR(1),C6 VARCHAR(1),C7 NUMERIC,C8 CHAR(1));
CREATE UNIQUE INDEX index_3 ON t6(c6);
CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM (SELECT * FROM t3 WHERE c3 IN ('w','e','y','x','i','h') ORDER BY 1,2,3,4)a;
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE p.job NOT IN ('MANAGER','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;
