test1 AS (SELECT * FROM (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno ORDER BY 1)bb UNION SELECT * FROM (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t4 e,t5 p WHERE e.deptno = p.deptno ORDER BY 1)m),
test2 AS (SELECT loc,SUM(sal)ssal FROM (SELECT * FROM temp UNION SELECT * FROM test1)cc GROUP BY loc ORDER BY 1)
SELECT e.deptno,e.loc,p.ename,p.job,p.sal,c.ssal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.loc = c.loc ORDER BY 1,2,3,4;
