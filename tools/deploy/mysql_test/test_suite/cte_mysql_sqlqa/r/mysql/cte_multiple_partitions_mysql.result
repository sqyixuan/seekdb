WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 PARTITION(p1sub1) GROUP BY deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,AVG(e.sal)asal FROM t2 PARTITION(p1sub1) e,temp p WHERE e.deptno = p.dept GROUP BY e.deptno,p.msal HAVING AVG(e.sal) > p.msal),
test2 AS (SELECT e.deptno,MAX(e.sal)msal FROM t2 PARTITION(p1sub1) e,test1 p WHERE e.deptno = p.deptno GROUP BY e.deptno,p.asal HAVING MAX(e.sal) > p.asal)
SELECT /*+ parallel(5)*/e.* FROM (SELECT * FROM test2  UNION SELECT * FROM test1 UNION SELECT * FROM temp ORDER BY 1,2)e;
deptno	msal
3	1500.000000
WITH 
temp AS (SELECT job FROM t2 PARTITION(p1sub1) GROUP BY job),
test1 AS (SELECT job,COUNT(empno)cont FROM (SELECT p.job,e.empno,e.sal FROM t2 PARTITION(p1sub1) e,temp p WHERE e.job = p.job 
UNION ALL SELECT p.job,e.empno,e.sal FROM t2 PARTITION(p1sub2) e,temp p WHERE e.job = p.job
UNION ALL SELECT p.job,e.empno,e.sal FROM t2 PARTITION(p2sub1) e,temp p WHERE e.job = p.job)aa GROUP BY job HAVING MIN(sal) < 1500),
test2 AS (SELECT e.deptno,AVG(e.sal)vsal FROM t2 PARTITION(p1sub1) e GROUP BY e.deptno)
SELECT e.ename,p.cont,p.job,c.vsal FROM test1 p,test2 c,t2 PARTITION(p1sub1) e WHERE e.job = p.job AND c.deptno = e.deptno ORDER BY 1,2,3,4;
