UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id) 
)
