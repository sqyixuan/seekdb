#Environmental cleaning
drop user zhe123@'%';
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
#数据准备
DROP TABLE t_2;
CREATE TABLE
t_2 ( cat_id int PRIMARY KEY ,
name varchar(10) ,
parent_cid DECIMAL(5),
cat_level DECIMAL(5) ,
product_count DECIMAL(5))
PARTITION BY RANGE(cat_id)
(PARTITION p0 VALUES LESS THAN(20),
PARTITION p1 VALUES LESS THAN(40),
PARTITION p2 VALUES LESS THAN(60),
PARTITION p3 VALUES LESS THAN(80),
PARTITION p4 VALUES LESS THAN(maxvalue));
