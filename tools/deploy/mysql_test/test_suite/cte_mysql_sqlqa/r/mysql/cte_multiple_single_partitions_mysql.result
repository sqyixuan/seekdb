WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 PARTITION(part2) GROUP BY deptno),
test1 AS (SELECT p.loc,e.dept FROM temp e,t1 PARTITION(part0) p WHERE e.dept = p.deptno AND e.msal 
< ANY(SELECT p.sal FROM temp e,t5 p WHERE e.dept = p.deptno AND e.msal 
< ANY(SELECT * FROM (SELECT e.msal FROM t3 PARTITION(part10) p,temp e WHERE e.dept = p.c1 
UNION ALL SELECT e.msal FROM t3 PARTITION(part11)p,temp e WHERE e.dept = p.c1)k))),
test2 AS (SELECT e.msal,e.dept,(SELECT * FROM (SELECT AVG(e.sal)vsal FROM t5 e,temp p GROUP BY e.deptno,p.msal HAVING MAX(e.sal) > p.msal order by 1)k  LIMIT  1)vsal FROM temp e WHERE e.msal 
= (SELECT MAX(msal) FROM temp e GROUP BY e.msal HAVING e.msal = (SELECT msal FROM temp e WHERE msal = 1300))),
test3 AS (SELECT e.msal,e.dept,(SELECT * FROM (SELECT AVG(e.sal)vsal FROM t5 e,temp p GROUP BY e.deptno,p.msal HAVING MAX(e.sal) > p.msal)k)vsal FROM temp e)
SELECT c.dept,c.msal,e.loc,p.vsal FROM test1 e,test2 p,temp c WHERE e.dept = c.dept AND c.dept = p.dept ORDER BY 1,2,3,4;
