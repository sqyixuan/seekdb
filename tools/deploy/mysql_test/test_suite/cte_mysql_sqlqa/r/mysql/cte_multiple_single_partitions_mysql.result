WITH
temp AS
(
SELECT * FROM (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part2) p WHERE e.deptno = p.deptno
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part1) e,t2 PARTITION(part3) p WHERE e.deptno = p.deptno)k
WHERE sal > (SELECT MIN(sal) FROM t5 WHERE job = 'SALESMAN') ORDER BY deptno),
test1 AS 
(
SELECT * FROM (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part2) p WHERE e.deptno = p.deptno 
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part1) e,t2 PARTITION(part4) p WHERE e.deptno = p.deptno
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part1) e,t2 PARTITION(part3) p WHERE e.deptno = p.deptno
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part2) p WHERE e.deptno = p.deptno
) k
WHERE sal = (SELECT MIN(sal) FROM temp WHERE job IN ('CLERK','SALESMAN') ) ORDER BY deptno),
test2  AS 
(
SELECT * FROM (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part1) e,t2 PARTITION(part3) p WHERE e.deptno = p.deptno
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part1) p WHERE e.deptno = p.deptno
UNION
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part3) p WHERE e.deptno = p.deptno
)k
WHERE sal <> (SELECT AVG(sal) FROM test1 WHERE job = 'CLERK') ORDER BY deptno)
SELECT e.deptno,p.loc,p.ename,c.job,c.sal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ORDER BY 1,2,3,4;
