test1 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(part2) e WHERE e.sal = ANY (SELECT p.sal FROM temp p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
