WITH 
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,c.c6,c.c7 FROM t1 PARTITION(part0) e FULL JOIN t2 PARTITION(part2) p ON e.deptno = p.deptno FULL JOIN t3 PARTITION(part10) c ON p.deptno = c.c1 WHERE c.c7 IS NOT NULL AND p.sal < 1500 AND e.loc IN ('New York','DallAs')  ORDER BY c.c1,p.deptno,e.deptno),
test1 AS (SELECT temp.deptno,SUM(t1.sal)sal FROM (SELECT e.deptno,e.dname,p.sal,p.comm FROM t1 PARTITION(part1) e FULL JOIN t5 p ON e.deptno = p.deptno WHERE e.loc != 'New York' AND p.ename <> 'JONES' ORDER BY 1,2)t1  FULL JOIN temp ON t1.deptno = temp.deptno WHERE EXISTS (SELECT * FROM temp c WHERE c.c6 = 's' AND c.ename = 'KING') GROUP BY temp.deptno ORDER BY temp.deptno)
SELECT p.ename,p.loc,p.job,p.c6,p.c7,e.deptno,e.sal FROM test1 e FULL JOIN temp p ON e.deptno = p.deptno ORDER BY e.deptno,e.sal,3,5;
