WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t2 PARTITION(part2) p WHERE e.deptno = p.deptno AND EXISTS (SELECT * FROM t3 PARTITION(part11) c,t1 PARTITION(part1) d WHERE c.c1 = d.deptno AND c.c4 = 2 AND c.c5 IS NOT NULL) AND p.sal BETWEEN 1000 AND 2000 ORDER BY p.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 PARTITION(part0) e,t5 p WHERE e.deptno = p.deptno AND NOT EXISTS (SELECT * FROM t3 PARTITION(part10) e,t6 p WHERE e.c1 = p.c1 AND e.c5 IS NULL AND p.c1 > 5) AND p.sal < 1500 ORDER BY p.deptno )
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;
deptno	loc	ename	job	sal
