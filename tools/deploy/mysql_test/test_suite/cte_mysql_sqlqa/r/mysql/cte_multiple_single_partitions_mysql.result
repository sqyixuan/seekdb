CREATE TABLE t4(DEPTNO int,DNAME VARCHAR(14),LOC VARCHAR(13))PARTITION BY LIST columns(loc)(PARTITION pat5 VALUES in('New York'),PARTITION pat6 VALUES in('DallAs'),PARTITION pat7 VALUES in('ChiCaGo'));
INSERT INTO t4 SELECT * FROM t1 LIMIT 3;
CREATE TABLE t5(EMPNO INT UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR INT,HIREDATE DATE,SAL DECIMAL(7,2),COMM DECIMAL(7,2),DEPTNO int)PARTITION BY HASH(EMPNO)(PARTITION part6,PARTITION part7,PARTITION part8);
INSERT INTO t5 SELECT * FROM(SELECT * FROM t2 )a ORDER BY 1,2,3,4,5,6 LIMIT 6 ;
CREATE TABLE
t6(C1 INT ,
C2 DECIMAL(5,2),
C3 CHAR(1),
C4 DECIMAL,
C5 VARCHAR(1),
C6 VARCHAR(1),
C7 DECIMAL,
C8 CHAR(1))PARTITION BY LIST COLUMNS (C6)(
PARTITION pat2 VALUES in('t','k','u','z'),
PARTITION pat3 VALUES in('p','x','v','q'),
PARTITION pat4 VALUES in('l','s','f','w'));
CREATE UNIQUE INDEX index_3 ON t6(c6);
CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM t3 ORDER BY 1,2,3,4,5,6  LIMIT 6;
WITH 
temp AS (SELECT * FROM (SELECT e.deptno,e.loc FROM t1 PARTITION(part0) e WHERE e.loc IN ('New York','ChiCaGo') 
UNION ALL 
SELECT e.deptno,e.loc FROM t1 PARTITION(part1) e WHERE e.loc IN ('New York','ChiCaGo'))k
ORDER BY deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(part2) p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;
