WITH
temp AS (
SELECT e.deptno,e.loc,p.ename,p.job FROM t1 PARTITION(part0) e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000
UNION ALL 
SELECT e.deptno,e.loc,p.ename,p.job FROM t1 PARTITION(part1) e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000
ORDER BY 1,2,3,4),
test1 AS (
SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 PARTITION(part2) e,t2 PARTITION(part3) p,t1 PARTITION(part0) c WHERE e.mgr = p.empno AND p.deptno = c.deptno 
UNION ALL 
SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 PARTITION(part1) e,t2 PARTITION(part4) p,t1 PARTITION(part0) c WHERE e.mgr = p.empno AND p.deptno = c.deptno
AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (
SELECT * FROM (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 PARTITION(part10) e,temp p WHERE e.c1 = p.deptno 
UNION ALL 
SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 PARTITION(part11) e,temp p WHERE e.c1 = p.deptno
UNION ALL 
SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 PARTITION(part12) e,temp p WHERE e.c1 = p.deptno)k
WHERE c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (
SELECT p.deptno,e.c6,e.c4,p.dname FROM t3 PARTITION(part11) e,test1 p WHERE e.c1 = p.deptno AND c7 IS NOT NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4)
UNION ALL
SELECT p.deptno,e.c6,e.c4,p.dname FROM t3 PARTITION(part10) e,test1 p WHERE e.c1 = p.deptno AND c7 IS NOT NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) 
ORDER BY 1,2,3,4)
SELECT /*+ ordered use_nl(d),parallel(a,4),parallel(b,4),parallel(c,1) */ * FROM (SELECT a.deptno,a.loc,a.empno,a.mgr,b.c8,b.c7 FROM (SELECT DISTINCT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,test2 b WHERE a.deptno = b.deptno)c,test3 d WHERE c.deptno = d.deptno ORDER BY 1,2,3,4;
