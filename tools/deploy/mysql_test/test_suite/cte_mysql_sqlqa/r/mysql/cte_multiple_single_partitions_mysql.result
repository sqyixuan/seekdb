test1 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(part2) e WHERE e.sal = SOME (SELECT p.sal FROM temp p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test2 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(part2) e WHERE e.sal < SOME (SELECT p.sal FROM test1 p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test3 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(part2) e WHERE e.sal != SOME (SELECT p.sal FROM test2  p WHERE job = 'SALESMAN') ORDER BY e.deptno )
SELECT /*+ parallel(5) */e.deptno,p.ename,c.job,d.sal FROM  temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;
