CREATE TABLE t3(
C1 INT,
C2 DECIMAL(5,2),
C3 CHAR(1),
C4 DECIMAL,
C5 VARCHAR(1),
C6 VARCHAR(1),
C7 int,
C8 CHAR(1))
PARTITION BY list columns(c1)
(
PARTITION part9 VALUES in(1),
PARTITION part10 VALUES in(2),
PARTITION part11 VALUES in(3),
PARTITION part12 VALUES in(4)
);
