WITH 
temp AS
(
SELECT DISTINCT p.deptno,e.ename,SUM(e.sal+d.sal)OVER(PARTITION BY p.deptno ORDER BY f.c6)sal FROM (SELECT e.deptno,e.dname,e.loc,p.empno,p.ename,p.job,p.sal FROM t1 e INNER JOIN t2 PARTITION(p1sub1)p ON e.deptno = p.deptno 
UNION ALL SELECT e.deptno,e.dname,e.loc,p.empno,p.ename,p.job,p.sal FROM t1_view e INNER JOIN t2 PARTITION(p2)p ON e.deptno = p.deptno)e 
RIGHT JOIN t1_view p ON e.deptno = p.deptno  LEFT JOIN t2_view d ON p.deptno = d.deptno INNER JOIN t3 f ON d.deptno = f.c1
WHERE f.c6 IN (SELECT p.c6 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL AND (e.c7 = 0 OR p.c7 = 8 OR e.c7 = 2) AND p.c5 IS NOT NULL AND e.c8 <> 'f') 
AND d.comm > (SELECT p.comm FROM t4 e,t5 p WHERE e.deptno = p.deptno AND e.loc = 'DallAs' AND p.sal < 1000)
),
test1 AS
(
SELECT DISTINCT p.deptno,e.ename,AVG((p.sal+c.ssal+d.sal)/2)OVER(PARTITION BY p.deptno ORDER BY d.c6)vsal
FROM t1_view e,t2_view p,t4_view c,t5_view d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno 
AND d.c6 IN (SELECT p.c6 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL AND (e.c7 = 0 OR p.c7 = 8 OR e.c7 = 2) AND p.c5 IS NOT NULL AND e.c8 <> 'f') 
AND (p.sal+c.ssal+d.sal)*100 > ALL (SELECT sal FROM temp WHERE deptno =2 )
),
test2 AS 
(
SELECT DISTINCT e.deptno,p.ename,STDDEV((p.sal+d.sal+c.sal)) OVER(PARTITION BY e.deptno )stsal FROM t1 e,t2 PARTITION(p2) p,t5_view d,t6_view c,t3 q 
WHERE e.deptno = p.deptno AND p.deptno = d.deptno AND d.deptno = c.deptno AND c.deptno = q.c1
AND d.c6 IN (SELECT p.c6 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL AND (e.c7 = 0 OR p.c7 = 8 OR e.c7 = 2) AND p.c5 IS NOT NULL AND e.c8 <> 'f') 
AND q.c6 IN (SELECT p.c6 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL AND (e.c7 = 0 OR p.c7 = 8 OR e.c7 = 2) AND p.c5 IS NOT NULL AND e.c8 <> 'f')
AND q.c8 IS NOT NULL  AND p.sal + d.sal + c.sal < ALL(SELECT e.sal- p.vsal FROM temp e,test1 p WHERE e.deptno = p.deptno AND e.deptno = 2 AND p.deptno = 2)
)
SELECT e.deptno,e.sal,p.ename,p.vsal,c.stsal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.ename = c.ename ORDER BY 1,2,3,4,5;
