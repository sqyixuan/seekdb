AND  e.sal < (SELECT DISTINCT sal FROM t6_view e,t1_view p WHERE e.deptno = p.deptno  AND dname NOT IN ('ReSeaRch','AccounTing') AND empno = (SELECT mgr FROM t6_view WHERE ename = 'WARD' AND sal > 1000))
