INSERT INTO t2 VALUES(7900,'JAMES',11001,7698,str_to_date('3-12-1981','%d-%m-%Y'),950,-1808,3);
INSERT INTO t2 VALUES(7902,'FORD',21083,7566,str_to_date('3-12-1981','%d-%m-%Y'),3001,753.9,2);
INSERT INTO t2 VALUES(7934,'MILLER',11001,7782,str_to_date('23-1-1982','%d-%m-%Y'),1300,729,1);
CREATE TABLE t3(C1 DECIMAL(5,2),C2 DECIMAL(5,2),C3 CHAR(1),C4 DECIMAL,C5 VARCHAR(1),C6 VARCHAR(1),C7 DECIMAL,C8 CHAR(1))PARTITION BY RANGE(FLOOR(c1))SUBPARTITION BY HASH(FLOOR(c2))(PARTITION part10 VALUES LESS THAN(2)(SUBPARTITION p1sub3,SUBPARTITION p1sub4),
PARTITION part11 VALUES LESS THAN(5)(SUBPARTITION p1sub5,SUBPARTITION p1sub6));
INSERT INTO t3 VALUES  (1, 5, 'e', 8, NULL, 't', NULL, NULL) ;
INSERT INTO t3 VALUES  (2, 3, 'x', 2, 'q', 'k', 0, NULL) ;
INSERT INTO t3 VALUES  (2, 4, 'o', 5, 'w', 'u', 8,'n') ;
INSERT INTO t3 VALUES  (3, 4, 'h', 2, 'y', 'z', NULL, NULL) ;
INSERT INTO t3 VALUES  (4, 6, 'j', 2, 'h', 'p', 1,NULL) ;
INSERT INTO t3 VALUES  (4, 4, 'i', 2, 'd', 'x', 0,'f') ;
INSERT INTO t3 VALUES  (3, 9, 'e', 0, 'r', 'v', 6, 'd') ;
INSERT INTO t3 VALUES  (2, 9, 'y', 7, 'h', 'q', 2,'v') ;
INSERT INTO t3 VALUES  (1, 2, 'w', 1, 'c', 'l', 7,'o') ;
INSERT INTO t3 VALUES  (1, 9, 'y', 1, NULL, 's', 5, NULL) ;
INSERT INTO t3 VALUES  (2, 6, 'h', 7, NULL, 'f', 8, NULL) ;
INSERT INTO t3 VALUES  (4, 5, 'i', 2, NULL, 'w', NULL,'x') ;
CREATE TABLE t4(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t4 SELECT * FROM t1 LIMIT 3;
CREATE TABLE t5(EMPNO DECIMAL(4) ,ENAME VARCHAR(10) NOT NULL,JOB INT,MGR DECIMAL(4),HIREDATE DATE,SAL DECIMAL(7,2),COMM DECIMAL(7,2),DEPTNO INT)PARTITION BY HASH(FLOOR(DEPTNO))(PARTITION part6,PARTITION part7,PARTITION part8);
INSERT INTO t5 SELECT * FROM(SELECT * FROM t2 ORDER BY empno)a order by 1,2,3,4,5,6 LIMIT 6 ;
CREATE TABLE t6(C1 DECIMAL(5,2),C2 DECIMAL(5,2),C3 CHAR(1),C4 DECIMAL,C5 VARCHAR(1),C6 VARCHAR(1),C7 DECIMAL,C8 CHAR(1));
CREATE UNIQUE INDEX index_3 ON t6(c6);
CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM (SELECT * FROM t3 WHERE c3 IN ('w','e','y','x','i','h') ORDER BY 1,2,3,4)a;
CREATE OR REPLACE VIEW t1_view AS SELECT e.deptno,e.dname,e.loc,p.ename,p.job FROM t1 e LEFT JOIN t5 p ON e.deptno = p.deptno ORDER BY 1,2,3;
CREATE OR REPLACE VIEW t2_view AS SELECT * FROM(SELECT * FROM t2 e WHERE e.sal < 4000 UNION ALL SELECT * FROM t5 p WHERE p.sal BETWEEN 1500 AND 3000 ORDER BY 1,2,3,4)a;
CREATE OR REPLACE VIEW t3_view AS SELECT DISTINCT e.c1,e.c2,e.c3,e.c4,p.c5,p.c6,p.c7,p.c8 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL ORDER BY 1,2,3,4;
CREATE OR REPLACE VIEW t4_view AS SELECT e.deptno,SUM(p.sal)ssal FROM t4 e,t2 p WHERE e.deptno = p.deptno GROUP BY e.deptno ORDER BY e.deptno;
CREATE OR REPLACE VIEW t5_view AS SELECT e.deptno,p.sal,c.c6,d.dname,v.job FROM t1 e LEFT JOIN t2 p ON e.deptno = p.deptno INNER JOIN t3 c ON p.deptno = c.c1 RIGHT JOIN t4 d ON c.c1 = d.deptno LEFT JOIN t5 v ON d.deptno = v.deptno;
CREATE OR REPLACE VIEW t6_view AS SELECT * FROM t2 e WHERE EXISTS (SELECT p.sal FROM t5 p WHERE p.ename = 'ALLEN');
CREATE OR REPLACE VIEW t7_view AS SELECT * FROM t5 e WHERE NOT EXISTS (SELECT * FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.deptno = 4);
WITH 
temp AS (
SELECT DISTINCT e.deptno,p.ename,c.dname,d.c6,d.cot,f.sal,q.mgr FROM t1 e INNER JOIN t2 p ON e.deptno = p.deptno 
INNER JOIN (SELECT e.dname,e.deptno,p.ename FROM t1_view e,t2_view p WHERE e.deptno = p.deptno AND p.sal BETWEEN 1000 AND 2000 
AND e.dname IN (SELECT dname FROM (SELECT dname,COUNT(job) FROM t5_view WHERE sal BETWEEN 1000 AND 2000 AND job IS NOT NULL GROUP BY dname HAVING COUNT(*) >= 8 ORDER BY 1,2)k) ) c ON p.deptno = c.deptno 
INNER JOIN (SELECT e.c6,p.c1,COUNT(p.c8)cot FROM t3_view e RIGHT JOIN t3 p ON e.c1 = p.c1 GROUP BY e.c6,p.c1  ORDER BY 1,2)d ON c.deptno = d.c1 
INNER JOIN (SELECT e.deptno,(p.sal+e.ssal)sal,p.job FROM t4_view e LEFT JOIN t5 p ON e.deptno = p.deptno WHERE p.deptno IS NOT NULL AND p.comm + p.sal > 0 )f ON d.c1 = f.deptno
INNER JOIN (SELECT e.deptno,e.ename,e.mgr FROM t5 e WHERE empno = (SELECT mgr FROM (SELECT mgr,COUNT(*) FROM t5 
WHERE ename IN (SELECT ename FROM t2 WHERE sal BETWEEN 1500 AND 3000) GROUP BY mgr HAVING COUNT(*) <2  ORDER BY 1,2 )k))q ON  f.deptno = q.deptno
WHERE p.sal < (SELECT DISTINCT sal FROM t6_view e,t1_view p WHERE e.deptno = p.deptno  AND dname NOT IN ('ReSeaRch','AccounTing') AND empno = (SELECT mgr FROM t6_view WHERE ename = 'WARD' AND sal > 1000))
AND f.sal > (SELECT SUM(p.sal + (SELECT sal FROM (SELECT SUM(e.sal)sal,p.dname FROM t5 e,t4 p WHERE e.deptno = p.deptno GROUP BY p.dname HAVING SUM(e.sal) > 5000)k)
+CASE (SELECT DISTINCT e.sal FROM t5_view e,t1 p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND e.sal BETWEEN 1000 AND 2000) WHEN 1100 THEN 1100+200 ELSE 2000 END)/3.3 FROM t1 e,t2 p WHERE e.deptno = p.deptno
GROUP BY e.dname HAVING SUM(p.sal + (SELECT sal FROM (SELECT SUM(e.sal)sal,p.dname FROM t5 e,t4 p WHERE e.deptno = p.deptno GROUP BY p.dname HAVING SUM(e.sal) > 5000)k)
+CASE (SELECT DISTINCT e.sal FROM t5_view e,t1 p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND e.sal BETWEEN 1000 AND 2000) WHEN 1100 THEN 1100+200 ELSE 2000 END) < 50000) 
AND EXISTS (SELECT e.dname,SUM(p.sal+c.sal) FROM t1 e,t2 p,t5 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno GROUP BY e.dname HAVING SUM(p.sal+c.sal) > (SELECT SUM(ssal) FROM t4_view WHERE deptno <>1))
ORDER BY 1,2,3,4
),
test1 AS (
SELECT DISTINCT e.deptno,e.sal,p.c6,c.ssal,d.mgr,f.c7,q.ename FROM t2_view e,t3_view p,t4_view c,t6_view d,t6 f,t7_view q WHERE e.deptno = p.c1 AND p.c1 = c.deptno AND c.deptno = d.deptno AND d.deptno = f.c1 AND f.c1 = q.deptno
AND EXISTS (SELECT e.dname,SUM(p.sal+c.sal) FROM t1 e,t2 p,t5 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno GROUP BY e.dname HAVING SUM(p.sal+c.sal) > (SELECT SUM(ssal) FROM t4_view WHERE deptno <>1))
AND  e.sal < (SELECT DISTINCT sal FROM t6_view e,t1_view p WHERE e.deptno = p.deptno  AND dname NOT IN ('ReSeaRch','AccounTing') AND empno = (SELECT mgr FROM t6_view WHERE ename = 'WARD' AND sal > 1000))
AND c.ssal < ALL(SELECT sal FROM temp ) AND p.c6 IN (SELECT DISTINCT c6 FROM temp) AND d.empno != (SELECT DISTINCT mgr FROM temp)  
AND NOT EXISTS (SELECT * FROM t1 e,t2 p,t3 q WHERE e.deptno = p.deptno AND p.deptno = q.c1 
AND p.sal < (SELECT sal FROM temp WHERE mgr = (SELECT MAX(p.empno) FROM t1 e,t2 p WHERE e.deptno = p.deptno AND e.dname 
NOT IN (SELECT DISTINCT dname FROM temp WHERE c6 = (SELECT c6 FROM t3_view WHERE c5 = 'r' AND c8 = 'd')
AND sal = ALL(SELECT AVG(sal) FROM temp GROUP BY ename))))
AND p.ename NOT IN (SELECT ename FROM temp WHERE c6 = (SELECT c6 FROM t3_view WHERE c5 = 'r' AND c8 = 'd')) AND sal > 4000 AND comm IS NOT NULL) 
AND f.c7 > ALL(SELECT cot FROM temp) AND e.sal >ALL(SELECT * FROM (SELECT sal FROM t1 e,t5 p WHERE e.deptno = p.deptno ORDER BY 1)k where k.sal <1600) ORDER BY 1,2,3,4
)
SELECT e.ename,COUNT(*) FROM test1 e INNER JOIN temp p ON e.deptno = p.deptno GROUP BY e.ename ORDER BY 1,2;
ename	COUNT(*)
ALLEN	80
BLAKE	80
MARTIN	80
WARD	80
