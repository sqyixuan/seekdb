2	SMITH	k	1
2	SMITH	q	1
WITH 
temp  AS 
(
SELECT e.deptno,p.ename,d.job,c.sal,f.ssal  FROM t1 e INNER JOIN t2 p ON e.deptno = p.deptno INNER JOIN t1_view d ON e.deptno = d.deptno 
INNER JOIN t2_view c ON e.deptno = c.deptno INNER JOIN t4_view f ON e.deptno = f.deptno WHERE  c.comm IS NOT NULL  AND p.sal BETWEEN 1000 AND 3000 AND c.comm > 0  AND p.job IN (11001,21083)
)
,
test1 AS 
(
SELECT COUNT(*)cot,((e.ssal+e.sal+p.sal)-(SELECT MAX(ssal) FROM t4_view))sal,p.deptno
FROM temp e INNER JOIN (SELECT e.deptno,p.ename,d.job,f.empno,f.sal  FROM t4 e LEFT JOIN t5 p ON e.deptno = p.deptno RIGHT JOIN t5_view d ON e.deptno = d.deptno 
INNER JOIN (SELECT e.deptno,p.empno,e.ename,p.sal FROM t6_view e INNER JOIN t7_view p ON e.mgr = p.empno)f ON e.deptno = f.deptno)p ON e.deptno = p.deptno
WHERE e.sal  >= (SELECT sal FROM (SELECT COUNT(*),sal FROM temp WHERE job = (SELECT e.job FROM t1_view e,t2 PARTITION(p2) p WHERE e.deptno = p.deptno AND e.job IS NOT NULL AND p.comm IS NOT NULL AND p.job = 17520 
AND e.ename =  'SMITH' AND e.dname = 'ReSeaRch' AND p.deptno IN (SELECT deptno FROM temp)) GROUP BY sal HAVING COUNT(*) > 3)k)
AND p.job = (SELECT job FROM (SELECT COUNT(*),p.job FROM t3_view e,t2 p WHERE e.c1 = p.deptno AND e.c5 IS NOT NULL AND e.c6 = 'q' GROUP BY p.job HAVING COUNT(*) < 5)k )
GROUP BY e.ssal,e.sal,p.sal,p.deptno 
),
test2 AS 
(
SELECT (SELECT MAX(sal) FROM test1)msal,(SELECT ssal FROM temp WHERE job IS NULL)ssal,e.dname,e.loc,e.ename,p.cot,p.sal,e.deptno FROM 
(SELECT e.deptno,e.dname,e.loc,p.ename,p.sal FROM t1 e INNER JOIN temp p ON e.deptno = p.deptno )e 
INNER JOIN (SELECT e.deptno,e.dname,e.loc,p.cot,p.sal FROM t1 e,test1 p WHERE e.deptno = p.deptno)p  ON e.deptno = p.deptno
WHERE p.cot > ALL(SELECT COUNT(*)cot FROM test1 e,temp p,t7_view c WHERE e.deptno = p.deptno AND e.deptno = c.deptno GROUP BY p.sal)
AND p.sal > (SELECT AVG(sal+comm) FROM t1 e, t2 PARTITION(p2sub3)p WHERE e.deptno = p.deptno )
AND e.ename IN (SELECT ename FROM (SELECT COUNT(c.ssal),p.ename FROM t1_view e,t2_view p,temp c,test1 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno AND e.loc = 'DallAs' 
AND p.sal BETWEEN 2000 AND 3000  AND d.cot > 500 GROUP BY p.ename HAVING COUNT(*) < 90)k) AND p.cot != 480 
AND (SELECT MAX(sal) FROM test1) + (SELECT MIN(ssal) FROM t4_view ) - (SELECT ssal FROM temp WHERE job IS NULL) > (SELECT AVG(p.sal+p.comm) FROM t1 e,t2 PARTITION(p2)p WHERE e.deptno = p.deptno) 
)             
SELECT DISTINCT e.deptno,e.ename,e.ssal,p.cot,p.sal,c.msal,c.ssal,c.dname FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ORDER BY 1,2,3,4,5,6;
