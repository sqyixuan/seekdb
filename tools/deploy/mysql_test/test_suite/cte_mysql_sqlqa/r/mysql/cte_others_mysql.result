WITH 
temp AS 
(
SELECT f.ename,AVG(p.sal+f.sal+(SELECT ssal FROM t4_view WHERE deptno = 2))sal FROM t1 e,t2 p,t3 c,t4 d,t5 f,t6 q WHERE e.deptno = p.deptno AND p.job = f.job AND f.deptno = c.c1 AND c.c1 = d.deptno AND d.deptno = q.c1
GROUP BY f.ename ORDER BY 1,2
), 
test1 AS 
(
SELECT e.deptno,p.ename,d.c6,f.ssal FROM t1 e,t2 PARTITION(p1) p,t3 d,t4_view f WHERE e.deptno = p.deptno AND p.deptno = d.c1 AND d.c1 = f.deptno AND d.c7 IS NOT NULL AND p.ename IN (SELECT ename FROM temp)
AND f.ssal + p.sal >(SELECT MIN(sal)/4 FROM temp WHERE ename IN 
(SELECT p.ename FROM t1 e INNER JOIN t2 PARTITION(p1sub3) p ON e.deptno = p.deptno 
WHERE ename IN (SELECT p.ename FROM temp e,t1_view p WHERE e.ename = p.ename AND p.job IN (SELECT DISTINCT job FROM t5_view 
WHERE sal < ALL(SELECT sal FROM (SELECT AVG(e.sal-p.ssal-d.sal)sal,d.ename FROM temp e,t4_view p,t5 d WHERE e.ename = d.ename AND d.deptno = p.deptno  GROUP BY d.ename )k)))))
),
test2 AS 
(
SELECT deptno,AVG(sal) FROM (
SELECT e.loc,p.sal,d.c7,f.deptno FROM t1_view e,t2_view p,t3_view d,t4_view f WHERE e.deptno = p.deptno AND p.deptno = d.c1 AND d.c1 = f.deptno AND d.c7 IS NOT NULL  AND p.ename IN (SELECT ename FROM temp)
