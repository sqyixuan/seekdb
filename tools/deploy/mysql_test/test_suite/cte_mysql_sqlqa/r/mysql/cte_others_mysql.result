WITH
temp AS 
(
SELECT e.deptno,e.loc,p.ename,p.sal,c.sal AS csal,c.job FROM t1 e INNER JOIN t2 PARTITION(p1) p ON e.deptno = p.deptno INNER JOIN 
(SELECT p.deptno,e.loc,p.ename,p.sal,p.job FROM t4 e,t5 p WHERE e.deptno = p.deptno )c ON p.deptno = c.deptno ORDER BY 1,2
),
test1 AS 
(
SELECT COUNT(e.c1+e.c2)cot,c.dname  FROM t3 e INNER JOIN t3_view p ON e.c1 = p.c1 INNER JOIN (SELECT p.c1,e.dname,e.sal,p.c6,p.c7 FROM t5_view e,t6 p WHERE e.deptno = p.c1) c ON p.c1 = c.c1 
WHERE p.c8 IS NOT NULL AND c.sal > (SELECT MAX(sal) FROM temp WHERE csal > (SELECT MIN(csal) FROM temp WHERE job = (SELECT job FROM t5_view WHERE c6 = 'q' 
AND sal = (SELECT msal FROM (SELECT deptno,MIN(sal)msal FROM temp GROUP BY deptno HAVING MIN(sal) <= 
(SELECT MIN(sal) FROM (SELECT MIN(sal)sal,p.dname FROM t6_view e,t1 p WHERE e.deptno = p.deptno GROUP BY p.dname HAVING MIN(sal) < 1000 )k))k) 
AND job = (SELECT job FROM (SELECT COUNT(*),p.job FROM t1_view e,t5_view p WHERE e.deptno = p.deptno GROUP BY p.job HAVING COUNT(*) < 100 AND COUNT(*) > 50)k ))) )
GROUP BY  c.dname HAVING COUNT(e.c1 + e.c2) < 1000 ORDER BY 1,2
),
test2 AS 
(
SELECT e.deptno,e.dname,p.c6,p.c7,c.ssal,d.ename,d.job,d.sal FROM t1_view e,t3 p,t4_view c,t7_view d WHERE e.deptno = p.c1 AND p.c1 = c.deptno AND c.deptno = d.deptno 
AND e.loc IN (SELECT loc FROM (SELECT loc,COUNT(*) FROM temp WHERE sal > 1000 AND csal < 3000 GROUP BY loc HAVING COUNT(*) < ALL(SELECT cot FROM test1))k)
AND e.dname IN (SELECT dname FROM test1) AND d.sal BETWEEN (SELECT AVG(sal) FROM (SELECT AVG(sal)sal,ename FROM temp GROUP BY ename)k) AND (SELECT MAX(csal) FROM (SELECT AVG(csal)csal,ename FROM temp GROUP BY ename)k)
AND p.c6 = (SELECT c6 FROM (SELECT SUM(p.sal),p.c6 FROM t1 e,t5_view p WHERE e.deptno = p.deptno AND p.job IS NOT NULL AND e.loc IN (SELECT loc FROM temp) 
AND e.dname = (SELECT dname FROM test1 WHERE cot  = (SELECT MIN(cot) FROM test1 )) GROUP BY p.c6 HAVING SUM(p.sal) > (SELECT SUM(ssal) FROM t4_view WHERE deptno IN(2,3)) ORDER BY 1,2 )k LIMIT 1)
)
SELECT DISTINCT e.ename,e.sal,e.csal,e.job,p.cot,c.dname,c.ssal,c.c6,d.scot,
(
WITH 
temp AS 
(
SELECT SUM(p.sal+c.c1+c.c2+d.deptno)scot,p.job FROM t1 e, t2 p,t3 c,t5 d WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = d.deptno  
AND  c.c7 IS NOT NULL AND e.dname <> 'SaLeS' GROUP BY p.job HAVING SUM(p.sal+c.c1+c.c2+d.deptno) > 15000 ORDER BY 1,2
),
test1 AS 
(
SELECT SUM(e.c1+e.c2+p.ssal+c.sal+d.deptno)sacot,c.job FROM t3_view e,t4_view p,t6_view c,t7_view d WHERE e.c1 = p.deptno  AND p.deptno = c.deptno AND c.deptno = d.deptno 
AND p.ssal + c.sal + d.sal + c.comm + d.comm > (SELECT MIN(scot) FROM temp ) 
AND e.c6 IN (SELECT e.c6 FROM t3 e,t2 p WHERE e.c1 = p.deptno AND p.job IN (SELECT job FROM temp) AND e.c7 IS NOT NULL) GROUP BY c.job
)
SELECT MIN(scot) FROM (SELECT SUM(sacot+scot)scot FROM test1 e,temp p WHERE e.job = p.job GROUP BY e.job)k
)sacot
FROM temp e,test1 p,test2 c,
(
WITH 
temp AS 
(
SELECT e.deptno,p.job,p.sal,p.ename,c.sal AS csal,e.dname FROM t1 e,t2 PARTITION(p1)p,t2_view c WHERE e.deptno = p.deptno AND p.deptno = c.deptno
)
,
test1 AS 
(
SELECT DISTINCT p.deptno,
AVG(e.sal+e.csal+p.sal) OVER(ORDER BY e.sal+e.csal+p.sal RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)sal_unbound_avg,
SUM(e.sal+e.csal+p.sal) OVER(ORDER BY e.sal+e.csal+p.sal ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) rows_unbound_avg
FROM temp e INNER JOIN t2 p ON e.deptno = p.deptno WHERE p.job IN (SELECT DISTINCT job FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.sal BETWEEN 2000 AND 3000)
),
test2 AS 
(
SELECT e.job, 
COUNT(e.sal+e.csal+p.sal) OVER(ORDER BY e.deptno  RANGE BETWEEN 1 PRECEDING AND 2 FOLLOWING) range_count,
SUM(e.sal+e.csal+p.sal) OVER(ORDER BY e.deptno ROWS BETWEEN 1 PRECEDING AND 2 FOLLOWING) rows_count
FROM temp e,t2_view p WHERE p.sal BETWEEN 1500 AND 3000 
AND p.job = (SELECT job FROM (SELECT MIN(cotsal),job FROM (SELECT AVG(sal+csal) OVER(ORDER BY sal+csal RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)cotsal,job FROM temp)k GROUP BY job HAVING MIN(cotsal) > 1600)k )
)
SELECT  c.deptno,c.dname,COUNT(p.sal_unbound_avg+p.rows_unbound_avg+e.range_count+e.rows_count)scot FROM test2 e,test1 p,temp c WHERE p.deptno = c.deptno AND c.job = e.job 
GROUP BY c.deptno,c.dname ORDER BY 1,2,3
)d
WHERE p.dname = d.dname AND d.deptno = e.deptno AND e.deptno = c.deptno ORDER BY 1,2,3,4;
