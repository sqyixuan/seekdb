WITH
temp AS
(
SELECT e.deptno,p.ename,c.c6,RANK()OVER(ORDER BY p.sal+p.comm+d.sal)rk FROM t1 e INNER JOIN t2 PARTITION(p1) p ON e.deptno = p.deptno LEFT JOIN t3_view c ON p.deptno = c.c1 INNER JOIN 
(SELECT e.deptno,e.dname,p.ename,p.sal FROM t1 e,t2 PARTITION(p2sub1) p WHERE e.deptno = p.deptno  )d ON c.c1 = d.deptno 
)
,
test1 AS 
(
SELECT DISTINCT e.deptno,p.ename,f.c6,FIRST_VALUE (d.mgr+c.mgr+p.mgr+q.mgr) IGNORE NULLS OVER ( ORDER BY p.sal+d.sal+c.sal+q.sal DESC ROWS UNBOUNDED PRECEDING )AS first_MGR  FROM t1_view e LEFT JOIN t5 p ON e.deptno = p.deptno 
INNER JOIN (SELECT e.deptno,e.dname,p.ename,p.sal,p.mgr FROM t1_view e,t2 PARTITION(p2) p WHERE e.deptno = p.deptno )d ON p.deptno = d.deptno 
INNER join(SELECT e.deptno,e.dname,p.ename,p.sal,p.mgr  FROM t1_view e,t2_view p WHERE e.deptno = p.deptno)c ON d.deptno = c.deptno 
INNER JOIN (SELECT e.deptno,e.dname,p.ename,p.sal,p.mgr FROM t1_view e,t6_view p WHERE e.deptno = p.deptno)q ON c.deptno = q.deptno 
INNER JOIN t3_view f ON q.deptno = f.c1
WHERE f.c6 IN (SELECT c6 FROM temp e,t1 p WHERE e.deptno = p.deptno 
AND p.loc = (SELECT DISTINCT e.loc FROM t1_view e,t6_view p WHERE e.deptno = p.deptno AND p.sal BETWEEN 2000 AND 3000  AND p.comm IS NOT NULL AND EXISTS
(SELECT * FROM temp WHERE rk >ANY(SELECT RANK()OVER(ORDER BY e.sal + p.sal + c.sal) FROM t2_view e,t6_view p,t7_view c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ))))
AND f.c6 IN (SELECT c6 FROM (SELECT COUNT(*),c6 FROM temp WHERE rk < (SELECT MAX(rk) FROM (SELECT RANK()OVER(ORDER BY e.sal+p.ssal)rk FROM t5_view e,t4_view p WHERE e.deptno = p.deptno AND e.sal BETWEEN 3000 AND 5000 ORDER BY 1 )k)
AND ename = (SELECT DISTINCT e.ename FROM temp e,t1_view p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND p.job = 17520 AND e.rk < 10)  GROUP BY c6 HAVING COUNT(*) > 1 ORDER BY 1,2)k)
AND p.sal BETWEEN (SELECT MIN(sal) FROM (SELECT AVG(p.sal)sal,e.dname FROM t1 e,t2 p WHERE e.deptno = p.deptno GROUP BY e.dname HAVING AVG(p.sal) > 2000 ORDER BY 1,2)k)
AND (SELECT MAX(sal) FROM (SELECT e.loc,MAX(sal)sal FROM t4 e,t5 p WHERE e.deptno = p.deptno GROUP BY e.loc ORDER BY 1,2)k )
AND d.ename IN (SELECT DISTINCT e.ename FROM t1_view e,t5_view d WHERE e.dname = d.dname AND d.c6 = 'k' )
)
SELECT DISTINCT e.deptno,e.ename,p.c6,RANK()OVER(ORDER BY e.rk+p.first_MGR ) FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;
deptno	ename	c6	RANK()OVER(ORDER BY e.rk+p.first_MGR )
