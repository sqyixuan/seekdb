WITH
temp AS 
(
SELECT * FROM t1 e,t2 p,(
WITH test1 AS (SELECT DISTINCT e.deptno,e.ename,p.sal,p.c6 FROM t1_view e,t5_view p WHERE e.deptno = p.deptno AND e.job IS NOT NULL AND p.sal BETWEEN 2000 AND 3000 AND c6 IN (SELECT c6 FROM t3 WHERE c6 = 'f'))
SELECT * FROM test1
)c WHERE e.deptno = p.deptno AND p.deptno = c.deptno
)
SELECT * FROM temp;
WITH 
temp AS 
(
SELECT (CASE WHEN p.sal+c.sal <= 3000 THEN 3000 WHEN p.sal+c.sal <= 4000 THEN 4000 WHEN p.sal+c.sal <= 5000 THEN 5000 ELSE 6000 END)sal FROM t1 e LEFT JOIN t2 PARTITION(p1) p ON e.deptno = p.deptno 
RIGHT JOIN (SELECT e.deptno,e.ssal,p.sal FROM t4_view e,t6_view p WHERE e.deptno = p.deptno)c ON p.deptno = c.deptno 
),
test1 AS 
(
SELECT DISTINCT SUM(sal) OVER(ORDER BY sal) default_sum,
SUM(sal) OVER(ORDER BY sal RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) range_unbound_sum,
SUM(sal) OVER(ORDER BY sal ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) rows_unbound_sum,
SUM(sal) OVER(ORDER BY sal RANGE BETWEEN 3000 PRECEDING AND 5000 FOLLOWING) range_sum,
SUM(sal) OVER(ORDER BY sal ROWS BETWEEN 4000 PRECEDING AND 6000 FOLLOWING) rows_sum
FROM temp 
),
test2 AS 
(
SELECT DISTINCT COUNT(sal) OVER(ORDER BY sal) default_count,
COUNT(sal) OVER(ORDER BY sal RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) range_unbound_count,
COUNT(sal) OVER(ORDER BY sal ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) rows_unbound_count,
COUNT(sal) OVER(ORDER BY sal RANGE BETWEEN 3000 PRECEDING AND 5000 FOLLOWING) range_count,
COUNT(sal) OVER(ORDER BY sal ROWS BETWEEN 4000 PRECEDING AND 6000 FOLLOWING) rows_count
FROM temp 
),
test3 AS 
(
SELECT e.loc,e.dname,p.ename,p.job,p.sal,c.ssal,d.comm,
(SELECT default_sum FROM test1 WHERE default_sum <= (SELECT MIN(default_sum) FROM test1) AND range_unbound_sum <= (SELECT MIN(range_unbound_sum) FROM test1) 
AND rows_unbound_sum <= (SELECT MIN(rows_unbound_sum) FROM test1)) default_sum,
(SELECT range_unbound_sum FROM test1 WHERE default_sum <= (SELECT MIN(default_sum) FROM test1) AND range_unbound_sum <= (SELECT MIN(range_unbound_sum) FROM test1) 
AND rows_unbound_sum <= (SELECT MIN(rows_unbound_sum) FROM test1)) range_unbound_sum,
(SELECT rows_unbound_sum FROM test1 WHERE default_sum <= (SELECT MIN(default_sum) FROM test1) AND range_unbound_sum <= (SELECT MIN(range_unbound_sum) FROM test1) 
AND rows_unbound_sum <= (SELECT MIN(rows_unbound_sum) FROM test1))rows_unbound_sum,
(SELECT range_sum FROM test1 WHERE default_sum <= (SELECT MIN(default_sum) FROM test1) AND range_unbound_sum <= (SELECT MIN(range_unbound_sum) FROM test1) 
AND rows_unbound_sum <= (SELECT MIN(rows_unbound_sum) FROM test1)) range_sum,
(SELECT rows_sum FROM test1 WHERE default_sum <= (SELECT MIN(default_sum) FROM test1) AND range_unbound_sum <= (SELECT MIN(range_unbound_sum) FROM test1) 
AND rows_unbound_sum <= (SELECT MIN(rows_unbound_sum) FROM test1))rows_sum,
(SELECT default_count FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2) AND rows_unbound_count = 
(SELECT AVG(rows_unbound_count) FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2))) default_count,
(SELECT range_unbound_count FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2) AND rows_unbound_count = 
(SELECT AVG(rows_unbound_count) FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2))) range_unbound_count,
(SELECT rows_unbound_count FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2) AND rows_unbound_count = 
(SELECT AVG(rows_unbound_count) FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2))) rows_unbound_count,
(SELECT range_count FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2) AND rows_unbound_count = 
(SELECT AVG(rows_unbound_count) FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2))) range_count,
(SELECT rows_count FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2) AND rows_unbound_count = 
(SELECT AVG(rows_unbound_count) FROM test2 WHERE default_count <= (SELECT MIN(default_count) FROM test2))) rows_count
FROM t1 e LEFT JOIN  t2_view p ON e.deptno = p.deptno INNER JOIN t4_view c ON p.deptno = c.deptno  INNER JOIN t6_view d ON c.deptno = d.deptno 
)
SELECT COUNT(*) FROM test1 e,test2 p,test3 c WHERE c.default_sum = e.default_sum AND c.default_count = p.default_count ORDER BY 1;
COUNT(*)
59049
