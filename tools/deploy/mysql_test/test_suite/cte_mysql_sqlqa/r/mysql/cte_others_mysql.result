#Environmental cleaning
drop user zhe123@'%';
drop database zhe123;
create database zhe123;
create user zhe123 identified by 'zhe123';
grant all on *.* to zhe123 WITH GRANT OPTION;
set @ori_parallel_servers_target = @@parallel_servers_target;
set global parallel_servers_target = 200;
DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;
DROP TABLE t4;
DROP TABLE t5;
DROP TABLE t6;
DROP VIEW t1_view;
DROP VIEW t2_view;
DROP VIEW t3_view;
DROP VIEW t4_view;
DROP VIEW t5_view;
DROP VIEW t6_view;
DROP VIEW t7_view;
CREATE TABLE t1(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t1 VALUES(1,'AccounTing','New York');
INSERT INTO t1 VALUES (2,'ReSeaRch','DallAs');
INSERT INTO t1 VALUES(3,'SaLeS','ChiCaGo');
INSERT INTO t1 VALUES(4,'OperaTions','BoSton');
CREATE TABLE t2(
EMPNO DECIMAL(4) ,
ENAME VARCHAR(10) NOT NULL,
JOB INT,
MGR DECIMAL(4),
HIREDATE DATE,
SAL DECIMAL(7,2),
COMM DECIMAL(7,2),
DEPTNO INT) 
PARTITION BY RANGE(FLOOR(SAL)) 
SUBPARTITION BY hash(JOB)(
PARTITION p1 VALUES less than(2500)
(
SUBPARTITION p1sub1,
SUBPARTITION p1sub2,
SUBPARTITION p1sub3
),
PARTITION p2 VALUES less than(5000)
(
SUBPARTITION p2sub1,
SUBPARTITION p2sub2,
SUBPARTITION p2sub3
)
);
INSERT INTO t2 VALUES(7369,'SMITH',11001,7902,str_to_date('17-12-1980','%d-%m-%Y'),800,100,2);
