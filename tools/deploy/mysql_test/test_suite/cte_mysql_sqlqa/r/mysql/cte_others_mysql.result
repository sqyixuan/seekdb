AND ename = (SELECT DISTINCT e.ename FROM temp e,t1_view p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND p.job = 17520 AND e.rk < 10)  GROUP BY c6 HAVING COUNT(*) > 1 ORDER BY 1,2))
AND p.sal BETWEEN (SELECT MIN(sal) FROM (SELECT AVG(p.sal)sal,e.dname FROM t1 e,t2 p WHERE e.deptno = p.deptno GROUP BY e.dname HAVING AVG(p.sal) > 2000 ORDER BY 1,2))
AND (SELECT MAX(sal) FROM (SELECT e.loc,MAX(sal)sal FROM t4 e,t5 p WHERE e.deptno = p.deptno GROUP BY e.loc ORDER BY 1,2) )
AND d.ename IN (SELECT DISTINCT e.ename FROM t1_view e,t5_view d WHERE e.dname = d.dname AND d.c6 = 'k' )
)
SELECT /*+ parallel(e,5),parallel(p,4) */DISTINCT e.deptno,e.ename,p.c6,RANK()OVER(ORDER BY e.rk+p.first_MGR ) FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;
deptno	ename	c6	RANK()OVER(ORDER BY e.rk+p.first_MGR )
