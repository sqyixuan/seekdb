--error 0,1305
drop procedure cte_test2;
delimiter //;
CREATE PROCEDURE cte_test2(IN p_playerno INTEGER)
	BEGIN
		WITH RECURSIVE temp as 
		(
			select deptno,ename,job,AVG(sal) avg_sal from t2 
			UNION ALL
			select a.deptno,a.ename,a.job,a.avg_sal from temp a left join t1 b on a.deptno=b.deptno where a.avg_sal=p_playerno and a.ename ='KING'
		) 
		select * from temp ;

END//

delimiter ;//
call cte_test2(1600);



#存储过程中也不支持递归部分包含窗口函数 
--error 0,1305
drop procedure cte_test3;
delimiter //;
CREATE PROCEDURE cte_test3(IN p_playerno INTEGER)
	BEGIN
		WITH RECURSIVE temp as 
			(
			select deptno,ename,job,sal,rank() over (order by sal)  from t2  where job='CLERK'
			UNION ALL
			select a.deptno,a.ename,a.job,a.sal,rank() over (order by sal)  from temp a left join t1 b on a.deptno=b.deptno where a.ename='SMITH' and sal=p_playerno
		)
		select * from temp order by 1,2,3,4;

END//

delimiter ;//
--error 0,3575
call cte_test3(800);

#结合优化器使用
--error 0,1051
drop table rockets;

CREATE TABLE rockets
(origin CHAR(20), destination CHAR(20), trip_time INT);
INSERT INTO rockets VALUES
('地球', '火星', 2),
('火星', '木星', 3),
('木星', '土星', 4);

--error 0,1305
drop procedure cte_test4;
delimiter //;
CREATE PROCEDURE cte_test4()
	BEGIN
		WITH RECURSIVE all_destinations AS
			(
			SELECT destination AS planet
			FROM rockets
			WHERE origin='地球' 
			UNION ALL
			SELECT r.destination
			FROM rockets r, all_destinations d
			WHERE r.origin=d.planet
		)
		SELECT /*+ MAX_EXECUTION_TIME(100) */ * FROM all_destinations;
END//

delimiter ;//
call cte_test4();




#存储过程中使用 INSERT……WITH语法
--error 0,1051
DROP TABLE numbers;
CREATE TABLE numbers(n int(5));

--echo #INSERT
--error 0,1305
drop procedure cte_test5;
delimiter //;
CREATE PROCEDURE cte_test5()
	BEGIN	
		INSERT INTO numbers
		WITH RECURSIVE my_cte(n) AS
		(
		  SELECT 1
		  UNION ALL
		  SELECT 1+n FROM my_cte WHERE n<6
		)
		SELECT * FROM my_cte;
END//

delimiter ;//
call cte_test5();
call cte_test5();
select n from numbers;

--echo #REPLACE
--error 0,1305
drop procedure cte_test6;
delimiter //;
CREATE PROCEDURE cte_test6()
	BEGIN	
		REPLACE INTO numbers
		WITH RECURSIVE my_cte(n) AS
		(
		  SELECT 1
		  UNION ALL
		  SELECT 2+n FROM my_cte WHERE n<6
		)
		SELECT * FROM my_cte;

END//

delimiter ;//
call cte_test6();
select n from numbers;

 #CREATE TABLE
--error 0,1305 
drop procedure cte_test6;
--error 0,1051
drop table numbers1;
delimiter //;
CREATE PROCEDURE cte_test6()
	BEGIN	
		CREATE TABLE numbers1
		  WITH RECURSIVE my_cte(n) AS
		  (
			SELECT 1
			UNION ALL
			SELECT 1+n FROM my_cte WHERE n<6
		  )
		  SELECT * FROM my_cte;

END//

delimiter ;//
call cte_test6();
select n from numbers;
drop table numbers1;

--echo #CREATE VIEW 
--error 0,1305
drop procedure cte_test6;
--error 0,1051
drop view numbers2;
delimiter //;
CREATE PROCEDURE cte_test6()
	BEGIN		
		CREATE VIEW numbers2 AS
		  WITH RECURSIVE my_cte(n) AS
		  (
			SELECT 1
			UNION ALL
			SELECT 3+n FROM my_cte WHERE n<50
		  )
		  SELECT * FROM my_cte;

END//

delimiter ;//
call cte_test6();
select n from numbers;
drop VIEW numbers2;




#创建函数中使用递归CTE
--error 0,1305
drop function cte_test2;
delimiter //;
CREATE function  cte_test2(p_playerno INT) 
RETURNS VARCHAR(300)
	BEGIN
		RETURN
		(
			WITH RECURSIVE temp as 
			(
				select deptno,ename,job,AVG(sal) avg_sal from t2 
				UNION ALL
				select a.deptno,a.ename,a.job,a.avg_sal from temp a left join t1 b on a.deptno=b.deptno where a.avg_sal=p_playerno and a.ename ='KING'
			) 
			select * from temp
		);
END//
delimiter ;//
call cte_test2(1600);

#创建函数中使用 递归部分包含窗口函数 不支持
--error 0,1305
drop function cte_test3;
delimiter //;
CREATE function cte_test3(p_playerno INT) 
RETURNS VARCHAR(300)
	BEGIN
	RETURN(
		WITH RECURSIVE temp as 
			(
			select deptno,ename,job,sal,rank() over (order by sal)  from t2  where job='CLERK'
			UNION ALL
			select a.deptno,a.ename,a.job,a.sal,rank() over (order by sal)  from temp a left join t1 b on a.deptno=b.deptno where a.ename='SMITH' and sal=p_playerno
		)
		select * from temp order by 1,2,3,4
		);

END//

delimiter ;//
--error 0,3575
call cte_test3(800);

#创建函数，结合优化器使用
drop table if exists rockets;

CREATE TABLE rockets
(origin CHAR(20), destination CHAR(20), trip_time INT);
INSERT INTO rockets VALUES
('地球', '火星', 2),
('火星', '木星', 3),
('木星', '土星', 4);
--error 0,1305
drop function cte_test4;
delimiter //;
CREATE function cte_test4()
RETURNS VARCHAR(300)
	BEGIN
	RETURN(
		WITH RECURSIVE all_destinations AS
			(
			SELECT destination AS planet
			FROM rockets
			WHERE origin='地球' 
			UNION ALL
			SELECT r.destination
			FROM rockets r, all_destinations d
			WHERE r.origin=d.planet
		)
		SELECT /*+ MAX_EXECUTION_TIME(100) */ * FROM all_destinations
		);
END//

delimiter ;//
call cte_test4();





