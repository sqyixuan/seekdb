CREATE TABLE t2(
	EMPNO DECIMAL(4) ,
	ENAME VARCHAR(10) NOT NULL,
	JOB INT,
	MGR DECIMAL(4),
	HIREDATE DATE,
	SAL DECIMAL(7,2),
	COMM DECIMAL(7,2),
	DEPTNO DECIMAL(2));
