CREATE TABLE t4(DEPTNO DECIMAL(2) PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t4 SELECT * FROM t1 LIMIT 3;
CREATE TABLE t5(EMPNO DECIMAL(4) ,ENAME VARCHAR(10) NOT NULL,JOB INT,MGR DECIMAL(4),HIREDATE DATE,SAL DECIMAL(7,2),COMM DECIMAL(7,2),DEPTNO DECIMAL(2))PARTITION BY HASH(FLOOR(DEPTNO))(PARTITION part6,PARTITION part7,PARTITION part8);
delete from t5;
SELECT * FROM(SELECT * FROM t2 ORDER BY empno,ename,job)a LIMIT 6;
INSERT INTO t5 (SELECT * FROM(SELECT * FROM t2 ORDER BY empno,ename,job)a  );
select * from t5 order by empno;
CREATE TABLE t6(C1 DECIMAL(5,2),C2 DECIMAL(5,2),C3 CHAR(1),C4 DECIMAL,C5 VARCHAR(1),C6 VARCHAR(1),C7 DECIMAL,C8 CHAR(1));
CREATE UNIQUE INDEX index_3 ON t6(c6);
CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM (SELECT * FROM t3 WHERE c3 IN ('w','e','y','x','i','h') ORDER BY 1,2,3,4)a;


CREATE OR REPLACE VIEW t1_view AS SELECT e.deptno,e.dname,e.loc,p.ename,p.job FROM t1 e LEFT JOIN t5 p ON e.deptno = p.deptno ORDER BY 1,2,3;

CREATE OR REPLACE VIEW t2_view AS SELECT * FROM(SELECT * FROM t2 e WHERE e.sal < 4000 UNION ALL SELECT * FROM t5 p WHERE p.sal BETWEEN 1500 AND 3000 ORDER BY 1,2,3,4)a;
CREATE OR REPLACE VIEW t3_view AS SELECT DISTINCT e.c1,e.c2,e.c3,e.c4,p.c5,p.c6,p.c7,p.c8 FROM t3 e,t6 p WHERE e.c1 = p.c1 AND e.c7 IS NOT NULL ORDER BY 1,2,3,4;
CREATE OR REPLACE VIEW t4_view AS SELECT e.deptno,SUM(p.sal)ssal FROM t4 e,t2 p WHERE e.deptno = p.deptno GROUP BY e.deptno ORDER BY e.deptno;
CREATE OR REPLACE VIEW t5_view AS SELECT e.deptno,p.sal,c.c6,d.dname,v.job FROM t1 e LEFT JOIN t2 p ON e.deptno = p.deptno INNER JOIN t3 c ON p.deptno = c.c1 RIGHT JOIN t4 d ON c.c1 = d.deptno LEFT JOIN t5 v ON d.deptno = v.deptno; 
CREATE OR REPLACE VIEW t6_view AS SELECT * FROM t2 e WHERE EXISTS (SELECT p.sal FROM t5 p WHERE p.ename = 'ALLEN');
CREATE OR REPLACE VIEW t7_view AS SELECT * FROM t5 e WHERE NOT EXISTS (SELECT * FROM t1 e,t2 p WHERE e.deptno = p.deptno AND p.deptno = 4);


--echo # IN/NOT IN EXISTS/NOT EXISTS BETWEEN AND AND/OR/NOT  IS NULL/IS NOT NULL LIKE
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
WITH RECURSIVE temp AS (
(SELECT DISTINCT e.deptno,p.ename,c.dname,d.c6,d.cot,f.sal,q.mgr FROM t1 e INNER JOIN t2 p ON e.deptno = p.deptno 
INNER JOIN (
SELECT e.dname,e.deptno,p.ename FROM t1_view e,t2_view p WHERE e.deptno = p.deptno AND p.sal BETWEEN 1000 AND 2000 
AND e.dname IN (SELECT r.dname FROM (SELECT dname,COUNT(job) FROM t5_view WHERE sal BETWEEN 1000 AND 2000 AND job IS NOT NULL GROUP BY dname HAVING COUNT(*) >= 8 ORDER BY 1,2)r )) c ON p.deptno = c.deptno 
INNER JOIN (
SELECT e.c6,p.c1,COUNT(p.c8)cot FROM t3_view e RIGHT JOIN t3 p ON e.c1 = p.c1 GROUP BY e.c6,p.c1  ORDER BY 1,2)d ON c.deptno = d.c1 
INNER JOIN (
SELECT e.deptno,(p.sal+e.ssal)sal,p.job FROM t4_view e LEFT JOIN t5 p ON e.deptno = p.deptno WHERE p.deptno IS NOT NULL AND p.comm + p.sal > 0 )f ON d.c1 = f.deptno
INNER JOIN (
SELECT e.deptno,e.ename,e.mgr FROM t5 e WHERE empno = (SELECT mgr FROM (SELECT mgr,COUNT(*) FROM t5 
WHERE ename IN (SELECT ename FROM t2 WHERE sal BETWEEN 1500 AND 3000) GROUP BY mgr HAVING COUNT(*) <2  ORDER BY 1,2 )nn))q ON  f.deptno = q.deptno WHERE p.ename='JONES' order by 1,2,3,4,5,6,7 limit 2)
UNION ALL
SELECT deptno,ename,dname,c6,cot,sal,mgr FROM temp where sal='11676.00' and c6='q' 
)
select deptno,ename,dname,c6,cot,sal,mgr from temp order by 1,2,3,4,5,6; 



#select a.empno,a.ename,a.job,a.deptno from t6_view a left join t7_view b on a.deptno=b.deptno where not exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.deptno = 4)  and a.ename like '%WARD%' ;


--echo #查询视图

WITH RECURSIVE temp AS (
select a.empno,a.ename,a.job,a.deptno,a.comm from t6_view a 
UNION ALL
select b.deptno,c.ename,c.job,c.deptno,c.comm from temp c ,t6_view b where  b.sal=c.comm and not exists (select * from t1 e,t2 p where e.deptno = p.deptno and p.deptno = 4)  and  c.ename like '%WARD%' 
)select  /*+ MAX_EXECUTION_TIME(100) */ * from temp;

WITH RECURSIVE temp AS (
select a.empno,a.ename,a.job,a.deptno,a.comm from t6_view a where   a.ename like '%MILLER%' 
UNION ALL
select b.deptno,c.ename,c.job,c.deptno,c.comm from temp c ,t6_view b where  b.sal=c.comm 
)select  * from temp;

WITH RECURSIVE temp AS (
select t.job,t.ename from t1_view t 
UNION ALL
select p.job+2,p.ename from temp p,t1_view t  where t.ename=p.ename and p.ename='ALLEN' and p.job =21095 
)select * from temp order by job ;

WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno from t1_view t 
UNION ALL
select p.job+2,p.ename,t.deptno from temp p,t1_view t  where t.ename=p.ename and p.ename='ALLEN' and p.job =21095 
)select * from temp a left join t1_view b on a.deptno=b.deptno order by b.job;


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno from t1_view t 
UNION ALL
select p.job+2,p.ename,t.deptno from temp p,t1_view t  where t.ename=p.ename and p.ename='ALLEN' and p.job =21095 
)select * from  t1_view a left join  temp b on a.deptno=b.deptno order by b.job;


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno from t1_view t 
UNION ALL
select p.job+2,p.ename,t.deptno from t1_view t ,temp p where t.ename=p.ename and p.ename='ALLEN' and p.job =21095 
)select * from  t1_view a left join  temp b on a.deptno=b.deptno order by a.job desc limit 10;



--echo #递归查询部分结合运算符
WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno from t1_view t 
UNION ALL
select p.job+2,p.ename,t.deptno from t1_view t ,temp p where t.ename=p.ename and t.ename !='ALLEN' and t.job =21095 
)select * from  t1_view a left join  temp b on a.deptno=b.deptno order by a.job desc limit 10;


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno from t1_view t 
UNION ALL
select p.job+2,p.ename,t.deptno from t1_view t ,temp p where t.ename=p.ename and t.ename <>'ALLEN' and t.job =21095 
)select * from  t1_view a left join  temp b on a.deptno=b.deptno order by a.job desc limit 10;


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal from t2_view t 
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal from t2_view t ,temp p where t.ename=p.ename and t.ename <>'ALLEN' and t.job =21095 and t.sal >1000
)select * from  t2_view a left join  temp b on a.deptno=b.deptno order by 1,2,3,4 desc limit 10;


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno from t2_view t where  t.ename <>'ALLEN' and t.sal >100 and t.job !=11001
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno from t2_view t ,temp p where t.ename=p.ename and t.ename ='ALLEN' and p.job =17520 and p.sal >=3000 and p.empno=7369
)select * from  t2_view a left join  temp b on a.deptno=b.deptno where  b.sal <3000 and b.ename ='TURNER' order by 1,2,3,4 desc;

WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno from t2_view t where  t.ename <>'ALLEN' and t.sal >100 and t.job !=11001
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno from t2_view t ,temp p where t.ename=p.ename and t.ename ='ALLEN' and p.job =17520 and p.sal = ANY(select sal from t2_view where ename='MARTIN') and p.empno=7369
)select * from  t2_view a left join  temp b on a.deptno=b.deptno where  b.sal <3000 and b.ename ='TURNER' order by 1,2,3,4 desc;

