UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno from t2_view t ,temp p where t.ename=p.ename and t.ename <>'ALLEN' and p.job =11001 and p.sal <> ALL(select sal from t2_view where ename='BLAKE') and p.empno=7369
)select b.job,b.deptno,b.sal,a.empno,a.sal,a.job from  t2_view a left join  temp b on a.deptno=b.deptno and b.sal=800 order by ISNULL(b.job) ,1,2,3,4 limit 5;  



--echo #查询分区
WITH RECURSIVE temp AS (
select m.empno,m.ename,m.job,m.sal from  t2 PARTITION(p1) m where m.sal<1100.00
UNION ALL
select a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a,temp b where a.empno=b.empno and b.sal=1100.00
)select * from temp ;


WITH RECURSIVE temp AS (
select m.empno,m.ename,m.job,m.sal from  t2 PARTITION(p1) m where m.sal<1100.00
UNION ALL
select a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a,temp b where a.empno=b.empno and b.sal=1100.00
)select * from temp c  right join t2 PARTITION(p1sub3) d on c.empno=d.empno order by 5,6,8,10;

WITH RECURSIVE temp AS (
select m.empno,m.ename,m.job,m.sal from  t2 PARTITION(p1) m where m.sal<1100.00
UNION ALL
select a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a,temp b where a.empno=b.empno and b.sal=1100.00
)select * from temp c  group by c.sal having sum(c.sal) >100;


WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,a.sal from t2 PARTITION(p1sub1) a inner join temp b where a.empno=b.empno 
)select * from temp c  right join t2 PARTITION(p1sub3) d on c.empno=d.empno;


WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) as sum_sal from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,b.sum_sal from t2 PARTITION(p1sub1) a right join temp b on a.empno=b.empno where  b.sum_sal >3000
)select * from temp c order by 1,2,3,4;

WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) as sum_sal from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,b.sum_sal from t2 PARTITION(p1sub1) a right join temp b on a.empno=b.empno where  b.ename in ('ALLEN','BLAKE')
)select * from temp c order by 1,2,3,4;

WITH RECURSIVE temp AS (
select distinct a.empno,a.ename,a.job,sum(a.sal) as sum_sal from  t2 PARTITION(p1) a group by a.sal having sum(a.sal) =1600.00
UNION ALL
select  a.empno,a.ename,a.job,b.sum_sal from t2 PARTITION(p1sub1) a right join temp b on a.empno=b.empno where  b.ename  not in ('ALLEN','BLAKE')
)select * from temp c order by 1,2,3,4;

WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno from t2 PARTITION(p2sub3) t 
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno from t2 PARTITION(p2sub3) t ,temp p where t.ename=p.ename and t.ename <>'ALLEN' and p.job =11001 and p.sal <> ALL(select sal from t2_view where ename='BLAKE') and p.empno=7369
)select b.ename,b.deptno,b.sal,a.empno,a.sal,a.ename from  t2 PARTITION(p2sub3) a left join  temp b on a.deptno=b.deptno and b.sal=800 order by ISNULL(b.job) ,1,2,3,4 limit 5;  


WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno,t.HIREDATE from t2 PARTITION(p2sub3) t 
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno,t.HIREDATE from t2 PARTITION(p1sub1) t ,temp p where t.HIREDATE=p.HIREDATE and t.empno=7876
)select * from temp;



WITH RECURSIVE temp AS (
select t.job,t.ename,t.deptno,t.sal,t.empno,t.HIREDATE,t.MGR from t2 PARTITION(p2sub1) t where t.empno=7698
UNION ALL
select p.job+2,p.ename,t.deptno,t.sal,t.empno,t.HIREDATE,t.MGR from t2 PARTITION(p1sub3) t ,temp p where t.empno=p.MGR 
)select * from temp;




