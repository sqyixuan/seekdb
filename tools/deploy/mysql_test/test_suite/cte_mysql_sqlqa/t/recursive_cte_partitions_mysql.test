CREATE TABLE t3(C1 DECIMAL(5,2),C2 DECIMAL(5,2),C3 CHAR(1),C4 DECIMAL,C5 VARCHAR(1),C6 VARCHAR(1),C7 DECIMAL,C8 CHAR(1))PARTITION BY RANGE(FLOOR(c1))SUBPARTITION BY HASH(FLOOR(c2))(PARTITION part10 VALUES LESS THAN(2)(SUBPARTITION p1sub3,SUBPARTITION p1sub4),
PARTITION part11 VALUES LESS THAN(5)(SUBPARTITION p1sub5,SUBPARTITION p1sub6));



