test2 AS (SELECT e.deptno,MAX(e.sal)msal FROM t2 PARTITION(p1sub1) e,test1 p WHERE e.deptno = p.deptno GROUP BY e.deptno,p.asal HAVING MAX(e.sal) > p.asal)
