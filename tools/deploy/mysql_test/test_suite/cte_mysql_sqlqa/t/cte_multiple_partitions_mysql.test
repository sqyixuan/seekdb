#test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 PARTITION(p1sub2) p WHERE p.sal < 3000 AND p.comm > 0 ORDER BY 1,2,4),
#test2 AS (SELECT c.deptno,c.loc FROM t1 c WHERE c.dname !='ReSeaRch' AND c.loc !='BoSton'  ORDER BY 1,2),
