temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc LIKE '%a%' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.sal,p.job FROM t2 PARTITION(p1sub1) p WHERE p.sal BETWEEN 1000 AND 3000 ORDER BY 1)
