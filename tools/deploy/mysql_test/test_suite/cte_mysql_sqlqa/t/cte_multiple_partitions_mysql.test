#多表显示cte包含过滤谓词ANY/SOME/ALL
--sorted_result
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p1sub2) p WHERE e.deptno = p.deptno AND p.sal > ANY (SELECT MIN(p.sal) FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('SALESMAN','MANAGER') GROUP BY p.job)ORDER BY p.deptno),
test1 AS (SELECT AVG(e.sal)vsal,p.loc FROM temp e,t4 p WHERE e.loc = p.loc AND e.sal = ANY(SELECT MIN(e.sal) FROM temp e,t5 p WHERE e.deptno = p.deptno AND e.job != 'PRESIDENT' GROUP BY e.job) GROUP BY p.loc ORDER BY p.loc),
test2 AS (SELECT e.deptno,e.ename,e.job,p.vsal,p.loc FROM temp e,test1 p WHERE e.loc = p.loc AND p.vsal < ANY(SELECT AVG(p.sal) FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('SALESMAN','MANAGER') GROUP BY p.job ) )
SELECT e.deptno,e.sal,p.vsal,c.job,c.ename,d.dname FROM temp e,test1 p,t1 d,test2 c WHERE e.loc = p.loc AND p.loc = d.loc AND d.deptno = c.deptno ORDER BY 1,2,3,4;

