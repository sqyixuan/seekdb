test1 AS (SELECT e.loc,e.dname,p.c6,p.c7 FROM t4 e INNER JOIN t3 PARTITION(part11) p ON e.deptno = p.c1 WHERE p.c6 LIKE '%z%' ORDER BY p.c1,e.deptno)
SELECT * FROM temp e INNER JOIN test1 p ON e.loc = p.loc ORDER BY 1;

