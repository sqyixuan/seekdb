test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 PARTITION(p1sub1) p WHERE p.job NOT IN ('MANAGER','PRESIDENT') AND p.sal <= 1500 ORDER BY 1)
SELECT  /*+ parallel(5)*/e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


