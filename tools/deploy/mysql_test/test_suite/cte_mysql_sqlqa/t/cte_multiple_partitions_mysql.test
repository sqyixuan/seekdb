#LEFT Deep Tree hash JOIN 

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 PARTITION(p1sub1) e,t2 PARTITION(p2sub1) p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT * FROM (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 PARTITION(part10) e,temp p WHERE e.c1 = p.deptno 
UNION ALL SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 PARTITION(part11) e,temp p WHERE e.c1 = p.deptno)aa
WHERE c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t3 PARTITION(part11) e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT /*+ ordered use_hash(test1,test2,test3) */DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


