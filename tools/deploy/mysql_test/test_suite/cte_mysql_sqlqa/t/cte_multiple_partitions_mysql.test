#多表显示cte包含过滤谓词比较条件
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno AND p.sal > (SELECT MIN(sal) FROM t5 WHERE job = 'SALESMAN') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno AND p.sal = (SELECT MIN(sal) FROM temp WHERE job IN ('CLERK','SALESMAN') ) ORDER BY e.deptno),
test2  AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p2sub1) p WHERE e.deptno = p.deptno AND p.sal <> (SELECT AVG(sal) FROM test1 WHERE p.job = 'MANAGER') ORDER BY e.deptno)
SELECT e.deptno,p.loc,p.ename,c.job,c.sal FROM temp e,test1 p,test2 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno ORDER BY 1,2,3,4;


