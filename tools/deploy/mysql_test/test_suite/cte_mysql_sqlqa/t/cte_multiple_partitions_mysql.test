CREATE TABLE t3(C1 NUMERIC(5,2),C2 NUMERIC(5,2),C3 CHAR(1),C4 NUMERIC,C5 VARCHAR(1),C6 VARCHAR(1),C7 NUMERIC,C8 CHAR(1))PARTITION BY RANGE(FLOOR(c1))SUBPARTITION BY HASH(FLOOR(c2))(PARTITION part10 VALUES LESS THAN(2)(SUBPARTITION p1sub3,SUBPARTITION p1sub4),
PARTITION part11 VALUES LESS THAN(5)(SUBPARTITION p1sub5,SUBPARTITION p1sub6));
INSERT INTO t3 VALUES  (1, 5, 'e', 8, NULL, 't', NULL, NULL) ;
INSERT INTO t3 VALUES  (2, 3, 'x', 2, 'q', 'k', 0, NULL) ;
INSERT INTO t3 VALUES  (2, 4, 'o', 5, 'w', 'u', 8,'n') ;
INSERT INTO t3 VALUES  (3, 4, 'h', 2, 'y', 'z', NULL, NULL) ;
INSERT INTO t3 VALUES  (4, 6, 'j', 2, 'h', 'p', 1,NULL) ;
INSERT INTO t3 VALUES  (4, 4, 'i', 2, 'd', 'x', 0,'f') ;
INSERT INTO t3 VALUES  (3, 9, 'e', 0, 'r', 'v', 6, 'd') ;
INSERT INTO t3 VALUES  (2, 9, 'y', 7, 'h', 'q', 2,'v') ;
INSERT INTO t3 VALUES  (1, 2, 'w', 1, 'c', 'l', 7,'o') ;
INSERT INTO t3 VALUES  (1, 9, 'y', 1, NULL, 's', 5, NULL) ;  
INSERT INTO t3 VALUES  (2, 6, 'h', 7, NULL, 'f', 8, NULL) ;
INSERT INTO t3 VALUES  (4, 5, 'i', 2, NULL, 'w', NULL,'x') ;
CREATE TABLE t4(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t4 SELECT * FROM t1 LIMIT 3;
CREATE TABLE t5(EMPNO INT UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMERIC(4),HIREDATE DATE,SAL NUMERIC(7,2),COMM NUMERIC(7,2),DEPTNO INT)PARTITION BY HASH(FLOOR(EMPNO))(PARTITION part6,PARTITION part7,PARTITION part8);
INSERT INTO t5 SELECT * FROM(SELECT * FROM t2 ORDER BY empno) as a order by 1,2,3,6 LIMIT 6 ;
CREATE TABLE t6(C1 NUMERIC(5,2),C2 NUMERIC(5,2),C3 CHAR(1),C4 NUMERIC,C5 VARCHAR(1),C6 VARCHAR(1),C7 NUMERIC,C8 CHAR(1));
CREATE UNIQUE INDEX index_3 ON t6(c6);
CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM (SELECT * FROM t3 WHERE c3 IN ('w','e','y','x','i','h') ORDER BY 1,2,3,4)a;


#cte 一次调用

WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE p.job NOT IN ('MANAGER','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE p.job NOT IN ('MANAGER','ANALYST') ORDER BY p.deptno)
SELECT  /*+ parallel(5)*/e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE p.job NOT IN ('MANAGER','ANALYST') ORDER BY p.deptno)
SELECT /*+no_rewrite*/e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


#显示cte单表包含EXISTS\NOT EXISTS

WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 PARTITION(part10) WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 PARTITION(part10) WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT  /*+ parallel(5)*/e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 PARTITION(part10) WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 PARTITION(p1sub1) p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT /*+no_rewrite*/e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


