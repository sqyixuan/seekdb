#显示cte多表包含连接谓词UNION\UNION ALL

WITH 
temp AS (SELECT e.deptno,e.dname,p.ename,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno ),
test1 AS (SELECT e.deptno,e.dname,p.ename,p.sal FROM t4 e,t5 p WHERE e.deptno = p.deptno),
test2  AS (SELECT * FROM temp UNION SELECT * FROM test1),
test3  AS (SELECT * FROM temp UNION ALL SELECT * FROM test1),
test4 AS (SELECT e.deptno,SUM(e.sal)asal FROM test2  e GROUP BY e.deptno UNION SELECT p.deptno,SUM(p.sal) FROM test3  p GROUP BY p.deptno),
test5 AS (SELECT e.deptno,AVG(e.sal)vsal FROM test2  e GROUP BY e.deptno UNION ALL SELECT p.deptno,AVG(p.sal) FROM test3  p GROUP BY p.deptno)
SELECT * FROM test4 UNION SELECT * FROM test5 ORDER BY 1,2; 

