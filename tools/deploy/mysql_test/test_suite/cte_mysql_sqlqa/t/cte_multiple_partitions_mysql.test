CREATE TABLE t1(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
INSERT INTO t1 VALUES(1,'AccounTing','New York');
INSERT INTO t1 VALUES (2,'ReSeaRch','DallAs');
INSERT INTO t1 VALUES(3,'SaLeS','ChiCaGo');
INSERT INTO t1 VALUES(4,'OperaTions','BoSton');
CREATE TABLE t2(EMPNO INT,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMERIC(4),HIREDATE DATE ,SAL NUMERIC(7,2) UNIQUE,COMM NUMERIC(7,2),DEPTNO INT)
  PARTITION BY RANGE(FLOOR(SAL))
  SUBPARTITION BY HASH(FLOOR(SAL))
  ( 
	PARTITION p1 VALUES less than(2500)
	(
	  SUBPARTITION p1sub1,
	  SUBPARTITION p1sub2,
	  SUBPARTITION p1sub3
	),
	PARTITION p2 VALUES less than(5000)
	(
	  SUBPARTITION p2sub1,
	  SUBPARTITION p2sub2,
	  SUBPARTITION p2sub3 
	)
);

