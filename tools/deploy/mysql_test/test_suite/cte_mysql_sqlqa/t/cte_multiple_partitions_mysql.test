#显示cte单表包含比较条件

WITH 
temp AS (SELECT e.c1,e.c3,e.c6 FROM t3 PARTITION(part11) e WHERE e.c3 = 'i' OR e.c6 <> 'q' ORDER BY 1,2,3),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 PARTITION(p1sub1) p WHERE p.sal < 3000 AND p.comm >=0 ORDER BY 1,2,3,4),
test2 AS (SELECT c.deptno,c.loc FROM t1 c WHERE c.dname !='ReSeaRch' AND c.loc !='BoSton'  ORDER BY 1,2),
test3 AS (SELECT d.deptno,d.job,d.comm FROM t5 d WHERE d.sal >= 500 AND d.comm < 1000 ORDER BY 1,2,3)
SELECT p.deptno,e.c3,e.c6,p.ename,p.job,p.sal,c.loc,d.comm FROM temp e,test1 p,test2 PARTITION(part100) c,test3 PARTITION(part110) d WHERE e.c1 = p.deptno AND p.job = d.job AND d.deptno = c.deptno ORDER BY 1,2,3,4,5,6,7,8;

with temp as (select * from t1)
select * from temp partition(part100);

WITH 
temp AS (SELECT e.c1,e.c3,e.c6 FROM t3 PARTITION(part11) e WHERE e.c3 = 'i' OR e.c6 <> 'q' ORDER BY e.c1,e.c3,e.c6),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 PARTITION(p1sub2) p WHERE p.sal < 3000 AND p.comm > 0 ORDER BY 1,2,3,4),
test2 AS (SELECT c.deptno,c.loc FROM t1 c WHERE c.dname !='ReSeaRch' AND c.loc !='BoSton'  ORDER BY 1),
test3 AS (SELECT d.deptno,d.job,d.comm FROM t5 d WHERE d.sal >= 500 AND d.comm < 1000 ORDER BY 1)
SELECT p.deptno,e.c3,e.c6,p.ename,p.job,p.sal,c.loc,d.comm FROM temp e,test1 p,test2 c,test3 d WHERE e.c1 = p.deptno AND p.job = d.job AND d.deptno = c.deptno ORDER BY 1,2,3,4,5,6,7,8;


