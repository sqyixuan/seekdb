SELECT e.deptno,e.ename,e.job,e.sal,p.dname,p.loc,c.ssal FROM temp e RIGHT JOIN t1 p ON e.deptno = p.deptno RIGHT JOIN test1 c ON p.loc = c.loc ORDER BY 1,2,3,4;


