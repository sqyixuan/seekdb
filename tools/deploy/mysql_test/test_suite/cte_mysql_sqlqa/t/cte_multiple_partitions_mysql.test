SELECT /*+ ordered use_hash(test1,test2,test3),no_rewrite */DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;

