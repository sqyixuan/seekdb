#显示cte单表包含IS NULL\IS NOT NULL

WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
SELECT e.deptno,e.ename,e.sal,p.job,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1;


WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
SELECT  /*+ parallel(5)*/e.deptno,e.ename,e.sal,p.job,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1;


WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
