SELECT /*+ parallel(5) */e.deptno,e.ename,e.loc,p.job,p.sal,c.dname FROM temp e LEFT JOIN test1 p ON e.deptno = p.deptno LEFT JOIN test2 c ON p.job = c.job ORDER BY 1,2,5;



