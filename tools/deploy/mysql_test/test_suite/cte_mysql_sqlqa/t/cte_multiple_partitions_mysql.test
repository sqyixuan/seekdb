WITH 
temp AS (SELECT e.c1,e.c3,e.c6 FROM t3 PARTITION(part11) e WHERE e.c3 = 'i' OR e.c6 <> 'q' ORDER BY e.c1,e.c3),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 PARTITION(p1sub2) p WHERE p.sal < 3000 AND p.comm > 0 ORDER BY 1),
test2 AS (SELECT c.deptno,c.loc FROM t1 c WHERE c.dname !='ReSeaRch' AND c.loc !='BoSton'  ORDER BY 1),
test3 AS (SELECT d.deptno,d.job,d.comm FROM t5 d WHERE d.sal >= 500 AND d.comm < 1000 ORDER BY 1)
SELECT /*+no_rewrite*/p.deptno,e.c3,e.c6,p.ename,p.job,p.sal,c.loc,d.comm FROM temp e,test1 p,test2 c,test3 d WHERE e.c1 = p.deptno AND p.job = d.job AND d.deptno = c.deptno ORDER BY 1,2,3,4,5,6,7,8;


#显示cte单表包含ANY/SOME/ALL

WITH 
temp AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub2) e WHERE e.sal > ANY (SELECT p.sal FROM t5 p WHERE job = 'SALESMAN') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub2) e WHERE e.sal = ANY (SELECT p.sal FROM temp p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test2  AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub2) e WHERE e.sal < ANY (SELECT p.sal FROM test1 p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test3  AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub1) e WHERE e.sal != ANY (SELECT p.sal FROM test2 p WHERE job = 'SALESMAN') ORDER BY e.deptno )
SELECT e.deptno,p.ename,c.job,d.sal FROM  temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


WITH 
temp AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.sal > SOME (SELECT p.sal FROM t5 p WHERE job = 'MANAGER') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.sal = SOME (SELECT p.sal FROM temp p WHERE job = 'ANALYST') ORDER BY e.deptno ),
test2 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub1) e WHERE e.sal < SOME (SELECT p.sal FROM test1 p WHERE job = 'ANALYST') ORDER BY e.deptno ),
test3 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p2sub3) e WHERE e.sal != SOME (SELECT p.sal FROM test2  p WHERE job = 'SALESMAN') ORDER BY e.deptno )
SELECT  /*+ parallel(5)*/e.deptno,p.ename,d.job FROM  temp e,test1 p,test3 d WHERE e.deptno = p.deptno AND p.deptno = d.deptno  ORDER BY 1,2,3;


WITH 
temp AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p2sub1) e WHERE e.sal > ALL (SELECT p.sal FROM t5 p WHERE job = 'SALESMAN') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub1) e WHERE e.sal = ALL (SELECT p.sal FROM temp p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test2 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub1) e WHERE e.sal <= ALL (SELECT p.sal FROM test1 p WHERE job = 'SALESMAN') ORDER BY e.deptno ),
test3 AS (SELECT e.deptno,e.ename,e.job,e.sal FROM t2 PARTITION(p1sub1) e WHERE e.sal = ALL (SELECT p.sal FROM test2  p WHERE job = 'SALESMAN') ORDER BY e.deptno )
SELECT /*+no_rewrite*/e.deptno,p.ename,c.job,d.sal FROM  temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;



#单表显示cte不包含过滤谓词

WITH
temp AS (SELECT e.deptno AS dept,e.loc FROM t1 e),
test1 AS (SELECT e.deptno,e.ename,e.job FROM t2 PARTITION(p1sub1) e)
SELECT * FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno AS dept,e.loc FROM t1 e),
test1 AS (SELECT e.deptno,e.ename,e.job FROM t2 PARTITION(p1sub1) e)
SELECT /*+ parallel(5)*/e.dept,p.deptno,p.ename,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno AS dept,e.loc FROM t1 e),
test1 AS (SELECT e.deptno,e.ename,e.job FROM t2 PARTITION(p1sub1) e)
SELECT /*+no_rewrite*/e.dept,p.deptno,p.ename,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;



#多表显示cte包含过滤谓词IN\NOT IN

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno AND p.job NOT IN ('ANALYST','ANALYST','MANAGER') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.dname,p.job FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('CLERK','MANAGER') ORDER BY e.deptno)
SELECT e.deptno,e.ename,e.loc,e.sal,p.dname,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno AND p.job NOT IN ('ANALYST','ANALYST','MANAGER') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.dname,p.job FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('CLERK','MANAGER') ORDER BY e.deptno)
SELECT /*+ parallel(5) */e.deptno,e.ename,e.loc,e.sal,p.dname,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.sal FROM t1 e,t2 PARTITION(p1sub1) p WHERE e.deptno = p.deptno AND p.job NOT IN ('ANALYST','ANALYST','MANAGER') ORDER BY e.deptno),
test1 AS (SELECT e.deptno,e.dname,p.job FROM t4 e,t5 p WHERE e.deptno = p.deptno AND p.job IN ('CLERK','MANAGER') ORDER BY e.deptno)
SELECT /*+no_rewrite*/e.deptno,e.ename,e.loc,e.sal,p.dname,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


#多表显示cte包含过滤谓词EXISTS\NOT EXISTS

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e,t2 PARTITION(p1sub2) p WHERE e.deptno = p.deptno AND EXISTS (SELECT * FROM t3 PARTITION(part11) c,t4 d WHERE c.c1 = d.deptno AND c.c4 = 7 AND c.c5 IS NOT NULL) AND p.sal BETWEEN 1500 AND 3000 ORDER BY p.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t4 e,t5 p WHERE e.deptno = p.deptno AND NOT EXISTS (SELECT * FROM t3 PARTITION(part10) e,t6 p WHERE e.c1 = p.c1 AND e.c5 IS NULL AND p.c1 > 5) AND p.sal < 1500 ORDER BY p.deptno )
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


