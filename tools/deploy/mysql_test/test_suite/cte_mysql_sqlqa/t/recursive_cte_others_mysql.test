--echo #cte-2-2 数据截断,递归部分为列生成比非递归部分更宽的值
set sql_mode = "";
WITH RECURSIVE cte AS
(
  SELECT 1 AS n, 'abc' AS str
  UNION ALL
  SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

--echo #CAST() 在非递归中使用SELECT以使str列变宽
WITH RECURSIVE cte AS
(
  SELECT 1 AS n, cast('abc' as char(20))AS str
  UNION ALL
  SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;

--echo #数据较长时，层次查询
--error 0,1051
drop table  c;
create table c(id int PRIMARY KEY,ParentID int,name int);
 
--error 0,1305
drop procedure test1;
delimiter //;

create procedure test1(in i INTEGER)
BEGIN
	DECLARE  v_i INTEGER;
	set v_i = 0;
while v_i <= i do
	insert into c values(v_i+1,v_i,v_i+1000);
	set v_i = v_i + 1;
end while;
END;
//
delimiter ;//


call test1(47);

select * from c;

with recursive r as
(
select id,ParentID,name from c where id =11
union all
select c.* from c,r where c.id=r.ParentID
) select * from r order by id;

with recursive r as
(
select id,cast(name as char(1000)) as name from c where id=35
union all
select c.id,CONCAT(r.name, '>', c.name) as name from c,r where r.id = c.ParentID
)select id,name from r;


--echo #cte-2-3 限制CTE递归相关配置
set max_execution_time=1;
--echo #error 0,1193
#set cte_max_recursion_depth=5200;
--echo #mysql is 3024
--error 0,3636
with recursive r as
(
select id,ParentID,name from c where id =11
union all
select r.* from c,r where c.id=r.ParentID
) select * from r order by id;


set max_execution_time=1000;
--echo #error 0,1193
#set cte_max_recursion_depth=1200;
--echo #mysql is 3636
--error 0,3636
with recursive r as
(
select id,ParentID,name from c where id =11
union all
select r.* from c,r where c.id=r.ParentID
) select * from r order by id;





