WHERE r.origin=d.planet
)
SELECT * FROM all_destinations;



--echo #cte-2-5 在SELECT, UPDATE, 和 DELETE  语句之后
--error 0,1051
DROP TABLE numbers;
CREATE TABLE numbers(n int(5) PRIMARY KEY,name varchar(10));
insert into numbers values(6,'');
select * from rockets;
--echo #UPDATE
WITH RECURSIVE my_cte(n) AS
(
  SELECT 1
  UNION ALL
  SELECT 1+n FROM my_cte WHERE n<6
)
UPDATE rockets, my_cte
SET rockets.trip_time=4
WHERE rockets.trip_time=my_cte.n*my_cte.n;

--echo #DELETE
WITH RECURSIVE my_cte(n) AS
(
  SELECT 1
  UNION ALL
  SELECT 1+n FROM my_cte WHERE n<6
)
DELETE FROM rockets
WHERE rockets.trip_time > (SELECT AVG(n) FROM my_cte);

select * from rockets;


DELETE FROM rockets 
WHERE rockets.trip_time >
  (
    WITH RECURSIVE my_cte(n) AS
    (
      SELECT 1
      UNION ALL
      SELECT 1+n FROM my_cte WHERE n<3
    )
    SELECT MAX(n) FROM my_cte
  );
  
INSERT INTO rockets VALUES ('木星', '土星', 4);


--echo #cte-2-6 在INSERT,REPLACE,CREATE,DECLARE,EXPLAIN之后，在SELECT语句之前
--error 0,1051
DROP TABLE sales;
create table sales (date date,price DECIMAL(9,2));
insert into sales values
(str_to_date('2017-01-03','%Y-%m-%d'),100.00),
(str_to_date('2017-01-03','%Y-%m-%d'),200.00),
(str_to_date('2017-01-06','%Y-%m-%d'),50.00),
(str_to_date('2017-01-08','%Y-%m-%d'),10.00),
(str_to_date('2017-01-08','%Y-%m-%d'),20.00),
(str_to_date('2017-01-08','%Y-%m-%d'),150.00),
(str_to_date('2017-01-10','%Y-%m-%d'),5.00);

WITH RECURSIVE dates (date) AS
(
  SELECT MIN(date) FROM sales
  UNION ALL
  SELECT date + INTERVAL 1 DAY FROM dates
  WHERE date + INTERVAL 1 DAY <= (SELECT MAX(date) FROM sales)
)
SELECT dates.date, COALESCE(SUM(price), 0) AS sum_price
FROM dates LEFT JOIN sales ON dates.date = sales.date
GROUP BY dates.date
ORDER BY dates.date;


--echo #CREATE TABEL
--error 0,1051
DROP TABLE numbers1;
CREATE TABLE numbers1
WITH RECURSIVE dates (date) AS
(
  SELECT MIN(date) FROM sales
  UNION ALL
  SELECT date + INTERVAL 1 DAY FROM dates
  WHERE date + INTERVAL 1 DAY <= (SELECT MAX(date) FROM sales)
)
SELECT dates.date, COALESCE(SUM(price), 0) AS sum_price
FROM dates LEFT JOIN sales ON dates.date = sales.date
GROUP BY dates.date
ORDER BY dates.date;

--error 0,1051
DROP TABLE numbers1;  
create table numbers1 (date date,sum_price DECIMAL(9,2));
--echo #INSERT
INSERT INTO numbers1
WITH RECURSIVE dates (date) AS
(
  SELECT MIN(date) FROM sales
  UNION ALL
  SELECT date + INTERVAL 1 DAY FROM dates
  WHERE date + INTERVAL 1 DAY <= (SELECT MAX(date) FROM sales)
)
SELECT dates.date, COALESCE(SUM(price), 0) AS sum_price
FROM dates LEFT JOIN sales ON dates.date = sales.date
GROUP BY dates.date
ORDER BY dates.date;

--echo #REPLACE
REPLACE INTO numbers1
WITH RECURSIVE dates (date) AS
(
  SELECT MIN(date) FROM sales
  UNION ALL
  SELECT date + INTERVAL 1 DAY FROM dates
  WHERE date + INTERVAL 1 DAY <= (SELECT MAX(date) FROM sales)
)
SELECT dates.date, COALESCE(SUM(price), 0) AS sum_price
FROM dates LEFT JOIN sales ON dates.date = sales.date
GROUP BY dates.date
ORDER BY dates.date;


--echo #CREATE VIEW
--error 0,1051
DROP VIEW numbers2;
CREATE VIEW numbers2 AS
WITH RECURSIVE dates (date) AS
(
  SELECT MIN(date) FROM sales
  UNION ALL
  SELECT date + INTERVAL 1 DAY FROM dates
  WHERE date + INTERVAL 1 DAY <= (SELECT MAX(date) FROM sales)
)
SELECT dates.date, COALESCE(SUM(price), 0) AS sum_price
FROM dates LEFT JOIN sales ON dates.date = sales.date
GROUP BY dates.date
ORDER BY dates.date;

