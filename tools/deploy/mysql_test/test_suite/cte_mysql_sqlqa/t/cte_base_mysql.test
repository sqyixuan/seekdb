temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c,temp d WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = d.deptno ORDER BY 1,2,3,6; 

WITH
temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT /*+ parallel(5)*/e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c,temp d WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = d.deptno ORDER BY 1,2,3,6,4,5; 


WITH
temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT  /*+no_rewrite*/e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c,temp d WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = d.deptno ORDER BY 1,2,3,6,4,5; 


WITH
temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = e.deptno ORDER BY 1,2,3,4,5,6; 


WITH
temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT /*+ parallel(5)*/e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = e.deptno ORDER BY 1,2,3,4,5,6; 


WITH
temp(deptno,sal) AS (SELECT e.deptno,SUM(sal)ssal FROM t2 e WHERE e.job IN ('SALESMAN','MANAGER','CLERK') GROUP BY e.deptno ORDER BY e.deptno)
SELECT  /*+no_rewrite*/e.deptno,e.sal,p.loc,p.dname,c.c2,c.c6 FROM temp e ,t1 p,t3 c WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = e.deptno ORDER BY 1,2,3,4,5,6; 


#本地查询和子查询引用

WITH 
temp(deptno,loc) AS (SELECT deptno,loc FROM t1 WHERE deptno NOT IN (40)),
test1 AS (SELECT e.deptno,e.ename,p.loc FROM t2 e ,temp p WHERE e.deptno = p.deptno AND p.loc IN (SELECT p.loc FROM t5 e,temp p WHERE e.deptno = p.deptno AND e.job NOT IN ('MANAGER','CLERK')))
SELECT p.deptno,p.loc,e.ename FROM test1 e,temp p WHERE e.deptno = p.deptno ORDER BY 1;


WITH 
temp(deptno,loc) AS (SELECT deptno,loc FROM t1 WHERE deptno NOT IN (40)),
test1 AS (SELECT e.deptno,e.ename,p.loc FROM t2 e ,temp p WHERE e.deptno = p.deptno AND p.loc IN (SELECT p.loc FROM t5 e,temp p WHERE e.deptno = p.deptno AND e.job NOT IN ('MANAGER','CLERK')))
SELECT /*+ parallel(5)*/p.deptno,p.loc,e.ename FROM test1 e,temp p WHERE e.deptno = p.deptno ORDER BY 1,2,3;


WITH 
temp(deptno,loc) AS (SELECT deptno,loc FROM t1 WHERE deptno NOT IN (40)),
test1 AS (SELECT e.deptno,e.ename,p.loc FROM t2 e ,temp p WHERE e.deptno = p.deptno AND p.loc IN (SELECT p.loc FROM t5 e,temp p WHERE e.deptno = p.deptno AND e.job NOT IN ('MANAGER','CLERK')))
SELECT  /*+no_rewrite*/p.deptno,p.loc,e.ename FROM test1 e,temp p WHERE e.deptno = p.deptno ORDER BY 1;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,AVG(e.sal)asal FROM t2 e,temp p WHERE e.deptno = p.dept GROUP BY e.deptno,p.msal HAVING AVG(e.sal) > p.msal),
test2 AS (SELECT e.deptno,MAX(e.sal)msal FROM t2 e,test1 p WHERE e.deptno = p.deptno GROUP BY e.deptno,p.asal HAVING MAX(e.sal) > p.asal)
SELECT * FROM (SELECT * FROM test2  UNION SELECT * FROM test1 UNION SELECT * FROM temp ORDER BY 1,2)e;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,AVG(e.sal)asal FROM t2 e,temp p WHERE e.deptno = p.dept GROUP BY e.deptno,p.msal HAVING AVG(e.sal) > p.msal),
test2 AS (SELECT e.deptno,MAX(e.sal)msal FROM t2 e,test1 p WHERE e.deptno = p.deptno GROUP BY e.deptno,p.asal HAVING MAX(e.sal) > p.asal)
SELECT /*+ parallel(5)*/e.* FROM (SELECT * FROM test2  UNION SELECT * FROM test1 UNION SELECT * FROM temp ORDER BY 1,2)e order by 1,2;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,AVG(e.sal)asal FROM t2 e,temp p WHERE e.deptno = p.dept GROUP BY e.deptno,p.msal HAVING AVG(e.sal) > p.msal),
test2 AS (SELECT e.deptno,MAX(e.sal)msal FROM t2 e,test1 p WHERE e.deptno = p.deptno GROUP BY e.deptno,p.asal HAVING MAX(e.sal) > p.asal)
SELECT  /*+no_rewrite*/e.* FROM (SELECT * FROM test2  UNION SELECT * FROM test1 UNION SELECT * FROM temp ORDER BY 1,2)e;


#cte本地查询引用和多层嵌套子查询

WITH 
temp AS (SELECT job FROM t2 GROUP BY job),
test1 AS (SELECT e.job,COUNT(e.empno)cont FROM t2 e,temp p WHERE e.job = p.job GROUP BY e.job HAVING MIN(e.sal) > 1500),
test2 AS (SELECT e.deptno,AVG(e.sal)vsal FROM t2 e GROUP BY e.deptno)
SELECT e.ename,p.cont,p.job,c.vsal FROM test1 p,test2 c,t2 e WHERE e.job = p.job AND c.deptno = e.deptno ORDER BY 1,2,3,4;


WITH 
temp AS (SELECT job FROM t2 GROUP BY job),
test1 AS (SELECT e.job,COUNT(e.empno)cont FROM t2 e,temp p WHERE e.job = p.job GROUP BY e.job HAVING MIN(e.sal) > 1500),
test2 AS (SELECT e.deptno,AVG(e.sal)vsal FROM t2 e GROUP BY e.deptno)
SELECT /*+ parallel(5)*/e.ename,p.cont,p.job,c.vsal FROM test1 p,test2 c,t2 e WHERE e.job = p.job AND c.deptno = e.deptno ORDER BY 1,2,3,4;



WITH 
temp AS (SELECT job FROM t2 GROUP BY job),
test1 AS (SELECT e.job,COUNT(e.empno)cont FROM t2 e,temp p WHERE e.job = p.job GROUP BY e.job HAVING MIN(e.sal) > 1500),
test2 AS (SELECT e.deptno,AVG(e.sal)vsal FROM t2 e GROUP BY e.deptno)
SELECT  /*+no_rewrite*/e.ename,p.cont,p.job,c.vsal FROM test1 p,test2 c,t2 e WHERE e.job = p.job AND c.deptno = e.deptno ORDER BY 1,2,3,4;



WITH 
temp AS (SELECT deptno,job FROM t2 GROUP BY job,deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,e.sal FROM t2 e,(SELECT e.deptno,p.job,e.loc FROM t1 e,temp p WHERE e.deptno = p.deptno AND p.job IN (SELECT p.job FROM t5 e ,temp p WHERE e.deptno = p.deptno AND e.sal > 1500))p WHERE e.deptno = p.deptno AND e.sal >1500)
SELECT e.deptno,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno order by 1,2;


WITH 
temp AS (SELECT deptno,job FROM t2 GROUP BY job,deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,e.sal FROM t2 e,(SELECT e.deptno,p.job,e.loc FROM t1 e,temp p WHERE e.deptno = p.deptno AND p.job IN (SELECT p.job FROM t5 e ,temp p WHERE e.deptno = p.deptno AND e.sal > 1500))p WHERE e.deptno = p.deptno AND e.sal >1500)
SELECT /*+ parallel(5)*/e.deptno,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno order by 1,2;



WITH 
temp AS (SELECT deptno,job FROM t2 GROUP BY job,deptno ORDER BY deptno),
test1 AS (SELECT e.deptno,e.sal FROM t2 e,(SELECT e.deptno,p.job,e.loc FROM t1 e,temp p WHERE e.deptno = p.deptno AND p.job IN (SELECT p.job FROM t5 e ,temp p WHERE e.deptno = p.deptno AND e.sal > 1500))p WHERE e.deptno = p.deptno AND e.sal >1500)
SELECT  /*+no_rewrite*/e.deptno,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno;


WITH
temp AS (SELECT deptno  FROM t1 WHERE loc <> 'BoSton'),
test1 AS (SELECT e.deptno,p.ename,p.sal FROM temp e,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT MIN(e.sal) FROM t5 e,temp p WHERE e.deptno = p.deptno AND p.job = 'SALESMAN'))
SELECT p.deptno,e.ename,e.sal FROM test1 e,temp p WHERE e.deptno = p.deptno;

WITH
temp AS (SELECT deptno  FROM t1 WHERE loc <> 'BoSton'),
test1 AS (SELECT e.deptno,p.ename,p.sal FROM temp e,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT MIN(e.sal) FROM t5 e,temp p WHERE e.deptno = p.deptno AND p.job = 'SALESMAN'))
SELECT /*+ parallel(5)*/p.deptno,e.ename,e.sal FROM test1 e,temp p WHERE e.deptno = p.deptno order by 1,2,3;


WITH
temp AS (SELECT deptno  FROM t1 WHERE loc <> 'BoSton'),
test1 AS (SELECT e.deptno,p.ename,p.sal FROM temp e,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT MIN(e.sal) FROM t5 e,temp p WHERE e.deptno = p.deptno AND p.job = 'SALESMAN'))
SELECT  /*+no_rewrite*/p.deptno,e.ename,e.sal FROM test1 e,temp p WHERE e.deptno = p.deptno;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno),
test1 AS (SELECT p.loc,e.dept FROM temp e,t1 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT p.sal FROM temp e,t5 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT e.msal FROM t3 p,temp e WHERE e.dept = p.c1 ))),
test2 AS (SELECT e.msal,e.dept,(SELECT * FROM (SELECT AVG(e.sal)vsal FROM t5 e,temp p GROUP BY e.deptno,p.msal HAVING MAX(e.sal) > p.msal) as ddd order by vsal  LIMIT 1 ) vsal FROM temp e WHERE e.msal = (SELECT MAX(msal) FROM temp e GROUP BY e.msal HAVING e.msal > (SELECT msal FROM temp e WHERE msal = 950)))
SELECT c.dept,c.msal,e.loc,p.vsal FROM test1 e,test2 p,temp c WHERE e.dept = c.dept AND c.dept = p.dept ORDER BY 1,2,3,4;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno),
test1 AS (SELECT p.loc,e.dept FROM temp e,t1 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT p.sal FROM temp e,t5 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT e.msal FROM t3 p,temp e WHERE e.dept = p.c1  ))),
test2 AS (SELECT e.msal,e.dept,(SELECT * FROM (SELECT AVG(e.sal)vsal FROM t5 e,temp p GROUP BY e.deptno,p.msal HAVING MAX(e.sal) > p.msal) as ddd order by vsal LIMIT 1) vsal FROM temp e WHERE e.msal = (SELECT MAX(msal) FROM temp e GROUP BY e.msal HAVING e.msal > (SELECT msal FROM temp e WHERE msal = 950)))
SELECT /*+ parallel(5)*/c.dept,c.msal,e.loc,p.vsal FROM test1 e,test2 p,temp c WHERE e.dept = c.dept AND c.dept = p.dept ORDER BY 1,2,3,4;


WITH
temp(dept,msal) AS (SELECT deptno,MIN(sal) FROM t2 GROUP BY deptno),
test1 AS (SELECT p.loc,e.dept FROM temp e,t1 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT p.sal FROM temp e,t5 p WHERE e.dept = p.deptno AND e.msal < ANY(SELECT e.msal FROM t3 p,temp e WHERE e.dept = p.c1  ))),
test2 AS (SELECT e.msal,e.dept,(SELECT * FROM (SELECT AVG(e.sal)vsal FROM t5 e,temp p GROUP BY e.deptno,p.msal HAVING MAX(e.sal) > p.msal) as ddd order by vsal LIMIT 1)vsal FROM temp e WHERE e.msal = (SELECT MAX(msal) FROM temp e GROUP BY e.msal HAVING e.msal > (SELECT msal FROM temp e WHERE msal = 950)))
SELECT   /*+no_rewrite*/c.dept,c.msal,e.loc,p.vsal FROM test1 e,test2 p,temp c WHERE e.dept = c.dept AND c.dept = p.dept ORDER BY 1,2,3,4;


WITH
temp(dept,sal) AS (SELECT e.deptno,AVG(e.sal) FROM t2 e GROUP BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e ,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT e.sal FROM temp e WHERE e.dept IN (SELECT p.c1 FROM temp e,t3 p WHERE e.dept = p.c1 AND p.c1  = (SELECT e.deptno FROM t4 e,temp p WHERE e.deptno = p.dept AND e.loc = 'ChiCaGo' AND p.sal < (SELECT MAX(e.sal) FROM temp e WHERE dept = 1))))),
test2 AS (SELECT e.deptno,e.ename,e.job,p.sal FROM t2 e,temp p WHERE e.deptno = p.dept AND p.sal > (SELECT MIN(e.sal) FROM temp e,t5 p WHERE e.dept = p.deptno  GROUP BY p.deptno HAVING MIN(e.sal) > 2000) )
SELECT e.deptno,e.loc,e.job,p.ename,p.sal,c.sal FROM test1 e,test2 p,temp c WHERE e.deptno = c.dept AND c.dept = p.deptno  ORDER BY 1,2,3,4;

