CREATE TABLE t1(DEPTNO NUMERIC(2) PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13)) ;
CREATE TABLE t2(EMPNO NUMERIC(4) UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMERIC(4),HIREDATE DATE,SAL NUMERIC(7,2),COMM NUMERIC(7,2),DEPTNO NUMERIC(2));
CREATE TABLE t3(C1 NUMERIC(5,2),C2 NUMERIC(5,2),C3 VARCHAR(1),C4 NUMERIC,C5 VARCHAR(1),C6 VARCHAR(1),C7 NUMERIC,C8 VARCHAR(1));
CREATE UNIQUE INDEX index_1 ON t3(c6);
CREATE INDEX index_2 ON t3(c1);
