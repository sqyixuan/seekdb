WITH
temp(dept,sal) AS (SELECT e.deptno,AVG(e.sal) FROM t2 e GROUP BY e.deptno),
test1 AS (SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM t1 e ,t2 p WHERE e.deptno = p.deptno AND p.sal > (SELECT e.sal FROM temp e WHERE e.dept IN (SELECT p.c1 FROM temp e,t3 p WHERE e.dept = p.c1 AND p.c1  = (SELECT e.deptno FROM t4 e,temp p WHERE e.deptno = p.dept AND e.loc = 'ChiCaGo' AND p.sal < (SELECT MAX(e.sal) FROM temp e WHERE dept = 1))))),
test2 AS (SELECT e.deptno,e.ename,e.job,p.sal FROM t2 e,temp p WHERE e.deptno = p.dept AND p.sal > (SELECT MIN(e.sal) FROM temp e,t5 p WHERE e.dept = p.deptno  GROUP BY p.deptno HAVING MIN(e.sal) > 2000) )
SELECT  /*+no_rewrite*/e.deptno,e.loc,e.job,p.ename,p.sal,c.sal FROM test1 e,test2 p,temp c WHERE e.deptno = c.dept AND c.dept = p.deptno  ORDER BY 1,2,3,4;


#cte计划枚举 Left Deep Tree

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;

