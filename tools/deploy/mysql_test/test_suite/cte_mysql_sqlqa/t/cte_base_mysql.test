#cte单表包含EXISTS\NOT EXISTS

WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


WITH 
temp(dept,loc) AS (SELECT e.deptno,e.loc FROM t1 e WHERE EXISTS (SELECT * FROM t3 WHERE c6 IN ('t','f','l','s'))),
test1(deptno,name,job) AS (SELECT p.deptno,p.ename,p.job FROM t2 p WHERE NOT EXISTS (SELECT * FROM t5 WHERE job NOT IN ('SALESMAN','CLERK','MANAGER')))
SELECT /*+no_rewrite*/e.dept,e.loc,p.name,p.job FROM temp e,test1 p WHERE e.dept = p.deptno ORDER BY 1,2,3,4;


#cte单表包含BETWEEN AND\LIKE

WITH
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc LIKE '%a%' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.sal,p.job FROM t2 p WHERE p.sal BETWEEN 1000 AND 3000 ORDER BY 1)
SELECT e.deptno,e.loc,p.ename,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc LIKE '%a%' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.sal,p.job FROM t2 p WHERE p.sal BETWEEN 1000 AND 3000 ORDER BY 1)
SELECT e.deptno,e.loc,p.ename,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc LIKE '%a%' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.sal,p.job FROM t2 p WHERE p.sal BETWEEN 1000 AND 3000 ORDER BY 1)
SELECT /*+no_rewrite*/e.deptno,e.loc,p.ename,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


#cte单表包含AND\OR\NOT

WITH 
temp AS(SELECT e.deptno,e.loc FROM t1 e WHERE e.dname = 'SaLeS' OR loc = 'New York' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 p WHERE p.job NOT IN ('CLERK','PRESIDENT') AND p.sal > 1500 ORDER BY 1)
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH 
temp AS(SELECT e.deptno,e.loc FROM t1 e WHERE e.dname = 'SaLeS' OR loc = 'New York' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 p WHERE p.job NOT IN ('CLERK','PRESIDENT') AND p.sal > 1500 ORDER BY 1)
SELECT e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


WITH 
temp AS(SELECT e.deptno,e.loc FROM t1 e WHERE e.dname = 'SaLeS' OR loc = 'New York' ORDER BY 1),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 p WHERE p.job NOT IN ('CLERK','PRESIDENT') AND p.sal > 1500 ORDER BY 1)
SELECT /*+no_rewrite*/e.deptno,e.loc,p.ename,p.job,p.sal FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


#cte单表包含IS NULL\IS NOT NULL

WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
SELECT e.deptno,e.ename,e.sal,p.job,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1;

WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
SELECT /*+no_rewrite*/e.deptno,e.ename,e.sal,p.job,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1;


WITH
temp AS (SELECT e.deptno,e.ename,e.sal FROM t2 e WHERE e.ename IS NOT NULL AND e.comm IS NULL ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.job,p.mgr FROM t5 p WHERE p.empno IS NOT NULL AND p.comm IS NULL ORDER BY 1)
SELECT e.deptno,e.ename,e.sal,p.job,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1;


#cte单表包含比较条件

WITH 
temp AS (SELECT e.c1,e.c3,e.c6 FROM t3 e WHERE e.c3 = 'i' OR e.c6 <> 'q' ORDER BY e.c1),
test1 AS (SELECT p.deptno,p.ename,p.job,p.sal FROM t2 p WHERE p.sal < 3000 AND p.comm > 0 ORDER BY 1),
test2 AS (SELECT c.deptno,c.loc FROM t1 c WHERE c.dname != 'ReSeaRch' AND c.loc != 'BoSton'  ORDER BY 1),
test3 AS (SELECT d.deptno,d.job,d.comm FROM t5 d WHERE d.sal >= 500 AND d.comm < 1000 ORDER BY 1)
SELECT p.deptno,e.c3,e.c6,p.ename,p.job,p.sal,c.loc,d.comm FROM temp e,test1 p,test2 c,test3 d WHERE e.c1 = p.deptno AND p.job = d.job AND d.deptno = c.deptno ORDER BY 1,2,3,4;


