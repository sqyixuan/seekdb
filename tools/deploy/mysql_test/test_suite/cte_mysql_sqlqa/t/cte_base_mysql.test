CREATE INDEX index_4 ON t6(c1);
INSERT INTO t6 SELECT * FROM t3 LIMIT 6;


--echo cte-1-1 语法要求
--echo cte-1-1-1 RECURSIVE关键字可选
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;

WITH RECURSIVE
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
test1 AS (SELECT p.deptno,p.ename,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.ename,p.job FROM temp e,test1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3,4;


--echo cte cte-1-1-2个数校验
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno)
SELECT e.deptno,e.loc FROM temp e ORDER BY 1,2;


WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e,temp1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3;

WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno),
temp2 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e left join temp1 p on e.deptno = p.deptno left join temp2 q on e.deptno=q.deptno ORDER BY 1,2,3;

--echo cte-1-1-3 子查询部分校验

WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno)
SELECT e.deptno,e.loc FROM temp e ORDER BY 1,2;


--echo cte-1-1-4 WITH同级别唯一子句校验
--error 0,1064
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno)
WITH
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e,temp1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3;



--echo cte-1-1-5  cte_name唯一校验
--echo 37501730- 【CTE-mysql】If the CTE name is the same, the OB error code is 1054 ，the MySQL error code is 1066
--error 0,1066
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e,temp p WHERE e.deptno = p.deptno ORDER BY 1,2,3;


WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e,temp1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3;

--echo cte-1-1-6 cte定义列数与子查询中列数比较
--error 0,1353
WITH cte (col1) AS
(
  SELECT 1, 2
  UNION ALL
  SELECT 3, 4
)
SELECT col1, col2 FROM cte;
--error 0,1353
WITH cte (col1,col2,col3) AS
(
  SELECT 1, 2
  UNION ALL
  SELECT 3, 4
)
SELECT col1, col2,col3 FROM cte;


WITH cte AS
(
  SELECT 1 AS col1, 2 AS col2
  UNION ALL
  SELECT 3, 4
)
SELECT col1, col2 FROM cte;


--echo cte-1-1-7 子查询中嵌套CTE
WITH 
temp2 AS (
WITH 
temp AS (SELECT e.deptno,e.loc FROM t1 e WHERE e.loc IN ('New York','ChiCaGo') ORDER BY e.deptno),
temp1 AS (SELECT p.deptno,p.job FROM t2 p WHERE p.job NOT IN ('CLERK','ANALYST') ORDER BY p.deptno)
SELECT e.deptno,e.loc,p.job FROM temp e,temp1 p WHERE e.deptno = p.deptno ORDER BY 1,2,3
)
select e.deptno,e.loc,e.loc FROM temp2 e;


