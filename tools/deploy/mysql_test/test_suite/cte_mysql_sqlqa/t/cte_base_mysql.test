# SELECT /*+ parallel(5)*/DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+no_rewrite*/DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


#LEFT Deep Tree hash JOIN 
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT /*+ ordered use_hash(test1,test2,test3) */DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;



#LEFT Deep nest LOOP 

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT /*+ ordered use_nl(test1,test2,test3) */DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


#cte计划枚举Right Deep Tree

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT /*+ leading (test3 test2 test1 temp)use_nl(test2) swap_join_inputs(test2)use_nl(test1) swap_join_inputs(test1)use_nl(temp) swap_join_inputs(temp)*/DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


#cte计划枚举Right Deep Tree
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT /*+ leading (test3 test2 test1 temp)use_hash(test2) swap_join_inputs(test2)use_hash(test1) swap_join_inputs(test1)use_hash(temp) swap_join_inputs(temp)*/DISTINCT e.deptno,e.loc,p.empno,p.mgr,c.c7,c.c8,d.c6,d.c4,d.dname  FROM temp e,test1 p,test2 c,test3 d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno ORDER BY 1,2,3,4;


#cte计划枚举Bushy Tree

WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+ ordered use_hash(b) */a.* FROM (SELECT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,(SELECT c.deptno,c.c8,d.c6,d.c4,d.dname FROM test2 c,test3 d WHERE c.deptno = d.deptno)b WHERE a.deptno = b.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+ ordered use_nl(b) */a.* FROM (SELECT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,(SELECT c.deptno,c.c8,d.c6,d.c4,d.dname FROM test2 c,test3 d WHERE c.deptno = d.deptno)b WHERE a.deptno = b.deptno ORDER BY 1,2,3,4;




#cte Deep Tree
WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+ ordered use_hash(d) */c.* FROM (SELECT a.deptno,a.loc,a.empno,a.mgr,b.c8,b.c7 FROM (SELECT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,test2 b WHERE a.deptno = b.deptno)c,test3 d WHERE c.deptno = d.deptno ORDER BY 1,2,3,4;


WITH
temp AS (SELECT e.deptno,e.loc,p.ename,p.job FROM t1 e,t5 p WHERE e.deptno = p.deptno AND p.sal > 1000 ORDER BY 1,2,3,4),
test1 AS (SELECT e.deptno,e.empno,e.mgr,c.dname FROM t2 e,t2 p,t1 c WHERE e.mgr = p.empno AND p.deptno = c.deptno AND p.sal < 4000 ORDER BY 1,2,3,4),
test2 AS (SELECT e.c7,e.c8,p.deptno,p.loc FROM t3 e,temp p WHERE e.c1 = p.deptno AND e.c7 IS NOT NULL ORDER BY 1,2,3,4),
test3 AS (SELECT p.deptno,e.c6,e.c4,p.dname  FROM t6 e,test1 p WHERE e.c1 = p.deptno AND c7 IS NULL AND NOT EXISTS(SELECT * FROM test2 WHERE deptno = 4) ORDER BY 1,2,3,4)
SELECT  /*+ ordered use_nl(d) */ c.* FROM (SELECT a.deptno,a.loc,a.empno,a.mgr,b.c8,b.c7 FROM (SELECT e.deptno,e.loc,p.empno,p.mgr FROM temp e,test1 p WHERE e.deptno = p.deptno)a,test2 b WHERE a.deptno = b.deptno)c,test3 d WHERE c.deptno = d.deptno ORDER BY 1,2,3,4;




