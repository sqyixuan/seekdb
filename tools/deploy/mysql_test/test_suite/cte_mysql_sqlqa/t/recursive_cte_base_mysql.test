UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c right join temp r on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo #inner join 引用对象在左边
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM  temp r  inner join t_2 c on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;

--echo #inner join 引用对象在右边
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c inner join temp r on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;



--echo #natural join 引用对象在左边
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =46
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM temp r  natural join t_2 c WHERE  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;

--echo #natural join 引用对象在右边
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =46
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c natural join temp r WHERE  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo # WHERE 子查询中引用对象
--error 0,3577
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =81
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid and c.product_count =(SELECT product_count FROM temp)
) SELECT * FROM temp order by cat_id;

--echo # WHERE 子查询对象是普通表
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =81
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid and c.product_count =(SELECT max(product_count) FROM t_2)
) SELECT * FROM temp order by cat_id;




