--echo #只能在其FROM子句中引用

--echo #left join 引用对象在左边
--error 0,3636
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM temp r left join  t_2 c  on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;

--echo #left join 引用对象在右边
--error 0,3576 
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM  t_2 c left join temp r  on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo #right join 引用对象在左边
--error 0,3576
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM temp r right join  t_2 c on  c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;

--echo #right join 引用对象在右边
