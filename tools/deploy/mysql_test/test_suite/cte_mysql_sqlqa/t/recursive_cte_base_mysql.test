--echo # ORDER BY OB支持
WITH RECURSIVE my_cte AS
(
  SELECT 1 AS n
  UNION ALL
  SELECT 1+n FROM my_cte  where n<10 ORDER BY n
)
SELECT * FROM my_cte;


