--echo cte-2-1递归cte语法校验
--echo cte-2-1-1 RECURSIVE关键字必填
--echo 37502128- 【CTE-mysql】 Recursive keyword of recursive CTE is required
--error 0,1146
with temp AS
(
SELECT cat_id,parent_cid,name FROM t_2 WHERE cat_id =81
UNION ALL
SELECT c.cat_id,c.parent_cid,c.name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo #cte-2-1-2 连接谓词
--echo #UNION ALL
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,name FROM t_2 WHERE cat_id =81
UNION ALL
SELECT c.cat_id,c.parent_cid,c.name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo #UNION  预期支持，目前不支持
--error 0,1235
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,name FROM t_2 WHERE cat_id =81
UNION 
SELECT c.cat_id,c.parent_cid,c.name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;
 
--echo #UNION DISTINCT  预期支持，目前不支持
--error 0,1235
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,name FROM t_2 WHERE cat_id =81
UNION DISTINCT
SELECT c.cat_id,c.parent_cid,c.name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;


--echo #cte-2-1-3  非递归查询部分不能引用自身
--error 0,3574
WITH RECURSIVE my_cte(n) AS
(
  SELECT 1+n FROM my_cte WHERE n<10
  UNION ALL
  SELECT 1 AS n
)
SELECT * FROM my_cte;



--echo #cte-2-1-4 递归查询部分只能引用一次
--echo #单次引用
WITH RECURSIVE temp AS
(
SELECT cat_id,parent_cid,cast(name as char(1000)) as name FROM t_2 WHERE cat_id =63
UNION ALL
SELECT c.cat_id,c.parent_cid,CONCAT(r.name, '>', c.name) as name FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid
) SELECT * FROM temp order by cat_id;

