--echo #cte-2-1-6 非递归部分、where 子查询可包含窗口函数


WITH RECURSIVE temp AS
(
SELECT count(t.cat_id) as a,t.name,t.parent_cid,t.product_count FROM t_2 t GROUP BY cat_level,cat_id HAVING (sum(product_count)<500)
UNION ALL
SELECT c.cat_id as a,c.name,c.parent_cid,c.product_count FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid 
) SELECT * FROM temp group by a,name,parent_cid order by 1,2,3,4;


WITH RECURSIVE temp AS
(
SELECT t.cat_id,t.name,t.parent_cid,t.product_count FROM t_2 t GROUP BY cat_level,product_count HAVING (sum(product_count)>500)
UNION ALL
SELECT c.cat_id,c.name,c.parent_cid,c.product_count FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid 
) SELECT * FROM temp;


WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid 
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4 limit 5;



WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c,temp r WHERE c.cat_id=r.parent_cid  and 
c.cat_id in (
select cat_id from t_1 GROUP BY product_time HAVING ( max(product_time)>'1988-04-07')order by cat_id)
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4;

--echo # cte-2-1-7 非递归和递归查询部分分别由多个查询联合
--echo # 递归查询部分由多个查询联合

WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c RIGHT JOIN temp r ON  c.cat_id=r.parent_cid  LEFT JOIN t_1 ON r.parent_cid=c.cat_id WHERE   
c.cat_id in (
select cat_id from t_1 GROUP BY product_time HAVING ( max(product_time)>'1988-04-07')order by cat_id)
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4;


WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(100)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c INNER JOIN temp r ON  c.cat_id=r.parent_cid  WHERE   
c.cat_id NOT IN (
select cat_id from t_1 GROUP BY product_time HAVING ( MIN(product_time)>='1988-04-07')order by cat_id)
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4;


WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id NOT IN (
select cat_id from t_1 GROUP BY product_time HAVING ( MIN(product_time)>='1988-04-07')order by cat_id)
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4;



--echo # 非递归查询部分由多个查询联合

WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t LEFT JOIN t_1 k ON t.cat_id=k.cat_id GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id NOT IN (
select cat_id from t_1 GROUP BY product_time HAVING ( MIN(product_time)>='1988-04-07')order by cat_id) 
) SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r order by 1,2,3,4;

WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t LEFT JOIN t_1 a ON t.cat_id=a.cat_id GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id) 
)
SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r RIGHT JOIN t_1 a on r.cat_id=a.cat_id order by ISNULL(r.cat_id) limit 2;

WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name  ,t.parent_cid,avg(t.product_count) a ,max(t.product_count) b FROM t_2 t LEFT JOIN t_1 a ON t.cat_id=a.cat_id GROUP BY t.cat_level HAVING (min(t.product_count)=10) 
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,c.parent_cid,c.product_count,1 FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id) 
)
SELECT r.cat_id,r.name,r.parent_cid,r.a,r.b FROM temp r LEFT JOIN t_1 a on r.cat_id=a.cat_id order by ISNULL(r.cat_id) limit 2;

WITH RECURSIVE temp AS
(
SELECT distinct t.cat_id,cast(t.name as char(1000)) name ,sum(t.product_count) sum_count ,t.parent_cid ,c.prices,c.num FROM t_2 t RIGHT JOIN t_1 a ON t.cat_id=a.cat_id INNER JOIN t_3 c ON a.num=c.num GROUP BY t.cat_level  
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,1,c.parent_cid,r.prices,r.num FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND   
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id) 
)
SELECT sum(r.prices)*sum(sum_count) FROM temp r;

--error 0,1051
DROP TABLE t_1;
--error 0,1051
DROP TABLE t_2;
--error 0,1051
DROP TABLE t_3;

--echo #end释放空间、断开连接、删除用户
--enable_warnings
purge recyclebin;
connection default;
--error 0,1008
drop database zhe123;
--error 0,600
drop user zhe123;
--enable_warnings
