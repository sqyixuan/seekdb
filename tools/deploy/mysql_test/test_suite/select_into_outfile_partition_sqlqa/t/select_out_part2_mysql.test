eval select /*+parallel(6)*/ a,count(b),row_number() over (order by c) c1 from zct1 t group by a having a < 6 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',b)  FIELDS TERMINATED BY '    | '  single = FALSE  ;
