# description: test select into outfile partition by

--result_format 4
--enable_sorted_result

--source mysql_test/include/oss_config_for_import.inc

let $RANDOM_NUM=query_get_value(select abs(random()) ran from dual,ran,1);
let $DATA_FOLDER_NAME = antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/outfile_partition_$RANDOM_NUM;

--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump_oss.inc

connection default;
--disable_query_log
--error 0,1051
drop table zct1;
--error 0,1051
drop table zct2;
--error 0,1051
drop table zct3;
--enable_query_log

let $FILE_PREFIX = par;
####分区导出from不同类型的表####
####常规表
create table zct1(a int, b varchar(5), c date, d datetime, e timestamp, f time, g year, h blob, i text, j float, k double, l decimal(5, 2), m bigint);
insert into zct1 values(1, 'a', '2020-01-01', '2020-01-01 00:00:00', '2020-01-01 00:00:00', '00:00:00', 2020, 'blob', 'text', 1.1, 2.2, 3.3, 1 );
insert into zct1 values(2, 'b', '2020-01-02', '2020-01-02 00:00:00', '2020-01-02 00:00:00', '00:00:01', 2021, 'blob', 'text', 2.1, 3.2, 4.3, 2 );
insert into zct1 values(3, 'c', '2020-01-03', '2020-01-03 00:00:00', '2020-01-03 00:00:00', '00:00:02', 2022, 'blob', 'text', 3.1, 4.2, 5.3, 3 );
insert into zct1 values(4, 'd', '2020-01-04', '2020-01-04 00:00:00', '2020-01-04 00:00:00', '00:00:03', 2023, 'blob', 'text', 4.1, 5.2, 6.3, 4 );
insert into zct1 values(5, 'e', '2020-01-05', '2020-01-05 00:00:00', '2020-01-05 00:00:00', '00:00:04', 2024, 'blob', 'text', 5.1, 6.2, 7.3, 5 );
##index
alter table zct1 add index idx_a(a);

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

alter table zct1 add index idx_zct1(a,b);

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a,b)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

alter table zct1 add index idx_zct1_eachcol(a,b,c) WITH COLUMN GROUP(each column);

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a,b,c)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 where a>1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
