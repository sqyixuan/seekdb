--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(6)*/ b,count(a),row_number() over (order by c) c1 from zct1 t group by b with rollup having b is not null into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',b)  FIELDS TERMINATED BY '    | '  single = FALSE  ;
