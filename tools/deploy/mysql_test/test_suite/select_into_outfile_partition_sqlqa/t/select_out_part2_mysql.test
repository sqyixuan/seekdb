--error 0,1051
drop table zct1_for;
create table zct1_for(a int, b varchar(5) ,primary key( a));
insert into zct1_for values( 1, 'a'), (2, 'b'), (3, 'c'), (4, 'd'), (5, 'e');

alter table zct1 add constraint zct1_a_for foreign key(a) references zct1_for(a);

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

##primary
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3) INDEX(zct1_for PRIMARY)*/ * from zct1_for where a > 1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',a)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

##AUTO_INCREMENT
alter table zct1 add ai int AUTO_INCREMENT COMMENT 'auto increment' first;

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3) INDEX(zct1_for PRIMARY)*/ * from zct1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',ai)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

##生成列
alter table zct1 add gc int GENERATED ALWAYS AS (a+b) VIRTUAL;

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zct1 t into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',t.gc)   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc


####视图
create view zcv1 as select a,b,c,d,e,f,g from zct1;

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zcv1 v into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',mod(v.a,2))   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

drop view zcv1;

##mv
CREATE MATERIALIZED VIEW LOG ON zct1 parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(a)INCLUDING NEW VALUES;
set mview_refresh_dop = 1;
create materialized view ZC_MV1 REFRESH FORCE ON DEMAND enable query rewrite AS
select a,b,c,d,e,f,g from zct1 ZT1;

insert into zct1_for(a) values(6);
insert into zct1(a) values(6);
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from zc_mv1 v into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',mod(v.a,2))   single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc

drop MATERIALIZED VIEW LOG ON zct1;
drop MATERIALIZED VIEW ZC_MV1;

