--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(6)*/* from zct1 t where a <> 6 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY (case t.a when 1 then 'par1' when 2 then 'par2' else 'par0' end)  FIELDS TERMINATED BY '    | '  single = FALSE  ;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
