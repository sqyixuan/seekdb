##24576行数据共6.65MB大小文件，par_-1分区1642个文件，par_1分区1642个文件，__NULL__分区485个文件，验证通过，单个文件大小1890.00B左右，验证通过
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2) QUERY_TIMEOUT(1000000000000)*/ * from zct2 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',c1) FIELDS TERMINATED BY ' ' OPTIONALLY ENCLOSED BY  '"' LINES  TERMINATED BY '\n'  single = FALSE MAX_FILE_SIZE = '2KB' ;
