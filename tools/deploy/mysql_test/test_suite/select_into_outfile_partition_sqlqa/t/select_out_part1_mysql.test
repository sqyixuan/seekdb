# owner: linyi.cl
# owner group: 技术部-SQL-优化器
# tags: external_table
# description: test select into outfile partition by

--result_format 4

--source mysql_test/include/oss_config_for_import.inc

let $RANDOM_NUM=query_get_value(select abs(random()) ran from dual,ran,1);
let $DATA_FOLDER_NAME = antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/outfile_partition_$RANDOM_NUM;

--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump_oss.inc

--error 0,1051
drop table t1;
CREATE table t1(c1 int,c2 varchar(50),c3 DATE);
INSERT INTO t1 VALUES(1,'a','0001-01-01');
INSERT INTO t1 VALUES(2,'b','0002-02-02');
INSERT INTO t1 VALUES(3,'c','0003-03-03');

let $FILE_PREFIX = t1;
--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/t1?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY';
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc

--error 0,1051
drop table ex_t1;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval create external table ex_t1 (c1 int,c2 varchar(50),c3 date)
location= 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@cn-heyuan-alipay-b.oss-alipay.aliyuncs.com/$DATA_FOLDER_NAME/'
format ( type = 'csv' LINE_DELIMITER = '\n') PATTERN = 't1'
;

select * from ex_t1;

--error 0,1051
drop table ex_t1;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc


####partition_expr####
let $FILE_PREFIX = par;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par_',c2) single = FALSE;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_files_oss.inc

--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' PARTITION BY concat('par',cast(c1 as char)) single = FALSE;
--source mysql_test/test_suite/select_into_outfile_partition_sqlqa/include/cat_dir_oss.inc
--source mysql_test/include/select_into_outfile/delete_files_oss.inc

