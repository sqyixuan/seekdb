CREATE TABLE if not exists `couponlimit` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmtcreatetime` datetime NOT NULL COMMENT '创建时间',
`gmtmodifytime` datetime NOT NULL COMMENT '修改时间',
`couponid` bigint(20) unsigned NOT NULL COMMENT '优惠券ID',
`getdate` datetime NOT NULL COMMENT '发放日期',
`count` bigint(20) unsigned NOT NULL COMMENT '已发放数量',
`gmtcreateuser` varchar(100) NOT NULL COMMENT '创建用户',
`gmtmodifyuser` varchar(100) NOT NULL COMMENT '最后修改用户',
PRIMARY KEY (`id`),
UNIQUE KEY `coupon_get_date` (`couponid`,`getdate`)
)  AUTO_INCREMENT=2084 ,DEFAULT CHARSET=utf8 ,COMMENT='用于控制每个优惠券每天的领取个数. (注意: 因为领取是在UMP方, 所以这里做控制无法做到100%无遗漏. 会有超发的情况. 业务方接受)';
CREATE TABLE if not exists `history` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmtcreatetime` datetime NOT NULL COMMENT '创建时间',
`userid` bigint(20) unsigned NOT NULL COMMENT '用户ID',
`nick` varchar(50) NOT NULL COMMENT '用户昵称',
`type` varchar(50) NOT NULL COMMENT '操作类型',
`msg` varchar(1000) NOT NULL COMMENT '日志',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=7971953 ,DEFAULT CHARSET=utf8 ,COMMENT='做为日志记录. 记录用户的涉及积分变化/优惠券领取的操作.';
CREATE TABLE if not exists `market_c2b` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户Id',
`solutions` varchar(100) NOT NULL COMMENT '用户方案',
`pre_pay` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '预付金额',
`user_nick` varchar(100) NOT NULL COMMENT '用户昵称',
`type` varchar(10) NOT NULL COMMENT '定制类型',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0:新建 1 已完成提交,-1 丢弃',
PRIMARY KEY (`id`),
KEY `select_index` (`user_id`,`type`,`status`)
)  AUTO_INCREMENT=19306 ,DEFAULT CHARSET=utf8 ,COMMENT='c2b';
CREATE TABLE if not exists `meeting` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(100) NOT NULL COMMENT '会议名称',
`gmt_start` datetime NOT NULL COMMENT '会议开始时间',
`gmt_end` datetime NOT NULL COMMENT '会议结束时间',
`location` varchar(50) NOT NULL COMMENT '会议地点',
`number` bigint(20) NOT NULL COMMENT '人数',
`promoter_id` bigint(20) NOT NULL COMMENT '发起人id',
`promoter_nick` varchar(50) NOT NULL COMMENT '发起人名称',
`sub_type` varchar(100) DEFAULT 'default' COMMENT '子类型',
`info_config` varchar(500) NOT NULL COMMENT '收集信息配置',
`status` int(11) NOT NULL DEFAULT '1' COMMENT '会议状态',
PRIMARY KEY (`id`),
KEY `status` (`status`)
)  AUTO_INCREMENT=7 ,DEFAULT CHARSET=utf8 ,COMMENT='代表一个招商会议';
CREATE TABLE if not exists `merchant` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`meeting_id` bigint(20) NOT NULL COMMENT '会议id',
`sub_type` varchar(100) NOT NULL DEFAULT 'default' COMMENT '子类型',
`info` varchar(500) NOT NULL COMMENT '商家信息',
PRIMARY KEY (`id`),
KEY `meeting_id` (`meeting_id`),
KEY `sub_type` (`sub_type`)
)  AUTO_INCREMENT=400 ,DEFAULT CHARSET=utf8 ,COMMENT='商家表';
CREATE TABLE if not exists `point` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmtcreatetime` datetime NOT NULL COMMENT '创建时间',
`gmtmodifytime` datetime NOT NULL COMMENT '修改时间',
`userid` bigint(20) unsigned NOT NULL COMMENT '用户id',
`nick` varchar(50) NOT NULL COMMENT '用户昵称',
`lastsignindate` datetime NOT NULL COMMENT '用户上一次签到时间',
`point` bigint(20) unsigned NOT NULL COMMENT '用户当前积分',
`gmtcreateuser` varchar(50) DEFAULT NULL COMMENT '创建用户',
`gmtmodifyuser` varchar(50) DEFAULT NULL COMMENT '最后修改用户',
PRIMARY KEY (`id`),
UNIQUE KEY `userid` (`userid`)
)  AUTO_INCREMENT=296050 ,DEFAULT CHARSET=utf8 ,COMMENT='用户签到积分表';
CREATE TABLE if not exists `system_evaluation` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '系???估 Id',
`gmt_create` datetime NOT NULL COMMENT '建??',
`gmt_modified` datetime NOT NULL COMMENT '修???',
`car_id` bigint(20) unsigned NOT NULL COMMENT '稷汽车 Id',
`price` decimal(10,0) NOT NULL COMMENT '价格',
`status` int(11) NOT NULL COMMENT '// 价格 0. 系???? 1. 汽车太?? 2.???误,3. 正确 ? 0. 样 1. ?',
`source` int(11) DEFAULT '0' COMMENT '来源，默认是0
0：pc 1.手淘 2.闲鱼',
PRIMARY KEY (`id`),
KEY `envaluation_id_index` (`car_id`),
KEY `draw_index` (`car_id`,`gmt_modified`),
KEY `date_index` (`gmt_modified`),
KEY `price_index` (`price`)
)  AUTO_INCREMENT=3306485 ,DEFAULT CHARSET=utf8 ,COMMENT='系???估';
CREATE TABLE if not exists `tb_car` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主?',
`gmt_create` datetime NOT NULL COMMENT '建??',
`gmt_modified` datetime NOT NULL COMMENT '修???',
`brand_pid` bigint(20) unsigned NOT NULL COMMENT '??Pid',
`brand_vid` bigint(20) unsigned NOT NULL COMMENT '??Vid',
`brand_name` varchar(2000) NOT NULL COMMENT '???称',
`serial_pid` bigint(20) unsigned NOT NULL COMMENT '车系Pid',
`serial_vid` bigint(20) unsigned NOT NULL COMMENT '车系Vid',
`serial_name` varchar(2000) NOT NULL COMMENT '车系?称',
`year_pid` bigint(20) unsigned NOT NULL COMMENT '年款Pid',
`year_vid` bigint(20) unsigned NOT NULL COMMENT '年款Vid',
`year_name` varchar(2000) NOT NULL COMMENT '年款?称',
`model_pid` bigint(20) unsigned NOT NULL COMMENT '车?Pid',
`model_vid` bigint(20) unsigned NOT NULL COMMENT '车?Vid',
`model_name` varchar(2000) NOT NULL COMMENT '车??称',
`car_id` bigint(20) unsigned NOT NULL COMMENT '汽车Id',
`buy_year` int(11) NOT NULL COMMENT '购买年份',
`price_info` varchar(2000) NOT NULL COMMENT '?估价格Json',
PRIMARY KEY (`id`),
KEY `index_key` (`brand_vid`,`serial_vid`,`year_vid`,`model_vid`,`buy_year`)
)  AUTO_INCREMENT=25359 ,DEFAULT CHARSET=utf8 ,COMMENT='??汽车??';
CREATE TABLE if not exists `user_car` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主?',
`gmt_create` datetime NOT NULL COMMENT '建??',
`gmt_modified` datetime NOT NULL COMMENT '修???',
`bvid` bigint(20) unsigned NOT NULL COMMENT '??',
`svid` bigint(20) unsigned NOT NULL COMMENT '车系',
`yvid` bigint(20) unsigned NOT NULL COMMENT '年款',
`mvid` bigint(20) unsigned NOT NULL COMMENT '车?',
`province_city` varchar(50) NOT NULL COMMENT '?份:???',
`buy_date` varchar(20) NOT NULL COMMENT '购买??? YYYY-MM',
`user_id` bigint(20) unsigned NOT NULL COMMENT '稷Id',
`archives` tinyint(4) NOT NULL COMMENT '???汽车档',
`bpid` bigint(20) unsigned NOT NULL COMMENT '??vid',
`spid` bigint(20) unsigned NOT NULL COMMENT '车系pid',
`ypid` bigint(20) unsigned NOT NULL COMMENT '年款pid',
`mpid` bigint(20) unsigned NOT NULL COMMENT '车?pid',
`mileage` int(11) NOT NULL COMMENT '?驶??',
PRIMARY KEY (`id`),
KEY `index_key` (`bvid`,`svid`,`yvid`,`mvid`,`province_city`,`buy_date`,`user_id`),
KEY `user_car_index` (`id`,`user_id`)
)  AUTO_INCREMENT=3286846 ,DEFAULT CHARSET=utf8 ,COMMENT='稷?估?车?';
CREATE TABLE if not exists `user_inquiry` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主?',
`gmt_create` datetime NOT NULL COMMENT '建??',
`gmt_modified` datetime NOT NULL COMMENT '修???',
`seller_id` bigint(20) unsigned NOT NULL COMMENT '?家id',
`seller_phone` bigint(20) unsigned DEFAULT NULL COMMENT '????',
`system_envaluation_id` bigint(20) unsigned NOT NULL COMMENT '系???估Id',
`status` int(11) NOT NULL COMMENT '?价???',
`buyer_id` bigint(20) unsigned NOT NULL COMMENT '???_id',
`gmt_commit` datetime DEFAULT NULL COMMENT '?约????',
`gmt_contact` datetime DEFAULT NULL COMMENT '???车',
`gmt_deal` datetime DEFAULT NULL COMMENT '达交?',
`gmt_cancel` datetime DEFAULT NULL COMMENT '???订?',
`price` decimal(10,0) NOT NULL COMMENT '询价?价格',
`seller_comment` varchar(2000) DEFAULT NULL COMMENT '?家?注',
`buyer_comment` varchar(2000) DEFAULT NULL COMMENT '????注',
`gmt_envaluate` datetime DEFAULT NULL COMMENT '估价??',
`division_id` bigint(20) unsigned DEFAULT NULL COMMENT '??Id',
`order_id` varchar(30) DEFAULT NULL COMMENT '订?Id',
`seller_name` varchar(50) NOT NULL COMMENT '?家?称',
`seller_nick` varchar(50) NOT NULL COMMENT '?家?称',
`buyer_name` varchar(50) NOT NULL COMMENT '????称',
`buyer_nick` varchar(50) NOT NULL COMMENT '????称',
`province` varchar(50) DEFAULT NULL COMMENT '?份',
`city` varchar(50) DEFAULT NULL COMMENT '???',
`town` varchar(50) DEFAULT NULL COMMENT '????????',
`bstatus` int(11) NOT NULL COMMENT '?估??????????',
PRIMARY KEY (`id`),
KEY `join_key` (`seller_id`,`buyer_id`,`system_envaluation_id`,`status`),
KEY `seller_key` (`seller_id`,`status`),
KEY `evaluation_key` (`status`,`system_envaluation_id`),
KEY `idx_bidstagmt` (`buyer_id`,`status`,`gmt_create`)
)  AUTO_INCREMENT=630889 ,DEFAULT CHARSET=utf8 ,COMMENT='稷询价?';
