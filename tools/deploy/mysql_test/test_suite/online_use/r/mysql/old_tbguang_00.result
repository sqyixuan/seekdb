`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`source_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '动作发出者用户id',
`album_id` bigint(20) unsigned DEFAULT NULL COMMENT '专辑id',
`action` tinyint(4) DEFAULT NULL COMMENT '动作。2-被喜欢，4-被加入专辑，5-发布加专辑',
`status` tinyint(4) DEFAULT NULL COMMENT '状态 0删除 1正常',
`target_user_id` bigint(20) unsigned DEFAULT NULL COMMENT '资源的拥有者id',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_sid_uid_action` (`user_id`,`source_id`,`album_id`,`action`),
KEY `idx_sid_status` (`source_id`,`status`,`gmt_modified`)
)  AUTO_INCREMENT=606148 ,DEFAULT CHARSET=utf8 ,COMMENT='泛p维度的关系表0';
