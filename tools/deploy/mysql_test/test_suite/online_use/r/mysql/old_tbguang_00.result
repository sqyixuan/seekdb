`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`group_id` bigint(20) unsigned NOT NULL COMMENT '分表字段，需要全局唯一',
`type` tinyint(4) DEFAULT NULL COMMENT '群类型，0，正常 1，达人导入',
`background` varchar(256) DEFAULT NULL COMMENT '群背景图片url，相对地址',
`status` tinyint(4) DEFAULT NULL COMMENT '状态，0：待审核，1：审核通过，2：审核不通过 ，3：删除',
`attributes` varchar(1024) DEFAULT NULL COMMENT '扩展属性',
`creator_id` bigint(20) unsigned DEFAULT NULL COMMENT '创建者用户id',
`style` tinyint(4) DEFAULT NULL COMMENT '风格',
`group_name` varchar(128) DEFAULT NULL COMMENT '群名称',
PRIMARY KEY (`id`),
KEY `idx_group` (`group_id`)
)  AUTO_INCREMENT=5 ,DEFAULT CHARSET=utf8 ,COMMENT='群表信息';
