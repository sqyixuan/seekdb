CREATE TABLE if not exists `agj_sources_0000` (
`source_id` bigint(20) unsigned NOT NULL COMMENT '主键,全局序列',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`type` tinyint(4) DEFAULT NULL COMMENT '泛p类型：图片、商品',
`source_from` tinyint(4) DEFAULT NULL COMMENT '泛p来源',
`user_nick` varchar(64) DEFAULT NULL COMMENT 'snsnick或uicnick',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`cat_id` int(11) DEFAULT NULL COMMENT '所属前台类目id',
`privacy` tinyint(4) DEFAULT NULL COMMENT '隐私字段',
`descript` varchar(512) DEFAULT NULL COMMENT '描述',
`tags` varchar(128) DEFAULT NULL COMMENT '标签',
`attributes` varchar(512) DEFAULT NULL COMMENT '属性扩展kv',
`seq_no` int(11) DEFAULT NULL COMMENT '分表序列 预留',
PRIMARY KEY (`source_id`),
KEY `idx_uid_stat_from` (`user_id`,`status`,`source_from`),
KEY `idx_uid_sid` (`user_id`,`source_id`,`gmt_create`)
)  DEFAULT CHARSET=utf8 ,COMMENT='泛p主表-';
