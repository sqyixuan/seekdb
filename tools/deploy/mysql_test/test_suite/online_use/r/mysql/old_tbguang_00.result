CREATE TABLE if not exists `agj_user_tag` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户ID',
`user_nick` varchar(64) NOT NULL COMMENT '用户昵称',
`user_tag` varchar(128) NOT NULL COMMENT '用户标签',
`status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '用户状态',
PRIMARY KEY (`id`),
KEY `idx_userid` (`user_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='用户标签表';
