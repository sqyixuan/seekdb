CREATE TABLE if not exists `agj_relation_album_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`album_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`target_id` bigint(20) unsigned NOT NULL COMMENT '关系对象id，泛p/用户id',
`target_type` tinyint(4) NOT NULL COMMENT '1:泛p，3，用户',
`target_user_id` bigint(20) unsigned DEFAULT NULL COMMENT '如果是泛p则表示拥有者id，如果是用户，则=target_id',
`action` tinyint(4) DEFAULT NULL COMMENT '关系的动作，3：被关注，4：资源被转采到',
`status` tinyint(4) DEFAULT '1' COMMENT '状态，0-删除 ，1-正常',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_aid_target_action` (`album_id`,`target_id`,`action`,`target_type`),
KEY `idx_abid` (`album_id`)
)  AUTO_INCREMENT=240567 ,DEFAULT CHARSET=utf8 ,COMMENT='专辑维度出发的关系表';
