CREATE TABLE if not exists `agj_dapei_contents` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT 'uid',
`user_nick` varchar(128) DEFAULT NULL COMMENT 'unick',
`descript` varchar(512) DEFAULT NULL COMMENT '描述',
`tags` varchar(512) DEFAULT NULL COMMENT '标签集',
`multi_pic_path` varchar(512) DEFAULT NULL COMMENT '多图路径',
`multi_item_id` varchar(512) DEFAULT NULL COMMENT '多宝贝id',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='搭配数据';
CREATE TABLE if not exists `agj_dapei_tag_dict` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '标签名称',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='搭配标签字典';
CREATE TABLE if not exists `agj_dict` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`dict_key` varchar(80) NOT NULL COMMENT '键',
`dict_value` varchar(500) NOT NULL COMMENT '值',
`status` int(11) NOT NULL DEFAULT '1' COMMENT '状态 0：可删除，1：正常',
`type` int(11) NOT NULL COMMENT '类型 1：手淘消息合并',
`dict_subkey` varchar(80) NOT NULL COMMENT '子键',
PRIMARY KEY (`id`),
KEY `idx_stauts` (`status`),
KEY `idx_key_type_subkey` (`dict_key`,`type`,`dict_subkey`)
)  AUTO_INCREMENT=5014881 ,DEFAULT CHARSET=utf8 ,COMMENT='爱逛街字典表';
CREATE TABLE if not exists `agj_group_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`group_id` bigint(20) unsigned NOT NULL COMMENT '分表字段，需要全局唯一',
`type` tinyint(4) DEFAULT NULL COMMENT '群类型，0，正常 1，达人导入',
`background` varchar(256) DEFAULT NULL COMMENT '群背景图片url，相对地址',
`status` tinyint(4) DEFAULT NULL COMMENT '状态，0：待审核，1：审核通过，2：审核不通过 ，3：删除',
`attributes` varchar(1024) DEFAULT NULL COMMENT '扩展属性',
`creator_id` bigint(20) unsigned DEFAULT NULL COMMENT '创建者用户id',
`style` tinyint(4) DEFAULT NULL COMMENT '风格',
`group_name` varchar(128) DEFAULT NULL COMMENT '群名称',
PRIMARY KEY (`id`),
KEY `idx_group` (`group_id`)
)  AUTO_INCREMENT=4 ,DEFAULT CHARSET=utf8 ,COMMENT='群表信息';
