`from_id` bigint(20) unsigned DEFAULT NULL COMMENT '关系链上游id，未使用',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_uid_target_action` (`user_id`,`target_id`,`target_type`,`action`),
KEY `idx_uid_type` (`user_id`,`target_type`)
)  AUTO_INCREMENT=525067 ,DEFAULT CHARSET=utf8 ,COMMENT='用户维度关系表';
