CREATE TABLE if not exists `agj_relation_group_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`group_id` bigint(20) unsigned NOT NULL COMMENT '分表字段，agj_group主键',
`type` tinyint(4) DEFAULT NULL COMMENT '关系对象类型，2:专辑，3：用户',
`target_id` bigint(20) unsigned DEFAULT NULL COMMENT '产生关系端id,和type对应；专辑id或用户id',
`action` tinyint(4) DEFAULT NULL COMMENT '动作类型，1：创建，2：加入，3：关注',
`attributes` varchar(256) DEFAULT NULL COMMENT '扩展属性，非特殊情况不要写入',
`status` tinyint(4) DEFAULT NULL COMMENT '状态，1正常，0删除',
`target_user_id` bigint(20) unsigned DEFAULT NULL COMMENT 'target_id的拥有者，如果是用户则为空',
PRIMARY KEY (`id`),
KEY `idx_group_action_type` (`group_id`,`type`,`action`,`gmt_modified`),
KEY `idx_group_target` (`target_id`,`type`,`group_id`,`action`)
)  AUTO_INCREMENT=23 ,DEFAULT CHARSET=utf8 ,COMMENT='群关系维度表.';
