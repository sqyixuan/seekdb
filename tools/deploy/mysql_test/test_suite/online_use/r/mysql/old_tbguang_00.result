CREATE TABLE if not exists `agj_albums_0000` (
`id` bigint(20) unsigned NOT NULL COMMENT '专辑id/主键，全局序列产生',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`user_nick` varchar(64) DEFAULT NULL COMMENT '用户昵称，snsnick或uicnick',
`title` varchar(128) DEFAULT NULL COMMENT '专辑标题',
`cat_id` int(11) DEFAULT NULL COMMENT '前台分类id',
`album_from` tinyint(4) DEFAULT NULL COMMENT '来源标志',
`tags` varchar(128) DEFAULT NULL COMMENT '专辑标签',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`attributes` varchar(512) DEFAULT NULL COMMENT '属性扩展字段kv结构',
`recent_used_time` datetime DEFAULT NULL COMMENT '业务使用时间',
`seq_no` int(11) DEFAULT NULL COMMENT '分表、预留字段',
`description` varchar(512) DEFAULT NULL COMMENT '描述',
PRIMARY KEY (`id`),
KEY `idx_uid_status_time` (`user_id`,`status`,`recent_used_time`)
)  DEFAULT CHARSET=utf8 ,COMMENT='专辑表0';
