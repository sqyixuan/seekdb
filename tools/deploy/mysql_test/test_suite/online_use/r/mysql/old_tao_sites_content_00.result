`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '内容所属用户',
`site_id` bigint(20) unsigned DEFAULT '0' COMMENT '内容所属站点',
`site_category_id` int(10) unsigned NOT NULL COMMENT '内容所属物种',
`schema_name` varchar(32) NOT NULL COMMENT '内容对应的schema',
`type` int(11) NOT NULL COMMENT '内容来源。 1：拖拽版， 2：编码版',
`title` varchar(256) NOT NULL COMMENT '内容标题',
`status` int(11) NOT NULL COMMENT '内容状态。 1：正常 -1：删除',
`modify_time` datetime DEFAULT NULL COMMENT '内容最后修改时间',
`content_class_id` int(11) DEFAULT NULL COMMENT '内容所属分类',
`tags` varchar(512) DEFAULT NULL COMMENT '内容的标签信息，逗号分割',
`refer_id` bigint(20) DEFAULT NULL COMMENT '内容相关的外部关联ID,如sns的内容id等',
`target_type` int(11) DEFAULT NULL COMMENT '内容附着的目标的类型 1：其他内容；2：ITEM, 3：SPU',
`target_id` bigint(20) DEFAULT NULL COMMENT '附着目标的目标id',
`refer_items` varchar(2048) DEFAULT NULL COMMENT '该内容关联到的商品id。如果有多个商品，用逗号分割',
`content_class_name` varchar(256) DEFAULT NULL COMMENT '内容分类名称（冗余字段）',
`like_num` int(11) NOT NULL DEFAULT '0' COMMENT '喜欢数',
`share_num` int(11) NOT NULL DEFAULT '0' COMMENT '分享数',
`comment_num` int(11) NOT NULL DEFAULT '0' COMMENT '评论数',
`view_num` int(11) NOT NULL DEFAULT '0' COMMENT '浏览数',
`top_enable` bigint(20) unsigned NOT NULL COMMENT '是否置顶',
`keyword` varchar(256) DEFAULT NULL COMMENT '关键词',
`out_id` bigint(20) DEFAULT NULL COMMENT '如果该内容是从外部抓取的，则表示的是外部来源ID',
`out_refer_url` varchar(512) DEFAULT NULL COMMENT '如果该内容是从外部抓取的，则表示的是外部来源的URL',
`main_pic` varchar(512) DEFAULT NULL COMMENT '内容主图',
`target_url` varchar(512) DEFAULT NULL COMMENT '目标URL，展现内容详情的URL',
`market_ids` varchar(80) DEFAULT NULL COMMENT '关联的行业市场ID，逗号分割',
`cat_ids` varchar(150) DEFAULT NULL COMMENT '内容关联的类目ID',
`tae_site_id` bigint(20) unsigned NOT NULL COMMENT 'tae的站点id',
`mark` int(11) DEFAULT '0' COMMENT '内容扩展属性，用于内容打标',
`intervention_score` double DEFAULT '0' COMMENT '小二干预质量分',
PRIMARY KEY (`id`),
KEY `idx_schemaname` (`schema_name`)
)  AUTO_INCREMENT=223355364 ,DEFAULT CHARSET=utf8 ,COMMENT='建站平台 内容表';
