set ob_query_timeout = 500000000;
set ob_trx_timeout = 500000000;
DROP DATABASE if EXISTS dynamic_center_01;
CREATE DATABASE dynamic_center_01;
USE dynamic_center_01;
SET global recyclebin = 'off';
CREATE TABLE if not exists `uac_dynamic_shop_infor_0032` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家编号',
`shop_id` bigint(20) unsigned NOT NULL COMMENT '店铺编号',
`shop_type` int(11) DEFAULT NULL COMMENT '店铺类型',
`state` int(11) DEFAULT NULL COMMENT '状态',
`promotion_start_time` datetime DEFAULT NULL COMMENT '优惠开始时间',
`promotion_end_time` datetime DEFAULT NULL COMMENT '优惠结束时间',
`today_new_count` int(11) NOT NULL DEFAULT '0' COMMENT '当天的上新',
`seven_ago_new_count` int(11) NOT NULL DEFAULT '0' COMMENT '7天的上新',
`fifteen_ago_new_count` int(11) NOT NULL DEFAULT '0' COMMENT '15天的上新',
`thirty_ago_new_count` int(11) NOT NULL DEFAULT '0' COMMENT '30天的上新',
`promotion_count` int(11) NOT NULL DEFAULT '0' COMMENT '优惠的计数',
`pre_new_count` int(11) NOT NULL DEFAULT '0' COMMENT '预上新的计数',
`pre_new_time` datetime DEFAULT NULL COMMENT '预上新的时间',
`features` varchar(1024) DEFAULT NULL COMMENT '备注',
`new_time` datetime DEFAULT NULL COMMENT '上新时间',
PRIMARY KEY (`id`),
UNIQUE KEY `seller_id` (`seller_id`)
)  AUTO_INCREMENT=177756 ,DEFAULT CHARSET=utf8 ,COMMENT='卖家信息表，用于记录卖家的count数和上新时间等';
