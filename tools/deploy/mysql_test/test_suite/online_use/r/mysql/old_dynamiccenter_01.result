PRIMARY KEY (`id`),
UNIQUE KEY `seller_type_days_cate_uidx` (`seller_id`,`count_type`,`days`,`category_id`)
)  AUTO_INCREMENT=305221 ,DEFAULT CHARSET=utf8 ,COMMENT='uac 店铺类目上新数统计表';
