CREATE TABLE if not exists `uac_promotion_item_0032` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`seller_id` bigint(20) NOT NULL COMMENT '卖家seller_id,分表字段',
`item_id` bigint(20) NOT NULL COMMENT '商品id',
`activity_id` bigint(20) NOT NULL COMMENT '优惠活动id',
`purchase_price` bigint(20) DEFAULT NULL COMMENT '优惠后的价格，精确到分',
`discount` int(11) DEFAULT NULL COMMENT '折扣率，精确到分，如8折为800',
`decrease_price` bigint(20) DEFAULT NULL COMMENT '减钱，精确到分',
`promotion_name` varchar(1024) NOT NULL COMMENT '优惠名称',
`start_time` datetime NOT NULL COMMENT '优惠开始时间，建立索引',
`end_time` datetime NOT NULL COMMENT '优惠结束时间，建立索引',
`shop_id` bigint(20) DEFAULT '0' COMMENT '店铺id',
`feature` varchar(1024) DEFAULT NULL COMMENT '额外的一些特性（json格式）',
`promotion_id` bigint(20) DEFAULT NULL COMMENT '自定义优惠id（兼容宝贝动态）',
`ex_1` bigint(20) DEFAULT NULL COMMENT '预留的扩展字段',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_uq_item_promotion_activity` (`item_id`,`promotion_id`,`activity_id`),
KEY `end_time` (`end_time`),
KEY `start_time` (`start_time`),
KEY `idx_seller_id_activity` (`seller_id`,`activity_id`)
)  AUTO_INCREMENT=23291849 ,DEFAULT CHARSET=utf8 ,COMMENT='优惠总表按seller_id进行分表';
