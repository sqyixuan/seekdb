CREATE TABLE if not exists `uac_new_arrival_item_0256` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`seller_id` bigint(20) unsigned DEFAULT NULL COMMENT '卖家id',
`item_id` bigint(20) unsigned DEFAULT NULL COMMENT 'itemId',
`start_time` datetime DEFAULT NULL COMMENT '商品首次上架时间，预上架的不算。没有上架之前该时间可以更改，一旦上架，不再改变',
`new_time` datetime DEFAULT NULL COMMENT '上架或发布时间',
`price` bigint(20) DEFAULT NULL COMMENT '发布价格',
`pic` varchar(254) DEFAULT NULL COMMENT '发布时主图',
`title` varchar(254) DEFAULT NULL COMMENT '发布时title',
`category_id` bigint(20) unsigned DEFAULT NULL COMMENT '发布时淘宝类目',
`state` smallint(6) DEFAULT NULL COMMENT '状态， 可已为null,',
`item_type` int(11) DEFAULT '1' COMMENT 'item类型，b,c商品',
`deleted` int(11) DEFAULT '0' COMMENT '是否逻辑删除',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modify` datetime DEFAULT NULL COMMENT '最后修改时间',
`first_start_time` datetime DEFAULT NULL COMMENT '商品首次上架时间，预上架的不算。没有上架之前该时间可以更改，一旦上架，不再改变',
PRIMARY KEY (`id`),
KEY `idx_seller_id_new_time_start_time` (`seller_id`,`new_time`,`start_time`),
KEY `idx_seller_id_item_id` (`seller_id`,`item_id`),
KEY `idx_seller_id_category_id_new_time` (`seller_id`,`category_id`,`new_time`),
KEY `idx_seller_id_first_start_time` (`seller_id`,`deleted`,`first_start_time`),
KEY `idx_seller_id_category_id_first_start_time` (`seller_id`,`deleted`,`category_id`,`first_start_time`),
KEY `idx_seller_id_start_time_item_id` (`seller_id`,`start_time`,`item_id`)
)  AUTO_INCREMENT=4551476 ,DEFAULT CHARSET=utf8 ,COMMENT='上新优惠详情表';
