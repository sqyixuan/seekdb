CREATE TABLE if not exists `autosave_gov_bid_extra` (
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`item_id` bigint(20) DEFAULT NULL COMMENT '宝贝ID',
`auction_starts` datetime DEFAULT NULL COMMENT '开始时间',
`auction_ends` datetime DEFAULT NULL COMMENT '结束时间',
`auction_type` tinyint(4) DEFAULT NULL COMMENT '宝贝类型',
`features` varchar(512) DEFAULT NULL COMMENT '附加字段',
`options` bigint(20) DEFAULT NULL COMMENT '标示字段',
`current_price` bigint(20) DEFAULT NULL COMMENT '当前价',
`reserve_price` varchar(128) DEFAULT NULL COMMENT '保留价',
`next_bid` bigint(20) DEFAULT NULL COMMENT '下次出价价格',
`consult_price` bigint(20) DEFAULT NULL COMMENT '评估价',
`user_id` bigint(20) NOT NULL COMMENT '用户id',
`link_man` varchar(64) DEFAULT NULL COMMENT '联系人',
`mobile_phone` varchar(20) DEFAULT NULL COMMENT '联系手机',
`phone` varchar(30) DEFAULT NULL COMMENT '手机',
`has_attach` tinyint(4) DEFAULT NULL COMMENT '是否包含附件',
`project_id` bigint(20) DEFAULT NULL COMMENT '项目id',
`custom_pic_url` varchar(2048) DEFAULT NULL COMMENT '自定义图片',
`movie_url` varchar(256) DEFAULT NULL COMMENT '视频在ftf的链接',
`cat_id` bigint(20) DEFAULT NULL COMMENT '类目ID',
`notice_tfsname` varchar(256) DEFAULT NULL COMMENT '须知tfs',
`priority_users` varchar(1024) DEFAULT NULL COMMENT '优先购买权人',
`coordinate` varchar(64) DEFAULT NULL COMMENT '坐标',
`location` varchar(256) DEFAULT NULL COMMENT '所在地',
`item_desc` varchar(64) DEFAULT NULL COMMENT '宝贝描述临时保存',
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`is_deleted` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否被删除',
`title` varchar(256) DEFAULT NULL COMMENT '宝贝标题',
`black_users` varchar(1024) DEFAULT NULL COMMENT '黑名单用户字段',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '入驻类型:0=司法,11=资产政府类,12=资产商业类,13=拍卖行',
`buyer_qualification` varchar(2048) DEFAULT NULL COMMENT '资产竞买人资格',
`comp` int(11) DEFAULT '0' COMMENT '佣金比例，DB存储是实际比例(小数点后最多5位)的100000倍。',
`postage` bigint(20) unsigned DEFAULT NULL COMMENT '资产类的邮费',
`loan_tfs_name` varchar(256) DEFAULT NULL COMMENT '司法贷款服务',
PRIMARY KEY (`id`),
KEY `user_id_pk` (`user_id`)
)  AUTO_INCREMENT=78295 ,DEFAULT CHARSET=utf8 ,COMMENT='自动保存司法宝贝';
CREATE TABLE if not exists `bid_album_statistics` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`title` varchar(200) DEFAULT NULL COMMENT '专场名称',
`start_time` date DEFAULT NULL COMMENT '专场开始时间',
`end_time` date DEFAULT NULL COMMENT '专场结束时间',
`creator_id` bigint(20) DEFAULT NULL COMMENT '专场创建人id',
`nick` varchar(100) DEFAULT NULL COMMENT '创建人nick',
`album_id` bigint(20) DEFAULT NULL COMMENT '专场id',
`front_cat_name` varchar(1000) DEFAULT NULL COMMENT '前台类目名称',
`cat_item_count` int(11) DEFAULT NULL COMMENT '类目下商品数目',
`bid_count` int(11) DEFAULT NULL COMMENT '类目下商品的出价次数',
`bid_buyer_count` int(11) DEFAULT NULL COMMENT '类目下商品的出价人数',
`paixia_item_count` int(11) DEFAULT NULL COMMENT '类目下拍下商品数',
`suc_item_count` int(11) DEFAULT NULL COMMENT '类目下成交商品数',
`ing_item_count` int(11) DEFAULT NULL COMMENT '类目下正在走交易流程的商品数',
`ing_gmv` double DEFAULT NULL COMMENT '类目下正在走交易流程的gmv',
`suc_item_amount` int(11) DEFAULT NULL COMMENT '交易成功的商品数量',
`paixia_gmv` double DEFAULT NULL COMMENT '拍下gmv',
`suc_gmv` double DEFAULT NULL COMMENT '成交gmv',
`refund_item_count` int(11) DEFAULT NULL COMMENT '退款商品数',
`refund_item_gmv` bigint(20) unsigned DEFAULT NULL COMMENT '退款gmv',
`ipv` bigint(20) DEFAULT NULL COMMENT 'ipv',
`iuv` bigint(20) DEFAULT NULL COMMENT 'iuv',
`biz_date` date DEFAULT NULL COMMENT '数据的截止日期（包括biz_date)，数据是计算的一月内的专场的数据',
`pv` bigint(20) DEFAULT NULL COMMENT '专场pv数据',
`uv` bigint(20) DEFAULT NULL COMMENT '专场uv数据',
PRIMARY KEY (`id`),
KEY `biz_date` (`biz_date`),
KEY `ttile` (`title`),
KEY `album_id` (`album_id`),
KEY `start_end_time` (`start_time`,`end_time`),
KEY `cat_id` (`front_cat_name`)
)  AUTO_INCREMENT=2660208 ,DEFAULT CHARSET=utf8 ,COMMENT='拍卖专场统计数据';
CREATE TABLE if not exists `gov_attach_file` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`source_id` bigint(20) unsigned NOT NULL COMMENT '所属源id（标的物或公告id），外键',
`title` varchar(256) DEFAULT NULL COMMENT '附件标题',
`url` varchar(256) DEFAULT NULL COMMENT '附件链接',
`file_type` tinyint(4) DEFAULT NULL COMMENT '附件文件类型，如doc、txt',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_gov_attach_file_sid` (`source_id`,`file_type`)
)  AUTO_INCREMENT=17012 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖附件表';
CREATE TABLE if not exists `gov_bid_auction` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`item_id` bigint(20) unsigned NOT NULL COMMENT '宝贝id',
`buyer_id` bigint(20) unsigned NOT NULL COMMENT '出价者id',
`bid_time` datetime NOT NULL COMMENT '出价时间',
`bid_price` bigint(20) unsigned NOT NULL COMMENT '出价金额，单位分',
`quantity` int(10) unsigned NOT NULL COMMENT '出价数量',
`bid_ip` varchar(32) DEFAULT NULL COMMENT '出价ip',
`status` tinyint(4) NOT NULL COMMENT '出价记录状态',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '位与字段',
`biz_order_id` bigint(20) unsigned DEFAULT NULL COMMENT '订单id',
`alias_name` varchar(32) DEFAULT NULL COMMENT '出价者别名',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`pause_flag` tinyint(4) DEFAULT NULL COMMENT '中止标记',
PRIMARY KEY (`id`),
KEY `idx_gov_bid_auction_itemid_buyerid` (`item_id`,`buyer_id`),
KEY `idx_gov_bid_auction_itemid_bidtime` (`item_id`,`bid_time`),
KEY `idx_gid_id_bidp` (`item_id`,`status`,`bid_price`,`gmt_create`)
)  AUTO_INCREMENT=930099 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖出价表';
CREATE TABLE if not exists `gov_bid_extra` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`item_id` bigint(20) unsigned NOT NULL COMMENT '宝贝id',
`auction_starts` datetime DEFAULT NULL COMMENT '拍卖开始时间',
`auction_ends` datetime DEFAULT NULL COMMENT '拍卖结束时间',
`auction_type` tinyint(4) NOT NULL COMMENT '拍卖类型，1单件拍',
`bid_status` tinyint(4) NOT NULL COMMENT '拍卖状态（0未出价，1出价中，2已生成订单，3失败，4失效）',
`features` varchar(1000) DEFAULT NULL COMMENT '规则信息等',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '扩展预留位*',
`attribute_cc` bigint(20) unsigned NOT NULL COMMENT '系统标示版本号',
`current_price` bigint(20) unsigned DEFAULT NULL COMMENT '当前价格，单位分',
`reserve_price` varchar(128) DEFAULT NULL COMMENT '保留价，加密字段',
`next_bid` bigint(20) unsigned DEFAULT NULL COMMENT '下次最小出价，单位分',
`consult_price` bigint(20) DEFAULT NULL COMMENT '市场估价，单位分',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`link_man` varchar(64) DEFAULT NULL COMMENT '标的物联系人',
`mobile_phone` varchar(20) DEFAULT NULL COMMENT '手机号',
`phone` varchar(30) DEFAULT NULL COMMENT '电话号码',
`has_attach` tinyint(4) DEFAULT NULL COMMENT '是否有附件，0没有，1有',
`project_id` bigint(20) unsigned DEFAULT NULL COMMENT '项目id，外键',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`end_url` varchar(256) DEFAULT NULL COMMENT '终结理由链接',
`custom_pic_url` varchar(256) DEFAULT NULL COMMENT '自定义的图片',
`movie_url` varchar(256) DEFAULT NULL COMMENT '视频在tft的链接',
`export_info` varchar(256) DEFAULT NULL COMMENT '文件导出信息',
`cat_id` bigint(20) unsigned DEFAULT '0' COMMENT '类目id',
`notice_tfsname` varchar(256) DEFAULT NULL COMMENT '商品须知的tfsName',
`priority_users` varchar(2048) DEFAULT NULL COMMENT '优先竞买权人用户id',
`coordinate` varchar(64) DEFAULT NULL COMMENT '坐标',
`location` varchar(256) DEFAULT NULL COMMENT '所在地',
`pub_time` datetime DEFAULT NULL COMMENT '标的物发布时间',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '入驻类型:0=司法,11=资产政府类,12=资产商业类,13=拍卖行',
`buyer_qualification` varchar(2048) DEFAULT NULL COMMENT '资产竞买人资格',
`comp` int(11) DEFAULT NULL COMMENT '佣金比例，DB存储是实际比例(小数点后最多5位)的100000倍。',
`postage` bigint(20) unsigned DEFAULT NULL COMMENT '资产类的邮费',
`root_item_id` bigint(20) unsigned DEFAULT NULL COMMENT '第一次拍卖时的记录下的宝贝id，后续通过转拍产生的新标的物商品也会冗余这个宝贝id。',
`loan_tfs_name` varchar(256) DEFAULT NULL COMMENT '司法贷款服务TFS',
PRIMARY KEY (`id`),
KEY `idx_gov_bid_extra_itemid` (`item_id`),
KEY `idx_gov_bid_extra_projectid` (`project_id`,`bid_status`),
KEY `idx_gov_bid_extra_bidstu_auctionend` (`bid_status`,`auction_ends`),
KEY `idx_gov_bid_extra_userid_pubtime_bidstatus` (`user_id`,`pub_time`,`bid_status`),
KEY `ind_cu` (`current_price`),
KEY `inx_root_item_id` (`root_item_id`,`gmt_create`),
KEY `idx_uid_auctst_bstat` (`user_id`,`auction_starts`,`bid_status`)
)  AUTO_INCREMENT=135262 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖子表';
CREATE TABLE if not exists `gov_bid_foregift` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`item_id` bigint(20) unsigned NOT NULL COMMENT '宝贝id',
`buyer_id` bigint(20) unsigned NOT NULL COMMENT '买家用户id',
`seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家id',
`alipay_id` varchar(32) NOT NULL COMMENT '转出支付宝账号',
`amount` bigint(20) unsigned NOT NULL COMMENT '冻结金额',
`type` tinyint(4) NOT NULL COMMENT '押金类型1-冻结 2-解冻 3-转移',
`status` tinyint(4) NOT NULL COMMENT '押金状态：0-初始化 1-成功 2-失败',
`operator` varchar(64) DEFAULT NULL COMMENT '操作者',
`error_code` varchar(64) DEFAULT NULL COMMENT '错误码',
`alias_name` varchar(32) DEFAULT NULL COMMENT '用户别名',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`contact` varchar(256) DEFAULT NULL COMMENT '联系地址|联系电话',
`pause_flag` tinyint(4) DEFAULT NULL COMMENT '中止标记',
`features` varchar(2000) DEFAULT NULL COMMENT '扩展字段',
`is_deleted` tinyint(4) DEFAULT NULL COMMENT '删除标记',
`event_history` varchar(2048) DEFAULT NULL COMMENT '变更事件历史',
`pre_auth_id` bigint(20) DEFAULT NULL COMMENT '资金预授权资金单id',
`idcard_type` tinyint(4) DEFAULT NULL COMMENT '证件类型',
`idcard_id` varchar(64) DEFAULT NULL COMMENT '用户证件id，需要加密',
`idcard_name` varchar(128) DEFAULT NULL COMMENT '用户真名',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_gov_bid_foregift_itemid_aliasname` (`item_id`,`alias_name`),
KEY `idx_gov_bid_foregift_buyerid` (`buyer_id`),
KEY `idx_bidstype` (`buyer_id`,`status`,`type`)
)  AUTO_INCREMENT=439006 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖押金表';
CREATE TABLE if not exists `gov_bid_spc_user` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`bid_auction_id` bigint(20) unsigned NOT NULL COMMENT '拍品id',
`name` varchar(512) NOT NULL COMMENT '用户姓名',
`id_card_num` varchar(512) NOT NULL COMMENT '身份证号',
`deleted` tinyint(4) NOT NULL COMMENT '是否被删除，1表示被删除，0表示正常',
`type` bigint(20) unsigned NOT NULL COMMENT '特殊用户的类型，目前只有黑名单，0表示黑名单类型',
`id_card_type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '证件类型(1表示企业营业执照 ，2身份证，3台胞证，4港澳，5护照等)',
PRIMARY KEY (`id`),
KEY `bid_auction_id_type` (`bid_auction_id`,`type`)
)  AUTO_INCREMENT=5516 ,DEFAULT CHARSET=utf8 ,COMMENT='拍卖特殊用户（黑名单）';
CREATE TABLE if not exists `gov_court_address` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`province` varchar(256) DEFAULT NULL COMMENT '省',
`city` varchar(256) DEFAULT NULL COMMENT '市',
`area` varchar(256) DEFAULT NULL COMMENT '区（县）',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '法院用户ID',
`user_nick` varchar(32) DEFAULT NULL COMMENT '法院名称 - uic一致冗余',
`parent_user_id` bigint(20) unsigned DEFAULT NULL COMMENT '父级法院(user_id)',
`char_1` varchar(512) DEFAULT NULL COMMENT 'backup',
`number_1` bigint(20) unsigned DEFAULT NULL COMMENT 'backup',
`province_id` bigint(20) unsigned DEFAULT '0' COMMENT '省division_id(行政层级2)',
`city_id` bigint(20) unsigned DEFAULT '0' COMMENT '市division_id((行政层级3)',
`area_id` bigint(20) unsigned DEFAULT '0' COMMENT '区/县divsion_id(行政层级4)',
`gov_settled_id` bigint(20) unsigned DEFAULT NULL COMMENT '关联gov_judicial_settled表的外键id',
PRIMARY KEY (`id`),
KEY `idx_gsid` (`gov_settled_id`),
KEY `idx_user_id` (`user_id`)
)  AUTO_INCREMENT=876 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖法院地域层级关系';
CREATE TABLE if not exists `gov_court_paimai_summary` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`court_id` bigint(20) unsigned NOT NULL COMMENT '法院id',
`court_nick` varchar(100) NOT NULL COMMENT '法院名称',
`month` int(10) unsigned NOT NULL COMMENT '统计的月份',
`paimai_num` int(10) unsigned DEFAULT NULL COMMENT '开拍次数（除了待发布的）',
`paimai_extra_num` int(10) unsigned DEFAULT NULL COMMENT '开拍标的数',
`deal_extra_num` int(10) unsigned DEFAULT NULL COMMENT '成交标的数',
`notify_user_num` bigint(20) unsigned DEFAULT NULL COMMENT '提醒人数',
`pay_foregift_num` bigint(20) unsigned DEFAULT NULL COMMENT '缴纳保证金人数',
`paimai_user_num` bigint(20) unsigned DEFAULT NULL COMMENT '参拍人数',
`foregift_total` bigint(20) unsigned DEFAULT NULL COMMENT '保证金额度',
`deal_money_total` bigint(20) unsigned DEFAULT NULL COMMENT '成交金额',
`deal_percent` varchar(10) DEFAULT NULL COMMENT '成交率（小数点二位的格式）',
`premium_rate` varchar(10) DEFAULT NULL COMMENT '溢价率（小数点二位的格式）',
`extinfo` varchar(4000) DEFAULT NULL COMMENT '扩展信息',
`version` bigint(20) unsigned DEFAULT NULL COMMENT '版本号',
`last_scan_time` datetime DEFAULT NULL COMMENT '上次统计标物的时间',
`look_user_num` bigint(20) unsigned DEFAULT NULL COMMENT '围观人数',
`complete` int(11) DEFAULT '0' COMMENT '数据是否完整，0-不完整，1-完整',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_id_month` (`court_id`,`month`),
KEY `idx_month` (`month`),
KEY `idx_last_scan_time` (`last_scan_time`),
KEY `idx_c_complete` (`court_id`,`complete`)
)  AUTO_INCREMENT=14400 ,DEFAULT CHARSET=utf8 ,COMMENT='法院拍卖数据摘要';
CREATE TABLE if not exists `gov_court_shorturl` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) DEFAULT NULL COMMENT '淘宝用户id',
`court_name` varchar(100) DEFAULT NULL COMMENT '法院的名称（旺旺名）',
`short_url` varchar(100) DEFAULT NULL COMMENT '短链地址',
`operator` varchar(100) DEFAULT NULL COMMENT '短链接最近一次修改人',
`status` tinyint(4) DEFAULT NULL COMMENT '状态（0,：初始化，1,：生效，-1：失效）',
PRIMARY KEY (`id`),
KEY `pri_short_url` (`short_url`),
KEY `pri_user_id` (`user_id`)
)  AUTO_INCREMENT=808 ,DEFAULT CHARSET=utf8 ,COMMENT='法院短链的存储表';
CREATE TABLE if not exists `gov_extra_data_detail` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`court_id` bigint(20) unsigned NOT NULL COMMENT '发布法院id',
`extra_id` bigint(20) unsigned NOT NULL COMMENT '拍品id',
`pub_court_nick` varchar(100) DEFAULT NULL COMMENT '发布法院名称',
`pub_court_location` varchar(30) DEFAULT NULL COMMENT '发布法院所在地区',
`case_no` varchar(100) DEFAULT NULL COMMENT '案号',
`auction_starts` datetime DEFAULT NULL COMMENT '拍卖开始时间',
`auction_ends` datetime DEFAULT NULL COMMENT '拍卖结束时间',
`circ` varchar(10) DEFAULT NULL COMMENT '拍卖阶段',
`extra_title` varchar(100) DEFAULT NULL COMMENT '拍卖名称',
`extra_type` varchar(10) DEFAULT NULL COMMENT '拍品类型（如，房产）',
`extra_location` char(30) DEFAULT NULL COMMENT '拍品所在地',
`look_user_num` int(10) unsigned DEFAULT NULL COMMENT '围观人次',
`sub_notify_user_num` int(10) unsigned DEFAULT NULL COMMENT '订阅提醒人数',
`apply_user_num` int(10) unsigned DEFAULT NULL COMMENT '报名人数',
`bid_user_num` int(10) unsigned DEFAULT NULL COMMENT '出价人数',
`bid_num` int(10) unsigned DEFAULT NULL COMMENT '出价次数',
`start_price` bigint(20) unsigned DEFAULT NULL COMMENT '起拍价(cent)',
`consult_price` bigint(20) DEFAULT NULL COMMENT '评估价(cent)',
`deal_price` bigint(20) unsigned DEFAULT NULL COMMENT '成交价(cent)',
`pai_mai_result` varchar(10) DEFAULT NULL COMMENT '拍卖结果',
`premium_rate` varchar(10) DEFAULT NULL COMMENT '溢价率(两位小数点格式)',
`parent_extra_id` bigint(20) unsigned DEFAULT NULL COMMENT '上一拍的拍品id',
`root_extra_id` bigint(20) unsigned DEFAULT NULL COMMENT '第一次拍卖的id',
`extinfo` varchar(2000) DEFAULT NULL COMMENT '扩展信息',
`version` bigint(20) unsigned DEFAULT NULL COMMENT '版本号',
`foregift` bigint(20) unsigned DEFAULT NULL COMMENT '保证金(cent)',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_extra_id` (`extra_id`),
KEY `idx_auction_starts` (`auction_starts`),
KEY `idx_court_id` (`court_id`),
KEY `idx_ends` (`court_id`,`auction_ends`),
KEY `idx_start` (`court_id`,`auction_starts`)
)  AUTO_INCREMENT=139542 ,DEFAULT CHARSET=utf8 ,COMMENT='司法标物拍卖的数据明细';
CREATE TABLE if not exists `gov_high_court` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`court_nick` varchar(200) NOT NULL COMMENT '法院名称',
`court_account` varchar(200) NOT NULL COMMENT '法院账号',
`prov` varchar(10) DEFAULT NULL COMMENT '所在省',
`city` varchar(10) DEFAULT NULL COMMENT '所在市',
`sub_courts_id` varchar(4000) DEFAULT NULL COMMENT '下属法院（id,id,id）',
`extinfo` varchar(2000) DEFAULT NULL COMMENT '扩展信息',
`version` bigint(20) unsigned NOT NULL COMMENT '版本号',
`court_id` bigint(20) unsigned NOT NULL COMMENT '法院用户id',
PRIMARY KEY (`id`),
KEY `idx_court_nick` (`court_nick`),
KEY `idx_court_account` (`court_account`),
KEY `idx_court_id` (`court_id`),
KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT=24 ,DEFAULT CHARSET=utf8 ,COMMENT='高院用户表';
CREATE TABLE if not exists `gov_judicial_settled` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(32) NOT NULL COMMENT '法院名称，即淘宝账号，跟uic一样32的长度',
`email` varchar(64) DEFAULT NULL COMMENT '法院邮箱',
`organization_code` varchar(64) NOT NULL COMMENT '法院组织机构代码',
`organization_address` varchar(512) NOT NULL COMMENT '组织机构代码证详细地址',
`legal_name` varchar(32) NOT NULL COMMENT '法人代表姓名',
`legal_identity` varchar(64) NOT NULL COMMENT '法人代表身份证，需加密',
`address` varchar(512) NOT NULL COMMENT '法院联系地址',
`phone` varchar(32) NOT NULL COMMENT '法院联系电话',
`contact_name` varchar(32) DEFAULT NULL COMMENT '法院联系接口人',
`contact_phone` varchar(32) DEFAULT NULL COMMENT '法院联系人手机',
`fax` varchar(32) NOT NULL COMMENT '传真',
`organization_picurl` varchar(256) NOT NULL COMMENT '组织机构代码证扫描件',
`parent_bodies` varchar(256) DEFAULT NULL COMMENT '法院上级机构',
`bank_account_name` varchar(64) NOT NULL COMMENT '开户名称',
`bank_province` varchar(64) DEFAULT NULL COMMENT '开户银行所在省份',
`bank_city` varchar(64) DEFAULT NULL COMMENT '开户银行所在城市',
`bank_name` varchar(64) NOT NULL COMMENT '开户银行名称',
`bank_branch_name` varchar(64) NOT NULL COMMENT '开户支行名称',
`bank_account_num` varchar(64) NOT NULL COMMENT '法院银行帐号',
`status` tinyint(4) NOT NULL COMMENT '帐号状态',
`valid_date` date DEFAULT NULL COMMENT '帐号有效期',
`export_info` varchar(256) DEFAULT NULL COMMENT '文件导出信息',
`is_deleted` tinyint(4) NOT NULL COMMENT '逻辑删除位',
`user_id` bigint(20) DEFAULT NULL COMMENT '淘宝用户id',
`organization_valid_time` datetime DEFAULT NULL COMMENT '法院组织机构代码证有效期',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '入驻类型:0=司法,1=资产政府类,2=资产商业类,3=拍卖行',
`data` varchar(2048) DEFAULT NULL COMMENT '入驻信息记录',
`amount` bigint(20) unsigned DEFAULT NULL COMMENT '入驻需要缴纳的保证金',
`attribute` varchar(2048) DEFAULT NULL COMMENT '扩展字段，json格式',
PRIMARY KEY (`id`),
KEY `k_name` (`name`),
KEY `idx_name` (`name`),
KEY `idx_email` (`email`),
KEY `idx_uid` (`user_id`),
KEY `idx_bac` (`bank_account_num`),
KEY `idx_lid` (`legal_identity`),
KEY `idx_status_gctime` (`status`,`gmt_create`)
)  AUTO_INCREMENT=945 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖法院入驻信息表';
CREATE TABLE if not exists `gov_priority_bid` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`item_id` bigint(20) unsigned NOT NULL COMMENT '商品id',
`round_index` int(11) NOT NULL COMMENT '第几轮竞价',
`first_winner` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '首轮竞价优胜者',
`final_winner` bigint(20) unsigned DEFAULT '0' COMMENT '最终优胜者',
`apply_priority` varchar(2048) DEFAULT NULL COMMENT '报名的优先购买人',
`valid_users` varchar(2048) DEFAULT NULL COMMENT '本轮有效的优先人，不包括首轮出价者',
`accept_users` varchar(2048) DEFAULT NULL COMMENT '本轮应价的用户',
`give_up_users` varchar(2048) DEFAULT NULL COMMENT '本轮放弃的用户',
`stage` tinyint(4) NOT NULL COMMENT '优先竞买阶段状态：0:优先人要价阶段,1:首轮胜出者出价阶段,2:优先人抽签阶段,3:结束',
`version` int(11) DEFAULT '0' COMMENT '更新时使用的版本号',
`gmt_round_end` datetime NOT NULL COMMENT '本轮应该结束的时间，不一定是实际结束时间',
`is_deleted` tinyint(4) NOT NULL DEFAULT '0' COMMENT '逻辑删除，0:未删除，1:已删除',
`first_alias_name` varchar(32) DEFAULT NULL COMMENT '首轮优胜者的竞拍号',
`draw_lots_user` varchar(2048) DEFAULT NULL COMMENT '抽签的用户名单，只在抽奖阶段才有值',
`time_out_users` varchar(2048) DEFAULT NULL COMMENT '超时放弃的用户名单',
PRIMARY KEY (`id`),
UNIQUE KEY `item_round` (`item_id`,`round_index`)
)  AUTO_INCREMENT=26842 ,DEFAULT CHARSET=utf8 ,COMMENT='优先人阶段的应价记录';
CREATE TABLE if not exists `gov_project_notice` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`title` varchar(256) NOT NULL COMMENT '项目公告标题',
`status` tinyint(4) DEFAULT NULL COMMENT '公告状态（初始化：0，发布：1，撤下：2）',
`content_url` varchar(256) DEFAULT NULL COMMENT '公告内容tfs地址',
`last_modified` datetime NOT NULL COMMENT '最后编辑时间',
`has_attach` tinyint(4) DEFAULT NULL COMMENT '是否有附件，0没有，1有',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`publish_time` datetime DEFAULT NULL,
`case_no` varchar(256) DEFAULT NULL COMMENT '案号',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '入驻类型:0=司法,1=资产政府类,2=资产商业类,3=拍卖行',
`is_deleted` tinyint(4) NOT NULL DEFAULT '0' COMMENT '逻辑删除，0:未删除，1:已删除',
PRIMARY KEY (`id`),
KEY `idx_userid_status` (`user_id`,`status`),
KEY `idx_status_id` (`status`,`id`)
)  AUTO_INCREMENT=130390 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖项目公告表';
CREATE TABLE if not exists `gov_sub_to_high_court` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`sub_court_nick` varchar(200) NOT NULL COMMENT '下属法院名称',
`high_court` varchar(300) DEFAULT NULL COMMENT '所属高院（id:nick,id:nick）,一个高院可以对应多个执行法院',
`extinfo` varchar(2000) DEFAULT NULL COMMENT '扩展信息',
`sub_court_accout` varchar(100) NOT NULL COMMENT '下属法院账号',
`version` bigint(20) unsigned NOT NULL COMMENT '版本号',
`sub_court_id` bigint(20) unsigned NOT NULL COMMENT '下属法院用户id',
PRIMARY KEY (`id`),
KEY `idx_sub_court_nick` (`sub_court_nick`),
KEY `idx_sub_court_account` (`sub_court_accout`),
KEY `idx_sub_court_id` (`sub_court_id`)
)  AUTO_INCREMENT=248 ,DEFAULT CHARSET=utf8 ,COMMENT='用于根据下属法院模糊搜索高院';
CREATE TABLE if not exists `gov_user_verification` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) unsigned NOT NULL COMMENT '淘宝用户id',
`alipay_id` varchar(32) NOT NULL COMMENT '支付宝id',
`idcard_name` varchar(128) DEFAULT NULL COMMENT '用户真名',
`idcard_id` varchar(64) DEFAULT NULL COMMENT '用户证件id，需加密',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`idcard_type` tinyint(4) DEFAULT NULL COMMENT '证件类型',
PRIMARY KEY (`id`),
KEY `idx_gov_user_verif_userid` (`user_id`)
)  AUTO_INCREMENT=226629 ,DEFAULT CHARSET=utf8 ,COMMENT='司法拍卖用户信息表';
CREATE TABLE if not exists `merchant_notice` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) NOT NULL COMMENT '处置主体用户ID',
`name` varchar(32) NOT NULL COMMENT '处置主体名称',
`title` varchar(128) NOT NULL COMMENT '公告标题',
`type` bigint(20) NOT NULL COMMENT '资产类型',
`subtype` varchar(512) DEFAULT NULL COMMENT '子类型，逗号分隔',
`location` varchar(32) NOT NULL COMMENT '所在地，区域码',
`contacts` varchar(2048) DEFAULT NULL COMMENT '联系人，json格式',
`pics` varchar(2048) DEFAULT NULL COMMENT '图片，逗号分隔',
`video_url` varchar(512) DEFAULT NULL COMMENT '视频地址',
`summary` varchar(2048) DEFAULT NULL COMMENT '摘要，搜索结果展示',
`detail_url` varchar(256) NOT NULL COMMENT '详情地址',
`attachments` varchar(2048) DEFAULT NULL COMMENT '附件,json格式，需要存储原文件名',
`lower_price` bigint(20) NOT NULL COMMENT '参考价值下限(单位：元)',
`upper_price` bigint(20) NOT NULL COMMENT '参考价值上限(单位：元)',
`start_time` datetime NOT NULL COMMENT '公告开始时间（当前时间）',
`end_time` datetime NOT NULL COMMENT '公告结果时间',
`interval_day` int(11) NOT NULL COMMENT '公告间隔天数',
`status` int(11) NOT NULL COMMENT '状态
1-编辑中
2-招商中
3-已转竞价
4-线下已处置
5-已结束
6-已撤回 -1已删除',
`withdraw_reason` varchar(2048) DEFAULT NULL COMMENT '撤回理由',
`intention_person` varchar(2048) DEFAULT NULL COMMENT '意向人，json格式',
`attribute` varchar(2048) DEFAULT NULL COMMENT '扩展字段',
`pic_count` int(11) NOT NULL COMMENT '图片数',
`has_video` tinyint(4) NOT NULL COMMENT '是否有视频
0-无，1-有',
`intention_person_count` int(11) NOT NULL COMMENT '意向人数',
`prov` varchar(64) NOT NULL COMMENT '省',
`city` varchar(64) NOT NULL COMMENT '市',
PRIMARY KEY (`id`),
KEY `user_status_idx` (`user_id`,`status`),
KEY `status_end_idx` (`status`,`end_time`)
)  AUTO_INCREMENT=450 ,DEFAULT CHARSET=utf8 ,COMMENT='招商公告';
