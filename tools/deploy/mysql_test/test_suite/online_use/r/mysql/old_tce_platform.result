CREATE TABLE if not exists `check_task` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '编号',
`name` varchar(255) NOT NULL COMMENT '任务名称',
`task_id` varchar(255) NOT NULL COMMENT '任务ID，对应的是任务类型中的ID',
`task_type` varchar(64) NOT NULL COMMENT '任务类型',
`run_type` char(1) NOT NULL DEFAULT '0' COMMENT '执行类型，一次性任务还是周期性任务。0：一次性任务，1：周期性任务',
`cron` varchar(64) NOT NULL COMMENT '执行时间，CRON表达式',
`convarchar(1024)` varchar(1024) COMMENT '初始化数据，以JSON形式存储',
`create_date` datetime NOT NULL COMMENT '创建时间',
`creator` varchar(64) NOT NULL COMMENT '创建者',
`remarks` varchar(255) DEFAULT NULL COMMENT '备注信息',
`status` char(1) NOT NULL DEFAULT '0' COMMENT '状态标记,0表示删除,1表示正常数据',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT 'buc中的user_id',
PRIMARY KEY (`id`),
KEY `idx_check_task_userid` (`user_id`)
)  AUTO_INCREMENT=24 ,DEFAULT CHARSET=utf8 ,COMMENT='检查任务';
CREATE TABLE if not exists `check_task_result` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '编号',
`check_task_id` bigint(20) NOT NULL COMMENT '检查任务ID，对应的是任务类型中的ID',
`object_id` varchar(64) DEFAULT NULL COMMENT '任务关联验证对象ID',
`object_type` varchar(64) DEFAULT NULL COMMENT '任务关联的验证对象类型',
`start_date` datetime DEFAULT NULL COMMENT '任务开始时间',
`end_date` datetime DEFAULT NULL COMMENT '任务结束时间',
`creator` varchar(64) DEFAULT NULL COMMENT '创建者',
`remarks` varchar(255) DEFAULT NULL COMMENT '备注信息',
`status` char(1) NOT NULL DEFAULT '1' COMMENT '状态标记,0任务删除,1表示正常',
`task_status` char(2) NOT NULL DEFAULT '0' COMMENT '状态标记,0待执行,1执行中,2执行成功,3执行失败,4执行取消',
PRIMARY KEY (`id`),
KEY `idx_check_task_id` (`check_task_id`)
)  AUTO_INCREMENT=122 ,DEFAULT CHARSET=utf8 ,COMMENT='检查任务结果';
CREATE TABLE if not exists `check_task_result_content` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '编号',
`check_task_result_id` bigint(20) NOT NULL COMMENT '检查任务结果ID',
`content_type` varchar(64) NOT NULL COMMENT '内容类型，自定义的ID在100以上，0-99属于系统预留内容类型',
`store_type` varchar(64) NOT NULL COMMENT '任务存储类型，0表示存储在CONTENT字段中，1表示存储在服务器临时文件目录，2表示存储在TFS系统',
`content_key` varchar(1000) DEFAULT NULL COMMENT '执行内容具体存储的位置，如文件路径，tfs文件的key',
`content` varchar(1024) COMMENT '本地存储，只支持文本类型',
`status` char(1) NOT NULL DEFAULT '1' COMMENT '状态标记,0任务删除,1表示正常',
PRIMARY KEY (`id`),
KEY `idx_check_task_result_id` (`check_task_result_id`)
)  AUTO_INCREMENT=113 ,DEFAULT CHARSET=utf8 ,COMMENT='检查任务结果具体内容，其中有标准类型的内容，支持统一页面处理，如excel文件等类型的文件，支持统一下载，html结果的文件，支持页面展现';
CREATE TABLE if not exists `datasource` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(100) NOT NULL COMMENT '标题',
`algorithm_desc` varchar(200) DEFAULT NULL COMMENT '算法描述',
`creator` varchar(20) NOT NULL COMMENT '创建者',
`input_template` varchar(1000) DEFAULT NULL COMMENT '输入配置模板',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0正常，1删除',
`engines` varchar(1000) DEFAULT NULL COMMENT '数据源支持的引擎',
`data_model` int(11) NOT NULL COMMENT '数据模型',
`type` varchar(100) DEFAULT NULL COMMENT '数据源业务类型（U站）',
`processer` varchar(100) DEFAULT NULL COMMENT '数据源处理流程',
PRIMARY KEY (`id`),
KEY `idx_st` (`status`),
KEY `idx_st_dm_cr` (`status`,`data_model`,`creator`)
)  AUTO_INCREMENT=23 ,DEFAULT CHARSET=utf8 ,COMMENT='投放数据源表';
CREATE TABLE if not exists `plan` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`scene_id` int(10) unsigned NOT NULL COMMENT '场景id',
`query_rules` varchar(1000) DEFAULT NULL COMMENT '查询规则',
`display_rule` varchar(1000) DEFAULT NULL COMMENT '展现规则',
`name` varchar(100) NOT NULL COMMENT '方案名称',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0正常 -1删除',
`ab_exp_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫实验id',
`ab_version_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫实验版本id',
`bucket_list` varchar(512) DEFAULT NULL COMMENT '天猫桶号id列表',
PRIMARY KEY (`id`),
KEY `idx_sid_stidx_sid_st` (`scene_id`,`status`),
KEY `idx_st` (`status`)
)  AUTO_INCREMENT=290 ,DEFAULT CHARSET=utf8 ,COMMENT='投放查询方案';
CREATE TABLE if not exists `scene` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`title` varchar(100) NOT NULL COMMENT '标题',
`description` varchar(300) DEFAULT NULL COMMENT '描述',
`status` int(11) NOT NULL COMMENT '状态',
`data_model` int(11) NOT NULL COMMENT '数据模型',
`creator` varchar(20) NOT NULL COMMENT '创建者',
`default_plan_id` int(11) DEFAULT NULL COMMENT '默认方案',
`ab_module_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫ab模块id',
PRIMARY KEY (`id`),
KEY `idx_st` (`status`),
KEY `idx_st_cr` (`status`,`creator`)
)  AUTO_INCREMENT=287 ,DEFAULT CHARSET=utf8 ,COMMENT='投放场景表';
CREATE TABLE if not exists `tce_component` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`title` varchar(48) DEFAULT NULL COMMENT '组件标题',
`description` varchar(1024) DEFAULT NULL COMMENT '组件描述',
`code` varchar(48) DEFAULT NULL COMMENT '组件编码',
`code_type` tinyint(4) DEFAULT NULL COMMENT '组件语言类型',
`biz_type` tinyint(4) DEFAULT NULL COMMENT '组件业务类型',
`svn` varchar(1024) DEFAULT NULL COMMENT 'svn地址',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='投放组件表';
CREATE TABLE if not exists `tce_component_config` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`config` varchar(4096) DEFAULT NULL COMMENT '组件配置',
`component_id` bigint(20) unsigned DEFAULT NULL COMMENT '组件id',
`data_plan_id` bigint(20) unsigned DEFAULT NULL COMMENT '投放方案id',
`phase_name` varchar(32) DEFAULT NULL COMMENT 'phase的名字',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='投放组件配置表';
CREATE TABLE if not exists `tce_data` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`data_key` varchar(96) DEFAULT NULL COMMENT '数据集的key',
`data_name` varchar(96) DEFAULT NULL COMMENT '数据中文标题',
`scene_id` bigint(20) unsigned DEFAULT NULL COMMENT '新场景id',
`parent` bigint(20) unsigned DEFAULT NULL COMMENT '父数据集',
`sequence` int(10) unsigned DEFAULT NULL COMMENT '索引号',
`is_dynamic` tinyint(4) DEFAULT NULL COMMENT '是否是动态',
`config` varchar(2048) DEFAULT NULL COMMENT '非TCE数据源配置',
`display_fields` varchar(2048) DEFAULT NULL COMMENT '展示字段配置',
`extend_fields` varchar(2048) DEFAULT NULL COMMENT '扩展字段配置',
`data_model_id` bigint(20) unsigned DEFAULT NULL COMMENT '数据模型id',
`ab_module_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫投放模块id',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`parent_plan_id` bigint(20) unsigned DEFAULT NULL COMMENT '上维方案id',
`parent_content_no` int(10) unsigned DEFAULT NULL COMMENT '上维坑位序号',
`data_model_code` varchar(32) DEFAULT NULL COMMENT '数据模型code',
`max_items` int(10) unsigned DEFAULT NULL COMMENT '表示支持最大方案数',
PRIMARY KEY (`id`),
KEY `ind_pa_st` (`parent`,`status`),
KEY `ind_sc_st` (`scene_id`,`status`)
)  AUTO_INCREMENT=77436 ,DEFAULT CHARSET=utf8 ,COMMENT='TCE投放数据规则表';
CREATE TABLE if not exists `tce_data_content` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`data_rule_id` bigint(20) unsigned DEFAULT NULL COMMENT '数据规则id',
`edit_content` varchar(4096) DEFAULT NULL COMMENT '编辑内容',
`publish_content` varchar(4096) DEFAULT NULL COMMENT '发布内容',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`sequence` int(10) unsigned DEFAULT NULL COMMENT '序号',
`scene_id` bigint(20) unsigned DEFAULT NULL COMMENT '场景id',
PRIMARY KEY (`id`),
KEY `ind_da` (`data_rule_id`,`status`)
)  AUTO_INCREMENT=1526731 ,DEFAULT CHARSET=utf8 ,COMMENT='数据内容表';
CREATE TABLE if not exists `tce_data_model` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`code` varchar(32) DEFAULT NULL COMMENT '模型编码',
`name` varchar(32) DEFAULT NULL COMMENT '模型名称',
`fields` varchar(2048) DEFAULT NULL COMMENT '模型字段列表',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=13 ,DEFAULT CHARSET=utf8 ,COMMENT='模型表';
CREATE TABLE if not exists `tce_data_plan` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`data_id` bigint(20) unsigned DEFAULT NULL COMMENT '数据规则id',
`title` varchar(48) DEFAULT NULL COMMENT '标题',
`data_count` int(10) unsigned DEFAULT NULL COMMENT '内容数量',
`conponent_config_id` bigint(20) unsigned DEFAULT NULL COMMENT '组件实例id',
`process` varchar(2048) DEFAULT NULL COMMENT '组件流程配置',
`ab_exp_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫实验id',
`ab_version_id` bigint(20) unsigned DEFAULT NULL COMMENT '天猫实验版本id',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`plan_index` int(10) unsigned DEFAULT NULL COMMENT '顺序',
`schedule_start` varchar(128) DEFAULT '0' COMMENT '排期开始时间',
`schedule_end` varchar(128) DEFAULT '0' COMMENT '排期截止时间',
`deduplicate_group` varchar(128) DEFAULT NULL COMMENT '去重分组',
`deduplicate_field` varchar(128) DEFAULT NULL COMMENT '去重字段',
`scene_id` bigint(20) unsigned DEFAULT NULL COMMENT '场景id',
PRIMARY KEY (`id`),
KEY `ind_da_st` (`data_id`,`status`)
)  AUTO_INCREMENT=92632 ,DEFAULT CHARSET=utf8 ,COMMENT='投放计划表';
CREATE TABLE if not exists `tce_data_rule` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`data_plan_id` bigint(20) unsigned DEFAULT NULL COMMENT '投放方案id',
`sequence` int(10) unsigned DEFAULT NULL COMMENT '序号',
`ref` bigint(20) unsigned DEFAULT NULL COMMENT '引用其他data_rule',
`is_dynamic` tinyint(4) DEFAULT NULL COMMENT '是否动态',
`datasource_id` bigint(20) unsigned DEFAULT NULL COMMENT '数据源id',
`data_count` int(10) unsigned DEFAULT NULL COMMENT '内容数量',
`query` varchar(4096) DEFAULT NULL COMMENT '参数规则',
`field_map` varchar(2048) DEFAULT NULL COMMENT '字段映射',
`tce_field_map` varchar(4096) DEFAULT NULL COMMENT 'tce的字段映射',
`status` tinyint(4) DEFAULT NULL COMMENT '状态 -1表示删除',
`page_content_id` bigint(20) unsigned DEFAULT '0' COMMENT '模块ID',
`data_model_key` varchar(256) DEFAULT NULL COMMENT '对应模块的数据模型key',
`scene_id` bigint(20) unsigned DEFAULT '0' COMMENT '场景ID',
PRIMARY KEY (`id`),
KEY `ind_da_st` (`data_plan_id`,`status`),
KEY `ind_id_st` (`id`,`status`)
)  AUTO_INCREMENT=346704 ,DEFAULT CHARSET=utf8 ,COMMENT='投放数据规则表';
CREATE TABLE if not exists `tce_datasource` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`data_model_id` bigint(20) unsigned DEFAULT NULL COMMENT '数据模型id',
`query_schema` varchar(4096) DEFAULT NULL COMMENT '数据参数配置',
`component_id` bigint(20) unsigned DEFAULT NULL COMMENT '组件id',
`supply_fields` varchar(1024) DEFAULT NULL COMMENT '补全字段',
`type` varchar(50) DEFAULT NULL COMMENT '数据源类型code',
`description` varchar(2048) DEFAULT NULL COMMENT '数据源描述信息',
`status` tinyint(4) DEFAULT '0' COMMENT '数据源状态',
`title` varchar(512) DEFAULT NULL COMMENT '数据源名称',
`model_fields` varchar(4096) DEFAULT NULL COMMENT '数据源字段描述',
`code` varchar(32) DEFAULT NULL COMMENT '数据源编码',
`component_config` varchar(2048) DEFAULT NULL COMMENT '数据源组件配置',
`dump_config` varchar(2048) DEFAULT NULL COMMENT 'dump配置',
`source` tinyint(4) DEFAULT NULL COMMENT '数据来源(hbase/hdfs)',
`model_path` varchar(512) DEFAULT NULL COMMENT '数据模型路径',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=60 ,DEFAULT CHARSET=utf8 ,COMMENT='投放数据源配置表';
CREATE TABLE if not exists `tce_global_rule` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(48) DEFAULT NULL COMMENT '创建人',
`scene_data_id` bigint(20) unsigned DEFAULT NULL COMMENT 'sceneData的id',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`datasource_id` int(10) unsigned DEFAULT NULL COMMENT '数据源id',
`data_count` int(11) DEFAULT NULL COMMENT '内容数',
`offset` varchar(1024) DEFAULT NULL COMMENT '坑位序号',
`query` varchar(1024) COMMENT '请求串',
`config` varchar(1024) COMMENT '配置',
`field_map` varchar(1024) COMMENT '字段映射',
`tce_field_map` varchar(1024) COMMENT 'tce字段映射',
`page_content_id` bigint(20) unsigned DEFAULT NULL COMMENT '模块id',
`data_model_key` varchar(256) DEFAULT NULL COMMENT '数据集key',
`scene_id` bigint(20) unsigned DEFAULT NULL COMMENT '场景id',
PRIMARY KEY (`id`),
KEY `idx_scene_data_id` (`scene_data_id`)
)  AUTO_INCREMENT=36 ,DEFAULT CHARSET=utf8 ,COMMENT='全局rule';
CREATE TABLE if not exists `tce_resource` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(32) DEFAULT NULL COMMENT '创建人',
`title` varchar(256) DEFAULT NULL COMMENT '资源位标题',
`admins` varchar(256) DEFAULT NULL COMMENT '管理员',
`material_admins` varchar(256) DEFAULT NULL COMMENT '素材审核管理员',
`data_schema` varchar(1024) COMMENT '字段结构',
`model` tinyint(4) DEFAULT NULL COMMENT '数据模型',
`start_days` int(11) DEFAULT NULL COMMENT '最早开始时间距活动天数',
`end_days` int(11) DEFAULT NULL COMMENT '最晚截止时间距活动天数',
`meta` varchar(2048) DEFAULT NULL COMMENT '备用信息字段',
`format` varchar(2048) DEFAULT NULL COMMENT '字段规格',
`apply_check` tinyint(4) DEFAULT NULL COMMENT '是否开启资源位审核流程',
`material_check` tinyint(4) DEFAULT NULL COMMENT '是否开启素材审核流程',
`tms_site_id` bigint(20) DEFAULT NULL COMMENT 'tms站点id',
`tms_site_name` varchar(48) DEFAULT NULL COMMENT 'tms站点名称',
`tms_page_id` bigint(20) DEFAULT NULL COMMENT 'tms页面id',
`tms_module_id` bigint(20) DEFAULT NULL COMMENT 'tms模块id',
`scene_id` bigint(20) DEFAULT NULL COMMENT '场景id',
`spm` varchar(256) DEFAULT NULL COMMENT '埋点',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`data_count` int(11) DEFAULT NULL COMMENT '内容数',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=64 ,DEFAULT CHARSET=utf8 ,COMMENT='资源位表';
CREATE TABLE if not exists `tce_scene` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`code` varchar(32) DEFAULT NULL COMMENT '编码',
`title` varchar(32) DEFAULT NULL COMMENT '中文标题',
`status` tinyint(4) DEFAULT NULL COMMENT '状态',
`module_info` varchar(4096) DEFAULT NULL COMMENT '单维结构',
`version` bigint(20) unsigned DEFAULT NULL COMMENT '版本号',
`data_schema` varchar(1024) COMMENT '结构描述',
`dpl_module_id` bigint(20) unsigned DEFAULT NULL COMMENT 'DPL的模块id',
`page_content_id` bigint(20) unsigned DEFAULT NULL COMMENT '模块表id',
`description` varchar(1024) DEFAULT NULL COMMENT '场景描述',
`creator` varchar(48) DEFAULT NULL COMMENT '场景创建人',
`biz_type` varchar(48) DEFAULT 'tms' COMMENT '业务类型',
`page_id` bigint(20) unsigned DEFAULT NULL COMMENT 'tms页面ID',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '场景的特性',
PRIMARY KEY (`id`),
KEY `content_index` (`page_content_id`,`status`),
KEY `ind_pa` (`page_id`),
KEY `ind_co_bi` (`page_content_id`,`biz_type`)
)  AUTO_INCREMENT=34193 ,DEFAULT CHARSET=utf8 ,COMMENT='投放平台新场景';
CREATE TABLE if not exists `tce_scene_version` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`creator` varchar(64) DEFAULT NULL COMMENT '创建人',
`type` tinyint(4) DEFAULT NULL COMMENT '版本类型',
`file_name` varchar(1024) DEFAULT NULL COMMENT '文件名称',
`status` tinyint(4) DEFAULT NULL COMMENT '版本状态',
`scene_id` bigint(20) DEFAULT '-1' COMMENT '场景id',
`schema_version` varchar(512) DEFAULT '0' COMMENT 'schema的version',
PRIMARY KEY (`id`),
KEY `ind_sid_sv_s_c` (`gmt_create`,`status`,`scene_id`,`schema_version`),
KEY `ind_sid_sv_s` (`scene_id`,`schema_version`,`status`)
)  AUTO_INCREMENT=102902 ,DEFAULT CHARSET=utf8 ,COMMENT='投放场景版本控制表';
CREATE TABLE if not exists `tce_script_meta` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(32) NOT NULL COMMENT '脚本名称',
`type` char(2) NOT NULL COMMENT '脚本类型',
`status` char(2) NOT NULL COMMENT '脚本状态，1-启用，0-禁用',
`creator` varchar(32) NOT NULL COMMENT '脚本创建人',
`description` varchar(128) DEFAULT NULL COMMENT '脚本描述',
`model` char(2) NOT NULL COMMENT '脚本模型',
PRIMARY KEY (`id`),
KEY `idx_name` (`name`),
KEY `idx_statux` (`status`),
KEY `idx_type` (`type`),
KEY `idx_id_type_status` (`id`,`type`,`status`)
)  AUTO_INCREMENT=5 ,DEFAULT CHARSET=utf8 ,COMMENT='tce动态脚本元信息';
CREATE TABLE if not exists `tce_script_repository` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`meta_id` bigint(20) unsigned NOT NULL COMMENT '关联元信息ID',
`version` char(16) NOT NULL DEFAULT '1' COMMENT '脚本版本',
`creator` varchar(32) NOT NULL COMMENT '创建人',
`content` varchar(128) DEFAULT NULL COMMENT '脚本内容-tfspath',
`check_code` varchar(128) DEFAULT NULL COMMENT '脚本校验码',
PRIMARY KEY (`id`),
UNIQUE KEY `uniq_meta_id_version` (`meta_id`,`version`),
KEY `idx_meta_id` (`meta_id`),
KEY `idx_meta_id_version` (`meta_id`,`version`)
)  AUTO_INCREMENT=5 ,DEFAULT CHARSET=utf8 ,COMMENT='tce动态脚本资源库';
CREATE TABLE if not exists `tce_script_work` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`meta_id` bigint(20) unsigned NOT NULL COMMENT '关联元信息ID',
`status` char(2) NOT NULL COMMENT '本地库脚本状态，1-已同步,0-未同步',
`content` varchar(128) DEFAULT NULL COMMENT '脚本内容-tfspath',
`creator` varchar(32) NOT NULL COMMENT '创建人',
`check_code` varchar(128) DEFAULT NULL COMMENT '脚本校验码',
`repository_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '关联版本库ID',
PRIMARY KEY (`id`),
KEY `idx_meta_id` (`meta_id`),
KEY `idx_status` (`status`),
KEY `idx_repository_id` (`repository_id`),
KEY `idx_metaid_status` (`id`,`meta_id`,`status`)
)  AUTO_INCREMENT=5 ,DEFAULT CHARSET=utf8 ,COMMENT='tce动态脚本本地库';
CREATE TABLE if not exists `tcp_classify` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`model_id` int(10) unsigned NOT NULL COMMENT '选品模型id',
`name` varchar(128) NOT NULL COMMENT '名称',
`ownner` varchar(64) NOT NULL COMMENT '创建者',
`description` varchar(256) DEFAULT NULL COMMENT '描述',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0:正常
-1:删除',
`group_order` int(10) unsigned DEFAULT '1' COMMENT '组内顺序',
PRIMARY KEY (`id`),
KEY `idx_modelid` (`model_id`,`status`),
KEY `idx_name` (`name`),
KEY `ind_ow_mo` (`ownner`,`model_id`)
)  AUTO_INCREMENT=1238 ,DEFAULT CHARSET=utf8 ,COMMENT='分类(场景)表，规则，指标都需要属于某一分类，比如美妆，全球购';
CREATE TABLE if not exists `tcp_export` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`model_id` bigint(20) unsigned NOT NULL COMMENT '模型id',
`name` varchar(64) NOT NULL COMMENT '渠道名称',
`value` varchar(64) NOT NULL COMMENT '渠道唯一标识',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '1:启用
0:待启用
-1:删除',
`config` varchar(512) DEFAULT NULL COMMENT '配置',
`type` int(11) DEFAULT NULL COMMENT '类型',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='选品输出配置表';
CREATE TABLE if not exists `tcp_indicator` (
`id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '指标名称',
`tips` varchar(512) DEFAULT NULL COMMENT '指标提示',
`ownner` varchar(64) NOT NULL COMMENT '创建者',
`provider` varchar(512) DEFAULT NULL COMMENT '指标提供者',
`model_id` int(10) unsigned NOT NULL COMMENT '所属模型id',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0:未上线
1:上线
-1:删除',
`group_id` int(10) unsigned NOT NULL COMMENT '分组id',
`classify_ids` varchar(128) NOT NULL COMMENT '所属行业，逗号分割',
`page_class` varchar(1024) NOT NULL COMMENT '指标所用筛选组件类',
`page_parameter` varchar(512) NOT NULL COMMENT '指标所用筛选参数',
`features` varchar(1024) DEFAULT NULL COMMENT '扩展字段',
`group_order` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '组内排序',
`description` varchar(1024) DEFAULT NULL COMMENT '指标描述',
PRIMARY KEY (`id`),
KEY `ind_name` (`name`),
KEY `ind_classify` (`classify_ids`)
)  AUTO_INCREMENT=131 ,DEFAULT CHARSET=utf8 ,COMMENT='选品筛选指标表';
CREATE TABLE if not exists `tcp_indicator_group` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '分组名',
`model_id` int(10) unsigned NOT NULL COMMENT '选品模型id',
`status` int(11) DEFAULT NULL COMMENT '0:正常
-1:删除',
`group_order` int(10) unsigned DEFAULT '1' COMMENT '组内顺序',
PRIMARY KEY (`id`),
KEY `idx_modelid_status` (`model_id`,`status`),
KEY `ind_na_mo` (`name`,`model_id`)
)  AUTO_INCREMENT=53 ,DEFAULT CHARSET=utf8 ,COMMENT='指标分组表';
CREATE TABLE if not exists `tcp_indicator_statistic` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`indicator_id` bigint(20) unsigned NOT NULL COMMENT '指标id',
`stat_info` varchar(1024) NOT NULL COMMENT '统计结果，用json存储以适应格式变化',
`ds` bigint(20) unsigned DEFAULT NULL COMMENT '统计时间',
PRIMARY KEY (`id`),
KEY `ind_in_ds` (`indicator_id`,`ds`)
)  DEFAULT CHARSET=utf8 ,COMMENT='选品指标统计结果';
CREATE TABLE if not exists `tcp_model` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '模型名称',
`description` varchar(1024) DEFAULT NULL COMMENT '模型描述',
`ownner` varchar(64) NOT NULL COMMENT '创建者',
`status` int(11) NOT NULL COMMENT '0:新增
1:上线
-1:删除',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=2 ,DEFAULT CHARSET=utf8 ,COMMENT='选品模型，代表一种类型的选品';
CREATE TABLE if not exists `tcp_rule` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`parent_id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '父规则id',
`model_id` int(10) unsigned NOT NULL COMMENT '所属选品模型id',
`classify_id` int(10) unsigned NOT NULL COMMENT '规则分类id',
`name` varchar(128) NOT NULL COMMENT '规则名称',
`ownner` varchar(64) NOT NULL COMMENT '规则创建者',
`status` int(11) DEFAULT NULL COMMENT '规则状态 1:启用 0:未启用 -1:删除',
`export` varchar(2048) DEFAULT NULL COMMENT '选品结果输出定义',
`features` varchar(512) DEFAULT NULL COMMENT '扩展字段',
PRIMARY KEY (`id`),
KEY `ind_export` (`export`),
KEY `ind_modelid_status` (`model_id`,`status`),
KEY `ind_name` (`name`),
KEY `ind_ownner` (`ownner`)
)  AUTO_INCREMENT=10236 ,DEFAULT CHARSET=utf8 ,COMMENT='选品规则表';
CREATE TABLE if not exists `tcp_rule_condition` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`parent_id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '父id',
`rule_id` int(10) unsigned NOT NULL COMMENT '规则id',
`model_id` int(10) unsigned NOT NULL COMMENT '选品模型id',
`model_data` varchar(1024) COMMENT 'model数据',
`model_type` varchar(512) NOT NULL COMMENT 'model class',
`features` varchar(1024) DEFAULT NULL COMMENT '扩展字段',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0:正常
-1:删除',
`indicator` varchar(64) DEFAULT NULL COMMENT '对应指标',
`name` varchar(128) DEFAULT NULL COMMENT '名称',
PRIMARY KEY (`id`),
KEY `indx_rule` (`rule_id`),
KEY `indx_model` (`model_id`),
KEY `indx_parent` (`parent_id`)
)  AUTO_INCREMENT=184555 ,DEFAULT CHARSET=utf8 ,COMMENT='选品规则条件表';
CREATE TABLE if not exists `tcp_rule_statistic` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`rule_id` bigint(20) unsigned NOT NULL COMMENT '规则id',
`item_count` bigint(20) unsigned DEFAULT NULL COMMENT '商品数量',
`seller_count` bigint(20) unsigned DEFAULT NULL COMMENT '卖家数量',
`need_supply` bigint(20) unsigned DEFAULT NULL COMMENT '0:正常不需要补全,1:需要补全(完全没数量),2:需要补全(数量小于设定)',
`min_item_count` bigint(20) unsigned DEFAULT NULL COMMENT '规则设定最小数量',
`tag_id` bigint(20) unsigned DEFAULT NULL COMMENT '规则需要打标的ID,如果不是打标规则id则为null',
`ds` bigint(20) unsigned NOT NULL COMMENT '数据时间',
PRIMARY KEY (`id`),
KEY `ind_ru` (`rule_id`)
)  AUTO_INCREMENT=56453 ,DEFAULT CHARSET=utf8 ,COMMENT='全量筛选统计结果表';
CREATE TABLE if not exists `tcp_seller_indicator` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '名称',
`type` tinyint(3) unsigned NOT NULL COMMENT '0:数值,1:布尔,2:枚举，3:字符',
`group_id` bigint(20) unsigned NOT NULL COMMENT '组id，tcp_seller_indicator_group表主键',
`status` tinyint(3) unsigned NOT NULL COMMENT '0:正常，-1:删除',
`page_info` varchar(1024) COMMENT '配置数据',
`use_type` tinyint(3) unsigned NOT NULL COMMENT '能否用于筛选.0:no,1:yes',
`description` varchar(2048) DEFAULT NULL COMMENT '描述',
`is_public` tinyint(3) unsigned NOT NULL COMMENT '能否公共调取.0:no,1:yes',
`owner` varchar(128) DEFAULT NULL COMMENT '创建者nick',
PRIMARY KEY (`id`),
KEY `ind_status` (`status`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家分层指标表';
CREATE TABLE if not exists `tcp_seller_indicator_group` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '名称',
`status` tinyint(4) NOT NULL COMMENT '状态。0:正常，-1：删除',
`description` varchar(2048) DEFAULT NULL COMMENT '描述',
PRIMARY KEY (`id`),
KEY `status` (`status`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家字段分类表';
CREATE TABLE if not exists `tcp_seller_rule` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(128) NOT NULL COMMENT '名称',
`owner` varchar(128) DEFAULT NULL COMMENT '状态.0:正常,-1：删除',
`period` varchar(2048) NOT NULL COMMENT '周期，如半个月。',
`description` varchar(2048) DEFAULT NULL COMMENT '描述',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家分层规则';
CREATE TABLE if not exists `tcp_seller_rule_condition` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`rule_id` bigint(20) unsigned NOT NULL COMMENT '规则id,tcp_seller_rule表主键',
`parent_id` bigint(20) unsigned NOT NULL COMMENT '父id',
`indicator_id` bigint(20) unsigned DEFAULT NULL COMMENT '指标id',
`model_data` varchar(16384) NOT NULL COMMENT '选择内容',
`model_type` varchar(2048) NOT NULL COMMENT '模型的java类路径',
`group_id` bigint(20) unsigned NOT NULL COMMENT '指标分组id',
`name` varchar(1024) DEFAULT NULL COMMENT '名称',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家分层详细条目设置';
CREATE TABLE if not exists `tcp_seller_rule_stat` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`rule_id` bigint(20) unsigned NOT NULL COMMENT '分层规则id,tcp_seller_rule主键',
`stat_info` varchar(16384) NOT NULL COMMENT '结果内容。json格式，方便扩展',
`ds` bigint(20) unsigned NOT NULL COMMENT '统计时间，odps上的分区',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家分层数据统计';
