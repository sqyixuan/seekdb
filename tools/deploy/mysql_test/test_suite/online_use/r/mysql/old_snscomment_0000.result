CREATE TABLE if not exists `comment_type` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`app_id` bigint(20) DEFAULT NULL COMMENT '应用id',
`type_id` int(11) NOT NULL COMMENT '类型',
`app_name` varchar(32) DEFAULT NULL COMMENT 'app 名称',
`extra_content` varchar(512) DEFAULT NULL COMMENT '扩展字段',
`group_name` varchar(32) DEFAULT NULL COMMENT '分组：赞、评论',
`descriptions` varchar(256) DEFAULT NULL COMMENT '描述',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`apply_user_id` bigint(20) NOT NULL COMMENT '申请人userId',
`apply_user_nick` varchar(32) NOT NULL COMMENT '申请人旺旺号',
`site_url` varchar(128) NOT NULL COMMENT '申请应用网址',
PRIMARY KEY (`id`),
KEY `ind_COMMENT_TYPE_group` (`group_name`,`type_id`),
KEY `ind_COMMENT_TYPE_app` (`app_id`,`type_id`)
)  AUTO_INCREMENT=837 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `evaluate_0000` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '鑷??涓婚敭',
`evaluate_id` bigint(20) NOT NULL COMMENT '璇勪环id',
`explain_content` varchar(1000) DEFAULT NULL COMMENT '瑙ｉ噴鍐呭?',
`user_id` bigint(20) NOT NULL COMMENT '解释发表者',
`user_nick` varchar(32) DEFAULT NULL COMMENT '解释发表者昵称',
`recevied_user_id` bigint(20) NOT NULL COMMENT '被解释者id',
`recevied_user_nick` varchar(32) DEFAULT NULL COMMENT '被解释者昵称',
`is_deleted` tinyint(4) NOT NULL DEFAULT '0' COMMENT '閫昏緫鍒犻櫎瀛楁?',
`gmt_create` datetime NOT NULL COMMENT '璁板綍鍒涘缓鏃堕棿',
`gmt_modified` datetime NOT NULL COMMENT '璁板綍鏈?悗淇?敼鏃堕棿',
`modifier_id` bigint(20) DEFAULT NULL COMMENT '鍒犻櫎浜',
`comment_id` bigint(20) NOT NULL COMMENT '璇勮?id',
`item_id` bigint(20) DEFAULT NULL COMMENT '商品id',
`creator_id` bigint(20) DEFAULT NULL COMMENT '创建者id，子账号的时候用',
PRIMARY KEY (`id`),
KEY `idx_eid_sid_id` (`evaluate_id`,`user_id`,`is_deleted`),
KEY `idx_iid` (`item_id`,`user_id`,`is_deleted`)
)  AUTO_INCREMENT=464120083 ,DEFAULT CHARSET=utf8;
