CREATE TABLE if not exists `my_favor_0000` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '鑷??涓婚敭',
`target_id` bigint(20) NOT NULL COMMENT 'typeid:target_key鐨刪ash鍊',
`target_key` varchar(60) NOT NULL COMMENT '鐩稿叧涓氬姟鐨勪富閿',
`user_id` bigint(20) NOT NULL COMMENT '鍒嗚〃渚濇嵁锛屽垱寤鸿?id',
`type_id` bigint(20) NOT NULL COMMENT '绫诲瀷',
`app_id` bigint(20) DEFAULT NULL COMMENT 'appid',
`rec_user_id` bigint(20) DEFAULT NULL COMMENT '鎺ユ敹璧炵殑鐢ㄦ埛id(鐩稿叧涓氬姟鐨勬嫢鏈夎?)',
`properties` varchar(1024) DEFAULT NULL COMMENT '鎵╁睍灞炴?锛屽彲浠ュ寘鎷?紙绯荤粺娑堟伅id锛岃浆鍙戠殑feedid绛夛級',
`gmt_create` datetime NOT NULL COMMENT '鍒涘缓鏃堕棿',
`gmt_modified` datetime NOT NULL COMMENT '淇?敼鏃堕棿',
`sub_type` tinyint(4) DEFAULT NULL COMMENT '瀛愮被鍨?椤躲?韪╃瓑',
`client_id` bigint(20) NOT NULL DEFAULT '0' COMMENT 'clientId',
PRIMARY KEY (`id`),
KEY `idx_uid_tid_cid_st` (`user_id`,`type_id`,`client_id`,`sub_type`,`gmt_create`),
KEY `idx_uid_tid_tkey_cid` (`user_id`,`target_id`,`target_key`,`client_id`,`sub_type`)
)  AUTO_INCREMENT=955872060 ,DEFAULT CHARSET=utf8 ,COMMENT='鎴戣禐杩囩殑琛';
