CREATE TABLE if not exists `auditting_comment` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`target_key` varchar(60) NOT NULL COMMENT '业务主键',
`type_id` int(11) NOT NULL COMMENT '业务类型',
`comment_id` bigint(20) NOT NULL COMMENT '评论id',
`comment_target_info` varchar(1024) NOT NULL COMMENT '附加字段',
`client_id` bigint(20) unsigned NOT NULL COMMENT 'client_id',
`is_forward` tinyint(4) NOT NULL COMMENT '是否转发',
`is_deal` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否被处理过0未处理，1处理过',
PRIMARY KEY (`id`),
KEY `idx_is_deal_gmt_create` (`is_deal`,`gmt_create`)
)  DEFAULT CHARSET=utf8 ,COMMENT='审核评论表';
CREATE TABLE if not exists `comm_del_detail` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`comment_id` bigint(20) NOT NULL COMMENT '评论ID',
`from_type` tinyint(4) NOT NULL COMMENT '评论来源类型，0表示cc，1表示feed',
`subject_id` bigint(20) NOT NULL COMMENT 'cc评论时表示targetId,feed评论时表示feedId',
`operator_id` bigint(20) NOT NULL COMMENT '删除者ID',
`gmt_create` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_detail_commentid` (`comment_id`,`from_type`)
)  AUTO_INCREMENT=17956074 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `comm_del_his_oper_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`owner_user_id` bigint(20) NOT NULL,
`owner_nick` varchar(32) NOT NULL,
`content` varchar(2000) NOT NULL,
`del_count` int(11) NOT NULL,
`oper_reason` varchar(512) NOT NULL,
`operator_id` bigint(20) NOT NULL,
`operator_nick` varchar(32) NOT NULL,
`oper_type` tinyint(4) NOT NULL,
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_oper_operid` (`operator_id`,`gmt_create`,`owner_user_id`)
)  AUTO_INCREMENT=30329146 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `comm_del_his_owner_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`owner_user_id` bigint(20) NOT NULL,
`owner_nick` varchar(32) NOT NULL,
`content` varchar(2000) NOT NULL,
`del_count` int(11) NOT NULL,
`oper_reason` varchar(512) NOT NULL,
`operator_id` bigint(20) NOT NULL,
`operator_nick` varchar(32) NOT NULL,
`oper_type` tinyint(4) NOT NULL,
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_owner_owneruid` (`owner_user_id`,`gmt_create`,`operator_id`)
)  AUTO_INCREMENT=30397146 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `comment_0000` (
`id` bigint(20) NOT NULL,
`target_id` bigint(20) NOT NULL,
`target_key` varchar(60) NOT NULL,
`pro_user_id` bigint(20) NOT NULL,
`pro_user_nick` varchar(32) DEFAULT NULL,
`status` tinyint(4) DEFAULT NULL,
`whisper` tinyint(4) DEFAULT NULL,
`content` varchar(2000) DEFAULT NULL,
`rec_user_id` bigint(20) NOT NULL,
`rec_user_nick` varchar(32) DEFAULT NULL,
`type_id` int(11) NOT NULL,
`parent_id` bigint(20) DEFAULT NULL,
`quote_id` bigint(20) DEFAULT NULL,
`rec_user_pic` varchar(500) DEFAULT NULL,
`pro_user_pic` varchar(500) DEFAULT NULL,
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`char_1` varchar(1200) DEFAULT NULL,
`number_1` bigint(20) DEFAULT NULL,
`date_1` datetime DEFAULT NULL,
`is_deleted` tinyint(4) NOT NULL DEFAULT '0',
`comment_index` int(11) DEFAULT NULL COMMENT '楼层序号',
`tag` varchar(32) DEFAULT NULL,
`sub_type` tinyint(4) DEFAULT NULL,
`froms` tinyint(4) DEFAULT NULL,
`modifier` bigint(20) DEFAULT NULL,
`image_urls` varchar(512) DEFAULT NULL,
`client_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '客户端id',
`app_id` bigint(20) DEFAULT NULL COMMENT '应用id',
`ip` varchar(32) DEFAULT NULL COMMENT '记录用户IP',
PRIMARY KEY (`id`),
KEY `idx_comment_gmtmodified` (`gmt_modified`),
KEY `idx_comment_targetid` (`target_id`,`target_key`,`is_deleted`,`gmt_create`,`pro_user_id`),
KEY `idx_comment_typeid` (`type_id`,`is_deleted`,`target_key`)
)  DEFAULT CHARSET=utf8;
