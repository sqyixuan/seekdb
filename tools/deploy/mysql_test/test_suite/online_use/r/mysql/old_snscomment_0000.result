CREATE TABLE if not exists `judge_result` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`content` varchar(1024) NOT NULL COMMENT '内容',
`content_id` bigint(20) unsigned NOT NULL COMMENT '内容来源主键ID',
`type` tinyint(4) NOT NULL COMMENT '结果类型 1:误杀2:漏杀',
`rid` varchar(100) DEFAULT NULL COMMENT '规则id',
`rscore` float DEFAULT NULL COMMENT '分值--关联着规则',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`date` varchar(10) DEFAULT NULL COMMENT '日期',
`app_id` bigint(20) unsigned DEFAULT '0' COMMENT '应用id',
PRIMARY KEY (`id`),
KEY `index_app_type_date` (`app_id`,`type`,`date`)
)  AUTO_INCREMENT=134 ,DEFAULT CHARSET=utf8 ,COMMENT='作为垃圾防控的评测记录';
CREATE TABLE if not exists `judge_statistics` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`miss_count` int(11) DEFAULT '0' COMMENT '漏杀数量',
`kill_count` int(11) DEFAULT '0' COMMENT '误杀数量',
`rid` varchar(100) DEFAULT NULL COMMENT '规则ID',
`type` tinyint(4) DEFAULT '0' COMMENT '统计类型,0表示全部统计，1表示按照rid的统计。',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`kill_total` int(11) DEFAULT '0' COMMENT '误杀评测总数',
`miss_total` int(11) DEFAULT '0' COMMENT '漏杀评测总数',
`app_id` bigint(20) unsigned DEFAULT NULL COMMENT '应用ID',
`date` varchar(10) NOT NULL COMMENT '数据时间',
`missall` bigint(20) unsigned DEFAULT NULL COMMENT '正常数据的总数',
PRIMARY KEY (`id`),
KEY `idx_app_id_type` (`app_id`,`type`),
KEY `idx_date_type` (`date`,`type`)
)  AUTO_INCREMENT=968 ,DEFAULT CHARSET=utf8 ,COMMENT='评测统计表';
