CREATE TABLE if not exists `group_shop_binding` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`group_id` bigint(20) unsigned NOT NULL COMMENT '帮派ID',
`shop_id` bigint(20) unsigned NOT NULL COMMENT '店铺ID',
`thread_count` tinyint(4) unsigned NOT NULL COMMENT '显示帖子数',
`activity_count` tinyint(4) unsigned NOT NULL COMMENT '显示活动数量',
`digest_prior` tinyint(4) unsigned NOT NULL DEFAULT '0' COMMENT '精华优先',
`top_prior` tinyint(4) unsigned NOT NULL DEFAULT '0' COMMENT '置顶优先',
`number_1` bigint(20) unsigned DEFAULT NULL COMMENT '备用字段',
`char_1` varchar(256) DEFAULT NULL COMMENT '备用字段',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_group_shop_binding_gid` (`group_id`),
UNIQUE KEY `uk_group_shop_binding_sid` (`shop_id`),
KEY `idx_group_shop_binding_gmod` (`gmt_modified`)
)  DEFAULT CHARSET=utf8 ,COMMENT='帮派和店铺绑定表';
CREATE TABLE if not exists `group_thread_body_0000` (
`thread_id` bigint(20) NOT NULL,
`group_id` bigint(20) NOT NULL,
`content` varchar(1024) NOT NULL,
`number_1` bigint(20) DEFAULT NULL,
`reply` varchar(1000) DEFAULT NULL COMMENT '小二回复',
`reply_time` datetime DEFAULT NULL COMMENT '小二回复时间',
`content_flag` tinyint(3) unsigned DEFAULT NULL COMMENT '区分是content_ext存放的是帖子内容还是帖子内容对应的TFS的KEY',
`content_ext` varchar(1000) DEFAULT NULL,
PRIMARY KEY (`thread_id`),
KEY `idx_body_replytime` (`reply_time`)
)  DEFAULT CHARSET=utf8;
