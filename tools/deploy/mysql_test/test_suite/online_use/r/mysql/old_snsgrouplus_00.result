`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_original_pic` (`original_pic`)
)  AUTO_INCREMENT=867 ,DEFAULT CHARSET=utf8 ,COMMENT='帖子原始图片与缩略图片的对应关系';
