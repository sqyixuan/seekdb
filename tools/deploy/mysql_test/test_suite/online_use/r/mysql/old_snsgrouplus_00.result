CREATE TABLE if not exists `group_user_recommand_0000` (
`id` bigint(20) NOT NULL COMMENT '主键',
`user_id` bigint(20) NOT NULL COMMENT 'userid',
`user_nick` varchar(32) NOT NULL COMMENT 'usernick',
`group_id` bigint(20) NOT NULL COMMENT '圈子id',
`weight` int(11) NOT NULL COMMENT '推荐的圈子的权重，共2级，0为最高，1为普通',
`is_read` int(11) NOT NULL COMMENT '是否已经展示过了',
`deleted` int(11) NOT NULL COMMENT '用户是否点击了“不再推荐”',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
PRIMARY KEY (`id`),
KEY `idx_gur_uid` (`user_id`,`deleted`,`is_read`,`weight`,`gmt_create`)
)  DEFAULT CHARSET=utf8 ,COMMENT='用户的圈子精准推荐表';
