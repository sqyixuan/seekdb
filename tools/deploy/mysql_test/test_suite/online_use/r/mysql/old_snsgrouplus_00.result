set ob_query_timeout = 500000000;
set ob_trx_timeout = 500000000;
set global recyclebin = 'off';
DROP DATABASE if EXISTS snsgrouplus;
CREATE DATABASE snsgrouplus;
USE snsgrouplus;
CREATE TABLE if not exists `bbs_thread_temp` (
`id` bigint(20) NOT NULL,
`group_id` bigint(20) NOT NULL,
`from_id` bigint(20) NOT NULL,
`from_group_id` bigint(20) NOT NULL,
`subject` varchar(50) NOT NULL,
`type` tinyint(4) NOT NULL,
`status` tinyint(4) NOT NULL,
`digest` tinyint(4) NOT NULL,
`deleted` tinyint(4) NOT NULL,
`view_count` int(11) NOT NULL,
`reply_count` int(11) NOT NULL,
`author_id` bigint(20) NOT NULL,
`author_nick` varchar(32) NOT NULL,
`author_ip` varchar(16) NOT NULL,
`last_reply_author_id` bigint(20) DEFAULT NULL,
`last_reply_author_nick` varchar(32) DEFAULT NULL,
`last_reply_id` bigint(20) DEFAULT NULL,
`last_reply_time` datetime DEFAULT NULL,
`last_modified` datetime DEFAULT NULL COMMENT '最后修改时间',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`options` bigint(20) DEFAULT NULL COMMENT '是否有小二回复',
`char_1` varchar(256) DEFAULT NULL,
`from_group_name` varchar(50) DEFAULT NULL,
`board_id` bigint(20) DEFAULT NULL,
`category` tinyint(4) DEFAULT NULL,
`verify` smallint(6) DEFAULT NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)',
`operator_id` bigint(20) DEFAULT NULL COMMENT '审核人的id',
`operator_time` datetime DEFAULT NULL COMMENT '操作时间',
`rated_respect` int(11) DEFAULT NULL COMMENT '被评价的分数',
`tp_id` bigint(20) DEFAULT NULL COMMENT '合作伙伴id，若为空，则来源为淘宝',
`priority` int(11) DEFAULT NULL COMMENT '优先级',
`extra_user_id` bigint(20) DEFAULT NULL COMMENT '外部第三方名称',
`sync_to_tp` tinyint(4) DEFAULT NULL COMMENT '是否同步给第三方（0不同步，1同步）',
`content` varchar(1024) NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_btt_anick` (`author_nick`,`type`,`deleted`)
)  DEFAULT CHARSET=utf8 ,COMMENT='论坛美妆论坛帖子迁入圈子的临时表';
CREATE TABLE if not exists `bbs_thread_temp_bak` (
`id` bigint(20) NOT NULL,
`group_id` bigint(20) NOT NULL,
`from_id` bigint(20) NOT NULL,
`from_group_id` bigint(20) NOT NULL,
`subject` varchar(50) NOT NULL,
`type` tinyint(4) NOT NULL,
`status` tinyint(4) NOT NULL,
`digest` tinyint(4) NOT NULL,
`deleted` tinyint(4) NOT NULL,
`view_count` int(11) NOT NULL,
`reply_count` int(11) NOT NULL,
`author_id` bigint(20) NOT NULL,
`author_nick` varchar(32) NOT NULL,
`author_ip` varchar(16) NOT NULL,
`last_reply_author_id` bigint(20) DEFAULT NULL,
`last_reply_author_nick` varchar(32) DEFAULT NULL,
`last_reply_id` bigint(20) DEFAULT NULL,
`last_reply_time` datetime DEFAULT NULL,
`last_modified` datetime DEFAULT NULL COMMENT '最后修改时间',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`options` bigint(20) DEFAULT NULL COMMENT '是否有小二回复',
`char_1` varchar(256) DEFAULT NULL,
`from_group_name` varchar(50) DEFAULT NULL,
`board_id` bigint(20) DEFAULT NULL,
`category` tinyint(4) DEFAULT NULL,
`verify` smallint(6) DEFAULT NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)',
`operator_id` bigint(20) DEFAULT NULL COMMENT '审核人的id',
`operator_time` datetime DEFAULT NULL COMMENT '操作时间',
`rated_respect` int(11) DEFAULT NULL COMMENT '被评价的分数',
`tp_id` bigint(20) DEFAULT NULL COMMENT '合作伙伴id，若为空，则来源为淘宝',
`priority` int(11) DEFAULT NULL COMMENT '优先级',
`extra_user_id` bigint(20) DEFAULT NULL COMMENT '外部第三方名称',
`sync_to_tp` tinyint(4) DEFAULT NULL COMMENT '是否同步给第三方（0不同步，1同步）',
`content` varchar(1024) NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_btt_anick` (`author_nick`,`type`,`deleted`)
)  DEFAULT CHARSET=utf8 ,COMMENT='论坛美妆论坛帖子迁入圈子的临时表';
drop table if exists group_activity_0000;
CREATE TABLE if not exists `group_activity_0000` (
`id` bigint(20) NOT NULL AUTO_INCREMENT,
`thread_id` bigint(20) NOT NULL,
`group_id` bigint(20) NOT NULL,
`start_time` datetime NOT NULL COMMENT '活动开始时间',
`end_time` datetime NOT NULL COMMENT '活动截止时间',
`toplimit` int(11) NOT NULL COMMENT '活动人数上限',
`tag` varchar(100) DEFAULT NULL COMMENT '活动的标签',
`options` bigint(20) unsigned NOT NULL COMMENT '第1位：仅本帮成员可以参加
第2位：仅实名认证用户可以参加
第3位：参加报名需要提供电话
',
`logo_url` varchar(200) DEFAULT NULL COMMENT '活动logo url',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`activity_type` smallint(6) NOT NULL COMMENT '3 促销打折 
4 店铺买家秀
5 商品团购 
6 免费试用 
7线下聚会 
8 同城交友 
9 团队建设
',
`expense` int(10) unsigned DEFAULT NULL COMMENT '每人花费的费用。转换成分存储',
`joined_user_count` int(11) NOT NULL COMMENT '已经加入活动人数',
`number_1` bigint(20) DEFAULT NULL,
`char_1` varchar(256) DEFAULT NULL,
PRIMARY KEY (`id`),
KEY `idx_group_act_tid` (`thread_id`,`joined_user_count`,`toplimit`) USING BTREE
)  DEFAULT CHARSET=utf8;
