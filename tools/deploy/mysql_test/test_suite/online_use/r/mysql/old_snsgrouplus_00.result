CREATE TABLE if not exists `group_user_0000` (
`user_id` bigint(20) NOT NULL,
`user_nick` varchar(32) NOT NULL,
`point` int(11) NOT NULL COMMENT '积分',
`point_day` datetime DEFAULT NULL COMMENT '记分时间戳',
`point_thread` int(11) NOT NULL DEFAULT '0' COMMENT '当天的已发帖数',
`point_reply` int(11) NOT NULL DEFAULT '0' COMMENT '当天的已回帖数',
`thread_count` int(11) NOT NULL DEFAULT '0' COMMENT '发贴总数',
`digest_thread_count` int(11) NOT NULL DEFAULT '0' COMMENT '精华贴总数',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`number_1` bigint(20) DEFAULT NULL,
`char_1` varchar(256) DEFAULT NULL,
`respect` int(11) DEFAULT NULL COMMENT '威望',
`coin` int(11) DEFAULT NULL COMMENT '社区币',
`contribution` int(11) DEFAULT NULL COMMENT '贡献值',
`applied_count_day` smallint(6) DEFAULT NULL COMMENT '每天申请的活动数量',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '第１位：是否已经看过新人指南',
PRIMARY KEY (`user_id`),
KEY `IDX_group_user_modified` (`gmt_modified`)
)  DEFAULT CHARSET=utf8;
