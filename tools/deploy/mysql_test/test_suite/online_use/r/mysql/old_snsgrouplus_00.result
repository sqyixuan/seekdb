CREATE TABLE if not exists `group_thread_item_0000` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '帖子宝贝id，PK',
`thread_id` bigint(20) NOT NULL COMMENT '甯栧瓙id ',
`group_id` bigint(20) NOT NULL COMMENT '甯?淳id',
`reply_id` bigint(20) DEFAULT NULL COMMENT '甯?淳id',
`item_id` bigint(20) NOT NULL COMMENT '瀹濊礉id ',
`title` varchar(120) NOT NULL COMMENT '瀹濊礉鍚嶇О',
`price` bigint(20) NOT NULL COMMENT '瀹濊礉浠锋牸 ',
`category_id` bigint(20) DEFAULT NULL COMMENT '瀹濊礉绫荤洰 ',
`share_content` varchar(1024) DEFAULT NULL COMMENT '推荐理由、评语 ',
`pic_url` varchar(256) NOT NULL COMMENT '瀹濊礉鍥剧墖URL ',
`deleted` tinyint(4) DEFAULT '0' COMMENT '瀹濊礉鏄?惁鍒犻櫎鏍囩ず锛? 姝ｅ父  1 鍒犻櫎銆',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`number_1` bigint(20) DEFAULT NULL COMMENT '澶囩敤瀛楁?锛屾暟瀛楀瀷 ',
`char_1` varchar(256) DEFAULT NULL COMMENT '澶囩敤瀛楁?锛屽瓧绗︿覆 ',
`digest` tinyint(4) DEFAULT '0' COMMENT '0 普通 1 精华',
PRIMARY KEY (`id`),
KEY `idx_group_thread_item_group_id` (`group_id`),
KEY `idx_group_thread_item_thread_id` (`thread_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='甯栧瓙涓庡疂璐濆?搴斿叧绯昏〃';
