`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`outer_id` varchar(128) NOT NULL COMMENT '分表字段,用户的外站的id',
`partner_id` int(11) NOT NULL COMMENT '外站的编号,比如新浪是4',
`login_name` varchar(128) DEFAULT NULL COMMENT '登陆名,在外站上是唯一的',
`display_face` varchar(512) DEFAULT NULL COMMENT '用户在外站上的头像地址,取的是原图',
`remark` varchar(512) DEFAULT NULL COMMENT '用户自己的说明,备注',
`birthday` varchar(32) DEFAULT NULL COMMENT '生日,会尽量保证yyyy-MM-dd的格式',
`location` varchar(128) DEFAULT NULL COMMENT '地址,各个站点的略有不同,新浪的格式如北京 朝阳区',
`gender` char(1) DEFAULT NULL COMMENT '性别',
`profile_info` varchar(4096) DEFAULT NULL COMMENT '一些额外的信息',
`is_delete` bigint(20) unsigned DEFAULT NULL COMMENT '是否被删除',
`real_name` varchar(32) DEFAULT NULL COMMENT '真实姓名,可能会有重名',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_oid_pid` (`outer_id`,`partner_id`)
)  AUTO_INCREMENT=9187917 ,DEFAULT CHARSET=utf8 ,COMMENT='用来记录从外站来的用户信息,可做分析或者其他用途,profile_info里面会保留外站的几乎全部原始信息. 256张表';
