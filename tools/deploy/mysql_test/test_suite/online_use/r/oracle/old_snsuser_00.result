CREATE TABLE if not exists `sns_outer_partner` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`name` varchar(32) NOT NULL COMMENT '站点名',
`auth_type` int(11) NOT NULL COMMENT '认证类型，0-auth',
`app_key` varchar(64) NOT NULL COMMENT '合作伙伴app key',
`app_secret` varchar(64) NOT NULL COMMENT '合作伙伴app secret',
`request_token_url` varchar(128) DEFAULT NULL COMMENT 'Request Token URL',
`auth_token_url` varchar(128) DEFAULT NULL COMMENT '用户认证URL',
`access_token_url` varchar(128) DEFAULT NULL COMMENT '访问授权URL',
`auth_signature_method` varchar(64) DEFAULT NULL COMMENT '认证签名方法',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`callback_url` varchar(384) DEFAULT NULL COMMENT '对应每个站外的回调链接，认证通过后调用到此链接',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=13 ,DEFAULT CHARSET=utf8;
