CREATE TABLE if not exists `sns_department_info` (
`depart_id` int(11) NOT NULL,
`name` varchar(300) NOT NULL,
`school_id` int(11) NOT NULL,
`gmt_create` datetime NOT NULL,
PRIMARY KEY (`depart_id`),
KEY `IDX_schoolid` (`school_id`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `sns_micro_shop_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) NOT NULL COMMENT '微店店主的id',
`shop_type` tinyint(4) NOT NULL COMMENT '微店的类型1|商城,2|集市,3|品牌机构,4|线下店铺',
`shop_name` varchar(128) NOT NULL COMMENT '微店的店铺名称',
`logo_picurl` varchar(500) DEFAULT NULL COMMENT '微店的店标logo',
`shop_id` bigint(20) DEFAULT NULL COMMENT '线上店铺的shopid',
`status` tinyint(4) NOT NULL COMMENT '1|关闭 0|正常',
`char_1` varchar(256) DEFAULT NULL,
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`number_1` int(11) DEFAULT NULL,
PRIMARY KEY (`id`),
UNIQUE KEY `uk_sms_uid` (`user_id`),
KEY `idx_sms_stype` (`shop_type`),
KEY `idx_sms_sname` (`shop_name`,`shop_id`)
)  AUTO_INCREMENT=23342009 ,DEFAULT CHARSET=utf8 ,COMMENT='微店基本信息表';
CREATE TABLE if not exists `sns_micro_shop_profile_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`user_id` bigint(20) NOT NULL COMMENT '微店店主的id',
`add_province` varchar(20) DEFAULT NULL COMMENT '微店所在地 (省代码)',
`add_city` varchar(20) DEFAULT NULL COMMENT '微店所在地 (市代码)',
`add_area` varchar(20) DEFAULT NULL COMMENT '微店所在地 (区代码)',
`add_other` varchar(128) DEFAULT NULL COMMENT '微店所在地 (街道门牌号等)',
`business_scope` varchar(128) NOT NULL COMMENT '店铺的主营范围',
`tag` varchar(128) DEFAULT NULL COMMENT '店铺标签',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`service_phone` varchar(128) DEFAULT NULL COMMENT '微店的服务电话',
`description` varchar(512) DEFAULT NULL COMMENT '店铺介绍',
`char_1` varchar(256) DEFAULT NULL,
`char_2` varchar(256) DEFAULT NULL,
`number_1` int(11) DEFAULT NULL,
`number_2` int(11) DEFAULT NULL,
PRIMARY KEY (`id`),
UNIQUE KEY `uk_smsp_uid` (`user_id`)
)  AUTO_INCREMENT=22970009 ,DEFAULT CHARSET=utf8 ,COMMENT='微店的扩展信息表';
CREATE TABLE if not exists `sns_micro_shop_user_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`shop_id` bigint(20) NOT NULL COMMENT '店铺id，分表键',
`user_id` bigint(20) NOT NULL COMMENT '店铺对应的卖家id',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
KEY `idx_smsu_sid` (`shop_id`,`user_id`)
)  AUTO_INCREMENT=22992009 ,DEFAULT CHARSET=utf8 ,COMMENT='根据店铺id反查用户id表表';
CREATE TABLE if not exists `sns_outer_account_auth_0000` (
`id` bigint(20) unsigned NOT NULL,
`user_id` bigint(20) NOT NULL COMMENT '用户ID',
`partner_id` int(11) NOT NULL COMMENT '合作伙伴ID',
`auth_token` varchar(256) DEFAULT NULL COMMENT 'auth token',
`access_token` varchar(256) DEFAULT NULL COMMENT 'access token',
`auth_secret` varchar(256) DEFAULT NULL COMMENT 'auth secret',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`status` tinyint(4) NOT NULL DEFAULT '0',
`outer_id` varchar(128) DEFAULT NULL COMMENT '站外关系绑定的唯一字段',
`login_name` varchar(128) DEFAULT NULL COMMENT '站外用户的nick，跟sns_outer_relation表里的login_name对应',
`real_name` varchar(32) DEFAULT NULL COMMENT '增加站外用户真实姓名',
`invalid_time` datetime DEFAULT NULL COMMENT 'accessToken失效时间',
`display_face` varchar(512) DEFAULT NULL COMMENT '头像地址',
`remark` varchar(512) DEFAULT NULL COMMENT '描述',
`birthday` varchar(32) DEFAULT NULL COMMENT '生日，存储格式yyyy-MM-dd',
`location` varchar(128) DEFAULT NULL COMMENT '所在地',
`gender` char(1) DEFAULT NULL COMMENT '性别',
`tags` varchar(512) DEFAULT NULL COMMENT '用户身上的标签',
`profile_info` varchar(2048) DEFAULT NULL COMMENT '其他一些profile信息',
PRIMARY KEY (`id`),
KEY `idx_accauth_userid` (`user_id`,`partner_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='站外关系绑定';
