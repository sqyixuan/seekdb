CREATE TABLE if not exists `sns_user_uniquename_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`namehash` bigint(20) NOT NULL COMMENT '分表字段,用户名字的hash值',
`unique_name` varchar(32) NOT NULL COMMENT '用户的唯一姓名',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_namehash_uniquename` (`namehash`,`unique_name`)
)  AUTO_INCREMENT=1298388 ,DEFAULT CHARSET=utf8 ,COMMENT='用户记录用户的唯一昵称';
