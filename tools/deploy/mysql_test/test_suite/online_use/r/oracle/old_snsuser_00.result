CREATE TABLE if not exists `biz_code_key` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`app_name` varchar(50) DEFAULT NULL COMMENT '接入应用名',
`biz_code` varchar(50) DEFAULT NULL COMMENT '分配给接入方的CODE',
`description` varchar(255) DEFAULT NULL COMMENT '描述信息',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='SNS基础组件HSF访问控制';
CREATE TABLE if not exists `sns_base_info_0000` (
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户数字id',
`key_id` smallint(6) NOT NULL,
`value` varchar(300) NOT NULL COMMENT '值',
`open_status` tinyint(4) NOT NULL COMMENT '是否公布资料',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`char_1` varchar(256) DEFAULT NULL COMMENT '保留字段',
`number_1` bigint(20) DEFAULT NULL COMMENT '保留字段',
PRIMARY KEY (`user_id`,`key_id`),
KEY `IDX_baseinfo_modified` (`gmt_modified`)
)  DEFAULT CHARSET=utf8;
