CREATE TABLE if not exists `sns_users_0003` (
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户数字id',
`nick` varchar(32) NOT NULL COMMENT '用户nick',
`real_name` varchar(256) DEFAULT NULL COMMENT '真是姓名',
`pic_url` varchar(500) DEFAULT NULL COMMENT '图片url',
`heart_desc` varchar(512) DEFAULT NULL COMMENT '一句话心情',
`space_title` varchar(100) DEFAULT NULL COMMENT '空间标题',
`space_pic` varchar(500) DEFAULT NULL COMMENT '空间图片',
`finished_Status` tinyint(6) DEFAULT NULL COMMENT '资料完成度',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`char_1` varchar(256) DEFAULT NULL COMMENT '保留字段',
`number_1` bigint(20) DEFAULT NULL,
`space_title_style` varchar(1024) DEFAULT NULL,
`space_pic_style` tinyint(4) DEFAULT NULL,
`status` tinyint(4) DEFAULT NULL,
`gmt_head_opt` datetime DEFAULT NULL,
`head_status` char(1) DEFAULT NULL,
`birthday` datetime DEFAULT NULL,
`gender` char(1) DEFAULT NULL,
`prov` varchar(20) DEFAULT NULL,
`city` varchar(20) DEFAULT NULL,
`area` varchar(20) DEFAULT NULL,
`level` int(11) DEFAULT NULL,
`type` varchar(1024) DEFAULT NULL,
`unique_name` varchar(32) DEFAULT NULL COMMENT '用户的唯一昵称',
PRIMARY KEY (`user_id`),
KEY `IDX_user_users_modified` (`gmt_modified`),
KEY `IDX_user_headstatus` (`head_status`,`pic_url`),
KEY `IDX_user_level` (`level`)
)  DEFAULT CHARSET=utf8 ,COMMENT='用户的个人信息表';
