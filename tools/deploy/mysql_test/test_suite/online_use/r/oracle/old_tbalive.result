CREATE TABLE if not exists `anchor` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`content_id` bigint(20) unsigned NOT NULL COMMENT '锚点关联内容id',
`item_id` bigint(20) unsigned NOT NULL COMMENT '锚点关联商品id',
`item_name` varchar(512) NOT NULL COMMENT '锚点关联商品标题',
`buy_url` varchar(512) NOT NULL COMMENT '锚点关联商品购买链接',
`pic_url` varchar(512) NOT NULL COMMENT '锚点关联商品主图url',
`price` double NOT NULL COMMENT '锚点关联商品价格',
`features` varchar(512) NOT NULL COMMENT '扩展属性，主要包含坐标信息等',
`class_id` int(10) unsigned NOT NULL COMMENT '行业id',
`biz_type` int(10) unsigned NOT NULL COMMENT '业务id',
`user_id` bigint(20) unsigned NOT NULL COMMENT '锚点用户id',
`owner_id` bigint(20) unsigned NOT NULL COMMENT '内容所有者id',
`status` int(11) NOT NULL COMMENT '锚点状态',
PRIMARY KEY (`id`),
KEY `content` (`class_id`,`biz_type`,`content_id`),
KEY `user_anchor` (`class_id`,`biz_type`,`user_id`),
KEY `owner_anchor` (`class_id`,`biz_type`,`owner_id`)
)  AUTO_INCREMENT=20270 ,DEFAULT CHARSET=utf8 ,COMMENT='锚点信息表';
CREATE TABLE if not exists `app_content` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`class_id` int(11) NOT NULL COMMENT '行业id
1:家居',
`group_id` bigint(20) unsigned DEFAULT NULL COMMENT '专辑id',
`biz_type` int(11) NOT NULL COMMENT '1：日记
2：样板
3：攻略',
`cover_image_url` varchar(512) DEFAULT NULL COMMENT '封面地址',
`properties` varchar(1024) DEFAULT NULL COMMENT '属性对',
`input_properties` varchar(1024) DEFAULT NULL COMMENT '属性的可输入属性值',
`content_id` bigint(20) unsigned DEFAULT NULL COMMENT '内容平台id',
`nick` varchar(128) NOT NULL COMMENT '用户nick',
`title` varchar(512) NOT NULL COMMENT '标题',
`summary` varchar(2048) DEFAULT NULL COMMENT '摘要',
`features` varchar(4096) DEFAULT NULL COMMENT '扩展字段',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0：正常
-1：删除
-2：屏蔽',
`user_modified` datetime NOT NULL COMMENT '用户修改时间',
`tfs_path` varchar(256) DEFAULT NULL COMMENT '内容tfs路径',
`tags` bigint(20) unsigned DEFAULT NULL COMMENT 'Int标签',
`content_items` varchar(1024) DEFAULT NULL COMMENT '对应套餐的商品列表
ex:     11111,22222',
`extend_info` varchar(1024) COMMENT '扩展信息',
`extend_imginfo` varchar(1024) COMMENT '扩展图片信息',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `ind_gr_st` (`group_id`,`status`),
KEY `k_uid_btype` (`user_id`,`biz_type`),
KEY `ind_user` (`user_id`),
KEY `by_status` (`class_id`,`biz_type`,`status`),
KEY `ind_group` (`group_id`,`gmt_modified`)
)  AUTO_INCREMENT=45301162677 ,DEFAULT CHARSET=utf8 ,COMMENT='行业社区基础内容表';
CREATE TABLE if not exists `appcontent_temp` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_modified` datetime DEFAULT NULL COMMENT '用户修改时间',
`lock_user` varchar(31) DEFAULT NULL COMMENT '当前编辑的用户',
`app_key` varchar(127) NOT NULL COMMENT '接入源业务标识。app_key,biz_key父子关系。字段值一般由biz_key反推得到',
`source_type` int(10) unsigned NOT NULL COMMENT '同一接入源  多种接入方式：1：爬虫；2：达人',
`content` varchar(1024) NOT NULL COMMENT '正文内容',
`title` varchar(511) NOT NULL COMMENT '标题',
`keywords` varchar(511) NOT NULL COMMENT '关键词',
`summary` varchar(1023) DEFAULT NULL COMMENT '概括',
`comment` varchar(1023) DEFAULT NULL COMMENT '对爬取文章的描述 ， 方便工作交接，备忘',
`status` int(11) NOT NULL COMMENT '状态：0待审核，1审核通过，-1：删除',
`app_content_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT 'app_content表主键，表示已经插入过记录',
`cat_id` bigint(20) unsigned NOT NULL COMMENT '对应的后台类目ID',
`properties` varchar(1023) DEFAULT NULL COMMENT '属性、属性值',
`raw_tags` varchar(1023) DEFAULT NULL COMMENT '数据源提供的分类标签：方便对内容 进行标准化分类 决策',
`url` varchar(1023) DEFAULT NULL COMMENT '数据来源的url',
`feature` varchar(2047) DEFAULT NULL COMMENT 'feature字段',
`biz_key` varchar(127) NOT NULL COMMENT '接入源业务下的产品标识',
`source_site` varchar(127) DEFAULT NULL COMMENT '数据源站点Domain',
`cover_image` varchar(255) DEFAULT NULL COMMENT '内容主图，某些数据来源会提供这个字段',
`external_id` varchar(127) DEFAULT NULL COMMENT '外部数据源的主键，方便排查问题',
`item_ids` varchar(1023) DEFAULT NULL COMMENT '提供的商品ID列表',
PRIMARY KEY (`id`),
KEY `app_by_biz` (`biz_key`),
KEY `biz_by_app` (`app_key`)
)  AUTO_INCREMENT=40 ,DEFAULT CHARSET=utf8 ,COMMENT='appcontent临时表，统一多方数据源存储。运营审核通过后进入appcontent，每天会增量dump，首批数据会比较多';
CREATE TABLE if not exists `content_count` (
`id` bigint(20) unsigned NOT NULL COMMENT '内容 or 专辑 id',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`type` int(11) NOT NULL COMMENT '1：内容
2：专辑',
`browse_count` bigint(20) unsigned DEFAULT '0' COMMENT '浏览数',
`like_count` bigint(20) unsigned DEFAULT '0' COMMENT '喜欢数',
`share_count` bigint(20) unsigned DEFAULT '0' COMMENT '分享数',
`comment_count` bigint(20) unsigned DEFAULT '0' COMMENT '评论数',
`last_comment_time` datetime DEFAULT NULL COMMENT '最后评论时间',
PRIMARY KEY (`id`,`type`),
KEY `ind_type` (`type`,`last_comment_time`)
)  DEFAULT CHARSET=utf8 ,COMMENT='行业社区内容互动统计表';
CREATE TABLE if not exists `content_group` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`nick` varchar(128) NOT NULL COMMENT '用户nick',
`class_id` int(11) NOT NULL COMMENT '行业id
1:家居',
`biz_type` int(11) NOT NULL COMMENT '1：日记
2：样板
3：攻略',
`cover_image_url` varchar(512) DEFAULT NULL COMMENT '封面地址',
`properties` varchar(1024) DEFAULT NULL COMMENT '属性对',
`input_properties` varchar(1024) DEFAULT NULL COMMENT '属性的可输入属性值',
`title` varchar(512) NOT NULL COMMENT '标题',
`features` varchar(4096) DEFAULT NULL COMMENT '扩展字段',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '0：正常 -1：删除 -2 屏蔽',
`user_modified` datetime NOT NULL COMMENT '用户修改时间',
`tags` bigint(20) unsigned DEFAULT NULL COMMENT 'Int标签',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `class_biz` (`class_id`,`biz_type`,`user_id`),
KEY `user_id_idx` (`user_id`,`status`)
)  AUTO_INCREMENT=100505 ,DEFAULT CHARSET=utf8 ,COMMENT='行业社区专辑表';
CREATE TABLE if not exists `content_item` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`group_id` bigint(20) unsigned DEFAULT NULL COMMENT '专辑id',
`app_content_id` bigint(20) unsigned NOT NULL COMMENT '内容id',
`order_id` bigint(20) unsigned DEFAULT NULL COMMENT '订单id',
`item_type` int(11) DEFAULT NULL COMMENT '3:tmall
4:taobao',
`buy_url` varchar(256) DEFAULT NULL COMMENT '购买地址',
`item_id` bigint(20) unsigned NOT NULL COMMENT '商品id',
`item_price` bigint(20) unsigned DEFAULT NULL COMMENT '商品价格',
`item_quantity` bigint(20) unsigned DEFAULT NULL COMMENT '商品数量',
`pic_url` varchar(256) DEFAULT NULL COMMENT '商品主图',
`category_id` bigint(20) unsigned DEFAULT NULL COMMENT '类目id',
`seller_id` bigint(20) unsigned DEFAULT NULL COMMENT '卖家id',
`online` int(11) DEFAULT NULL COMMENT '商品是否在售，1在售，0非在售',
`status` int(11) NOT NULL COMMENT '0 正常 -1 删除',
`category_level2` bigint(20) unsigned DEFAULT NULL COMMENT '商品所属二级类目',
`item_name` varchar(128) DEFAULT NULL COMMENT '商品标题',
`feature` varchar(2048) DEFAULT NULL COMMENT '扩展字段，json格式',
`user_id` bigint(20) unsigned DEFAULT '0' COMMENT '用户ID',
`class_id` int(11) DEFAULT '0' COMMENT '行业ID',
`biz_type` int(11) DEFAULT '0' COMMENT '产品ID',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `ind_st_ap` (`status`,`app_content_id`),
KEY `ind_gr_st` (`group_id`,`status`),
KEY `ind_item` (`item_id`),
KEY `ind_us_bi_cl` (`user_id`,`class_id`,`biz_type`),
KEY `ind_ap` (`app_content_id`),
KEY `ind_class` (`class_id`,`status`),
KEY `ind_time` (`biz_type`,`status`,`gmt_modified`)
)  AUTO_INCREMENT=19587891908 ,DEFAULT CHARSET=utf8 ,COMMENT='行业社区内容关联商品表';
CREATE TABLE if not exists `content_pic` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`group_id` bigint(20) unsigned DEFAULT NULL COMMENT '专辑id',
`app_content_id` bigint(20) unsigned NOT NULL COMMENT '内容id',
`tags` varchar(128) DEFAULT NULL COMMENT '图片标签',
`description` varchar(1024) DEFAULT NULL COMMENT '图片描述',
`features` varchar(4096) DEFAULT NULL COMMENT '扩展字段',
`status` int(11) NOT NULL COMMENT '0 正常 -1 删除',
`url` varchar(512) NOT NULL COMMENT '图片地址',
`user_id` bigint(20) unsigned DEFAULT '0' COMMENT '用户ID',
`biz_type` int(11) DEFAULT '0' COMMENT '产品ID',
`class_id` int(11) DEFAULT '0' COMMENT '行业ID',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `ind_gr_st_ur` (`group_id`,`status`,`url`),
KEY `ind_ap_st_gr` (`app_content_id`,`status`,`group_id`),
KEY `ind_st_ur` (`status`,`url`),
KEY `ind_ap_st_url` (`app_content_id`,`status`,`url`),
KEY `ind_us_bi_cl` (`user_id`,`biz_type`,`class_id`)
)  AUTO_INCREMENT=3525373 ,DEFAULT CHARSET=utf8 ,COMMENT='行业社区内容关联图片表';
CREATE TABLE if not exists `content_snapshot` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`content_id` bigint(20) unsigned NOT NULL COMMENT '内容表对应的id',
`biz_key` varchar(50) NOT NULL COMMENT '业务key',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`item_ids` varchar(1024) DEFAULT NULL COMMENT '收藏的商品id,逗号分割',
`status` int(11) NOT NULL COMMENT '状态',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='内容的快照表';
CREATE TABLE if not exists `dbloadplug` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`plugname` varchar(100) DEFAULT NULL COMMENT '组件名称',
`plugver` varchar(50) DEFAULT NULL COMMENT '组件版本',
`plugdesc` varchar(200) DEFAULT NULL COMMENT '组件描述',
`loadsql` varchar(1000) DEFAULT NULL COMMENT 'SQL',
`loadparam` varchar(200) DEFAULT NULL COMMENT '条件参数',
`resulttype` tinyint(4) DEFAULT NULL COMMENT '返回处理方式1单条记录2多条记录3多条记录json',
`resultmap` varchar(300) DEFAULT NULL COMMENT '映射关系',
PRIMARY KEY (`id`),
KEY `plugindex` (`plugname`,`plugver`)
)  AUTO_INCREMENT=29 ,DEFAULT CHARSET=utf8 ,COMMENT='数据提取配置表';
CREATE TABLE if not exists `flowplug` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`class_id` int(11) DEFAULT NULL COMMENT '行业',
`biz_type` int(11) DEFAULT NULL COMMENT '业务类型',
`flowver` varchar(20) DEFAULT NULL COMMENT '流程版本',
`flowcontent` varchar(1024) COMMENT '流程内容',
`flowname` varchar(50) DEFAULT NULL COMMENT '流程名称',
PRIMARY KEY (`id`),
KEY `plugindex` (`class_id`,`biz_type`),
KEY `plugnameindex` (`flowname`)
)  AUTO_INCREMENT=24 ,DEFAULT CHARSET=utf8 ,COMMENT='流程组件';
CREATE TABLE if not exists `kratos_plugin` (
`pluginurl` varchar(200) DEFAULT NULL COMMENT '插件地址',
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`pluginname` varchar(100) DEFAULT NULL COMMENT '插件名称',
`pluginver` varchar(30) DEFAULT NULL COMMENT '插件版本',
`plugindesc` varchar(500) DEFAULT NULL COMMENT '插件描述',
`appname` varchar(100) DEFAULT NULL COMMENT '应用名称',
`pluginfrom` varchar(100) DEFAULT NULL COMMENT '插件来源',
`pluginstate` tinyint(4) DEFAULT NULL COMMENT '状态0启用-1禁用',
PRIMARY KEY (`id`),
KEY `plugindex` (`appname`,`pluginname`,`pluginver`),
KEY `pluginstate` (`pluginstate`)
)  DEFAULT CHARSET=utf8 ,COMMENT='消息中心插件配置';
CREATE TABLE if not exists `listproperty` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`parentpid` bigint(20) unsigned DEFAULT NULL COMMENT 'parentPid',
`name` varchar(255) NOT NULL COMMENT '内部名称',
`alias` varchar(255) NOT NULL COMMENT '页面显示名称',
`description` varchar(255) DEFAULT NULL COMMENT '描述',
`image` varchar(255) DEFAULT NULL COMMENT '图像路径',
`feature` varchar(1024) COMMENT '自定义',
`class_id` bigint(20) unsigned NOT NULL COMMENT '行业id',
`biz_type` bigint(20) unsigned DEFAULT NULL COMMENT '子产品类型',
`sort_order` bigint(20) unsigned DEFAULT NULL COMMENT '排序值',
`pid` bigint(20) unsigned NOT NULL COMMENT 'property id',
`flaguse` int(11) DEFAULT NULL COMMENT '标记是否删除，1表示使用，0表示删除。（null，寓意1）',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `idx_classid_vid_biztype` (`class_id`,`biz_type`,`pid`)
)  AUTO_INCREMENT=1000000023 ,DEFAULT CHARSET=utf8 ,COMMENT='标签的大类，抽象为属性。标签内容抽象为属性值。';
CREATE TABLE if not exists `listvalue` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(255) NOT NULL COMMENT '内部名称',
`alias` varchar(255) NOT NULL COMMENT '页面显示别名',
`description` varchar(255) DEFAULT NULL COMMENT '描述',
`feature` varchar(1024) COMMENT '自定义',
`image` varchar(255) DEFAULT NULL COMMENT '图标',
`class_id` bigint(20) unsigned NOT NULL COMMENT '行业id',
`biz_type` bigint(20) unsigned DEFAULT NULL COMMENT '子产品',
`sort_order` bigint(20) unsigned DEFAULT NULL COMMENT '排序值',
`vid` bigint(20) unsigned NOT NULL COMMENT 'value id',
`flaguse` int(11) DEFAULT NULL COMMENT '标记是否删除，1表示使用，0表示删除。（null，寓意1）',
`app_key` varchar(128) DEFAULT NULL COMMENT '应用key',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`),
KEY `idx_classid_vid_biztype` (`vid`,`biz_type`,`class_id`)
)  AUTO_INCREMENT=1000000046 ,DEFAULT CHARSET=utf8 ,COMMENT='标签的大类，抽象为属性。标签内容抽象为属性值。';
CREATE TABLE if not exists `person_sms_count` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`send_date` date NOT NULL COMMENT '日期',
`count` bigint(20) unsigned NOT NULL COMMENT '日期当天发送的短信总数',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`user_nick` varchar(50) NOT NULL COMMENT '用户昵称',
PRIMARY KEY (`id`),
KEY `idx_user_date` (`send_date`,`user_id`)
)  AUTO_INCREMENT=1414 ,DEFAULT CHARSET=utf8 ,COMMENT='保存短信发送的次数';
CREATE TABLE if not exists `personal_profile` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_createtime` datetime NOT NULL COMMENT '创建时间',
`gmt_modifytime` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户ID',
`user_nick` varchar(50) NOT NULL COMMENT '用户昵称',
`profile` varchar(1000) NOT NULL COMMENT '档案',
`market_profile_type` varchar(50) NOT NULL COMMENT '行业市场类型',
`extra_property` varchar(100) DEFAULT NULL COMMENT '额外信息.',
`gmt_createuser` varchar(50) NOT NULL COMMENT '创建人',
`gmt_modifyuser` varchar(50) NOT NULL COMMENT '修改人',
PRIMARY KEY (`id`),
KEY `idx_user_id` (`user_id`)
)  AUTO_INCREMENT=7653 ,DEFAULT CHARSET=utf8 ,COMMENT='保存淘宝用户创建的行业档案';
CREATE TABLE if not exists `personal_profile_template` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`profile_template` varchar(1000) NOT NULL COMMENT '模板档案',
`profile_template_bak` varchar(1000) NOT NULL COMMENT '模板档案备份',
`market_profile_type` varchar(50) NOT NULL COMMENT '行业类型',
`gmt_modifytime` datetime NOT NULL COMMENT '修改时间',
`gmt_modifyuser` varchar(50) NOT NULL COMMENT '修改人',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='保存各行业市场用户档案模板';
CREATE TABLE if not exists `role` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`biz_key` bigint(20) unsigned DEFAULT NULL COMMENT '业务key',
`role_name` varchar(255) DEFAULT NULL COMMENT '角色名',
`role_description` varchar(1024) DEFAULT NULL COMMENT '角色描述',
`status` int(11) DEFAULT NULL COMMENT '状态',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='角色表';
CREATE TABLE if not exists `scriptplug` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`scriptdesc` varchar(200) DEFAULT NULL COMMENT '脚本描述',
`scriptname` varchar(100) DEFAULT NULL COMMENT '脚本名称',
`scriptcontent` varchar(1024) COMMENT '脚本内容',
`scriptver` varchar(50) DEFAULT NULL COMMENT '脚本版本',
PRIMARY KEY (`id`),
KEY `scriptindex` (`scriptname`,`scriptver`)
)  AUTO_INCREMENT=54 ,DEFAULT CHARSET=utf8 ,COMMENT='脚本插件表';
CREATE TABLE if not exists `seller_ranking` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`seller_id` bigint(20) unsigned DEFAULT NULL COMMENT '卖家id',
`seller_nick` varchar(200) DEFAULT NULL COMMENT '卖家昵称',
`seller_pv` bigint(20) unsigned DEFAULT NULL COMMENT 'pv',
`seller_uv` bigint(20) unsigned DEFAULT NULL COMMENT 'uv',
`riji_count` int(11) DEFAULT NULL COMMENT '日记数量',
`riji_id` varchar(1024) COMMENT 'id串',
`extend1` int(11) DEFAULT NULL COMMENT '扩展字段1',
`extend2` varchar(300) DEFAULT NULL COMMENT '扩展字段2',
`extend3` int(11) DEFAULT NULL COMMENT '扩展字段3',
`extend4` varchar(500) DEFAULT NULL COMMENT '扩展字段4',
PRIMARY KEY (`id`),
KEY `sellernickindex` (`seller_nick`),
KEY `selleridindex` (`seller_id`)
)  AUTO_INCREMENT=38334 ,DEFAULT CHARSET=utf8 ,COMMENT='排行榜';
CREATE TABLE if not exists `tag` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(255) NOT NULL COMMENT '名称',
`sort_order` bigint(20) unsigned DEFAULT NULL COMMENT '排序值',
`status` int(11) NOT NULL COMMENT '状态',
`type` bigint(20) unsigned DEFAULT NULL COMMENT '类型',
`feature` varchar(4096) DEFAULT NULL COMMENT '扩展字段',
`app_key` varchar(255) NOT NULL COMMENT '应用key，需要申请',
`parent_tid` bigint(20) unsigned DEFAULT NULL COMMENT '父标签id',
`class_id` bigint(20) unsigned DEFAULT NULL COMMENT '暂时没有使用',
`biz_type` bigint(20) unsigned DEFAULT NULL COMMENT '业务类型，业务可自定义',
`biz_key` varchar(128) DEFAULT NULL COMMENT '接入业务的key',
`app_type` int(11) DEFAULT NULL COMMENT '接入业务的类型',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=57867 ,DEFAULT CHARSET=utf8 ,COMMENT='标签表';
CREATE TABLE if not exists `tag_group` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`biz_key` varchar(50) NOT NULL COMMENT '业务key',
`tag_group_name` varchar(255) NOT NULL COMMENT '标签组名',
`tag_group_key` varchar(255) DEFAULT NULL COMMENT '标签组key',
`description` varchar(1024) DEFAULT NULL COMMENT '描述',
`status` int(11) NOT NULL COMMENT '状态',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='标签的聚合表';
CREATE TABLE if not exists `user_record` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`class_id` int(10) unsigned NOT NULL COMMENT '行业类型',
`biz_type` int(10) unsigned NOT NULL COMMENT '业务类型',
`status` int(11) NOT NULL COMMENT '行为状态',
`content_id` bigint(20) unsigned NOT NULL COMMENT '内容id',
`group_id` bigint(20) unsigned DEFAULT NULL COMMENT '专辑id',
`action_type` int(10) unsigned NOT NULL COMMENT '行为类型',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`owner_id` bigint(20) unsigned NOT NULL COMMENT '内容拥有者id',
`order_id` int(11) DEFAULT '0' COMMENT '顺序',
PRIMARY KEY (`id`),
KEY `class_biz` (`biz_type`,`action_type`,`user_id`,`class_id`),
KEY `group_idx` (`action_type`,`group_id`),
KEY `content_idx` (`action_type`,`content_id`),
KEY `order_idx` (`class_id`,`user_id`,`content_id`,`order_id`),
KEY `order1_idx` (`content_id`,`group_id`,`class_id`,`biz_type`)
)  AUTO_INCREMENT=236648 ,DEFAULT CHARSET=utf8 ,COMMENT='用户行为记录表';
CREATE TABLE if not exists `user_role` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`role_id` int(10) unsigned NOT NULL COMMENT '角色id',
`features` varchar(2048) DEFAULT NULL COMMENT '扩展字段',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '状态：1 审核通过
-1 删除
0 待审核',
`user_modified` datetime DEFAULT NULL COMMENT '用户修改时间',
`class_id` int(11) NOT NULL COMMENT '行业id，冗余一份，便于查询',
`field_values` varchar(16384) DEFAULT NULL COMMENT '字段值列表，json格式',
`nick` varchar(128) DEFAULT NULL COMMENT '用户的名称，缺省SNS的nick',
`role_type` int(11) DEFAULT '0' COMMENT '角色类型',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_urc_uniq` (`user_id`,`role_id`,`class_id`),
KEY `ind_us_cl_st` (`user_id`,`class_id`,`status`),
KEY `ind_us_ro` (`user_id`,`role_id`)
)  AUTO_INCREMENT=30267 ,DEFAULT CHARSET=utf8 ,COMMENT='用户身份表';
CREATE TABLE if not exists `wireless_code` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`userid` bigint(20) DEFAULT NULL COMMENT '用户ID',
`codeid` varchar(50) DEFAULT NULL COMMENT '二维码标识',
`expiretime` datetime DEFAULT NULL COMMENT '过期时间',
PRIMARY KEY (`id`),
KEY `codeidindex` (`codeid`)
)  AUTO_INCREMENT=139044 ,DEFAULT CHARSET=utf8 ,COMMENT='无线二维码标识';
CREATE TABLE if not exists `wireless_code_item` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`codeid` varchar(50) DEFAULT NULL COMMENT '二维码Id',
`tfsname` varchar(100) NOT NULL COMMENT 'tfs文件名',
PRIMARY KEY (`id`),
KEY `codeidindex` (`codeid`)
)  AUTO_INCREMENT=5326 ,DEFAULT CHARSET=utf8 ,COMMENT='二维码关联图片明细';
CREATE TABLE if not exists `youjia_activities` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`userid` bigint(20) unsigned DEFAULT NULL COMMENT '用户ID',
`realname` varchar(20) DEFAULT NULL COMMENT '真实姓名',
`phone` varchar(20) DEFAULT NULL COMMENT '手机号码',
`location` varchar(200) DEFAULT NULL COMMENT '所在地',
`activitiesid` varchar(10) DEFAULT NULL COMMENT '活动ID',
`extend1` bigint(20) unsigned DEFAULT NULL COMMENT '扩展字段1',
`extend2` varchar(500) DEFAULT NULL COMMENT '扩展字段2',
`extend3` varchar(1024) COMMENT '扩展字段3',
`profession` varchar(100) DEFAULT NULL COMMENT '职业',
`mail` varchar(100) DEFAULT NULL COMMENT '邮箱',
PRIMARY KEY (`id`),
KEY `userid_idx` (`userid`),
KEY `name_idx` (`realname`,`phone`)
)  AUTO_INCREMENT=395 ,DEFAULT CHARSET=utf8 ,COMMENT='有家临时活动表';
