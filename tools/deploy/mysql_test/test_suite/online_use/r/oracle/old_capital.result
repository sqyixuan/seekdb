CREATE TABLE if not exists `compensate_remind_cfg` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`compen_type` varchar(32) NOT NULL COMMENT '赔付类型',
`max_retry_times` int(11) NOT NULL COMMENT '最多重试次数',
`interval_days` int(11) NOT NULL COMMENT '催缴间隔时间',
`env_type` varchar(40) DEFAULT NULL COMMENT '环境标记，预发还是线上',
`status` int(11) DEFAULT NULL COMMENT '配置状态',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付催缴配置表';
CREATE TABLE if not exists `compensate_reminder` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`compen_id` bigint(20) unsigned NOT NULL COMMENT '赔付编号',
`compen_type` varchar(32) NOT NULL COMMENT '冗余赔付类型',
`reminder_user_id` bigint(20) unsigned NOT NULL COMMENT '被催缴人id',
`amount` bigint(20) unsigned NOT NULL COMMENT '催缴金额',
`alipay_order_id` varchar(64) DEFAULT NULL COMMENT '催缴的支付宝交易号',
`return_payment_date` datetime DEFAULT NULL COMMENT '催缴还款时间',
`retry_times` int(11) DEFAULT NULL COMMENT '催缴重试次数',
`status` int(11) NOT NULL COMMENT '催缴状态',
`reminder_memo` varchar(1000) DEFAULT NULL COMMENT '备注',
`reminder_user_nick` varchar(100) NOT NULL COMMENT '被催缴人nick',
`env_type` varchar(20) DEFAULT NULL COMMENT '当期提醒的执行环境',
`remind_pay_url` varchar(400) DEFAULT NULL COMMENT '催缴还款链接',
`cancel_reason` int(11) DEFAULT NULL COMMENT '撤销原因',
`islocked` int(11) DEFAULT NULL COMMENT '数据是否锁住',
PRIMARY KEY (`id`),
KEY `ind_compensate_reminder_compen` (`compen_id`),
KEY `ind_compensate_reminder_user` (`reminder_user_id`,`status`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付催缴表';
CREATE TABLE if not exists `compensate_sequence` (
`name` varchar(50) NOT NULL COMMENT '主键',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`seq_value` bigint(20) NOT NULL COMMENT '当前序列值',
PRIMARY KEY (`name`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付编号序列表';
CREATE TABLE if not exists `compensate_type` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`code` varchar(100) NOT NULL COMMENT '赔付code',
`parent_code` varchar(100) NOT NULL COMMENT '父节点code',
`alias` varchar(100) NOT NULL COMMENT '赔付类型全称',
`name` varchar(100) NOT NULL COMMENT '赔付类型简称',
`type_level` int(11) DEFAULT NULL COMMENT '暂时未使用',
PRIMARY KEY (`id`),
KEY `ind_compensate_type` (`code`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付类型表';
CREATE TABLE if not exists `crm_advance_timeout` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_created` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`refund_id` bigint(20) unsigned DEFAULT NULL COMMENT '退款id',
`timeout_type` int(10) unsigned DEFAULT NULL COMMENT '超时类型 1.等待买家退货 2.等待卖家确认收货 3. 未收到货等待卖家确认',
`gmt_finished` datetime DEFAULT NULL COMMENT '完结时间',
`gmt_timeout` datetime DEFAULT NULL COMMENT '超时时间',
`fail_count` int(10) unsigned DEFAULT NULL COMMENT '失败次数(默认超过10次,置为异常,不再处理)',
`fail_info` varchar(500) DEFAULT NULL COMMENT '失败信息',
`status` int(10) unsigned DEFAULT NULL COMMENT '状态0.未处理 1.处理中2.完成，4异常',
PRIMARY KEY (`id`),
KEY `idx_adv_timeout_rid` (`refund_id`,`timeout_type`,`gmt_created`),
KEY `idx_adv_timeout_st_gmttimeout` (`status`,`gmt_timeout`),
KEY `idx_adv_timeout_status` (`status`,`gmt_modified`,`timeout_type`,`gmt_timeout`)
)  DEFAULT CHARSET=utf8 ,COMMENT='垫付超时表，应该可以废弃';
CREATE TABLE if not exists `crm_compensate_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`scheme_id` bigint(20) DEFAULT NULL COMMENT '任务ID（CRM_SCHEME_DETAIL.ID）',
`compen_fee` bigint(20) unsigned DEFAULT NULL COMMENT '赔付金额',
`trade_id` bigint(20) DEFAULT NULL COMMENT '淘宝交易号',
`alipay_trade_no` varchar(100) DEFAULT NULL COMMENT '支付宝交易号',
`memo` varchar(2000) DEFAULT NULL COMMENT '备注',
`source_info_id` bigint(20) DEFAULT NULL COMMENT '投诉退款编号 投诉举报（包括物流）：CRM_PUNISH_INFO.PUNISH_ID 退款编号：CRM_REFUND_INFO.REFUND_ID',
`biz_source` int(11) DEFAULT NULL COMMENT '业务类型 801-投诉举报任务 803-物流投诉任务 999-退款任务',
`compen_status` int(11) DEFAULT NULL COMMENT '0-待提交1-待初审2-待复审3-待财务审批4-已完成5-已取消',
`payee_user_id` bigint(20) DEFAULT NULL COMMENT '收款人数字ID',
`payer_user_id` bigint(20) DEFAULT NULL COMMENT '付款人数字ID',
`is_backward` int(11) DEFAULT NULL COMMENT '是否被退回 0-否 1-是',
`compen_type` varchar(100) DEFAULT NULL COMMENT '赔付类型',
`creator_id` bigint(20) unsigned DEFAULT NULL COMMENT '创建人id',
`deal_id` bigint(20) unsigned DEFAULT NULL COMMENT '处理人id',
`move_freeze_fee` bigint(20) unsigned DEFAULT NULL COMMENT '冻结金额',
`previou_user_id` bigint(20) DEFAULT NULL COMMENT '上一个用户ID',
`payment_remind_status` int(11) DEFAULT NULL COMMENT '赔付催缴状态（1：催缴中，2：催缴完成）',
`payment_remind_money` bigint(20) unsigned DEFAULT NULL COMMENT '赔付催缴金额',
`payment_be_reminders` varchar(50) DEFAULT NULL COMMENT '被催缴人nick',
`payment_remind_date` datetime DEFAULT NULL COMMENT '催缴还款时间',
`payment_remind_tradeno` varchar(800) DEFAULT NULL COMMENT '催缴还款对应的支付宝交易号',
`auto_punish_date` datetime DEFAULT NULL COMMENT '自动处罚时间',
`compen_paymoeny_date` datetime DEFAULT NULL COMMENT '财务出账时间',
`advance_type` int(11) DEFAULT NULL COMMENT '=CRM_ADVANCE_INFO.ADVANCE_TYPE',
`sync_version` bigint(20) DEFAULT NULL COMMENT '无用字段',
PRIMARY KEY (`id`),
KEY `index_scheme_id` (`scheme_id`),
KEY `index_payee` (`payee_user_id`),
KEY `index_payer` (`payer_user_id`),
KEY `index_tradeid` (`trade_id`),
KEY `index_businessid` (`source_info_id`),
KEY `index_alipay_no` (`alipay_trade_no`),
KEY `index_compen_paymoeny_date` (`compen_paymoeny_date`)
)  AUTO_INCREMENT=6500061 ,DEFAULT CHARSET=utf8 ,COMMENT='老的赔付表，迁移自CRM库';
CREATE TABLE if not exists `crm_compensate_type` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`compen_key` varchar(100) DEFAULT NULL COMMENT '赔付类型key值',
`compen_code` varchar(200) DEFAULT NULL COMMENT '编码',
`compen_name` varchar(200) DEFAULT NULL COMMENT '赔付类型名称',
`compen_parents` bigint(20) DEFAULT NULL COMMENT '父亲类型id',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=195 ,DEFAULT CHARSET=utf8 ,COMMENT='老的赔付类型';
CREATE TABLE if not exists `crm_mall_apply` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modify` datetime NOT NULL COMMENT '修改时间',
`punish_id` bigint(20) unsigned NOT NULL COMMENT '投诉任务id',
`sub_order_id` bigint(20) unsigned NOT NULL COMMENT '淘宝交易号',
`main_order_id` bigint(20) unsigned NOT NULL COMMENT '父淘宝交易号',
`alipay_id` varchar(40) NOT NULL COMMENT '支付宝交易号',
`refund_cash_to_buyer` bigint(20) DEFAULT NULL COMMENT '退给买家的现金',
`refund_point_to_buyer` bigint(20) DEFAULT NULL COMMENT '退的买家消费积分',
`refund_commission_to_seller` bigint(20) DEFAULT NULL COMMENT '退给卖家的佣金',
`refund_other_to_buyer` bigint(20) DEFAULT NULL COMMENT '退给卖家的其他金额包括返点积分',
`refund_buyer` varchar(32) NOT NULL COMMENT '买家昵称',
`refund_buyer_id` bigint(20) unsigned NOT NULL COMMENT '买家数字id',
`refund_seller` varchar(32) NOT NULL COMMENT '卖家昵称',
`refund_seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家数字id',
`order_status` int(11) DEFAULT NULL COMMENT '申请单状态 1- 复审被退回 2- 待复审 3- 已完成',
`create_dealer_id` bigint(20) unsigned NOT NULL COMMENT '创建人',
`process_status` bigint(20) unsigned DEFAULT NULL COMMENT '申请单处理状态',
`xiaoer_quantity` bigint(20) unsigned DEFAULT NULL COMMENT '小二填写的退货数量',
`auction_title` varchar(256) DEFAULT NULL COMMENT '宝贝title',
`peifu_to_buyer` bigint(20) DEFAULT NULL COMMENT '多余赔付买家的金额',
`compen_funds_source` int(11) DEFAULT NULL COMMENT '商城保证金来源, 0-商城基础保证金  1-聚划算商城保证金',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='旧赔付记录表';
CREATE TABLE if not exists `crm_payment_reminder` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`from_type` bigint(20) unsigned DEFAULT NULL COMMENT '催缴来源类型',
`from_source_id` bigint(20) unsigned DEFAULT NULL COMMENT '催缴来源业务编号id',
`reminder_status` bigint(20) unsigned DEFAULT NULL COMMENT '催缴状态',
`reminder_money` bigint(20) unsigned DEFAULT NULL COMMENT '催缴金额',
`bereminder` varchar(50) DEFAULT NULL COMMENT '被催缴人',
`remind_tradeurl` varchar(500) DEFAULT NULL COMMENT '催缴后用来支付的url',
`memo` varchar(500) DEFAULT NULL COMMENT '备注',
`auto_punish` date DEFAULT NULL COMMENT '处罚时间，赔付的催缴到时间了需要进行处罚的，每次自动处罚后会更新这个时间。',
`returnmoeny_date` date DEFAULT NULL COMMENT '*',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='老的赔付催缴表';
