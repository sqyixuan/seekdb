CREATE TABLE if not exists `capital_sequence` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`name` varchar(64) NOT NULL COMMENT '序列名',
`value` bigint(20) NOT NULL COMMENT '序列值',
`gmt_create` timestamp NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建日期',
`gmt_modified` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00' COMMENT '记录更新时间',
PRIMARY KEY (`id`),
UNIQUE KEY `unique_name` (`name`)
)  AUTO_INCREMENT=5 ,DEFAULT CHARSET=utf8 ,COMMENT='赔付序列表';
CREATE TABLE if not exists `compen_auto_unique` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`out_id` varchar(200) NOT NULL COMMENT '外部唯一编号',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_compen_auto_unique_out_id` (`out_id`)
)  AUTO_INCREMENT=28243221 ,DEFAULT CHARSET=utf8 ,COMMENT='赔付唯一主键表';
CREATE TABLE if not exists `compen_type_config` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`compen_type_name` varchar(30) NOT NULL COMMENT '赔付类型名称',
`money_types` varchar(20) NOT NULL COMMENT '资金类型，COMPEN_TOTAL_FEE(0,"赔付总金额"),
COMPEN_FEE(1,"赔付金额"),
ADVANCE_FEE(2,"垫付金额"),
EXTRA_ADVANCE_FEE(3,"额外垫付金额"),
TMALL_POINTS(4,"商城积分"),
POST_FEE(5, "退货运费"),
FAKEFIVE_FEE(6, "假一赔五"),',
`payer_actors` varchar(20) NOT NULL COMMENT '赔付角色，TAOBAO(1,"淘宝"),
BUYER(2,"买家"),
SELLER(3,"卖家"),
CHOUJIAN(4,"抽检方"),
WLBTP(5,"物流宝TP"),
SPECIAL(6,"特殊赔付对象"),
SUPPLIER(7,"供应商"),
TMALL(8,"天猫"),
LOGISTICSTP(9,"物流TP"),
ROOKIE(10,"菜鸟")',
`payee_actors` varchar(20) NOT NULL COMMENT '同payer_actors',
`reminder_actos` varchar(20) DEFAULT NULL COMMENT '同payer_actors',
`freeze_types` varchar(20) DEFAULT NULL COMMENT '资金冻结类型，ADVANCE_FREEZE(0, "是否冻结垫付金额", "advanceFreeze"),
TRANSFER_FREEZE(1, "是否冻结保证金", "transferFreeze")',
`other_inputs` varchar(20) DEFAULT NULL COMMENT '其他输入，BEREMINDER_INPUT(0, "催缴金额", "bereminderInput"),
MOVE_FREEZE_MONEY(1, "转移冻结金额", "monveFreezeMoney")',
`common_validators` varchar(200) DEFAULT NULL COMMENT '通用校验器',
`create_validators` varchar(100) DEFAULT NULL COMMENT '创建校验器',
`edit_vliadators` varchar(100) DEFAULT NULL COMMENT '编辑校验器',
`processname` varchar(50) NOT NULL COMMENT '流程名称',
`payagent` varchar(30) DEFAULT NULL COMMENT '出账接口',
`case_types` varchar(20) DEFAULT NULL COMMENT 'case类型，REFUND_CASE(1,"退款"),
SUIT_CASE(2,"投诉"),
LOGISTICS_CASE(3,"物流工单"),
FORM_CASE(4,"表单"),
TMALL_SUIT(5,"天猫投诉"),
RIGHT_CASE(6,"淘宝售后")',
`order_types` varchar(20) DEFAULT NULL COMMENT '订单类型，TC(1,"交易订单"),
WLB(2,"物流宝订单"),
ZHIJIAN(3,"质检订单"),
ALIPAY(4,"支付宝订单"),
SPECIAL(5,"特殊编号"),
LOGISTICS(6,"物流订单"),
AIRTRAVEL(7,"机票订单"),
LOTTERY(8,"彩票订单"),',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '更新时间',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_unique_primary` (`compen_type_name`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付类型配置表';
CREATE TABLE if not exists `compensate_bill_alive` (
`id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`order_id` varchar(64) DEFAULT NULL COMMENT '订单编号',
`order_type` int(10) unsigned DEFAULT NULL COMMENT '订单类型，淘宝订单、彩票订单、物流宝订单等',
`case_id` bigint(20) unsigned DEFAULT NULL COMMENT 'case编号',
`case_type` int(10) unsigned DEFAULT NULL COMMENT 'case类型，退款、投诉、表单等',
`alipay_order_id` varchar(64) DEFAULT NULL COMMENT '赔付记录关联的订单的支付宝交易号',
`compen_type` varchar(32) NOT NULL COMMENT '赔付类型',
`payer_id` bigint(20) unsigned NOT NULL COMMENT '付款方UIC-ID',
`payer_actor` int(10) unsigned NOT NULL COMMENT '付款方角色',
`payee_id` bigint(20) unsigned NOT NULL COMMENT '收款方UIC-ID',
`payee_actor` int(10) unsigned NOT NULL COMMENT '收款方角色',
`total_amout` bigint(20) unsigned NOT NULL COMMENT '赔付金额，单位分',
`amounts` varchar(1000) DEFAULT NULL COMMENT '赔付金额，积分明细',
`creator_id` bigint(20) unsigned DEFAULT NULL COMMENT '赔付单创建人',
`previous_id` bigint(20) unsigned DEFAULT NULL COMMENT '赔付单之前审批人',
`dealer_id` bigint(20) unsigned DEFAULT NULL COMMENT '赔付单当前审批人',
`status` int(11) NOT NULL COMMENT '赔付状态',
`reminder_status` int(11) DEFAULT NULL COMMENT '催缴状态',
`compen_memo` varchar(1000) DEFAULT NULL COMMENT '赔付单备注',
`gmt_pay_date` datetime DEFAULT NULL COMMENT '出账时间',
`pay_alipay_order_id` varchar(64) DEFAULT NULL COMMENT '出账的支付宝交易号',
`move_freeze_fee` bigint(20) unsigned DEFAULT NULL COMMENT '冻结金额',
`sync_version` int(11) DEFAULT NULL COMMENT '版本信息，暂时未用',
`main_order_id` varchar(64) DEFAULT NULL COMMENT '赔付记录关联的主订单编号',
`out_id` varchar(100) DEFAULT NULL COMMENT '赔付唯一外部编号',
`attributes` varchar(1000) DEFAULT NULL COMMENT '赔付属性及扩充字段',
PRIMARY KEY (`id`),
KEY `idx_compensate_bill_outid` (`out_id`),
KEY `ind_compensate_bill_case` (`case_id`,`case_type`),
KEY `ind_compensate_bill_creator` (`creator_id`,`status`,`gmt_create`),
KEY `ind_compensate_bill_dealer` (`dealer_id`,`status`,`gmt_create`),
KEY `ind_compensate_bill_moid` (`main_order_id`),
KEY `ind_compensate_bill_order` (`order_id`),
KEY `ind_compensate_bill_payee` (`payee_id`,`gmt_create`),
KEY `ind_compensate_bill_payer` (`payer_id`,`gmt_create`)
)  DEFAULT CHARSET=utf8 ,COMMENT='赔付记录活跃表';
