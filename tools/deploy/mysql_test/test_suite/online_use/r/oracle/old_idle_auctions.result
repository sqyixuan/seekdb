`effect_date` datetime NOT NULL COMMENT '生效日期',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`rule_name` varchar(50) NOT NULL COMMENT '规则名',
PRIMARY KEY (`id`),
KEY `idx_conf_effect_rule_id` (`rule_id`)
)  AUTO_INCREMENT=5379 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索规则生效日期记录表';
CREATE TABLE if not exists `idle_search_conf_page` (
