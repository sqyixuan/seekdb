PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='宝贝评分分布表';
CREATE TABLE if not exists `idle_best_offer` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键id',
`buyer_id` bigint(20) NOT NULL COMMENT '用户id',
`buyer_nick` varchar(50) NOT NULL COMMENT '用户nick',
`price` bigint(20) NOT NULL COMMENT '心愿价',
`phone` varchar(50) NOT NULL COMMENT '联系电话',
`prov` varchar(50) DEFAULT NULL COMMENT '省份',
`city` varchar(50) DEFAULT NULL COMMENT '城市',
`rank` int(11) DEFAULT NULL COMMENT '买家信用',
`auth_status` tinyint(4) NOT NULL COMMENT '是否实名认证：1为已认证；0为未认证',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录修改时间',
`item_id` bigint(20) NOT NULL COMMENT '商品id',
`seller_id` bigint(20) NOT NULL COMMENT '商品对应的卖家Id',
`biz_order_id` bigint(20) DEFAULT NULL COMMENT '该商品成交的订单号',
`status` tinyint(4) NOT NULL COMMENT '璁?环鐘舵?锛?绛夊緟鍗栧?鍚屾剰锛?鍥炴敹鍟嗚秴鏃朵粯娆句骇鐢熺殑鐘舵?锛屼腑闂寸姸鎬侊紝3鍗栧?宸茬粡鍚屾剰锛岀瓑寰呬拱瀹朵粯娆撅紝4宸叉彁浜ゆ柊璁?环,璇ヨ?浠蜂綔搴燂紝5鍗栧?閫変腑鐨勫洖鏀跺晢锛岃繖涓?笉鍋氬睍绀虹敤锛?鍗栧?涓嶅悓鎰忚?浠蜂俊鎭',
`item_detail` varchar(5000) DEFAULT NULL COMMENT '冗余一份回收平台提交过来的议价信息',
`buyer_message` varchar(140) DEFAULT NULL COMMENT '涔板?鐣欒█',
`view_status` tinyint(4) DEFAULT NULL COMMENT '闃呰?鐘舵?锛?涓烘湭闃咃紝1涓?闃',
`offer_from` bigint(20) DEFAULT NULL COMMENT '鏉ユ簮锛?涓篜C',
PRIMARY KEY (`id`),
KEY `idx_iit_st` (`item_id`,`status`),
KEY `idx_bid_gc` (`buyer_id`,`gmt_create`),
KEY `idx_gc` (`gmt_create`),
KEY `idx_gm` (`gmt_modified`),
KEY `index_gmt` (`gmt_create`),
KEY `index_bid_status_gmt` (`buyer_id`,`status`,`gmt_create`),
KEY `idx_item_id_status_gmt_create` (`item_id`,`status`,`gmt_create`),
KEY `index_sellerid_gmt` (`seller_id`,`gmt_create`)
)  AUTO_INCREMENT=9695262 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置议价表信息';
CREATE TABLE if not exists `idle_care_item` (
`care_id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键，订阅id',
`user_id` bigint(20) NOT NULL COMMENT '用户id',
`item_id` bigint(20) NOT NULL COMMENT '商品id',
`title` varchar(256) NOT NULL COMMENT '商品标题',
`price` decimal(14,2) NOT NULL COMMENT '商品价格',
`pic_url` varchar(256) NOT NULL COMMENT '商品主图路径',
`item_from` varchar(50) NOT NULL COMMENT '商品来源',
`chop_pic` varchar(256) DEFAULT NULL COMMENT '商品正方形主图',
`item_tag` varchar(100) DEFAULT NULL COMMENT '商品关键字',
`category` bigint(20) NOT NULL COMMENT '叶子类目id',
`property` varchar(2048) DEFAULT NULL COMMENT '类目属性',
`stuff_status` tinyint(4) DEFAULT NULL COMMENT '商品新旧程度（10-全新 9-九成新 8-八成新 7-七成新及以下）',
`status` tinyint(4) NOT NULL COMMENT '订阅状态:1表示订阅，2表示取消订阅',
