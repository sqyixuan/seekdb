CREATE TABLE if not exists `act_earth_notice` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) NOT NULL COMMENT '用户id',
`notice_cat` int(11) NOT NULL COMMENT '宣言类别',
`notice_cat_name` varchar(20) NOT NULL COMMENT '宣言名称',
`notice` varchar(100) NOT NULL COMMENT '宣言',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`nick` varchar(32) DEFAULT NULL COMMENT '昵称',
`status` int(11) NOT NULL DEFAULT '0' COMMENT '留言状态  0：正常 1：可以用户',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_act_earth_notice_user_id` (`user_id`),
KEY `idx_act_earth_notice_status` (`status`),
KEY `idx_act_earth_notice_nick` (`nick`),
KEY `idx_act_earth_notice_cat` (`notice_cat`),
KEY `idx_act_earth_notice_statcat` (`notice_cat`,`status`)
)  AUTO_INCREMENT=78838 ,DEFAULT CHARSET=utf8 ,COMMENT='地球日活动宣言表';
CREATE TABLE if not exists `act_earth_user_support` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`share_uid` bigint(20) NOT NULL COMMENT '宣言用户id',
`share_cat` bigint(20) NOT NULL COMMENT '宣言类别',
`share_nick` varchar(32) NOT NULL COMMENT '宣言用户昵称',
`user_id` bigint(20) DEFAULT NULL COMMENT '支持者id',
`ip` varchar(30) DEFAULT NULL COMMENT '支持者ip',
`cookie` varchar(50) DEFAULT NULL COMMENT '支持者cookie',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
PRIMARY KEY (`id`),
KEY `idx_Act_earth_user_support_user_id` (`user_id`),
KEY `idx_user_support_share_uid` (`share_uid`),
KEY `idx_user_support_gmt` (`gmt_create`),
KEY `idx_user_support_uidid` (`share_uid`,`user_id`),
KEY `idx_user_support_uidipcoo` (`share_uid`,`ip`,`cookie`)
)  AUTO_INCREMENT=369773 ,DEFAULT CHARSET=utf8 ,COMMENT='地球日活动用户支持表';
CREATE TABLE if not exists `erhuo_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '用户ID',
`nick` varchar(100) DEFAULT NULL COMMENT '用户昵称',
`title` varchar(200) DEFAULT NULL COMMENT '标题',
`desc_varchar(1024)` varchar(1000) DEFAULT NULL COMMENT '描述',
`image_url` varchar(200) DEFAULT NULL COMMENT '图片地址',
`mix_image_url` varchar(200) DEFAULT NULL COMMENT '合成图片地址',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '活动类型  1- 贩2',
`feature` varchar(1000) DEFAULT NULL COMMENT '冗余信息',
`status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '-1 无效状态',
`act_id` bigint(20) unsigned DEFAULT '0' COMMENT '冗余活动ID',
`pop_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '人气指数',
PRIMARY KEY (`id`),
KEY `orderbykey` (`gmt_create`,`status`),
KEY `userkey` (`user_id`,`status`)
)  AUTO_INCREMENT=2744 ,DEFAULT CHARSET=utf8 ,COMMENT='二货信息';
CREATE TABLE if not exists `idle_2013_orders_0000` (
`buyer_id` bigint(20) unsigned NOT NULL COMMENT '分表字段，主键',
`buyer_nick` varchar(64) DEFAULT NULL COMMENT '用户nick',
`top_category` varchar(10) DEFAULT NULL COMMENT '购买金额最多的类目',
`top_money` varchar(20) DEFAULT NULL COMMENT '购买金额最多的类目，其对应的购买金额',
`attributes` varchar(5000) DEFAULT NULL COMMENT 'biz_order_id:订单号
auction_id:宝贝id
pict_url:宝贝图片
price:宝贝价格
title：宝贝标题
逗号分割，分号分组',
PRIMARY KEY (`buyer_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='云梯2013年购买最多的类目和其对应金额，以及前8个商品';
