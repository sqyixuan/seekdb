`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`user_nick` varchar(100) DEFAULT NULL COMMENT '淘宝nick',
`idle_nick` varchar(100) DEFAULT NULL COMMENT '二手用户别名',
`idle_level` int(11) DEFAULT NULL COMMENT '二手用户等级',
`idle_credit_score` int(11) DEFAULT '10000' COMMENT '二手信用分，默认10000分',
`idle_icon` varchar(200) DEFAULT NULL COMMENT '二手用户头像',
`idle_mobile` varchar(100) DEFAULT NULL COMMENT '二手用户联系方式',
`idle_email` varchar(100) DEFAULT NULL COMMENT '二手用户邮箱',
`idle_status` tinyint(4) DEFAULT NULL COMMENT '用户状态，1正常2屏蔽3CC',
`idle_last_long_date` datetime DEFAULT NULL COMMENT '用户上次登录时间',
`idle_login_imei` varchar(40) DEFAULT NULL COMMENT '用户登录设备imei号',
`attributes` varchar(500) DEFAULT NULL COMMENT '属性，扩展用',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '用户权限',
`f_seller_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的评价数',
`f_buyer_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的评价数',
`f_seller_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的“好”评数',
`f_buyer_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的“好”评数',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_uniq_userid` (`user_id`),
KEY `idx_userid_status` (`user_id`,`idle_status`),
KEY `idx_usernick_status` (`idle_nick`,`idle_status`)
)  AUTO_INCREMENT=59460 ,DEFAULT CHARSET=utf8 ,COMMENT='二手用户表';
