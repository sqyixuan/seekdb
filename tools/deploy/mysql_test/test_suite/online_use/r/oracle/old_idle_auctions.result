`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_shop_info_extra_shop_id` (`shop_id`)
)  AUTO_INCREMENT=7763 ,DEFAULT CHARSET=utf8 ,COMMENT='“同店转让”店铺用于存店铺bannar';
CREATE TABLE if not exists `idle_theme_list` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`name` varchar(50) NOT NULL COMMENT '主题名称',
`pict_url` varchar(200) NOT NULL COMMENT '主题氛围图',
`icon_url` varchar(200) NOT NULL COMMENT '主题图标图',
`link` varchar(50) NOT NULL COMMENT '主题链接',
`introduce` varchar(500) NOT NULL COMMENT '主题介绍',
`market` varchar(50) NOT NULL COMMENT '所属市场',
`rule_id` varchar(50) NOT NULL COMMENT '关联规则',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`query` int(11) NOT NULL DEFAULT '0' COMMENT '是否支持搜索 0:不支持 1:支持',
`sort` varchar(20) DEFAULT NULL COMMENT '默认排序(帮你淘、发布时间、价格)',
`modules` varchar(100) DEFAULT NULL COMMENT '专题模块(区域筛选、卖家筛选、刚刚转让、专题讨论)',
`ralate` varchar(100) DEFAULT NULL COMMENT '关联主题',
`icon_url2` varchar(200) NOT NULL COMMENT '主题图标，客户端用',
`bg_color` varchar(50) NOT NULL COMMENT '背景色',
`style` varchar(50) NOT NULL COMMENT '配色风格',
`client_order` int(11) DEFAULT NULL COMMENT '客户端排序字段',
`pc_order` int(11) DEFAULT NULL COMMENT 'PC端排序字段',
`type` tinyint(4) DEFAULT '0' COMMENT '0 主题, 1 专题,',
`tfs_path` varchar(60) DEFAULT NULL COMMENT '专题描述tfs路径',
`guide_url` varchar(300) DEFAULT NULL COMMENT '专题引导链接',
`mix_rule` int(11) DEFAULT '0' COMMENT '搜索机选和人工选择的打散规则,0机选，1人选',
`theme_tab_id` bigint(20) unsigned DEFAULT NULL COMMENT '人选规则ID',
`theme_order` int(11) DEFAULT '0' COMMENT '客户端首页排序 0不在首页显示',
PRIMARY KEY (`id`),
KEY `idx_market_gc` (`market`,`gmt_create`),
KEY `idx_gm` (`gmt_modified`),
KEY `idx_gc` (`gmt_create`),
KEY `index_market` (`market`),
KEY `index_type` (`type`),
KEY `index_order` (`theme_order`)
)  AUTO_INCREMENT=224 ,DEFAULT CHARSET=utf8 ,COMMENT='主题列表基础信息表';
CREATE TABLE if not exists `idle_theme_tag` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`tag_name` varchar(50) NOT NULL COMMENT '标签名',
`tag_link` varchar(200) NOT NULL COMMENT '标签链接',
`group_name` varchar(50) NOT NULL COMMENT '标签组',
`tm_id` int(11) NOT NULL COMMENT '所属主题',
`tag_order` int(11) DEFAULT NULL COMMENT '标签顺序',
`group_order` int(11) DEFAULT NULL COMMENT '标签组顺序',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
PRIMARY KEY (`id`),
KEY `idx_gm` (`gmt_modified`),
KEY `idx_gc` (`gmt_create`),
KEY `idx_tm_id_group_tag_order` (`tm_id`,`group_order`,`tag_order`),
KEY `ind_tm` (`tm_id`),
KEY `idx_tmid` (`tm_id`)
)  AUTO_INCREMENT=765 ,DEFAULT CHARSET=utf8 ,COMMENT='主题列表导航标签';
CREATE TABLE if not exists `idle_top_tag` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`tag` varchar(30) NOT NULL COMMENT '热门标签',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`ranking` int(11) NOT NULL COMMENT '排名',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=177 ,DEFAULT CHARSET=utf8 ,COMMENT='热门标签表';
CREATE TABLE if not exists `idle_transfershop_data` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`buyer_id` bigint(20) DEFAULT NULL COMMENT '买家id',
`buyer_nick` varchar(32) DEFAULT NULL COMMENT '买家nick',
`seller_id` bigint(20) DEFAULT NULL COMMENT '卖家id',
`seller_nick` varchar(32) DEFAULT NULL COMMENT '卖家nick',
`shop_id` bigint(20) DEFAULT NULL COMMENT '卖家对应店铺id',
`shop_title` varchar(110) DEFAULT NULL COMMENT '卖家对应店铺nick',
`max_order_count` bigint(20) DEFAULT NULL COMMENT '买家在该店铺购买的订单数',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
PRIMARY KEY (`id`),
KEY `idx_transfershop_data_buyer_id` (`buyer_id`)
)  AUTO_INCREMENT=128801257 ,DEFAULT CHARSET=utf8 ,COMMENT='记录三个月内女装类目购买数据';
CREATE TABLE if not exists `idle_transfershop_unset` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`shop_id` bigint(20) NOT NULL COMMENT '店铺id',
`shop_title` varchar(110) DEFAULT NULL COMMENT '店铺名称',
`seller_id` bigint(20) DEFAULT NULL COMMENT '店铺所属卖家id',
`seller_nick` varchar(32) DEFAULT NULL COMMENT '店铺所属卖家nick',
`buyer_id` bigint(20) DEFAULT NULL COMMENT '希望开通同店转让的用户id',
`buyer_nick` varchar(32) DEFAULT NULL COMMENT '希望开通同店转让的用户nick',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
PRIMARY KEY (`id`),
KEY `idx_transfershop_unset_shop_id` (`shop_id`),
KEY `idx_transfershop_unset_buyer_id` (`buyer_id`)
)  AUTO_INCREMENT=70473 ,DEFAULT CHARSET=utf8 ,COMMENT='记录购买记录多而未开通同店转让的店铺';
CREATE TABLE if not exists `idle_user_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
`user_nick` varchar(100) DEFAULT NULL COMMENT '淘宝nick',
`idle_nick` varchar(100) DEFAULT NULL COMMENT '二手用户别名',
`idle_level` int(11) DEFAULT NULL COMMENT '二手用户等级',
`idle_credit_score` int(11) DEFAULT '10000' COMMENT '二手信用分，默认10000分',
`idle_icon` varchar(200) DEFAULT NULL COMMENT '二手用户头像',
`idle_mobile` varchar(100) DEFAULT NULL COMMENT '二手用户联系方式',
`idle_email` varchar(100) DEFAULT NULL COMMENT '二手用户邮箱',
`idle_status` tinyint(4) DEFAULT NULL COMMENT '用户状态，1正常2屏蔽3CC',
`idle_last_long_date` datetime DEFAULT NULL COMMENT '用户上次登录时间',
`idle_login_imei` varchar(40) DEFAULT NULL COMMENT '用户登录设备imei号',
`attributes` varchar(500) DEFAULT NULL COMMENT '属性，扩展用',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '用户权限',
`f_seller_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的评价数',
`f_buyer_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的评价数',
`f_seller_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的“好”评数',
`f_buyer_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的“好”评数',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_uniq_userid` (`user_id`),
KEY `idx_userid_status` (`user_id`,`idle_status`),
KEY `idx_usernick_status` (`idle_nick`,`idle_status`)
)  AUTO_INCREMENT=59527 ,DEFAULT CHARSET=utf8 ,COMMENT='二手用户表';
