)  AUTO_INCREMENT=21 ,DEFAULT CHARSET=utf8 ,COMMENT='同步honey的相关数据';
CREATE TABLE if not exists `idle_itb_namelist` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户userid',
`nick` varchar(64) DEFAULT NULL COMMENT '用户昵称',
`site` varchar(64) DEFAULT NULL COMMENT '站点名称,例如:TAOBAO',
`category` varchar(32) DEFAULT NULL COMMENT '类目信息，对应规则中：手机=B,平板电脑=C,笔记本电脑=D,相机=F,镜头=G,台式机/一体机=H',
`level` int(11) DEFAULT NULL COMMENT '优先级,1-5',
