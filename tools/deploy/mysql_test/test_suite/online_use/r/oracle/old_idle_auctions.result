`page_name` varchar(30) NOT NULL COMMENT '页面名称',
`search_app` varchar(30) NOT NULL COMMENT '搜索app',
`operator` varchar(30) NOT NULL COMMENT '操作人',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=97 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索定制化-规则分页信息表';
CREATE TABLE if not exists `sc_param_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`param_name` varchar(30) NOT NULL COMMENT '参数名',
`param_value` varchar(1000) NOT NULL COMMENT '参数值',
`param_type` tinyint(3) unsigned NOT NULL COMMENT '参数类型',
`rule_id` bigint(20) unsigned NOT NULL COMMENT '所属规则',
`operator` varchar(30) NOT NULL COMMENT '操作人',
`status` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '状态：0 预览 1 生效',
PRIMARY KEY (`id`),
KEY `index_rule_id` (`rule_id`)
)  AUTO_INCREMENT=17744 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索定制化-参数配置表';
CREATE TABLE if not exists `sc_rule_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`rule_name` varchar(30) NOT NULL COMMENT '规则名',
`remark` varchar(50) NOT NULL COMMENT '备注',
`version` tinyint(3) unsigned NOT NULL DEFAULT '1' COMMENT '规则版本',
`status` tinyint(3) unsigned NOT NULL COMMENT '状态：0 未启用 1启用',
`page_id` bigint(20) unsigned NOT NULL COMMENT '所属页面',
`search_app` varchar(30) NOT NULL COMMENT '搜索app',
`operator` varchar(30) NOT NULL COMMENT '操作人',
PRIMARY KEY (`id`),
KEY `index_search_app` (`search_app`),
KEY `index_page_id` (`page_id`),
KEY `index_status` (`status`,`rule_name`)
)  AUTO_INCREMENT=1278 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索定制化-规则配置信息表';
CREATE TABLE if not exists `sc_schema_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`field` varchar(30) NOT NULL COMMENT '索引字段',
`name` varchar(30) DEFAULT NULL COMMENT '名称',
`remark` varchar(200) DEFAULT NULL COMMENT '备注',
`sort_field` tinyint(3) unsigned DEFAULT '0' COMMENT '做为排序字段用：1是，0否， 2 仅仅作为排序字段',
`group_field` tinyint(3) unsigned DEFAULT '0' COMMENT '做为分组字段用：1是，0否',
`sn` tinyint(4) DEFAULT '0' COMMENT '顺序号',
`search_app` varchar(30) NOT NULL COMMENT '所属app',
`operator` varchar(30) NOT NULL COMMENT '操作人',
`filter_query_field` tinyint(3) unsigned DEFAULT '0' COMMENT '作为filterQuery字段',
`input_content` varchar(500) DEFAULT NULL COMMENT '输入选项',
`input_type` tinyint(3) unsigned DEFAULT '0' COMMENT '输入类型',
PRIMARY KEY (`id`),
KEY `index_search_app` (`search_app`),
KEY `index_sn` (`sn`)
)  AUTO_INCREMENT=1330 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索定制化-schema初始化信息表';
CREATE TABLE if not exists `search_field_conf` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`app_name` varchar(20) NOT NULL COMMENT '应用名',
`search_app_name` varchar(20) NOT NULL COMMENT '搜索应用名',
`config` varchar(4000) NOT NULL COMMENT '配置',
PRIMARY KEY (`id`),
KEY `pk_app_search` (`app_name`,`search_app_name`)
)  AUTO_INCREMENT=2 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索索引与前台搜索字段对应表';
CREATE TABLE if not exists `search_index_conf` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`app_name` varchar(100) NOT NULL COMMENT '应用名',
`search_app_name` varchar(128) NOT NULL COMMENT '搜索应用名',
`config` varchar(4000) NOT NULL COMMENT '索引配置',
`env` varchar(10) NOT NULL COMMENT '环境',
PRIMARY KEY (`id`),
KEY `unique_key` (`app_name`,`search_app_name`,`env`)
)  AUTO_INCREMENT=6 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索SDK索引配置表';
CREATE TABLE if not exists `tmp_idle_credit_total_result0607` (
`id` bigint(20) NOT NULL DEFAULT '0' COMMENT '自增主键',
