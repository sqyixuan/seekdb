CREATE TABLE if not exists `idle_fish_pool_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键-圈子ID',
`pool_name` varchar(20) NOT NULL COMMENT '圈子名称',
`gps_center` varchar(40) NOT NULL COMMENT '中心点GPS坐标',
`gps_radius` bigint(20) unsigned DEFAULT NULL COMMENT '单位：米，鱼塘发布半径（矩形是边长一半）',
`gps_type` tinyint(4) NOT NULL DEFAULT '1' COMMENT 'gps类型。1：圆形3：矩形3：多边形.默认圆形',
`gps_clockwise_point` varchar(200) DEFAULT NULL COMMENT '多边形顺时针坐标点，不超过10个点',
`prov` varchar(20) DEFAULT NULL COMMENT '省',
`city` varchar(30) DEFAULT NULL COMMENT '市',
`area` varchar(50) DEFAULT NULL COMMENT '区',
`icon_url` varchar(256) DEFAULT NULL COMMENT '鱼塘头像图片',
`pic_url` varchar(256) DEFAULT NULL COMMENT '鱼塘背景图片',
`pool_type` varchar(20) DEFAULT NULL COMMENT '鱼塘类型，例如学校、住宅区、产业园区、写字楼、商圈、街道、区镇、城市',
`pool_status` tinyint(4) NOT NULL DEFAULT '1' COMMENT '鱼塘状态，1正常2删除3未启用，默认1',
`attributes` varchar(500) DEFAULT NULL COMMENT '附加属性，用于扩展',
`gps_view_radius` bigint(20) unsigned DEFAULT NULL COMMENT '鱼塘可见半径，单位米',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
KEY `idx_id_status` (`id`,`pool_status`),
KEY `idx_name_type_status` (`pool_name`,`pool_type`,`pool_status`)
)  AUTO_INCREMENT=4333 ,DEFAULT CHARSET=utf8 ,COMMENT='咸鱼生活圈鱼塘基本信息';
CREATE TABLE if not exists `idle_fishpool_admin_relation` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`fish_pool_id` bigint(20) unsigned NOT NULL COMMENT '鱼塘ID',
`fish_pool_name` varchar(20) DEFAULT NULL COMMENT '鱼塘名称',
`pool_admin_user_id` bigint(20) unsigned NOT NULL COMMENT '鱼塘塘主id',
`pool_admin_user_nick` varchar(32) DEFAULT NULL COMMENT '塘主nick',
`pool_admin_idle_nick` varchar(32) DEFAULT NULL COMMENT '二手用户别名',
`pool_admin_privilege` bigint(20) unsigned NOT NULL DEFAULT '1' COMMENT '塘主权限级别，1主塘主2辅助塘主',
`pool_admin_status` tinyint(4) NOT NULL DEFAULT '1' COMMENT '塘主状态1正常2删除',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
KEY `idx_fpid_userid_priv_status` (`fish_pool_id`,`pool_admin_user_id`,`pool_admin_privilege`,`pool_admin_status`),
KEY `idx_fpid_priv_status` (`fish_pool_id`,`pool_admin_privilege`,`pool_admin_status`),
KEY `idx_userid_priv_status` (`pool_admin_user_id`,`pool_admin_privilege`,`pool_admin_status`)
)  AUTO_INCREMENT=10667 ,DEFAULT CHARSET=utf8 ,COMMENT='鱼塘和塘主映射关系表，记录鱼塘id和塘主id，塘主权限等';
CREATE TABLE if not exists `idle_fishpool_alterapply` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录的最后编辑时间',
`applicant_user_id` bigint(20) NOT NULL COMMENT '申请者用户id',
`applicant_user_nick` varchar(45) NOT NULL COMMENT '申请者用户nick',
`submit_type` int(11) NOT NULL DEFAULT '0' COMMENT '申请类型： 0表示申请创建新鱼塘；1表示申请扩大鱼塘；2表示申请合并鱼塘',
`applicant_lang` varchar(20) DEFAULT NULL COMMENT '申请者所在经度',
`applicant_lat` varchar(20) DEFAULT NULL COMMENT '申请者所在维度',
`applicant_lbs` varchar(200) DEFAULT NULL COMMENT '申请者所在的lbs信息',
`pool_name` varchar(200) DEFAULT NULL COMMENT '鱼塘的新名称',
`pool_type` varchar(20) DEFAULT NULL COMMENT '鱼塘类型，例如学校、住宅区、产业园区、写字楼、商圈、街道、区镇、城市',
`prov` varchar(20) DEFAULT NULL COMMENT '省',
`city` varchar(30) DEFAULT NULL COMMENT '市',
`area` varchar(50) DEFAULT NULL COMMENT '区',
`pool_range_desc` varchar(1024) COMMENT '申请者填写的申请范围描述。如：东至某路等',
`applicat_reason` varchar(1024) COMMENT '申请理由描述（如果是创建新鱼塘则是用户填写的创建原因；如果是调整鱼塘则是选择的调整原因）',
`strategic_plan` varchar(1024) COMMENT '申请成功后，申请者填写的对该鱼塘的后续计划描述',
`is_apply_for_admin` int(11) DEFAULT '0' COMMENT '如果为创建新鱼塘，表示是否申请成为塘主。 0表示否，1表示是。',
`merge_main_pool_id` bigint(20) DEFAULT NULL COMMENT '申请类型是2（即合并鱼塘）时，主合并鱼塘的id',
`merged_pool_ids` varchar(400) DEFAULT NULL COMMENT '待合并的其它鱼塘id，多个鱼塘id用英文逗号分隔',
`is_agree_protocal` int(11) DEFAULT '0' COMMENT '如果创建新鱼塘且成为塘主，则需要阅读并同意塘主报名协议。0表示否，1表示是。',
`applicat_real_name` varchar(50) DEFAULT NULL COMMENT '申请者的真实姓名',
`applicat_phone` varchar(50) DEFAULT NULL COMMENT '申请者的手机号',
`applicat_email` varchar(50) DEFAULT NULL COMMENT '申请者的邮箱',
`applicat_bbs` varchar(50) DEFAULT NULL COMMENT 'BBS论坛地址',
`applicat_group_num` varchar(50) DEFAULT NULL COMMENT '公司/业委QQ群/旺旺群 群号',
`applicat_wechat_id` varchar(50) DEFAULT NULL COMMENT '微信公共账号ID',
`xiaoer_already_operate` int(11) DEFAULT '0' COMMENT '小二是否已审批。 0表示尚未审批，1表示同意，2表示已拒绝,-1表示删除',
`xiaoer_perate_time` datetime DEFAULT NULL COMMENT '小二审批时间',
`xiaoer_operate_desc` varchar(1024) COMMENT '小二审批后的描述',
`attributes` varchar(2000) DEFAULT NULL COMMENT '扩展字段',
`xiaoer_new_fishpool_id` bigint(20) DEFAULT NULL COMMENT '小二审批通过后，成功创建后的鱼塘id',
`xiaoer_push_msg` varchar(400) DEFAULT NULL COMMENT '小二审批后，给用户发出的push消息',
PRIMARY KEY (`id`),
KEY `index_sortbysubmittypexiaoeroperate` (`submit_type`,`xiaoer_already_operate`,`applicant_user_id`),
KEY `index_sortbyapplicatuserid` (`applicant_user_id`)
)  AUTO_INCREMENT=3612 ,DEFAULT CHARSET=utf8 ,COMMENT='申请创建鱼塘、合并鱼塘、扩大鱼塘';
CREATE TABLE if not exists `idle_fishpool_announcement` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`fishpool_id` bigint(20) unsigned NOT NULL COMMENT '鱼塘ID',
`title` varchar(50) DEFAULT NULL COMMENT '标题',
`content` varchar(128) DEFAULT NULL COMMENT '富文本公告的TFS地址',
`status` tinyint(4) DEFAULT '1' COMMENT '公告状态1上线2编辑3删除默认上线',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '最后一次编辑公告的用户id',
`image_urls` varchar(1000) DEFAULT NULL COMMENT '公告图片，用英文逗号分隔，最多五张公告图片',
`attributes` varchar(3000) DEFAULT NULL COMMENT '扩展字段',
`anno_type` tinyint(4) DEFAULT '0' COMMENT '公告类型。0表示塘主公告，1表示运营公告',
PRIMARY KEY (`id`),
KEY `idx_poolid_status` (`fishpool_id`,`status`,`gmt_modified`)
)  AUTO_INCREMENT=4331 ,DEFAULT CHARSET=utf8 ,COMMENT='鱼塘公告';
CREATE TABLE if not exists `idle_fishpool_apply` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '申请用户ID',
`fish_pool_id` bigint(20) unsigned NOT NULL COMMENT '申请鱼塘ID',
`real_name` varchar(40) NOT NULL COMMENT '真实姓名',
`nick` varchar(32) NOT NULL COMMENT '旺旺号码',
`phone` varchar(50) NOT NULL COMMENT '手机号码',
`email` varchar(100) NOT NULL COMMENT '邮箱',
`bbs` varchar(500) DEFAULT NULL COMMENT 'BBS论坛地址',
`group_num` varchar(50) DEFAULT NULL COMMENT '公司/业委QQ群/旺旺群 群号',
`wechat_id` varchar(50) DEFAULT NULL COMMENT '微信公共账号ID',
`other_comment` varchar(512) DEFAULT NULL COMMENT '其他(描述)',
`my_introduce` varchar(128) NOT NULL COMMENT '自我介绍',
`expected_harves` varchar(128) NOT NULL COMMENT '预计收获描述',
`pool_introduce` varchar(128) NOT NULL COMMENT '竞选鱼塘介绍',
`propaganda` varchar(128) NOT NULL COMMENT '线下宣传说明',
`manage_time` varchar(512) NOT NULL COMMENT '每天管理鱼塘时间描述',
`how_know` varchar(128) NOT NULL COMMENT '怎样让别人尽快知道 描述',
`status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '审批状态。
0:初始状态, 1:审批通过, 2:拒绝1, 3:拒绝2',
`message` varchar(512) DEFAULT NULL COMMENT '消息提醒内容',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_user_fish_pool` (`user_id`,`fish_pool_id`),
KEY `index_fish_pool_id` (`fish_pool_id`)
)  AUTO_INCREMENT=15758 ,DEFAULT CHARSET=utf8 ,COMMENT='塘主报名信息表';
CREATE TABLE if not exists `idle_fishpool_topic` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`topic_name` varchar(20) NOT NULL COMMENT '鱼塘下的分类名称',
`topic_order` tinyint(4) DEFAULT NULL COMMENT '分类排序',
`fishpool_id` bigint(20) unsigned NOT NULL COMMENT '鱼塘id',
`searche_rule` varchar(5000) DEFAULT NULL COMMENT '分类下商品搜索规则，JSON方式存储搜素规则',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '创建者用户淘宝id',
`status` tinyint(4) DEFAULT '1' COMMENT '1:正常,2:删除',
`topic_create_type` tinyint(4) DEFAULT '0' COMMENT '0表示塘主自定义的分类，1表示系统统一配置的分类',
PRIMARY KEY (`id`),
KEY `idx_fpid_status_topicorder` (`fishpool_id`,`status`,`topic_order`)
)  AUTO_INCREMENT=29259 ,DEFAULT CHARSET=utf8 ,COMMENT='鱼塘下分类信息';
CREATE TABLE if not exists `idle_fishpool_uv_sum` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
