`offlined` tinyint(4) DEFAULT NULL COMMENT '交易方式 （0-线上 1-线下 2-线上线下均可）',
`gps` varchar(40) DEFAULT NULL COMMENT '地图定位：纬度,经度',
`prov` varchar(20) DEFAULT NULL COMMENT '商品所在省份',
`city` varchar(30) DEFAULT NULL COMMENT '商品所在城市',
`area` varchar(50) DEFAULT NULL COMMENT '商品所在地区，同闲置子表',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`care_id`),
UNIQUE KEY `uk_uid_itemid` (`user_id`,`item_id`),
KEY `idx_uid_st_gm` (`user_id`,`status`,`gmt_modified`),
KEY `idx_gm` (`gmt_modified`),
KEY `idx_gc` (`gmt_create`)
)  AUTO_INCREMENT=33968689 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置订阅列表';
