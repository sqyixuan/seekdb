CREATE TABLE if not exists `idle_act_award` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`award_type_id` int(11) NOT NULL COMMENT '奖励类型',
`award_detail` varchar(500) DEFAULT NULL COMMENT '奖励参数明细，json串',
`task_id` bigint(20) unsigned NOT NULL COMMENT '所属任务id',
`status` int(11) DEFAULT NULL COMMENT '奖励状态，1为正常，2为删除',
`award_user_type` int(11) NOT NULL COMMENT '奖励对象，1为卖家，2为买家',
PRIMARY KEY (`id`),
KEY `idx_taskid` (`task_id`)
)  AUTO_INCREMENT=4 ,DEFAULT CHARSET=utf8 ,COMMENT='活动奖励信息';
CREATE TABLE if not exists `idle_act_data` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '用户id',
`activity_id` bigint(20) unsigned DEFAULT NULL COMMENT '活动id',
`task_id` bigint(20) unsigned DEFAULT NULL COMMENT '任务id',
`award_id` bigint(20) unsigned DEFAULT NULL COMMENT '奖励id',
PRIMARY KEY (`id`),
KEY `ind_us_ac_ta` (`user_id`,`activity_id`,`task_id`),
KEY `idx_all` (`activity_id`,`task_id`,`award_id`,`user_id`,`gmt_create`,`id`)
)  AUTO_INCREMENT=559403 ,DEFAULT CHARSET=utf8 ,COMMENT='活动获奖记录';
CREATE TABLE if not exists `idle_act_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`name` varchar(25) NOT NULL COMMENT '活动名称',
`activity_start` datetime DEFAULT NULL COMMENT '开始时间',
`activity_end` datetime DEFAULT NULL COMMENT '结束时间',
`type` smallint(6) DEFAULT NULL COMMENT '活动类型',
`owner` varchar(10) DEFAULT NULL COMMENT '创建者',
`attribute` varchar(1000) DEFAULT NULL COMMENT '活动其他信息',
`aid` bigint(20) DEFAULT NULL COMMENT '定向回收活动的id',
PRIMARY KEY (`id`),
KEY `ind_ow` (`owner`),
KEY `idx_start_end_owner_name_id` (`activity_start`,`activity_end`,`owner`,`name`,`id`)
)  AUTO_INCREMENT=3 ,DEFAULT CHARSET=utf8 ,COMMENT='活动列表';
CREATE TABLE if not exists `idle_act_machine_data` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`user_nick` varchar(50) DEFAULT NULL COMMENT '用户昵称',
`utdid` varchar(50) DEFAULT NULL COMMENT 'ios设备号',
`imei` varchar(50) DEFAULT NULL COMMENT 'android设备号',
`app_id` bigint(20) unsigned NOT NULL COMMENT 'appId:21407387 android ,12431167  ios',
`last_login_time` datetime DEFAULT NULL COMMENT '最后一次登录时间',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '用户userId',
PRIMARY KEY (`id`),
KEY `index_utdid` (`utdid`),
KEY `index_user_nick` (`user_nick`),
KEY `index_imei` (`imei`),
KEY `idx_last_login_time_user_id` (`last_login_time`,`user_id`)
)  AUTO_INCREMENT=41752491 ,DEFAULT CHARSET=utf8 ,COMMENT='二手客户端用户&amp;机器历史数据';
CREATE TABLE if not exists `idle_act_maimeng_detail` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户Id',
`item_id` bigint(20) unsigned NOT NULL COMMENT '商品Id',
`status` tinyint(4) NOT NULL COMMENT '状态：1:支持，-1:反对',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '0:卖萌,1:旅游卫视',
PRIMARY KEY (`id`),
KEY `index_item_id` (`item_id`),
KEY `index_user_id` (`user_id`),
KEY `index_item_id_type` (`item_id`,`type`)
)  AUTO_INCREMENT=82090 ,DEFAULT CHARSET=utf8 ,COMMENT='二手活动投票详情';
CREATE TABLE if not exists `idle_act_maimeng_sum` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`item_id` bigint(20) unsigned NOT NULL COMMENT '宝贝ID',
`support_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '支持数',
`unsupport_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '反对数',
`total_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '总数',
`type` tinyint(4) NOT NULL DEFAULT '0' COMMENT '0:卖萌 ,1:旅游卫视',
PRIMARY KEY (`id`),
KEY `index_unsupport_num` (`unsupport_num`),
KEY `index_support_num` (`support_num`),
KEY `index_item_id` (`item_id`),
KEY `index_total_num` (`total_num`),
KEY `index_item_id_type` (`item_id`,`type`)
)  AUTO_INCREMENT=1450 ,DEFAULT CHARSET=utf8 ,COMMENT='二手活动投票数据汇总表';
CREATE TABLE if not exists `idle_act_task` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`activity_id` bigint(20) unsigned NOT NULL COMMENT '所属活动ID',
`task_type_id` int(11) NOT NULL COMMENT '任务类型ID，如发布、估价',
`task_constraint` varchar(1000) DEFAULT NULL COMMENT '任务约束',
`activity_start` datetime NOT NULL COMMENT '开始时间',
`activity_end` datetime NOT NULL COMMENT '结束时间',
`status` tinyint(4) NOT NULL COMMENT '任务状态，1为正常，2为删除',
`remark` varchar(200) DEFAULT NULL COMMENT '任务备注',
PRIMARY KEY (`id`),
KEY `ind_sta` (`status`),
KEY `ind_ac` (`activity_id`)
)  AUTO_INCREMENT=4 ,DEFAULT CHARSET=utf8 ,COMMENT='活动任务信息';
CREATE TABLE if not exists `idle_auction_tag_num` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`tagname` varchar(20) NOT NULL COMMENT '标签名',
`matchnum` bigint(20) NOT NULL COMMENT '匹配数',
`qualinum` bigint(20) NOT NULL COMMENT '合格数（比如：bqTag&gt;=500）',
PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='宝贝标签数量对应表';
CREATE TABLE if not exists `idle_auctions_credit` (
`item_id` bigint(20) NOT NULL COMMENT '宝贝ID',
`user_id` bigint(20) NOT NULL COMMENT '用户id',
`ref_score` double DEFAULT NULL COMMENT '用户买家信用得分',
`score` double DEFAULT NULL COMMENT '商品信用得分',
`gmt_date` datetime DEFAULT NULL COMMENT '入库时间',
`gmt_create` datetime DEFAULT NULL COMMENT '记录创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '记录最后修改时间',
`grade` double DEFAULT NULL COMMENT '商品基本信息分数',
`buyer_star_id` bigint(20) DEFAULT NULL COMMENT '买家星级id',
`buyer_star_name` varchar(111) DEFAULT NULL COMMENT '买家星级名称',
`seller_star_id` bigint(20) DEFAULT NULL COMMENT '卖家星级id',
`seller_star_name` varchar(111) DEFAULT NULL COMMENT '卖家星级名称',
`vip_level` int(11) DEFAULT NULL COMMENT '用户星级',
`attributes` varchar(1000) DEFAULT NULL COMMENT '冗余字段',
`online_item_count` int(11) DEFAULT NULL COMMENT '当前在线商品数',
`user_type` int(11) DEFAULT NULL COMMENT '用户标记：与运算',
`bq_tag` int(11) DEFAULT '0' COMMENT '商品等级',
`item_tag` varchar(200) DEFAULT NULL COMMENT '商品标签',
PRIMARY KEY (`item_id`),
KEY `idx_user_id_type` (`user_id`,`user_type`)
)  DEFAULT CHARSET=utf8 ,COMMENT='用户、商品等级信息';
CREATE TABLE if not exists `idle_auctions_extra` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
`item_id` bigint(20) NOT NULL COMMENT '宝贝数字id',
`user_id` bigint(20) NOT NULL COMMENT '卖家数字id（索引）',
`area` varchar(50) NOT NULL COMMENT '宝贝所在的区',
`stuff_status` tinyint(4) NOT NULL COMMENT '宝贝新旧程度（10-全新 9-九成新 8-八成新  7-七成新及以下）',
`tag` varchar(100) DEFAULT NULL COMMENT '宝贝标签',
`offlined` tinyint(4) NOT NULL COMMENT '交易方式 （0-线上 1-线下 2-线上线下均可）',
`status` tinyint(4) NOT NULL COMMENT '宝贝状态 （0-在线 1-售出 -1 用户删除 -2 用户下架 -3 小二下架 -4 小二删除 -5 从未上架 -9 cc -98 历史库宝贝）',
`contacter` varchar(40) DEFAULT NULL COMMENT '联系人',
`phone` varchar(20) DEFAULT NULL COMMENT '联系电话',
`other_con` varchar(50) DEFAULT NULL COMMENT '其他联系方式',
`first_modified` datetime DEFAULT NULL COMMENT '宝贝当天的第一次编辑时间',
`gmt_create` datetime NOT NULL COMMENT '宝贝创建时间',
`gmt_modified` datetime NOT NULL COMMENT '宝贝修改时间',
`nick` varchar(32) DEFAULT NULL COMMENT '用户昵称',
`title` varchar(256) DEFAULT NULL COMMENT '宝贝标题',
`pict_url` varchar(256) DEFAULT NULL COMMENT '主图路径',
`reserve_price` decimal(14,2) DEFAULT '0.00' COMMENT '商品价格',
`category` bigint(20) DEFAULT NULL,
`prov` varchar(20) DEFAULT NULL COMMENT '宝贝所在省',
`city` varchar(30) DEFAULT NULL COMMENT '宝贝所在市',
`desc_path` varchar(128) DEFAULT NULL COMMENT '描述路径',
`auction_type` varchar(1) DEFAULT NULL COMMENT '宝贝类型 （a-拍卖 b-一口价）',
`sold_quantity` int(11) DEFAULT '0' COMMENT '销售量',
`item_from` varchar(100) DEFAULT NULL COMMENT '发布来源',
`gps` varchar(40) DEFAULT NULL COMMENT '地图定位：纬度，经度',
`pose_price` decimal(14,2) DEFAULT NULL COMMENT '运费',
`original_price` decimal(14,2) DEFAULT '0.00' COMMENT '商品原价',
`order_trade_id` bigint(20) DEFAULT NULL COMMENT '交易id',
`chop_pic` varchar(256) DEFAULT NULL COMMENT '宝贝主图：正方形主图',
`attributes` varchar(1000) DEFAULT NULL COMMENT '业务系统自定义的属性，（key:value格式）',
`property` varchar(2048) DEFAULT NULL,
`grade` double DEFAULT NULL COMMENT '宝贝信息完善度的评分',
`spu_id` bigint(20) DEFAULT NULL COMMENT '商品spu_id',
`image_varchar(1024)s` varchar(128) DEFAULT NULL COMMENT '图文描述地址',
`video_url` varchar(256) DEFAULT NULL COMMENT '视频地址',
`user_modified` datetime DEFAULT NULL COMMENT '用户擦亮时间戳',
PRIMARY KEY (`id`),
UNIQUE KEY `UK_IDLE_AUCTIONS_EXTRA_IID` (`item_id`),
KEY `IDX_AUCTIONS_EXTRA_CATEGORY` (`category`,`gmt_create`,`status`),
KEY `IDX_AUCTIONS_EXTRA_GMTCREATE` (`gmt_create`,`status`),
KEY `IND_AUCTIONS_EXTRA_STATUS` (`status`,`gmt_modified`),
KEY `IND_AUCTIONS_EXTRA_USERID` (`user_id`,`gmt_create`),
KEY `IND_IDLE_AUCTIONS_EXTRA_OTID` (`order_trade_id`,`status`),
KEY `idx_auctions_extra_usg` (`user_id`,`status`,`gmt_create`),
KEY `IND_GMT_STATUS` (`gmt_modified`,`status`,`item_id`),
KEY `idx_st_gc` (`status`,`gmt_create`),
KEY `ind_userid_itemfrom` (`user_id`,`item_from`),
KEY `ind_user_modified` (`user_modified`)
)  AUTO_INCREMENT=216046019 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置宝贝信息表';
CREATE TABLE if not exists `idle_auctions_extra_foractivity` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`item_id` bigint(20) unsigned NOT NULL COMMENT '宝贝数字id',
`user_id` bigint(20) unsigned NOT NULL COMMENT '卖家数字id（索引）',
PRIMARY KEY (`id`),
KEY `idx_itemid_userid` (`item_id`,`user_id`)
)  AUTO_INCREMENT=2006284 ,DEFAULT CHARSET=utf8 ,COMMENT='闲鱼商品表活动数据抽取表（从idle_auctions_extra表中抽取商品，odps回流进来）';
CREATE TABLE if not exists `idle_auctions_extra_partner` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`taobao_user_id` bigint(20) NOT NULL COMMENT '淘宝卖家id',
`partner_type_id` bigint(20) NOT NULL COMMENT '合作伙伴类型，按位运算，新浪微博为2的0次方=1',
`partner_user_id` bigint(20) DEFAULT NULL COMMENT '合作伙伴的用户id',
`partner_user_nick` varchar(32) DEFAULT NULL COMMENT '合作伙伴的用户昵称',
`partner_user_sex` bigint(20) DEFAULT NULL COMMENT '合作伙伴的用户性别，1为男，2为女，3为未知',
`partner_user_auth` bigint(20) DEFAULT NULL COMMENT '合作伙伴的认证信息，1为新浪微博加v，2为新浪微博达人',
`partner_user_auth_detail` varchar(100) DEFAULT NULL COMMENT '合作伙伴的认证详细描述信息',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`partner_status` bigint(20) NOT NULL COMMENT '该记录状态，1为正常，0为不正常',
PRIMARY KEY (`id`),
KEY `idx_extra_partner_tui` (`taobao_user_id`)
)  AUTO_INCREMENT=10358 ,DEFAULT CHARSET=utf8 ,COMMENT='发布宝贝的合作伙伴用户信息';
CREATE TABLE if not exists `idle_auctions_for_dump` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`item_id` bigint(20) unsigned NOT NULL COMMENT '商品Id',
`title` varchar(100) DEFAULT NULL COMMENT '商品标题',
`price` bigint(20) DEFAULT NULL COMMENT '转让价',
`original_price` bigint(20) DEFAULT NULL COMMENT '原价',
`discount` int(11) DEFAULT NULL COMMENT '折扣，75表示7.5折',
`stuff_status` int(11) DEFAULT NULL COMMENT '10 全新 9 非全新',
`pict_url` varchar(100) DEFAULT NULL COMMENT '主图链接',
`chop_url` varchar(100) DEFAULT NULL COMMENT '方图链接',
`pic_measure` varchar(20) DEFAULT NULL COMMENT '图片尺寸',
`has_picurl` int(11) DEFAULT NULL COMMENT '是否有图 0 无 1 有',
`cat_id` bigint(20) unsigned DEFAULT NULL COMMENT '后台类目',
`front_cat_id` varchar(100) DEFAULT NULL COMMENT '前台类目',
`prov` varchar(10) DEFAULT NULL COMMENT '宝贝所在地 省份',
`city` varchar(20) DEFAULT NULL COMMENT '城市',
`area` varchar(30) DEFAULT NULL COMMENT '区县',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '卖家id',
`user_nick` varchar(30) DEFAULT NULL COMMENT '卖家nick',
`has_phone` int(11) DEFAULT NULL COMMENT '是否有联系电话',
`offline` int(11) DEFAULT NULL COMMENT '0:仅见面交易；1:在线交易；2:二者均可',
`first_modified` bigint(20) unsigned DEFAULT NULL COMMENT '当天第一次编辑时间',
`scan` int(11) DEFAULT NULL COMMENT '流览量',
`collect` int(11) DEFAULT NULL COMMENT '收藏数',
`comment` int(11) DEFAULT NULL COMMENT '留言数',
`heat` int(11) DEFAULT NULL COMMENT '宝贝热度',
`item_desc` varchar(150) DEFAULT NULL COMMENT '宝贝描述',
`has_desc` int(11) DEFAULT NULL COMMENT '是否有描述',
`auction_type` varchar(1) DEFAULT NULL COMMENT '商品类型，拍卖:a 一口价:b',
`auction_from` varchar(10) DEFAULT NULL COMMENT '发布来源',
`auction_tag` varchar(100) DEFAULT NULL COMMENT '商品标签',
`bq_tag` int(11) DEFAULT NULL COMMENT '商品排序分值',
`position` varchar(40) DEFAULT NULL COMMENT 'gps',
`total_cnt` int(11) DEFAULT NULL COMMENT '拍卖宝贝的出价数',
`ends` bigint(20) unsigned DEFAULT NULL COMMENT '结束时间',
`properties` varchar(1024) DEFAULT NULL COMMENT '属性',
`seller_types` varchar(100) DEFAULT NULL COMMENT '卖家类型',
`user_score` int(11) DEFAULT NULL COMMENT '另一排序值',
`has_video` int(11) DEFAULT NULL COMMENT '是否有语音',
`video_url` varchar(100) DEFAULT NULL COMMENT '语音地址',
`vlen` int(11) DEFAULT NULL COMMENT '语音长度',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '最后修改时间',
`sell_status` int(11) DEFAULT NULL COMMENT '0 在线 1 已售出 2 下架',
`fishpool_id` bigint(20) unsigned DEFAULT NULL COMMENT '鱼塘id',
`fishpool_topitem` tinyint(4) DEFAULT NULL COMMENT '鱼塘中是否置顶商品1否，99是',
`theme_tab_id` bigint(20) unsigned DEFAULT NULL COMMENT '主题id',
`theme_tab_date` bigint(20) unsigned DEFAULT NULL COMMENT '在主题中上线日期',
`theme_tab_top` tinyint(4) DEFAULT NULL COMMENT '是否主题中顶置',
PRIMARY KEY (`id`),
KEY `index_item_id` (`item_id`),
KEY `index_sell_status` (`sell_status`,`gmt_modified`)
)  AUTO_INCREMENT=63120927 ,DEFAULT CHARSET=utf8 ,COMMENT='二手商品宽表，仅用于搜索dump';
CREATE TABLE if not exists `idle_auctions_grade` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
