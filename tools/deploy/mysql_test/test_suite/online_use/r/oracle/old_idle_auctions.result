`imei_daily` bigint(20) unsigned NOT NULL COMMENT '每日设备访问数量',
`imei_sum` bigint(20) unsigned NOT NULL COMMENT '累计设备访问数量',
`fish_pool_id` bigint(20) unsigned NOT NULL COMMENT '对应鱼塘id',
