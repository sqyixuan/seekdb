`idle_last_long_date` datetime DEFAULT NULL COMMENT '用户上次登录时间',
`idle_login_imei` varchar(40) DEFAULT NULL COMMENT '用户登录设备imei号',
`attributes` varchar(500) DEFAULT NULL COMMENT '属性，扩展用',
`options` bigint(20) unsigned DEFAULT NULL COMMENT '用户权限',
`f_seller_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的评价数',
`f_buyer_feed_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的评价数',
`f_seller_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自卖家的“好”评数',
`f_buyer_good_num` bigint(20) unsigned DEFAULT '0' COMMENT '来自买家的“好”评数',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_uniq_userid` (`user_id`),
KEY `idx_userid_status` (`user_id`,`idle_status`),
KEY `idx_usernick_status` (`idle_nick`,`idle_status`)
)  AUTO_INCREMENT=59548 ,DEFAULT CHARSET=utf8 ,COMMENT='二手用户表';
CREATE TABLE if not exists `idle_user_count` (
`user_id` bigint(20) unsigned NOT NULL COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`info` varchar(500) DEFAULT NULL COMMENT '记录标记信息',
PRIMARY KEY (`user_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='用于客户端引导页计数的表';
CREATE TABLE if not exists `idle_user_credit_info` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) NOT NULL COMMENT '用户id',
`score` double NOT NULL DEFAULT '0' COMMENT '闲置卖家信用总分',
`ref_score` double NOT NULL DEFAULT '0' COMMENT '用户作为买家急速退款分数',
`buyer_star_name` varchar(111) DEFAULT NULL COMMENT '买家星级',
`seller_star_name` varchar(111) DEFAULT NULL COMMENT '卖家星级',
`vip_level` int(11) DEFAULT NULL COMMENT 'vip等级',
`attributes` varchar(1000) DEFAULT NULL,
`gmt_create` datetime DEFAULT NULL COMMENT '记录创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '记录最后修改时间',
`nick` varchar(50) DEFAULT NULL COMMENT '昵称',
PRIMARY KEY (`id`),
UNIQUE KEY `idx_credit_info_user_id` (`user_id`),
KEY `idx_credit_info_uid` (`user_id`)
)  AUTO_INCREMENT=5152360 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置卖家信息评分信息';
CREATE TABLE if not exists `idle_user_earn_fee` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
`nick` varchar(32) NOT NULL COMMENT '用户nick',
`fee` decimal(14,0) NOT NULL COMMENT '在闲置市场卖出多少价值商品(分)',
PRIMARY KEY (`id`),
UNIQUE KEY `unique_user_id` (`user_id`)
)  AUTO_INCREMENT=536957238 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置交易额汇总表';
CREATE TABLE if not exists `idle_user_feed_detail` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`feed_id` bigint(20) unsigned NOT NULL COMMENT '评论ID',
`rated_uid` bigint(20) unsigned NOT NULL COMMENT '被评论者数字ID，如果rater_type=0，则表示卖家数字id',
`rated_user_nick` varchar(32) NOT NULL COMMENT '被评论者昵称',
`rater_uid` bigint(20) unsigned NOT NULL COMMENT '评论者数字ID，如果rater_type=0，则表示买家数字id',
`rater_user_nick` varchar(32) NOT NULL COMMENT '评论者昵称',
`rater_type` tinyint(4) NOT NULL COMMENT '评论者交易角色 1：评论者是卖家 0：评论者是买家',
`status` tinyint(4) DEFAULT NULL COMMENT '业务数据状态：0正常 1删除 2单向挂起或未生效 3 48小时挂起 4删除后恢复  5炒一罚二只删不罚 6炒一罚二删除并罚两分 7广告评价(fengxiao.xb)',
`validscore` bigint(20) unsigned DEFAULT NULL COMMENT '评价的计分状态：1：计分；0：不计分，平衡一个月内不超过4分',
`rate` bigint(20) unsigned DEFAULT NULL COMMENT '评价结果：1好评 0默认',
`trade_id` bigint(20) unsigned DEFAULT NULL COMMENT '交易子订单id，-1表示无订单',
`parent_trade_id` bigint(20) unsigned DEFAULT NULL COMMENT '交易父订单ID，-1表示无订单',
`item_id` bigint(20) unsigned DEFAULT NULL COMMENT '商品数字ID',
`attributes` varchar(2000) DEFAULT NULL COMMENT 'key-value的形式存放记录的信息',
PRIMARY KEY (`id`),
UNIQUE KEY `unique_feedid` (`feed_id`),
KEY `index_rateinfo` (`rated_uid`,`rater_uid`,`validscore`,`parent_trade_id`,`gmt_create`)
)  AUTO_INCREMENT=9436613 ,DEFAULT CHARSET=utf8 ,COMMENT='评价闲置子表';
CREATE TABLE if not exists `idle_user_search_info` (
`user_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '卖家id',
`item_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '在线的宝贝数量',
`category_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '在线宝贝涉及的叶子类目数',
`reserve_price` double NOT NULL DEFAULT '0' COMMENT '在线宝贝涉及总金额',
`max_phone_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '联系手机最多关联卖家数',
`min_phone_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '联系手机最小关联卖家数',
`id_card_number_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '同一身份证管理的帐号数',
`comment_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内评价数',
`comment_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内评价的涉及用户数',
`comment_item_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内评价的涉及的商品数',
`collect_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内收藏量',
`collect_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内收藏的涉及用户数',
`collect_item_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内收藏的涉及的商品数',
`share_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内分享数',
`share_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内分享的涉及用户数',
`share_item_count` bigint(20) NOT NULL COMMENT '30天内分享的涉及的商品数',
`create_order_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内创建的订单数',
`pay_order_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内付款订单数',
`pay_buyer_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内支付涉及的买家数',
`pay_auction_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内付款涉及的宝贝',
`pay_fee` double NOT NULL DEFAULT '0' COMMENT '30天内付款总金额',
`pay_category_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内付款涉及的类目数',
`order_onday_end_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内同一天完成的交易量',
`refund_order_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内退款订单数',
`refund_user_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内退款涉及买家数',
`refund_auction_count` bigint(20) NOT NULL DEFAULT '0' COMMENT '30天内退款宝贝数',
`refund_fee` double NOT NULL DEFAULT '0' COMMENT '30天内退款金额',
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增',
`gmt_create` date DEFAULT NULL COMMENT '日期',
PRIMARY KEY (`id`),
KEY `index_user_id` (`user_id`)
)  AUTO_INCREMENT=3833798 ,DEFAULT CHARSET=utf8 ,COMMENT='30天内退款金额';
