`prom_id2` bigint(20) DEFAULT NULL COMMENT '9折以上优惠id',
`discount2` bigint(20) DEFAULT NULL COMMENT '9折以上折扣率',
`discount_price2` bigint(20) DEFAULT NULL COMMENT '9折以上折扣价',
`start_time` datetime DEFAULT NULL COMMENT '开始时间',
`end_time` datetime DEFAULT NULL COMMENT '结束时间',
`gmt_create` datetime NOT NULL COMMENT '记录最后创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`group_id1` bigint(20) DEFAULT NULL COMMENT '0-7折group_id',
`group_id2` bigint(20) DEFAULT NULL COMMENT '9折以上group_id',
PRIMARY KEY (`id`),
KEY `idx_gid1_st` (`group_id1`,`start_time`),
KEY `idx_pid1_st` (`prom_id1`,`start_time`),
KEY `idx_gid_dc1` (`group_id1`,`discount1`),
KEY `idx_gid_dc2` (`group_id2`,`discount2`)
)  AUTO_INCREMENT=23234741173 ,DEFAULT CHARSET=utf8 ,COMMENT='闲置参与以旧换新的促销商品信息';
