`seller_order_detail_count` bigint(20) DEFAULT NULL,
`seller_auction_fee` bigint(20) DEFAULT NULL,
`seller_confirm_paid_fee` bigint(20) DEFAULT NULL,
`order_max_fee` bigint(20) DEFAULT NULL,
`refund_count` int(11) DEFAULT NULL,
`city_trade_count` int(11) DEFAULT NULL,
`day_off_count` int(11) DEFAULT NULL,
`tsp_count` int(11) DEFAULT NULL,
`phone_used_num` int(11) DEFAULT NULL,
`score` double DEFAULT NULL COMMENT '急速退款得分',
`gmt_date` datetime NOT NULL COMMENT '入库时间',
`online_item` int(11) DEFAULT NULL COMMENT '在线商品数',
`threeday_ship` int(11) DEFAULT NULL COMMENT '3日内发货商品',
`cc_user` bigint(20) DEFAULT NULL COMMENT '被cc的用户',
`attributes` varchar(1000) DEFAULT NULL COMMENT '冗余字段'
)  DEFAULT CHARSET=utf8;
