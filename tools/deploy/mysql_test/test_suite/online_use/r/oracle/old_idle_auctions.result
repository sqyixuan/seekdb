)  DEFAULT CHARSET=utf8 ,COMMENT='需要迁移的认证数据';
CREATE TABLE if not exists `vote_record` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`vote_id` bigint(20) unsigned NOT NULL COMMENT '投票者ID',
`voted_id` bigint(20) unsigned NOT NULL COMMENT '被投票者ID',
`status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '支持or反对  1-支持 -1 反对',
`vote_type` int(11) NOT NULL DEFAULT '0' COMMENT '根据当前活动而设定 1- 贩二',
PRIMARY KEY (`id`),
KEY `uniquekey` (`vote_id`,`voted_id`,`vote_type`)
)  AUTO_INCREMENT=5735 ,DEFAULT CHARSET=utf8 ,COMMENT='投票记录';
CREATE TABLE if not exists `vote_result` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`voted_user_id` bigint(20) unsigned DEFAULT '0' COMMENT '被投票所属用户',
`voted_id` bigint(20) unsigned NOT NULL COMMENT '被投票ID',
`vote_type` int(11) NOT NULL DEFAULT '0' COMMENT '投票类型 1 - 贩二',
`support_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '支持数',
`unsupport_num` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '反对数',
`feature` varchar(520) DEFAULT NULL COMMENT '冗余字段',
`status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '状态  -1 无效',
PRIMARY KEY (`id`),
KEY `orderbyid` (`gmt_create`,`voted_user_id`),
KEY `uniquekey` (`voted_id`,`vote_type`)
)  DEFAULT CHARSET=utf8 ,COMMENT='投票结果';
