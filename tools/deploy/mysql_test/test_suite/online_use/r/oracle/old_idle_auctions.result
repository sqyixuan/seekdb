CREATE TABLE if not exists `recycle_search_keyword` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`category` bigint(20) unsigned NOT NULL COMMENT '类目',
`keyword` varchar(100) NOT NULL COMMENT '搜索词',
`count` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '搜索词出现次数',
PRIMARY KEY (`id`),
KEY `cate` (`category`),
KEY `count` (`count`)
)  DEFAULT CHARSET=utf8 ,COMMENT='数码回收热门搜索词';
CREATE TABLE if not exists `recycler_funds` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
`buyer_id` bigint(20) unsigned NOT NULL COMMENT '回收商id',
`buyer_nick` varchar(256) NOT NULL COMMENT '回收商昵称',
`max_fee` double NOT NULL COMMENT '日流动资金最大值',
`min_fee` double NOT NULL COMMENT '日流动资金最小值',
`avg_fee` double NOT NULL COMMENT '评价日流动资金',
PRIMARY KEY (`id`),
KEY `idx_buyer_id` (`buyer_id`)
)  AUTO_INCREMENT=18939616 ,DEFAULT CHARSET=utf8 ,COMMENT='回收商的日流动资金';
CREATE TABLE if not exists `recycler_hour_pay_rate` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
`buyer_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '回收商id',
`buyer_nick` varchar(256) NOT NULL COMMENT '回收商昵称',
`hour` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '小时',
`create_order` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '创建订单量',
`create_uv` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '创建Uv',
`pay_order` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '支付订单量',
`pay_uv` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '支付UV',
PRIMARY KEY (`id`),
KEY `idx_buyer_hour` (`buyer_id`,`hour`)
)  AUTO_INCREMENT=2157291970 ,DEFAULT CHARSET=utf8 ,COMMENT='回收商的小时支付率';
CREATE TABLE if not exists `recycler_level` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
`recycler_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '回收商id',
`category_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '类目id',
`value_id` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '品牌id',
`level` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '回收商等级',
`fund_ability` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '回收商资金能力',
`comprehensive_ability` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '回收商综合能力',
PRIMARY KEY (`id`),
KEY `idx_recyid_valueid_cateid` (`recycler_id`,`category_id`,`value_id`)
)  AUTO_INCREMENT=932 ,DEFAULT CHARSET=utf8 ,COMMENT='回收商登记表';
CREATE TABLE if not exists `recycler_recommended_index` (
`recycler_user_nick` varchar(256) DEFAULT NULL COMMENT '回收商昵称',
`recycler_user_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '回收商Id',
`category_name` varchar(256) DEFAULT NULL COMMENT '类目',
`value_data` varchar(256) DEFAULT NULL COMMENT '品牌',
`category_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '类目Id',
`value_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '品牌Id',
`gujia_count` bigint(20) DEFAULT '0' COMMENT '估价次数',
`user_count` bigint(20) DEFAULT '0' COMMENT '估价用户数',
`all_order` bigint(20) DEFAULT '0' COMMENT '订单数',
`all_user` bigint(20) DEFAULT '0' COMMENT '订单用户数',
`all_auction` bigint(20) DEFAULT '0' COMMENT '宝贝数',
`create_fee` double DEFAULT '0' COMMENT '创建交易额',
`discount_order` bigint(20) DEFAULT '0' COMMENT '折扣订单',
`discount_user` bigint(20) DEFAULT '0' COMMENT '折扣用户数',
`discount_pay_order` bigint(20) DEFAULT '0' COMMENT '折扣付款订单',
`discount_pay_user` bigint(20) DEFAULT '0' COMMENT '折扣付款用户',
`adjust_order` bigint(20) DEFAULT '0' COMMENT '修改价格订单',
`adjust_user` bigint(20) DEFAULT '0' COMMENT '修改价格用户',
`adjust_pay_order` bigint(20) DEFAULT '0' COMMENT '修改价格付款订单',
`adjust_pay_user` bigint(20) DEFAULT '0' COMMENT '修改价格付款用户',
`pay_count` bigint(20) DEFAULT '0' COMMENT '付款订单',
`pay_fee` double DEFAULT '0' COMMENT '付款金额',
`day_pay_uv` bigint(20) DEFAULT '0' COMMENT '付款uv',
`success_count` bigint(20) DEFAULT '0' COMMENT '成功订单',
`success_fee` double DEFAULT '0' COMMENT '成功金额',
`success_uv` bigint(20) DEFAULT '0' COMMENT '成功uv',
`day_b_refund_count` bigint(20) DEFAULT '0' COMMENT '部分退款订单',
`b_refund_fee` double DEFAULT '0' COMMENT '部分退款金额',
`b_confirm_fee` double DEFAULT '0' COMMENT '部分确认收货金额',
`b_refund_uv` bigint(20) DEFAULT '0' COMMENT '部分退款uv',
`q_refund_count` bigint(20) DEFAULT '0' COMMENT '全部退款订单',
`q_refund_fee` double DEFAULT '0' COMMENT '全部退款金额',
`q_confirm_fee` double DEFAULT '0' COMMENT '全部确认收货金额',
`q_refund_uv` bigint(20) DEFAULT '0' COMMENT '全部退款uv',
`no_refund_time_cons` double DEFAULT '0' COMMENT '有退款耗时',
`refund_time_cons` double DEFAULT '0' COMMENT '无退款耗时',
`liudong_order` bigint(20) DEFAULT '0' COMMENT '交易中订单量',
`liudong_seller` bigint(20) DEFAULT '0' COMMENT '交易中用户量',
`good_rate` bigint(20) DEFAULT '0' COMMENT '好评量',
`mid_rate` bigint(20) DEFAULT '0' COMMENT '中评量',
`bad_rate` bigint(20) DEFAULT '0' COMMENT '差评量',
`gmt_create` date DEFAULT NULL COMMENT '日期',
`gmt_modified` date DEFAULT NULL COMMENT '日期',
PRIMARY KEY (`recycler_user_id`,`category_id`,`value_id`),
KEY `ind_re_ca` (`recycler_user_id`,`category_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='回收商';
CREATE TABLE if not exists `sc_app_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`market` varchar(30) NOT NULL COMMENT '市场名',
`search_app` varchar(30) NOT NULL COMMENT '搜索应用',
`operator` varchar(30) NOT NULL COMMENT '操作人',
`url` varchar(200) NOT NULL COMMENT 'url',
`preview_url` varchar(200) DEFAULT NULL COMMENT '预览地址',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=4 ,DEFAULT CHARSET=utf8 ,COMMENT='搜索定制化-应用信息表';
CREATE TABLE if not exists `sc_page_info` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
