CREATE TABLE if not exists `sns_fans_0000` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) unsigned NOT NULL,
`fan_id` bigint(20) unsigned NOT NULL COMMENT '我的粉丝的id',
`twoway` tinyint(4) DEFAULT NULL COMMENT '双向好友标识, 1标识是双向好友.空或者0标识非双向好友',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`app_id` bigint(20) unsigned DEFAULT NULL COMMENT '粉丝来源的应用',
`type` int(11) DEFAULT NULL COMMENT '各个appid下的子类型,各业务方自定义',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_user_fan` (`user_id`,`fan_id`),
KEY `ind_fan_user_gmt` (`user_id`,`gmt_create`),
KEY `ind_uid_appid_gmt` (`user_id`,`app_id`,`gmt_create`)
)  AUTO_INCREMENT=4299313 ,DEFAULT CHARSET=utf8 ,COMMENT='我的粉丝表.记录了所有关注我的人. 512张分表';
