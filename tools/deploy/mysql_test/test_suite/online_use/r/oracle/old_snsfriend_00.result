CREATE TABLE if not exists `sns_subscribe_0000` (
`id` int(10) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`user_id` bigint(20) unsigned NOT NULL,
`subscribe_id` bigint(20) unsigned NOT NULL COMMENT '我关注的人的id',
`twoway` tinyint(4) DEFAULT NULL COMMENT '双向好友标识, 1标识双向好友.空或者0标识非双向好友',
`group_ids` varchar(256) DEFAULT NULL COMMENT '我对关注用户的分组,每个组之间用,分隔',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`app_id` bigint(20) unsigned DEFAULT NULL COMMENT '关系来源的应用',
`type` int(11) DEFAULT NULL COMMENT '各个appid下的子类型,各业务方自定义',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_user_sub` (`user_id`,`subscribe_id`),
KEY `idx_uid_gmt_create` (`user_id`,`gmt_create`)
)  AUTO_INCREMENT=3848049 ,DEFAULT CHARSET=utf8 ,COMMENT='我的关注,记录我所关注的人, 512张分表';
