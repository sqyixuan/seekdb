CREATE TABLE if not exists `mshop_follower_order` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`shop_owner_id` bigint(20) NOT NULL COMMENT '微店店主id',
`count` int(11) NOT NULL COMMENT '该微店每天新增加的计数',
`type` tinyint(4) NOT NULL COMMENT '个数累计类型，1表示根据粉丝个数累计',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
PRIMARY KEY (`id`),
KEY `idx_mfo_gcreate` (`gmt_create`)
)  AUTO_INCREMENT=64326 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `mshop_order_filter` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`shop_owner_id` bigint(20) unsigned NOT NULL COMMENT '店主id',
`days` int(11) NOT NULL COMMENT '不展示的天数',
`gmt_processed` datetime NOT NULL COMMENT '记录被修改的时间',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
PRIMARY KEY (`id`),
KEY `idx_mshop_order_filter_spoid` (`shop_owner_id`),
KEY `idx_mshop_order_filter_gmtprocd` (`gmt_processed`)
)  DEFAULT CHARSET=utf8 ,COMMENT='topn用户的过滤表，进入过滤表的用户将不会显示在排行榜中';
CREATE TABLE if not exists `outer_follow_relation_0000` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_create` datetime NOT NULL COMMENT '创建时间',
`gmt_modified` datetime NOT NULL COMMENT '修改时间',
`user_outer_id` varchar(128) NOT NULL COMMENT '分表字段,用户的外站id',
`user_id` bigint(20) unsigned DEFAULT NULL COMMENT '用户的淘宝id,可能为空',
`follow_uid` bigint(20) unsigned DEFAULT NULL COMMENT '关注的人的淘宝id,如果这个用户没有绑定就为空',
`follow_outer_id` varchar(128) NOT NULL COMMENT '关注的人的外站id',
`partner_id` int(11) NOT NULL COMMENT '来源的类型,比如新浪是4',
`login_name` varchar(32) DEFAULT NULL COMMENT '关注的人的外部的登录名,对应新浪个人信息中的screen_name',
`twoway` tinyint(3) unsigned NOT NULL DEFAULT '0' COMMENT '双向的情况,双向为1,否则为0',
`is_delete` tinyint(3) unsigned DEFAULT NULL COMMENT '删除的数据置为1',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_uoid_pid_foid` (`user_outer_id`,`partner_id`,`follow_outer_id`)
)  AUTO_INCREMENT=12473226 ,DEFAULT CHARSET=utf8 ,COMMENT='保存拉取的外站用户所有关注关系1.主动绑定时,拉取2层关注关系.2.和绑定用户发生关注动作时,拉取所有的关注关系';
