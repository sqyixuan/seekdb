`user_id` bigint(20) unsigned NOT NULL COMMENT '用户自己的userId',
`group_id` bigint(20) unsigned NOT NULL COMMENT '组的id,通过seq生成.默认组除外',
`group_name` varchar(32) NOT NULL COMMENT '组的名字',
`group_desc` varchar(64) DEFAULT NULL COMMENT '组的描述',
`group_count` int(10) unsigned NOT NULL COMMENT '组内的人数',
`is_delete` tinyint(4) DEFAULT NULL COMMENT '删除标志位.1标识删除.用户自定义组物理删除.默认组才使用这个标志位',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
`app_id` bigint(20) DEFAULT NULL,
PRIMARY KEY (`id`),
UNIQUE KEY `uk_user_group` (`app_id`,`user_id`,`group_id`)
)  AUTO_INCREMENT=64230 ,DEFAULT CHARSET=utf8 ,COMMENT='用户关注淘字号的分组信息表.记录了默认组以及用户自定义组的信息  512张分表';
