`type` int(11) DEFAULT NULL COMMENT '各个appid下的子类型,各业务方自定义',
PRIMARY KEY (`id`),
UNIQUE KEY `uk_taozihao_fans_userrolefan` (`app_id`,`user_id`,`role_id`,`fan_id`),
