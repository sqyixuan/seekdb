KEY `idx_taozihao_fans_userroleappid` (`user_id`,`role_id`,`app_id`,`gmt_create`)
)  AUTO_INCREMENT=15675753 ,DEFAULT CHARSET=utf8 ,COMMENT='淘字号的粉丝表.记录了所有关注我的人. 512张分表';
