`outer_id` varchar(128) NOT NULL COMMENT 'outer_id变更字段类型为字符串',
`login_name` varchar(128) DEFAULT NULL COMMENT ' ',
`display_name` varchar(128) DEFAULT NULL COMMENT '显示名称',
`display_face` varchar(512) DEFAULT NULL COMMENT '显示头像URL',
`gmt_create` datetime NOT NULL,
`gmt_modified` datetime NOT NULL,
`two_way` tinyint(4) DEFAULT NULL,
`location` varchar(128) DEFAULT NULL,
PRIMARY KEY (`id`),
KEY `idx_outrelation_userid` (`user_id`,`partner_id`,`login_name`),
KEY `index_outer_relation` (`user_id`,`partner_id`,`outer_id`,`two_way`)
)  DEFAULT CHARSET=utf8;
