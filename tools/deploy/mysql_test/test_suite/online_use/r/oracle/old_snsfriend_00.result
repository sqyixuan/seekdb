CREATE TABLE if not exists `tmp_xc` (
`id` int(10) unsigned NOT NULL DEFAULT '0' COMMENT '自增主键',
`user_id` bigint(20) unsigned NOT NULL,
`subscribe_id` bigint(20) unsigned NOT NULL COMMENT '我关注的人的id',
`twoway` tinyint(4) DEFAULT NULL COMMENT '双向好友标识, 1标识双向好友.空或者0标识非双向好友',
`group_ids` varchar(256) DEFAULT NULL COMMENT '我对关注用户的分组,每个组之间用,分隔',
`gmt_create` datetime NOT NULL COMMENT '记录创建时间',
`gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间'
)  DEFAULT CHARSET=utf8;
