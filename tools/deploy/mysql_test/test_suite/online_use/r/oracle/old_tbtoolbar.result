CREATE TABLE if not exists `component` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
`gmt_modified` bigint(20) NOT NULL COMMENT '修改时间',
`name` varchar(32) NOT NULL COMMENT '组件名称',
`cdn_path` varchar(512) DEFAULT NULL COMMENT '组件的js的cdn地址，系统组件有默认的js地址',
`component_type` int(11) NOT NULL DEFAULT '0' COMMENT '组件类型，0系统组件，1场景组件，2用户组件',
`properties` varchar(1024) DEFAULT NULL COMMENT 'key value形式的属性，分号分割',
`status` int(11) DEFAULT '0' COMMENT '状态',
`icon_url` varchar(512) DEFAULT NULL COMMENT '组件icon地址',
`front_type` varchar(32) NOT NULL DEFAULT 'tab' COMMENT '前端用到的组件类型， tab linkcom',
`location` varchar(1024) DEFAULT NULL COMMENT '组件的位置',
PRIMARY KEY (`id`)
)  AUTO_INCREMENT=7 ,DEFAULT CHARSET=utf8 ,COMMENT='淘宝toolbar的组件';
