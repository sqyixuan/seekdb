  `coop2` varchar(128) NOT NULL COMMENT '备选服务商',
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家id',
  `seller_nick` varchar(64) DEFAULT NULL COMMENT '卖家昵称',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_game_coop_select_seller_id` (`seller_id`)
)  AUTO_INCREMENT=33953 ,DEFAULT CHARSET=utf8 ,COMMENT='主备服务商选择（2013.12.23专用）';
