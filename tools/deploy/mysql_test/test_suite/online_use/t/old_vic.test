CREATE TABLE if not exists `game_cooperation_service_zhibiao` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `status` int(11) NOT NULL DEFAULT '1' COMMENT '方便运营控制，默认填写1-正常',
  `coop_id` varchar(16) NOT NULL COMMENT '服务商ID，因为汇总得不到ID，改为服务商nike',
  `game_forest_id` bigint(20) unsigned NOT NULL COMMENT '游戏类目ID',
  `equipment_type` varchar(32) NOT NULL COMMENT '交易类型：游戏币：44791 点卡：28136 装备：27533 账号：3249948 代练：58338 道具：44789 点券：3240975 装备代打：131277252 其他剩余：other',
  `business_mode` int(11) NOT NULL COMMENT '交易方式（1-担保交易， 2-寄售交易）',
  `complaints_rate` int(11) NOT NULL COMMENT '投诉率（精度到百分位，元数据为扩大10000倍，既：23.33% 存储为 2333）投诉率：投诉次数/总交易笔数×100%',
  `success_rate` int(11) NOT NULL COMMENT '成功率（精度到百分位，元数据为扩大10000倍，既：23.33% 存储为 2333）成功率：成功笔数/总交易笔数×100%',
  `delivery_speed` int(11) NOT NULL COMMENT '平均发货速度（整数，如195,小数部分省略）',
  `pay_sum` bigint(20) unsigned NOT NULL COMMENT '总成交笔数（服务商服务笔数）最近30天，支付宝付款笔数',
  PRIMARY KEY (`id`),
  KEY `coop_cat_type_mode_status` (`coop_id`,`game_forest_id`,`equipment_type`,`business_mode`,`status`)
)  AUTO_INCREMENT=20743124 ,DEFAULT CHARSET=utf8 ,COMMENT='4维度服务商指标回流表(30day)';
CREATE TABLE if not exists `game_exchange_info` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `coin_url` varchar(2000) NOT NULL COMMENT '淘金币接口',
  `server_status_url` varchar(2000) NOT NULL COMMENT '服务器状态url',
  `server_user_url` varchar(2000) NOT NULL COMMENT '服务器人数url',
  `rate` int(11) NOT NULL COMMENT '汇率',
  `game_id` bigint(20) unsigned NOT NULL COMMENT '游戏id',
  `private_key` varchar(2000) NOT NULL COMMENT '游戏私钥',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '厂商id',
  `unit` varchar(100) NOT NULL COMMENT '货币单位',
  `item_id` bigint(20) unsigned NOT NULL COMMENT '游戏宝贝id',
  `tjb_num` int(11) DEFAULT '1' COMMENT '淘金币数量：游戏币数量中的淘金币数量',
  `game_num` int(11) DEFAULT '1' COMMENT '淘金币数量：游戏币数量中的游戏币数量',
  PRIMARY KEY (`id`),
  KEY `idx_game_id` (`game_id`)
)  AUTO_INCREMENT=85 ,DEFAULT CHARSET=utf8 ,COMMENT='游戏外部参数表';
CREATE TABLE if not exists `game_partner` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `partner_id` bigint(20) NOT NULL COMMENT '合作方id',
  `partner_name` varchar(50) NOT NULL COMMENT '合作方名称',
  `partner_wangwang` varchar(50) NOT NULL COMMENT '合作方旺旺',
  `partner_url` varchar(500) NOT NULL COMMENT '合作方url',
  `partner_phone` varchar(50) NOT NULL COMMENT '合作方电话',
  `account_verify_url` varchar(500) NOT NULL COMMENT '下单时帐号验证接口地址',
  `transaction_url` varchar(500) NOT NULL COMMENT '付款后交易接口地址',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `offline_notify_url` varchar(500) NOT NULL COMMENT '宝贝下架通知地址',
  `app_key` varchar(512) NOT NULL COMMENT 'top appkey',
  `game_id` bigint(20) NOT NULL COMMENT '游戏id',
  `status` bigint(20) NOT NULL COMMENT '状态,0正常,1中止',
  `validthru` datetime NOT NULL COMMENT '合同到期时间,只显示不做控制',
  `sign_key` varchar(32) NOT NULL COMMENT '对称密钥（用于签名时使用）',
  PRIMARY KEY (`id`),
  KEY `idx_game_partner_partid` (`partner_id`,`game_id`),
  KEY `idx_game_partner_appkey` (`app_key`),
  KEY `idx_game_partner_gameid` (`game_id`)
)  AUTO_INCREMENT=6 ,DEFAULT CHARSET=utf8 ,COMMENT='网游平台官方合作信息';
CREATE TABLE if not exists `game_partner_log` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `partner_id` bigint(20) NOT NULL,
  `operator` varchar(32) NOT NULL,
  `operator_ip` varchar(15) NOT NULL,
  `content` varchar(4000) NOT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_game_partner_partid` (`partner_id`,`id`) USING BTREE,
  KEY `idx_game_partner_oper` (`operator`,`id`) USING BTREE,
  KEY `idx_game_partner_ip` (`operator_ip`,`id`) USING BTREE
)  AUTO_INCREMENT=22 ,DEFAULT CHARSET=utf8 ,COMMENT='partner修改的日志表';
CREATE TABLE if not exists `game_sell_zhibiao` (
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '主键',
  `pay_sum` bigint(20) unsigned NOT NULL COMMENT '总成交笔数，最近30天，支付宝付款笔数',
  `success_rate` int(11) NOT NULL COMMENT '成功率（精度到百分位，元数据为扩大10000倍，既：23.33% 存储为 2333）成功笔数/总成交笔数×100%',
  `success_sum` bigint(20) unsigned NOT NULL COMMENT '成功笔数，最近30天，订单成功笔数',
  `game_max_sum` varchar(128) DEFAULT NULL COMMENT '最大成交笔数，两笔，按交易量顺序，维度为游戏厂商+游戏。格式为(游戏名称:交易笔数,游戏名称:交易笔数)',
  `game_other_sum` bigint(20) unsigned DEFAULT '0' COMMENT '其他成交笔数，除了上面最大的两笔，剩下的总数。只给出一个汇总值就可以',
  PRIMARY KEY (`seller_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='卖家维度数据指标表(30day)';
CREATE TABLE if not exists `game_tio` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `category_id` bigint(20) unsigned NOT NULL COMMENT '类目id',
  `game_id` bigint(20) unsigned NOT NULL COMMENT '游戏id',
  `game_name` varchar(1024) NOT NULL COMMENT '游戏名称',
  PRIMARY KEY (`id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='游戏装备账号金币交易关联表，即以前的GT2类目，升级之后新名称叫TIO（two in one)二合一，简单好记。';
CREATE TABLE if not exists `game_tjb_order_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `user_name` varchar(64) NOT NULL COMMENT '用户名称',
  `tjb` int(11) NOT NULL COMMENT '兑换使用的淘金币数量',
  `game_money` int(11) NOT NULL COMMENT '可以兑换成的游戏币数目',
  `game_id` bigint(20) unsigned NOT NULL COMMENT '游戏id ，这里是游戏品牌id',
  `game_name` varchar(64) DEFAULT NULL COMMENT '游戏名称',
  `rate` int(10) unsigned NOT NULL COMMENT '兑换汇率，淘金币：游戏币',
  `status` int(11) NOT NULL COMMENT '兑换状态',
  `reason` varchar(32) DEFAULT NULL COMMENT '失败原因',
  `out_order_id` bigint(20) unsigned NOT NULL COMMENT '生成订单id',
  `section1` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '游戏区服id',
  `section2` bigint(20) unsigned DEFAULT NULL COMMENT '游戏二级区服',
  PRIMARY KEY (`id`),
  UNIQUE KEY `idx_out_order_id_uid` (`out_order_id`,`user_id`),
  KEY `k_stat_uid` (`status`,`user_id`),
  KEY `k_stat_gmtc` (`status`,`gmt_create`)
)  AUTO_INCREMENT=168135 ,DEFAULT CHARSET=utf8 ,COMMENT='网游双十二淘金币兑换信息存放';
