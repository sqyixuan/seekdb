CREATE TABLE if not exists `gp_card` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `name` varchar(64) NOT NULL COMMENT '卡片名（最多30个字符）',
  `service_area` bigint(20) NOT NULL COMMENT '卡关联区服（单选）（淘宝一区、淘宝二区…）',
  `content` varchar(512) NOT NULL COMMENT '卡包内容（最多200个字符）',
  `card_usage` varchar(512) NOT NULL COMMENT '卡使用方法（最多200个字符）',
  `picture` varchar(128) NOT NULL COMMENT '卡图片',
  `valid_begin` datetime NOT NULL COMMENT '卡使用有效期（起）',
  `valid_end` datetime NOT NULL COMMENT '卡使用有效期（止）',
  `begin_time` datetime NOT NULL COMMENT '卡发放时间（起）',
  `end_time` datetime NOT NULL COMMENT '卡发放时间（止）',
  `biz_type` tinyint(4) NOT NULL COMMENT '关联业务方（小二后台、页游、礼包卡…）',
  `rec_mode` tinyint(4) NOT NULL COMMENT '领取方式（多张、一张）',
  `card_use` tinyint(4) NOT NULL COMMENT '卡用途',
  `amount` bigint(20) NOT NULL COMMENT '卡数量（总数）',
  `amount_already` bigint(20) NOT NULL COMMENT '已领取数量（已经被领取的数量）',
  `status` tinyint(4) NOT NULL COMMENT '卡状态（审核中、审核通过、未开始、领取中、已领光、已结束，正在创建卡密）',
  `card_code` varchar(32) NOT NULL COMMENT '卡号',
  `biz_id` bigint(20) NOT NULL COMMENT '关联业务方定义的标识',
  PRIMARY KEY (`id`),
  KEY `query_list_idx` (`begin_time`,`end_time`,`biz_type`,`biz_id`,`service_area`),
  KEY `status_createtime_idx` (`status`,`gmt_create`),
  KEY `biztype_idx` (`biz_type`)
)  AUTO_INCREMENT=2002 ,DEFAULT CHARSET=utf8 ,COMMENT='卡信息主表';
CREATE TABLE if not exists `gp_card_file` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `card_id` bigint(20) NOT NULL COMMENT '卡表主键',
  `file_error` varchar(128) NOT NULL COMMENT '文件路径',
  `file_url` varchar(128) NOT NULL COMMENT '文件链接',
  `user_id` bigint(20) NOT NULL COMMENT '上传文件人',
  `status` tinyint(4) NOT NULL COMMENT '1-待处理  2-正在处理 3-已处理',
  `amount` bigint(20) NOT NULL COMMENT '总数量',
  `amount_error` bigint(20) NOT NULL COMMENT '失败数量',
  `file_name` varchar(64) NOT NULL COMMENT '文件名（和card_id的组合必须唯一否则会创建失败）',
  PRIMARY KEY (`id`),
  KEY `status_idx` (`status`),
  KEY `cardid_idx` (`card_id`)
)  AUTO_INCREMENT=2109 ,DEFAULT CHARSET=utf8 ,COMMENT='卡密文件列表';
CREATE TABLE if not exists `gp_card_secret_0000` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `card_id` bigint(20) NOT NULL COMMENT '分表字段(卡标识)',
  `biz_type` tinyint(4) NOT NULL COMMENT '参考卡表的相同字段',
  `service_area` bigint(20) NOT NULL COMMENT '参考卡表的相同字段',
  `secret_key` varchar(128) NOT NULL COMMENT '卡密码',
  `card_code` varchar(64) NOT NULL COMMENT '卡号',
  `apply_user` bigint(20) NOT NULL COMMENT '领取人',
  `status` tinyint(4) NOT NULL COMMENT '状态（待领取、已领取）',
  PRIMARY KEY (`id`),
  UNIQUE KEY `secret_cardid_idx` (`card_id`,`secret_key`),
  KEY `status_cardid_idx` (`status`,`card_id`),
  KEY `applyuser_card_id_idx` (`apply_user`,`card_id`)
)  AUTO_INCREMENT=417702 ,DEFAULT CHARSET=utf8 ,COMMENT='冗余了卡表的几个字段，只要考虑到未来可能根据限制某个业务限制是否可以被某些人使用（使用次数以及是否有权利使用）；';
