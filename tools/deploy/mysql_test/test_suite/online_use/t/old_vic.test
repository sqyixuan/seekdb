#**CREATE**/
CREATE TABLE if not exists `auction_game_0000` (
  `id` bigint(20) NOT NULL,
  `auction_id` bigint(20) NOT NULL,
  `trade_time` varchar(100) DEFAULT NULL COMMENT '方便交易时间，以 - 分隔',
  `freeze_id` bigint(20) DEFAULT NULL COMMENT '诚信赔付押金表id号',
  `status` tinyint(4) NOT NULL,
  `game_name` bigint(20) DEFAULT NULL COMMENT '游戏名',
  `game_area` bigint(20) DEFAULT NULL COMMENT '游戏区域',
  `game_server` bigint(20) DEFAULT NULL COMMENT '游戏服务器',
  `game_camp` bigint(20) DEFAULT NULL COMMENT '游戏阵营',
  `game_type` bigint(20) DEFAULT NULL COMMENT '物品类型(3249948表示账号; 44791表示游戏币)',
  `post` int(11) NOT NULL COMMENT '是否支持邮寄',
  `user_id` bigint(20) NOT NULL,
  `features` varchar(4000) DEFAULT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `security_grade` smallint(6) DEFAULT NULL COMMENT '安全等级',
  `freezeid_account` bigint(20) DEFAULT NULL COMMENT '增值服务freezeId',
  `msg_for_check` varchar(2000) DEFAULT NULL COMMENT '猎宝审核结果',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_game_auctionid` (`auction_id`) USING BTREE
)  DEFAULT CHARSET=utf8;
