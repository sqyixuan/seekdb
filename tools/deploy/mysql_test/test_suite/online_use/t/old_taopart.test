  `push_end_time` int(10) unsigned NOT NULL DEFAULT '79200' COMMENT '接收push的结束时间，秒，默认22*60*60',
  `status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '用户状态，0=正常，-1=失效',
  PRIMARY KEY (`id`),
  UNIQUE KEY `user_nick_index` (`user_nick`),
  UNIQUE KEY `user_id_index` (`user_id`)
)  AUTO_INCREMENT=210916 ,DEFAULT CHARSET=utf8 ,COMMENT='淘伴用户表';
