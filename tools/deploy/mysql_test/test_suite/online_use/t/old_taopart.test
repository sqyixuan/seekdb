CREATE TABLE if not exists `tb_user_logistics_0076` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家ID，用于查物流',
  `trade_id` bigint(20) unsigned NOT NULL COMMENT '交易ID，用于查物流',
  `mail_no` varchar(32) NOT NULL COMMENT '运单号，用于显示',
  `company_name` varchar(64) NOT NULL COMMENT '物流公司名',
  `item_img` varchar(256) NOT NULL COMMENT '宝贝图片，只取一个宝贝的主图。tfs相对路径。',
  `item_name` varchar(256) NOT NULL COMMENT '宝贝名，只取一个宝贝',
  `gmt_last_read_time` datetime NOT NULL COMMENT '用户上一次读取该记录的时间。初始值是记录的创建时间。',
  `last_read_step_count` tinyint(4) NOT NULL DEFAULT '0' COMMENT '用户上次读取该记录时，读到的物流流转数',
  `now_step_count` tinyint(4) NOT NULL COMMENT '该订单的物流流转总数。该字段减去last_read_step_count就是未读流转数。',
  `transit_step_list` varchar(4096) NOT NULL COMMENT '详细物流流转数据，json格式',
  `status` tinyint(4) NOT NULL COMMENT '1=已发货；2=运输中；3=派件中；4=已收货',
  `gmt_update_time` datetime NOT NULL COMMENT '物流信息被更新的时间，是我们的服务端更新这条记录的时间。用户读取时不要更新。',
  `gmt_last_logistics_time` datetime NOT NULL COMMENT '最近一次流转发生的时间。解析transitStepList可以获取这个字段。但因为要排序，所以单独拿出来当做一个字段。',
  PRIMARY KEY (`id`),
  UNIQUE KEY `trade_id_index` (`trade_id`),
  KEY `idx_userid_status` (`user_id`,`status`)
)  AUTO_INCREMENT=1938629 ,DEFAULT CHARSET=utf8 ,COMMENT='记录用户的物流信息';
