--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc 
#owner group:sql3
#tags:online_use 
#description:this case is use for test online use of ob1.0 

#***  10.181.77.191:3306/taopart**/
#**CREATE**/

set ob_query_timeout = 500000000;
set ob_trx_timeout = 500000000;
set global recyclebin = 'off';
--disable_warnings
DROP DATABASE if EXISTS old_taopart;
--enable_warnings
CREATE DATABASE old_taopart;
USE old_taopart;

CREATE TABLE if not exists `buyershow` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `like_count` int(11) DEFAULT '0' COMMENT '喜欢数',
  `dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数',
  `show_count` int(11) DEFAULT '0' COMMENT '展示数',
  `path` varchar(1024) DEFAULT NULL COMMENT '图片地址',
  `feed_id` varchar(64) DEFAULT NULL COMMENT 's_feed_item_receive.feed_id 评论主键Id',
  `rated_uid` varchar(64) DEFAULT NULL COMMENT '卖家数字id（被评论者数字ID）',
  `rated_user_nick` varchar(64) DEFAULT NULL COMMENT '卖家昵称（被评论者昵称）',
  `rater_uid` varchar(64) DEFAULT NULL COMMENT '买家id（评论者数字ID',
  `rater_user_nick` varchar(64) DEFAULT NULL COMMENT '买家昵称（评论者昵称）',
  `trade_id` varchar(64) DEFAULT NULL COMMENT '交易子订单id，-1表示无订单',
  `parent_trade_id` varchar(64) DEFAULT NULL COMMENT '交易父订单ID，-1表示无订单',
  `gmt_trade_create` varchar(64) DEFAULT NULL COMMENT '交易创建时间',
  `gmt_trade_finished` varchar(64) DEFAULT NULL COMMENT '交易完成时间',
  `auc_num_id` varchar(64) DEFAULT NULL COMMENT '商品数字ID （IC的id）',
  `auction_title` varchar(1024) DEFAULT NULL COMMENT '商品标题',
  `auction_pic_url` varchar(512) DEFAULT NULL COMMENT '商品主图地址',
  `auction_price` varchar(64) DEFAULT NULL COMMENT '商品价格',
  `leaf_cat_id` varchar(64) DEFAULT NULL COMMENT '商品叶子类目id',
  `root_cat_id` varchar(64) DEFAULT NULL COMMENT '商品一级类目id（女装=16）',
  `spu_id` varchar(64) DEFAULT NULL COMMENT '商品对应spuId',
  `feedback` varchar(2048) DEFAULT NULL COMMENT '评论内容. 140610近45天线上最长757',
  `feedback_length` varchar(16) DEFAULT NULL COMMENT '评论内容长度',
  `source` varchar(16) DEFAULT NULL COMMENT '如果是biz_type=评价，以位标记形式标明来源，第1位-集市；第2位-天猫；第3位-外部；',
  `properties` varchar(1024) DEFAULT NULL COMMENT '评论中的个性化的垂直属性，以key:value保存，分号分隔，默认为Null. 线上最长138',
  `anony` varchar(4) DEFAULT NULL COMMENT '是否匿名评价',
  `vote_useful` varchar(4) DEFAULT NULL COMMENT '有用、赞、顶的通用计数',
  `rater_star` varchar(16) DEFAULT NULL COMMENT '评论者星级',
  `attributes` varchar(1024) DEFAULT NULL COMMENT '评论的备用字段。超好用的字段。很多杂七杂八的信息这里都有。',
  `feedback_ip` varchar(32) DEFAULT NULL COMMENT '评论者ip',
  `category_level1_name` varchar(512) DEFAULT NULL COMMENT '一级类目名字',
  `category_level2_name` varchar(512) DEFAULT NULL COMMENT '二级类目名字',
  `category_leaf_name` varchar(512) DEFAULT NULL COMMENT '叶子类目名字',
  `auction_status` varchar(16) DEFAULT NULL COMMENT '宝贝状态 0=正常，1=删除后正常，&lt;0 下架状态',
  `shop_url` varchar(512) DEFAULT NULL COMMENT '店铺URL',
  `is_prepay` varchar(16) DEFAULT NULL COMMENT '是否加入消保',
  `seller_good_rate` varchar(128) DEFAULT NULL COMMENT '店铺好评率 不知道为什么String类型',
  `dsr_merchandise` double DEFAULT NULL COMMENT 'dsr商品描述',
  `dsr_service` double DEFAULT NULL COMMENT 'dsr服务',
  `dsr_consignment` double DEFAULT NULL COMMENT 'dsr发货速度',
  `dsr_logistics_service` double DEFAULT NULL COMMENT 'dsr物流服务（不常用）',
  PRIMARY KEY (`id`)
)  AUTO_INCREMENT=40057232 ,DEFAULT CHARSET=utf8 ,COMMENT='买家秀主表（只有最近n天的数据）';
CREATE TABLE if not exists `buyershow_daily_sync` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `like_count` int(11) DEFAULT '0' COMMENT '喜欢数',
  `dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数',
  `show_count` int(11) DEFAULT '0' COMMENT '展示数',
  `path` varchar(1024) DEFAULT NULL COMMENT '图片地址',
  `feed_id` varchar(64) DEFAULT NULL COMMENT 's_feed_item_receive.feed_id 评论主键Id',
  `rated_uid` varchar(64) DEFAULT NULL COMMENT '卖家数字id（被评论者数字ID）',
  `rated_user_nick` varchar(64) DEFAULT NULL COMMENT '卖家昵称（被评论者昵称）',
  `rater_uid` varchar(64) DEFAULT NULL COMMENT '买家id（评论者数字ID',
  `rater_user_nick` varchar(64) DEFAULT NULL COMMENT '买家昵称（评论者昵称）',
  `trade_id` varchar(64) DEFAULT NULL COMMENT '交易子订单id，-1表示无订单',
  `parent_trade_id` varchar(64) DEFAULT NULL COMMENT '交易父订单ID，-1表示无订单',
  `gmt_trade_create` varchar(64) DEFAULT NULL COMMENT '交易创建时间',
  `gmt_trade_finished` varchar(64) DEFAULT NULL COMMENT '交易完成时间',
  `auc_num_id` varchar(64) DEFAULT NULL COMMENT '商品数字ID （IC的id）',
  `auction_title` varchar(1024) DEFAULT NULL COMMENT '商品标题',
  `auction_pic_url` varchar(512) DEFAULT NULL COMMENT '商品主图地址',
  `auction_price` varchar(64) DEFAULT NULL COMMENT '商品价格',
  `leaf_cat_id` varchar(64) DEFAULT NULL COMMENT '商品叶子类目id',
  `root_cat_id` varchar(64) DEFAULT NULL COMMENT '商品一级类目id（女装=16）',
  `spu_id` varchar(64) DEFAULT NULL COMMENT '商品对应spuId',
  `feedback` varchar(2048) DEFAULT NULL COMMENT '评论内容. 140610近45天线上最长757',
  `feedback_length` varchar(16) DEFAULT NULL COMMENT '评论内容长度',
  `source` varchar(16) DEFAULT NULL COMMENT '如果是biz_type=评价，以位标记形式标明来源，第1位-集市；第2位-天猫；第3位-外部；',
  `properties` varchar(1024) DEFAULT NULL COMMENT '评论中的个性化的垂直属性，以key:value保存，分号分隔，默认为Null. 线上最长138',
  `anony` varchar(4) DEFAULT NULL COMMENT '是否匿名评价',
  `vote_useful` varchar(4) DEFAULT NULL COMMENT '有用、赞、顶的通用计数',
  `rater_star` varchar(16) DEFAULT NULL COMMENT '评论者星级',
  `attributes` varchar(1024) DEFAULT NULL COMMENT '评论的备用字段。超好用的字段。很多杂七杂八的信息这里都有。',
  `feedback_ip` varchar(32) DEFAULT NULL COMMENT '评论者ip',
  `category_level1_name` varchar(512) DEFAULT NULL COMMENT '一级类目名字',
  `category_level2_name` varchar(512) DEFAULT NULL COMMENT '二级类目名字',
  `category_leaf_name` varchar(512) DEFAULT NULL COMMENT '叶子类目名字',
  `auction_status` varchar(16) DEFAULT NULL COMMENT '宝贝状态 0=正常，1=删除后正常，&lt;0 下架状态',
  `shop_url` varchar(512) DEFAULT NULL COMMENT '店铺URL',
  `is_prepay` varchar(16) DEFAULT NULL COMMENT '是否加入消保',
  `seller_good_rate` varchar(128) DEFAULT NULL COMMENT '店铺好评率 不知道为什么String类型',
  `dsr_merchandise` double DEFAULT NULL COMMENT 'dsr商品描述',
  `dsr_service` double DEFAULT NULL COMMENT 'dsr服务',
  `dsr_consignment` double DEFAULT NULL COMMENT 'dsr发货速度',
  `dsr_logistics_service` double DEFAULT NULL COMMENT 'dsr物流服务（不常用）',
  `isprocessed` varchar(4) DEFAULT 'n' COMMENT 'sync任务是否处理过',
  PRIMARY KEY (`id`)
)  AUTO_INCREMENT=40057238 ,DEFAULT CHARSET=utf8 ,COMMENT='每日同步表。每天会truncate。每天上午10点，通过datax把云梯上hive跑的带图评论结果拉回来暂存这里。';
CREATE TABLE if not exists `buyershow_task_log` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `type` varchar(128) DEFAULT NULL COMMENT '日志消息类型',
  `status` varchar(16) DEFAULT NULL COMMENT '状态。start 、 finish',
  `msg` varchar(1024) DEFAULT NULL COMMENT '文本消息',
  `has_exception` varchar(16) DEFAULT NULL COMMENT '是否出现异常',
  `exception_detail` varchar(2048) DEFAULT NULL COMMENT '异常明细',
  PRIMARY KEY (`id`)
)  AUTO_INCREMENT=1523 ,DEFAULT CHARSET=utf8 ,COMMENT='买家秀任务日志表';
CREATE TABLE if not exists `dedicate` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `target_id` bigint(20) unsigned NOT NULL COMMENT 'id',
  `type` varchar(100) NOT NULL COMMENT '类型',
  `count` int(11) NOT NULL COMMENT '献花次数',
  `sum` bigint(20) unsigned NOT NULL COMMENT '被献花总数',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '用户id',
  PRIMARY KEY (`id`),
  KEY `typeandid` (`target_id`,`type`),
  KEY `modify` (`gmt_modified`)
)  DEFAULT CHARSET=utf8 ,COMMENT='献花统计表';
CREATE TABLE if not exists `taobeauty` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `like_count` int(11) DEFAULT '0' COMMENT '喜欢数',
  `dislike_count` int(11) DEFAULT '0' COMMENT '不喜欢数',
  `show_count` int(11) DEFAULT '0' COMMENT '展示数',
  `pic_id` bigint(20) unsigned DEFAULT NULL COMMENT '淘女郎图片ID',
  `user_id` bigint(20) unsigned DEFAULT NULL COMMENT '淘女郎的userId',
  `path` varchar(256) DEFAULT NULL COMMENT '图片tfs地址',
  `is_deleted` varchar(4) DEFAULT 'n' COMMENT '是否已经被删除',
  PRIMARY KEY (`id`),
  KEY `pic_id_index` (`pic_id`)
)  AUTO_INCREMENT=4390380 ,DEFAULT CHARSET=utf8 ,COMMENT='淘女郎';
CREATE TABLE if not exists `taobeauty_sync` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `pic_id` bigint(20) unsigned DEFAULT NULL COMMENT '淘女郎图片ID',
  `user_id` bigint(20) unsigned DEFAULT NULL COMMENT '淘女郎的userId',
  `path` varchar(256) DEFAULT NULL COMMENT '图片tfs地址',
  PRIMARY KEY (`id`),
  KEY `pic_id_index` (`pic_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='淘女郎同步表';
CREATE TABLE if not exists `tb_client_version` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `client_type` tinyint(3) unsigned NOT NULL COMMENT '客户端类型，1=iOS，2=Android',
  `client_version` tinyint(4) NOT NULL COMMENT '客户端内部版本号',
  `client_version_show` varchar(32) NOT NULL COMMENT '客户端显示版本，比如“2.1.0”',
  `is_max_version` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否配置为最新版本，0=否，1=是。默认否，需要手动配置为最新版本。用户检查更新时，根据这个字段来取。如果一个新版本的该字段为0，则用户不会收到版本更新通知。',
  `is_force_version` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否为强制更新版本，0=否，1=是。默认否。',
  `update_msg` varchar(1024) NOT NULL COMMENT '更新时，通知用户的文案',
  PRIMARY KEY (`id`),
  UNIQUE KEY `type_version_show_index` (`client_type`,`client_version_show`),
  UNIQUE KEY `type_version_index` (`client_type`,`client_version`)
)  AUTO_INCREMENT=62 ,DEFAULT CHARSET=utf8 ,COMMENT='记录客户端的版本';
CREATE TABLE if not exists `tb_error_insert_shop_user` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '卖家id',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '订阅店铺的用户的id',
  `error_desc` varchar(4096) DEFAULT NULL COMMENT '发生错误的描述',
  `status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '该错误的处理状态。0=尚未处理，1=已经处理了。',
  PRIMARY KEY (`id`),
  KEY `index_seller_id` (`seller_id`),
  KEY `index_user_id` (`user_id`)
)  AUTO_INCREMENT=64704 ,DEFAULT CHARSET=utf8 ,COMMENT='记录从tb_user_shop_rel导数据到tb_shop_user_rel时，发生错误的记录';
CREATE TABLE if not exists `tb_plugin` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `plugin_id` smallint(5) unsigned NOT NULL COMMENT '主模块id，唯一',
  `name` varchar(256) NOT NULL COMMENT '模块的名字，例如“聚划算,女装”。对于物流，写“物流”即可。',
  `is_fixed` tinyint(3) unsigned NOT NULL COMMENT '是否固定订阅。0=不是固定订阅，可取消；1=固定订阅，不允许取消',
  `status` tinyint(3) unsigned NOT NULL COMMENT '状态码,-1=禁止订阅；0=即将开放订阅；1=可以订阅',
  `weight` tinyint(4) DEFAULT NULL COMMENT '插件权重',
  `subscribe_count` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '订阅该模块的人数',
  `icon` varchar(256) DEFAULT NULL COMMENT '插件对应icon',
  `has_sub_plugin` tinyint(3) unsigned NOT NULL COMMENT '是否有子插件',
  `description` varchar(1024) DEFAULT NULL COMMENT '描述',
  `h5_page_url` varchar(256) DEFAULT NULL COMMENT 'h5页面的url',
  `ext_pro` varchar(1024) DEFAULT NULL COMMENT '扩展属性',
  `dis_img_andriod` varchar(256) DEFAULT NULL COMMENT '安卓下的组件宣传图片',
  `dis_img_ios` varchar(256) DEFAULT NULL COMMENT 'IOS下的组件宣传图片',
  `banner_img` varchar(256) DEFAULT NULL COMMENT '自定义组件的banner图片',
  PRIMARY KEY (`id`),
  UNIQUE KEY `id_index` (`plugin_id`),
  KEY `ind_is_fixed` (`is_fixed`),
  KEY `ind_status` (`status`)
)  AUTO_INCREMENT=26 ,DEFAULT CHARSET=utf8 ,COMMENT='模块表，模块已插件形式，支持用户订阅';
CREATE TABLE if not exists `tb_plugin_rel` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `plugin_id` smallint(5) unsigned NOT NULL COMMENT '主模块id，标识这是‘上新优惠’、‘物流’、‘聚划算’......',
  `sub_plugin_id` smallint(5) unsigned NOT NULL COMMENT '子模块id',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_main_plugin` (`plugin_id`,`sub_plugin_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='主订阅插件表结构';
CREATE TABLE if not exists `tb_shop_info_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `shop_id` bigint(20) unsigned DEFAULT NULL COMMENT '店铺id',
  `shop_name` bigint(20) unsigned DEFAULT NULL COMMENT '店铺名称',
  `subcribe_count` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '订阅数',
  `icon` varchar(200) DEFAULT NULL COMMENT '店铺图标Url',
  `msxf` varchar(10) DEFAULT NULL COMMENT '描述相符',
  `fwtd` varchar(10) DEFAULT NULL COMMENT '服务态度',
  `fhsd` varchar(10) DEFAULT NULL COMMENT '发货速度',
  PRIMARY KEY (`id`),
  UNIQUE KEY `unique_seller_id_index` (`seller_id`)
)  AUTO_INCREMENT=39668 ,DEFAULT CHARSET=utf8 ,COMMENT='淘伴店铺概要信息表';
