CREATE TABLE if not exists `tb_user_client_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `client_type` tinyint(3) unsigned NOT NULL COMMENT '客户端类型，1=iOS，2=Android',
  `client_version` tinyint(4) NOT NULL COMMENT '客户端版本',
  `device_token` varchar(128) DEFAULT NULL COMMENT '设备token',
  `last_active_time` datetime NOT NULL COMMENT '用户最近使用该客户端的时间',
  `last_push_time` datetime DEFAULT NULL COMMENT '最近一次发送push的时间，用户初始化时，这个字段是null',
  `status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '客户端状态，0=正常，-1=失效',
  PRIMARY KEY (`id`),
  UNIQUE KEY `user_client_index` (`user_id`,`client_type`)
)  AUTO_INCREMENT=18224 ,DEFAULT CHARSET=utf8 ,COMMENT='用户的客户端表，如果用户既使用iOS，又使用Android，就会有两条记录';
