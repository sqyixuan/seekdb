CREATE TABLE if not exists `tb_user_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `user_nick` varchar(128) NOT NULL COMMENT '淘宝登陆nick',
  `last_active_time` datetime NOT NULL COMMENT '最近活跃时间',
  `accept_push_type` bigint(20) NOT NULL DEFAULT '7' COMMENT '用户接收的push类型，从低位到高位，每一位表示一种，0=拒绝，1=接收。第一位是淘金币，第二位是上新促销，第三位是物流',
  `push_start_time` int(10) unsigned NOT NULL DEFAULT '28800' COMMENT '接收push的开始时间，秒，默认8*60*60',
  `push_end_time` int(10) unsigned NOT NULL DEFAULT '79200' COMMENT '接收push的结束时间，秒，默认22*60*60',
  `status` tinyint(4) NOT NULL DEFAULT '0' COMMENT '用户状态，0=正常，-1=失效',
  PRIMARY KEY (`id`),
  UNIQUE KEY `user_nick_index` (`user_nick`),
  UNIQUE KEY `user_id_index` (`user_id`)
)  AUTO_INCREMENT=210680 ,DEFAULT CHARSET=utf8 ,COMMENT='淘伴用户表';
