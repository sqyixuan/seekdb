CREATE TABLE if not exists `tb_shop_user_rel_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `seller_id` bigint(20) unsigned NOT NULL COMMENT '分表字段，卖家id',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '订阅店铺的用户的id',
  `shop_id` bigint(20) unsigned NOT NULL COMMENT '店铺id',
  `source` tinyint(4) NOT NULL COMMENT '关注来源。0=默认推荐；1=从淘伴关注；2=从pc端关注',
  `status` tinyint(4) NOT NULL DEFAULT '1' COMMENT '状态码，0=用户取消订阅；1=正常订阅',
  `props` varchar(1024) DEFAULT NULL COMMENT '扩展属性（Json串',
  `last_visitor_time` datetime DEFAULT NULL COMMENT '用户最近访问时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `index_sellerid_userid` (`seller_id`,`user_id`),
  KEY `index_sellerid_status` (`status`,`seller_id`)
)  AUTO_INCREMENT=3072075 ,DEFAULT CHARSET=utf8 ,COMMENT='这是tb_user_shop_rel的反向查询表，可以根据seller_id查询订阅了该店铺的用户';
