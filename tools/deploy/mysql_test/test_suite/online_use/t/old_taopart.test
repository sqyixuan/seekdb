  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `trade_id` bigint(20) unsigned NOT NULL COMMENT '交易订单id',
  `gmt_last_read_time` datetime DEFAULT NULL COMMENT '用户上一次读取该记录的时间',
  `gmt_last_event_time` datetime NOT NULL COMMENT '最新一条快递流转事件的时间',
  `last_read_step_count` int(11) NOT NULL COMMENT '用户上次读取该记录时，读到的物流流转数',
  `now_step_count` int(11) NOT NULL COMMENT '该订单目前的物流流转总数',
  `status` tinyint(4) NOT NULL COMMENT '1=已发货；2=运输中；3=派件中；4=已收货；5=已完成',
  `gmt_update_time` datetime NOT NULL COMMENT '后台任务更新本记录的时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_tid` (`trade_id`),
  KEY `k_tid` (`user_id`)
)  AUTO_INCREMENT=19376 ,DEFAULT CHARSET=utf8 ,COMMENT='淘伴用户的物流状态表';
