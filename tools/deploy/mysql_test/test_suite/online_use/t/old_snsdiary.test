CREATE TABLE if not exists `diary_ids` (
  `id` bigint(20) DEFAULT NULL COMMENT 'id',
  `type` varchar(100) NOT NULL COMMENT '?3¨¤¨¤D¨a',
  `gmt_modified` datetime DEFAULT NULL,
  PRIMARY KEY (`type`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `fa_diary_0000` (
  `id` bigint(20) NOT NULL,
  `feeds_id` bigint(20) NOT NULL,
  `user_id` bigint(20) NOT NULL,
  `user_nick` varchar(32) NOT NULL,
  `status` tinyint(4) NOT NULL,
  `pic_url` varchar(200) DEFAULT NULL,
  `type` tinyint(4) DEFAULT NULL,
  `content` varchar(4000) DEFAULT NULL,
  `audit_status` tinyint(4) DEFAULT NULL,
  `opt_id` bigint(20) DEFAULT NULL,
  `opt_nick` varchar(32) DEFAULT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  `date_1` datetime DEFAULT NULL,
  `publish_type` tinyint(4) NOT NULL DEFAULT '0',
  `property` varchar(2000) DEFAULT NULL,
  `forward_count` int(11) NOT NULL DEFAULT '0',
  `origin_id` bigint(20) DEFAULT NULL,
  `origin_user_id` bigint(20) DEFAULT NULL,
  `origin_user_nick` varchar(32) DEFAULT NULL,
  `origin_content` varchar(4000) DEFAULT NULL,
  `forward_id` bigint(20) DEFAULT NULL,
  `forward_user_id` bigint(20) DEFAULT NULL,
  `is_deleted` char(1) NOT NULL DEFAULT 'n',
  `origin_type` bigint(20) NOT NULL DEFAULT '12005723',
  PRIMARY KEY (`id`),
  KEY `user_id` (`user_id`,`gmt_create`,`type`),
  KEY `idx_diary_isdeleted` (`is_deleted`,`gmt_create`,`user_id`),
  KEY `idx_diary_gmtmodified` (`gmt_modified`)
)  DEFAULT CHARSET=utf8;
