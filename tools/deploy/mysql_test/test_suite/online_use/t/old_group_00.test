CREATE TABLE if not exists `group_claw_name_value` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL COMMENT '标识符 ',
  `value` varchar(2048) NOT NULL COMMENT '值对象',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  PRIMARY KEY (`id`)
)  AUTO_INCREMENT=347 ,DEFAULT CHARSET=utf8 ,COMMENT='迁移表断点续传表';
CREATE TABLE if not exists `group_group` (
  `id` bigint(20) unsigned NOT NULL,
  `catalog_id` bigint(20) NOT NULL COMMENT '类目id',
  `type` tinyint(4) NOT NULL COMMENT '帮派公开性设置,-1 类目的聚合圈子 0 公开 1 半公开 2 私密',
  `status` tinyint(4) NOT NULL COMMENT '帮派状态：0 正常 1解散',
  `name` varchar(50) NOT NULL COMMENT '帮派名字',
  `logo_url` varchar(200) DEFAULT NULL COMMENT 'Logo链接地址',
  `head_url` varchar(200) DEFAULT NULL COMMENT 'head链接地址',
  `bulletin` varchar(10000) DEFAULT NULL,
  `tag` varchar(50) DEFAULT NULL COMMENT '标签',
  `description` varchar(200) DEFAULT NULL COMMENT '描述',
  `point` int(11) NOT NULL COMMENT '积分',
  `member_count` int(11) NOT NULL COMMENT '成员数',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  `lz_stat_id` bigint(20) DEFAULT NULL,
  `options` bigint(20) DEFAULT '0',
  `ww_group_id` varchar(100) DEFAULT NULL COMMENT '旺旺群号',
  `statistics_date` datetime DEFAULT NULL,
  `recommendable` tinyint(4) DEFAULT NULL COMMENT ' 能否被推荐 0:可以被推荐 1：不能被推荐',
  `hot` int(11) DEFAULT NULL COMMENT '类目下帮派的数量',
  `verify` smallint(6) DEFAULT NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)',
  `operator_id` bigint(20) DEFAULT NULL COMMENT '审核人的id',
  `operator_time` datetime DEFAULT NULL COMMENT '操作时间',
  PRIMARY KEY (`id`),
  KEY `name` (`name`),
  KEY `gmt_modified` (`gmt_modified`),
  KEY `catalog_id1` (`catalog_id`,`status`,`hot`,`type`,`id`),
  KEY `statistics_date` (`statistics_date`,`status`,`type`),
  KEY `idx_status` (`status`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `group_group_authentication` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '申请id',
  `group_id` bigint(20) unsigned NOT NULL COMMENT '申请帮派id',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '申请人id',
  `user_nick` varchar(32) NOT NULL COMMENT '申请人昵称',
  `custom_url` varchar(512) DEFAULT NULL COMMENT '业务线链接',
  `custom_name` varchar(60) NOT NULL COMMENT '自定义名称',
  `reason` varchar(512) DEFAULT NULL COMMENT '拒绝原因',
  `description` varchar(512) NOT NULL COMMENT '自定义说明',
  `status` tinyint(4) unsigned NOT NULL COMMENT '申请状态',
  `auth_type` tinyint(4) unsigned NOT NULL COMMENT '申请类型',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `deleted` tinyint(4) unsigned NOT NULL COMMENT '是否删除',
  `number_1` bigint(20) unsigned DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_group_group_auth_gid` (`group_id`,`auth_type`),
  KEY `idx_group_group_authentication_sta` (`status`,`auth_type`,`deleted`,`gmt_create`),
  KEY `idx_group_group_authentication_unick` (`user_nick`,`gmt_create`)
)  AUTO_INCREMENT=3161011 ,DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `group_group_blacklist_0000` (
  `id` bigint(20) NOT NULL,
  `group_id` bigint(20) NOT NULL,
  `user_id` bigint(20) NOT NULL,
  `user_nick` varchar(32) NOT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `group_id` (`group_id`,`user_id`,`gmt_create`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `group_group_blacklist_0001` (
  `id` bigint(20) NOT NULL,
  `group_id` bigint(20) NOT NULL,
  `user_id` bigint(20) NOT NULL,
