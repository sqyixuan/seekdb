CREATE TABLE if not exists `group_activity_user_0000` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT,
  `thread_id` bigint(20) NOT NULL,
  `user_id` bigint(20) NOT NULL,
  `group_id` bigint(20) DEFAULT NULL,
  `user_nick` varchar(32) DEFAULT NULL,
  `phone_num` varchar(20) DEFAULT NULL COMMENT '电话号码',
  `status` tinyint(4) unsigned NOT NULL COMMENT '1.已参加（直接参加或者审核已通过）n2.拒绝(审核没通过)n3.退出（用户主动退出活动，或者取消报名）n',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `idx_group_act_utid` (`user_id`,`thread_id`) USING BTREE,
  KEY `idx_group_act_tgsid` (`thread_id`,`gmt_modified`,`status`) USING BTREE
)  AUTO_INCREMENT=182113 ,DEFAULT CHARSET=utf8;
