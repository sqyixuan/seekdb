  `deleted` tinyint(4) NOT NULL COMMENT '0 正常  1 删除',
  `author_id` bigint(20) NOT NULL COMMENT '作者id',
  `author_nick` varchar(32) NOT NULL COMMENT '作者nick',
  `author_ip` varchar(16) NOT NULL COMMENT '作者ip',
  `content` varchar(1024) NOT NULL COMMENT '恢复内容',
  `last_modified` datetime DEFAULT NULL COMMENT '帖子最后修改',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `reply` varchar(256) DEFAULT NULL COMMENT '小二回复',
  `floor` int(11) NOT NULL DEFAULT '0',
  `reply_time` datetime DEFAULT NULL COMMENT '小二回复时间',
  `verify` smallint(6) DEFAULT NULL COMMENT '审核状态(Null 无审核、0C级别待审核、1D级别待审核、2通过、3删除)',
  `operator_id` bigint(20) DEFAULT NULL COMMENT '审核人的id',
  `operator_time` datetime DEFAULT NULL COMMENT '操作时间',
  `rated_respect` int(11) DEFAULT NULL COMMENT '被评价的分数',
  `options` bigint(20) DEFAULT NULL,
  `content_flag` tinyint(3) unsigned DEFAULT NULL COMMENT '区分是content_ext存放的是帖子内容还是帖子内容对应的TFS的KEY',
  `content_ext` varchar(1000) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  `number_2` bigint(20) DEFAULT NULL,
  `number_3` bigint(20) DEFAULT NULL,
  `sticky` tinyint(4) DEFAULT '0' COMMENT '0 普通 1 置顶(默认值是0)',
  `sticky_author_id` bigint(20) DEFAULT NULL COMMENT '回复顶置者ID',
  `sticky_author_nick` varchar(32) DEFAULT NULL COMMENT '回复顶置者nick',
  `sticky_time` datetime DEFAULT NULL COMMENT '回复顶置时间',
  PRIMARY KEY (`id`),
  KEY `IDX_group_reply_modified` (`gmt_modified`),
  KEY `thread_id` (`thread_id`,`gmt_create`,`floor`,`author_id`,`deleted`),
  KEY `author_id` (`author_id`,`thread_id`,`deleted`,`gmt_create`),
  KEY `idx_tid_sticky_delete_time` (`thread_id`,`sticky`,`deleted`,`sticky_time`)
)  DEFAULT CHARSET=utf8;
