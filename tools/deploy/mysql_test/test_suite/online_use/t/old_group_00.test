)  DEFAULT CHARSET=utf8 ,COMMENT='帖子内容与图片对应关系表';
CREATE TABLE if not exists `group_thread_pic_0001` (
  `pic_id` bigint(20) NOT NULL COMMENT '从相册传递过来的图片id，PK',
