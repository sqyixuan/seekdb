#***  10.181.157.93:3706/group_00**/
#**CREATE**/
CREATE TABLE if not exists `group_activity_0000` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `thread_id` bigint(20) NOT NULL,
  `group_id` bigint(20) NOT NULL,
  `start_time` datetime NOT NULL COMMENT '活动开始时间',
  `end_time` datetime NOT NULL COMMENT '活动截止时间',
  `toplimit` int(11) NOT NULL COMMENT '活动人数上限',
  `tag` varchar(100) DEFAULT NULL COMMENT '活动的标签',
  `options` bigint(20) unsigned NOT NULL COMMENT '第1位：仅本帮成员可以参加
第2位：仅实名认证用户可以参加
第3位：参加报名需要提供电话
',
  `logo_url` varchar(200) DEFAULT NULL COMMENT '活动logo url',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `activity_type` smallint(6) NOT NULL COMMENT '3 促销打折 
4 店铺买家秀
5 商品团购 
6 免费试用 
7线下聚会 
8 同城交友 
9 团队建设
',
  `expense` int(10) unsigned DEFAULT NULL COMMENT '每人花费的费用。转换成分存储',
  `joined_user_count` int(11) NOT NULL COMMENT '已经加入活动人数',
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_group_act_tid` (`thread_id`,`joined_user_count`,`toplimit`) USING BTREE,
  KEY `idx_gmt_create` (`gmt_create`)
)  AUTO_INCREMENT=23019 ,DEFAULT CHARSET=utf8;
