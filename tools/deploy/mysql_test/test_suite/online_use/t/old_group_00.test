  `subject` varchar(50) NOT NULL COMMENT '帖子标题',
  `type` tinyint(4) NOT NULL COMMENT '0 普通 1 置顶',
  `status` tinyint(4) NOT NULL COMMENT '0 普通  1 主贴锁定  2 主题锁定',
  `digest` tinyint(4) NOT NULL COMMENT '0 普通 1 精华',
  `options` bigint(20) NOT NULL,
  `deleted` tinyint(4) NOT NULL COMMENT '0 正常  1 删除',
  `view_count` int(11) NOT NULL COMMENT '浏览数',
  `reply_count` int(11) NOT NULL COMMENT '回答数',
  `author_id` bigint(20) NOT NULL COMMENT '作者id',
  `author_nick` varchar(32) NOT NULL COMMENT '作者nick',
  `author_ip` varchar(16) NOT NULL COMMENT '作者ip',
