CREATE TABLE if not exists `group_vote_choice_0000` (
  `id` bigint(20) NOT NULL,
  `thread_id` bigint(20) NOT NULL COMMENT '帖子Id',
  `description` varchar(60) DEFAULT NULL COMMENT '选项文字说明',
  `link_url` varchar(1024) DEFAULT NULL COMMENT '选项的链接地址',
  `image_url` varchar(200) DEFAULT NULL COMMENT '图片链接中图片的地址 ',
  `vote_count` int(11) NOT NULL COMMENT '票数',
  `status` tinyint(4) NOT NULL COMMENT '０正常　１删除',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `num_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `thread_id` (`thread_id`,`status`)
)  DEFAULT CHARSET=utf8;
