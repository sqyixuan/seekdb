CREATE TABLE if not exists `group_catalog` (
  `id` bigint(20) unsigned NOT NULL,
  `channel_id` bigint(20) NOT NULL,
  `name` varchar(50) NOT NULL,
  `official` tinyint(4) NOT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `options` bigint(20) DEFAULT NULL COMMENT '标记位。第一位如果是：0：在聚合页面显示，１在聚合页面不显示',
  `char_1` varchar(256) DEFAULT NULL,
  `group_id` bigint(20) DEFAULT NULL,
  `weight` int(11) DEFAULT NULL COMMENT '类目的权限',
  `catalog_type` tinyint(4) DEFAULT NULL,
  `group_count` int(11) DEFAULT NULL,
  `deleted` tinyint(4) DEFAULT NULL COMMENT '删除标识位；0：正常，1：已删除',
  PRIMARY KEY (`id`),
  KEY `name` (`name`),
  KEY `channel_id` (`channel_id`),
  KEY `group_id` (`group_id`)
)  DEFAULT CHARSET=utf8;
CREATE TABLE if not exists `group_channel` (
  `id` bigint(20) unsigned NOT NULL,
  `name` varchar(50) NOT NULL,
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `number_1` bigint(20) DEFAULT NULL,
  `char_1` varchar(256) DEFAULT NULL,
  `channel_type` tinyint(4) DEFAULT NULL,
  `weight` int(11) DEFAULT NULL,
  `bg_img` varchar(1024) DEFAULT NULL COMMENT '类目背景图片地址',
  `skin` varchar(50) DEFAULT NULL COMMENT '肤色样式',
  PRIMARY KEY (`id`),
  KEY `name` (`name`)
)  DEFAULT CHARSET=utf8;
