--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc 
#owner group:sql3
#tags:online_use 
#description:this case is use for test online use of ob1.0 
set ob_query_timeout = 500000000;
set ob_trx_timeout = 500000000;
set global recyclebin = 'off';
--disable_warnings
DROP DATABASE if EXISTS old_tbphoto;
--enable_warnings
CREATE DATABASE old_tbphoto;
USE old_tbphoto;

CREATE TABLE if not exists `accounts_0000` (
  `user_id` bigint(20) unsigned NOT NULL COMMENT '主键字段 ',
  `login_id` varchar(45) NOT NULL,
  `last_login_time` bigint(20) unsigned DEFAULT NULL,
  `last_modified_time` bigint(20) unsigned DEFAULT NULL,
  `create_time` bigint(20) unsigned DEFAULT NULL,
  `gmt_create` datetime NOT NULL COMMENT '记录创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '记录最后修改时间',
  PRIMARY KEY (`user_id`),
  KEY `idx_loginid` (`login_id`),
  KEY `idx_gmt_create` (`gmt_create`)
)  DEFAULT CHARSET=utf8;
