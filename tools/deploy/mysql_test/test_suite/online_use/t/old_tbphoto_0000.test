CREATE TABLE if not exists `photos_0000` (
  `pid` bigint(20) unsigned NOT NULL COMMENT '主键字段',
  `id` binary(16) DEFAULT NULL,
  `name` varchar(255) DEFAULT NULL,
  `last_modified_time` bigint(20) unsigned NOT NULL,
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `comments` varchar(4000) DEFAULT NULL,
  `tag` varchar(4000) DEFAULT NULL,
  `picture_type` varchar(45) DEFAULT NULL,
  `display_path` varchar(255) DEFAULT NULL,
  `original_path` varchar(255) DEFAULT NULL,
  `uploaded_time` bigint(20) unsigned DEFAULT NULL,
  `thumbnail_path` varchar(255) DEFAULT NULL,
  `safety_level` tinyint(4) DEFAULT '0',
  `big_thumbnail_path` varchar(255) DEFAULT NULL,
  `poster_path` varchar(255) DEFAULT NULL,
  `fav_count` int(10) unsigned DEFAULT '0',
  `comment_count` int(10) unsigned DEFAULT '0',
  `hit_count` int(10) unsigned DEFAULT '0',
  `attributes` varchar(1000) DEFAULT NULL COMMENT '备用字段',
  `gmt_create` datetime NOT NULL,
  `gmt_modified` datetime NOT NULL,
  `original_length` int(10) unsigned NOT NULL,
  `biz_type` int(11) DEFAULT '0' COMMENT '0：淘相册照片、1：评价照片、2：淘单照片',
  PRIMARY KEY (`pid`),
  KEY `idx_user_id_last_modify` (`user_id`,`last_modified_time`),
  KEY `idx_id` (`id`),
  KEY `idx_gmt_create` (`gmt_create`),
  KEY `idx_user_id` (`user_id`)
)  DEFAULT CHARSET=utf8 ,COMMENT='photos';
