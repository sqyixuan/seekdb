CREATE TABLE if not exists `albums_0000` (
  `aid` bigint(20) unsigned NOT NULL COMMENT '主键字段',
  `id` binary(16) DEFAULT NULL,
  `name` varchar(255) DEFAULT NULL,
  `photo_count` int(10) unsigned DEFAULT '0',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `preface_photo` binary(16) DEFAULT NULL,
  `preface_photo_id` bigint(20) unsigned DEFAULT '0',
  `source_type` int(11) DEFAULT '0',
  `album_size` bigint(20) unsigned DEFAULT '0',
  `safety_level` tinyint(4) DEFAULT '0',
  `description` varchar(255) DEFAULT NULL,
  `viewtype` tinyint(4) NOT NULL DEFAULT '1' COMMENT '之前类型为bit(1)，值为b''1',
  `tag` varchar(500) DEFAULT NULL,
  `hit_count` int(10) unsigned DEFAULT '1',
  `photo_comment_count` int(10) unsigned DEFAULT '0',
  `fav_count` int(10) unsigned DEFAULT '0',
  `last_modified_time` bigint(20) unsigned NOT NULL,
  `create_time` bigint(20) unsigned DEFAULT NULL,
  `attributes` varchar(500) DEFAULT NULL COMMENT '备用字段',
  `gmt_create` datetime NOT NULL COMMENT '记录创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '记录修改时间',
  PRIMARY KEY (`aid`),
  KEY `idx_albums_owner_lmt_ind` (`user_id`,`last_modified_time`),
  KEY `idx_album_id` (`id`),
  KEY `idx_album_preface_photo_id` (`preface_photo_id`),
  KEY `idx_gmt_create` (`gmt_create`),
  KEY `idx_user_id` (`user_id`)
)  DEFAULT CHARSET=utf8;
