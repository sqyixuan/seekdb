CREATE TABLE if not exists `photo_transfer_0000` (
  `tb_photo_id` bigint(20) unsigned NOT NULL COMMENT '淘相册照片id ',
  `source_photo_id` bigint(20) unsigned NOT NULL COMMENT '来源处的照片id ',
  `source_type` int(11) DEFAULT '0' COMMENT '照片来源类型。0表示来源于淘江湖',
  `user_id` bigint(20) unsigned NOT NULL COMMENT '分表字段',
  `gmt_create` datetime NOT NULL COMMENT '记录创建时间',
  PRIMARY KEY (`tb_photo_id`),
  KEY `idx_gmt_create` (`gmt_create`),
  KEY `idx_user_id` (`user_id`),
  KEY `idx_source_type` (`source_type`),
  KEY `idx_source_photo_id` (`source_photo_id`)
)  DEFAULT CHARSET=utf8;
