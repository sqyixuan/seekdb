# owner: cxf262476
# owner group: transaction
# description: basic test for flush table
#
--disable_warnings
drop table if exists flush_table_t,flush_table_tt;
--enable_warnings

--disable_query_log
create table flush_table_t(k int);
create table flush_table_tt(k int);
# 1. FLUSH TABLE GRAMMAR CHECK
--echo "STEP: check before enable mock stmt"
--error 1235
FLUSH TABLE;
--error 1235
FLUSH TABLES;
--error 1235
FLUSH LOCAL TABLE;
--error 1235
FLUSH LOCAL TABLES;
--error 1235
FLUSH NO_WRITE_TO_BINLOG TABLE;
--error 1235
FLUSH NO_WRITE_TO_BINLOG TABLES;
--error 1235
FLUSH TABLE WITH READ LOCK;
--error 1235
FLUSH TABLES WITH READ LOCK;
--error 1235
FLUSH TABLE flush_table_t;
--error 1235
FLUSH TABLES flush_table_t;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt;

--error 1235
FLUSH TABLE flush_table_t WITH READ LOCK;
--error 1235
FLUSH TABLES flush_table_t WITH READ LOCK;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt WITH READ LOCK;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt WITH READ LOCK;

--error 1235
FLUSH TABLE flush_table_t FOR EXPORT;
--error 1235
FLUSH TABLES flush_table_t FOR EXPORT;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt FOR EXPORT;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt FOR EXPORT;

# 2. FLUSH TABLE AFTER SET _enable_mock_stmt_flush_table
--echo "STEP: check after set _enable_mock_stmt_flush_table"
ALTER SYSTEM SET _enable_mock_stmt_flush_table = true;
sleep 3;
FLUSH TABLE;
FLUSH TABLES;
FLUSH LOCAL TABLE;
FLUSH LOCAL TABLES;
FLUSH NO_WRITE_TO_BINLOG TABLE;
FLUSH NO_WRITE_TO_BINLOG TABLES;
FLUSH TABLE WITH READ LOCK;
FLUSH TABLES WITH READ LOCK;
FLUSH TABLE flush_table_t;
FLUSH TABLES flush_table_t;
FLUSH TABLE flush_table_t, flush_table_tt;
FLUSH TABLES flush_table_t, flush_table_tt;

FLUSH TABLE flush_table_t WITH READ LOCK;
FLUSH TABLES flush_table_t WITH READ LOCK;
FLUSH TABLE flush_table_t, flush_table_tt WITH READ LOCK;
FLUSH TABLES flush_table_t, flush_table_tt WITH READ LOCK;

FLUSH TABLE flush_table_t FOR EXPORT;
FLUSH TABLES flush_table_t FOR EXPORT;
FLUSH TABLE flush_table_t, flush_table_tt FOR EXPORT;
FLUSH TABLES flush_table_t, flush_table_tt FOR EXPORT;

# 3. RECHECK
--echo "STEP: check after unset _enable_mock_stmt_flush_table"
ALTER SYSTEM SET _enable_mock_stmt_flush_table = false;
sleep 3;
--error 1235
FLUSH TABLE;
--error 1235
FLUSH TABLES;
--error 1235
FLUSH LOCAL TABLE;
--error 1235
FLUSH LOCAL TABLES;
--error 1235
FLUSH NO_WRITE_TO_BINLOG TABLE;
--error 1235
FLUSH NO_WRITE_TO_BINLOG TABLES;
--error 1235
FLUSH TABLE WITH READ LOCK;
--error 1235
FLUSH TABLES WITH READ LOCK;
--error 1235
FLUSH TABLE flush_table_t;
--error 1235
FLUSH TABLES flush_table_t;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt;

--error 1235
FLUSH TABLE flush_table_t WITH READ LOCK;
--error 1235
FLUSH TABLES flush_table_t WITH READ LOCK;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt WITH READ LOCK;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt WITH READ LOCK;

--error 1235
FLUSH TABLE flush_table_t FOR EXPORT;
--error 1235
FLUSH TABLES flush_table_t FOR EXPORT;
--error 1235
FLUSH TABLE flush_table_t, flush_table_tt FOR EXPORT;
--error 1235
FLUSH TABLES flush_table_t, flush_table_tt FOR EXPORT;

# 4. CLEAN
--echo "STEP: clean"
--disable_warnings
--echo "STEP: drop table"
drop table flush_table_t;
drop table flush_table_tt;
