CREATE FUNCTION factorial(n INT) RETURNS INT
BEGIN
DECLARE i INT;
DECLARE result INT;
SET i = 1;
SET result = 1;
WHILE i <= n DO
SET result = result * i;
SET i = i + 1;
END WHILE;
RETURN result;
END//
