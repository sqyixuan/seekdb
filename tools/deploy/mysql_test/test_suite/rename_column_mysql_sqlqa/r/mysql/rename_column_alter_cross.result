#50980237- 【mysql_rename_column】当删除的约束和索引涉及多列，正交rename涉及到的列为新的列名，约束报4016.索引报1072 (42000): Key column 'col3' doesn't exist
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT);
ALTER TABLE t1 ADD CONSTRAINT my_check3 CHECK (col1+col2> col1+1);
ALTER TABLE t1 drop CONSTRAINT my_check3, rename column col2 to col3,rename column col1 to col5;
#生成列
#作为生成列引用列无法rename
drop table if exists t1;
create table t1(c1 int, c2 int as (c3+1) stored,c3 int , 
c5 int as (c1+1),c4 varchar(200));
alter table t1 RENAME COLUMN c1 to c6;
ERROR HY000: Column 'c1' has a generated column dependency
alter table t1 RENAME COLUMN c3 to c9;
ERROR HY000: Column 'c3' has a generated column dependency
alter table t1 RENAME COLUMN c4 to c12;
alter table t1 RENAME COLUMN c2 to c5,RENAME COLUMN c5 to c2;
alter table t1 RENAME COLUMN c5 to c13,RENAME COLUMN c2 to c14;
desc  t1;
Field	Type	Null	Key	Default	Extra
c1	int(11)	YES		NULL	
c13	int(11)	YES		(`c3` + 1)	STORED GENERATED
c3	int(11)	YES		NULL	
c14	int(11)	YES		(`c1` + 1)	VIRTUAL GENERATED
c12	varchar(200)	YES		NULL	
insert into t1(c1,c12,c3) values(2,1,1);
select * from t1;
c1	c13	c3	c14	c12
2	2	1	3	1
drop table t1;
create table t1(c1 int, c2 int generated always as (c3+1) stored,c3 int , 
c5 int generated always as (concat(c3,c1)),c4 varchar(200),unique index(c2,c5,c1,c3));
alter table t1 RENAME COLUMN c1 to c6;
ERROR HY000: Column 'c1' has a generated column dependency
alter table t1 RENAME COLUMN c3 to c9;
ERROR HY000: Column 'c3' has a generated column dependency
alter table t1 RENAME COLUMN c4 to c12;
alter table t1 RENAME COLUMN c2 to c5,RENAME COLUMN c5 to c2;
alter table t1 RENAME COLUMN c5 to c13,RENAME COLUMN c2 to c14;
desc  t1;
Field	Type	Null	Key	Default	Extra
c1	int(11)	YES		NULL	
c13	int(11)	YES	MUL	(`c3` + 1)	STORED GENERATED
c3	int(11)	YES		NULL	
c14	int(11)	YES		concat(`c3`,`c1`)	VIRTUAL GENERATED
c12	varchar(200)	YES		NULL	
insert into t1(c1,c12,c3) values(2,1,1);
select * from t1;
c1	c13	c3	c14	c12
2	2	1	12	1
#列带有不同可rename属性的循环，包括index和联合index、primary key、复合primary key、unique、default、not null、foreign key、复合外键、auto_increment
drop table if exists t1;
drop table if exists t2;
CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
);
CREATE TABLE   t1(c1 int not null auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 varchar(40) not null default'1',
c5 varchar(300),
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4(10)),unique index (c3),primary key(c1,uid),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
);
insert into t2 values(20220101,1,3);
insert into t1(c1,c2,c5,uid,money) values(1,20220101,3,1,200.321);
