#分区ddl
#50784065- 【mysql_rename_column】ob在rename+PARTITION_ddl场景，ob异常，PARTITION_ddl会默认选中所有分区，对于mysql，语法上禁止rename+PARTITION_ddl场景
drop table if exists t1;
CREATE TABLE t1 (
log_id      bigint NOT NULL 
, log_value varchar(50)
, log_date  timestamp NOT NULL  
) PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
(
PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
, PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
, PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
, PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
, PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
);
insert into t1 values(1,'zz','2020/05/01');
insert into t1 values(1,'zz','2020/01/01');
SELECT * FROM t1 PARTITION (M202001);
log_id	log_value	log_date
1	zz	2020-01-01 00:00:00
SELECT * FROM t1 PARTITION (M202005);
log_id	log_value	log_date
1	zz	2020-05-01 00:00:00
ALTER TABLE t1 truncate PARTITION M202001;
select * from t1;
log_id	log_value	log_date
1	zz	2020-05-01 00:00:00
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id,truncate PARTITION M202001;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'truncate PARTITION M202001' at line 1
select * from t1;
log_id	log_value	log_date
1	zz	2020-05-01 00:00:00
