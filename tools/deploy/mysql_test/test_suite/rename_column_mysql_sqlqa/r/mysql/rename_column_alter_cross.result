#50906375- 【mysql_rename_column】指定列顺序+rename指定列，ob处理不一致
#ob成功，mysql失败
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );
ALTER TABLE `t1`  CHANGE COLUMN `col2` `c2` INT(11) NULL DEFAULT NULL  COMMENT 'renames' AFTER `col1`,rename column col1 to c99;
#ob报错信息缺少列
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );
ALTER TABLE `t1`  CHANGE COLUMN `col1` `c2` INT(11) NULL DEFAULT NULL  COMMENT 'renames' AFTER `col2`,rename column col2 to c99;
#循环+after结果不一致,暂不兼容
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );
ALTER TABLE `t1`  CHANGE COLUMN `c3` `col3` INT(11)  AFTER `col2`,
rename column col1 to col2,rename column col2 to col1;
desc  `t1`;
Field	Type	Null	Key	Default	Extra
col2	int(11)	YES		NULL	
col1	int(11)	YES		NULL	
col3	int(11)	YES		NULL	
