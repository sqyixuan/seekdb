c1	int(11)	NO	PRI	NULL	
c2	int(11)	YES		NULL	
drop table if exists t1;
CREATE TABLE t1(col1 date,col2 INT) 
PARTITION BY RANGE (year(col1))
(PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300)
);
alter table t1 rename column col1 to col2,rename column col2 to col1;
ERROR HY000: Column 'col1' has a partitioning function dependency and cannot be dropped or renamed.
drop table if exists t1;
CREATE TABLE t1 (col1 INT,col2 DATE)
PARTITION BY LIST(col1)
(PARTITION p0 VALUES IN (100),
PARTITION p1 VALUES IN (200)
);
alter table t1 rename column col1 to col1,rename column col2 to col2;
ERROR HY000: Column 'col1' has a partitioning function dependency and cannot be dropped or renamed.
desc  t1;
Field	Type	Null	Key	Default	Extra
col1	int(11)	YES		NULL	
col2	date	YES		NULL	
