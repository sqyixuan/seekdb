#开启 Encoding 并使用 zstd 压缩，宏块保留空间为 5%
drop table if exists t1;
CREATE TABLE t1 (c1 INT, c2 INT, c3 VARCHAR(64))
COMPRESSION 'zstd_1.0'
      ROW_FORMAT DYNAMIC
PCTFREE 5;
alter table t1 rename column c2 to c1,rename column c1 to c3,rename column c3 to c2;
desc  t1;
Field	Type	Null	Key	Default	Extra
c3	int(11)	YES		NULL	
c1	int(11)	YES		NULL	
c2	varchar(64)	YES		NULL	
