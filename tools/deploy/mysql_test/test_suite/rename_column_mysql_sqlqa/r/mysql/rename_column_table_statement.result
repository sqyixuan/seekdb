drop table if exists t1;
Warnings:
Note	1051	Unknown table 'nxa.t1'
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'nxa.t2'
CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
);
CREATE TABLE   t1(c1 int primary key auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 int not null default'1',
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4),unique index (c3),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
);
drop table if exists t1s;
Warnings:
Note	1051	Unknown table 'nxa.t1s'
CREATE TABLE  t1s like t1;
ALTER TABLE t1s  rename column money to uid,rename column uid to money,rename column c1 to c3,rename column c3 to c1;
