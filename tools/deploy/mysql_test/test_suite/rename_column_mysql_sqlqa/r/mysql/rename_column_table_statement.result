SET @b = CONCAT('CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int)');
SET @s = CONCAT('alter table t1 rename column c1_a to ', @colname);
PREPARE stmt1 FROM @a;
PREPARE stmt2 FROM @b;
EXECUTE stmt1;
