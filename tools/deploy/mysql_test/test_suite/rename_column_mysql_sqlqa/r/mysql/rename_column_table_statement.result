#50993220- 【mysql_rename_column】rename分区列为原来相同的列名，ob成功，mysql禁止
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT) PARTITION BY HASH(c1) PARTITIONS 8;
alter table t1 rename column c1 to c1;
ERROR HY000: Column 'c1' has a partitioning function dependency and cannot be dropped or renamed.
