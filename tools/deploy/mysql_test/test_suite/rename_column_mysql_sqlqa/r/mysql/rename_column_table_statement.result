SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
(PARTITION p0 VALUES LESS THAN(0), PARTITION p1 VALUES LESS THAN(100));
alter table t1 rename column c2 to c3,rename column c3 to c2;
ERROR HY000: Column 'c2' has a partitioning function dependency and cannot be dropped or renamed.
#字符集gbk
drop table if exists t1;
