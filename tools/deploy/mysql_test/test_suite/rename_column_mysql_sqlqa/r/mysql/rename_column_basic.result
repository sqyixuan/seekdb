#check约束
#50749392- 【mysql_rename_column】ob通过rename后约束均条件变为`col1` = (`col1` * 2)，无法插入除0以外数据，mysql存在约束时不能修改涉及约束条件的列名。
#修改后均不支持renamecheck相关列
drop table if exists t1;
CREATE TABLE t1 (col1 INT,  col3 INT, CONSTRAINT equal_check1 CHECK(col1 = col3 * 2));
insert into t1 values(2,1);
alter table t1 rename column col1 to col3,rename column col3 to col1;
ERROR HY000: Check constraint 'equal_check1' uses column 'col1', hence column cannot be dropped or renamed.
drop table if exists t1;
CREATE TABLE t1 (col1 INT,  col3 INT, CONSTRAINT equal_check1 CHECK(col1 is not null));
insert into t1 values(2,1);
alter table t1 rename column col3 to col4;
alter table t1 rename column col1 to col5;
ERROR HY000: Check constraint 'equal_check1' uses column 'col1', hence column cannot be dropped or renamed.
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT,CONSTRAINT my_check CHECK (col1> col2+1));
ALTER TABLE t1 rename column col2 to col3,rename column col1 to col4;
ERROR HY000: Check constraint 'my_check' uses column 'col2', hence column cannot be dropped or renamed.
