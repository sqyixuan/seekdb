#owner:zongmei.zzm
#owner group: 技术部-SQL-执行器
#description: obmysql模式, rename_column测试
#tags:ddl
#author: wb-nxa01399802

--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by 'nxa';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,nxa,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;



--echo #alter 语句正交
--echo #alter 表
drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT);
ALTER TABLE t1 ENGINE =oceanbase,rename column col1 to col2,rename column col2 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT);
ALTER TABLE t1 PARALLEL 2,rename column col1 to col2,rename column col2 to col1,PARALLEL 3;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT);
ALTER TABLE t1 ROW_FORMAT = COMPRESSED,rename column col1 to col2,rename column col2 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT);
ALTER TABLE t1 AUTO_INCREMENT = 13,rename column col1 to col2,rename column col2 to col1;
desc  t1;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, 电风扇 INT);
ALTER TABLE t1 CHARACTER SET = gbk,rename column col1 to 晗,rename column 电风扇 to col1;
desc  t1;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT);
ALTER TABLE t1 COMMENT = 'New table comment',rename column col1 to col2,rename column col2 to col1;
desc  t1;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,INDEX (col1));
ALTER TABLE t1 RENAME tr,rename column col1  to col2, RENAME t1,rename column col2 to col1;
desc  t1;


--echo #列alter

--echo #add_column

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,INDEX (col1));
ALTER TABLE t1 RENAME t1,ADD c3 INT,rename column col1  to c4;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,INDEX (col1));
--error 1054
ALTER TABLE t1 RENAME t1,ADD c3 INT,rename column c3 to c555;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,INDEX (col1));
--error 1060
ALTER TABLE t1 RENAME tr,ADD c3 INT,rename column col1  to c3, RENAME t1;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1 ADD COLUMN c4 INTEGER FIRST,rename column c3  to c5;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1 rename column col1 to c3,rename column c3 to col1, ADD COLUMN c9 INTEGER FIRST ;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
--error 1054
ALTER TABLE t1 rename column col1 to c9,rename column c9 to col1, ADD COLUMN c9 INTEGER FIRST ;




drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER col1 , ADD COLUMN c10 INTEGER AFTER col2,ADD COLUMN c11 INTEGER FIRST,rename column col1 to col2,rename column col2 to c3,rename column c3 to col1;
desc  t1;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER col1 , ADD COLUMN c10 INTEGER AFTER col2,ADD COLUMN c11 INTEGER FIRST,
rename column col1 to col2,rename column col2 to c3,rename column c3 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,unique INDEX (col1,col2));
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER col1 , ADD COLUMN c10 INTEGER AFTER col2,ADD COLUMN c11 INTEGER FIRST,
rename column col1 to col2,rename column col2 to c3,rename column c3 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER cr , ADD COLUMN c10 INTEGER AFTER cr,ADD COLUMN c11 INTEGER FIRST,
rename column col1 to col2,rename column col2 to col1,rename column c3 to cr;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER col1 , ADD COLUMN c10 INTEGER AFTER col2,ADD COLUMN c5 INT before col2,rename column col1 to col2,rename column col2 to c3,rename column c3 to col1;
desc  t1;


--echo #drop_column
drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 INT,INDEX (col1));
--error 1091
ALTER TABLE t1 drop c3 ,rename column c3  to c1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 INT,INDEX (col1));
--error 1060
ALTER TABLE t1 drop c3 ,rename column col1  to col2,rename column col2  to c3;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key , col2 INT,c3 INT,INDEX (col2));
--error 1054
ALTER TABLE t1  drop c3 ,drop col2, rename column col1 to c3,rename column col1 to col2;





--echo #MODIFY

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  MODIFY c3 BIGINT(10) primary key AUTO_INCREMENT,rename column col1 to col2,rename column col2 to col1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
--error 1054
ALTER TABLE t1  rename column c3 to c4,MODIFY c4 BIGINT(10) primary key AUTO_INCREMENT;



drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT,c3 int ,INDEX (col1));
--error 1054
ALTER TABLE t1  rename column c3 to c3,MODIFY c3 BIGINT(10) primary key AUTO_INCREMENT;


drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  rename column c3 to col2, rename column col2 to c3,MODIFY col1 BIGINT(10) not null AUTO_INCREMENT;
desc  t1;


--echo #change

--echo #50783665- 【mysql_rename_column】CHANGE COLUMN+primary key，ob报错4016，mysql正常

drop table if exists t1;
CREATE TABLE t1 (col1 INT , col2 INT,c3 int );
ALTER TABLE t1 CHANGE COLUMN col1  c6 VARCHAR(50) primary key;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT , col2 INT,c3 int ,INDEX (col1));
ALTER TABLE t1  rename column c3 to c4,CHANGE COLUMN col1  c6 VARCHAR(50) primary key,rename column col2 to col4;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT , col2 INT,c3 int );
ALTER TABLE t1 CHANGE  col1 c4 BIGINT(10) default 23,rename column col2 to col4;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT , col2 INT,c3 int ,INDEX (col1));
--error 1054
ALTER TABLE t1  rename column c6 to c4,CHANGE COLUMN col1  c6 VARCHAR(50) primary key,rename column col2 to col1;


--echo #50906375- 【mysql_rename_column】指定列顺序+rename指定列，ob处理不一致
--echo #ob成功，mysql失败
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );

ALTER TABLE `t1`  CHANGE COLUMN `col2` `c2` INT(11) NULL DEFAULT NULL  COMMENT 'renames' AFTER `col1`,rename column col1 to c99;


--echo #ob报错信息缺少列
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );

ALTER TABLE `t1`  CHANGE COLUMN `col1` `c2` INT(11) NULL DEFAULT NULL  COMMENT 'renames' AFTER `col2`,rename column col2 to c99;


--echo #循环+after结果不一致,暂不兼容
drop table if exists `t1`;
CREATE TABLE `t1` (`col1` INT , `col2` INT,`c3` int );
ALTER TABLE `t1`  CHANGE COLUMN `c3` `col3` INT(11)  AFTER `col2`,
rename column col1 to col2,rename column col2 to col1;
desc  `t1`;






--echo #change+add+drop(drop的列名可做为rename新列名使用)+MODIFY

--echo #50851954- 【mysql_rename_column】add+drop+rename_col,ob报错4200，mysql成功
drop table if exists t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c5 varchar(50),c3 varchar(50) ,c4 varchar(50) primary key,c8 int, unique INDEX (col1,col2(20),c4(10)));
--error 1060
ALTER TABLE t1 add c5 int,drop c3,rename column c5 to c3;
desc  t1;




drop table if exists t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c3 varchar(50) ,c6 varchar(50) ,c7 int,c4 varchar(50) primary key,c8 int, unique INDEX (col1,col2(20),c4(10)));
--error 1060
ALTER TABLE t1  ADD COLUMN c9 INTEGER AFTER col2 , ADD COLUMN c10 INTEGER AFTER col2,ADD COLUMN c5 INTEGER FIRST,
rename column col1 to col2,rename column col2 to c3,rename column c3 to col1,
drop column c6,change column c8  c8 varchar(50),MODIFY c7 BIGINT(10),rename column c4 to c6;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c3 varchar(50) ,c6 varchar(50) ,c7 int,c4 varchar(50) primary key, unique INDEX (col1,col2(20),c4(10)));
ALTER TABLE t1  rename column col1 to col2,rename column col2 to c3,rename column c3 to col1,change column c4  c4 varchar(50)unique;
desc  t1;



drop table if exists t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c3 varchar(50) ,c6 varchar(50) ,c7 int,c4 varchar(50) primary key, unique INDEX (col1,col2(20),c4(10)));
ALTER TABLE t1  rename column c7 to col2,rename column col2 to c3,rename column c3 to c71,rename column c4 to col1 ,rename column col1 to c6,rename column c6 to c4;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 varchar(50), col2 varchar(50),c3 varchar(50) ,c6 varchar(50) ,c7 int,c4 varchar(50) primary key,c8 int, INDEX (col1,col2(20),c4(10)));
--error 3108
ALTER TABLE t1 drop column c3,drop column c4,drop column c6,drop column c7;



--echo #index
--echo #rename_index
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 varchar(50),c3 int ,INDEX ind1(col2(10)));
ALTER TABLE t1  RENAME INDEX ind1 TO ind2,rename column col1 to c3,rename column c3 to col2,rename column col2 to col1;
desc  t1;
ALTER TABLE t1  RENAME INDEX ind2 TO ind3,rename column col1 to c1,rename column c3 to col3,rename column col2 to c2;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (c1 INT unique, c2 INT, c3 INT);
alter table t1  ADD INDEX ind3 (c2,c3),rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;

--echo #add_index
drop table if exists t1;
CREATE TABLE t1 (c1 INT unique, c2 INT, c3 varchar(50));
--error 1072
alter table t1  ADD INDEX ind3 (c2,c3),rename column c1 to c5,rename column c2 to c6,rename column c3 to c7;



drop table if exists t1;
CREATE TABLE t1 (c1 INT primary key, c2 INT, c3 varchar(300));
alter table t1  ADD INDEX ind3 (c5,c6,c7(10)),rename column c1 to c5,rename column c2 to c6,rename column c3 to c7;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (c1 INT primary key, c2 INT, c3 varchar(300));
alter table t1  ADD INDEX ind3 (c2,c3,c1(1)),rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;

--echo #add fun_INDEX 
--echo #50852202- 【mysql_rename_column】rename+add_func_index(new_col),ob报错，mysql成功
drop table if exists t1;
CREATE TABLE t1 (col1 varchar(200), col2 INT);

ALTER TABLE t1 rename column col1 to col4,add INDEX func_index ((ABS(col4)));



--echo #drop_index

drop table if exists t1;
CREATE TABLE t1 (c1 INT primary key, c2 INT, c3 INT);
alter table t1  ADD INDEX ind3 (c2,c3,c1),rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;

ALTER TABLE t1 DROP INDEX ind3,rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX (col1,col2));
ALTER TABLE t1 rename column col1 to col3,rename column col2 to col4,drop INDEX col1 ;
desc  t1;

--echo #50783699- 【mysql_rename_column】drop index +rename column,ob的rename操作先检测到了index,mysql成功

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1))));
--error 3837
ALTER TABLE t1 drop INDEX func_index,rename column col1 to col3;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1))));
--error 3837
ALTER TABLE t1 rename column col1 to col3,drop INDEX func_index ;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1+col2))));
--error 3837
ALTER TABLE t1 rename column col1 to col2,rename column col2 to col1,drop INDEX func_index ;
desc  t1;

--echo #50980237- 【mysql_rename_column】当删除的约束和索引涉及多列，正交rename涉及到的列为新的列名，约束报4016.索引报1072 (42000): Key column 'col3' doesn't exist
drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1+col2))));

--error 3837
ALTER TABLE t1 rename column col1 to col3,rename column col2 to col4,drop INDEX func_index ;
desc  t1;





--echo #分区ddl
--echo #50784065- 【mysql_rename_column】ob在rename+PARTITION_ddl场景，ob异常，PARTITION_ddl会默认选中所有分区，对于mysql，语法上禁止rename+PARTITION_ddl场景
drop table if exists t1;
CREATE TABLE t1 (
    log_id      bigint NOT NULL 
    , log_value varchar(50)
    , log_date  timestamp NOT NULL  
) PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
(
    PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
    , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
    , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
    , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
    , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
);

insert into t1 values(1,'zz','2020/05/01');
insert into t1 values(1,'zz','2020/01/01');

SELECT * FROM t1 PARTITION (M202001);
SELECT * FROM t1 PARTITION (M202005);

ALTER TABLE t1 truncate PARTITION M202001;
select * from t1;
--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id,truncate PARTITION M202001;
select * from t1;

--echo #drop

drop table if exists t1;
CREATE TABLE t1 (
    log_id      bigint NOT NULL 
    , log_value varchar(50)
    , log_date  timestamp NOT NULL  
) PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
(
    PARTITION M202001 VALUES LESS THAN(UNIX_TIMESTAMP('2020/02/01'))
    , PARTITION M202002 VALUES LESS THAN(UNIX_TIMESTAMP('2020/03/01'))
    , PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
    , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/05/01'))
    , PARTITION M202005 VALUES LESS THAN(UNIX_TIMESTAMP('2020/06/01'))
);

--error 1064
ALTER TABLE t1 rename column log_id to log_value, rename column log_value to log_id,drop PARTITION M202001;
desc  t1;

