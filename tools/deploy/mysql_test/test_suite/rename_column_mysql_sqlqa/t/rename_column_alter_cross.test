--echo #ob不支持REORGANIZE
drop table if exists members;
CREATE TABLE members (
    id INT,
    fname VARCHAR(25),
    lname VARCHAR(25),
    dob DATE
)
PARTITION BY RANGE( YEAR(dob) ) (
    PARTITION p0 VALUES LESS THAN (1980),
    PARTITION p1 VALUES LESS THAN (1990),
    PARTITION p2 VALUES LESS THAN (2000),
	PARTITION p3 VALUES LESS THAN (2010)
);

--error 1235
ALTER TABLE members
    REORGANIZE PARTITION p0 INTO (
        PARTITION n0 VALUES LESS THAN (1970),
        PARTITION n1 VALUES LESS THAN (1980)
);

--echo #COALESCE ob不支持
drop table if exists t1;
CREATE TABLE t1 (
    id INT,
    fname VARCHAR(30),
    lname VARCHAR(30),
    signed DATE
)
PARTITION BY HASH( MONTH(signed) )
PARTITIONS 12;
--error 1064
ALTER TABLE t1 COALESCE PARTITION 4;



--echo #约束ddl

--echo #外键约束
--echo #ob:Add/modify foreign key together with other DDLs not supported
drop table if exists t2;
drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY,c2 INT); 
CREATE TABLE t2(c1 INT PRIMARY KEY,c2 INT);
--error 1235
ALTER TABLE t1 ADD CONSTRAINT fk1 FOREIGN KEY (c2) REFERENCES t2(c1),rename column c1 to c4;



drop table if exists t1;
drop table if exists t2;
CREATE TABLE t1(c1 INT PRIMARY KEY,c2 INT); 
CREATE TABLE t2(c1 INT PRIMARY KEY,c2 INT);
ALTER TABLE t1 ADD CONSTRAINT fk1 FOREIGN KEY (c2) REFERENCES t2(c1);
desc  t1;
ALTER TABLE t1 DROP FOREIGN KEY fk1,rename column c1 to c2,rename column c2 to c1;
desc  t1;

--echo #主键约束,ob不支持一起ddl
--echo #ob:1235 (0A000):  and add primary key in single statment not supported
drop table if exists t1;
CREATE TABLE t1 (c1_a INT , c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
--error 1235
alter table t1  add primary key (c1_a), rename column c3_c to c333_e;



drop table if exists t1;
CREATE TABLE t1 (c1_a INT primary key, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
--error 1235
alter table t1  drop primary key , rename column c3_c to c333_e;




--echo #add_check
--echo #1235 (0A000): Add/modify constraint together with other DDLs not supported
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT);
--error 1235
ALTER TABLE t1 ADD CONSTRAINT my_check1 CHECK (col1> col2),rename column col2 to col1,rename column col1 to col2  ;



drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT,col3 int);
--error 1235
ALTER TABLE t1 ADD CONSTRAINT my_check CHECK (col1> col2),rename column col2 to col5,rename column col1 to col6  ;


drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT,col3 int);
--error 1235
ALTER TABLE t1 ADD CONSTRAINT my_check CHECK (col1> col2),rename column col3 to col5 ;



--echo #drop_check
--echo #50783699- 【mysql_rename_column】drop index/约束 +rename column,ob的rename操作先检测到了index/约束,mysql成功
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT);
ALTER TABLE t1 ADD CONSTRAINT my_check3 CHECK (col1> col2);
ALTER TABLE t1 drop CONSTRAINT my_check3, rename column col2 to col1,rename column col1 to col2;  
desc  t1;

--echo #50980237- 【mysql_rename_column】当删除的约束和索引涉及多列，正交rename涉及到的列为新的列名，约束报4016.索引报1072 (42000): Key column 'col3' doesn't exist
drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT);
ALTER TABLE t1 ADD CONSTRAINT my_check3 CHECK (col1+col2> col1+1);
ALTER TABLE t1 drop CONSTRAINT my_check3, rename column col2 to col3,rename column col1 to col5;  




--echo #生成列
--echo #作为生成列引用列无法rename
drop table if exists t1;
create table t1(c1 int, c2 int as (c3+1) stored,c3 int , 
c5 int as (c1+1),c4 varchar(200)); 
--error 3108
alter table t1 RENAME COLUMN c1 to c6;
--error 3108
alter table t1 RENAME COLUMN c3 to c9;
alter table t1 RENAME COLUMN c4 to c12;
alter table t1 RENAME COLUMN c2 to c5,RENAME COLUMN c5 to c2;
alter table t1 RENAME COLUMN c5 to c13,RENAME COLUMN c2 to c14;
desc  t1;

insert into t1(c1,c12,c3) values(2,1,1);
select * from t1;

drop table t1;
create table t1(c1 int, c2 int generated always as (c3+1) stored,c3 int , 
c5 int generated always as (concat(c3,c1)),c4 varchar(200),unique index(c2,c5,c1,c3)); 
--error 3108
alter table t1 RENAME COLUMN c1 to c6;
--error 3108
alter table t1 RENAME COLUMN c3 to c9;
alter table t1 RENAME COLUMN c4 to c12;
alter table t1 RENAME COLUMN c2 to c5,RENAME COLUMN c5 to c2;
alter table t1 RENAME COLUMN c5 to c13,RENAME COLUMN c2 to c14;
desc  t1;

insert into t1(c1,c12,c3) values(2,1,1);
select * from t1;






--echo #列带有不同可rename属性的循环，包括index和联合index、primary key、复合primary key、unique、default、not null、foreign key、复合外键、auto_increment

drop table if exists t1;
drop table if exists t2;

CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
);

CREATE TABLE   t1(c1 int not null auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 varchar(40) not null default'1',
c5 varchar(300),
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4(10)),unique index (c3),primary key(c1,uid),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
);

insert into t2 values(20220101,1,3);
insert into t1(c1,c2,c5,uid,money) values(1,20220101,3,1,200.321);

--echo #由于rename成功,即是成功执行多次
