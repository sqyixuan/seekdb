CREATE TRIGGER insert_t1
BEFORE  INSERT ON t2
FOR EACH ROW
BEGIN
  INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (3,6,8);
END//

CREATE TRIGGER update_t1
BEFORE  update ON t2
FOR EACH ROW
BEGIN
  update t1 set c2_b = 999 where c2_b=3 ;
END//

CREATE TRIGGER delete_t1
BEFORE  delete ON t2
FOR EACH ROW
