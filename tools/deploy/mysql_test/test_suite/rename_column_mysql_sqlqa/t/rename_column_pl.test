--echo #after_dml

drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT default null, c3_c INT,c5_e VARCHAR(312),c4_d int);
drop table if exists t2;
CREATE TABLE t2 (c1_a INT PRIMARY KEY, c2_b INT default null, c3_c INT,c5_e VARCHAR(312),c4_d int);
INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (5,2,1);
INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (9,3,2);

delimiter //;
--error 1360
drop trigger insert_t1;//
--error 1360
drop trigger update_t1;//
--error 1360
drop trigger delete_t1;//
CREATE TRIGGER insert_t1
after  INSERT ON t2
FOR EACH ROW
BEGIN
  INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (3,6,8);
END//

CREATE TRIGGER update_t1
after  update ON t2
FOR EACH ROW
BEGIN
  update t1 set c2_b = 999 where c2_b=3 ;
END//

CREATE TRIGGER delete_t1
after  delete ON t2
FOR EACH ROW
BEGIN
  delete from t1 where c1_a =5 ;
END//

delimiter ;//
INSERT INTO t2 (c1_a, c2_b, c5_e) VALUES (1,1,1);
update t2 set c1_a =4;
delete from t2 where c1_a=4;
select * from t1;

--echo #循环命名后
INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (5,2,1);
INSERT INTO t1 (c1_a, c2_b, c5_e)VALUES (10,3,2);
alter table t1 rename column c1_a to c2_b, rename column c2_b to c1_a,rename column c5_e to c3_c,rename column c3_c to c5_e;
INSERT INTO t2 (c1_a, c2_b, c5_e) VALUES (1,1,1);
update t2 set c1_a =4;
delete from t2 where c1_a=4;
select * from t1;

--echo #rename新列后，原有触发器涉及的列不存在报错
