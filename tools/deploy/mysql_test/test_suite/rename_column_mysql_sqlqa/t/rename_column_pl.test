--echo #function
--error 1305
drop FUNCTION days_between;
delimiter //;
CREATE FUNCTION days_between(date1 DATE, date2 DATE)
RETURNS INT deterministic
BEGIN
  DECLARE days INT;
  SET days = DATEDIFF(date1, date2);
  RETURN days;
END//


delimiter ;//
drop table if exists t1;
CREATE TABLE t1 (c1_a date PRIMARY KEY, c2_b date default null, c3_c INT,c5_e VARCHAR(312),c4_d int);
insert into t1(c1_a , c2_b) values('20210503','19281212');

select days_between(c1_a,c2_b) from t1;
alter table t1 rename column c1_a TO c2_b,rename column c2_b TO c1_a;
select days_between(c1_a,c2_b) from t1;
alter table t1 rename column c1_a TO c2,rename column c2_b TO c1;
--error 1054
select days_between(c1_a,c2_b) from t1;



delimiter //;
CREATE FUNCTION factorial(n INT) RETURNS INT
BEGIN
  DECLARE i INT;
  DECLARE result INT;
  SET i = 1;
  SET result = 1;
  WHILE i <= n DO
    SET result = result * i;
    SET i = i + 1;
  END WHILE;
  RETURN result;
END//
delimiter ;//
drop table if exists t1;
CREATE TABLE t1 (c1_a date PRIMARY KEY, c2_b date default null, c3_c INT,c5_e VARCHAR(312),c4_d int);
insert into t1(c1_a , c3_c,c4_d) values('20210503',3,6);


select factorial(c3_c) from t1;
alter table t1 rename column c3_c TO c4_d,rename column c4_d TO c3_c;
select factorial(c3_c) from t1;
alter table t1 rename column c3_c TO cd,rename column c4_d TO c3;
--error 1054
select factorial(c3_c) from t1;
select factorial(c3) from t1;



delimiter //;
drop FUNCTION days_between;//
CREATE FUNCTION days_between(date1 DATE, date2 DATE)
RETURNS INT DETERMINISTIC
BEGIN
  DECLARE days INT;
  select  DATEDIFF(date1, c2_b) into days from t1 ;
  RETURN days;
END//

delimiter ;//
drop table if exists t1;
CREATE TABLE t1 (c1_a date PRIMARY KEY, c2_b date default null, c3_c INT,c5_e VARCHAR(312),c4_d int);
insert into t1(c1_a , c2_b) values('20210503','19281212');

select days_between(c1_a,c2_b) from t1;
alter table t1 rename column c1_a TO c2_b,rename column c2_b TO c1_a;
select days_between(c1_a,c2_b) from t1;

alter table t1 drop column c1_a, rename column c5_e TO c2_b,rename column c2_b TO c1_99;
insert into t1(c1_99 , c2_b) values('20210506','19281212');

