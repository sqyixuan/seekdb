--echo #存储过程
drop table if exists t1;
drop table if exists users;
CREATE TABLE `users`
 (
 `ID` BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
 `user_name` VARCHAR(60),
 `user_pass` VARCHAR(64),
 PRIMARY KEY (`ID`)
);


drop table if exists test;
