alter table account rename column amount to acct_num,rename column acct_num to amount;
#alter table account drop column amount,add column acct_num int,rename column acct_num to amount;
SET @sum = 0;
INSERT INTO account VALUES(137,14.98),(141,1937.50),(97,-100.00);
