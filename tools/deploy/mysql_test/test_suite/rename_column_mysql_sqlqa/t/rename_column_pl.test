insert into test(id,c1) values(2,'zzz');

INSERT INTO users VALUES(null,'sheng','sheng123'),
(null,'yu','yu123'),
(null,'ling','ling123');

delimiter //;
--error 1305
drop PROCEDURE pro_users//
CREATE PROCEDURE pro_users()
BEGIN
UPDATE users SET user_name=(select id from test);
alter table test rename column c1 to c4,rename column id to num;
UPDATE users SET user_name=(select id from test);
alter table test rename column c4 to num,rename column num to c4,rename t1;
END //

call pro_users() //
desc  t1;//
SELECT * FROM users //
delimiter ;//
--error 1146
