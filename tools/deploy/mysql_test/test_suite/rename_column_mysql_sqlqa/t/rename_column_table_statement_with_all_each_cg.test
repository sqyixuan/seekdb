#owner:zhuoran.zzr
#owner group: storage.ddl
#description: obmysql模式, rename_column测试
#tags:ddl
#author: zhuoran.zzr

--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by 'nxa';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,nxa,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;


--echo #建表
--echo #create table like

drop table if exists t1;
drop table if exists t2;

CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
) with column group(all columns, each column);

CREATE TABLE   t1(c1 int primary key auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 int not null default'1',
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4),unique index (c3),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
) with column group(all columns, each column);

drop table if exists t1s;
CREATE TABLE  t1s like t1;
ALTER TABLE t1s  rename column money to uid,rename column uid to money,rename column c1 to c3,rename column c3 to c1;  
desc  t1s;
drop table if exists t1a;
CREATE TABLE  t1a like t1s;
desc  t1a;

--echo #create table as select 
drop table if exists t1;
drop table if exists t2;

CREATE TABLE  t2(
logindate DATE,
uid VARCHAR(225),
new_user INT,
PRIMARY KEY(logindate,uid)
) with column group(all columns, each column);

CREATE TABLE   t1(c1 int primary key auto_increment,
c2 DATE unique,
c3 DATETIME default'2022-12-12 12:12:12',
c4 int not null default'1',
uid VARCHAR(225),
money FLOAT,index(c1,c2),unique(c3,c4),unique index (c3),
FOREIGN KEY(c2,uid) REFERENCES t2(logindate,uid)
) with column group(all columns, each column);

drop table if exists t1s;
CREATE TABLE  t1s with column group(all columns, each column) as select c1,c2,c3,c4,uid,money from t1;
ALTER TABLE t1s  rename column money to uid,rename column uid to money,rename column c1 to c3,rename column c3 to c1;  
desc  t1s;
drop table if exists t1a;
CREATE TABLE  t1a like t1s;
desc  t1a;


--echo #视图(改名后查询视图均报错1356)

drop table if exists test;
CREATE TABLE test (ii int primary key,c1 blob) with column group(all columns, each column);
insert into test values(2,5);

drop view  if exists  vv;
create view vv as select ii id from test;
select * from vv;

alter table test rename column ii to id;
--error 1356
select * from vv;


--echo #循环rename视图可以继续使用
drop table if exists test;
CREATE TABLE test (id int primary key,c1 blob) with column group(all columns, each column);
insert into test values(2,5);

drop view  if exists vv;
create view vv as select id c1,c1 id from test;
select * from vv;

alter table test rename column c1 to id,rename column id to c1;
select * from vv;

--echo #修改视图
alter view vv as select c1,id from test;
select * from vv;
desc  vv;




--echo #外键在rename时候，不支持change其他列,ob支持
drop table if exists child;
drop table if exists parent;
CREATE TABLE parent (
    id INT NOT NULL,
	zz int,
    PRIMARY KEY (id)
) with column group(all columns, each column);


CREATE TABLE child (z0 int,
    id INT,
    parent_id INT,
    INDEX par_ind (parent_id),
    FOREIGN KEY (parent_id)
        REFERENCES parent(id)
        ON DELETE CASCADE
)  with column group(all columns, each column);

alter table child rename column id to parent_id,rename column parent_id to id,change z0 zz varchar(200);

desc  parent;
desc  child;

--echo #表类型
--echo #带分区的表
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT) PARTITION BY HASH(c1) PARTITIONS 8 with column group(all columns, each column);
--error 3855
alter table t1 rename column c1 to c4__6_;


--echo #50993220- 【mysql_rename_column】rename分区列为原来相同的列名，ob成功，mysql禁止
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT) PARTITION BY HASH(c1) PARTITIONS 8 with column group(all columns, each column);
--error 3855
alter table t1 rename column c1 to c1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1(col1 date,col2 INT) 
       PARTITION BY RANGE (year(col1))
        (PARTITION p0 VALUES LESS THAN(100),
         PARTITION p1 VALUES LESS THAN(200),
         PARTITION p2 VALUES LESS THAN(300)
        ) with column group(all columns, each column);
--error 3855
alter table t1 rename column col1 to col2,rename column col2 to col1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT,col2 DATE)
       PARTITION BY LIST(col1)
        (PARTITION p0 VALUES IN (100),
         PARTITION p1 VALUES IN (200)
        ) with column group(all columns, each column);
--error 3855
alter table t1 rename column col1 to col1,rename column col2 to col2;
desc  t1;


--echo #二级分区
drop table if exists t1;
CREATE TABLE t1 (c1 INT, c2 INT, c3 INT) PARTITION BY RANGE COLUMNS(c1) 
     SUBPARTITION BY KEY(c2, c3) SUBPARTITIONS 5
     (PARTITION p0 VALUES LESS THAN(0), PARTITION p1 VALUES LESS THAN(100)) with column group(all columns, each column);
--error 3855
alter table t1 rename column c2 to c3,rename column c3 to c2;



--echo #字符集gbk
drop table if exists t1;
CREATE TABLE t1 (c1 VARCHAR(10),
                 飞鸽 VARCHAR(10) CHARSET GBK COLLATE gbk_bin)
             DEFAULT CHARSET utf8 COLLATE utf8_general_ci with column group(all columns, each column);
insert into t1 values('个人风格','认同感');
alter table t1 rename column 飞鸽 to 鸽;
desc  t1;
select * from t1;

--echo #开启 Encoding 并使用 zstd 压缩，宏块保留空间为 5%
drop table if exists t1;
CREATE TABLE t1 (c1 INT, c2 INT, c3 VARCHAR(64))
      COMPRESSION 'zstd_1.0'
      ROW_FORMAT DYNAMIC
      PCTFREE 5 with column group(all columns, each column);
alter table t1 rename column c2 to c1,rename column c1 to c3,rename column c3 to c2;
desc  t1;
--echo #创建表 t1，并设置并行度为 3 。
drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY, c2 INT) PARALLEL 3 with column group(all columns, each column);
alter table t1 rename column c2 to c1,rename column c1 to c2;
desc  t1;


