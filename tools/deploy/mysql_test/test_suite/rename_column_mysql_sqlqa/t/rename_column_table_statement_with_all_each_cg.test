--echo #更改TABLEGROUP中的表
purge recyclebin;
--error 0,1051
drop table  myt1;
--error 0,5151
drop tableGROUP  myTableGroup1;

CREATE TABLEGROUP myTableGroup1;

CREATE TABLE myt1 (c1 int primary key, c2 varchar(200),c4 int ,unique index(c1,c2(20)) ) TABLEGROUP = myTableGroup1 with column group(all columns, each column);
--error 1060
alter table myt1 add c3 int after c2,rename column c1 to c2,rename column c2 to c4,drop column c4;
desc  myt1;
drop table  myt1;
drop tableGROUP  myTableGroup1;

--echo #更改informtion_schema 库中表
#ALTER TABLE information_schema.tables RENAME column TABLE_NAME to TABLE_NAMES;

--echo #改其他库的表
--error 1008
drop database nxa1;
create database nxa1;
drop table if exists nxa1.t2;
CREATE TABLE nxa1.t2 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int) with column group(all columns, each column);
alter table nxa1.t2  rename column c1_a to c2_b,rename column c2_b to c3_c,
rename column c3_c to c1_a,rename COLUMN c5_e TO c5_E,rename COLUMN c4_D TO c4;
desc  nxa1.t2;
drop database nxa1;

--echo #事务

set autocommit = 0;
drop table if exists users;
CREATE TABLE `users`
 (
 `ID` BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
 `user_name` VARCHAR(60),
 `user_pass` VARCHAR(64),
 PRIMARY KEY (`ID`)
) with column group(all columns, each column);


drop table if exists test;
CREATE TABLE test (id int primary key,c1 varchar(20)) with column group(all columns, each column);
insert into test values(2,'zzz');

INSERT INTO users VALUES(null,'sheng','sheng123'),
(null,'yu','yu123'),
(null,'ling','ling123');


alter table test rename column c1 to id,rename column id to c1;
savepoint a2;
UPDATE users SET user_name=(select c1 from test);
SELECT * FROM users ;
rollback to a2;
SELECT * FROM users ;
UPDATE users SET user_name=(select c1 from test);
alter table test rename column c1 to id,rename column id to c1;
rollback;
SELECT * FROM users ;

--echo #ddl隐式提交
--echo #均无法rollback
set autocommit = 0;
drop table if exists t1;
drop table if exists users;
CREATE TABLE `users`
 (
 `ID` BIGINT(20) UNSIGNED NOT NULL AUTO_INCREMENT,
 `user_name` VARCHAR(60),
 `user_pass` VARCHAR(64),
 PRIMARY KEY (`ID`)
) with column group(all columns, each column);


drop table if exists test;
CREATE TABLE test (id int primary key,c1 varchar(20)) with column group(all columns, each column);
insert into test values(2,'zzz');

INSERT INTO users VALUES(null,'sheng','sheng123'),
(null,'yu','yu123'),
(null,'ling','ling123');
DELIMITER //;
--error 1305
drop PROCEDURE pro_users//
CREATE PROCEDURE pro_users()
BEGIN
UPDATE users SET user_name=(select id from test);
alter table test rename column c1 to c4,rename column id to num;
rollback;
END //

call pro_users() //
desc  test;//
SELECT * FROM users //
DELIMITER ;//


--echo #PREPARE+EXECUTE
--error 0,1243
DEALLOCATE PREPARE stmt1;
--error 0,1243
DEALLOCATE PREPARE stmt2;
--error 0,1243
DEALLOCATE PREPARE stmt3;

SET @colname = lpad('hello',3,'ya') ;
SET @a = CONCAT('drop table if exists t1');
SET @b = CONCAT('CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int)');
SET @s = CONCAT('alter table t1 rename column c1_a to ', @colname);
PREPARE stmt1 FROM @a;
PREPARE stmt2 FROM @b;
EXECUTE stmt1;
EXECUTE stmt2;
PREPARE stmt3 FROM @s;
EXECUTE stmt3;
desc  t1;


DEALLOCATE PREPARE stmt1;
DEALLOCATE PREPARE stmt2;
DEALLOCATE PREPARE stmt3;

SET @colname1 = 'c1_a' ;
SET @colname2 = 'c1_b' ;
SET @a = 'drop table if exists t1';
SET @b = 'CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int)';
SET @s = CONCAT(CONCAT('alter table t1 rename column ',@colname1),CONCAT(' to ', @colname2));
PREPARE stmt1 FROM @a;
PREPARE stmt2 FROM @b;
EXECUTE stmt1;
EXECUTE stmt2;
PREPARE stmt3 FROM @s;
EXECUTE stmt3;
desc  t1;



SET @colname1 = 'c1_a' ;
SET @colname2 = 'c1_b' ;
SET @a = 'drop table if exists t1';
SET @b = 'CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int)';
SET @s = 'alter table t1 rename column c1_a to c2_b,rename column c2_b to c5_e,rename column c5_e to c1_a';
PREPARE stmt1 FROM @a;
PREPARE stmt2 FROM @b;
EXECUTE stmt1;
EXECUTE stmt2;
PREPARE stmt3 FROM @s;
EXECUTE stmt3;
desc  t1;







--echo #表锁
--echo #目前ob表锁没生效
drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY auto_increment, c2 bigINT, c3 bigINT, c4 bigINT, INDEX k1(c2,c3)) with column group(all columns, each column);

lock table t1 read;
alter table t1 rename column c1 to col1;
UNLOCK TABLES;
alter table t1 rename column c2 to col2;
desc  t1;


drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY auto_increment, c2 bigINT, c3 bigINT, c4 bigINT, INDEX k1(c2,c3)) with column group(all columns, each column);
lock table t1 write;
alter table t1 rename column c1 to col1;
UNLOCK TABLES;
alter table t1 rename column c2 to col2;
desc  t1;



--echo #dml
drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY auto_increment, c2 bigINT, c3 bigINT, c4 bigINT, INDEX k1(c2,c3)) with column group(all columns, each column);
INSERT INTO t1 (c2,c3,c4 )VALUES(  15245668215,2259478113654872164,202012121212);
INSERT INTO t1 (c2,c3,c4 )VALUES(  1524566,2259478113654872164,202012121212);


alter table t1 rename column c1 to a,rename column c2 to b,rename column c3 to c4,rename column c4 to c3;

select a, b,c3,c4 from t1;
select a c1, b c2,c3 ,c4 from t1;
select a from t1 where c4 = c3;
select a from t1 where c4 in (c3);

update t1 set c3 = c4/c3;
update t1 set c4 = b/a;
UPDATE t1 SET b = a + 1 WHERE b in(b) ORDER BY a aSC ;
select * from t1;

insert into t1(b,c3,c4) values(9,9,9);
insert into t1(b,c3,c4) select b,c3,c4 from t1;
INSERT INTO t1 (b,c3,c4) VALUES (10,2,3)ON DUPLICATE KEY UPDATE c4=c4+1;
select * from t1;

REPLACE INTO t1 ( a, b, c3, c4 )VALUES( '1', 1, 1, 1 ), ( '700', 2, 2, 2 );
SELECT * FROM t1 WHERE a in(1,700) ;


