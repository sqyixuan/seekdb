#owner:zongmei.zzm
#owner group: 技术部-SQL-执行器
#description: obmysql模式, rename_column测试
#tags:ddl
#author: wb-nxa01399802

--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by 'nxa';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,nxa,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;



--echo #syntax

drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
alter table t1 rename column c1_a to c2_e;
desc  t1;


--echo #加上表名.列，ob成功，mysql失败
--echo #50905029- 【mysql_rename_column】ob_rename旧列可以指定表名，mysql语法上禁止
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);


drop table if exists t2;
CREATE TABLE t2 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);

drop table if exists tt5;
--error 1064
alter table t2 rename  tt5,rename column nxa.tt5.`c1_a` to c1_5555;



--echo #表中列名更换到新列，再更换新列
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
--error 1054
alter table t1 rename column c1_a to c2_e,rename column c2_e to c1_a;
desc  t1;

--echo #表中列名循环
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
alter table t1 rename column c1_a to c2_b,rename column c2_b to c3_c,rename column c3_c to c4_d,
rename column c4_d to c5_e,rename column c5_e to c1_a;
desc  t1;
--echo #多个循环
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int,c6 int);
alter table t1 rename column c1_a to c2_b,rename column c2_b to c1_c,rename column c3_c to c6,rename column c6 to c3_c,
rename column c4_d to c5_e,rename column c5_e to c4_d;
desc  t1;


--echo #表中列名跟换新列
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
alter table t1 rename column c1_a to c2_b,rename column c2_b to c3_c,rename column c3_c to c4_d,
rename column c4_d to c5_e,rename column c5_e to c1_ff;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
alter table t1 rename column c1_a to c2_a,rename column c2_b to c3_a,rename column c3_c to c4_a,
rename column c4_d to c5_a,rename column c5_e to c1_a ;
desc  t1;


--echo #表中循环结束再rename到新列
drop table if exists t1;
CREATE TABLE t1 (c1_a INT PRIMARY KEY, c2_b INT, c3_c INT,c5_e VARCHAR(312),c4_d int);
--error 1054
alter table t1 rename column c1_a to c2_b,rename column c2_b to c3_c,rename column c3_c to c4_d,
rename column c4_d to c5_e,rename column c5_e to c1_a,rename column c1_a to c1_tttt;



--echo #列名带空格
drop table if exists t1;
CREATE TABLE t1 (`c1_ a` INT PRIMARY KEY, `c2_ b` INT, `c4_ d` int);
alter table t1 rename column `c1_ a` to `c2_ b`,rename column `c2_ b` to `c4_ d`,rename column `c4_ d` to `c1_ a`;
desc  t1;

--echo #列名大小写
drop table if exists t1;
CREATE TABLE t1 (c1_A INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column c1_A to `c2_ B`,rename column c2_B to `c4_ d`,rename column c4_d to c1_a;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (c1_A INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column c1_a to `c2_ B`,rename column c2_B to `c4_ d`,rename column c4_d to c1_a;
desc  t1;
--echo #跟换特殊字符列名
drop table if exists t1;
CREATE TABLE t1 (`@! ￥$#&()!??_+% _`INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column `@! ￥$#&()!??_+% _`  to c2_B,rename column c2_B to c4_d,rename column c4_d to `@! ￥$#&()!??_+% _`;
desc  t1;

--echo #关键字
drop table if exists t1;
CREATE TABLE t1 (`@! ￥$#&()!??_+% _`INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column `@! ￥$#&()!??_+% _`  to c2_B,rename column c2_B to `to`,rename column c4_d to `table`;
desc  t1;


--echo #表中与其他列相同列名
drop table if exists t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1060
alter table t1 rename column `c1_a`  to c2_B,rename column c2_B  to c2_B;


--echo #本列新旧列名相同
--echo #50748682- 【mysql_rename_column】rename新旧列名相同，ob报错1110 (42000): Column 'c1_ a' specified twice，mysql成功
drop table if exists t1;
CREATE TABLE t1 (`c1_ a` INT PRIMARY KEY, `c2_ b` INT, `c4_ d` int);
alter table t1 rename column `c1_ a` to `c1_ a`;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1054
alter table t1 rename column `c1_a`  to c2_B,rename column c2_B  to c4_d,rename column c4_d  to c1_a,rename column c1_a to c2_b;

--echo #与表名相同
drop table if exists t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column `c1_a`  to t1;
desc  t1;

drop table if exists t1; 
CREATE TABLE t1 (t1 INT PRIMARY KEY, c2_B INT, c4_d int);
alter table t1 rename column t1  to zzz;
desc  t1;
--echo #多个rename，新列名相同
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT);
--error 1060
alter table t1 rename column c2 to c2_,rename column c3 to c2_;
desc  t1;



--echo #重复命名
--echo #50750664- 【mysql_rename_column】单列重复命名，ob报错信息与mysql不一致
drop table if exists t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1054
alter table t1 rename column `c1_a`  to cc,rename column `c1_a`  to cc,rename column `c1_a`  to cc,rename column `c1_a`  to cc;


drop table if exists t1;
CREATE TABLE t1 (`c1_a` INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1054
alter table t1 rename column `c1_a`  to cc,rename column `c1_a`  to aa,rename column `c1_a`  to ff,rename column `c1_a`  to gg;

--echo #超长列名
--echo #ob列名长度比mysql大 
drop table if exists t2;
CREATE TABLE t2 (
    cc INT,
    dd binary
);
SET @colname = lpad('hello',125,'ya') ;
SET @s = CONCAT('alter table t2 rename column cc to ', @colname);
PREPARE stmt3 FROM @s;
EXECUTE stmt3;



