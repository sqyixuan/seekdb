rename column c17_ to c10_,rename column c10_ to c8_,rename column c8_ to c7_,rename column c7_ to c9_,
rename column c9_ to c11_,rename column c11_ to c16_,rename column c16_ to c12_,rename column c12_ to c13_,
rename column c13_ to c15_,rename column c15_ to c14_,rename column c14_ to c1_,rename column c24_24 to c25_25,
rename column c25_25 to c24_24;

desc  t1;



--echo #索引
--echo #普通索引
--echo #主键列和索引列交换，且rename顺序由普通列转为主键列，ob报错验证
--echo #50755229- 【mysql_rename_column】rename联合索引中的列，ob报错1060 (42S21): Duplicate column，mysql成功改变
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, unique INDEX i1 (c2));
desc  t1;
alter table t1 rename column c2 to c1,rename column c1 to c2;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, INDEX i1 (c2));
desc  t1;
alter table t1 rename column c2 to c333,rename column c3 to c222;
desc  t1;


--echo #主键
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, INDEX i1 ((c2+1)));
alter table t1 rename column c1 to c9;
desc  t1;


drop table if exists emp2;

drop table if exists emp;
create table emp (id int  primary key ,name1 varchar(8),index(name1));
create table emp2(id int,name varchar(8),id1 int, constraint pk_id primary key(id),constraint fk_name foreign key(id1) references emp(id));
desc  emp2;
alter table emp rename column id to name1,rename column name1 to id;
alter table emp2 rename column id to name,rename column name to id1,rename column id1 to id;
desc  emp2;



--echo #复合主键
drop table if exists t1;
create table t1(
    id int(10),
    name varchar(32) not null,
    email varchar(128) unique,
    primary key(id,name)
);
alter table t1 rename column id to name,rename column name to id;
desc  t1;

alter table t1 rename column id to id,rename column name to name;
desc  t1;

alter table t1 rename column id to vv,rename column name to cc;
desc  t1;



--echo #唯一
drop table if exists t1;
CREATE TABLE t1 (c1 INT primary key unique, c2 INT, c3 INT, unique INDEX i1 (c2));
alter table t1 rename column c2 to c2_,rename column c1 to c2_1;
desc  t1;

--echo #50794297- 【mysql_rename_column】rename循环主键列+unique列，ob报错1060 (42S21): Duplicate column name
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, unique INDEX i1 (c2));
alter table t1 rename column c2 to c1,rename column c1 to c2;
desc  t1;

alter table t1 rename column c2 to c2,rename column c1 to c1;
desc  t1;


--echo #表级unique

drop table if exists t1;
CREATE TABLE t1 (c1 INT unique, c2 INT, c3 INT, unique (c2,c3));
alter table t1 rename column c2 to c2_,rename column c1 to c2_1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (c1 INT unique, c2 INT, c3 INT, unique (c2,c3));
alter table t1 rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (c1 INT unique, c2 INT, c3 INT, unique (c2,c3));
alter table t1 rename column c2 to c4,rename column c3 to c5;
desc  t1;
--echo #联合索引
--echo #50755229- 【mysql_rename_column】rename联合索引中的列，ob报错，mysql成功改变
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT,  INDEX i1 (c1,c2,c3));
alter table t1 rename column c2 to c3,rename column c3 to c1,rename column c1 to c2;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT,  INDEX i1 (c1,c2,c3));
alter table t1 rename column c2 to c33;
desc  t1;

--echo #主键未参与
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT,  INDEX i1 (c2,c3));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;



--echo #函数索引
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, INDEX i1 ((c2+c3)));
alter table t1 rename column c1 to c1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 INT, col2 INT, INDEX func_index ((ABS(col1))));

--error 3837
alter table t1 rename column col1 to col2,rename column col2 to col1;


--echo #前缀索引
--echo #50755953- 【mysql_rename_column】rename前缀索引中的列，ob报错3108 (HY000): Column 'c2' has a generated column dependency，mysql成功
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 BLOB, c3 INT, INDEX i1 (c2(10)));
alter table t1 rename column c2 to c2_,rename column c1 to c2_1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX (col1(5), col2(10)));
alter table t1 rename column col1 to col2,rename column col2 to col1;
desc  t1;

drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10)primary key,col2 VARCHAR(20),INDEX (col1(5), col2(10)));
alter table t1 rename column col2  to c2_,rename column col1 to c2_1;
desc  t1;




--echo #某列多个索引
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX i1 (col2),INDEX i2 (col2(10)),INDEX i3 (col1, col2(10)),unique index i4(col2),
INDEX i5 (col1),INDEX i6 (col1(10)),INDEX i7 (col2, col1(10)),unique index i8(col1));
alter table t1 rename column col1 to col2,rename column col2 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX i1 (col2),INDEX i2 (col2(10)),INDEX i3 (col1, col2(10)),unique index i4(col2),
INDEX i5 (col1),INDEX i6 (col1(10)),INDEX i7 (col2, col1(10)),unique index i8(col1));
alter table t1 rename column col1 to col4,rename column col2 to col9;
desc  t1;




--echo #各个索引间的循环命名
--echo #普通+普通
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, INDEX i1 (c2),INDEX i2 (c3));
desc  t1;
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;
--echo #普通+主键
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 INT, INDEX i1 (c2));
desc  t1;
alter table t1 rename column c2 to c1,rename column c1 to c2;
desc  t1;
--echo #普通+前缀
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 VARCHAR(20), INDEX i1 (c3(10)),INDEX i2 (c2));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;

--echo #普通+唯一
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 VARCHAR(20), unique INDEX i1 (c3),INDEX i2 (c2));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;
--echo #普通+组合
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 VARCHAR(20), unique INDEX i1 (c3,c2),INDEX i2 (c2));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;
--echo #前缀+唯一
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 VARCHAR(20), INDEX i1 (c3(10)),unique INDEX i2 (c2));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;

--echo #前缀+组合
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT, c3 VARCHAR(20), INDEX i1 (c3(10)),unique INDEX i2 (c2,c1));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;

--echo #前缀+前缀
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 VARCHAR(20), c3 VARCHAR(20), INDEX i1 (c3(10)),INDEX i2 (c2(11)));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;

--echo #唯一+组合
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 VARCHAR(20), c3 VARCHAR(20), unique INDEX i1 (c3(10)),INDEX i2 (c2(11),c1));
alter table t1 rename column c2 to c3,rename column c3 to c2;
desc  t1;

--echo #唯一+唯一
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 VARCHAR(20), c3 VARCHAR(20), unique INDEX i1 (c3),unique INDEX i2 (c2));
alter table t1 rename column c2 to c3,rename column c3 to c2,rename column c1 to c1;
desc  t1;


--echo #组合+组合
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 VARCHAR(20), c3 VARCHAR(20),c4 VARCHAR(20),INDEX i2 (c2(11),c1),INDEX i3 (c3,c4));
alter table t1 rename column c2 to c3,rename column c3 to c2,rename column c1 to c4,rename column c4 to c1;
desc  t1;





--echo #约束
--echo #foreign key

drop table if exists child;
drop table if exists parent;
CREATE TABLE parent (
    id INT NOT NULL,
	zz int,
    PRIMARY KEY (id)
);


CREATE TABLE child (
    id INT,
    parent_id INT,
    INDEX par_ind (parent_id),
    FOREIGN KEY (parent_id)
        REFERENCES parent(id)
        ON DELETE CASCADE
) ;

alter table parent rename column id to zz,rename column zz to id;
desc  parent;
desc  child;
alter table child rename column id to parent_id,rename column parent_id to id;
desc  parent;
desc  child;

alter table child rename column id to iiii,rename column parent_id to pppp;
desc  parent;
desc  child;


insert into parent values(1,9);
insert into child values(1,1);
--error 1452
insert into child values(2,2);
--error 1452
insert into child values(1,2);
insert into child values(2,1);
select * from child;


--echo #复合外键

drop table if exists product_order;
drop table if exists customer;
drop table if exists product;
CREATE TABLE product (
    category INT NOT NULL, id INT NOT NULL,
    price DECIMAL,
    PRIMARY KEY(category, id)
);

CREATE TABLE customer (
    id INT NOT NULL,
    PRIMARY KEY (id)
);

CREATE TABLE product_order (
    no INT NOT NULL AUTO_INCREMENT,
    product_category INT NOT NULL,
    product_id INT NOT NULL,
    customer_id INT NOT NULL,

    PRIMARY KEY(no),
    INDEX (product_category, product_id),
    INDEX (customer_id),

    FOREIGN KEY (product_category, product_id)
      REFERENCES product(category, id)
      ON UPDATE CASCADE ON DELETE RESTRICT,

    FOREIGN KEY (customer_id)
      REFERENCES customer(id)
);

alter table product rename column category to price,rename column price to category;
desc  product;
desc  customer;
desc  product_order;


alter table customer rename column id to zzzz;
desc  product;
desc  customer;
desc  product_order;

alter table product_order rename column product_category to product_id,rename column product_id to customer_id,
rename column customer_id to product_order;
desc  product_order;

alter table product_order rename column customer_id to cus,rename column product_id to pro,
rename column product_order to pro_or;
desc  product_order;



--echo #自引用外键

drop table if exists t1;
create table t1 (
    c1 int unique key,
    c2 int ,
    c3 int unique key,
    FOREIGN KEY (c3) REFERENCES t1(c1),
    FOREIGN KEY (c2) REFERENCES t1(c3)
);

alter table t1 rename column c1 to c3 ,rename column c3 to c2,rename column c2 to c1;
desc  t1 ;

alter table t1 rename column c1 to c45 ,rename column c2 to c54,rename column c3 to c3445;
desc  t1 ;



--echo #not null
drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY not null, c2 BLOB not null, c3 INT not null);
alter table t1 rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
desc  t1;
alter table t1 rename column c1 to c11,rename column c2 to c22,rename column c3 to c33;
desc  t1;

--echo #auto_increment
drop table if exists t1;
CREATE TABLE t1 ( c1 INT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY, c2 BLOB not null , c3 INT not null);
alter table t1 rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
alter table t1 rename column c1 to c555;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (
 c1 INT UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY, 
 c2 CHAR(1)
 );
INSERT INTO t1 (c1,c2) VALUES (1,'a'), (NULL,'b'), (5,'c'), (NULL,'d');
alter table t1 rename column c1 to c2,rename column c2 to c1;
INSERT INTO t1 (c2,c1) VALUES (99,'a'), (NULL,'b'), (45,'c'), (NULL,'d');
select * from t1;

--echo #default
drop table if exists t1;
CREATE TABLE t1 ( c1 INT UNSIGNED NOT NULL  PRIMARY KEY default '1', c2 int not null default '1' , c3 INT not null default '57');
alter table t1 rename column c1 to c2,rename column c2 to c3,rename column c3 to c1;
alter table t1 rename column c1 to c555;
desc  t1;



--echo #check约束
--echo #50749392- 【mysql_rename_column】ob通过rename后约束均条件变为`col1` = (`col1` * 2)，无法插入除0以外数据，mysql存在约束时不能修改涉及约束条件的列名。
--echo #修改后均不支持renamecheck相关列
drop table if exists t1;
CREATE TABLE t1 (col1 INT,  col3 INT, CONSTRAINT equal_check1 CHECK(col1 = col3 * 2));
insert into t1 values(2,1);
--error 3959
alter table t1 rename column col1 to col3,rename column col3 to col1;




drop table if exists t1;
CREATE TABLE t1 (col1 INT,  col3 INT, CONSTRAINT equal_check1 CHECK(col1 is not null));
insert into t1 values(2,1);
alter table t1 rename column col3 to col4;
--error 3959
alter table t1 rename column col1 to col5;



drop table if exists t1;
CREATE TABLE t1 (col1 INT primary key, col2 INT,CONSTRAINT my_check CHECK (col1> col2+1));
--error 3959
ALTER TABLE t1 rename column col2 to col3,rename column col1 to col4;  





--echo #重命名column_ddl之后的列
--echo #alter column
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX (col1));
alter table t1 alter column col2 set default 5;
alter table t1 rename column col1 to col2,rename column col2 to col1;
desc  t1;

--echo #MODIFY COLUMN
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX (col1));
ALTER TABLE t1 MODIFY COLUMN col1 VARCHAR(32) NOT NULL AFTER col2;
alter table t1 rename column col1 to col2,rename column col2 to col1;
desc  t1;


--echo #CHANGE COLUMN
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX (col1));
ALTER TABLE t1 CHANGE COLUMN col1 col8 VARCHAR(32)  ;
desc  t1;
alter table t1 rename column col8 to col2,rename column col2 to col1;
desc  t1;


drop table if exists t1;
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2_1 INT, c3 INT,c5 VARCHAR(312),c4 int,INDEX (c3));
ALTER TABLE t1 CHANGE COLUMN c3 c2 VARCHAR(50);
desc  t1;
alter table t1 rename column c5 to c2,rename column c2 to c5;
desc  t1;


--echo #add COLUMN
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),INDEX (col1));
ALTER TABLE t1 add COLUMN  col8 VARCHAR(32)  ;
desc  t1;
alter table t1 rename column col1 to col8,rename column col8 to col1;
desc  t1;

--echo #drop COLUMN
drop table if exists t1;
CREATE TABLE t1 (col1 VARCHAR(10),col2 VARCHAR(20),col8 VARCHAR(32) ,INDEX (col1));
ALTER TABLE t1 drop COLUMN  col8;
desc  t1;
alter table t1  rename column col1 to col2,rename column col2 to col1;
desc  t1;


###清理环境
connection default;
--disable_warnings
--error 0,1396
drop user nxa;
--enable_warnings

purge recyclebin;


