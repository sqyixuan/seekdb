CREATE TABLE t1 (`@! ￥$#&()!??_+% _`INT PRIMARY KEY, c2_B INT, c4_d int);
--error 1166
alter table t1 rename column `@! ￥$#&()!??_+% _`  to c2_B,rename column c2_B to c4_d,rename column c4_d to ``;


