alter table t1 rename column c5_5 to c5_;
alter table t1 rename column c6_6 to c6_;
alter table t1 rename column c7_7 to c7_;
alter table t1 rename column c8_8 to c8_;
alter table t1 rename column c9_9 to c9_;
alter table t1 rename column c10_10 to c10_;
alter table t1 rename column c11_11 to c11_;
alter table t1 rename column c12_12 to c12_;
alter table t1 rename column c13_13 to c13_;
alter table t1 rename column c14_14 to c14_;
alter table t1 rename column c15_15 to c15_;
alter table t1 rename column c16_16 to c16_;
alter table t1 rename column c17_17 to c17_;
alter table t1 rename column c18_18 to c18_;
alter table t1 rename column c19_19 to c19_;
alter table t1 rename column c20_20 to c20_;
alter table t1 rename column c21_21 to c21_;
