explain_protocol: 0
drop database if exists tlutest;
create database tlutest;
use tlutest;
drop table if exists t1, t2, t3;
create table t1(c1 int, c2 int, c3 int)
partition by range(c1)
subpartition by hash(c2) (
partition p0 values less than(0)
(subpartition sp00,
subpartition sp01),
partition p1 values less than(4)
(subpartition sp10,
subpartition sp11),
partition p2 values less than(maxvalue)
(subpartition sp20,
subpartition sp21));
create index idx on t1(c1) global;
create table t2(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1 on t2(c1) global;
create index idx2 on t2(c2) global partition by hash(c2) partitions 4;
create table t3(c1 int, c2 int, c3 int) partition by hash(c1 + c2 + 1) partitions 4;
create index idx on t3(c1) global;
create index idx2 on t3(c1, c2) global partition by hash(c1) partitions 5;
result_format: 4
call dbms_stats.gather_table_stats('TLUTEST', 'T1');
call dbms_stats.gather_table_stats('TLUTEST', 'T2');
call dbms_stats.gather_table_stats('TLUTEST', 'T3');
select owner, table_name, partition_name, num_rows, avg_row_len from oceanbase.dba_tab_statistics where owner = 'TLUTEST' and table_name in ('T1', 'T2', 'T3');
