## test selection from global index which has only one partition
select /*+index(t1 gkey)*/ c2,c3,c4 from t1;
+------+------+------+
| c2   | c3   | c4   |
+------+------+------+
|    1 |    1 |    1 |
|    2 |    2 |    2 |
|    3 |    3 |    3 |
|    4 |    4 |    4 |
+------+------+------+
affected rows: 4
select /*+index(t1 gkey)*/ c2,c3,c4 from t1 where c2 = 1 or c3 = 2;
+------+------+------+
| c2   | c3   | c4   |
+------+------+------+
|    1 |    1 |    1 |
|    2 |    2 |    2 |
+------+------+------+
affected rows: 2
select /*+index(t1 gkey)*/ c2,c3,c4 from t1 where c2 = 1 or c3 = 2 or c4 = 4;
+------+------+------+
| c2   | c3   | c4   |
+------+------+------+
|    1 |    1 |    1 |
|    2 |    2 |    2 |
|    4 |    4 |    4 |
+------+------+------+
affected rows: 3

