drop table t1;

create table t1 (c1 int primary key, c2 int, z1 datetime default now(), z2 datetime default now()) partition by hash(c1) partitions 2;

create index i1 on t1 (z1) global;
create index i2 on t1 (z2) global;

insert into t1 values(1, 1, '2020-02-04 00:00:00', '2020-02-04 01:00:30');
insert into t1 values(2, 2, '2020-02-04 01:00:00', '2020-02-04 02:00:30');

create index i3 on t1 (c2) storing (z1) global;
create index i4 on t1 (c2) storing (z2) global;
explain_protocol: 2
EXPLAIN select /*+index(t1 primary)*/ * from t1;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |2       |9           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|2       |8           |
|2 |  └─PX PARTITION ITERATOR|        |2       |5           |
|3 |    └─TABLE FULL SCAN    |t1      |2       |5           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.z1, t1.z2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.z1, t1.z2)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.z1], [t1.z2]), filter(nil), rowset=16
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.z1], [t1.z2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.z1], [t1.z2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
select /*+index(t1 primary)*/ * from t1;
