result_format: 4
create table t1 (c1 int, c2 int, c3 int,c4 int, primary key(c1,c2)) partition by hash(c2) partitions 2;
create index i1 on t1(c3) storing(c4) global;

insert into t1 values(1,1,1,1),(2,2,2,2);
insert into t1 values(3,100,100,100),(4,100,100,100);
insert into t1(c1,c2) values(5,100),(6,100);
insert into t1(c1,c2) values(6,200),(6,300);

insert into t1(c1,c2) values(7,100),(8,100);
select * from t1;
