drop table if exists t1,t2;
create table t1 (id int primary key, c1 varchar(20) collate utf8mb4_general_ci, c2 varchar(20) collate utf8mb4_general_ci, c3 char(20) collate utf8mb4_general_ci)
  partition by hash(id) partitions 2;
create index i1 on t1(c1) global;
create table t2 (id int primary key, c1 varchar(20) collate utf8mb4_general_ci, c2 varchar(20) collate utf8mb4_bin, c3 char(20) collate utf8mb4_bin)
  partition by hash(id) partitions 2;
create index i2 on t2(c2) global;
