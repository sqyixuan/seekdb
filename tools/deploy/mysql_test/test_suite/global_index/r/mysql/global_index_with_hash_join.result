result_format: 4
explain_protocol: 1
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8;
create table t1(a int primary key, b int, c varchar(20), d decimal(20, 10)) partition by hash(a) partitions 2;
create index i1 on t1(b, c) global;
create table t2(a int primary key, b varchar(20), c decimal(20,10)) partition by hash(a) partitions 2;
create index i2 on t2(b, c) global;
create table t3(a int primary key, b int, c int) partition by hash(a) partitions 2;
create index i3 on t3(b, c) global;
create table t4(a int primary key, b int, c varchar(20)) partition by hash(a) partitions 2;
create index i4 on t4(b) global;
create table t5(a int primary key, b varchar(20), c varchar(25) collate 'binary') partition by hash(a) partitions 2;
create index i5 on t5(b) global;
create table t6(a time, b datetime, c datetime(6), d date);
create table t7(a bit(10), b binary(10), c char(20), d double);
create table t8(a bit(20), b datetime, c datetime(6), d date);

