set @@session.explicit_defaults_for_timestamp=off;
create table t1(id int primary key, name varchar(300), age int, description varchar(65535)) progressive_merge_num=10 tablet_size=2097152 compression='none';
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
create index i1 on t1(name) partition by key(name) partitions 2;
