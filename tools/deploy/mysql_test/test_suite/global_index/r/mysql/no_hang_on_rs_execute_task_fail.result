alter system set_tp tp_no = 53, error_code = 1, frequency = 1;
drop table if exists t1;
set ob_query_timeout = 200000000;
create table t1 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3)) partition by hash(c2) partitions 4;
create index i1 on t1 (c4) global;
alter system set_tp tp_no = 53, error_code = 0, frequency = 0;
