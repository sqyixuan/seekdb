result_format: 4
drop database if exists muhangtest;
create database muhangtest;
use muhangtest;
create table test (i1 int, i2 longtext,i4 float, i5 datetime(6),i6 decimal(5,3),i7 longtext,i8 longtext,i9 longtext,i10 longtext, primary key(i1)) COMPRESSION = 'none' partition by hash(i1) partitions 6;
create index gkey on test(i1,i5) global partition by hash(i1) partitions 2;
select sum(length(i2)), sum(length(i7)), sum(length(i8)), sum(length(i9)), sum(length(i10)) from test;
+-----------------+-----------------+-----------------+-----------------+------------------+
| sum(length(i2)) | sum(length(i7)) | sum(length(i8)) | sum(length(i9)) | sum(length(i10)) |
+-----------------+-----------------+-----------------+-----------------+------------------+
|       235926900 |       235926900 |       235926900 |       235926900 |        235926900 |
+-----------------+-----------------+-----------------+-----------------+------------------+

explain select /*+index(test gkey)*/ * from test;
Query Plan
========================================================
|ID|OPERATOR                |NAME      |EST. ROWS|COST |
--------------------------------------------------------
|0 |TABLE LOOKUP            |test      |900      |11152|
|1 | PX COORDINATOR         |          |900      |3865 |
|2 |  EXCHANGE OUT DISTR    |:EX10000  |900      |180  |
|3 |   PX PARTITION ITERATOR|          |900      |180  |
|4 |    TABLE SCAN          |test(gkey)|900      |180  |
========================================================

Outputs & filters: 
-------------------------------------
  0 - output([test.i1], [test.i2], [test.i4], [test.i5], [test.i6], [test.i7], [test.i8], [test.i9], [test.i10]), filter(nil), 
      partitions(p[0-5])
  1 - output([test.i1]), filter(nil)
  2 - output([test.i1]), filter(nil), dop=1
  3 - output([test.i1]), filter(nil)
  4 - output([test.i1]), filter(nil), 
      access([test.i1]), partitions(p[0-1])


select /*+index(test gkey)*/ SQL_CALC_FOUND_ROWS * from test limit 0;
+----+------+------+------+------+------+------+------+------+
| i1 | i2   | i4   | i5   | i6   | i7   | i8   | i9   | i10  |
+----+------+------+------+------+------+------+------+------+
+----+------+------+------+------+------+------+------+------+

select found_rows();
+--------------+
| found_rows() |
+--------------+
|          900 |
+--------------+


create table test1 (i1 int, i2 longtext,i4 float, i5 datetime(6),i6 decimal(5,3),i7 longtext,i8 longtext,i9 longtext,i10 longtext, primary key(i1)) COMPRESSION = 'none' partition by hash(i1) partitions 2;
create index gkey on test1(i1,i5) global partition by hash(i1) partitions 2;
select sum(length(i2)), sum(length(i7)), sum(length(i8)), sum(length(i9)), sum(length(i10)) from test1;
