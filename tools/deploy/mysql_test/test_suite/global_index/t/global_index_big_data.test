set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj 
# owner group: storage
# description:
# tags: global_index
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log
create table t1(id int primary key, name varchar(300), age int, description varchar(65535)) progressive_merge_num=10 tablet_size=2097152 compression='none';
--source mysql_test/include/drop_and_flashback_table.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
disconnect obsys;
connection default;
# prepare data
let $pkey=0;
let $i=0;
while($i < 10000)
{
  --disable_query_log
    eval insert into t1 values($pkey, repeat(rand(),10), 0, repeat(rand(),900));
  inc $i;
  inc $pkey;
  --enable_query_log
}
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection default;
create index i1 on t1(name) partition by key(name) partitions 2;
--source mysql_test/include/check_all_idx_ok.inc
