--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: sql3
# tags: global_index
#
# create global index with generated column failed.
# 
#

--result_format 4

--disable_warnings
drop table if exists givt_test1, givt_test2, givt_test3,givt_test4,givt_test5,givt_test6;
--enable_warnings

create table givt_test1 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test1 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test1 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test1 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test2 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test2 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test2 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test2 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test3 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test3 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test3 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test3 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test5 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test5 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test5 (c1, c2, c3, c4, c5) values (2, 4, 4, 'b', 'a');
insert into givt_test5 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

create table givt_test6 (c1 int, c2 int, c3 int, c4 varchar(20), c5 varchar(20), primary key (c1, c2));
insert into givt_test6 (c1, c2, c3, c4, c5) values (1, 1, 1, 'a', 'b');
insert into givt_test6 (c1, c2, c3, c4, c5) values (2, 4, 5, 'b', 'a');
insert into givt_test6 (c1, c2, c3, c4, c5) values (3, 4, 5, 'd', 'c');

alter table givt_test1 add column c6 int generated always as (c3 + 5) virtual;
alter table givt_test2 add column c7 int generated always as (c3 + 5) stored;
alter table givt_test3 add column c8 varchar(80) generated always as (concat(c4, c5)) virtual;
alter table givt_test5 add column c9 int generated always as (c3 + 5) stored;
alter table givt_test6 add column c9 int generated always as (c3 + 5) stored;

--sleep 1

create index i1 on givt_test1 (c6) partition by hash (c6) partitions 2;
create index i2 on givt_test2 (c7) partition by hash (c7) partitions 2;
create index i3 on givt_test3 (c8, c2) partition by hash (c2) partitions 2;
create unique index i5 on givt_test5 (c9) partition by hash (c9) partitions 2;
# index i6 should fail cause c9 not unique
--error 1062
create unique index i6 on givt_test6 (c9) partition by hash (c9) partitions 2;

--source mysql_test/include/check_all_idx_ok.inc
connection default;

show index from givt_test1;
show index from givt_test2;
show index from givt_test3;
show index from givt_test5;
show index from givt_test6;

connect (sysconn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection sysconn;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='givt_test1' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_name, table_name, 1);

let $idx2 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='givt_test2' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_name, table_name, 1);
let $idx3 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='givt_test3' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_name, table_name, 1);
let $idx5 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='givt_test5' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_name, table_name, 1);

connection default;

set ob_enable_index_direct_select=1;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
eval select * from $idx3;
eval select * from $idx5;
--enable_query_log


# case from bug:
# 
#
create table givt_test4 (pk1 int, pk2 int, first_name varchar(100), last_name varchar(100), primary key(pk1, pk2)) partition by hash(pk1) partitions 2;
insert into givt_test4 values(1,1, 'first                     1', 'last                    1');

--sleep 1
create index test_index ON givt_test4(first_name(10));

--source mysql_test/include/check_all_idx_ok.inc
connection default;
show index from givt_test4;

let $TENANT = sys;
connection sysconn;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='givt_test4' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT')) b on a.data_table_id=b.table_id order by a.table_name, table_name, 1);
connection default;

--disable_query_log
eval select * from $idx1;
--enable_query_log

replace into givt_test4(pk1,pk2,first_name,last_name) values (1, 1, 'first                     1', 'last                    2');
insert into givt_test4(pk1,pk2,first_name,last_name) values (1, 1, 'first                     1', 'last                    2') on duplicate key update last_name = 'dtew';

select * from givt_test4;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
