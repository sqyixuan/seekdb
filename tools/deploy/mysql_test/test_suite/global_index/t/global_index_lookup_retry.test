#owner: yuchen.wyc
#owner group: sql3
# tags: optimizer, global_index
--source mysql_test/include/bigvarchar.inc

--result_format 4

--disable_warnings
drop database if exists muhangtest;
create database muhangtest;
use muhangtest;
--enable_warnings

create table test (i1 int, i2 longtext,i4 float, i5 datetime(6),i6 decimal(5,3),i7 longtext,i8 longtext,i9 longtext,i10 longtext, primary key(i1)) COMPRESSION = 'none' partition by hash(i1) partitions 6;
create index gkey on test(i1,i5) global partition by hash(i1) partitions 2;
--source mysql_test/include/check_all_idx_ok.inc
--disable_query_log
--disable_result_log
--let $loop=900
while  ($loop)
{
#bug 6626386
eval insert into test values($loop,$a,$loop,'2014-10-01 00:12:11',-1.345,$a,$a,$a,$a);
dec $loop;
}
--enable_result_log
--enable_query_log

select sum(length(i2)), sum(length(i7)), sum(length(i8)), sum(length(i9)), sum(length(i10)) from test;

explain select /*+index(test gkey)*/ * from test;

select /*+index(test gkey)*/ SQL_CALC_FOUND_ROWS * from test limit 0;

select found_rows();

--source mysql_test/include/bigvarchar_64K.inc

create table test1 (i1 int, i2 longtext,i4 float, i5 datetime(6),i6 decimal(5,3),i7 longtext,i8 longtext,i9 longtext,i10 longtext, primary key(i1)) COMPRESSION = 'none' partition by hash(i1) partitions 2;
create index gkey on test1(i1,i5) global partition by hash(i1) partitions 2;
--source mysql_test/include/check_all_idx_ok.inc
--disable_query_log
--disable_result_log
## hash分布，
--let $loop=2002
while  ($loop)
{
#bug 6626386
eval insert into test1 values($loop, $a, $loop,'2014-10-01 00:12:11',-1.345,$a,$a,$a,$a);
dec $loop;
}
--enable_result_log
--enable_query_log

select sum(length(i2)), sum(length(i7)), sum(length(i8)), sum(length(i9)), sum(length(i10)) from test1;

explain select /*+index(test gkey)*/ * from test1;

select /*+index(test gkey)*/ SQL_CALC_FOUND_ROWS * from test1 limit 0;

select found_rows();

explain select /*+index(test1 gkey)*/ SQL_CALC_FOUND_ROWS * from test1
where
(i4 > 2 and i4 < 100) or
(i4 > 102 and i4 < 200) or
(i4 > 202 and i4 < 300) or
(i4 > 302 and i4 < 400) or
(i4 > 402 and i4 < 500) or
(i4 > 502 and i4 < 600) or
(i4 > 602 and i4 < 700) or
(i4 > 702 and i4 < 800) or
(i4 > 802 and i4 < 900) or
(i4 > 902 and i4 < 1000) or
(i4 > 1002 and i4 < 1100) or
(i4 > 1102 and i4 < 1200) or
(i4 > 1202 and i4 < 1300) or
(i4 > 1302 and i4 < 1400) or
(i4 > 1402 and i4 < 1500) or
(i4 > 1502 and i4 < 1600) or
(i4 > 1602 and i4 < 1700) or
(i4 > 1702 and i4 < 1800) or
(i4 > 1802 and i4 < 1900) or
(i4 > 1902 and i4 < 2003) limit 0;

select /*+index(test1 gkey)*/ SQL_CALC_FOUND_ROWS * from test1
where
(i4 > 2 and i4 < 100) or
(i4 > 102 and i4 < 200) or
(i4 > 202 and i4 < 300) or
(i4 > 302 and i4 < 400) or
