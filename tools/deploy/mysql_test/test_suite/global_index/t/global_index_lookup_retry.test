(i4 > 1502 and i4 < 1600) or
(i4 > 1602 and i4 < 1700) or
(i4 > 1702 and i4 < 1800) or
(i4 > 1802 and i4 < 1900) or
(i4 > 1902 and i4 < 2003) limit 0;

select found_rows();

