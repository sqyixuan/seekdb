--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yuchen.wyc
#owner group: sql1
# tags: optimizer, dml, global_index
#this file try to test select statement from global index

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
drop database if exists global_index;
--enable_warnings
create database global_index;
use global_index;
let $tenant_id = query_get_value(select effective_tenant_id() x from DUAL, x, 1);

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;
create table das_t1(a int primary key, b int, c int) partition by hash(a) partitions 1;
create index idx on das_t1(b) global;
insert into das_t1 values(1, 1, 1);
select * from das_t1;
update das_t1 set b=2 where a=1;
select * from das_t1;
update das_t1 set a=2 where a=1;
select * from das_t1;
delete from das_t1 where a=2;
select * from das_t1;
insert into das_t1 values(1, 1, 1);
connection conn_admin;
let $das_tid = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'das_t1', table_id, 1); 
let $idx_tid = query_get_value(select table_id from oceanbase.__all_virtual_table where data_table_id = $das_tid, table_id, 1); 
let $idx_ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_tablet_to_ls where table_id = $idx_tid, ls_id, 1); 
let $idx_follower_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_ls_meta_table where ls_id = $idx_ls_id and role = 2 and tenant_id = $tenant_id, svr_ip, 1);
let $idx_follower_port = query_get_value(select svr_port from oceanbase.__all_virtual_ls_meta_table where ls_id = $idx_ls_id and role = 2 and tenant_id = $tenant_id, svr_port, 1);
--disable_query_log
#eval alter system switch replica leader ls=$idx_ls_id server='$idx_follower_ip:$idx_follower_port' tenant='mysql';
--enable_query_log
--sleep 10
connection default;
select /*+index(das_t1 idx)*/ * from das_t1 where b=1;
drop table das_t1;

create table das_t1(a int primary key, b int, c int) partition by hash(a) partitions 2;
create unique index idx on das_t1(b) global;
insert into das_t1 values(1, 1, 1);
--error 1062
insert into das_t1 values(2, 1, 1);
insert into das_t1 values(2, 2, 1);
--error 1062
update das_t1 set b=1 where a=2; 
update das_t1 set a=3 where a=2;
update das_t1 set b=3 where a=3;
select * from das_t1 partition(p0);
select * from das_t1 partition(p1);
delete from das_t1 where a=3;
select * from das_t1 where a=3;
select * from das_t1 where b=3;
drop table das_t1;

connection default;
--explain_protocol 1
create table t1(a int primary key, b int, c int) partition by hash(a) partitions 4;
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4);
create index i1 on t1(b) global partition by hash(b) partitions 4;
select /*+index(t1 i1)*/ * from t1;
select /*+index(t1 i1)*/ * from t1 where a=1;
select /*+index(t1 i1)*/ * from t1 where a=2;
select /*+index(t1 i1)*/ * from t1 where a>=2 and a<=3;
select /*+index(t1 i1)*/ * from t1 where a>4;
select /*+index(t1 i1)*/ * from t1 where b=1;
select /*+index(t1 i1)*/ * from t1 where b in (1, 2, 3);
select /*+index(t1 i1)*/ * from t1 where b>=2 and b<=3;
drop table t1;

#drop database global_index;
connection conn_admin;
alter tenant sys set primary_zone='zone1';
connection default;

create table t1(a int primary key, b int, c int) partition by hash(a) partitions 4;
create index i1 on t1(b) global partition by hash(b) partitions 4;
--disable_info
--disable_query_log
--let $count = 1
while($count <= 10000)
{
  --let $stmt=insert into t1(a, b, c) values ($count, $count+1, $count+2)
  eval $stmt;
  inc $count;
}
--enable_query_log

create table t2(a int primary key, b int, c int) partition by hash(a) partitions 2;
create index i1 on t2(b) global;

--disable_query_log
--let $count = 1
while($count <= 10000)
{
  --let $stmt=insert into t2(a, b, c) values ($count, $count+1, $count+2)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info

connection conn_admin;
# insert a trace event to throw an error that das result buffer overflow, test send remaining result through DTL
alter system set_tp tp_no = 301, error_code = 1, frequency = 1;
connection default;
set session ob_query_timeout = 100000000;
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ t1.* from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b=t2.b order by t1.a limit 100;
connection conn_admin;
alter system set_tp tp_no = 301, error_code = 0, frequency = 1;
connection default;

select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ count(1) from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b=t2.b;
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ count(1) from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b=t2.b;
SET _NLJ_BATCHING_ENABLED=false;
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ t1.* from t1 join t2 where t1.b>2 and t1.b<10 and t1.b=t2.b order by t1.a;
SET _NLJ_BATCHING_ENABLED=true;
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ * from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b=t2.b order by t1.a, t2.a limit 100;
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ t1.a, t1.c, t2.a, t2.c from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b=t2.b order by t1.a, t2.a limit 100;

create index i2 on t1(b) global partition by key(b) partitions 17;
## enable parallel dml
set _force_parallel_dml_dop = 3;
delete /*+index(t1 i1)*/ from t1 where b = 1;
## enable parallel query
set _force_parallel_query_dop = 3;
select /*+index(t1 i1)*/ * from t1 where b>1 and b <10;
## enable parallel query through parallel hint
set _force_parallel_query_dop = 1;
select /*+index(t1 i1), parallel(3)*/ * from t1 where b>1 and b<10;
drop database global_index;
