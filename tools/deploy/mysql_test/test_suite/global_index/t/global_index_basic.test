CREATE TABLE `test5` (
    `c1` int(11) NOT NULL AUTO_INCREMENT,
    `c2` int(11) NOT NULL,
    `c3` int(255) DEFAULT NULL,
    `c4` int(11) DEFAULT NULL,
    `c5` varchar(100) DEFAULT '五百公里外的家很遥远',
    `c6` varchar(30) DEFAULT '五百公里外的家很遥远',
    `c7` char(100) DEFAULT '五百英里外的家贾斯汀timberlake3848',
    `c8` binary(100) DEFAULT '??????????timberlake3848',
    PRIMARY KEY (`c2`)
    ) AUTO_INCREMENT = 12000012 DEFAULT CHARSET = utf8mb4
partition by key(c2) partitions 2;
create index c1 on test5(`c1`, `c2`, `c3`) global;
--source mysql_test/include/check_all_idx_ok.inc
insert into test5 (c2) values (1);
--replace_column 1 auto_increment
select * from test5;
drop table test5;

--disable_warnings
drop table if exists bmsql_oorder;
--enable_warnings
CREATE TABLE `bmsql_oorder` (
  `o_w_id` int(11) NOT NULL,
  `o_d_id` int(11) NOT NULL,
  `o_id` int(11) NOT NULL,
  `o_c_id` int(11) DEFAULT NULL,
  `o_carrier_id` int(11) DEFAULT NULL,
  `o_ol_cnt` decimal(2,0) DEFAULT NULL,
  `o_all_local` decimal(1,0) DEFAULT NULL,
  `o_entry_d` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`o_w_id`, `o_d_id`, `o_id`),
  KEY `o_w_id` (`o_w_id`, `o_d_id`, `o_c_id`, `o_id`) GLOBAL,
  KEY `o_w_id_2` (`o_w_id`, `o_d_id`, `o_ol_cnt`) GLOBAL
) DEFAULT CHARSET = utf8mb4
 partition by hash(o_w_id) partitions 2;
insert into bmsql_oorder(o_w_id,o_d_id,o_id,o_c_id,o_carrier_id) values(36,7,1,169,1);
select /*+index(bmsql_oorder primary)*/ * from bmsql_oorder;
select /*+index(bmsql_oorder o_w_id)*/ `o_w_id`, `o_d_id`, `o_c_id`, `o_id` from bmsql_oorder;
select /*+index(bmsql_oorder o_w_id_2)*/ `o_w_id`, `o_d_id`, `o_ol_cnt`, `o_id` from bmsql_oorder;
drop table bmsql_oorder;

--disable_warnings
drop table if exists t25;
--enable_warnings
create table t25(a int, b int, c int, d int, primary key(a, b)) partition by hash(a) partitions 2;
create unique index uk_t25 on t25(a, c, d) global;
