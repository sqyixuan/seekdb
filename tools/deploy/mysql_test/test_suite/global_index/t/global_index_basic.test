insert into t22 values(1, 1, 1, now());
--replace_column 4 TIMESTAMP
select * from t22;
update t22 set b=2, c=1 where a=1;
--replace_column 3 TIMESTAMP
select /*+index(t22 primary)*/ a, c, d from t22;
--replace_column 3 TIMESTAMP
select /*+index(t22 idx)*/ a, c, d from t22;
update t22 set b=2, c=2 where a=1;
--replace_column 3 TIMESTAMP
select /*+index(t22 primary)*/ a, c, d from t22;
--replace_column 3 TIMESTAMP
select /*+index(t22 idx)*/ a, c, d from t22;
drop table t22;

insert into t23 values(1, 1, 1, now());
--replace_column 4 TIMESTAMP
select * from t23;
let $old_timestamp = query_get_value(select d from t23, d, 1);
insert into t23 values(1, 1, 1, now()) on duplicate key update b=1, c=1;
--replace_column 3 TIMESTAMP
select /*+index(t23 primary)*/ a, c, d from t23; 
--replace_column 3 TIMESTAMP
select /*+index(t23 idx)*/ a, c, d from t23;
let $new_timestamp = query_get_value(select d from t23, d, 1);
if ($old_timestamp != $new_timestamp)
{
  echo "error! timestamp is different!";
}
if ($old_timestamp == $new_timestamp)
{
  echo "OK! timestamp is the same";
}
insert into t23 values(1, 1, 1, now()) on duplicate key update b=2, c=1;
--replace_column 3 TIMESTAMP
select /*+index(t23 primary)*/ a, c, d from t23;
--replace_column 3 TIMESTAMP
select /*+index(t23 idx)*/ a, c, d from t23;
insert into t23 values(1, 1, 1, now()) on duplicate key update b=2, c=2;
--replace_column 3 TIMESTAMP
select /*+index(t23 primary)*/ a, c, d from t23;
--replace_column 3 TIMESTAMP
select /*+index(t23 idx)*/ a, c, d from t23;
drop table t23;

replace into t24 select * from t24;
insert into t24 select * from t24 on duplicate key update t24.c=1;
--sorted_result
select * from t24;
drop table t24;

select /*+index(t27 idx27_1)*/ * from t27 where c2 in (2,4,6,8,10,12);
select /*+index(t27 idx27_2)*/ * from t27 where c3 in ('0A','1B','2C');
update t27 set c2 = 10 where c2 = 9;
