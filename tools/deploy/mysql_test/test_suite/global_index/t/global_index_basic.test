select * from t16;
drop table t16, t17;

replace into t18 values(1, 2, 3);
--sorted_result
select * from t18;
drop table t18;

insert into t19 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 5, 5);
--sorted_result
select * from t19;
insert into t19 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 5, 5) on duplicate key update b=values(b);
--sorted_result
select * from t19;
drop table t19;

--sorted_result
select * from t20;
drop table t20;

insert into t21(b, c) values(1, 1), (2, 2), (3, 3);
--sleep 1
--replace_column 1 auto_increment
select * from t21;
insert into t21(b, c) values(1, 1), (2, 2), (3, 3), (4, 4) on duplicate key update b=values(b)+10;
--sleep 1
--replace_column 1 auto_increment
select * from t21;
replace into t21(b, c) values(1, 1), (2, 2), (3, 3), (4, 5);
--replace_column 1 auto_increment
select * from t21;
