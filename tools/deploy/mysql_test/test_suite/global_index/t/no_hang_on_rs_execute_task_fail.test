# owner: bin.lb
# owner group: sql2
# tags: global_index
# wakeup sql distribute scheduler when rs execute task fail

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system set_tp tp_no = 53, error_code = 1, frequency = 1;
--sleep 1

connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings
set ob_query_timeout = 200000000;
create table t1 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3)) partition by hash(c2) partitions 4;
send create index i1 on t1 (c4) global;

connection obsys;
--sleep 30
alter system set_tp tp_no = 53, error_code = 0, frequency = 0;

connection default;
reap;
