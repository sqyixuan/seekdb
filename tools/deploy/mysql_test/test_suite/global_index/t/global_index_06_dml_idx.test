--enable_sorted_result
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
#tags: optimizer
# owner group: SQL1
# description:
# tags: dml,global_index
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log
--result_format 4

create table t1 (c1 int, c2 int, c3 int,c4 int, primary key(c1,c2)) partition by hash(c2) partitions 2;
create index i1 on t1(c3) storing(c4) global;

insert into t1 values(1,1,1,1),(2,2,2,2);
insert into t1 values(3,100,100,100),(4,100,100,100);
insert into t1(c1,c2) values(5,100),(6,100);
insert into t1(c1,c2) values(6,200),(6,300);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1(c1,c2) values(7,100),(8,100);
select * from t1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;
let $idx = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1' and database_id = (select database_id from __all_virtual_database where database_name = 'test')) b on a.data_table_id=b.table_id, table_name, 1);
disconnect obsys;
connection default;
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from $idx;

#--error 1146 
#eval insert into $idx values(9,9,9,9);
eval select * from $idx where c1=1 and c2=1 and c3=1 for update;
--enable_query_log
select * from t1;
--disable_query_log
eval select * from $idx;
--enable_query_log

drop table t1;

create table t1 (c1 int primary key, c2 int, z1 datetime default now(), z2 datetime default now()) partition by hash(c1) partitions 2;

create index i1 on t1 (z1) global;
create index i2 on t1 (z2) global;

insert into t1 values(1, 1, '2020-02-04 00:00:00', '2020-02-04 01:00:30');
insert into t1 values(2, 2, '2020-02-04 01:00:00', '2020-02-04 02:00:30');

create index i3 on t1 (c2) storing (z1) global;
create index i4 on t1 (c2) storing (z2) global;
--explain_protocol 2
select /*+index(t1 primary)*/ * from t1;
select /*+index(t1 i1)*/ c1, z1 from t1;
select /*+index(t1 i2)*/ c1, z2 from t1;
select /*+index(t1 i3)*/ c1, c2, z1 from t1;
select /*+index(t1 i4)*/ c1, c2, z2 from t1;

drop table t1;

