select /*+index(t1 gkey)*/ * from t1 where (c,d,b) in ((1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5)) order by a,b,c,d;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b int, c int, d int, e int, primary key(a,b,c,d), key k1(b) local, key k2(c,b) local, key k3(c,d,b) local) partition by range(b+c) ( 
  partition p0 values less than (3),
  partition p1 values less than (5),
