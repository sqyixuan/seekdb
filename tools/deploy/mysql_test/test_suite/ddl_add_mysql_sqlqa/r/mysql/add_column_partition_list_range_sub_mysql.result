(5,1.4,4.2,'中!文','d',2,'2011-11-01','2004'),
(6,1.5,5.2,'中!文','e',1,'2014-01-11','2005'),
(7,1.6,6.2,'中!文','f',3,'2011-11-01','2006'),
(8,1.7,7.2,'中!文','g',1,'2017-01-11','2007'),
(9,1.8,8.2,'中!文','h',4,'2013-11-01','2011'),
(10,1.9,9.2,'中!文','i',5,'2011-11-11','2013'),
(11,2.0,1.9,'中!文','j',6,'2015-01-01','2016'),
