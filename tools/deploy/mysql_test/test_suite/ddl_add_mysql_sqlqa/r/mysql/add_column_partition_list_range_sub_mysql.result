#引用新增列并创建生成列
ALTER TABLE t1 ADD c9 INT DEFAULT 100,ADD c10 INT(5) ZEROFILL GENERATED ALWAYS AS (2*c9) STORED AFTER c0,DROP c2;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` int(11) DEFAULT NULL,
  `c10` int(5) unsigned zerofill GENERATED ALWAYS AS ((2 * `c9`)) STORED,
  `c1` float DEFAULT NULL,
  `c3` char(10) CHARACTER SET gb18030 COLLATE gb18030_bin DEFAULT NULL,
  `c4` varchar(10) GENERATED ALWAYS AS (UPPER(`c5`)) STORED COMMENT '字符串生成列',
  `c5` char(10) CHARACTER SET latin1 COLLATE latin1_bin DEFAULT NULL,
  `c6` int(11) DEFAULT NULL,
  `c7` date DEFAULT NULL,
  `c8` year(4) DEFAULT NULL,
  `c9` int(11) DEFAULT '100'
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(c4) subpartition by hash(c0) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`)
(partition `p1` values less than ('e'),
partition `p2` values less than ('j'),
partition `p3` values less than ('o'),
partition `p4` values less than (MAXVALUE))
