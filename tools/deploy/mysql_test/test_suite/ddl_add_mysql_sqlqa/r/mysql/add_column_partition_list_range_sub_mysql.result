#引用新增列并创建生成列
ALTER TABLE t1 ADD c9 INT DEFAULT 100,ADD c10 INT(5) ZEROFILL GENERATED ALWAYS AS (2*c9) STORED AFTER c0,DROP c2;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` int(11) DEFAULT NULL,
  `c10` int(5) unsigned zerofill GENERATED ALWAYS AS ((2 * `c9`)) STORED,
  `c1` float DEFAULT NULL,
  `c3` char(10) CHARACTER SET gb18030 COLLATE gb18030_bin DEFAULT NULL,
  `c4` varchar(10) GENERATED ALWAYS AS (UPPER(`c5`)) STORED COMMENT '字符串生成列',
