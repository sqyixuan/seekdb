c2 DOUBLE AUTO_INCREMENT PRIMARY KEY,
c3 BIT(20) DEFAULT 0,
c4 BLOB,
c5 TEXT,
c6 VARCHAR(50) UNIQUE,
c7 CHAR(50),
c8 BINARY(50) NOT NULL,
c9 VARBINARY(50) NOT NULL,
c10 ENUM('a','b','c','d','e','f','g','h'),
c11 SET('i','j','k','l','m','n','o','p'),
c12 TIME NOT NULL,
c13 DATE NOT NULL,
c14 DATETIME NOT NULL,
c15 TIMESTAMP NOT NULL,
c16 YEAR ,CHECK(c16>=2000));
