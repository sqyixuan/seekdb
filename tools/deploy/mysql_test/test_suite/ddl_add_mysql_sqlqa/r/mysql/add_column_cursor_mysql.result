t1	CREATE TEMPORARY TABLE `t1` (
  `c0` int(5) unsigned zerofill DEFAULT NULL,
  `c1` char(50) DEFAULT NULL,
  `c2` varchar(50) NOT NULL,
  `c3` blob DEFAULT NULL,
  `c4` enum('A','B','D','E') DEFAULT NULL,
  `c5` date DEFAULT NULL,
  `c6` varchar(100) GENERATED ALWAYS AS (CONCAT(`c1`,`c2`)) VIRTUAL COMMENT '字符串生成列',
  `c7` int(11) DEFAULT '0'
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
