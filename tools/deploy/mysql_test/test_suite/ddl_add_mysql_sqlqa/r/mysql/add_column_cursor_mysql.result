#创建唯一约束、默认值约束，并执行alter table
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1 (c0 INT(5) ZEROFILL,
c1 CHAR(50) DEFAULT 'ABC',
c2 VARCHAR(50),CHECK(c2 <> c4),
c3 BLOB,
c4 ENUM('A','B','D','E'),
c5 DATE);
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
1000
#创建临时表，添加外键约束
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1 (c0 INT(5) PRIMARY KEY,
c1 BINARY(50),
c2 VARBINARY(50),
c3 TEXT,
c4 SET('A','B','D','E'),
c5 DATETIME);
CALL p1();
DROP TEMPORARY TABLE IF EXISTS t2;
CREATE TEMPORARY TABLE t2 (c0 INT(5),
c1 BINARY(10),
c2 VARBINARY(10),
c3 TEXT,
c4 SET('A','B','D','E'),
c5 DATETIME);
INSERT INTO t2 VALUES(1,'A','A','A','A','2000-01-01 00:00:01'),
(2,'B','B','B','B','2001-01-01 00:00:01'),
(3,'C','C','C','B','2002-01-01 00:00:01'),
(4,'D','D','D','D','2003-01-01 00:00:01'),
(5,'E','E','E','E','2004-01-01 00:00:01');
DROP PROCEDURE p1;
DROP TEMPORARY TABLE IF EXISTS t2;
DROP TEMPORARY TABLE IF EXISTS t1;
