purge recyclebin;
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
#mysql_add-2
#mysql_add-2-1/mysql_add-2-2
#CREATE DATA (DATA TYPE + INDEX + CONSTRAINT)
CREATE TABLE t1(c0 INT(4) ZEROFILL,
c1 FLOAT ,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 VARCHAR(10) UNIQUE,
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR ,CHECK(c8>=c0));
