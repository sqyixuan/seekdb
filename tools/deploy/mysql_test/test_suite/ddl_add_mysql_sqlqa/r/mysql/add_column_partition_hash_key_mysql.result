#新增列为其他新增列的引用列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT ,
c7 TIME,
c8 YEAR)
PARTITION BY HASH(c6)
