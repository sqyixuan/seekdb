DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT ,
c7 TIME,
c8 YEAR)
PARTITION BY KEY(c6)
(PARTITION p1,PARTITION p2,PARTITION p3,PARTITION p4);
