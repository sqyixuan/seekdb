#新增列为生成列
#STORED/VIRTUAL类型生成列,分区键为生成列的引用列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR GENERATED ALWAYS AS (c6*2) STORED COMMENT '数值生成列')
PARTITION BY HASH(c8) PARTITIONS 4;
