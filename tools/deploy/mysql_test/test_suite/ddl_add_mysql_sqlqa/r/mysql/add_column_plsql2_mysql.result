DROP PROCEDURE IF EXISTS pro4;
CREATE PROCEDURE pro4(IN v_c0 INT)
BEGIN
DECLARE a INT DEFAULT 1;
loop1: LOOP
INSERT INTO t1 SELECT t1.* FROM t1 LEFT JOIN t2 ON t1.c0 = t2.c0 WHERE
t2.c1 IN(SELECT c1 FROM t1 WHERE c0 > v_c0);COMMIT;
DELETE FROM t1 WHERE c0=a OR c0=v_c0+5;COMMIT;
IF a = 3 THEN
LEAVE loop1;
END IF;
SET a = a + 1;
END LOOP;
END;
