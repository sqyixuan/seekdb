DROP PROCEDURE IF EXISTS pro3;
CREATE PROCEDURE pro3(IN v_c0 INT)
BEGIN
DECLARE a INT DEFAULT 1;
wh1:WHILE a <=1 DO
INSERT INTO t1 SELECT t1.* FROM t1 RIGHT JOIN t2 ON t1.c0 = t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0);COMMIT;
DELETE FROM t1 WHERE c1 NOT IN(SELECT t2.c1 FROM t2 WHERE c1 IN(SELECT c1 FROM t1 WHERE c0 < v_c0));COMMIT;
SET a = a + 1;
END WHILE wh1;
END;
