DROP PROCEDURE IF EXISTS pro2;
CREATE PROCEDURE pro2(IN v_c0 INT)
BEGIN
IF v_c0 <= 5 THEN
INSERT INTO t1
WITH
s1 AS (SELECT t2.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t1 WHERE c0 > v_c0)),
s2 AS (SELECT t1.* FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN(SELECT c1 FROM t1 WHERE c0 < v_c0))
SELECT s2.* FROM s1 ,s2 WHERE s2.c1 NOT IN(SELECT c1 FROM s1);
ELSEIF v_c0 <= 10 THEN
UPDATE t1 SET c0=c0+5 WHERE c1 IN (SELECT t2.c1 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 >= v_c0));
ELSE
DELETE FROM t1 WHERE c0 <>ALL(SELECT t2.c0 FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN(SELECT c1 FROM t1 WHERE t1.c0 < v_c0));
END IF;
END;
