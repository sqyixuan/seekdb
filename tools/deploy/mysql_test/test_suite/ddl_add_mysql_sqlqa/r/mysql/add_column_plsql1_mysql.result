#DELETE型触发器
DROP TRIGGER IF EXISTS trg_delete;
CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
ALTER TABLE t1 ADD c9 INT;
END
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
#UPDATE型触发器
DROP TRIGGER IF EXISTS trg_update;
//
CREATE TRIGGER trg_update AFTER UPDATE ON t2
FOR EACH ROW
BEGIN
ALTER TABLE t1 ADD c9 INT;
END
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
#INSERT型触发器
DROP TRIGGER IF EXISTS trg_insert;
//
CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
ALTER TABLE t1 ADD c9 INT;
END
//
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
