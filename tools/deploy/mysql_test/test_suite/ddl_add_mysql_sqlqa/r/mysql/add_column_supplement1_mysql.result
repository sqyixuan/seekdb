#表中无生成列，新增列为生成列并加上唯一约束，然后执行DML操作
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 CHAR(10),
c5 INT,
c6 TIME);
