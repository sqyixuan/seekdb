#在生成列上创建全局/局部索引,然后创建新增列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
c5 INT AS (c0*2) STORED COMMENT '数值生成列',
c6 TIME);
