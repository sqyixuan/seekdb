CREATE INDEX global_ind ON t1(c5) GLOBAL
PARTITION BY LIST(c5)
(PARTITION p1 VALUES IN('A','B','C','D','E'),
PARTITION p2 VALUES IN('F','G','H','I','G'),
PARTITION p3 VALUES IN('K','L','M','N','O')
);
