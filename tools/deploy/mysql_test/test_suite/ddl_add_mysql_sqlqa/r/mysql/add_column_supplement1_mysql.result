#创建新增列为生成列，然后在新增列上创建全局/局部索引,最后执行DML操作
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 TIME);
