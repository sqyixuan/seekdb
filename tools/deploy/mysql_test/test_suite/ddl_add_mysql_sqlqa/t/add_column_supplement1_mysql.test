--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


--disable_warnings

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;


--echo #已有外键约束，新增列后执行DML操作

CREATE TABLE t1(c0 INT(4) PRIMARY KEY,
                c1 FLOAT UNIQUE,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 CHAR(10),
                c5 INT,
                c6 TIME);
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',1,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',1,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',1,'11:11:11');

--echo #外键带有ON UPDATE引用行为

--echo #ON UPDATE CASCADE

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT UNIQUE,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 CHAR(10),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0) ON UPDATE CASCADE);
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',1,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',1,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',1,'11:11:11');

ALTER TABLE t1 ADD c7 INT AFTER c0;
sleep 2;
ALTER TABLE t2 ADD c7 INT AFTER c0;
sleep 2;
##SHOW CREATE TABLE t1;
##SHOW CREATE TABLE t2;


