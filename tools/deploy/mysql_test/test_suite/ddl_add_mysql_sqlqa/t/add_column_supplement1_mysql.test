--echo #表中创建生成列并加上唯一约束，然后新增列后执行DML操作

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(3),
                c1 FLOAT,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列' UNIQUE,
                c5 INT AS (c0*2) STORED COMMENT '数值生成列' UNIQUE,
                c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
                     (2,1.1,1.2,'a','11:11:11'),
                     (3,1.2,2.2,'b','11:11:11'),
                     (4,1.3,3.2,'c','11:11:11'),
                     (5,1.4,4.2,'d','11:11:11');

ALTER TABLE t1 ADD c7 VARCHAR(50) AFTER c4;
sleep 2;
#SHOW CREATE TABLE t1;

