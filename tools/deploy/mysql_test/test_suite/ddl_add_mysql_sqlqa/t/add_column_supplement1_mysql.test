INSERT INTO t1(c0,c1,c2,c3,c6,c7) VALUES(6,1.5,5.2,'e','12:12:12','test1');
SELECT * FROM t1 ORDER BY 1;

UPDATE t1 SET c0=10,c3='f' WHERE c4='A' AND c5=4;
SELECT * FROM t1 ORDER BY 1;
                     
DELETE FROM t1 WHERE c4='F' AND c5=20;
SELECT * FROM t1 ORDER BY 1;


