--echo #修改列属性及顺序后使用函数


ALTER TABLE t1 ADD c10 INT(4) ZEROFILL AS (2*c6) AFTER c0;
sleep 2;
##SHOW CREATE TABLE t1;

#运算符

SELECT MOD(c10,2) 'c10列取余', 2*c10 'c10列的2倍值', c10 DIV(2) 'c10列的商数' FROM t1 ORDER BY 1,2,3;

SELECT c10 FROM t1 WHERE c10>3 AND c10 IN(4,6) ORDER BY 1;

SELECT @var1 := MIN(c10) 'c10列赋值给变量var1' FROM t1;


#聚合函数

SELECT AVG(c10) 'c10列平均值',MAX(c10) 'C6列最大值',SUM(c10) 'c10列合计值' FROM t1;


#时间函数

SELECT TIME(c10) 'c10列使用时间函数1',YEAR(c10) 'c10列使用时间函数2',HOUR(c10) 'c10列使用时间函数3' FROM t1 ORDER BY 1;


#字符串函数

SELECT BIN(c10),ASCII(c10),CONCAT(c10,c5) FROM t1 ORDER BY 1,2,3;


#比较函数

SELECT GREATEST(c10,c0) FROM t1 ORDER BY 1;


#流程控制函数

SELECT CASE 1000*c10 WHEN 1000*c10 > 5000 THEN 'A' ELSE 'B' END FROM t1 ORDER BY 1;


#加密函数

SELECT MD5(c10) 'c10列加密' FROM t1 ORDER BY 1;


#信息函数

SELECT CHARSET(c10) FROM t1;


#其他函数

SELECT ANY_VALUE(c10) FROM t1 GROUP BY c3 ORDER BY 1;


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

--enable_warnings


