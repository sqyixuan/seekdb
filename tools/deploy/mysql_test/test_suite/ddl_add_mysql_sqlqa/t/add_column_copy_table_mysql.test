--echo #生成列
--echo #mysql_add-2-3

DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t3;
DROP TABLE IF EXISTS t2;

CREATE TABLE t1(c0 INT(3),
                c1 FLOAT,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 CHAR(10) GENERATED ALWAYS AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
                c5 INT GENERATED ALWAYS AS (c0*2) STORED COMMENT '数值生成列',
                c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
                     (2,1.1,1.2,'a','11:11:11'),
                     (3,1.2,2.2,'b','11:11:11'),
                     (4,1.3,3.2,'c','11:11:11'),
                     (5,1.4,4.2,'d','11:11:11');

--echo #使用as关键字创建复制表

CREATE TABLE t3 AS SELECT * FROM t1;
SELECT * FROM t3 ORDER BY c0;
#SHOW CREATE TABLE t3;

#引用普通列创建生成列
ALTER TABLE t3 ADD c7 INT GENERATED ALWAYS AS (2*c0);
#SHOW CREATE TABLE t3;
SELECT c7 FROM t3 ORDER BY 1;

#引用生成列创建生成列
ALTER TABLE t3 ADD c8 INT GENERATED ALWAYS AS (2*c5);
#SHOW CREATE TABLE t3;
SELECT c8 FROM t3 ORDER BY 1;

ALTER TABLE t3 DROP c7,DROP c8;
#SHOW CREATE TABLE t3;

#暂不支持
#ALTER TABLE t3 ADD c7 INT GENERATED ALWAYS AS (2*c0),ADD c8 INT GENERATED ALWAYS AS (2*c7);
##SHOW CREATE TABLE t3;
--error 0, 0,1091
ALTER TABLE t3 DROP c8;
--error 0, 0,1091
ALTER TABLE t3 DROP c7;
#SHOW CREATE TABLE t3;

#删除引用列并创建生成列
--error 1054
ALTER TABLE t3 DROP c0,ADD c7 INT GENERATED ALWAYS AS (2*c0);
#SHOW CREATE TABLE t3;

#修改引用列并创建生成列

#暂不支持
#ALTER TABLE t3 CHANGE c0 c0 VARCHAR(10),ADD c7 INT GENERATED ALWAYS AS (2*c0);
##SHOW CREATE TABLE t3;

--error 0, 0,1091
ALTER TABLE t3 DROP c7;
#SHOW CREATE TABLE t3;

#新增列并引用新增列创建生成列

ALTER TABLE t3 ADD c7 VARCHAR(10),ADD c8 BINARY(10) GENERATED ALWAYS AS (UPPER(c7));
#SHOW CREATE TABLE t3;

