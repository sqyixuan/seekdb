--echo #创建复制表并新增所有列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(4) ZEROFILL,
                c1 FLOAT AUTO_INCREMENT PRIMARY KEY,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=c0));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中-文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中=文','B','a',1,'11:11:11','2002'),
                     (4,1.3,3.2,'中+文','C','a',1,'11:11:11','2003'),
                     (5,1.4,4.2,'中0文','D','a',1,'11:11:11','2004'),
                     (6,1.5,5.2,'中9文','E','a',1,'11:11:11','2005'),
                     (7,1.6,6.2,'中8文','F','a',1,'11:11:11','2006'),
                     (8,1.7,7.2,'中7文','G','a',1,'11:11:11','2007'),
