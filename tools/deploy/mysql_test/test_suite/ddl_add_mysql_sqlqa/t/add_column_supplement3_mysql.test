--echo   #删除约束和主键   有数据表
--error 0,1051
drop table 工▓作簿1_csv;
CREATE table 工▓作簿1_csv (`♛工作簿2.txt` int PRIMARY key,
`⚽足球簿3_xlsx\0` int DEFAULT 1,
`工作┋簿ほ4\'.ppt\'` char(10) UNIQUE,
`工作ぁ簿 5 csv` TINYINT not null,
`工作&簿⑤15_txy` bigint not null);
insert into 工▓作簿1_csv values(6,1,'aaaa',55,789456123);
insert into 工▓作簿1_csv values(2,1,'cccc',44,111111111);
select  * from 工▓作簿1_csv;
desc 工▓作簿1_csv;
Alter table 工▓作簿1_csv change `♛工作簿2.txt` `♛工作簿2.txt` int;
sleep 2;
Alter table 工▓作簿1_csv drop primary key;
desc 工▓作簿1_csv;
ALTER TABLE 工▓作簿1_csv MODIFY `⚽足球簿3_xlsx\0` int;
sleep 2; 
desc 工▓作簿1_csv;
ALTER TABLE 工▓作簿1_csv DROP INDEX `工作┋簿ほ4\'.ppt\'`;
sleep 2; 
desc 工▓作簿1_csv;					
ALTER TABLE 工▓作簿1_csv MODIFY `工作ぁ簿 5 csv` TINYINT null;
sleep 2; 
desc 工▓作簿1_csv;
drop table 工▓作簿1_csv;





