                     (4,1.3,3.2,'中!文','a',1,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',1,'11:11:11');


--echo #创建trigger后，删除引用列，然后触发trigger执行


--echo #insert型触发器


DROP TRIGGER IF EXISTS trg_insert;


DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE a VARCHAR(10);
    SET a=CONCAT(NEW.c4,'A');
    INSERT INTO t1(c0,c1,c2,c4,c5,c6,c7,c8) VALUES(NEW.c0+10,NEW.c1,NEW.c2,a,NEW.c5,NEW.c6,'12:12:12','2020');
END
//

DELIMITER ;//

--echo #新增列

ALTER TABLE t2 ADD c7 INT(5) ZEROFILL AFTER c5;
sleep 2;
#SHOW CREATE TABLE t2;

INSERT INTO t2 VALUES(6,1.5,5.2,'中￥文','a',1,0,'10:10:10');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


ALTER TABLE t1 ADD c9 VARCHAR(10);
sleep 2;
#SHOW CREATE TABLE t1;

INSERT INTO t2 VALUES(7,1.6,5.3,'中0文','b',2,1,'12:12:12');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

ALTER TABLE t1 ADD c10 CHAR(10) NOT NULL;
sleep 2;
#SHOW CREATE TABLE t1;

--error 01364
INSERT INTO t2 VALUES(8,1.7,5.4,'中9文','c',3,2,'13:13:13');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #重新创建触发器
DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE a VARCHAR(10);
    SET a=CONCAT(NEW.c4,'A');
    INSERT INTO t1(c0,c1,c2,c4,c5,c6,c7,c8,c10) VALUES(NEW.c0+10,NEW.c1,0,a,NEW.c5,NEW.c6,'12:12:12','2020','test');
END
//

DELIMITER ;//

INSERT INTO t2 VALUES(8,1.7,5.4,'中9文','c',3,2,'13:13:13');
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #update型触发器

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT UNIQUE,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');

DROP TRIGGER IF EXISTS trg_update;

DELIMITER //;

CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
    UPDATE t1 SET c1=NEW.c1,c2=NEW.c2,c4=CONCAT(NEW.c4,'A'),c7=NEW.c6 WHERE c6=NEW.c5; 
END
//

DELIMITER ;//


--echo #新增列

ALTER TABLE t2 ADD c7 INT;
sleep 2;
#SHOW CREATE TABLE t2;
SELECT * FROM t1 ORDER BY 2;


UPDATE t2 SET c1=1.5,c2=5.2,c4='b',c5=1,c6='12:12:12',c7=0 WHERE c0=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;



ALTER TABLE t1 ADD c9 FLOAT GENERATED ALWAYS AS (3*c2) VIRTUAL;
#SHOW CREATE TABLE t1;

UPDATE t2 SET c1=2.5,c2=5.3,c4='c',c5=2,c6='22:22:22',c7=1 WHERE c0=2;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #delete型触发器

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');
                     
DROP TRIGGER IF EXISTS trg_delete;


DELIMITER //;

CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c1=OLD.c1 OR c2=OLD.c2;
END
//

DELIMITER ;//


--echo #新增列

ALTER TABLE t2 ADD c7 INT(5) ZEROFILL AFTER c5;
sleep 2;
#SHOW CREATE TABLE t2;

DELETE FROM t2 WHERE c3='中文';
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

ALTER TABLE t1 ADD c9 INT(5) DEFAULT 0;
sleep 2;
#SHOW CREATE TABLE t1;

DELETE FROM t2 WHERE c5=1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;


--echo #创建trigger时添加新增列，然后触发trigger执行

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR ,CHECK(c8>=2000));
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));

INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');

--echo #DELETE型触发器

DROP TRIGGER IF EXISTS trg_delete;

DELIMITER //;

--error 01422
CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    ALTER TABLE t1 ADD c9 INT;
END
//



--echo #UPDATE型触发器

DROP TRIGGER IF EXISTS trg_update;
//

--error 01422
CREATE TRIGGER trg_update AFTER UPDATE ON t2
FOR EACH ROW
BEGIN
    ALTER TABLE t1 ADD c9 INT;
END
//



--echo #INSERT型触发器

DROP TRIGGER IF EXISTS trg_insert;
//

--error 0,1422
CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    ALTER TABLE t1 ADD c9 INT;
END
//

DELIMITER ;//


DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

