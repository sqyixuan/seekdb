--echo #新增列带有自增约束

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
                c1 FLOAT DEFAULT 0,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR NOT NULL)
PARTITION BY HASH(c0) PARTITIONS 2;

