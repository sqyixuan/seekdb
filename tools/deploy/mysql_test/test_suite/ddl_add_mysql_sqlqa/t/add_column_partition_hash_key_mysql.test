                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY HASH(c8)
(PARTITION p1,PARTITION p2,PARTITION p3);

