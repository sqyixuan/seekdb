                     (1.4,4.2,'中$文','D','a',1004,'11:11:11',2004),
                     (1.5,5.2,'中%文','E','a',1005,'11:11:11',2005),
                     (1.6,6.2,'中^文','F','a',1006,'11:11:11',2006),
                     (1.7,7.2,'中&文','G','a',1000,'11:11:11',2007),
                     (1.8,8.2,'中*文','H','a',1001,'11:11:11',2008),
                     (1.9,9.2,'中-文','I','a',1002,'11:11:11',2009),
