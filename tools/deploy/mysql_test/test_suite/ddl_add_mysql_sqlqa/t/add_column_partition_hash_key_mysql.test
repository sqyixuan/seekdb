#description: 新增列--创建不同分区类型的表，带有约束/索引/不同数据类型/生成列等，然后执行alter table语法进行add操作
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;

--echo #mysql_add-3
--echo #mysql_add-3-1/mysql_add-3-2/mysql_add-3-3


--echo ######################PARTITION BY HASH########################

--echo #普通哈希分区表

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY HASH(c8) PARTITIONS 3;

INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'2010-10-11','1989'),
                     (2,1.1,1.2,'中!文','A','a',1,'2001-01-11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'2016-02-11','2002'),
                     (4,1.3,3.2,'中!文','C','a',1,'2021-03-11','2003'),
                     (5,1.4,4.2,'中!文','D','a',2,'2011-11-01','2004'),
                     (6,1.5,5.2,'中!文','E','a',1,'2014-01-11','2005'),
                     (7,1.6,6.2,'中!文','F','a',3,'2011-11-01','2006'),
                     (8,1.7,7.2,'中!文','G','a',1,'2017-01-11','2007'),
                     (9,1.8,8.2,'中!文','H','a',4,'2013-11-01','2011'),
                     (10,1.9,9.2,'中!文','I','a',5,'2011-11-11','2013'),
                     (11,2.0,1.9,'中!文','J','a',6,'2015-01-01','2016'),
                     (12,2.1,1.8,'中!文','K','a',7,'2012-12-11','2016');

ALTER TABLE t1 ADD c9 INT DEFAULT 0 AFTER c6;
#SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1;

ALTER TABLE t1 ADD c10 INT(4) ZEROFILL AFTER c0,ADD c11 FLOAT(5,0) AFTER c1,ADD c12 TIMESTAMP DEFAULT '2000-01-01 00:00:00';
#SHOW CREATE TABLE t1;
SELECT * FROM t1 ORDER BY 1;


UPDATE t1 SET c8=2000 WHERE c8=2016;
INSERT INTO t1(c0,c10,c1,c2,c3,c4,c5,c6,c7,c8) VALUES(13,0,2.2,1.7,'中!文','L','a',7,'2012-12-11','2016');
SELECT * FROM t1 WHERE c0=13;


--echo #新增列与其他操作混用情景


