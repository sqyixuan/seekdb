--echo #新增列为生成列

--echo #STORED/VIRTUAL类型生成列,分区键为生成列的引用列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR GENERATED ALWAYS AS (c6*2) STORED COMMENT '数值生成列')
PARTITION BY HASH(c8) PARTITIONS 4;

INSERT INTO t1(c0,c1,c2,c3,c4,c5,c6,c7) VALUES(1,1.0,1.1,'中文','','',1000,'11:11:11'),
                     (2,1.1,1.2,'中!文','A','a',1001,'11:11:11'),
                     (3,1.2,2.2,'中@文','B','a',1002,'11:11:11'),
                     (4,1.3,3.2,'中_文','C','a',1003,'11:11:11'),
                     (5,1.4,4.2,'中$文','D','a',1004,'11:11:11'),
                     (6,1.5,5.2,'中%文','E','a',1005,'11:11:11'),
                     (7,1.6,6.2,'中^文','F','a',1006,'11:11:11'),
                     (8,1.7,7.2,'中&文','G','a',1000,'11:11:11'),
                     (9,1.8,8.2,'中*文','H','a',1001,'11:11:11'),
                     (10,1.9,9.2,'中-文','I','a',1002,'11:11:11'),
                     (11,2.0,1.9,'中=文','J','a',1003,'11:11:11'),
                     (12,2.1,1.8,'中+文','K','a',1004,'11:11:11');

#ob暂不支持，待支持后执行

--disable_parsing

ALTER TABLE t1 ADD c9 INT AS (2*c8) STORED COMMENT '数值生成列',DROP c1,CHANGE c2 c2 DOUBLE(5,0) NOT NULL;
#SHOW CREATE TABLE t1;

INSERT INTO t1(c0,c2,c3,c4,c5,c6,c7) VALUES(13,1.7,'中+文','L','a',1007,'11:11:11');
SELECT * FROM t1 ORDER BY 1;

--enable_parsing


--echo #新增列为其他新增列的引用列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT ,
                c7 TIME,
                c8 YEAR)
PARTITION BY HASH(c6)
(PARTITION p1,PARTITION p2,PARTITION p3,PARTITION p4);

INSERT INTO t1(c1,c2,c3,c4,c5,c6,c7,c8) VALUES(1.0,1.1,'中文','','',1000,'11:11:11',2000),
                     (1.1,1.2,'中!文','A','a',1001,'11:11:11',2001),
