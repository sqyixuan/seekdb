ALTER TABLE t1 ADD c9 INT ,ADD c10 INT AS (2*c9) VIRTUAL COMMENT '数值生成列',DROP c1,CHANGE c2 c2 DOUBLE(5,0) NOT NULL,ADD INDEX ind_1(c9,c6);
#SHOW CREATE TABLE t1;

