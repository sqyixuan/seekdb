                     (4,1.3,3.2,'中!文','C','a',1,'2021-03-11','2003'),
                     (5,1.4,4.2,'中!文','D','a',2,'2011-11-01','2004'),
                     (6,1.5,5.2,'中!文','E','a',1,'2014-01-11','2005'),
                     (7,1.6,6.2,'中!文','F','a',3,'2011-11-01','2006'),
                     (8,1.7,7.2,'中!文','G','a',1,'2017-01-11','2007'),
                     (9,1.8,8.2,'中!文','H','a',4,'2013-11-01','2011'),
