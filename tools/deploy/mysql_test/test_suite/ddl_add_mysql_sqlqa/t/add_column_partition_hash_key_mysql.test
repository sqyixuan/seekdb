--enable_parsing



--echo #######################PARTITION BY KEY#########################



--echo #普通KEY分区表

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY KEY(c8) PARTITIONS 3;

