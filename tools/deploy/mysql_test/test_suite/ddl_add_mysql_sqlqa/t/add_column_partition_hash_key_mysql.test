                     (12,2.1,1.8,'中!文','K','a',7,'2012-12-11','2016');

ALTER TABLE t1 ADD c9 INT(5) ZEROFILL DEFAULT 0 FIRST;
#SHOW CREATE TABLE t1;

--echo #使用新增列创建全局分区索引
--error 01235
CREATE INDEX ind_g ON t1(c8,c9) GLOBAL
PARTITION BY RANGE(c9)
(PARTITION p1 VALUES LESS THAN(4),
 PARTITION p2 VALUES LESS THAN(8),
 PARTITION p3 VALUES LESS THAN(10),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

CREATE INDEX ind_g ON t1(c8,c9) GLOBAL
PARTITION BY RANGE(c8)
(PARTITION p1 VALUES LESS THAN(4),
 PARTITION p2 VALUES LESS THAN(8),
 PARTITION p3 VALUES LESS THAN(10),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
#SHOW CREATE TABLE t1;


