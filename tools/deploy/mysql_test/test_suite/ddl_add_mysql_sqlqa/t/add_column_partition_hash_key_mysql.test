--echo #新增列带有默认值约束

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT NOT NULL,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR DEFAULT 2022)
PARTITION BY HASH(c8) PARTITIONS 4;

