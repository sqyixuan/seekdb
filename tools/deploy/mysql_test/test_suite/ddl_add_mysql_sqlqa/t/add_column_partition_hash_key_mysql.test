--disable_parsing

--error 01235
ALTER TABLE t1 ADD c13 INT NOT NULL,DROP c8,CHANGE c10 c10 VARCHAR(10);
#SHOW CREATE TABLE t1;

ALTER TABLE t1 ADD c13 INT NOT NULL,CHANGE c1 c1 FLOAT(5,0),ADD INDEX ind_1(c2),DROP c9;
#SHOW CREATE TABLE t1;

ALTER TABLE t1 ADD c14 SET('A','B','C'),PARALLEL 4;
#SHOW CREATE TABLE t1;

--error 01064
ALTER TABLE t1 ADD c15 VARCHAR(10),ADD PARTITION(PARTITION BY HASH(c8) PARTITIONS 4);
#SHOW CREATE TABLE t1;

ALTER TABLE t1 ADD c15 VARCHAR(10),DROP INDEX ind_1,CHANGE c6 c6 INT(4) ZEROFILL,DROP c3,ADD c16 INT FIRST;
#SHOW CREATE TABLE t1;

