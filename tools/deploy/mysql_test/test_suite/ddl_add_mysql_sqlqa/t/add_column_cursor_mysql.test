--echo #创建临时表，添加外键约束

DROP TEMPORARY TABLE IF EXISTS t1;

CREATE TEMPORARY TABLE t1 (c0 INT(5) PRIMARY KEY,
                           c1 BINARY(50),
                           c2 VARBINARY(50),
                           c3 TEXT,
                           c4 SET('A','B','D','E'),
                           c5 DATETIME);

CALL p1();

DROP TEMPORARY TABLE IF EXISTS t2;

CREATE TEMPORARY TABLE t2 (c0 INT(5),
                           c1 BINARY(10),
                           c2 VARBINARY(10),
                           c3 TEXT,
                           c4 SET('A','B','D','E'),
                           c5 DATETIME);

