--echo #事务

--echo #设置自动提交为0
SET AUTOCOMMIT=0;


DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1(c0 INT(3),
                c1 FLOAT,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 CHAR(10) GENERATED ALWAYS AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
                c5 INT GENERATED ALWAYS AS (c0*2) STORED COMMENT '数值生成列',
                c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
                     (2,1.1,1.2,'a','11:11:11'),
                     (3,1.2,2.2,'b','11:11:11'),
                     (4,1.3,3.2,'c','11:11:11'),
                     (5,1.4,4.2,'d','11:11:11');
COMMIT;


BEGIN;
ALTER TABLE t1 ADD c7 INT;
ROLLBACK;
SHOW CREATE TABLE t1;

--error 01136
INSERT INTO t1 VALUES(8,1.5,4.1,'e','12:12:12');
SELECT * FROM t1 ORDER BY 1;


BEGIN;
SAVEPOINT s1;
ALTER TABLE t1 ADD c8 VARCHAR(10);
SAVEPOINT s2;
ALTER TABLE t1 ADD c9 FLOAT;
SAVEPOINT s3;
ALTER TABLE t1 ADD c10 DATE;

--error 01305
ROLLBACK TO s1;

SHOW CREATE TABLE t1;

--error 01136
INSERT INTO t1 VALUES(9,1.6,5.1,'f','21:21:21');
SELECT * FROM t1 ORDER BY 1;

--echo #设置自动提交为1
SET AUTOCOMMIT=1;


--echo #对表进行加锁后删除列
--echo #mysql_add-4-1-3

--echo #OB目前不支持对表的加锁操作，故先不测试。可以进行对行的加锁操作。

DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1(c0 INT(4),
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 CHAR(10),
                c5 INT,
                c6 TIME);
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',1,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',1,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',1,'11:11:11');

SELECT * FROM t1 ORDER BY c0;

--echo #对行加锁

SELECT * FROM t1 WHERE c0=1 FOR UPDATE;


ALTER TABLE t1 ADD COLUMN c7 INT;
SHOW CREATE TABLE t1;

--error 01136
INSERT INTO t1 VALUES(6,1.0,1.1,'中文','',0,'11:11:11');

INSERT INTO t1 VALUES(6,1.0,1.1,'中文','',0,'11:11:11',0);
SELECT * FROM t1 ORDER BY c0;


--echo #不支持在临时表中创建分区，故不测试


--echo #单sql执行新增列并修改及删除列


DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1(c0 INT(5) ZEROFILL,
                c1 FLOAT NOT NULL,
                c2 DOUBLE AUTO_INCREMENT PRIMARY KEY,
                c3 BIT(20) DEFAULT 0,
                c4 BLOB,
                c5 TEXT,
                c6 VARCHAR(50) UNIQUE,
                c7 CHAR(50),
                c8 BINARY(50) NOT NULL,
                c9 VARBINARY(50) NOT NULL,
                c10 ENUM('a','b','c','d','e','f','g','h'),
                c11 SET('i','j','k','l','m','n','o','p'),
                c12 TIME NOT NULL,
                c13 DATE NOT NULL,
                c14 DATETIME NOT NULL,
                c15 TIMESTAMP NOT NULL,
                c16 YEAR ,CHECK(c16>=2000));
