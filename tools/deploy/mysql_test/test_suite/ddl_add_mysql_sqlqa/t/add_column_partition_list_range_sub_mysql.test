                     (8,1.7,7.2,'中!文','G','a',1,'2017-01-11','2007'),
                     (9,1.8,8.2,'中!文','H','a',4,'2013-11-01','2011'),
                     (10,1.9,9.2,'中!文','I','a',5,'2011-11-11','2013'),
                     (11,2.0,1.9,'中!文','J','a',6,'2015-01-01','2016'),
                     (12,2.1,1.8,'中!文','K','a',7,'2012-12-11','2016');

CREATE INDEX ind_1 ON t1(c4);

ALTER TABLE t1 ADD c9 VARCHAR(10) CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_bin';
SHOW CREATE TABLE t1;

