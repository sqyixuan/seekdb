ALTER TABLE t1 ADD c12 CHAR(10) CHARACTER SET 'gbk' COLLATE 'gbk_bin' NOT NULL,ADD INDEX ind_6(c12,c1,c9),DROP INDEX ind_3;
SHOW CREATE TABLE t1;

--echo #新增列加分区索引

ALTER TABLE t1 ADD c13 TEXT NOT NULL AFTER c4;
SHOW CREATE TABLE t1;

--error 01167
CREATE INDEX ind_g ON t1(c4,c13) GLOBAL
PARTITION BY RANGE COLUMNS(c0)
(PARTITION p1 VALUES LESS THAN(4),
 PARTITION p2 VALUES LESS THAN(8),
 PARTITION p3 VALUES LESS THAN(10),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

--error 1267
ALTER TABLE t1 ADD c14 VARCHAR(100);
SHOW CREATE TABLE t1;

CREATE INDEX ind_g ON t1(c4,c14) GLOBAL
PARTITION BY RANGE COLUMNS(c4)
(PARTITION p1 VALUES LESS THAN('E'),
 PARTITION p2 VALUES LESS THAN('J'),
 PARTITION p3 VALUES LESS THAN('O'),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

SHOW CREATE TABLE t1;

