--echo #新增列并删除分区
--error 1064
ALTER TABLE t1 ADD c12 VARCHAR(10) CHARACTER SET 'binary' COLLATE 'binary' DEFAULT 'BB',DROP PARTITION p1;


--echo #新增列并新增分区
--error 1064
ALTER TABLE t1 ADD c12 VARCHAR(10) CHARACTER SET 'binary' COLLATE 'binary' DEFAULT 'BB',ADD PARTITION(PARTITION p6 VALUES IN('1','2','3','4','5','6'));

SHOW CREATE TABLE t1;


