#owner group: 技术部-存储
#description: 新增列--创建不同分区类型的表，带有约束/索引/不同数据类型/生成列等，然后执行alter table语法进行add操作
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log




--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;


--echo #mysql_add-3
--echo #mysql_add-3-1/mysql_add-3-2/mysql_add-3-3

--echo ########################PARTITION BY LIST COLUMN WITH SUBPARITIONS###############################


--echo #新增列带有指定字符集和字符序

CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c4 VARCHAR(10) CHARACTER SET 'utf16' COLLATE 'utf16_bin',
                c5 CHAR(10) CHARACTER SET 'gbk' COLLATE 'gbk_bin',
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY LIST COLUMNS(c4)
(PARTITION p1 VALUES IN('','A','B','C','D','E'),
 PARTITION p2 VALUES IN('F','G','H','I','J'),
 PARTITION p3 VALUES IN('K','L','M','N','O'),
 PARTITION p4 VALUES IN('P','Q','R','S','T'),
 PARTITION p5 VALUES IN('U','V','W','X','Y','Z')
);

INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'2010-10-11','1989'),
