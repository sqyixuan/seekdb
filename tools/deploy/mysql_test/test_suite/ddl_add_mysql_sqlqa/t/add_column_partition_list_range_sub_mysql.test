--echo #新增列为STORED/VIRTUAL型生成列


DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c4 VARCHAR(10) GENERATED ALWAYS AS (UPPER(c5)) STORED COMMENT '字符串生成列' ,
                c5 CHAR(10) CHARACTER SET 'latin1' COLLATE 'latin1_bin',
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE COLUMNS(c4)
SUBPARTITION BY HASH(c0) SUBPARTITIONS 3
(PARTITION p1 VALUES LESS THAN('e'),
 PARTITION p2 VALUES LESS THAN('j'),
 PARTITION p3 VALUES LESS THAN('o'),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

