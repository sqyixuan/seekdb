--echo #新增列为STORED/VIRTUAL型生成列


DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c4 VARCHAR(10) GENERATED ALWAYS AS (UPPER(c5)) STORED COMMENT '字符串生成列' ,
                c5 CHAR(10) CHARACTER SET 'latin1' COLLATE 'latin1_bin',
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY LIST COLUMNS(c4)
SUBPARTITION BY HASH(c0) SUBPARTITIONS 3
(PARTITION p1 VALUES IN('','A','B','C','D','E'),
 PARTITION p2 VALUES IN('F','G','H','I','J'),
 PARTITION p3 VALUES IN('K','L','M','N','O'),
 PARTITION p4 VALUES IN('P','Q','R','S','T'),
 PARTITION p5 VALUES IN('U','V','W','X','Y','Z')
);

INSERT INTO t1(c0,c1,c2,c3,c5,c6,c7,c8) VALUES(1,1.0,1.1,'中文','',0,'2010-10-11','1989'),
                     (2,1.1,1.2,'中!文','a',1,'2001-01-11','2001'),
                     (3,1.2,2.2,'中!文','b',2,'2016-02-11','2002'),
                     (4,1.3,3.2,'中!文','c',1,'2021-03-11','2003'),
                     (5,1.4,4.2,'中!文','d',2,'2011-11-01','2004'),
                     (6,1.5,5.2,'中!文','e',1,'2014-01-11','2005'),
                     (7,1.6,6.2,'中!文','f',3,'2011-11-01','2006'),
                     (8,1.7,7.2,'中!文','g',1,'2017-01-11','2007'),
                     (9,1.8,8.2,'中!文','h',4,'2013-11-01','2011'),
                     (10,1.9,9.2,'中!文','i',5,'2011-11-11','2013'),
                     (11,2.0,1.9,'中!文','j',6,'2015-01-01','2016'),
                     (12,2.1,1.8,'中!文','k',7,'2012-12-11','2016');

