#owner group: 技术部-存储
#description: 新增列--补充测试用例
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log



--disable_warnings


#设置sql_mode
SET sql_mode='PAD_CHAR_TO_FULL_LENGTH';


--echo #在普通表中测试禁用修剪后新增列，并校验。



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');



#新增不同类型多列


ALTER TABLE t1 ADD c3 CHAR(5) UNIQUE COMMENT '唯一约束列',ADD c4 BINARY(5) DEFAULT 'TEST' AFTER c2,ADD c5 VARCHAR(5) AFTER c1,ADD c6 INT(5) FIRST;
sleep 3;
#SHOW CREATE TABLE t1;

SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t1 ORDER BY 1;


INSERT INTO t1 VALUES(999999,22,'TESTCASE','TEST/TEST/TEST','TEST@$%^&','测试用例总结'),(1,23,'A','B','C','D');
SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t1 ORDER BY 1;

UPDATE t1 SET c2='tstecaseofadd' , c3='tstecaseofadd' WHERE c2='G         ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c4='C    ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;



#新增列并删除修改列


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#此处执行报内部错误，为已知问题，带修复后执行

--disable_parsing


ALTER TABLE t1 ADD c3 CHAR(5),MODIFY c2 BINARY(5) DEFAULT 'TEST' AFTER c3,DROP c1;
sleep 3;
#SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES('TESTCASE','特殊%￥……&字符'),('aa','bb');
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

UPDATE t1 SET c2='test/test',c3='hahhahh' WHERE c3='aa   ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c2='test/';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;


--enable_parsing


#新增列并执行其他DDL操作


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#暂不知此，带支持后执行sql

--disable_parsing


ALTER TABLE t1 ADD c3 CHAR(5) NOT NULL DEFAULT 'TEST/TEST' AFTER c1,ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c3),ALTER c1 SET DEFAULT 0,PARALLEL 5;
sleep 3;
#SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES(21,'TESTCASE','AA/BB/CC/DD/EE/FF'),(23,'A','B');
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;


--enable_parsing



--echo #在分区表中测试禁用修剪后新增列，并校验。



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 VARCHAR(10))
                PARTITION BY RANGE COLUMNS(c2)
                (PARTITION r1 VALUES LESS THAN('F'),
                PARTITION r2 VALUES LESS THAN('J'),
                PARTITION r3 VALUES LESS THAN('M')
                );

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');



#新增不同类型多列


--echo #此处指定了C4列的位置以后，查询C4列的长度和MySQL不一致，问题链接：

--disable_parsing

ALTER TABLE t1 ADD c3 CHAR(5) COMMENT '唯一约束列',ADD c4 BINARY(5) DEFAULT 'TEST' AFTER c2,ADD c5 VARCHAR(5) AFTER c1,ADD c6 INT(5) FIRST;
sleep 3;
#SHOW CREATE TABLE t1;
SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t1 ORDER BY 1;

#此处mysql插入报错，OB插入成功，是有点问题的，正在和晓楚老师确认
INSERT INTO t1 VALUES(999999,22,'TESTCASE','TEST/TEST/TEST','TEST@$%^&','测试用例总结'),(1,23,'A','B','C','D');
SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t1 ORDER BY 1;

--error 01526
UPDATE t1 SET c2='tstecaseofadd' , c3='tstecaseofadd' WHERE c2='G         ';

#此处报错，致命错误，需要找对应开发确认问题。
UPDATE t1 SET c2='HHHHHHHHHHHHHHHH' , c3='tstecaseofadd' WHERE c2='G';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c4='C    ';
SELECT c2,CHAR_LENGTH(c2),c4,CHAR_LENGTH(c4) FROM t1 ORDER BY 1;

--enable_parsing


#新增列并删除修改列


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 VARCHAR(10))
                PARTITION BY LIST COLUMNS(c2)
                (PARTITION r1 VALUES IN('A','B','C','D','E','F','G'),
                PARTITION r2 VALUES IN('H','I','J','K','L','M','N'),
                PARTITION r3 VALUES IN('O','P','Q','R','S','T')
                );

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#此处执行报内部错误，为已知问题，带修复后执行

--disable_parsing

ALTER TABLE t1 ADD c3 CHAR(5),MODIFY c2 BINARY(5) DEFAULT 'TEST' AFTER c3,DROP c1;
sleep 3;
#SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES('TESTCASE','特殊%￥……&字符'),('aa','bb');
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

UPDATE t1 SET c2='est/est',c3='hahhahh' WHERE c3='aa   ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c2='test/';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;


--enable_parsing


#新增列并执行其他DDL操作


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10))
                PARTITION BY KEY(c2)
                (PARTITION r1 ,PARTITION r2 ,PARTITION r3);

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#暂不支持，带支持后执行sql

--disable_parsing


ALTER TABLE t1 ADD c3 CHAR(5) NOT NULL DEFAULT 'TEST' AFTER c1,ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c3),ALTER c1 SET DEFAULT 0,PARALLEL 5;
sleep 3;
#SHOW CREATE TABLE t1;

--error 01062
INSERT INTO t1 VALUES(21,'TESTCASE','AA/BB/CC/DD/EE/FF'),(23,'A','B');

INSERT INTO t1 VALUES(21,'TESTCASE','AA/BB/CC/DD/EE/FF'),(23,'A','H');
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;


--enable_parsing



--echo #在复制表中测试禁用修剪后新增列，并校验。



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#使用as关键字创建复制表

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 AS SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


#新增不同类型多列


ALTER TABLE t2 ADD c3 CHAR(5) UNIQUE COMMENT '唯一约束列',ADD c4 BINARY(5) DEFAULT 'TEST' AFTER c2,ADD c5 VARCHAR(5) AFTER c1,ADD c6 INT(5) FIRST;
sleep 3;
#SHOW CREATE TABLE t2;

SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t2 ORDER BY 1;


INSERT INTO t2 VALUES(999999,22,'TESTCASE','TEST/TEST/TEST','TEST@$%^&','测试用例总结'),(1,23,'A','B','C','D');
SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t2 ORDER BY 1;

UPDATE t2 SET c2='tstecaseofadd' , c3='tstecaseofadd' WHERE c2='G         ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t2 ORDER BY 1;

DELETE FROM t2 WHERE c4='C    ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t2 ORDER BY 1;


#使用LIKE关键字创建复制表

