CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


ALTER TABLE t2 ADD c3 CHAR(5) UNIQUE COMMENT '唯一约束列',ADD c4 BINARY(5) DEFAULT 'TEST' AFTER c2,ADD c5 VARCHAR(5) AFTER c1,ADD c6 INT(5) FIRST;
sleep 3;
#SHOW CREATE TABLE t2;

SELECT c1,c5,c6,c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3),c4,CHAR_LENGTH(c4) FROM t2 ORDER BY 1;


