--echo #新增列为生成列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10) GENERATED ALWAYS AS (CONCAT(c4,c8)) VIRTUAL COMMENT '字符生成列',
                c6 INT GENERATED ALWAYS AS (c0*2) STORED COMMENT '数值生成列',
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE(c8)
SUBPARTITION BY KEY(c6) SUBPARTITIONS 3
(PARTITION l1 VALUES LESS THAN(2000),
 PARTITION l2 VALUES LESS THAN(2005),
 PARTITION l3 VALUES LESS THAN(2010),
 PARTITION l4 VALUES LESS THAN(2015),
 PARTITION l5 VALUES LESS THAN MAXVALUE
);

