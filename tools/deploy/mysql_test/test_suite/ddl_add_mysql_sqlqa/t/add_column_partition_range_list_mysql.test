--echo #新增列带有索引或者约束

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT NOT NULL,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR )
PARTITION BY LIST(c8)
SUBPARTITION BY KEY(c8) SUBPARTITIONS 3
(PARTITION l1 VALUES IN (2000,2002,2004,2006,2008,2010,2012),
 PARTITION l2 VALUES IN (2001,2003,2005,2007,2009,2011,2013)
);

