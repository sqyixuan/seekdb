--echo #新增列加上约束或索引


DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE(c0)
(PARTITION l1 VALUES LESS THAN(7),
 PARTITION l2 VALUES LESS THAN(15)
);

INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'2010-10-11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'2001-01-11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'2016-02-11','2002'),
                     (4,1.3,3.2,'中!文','C','a',1,'2021-03-11','2003'),
                     (5,1.4,4.2,'中!文','D','a',2,'2011-11-01','2004'),
