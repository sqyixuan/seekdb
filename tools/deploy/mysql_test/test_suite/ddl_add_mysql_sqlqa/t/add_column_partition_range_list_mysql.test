--echo ##########################PARTITION BY RANGE WITH SUBPARITIONS#############################



DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE(c0)
SUBPARTITION BY HASH(c6) SUBPARTITIONS 3
(PARTITION l1 VALUES LESS THAN(7),
 PARTITION l2 VALUES LESS THAN(15),
 PARTITION l3 VALUES LESS THAN(20)
);

