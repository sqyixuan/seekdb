#owner group: sql3
# tags: dml, ddl


--disable_warnings
drop database if exists db_prefix;
create database db_prefix;
use db_prefix;
--enable_warnings
--result_format 4

create table t1 (c1 varchar(100), index ip1 (c1(10)));
insert into t1 values('aa'), ('bb');
create view v1 as select * from t1 where c1 = 'aa';
select * from v1;
show create view v1;

create view v2 as select * from t1 where c1 in ('bb', 'cc');
select * from v2;
show create view v2;

drop database db_prefix;
