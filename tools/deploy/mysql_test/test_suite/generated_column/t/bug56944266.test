# owner: lijinmao.ljm
# owner group: SQL1
# get_local_tz_info memory leak

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone_mysql.inc

--disable_warnings
DROP TABLE if exists offline_dailyreconciliation;
--enable_warnings

set time_zone = 'America/New_York';
show variables like "time_zone";

CREATE TABLE `offline_dailyreconciliation` (
  `id` int unsigned NOT NULL,
  `tradeDate` datetime DEFAULT NULL,
  `tradedate_index1` datetime GENERATED ALWAYS AS (date_format(`tradeDate`, '%Y-%m-%d')) stored,
  `tradedate_index2` datetime GENERATED ALWAYS AS (date_format(`tradeDate`, '%Y-%m-%d')) stored
) partition by hash(id) partitions 10;

SET time_zone = default;
show variables like "time_zone";

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
alter system set _min_malloc_sample_interval = 1;
alter system set _max_malloc_sample_interval = 1;
connection default;

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into offline_dailyreconciliation(id,tradeDate) values($cnt,current_time());
	dec $cnt;
}
--enable_query_log

connection sysc;
alter system refresh memory stat;
connection default;

drop table offline_dailyreconciliation;