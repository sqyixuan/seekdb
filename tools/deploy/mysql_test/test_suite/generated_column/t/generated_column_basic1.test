--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#tags: ddl, optimizer
#description:

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t, t1, t2, t3, t4, t5;
--enable_warnings

create table t(pk int primary key, a int);
insert into t values(1,1);
alter table t add column b int as(a+1);
select * from t;
create index idx on t(b);
--source mysql_test/include/check_all_idx_ok.inc
explain basic select /*+index(t primary)*/* from t;
select /*+index(t primary)*/* from t;
explain basic select /*+index(t idx)*/* from t;
select /*+index(t idx)*/* from t;
drop table t;

create table t(a int, b int, c int as (a+b));
insert into t values();
drop table t;

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
create table t1(pk int primary key, a char(5));
insert into t1 values(1,'a');
alter table t1 add column b char(10) as(concat(a, '1'));
select * from t1;

create table t2(pk int primary key, a char(5));
insert into t2 values(1,'a');
alter table t2 add column b char(10) as(concat(a, '1')) stored;
select * from t2;

create table t3(a int,b varchar(100),c varchar(100)) progressive_merge_num=2;
insert into t3 values (1,'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa','bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb');
insert into t3 select * from t3;

create table t4(pk int primary key, a int);
insert into t4 values(1,1);

create table t(a int as (1+1));
insert into t values(default);
select * from t;
drop table t;

create table t(a int, b int as (a+1));
insert into t values(1, default);
select * from t;
drop table t;

create table t(a int, b int);
insert into t values(1, a+1);
select * from t;
drop table t;

--error 3106
create table t(a int, b varchar(25) default null, c datetime, v_c1 varchar(20) generated always as (substr(b, 3)), v_c2 varchar(20) generated always as (substr(v_c1, 3))  virtual, primary key(a,b,c));

create table t(a int, b int as(a+1));
--error 3106
alter table t add column c int as(b+1);
drop table t;

--error 3106
create table t(a int, b int as(a+1), c int as(b+1));

create table t5(a int primary key, c int, b varchar(10) as (a+1));
insert into t5(a) values(1);

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't3');
call dbms_stats.gather_table_stats('TEST', 't4');
call dbms_stats.gather_table_stats('TEST', 't5');

select * from t1;
drop table t1;
select * from t2;
drop table t2;
alter table t3 add column gen int as(a+1) stored;
create index idx on t3(gen);
show index from t3;
explain basic select /*+index(t3 primary)*/* from t3;
select /*+index(t3 primary)*/* from t3;
explain basic select /*+index(t3 idx)*/* from t3;
select /*+index(t3 idx)*/* from t3;
drop table t3;
alter table t4 add column gen int as(a+1) stored;
create index idx on t4(gen);
show index from t4;
explain basic select /*+index(t4 primary)*/* from t4;
select /*+index(t4 primary)*/* from t4;
explain basic select /*+index(t4 idx)*/* from t4;
select /*+index(t4 idx)*/* from t4;
drop table t4;
create index i1 on t5(c) storing(b);
insert into t5(a) values(2);
show index from t5;
explain basic select * from t5 where c>1 and b=3;
select * from t5 where c>1 and b=3;
drop table t5;
