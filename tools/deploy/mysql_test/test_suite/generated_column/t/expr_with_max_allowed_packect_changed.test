#owner: lijinmao.ljm
#owner group: sql1
#tags: ddl, optimizer

--disable_warnings
drop database if exists test_generated_column_expr;
create database test_generated_column_expr;
use test_generated_column_expr;
drop table if exists t1;
--enable_warnings
--result_format 3

--disable_warnings
--echo #### space
connection default;
use test_generated_column_expr;
select @@max_allowed_packet;
create table t1 (c1 int, c2 int as (length(space(200000))));
create index idx1 on t1(c2);
set global max_allowed_packet = 100000;
connect(con1, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
use test_generated_column_expr;
select @@max_allowed_packet;
insert into t1(c1) values(1);
select * from t1;
set global max_allowed_packet = default;
disconnect con1;
connect(con2, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
use test_generated_column_expr;
select @@max_allowed_packet;
insert into t1(c1) values(1);
select * from t1;
drop table t1;
disconnect con2;

--echo #### lpad/rpad
connection default;
use test_generated_column_expr;
select @@max_allowed_packet;
create table t1 (c1 int, c2 int as (length(lpad('a', 200000, ' '))), c3 int as (length(rpad('a', 200000, ' '))));
create index idx1 on t1(c2);
create index idx2 on t1(c3);
set global max_allowed_packet = 100000;
connect(con1, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
use test_generated_column_expr;
select @@max_allowed_packet;
insert into t1(c1) values(1);
select * from t1;
set global max_allowed_packet = default;
disconnect con1;
connect(con2, $OBMYSQL_MS0, $OBMYSQL_USR, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
use test_generated_column_expr;
select @@max_allowed_packet;
insert into t1(c1) values(1);
select * from t1;
drop table t1;
disconnect con2;