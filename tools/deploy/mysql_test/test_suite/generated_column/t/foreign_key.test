#owner: lijinmao.ljm
#owner group: sql3
#notes: Used to test foreign key constraint on generated column in Mysql mode

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_warnings
drop table if exists t2, t1;
--enable_warnings

--echo # Virtual column as child
create table t1(
    s1 int primary key,
    s2 int default 666);

insert into t1(s1) values(2);
insert into t1(s1) values(4);
insert into t1(s1) values(6);
insert into t1(s1) values(8);
insert into t1(s1) values(10);

select * from t1 order by s1;

create table t2(
    s1 int,
    s2 int generated always as(s1*2),
    constraint stu_pk primary key(s1),
    constraint stu_fk foreign key (s2) references t1(s1))
    partition by hash(s2) partitions 10;

insert into t2 (s1) values (1);
insert into t2 (s1) values (2);
insert into t2 (s1) values (3);
insert into t2 (s1) values (4);
insert into t2 (s1) values (5);
--error 1452
insert into t2 (s1) values (6);

select * from t2 order by s1;

--echo # Virutal column as parent
drop table if exists t2, t1;

create table t1(
    s1 int primary key,
    s2 int generated always as (2*s1),
    constraint uq unique (s2));

insert into t1(s1) values(2);
insert into t1(s1) values(4);
insert into t1(s1) values(6);
insert into t1(s1) values(8);
insert into t1(s1) values(10);

select * from t1 order by s1;

create table t2 (
    s1 int,
    s2 int,
    constraint stu_fk foreign key (s2) references t1 (s2)
);

insert into t2 values (1,4);
insert into t2 values (1,8);
insert into t2 values (1,12);
insert into t2 values (1,16);
insert into t2 values (1,20);
--error 1452
insert into t2 values (1,15);

select * from t2 order by s2;

--echo # Clean
drop table if exists t2, t1;