--disable_warnings
drop table if exists t9_dkz;
drop view if exists t9_view_dkz;
--enable_warnings

CREATE TABLE `t9_dkz` (
  `c1` binary(79) DEFAULT NULL,
  `c2` decimal(64,22) DEFAULT NULL,
  `c5` int(127) NOT NULL AUTO_INCREMENT,
  `c33` decimal(64,0) GENERATED ALWAYS AS ((`c2` + `c2`)) VIRTUAL,
  KEY `u_generated_t9_dkz` (`c33`, `c2`) BLOCK_SIZE 16384 LOCAL
) ;

CREATE VIEW `t9_view_dkz` AS select `test`.`t9_dkz`.`c1` AS `c1`,`test`.`t9_dkz`.`c2` AS `c2`,`test`.`t9_dkz`.`c5` AS `c5` from `test`.`t9_dkz`;

INSERT INTO t9_dkz(c1,c2,c5) VALUES ('ArcptytGNAUFEYGslVXxWonJCzlwNUtDSmGJO PQR ST092',92.0000000000000000000000, 92);
