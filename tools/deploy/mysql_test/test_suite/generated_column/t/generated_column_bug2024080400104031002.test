INSERT INTO t9_dkz(c1,c2,c5) VALUES ('WQqCDjsEuPtdDAN stu vwx095',-95.0000000000000000000000,-95);

UPDATE /*+no_rewrite*/
  t9_view_dkz AS t9_view_dkz_100
  LEFT OUTER JOIN (
    SELECT /*+no_rewrite*/
      t9_view_dkz.c2,
      t9_view_dkz.c5
    FROM
      t9_view_dkz
  ) AS t9_view_dkz_200 ON (t9_view_dkz_100.c5 = 762 and t9_view_dkz_200.c2 = CAST(NULL AS signed))
SET
  t9_view_dkz_100.c2 = 11111.7,
  t9_view_dkz_100.c5 = -326
WHERE
  1=1;

explain UPDATE /*+no_rewrite*/
  t9_view_dkz AS t9_view_dkz_100
  LEFT OUTER JOIN (
    SELECT /*+no_rewrite*/
      t9_view_dkz.c2,
      t9_view_dkz.c5
    FROM
      t9_view_dkz
  ) AS t9_view_dkz_200 ON (t9_view_dkz_100.c5 = 762 and t9_view_dkz_200.c2 = CAST(NULL AS signed))
SET
  t9_view_dkz_100.c2 = 11111.7,
  t9_view_dkz_100.c5 = -326
WHERE
  1=1;

select /*+ opt_param('hidden_column_visible', 'true') */ __pk_increment, c33,c2 from t9_dkz ;

drop table t9_dkz;
drop view t9_view_dkz;