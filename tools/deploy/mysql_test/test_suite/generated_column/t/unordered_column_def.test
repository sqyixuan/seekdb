#owner: lijinmao.ljm
#owner group: sql3

--disable_warnings
drop database if exists u1;
create database u1;
use u1;
--enable_warnings

--echo # Mysql allow unordered column definition
create table t1 (x int generated always as (y+1), y int);
insert into t1 (y) values (2);
select * from t1 order by y;

--echo # Add column is allowed as well
#alter table t1 add (a int generated always as (b+1), b int);
#insert into t1 (y, b) values (5,5);
#select * from t1 order by y;

drop table t1;

drop database if exists u1;