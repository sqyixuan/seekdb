#owner: sean.yyj
#owner group: sql3
#tags: ddl

--disable_warnings
drop database if exists ufbi;
create database ufbi;
use ufbi;
--enable_warnings
--result_format 3

create table t1(c1 int, c2 varchar(10) as (null));
insert into t1(c1) values(1);
create index i1 on t1(c2);
desc t1;
select * from t1;
create table t2(c1 int);
insert into t2(c1) values(1);
--error 1064
create index i2 on t2(null);
desc t2;
select * from t2;
create table t3 as select null c1 from dual;
desc t3;
select * from t3;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection default;
use ufbi;
select * from t1;
select * from t2;
select * from t3;

--result_format 1
drop database ufbi;
