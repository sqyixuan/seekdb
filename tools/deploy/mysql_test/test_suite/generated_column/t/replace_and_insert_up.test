--disable_warnings
DROP TABLE IF EXISTS w0caseeolafy, t;
--enable_warnings

connect (root,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection root;
alter system set _enable_defensive_check=2;
create table w0caseeolafy ( w0_test0 char(10) , w0_test1 int primary key, w0_test2 year, w0_test3 varchar(10), w0_test4 real generated always as (w0_test1 + w0_test2),unique (w0_test0,w0_test1), index i0 using hash (w0_test0,w0_test1,w0_test2,w0_test3,w0_test4)) ;
insert into w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('a','12','1999','b');
CREATE TABLE `t` (  `concat(c.w0_test0,'cc')` varchar(12) DEFAULT NULL,  `w0_test1` int(11) NOT NULL,  `w0_test2` year(4) DEFAULT NULL,  `w0_test3` varchar(10) DEFAULT NULL);
insert into t values('acc', 12, 1999, 'b');
replace w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) select * from t;
drop table w0caseeolafy;
drop table t;

create table w0caseeolafy ( w0_test0 char(10) , w0_test1 int primary key, w0_test2 year, w0_test3 varchar(10), w0_test4 real generated always as (w0_test1 + w0_test2),unique (w0_test0,w0_test1), index i0 using hash (w0_test0,w0_test1,w0_test2,w0_test3,w0_test4)) ;
insert into w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('a','12','1999','b');
replace w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('acc', 12, 1999, 'b');
drop table w0caseeolafy;

create table w0caseeolafy ( w0_test0 char(10) , w0_test1 int primary key, w0_test2 year, w0_test3 varchar(10), w0_test4 real generated always as (w0_test1 + w0_test2),unique (w0_test0,w0_test1), index i0 using hash (w0_test0,w0_test1,w0_test2,w0_test3,w0_test4)) ;
insert into w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('a','12','1999','b');
insert into w0caseeolafy partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values('a','12','1999','b') on duplicate key update w0_test0='acc';
drop table w0caseeolafy;

--disable_warnings
DROP TABLE IF EXISTS TT;
--enable_warnings

create table TT(
    first_name varchar(50),
    primary key(first_name),
    last_name varchar(50),
    fullname varchar(10) collate 'utf8mb4_bin'
    generated always as (substring(first_name, 3)))
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));
insert into TT(first_name, last_name) values('sxxxxxx', 'abc') on duplicate key update first_name='way';
insert into TT(first_name, last_name) values('sxxxxxx', 'abc') on duplicate key update first_name='way';
insert into TT(first_name, last_name) values('sxxxxxx', 'abc') on duplicate key update first_name='way';
--error 1062
insert into TT(first_name, last_name) values('sxxxxxx', 'abc') on duplicate key update first_name='way';
drop table TT;

create table TT(
    first_name varchar(50),
    primary key(first_name),
    last_name varchar(50),
    fullname varchar(10) collate 'utf8mb4_bin'
    generated always as (substring(first_name, 3)))
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));
replace into TT(first_name, last_name) values('sxxxxxx', 'abc');
replace into TT(first_name, last_name) values('sxxxxxx', 'def');
drop table TT;

create table TT(
    first_name varchar(50),
    primary key(first_name),
    last_name varchar(50),
    fullname varchar(10) collate 'utf8mb4_bin'
    generated always as (substring(first_name, 3)))
    partition by range columns(fullname)
    (partition p1 values less than ('xxx'),
     partition p2 values less than ('zzz'));
CREATE TABLE `t` (first_name varchar(50), last_name varchar(50));
insert into t values('sxxxxxx','beee');
insert into TT(first_name, last_name) values('sxxxxxx', 'abc');
replace into TT(first_name, last_name) select * from t;
drop table TT;


--disable_warnings
DROP TABLE IF EXISTS test;
--enable_warnings
create table test(pk1 int, pk2 int, first_name varchar(100), last_name varchar(100), primary key(pk1, pk2)) partition by hash(pk1) partitions 2;
insert into test values(1,1, 'first                     1', 'last                    1');
create index test_index ON test(first_name(10));
replace into test(pk1,pk2,first_name,last_name) values (1, 1, 'first                     1', 'last                    2');
drop table test;

create table test(pk1 int, pk2 int, first_name varchar(100), last_name varchar(100), primary key(pk1, pk2)) partition by hash(pk1) partitions 2;
insert into test values(1,1, 'first                     1', 'last                    1');
create index test_index ON test(first_name(10));
insert into test(pk1,pk2,first_name,last_name) values (1, 1, 'first                     1', 'last                    2') on duplicate key update pk1 = 1;
drop table test;

--disable_warnings
DROP TABLE IF EXISTS t0,t1;
--enable_warnings
create table t0 ( w0_test0 char(10) , w0_test1 int primary key, w0_test2 year, w0_test3 varchar(10), w0_test4 real generated always as (w0_test1 + w0_test2),unique (w0_test0,w0_test1), index i0 using hash (w0_test0,w0_test1,w0_test2,w0_test3,w0_test4)) ;
insert into t0 partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('a','12','1999','b');
insert into t0 partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) values ('a','11','1999','b');
CREATE TABLE `t1` (  `concat(c.w0_test0,'cc')` varchar(12) DEFAULT NULL,  `w0_test1` int(11) NOT NULL,  `w0_test2` year(4) DEFAULT NULL,  `w0_test3` varchar(10) DEFAULT NULL);
insert into t1 values('acc', 12, 1999, 'b');
insert into t1 values('acc', 11, 1999, 'b');

replace t0 partition (p0) (w0_test0,w0_test1,w0_test2,w0_test3) select * from t1;
