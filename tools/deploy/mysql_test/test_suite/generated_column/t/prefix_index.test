--disable_warnings
drop table if exists sms_in_log_230104;
--enable_warnings
CREATE TABLE `sms_in_log_230104` (

  `Id` int(11) NOT NULL AUTO_INCREMENT COMMENT '自动标识列',
  `GwCode` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '网关编码',
  `AppCode` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '网关应用编码',
  `GwTypeId` int(1) DEFAULT '0' COMMENT '网关类型，0HTTP，1CMPP2.0',
  `GwVer` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '接口版本，1.0',
  `ReqId` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '批次消息Id',
  `ReqCode` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '消息提交返回响应码',
  `Ip` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'IP地址',
  `ReqContent` varchar(8000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '批次消息内容',
  `Account` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账号',
  `Phone` varchar(8000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '手机号码',
  `SubmitTime` datetime(3) DEFAULT NULL COMMENT '提交时间',
  `InsertTime` datetime(3) DEFAULT CURRENT_TIMESTAMP(3) COMMENT '入库时间',
  PRIMARY KEY (`Id`),
  KEY `i_GwCode` (`GwCode`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_GwTypeId` (`GwTypeId`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_GwVer` (`GwVer`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_ReqId` (`ReqId`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_ReqCode` (`ReqCode`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_Ip` (`Ip`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_Account` (`Account`) BLOCK_SIZE 16384 LOCAL,
  KEY `i_Phone` (`Phone`(191)) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 6946588 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

select * from sms_in_log_230104 where phone='1234567890';
