select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10) like 'aa%';

explain extended_noaddr select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10) like 'aaa';
select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10) like 'aaa';

explain extended_noaddr select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10)='aaa';
select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10)='aaa';

explain extended_noaddr select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10)<='aaa' and substr(b, 1, 10)>='123';
select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 10)<='aaa' and substr(b, 1, 10)>='123';

explain extended_noaddr select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 11)<='aaa' and substr(b, 1, 11)>='123';
select /*+index(t1 prefix_idx)*/ * from t1 where substr(b, 1, 11)<='aaa' and substr(b, 1, 11)>='123';

explain extended_noaddr select /*+index(t1 prefix_idx)*/ * from t1 where b like 'aaa';
select /*+index(t1 prefix_idx)*/ * from t1 where b like 'aaaa';

explain basic select /*+index(t1 prefix_idx)*/ * from t1 where b like '123456789%';
select /*+index(t1 prefix_idx)*/ * from t1 where b like '123456789%';
