--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#tags: ddl, optimizer
#description:

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1, xf, xf2, xf3, xf4, xf5, xf6;
--enable_warnings

create table t1(a int primary key, b int as (a+1));
--error 3105
insert into t1 values(1, 1);
insert into t1 values(1, default);
select * from t1;
--error 1062
insert into t1(a) values(1);
select * from t1;
--error 1364
insert into t1 values();
select * from t1;
insert into t1 values(1, default) on duplicate key update a=3;
select * from t1;
insert into t1 values(1, default) on duplicate key update b=default;
select * from t1;
--error 3105
insert into t1 values(1, default) on duplicate key update b=2;
select * from t1;
--error 3106
alter table t1 modify b int;
--error 3106
alter table t1 change b c int;
drop table t1;

#测试生成列是否能够被修改定义
create table t1(a int primary key, b int);
--error 3106
alter table t1 modify b int as (a+1);
drop table t1;
create table t1(a int primary key, b int as (a+1));
--error 1235,3106
alter table t1 modify b int;
--error 1235,3106
alter table t1 change b c int;
--error 3106
alter table t1 alter column b set default 1;
drop table t1;
create table t1(a int primary key, b int as (a+1));
--error 1235
alter table t1 modify b int as (a+2);
drop table t1;

# fix bug 17633071
# 创建生成列时必须指定列类型，否则需要报语法错误
--error 1064
create table xf(c1 int primary key, c2 varchar(10), c3 as (case when c2 = 'T' then c1 end));
create table xf(c1 int primary key, c2 varchar(10), c3 int as (case when c2 = 'T' then c1 end));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf;
drop table xf;
create table xf2(c1 int, c2 varchar(25), c3 varchar(20) generated always as (substr(c2, 3)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf2;
--error 1064
alter table xf2 add c4 generated always as (substr(c2, 3));
alter table xf2 add c4 varchar(25) generated always as (substr(c2, 3));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table xf2;
drop table xf2;

# 测试生成列的 col type 和 expr type 不同的情况
create table xf3(c1 int primary key, c2 varchar(10), c3 char as (case when c2 = 'T' then c1 end));
insert into xf3 (c1, c2) values (1, "T");
select * from xf3;
insert into xf3 (c1, c2) values (2, "TT");
select * from xf3;
drop table xf3;
create table xf4(c1 char primary key, c2 varchar(10), c3 int as (case when c2 = 'T' then c1 end));
insert into xf4 (c1, c2) values ('1', "T");
set sql_mode=STRICT_TRANS_TABLES;
--error 1366
insert into xf4 (c1, c2) values ('a', "T");
set sql_mode='';
--error 1366
insert into xf4 (c1, c2) values ('a', "T");
select * from xf4;
drop table xf4;

# 测试生成列的 col type 和 expr type 相同，但 gen_col 的 length 大于 expr 的 length 的情况
create table xf5(c1 smallint primary key, c2 varchar(10), c3 bigint as (case when c2 = 'T' then c1 end));
insert into xf5 (c1, c2) values (1, "T");
select * from xf5;
drop table xf5;

# 测试生成列的 col type 和 expr type 相同，但 gen_col 的 length 小于 expr 的 length 的情况
create table xf6(c1 bigint primary key, c2 varchar(10), c3 smallint as (case when c2 = 'T' then c1 end));
insert into xf6 (c1, c2) values (1, "T");
set sql_mode=STRICT_TRANS_TABLES;
#--error 1264
insert into xf6 (c1, c2) values (2147483647, "T");
set sql_mode='';
--error 1062
insert into xf6 (c1, c2) values (2147483647, "T");
select * from xf6;
drop table xf6;
