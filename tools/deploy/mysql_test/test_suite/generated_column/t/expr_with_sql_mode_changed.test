#owner: lijinmao.ljm
#owner group: sql1
#tags: ddl, optimizer

--disable_warnings
drop database if exists test_generated_column_expr;
create database test_generated_column_expr;
use test_generated_column_expr;
drop table if exists t1;
--enable_warnings
--result_format 3

--disable_warnings
--echo #### convert
set sql_mode = default;
create table t1 (c1 int, c2 varchar(20) as (convert(0xff using utf8mb4)));
create index idx1 on t1(c2);
insert into t1(c1) values(1);
select * from t1;
set sql_mode = "";
insert into t1(c1) values(1);
select * from t1;
drop table t1;

--echo #### Inet6_Ntoa
set sql_mode = "";
create table t1 (c1 varchar(100), c2 varchar(100) as (Inet6_Ntoa(c1)));
insert into t1(c1) values (0x11);
select * from t1;
set sql_mode = default;
insert into t1(c1) values (0x11);
select * from t1;
drop table t1;

--echo #### unhex
set sql_mode = "";
create table t1 (c1 int, c2 varchar(100) as (unhex(0xff)));
insert into t1(c1) values (1);
select * from t1;
set sql_mode = default;
insert into t1(c1) values (1);
select * from t1;
drop table t1;

--result_format 1
drop database test_generated_column_expr;