#owner: jim.wjh
#owner group: sql3
#tags: ddl

--disable_warnings
drop database if exists test_generated_column_expr;
create database test_generated_column_expr;
use test_generated_column_expr;
--result_format 3
--enable_warnings

--disable_warnings
#conv
set collation_connection = 'utf8mb4_general_ci';
create table t1(c1 int, c2 varchar(100) as(collation(conv(c1, 10, 2))));
create index idx1 on t1(c2);
insert into t1(c1) values(1);
select * from t1;
set collation_connection = 'gbk_bin';
select * from t1;
insert into t1(c1) values(1);
select * from t1;
drop table t1;

#to_base64
set collation_connection = 'utf8mb4_general_ci';
create table t1(c1 int, c2 varchar(100) as(collation(to_base64(c1))));
create index idx1 on t1(c2);
insert into t1(c1) values(1);
select * from t1;
set collation_connection = 'gbk_bin';
select * from t1;
insert into t1(c1) values(1);
select * from t1;
drop table t1;

#hex
set collation_connection = 'utf8mb4_general_ci';
create table t1(c1 int, c2 varchar(100) as(collation(hex(c1))));
create index idx1 on t1(c2);
insert into t1(c1) values(1);
select * from t1;
set collation_connection = 'gbk_bin';
select * from t1;
insert into t1(c1) values(1);
select * from t1;
drop table t1;

#inet6_ntoa
set collation_connection = 'utf8mb4_general_ci';
create table t1(c1 varbinary(100), c2 varchar(100) as(collation(inet6_ntoa(c1))));
create index idx1 on t1(c2);
insert into t1(c1) values(UNHEX('0A000511'));
select hex(c1),c2 from t1;
set collation_connection = 'gbk_bin';
select hex(c1),c2 from t1;
insert into t1(c1) values(UNHEX('FCBE0000000000005C34CABDFEFA6312'));
select hex(c1),c2 from t1;
drop table t1;

