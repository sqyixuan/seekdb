--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jingfeng.jf
# owner group: SQL2
#

--disable_warnings
--error 0,1051
DROP TABLE test1;
--enable_warnings

create table test1(c1 int, c2 varchar(20), c3 varchar(20), gen1 varchar(10) generated always as (substr(c2,1,10)) virtual, primary key(c1), unique key i1 (c1, gen1) local);
delete /*+index(test1 i1)*/ from test1 where if (1, "a", test1.gen1) not in (if(1, c3, 1), "b");