#owner: sean.yyj
#owner group: sql3

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 char(100),c2 enum('a','b','c') as (c1) stored);
insert into t1(c1) values('a');
--error 1265
insert into t1(c1) values('d');

create table t2 (c1 char(100),c2 set('a','b','c') as (c1) stored);
insert into t2(c1) values('a');
--error 1265
insert into t2(c1) values('d');

drop table t1;
drop table t2;
