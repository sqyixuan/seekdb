--disable_warnings
drop database if exists ufbi;
create database ufbi;
use ufbi;
--enable_warnings
--result_format 3

set sql_mode='PAD_CHAR_TO_FULL_LENGTH';
create table t_noindex(id int, c1 char(10));
insert into t_noindex values(1,'a');
insert into t_noindex values(2,'b');
alter table t_noindex add c2 varchar(20) as (concat(c1, 'ddd'));
alter table t_noindex add c3 char(20) as (concat(c1, 'eee'));
insert into t_noindex(id,c1) values(3,'c');
select * from t_noindex;
create table t_nochar(id int, c1 varchar(10));
insert into t_nochar values(1,'a');
insert into t_nochar values(2,'b');
alter table t_nochar add c2 varchar(20) as (concat(c1, 'ddd'));
alter table t_nochar add c3 char(20) as (concat(c1, 'eee'));
create index i2 on t_nochar(c2);
create index i3 on t_nochar(c3);
insert into t_nochar(id,c1) values(3,'c');
select * from t_nochar;

create table t_pad_l(id int, c1 char(10)) partition by hash(id) partitions 2;
insert into t_pad_l values(1,'a');
insert into t_pad_l values(2,'b');
alter table t_pad_l add c2 varchar(20) as (concat(c1, 'ddd'));
alter table t_pad_l add c3 char(20) as (concat(c1, 'eee'));
insert into t_pad_l(id,c1) values(3,'c');
create index i1 on t_pad_l(c1(2)) local;
create index i2 on t_pad_l(c2) local;
create index i3 on t_pad_l(c3) local;
insert into t_pad_l(id,c1) values (4,'d');
select /*+index(t_pad_l primary)*/ c2, c3 from t_pad_l order by id;
