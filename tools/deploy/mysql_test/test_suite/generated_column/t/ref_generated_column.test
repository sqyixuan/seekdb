--disable_warnings
drop table if exists t1;
--enable_warnings

--result_format 3

create table t1 (c1 int, c2 int as (c1 + 2));
insert into t1(c1) values(c2);
insert into t1 set c1 = c2;
select * from t1;
drop table t1;

create table t1 (c1 int default 2, c2 int as (ifnull(c1, 5)));
insert into t1(c1) values(c2);
insert into t1 set c1 = c2;
select * from t1;
drop table t1;

--result_format 4

create table t1(a int primary key, b int, c int, d int as (b+1));
insert into t1 values(1, 1, 1, default);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t1; 
delete from t1 where a=1;
