# owner: lijinmao.ljm
# owner group: SQL1
# tags: cross_validation

--disable_warnings
drop table if exists jm, jm2;
--enable_warnings

create table jm (c1 int primary key, c2 double as (PI()), c3 double(8,6) as (PI()));
create index i2 on jm((PI()));
create table jm2 (c1 int primary key, c2 decimal(5,4) as (1/3), c3 decimal(10,3) as (1/3));
insert into jm2(c1) values (1);

--result_format 4
select c2*3, c3*3, 1/3*3 from jm2;

--disable_query_log
let $database_id = query_get_value("select database_id from oceanbase.__all_database where database_name = 'test'", database_id, 1);
let $table_id = query_get_value("select table_id from oceanbase.__all_table where table_name = 'jm' and database_id=$database_id", table_id, 1);
let $i2_name = query_get_value("select table_name from oceanbase.__all_table where data_table_id=$table_id and table_name like '%i2'", table_name, 1);
--enable_query_log

set ob_enable_index_direct_select = 'ON';
insert into jm(c1) values (1);
explain select c1, c2*1000000, c3*1000000 from jm;
select c1, c2*1000000, c3*1000000 from jm;
--replace_regex /__idx_[0-9]*/__idx_xxxxx/
eval select * from $i2_name;

delete from jm where c1 = 1;
select c1, c2*1000000, c3*1000000 from jm;
--replace_regex /__idx_[0-9]*/__idx_xxxxx/
eval select * from $i2_name;

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_sys;
alter system major freeze tenant = 'sys';
--source mysql_test/include/wait_daily_merge.inc
connection default;

drop table jm;
