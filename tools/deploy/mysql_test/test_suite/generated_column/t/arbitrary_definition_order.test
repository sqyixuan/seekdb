#owner: lijinmao.ljm
#owner group: sql3

--disable_warnings
drop database if exists u1;
create database u1;
use u1;
--enable_warnings

--echo # 可以按照任意顺序定义生成列
create table t1 (y int generated always as (x+1), x int);
drop table t1;

--echo # 可以按照任意顺序指定主键
create table t1 (primary key (x), x int);
drop table t1;

--echo # 可以按照任意顺序定义外键约束
create table tx (c1 int primary key);
create table t1 (constraint fk foreign key (x) references tx(c1), x int);
drop table t1;
create table t1 (foreign key (x) references tx(c1), x int);
drop table t1;
create table t1 (foreign key (x) references t1(y), y int primary key, x int);
drop table t1;
drop table tx;

create table tx (x int primary key);
create table t1 (foreign key (y) references tx(x), y int generated always as(x+1), x int);
drop table t1;
drop table tx;

--echo # 可以按照任意顺序定义 unique 约束
create table t1 (constraint uk unique(x), x int);
drop table t1;
create table t1 (constraint uk unique(y), y int generated always as(x+1), x int);
drop table t1;

--echo # 可以按照任意顺序定义索引
create table t1 (index (x), x int);
drop table t1;
create table t1 (index (y), y int generated always as (x+1), x int);
drop table t1;

drop database if exists u1;