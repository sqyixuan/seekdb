DROP TABLE t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range (c1) (PARTITION A VALUES LESS THAN ( 100), PARTITION B VALUES LESS THAN (200), PARTITION C VALUES LESS THAN (300));
insert into t1 (c1, c2, c3) values (150,150,150);
select c1 FROM t1 WHERE (c1) IN (150,250);
c1
150
drop table t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by range columns (c1,c2) (PARTITION A VALUES LESS THAN ( 100,100), PARTITION B VALUES LESS THAN (200,200), PARTITION C VALUES LESS THAN (300,300));
insert into t1 (c1, c2, c3) values (150,150,150);
select count(c1) over (partition by c3) FROM t1 WHERE (c1, c2) IN ((150,150),(250,250));
count(c1) over (partition by c3)
1
drop table t1;
create table t1(c1 double, c2 int, c3 int as (c1+1), primary key(c1)) partition by range (c3) (PARTITION A VALUES LESS THAN (100), PARTITION B VALUES LESS THAN (200), PARTITION C VALUES LESS THAN (300));
insert into t1 (c1, c2) values (150,150);
select * FROM t1 WHERE (c1) IN ((150), (250));
c1	c2	c3
150	150	151
drop table t1;
create table t1(c1 int, c2 int, c3 int as (c1+c2), primary key(c1,c2)) partition by range columns (c1, c3) (PARTITION A VALUES LESS THAN ( 100,100), PARTITION B VALUES LESS THAN (200,200), PARTITION C VALUES LESS THAN (300,300));
insert into t1 (c1, c2) values (150,150);
select count(c1) over (partition by c3) FROM t1 WHERE (c1, c2) IN ((150,150),(250,250));
count(c1) over (partition by c3)
1
drop table t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by hash (c1) partitions 4;
insert into t1 (c1, c2, c3) values (150,150,150);
select c1 FROM t1 WHERE (c1) IN (150,250);
c1
150
drop table t1;
create table t1(c1 double, c2 int, c3 int as (c1+c2), primary key(c1, c2)) partition by hash (c3) partitions 4;
insert into t1 (c1, c2) values (150,150);
select count(c1) over (partition by c3) FROM t1 WHERE (c1) IN (150,250);
count(c1) over (partition by c3)
1
drop table t1;
