drop database if exists db_prefix;
create database db_prefix;
use db_prefix;
result_format: 4
create table t1 (c1 varchar(100), index ip1 (c1(10)));
insert into t1 values('aa'), ('bb');
create view v1 as select * from t1 where c1 = 'aa';
select * from v1;
+------+
| c1   |
+------+
| aa   |
+------+
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `db_prefix`.`t1`.`c1` AS `c1` from `db_prefix`.`t1` where (`db_prefix`.`t1`.`c1` = 'aa')	utf8mb4	utf8mb4_general_ci

create view v2 as select * from t1 where c1 in ('bb', 'cc');
select * from v2;
+------+
| c1   |
+------+
| bb   |
+------+
show create view v2;
View	Create View	character_set_client	collation_connection
v2	CREATE VIEW `v2` AS select `db_prefix`.`t1`.`c1` AS `c1` from `db_prefix`.`t1` where (`db_prefix`.`t1`.`c1` in ('bb','cc'))	utf8mb4	utf8mb4_general_ci

drop database db_prefix;
