drop table if exists t, tmp;
set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
create table t(a int, b varchar(25), c datetime, d varchar(100) default null, v_column varchar(20) generated always as (substr(b, 3)) virtual, primary key(a,b,c)) partition by key(v_column) subpartition by range columns(c) subpartition template (
subpartition p20170101 values less than('2017-01-01 00:00:00'),
subpartition p20170701 values less than('2017-07-01 00:00:00'),
subpartition p20180101 values less than('2018-01-01 00:00:00')) partitions 3;
insert into t(a,b,c) values(1, 'asdfadsfasdfdsa', '2016-09-28 00:00:00');
select * from t;
