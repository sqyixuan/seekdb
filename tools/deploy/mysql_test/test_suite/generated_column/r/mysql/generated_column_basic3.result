Warning	1364	Field 'a' doesn't have a default value
insert into t(a,b,c) values(5, 'bbbbbbbbbb','2017-02-28 00:00:00') on duplicate key update d=default;
create index idx on t(v_column, a) local;
explain basic select * from t where substr(b,3) ='abcde';
