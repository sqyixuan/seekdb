drop database if exists test_generated_column_expr;
create database test_generated_column_expr;
use test_generated_column_expr;
result_format: 3
set collation_connection = 'utf8mb4_general_ci';
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
create table t1(c1 int, c2 int as ('a' = 'A'), c3 varchar(100) as ('\\'),
                index i1(c2), index i2(c3));
insert into t1(c1) values(1);
set collation_connection='utf8mb4_bin';
set sql_mode='NO_BACKSLASH_ESCAPES';
insert into t1(c1) values(1);
select * from t1;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    1 |    1 | \    |
|    1 |    1 | \    |
+------+------+------+
select /*+index(t1 i1)*/ c2 from t1;
+------+
| c2   |
+------+
|    1 |
|    1 |
+------+
select /*+index(t1 i2)*/ c3 from t1;
+------+
| c3   |
+------+
| \    |
| \    |
+------+
drop table t1;
set collation_connection = 'utf8mb4_general_ci';
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_DATE';
create table t1(c1 varchar(30), c2 date as(c1));
insert into t1(c1) values('0000-00-00');
ERROR 22007: Incorrect datetime value for column 'c2' at row 1
insert into t1(c1) values('2011-01-01');
select * from t1;
+------------+------------+
| c1         | c2         |
+------------+------------+
| 2011-01-01 | 2011-01-01 |
+------------+------------+
set sql_mode = '';
insert into t1(c1) values('0000-00-00');
ERROR 22007: Incorrect datetime value for column 'c2' at row 1
drop table t1;
create table t1(c1 varchar(30), index i1((cast(c1 as date))));
insert into t1(c1) values('0000-00-00');
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_DATE';
insert into t1(c1) values('0000-00-00');
select c1,cast(c1 as date) from t1;
+------------+------------------+
| c1         | cast(c1 as date) |
+------------+------------------+
| 0000-00-00 | NULL             |
| 0000-00-00 | NULL             |
+------------+------------------+
drop table t1;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_DATE';
set time_zone = '+00:00';
create table t1(c1 timestamp,
                c2 date as (c1),
                index i1(c2),
                c3 int as (weekday(c1)),
                index i2(c3),
                c4 int as (weekofyear(c1)),
                index i3(c4),
                c5 int as (yearweek(c1)),
                index i4(c5),
                c6 int as (week(c1)),
                index i5(c6));
insert into t1(c1) values('2023-09-30 23:00:00'), ('2023-10-01 23:00:00'), ('2023-10-02 23:00:00');
desc t1;
+-------+-----------+------+-----+------------------+-------------------+
| Field | Type      | Null | Key | Default          | Extra             |
+-------+-----------+------+-----+------------------+-------------------+
| c1    | timestamp | YES  |     | NULL             |                   |
| c2    | date      | YES  | MUL | `c1`             | VIRTUAL GENERATED |
| c3    | int(11)   | YES  | MUL | weekday(`c1`)    | VIRTUAL GENERATED |
| c4    | int(11)   | YES  | MUL | weekofyear(`c1`) | VIRTUAL GENERATED |
| c5    | int(11)   | YES  | MUL | yearweek(`c1`)   | VIRTUAL GENERATED |
| c6    | int(11)   | YES  | MUL | week(`c1`)       | VIRTUAL GENERATED |
+-------+-----------+------+-----+------------------+-------------------+
select * from t1;
+---------------------+------------+------+------+--------+------+
| c1                  | c2         | c3   | c4   | c5     | c6   |
+---------------------+------------+------+------+--------+------+
| 2023-09-30 23:00:00 | 2023-09-30 |    5 |   39 | 202339 |   39 |
| 2023-10-01 23:00:00 | 2023-10-01 |    6 |   39 | 202340 |   40 |
| 2023-10-02 23:00:00 | 2023-10-02 |    0 |   40 | 202340 |   40 |
+---------------------+------------+------+------+--------+------+
set time_zone = '+08:00';
select * from t1;
+---------------------+------------+------+------+--------+------+
| c1                  | c2         | c3   | c4   | c5     | c6   |
+---------------------+------------+------+------+--------+------+
| 2023-10-01 07:00:00 | 2023-09-30 |    5 |   39 | 202339 |   39 |
| 2023-10-02 07:00:00 | 2023-10-01 |    6 |   39 | 202340 |   40 |
| 2023-10-03 07:00:00 | 2023-10-02 |    0 |   40 | 202340 |   40 |
+---------------------+------------+------+------+--------+------+
select c1, weekday(c1), weekofyear(c1), yearweek(c1), week(c1) from t1;
+---------------------+-------------+----------------+--------------+----------+
| c1                  | weekday(c1) | weekofyear(c1) | yearweek(c1) | week(c1) |
+---------------------+-------------+----------------+--------------+----------+
| 2023-10-01 07:00:00 |           6 |             39 |       202340 |       40 |
| 2023-10-02 07:00:00 |           0 |             40 |       202340 |       40 |
| 2023-10-03 07:00:00 |           1 |             40 |       202340 |       40 |
+---------------------+-------------+----------------+--------------+----------+
select /*+index(t1 i1)*/ c2 from t1;
+------------+
| c2         |
+------------+
| 2023-09-30 |
| 2023-10-01 |
| 2023-10-02 |
+------------+
select /*+index(t1 i2)*/ c3 from t1;
+------+
| c3   |
+------+
|    0 |
|    5 |
|    6 |
+------+
select /*+index(t1 i3)*/ c4 from t1;
+------+
| c4   |
+------+
|   39 |
|   39 |
|   40 |
+------+
select /*+index(t1 i4)*/ c5 from t1;
+--------+
| c5     |
+--------+
| 202339 |
| 202340 |
| 202340 |
+--------+
select /*+index(t1 i5)*/ c6 from t1;
+------+
| c6   |
+------+
|   39 |
|   40 |
|   40 |
+------+
drop table t1;
set time_zone = '+00:00';
create table t1(c1 timestamp,
                c2 varchar(40) as (timestampadd(DAY, -1, c1)),
                index i1(c2));
insert into t1(c1) values('2023-09-30 23:00:00');
desc t1;
+-------+-------------+------+-----+----------------------------+-------------------+
| Field | Type        | Null | Key | Default                    | Extra             |
+-------+-------------+------+-----+----------------------------+-------------------+
| c1    | timestamp   | YES  |     | NULL                       |                   |
| c2    | varchar(40) | YES  | MUL | timestampadd(DAY ,-1,`c1`) | VIRTUAL GENERATED |
+-------+-------------+------+-----+----------------------------+-------------------+
select * from t1;
+---------------------+---------------------+
| c1                  | c2                  |
+---------------------+---------------------+
| 2023-09-30 23:00:00 | 2023-09-29 23:00:00 |
+---------------------+---------------------+
set time_zone = '+08:00';
select c1,c2,timestampadd(DAY, -1, c1) from t1;
+---------------------+---------------------+---------------------------+
| c1                  | c2                  | timestampadd(DAY, -1, c1) |
+---------------------+---------------------+---------------------------+
| 2023-10-01 07:00:00 | 2023-09-29 23:00:00 | 2023-09-30 07:00:00       |
+---------------------+---------------------+---------------------------+
select /*+index(t1 i1)*/ c2 from t1;
+---------------------+
| c2                  |
+---------------------+
| 2023-09-29 23:00:00 |
+---------------------+
drop table t1;
set time_zone = '+00:00';
create table t1(c1 timestamp,
                c2 varchar(40) as (timestampadd(DAY, -1, c1)),
                index i1(c2));
insert into t1(c1) values('2023-09-30 23:00:00');
desc t1;
+-------+-------------+------+-----+----------------------------+-------------------+
| Field | Type        | Null | Key | Default                    | Extra             |
+-------+-------------+------+-----+----------------------------+-------------------+
| c1    | timestamp   | YES  |     | NULL                       |                   |
| c2    | varchar(40) | YES  | MUL | timestampadd(DAY ,-1,`c1`) | VIRTUAL GENERATED |
+-------+-------------+------+-----+----------------------------+-------------------+
select * from t1;
+---------------------+---------------------+
| c1                  | c2                  |
+---------------------+---------------------+
| 2023-09-30 23:00:00 | 2023-09-29 23:00:00 |
+---------------------+---------------------+
set time_zone = '+08:00';
select c1,c2,timestampadd(DAY, -1, c1) from t1;
+---------------------+---------------------+---------------------------+
| c1                  | c2                  | timestampadd(DAY, -1, c1) |
+---------------------+---------------------+---------------------------+
| 2023-10-01 07:00:00 | 2023-09-29 23:00:00 | 2023-09-30 07:00:00       |
