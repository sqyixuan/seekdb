drop table if exists t1;
create table t1(c1 varchar(10), c2 varchar(10));
insert into t1 values('abcde', '[b-d]');
insert into t1 values('abcde', 'cd');
insert into t1 values('abcde', 'h');
alter table t1 add c3 varchar(100) generated always as (regexp_instr(c1, c2));
alter table t1 add c4 varchar(100) generated always as (regexp_like(c1, c2));
alter table t1 add c5 varchar(100) generated always as (regexp_replace(c1, c2, 'z'));
alter table t1 add c6 varchar(100) generated always as (regexp_substr(c1, c2));
alter table t1 add c7 varchar(100) generated always as (c1 regexp c2);
result_format: 4
select * from t1;
+-------+-------+------+------+-------+------+------+
| c1    | c2    | c3   | c4   | c5    | c6   | c7   |
+-------+-------+------+------+-------+------+------+
| abcde | [b-d] | 2    | 1    | azzze | b    | 1    |
| abcde | cd    | 3    | 1    | abze  | cd   | 1    |
| abcde | h     | 0    | 0    | abcde | NULL | 0    |
+-------+-------+------+------+-------+------+------+

drop table t1;
