drop table if exists t1;
set explicit_defaults_for_timestamp = off;
create table t1 (c1 varchar(100),c2 timestamp as (c1));
alter table t1 add column c3 timestamp as (c1);
desc t1;
Field	Type	Null	Key	Default	Extra
c1	varchar(100)	YES		NULL	
c2	timestamp	YES		`c1`	VIRTUAL GENERATED
c3	timestamp	YES		`c1`	VIRTUAL GENERATED
drop table t1;
