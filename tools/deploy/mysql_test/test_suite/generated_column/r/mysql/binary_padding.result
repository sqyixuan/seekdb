drop table if exists t_binary;
create table t_binary(a varchar(10), c int primary key);
insert into t_binary(a, c) values(1, 1);
alter table t_binary add column b binary(10) as (concat(a, '6'));
result_format: 3
select c, a, b, hex(b) from t_binary;
+---+------+------------+----------------------+
| c | a    | b          | hex(b)               |
+---+------+------------+----------------------+
| 1 | 1    | 16         | 31360000000000000000 |
+---+------+------------+----------------------+
result_format: 1
drop table t_binary;
