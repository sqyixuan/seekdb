drop table if exists t1;
result_format: 4
explain_protocol: 1
create table t1 (`pay_sub_no` varchar(128),
                `pay_sub_no_part` int(11) GENERATED ALWAYS AS (substr(`pay_sub_no`,10,2)) STORED)
partition by list(pay_sub_no_part)
(partition `P00` values in (0),
partition `P01` values in (1));

