DROP TABLE IF EXISTS t1, t2;
DROP VIEW IF EXISTS v;
result_format: 4
create table t1(s1 int, s2 int, s3 int);
create table t2(s1 int, s2 int generated always as(s1+1), s3 int);
create view v as select * from t2;

select s2 from (select s2 from t2);
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/ s2 from (select s2 from t2);
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select s2 from v;
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/ s2 from v;
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select * from (select * from (select * from (select s2 from t2)));
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/ * from (select /*+no_rewrite*/ * from (select /*+no_rewrite*/ * from (select s2 from t2)));
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select * from (select * from (select * from v));
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    1 |    2 |    1 |
|    2 |    3 |    2 |
|    3 |    4 |    3 |
|    4 |    5 |    4 |
+------+------+------+
select /*+no_rewrite*/ * from (select /*+no_rewrite*/ * from (select /*+no_rewrite*/ * from v));
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    1 |    2 |    1 |
|    2 |    3 |    2 |
|    3 |    4 |    3 |
|    4 |    5 |    4 |
+------+------+------+

select v.s2 from (select s2 from t2)v, (select s1 from t1)v1 where v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
+------+
select /*+no_rewrite*/s2 from (select s2 from t2)v, (select s1 from t1)v1 where v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
+------+

select v.s2 from v, (select s1 from t1)v1 where v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
+------+
select /*+no_rewrite*/s2 from v, (select s1 from t1)v1 where v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
+------+

select v.s2 from (select s2 from t2)v left join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/s2 from (select s2 from t2)v left join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select v.s2 from v left join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/s2 from v left join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select v.s2 from (select * from t2 order by s2 limit 2)v right join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
| NULL |
| NULL |
|    2 |
|    2 |
|    3 |
+------+
select /*+no_rewrite*/s2 from (select s2 from t2 order by s2 limit 2)v right join (select s1 from t1)v1 on v1.s1 > v.s2;
+------+
| s2   |
+------+
| NULL |
| NULL |
|    2 |
|    2 |
|    3 |
+------+

select v.s2 from (select * from t2 order by s2 limit 2)v1 right join v on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+
select /*+no_rewrite*/v.s2 from (select * from t2 order by s2 limit 2)v1 right join v on v1.s1 > v.s2;
+------+
| s2   |
+------+
|    2 |
|    3 |
|    4 |
|    5 |
+------+

select * from t1 where s1 in (select s2 from t2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    2 |    2 |
|    3 |    3 |    3 |
|    4 |    4 |    4 |
+------+------+------+
select /*+no_rewrite*/* from t1 where s1 in (select s2 from t2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    2 |    2 |
|    3 |    3 |    3 |
|    4 |    4 |    4 |
+------+------+------+

select * from v where s1 in (select s2 from t2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    3 |    2 |
|    3 |    4 |    3 |
|    4 |    5 |    4 |
+------+------+------+
select /*+no_rewrite*/* from v where s1 in (select s2 from t2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    3 |    2 |
|    3 |    4 |    3 |
|    4 |    5 |    4 |
+------+------+------+

select * from t1 where s1 in (select s2 from t2 limit 2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    2 |    2 |
|    3 |    3 |    3 |
+------+------+------+
select /*+no_rewrite*/* from t1 where s1 in (select s2 from t2 limit 2);
+------+------+------+
| s1   | s2   | s3   |
+------+------+------+
|    2 |    2 |    2 |
|    3 |    3 |    3 |
+------+------+------+

select (select s2 from t2 limit 1) from t1;
+-----------------------------+
| (select s2 from t2 limit 1) |
+-----------------------------+
|                           2 |
|                           2 |
|                           2 |
|                           2 |
+-----------------------------+
select /*+no_rewrite*/(select s2 from t2 limit 1) from t1;
+-----------------------------+
| (select s2 from t2 limit 1) |
+-----------------------------+
|                           2 |
|                           2 |
|                           2 |
|                           2 |
+-----------------------------+

select (select s2 from t2 limit 1) from t1 order by (select s2 from t2 limit 1);
+-----------------------------+
| (select s2 from t2 limit 1) |
+-----------------------------+
|                           2 |
|                           2 |
|                           2 |
|                           2 |
+-----------------------------+
select /*+no_rewrite*/(select s2 from t2 limit 1) from t1 order by (select s2 from t2 limit 1);
+-----------------------------+
| (select s2 from t2 limit 1) |
+-----------------------------+
|                           2 |
|                           2 |
|                           2 |
|                           2 |
+-----------------------------+

drop table t1,t2;
drop view v;
