result_format: 4
drop database if exists def_fun_db;
Warnings:
Note	1008	Can't drop database 'def_fun_db'; database doesn't exist

create database def_fun_db;

use def_fun_db;


1. basic default function


create table t1(c1 int default 1, c2 int default 10, c3 int as (default(c1)));
insert into t1(c1, c2) values(2,2);
insert into t1(c1, c2) values(3,3);
insert into t1(c1, c2) values(4,4);

select * from t1 order by 1,2,3;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    2 |    2 |    1 |
|    3 |    3 |    1 |
|    4 |    4 |    1 |
+------+------+------+

alter table t1 add column c4 int as (default(c2));

select * From t1 order by 1,2,3,4;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    2 |    2 |    1 |   10 |
|    3 |    3 |    1 |   10 |
|    4 |    4 |    1 |   10 |
+------+------+------+------+


2. multi default functions


drop table t1;
create table t1(c1 int default 1, c2 int default 10, c3 int as (default(c1) + default(c2)));

insert into t1(c1, c2) values(2,2);
insert into t1(c1, c2) values(3,3);
insert into t1(c1, c2) values(4,4);

select * from t1 order by 1,2,3;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    2 |    2 |   11 |
|    3 |    3 |   11 |
|    4 |    4 |   11 |
+------+------+------+

alter table t1 add column c4 int as (default(c2) - default(c1));

select * From t1 order by 1,2,3,4;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    2 |    2 |   11 |    9 |
|    3 |    3 |   11 |    9 |
|    4 |    4 |   11 |    9 |
+------+------+------+------+


3. non termindate function in default functions


drop table t1;

create table t1(c1 timestamp default now(), c2 int default 10, c3 timestamp as (default(c1)));
ERROR HY000: Expression of generated column contains a disallowed function

create table t1(c1 timestamp default now(), c2 int default 10, c3 int as (extract(day from default(c1))));
ERROR HY000: Expression of generated column contains a disallowed function

create table t1 (c1 timestamp default localtime(), c2 int default 10, c3 int as (default(c1)));
ERROR HY000: Expression of generated column contains a disallowed function

create table t1 (c1 timestamp default current_timestamp(), c2 int default 10, c3 int as (default(c1)));
ERROR HY000: Expression of generated column contains a disallowed function

create table t1 (c1 timestamp default localtimestamp(), c2 int default 10, c3 int as (default(c1)));
ERROR HY000: Expression of generated column contains a disallowed function

create table t1(c1 timestamp default now());

alter table t1 add c3 timestamp as (default(c1));
ERROR HY000: Expression of generated column contains a disallowed function

drop table t1;


4. enum type in default functions


create table t1(c1 enum('a','b','c') default 'b' , xx varchar(20) as(default(c1)));

insert into t1(c1) values('a');
insert into t1(c1) values('b');
insert into t1(c1) values('c');

select * from t1 order by 1,2;
+------+------+
| c1   | xx   |
+------+------+
| a    | b    |
| b    | b    |
| c    | b    |
+------+------+

drop table t1;

create table t1(c1 enum('a','b', 'c') default 'b');
insert into t1 values('a');
insert into t1 values('b');
insert into t1 values('c');

alter table t1 add xx varchar(20) generated always as(default(c1));

select * from t1 order by 1,2;
+------+------+
| c1   | xx   |
+------+------+
| a    | b    |
| b    | b    |
| c    | b    |
+------+------+

drop table t1;

create table t1(c1 enum('a','b','c') default 'b' , xx int as(default(c1)));

insert into t1(c1) values('a');
insert into t1(c1) values('b');
insert into t1(c1) values('c');

select * from t1 order by 1,2;
+------+------+
| c1   | xx   |
+------+------+
| a    |    2 |
| b    |    2 |
| c    |    2 |
+------+------+

drop table t1;

create table t1(c1 enum('a','b', 'c') default 'b');
insert into t1 values('a');
insert into t1 values('b');
insert into t1 values('c');

alter table t1 add xx int generated always as(default(c1));

select * from t1 order by 1,2;
+------+------+
| c1   | xx   |
+------+------+
| a    |    2 |
| b    |    2 |
| c    |    2 |
+------+------+

drop table t1;

drop database def_fun_db;

use test;
drop table if exists t1;
create table t1(c1 int default 0, c2 int as (c1 + default(c1)), check(c1 + default(c1) < 1));
insert into t1(c1) values(1);
ERROR HY000: check constraint violated
insert into t1(c1) values(0);
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    0 |    0 |
+------+------+
drop table t1;
