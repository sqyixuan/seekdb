drop table if exists t1;
result_format: 3
create table t1 (c1 int, c2 int as (c1 + 2));
insert into t1(c1) values(c2);
insert into t1 set c1 = c2;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
| NULL | NULL |
| NULL | NULL |
+------+------+
drop table t1;
create table t1 (c1 int default 2, c2 int as (ifnull(c1, 5)));
insert into t1(c1) values(c2);
insert into t1 set c1 = c2;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
| NULL |    5 |
| NULL |    5 |
+------+------+
drop table t1;
result_format: 4
create table t1(a int primary key, b int, c int, d int as (b+1));
insert into t1 values(1, 1, 1, default);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select * from t1;
+---+------+------+------+
| a | b    | c    | d    |
+---+------+------+------+
| 1 |    1 |    1 |    2 |
+---+------+------+------+
delete from t1 where a=1;
drop table t1;
