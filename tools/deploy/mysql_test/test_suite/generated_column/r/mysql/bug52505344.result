DROP TABLE t1;
create table t1 (c1 enum('a','b','c'));
insert into t1 values('a');
insert into t1 values('b');
insert into t1 values('c');
alter table t1 add column `xx` varchar(20) as (32)  virtual;
select   subq_0.c3 as c0,  
subq_0.c4 as c1,  
case when (1)  and (EXISTS ( select   4 as c0,  68 as c1,  54 as c2,  81 as c3,  88 as c4,  18 as c5,  2 as c6,  96 as c7,  19 as c8,  85 as c9,  17 as c10,  3 as c11,  86 as c12,  69 as c13,  15 as c14 from  t1 as ref_6 where EXISTS ( select   49 as c0,  45 as c1,  5 as c2,  41 as c3,  77 as c4,  39 as c5,  90 as c6,  9 as c7,  77 as c8,  87 as c9,  100 as c10,  78 as c11,  10 as c12,  26 as c13,  54 as c14 from  t1 as ref_7 where EXISTS ( select   31 as c0,  91 as c1,  87 as c2,  44 as c3,  31 as c4,  62 as c5 from  t1 as ref_8 where EXISTS ( select   18 as c0 from  t1 as ref_9 where 47 >> 8 limit 157)) limit 130) limit 141)) then 70 else subq_0.c10 end  as c2 
from  (select   ref_0.c1 as c0, 
ref_1.xx as c1,  
50 as c2,  
ref_2.c1 as c3,  
54 as c4,  
ref_2.xx as c5,  
2 as c6,  
84 as c7,  
case when EXISTS ( select   86 as c0,  94 as c1,  68 as c2,  83 as c3,  40 as c4,  37 as c5,  56 as c6,  49 as c7,  84 as c8,  86 as c9,  78 as c10 from  t1 as ref_3 where cast(null as CHAR) in ( cast(null as CHAR)) limit 105) then 38 else 71 end  as c8,  
46 as c9,  
20 as c10 
from  (t1 as ref_0 inner join (t1 as ref_1 inner join t1 as ref_2 on (ref_1.c1 = ref_2.c1 )) on (ref_0.xx = ref_1.xx )) 
where if( (EXISTS ( select   16 as c0 from  t1 as ref_4 where EXISTS ( select distinct  56 as c0,  
97 as c1,  
32 as c2,  
61 as c3,  
92 as c4,  
17 as c5,  
9 as c6,  
18 as c7,  
54 as c8,  
38 as c9,  
30 as c10,  
68 as c11,  
52 as c12,  
54 as c13,  
1 as c14,  
8 as c15,  
11 as c16,  
72 as c17,  
72 as c18,  
20 as c19 
from  t1 as ref_5 
where 34 / 80) 
limit 81))  or (0) , 68 , 36 )  not  in ( 99,  20) limit 194) as subq_0 
where EXISTS ( select   71 as c0,  
79 as c1,  
if( EXISTS ( select   96 as c0,  97 as c1,  63 as c2,  42 as c3,  68 as c4,  80 as c5 from  t1 as ref_11 where EXISTS ( select distinct  79 as c0,  8 as c1,  10 as c2,  5 as c3,  98 as c4,  86 as c5,  73 as c6,  32 as c7,  89 as c8,  6 as c9,  89 as c10,  69 as c11,  91 as c12,  57 as c13,  85 as c14,  53 as c15,  96 as c16,  78 as c17,  77 as c18,  40 as c19,  89 as c20,  5 as c21,  86 as c22,  29 as c23,  15 as c24 from  t1 as ref_12 where (EXISTS ( select   56 as c0,  8 as c1,  61 as c2,  4 as c3,  62 as c4,  57 as c5 from  t1 as ref_13 where 43 % 88))  and (EXISTS ( select   80 as c0,  72 as c1 from  t1 as ref_14 where 0))) limit 52) , 71 , 65 )  as c2,  
31 as c3,  
(select VAR_SAMP(xx) from t1 order by 1)  as c4,  
case when (36 LIKE 50)  or (0) then cast(nullif(69, 100) as DECIMAL) else subq_0.c4 end  as c5,  
(select c1 from t1 order by 1 desc  limit 1 offset 5)  as c6 
from  t1 as ref_10 where EXISTS ( select   87 as c0 from t1 as ref_15 where 25 = 58));
c0	c1	c2
