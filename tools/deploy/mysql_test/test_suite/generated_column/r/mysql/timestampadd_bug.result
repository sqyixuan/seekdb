DROP TABLE IF EXISTS time_add_t1;
result_format: 4

create table time_add_t1( sidea DATE, sidec DATE AS (TIMESTAMPADD(YEAR,1,sidea)));
insert into time_add_t1(sidea) values('1001-01-01');
select * from time_add_t1;
+------------+------------+
| sidea      | sidec      |
+------------+------------+
| 1001-01-01 | 1002-01-01 |
+------------+------------+
drop table time_add_t1;

