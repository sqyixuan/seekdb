DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,last_name)) VIRTUAL NOT NULL
);
update t1 set t1.full_name = default;
update t1 set t1.full_name = 'hello';
ERROR HY000: The value specified for generated column 'full_name' in table 't1' is not allowed
drop table t1;
CREATE TABLE t1 (
first_name VARCHAR(10),
last_name VARCHAR(10),
full_name VARCHAR(255) GENERATED ALWAYS AS (CONCAT(first_name,last_name)) STORED NOT NULL
);
update t1 set t1.full_name = default;
update t1 set t1.full_name = 'hello';
ERROR HY000: The value specified for generated column 'full_name' in table 't1' is not allowed
drop table t1;
