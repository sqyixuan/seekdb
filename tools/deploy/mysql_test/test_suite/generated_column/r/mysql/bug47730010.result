# create table for test
result_format: 4
##bug47730010
DROP TABLE cc1;
create table cc1(
c1 varchar(100) character set utf8mb4 collate utf8mb4_general_ci,
c2 varchar(100) character set utf8mb4 collate utf8mb4_bin GENERATED ALWAYS AS (c1)
)
partition by range columns(c2) (
	partition p0 values less than ('Z'),
	partition p1 values less than ('z')
);

insert into cc1(c1) values ('B'),('b');
select * from cc1 partition(p0);
+------+------+
| c1   | c2   |
+------+------+
| B    | B    |
+------+------+
select * from cc1 partition(p1);
+------+------+
| c1   | c2   |
+------+------+
| b    | b    |
+------+------+
select * from cc1 where c1 = 'b';
+------+------+
| c1   | c2   |
+------+------+
| B    | B    |
| b    | b    |
+------+------+
