CREATE TABLE `ops_action_node` ( `id` varchar(20) NOT NULL, `parent_id` varchar(20) DEFAULT NULL COMMENT '父节点的id', `node_type` varchar(32) NOT NULL COMMENT '节点的类型', `action_type` varchar(32) DEFAULT NULL COMMENT 'action的类型', `state` varchar(32) NOT NULL COMMENT 'action node状态', `state_type` varchar(32) DEFAULT NULL, `node_path` varchar(5000) NOT NULL COMMENT '节点路径，比如 ("1","2","3")', `start_node_id` varchar(20) DEFAULT NULL COMMENT '起始节点id，只对 ProcessNode 有效', `end_node_id` varchar(20) DEFAULT NULL COMMENT '结束节点id，只对 ProcessNode 有效', `is_async` bit(1) NOT NULL DEFAULT b'0' COMMENT '节点是否是异步节点', `is_rollback` bit(1) NOT NULL DEFAULT b'0' COMMENT '节点是否是回滚节点', `needs_trigger` bit(1) NOT NULL DEFAULT b'0', `needs_confirm` bit(1) NOT NULL DEFAULT b'0', `support_retry` bit(1) NOT NULL DEFAULT b'0', `support_ignore` bit(1) NOT NULL DEFAULT b'0', `support_rollback` bit(1) NOT NULL DEFAULT b'0', `is_child_process` bit(1) NOT NULL DEFAULT b'0', `namespace` varchar(64) DEFAULT NULL, `deployment_id` varchar(64) DEFAULT NULL, `process_instance_id` varchar(64) DEFAULT NULL COMMENT 'activiti process instance id', `context` longtext DEFAULT NULL COMMENT '对应的context的id', `instruction` varchar(256) DEFAULT NULL, `honorable_req_types` varchar(1000) DEFAULT NULL COMMENT '该字段目前只能是由如下状态组成的一个CANCEL_REQUESTED, ROLLBACK_REQUESTED', `exclusive_control_ref` varchar(256) DEFAULT NULL COMMENT '独占控制对象', `business_scope` varchar(50) NOT NULL DEFAULT 'opsware', `business_entity_code` varchar(50) DEFAULT NULL, `business_entity_id` varchar(50) DEFAULT NULL, `gmt_started` datetime(3) DEFAULT NULL COMMENT '服务器本地开始时间', `gmt_finished` datetime(3) DEFAULT NULL COMMENT '服务器本地结束时间', `utc_started` datetime(3) DEFAULT NULL COMMENT 'UTC开始时间', `utc_finished` datetime(3) DEFAULT NULL COMMENT 'UTC结束时间', `gmt_created` datetime(3) NOT NULL COMMENT 'GMT创建时间', `gmt_modified` datetime(3) NOT NULL COMMENT 'GMT修改时间', `utc_created` datetime(3) NOT NULL COMMENT 'UTC创建时间', `utc_modified` datetime(3) NOT NULL COMMENT 'UTC修改时间', PRIMARY KEY (`id`), KEY `PARENT_ID_INDEX` (`parent_id`), KEY `NODE_PATH_INDEX` (node_path(255)), KEY `NODE_NAMESPACE_INDEX` (`namespace`), KEY `BIZ_SCOPE_ID_INDEX` (`business_scope`, `business_entity_id`), KEY `BIZ_SCOPE_CODE_ID_INDEX` (`business_scope`, `business_entity_code`, `business_entity_id`));
