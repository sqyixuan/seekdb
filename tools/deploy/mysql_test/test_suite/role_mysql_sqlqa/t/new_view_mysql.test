#owner:jim.wjh
#owner group:sql1
#tags:DML\DDL
#description:系统变量 activate_all_roles_on_login
#author:wb-zcp01469308
--disable_query_log
#Environmental cleaning
--disable_warnings
--error 0,1396
drop user admin_hal@'%';
create user admin_hal identified by '123';
grant all privileges on *.* to admin_hal WITH GRANT OPTION;
--enable_warnings
--enable_query_log

###切换测试用户
connect (conn,$OBMYSQL_MS0,admin_hal,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS hal_db;
--enable_warnings
###创建DB，切换DB测试
create database hal_db character set utf8;
use hal_db;




--result_format 4
-- echo 对mysql.role_edges表和mysql.default_roles表进行DML（OB不支持）

-- error 0,1396
drop user user_halA;
create user user_halA identified by '123';
grant select,update,insert,delete on mysql.role_edges to user_halA;
grant select,update,insert,delete on mysql.default_roles to user_halA;
show grants for 'user_halA';

SELECT
    user,
    account_locked
FROM
    mysql.user
WHERE
    user = 'user_halA';



connect (conn_user_halA,$OBMYSQL_MS0,user_halA,123,mysql,$OBMYSQL_PORT);
connection conn_user_halA;
# mysql -uuser_halA -p123
# ./obclient -h100.88.109.130 -P10016 -uuser_halA -p123
######################################## mysql.role_edges #########################################
show grants for 'user_halA';

#-- error 1142
#select * from hal_db.hal;

-- error 5723
insert into mysql.role_edges(FROM_HOST,FROM_USER,TO_HOST,TO_USER) values('%','role_halB','%','user_halA');
select * from mysql.role_edges where to_user='user_halA';


####################################### mysql.default_roles #######################################
select * from mysql.default_roles where USER='user_halA';
-- error 5723
insert into mysql.default_roles values('%','user_halA','%','role_halA');
select * from mysql.default_roles where USER='user_halA';






--echo ################################# 清空回收站,删除测试数据库,表等 ##################################
connection default;

--disable_warnings
--error 0,1396
drop user admin_hal@'%' ;
--enable_warnings

purge recyclebin;

