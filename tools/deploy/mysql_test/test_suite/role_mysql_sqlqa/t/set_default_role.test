SELECT CURRENT_ROLE();
SET ROLE all except zc_user3;
SELECT CURRENT_ROLE();
SET ROLE all except zc_user1,zc_user3,zc_role11;
SELECT CURRENT_ROLE();
SET ROLE all except '';
SELECT CURRENT_ROLE();

SET ROLE NONE;
SELECT CURRENT_ROLE();


