SELECT CURRENT_ROLE();
SET ROLE all;
SELECT CURRENT_ROLE();
SET ROLE all except zc_role1;
SELECT CURRENT_ROLE();
SET ROLE all except zc_role1,zc_role2;
SELECT CURRENT_ROLE();
SET ROLE all except zc_role2,zc_user2;
SELECT CURRENT_ROLE();
