#### 5-3SET ROLE ####
####5-3-1set role default
--echo CONNECT zc_user1
DISCONNECT zc_user1;
connect (zc_user1,$OBMYSQL_MS0,zc_user1,,*NO-ONE*,$OBMYSQL_PORT);
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();
SET DEFAULT ROLE zc_role1 to zc_user1;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE all to zc_user1;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE NONE to zc_user1;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

--echo CONNECT zc_role2
DISCONNECT zc_role2;
connect (zc_role2,$OBMYSQL_MS0,zc_role2,,*NO-ONE*,$OBMYSQL_PORT);
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();
SET DEFAULT ROLE zc_role1 to zc_role2;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE zc_role1,zc_role3 to zc_role2;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE all to zc_role2;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

SET DEFAULT ROLE NONE to zc_role2;
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();

####5-3-2set role 'role'
--echo CONNECT zc_user1
connection zc_user1;
SELECT CURRENT_ROLE();
SET ROLE zc_role1;
SELECT CURRENT_ROLE();
SET ROLE zc_role1,zc_role2;
SELECT CURRENT_ROLE();
--error 3530
SET ROLE zc_user1;

--echo CONNECT zc_role2
connection zc_role2;
SELECT CURRENT_ROLE();
SET ROLE zc_role1;
SELECT CURRENT_ROLE();
SET ROLE zc_role1,zc_user2;
SELECT CURRENT_ROLE();
--error 3530
SET ROLE zc_role2;

