-- echo 1·1、使用DROP ROLE IF EXISTS role_name语法删除role（本期未实现）
-- echo 1·2、使用DROP ROLE role_name语法删除role

# 删除已存在role
drop role role1;

drop role role2,role3;

# 删除不存在role
-- error 1396
drop role role5;
-- error 1396
drop role role5,role6;

# 同时删除已存在和不存在的role
select user from mysql.user where user in('role4','role5');
-- error 1396
drop role role4,role5;
select user from mysql.user where user in('role4','role5');




-- echo 1·3、使用DROP ROLE role_name语法同时删除未锁定和锁定的role
# 删除未锁定的role
drop role role7;
select user,account_locked from mysql.user WHERE user in('role7','role8','role9');

# 同时删除未锁定和锁定的role
drop role role8,role9,role10;
select user,account_locked from mysql.user WHERE user in('role7','role8','role9');




