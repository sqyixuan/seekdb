-- echo 未启用系统变量read_only时
# 验证 grant xxx on *.* to xxx with grant option 和 grant grant option on *.* to xxx 的区别
# 结论： 都支持转授。前者带有with grant option的权限支持转授，后者自身的所有权限都支持转授（系统权限不确定）
-- echo 1、登录账户被授权的语法是grant xxx on *.* to xxx with grant option【补充场景】
connect (conn_user_grant_option_191,$OBMYSQL_MS0,user_grant_option,123,hal_db,$OBMYSQL_PORT);
connection conn_user_grant_option_191;
# mysql -uuser_grant_option -p123
# ./obclient -h100.88.109.130 -P10016 -uuser_grant_option -p123
show grants for 'user_grant_option';
