-- echo 1·1、当前账户具有SUPER权限
# Role登录数据库
connect (role1_644,$OBMYSQL_MS0,role1,123,mysql,$OBMYSQL_PORT);
connection role1_644;
# mysql -urole1 -p123
# ./obclient -h100.88.109.130 -P10016 -urole1 -p123

# 场景1：角色授予给角色
# one to one
show grants for 'role1';
grant role1 to role3;
grant role2 to role3;
select
    *
from
    mysql.role_edges
where
    (from_user='role1' and to_user='role3') or
    (from_user='role2' and to_user='role3');

# one to many
grant role2 to role4,role5;
select
    *
from
    mysql.role_edges
where
    (from_user='role2' and to_user='role4') or
    (from_user='role2' and to_user='role5');

# many to one
grant role7,role8 to role2;
select
    *
from
    mysql.role_edges
where
    (from_user='role7' and to_user='role2') or
    (from_user='role8' and to_user='role2');
# many to many
grant role7,role8 to role4,role5;
select
    *
from
    mysql.role_edges
where
    (from_user='role7' and to_user='role4') or
    (from_user='role8' and to_user='role5');


# 场景2：角色授予给用户
# one to one
grant role1 to user1;
select
    *
from
    mysql.role_edges
where
    (from_user='role1' and to_user='user1');

# one to many
grant role1 to user2,user3;
select
    *
from
    mysql.role_edges
where
    (from_user='role1' and to_user='user1') or
    (from_user='role1' and to_user='user2') or
    (from_user='role1' and to_user='user3');

# many to one
grant role1,role2,role3 to user4;
select
    *
from
    mysql.role_edges
where
    (from_user='role1' and to_user='user4') or
    (from_user='role2' and to_user='user4') or
    (from_user='role3' and to_user='user4');

# many to many
grant role1,role2,role3 to user5,user6;
select * from mysql.role_edges
where
    (from_user='role1' and to_user='user5') or
    (from_user='role2' and to_user='user5') or
