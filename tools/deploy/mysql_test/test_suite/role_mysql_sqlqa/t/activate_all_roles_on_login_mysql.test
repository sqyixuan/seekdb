#owner:jim.wjh
#owner group:sql1
#tags:DML\DDL
#description:系统变量 activate_all_roles_on_login
#author:wb-zcp01469308
--disable_query_log
#Environmental cleaning
--error 0,1396
drop user admin_hal@'%';
create user admin_hal identified by '123';
grant all privileges on *.* to admin_hal WITH GRANT OPTION;
--enable_query_log

###切换测试用户
connect (conn,$OBMYSQL_MS0,admin_hal,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS hal_db;
--enable_warnings
###创建DB，切换DB测试
create database hal_db character set utf8;
use hal_db;





--result_format 4
# 测试数据
-- error 0,1051
drop table riel;
create table riel(id int,name char(20),age int);
insert into riel values(1,'hal',1000);
insert into riel values(2,'riel',1200);
select * from riel;

-- error 0,1396
drop user halA;
create user halA identified by '123';
grant select on hal_db.* to halA;

-- error 0,1396
drop user halB;
create user halB identified by '123';
grant super on *.* to halB;

-- error 0,1396
drop role role_g1;
-- error 0,1396
drop role role_g2;
-- error 0,1396
drop role role_g3;

create role role_g1;
create role role_g2;
create role role_g3;

grant select on hal_db.riel to role_g1;
grant update on hal_db.riel to role_g2;

grant role_g1 to halB;
grant role_g2 to halB;
grant role_g3 to halB;
set default role role_g1 to halB;




############################### 拥有SUPER权限，支持更改该全局变量 ################################
-- echo set global activate_all_roles_on_login = OFF;（默认）
connect (conn_halB,$OBMYSQL_MS0,halB,123,hal_db,$OBMYSQL_PORT);
connection conn_halB;
# mysql -uhalB -p123
# ./obclient -h100.88.109.130 -P10016 -uhalB -p123

set global activate_all_roles_on_login = OFF;
show grants for 'halB';
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
select current_role();
select * from information_schema.enabled_roles;


# 重新登录
disconnect conn_halB;
connect (conn_halB2,$OBMYSQL_MS0,halB,123,hal_db,$OBMYSQL_PORT);
connection conn_halB2;
-- echo 重新登录
# mysql -uhalB -p123
# ./obclient -h100.88.109.130 -P10016 -uhalB -p123

show grants for 'halB';
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
SELECT @@global.activate_all_roles_on_login;
select current_role();
select * from information_schema.enabled_roles;

select * from hal_db.riel;
-- error 1142
update hal_db.riel set age=2100 where id=2;






-- echo set global activate_all_roles_on_login = ON;
set global activate_all_roles_on_login = ON;
show grants for 'halB';
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
SELECT @@global.activate_all_roles_on_login;

select current_role();


# 重新登录
connect (conn_halB3,$OBMYSQL_MS0,halB,123,hal_db,$OBMYSQL_PORT);
connection conn_halB3;
-- echo 重新登录
# mysql -uhalB -p123
# ./obclient -h100.88.109.130 -P10016 -uhalB -p123

show grants for 'halB';
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
SELECT @@global.activate_all_roles_on_login;
select current_role();

select * from hal_db.riel;
-- error 0,1142
update hal_db.riel set age=2100 where id=2;
select * from hal_db.riel;


# 恢复默认值
set global activate_all_roles_on_login = OFF;
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
SELECT @@global.activate_all_roles_on_login;
show grants for 'halB';
select current_role();
select * from information_schema.enabled_roles;


############################### 未拥有SUPER权限，不支持支持更改该全局变量 ###########################
connect (conn_halA,$OBMYSQL_MS0,halA,123,hal_db,$OBMYSQL_PORT);
connection conn_halA;

# mysql -uhalA -p123
# ./obclient -h100.88.109.130 -P10016 -uhalA -p123
show grants for 'halA';
SHOW VARIABLES LIKE 'activate_all_roles_on_login';

-- error 1227
set global activate_all_roles_on_login = on;

-- error 1227
set global activate_all_roles_on_login = OFF;
SHOW VARIABLES LIKE 'activate_all_roles_on_login';



-- echo 恢复环境
connection conn;
set global activate_all_roles_on_login = OFF;
SHOW VARIABLES LIKE 'activate_all_roles_on_login';




--echo ################################# 清空回收站,删除测试数据库,表等 ##################################
connection default;

--disable_warnings
--error 0,1396
drop user admin_hal@'%' ;
--enable_warnings

purge recyclebin;
