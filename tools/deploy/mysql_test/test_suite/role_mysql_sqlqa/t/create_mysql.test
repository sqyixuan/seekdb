# 有create user权限的role来执行的存储过程，执行成功
connect (conn_role_definer_priv_899,$OBMYSQL_MS0,role_definer_priv,123,mysql,$OBMYSQL_PORT);
connection conn_role_definer_priv_899;
# mysql -urole_definer_priv -p123
# ./obclient -h100.88.109.130 -P10016 -urole_definer_priv -p123
call hal_db.drop_create_role();

