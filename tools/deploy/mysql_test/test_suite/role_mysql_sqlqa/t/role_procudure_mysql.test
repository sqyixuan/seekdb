connection default;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

use test;

--result_format 4
# 恢复环境 read_only=OFF
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';

-- error 0,1051
drop table hal;
create table hal(id int,name char(20));
insert into hal values(1,'hal');
select * from hal;

--disable_warnings
-- error 0,1396
drop user user_procedure1;
create user user_procedure1 identified by '123';
-- error 0,1396
drop user user_procedure2;
create user user_procedure2 identified by '123';
-- error 0,1396
drop user user_procedure3;
create user user_procedure3 identified by '123';
-- error 0,1396
drop user user_procedure4;
create user user_procedure4 identified by '123';
select user from mysql.user where user in (
    'user_procedure1',
    'user_procedure2',
    'user_procedure3',
    'user_procedure4'
) order by user desc;

-- error 0,1396
drop role role_procedure1;
create role role_procedure1;
ALTER USER 'role_procedure1' ACCOUNT UNLOCK;
ALTER USER 'role_procedure1'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_procedure1' AND account_locked = 'N';
-- error 0,1396
drop role role_procedure2;
create role role_procedure2;
ALTER USER 'role_procedure2' ACCOUNT UNLOCK;
ALTER USER 'role_procedure2'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_procedure2' AND account_locked = 'N';
-- error 0,1396
drop role role_procedure3;
create role role_procedure3;
ALTER USER 'role_procedure3' ACCOUNT UNLOCK;
ALTER USER 'role_procedure3'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_procedure3' AND account_locked = 'N';
-- error 0,1396
drop role role_procedure4;
create role role_procedure4;
ALTER USER 'role_procedure4' ACCOUNT UNLOCK;
ALTER USER 'role_procedure4'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_procedure4' AND account_locked = 'N';
-- error 0,1396
drop role role_procedure5;
create role role_procedure5;
ALTER USER 'role_procedure5' ACCOUNT UNLOCK;
ALTER USER 'role_procedure5'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_procedure5' AND account_locked = 'N';
--enable_warnings


-- error 0,1305
DROP PROCEDURE procedure_to_role1;
DELIMITER /;
CREATE DEFINER = 'role_procedure4' PROCEDURE procedure_to_role1()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/

-- error 0,1305
DROP PROCEDURE procedure_to_role2;
DELIMITER /;
CREATE PROCEDURE procedure_to_role2()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/

-- error 0,1305
DROP PROCEDURE procedure_to_role3;
DELIMITER /;
CREATE DEFINER = 'role_procedure5' PROCEDURE procedure_to_role3()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/

-- error 0,1305
DROP PROCEDURE procedure_test1;
DELIMITER /;
CREATE PROCEDURE procedure_test1()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/
-- error 0,1305
DROP PROCEDURE procedure_test1_1;
DELIMITER /;
CREATE PROCEDURE procedure_test1_1()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/
-- error 0,1305
DROP PROCEDURE procedure_test4;
DELIMITER /;
CREATE PROCEDURE procedure_test4()
BEGIN
    select * from test.hal;
END /
DELIMITER ;/





-- echo 授予表权限
grant select,create on test.* to role_procedure1;
grant select,create on test.* to role_procedure2;
grant select,create on test.* to role_procedure3;
grant select,create on test.* to role_procedure4;
grant select,create on test.* to role_procedure5;

grant select,create on test.* to user_procedure1;
grant select,create on test.* to user_procedure2;
grant select,create on test.* to user_procedure3;
grant select,create on test.* to user_procedure4;

-- echo 分别授予role删除、创建、执行存储过程的权限
GRANT ALTER ROUTINE ON *.* TO 'role_procedure1'@'%';
# mysql drop procedure 还需要system_user，ob目前没有system_user权限
# GRANT system_user ON *.* TO 'role_procedure1'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_procedure2'@'%';
GRANT EXECUTE ON PROCEDURE test.procedure_to_role1 to 'role_procedure3'@'%';
GRANT EXECUTE ON PROCEDURE test.procedure_to_role2 to 'role_procedure3'@'%';

-- echo role_procedure4拥有删除、创建、执行存储过程的权限
GRANT ALTER ROUTINE ON *.* TO 'role_procedure4'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_procedure4'@'%';
GRANT EXECUTE ON PROCEDURE test.procedure_to_role2 to 'role_procedure4'@'%';

show grants for role_procedure1;
show grants for role_procedure2;
show grants for role_procedure3;
show grants for role_procedure4;
show grants for role_procedure5;


-- echo 把拥有删除、创建、执行存储过程权限的role分别授予给用户
grant role_procedure1 to user_procedure1;
grant role_procedure2 to user_procedure2;
grant role_procedure3 to user_procedure3;
grant role_procedure4 to user_procedure4;



############################## role登录场景 #########################
-- echo 仅有删除储存过程权限
connect (role_procedure1,$OBMYSQL_MS0,role_procedure1,123,test,$OBMYSQL_PORT);
connection role_procedure1;
DROP PROCEDURE procedure_test1;
DELIMITER /;
-- error 1370
CREATE PROCEDURE procedure_test1()
BEGIN

END /
DELIMITER ;/
-- error 1370
call procedure_to_role2;

-- echo 仅有创建储存过程权限
connect (role_procedure2,$OBMYSQL_MS0,role_procedure2,123,test,$OBMYSQL_PORT);
connection role_procedure2;
-- error 1370
DROP PROCEDURE procedure_test2;
DELIMITER /;
CREATE PROCEDURE procedure_test1()
BEGIN
    select * from hal;
END /
DELIMITER ;/
-- error 1370
call procedure_to_role2;

-- echo 仅有执行储存过程权限
connect (role_procedure3,$OBMYSQL_MS0,role_procedure3,123,test,$OBMYSQL_PORT);
connection role_procedure3;
-- error 1370
DROP PROCEDURE procedure_test3;
DELIMITER /;
-- error 1370
CREATE PROCEDURE procedure_test3()
BEGIN

END /
DELIMITER ;/
call procedure_to_role2;
-- echo 不是指定的definer账户，授予执行权限也会报错
-- error 1370
call procedure_to_role1;
--echo 不是执行指定的存储过程，无权限
--error 1305
call procedure_test3;

-- echo 有执行、创建、删除储存过程权限
connect (role_procedure4,$OBMYSQL_MS0,role_procedure4,123,test,$OBMYSQL_PORT);
connection role_procedure4;
DROP PROCEDURE procedure_test4;
DELIMITER /;
CREATE PROCEDURE procedure_test4()
BEGIN
    select * from hal;
END /
DELIMITER ;/
call procedure_test4;
-- echo 有执行存储过程权限，但不是procedure_to_role1的definer
-- error 1370
call procedure_to_role1;

-- echo 当前为definer账户，但没有execute权限
connect (role_procedure5,$OBMYSQL_MS0,role_procedure5,123,test,$OBMYSQL_PORT);
connection role_procedure5;
show grants for role_procedure5;
-- error 1305
call procedure_test3;


############################## user登录场景 #########################
-- echo 仅有删除储存过程权限
connect (user_procedure1,$OBMYSQL_MS0,user_procedure1,123,test,$OBMYSQL_PORT);
connection user_procedure1;
set role role_procedure1;
select CURRENT_ROLE();
DROP PROCEDURE procedure_test1_1;
DELIMITER /;
-- error 1370
CREATE PROCEDURE procedure_test1_1()
BEGIN

END /
DELIMITER ;/
-- error 1370
call procedure_to_role2;

-- echo 仅有创建储存过程权限
connect (user_procedure2,$OBMYSQL_MS0,user_procedure2,123,test,$OBMYSQL_PORT);
connection user_procedure2;
set role role_procedure2;
select CURRENT_ROLE();
-- error 1370
DROP PROCEDURE procedure_test2;
DELIMITER /;
CREATE PROCEDURE procedure_test1_1()
BEGIN
    select * from hal;
END /
DELIMITER ;/
-- error 1370
call procedure_to_role2;

-- echo 仅有执行储存过程权限
connect (user_procedure3,$OBMYSQL_MS0,user_procedure3,123,test,$OBMYSQL_PORT);
connection user_procedure3;
set role role_procedure3;
select CURRENT_ROLE();
-- error 1370
DROP PROCEDURE procedure_test3;
DELIMITER /;
-- error 1370
CREATE PROCEDURE procedure_test3()
BEGIN

END /
DELIMITER ;/
call procedure_to_role2;
-- echo 不是指定的definer账户，授予执行权限也会报错
-- error 1370
call procedure_to_role1;
--error 1305
call procedure_test3;

-- echo 有执行、创建、删除储存过程权限
connect (user_procedure4,$OBMYSQL_MS0,user_procedure4,123,test,$OBMYSQL_PORT);
connection user_procedure4;
set role role_procedure4;
select CURRENT_ROLE();
DROP PROCEDURE procedure_test4;
DELIMITER /;
CREATE PROCEDURE procedure_test4()
BEGIN
    select * from hal;
END /
DELIMITER ;/
call procedure_test4;
call procedure_to_role2;
-- echo 有执行存储过程权限，但不是procedure_to_role1的definer
-- error 1370
call procedure_to_role1;





--echo ################################# 清空回收站,删除测试数据库,表等 ##################################
connection default;

