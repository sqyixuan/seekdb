drop role role_procedure1;
--error 0,1396
drop role role_procedure2;
--error 0,1396
drop role role_procedure3;
--error 0,1396
drop role role_procedure4;
--error 0,1396
drop role role_procedure5;
--error 0,1396
drop user user_procedure1;
--error 0,1396
drop user user_procedure2;
--error 0,1396
drop user user_procedure3;
--error 0,1396
drop user user_procedure4;
