#owner:jim.wjh
#owner group:sql1
#tags:DML\DDL
#description:列授予给角色
#author:wb-zcp01469308
--disable_query_log
#Environmental cleaning
--disable_warnings
--error 0,1396
drop user admin_hal@'%';
create user admin_hal identified by '123';
grant all privileges on *.* to admin_hal WITH GRANT OPTION;
--enable_warnings
--enable_query_log

###切换测试用户
connect (conn,$OBMYSQL_MS0,admin_hal,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS hal_db;
--enable_warnings
###创建DB，切换DB测试
create database hal_db character set utf8;
use hal_db;



--result_format 4

# 测试数据
-- error 0,1051
drop table riel;
create table riel(id int,name char(20),age int,address char(20));
insert into riel values(1,'hal',1000,'hangzhou');
insert into riel values(2,'riel',1200,'suzhou');
select * from riel;

-- error 0,1396
drop user halA;
create user halA identified by '123';

-- error 0,1396
drop user halB;
create user halB identified by '123';

-- error 0,1396
drop user halC;
create user halC identified by '123';

-- error 0,1396
drop role role_g1;
-- error 0,1396
drop role role_g2;
-- error 0,1396
drop role role_g3;

create role role_g1;
create role role_g2;
create role role_g3;

# -- column to user
grant select(id,name) on hal_db.riel to halA;
grant select(age) on hal_db.riel to halA;
grant select(age) on hal_db.riel to halA;
-- error 0,1054
grant select(num) on hal_db.riel to halA;
show grants for halA;


grant select(id,name) on hal_db.riel to halB,halC with grant option;
grant select(age) on hal_db.riel to halB with grant option;
show grants for halB;
grant SUPER on *.* to halB;

grant role_g1 to halB;
grant role_g2 to halB;



############################### 授权账户没有被授对象的权限，将指定列授予给role ###########################
connect (conn_halA,$OBMYSQL_MS0,halA,123,hal_db,$OBMYSQL_PORT);
connection conn_halA;

# mysql -uhalA -p123
# ./obclient -h100.88.109.130 -P10016 -uhalA -p123
show grants for halA;
-- error 1143
select * from hal_db.riel;
select id,age,name from hal_db.riel;
-- error 1143
select address from hal_db.riel;
-- error 1143
select id,address from hal_db.riel;

# -- column to role
-- error 1142
grant select(id) on hal_db.riel to role_g1;
-- error 1142
grant select(name,age) on hal_db.riel to role_g2;




############################### 授权账户有被授对象的权限，将指定列授予给role ##############################
connect (conn_halB,$OBMYSQL_MS0,halB,123,hal_db,$OBMYSQL_PORT);
connection conn_halB;

# mysql -uhalB -p123
# ./obclient -h100.88.109.130 -P10016 -uhalB -p123
show grants for halB;
select id,age,name from hal_db.riel;

# -- column to role
grant select(id) on hal_db.riel to role_g1;
grant select(name,age) on hal_db.riel to role_g2;
-- error 1143
grant select(address) on hal_db.riel to role_g3;

grant role_g1 to halC;
grant role_g2 to halC;



# 验证：列权限授予给角色后，再把角色授予给用户
connect (conn_halC,$OBMYSQL_MS0,halC,123,hal_db,$OBMYSQL_PORT);
connection conn_halC;

# mysql -uhalC -p123
# ./obclient -h100.88.109.130 -P10016 -uhalC -p123
-- error 1143
select id,age,name from hal_db.riel;
select id,name from hal_db.riel;
show grants for halC;
set role role_g1,role_g2;
select id,age,name from hal_db.riel;






--echo ################################# 清空回收站,删除测试数据库,表等 ##################################
connection default;

--disable_warnings
--error 0,1396
drop user admin_hal@'%' ;
--enable_warnings

purge recyclebin;
