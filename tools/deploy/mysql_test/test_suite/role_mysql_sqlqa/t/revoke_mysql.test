######################## 移除当前用户拥有的Role中的权限会在当前会话中生效 ####################
connect (user_C_331,$OBMYSQL_MS0,user_C,,mysql,$OBMYSQL_PORT);
connection user_C_331;
#mysql -uuser_C
#./obclient -h100.88.109.130 -P10016 -uuser_C
-- error 1142
revoke insert on hal_db.riel from role1;

set role role_role,role9;
select current_role();

show grants for user_C;
select * from mysql.role_edges where TO_USER='user_C';
show grants for role_role;

-- echo 授权给当前账户时有grant option，支持revoke
select * from hal_db.hal;
revoke select on hal_db.hal from role_role;
-- error 1142
select * from hal_db.hal;

-- echo 授权给当前账户时有grant option，不支持revoke
select * from hal_db.riel;
-- error 1142
revoke select on hal_db.riel from role_role;
select * from hal_db.riel;


show grants for user_C;
select * from mysql.role_edges where TO_USER='user_C';



######################## REVOKE ALL ON *.* FROM role_name 会撤销当前role拥有的任何权限 ###################
# 创建环境数据
connection conn;
#mysql -uhal -p123 -h100.88.106.200
#./obclient -h100.88.109.130 -P10016 -uhal -p123

-- error 0,1051
drop table hal;
create table hal(id int,age int);
insert into hal values(1,10086);
select * from hal;

-- error 0,1051
drop table riel;
create table riel(id int,name char(20),age int);
insert into riel values(1,'hal',1000);
insert into riel values(2,'riel',1200);
select * from riel;

-- error 0,1396
drop role role3;
-- error 0,1396
drop role role4;
-- error 0,1396
drop role role5;
-- error 0,1396
drop role role6;
-- error 0,1396
drop role role7;

create role role3,role4,role5,role6,role7;

# REVOKE ALL 数据
-- error 0,1396
drop role role_all1;
create role role_all1;
grant CREATE USER on *.* to role_all1;
grant select on hal_db.hal to role_all1;
grant select on mysql.role_edges to role_all1;

grant select on hal_db.riel to role3;
grant role3,role4,role5,role6,role7 to role_all1;

show grants for role_all1;
select * from mysql.role_edges where to_user='role_all1';

# 解锁role
ALTER USER 'role_all1' ACCOUNT UNLOCK;
# 设置role密码
ALTER USER 'role_all1'@'%' IDENTIFIED BY '123';
# 角色被解锁
SELECT user,account_locked FROM mysql.user WHERE user = 'role_all1' AND account_locked = 'N';


-- error 0,1396
drop role role_all2;
create role role_all2;
grant CREATE USER on *.* to role_all2;
grant select on hal_db.hal to role_all2;
grant select on hal_db.riel to role3;
grant select on mysql.role_edges to role_all2;
grant role3,role4,role5,role6,role7 to role_all2;
-- error 0,1396
drop role hal_all2;
create role hal_all2;
grant CREATE USER on *.* to hal_all2;
grant select on hal_db.hal to hal_all2;
grant select on hal_db.riel to role3;
grant select on mysql.role_edges to hal_all2;
grant role3,role4,role5,role6,role7 to hal_all2;

-- error 0,1396
drop user hal_all1;
create user 'hal_all1' identified by '123';
grant select on mysql.role_edges to hal_all1;
grant create user on *.* to hal_all1;
grant select on hal_db.riel to role3;
grant role3,role4,role5,role6,role7 to hal_all1;







