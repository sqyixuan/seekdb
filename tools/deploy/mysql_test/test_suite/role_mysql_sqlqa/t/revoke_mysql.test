--disable_query_log
#Environmental cleaning
--disable_warnings
--error 0,1396
drop user admin_hal@'%';
create user admin_hal identified by '123';
grant all privileges on *.* to admin_hal WITH GRANT OPTION;
--enable_warnings
--enable_query_log

###切换测试用户
connect (conn,$OBMYSQL_MS0,admin_hal,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS hal_db;
--enable_warnings
###创建DB，切换DB测试
create database hal_db character set utf8;
use hal_db;




--result_format 4
# 恢复环境 read_only=OFF
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';



######################## 移除当前角色拥有的Role会在当前会话中生效（角色登录数据库）###########################
# REVOKE SELECT ON *.* FROM role1;语法

# mysql -uhal -p123
#./obclient -h100.88.109.130 -P10016 -uhal -p123
-- error 0,1008
drop database hal_db;
create database hal_db;
use hal_db;

-- error 0,1051
drop table hal;
create table hal(id int);
insert into hal values(10086);
select * from hal;

-- error 0,1051
drop table riel;
create table riel(id int,name char(20),age int);
insert into riel values(1,'hal',1000);
insert into riel values(2,'riel',1200);
select * from riel;

-- error 0,1396
drop role role1;
-- error 0,1396
drop role role2;
-- error 0,1396
drop role role3;
-- error 0,1396
drop role role4;
-- error 0,1396
drop role role5;
-- error 0,1396
drop role role6;
-- error 0,1396
drop role role7;
-- error 0,1396
drop role role8;
-- error 0,1396
drop role role10;

create role role1;
create role role2;
create role role3;
create role role4;
create role role5;
create role role6;
create role role7;
create role role8;
create role role10;

select user from mysql.user where user in(
    'role1','role2','role3','role4','role5',
    'role6','role7','role8','role10'
);

grant delete on hal_db.riel to role10;
grant role10 to role2;

grant super on *.* to role2;
grant select on mysql.role_edges to role2;
grant select on hal_db.hal to role1;
grant update,insert on hal_db.hal to role2;
grant insert,select on hal_db.riel to role1;
grant role1,role3,role4,role5,role6,role7 to role2;

show grants for role2;
select * from  mysql.role_edges where to_user='role2';

-- error 0,1396
drop user halA;
create user halA;

grant super on *.* to halA;
grant select on mysql.role_edges to halA;
grant update,insert on hal_db.hal to halA;
grant insert,select on hal_db.riel to halA with grant option;
grant role1,role3,role4,role5,role6,role7 to halA;
show grants for halA;

-- error 0,1396
drop user halB;
create user halB;

-- error 0,1396
drop role role9;
create role role9;
grant select on mysql.role_edges to halB;
grant select,update,insert on hal_db.hal to halB;
grant insert,select on hal_db.riel to halB with grant option;
grant role1,role3,role9 to halB;
grant select on mysql.role_edges to halB;
show grants for 'halB';


grant select on mysql.role_edges to role8;
grant select,update,insert on hal_db.hal to role8;
grant insert,select on hal_db.riel to role8 with grant option;
grant role1,role3,role4,role5,role6,role7 to role8;
show grants for 'role8';

-- error 0,1396
drop role role_role;
create role role_role;

-- error 0,1396
drop user user_C;
create user user_C;

grant select on mysql.* to user_C;
grant select on hal_db.hal to role_role with grant option;
grant insert,select on hal_db.riel to role_role;
grant role9,role_role to user_C;
show grants for 'user_C';



# 解锁role
ALTER USER 'role2' ACCOUNT UNLOCK;
ALTER USER 'role8' ACCOUNT UNLOCK;
#ALTER USER 'role11' ACCOUNT UNLOCK;
# 设置role密码
ALTER USER 'role2'@'%' IDENTIFIED BY '123';
ALTER USER 'role8'@'%' IDENTIFIED BY '123';
#ALTER USER 'role11'@'%' IDENTIFIED BY '123';
# 角色被解锁
SELECT user,account_locked FROM mysql.user WHERE user = 'role2' AND account_locked = 'N';
SELECT user,account_locked FROM mysql.user WHERE user = 'role8' AND account_locked = 'N';
#SELECT user,account_locked FROM mysql.user WHERE user = 'role11' AND account_locked = 'N';




# 有super权限
connect (role2_172,$OBMYSQL_MS0,role2,123,hal_db,$OBMYSQL_PORT);
connection role2_172;
#mysql -urole2 -p123
#./obclient -h100.88.109.130 -P10016 -urole2 -p123
-- echo 移除单个role
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';
-- error 1142
select * from hal_db.hal;
-- error 3530
set role role2;
set role role1;
select CURRENT_ROLE();

-- error 3523
revoke role111111111c from role2;

revoke role8 from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

-- error 1142
revoke insert on hal_db.hal from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

-- error 1142
revoke select on hal_db.hal from role2;
-- error 1142
revoke delete on hal_db.hal from role2;
-- error 1142
revoke update on hal_db.hal from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

-- echo 移除多个role
revoke role3,role4 from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

revoke role3,role4,role5 from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

-- error 3523
revoke role6,role51111111c from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

revoke role7,role8 from role2;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';

# 移除当前角色拥有的Role中的权限会在当前会话中生效（角色登录数据库）
-- error 1142
revoke delete on hal_db.riel from role10;
select * from hal_db.riel;

# 移除当前角色拥有的Role会在当前会话中生效
select * from hal_db.hal;
revoke role1 from role2;
-- error 0,1142
select * from hal_db.hal;
show grants for role2;
select * from mysql.role_edges where TO_USER='role2';




# 无super权限
connect (role8_242,$OBMYSQL_MS0,role8,123,hal_db,$OBMYSQL_PORT);
connection role8_242;
#mysql -urole8 -p123
#./obclient -h100.88.109.130 -P10016 -urole8 -p123
show grants for 'role8';

-- error 1142
revoke insert on hal_db.hal from role8;
revoke insert on hal_db.riel from role8;
-- error 1227
revoke role1 from role8;

show grants for 'role8';






