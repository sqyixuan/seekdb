-- error 3523
revoke role111111111c from halA;


-- error 1142
revoke insert on hal_db.hal from halA;
show grants for halA;
select * from mysql.role_edges where TO_USER='halA';

-- echo 移除多个role
revoke role3,role4 from halA;
show grants for halA;
select * from mysql.role_edges where TO_USER='halA';

revoke role3,role4,role5 from halA;
show grants for halA;
select * from mysql.role_edges where TO_USER='halA';

-- error 3523
revoke role6,role51111111c from halA;
show grants for halA;
select * from mysql.role_edges where TO_USER='halA';

revoke role7,role8 from halA;
show grants for halA;
select * from mysql.role_edges where TO_USER='halA';


# 无super权限
connect (halB_312,$OBMYSQL_MS0,halB,,hal_db,$OBMYSQL_PORT);
connection halB_312;
