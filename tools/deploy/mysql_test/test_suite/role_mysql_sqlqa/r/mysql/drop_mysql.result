drop table hal_db.lianjiechuan;
create table hal_db.lianjiechuan(id int);
grant select on hal_db.lianjiechuan to role9;
grant select on hal_db.lianjiechuan to role11;
grant select on hal_db.lianjiechuan to role12;

alter user 'role12'@'%' identified by '123';
alter user 'role11'@'%' identified by '123';
alter user 'role9'@'%' identified by '123';

alter user 'role7' account unlock;
alter user 'role8' account unlock;
alter user 'role9' account unlock;
alter user 'role11' account unlock;

select
    user,account_locked
from
    mysql.user
WHERE
    user in('role7','role8','role9','role11','role12') and account_locked = 'N';
+--------+----------------+
| user   | account_locked |
+--------+----------------+
| role7  | N              |
| role8  | N              |
| role9  | N              |
| role11 | N              |
+--------+----------------+

1·1、使用DROP ROLE IF EXISTS role_name语法删除role（本期未实现）
1·2、使用DROP ROLE role_name语法删除role
drop role role1;

drop role role2,role3;

drop role role5;
ERROR HY000: Operation DROP ROLE failed for 'role5'@'%'
drop role role5,role6;
ERROR HY000: Operation DROP ROLE failed for 'role5'@'%','role6'@'%'

select user from mysql.user where user in('role4','role5');
+-------+
| user  |
+-------+
| role4 |
+-------+
drop role role4,role5;
ERROR HY000: Operation DROP ROLE failed for 'role5'@'%'
select user from mysql.user where user in('role4','role5');
+-------+
| user  |
+-------+
| role4 |
+-------+


1·3、使用DROP ROLE role_name语法同时删除未锁定和锁定的role
drop role role7;
select user,account_locked from mysql.user WHERE user in('role7','role8','role9');
+-------+----------------+
| user  | account_locked |
+-------+----------------+
| role8 | N              |
| role9 | N              |
+-------+----------------+

drop role role8,role9,role10;
select user,account_locked from mysql.user WHERE user in('role7','role8','role9');
+------+----------------+
| user | account_locked |
+------+----------------+
+------+----------------+


1·4、被删除的role无法登录数据库
show grants for role11;
Grants for role11@%
GRANT USAGE ON *.* TO 'role11'
GRANT SELECT ON `hal_db`.`lianjiechuan` TO 'role11'
ERROR HY000: User locked
ERROR 42000: Access denied for user 'role9'@'xxx.xxx.xxx.xxx' (using password: YES)

拥有create user权限启用系统变量read_only时
SET GLOBAL read_only = ON;
SHOW VARIABLES LIKE 'read_only';
Variable_name	Value
read_only	ON

drop role role16;
drop role role17,role18;
select user from mysql.user where user in('role16','role17','role18');
+------+
| user |
+------+
+------+


拥有create user权限启用系统变量read_only时
drop role role13;
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
drop role role14,role15;
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
select user from mysql.user where user in('role13','role14','role15');
+--------+
| user   |
+--------+
| role13 |
| role14 |
| role15 |
+--------+



######################## 当前用户没有有删除ROLE权限 ########################
drop user user_uncreateS;
create user 'user_uncreateS' identified by '123';
grant super on *.* to user_uncreateS;
grant select on mysql.user to user_uncreateS;

drop user user_uncreate;
create user 'user_uncreate' identified by '123';
grant select on mysql.user to user_uncreate;

drop role role_uncreateS;
create role 'role_uncreateS';
grant super on *.* to role_uncreateS;
grant select on mysql.user to role_uncreateS;
alter user 'role_uncreateS'@'%' identified by '123';
alter user 'role_uncreateS' account unlock;

drop role role_uncreate;
create role 'role_uncreate';
grant select on mysql.user to role_uncreate;
alter user 'role_uncreate'@'%' identified by '123';
alter user 'role_uncreate' account unlock;

select user from mysql.user where user in ('user_uncreateS','user_uncreate','role_uncreateS','role_uncreate');
+----------------+
| user           |
+----------------+
| user_uncreateS |
| user_uncreate  |
| role_uncreateS |
| role_uncreate  |
+----------------+

