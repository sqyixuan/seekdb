create role role4;
create role role5;
create role role6;

select user from mysql.user where user in ('role1','role2','role3','role4','role5','role6');
+-------+
| user  |
+-------+
| role1 |
| role2 |
| role3 |
| role4 |
| role5 |
| role6 |
+-------+

当启用系统变量read_only
drop role role1;
ERROR 42501: Access denied; you need (at least one of) the CREATE USER or DROP ROLE privilege(s) for this operation

drop role role1;
ERROR 42501: Access denied; you need (at least one of) the CREATE USER or DROP ROLE privilege(s) for this operation

