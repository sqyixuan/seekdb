set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';
Variable_name	Value
read_only	OFF


######################## 当前用户具有删除ROLE权限 (create user)########################

1、当前用户拥有全局权限CREATE USER
drop user user1;
create user 'user1' identified by '123';
grant create user on *.* to 'user1';
grant select on mysql.user to user1;
select host,user,Create_user_priv from mysql.user where user='user1' and Create_user_priv='Y';
+------+-------+------------------+
| host | user  | Create_user_priv |
+------+-------+------------------+
| %    | user1 | Y                |
+------+-------+------------------+

drop user user_super;
create user 'user_super' identified by '123';
grant create user on *.* to 'user_super';
grant super on *.* to 'user_super';
grant select on mysql.user to user_super;
select
    host,user,Create_user_priv,super_priv
from
    mysql.user
where
    user='user_super' and
    Create_user_priv='Y'and
    super_priv='Y';
+------+------------+------------------+------------+
| host | user       | Create_user_priv | super_priv |
+------+------------+------------------+------------+
| %    | user_super | Y                | Y          |
+------+------------+------------------+------------+

drop user user_unsuper;
create user 'user_unsuper' identified by '123';
grant create user on *.* to 'user_unsuper';
grant select on mysql.user to user_unsuper;
select
    host,user,Create_user_priv,super_priv
from
    mysql.user
where
    user='user_unsuper' and
    Create_user_priv='Y'and
    super_priv='N';
+------+--------------+------------------+------------+
| host | user         | Create_user_priv | super_priv |
+------+--------------+------------------+------------+
| %    | user_unsuper | Y                | N          |
+------+--------------+------------------+------------+


