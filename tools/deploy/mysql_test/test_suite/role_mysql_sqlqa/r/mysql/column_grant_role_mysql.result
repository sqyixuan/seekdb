set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
drop table riel;
create table riel(id int,name char(20),age int,address char(20));
insert into riel values(1,'hal',1000,'hangzhou');
insert into riel values(2,'riel',1200,'suzhou');
select * from riel;
+------+------+------+----------+
| id   | name | age  | address  |
+------+------+------+----------+
|    1 | hal  | 1000 | hangzhou |
|    2 | riel | 1200 | suzhou   |
+------+------+------+----------+

drop user halA;
create user halA identified by '123';

drop user halB;
create user halB identified by '123';

drop user halC;
create user halC identified by '123';

drop role role_g1;
drop role role_g2;
drop role role_g3;

create role role_g1;
create role role_g2;
create role role_g3;

grant select(id,name) on hal_db.riel to halA;
grant select(age) on hal_db.riel to halA;
grant select(age) on hal_db.riel to halA;
grant select(num) on hal_db.riel to halA;
show grants for halA;
Grants for halA@%
GRANT USAGE ON *.* TO 'halA'
GRANT SELECT (`age`, `id`, `name`, `num`) ON `hal_db`.`riel` TO 'halA'

grant select(id,name) on hal_db.riel to halB,halC with grant option;
grant select(age) on hal_db.riel to halB with grant option;
show grants for halB;
Grants for halB@%
GRANT USAGE ON *.* TO 'halB'
GRANT SELECT (`age`, `id`, `name`) ON `hal_db`.`riel` TO 'halB' WITH GRANT OPTION
grant SUPER on *.* to halB;

grant role_g1 to halB;
grant role_g2 to halB;


############################### 授权账户没有被授对象的权限，将指定列授予给role ###########################

show grants for halA;
Grants for halA@%
GRANT USAGE ON *.* TO 'halA'
GRANT SELECT (`age`, `id`, `name`, `num`) ON `hal_db`.`riel` TO 'halA'
select * from hal_db.riel;
ERROR 42000: SELECT command denied to user 'halA'@'%' for column 'address' in table 'riel'
select id,age,name from hal_db.riel;
+------+------+------+
| id   | age  | name |
+------+------+------+
|    1 | 1000 | hal  |
|    2 | 1200 | riel |
+------+------+------+
select address from hal_db.riel;
ERROR 42000: SELECT command denied to user 'halA'@'%' for column 'address' in table 'riel'
select id,address from hal_db.riel;
ERROR 42000: SELECT command denied to user 'halA'@'%' for column 'address' in table 'riel'

grant select(id) on hal_db.riel to role_g1;
ERROR 42000: GRANT command denied to user 'halA'@'%' for table 'riel'
grant select(name,age) on hal_db.riel to role_g2;
ERROR 42000: GRANT command denied to user 'halA'@'%' for table 'riel'


############################### 授权账户有被授对象的权限，将指定列授予给role ##############################

show grants for halB;
Grants for halB@%
GRANT SUPER ON *.* TO 'halB'
GRANT SELECT (`age`, `id`, `name`) ON `hal_db`.`riel` TO 'halB' WITH GRANT OPTION
GRANT `role_g2`@`%`,`role_g1`@`%` TO `halB`@`%`
select id,age,name from hal_db.riel;
+------+------+------+
| id   | age  | name |
+------+------+------+
|    1 | 1000 | hal  |
|    2 | 1200 | riel |
+------+------+------+

grant select(id) on hal_db.riel to role_g1;
grant select(name,age) on hal_db.riel to role_g2;
grant select(address) on hal_db.riel to role_g3;
ERROR 42000: SELECT command denied to user 'halB'@'%' for column 'address' in table 'riel'

grant role_g1 to halC;
grant role_g2 to halC;



select id,age,name from hal_db.riel;
ERROR 42000: SELECT command denied to user 'halC'@'%' for column 'age' in table 'riel'
select id,name from hal_db.riel;
+------+------+
| id   | name |
+------+------+
|    1 | hal  |
|    2 | riel |
+------+------+
show grants for halC;
Grants for halC@%
GRANT USAGE ON *.* TO 'halC'
GRANT SELECT (`id`, `name`) ON `hal_db`.`riel` TO 'halC' WITH GRANT OPTION
GRANT `role_g2`@`%`,`role_g1`@`%` TO `halC`@`%`
set role role_g1,role_g2;
select id,age,name from hal_db.riel;
+------+------+------+
| id   | age  | name |
+------+------+------+
|    1 | 1000 | hal  |
|    2 | 1200 | riel |
+------+------+------+



################################# 清空回收站,删除测试数据库,表等 ##################################

drop user admin_hal@'%' ;
purge recyclebin;
