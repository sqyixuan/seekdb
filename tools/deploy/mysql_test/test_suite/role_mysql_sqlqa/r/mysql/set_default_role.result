result_format: 4
PURGE RECYCLEBIN;
########## 5设置默认角色 ##########
#### 5-1SET DEFAULT ROLE ####
####5-1-1当前用户/角色set
DROP user halB;
DROP user zc_user1;
DROP user zc_user2;
DROP user zc_user3;
DROP role zc_role1;
DROP role zc_role2;
DROP role zc_role3;
CREATE user zc_user1,zc_user2,zc_user3;
CREATE role zc_role1,zc_role2,zc_role3;
####role to user
GRANT zc_role1 to zc_user1;
SELECT * FROM mysql.default_roles ;
+------+------+-------------------+-------------------+
| HOST | USER | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+------+-------------------+-------------------+
+------+------+-------------------+-------------------+
CONNECT zc_user1
SET DEFAULT ROLE zc_role1 to zc_user1;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
####role to role
CONNECT DEFAULT
GRANT zc_role1 to zc_role2;
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_user1 | %                 | zc_role1          |
+------+----------+-------------------+-------------------+
ALTER USER 'zc_role2' ACCOUNT UNLOCK;
CONNECT zc_role2
##mysql执行这条语句之前要重置role2的密码ALTER USER zc_role2 IDENTIFIED BY ''
SET DEFAULT ROLE zc_role1 to zc_role2;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
####none to USER
CONNECT zc_user1
SET DEFAULT ROLE NONE to zc_user1;
CONNECT zc_user1
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
####none to ROLES
CONNECT zc_role2
SET DEFAULT ROLE NONE to zc_role2;
CONNECT zc_role2
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
####all to USER
CONNECT DEFAULT
GRANT zc_role1,zc_role2,zc_role3,zc_user2,zc_user3 to zc_user1;
SELECT * FROM mysql.default_roles ;
+------+------+-------------------+-------------------+
| HOST | USER | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+------+-------------------+-------------------+
+------+------+-------------------+-------------------+
CONNECT zc_user1
SET DEFAULT ROLE all to zc_user1;
CONNECT zc_user1
SELECT CURRENT_ROLE();
+----------------------------------------------------------------------------+
| CURRENT_ROLE()                                                             |
+----------------------------------------------------------------------------+
| `zc_role3`@`%`,`zc_role2`@`%`,`zc_role1`@`%`,`zc_user3`@`%`,`zc_user2`@`%` |
+----------------------------------------------------------------------------+
####all to ROLE
CONNECT DEFAULT
GRANT zc_role1,zc_role3,zc_user2,zc_user3 to zc_role2;
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_user1 | %                 | zc_role1          |
| %    | zc_user1 | %                 | zc_role2          |
| %    | zc_user1 | %                 | zc_role3          |
| %    | zc_user1 | %                 | zc_user2          |
| %    | zc_user1 | %                 | zc_user3          |
+------+----------+-------------------+-------------------+
CONNECT zc_role2
SET DEFAULT ROLE all to zc_role2;
CONNECT zc_role2
SELECT CURRENT_ROLE();
+-------------------------------------------------------------+
| CURRENT_ROLE()                                              |
+-------------------------------------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%`,`zc_user3`@`%`,`zc_user2`@`%` |
+-------------------------------------------------------------+
####zc_role1,zc_role2 to user
CONNECT zc_user1
SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1;
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role2`@`%`,`zc_role1`@`%` |
+-------------------------------+
####zc_role1,zc_role2 to role
CONNECT zc_role2
SET DEFAULT ROLE zc_role1,zc_role3 to zc_role2;
CONNECT zc_role2
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%` |
+-------------------------------+
CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_role2 | %                 | zc_role1          |
| %    | zc_role2 | %                 | zc_role3          |
| %    | zc_user1 | %                 | zc_role1          |
| %    | zc_user1 | %                 | zc_role2          |
+------+----------+-------------------+-------------------+
####当前账户未拥有该角色权限####
revoke zc_role1,zc_role2,zc_role3,zc_user1,zc_user2,zc_user3 from zc_user1;
revoke zc_role1,zc_role2,zc_role3,zc_user1,zc_user2,zc_user3 from zc_role2;
####role to USER
CONNECT zc_user1
SET DEFAULT ROLE zc_role1 to zc_user1;
ERROR HY000: `zc_role1`@`%` is not granted to `zc_user1`@`%`
SET DEFAULT ROLE zc_user2 to zc_user1;
ERROR HY000: `zc_user2`@`%` is not granted to `zc_user1`@`%`
####zc_role1,zc_role2 to user
SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1;
ERROR HY000: `zc_role1`@`%` is not granted to `zc_user1`@`%`
CONNECT DEFAULT
GRANT zc_role1 to zc_user1;
CONNECT zc_user1
SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1;
ERROR HY000: `zc_role2`@`%` is not granted to `zc_user1`@`%`
####role to ROLE
CONNECT zc_role2
SET DEFAULT ROLE zc_role1 to zc_role2;
ERROR HY000: `zc_role1`@`%` is not granted to `zc_role2`@`%`
SET DEFAULT ROLE zc_user1 to zc_role2;
ERROR HY000: `zc_user1`@`%` is not granted to `zc_role2`@`%`
####zc_role1,zc_role2 to role
SET DEFAULT ROLE zc_role1,zc_role3 to zc_role2;
ERROR HY000: `zc_role1`@`%` is not granted to `zc_role2`@`%`
CONNECT DEFAULT
GRANT zc_user1 to zc_role2;
CONNECT zc_role2
SET DEFAULT ROLE zc_user1,zc_user2 to zc_role2;
ERROR HY000: `zc_user2`@`%` is not granted to `zc_role2`@`%`
####5-1-2为其他用户设置default ROLE
