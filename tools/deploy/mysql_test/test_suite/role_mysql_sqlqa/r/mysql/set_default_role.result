revoke zc_role1,zc_role2,zc_role3,zc_user1,zc_user2,zc_user3 from zc_user1;
revoke zc_role1,zc_role2,zc_role3,zc_user1,zc_user2,zc_user3 from zc_role2;
DROP user zc_test1;
DROP user zc_test2;
DROP user zc_test3;
