+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
SET ROLE zc_role1;
ERROR HY000: `zc_role1`@`%` is not granted to `zc_role2`@`%`
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
SET ROLE all;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
SET ROLE all except zc_role1;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
SET ROLE NONE;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
#####开启read_only变量后，ob无法执行set role语句，待修复#####
##已修复
CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+------+-------------------+-------------------+
| HOST | USER | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+------+-------------------+-------------------+
+------+------+-------------------+-------------------+
####开启read_only
set global read_only = 1;
CONNECT zc_user1
SET ROLE DEFAULT;
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
CONNECT DEFAULT
set global read_only = 0;
DROP user zc_user1;
DROP user zc_user2;
DROP user zc_user3;
DROP user zc_role1;
DROP user zc_role2;
DROP user zc_role3;
DROP user zc_test1;
DROP user zc_test2;
DROP user zc_test3;
