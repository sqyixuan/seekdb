######################################## 使用角色连接数据库 ########################################
drop database hal_db;
create database hal_db;
use hal_db;
drop table hal;
create table hal(id int);

drop role role1;
create role 'role1';
ALTER USER 'role1' IDENTIFIED BY '123';
ALTER USER 'role1' ACCOUNT UNLOCK;
SELECT user,account_locked FROM mysql.user WHERE user = 'role1' AND account_locked = 'N';
+-------+----------------+
| user  | account_locked |
+-------+----------------+
| role1 | N              |
+-------+----------------+
grant select on mysql.user to role1;

drop role role2;
create role 'role2';
ALTER USER 'role2' ACCOUNT UNLOCK;
SELECT user,account_locked FROM mysql.user WHERE user = 'role2' AND account_locked = 'N';
+-------+----------------+
| user  | account_locked |
+-------+----------------+
| role2 | N              |
+-------+----------------+
grant select on mysql.user to role2;
grant select on hal_db.hal to role2;

drop role role3;
create role 'role3';
ALTER USER 'role3' IDENTIFIED BY '123';

drop role role4;
create role 'role4';

有密码，已解锁
select user from mysql.user where user='role2';
+-------+
| user  |
+-------+
| role2 |
+-------+
select * from hal_db.hal;

无密码，已解锁
select user from mysql.user where user='role2';
+-------+
| user  |
+-------+
| role2 |
+-------+
select * from hal_db.hal;
+------+
| id   |
+------+
+------+

有密码，未解锁
ERROR HY000: User locked
有密码，登录时未输出密码
无密码，未解锁
ERROR HY000: User locked


