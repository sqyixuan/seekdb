| role_definer_unpriv | N              |
+---------------------+----------------+

drop user user_definer_priv;
create user user_definer_priv IDENTIFIED BY '123';
grant select on hal_db.* to user_definer_priv;
grant create user on *.* to user_definer_priv;
grant select on mysql.user to user_definer_priv;
drop user user_definer_unpriv;
create user user_definer_unpriv IDENTIFIED BY '123';
grant select on hal_db.* to user_definer_unpriv;
select
    user
from
    mysql.user
where
    user in ('role_definer_priv','role_definer_nopriv','user_definer_priv','user_definer_nopriv');
+-------------------+
| user              |
+-------------------+
| role_definer_priv |
| user_definer_priv |
+-------------------+

drop role role_procedure1;
create role role_procedure1;
DROP PROCEDURE IF EXISTS drop_create_role;
CREATE DEFINER = 'role_definer_priv' PROCEDURE drop_create_role()
BEGIN
    drop role role_procedure1;
    create role role_procedure1;
    select user from mysql.user where user='role_procedure1';
END
/
grant EXECUTE ON PROCEDURE hal_db.drop_create_role to role_definer_priv;

drop role role_procedure2;
create role role_procedure2;
DROP PROCEDURE IF EXISTS drop_create_role2;
