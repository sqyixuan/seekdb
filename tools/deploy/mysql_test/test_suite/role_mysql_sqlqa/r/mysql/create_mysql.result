1、仅有CREATE ROLE权限（本期未支持）
2、仅有CREATE USER权限
######################## 当前账户具有CREATE USER创建ROLE权限（User登录系统） ########################
drop user user1;
create user 'user1' identified by '123';
GRANT CREATE USER ON *.* TO 'user1';
grant select on mysql.user to user1;


2·1、CREATE ROLE IF NOT EXISTS role_name语法创建

drop role role1;
create role if not exists role1;

create role if not exists role1;
show warnings;
Level	Code	Message
Note	3163	Authorization ID 'role1'@'%' already exists

drop role role1;
drop role role2;
drop role role3;
drop role role4;
create role if not exists role1,role2,role3,role4;

drop role role1;
drop role role2;
drop role role3;
drop role role4;
SELECT user FROM mysql.user where user in ('role1','role2','role3','role4') order by user desc;
+------+
| user |
+------+
+------+
create role if not exists role1,role2;
create role if not exists role1,role2,role3,role4;
SELECT user FROM mysql.user where user in ('role1','role2','role3','role4') order by user desc;
+-------+
| user  |
+-------+
| role4 |
| role3 |
| role2 |
| role1 |
+-------+
CREATE ROLE if not exists role1,role2,role3,role4;
show warnings;
Level	Code	Message
Note	3163	Authorization ID 'role1'@'%' already exists
Note	3163	Authorization ID 'role2'@'%' already exists
Note	3163	Authorization ID 'role3'@'%' already exists
Note	3163	Authorization ID 'role4'@'%' already exists

