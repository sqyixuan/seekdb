########################################## PL ##############################################
use hal_db;

drop role role_procedure1;
create role role_procedure1;

drop user create_user;
create user 'create_user' identified by '123';
grant select on mysql.user to create_user;
grant select on hal_db.* to create_user;
grant create user on *.* to create_user;
GRANT ALTER ROUTINE ON *.* TO 'create_user'@'%';
GRANT create ROUTINE ON *.* TO 'create_user'@'%';

drop user un_create_user;
create user 'un_create_user' identified by '123';
grant select on mysql.user to un_create_user;
grant select on hal_db.* to un_create_user;
GRANT ALTER ROUTINE ON *.* TO 'un_create_user'@'%';
GRANT create ROUTINE ON *.* TO 'un_create_user'@'%';

use hal_db;
show grants for 'un_create_user';
Grants for un_create_user@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'un_create_user'
GRANT SELECT ON `hal_db`.* TO 'un_create_user'
GRANT SELECT ON `mysql`.`user` TO 'un_create_user'
Procedure
DROP PROCEDURE IF EXISTS drop_role;
CREATE PROCEDURE drop_role()
BEGIN
    drop role role_procedure1;
    select user from mysql.user where user='role_procedure1';
END
/
CALL drop_role;
ERROR 42501: Access denied; you need (at least one of) the CREATE USER or DROP ROLE privilege(s) for this operation

DROP PROCEDURE IF EXISTS create_role;
CREATE PROCEDURE create_role()
BEGIN
    create role role_procedure1;
    select user from mysql.user where user='role_procedure1';
END
/
CALL create_role;
ERROR 42501: Access denied; you need (at least one of) the CREATE USER or CREATE ROLE privilege(s) for this operation


use hal_db;
show grants for 'create_user';
Grants for create_user@%
GRANT CREATE USER, ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'create_user'
GRANT SELECT ON `hal_db`.* TO 'create_user'
GRANT SELECT ON `mysql`.`user` TO 'create_user'

DROP PROCEDURE IF EXISTS drop_role;
CREATE PROCEDURE drop_role()
BEGIN
    DECLARE user_count INT;

    select user from mysql.user where user='role_procedure1';
    drop role role_procedure1;
    select count(*) into user_count from mysql.user where user='role_procedure1';

    if user_count = 0 then
        select 'role_procedure1 已被删除' as message;
    else
        select 'role 删除失败（ERROR!!）' as message;
    end if;
END
/
CALL drop_role;
+-----------------+
| user            |
+-----------------+
+------------------------------+
| message                      |
+------------------------------+
| role_procedure1 |
| role_procedure1 已被删除     |
+-----------------+
+------------------------------+

DROP PROCEDURE IF EXISTS create_role;
CREATE PROCEDURE create_role()
BEGIN
    create role role_procedure1;
    select user from mysql.user where user='role_procedure1';
END
/
CALL create_role;
+-----------------+
| user            |
+-----------------+
| role_procedure1 |
+-----------------+


