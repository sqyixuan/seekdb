set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
drop table riel;
create table riel(id int,name char(20),age int);
insert into riel values(1,'hal',1000);
insert into riel values(2,'riel',1200);
select * from riel;
+------+------+------+
| id   | name | age  |
+------+------+------+
|    1 | hal  | 1000 |
|    2 | riel | 1200 |
+------+------+------+

drop user halA;
create user halA identified by '123';
grant select on hal_db.* to halA;

drop user halB;
create user halB identified by '123';
grant super on *.* to halB;

drop role role_g1;
drop role role_g2;
drop role role_g3;

create role role_g1;
create role role_g2;
create role role_g3;

grant select on hal_db.riel to role_g1;
grant update on hal_db.riel to role_g2;

grant role_g1 to halB;
grant role_g2 to halB;
grant role_g3 to halB;
set default role role_g1 to halB;


############################### 拥有SUPER权限，支持更改该全局变量 ################################
set global activate_all_roles_on_login = OFF;（默认）
set global activate_all_roles_on_login = OFF;
show grants for 'halB';
Grants for halB@%
GRANT SUPER ON *.* TO 'halB'
GRANT `role_g3`@`%`,`role_g2`@`%`,`role_g1`@`%` TO `halB`@`%`
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
Variable_name	Value
activate_all_roles_on_login	OFF
select current_role();
+----------------+
| current_role() |
+----------------+
| `role_g1`@`%`  |
+----------------+
select * from information_schema.enabled_roles;
+-----------+-----------+------------+--------------+
| ROLE_NAME | ROLE_HOST | IS_DEFAULT | IS_MANDATORY |
+-----------+-----------+------------+--------------+
| role_g1   | %         | YES        | NO           |
+-----------+-----------+------------+--------------+

重新登录
show grants for 'halB';
Grants for halB@%
GRANT SUPER ON *.* TO 'halB'
GRANT `role_g3`@`%`,`role_g2`@`%`,`role_g1`@`%` TO `halB`@`%`
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
Variable_name	Value
activate_all_roles_on_login	OFF
SELECT @@global.activate_all_roles_on_login;
+--------------------------------------+
| @@global.activate_all_roles_on_login |
+--------------------------------------+
|                                    0 |
+--------------------------------------+
select current_role();
+----------------+
| current_role() |
+----------------+
| `role_g1`@`%`  |
+----------------+
select * from information_schema.enabled_roles;
+-----------+-----------+------------+--------------+
| ROLE_NAME | ROLE_HOST | IS_DEFAULT | IS_MANDATORY |
+-----------+-----------+------------+--------------+
| role_g1   | %         | YES        | NO           |
+-----------+-----------+------------+--------------+

select * from hal_db.riel;
+------+------+------+
| id   | name | age  |
+------+------+------+
|    1 | hal  | 1000 |
|    2 | riel | 1200 |
+------+------+------+
update hal_db.riel set age=2100 where id=2;
ERROR 42000: UPDATE command denied to user 'halB'@'%' for table 'riel'



set global activate_all_roles_on_login = ON;
set global activate_all_roles_on_login = ON;
show grants for 'halB';
Grants for halB@%
GRANT SUPER ON *.* TO 'halB'
GRANT `role_g3`@`%`,`role_g2`@`%`,`role_g1`@`%` TO `halB`@`%`
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
Variable_name	Value
activate_all_roles_on_login	OFF
SELECT @@global.activate_all_roles_on_login;
+--------------------------------------+
| @@global.activate_all_roles_on_login |
+--------------------------------------+
|                                    1 |
+--------------------------------------+

select current_role();
+----------------+
| current_role() |
+----------------+
| `role_g1`@`%`  |
+----------------+

重新登录
show grants for 'halB';
Grants for halB@%
GRANT SUPER ON *.* TO 'halB'
GRANT `role_g3`@`%`,`role_g2`@`%`,`role_g1`@`%` TO `halB`@`%`
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
Variable_name	Value
activate_all_roles_on_login	ON
SELECT @@global.activate_all_roles_on_login;
