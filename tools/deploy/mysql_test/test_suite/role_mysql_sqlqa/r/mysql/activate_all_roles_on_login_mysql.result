select * from hal_db.riel;
+------+------+------+
| id   | name | age  |
+------+------+------+
|    1 | hal  | 1000 |
|    2 | riel | 2100 |
+------+------+------+

set global activate_all_roles_on_login = OFF;
SHOW VARIABLES LIKE 'activate_all_roles_on_login';
Variable_name	Value
activate_all_roles_on_login	ON
SELECT @@global.activate_all_roles_on_login;
+--------------------------------------+
| @@global.activate_all_roles_on_login |
+--------------------------------------+
|                                    0 |
