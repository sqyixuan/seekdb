GRANT DELETE, INSERT, UPDATE, SELECT ON `mysql`.`default_roles` TO 'user_halA'
GRANT DELETE, INSERT, UPDATE, SELECT ON `mysql`.`role_edges` TO 'user_halA'

insert into mysql.role_edges(FROM_HOST,FROM_USER,TO_HOST,TO_USER) values('%','role_halB','%','user_halA');
