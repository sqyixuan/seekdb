set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
еЇ№mysql.role_edgesиЎЁе’Њmysql.default_rolesиЎЁиї›иЎЊDMLпј€OBдёЌж”ЇжЊЃпј‰
drop user user_halA;
create user user_halA identified by '123';
grant select,update,insert,delete on mysql.role_edges to user_halA;
grant select,update,insert,delete on mysql.default_roles to user_halA;
show grants for 'user_halA';
Grants for user_halA@%
GRANT USAGE ON *.* TO 'user_halA'
GRANT DELETE, INSERT, UPDATE, SELECT ON `mysql`.`default_roles` TO 'user_halA'
GRANT DELETE, INSERT, UPDATE, SELECT ON `mysql`.`role_edges` TO 'user_halA'

SELECT
    user,
    account_locked
FROM
    mysql.user
WHERE
    user = 'user_halA';
+-----------+----------------+
| user      | account_locked |
+-----------+----------------+
| user_halA | N              |
+-----------+----------------+


