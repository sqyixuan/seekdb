grant EXECUTE ON PROCEDURE test.zc_prole2 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole3 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole4 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole5 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole6 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole7 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole8 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole1 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole2 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole3 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole4 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole5 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole6 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole7 to 'zc_test3'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole8 to 'zc_test3'@'%';
####拥有CREATE USER权限
CONNECT zc_test1
##mysql中用户创建存储程序需要CREATE ROUTINE权限，ob不支持
##GRANT CREATE ROUTINE,ALTER ROUTINE,EXECUTE ON test.* to zc_test1;
use test;
DROP PROCEDURE zc_prole//
CREATE PROCEDURE zc_prole()
BEGIN
	SET DEFAULT ROLE zc_role1 to zc_user1;
end;
//
call zc_prole();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
use test;
DROP PROCEDURE zc_prole1//
CREATE PROCEDURE zc_prole1()
BEGIN
	SET DEFAULT ROLE zc_role1 to zc_user1;
end;
//
DROP PROCEDURE zc_prole2//
CREATE PROCEDURE zc_prole2()
BEGIN
	SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1;
end;
//
DROP PROCEDURE zc_prole3//
CREATE PROCEDURE zc_prole3()
BEGIN
	SET DEFAULT ROLE all to zc_user1;
end;
//
DROP PROCEDURE zc_prole4//
CREATE PROCEDURE zc_prole4()
BEGIN
	SET DEFAULT ROLE NONE to zc_user1;
end;
//
call test.zc_prole1();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
call test.zc_prole2();
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role2`@`%`,`zc_role1`@`%` |
+-------------------------------+
call test.zc_prole3();
SELECT CURRENT_ROLE();
+----------------------------------------------+
| CURRENT_ROLE()                               |
+----------------------------------------------+
| `zc_role2`@`%`,`zc_role1`@`%`,`zc_user2`@`%` |
+----------------------------------------------+
call test.zc_prole4();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
call test.zc_prole5();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
call test.zc_prole6();
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%` |
+-------------------------------+
call test.zc_prole7();
SELECT CURRENT_ROLE();
+----------------------------------------------+
| CURRENT_ROLE()                               |
+----------------------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%`,`zc_user2`@`%` |
+----------------------------------------------+
call test.zc_prole8();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_test1 | %                 | zc_role1          |
| %    | zc_test2 | %                 | zc_role1          |
| %    | zc_test3 | %                 | zc_role1          |
+------+----------+-------------------+-------------------+
grant EXECUTE ON PROCEDURE test.zc_prole1 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole2 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole3 to 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole4 to 'zc_test2'@'%';
