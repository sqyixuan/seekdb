#### FUNCTION TRIGGER(not support) ####
####ob在create阶段就会报错，mysql是在执行阶段报错
drop table test.zc_t;
CREATE table test.zc_t(a int);
CONNECT zc_user1
set role zc_role1;
use test;
DROP FUNCTION zc_frole//
CREATE FUNCTION zc_frole() RETURNS int
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE zc_role1;
	RETURN 1;
end;
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
DROP FUNCTION zc_frole//
CREATE FUNCTION zc_frole() RETURNS int
BEGIN
	set DEFAULT ROLE zc_role1 to zc_user1;
	RETURN 1;
end;
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
DROP TRIGGER zc_trole//
CREATE TRIGGER zc_trole BEFORE INSERT on test.zc_t for EACH ROW
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE zc_role1;
end;
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
DROP TRIGGER zc_trole//
CREATE TRIGGER zc_trole BEFORE INSERT on test.zc_t for EACH ROW
BEGIN
	set DEFAULT ROLE zc_role1 to zc_user1;
end;
//
ERROR HY000: Explicit or implicit commit is not allowed in stored function or trigger.
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_test1 | %                 | zc_role1          |
| %    | zc_test2 | %                 | zc_role1          |
| %    | zc_test3 | %                 | zc_role1          |
+------+----------+-------------------+-------------------+
