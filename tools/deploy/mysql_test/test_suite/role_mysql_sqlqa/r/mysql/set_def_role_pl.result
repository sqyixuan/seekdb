#### ALTER USER DEFAULT ROLE ####
DROP PROCEDURE zc_prole9//
CREATE PROCEDURE zc_prole9()
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE zc_role1;
end;
//
DROP PROCEDURE zc_prole10//
CREATE PROCEDURE zc_prole10()
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE zc_role1,zc_user2;
end;
//
DROP PROCEDURE zc_prole11//
CREATE PROCEDURE zc_prole11()
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE all;
end;
//
DROP PROCEDURE zc_prole12//
CREATE PROCEDURE zc_prole12()
BEGIN
	ALTER USER zc_user1 DEFAULT ROLE NONE;
end;
//
DROP PROCEDURE zc_prole13//
CREATE PROCEDURE zc_prole13()
BEGIN
	ALTER USER zc_role2 DEFAULT ROLE zc_role1;
end;
//
DROP PROCEDURE zc_prole14//
CREATE PROCEDURE zc_prole14()
BEGIN
	ALTER USER zc_role2 DEFAULT ROLE zc_role1,zc_user2;
end;
//
DROP PROCEDURE zc_prole15//
CREATE PROCEDURE zc_prole15()
BEGIN
	ALTER USER zc_role2 DEFAULT ROLE all;
end;
//
DROP PROCEDURE zc_prole16//
CREATE PROCEDURE zc_prole16()
BEGIN
	ALTER USER zc_role2 DEFAULT ROLE NONE;
end;
//
grant EXECUTE ON PROCEDURE test.zc_prole9 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole10 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole11 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole12 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole13 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole14 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole15 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole16 to 'zc_user1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole9 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole10 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole11 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole12 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole13 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole14 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole15 to 'zc_role2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole16 to 'zc_role2'@'%';
####执行(用户为另一个用户设置默认角色可以通过存储过程直接设置而不需要set default相关权限)
CONNECT zc_user1
call test.zc_prole9();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
