CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+----------+-------------------+-------------------+
| HOST | USER     | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+----------+-------------------+-------------------+
| %    | zc_test1 | %                 | zc_role1          |
| %    | zc_test2 | %                 | zc_role1          |
| %    | zc_test3 | %                 | zc_role1          |
+------+----------+-------------------+-------------------+
grant INSERT,UPDATE,DELETE,SELECT,TRIGGER on test.zc_t to zc_user1;
grant INSERT,UPDATE,DELETE,SELECT on test.zc_t to zc_role2;
CONNECT zc_user1
use test;
DROP TRIGGER test.zc_trole//
