result_format: 4
PURGE RECYCLEBIN;
########## SET DEFAULT ROLE 与set role 在pl中应用场景 ##########
DROP user halB;
DROP user zc_user1;
DROP user zc_user2;
DROP user zc_user3;
DROP user zc_role1;
DROP user zc_role2;
DROP user zc_role3;
DROP user zc_test1;
DROP user zc_test2;
DROP user zc_test3;
CREATE user zc_user1,zc_user2,zc_user3;
CREATE role zc_role1,zc_role2,zc_role3;
GRANT zc_role1,zc_role2,zc_user2 to zc_user1;
GRANT zc_role1,zc_role3,zc_user2 to zc_role2;
ALTER USER 'zc_role2' ACCOUNT UNLOCK;
GRANT CREATE on test.* to zc_role1;
set DEFAULT role all to zc_user1;
set DEFAULT role all to zc_role2;
GRANT ALTER ROUTINE ON *.* TO 'zc_user1'@'%';
GRANT CREATE ROUTINE ON *.* TO 'zc_user1'@'%';
GRANT ALTER ROUTINE ON *.* TO 'zc_role2'@'%';
GRANT CREATE ROUTINE ON *.* TO 'zc_role2'@'%';
########## SET DEFAULT ROLE ##########
#### PROCEDURE ####
##mysql中用户创建存储程序需要CREATE ROUTINE权限，ob不支持
##GRANT CREATE ROUTINE,ALTER ROUTINE,EXECUTE ON test.* to zc_user1;
####set user default role####
CONNECT zc_user1
use test;
DROP PROCEDURE zc_prole//
CREATE PROCEDURE zc_prole()
BEGIN
	SET DEFAULT ROLE zc_role1 to zc_user1;
end;
//
call zc_prole();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
use test;
DROP PROCEDURE zc_prole1//
CREATE PROCEDURE zc_prole1()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE zc_role1 to zc_user1';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole2//
CREATE PROCEDURE zc_prole2()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE zc_role1,zc_role2 to zc_user1';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole3//
CREATE PROCEDURE zc_prole3()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE all to zc_user1';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole4//
CREATE PROCEDURE zc_prole4()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE NONE to zc_user1';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
call test.zc_prole1();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
call test.zc_prole2();
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role2`@`%`,`zc_role1`@`%` |
+-------------------------------+
call test.zc_prole3();
SELECT CURRENT_ROLE();
+----------------------------------------------+
| CURRENT_ROLE()                               |
+----------------------------------------------+
| `zc_role2`@`%`,`zc_role1`@`%`,`zc_user2`@`%` |
+----------------------------------------------+
call test.zc_prole4();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
####set role default role####
CONNECT zc_role2
##mysql执行这条语句之前要重置role2的密码ALTER USER zc_role2 IDENTIFIED BY ''
use test;
DROP PROCEDURE zc_prole//
CREATE PROCEDURE zc_prole()
BEGIN
	SET DEFAULT ROLE zc_role1 to zc_role2;
end;
//
call zc_prole();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
use test;
DROP PROCEDURE zc_prole5//
CREATE PROCEDURE zc_prole5()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE zc_role1 to zc_role2';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole6//
CREATE PROCEDURE zc_prole6()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE zc_role1,zc_role3 to zc_role2';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole7//
CREATE PROCEDURE zc_prole7()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE all to zc_role2';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
DROP PROCEDURE zc_prole8//
CREATE PROCEDURE zc_prole8()
BEGIN
	PREPARE stmt1 FROM 'SET DEFAULT ROLE NONE to zc_role2';
	EXECUTE stmt1;
	DEALLOCATE PREPARE stmt1;
end;
//
call test.zc_prole5();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| `zc_role1`@`%` |
+----------------+
call test.zc_prole6();
SELECT CURRENT_ROLE();
+-------------------------------+
| CURRENT_ROLE()                |
+-------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%` |
+-------------------------------+
call test.zc_prole7();
SELECT CURRENT_ROLE();
+----------------------------------------------+
| CURRENT_ROLE()                               |
+----------------------------------------------+
| `zc_role3`@`%`,`zc_role1`@`%`,`zc_user2`@`%` |
+----------------------------------------------+
call test.zc_prole8();
SELECT CURRENT_ROLE();
+----------------+
| CURRENT_ROLE() |
+----------------+
| NONE           |
+----------------+
CONNECT DEFAULT
SELECT * FROM mysql.default_roles ;
+------+------+-------------------+-------------------+
| HOST | USER | DEFAULT_ROLE_HOST | DEFAULT_ROLE_USER |
+------+------+-------------------+-------------------+
+------+------+-------------------+-------------------+
####为其他用户设置default ROLE
DROP user zc_test1;
DROP user zc_test2;
DROP user zc_test3;
CREATE user zc_test1;
GRANT CREATE USER ON *.* to zc_test1;
CREATE user zc_test2;
GRANT UPDATE ON mysql.* to zc_test2;
CREATE user zc_test3;
GRANT CREATE on test.* to zc_role1;
GRANT zc_role1 to zc_test1,zc_test2,zc_test3;
set DEFAULT role zc_role1 to zc_test1;
set DEFAULT role zc_role1 to zc_test2;
set DEFAULT role zc_role1 to zc_test3;
GRANT ALTER ROUTINE ON *.* TO 'zc_test1'@'%';
GRANT CREATE ROUTINE ON *.* TO 'zc_test1'@'%';
GRANT ALTER ROUTINE ON *.* TO 'zc_test2'@'%';
GRANT CREATE ROUTINE ON *.* TO 'zc_test2'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole5 to 'zc_test1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole6 to 'zc_test1'@'%';
grant EXECUTE ON PROCEDURE test.zc_prole7 to 'zc_test1'@'%';
