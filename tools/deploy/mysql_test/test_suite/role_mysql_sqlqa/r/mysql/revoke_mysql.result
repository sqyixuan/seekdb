DROP PROCEDURE IF EXISTS definer_grant_option;
CREATE DEFINER = 'role_definer' PROCEDURE definer_grant_option()
BEGIN
    revoke select on hal_db.hal from role_priv;
END /
grant EXECUTE ON PROCEDURE hal_db.definer_grant_option to role_definer;

DROP PROCEDURE IF EXISTS definer_ungrant_option;
CREATE DEFINER = 'role_definer' PROCEDURE definer_ungrant_option()
BEGIN
    revoke select on hal_db.riel from role_priv;
END /
grant EXECUTE ON PROCEDURE hal_db.definer_ungrant_option to role_definer;

DROP PROCEDURE IF EXISTS definer_super;
CREATE DEFINER = 'role_super' PROCEDURE definer_super()
BEGIN
    revoke role1 from role_priv;
END /
grant EXECUTE ON PROCEDURE hal_db.definer_super to role_super;

DROP PROCEDURE IF EXISTS definer_unsuper;
CREATE DEFINER = 'role_definer' PROCEDURE definer_unsuper()
BEGIN
    revoke role2 from role_priv;
END /
grant EXECUTE ON PROCEDURE hal_db.definer_unsuper to role_definer;


