жңүgrant optionжқғйҷҗrevokeиҙҰжҲ·дёӯзҡ„жқғйҷҗ
show grants for 'role_undefiner';
Grants for role_undefiner@%
GRANT USAGE ON *.* TO 'role_undefiner'
GRANT SELECT ON `mysql`.* TO 'role_undefiner'
GRANT SELECT ON `hal_db`.`hal` TO 'role_undefiner' WITH GRANT OPTION
GRANT SELECT ON `hal_db`.`riel` TO 'role_undefiner'
DROP PROCEDURE IF EXISTS grant_option;
CREATE PROCEDURE grant_option()
BEGIN
    revoke select on hal_db.hal from role_undefiner;
END /

ж— grant optionжқғйҷҗrevokeиҙҰжҲ·дёӯзҡ„жқғйҷҗ
DROP PROCEDURE IF EXISTS ungrant_option;
CREATE PROCEDURE ungrant_option()
BEGIN
    revoke select on hal_db.riel from role_undefiner;
END /

ж— superжқғйҷҗrevokeиҙҰжҲ·дёӯзҡ„role
DROP PROCEDURE IF EXISTS procedure_unsuper;
CREATE PROCEDURE procedure_unsuper()
BEGIN
    revoke role1 from role_priv;
END /

жңүsuperжқғйҷҗrevokeиҙҰжҲ·дёӯзҡ„role
DROP PROCEDURE IF EXISTS procedure_super;
CREATE PROCEDURE procedure_super()
BEGIN
    revoke role1 from role_priv;
    revoke role2 from role_super;
END /

DROP PROCEDURE IF EXISTS grant_option;
CREATE PROCEDURE grant_option()
BEGIN
    select 1;
END /

DROP PROCEDURE IF EXISTS ungrant_option;
CREATE PROCEDURE ungrant_option()
BEGIN
    select 1;
END /

DROP PROCEDURE IF EXISTS procedure_unsuper;
CREATE PROCEDURE procedure_unsuper()
BEGIN
    select 1;
END /

DROP PROCEDURE IF EXISTS procedure_super;
CREATE PROCEDURE procedure_super()
BEGIN
    select 1;
END /

GRANT ALTER ROUTINE ON *.* TO 'role_undefiner'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_super to 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_super to 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.grant_option to 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.grant_option to 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.ungrant_option to 'role_undefiner'@'%';
grant EXECUTE ON PROCEDURE hal_db.ungrant_option to 'role_undefiner'@'%';
GRANT ALTER ROUTINE ON *.* TO 'role_priv'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_priv'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_unsuper to 'role_priv'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_unsuper to 'role_priv'@'%';
GRANT ALTER ROUTINE ON *.* TO 'role_super'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_super'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_super to 'role_super'@'%';
grant EXECUTE ON PROCEDURE hal_db.procedure_super to 'role_super'@'%';



