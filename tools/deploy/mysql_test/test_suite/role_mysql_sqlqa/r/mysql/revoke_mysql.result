set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';
Variable_name	Value
read_only	OFF


######################## з§»йҷӨеҪ“еүҚи§’иүІжӢҘжңүзҡ„RoleдјҡеңЁеҪ“еүҚдјҡиҜқдёӯз”ҹж•ҲпјҲи§’иүІзҷ»еҪ•ж•°жҚ®еә“пјү###########################
drop database hal_db;
create database hal_db;
use hal_db;

drop table hal;
create table hal(id int);
insert into hal values(10086);
select * from hal;
+-------+
| id    |
+-------+
| 10086 |
+-------+

drop table riel;
create table riel(id int,name char(20),age int);
insert into riel values(1,'hal',1000);
insert into riel values(2,'riel',1200);
select * from riel;
+------+------+------+
| id   | name | age  |
+------+------+------+
|    1 | hal  | 1000 |
|    2 | riel | 1200 |
+------+------+------+

drop role role1;
drop role role2;
drop role role3;
drop role role4;
drop role role5;
drop role role6;
drop role role7;
drop role role8;
drop role role10;

create role role1;
create role role2;
create role role3;
create role role4;
create role role5;
create role role6;
create role role7;
create role role8;
create role role10;

select user from mysql.user where user in(
    'role1','role2','role3','role4','role5',
    'role6','role7','role8','role10'
);
+--------+
| user   |
+--------+
| role1  |
| role2  |
| role3  |
| role4  |
| role5  |
| role6  |
| role7  |
| role8  |
| role10 |
+--------+

grant delete on hal_db.riel to role10;
grant role10 to role2;

grant super on *.* to role2;
grant select on mysql.role_edges to role2;
grant select on hal_db.hal to role1;
grant update,insert on hal_db.hal to role2;
grant insert,select on hal_db.riel to role1;
grant role1,role3,role4,role5,role6,role7 to role2;

show grants for role2;
Grants for role2@%
GRANT SUPER ON *.* TO 'role2'
GRANT INSERT, UPDATE ON `hal_db`.`hal` TO 'role2'
GRANT SELECT ON `mysql`.`role_edges` TO 'role2'
GRANT `role10`@`%`,`role7`@`%`,`role6`@`%`,`role5`@`%`,`role4`@`%`,`role3`@`%`,`role1`@`%` TO `role2`@`%`
select * from  mysql.role_edges where to_user='role2';
+-----------+-----------+---------+---------+-------------------+
| FROM_HOST | FROM_USER | TO_HOST | TO_USER | WITH_ADMIN_OPTION |
+-----------+-----------+---------+---------+-------------------+
| %         | role1     | %       | role2   | N                 |
| %         | role3     | %       | role2   | N                 |
| %         | role4     | %       | role2   | N                 |
| %         | role5     | %       | role2   | N                 |
| %         | role6     | %       | role2   | N                 |
| %         | role7     | %       | role2   | N                 |
| %         | role10    | %       | role2   | N                 |
+-----------+-----------+---------+---------+-------------------+

drop user halA;
create user halA;

grant super on *.* to halA;
grant select on mysql.role_edges to halA;
grant update,insert on hal_db.hal to halA;
grant insert,select on hal_db.riel to halA with grant option;
grant role1,role3,role4,role5,role6,role7 to halA;
show grants for halA;
Grants for halA@%
GRANT SUPER ON *.* TO 'halA'
GRANT INSERT, UPDATE ON `hal_db`.`hal` TO 'halA'
GRANT INSERT, SELECT ON `hal_db`.`riel` TO 'halA' WITH GRANT OPTION
GRANT SELECT ON `mysql`.`role_edges` TO 'halA'
GRANT `role7`@`%`,`role6`@`%`,`role5`@`%`,`role4`@`%`,`role3`@`%`,`role1`@`%` TO `halA`@`%`

drop user halB;
create user halB;

drop role role9;
create role role9;
grant select on mysql.role_edges to halB;
grant select,update,insert on hal_db.hal to halB;
grant insert,select on hal_db.riel to halB with grant option;
grant role1,role3,role9 to halB;
grant select on mysql.role_edges to halB;
show grants for 'halB';
Grants for halB@%
GRANT USAGE ON *.* TO 'halB'
GRANT INSERT, UPDATE, SELECT ON `hal_db`.`hal` TO 'halB'
GRANT INSERT, SELECT ON `hal_db`.`riel` TO 'halB' WITH GRANT OPTION
GRANT SELECT ON `mysql`.`role_edges` TO 'halB'
GRANT `role9`@`%`,`role3`@`%`,`role1`@`%` TO `halB`@`%`

grant select on mysql.role_edges to role8;
grant select,update,insert on hal_db.hal to role8;
grant insert,select on hal_db.riel to role8 with grant option;
grant role1,role3,role4,role5,role6,role7 to role8;
show grants for 'role8';
Grants for role8@%
GRANT USAGE ON *.* TO 'role8'
GRANT INSERT, UPDATE, SELECT ON `hal_db`.`hal` TO 'role8'
GRANT INSERT, SELECT ON `hal_db`.`riel` TO 'role8' WITH GRANT OPTION
GRANT SELECT ON `mysql`.`role_edges` TO 'role8'
GRANT `role7`@`%`,`role6`@`%`,`role5`@`%`,`role4`@`%`,`role3`@`%`,`role1`@`%` TO `role8`@`%`

drop role role_role;
create role role_role;

drop user user_C;
create user user_C;

grant select on mysql.* to user_C;
grant select on hal_db.hal to role_role with grant option;
grant insert,select on hal_db.riel to role_role;
grant role9,role_role to user_C;
show grants for 'user_C';
Grants for user_C@%
GRANT USAGE ON *.* TO 'user_C'
GRANT SELECT ON `mysql`.* TO 'user_C'
GRANT `role_role`@`%`,`role9`@`%` TO `user_C`@`%`


ALTER USER 'role2' ACCOUNT UNLOCK;
ALTER USER 'role8' ACCOUNT UNLOCK;
ALTER USER 'role2'@'%' IDENTIFIED BY '123';
ALTER USER 'role8'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role2' AND account_locked = 'N';
+-------+----------------+
| user  | account_locked |
+-------+----------------+
| role2 | N              |
+-------+----------------+
SELECT user,account_locked FROM mysql.user WHERE user = 'role8' AND account_locked = 'N';
+-------+----------------+
| user  | account_locked |
+-------+----------------+
| role8 | N              |
+-------+----------------+


