GRANT CREATE ROUTINE ON *.* TO 'role_priv'@'%';
grant EXECUTE ON PROCEDURE hal_db.select_hal to 'role_priv'@'%';
grant EXECUTE ON PROCEDURE hal_db.select_hal to 'role_priv'@'%';
GRANT ALTER ROUTINE ON *.* TO 'role_definer_grant_option'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_definer_grant_option'@'%';
grant EXECUTE ON PROCEDURE hal_db.definer_procedure1 to 'role_definer_grant_option'@'%';
grant EXECUTE ON PROCEDURE hal_db.definer_procedure1 to 'role_definer_grant_option'@'%';
GRANT ALTER ROUTINE ON *.* TO 'role_definer_ungrant_option'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_definer_ungrant_option'@'%';
grant EXECUTE ON PROCEDURE hal_db.definer_procedure2 to 'role_definer_ungrant_option'@'%';
grant EXECUTE ON PROCEDURE hal_db.definer_procedure2 to 'role_definer_ungrant_option'@'%';


========================= 有grant权限 ===========================================
use hal_db;
show grants for 'role_definer';
Grants for role_definer@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'role_definer'
GRANT SELECT ON `mysql`.* TO 'role_definer'
GRANT SELECT ON `hal_db`.`hal` TO 'role_definer' WITH GRANT OPTION
GRANT INSERT ON `hal_db`.`riel` TO 'role_definer'
GRANT EXECUTE ON PROCEDURE `hal_db`.`grant_procedure` TO 'role_definer'

DROP PROCEDURE IF EXISTS grant_procedure;
CREATE PROCEDURE grant_procedure()
BEGIN
    grant select on hal_db.hal to role_priv;
END /
show grants for 'role_priv';
Grants for role_priv@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'role_priv'
GRANT SELECT ON `hal_db`.`riel` TO 'role_priv'
GRANT EXECUTE ON PROCEDURE `hal_db`.`select_hal` TO 'role_priv'
CALL grant_procedure;
show grants for 'role_priv';
Grants for role_priv@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'role_priv'
GRANT SELECT ON `hal_db`.`hal` TO 'role_priv'
GRANT SELECT ON `hal_db`.`riel` TO 'role_priv'
GRANT EXECUTE ON PROCEDURE `hal_db`.`select_hal` TO 'role_priv'

========================= 无grant权限 ===========================================
DROP PROCEDURE IF EXISTS un_grant_procedure;
CREATE PROCEDURE un_grant_procedure()
BEGIN
    grant insert on hal_db.riel to role_priv;
END /
show grants for 'role_priv';
Grants for role_priv@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'role_priv'
GRANT SELECT ON `hal_db`.`hal` TO 'role_priv'
GRANT SELECT ON `hal_db`.`riel` TO 'role_priv'
GRANT EXECUTE ON PROCEDURE `hal_db`.`select_hal` TO 'role_priv'
CALL un_grant_procedure;
ERROR 42000: GRANT command denied to user 'role_definer'@'%' for table 'riel'
show grants for 'role_priv';
Grants for role_priv@%
GRANT ALTER ROUTINE, CREATE ROUTINE ON *.* TO 'role_priv'
GRANT SELECT ON `hal_db`.`hal` TO 'role_priv'
GRANT SELECT ON `hal_db`.`riel` TO 'role_priv'
GRANT EXECUTE ON PROCEDURE `hal_db`.`select_hal` TO 'role_priv'


