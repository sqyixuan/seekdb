drop role role_priv;
create role role_priv;
grant select on hal_db.riel to role_priv;
ALTER USER 'role_priv' ACCOUNT UNLOCK;
ALTER USER 'role_priv'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_priv' AND account_locked = 'N';
