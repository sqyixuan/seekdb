drop user user_priv;
create user user_priv IDENTIFIED BY '123';
grant select on mysql.* to user_priv;

drop role role_definer;
create role role_definer;
grant select on hal_db.hal to role_definer with grant option;
grant insert on hal_db.riel to role_definer;
grant select on mysql.* to role_definer;
show grants for 'role_definer';
