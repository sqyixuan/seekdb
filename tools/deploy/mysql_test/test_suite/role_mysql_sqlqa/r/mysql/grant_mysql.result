ALTER USER 'role_definer' ACCOUNT UNLOCK;
ALTER USER 'role_definer'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_definer' AND account_locked = 'N';
+--------------+----------------+
| user         | account_locked |
+--------------+----------------+
| role_definer | N              |
+--------------+----------------+

grant role_definer to user_priv;
show grants for 'user_priv';
Grants for user_priv@%
GRANT USAGE ON *.* TO 'user_priv'
GRANT SELECT ON `mysql`.* TO 'user_priv'
GRANT `role_definer`@`%` TO `user_priv`@`%`


