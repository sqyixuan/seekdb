+-------------+

drop user user_super_ungrant;
create user 'user_super_ungrant' identified by '123';
grant select on hal_db.hal to user_super_ungrant with grant option;
grant select on hal_db.riel to user_super_ungrant;
grant select on mysql.user to user_super_ungrant;
grant super on *.* to user_super_ungrant;
grant role4 to user_super_ungrant;
show grants for 'user_super_ungrant';
Grants for user_super_ungrant@%
GRANT SUPER ON *.* TO 'user_super_ungrant'
GRANT SELECT ON `hal_db`.`hal` TO 'user_super_ungrant' WITH GRANT OPTION
GRANT SELECT ON `hal_db`.`riel` TO 'user_super_ungrant'
GRANT SELECT ON `mysql`.`user` TO 'user_super_ungrant'
GRANT `role4`@`%` TO `user_super_ungrant`@`%`

drop role role_super_ungrant;
create role 'role_super_ungrant';
grant select on hal_db.hal to role_super_ungrant with grant option;
grant select on hal_db.riel to role_super_ungrant;
grant select on mysql.user to role_super_ungrant;
grant super on *.* to role_super_ungrant;
grant role4 to role_super_ungrant;
show grants for 'role_super_ungrant';
Grants for role_super_ungrant@%
GRANT SUPER ON *.* TO 'role_super_ungrant'
GRANT SELECT ON `hal_db`.`hal` TO 'role_super_ungrant' WITH GRANT OPTION
GRANT SELECT ON `hal_db`.`riel` TO 'role_super_ungrant'
GRANT SELECT ON `mysql`.`user` TO 'role_super_ungrant'
GRANT `role4`@`%` TO `role_super_ungrant`@`%`
ALTER USER 'role_super_ungrant' ACCOUNT UNLOCK;
ALTER USER 'role_super_ungrant'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_super_ungrant' AND account_locked = 'N';
+--------------------+----------------+
| user               | account_locked |
+--------------------+----------------+
| role_super_ungrant | N              |
