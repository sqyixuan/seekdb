set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS hal_db;
create database hal_db character set utf8;
use hal_db;
result_format: 4
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';
Variable_name	Value
read_only	OFF


######################## 当前账户具有 GRANT OPTION 权限允许授权 ###########################
drop database hal_db;
create database hal_db;
use hal_db;

drop table hal;
create table hal(id int);
insert into hal values(10086);
select * from hal;
+-------+
| id    |
+-------+
| 10086 |
+-------+

drop table riel;
create table riel(id int);
insert into riel values(10001);
select * from riel;
+-------+
| id    |
+-------+
| 10001 |
+-------+

drop role role1;
create role role1;
drop role role2;
create role role2;
drop role role3;
create role role3;
drop role role4;
create role role4;

drop user user_priv;
create user user_priv;
grant delete on hal_db.hal to user_priv;
show grants for 'user_priv';
Grants for user_priv@%
GRANT USAGE ON *.* TO 'user_priv'
GRANT DELETE ON `hal_db`.`hal` TO 'user_priv'

drop user user_priv2;
create user user_priv2;
show grants for 'user_priv2';
Grants for user_priv2@%
GRANT USAGE ON *.* TO 'user_priv2'

drop user user_ungrant_unupdate;
create user 'user_ungrant_unupdate' identified by '123';
grant select on hal_db.hal to user_ungrant_unupdate;
grant select on mysql.* to user_ungrant_unupdate;
grant role4 to user_ungrant_unupdate;
show grants for 'user_ungrant_unupdate';
Grants for user_ungrant_unupdate@%
GRANT USAGE ON *.* TO 'user_ungrant_unupdate'
GRANT SELECT ON `mysql`.* TO 'user_ungrant_unupdate'
GRANT SELECT ON `hal_db`.`hal` TO 'user_ungrant_unupdate'
GRANT `role4`@`%` TO `user_ungrant_unupdate`@`%`

drop user user_grant_option;
create user 'user_grant_option' identified by '123';
grant select on hal_db.hal to user_grant_option with grant option;
grant delete on hal_db.riel to user_grant_option;
grant select on mysql.user to user_grant_option;
grant role3,role4 to user_grant_option;
show grants for 'user_grant_option';
Grants for user_grant_option@%
GRANT USAGE ON *.* TO 'user_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'user_grant_option' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'user_grant_option'
GRANT SELECT ON `mysql`.`user` TO 'user_grant_option'
GRANT `role4`@`%`,`role3`@`%` TO `user_grant_option`@`%`

drop role role_priv;
create role role_priv;
grant insert,update  on hal_db.hal to role_priv;
show grants for 'role_priv';
Grants for role_priv@%
GRANT USAGE ON *.* TO 'role_priv'
GRANT INSERT, UPDATE ON `hal_db`.`hal` TO 'role_priv'

drop role role_ungrant_unupdate;
create role 'role_ungrant_unupdate';
grant select on hal_db.hal to role_ungrant_unupdate;
grant select on mysql.* to role_ungrant_unupdate;
show grants for 'role_ungrant_unupdate';
Grants for role_ungrant_unupdate@%
GRANT USAGE ON *.* TO 'role_ungrant_unupdate'
GRANT SELECT ON `mysql`.* TO 'role_ungrant_unupdate'
GRANT SELECT ON `hal_db`.`hal` TO 'role_ungrant_unupdate'
ALTER USER 'role_ungrant_unupdate' ACCOUNT UNLOCK;
ALTER USER 'role_ungrant_unupdate'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_ungrant_unupdate' AND account_locked = 'N';
+-----------------------+----------------+
| user                  | account_locked |
+-----------------------+----------------+
| role_ungrant_unupdate | N              |
+-----------------------+----------------+

drop role role_grant_option;
create role 'role_grant_option';
grant select on hal_db.hal to role_grant_option with grant option;
grant delete on hal_db.riel to role_grant_option;
grant select on mysql.user to role_grant_option;
grant role3,role4 to role_grant_option;
show grants for 'role_grant_option';
Grants for role_grant_option@%
GRANT USAGE ON *.* TO 'role_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'role_grant_option' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'role_grant_option'
GRANT SELECT ON `mysql`.`user` TO 'role_grant_option'
GRANT `role4`@`%`,`role3`@`%` TO `role_grant_option`@`%`
ALTER USER 'role_grant_option' ACCOUNT UNLOCK;
ALTER USER 'role_grant_option'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_grant_option' AND account_locked = 'N';
+-------------------+----------------+
| user              | account_locked |
+-------------------+----------------+
| role_grant_option | N              |
+-------------------+----------------+

drop user user_grant_grant_option;
create user 'user_grant_grant_option' identified by '123';
grant grant option on *.* to user_grant_grant_option;
grant select on hal_db.hal to user_grant_grant_option;
grant delete on hal_db.riel to user_grant_grant_option;
grant select on mysql.* to user_grant_grant_option;
show grants for 'user_grant_grant_option';
Grants for user_grant_grant_option@%
GRANT USAGE ON *.* TO 'user_grant_grant_option' WITH GRANT OPTION
GRANT SELECT ON `mysql`.* TO 'user_grant_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'user_grant_grant_option'
GRANT DELETE ON `hal_db`.`riel` TO 'user_grant_grant_option'

drop user user_update;
create user 'user_update' identified by '123';
grant select on hal_db.hal to user_update with grant option;
grant delete on hal_db.riel to user_update;
grant select on mysql.user to user_update;
grant role4  to user_update;
grant update on mysql.* to user_update;
show grants for 'user_update';
Grants for user_update@%
GRANT USAGE ON *.* TO 'user_update'
GRANT UPDATE ON `mysql`.* TO 'user_update'
GRANT SELECT ON `hal_db`.`hal` TO 'user_update' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'user_update'
GRANT SELECT ON `mysql`.`user` TO 'user_update'
GRANT `role4`@`%` TO `user_update`@`%`

drop role role_update;
create role 'role_update';
grant select on hal_db.hal to role_update with grant option;
grant delete on hal_db.riel to role_update;
grant select on mysql.user to role_update;
grant role4  to role_update;
grant update on mysql.* to role_update;
show grants for 'role_update';
Grants for role_update@%
GRANT USAGE ON *.* TO 'role_update'
GRANT UPDATE ON `mysql`.* TO 'role_update'
GRANT SELECT ON `hal_db`.`hal` TO 'role_update' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'role_update'
GRANT SELECT ON `mysql`.`user` TO 'role_update'
GRANT `role4`@`%` TO `role_update`@`%`
ALTER USER 'role_update' ACCOUNT UNLOCK;
ALTER USER 'role_update'@'%' IDENTIFIED BY '123';
SELECT user,account_locked FROM mysql.user WHERE user = 'role_update' AND account_locked = 'N';
+-------------+----------------+
| user        | account_locked |
+-------------+----------------+
| role_update | N              |
+-------------+----------------+
show grants for 'role_update';
Grants for role_update@%
GRANT USAGE ON *.* TO 'role_update'
GRANT UPDATE ON `mysql`.* TO 'role_update'
GRANT SELECT ON `hal_db`.`hal` TO 'role_update' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'role_update'
GRANT SELECT ON `mysql`.`user` TO 'role_update'
GRANT `role4`@`%` TO `role_update`@`%`

select user from mysql.user where user in (
    'user_update',
    'user_priv',
    'user_priv2',
    'user_ungrant_unupdate',
    'user_grant_option',
    'user_grant_grant_option',
    'role_update',
    'role_priv',
    'role_ungrant_unupdate',
    'role_grant_option',
    'role1',
    'role2',
    'role3',
    'role4'
) order by user desc;
+-------------------------+
| user                    |
+-------------------------+
| user_update             |
| user_ungrant_unupdate   |
| user_priv2              |
| user_priv               |
| user_grant_option       |
| user_grant_grant_option |
| role_update             |
| role_ungrant_unupdate   |
| role_priv               |
| role_grant_option       |
| role4                   |
| role3                   |
| role2                   |
| role1                   |
+-------------------------+


未启用系统变量read_only时
1、登录账户被授权的语法是grant xxx on *.* to xxx with grant option【补充场景】
show grants for 'user_grant_option';
Grants for user_grant_option@%
GRANT USAGE ON *.* TO 'user_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'user_grant_option' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'user_grant_option'
GRANT SELECT ON `mysql`.`user` TO 'user_grant_option'
GRANT `role4`@`%`,`role3`@`%` TO `user_grant_option`@`%`
把未拥有的权限授予给其他账户
grant role2 to role1;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
grant insert on hal_db.riel to role1;
ERROR 42000: GRANT command denied to user 'user_grant_option'@'%' for table 'riel'

把拥有的权限授予给其他账户
grant SELECT ON hal_db.hal TO role1;
grant delete on hal_db.riel to role1;
ERROR 42000: GRANT command denied to user 'user_grant_option'@'%' for table 'riel'
show grants for 'role1';
Grants for role1@%
GRANT USAGE ON *.* TO 'role1'
GRANT SELECT ON `hal_db`.`hal` TO 'role1'

2、登录账户被授权的语法是grant grant option on *.* to user/role【补充场景】
show grants for 'user_grant_grant_option';
Grants for user_grant_grant_option@%
GRANT USAGE ON *.* TO 'user_grant_grant_option' WITH GRANT OPTION
GRANT SELECT ON `mysql`.* TO 'user_grant_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'user_grant_grant_option'
GRANT DELETE ON `hal_db`.`riel` TO 'user_grant_grant_option'
把未拥有的权限授予给其他账户
grant role2 to role1;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
grant insert on hal_db.riel to role1;
ERROR 42000: INSERT command denied to user 'user_grant_grant_option'@'%' for table 'riel'

把拥有的权限授予给其他账户
grant SELECT ON hal_db.hal TO role1;
grant delete on hal_db.riel to role1;
show grants for 'role1';
Grants for role1@%
GRANT USAGE ON *.* TO 'role1'
GRANT SELECT ON `hal_db`.`hal` TO 'role1'
GRANT DELETE ON `hal_db`.`riel` TO 'role1'


###################################### echo 未启用系统变量read_only时 ################################
SET GLOBAL read_only = OFF;
SHOW VARIABLES LIKE 'read_only';
Variable_name	Value
read_only	OFF
SELECT @@read_only;
+-------------+
| @@read_only |
+-------------+
|           0 |
+-------------+

show grants for 'user_grant_option';
Grants for user_grant_option@%
GRANT USAGE ON *.* TO 'user_grant_option'
GRANT SELECT ON `hal_db`.`hal` TO 'user_grant_option' WITH GRANT OPTION
GRANT DELETE ON `hal_db`.`riel` TO 'user_grant_option'
GRANT SELECT ON `mysql`.`user` TO 'user_grant_option'
GRANT `role4`@`%`,`role3`@`%` TO `user_grant_option`@`%`
拥有 GRANT OPTION
场景1：角色授予给角色
grant role4 to role1;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
场景2：角色授予给用户
grant role4 to user_priv;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation
场景3：权限授予给角色
grant select on hal_db.hal to role_priv;
场景4：用户授予给角色
grant user_priv to role_priv;
ERROR 42501: Access denied; you need (at least one of) the SUPER privilege(s) for this operation

