DROP PROCEDURE IF EXISTS definer_procedure1;
CREATE DEFINER = 'role_definer_grant_option' PROCEDURE definer_procedure1()
BEGIN
    grant select on hal_db.hal to role_priv;
END /

DROP PROCEDURE IF EXISTS definer_procedure2;
CREATE DEFINER = 'role_definer_ungrant_option' PROCEDURE definer_procedure2()
BEGIN
    grant insert on hal_db.hal to role_priv;
END /


DROP PROCEDURE IF EXISTS grant_procedure;
CREATE PROCEDURE grant_procedure()
BEGIN
    select 1;
END /

DROP PROCEDURE IF EXISTS select_hal;
CREATE PROCEDURE select_hal()
BEGIN
    select 1;
END /

DROP PROCEDURE IF EXISTS definer_procedure1;
CREATE PROCEDURE definer_procedure1()
BEGIN
    select 1;
END /


GRANT ALTER ROUTINE ON *.* TO 'role_definer'@'%';
GRANT CREATE ROUTINE ON *.* TO 'role_definer'@'%';
grant EXECUTE ON PROCEDURE hal_db.grant_procedure to 'role_definer'@'%';
grant EXECUTE ON PROCEDURE hal_db.grant_procedure to 'role_definer'@'%';
