drop table test1;
create table test1(id int,h1 varchar(50));
insert into test1 values(1,hex(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8')));
insert into test1 values(1,hex(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8',0.5)));
