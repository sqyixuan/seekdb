drop function function_1;
CREATE FUNCTION function_1() RETURNS varchar(50)
BEGIN
DECLARE i int DEFAULT 2;
loop1:LOOP
IF i<0 THEN
UPDATE test1 SET h1=h1+1 where id<15;
LEAVE loop1;
END IF;
SET i = i-2;
END LOOP;
RETURN hex(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8',null));
END;
/
