#function-10-1   存储过程=====>if条件语句
drop table test1;
drop table test2;
drop table test3;
create table test1(uuid1 varchar(50));
create table test2(uuid2 varchar(50));
create table test3(uuid3 varchar(50));
drop procedure procedure_1;
create procedure procedure_1(aa int,bb int)
begin
if aa = bb then
insert into test1 values(hex(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8')));
insert into test1 values(hex(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8',-3)));
insert into test1 values(hex(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8',9)));
insert into test1 values(hex(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8',9.5)));
elseif aa > bb then
insert into test2 values(hex(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8')));
insert into test2 values(hex(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',-3)));
insert into test2 values(hex(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',9)));
insert into test2 values(hex(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',9.5)));
else
insert into test3 values(hex(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8')));
insert into test3 values(hex(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',-3)));
insert into test3 values(hex(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',9)));
insert into test3 values(hex(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',9.5)));
end if;
end;
/
