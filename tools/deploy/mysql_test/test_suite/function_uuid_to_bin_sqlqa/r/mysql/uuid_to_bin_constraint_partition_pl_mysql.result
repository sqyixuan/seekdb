1	8B40C56047A511EDAEDD7CD30ABC95D8
1	11ED47A58B40C560AEDD7CD30ABC95D8
CREATE FUNCTION function_1() RETURNS varchar(50)
begin
declare i varchar(50);
set i = 1;
repeat
update test1 set h1=h1+10;
set i = i + 1;
until i > 50 end repeat;
RETURN hex(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8',99));
end;
/
