select uuid_to_bin(JSON_SEARCH(@j, 'all', '10', NULL, '$[*]')) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
select uuid_to_bin(JSON_SET(@j, '$.a', 10, '$.c', '[true, false]')) from dual;
SET @j = '[100, "sakila", [1, 3, 5], 425.05]';
select uuid_to_bin(JSON_STORAGE_SIZE(@j)) from dual;
SET @j = '{"a": [10, true]}';
select uuid_to_bin(JSON_TYPE(@j)) from dual;
SET @j = '"abc"';
select uuid_to_bin(JSON_UNQUOTE(@j)) from dual;
select uuid_to_bin(JSON_VALID('{"a": 1}')) from dual;
select uuid_to_bin(JSON_VALUE('{"fname": "Joe", "lname": "Palmer"}', '$.fname')) from dual;
select uuid_to_bin(JSON_ARRAYAGG('["color", "fabric", "color", "fabric"]')) from dual;
select uuid_to_bin(JSON_OBJECTAGG('{"key": 4}')) from dual;
