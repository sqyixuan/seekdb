select uuid_to_bin(JSON_MERGE_PATCH('[1, 2]', '[true, false]')) from dual;
select uuid_to_bin(JSON_MERGE_PRESERVE('[1, 2]', '[true, false]')) from dual;
select uuid_to_bin(JSON_OBJECT('id', 87, 'name', 'carrot')) from dual;
select uuid_to_bin(JSON_OVERLAPS("[1,3,5,7]", "[2,6,8]")) from dual;
select uuid_to_bin(JSON_PRETTY('{"a":"10","b":"15","x":"25"}')) from dual;
select uuid_to_bin(JSON_QUOTE('{"name":sam, "scores":[100,200,300]}')) from dual;
SET @j = '["a", ["b", "c"], "d"]';
select uuid_to_bin(JSON_REMOVE(@j, '$[8]')) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
select uuid_to_bin(JSON_REPLACE(@j, '$.a', 10, '$.c', '[true, false]')) from dual;
