insert into test1(c1) values(hex(uuid_to_bin('jing1234-3990-11ed-958e-7cd30abc95d8')));
--error 0,1411
insert into test1(c1) values(hex(uuid_to_bin('1234jing-3990-11ed-958e-7cd30abc95d8')));
insert into test1(c1) values(hex(uuid_to_bin('1234abcd-3990-11ed-958e-7cd30abc95d8')));
