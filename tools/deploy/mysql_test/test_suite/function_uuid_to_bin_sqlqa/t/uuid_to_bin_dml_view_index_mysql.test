select * from test1 order by c1 asc;
--echo     #function-5-1-3    时间日期类型
--error 0,1051
drop table test1;
create table test1(c1 date,c2 time,c3 year);
select * from test1 order by c1 asc;
--error 0,1690
insert into test1 values(hex(uuid_to_bin('82134233-3990-11ed-958e-7cd30abc95d8')),hex(uuid_to_bin('12345678-398f-11ed-958e-7cd30abc95d8')),
hex(uuid_to_bin('00000000-398f-11ed-958e-7cd30abc95d8')));
select * from test1 order by c1 asc;
--error 0,1411
insert into test1 values(hex(uuid_to_bin('2020-02-03')),hex(uuid_to_bin('20:20:20')),hex(uuid_to_bin('2020')));
insert into test1 values('2020-02-20','20:20:20','2022');
select * from test1 order by c3 asc;
--error 0,1411
insert into test1 select * from(select uuid_to_bin(c1),uuid_to_bin(c2),uuid_to_bin(c3) from test1) as a;
--echo     #function-5-1-4    json类型
--error 0,1051
drop table test1;
create table test1(c1 json,c2 json);
--error 0,1411
insert into test1 values(hex(uuid_to_bin('')),hex(uuid_to_bin('6ccd780c-baba-1026-9564-5b8c656024db')));
--error 0,3140
insert into test1 values(hex(uuid_to_bin('{6ccd780c-baba-1026-9564-5b8c656024db}')),hex(uuid_to_bin('6ccd780c-baba-1026-9564-5b8c6560')));
insert into test1 values('{"name":"zhangsan"}','{"age":18}');
select * from test1 order by c1 asc;
insert into test1 select * from(select * from test1) as a;
select * from test1 order by c1 asc;
--error 0,1411
insert into test1 select * from(select uuid_to_bin(c1),uuid_to_bin(c2) from test1) as a;
