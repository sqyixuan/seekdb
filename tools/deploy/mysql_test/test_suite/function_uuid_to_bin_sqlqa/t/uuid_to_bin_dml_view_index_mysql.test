--echo     #function-5-1    insert语句
--echo     #function-5-1-1    数值类型
--error 0,1051
drop table test1;
create table test1(c1 bigint(100),c2 bigint(100));
--error 0,1265
insert into test1 values(hex(uuid_to_bin('12345678-398f-11ed-958e-7cd30abc95d8')),hex(uuid_to_bin('66666666-398f-11ed-958e-7cd30abc95d8')));
insert into test1 values(1,2);
insert into test1 values(2,3);
insert into test1 values(3,4);
select * from test1 order by c1 asc;
--error 0,1265
insert into test1(c1) select * from (select hex(uuid_to_bin('12345678-398f-11ed-958e-7cd30abc95d8')) from dual) as a;
--error 0,1411
insert into test1(c2) select * from (select hex(uuid_to_bin('swef5678-398f-11ed-958e-7cd30abc95d8')) from dual) as a;
--echo     #function-5-1-2    字符类型
--error 0,1051
drop table test1;
create table test1(c1 char(100),c2 char(100),c3 char(100));
