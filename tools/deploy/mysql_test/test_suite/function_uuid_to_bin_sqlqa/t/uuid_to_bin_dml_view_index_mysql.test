hex(uuid_to_bin('00000000-398f-11ed-958e-7cd30abc95d8')));
select * from test1 order by c1 asc;
--error 0,1411
insert into test1(c1) values(hex(uuid_to_bin('精华精华-3990-11ed-958e-7cd30abc95d8')));
