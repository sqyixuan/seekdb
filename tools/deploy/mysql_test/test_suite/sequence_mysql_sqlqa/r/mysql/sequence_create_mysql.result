ERROR HY000: sequence does not exist
drop table t1;
drop sequence s;
create table t1 (id int primary key, user_val int) partition by hash(id) partitions 3;
create sequence s;
insert into t1 values (10, 1);
insert into t1 values (s.nextval, s.currval);
select * from t1 order by id;
+----+----------+
| id | user_val |
+----+----------+
|  1 |        1 |
| 10 |        1 |
+----+----------+
drop table t1;
create sequence s1 order cache 10;
