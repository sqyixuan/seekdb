purge recyclebin;
result_format: 4
drop database IF EXISTS oblrp;
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
create sequence SFDA_EAI_VIRACCNOSEQ
minvalue 1
maxvalue 999999999999
start with 100000000000
increment by 1
cache 20
cycle;
create sequence SFDA_EI_ENTERPRISESEQ
minvalue 1
maxvalue 9999
start with 1000
increment by 1
cache 20
cycle;
