drop sequence s1;
drop sequence s2;
drop table t1;
drop table t2;
create sequence s1 start with 1 increment by 1 cache 30;
create sequence s2 start with 4;
create table t1 (i int primary key, j int);
create table t2 (i int primary key, j int) partition by hash(i) partitions 3;
select * from t1 where i = s1.nextval;
ERROR HY000: sequence number not allowed here
select s1.nextval from t1 group by j;
ERROR HY000: sequence number not allowed here
select s1.nextval from t1 order by i;
ERROR HY000: sequence number not allowed here
select distinct i, s1.nextval from t1;
ERROR HY000: sequence number not allowed here
select i, s1.nextval from t1 union select i, j from t2;
ERROR HY000: sequence number not allowed here
select s1.nextval  union all select 1;
ERROR HY000: sequence number not allowed here
select * from (select s1.nextval from t2) a, t2 b;
ERROR HY000: sequence number not allowed here
select * from t1 where not exists (select s1.nextval from t2);
ERROR HY000: sequence number not allowed here
