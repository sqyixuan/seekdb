select ok.nextval, ok.currval, ok.nextval ;
+---------+---------+---------+
| nextval | currval | nextval |
+---------+---------+---------+
|      16 |      16 |      16 |
+---------+---------+---------+
select ok.nextval from t_s;
+---------+
| nextval |
+---------+
|      17 |
|      18 |
+---------+
######### quick explain test ##########
explain basic select ok.nextval, i from t_p;
Query Plan
=========================================
|ID|OPERATOR                   |NAME    |
-----------------------------------------
|0 |SEQUENCE                   |        |
|1 |└─PX COORDINATOR           |        |
|2 |  └─EXCHANGE OUT DISTR     |:EX10000|
|3 |    └─PX PARTITION ITERATOR|        |
|4 |      └─TABLE FULL SCAN    |t_p     |
=========================================
Outputs & filters:
-------------------------------------
  0 - output([ok.nextval], [t_p.i]), filter(nil)
  1 - output([t_p.i]), filter(nil), rowset=16
  2 - output([t_p.i]), filter(nil), rowset=16
      dop=1
  3 - output([t_p.i]), filter(nil), rowset=16
      force partition granule
  4 - output([t_p.i]), filter(nil), rowset=16
      access([t_p.i]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t_p.i]), range(MIN ; MAX)always true
explain basic select ok.currval, i from t_p;
Query Plan
=========================================
|ID|OPERATOR                   |NAME    |
-----------------------------------------
|0 |SEQUENCE                   |        |
|1 |└─PX COORDINATOR           |        |
|2 |  └─EXCHANGE OUT DISTR     |:EX10000|
|3 |    └─PX PARTITION ITERATOR|        |
|4 |      └─TABLE FULL SCAN    |t_p     |
=========================================
Outputs & filters:
-------------------------------------
  0 - output([ok.currval], [t_p.i]), filter(nil)
  1 - output([t_p.i]), filter(nil), rowset=16
  2 - output([t_p.i]), filter(nil), rowset=16
      dop=1
  3 - output([t_p.i]), filter(nil), rowset=16
      force partition granule
  4 - output([t_p.i]), filter(nil), rowset=16
      access([t_p.i]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t_p.i]), range(MIN ; MAX)always true
