create sequence seq1 order cache 100;
alter sequence seq1 noorder cache 30;
drop sequence seq1;
#########  error test ##########
create sequence testx nomaxvalue maxvalue 1;
ERROR HY000: conflicting MAXVALUE/NOMAXVALUE specifications
create sequence testx nominvalue minvalue 1;
ERROR HY000: conflicting MINVALUE/NOMINVALUE specifications
create sequence testx cycle nocycle;
