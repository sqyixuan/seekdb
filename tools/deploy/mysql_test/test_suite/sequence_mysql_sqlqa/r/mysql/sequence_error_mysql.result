create sequence testx nocache nocache;
ERROR HY000: duplicate CACHE/NOCACHE specifications
create sequence testx nocache noorder noorder;
ERROR HY000: duplicate ORDER/NOORDER specifications
create sequence testx noorder noorder cache 10;
ERROR HY000: duplicate ORDER/NOORDER specifications
create sequence testx increment by 1 increment by 2;
ERROR HY000: duplicate INCREMENT BY specifications
create sequence testx start with 1 start with 2;
ERROR HY000: duplicate START WITH specifications
drop sequence s1;
create sequence s1 minvalue 100 maxvalue 100;
