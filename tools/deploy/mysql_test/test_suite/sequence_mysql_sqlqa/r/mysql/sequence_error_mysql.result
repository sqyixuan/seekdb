ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  maxvalue 1  increment by 1;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  minvalue 3 increment by -1;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  minvalue 1 increment by -1;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  minvalue -1 increment by -1;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  maxvalue -30;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  maxvalue -30 nominvalue;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  maxvalue 1 nominvalue;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1  minvalue -1 increment by -1 start with 10;
ERROR HY000: MINVALUE must be less than MAXVALUE
create sequence s1 minvalue 1 maxvalue 10 start with 1 increment by 10;
ERROR HY000: INCREMENT must be less than MAXVALUE minus MINVALUE
create sequence s1 minvalue 1 maxvalue 10 start with 1 increment by 11;
ERROR HY000: INCREMENT must be less than MAXVALUE minus MINVALUE
create sequence s1 minvalue 1 maxvalue 10 start with 1 increment by -10;
ERROR HY000: INCREMENT must be less than MAXVALUE minus MINVALUE
create sequence s1 minvalue 1 maxvalue 10 start with 1 increment by -11;
ERROR HY000: INCREMENT must be less than MAXVALUE minus MINVALUE
create sequence s1 increment by 0;
ERROR HY000: INCREMENT must be a nonzero integer
create sequence a4 minvalue -3 cycle increment by -1;
ERROR HY000: number to CACHE must be less than one cycle
create sequence a4 nominvalue cycle increment by -1;
ERROR HY000: descending sequences that CYCLE must specify MINVALUE
create sequence a4 minvalue -3 cycle increment by 1 cache 2;
ERROR HY000: ascending sequences that CYCLE must specify MAXVALUE
create sequence a4 start with 10 minvalue 11;
ERROR HY000: START WITH cannot be less than MINVALUE
create sequence a4 start with 10 maxvalue 9;
ERROR HY000: START WITH cannot be more than MAXVALUE
create sequence a4 minvalue 0 maxvalue 10 cache -1;
ERROR HY000: the number of values to CACHE must be greater than 1
create sequence ok start with 1 cache 1 minvalue 0 maxvalue 100;
ERROR HY000: the number of values to CACHE must be greater than 1
create sequence ok start with 1 nocache minvalue 0 maxvalue 100;
create table t_s (i int primary key, j int);
create table t_p (i int primary key, j int) partition by hash(i) partitions 3;
######### select error test ##########
select ok.nextval, ok.currval, ok.nextval from t_s order by 1;
ERROR HY000: sequence number not allowed here
select * from t_s order by ok.nextval;
ERROR HY000: sequence number not allowed here
select * from t_s where i = ok.nextval;
ERROR HY000: sequence number not allowed here
select * from t_s group by i + ok.nextval;
ERROR HY000: sequence number not allowed here
select * from t_s where i in (select ok.nextval from t_p);
ERROR HY000: sequence number not allowed here
create view nextval_view as select ok.nextval ;
ERROR HY000: sequence number not allowed here
#########  OK test ##########
insert into t_s values (ok.nextval, 1);
insert into t_s values (ok.nextval, 2);
insert into t_p values (ok.nextval, 1);
insert into t_p values (ok.nextval, 2);
insert into t_p values (100, ok.nextval);
insert into t_p values (101, ok.nextval);
update t_s set i = ok.nextval, j = ok.currval;
update t_p set i = ok.nextval, j = ok.currval;
select * from t_s order by 1;
+---+------+
| i | j    |
+---+------+
| 7 |    7 |
| 8 |    8 |
+---+------+
select * from t_p order by 1;
+----+------+
| i  | j    |
+----+------+
|  9 |    9 |
| 10 |   10 |
| 11 |   11 |
| 12 |   12 |
+----+------+
