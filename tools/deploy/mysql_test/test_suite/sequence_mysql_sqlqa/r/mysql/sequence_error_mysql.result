maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle;
create sequence SFDA_SA_ADDRESSSEQ
minvalue 100000
maxvalue 999999
start with 100000
increment by 1
cache 20
cycle;
create sequence SFDA_OF_ORDERFLOWSEQ
