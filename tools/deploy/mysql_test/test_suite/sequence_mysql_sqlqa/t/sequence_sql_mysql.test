SELECT TIMESTAMPADD(DAY, -s1.currval, '2010-01-01 00:00:00') from tt1;
SELECT TIMESTAMPADD(DAY, s1.nextval, '2010-01-01 00:00:00') from tt1;
SELECT TO_SECONDS(s1.currval),TO_SECONDS(s1.nextval) from tt1;
SELECT USEC_TO_TIME(s1.currval),usec_TO_time(s1.nextval) from tt1;
