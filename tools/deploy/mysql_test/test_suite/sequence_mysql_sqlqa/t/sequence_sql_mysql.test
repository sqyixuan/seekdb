SELECT ADDDATE('2021-08-01', INTERVAL s1.nextval DAY) from tt1;
SELECT DATE_ADD(NOW(), INTERVAL s1.currval DAY) from tt1;
SELECT DATE_ADD(NOW(), INTERVAL s1.nextval DAY) from tt1;
SELECT DATE_SUB(NOW(), INTERVAL s1.currval DAY) from tt1;
SELECT DATE_SUB(NOW(), INTERVAL s1.nextval DAY) from tt1;
SELECT FROM_DAYS(s1.currval), FROM_DAYS(s1.nextval) from tt1;
SELECT MAKEDATE(2011,s1.currval), MAKEDATE(2011,s1.nextval) from tt1;
SELECT MAKETIME(s1.currval,s1.currval,s1.currval) from tt1;
SELECT MAKETIME(s1.nextval,s1.nextval,s1.nextval) from tt1;
SELECT PERIOD_ADD(s1.nextval,s1.nextval) from tt1;
SELECT PERIOD_ADD(s1.currval,s1.currval) from tt1;
SELECT PERIOD_DIFF(s1.nextval,s1.nextval) from tt1;
SELECT PERIOD_DIFF(s1.currval,s1.currval) from tt1;
