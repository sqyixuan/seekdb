purge recyclebin;
let $char_charset = 'utf8';
--result_format 4
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


--disable_warnings
--disable_query_log
--error 0,4298
drop sequence SFDA_EAI_VIRACCNOSEQ;
--error 0,4298
drop sequence SFDA_EI_ENTERPRISESEQ;
--error 0,4298
drop sequence SFDA_UI_USERSEQ;
--error 0,4298
drop sequence SEQ_GOODSINFO;
--error 0,4298
drop sequence SFDA_MI_MERCHANTSEQ;
--error 0,4298
drop sequence SFDA_CI_CUSTOMERSEQ;
--error 0,4298
drop sequence SFDA_MSF_MSGSEQ;
--error 0,4298
drop sequence SFDA_SA_ADDRESSSEQ;
--error 0,4298
drop sequence SFDA_OF_ORDERFLOWSEQ;
--error 0,4298
drop sequence SFDA_OI_ORDERSEQ;
--error 0,4298
drop sequence SFDA_AF_ACCFLOWNOSEQ;
--error 0,4298
drop sequence SFDA_CRF_ACCCHECKSEQ;
--error 0,4298
drop sequence SFDA_CVI_VIRACCNOSEQ;
--error 0,4298
drop sequence SFDA_TFI_TRANFLOWNOSEQ;
--enable_warnings
--enable_query_log


create sequence SFDA_EAI_VIRACCNOSEQ
minvalue 1
maxvalue 999999999999
start with 100000000000
increment by 1
cache 20
cycle;

create sequence SFDA_EI_ENTERPRISESEQ
minvalue 1
maxvalue 9999
start with 1000
increment by 1
cache 20
cycle;

create sequence SFDA_UI_USERSEQ
minvalue 1
maxvalue 9999999999
start with 1000000000
increment by 1
cache 20
cycle;

create sequence SEQ_GOODSINFO
minvalue 1
maxvalue 9999999999
start with 1
increment by 1
cache 20;

create sequence SFDA_MI_MERCHANTSEQ
minvalue 1
maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle;

create sequence SFDA_CI_CUSTOMERSEQ
minvalue 1
maxvalue 9999999999
start with 1000000000
increment by 1
cache 20
cycle;

create sequence SFDA_MSF_MSGSEQ
minvalue 1
maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle;

create sequence SFDA_SA_ADDRESSSEQ
minvalue 100000
maxvalue 999999
start with 100000
increment by 1
cache 20
cycle;

create sequence SFDA_OF_ORDERFLOWSEQ
minvalue 10000000
maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle
order;

create sequence SFDA_OI_ORDERSEQ
minvalue 10000000
maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle
order;

create sequence SFDA_AF_ACCFLOWNOSEQ
minvalue 1
maxvalue 9999999999
start with 10002040
increment by 1
cache 20;

create sequence SFDA_CRF_ACCCHECKSEQ
minvalue 10000000
maxvalue 99999999
start with 10000000
increment by 1
cache 20
cycle;

create sequence SFDA_CVI_VIRACCNOSEQ
minvalue 1
maxvalue 99999999999
start with 10000160
increment by 1
cache 20;

create sequence SFDA_TFI_TRANFLOWNOSEQ
minvalue 1
maxvalue 999999999999
start with 10000840
increment by 1
cache 20;
