result_format: 4
drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
drop materialized view t1_mv3;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create materialized view t1_mv1 refresh fast on demand as
select a.*, (c1 + c3) / c2 val from t1 a where a.c2 > 0;
ERROR HY000: cannot fast refresh materialized view t1_mv1: column c4 of table t1 used in mv is required in the corresponding mlog table

create materialized view t1_mv1 refresh fast on demand as
select c1, c2, c3, (c1 + c3) / c2 val from t1 a where a.c2 > 0;

create or replace view t1_v1 as
select c1, c2, c3, (c1 + c3) / c2 val from t1 a where a.c2 > 0;

create materialized view t1_mv2 refresh fast on demand as
select c1, c2, c3, (c1 * c3) / c2 val from t1 a where a.c2 + a.c3 > 0;

create or replace view t1_v2 as
select c1, c2, c3, (c1 * c3) / c2 val from t1 a where a.c2 + a.c3 > 0;

create materialized view t1_mv3 refresh fast on demand as
select c1, c2, c3, (c2 + c1 * c3) / (c2 - c1) val from t1 a where a.c2 > 4 or a.c3 < 5;

create or replace view t1_v3 as
select c1, c2, c3, (c2 + c1 * c3) / (c2 - c1) val from t1 a where a.c2 > 4 or a.c3 < 5;

create or replace view res_com1
as
select res, count(*) from
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v1.*, '1.normal view' view_type from t1_v1
        union all
        select t1_mv1.*, '2.mview' from t1_mv1)
    group by c1
)
group by res
;

create or replace view res_com2
as
select res, count(*) from 
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v2.*, '1.normal view' view_type from t1_v2
        union all
        select t1_mv2.*, '2.mview' from t1_mv2)
    group by c1
)
group by res
;

create or replace view res_com3
as
select res, count(*) from 
(   select group_concat(view_type order by view_type) res
    from (
        select t1_v3.*, '1.normal view' view_type from t1_v3
        union all
        select t1_mv3.*, '2.mview' from t1_mv3)
    group by c1
)
group by res
;

select * from res_com1;
+-----------------------+----------+
| res                   | count(*) |
+-----------------------+----------+
| 1.normal view,2.mview |        1 |
+-----------------------+----------+
select * from res_com2;
+-----------------------+----------+
| res                   | count(*) |
+-----------------------+----------+
| 1.normal view,2.mview |        1 |
+-----------------------+----------+
select * from res_com3;
+-----------------------+----------+
| res                   | count(*) |
+-----------------------+----------+
| 1.normal view,2.mview |        1 |
+-----------------------+----------+

insert into t1 values(2,1,2,1);
insert into t1 values(3,1,3,1);
call dbms_mview_stats.set_system_default('COLLECTION_LEVEL', 'ADVANCED');
call dbms_mview_stats.purge_refresh_stats(NULL, -1);
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
