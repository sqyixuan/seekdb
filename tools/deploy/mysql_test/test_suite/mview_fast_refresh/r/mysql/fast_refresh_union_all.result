result_format: 4
drop materialized view log on t1;
drop table if exists t1;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
drop view if exists t1_v4;
drop view if exists t1_v5;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
drop materialized view t1_mv3;
drop materialized view t1_mv4;
drop materialized view t1_mv5;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3, c4) including new values;

no valid maker select item: equal value
create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot fast refresh materialized view t1_mv1: UNION ALL query without valid marker select item

no valid maker select item: equal value
create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, 1 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, 1 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot fast refresh materialized view t1_mv1: UNION ALL query without valid marker select item

create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, 1 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, 2 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, 2 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot fast refresh materialized view t1_mv1: UNION ALL query without valid marker select item

no valid maker select item: null value
create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, b.c1 as b_c1, NULL marker from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot fast refresh materialized view t1_mv1: UNION ALL query without valid marker select item

no valid maker select item: position mismatch
create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, 2 marker, b.c1 as b_c1 from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot fast refresh materialized view t1_mv1: UNION ALL query without valid marker select item

pkey select item with cast, not support now
create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker,
a.c2 cnt, b.c2 cnt_c3, a.c3 sum_c3, b.c3 avg_c3, b.c3 + a.c3 calc_1
from t1 a inner join t1 b on a.c2 = b.c3
union all
select c1, count(*) cnt, 2 marker,
c2, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1
from t1 group by c1, c2;
ERROR HY000: cannot fast refresh materialized view t1_mv1: primary keys of all base tables are required in the select item list in the 0-th set child query

union all not support on query computation
create materialized view t1_mv1
refresh fast on demand
enable on query computation
as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, b.c1 as b_c1, 2 marker from t1 a, t1 b where a.c2 = b.c3;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view t1_mv1: on query computation is not supported for materialized view with UNION ALL

create materialized view t1_mv1 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, b.c1 as b_c1, 2 marker from t1 a, t1 b where a.c2 = b.c3;

create or replace view t1_v1 as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker from t1 a, t1 b where a.c2 = b.c3
union all
select a.c1 as a_c1, b.c1 as b_c1, 2 marker from t1 a, t1 b where a.c2 = b.c3;

create materialized view t1_mv2 refresh fast on demand as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker,
a.c2 cnt, b.c2 cnt_c3, a.c3 sum_c3, b.c3 avg_c3, b.c3 + a.c3 calc_1
from t1 a inner join t1 b on a.c2 = b.c3
union all
select c1 a_c1, c2 b_c1, 2 marker,
count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1
from t1 group by c1, c2;

create or replace view t1_v2 as
select a.c1 as a_c1, b.c1 as b_c1, 1 marker,
a.c2 cnt, b.c2 cnt_c3, a.c3 sum_c3, b.c3 avg_c3, b.c3 + a.c3 calc_1
from t1 a inner join t1 b on a.c2 = b.c3
union all
select c1, c2, 2 marker,
count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3)/c2 calc_1
from t1 group by c1, c2;

create materialized view t1_mv3 refresh fast on demand as
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       1 as marker,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e
union all
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       2 as marker,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e;

create or replace view t1_v3 as
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       1 as marker,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e
union all
select a.c1 as a_c1,
       b.c1 as b_c1,
       c.c1 as c_c1,
       2 as marker,
       d.c1 as d_c1,
       e.c1 as e_c1 from t1 a, t1 b, t1 c, t1 d, t1 e;

create materialized view t1_mv4 refresh fast on demand as
select c1, count(*) cnt, 1 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select c1, count(*) cnt, 2 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1;

create or replace view t1_v4 as
select c1, count(*) cnt, 1 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select c1, count(*) cnt, 2 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1;

create materialized view t1_mv5 refresh fast on demand as
select c1, count(*) cnt, 1 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select c1, count(*) cnt, 2 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select a.c4 as group_col, count(*) cnt, 3 marker,
count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2, avg(b.c2) avg_c3, avg(b.c2)*sum(b.c2)/a.c4 calc_1
from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view t1_v5 as
select c1, count(*) cnt, 1 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select c1, count(*) cnt, 2 marker,
count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3)*sum(c3) calc_1
from t1 group by c1
union all
select a.c4 as group_col, count(*) cnt, 3 marker,
count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2, avg(b.c2) avg_c3, avg(b.c2)*sum(b.c2)/a.c4 calc_1
from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com1
as
select res, count(*) from 
(   select v.*, group_concat(view_type order by view_type) res
    from (
        select t1_v1.*, '1.normal view' view_type from t1_v1
        union all
        select t1_mv1.*, '2.mview' from t1_mv1) v
    group by 1,2,3
)
group by res
;

create or replace view res_com2
as
select res, count(*) from 
(   select v.*, group_concat(view_type order by view_type) res
    from (
        select t1_v2.*, '1.normal view' view_type from t1_v2
        union all
        select t1_mv2.*, '2.mview' from t1_mv2) v
    group by 1,2,3,4,5,6,7,8
)
group by res
;

create or replace view res_com3
as
select res, count(*) from 
(   select v.*, group_concat(view_type order by view_type) res
    from (
        select t1_v3.*, '1.normal view' view_type from t1_v3
        union all
        select t1_mv3.*, '2.mview' from t1_mv3) v
    group by 1,2,3,4,5,6
)
group by res
;

create or replace view res_com4
as
select res, count(*) from 
(   select v.*, group_concat(view_type order by view_type) res
    from (
        select t1_v4.*, '1.normal view' view_type from t1_v4
        union all
        select t1_mv4.*, '2.mview' from t1_mv4) v
    group by 1,2,3,4,5,6,7
)
group by res
;

create or replace view res_com5
as
select res, count(*) from 
(   select v.*, group_concat(view_type order by view_type) res
    from (
        select t1_v5.*, '1.normal view' view_type from t1_v5
        union all
        select t1_mv5.*, '2.mview' from t1_mv5) v
    group by 1,2,3,4,5,6,7
)
group by res
;

