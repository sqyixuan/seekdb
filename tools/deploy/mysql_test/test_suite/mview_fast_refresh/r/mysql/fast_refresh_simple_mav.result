insert into t1 values(4,1,4,1);
insert into t1 values(5,2,5,1);
update t1 set c3 = c1 * 4 where c1 > 3;
delete from t1 where c1 = 1;
insert into ht1 values(4,1,4,1);
insert into ht1 values(5,2,5,1);
update ht1 set c3 = c1 * 4 where c1 > 3;
delete from ht1 where c1 = 1;
insert into ht2 values(4,1,4,1);
insert into ht2 values(5,2,5,1);
update ht2 set c3 = c1 * 4 where c1 > 3;
delete from ht2 where c1 = 1;

