result_format: 4
drop materialized view log on t1;
drop table if exists t1;
drop materialized view t1_mv1;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;

create materialized view t1_mv1 refresh fast on demand as
select c1, count(*) cnt from t1 where ora_rowscn > 1234455 group by c1;
ERROR HY000: cannot fast refresh materialized view t1_mv1: query with ora_rowscn pseudo columns is not supported

create materialized view t1_mv1 refresh fast on demand as
select c1, count(*) cnt from t1 where c3 > curdate() group by c1;
ERROR HY000: cannot fast refresh materialized view t1_mv1: query with current time expression is not supported

create materialized view t1_mv1 refresh fast on demand as
select c1, count(*) cnt from t1 where c3 > sysdate() group by c1;
ERROR HY000: cannot fast refresh materialized view t1_mv1: non-deterministic query is not supported

create materialized view t1_mv1 refresh fast on demand as
select c1, count(*) cnt from t1 where c3 > random() group by c1;
ERROR HY000: cannot fast refresh materialized view t1_mv1: non-deterministic query is not supported

drop materialized view log on t1;
drop table if exists t1;
