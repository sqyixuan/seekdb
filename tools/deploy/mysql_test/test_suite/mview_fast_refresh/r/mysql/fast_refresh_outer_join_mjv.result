result_format: 4
drop materialized view log on t1;
drop materialized view log on t2;
drop materialized view log on t3;
drop materialized view log on t1_p;
drop materialized view log on t2_p;
drop materialized view log on t3_p;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t1_p;
drop table if exists t2_p;
drop table if exists t3_p;
drop view if exists v1;
drop materialized view mv1;
drop materialized view mv2;
drop materialized view mv3;
drop materialized view mv4;
drop materialized view mv5;
drop materialized view mv6;
drop materialized view mv7;
drop materialized view mv8;
drop materialized view mv9;
drop materialized view mv10;
drop materialized view mv11;
drop materialized view mv12;
drop materialized view mv13;
drop materialized view mv14;
drop materialized view mv15;
drop materialized view mv16;
drop materialized view mv17;
drop materialized view mv18;
drop materialized view mv1_p;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int primary key, c2 int, c3 int, c4 int);
create table t3(c1 int primary key, c2 int, c3 int, c4 int);
create table t4(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;
create materialized view log on t2 with primary key, rowid, sequence (c2, c3) including new values;
create materialized view log on t3 with primary key, rowid, sequence (c2, c3) including new values;
create view v1 as select c1, c2, c3, c2+c3 c23 from t1;

create table t1_p(c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;
create table t2_p(c1 int, c2 int, c3 int, c4 int, primary key (c1, c2, c3));
create table t3_p(c1 int, c2 int, c3 int, c4 int, primary key (c1, c2, c3)) partition by hash(c2) subpartition by hash(c3) partitions 6;
create materialized view log on t1_p with primary key, rowid, sequence (c2, c3) including new values;
create materialized view log on t2_p with primary key, rowid including new values;
create materialized view log on t3_p with primary key, rowid including new values;

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        right join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: only support left deep join tree for materialized view with OUTER JOIN

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: all single columns exist in the SELECT exprs are required in the SELECT item list for materialized view with OUTER JOIN

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: primary keys of all base tables are required in the select item list

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t1.c4 t1_c4, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: column c4 of table t1 used in mv is required in the corresponding mlog table

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from v1 t1 left join t2 on t1.c1 = t2.c1
           left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: query has invalid table type(GENERATED_TABLE). only basic table and materialized view are supported

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t4 t1 left join t2 on t1.c1 = t2.c1
           left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: base table t4 doesn't have mlog table

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t2.c1 = 3
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: OUTER JOIN condition should contain at least one table from each side

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on 1 = 1
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: OUTER JOIN condition should contain at least one table from each side

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 + t2.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot fast refresh materialized view mv1: can not contain more than two tables in one OUTER JOIN condition

create materialized view mv1 refresh fast on demand as 
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2
from t1 left join t2 on t1.c2 = t2.c2
where t2.c1 is null;
ERROR HY000: cannot fast refresh materialized view mv1: WHERE conditions should not contain any null side table

create materialized view mv1 refresh fast on demand as 
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2
from t1 left join t2 on t1.c2 = t2.c2
where case when t2.c1 is not null then 2 else 1 end = 1;
ERROR HY000: cannot fast refresh materialized view mv1: WHERE conditions should not contain any null side table

create materialized view mv1 refresh fast on demand enable on query computation as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;
ERROR HY000: cannot ENABLE ON QUERY COMPUTATION for the materialized view mv1: on query computation is not supported for materialized view with OUTER JOIN

create materialized view mv1 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv2 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv3 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 inner join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv4 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t3 right join
        (t1 left join t2 on t1.c1 = t2.c1)
          on t2.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv5 refresh fast on demand as
select t1.c1 t1_c1, t2.c1 t2_c1, t2b.c1 t2b_c1, t3.c1 t3_c1
from t1 left join t2 on t1.c1 = t2.c1
        inner join t2 t2b on t1.c1 = t2b.c1
        left join t3 on t2b.c1 = t3.c1
where t1.c3 > 3;

create materialized view mv6 refresh fast on demand as
select t1.c1 t1_c1, t2.c1 t2_c1, t2b.c1 t2b_c1, t3.c1 t3_c1
from t1 left join t2 on t1.c1 = 1
        inner join t2 t2b on 1 = 1
        left join t3 on t2b.c1 = 1
where t1.c3 > 3;

create materialized view mv7 (primary key(t1_c1)) refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c1 = t3.c1
where t1.c3 > 3;

create materialized view mv8 (primary key(t1_c3, t1_c1)) refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c1 = t3.c1
where t1.c3 > 3;

create materialized view mv9 (primary key(t1_c1, t1_c3)) PARTITION BY HASH(t1_c3) PARTITIONS 3  refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c1 = t3.c1
where t1.c3 > 3;

create materialized view mv10 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 = t3.c2 and t2.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv11 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2, t3.c1 t3_c1, t3.c2 t3_c2, t1_b.c1 t1b_c1, t1_b.c2 t1b_c2, t2_b.c1 t2b_c1, t2_b.c2 t2b_c2, t3_b.c1 t3b_c1, t3_b.c2 t3b_c2, t1.c2 + t3_b.c2 + t3.c2 cplus, case when t1_b.c1 is null then t2.c1 else t3.c1 end
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2,
     t3 t3_b left join t2 t2_b on t2_b.c1 = t3_b.c1
             left join t1 t1_b on t1_b.c1 = t3_b.c1
where t1.c3 > 3;

create materialized view mv12 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2, t3.c1 t3_c1, t3.c2 t3_c2, t1_b.c1 t1b_c1, t1_b.c2 t1b_c2, t2_b.c1 t2b_c1, t2_b.c2 t2b_c2, t3_b.c1 t3b_c1, t3_b.c2 t3b_c2, t1.c2 + t3_b.c2 + t3.c2 cplus, case when t1_b.c1 is null then t2.c1 else t3.c1 end
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2,
     t3 t3_b inner join t2 t2_b on t2_b.c1 = t3_b.c1
             inner join t1 t1_b on t1_b.c1 = t3_b.c1
where t1.c3 > 3 and case when t3_b.c1 > 5 then t1.c1 < 7 else t1.c1 > 3 end;

create materialized view mv13 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2, t3.c1 t3_c1, t3.c2 t3_c2, t1_b.c1 t1b_c1, t1_b.c2 t1b_c2, t2_b.c1 t2b_c1, t2_b.c2 t2b_c2, t3_b.c1 t3b_c1, t3_b.c2 t3b_c2, t1.c2 + t3_b.c2 + t3.c2 cplus, case when t1_b.c1 is null then t2.c1 else t3.c1 end
from t1 left join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2,
     t3 t3_b left join t2 t2_b on t2_b.c1 = t3_b.c1
             inner join t1 t1_b on t1_b.c1 = t3_b.c1
where t1.c3 > 3 and case when t3_b.c1 > 5 then t1.c1 < 7 else t1.c1 > 3 end;

create materialized view mv14 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2, t3.c1 t3_c1, t3.c2 t3_c2, t1_b.c1 t1b_c1, t1_b.c2 t1b_c2, t2_b.c1 t2b_c1, t2_b.c2 t2b_c2, t3_b.c1 t3b_c1, t3_b.c2 t3b_c2, t1.c2 + t3_b.c2 + t3.c2 cplus, case when t1_b.c1 is null then t2.c1 else t3.c1 end
from t1 inner join t2 on t1.c1 = t2.c1
        left join t3 on t2.c2 = t3.c2,
     t3 t3_b left join t2 t2_b on t2_b.c1 = t3_b.c1
             inner join t1 t1_b on t1_b.c1 = t3_b.c1
where t1.c3 > 3 and case when t3_b.c1 > 5 then t1.c1 < 7 else t1.c1 > 3 end;

create materialized view mv15 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 left join t2 on t1.c1 = t2.c1
        inner join t3 on t2.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv16 refresh fast on demand as
select t1.c1 t1_c1, t2.c1 t2_c1, t2b.c1 t2b_c1, t3.c1 t3_c1
from (t1 left join t2 on t1.c1 = t2.c1)
        inner join
      (t2 t2b inner join t3 on t2b.c1 = t3.c1) on 1
where t1.c3 > 3;

create materialized view mv17 refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1 full join t2 on t1.c1 = t2.c1
        left join t3 on t1.c2 = t3.c2
where t1.c3 > 3;

create materialized view mv18 refresh fast on demand as 
select t1.c1 t1_c1, t1.c2 t1_c2, t2.c1 t2_c1, t2.c2 t2_c2
from t1 left join t2 on t1.c2 = t2.c2
where t2.c1 = 3;

create materialized view mv1_p refresh fast on demand as
select t1.c1 t1_c1, t1.c2 t1_c2, t1.c3 t1_c3, t2.c1 t2_c1, t2.c2 t2_c2, t2.c3 t2_c3, t3.c1 t3_c1, t3.c2 t3_c2, t3.c3 t3_c3, t1.c3 + t2.c3 + t3.c3 cplus
from t1_p t1 left join t2_p t2 on t1.c1 = t2.c1
             left join t3_p t3 on t1.c2 = t3.c2
where t1.c3 > 3;

insert into t1 values(1,2,5,4);
insert into t1 values(2,2,5,4);
insert into t2 values(1,2,3,4);
insert into t2 values(2,2,3,4);
insert into t3 values(1,2,3,4);
insert into t3 values(2,2,3,4);
insert into t1_p values(1,2,5,4);
insert into t1_p values(2,2,5,4);
insert into t2_p values(1,2,3,4);
insert into t2_p values(2,2,3,4);
insert into t3_p values(1,2,3,4);
insert into t3_p values(2,2,3,4);

call dbms_mview_stats.set_system_default('COLLECTION_LEVEL', 'ADVANCED');
call dbms_mview_stats.purge_refresh_stats(NULL, -1);
call DBMS_MVIEW.REFRESH('mv1', 'f');
call DBMS_MVIEW.REFRESH('mv2', 'f');
