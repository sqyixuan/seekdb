call DBMS_MVIEW.REFRESH('mv5', 'f');
call DBMS_MVIEW.REFRESH('mv6', 'f');
call DBMS_MVIEW.REFRESH('mv7', 'f');
call DBMS_MVIEW.REFRESH('mv8', 'f');
call DBMS_MVIEW.REFRESH('mv9', 'f');
call DBMS_MVIEW.REFRESH('mv10', 'f');
call DBMS_MVIEW.REFRESH('mv11', 'f');
call DBMS_MVIEW.REFRESH('mv12', 'f');
call DBMS_MVIEW.REFRESH('mv13', 'f');
call DBMS_MVIEW.REFRESH('mv14', 'f');
call DBMS_MVIEW.REFRESH('mv15', 'f');
call DBMS_MVIEW.REFRESH('mv16', 'f');
call DBMS_MVIEW.REFRESH('mv17', 'f');
call DBMS_MVIEW.REFRESH('mv18', 'f');
call DBMS_MVIEW.REFRESH('mv1_p', 'f');

