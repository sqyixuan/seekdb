insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
insert into ht1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
call dbms_mview_stats.set_system_default('COLLECTION_LEVEL', 'ADVANCED');
call dbms_mview_stats.purge_refresh_stats(NULL, -1);
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
call DBMS_MVIEW.REFRESH('t1_mv4', 'f');
call DBMS_MVIEW.REFRESH('ht1_mv1', 'f');
