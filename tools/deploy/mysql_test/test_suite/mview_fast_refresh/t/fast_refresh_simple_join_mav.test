--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for fast refresh simple join mav
#tags: mv_optimizer,mview

--result_format 4

set ob_query_timeout = 100000000;

--disable_warnings
--error 0, 1146
drop materialized view log on t1;
--error 0, 1146
drop materialized view log on ht1;
--error 0, 1146
drop materialized view log on ht2;
drop table if exists t1;
drop table if exists t2;
drop table if exists ht1;
drop table if exists ht2;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
drop view if exists ht1_v1;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t1_mv2;
--error 0, 9757
drop materialized view t1_mv3;
--error 0, 9757
drop materialized view t1_mv4;
--error 0, 9757
drop materialized view ht1_mv1;
--enable_warnings

create table t1(c1 int primary key auto_increment, c2 int, c3 int, c4 int, c5 int);
create table t2(c1 int primary key auto_increment, c2 int, c3 int, c4 int, c5 int);
insert into t1(c2, c3, c4) values(1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3, c4) including new values;

CREATE TABLE ht1(c1 int primary key auto_increment, c2 int, c3 int, c4 int) ORGANIZATION = HEAP;
CREATE TABLE ht2(c1 int, c2 int, c3 int, c4 int) ORGANIZATION = HEAP PARTITION BY KEY (c1) partitions 3;
insert into ht1(c2, c3, c4) values(1,1,1);
insert into ht2 values(1,1,1,1);
create materialized view log on ht1 with primary key, rowid, sequence (c2, c3, c4) including new values;
create materialized view log on ht2 with primary key, rowid, sequence (c1, c2, c3, c4) including new values;

--error 9760
create materialized view t1_mv1 refresh fast on demand as
select count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c1;

--error 9760
create materialized view t1_mv1 refresh fast on demand as
select count(*) cnt from t1 a, t2 b where a.c2 = b.c3;

--error 9760
create materialized view t1_mv1 refresh fast on demand as
select count(*) cnt from t1 a left join t1 b on a.c2 = b.c3;

--error 9760
create materialized view t1_mv1 refresh fast on demand as
select a.c4 as group_col, count(*) cnt from ht1 a, ht2 b where a.c2 = b.c3 group by a.c4;

## allowed more than 5 table
create materialized view t1_mv1 refresh fast on demand as
select count(*) from t1 a, t1 b, t1 c, t1 d, t1 e, t1 f;
drop materialized view t1_mv1;

create materialized view t1_mv1 refresh fast on demand as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view t1_v1 as
select a.c4 as group_col, count(*) cnt from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com1
as
select 2 * (select count(*) from (select * from t1_v1 union select * from t1_mv1))
       -  (select count(*) from (select * from t1_v1 union all select * from t1_mv1)) as expect_0
from dual;

create materialized view ht1_mv1 refresh fast on demand as
select a.c4 as group_col, count(*) cnt from ht1 a, ht1 b where a.c2 = b.c3 group by a.c4;

create or replace view ht1_v1 as
select a.c4 as group_col, count(*) cnt from ht1 a, ht1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com_h1
as
select 2 * (select count(*) from (select * from ht1_v1 union select * from ht1_mv1))
       -  (select count(*) from (select * from ht1_v1 union all select * from ht1_mv1)) as expect_0
from dual;

create materialized view t1_mv2 refresh fast on demand as
select a.c4 as group_col, count(*) cnt, count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2
from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view t1_v2 as
select a.c4 as group_col, count(*) cnt, count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2
from t1 a, t1 b where a.c2 = b.c3 group by a.c4;

create or replace view res_com2
as
select 2 * (select count(*) from (select * from t1_v2 union select * from t1_mv2))
       -  (select count(*) from (select * from t1_v2 union all select * from t1_mv2)) as expect_0
from dual;

create materialized view t1_mv3 refresh fast on demand as
select count(*) cnt, count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2
from t1 a, t1 b where a.c2 = b.c3;

create or replace view t1_v3 as
select count(*) cnt, count(b.c2) cnt_b_c2, sum(b.c2) sum_b_c2
from t1 a, t1 b where a.c2 = b.c3;

create or replace view res_com3
as
select 2 * (select count(*) from (select * from t1_v3 union select * from t1_mv3))
       -  (select count(*) from (select * from t1_v3 union all select * from t1_mv3)) as expect_0
from dual;

create materialized view t1_mv4 refresh fast on demand as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3
       /* avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1 There is a loss of precision, do not check them use random data*/
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view t1_v4 as
select a.c3 a_c3, b.c2 b_c2,
       count(*) cnt,
       count(e.c4) cnt_e_c4,
       sum(e.c4) sum_e_c4,
       count(c.c3) cnt_c_c3,
       sum(c.c3) sum_c_c3
       /* avg(e.c4) avg_e_c4,
       sum(c.c3) * avg(e.c4) calc_1 There is a loss of precision, do not check them use random data*/
from t1 a, t1 b, t1 c, t1 d, t1 e
where a.c2 = b.c3 and b.c2 = c.c4 and c.c2 = d.c3 and d.c4 = e.c2
group by a.c3, b.c2
;

create or replace view res_com4
as
select 2 * (select count(*) from (select * from t1_v4 union select * from t1_mv4))
       -  (select count(*) from (select * from t1_v4 union all select * from t1_mv4)) as expect_0
from dual;

select * from res_com1;
select * from res_com2;
select * from res_com3;
select * from res_com4;
select * from res_com_h1;

insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
insert into ht1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
call dbms_mview_stats.set_system_default('COLLECTION_LEVEL', 'ADVANCED');
call dbms_mview_stats.purge_refresh_stats(NULL, -1);
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
call DBMS_MVIEW.REFRESH('t1_mv4', 'f');
call DBMS_MVIEW.REFRESH('ht1_mv1', 'f');
--replace_regex /[0-9]{19}/XXXXXX/
select step, sqlid, stmt from oceanbase.__all_mview_refresh_stmt_stats order by mview_id, step;
call dbms_mview_stats.set_system_default('COLLECTION_LEVEL', 'TYPICAL');

select * from res_com1;
select * from res_com2;
select * from res_com3;
select * from res_com4;
select * from res_com_h1;

insert into t1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
update t1 set c2 = c4 where c3 > 3;
delete from t1 where c4 < 2;
insert into ht1(c2, c3, c4) select uniform(1, 5, random()), uniform(1, 5, random()), uniform(1, 5, random()) from table(generator(20));
update ht1 set c2 = c4 where c3 > 3;
delete from ht1 where c4 < 2;
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
call DBMS_MVIEW.REFRESH('t1_mv4', 'f');
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
call DBMS_MVIEW.REFRESH('t1_mv4', 'f');
call DBMS_MVIEW.REFRESH('ht1_mv1', 'f');

select * from res_com1;
select * from res_com2;
select * from res_com3;
select * from res_com4;
select * from res_com_h1;

delete from t1;
delete from ht1;
call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');
call DBMS_MVIEW.REFRESH('t1_mv3', 'f');
call DBMS_MVIEW.REFRESH('t1_mv4', 'f');
call DBMS_MVIEW.REFRESH('ht1_mv1', 'f');

select * from res_com1;
select * from res_com2;
select * from res_com3;
select * from res_com4;
select * from res_com_h1;

drop materialized view log on t1;
drop materialized view log on ht1;
drop materialized view log on ht2;
drop table if exists t1;
drop table if exists t2;
drop table if exists ht1;
drop table if exists ht2;
drop view if exists t1_v1;
drop view if exists t1_v2;
drop view if exists t1_v3;
drop view if exists t1_v4;
drop view if exists ht1_v1;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
drop materialized view t1_mv3;
drop materialized view t1_mv4;
drop materialized view ht1_mv1;
