--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test mview column result type check
#tags: mv_optimizer,mview

--result_format 4
--enable_sorted_result

--disable_warnings
--error 0, 1146
drop materialized view log on t1;
drop table if exists t1;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t1_mv2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 varchar(20));
insert into t1 values(1,1,1,'1233');
insert into t1 values(2,2,1,'123.12');
create materialized view log on t1 with primary key, rowid, sequence (c2, c3, c4) including new values;

create materialized view t1_mv1 refresh fast on demand as
select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, sum(cast(c3*c3 as double)) sum_c3_2, sum(c3*c3) sum_c3_3 from t1 group by c2;
create or replace view t1_cmp_v1 as
select 'mview' view_type, t1_mv1.* from t1_mv1
union all
select 'view', c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, sum(cast(c3*c3 as double)) sum_c3_2, sum(c3*c3) sum_c3_3 from t1 group by c2;

create materialized view t1_mv2 refresh fast on demand as
select c2 as c2, count(*) cnt, count(c4) cnt_c4, sum(c4) sum_c4 from t1 group by c2;
create or replace view t1_cmp_v2 as
select 'mview' view_type, t1_mv2.* from t1_mv2
union all
select 'view', c2 as c2, count(*) cnt, count(c4) cnt_c4, sum(c4) sum_c4 from t1 group by c2;

select * from t1_cmp_v1;
select * from t1_cmp_v2;

insert into t1 values(3,2,1,'32.32');
insert into t1 values(4,1,1,'123.12');
insert into t1 values(5,1,1,'-12');

call DBMS_MVIEW.REFRESH('t1_mv1', 'f');
call DBMS_MVIEW.REFRESH('t1_mv2', 'f');

select * from t1_cmp_v1;
select * from t1_cmp_v2;

drop materialized view log on t1;
drop table if exists t1;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
