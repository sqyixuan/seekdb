drop table if exists t1;
drop table if exists t2;
set session ob_trx_timeout=100000000000;
create table t1 (c1 int NOT NULL, c2 int NOT NULL, c3 int NOT NULL, c4 blob NOT NULL, PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none' with column group (all columns, each column);
create table t2 (c1 int NOT NULL, c2 int NOT NULL, c3 int NOT NULL, c4 blob NOT NULL, PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none' with column group (all columns, each column);
alter system major freeze;
select * from t1 where c2 = 666 and c4 > '1';
