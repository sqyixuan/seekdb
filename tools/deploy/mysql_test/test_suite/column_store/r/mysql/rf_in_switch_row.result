drop table if exists t1;
drop table if exists t2;
create table t1(c1 int, c2 int) with column group (each column);
create table t2(c1 int, c2 int) with column group (each column);
alter system major freeze;
set runtime_filter_type='in';
explain select /*+parallel(2) leading(t1 t2) PQ_DISTRIBUTE(t2 hash, hash) px_join_filter(t2) no_px_part_join_filter(t2)*/ * from t1 join t2 on t1.c1=t2.c1 order by t1.c1;
