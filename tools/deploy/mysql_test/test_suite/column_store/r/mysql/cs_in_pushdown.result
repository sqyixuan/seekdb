create table t1(c1 int primary key, c2 smallint, c3 int unsigned, c4 date, c5 char(20), c6 varchar(20), c7 varchar(20)) row_format = compressed block_size = 2048 with column group (all columns, each column);
create table t2(c1 text, c2 mediumtext, c3 longtext) row_format = compressed block_size = 2048 with column group (all columns, each column);
create table t3(c1 text) row_format = compressed block_size = 2048 with column group (all columns, each column);
alter system major freeze;
