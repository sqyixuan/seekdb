explain select c1, c2 from t1 where c2 = 0 group by c1, c2 order by c1;
Query Plan
==========================================================
|ID|OPERATOR                  |NAME|EST.ROWS|EST.TIME(us)|
----------------------------------------------------------
|0 |MERGE DISTINCT            |    |64      |214         |
|1 |└─SORT                    |    |99      |213         |
|2 |  └─COLUMN TABLE FULL SCAN|t1  |99      |199         |
==========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2]), filter(nil), rowset=256
      distinct([t1.c1])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=256
      sort_keys([t1.c1, ASC])
  2 - output([t1.c2], [t1.c1]), filter([t1.c2 = 0]), rowset=256
      access([t1.c2], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.pk]), range(MIN ; MAX)always true
