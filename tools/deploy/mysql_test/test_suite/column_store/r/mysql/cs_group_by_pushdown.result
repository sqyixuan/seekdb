create table t1(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 with column group (all columns, each column);
create table t2(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 with column group (all columns, each column);
create table t3(pk int primary key, c1 int, c2 int) block_size=2048 with column group (all columns, each column);
create table pt1(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4 with column group (all columns, each column);
create table t_padding(pk int primary key, c1 char(20), c2 char(20)) block_size=2048 with column group (all columns, each column);
create table t_lob(pk int primary key, c1 int, c2 text) lob_inrow_threshold = 0 with column group (each column);
