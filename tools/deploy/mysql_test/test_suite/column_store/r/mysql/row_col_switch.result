===============================================================
===========  Step 0: prepare env and tables  ==================
===============================================================
alter system set undo_retention = 0;
set global recyclebin = OFF;
create table t1(c1 int, c2 int, primary key (c1)) with column group (all columns, each column);
create table t2(
c1 int, 
c2 DECIMAL(10, 2),
g1 DECIMAL(10, 2) as ((c1+c2+c3)*100/7) virtual,
g2 DECIMAL(10, 2) as ((c1+c2+c3)*100/7) stored,
c3 int,
primary key (c1, c2)) with column group (all columns, each column);
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key (c1)) with column group (all columns, each column);
create table t4(c1 int, c2 int, primary key (c1)) with column group (each column);
create table t5(
c1 int, 
c2 DECIMAL(10, 2),
g1 DECIMAL(10, 2) as ((c1+c2+c3)*100/7) virtual,
g2 DECIMAL(10, 2) as ((c1+c2+c3)*100/7) stored,
c3 int,
primary key (c1, c2)) with column group (each column);
create table t6(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key (c1)) with column group (each column);
create sequence seq1 cache 100000 noorder;
create sequence seq2 cache 100000 noorder;
create sequence seq3 cache 100000 noorder;
create sequence seq4 cache 100000 noorder;
create sequence seq5 cache 100000 noorder;
create sequence seq6 cache 100000 noorder;
