  1 - output([t1.c1], [T_FUN_COUNT_SUM(T_FUN_COUNT(*))]), filter(nil), rowset=2
      group([t1.c1]), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
  2 - output([t1.c1], [T_FUN_COUNT(*)]), filter(nil), rowset=2
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true, 
      pushdown_groupby([t1.c1]), pushdown_aggregation([T_FUN_COUNT(*)])
