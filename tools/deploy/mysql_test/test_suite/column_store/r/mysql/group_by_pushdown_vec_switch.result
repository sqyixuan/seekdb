set _enable_rich_vector_format = true;
create table t_empty(c1 int, c2 int) with column group (each column);
select count(c1), min(c1), max(c1), sum(c1) from t_empty;
count(c1)	min(c1)	max(c1)	sum(c1)
0	NULL	NULL	NULL
select count(c2), min(c2), max(c2), sum(c2) from t_empty;
count(c2)	min(c2)	max(c2)	sum(c2)
0	NULL	NULL	NULL
select c1,count(c2),min(c2),max(c2),sum(c2) from t_empty group by c1 order by c1;
c1	count(c2)	min(c2)	max(c2)	sum(c2)
select c2,count(c1),min(c1),max(c1),sum(c1) from t_empty group by c1 order by c2;
c2	count(c1)	min(c1)	max(c1)	sum(c1)
