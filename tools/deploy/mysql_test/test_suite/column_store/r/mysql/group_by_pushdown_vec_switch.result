create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100), primary key(c1,pk)) block_size=2048 with column group (each column);
create table t2(pk int primary key, c1 int, c2 decimal(4, 2), c3 varchar(100)) block_size=2048 with column group (each column);
create table t3(pk int primary key, c1 int, c2 decimal(4, 2), c3 longtext) block_size=2048 with column group (each column);
create table pt1(pk int primary key, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4 with column group (each column);
create table t_padding(pk int primary key, c1 char(20), c2 char(20)) block_size=2048 with column group (each column);
create table st1(pk int, c1 int, c2 int, primary key(pk)) with column group (each column);
create table st2(c1 int primary key, c2 int) with column group (each column);
create index st1_idx1 on st1(c1,c2);
create index st2_c2 on st2(c2);
insert into t3 select * from t2;
update t3 set c3 = repeat("abc", 10000) where mod(pk, 100) = 0;
insert into st1 select pk,pk%3,pk from t1 limit 5000;
insert into st2 select pk,c1 from st1;
