123456	123456	100	100	abd	abd	abcabcabcabcabcabcabcabcabcabc	abcabcabcabcabcabcabcabcabcabc
select min(b),max(b) from t2;
min(b)	max(b)
11	11
insert into t2(a,b) select a,a from t2;
select min(b),max(b) from t2;
