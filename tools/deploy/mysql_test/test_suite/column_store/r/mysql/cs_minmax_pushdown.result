create table pt1(a int) with column group (all columns, each column);
create table pt2(a int, b int, c int) partition by hash(a) partitions 4 with column group (all columns, each column);
create table pt3(a int, b int, c int) partition by hash(a) partitions 4 with column group (all columns, each column);
insert into pt1 values(1),(2),(3);
insert into pt2 values(1,1,1),(2,2,2),(3,3,3);
insert into pt3 values (null,null,null),(1,1,1),(2,2,2),(3,3,3);
select a,min(a),max(a),min(b),max(b),min(c),max(c) from pt2;
a	min(a)	max(a)	min(b)	max(b)	min(c)	max(c)
1	1	3	1	3	1	3
select a,min(a),max(a),min(b),max(b),min(c),max(c) from pt3;
a	min(a)	max(a)	min(b)	max(b)	min(c)	max(c)
NULL	1	3	1	3	1	3
select/*+ leading(pt1,tt) use_nl(pt1,tt) NO_USE_NL_MATERIALIZATION(tt) */ * from pt1,(select a,min(a),max(a),min(b),max(b),min(c),max(c) from pt2) as tt where pt1.a=tt.a;
a	a	min(a)	max(a)	min(b)	max(b)	min(c)	max(c)
1	1	1	3	1	3	1	3
select/*+ leading(pt1,tt) use_nl(pt1,tt) NO_USE_NL_MATERIALIZATION(tt) */ * from pt1,(select a,min(a),max(a),min(b),max(b),min(c),max(c) from pt3) as tt where pt1.a=tt.a;
a	a	min(a)	max(a)	min(b)	max(b)	min(c)	max(c)
drop table if exists t_types,t_empty,t_null1,t_null2,t_default1,t_default2,t_padding,t1,t2,pt1,pt2,pt3;
