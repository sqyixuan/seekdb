create table t_types(c0 bool, c1 tinyint, c2 smallint, c3 mediumint, c4 int, c5 bigint, c6 decimal(16,4), c7 float, c8 double, c10 date, c11 time, c12 datetime, c13 timestamp, c14 year, c15 char, c16 char(10), c17 varchar(10)) with column group (all columns, each column);
insert into t_types values(0,1,2,3,4,5,6.0,7.0,8.0,'2022-05-16','16:52:10','2022-05-16 16:52:10','2022-05-16 16:52:10','2022','a','ab','abc');
insert into t_types values(1,2,3,4,5,6,7.0,8.0,9.0,'2022-05-17','17:52:10','2022-05-17 16:52:10','2022-05-17 16:52:10','2023','b','bc','bcd');
select min(c0),min(c1),min(c2),min(c3),min(c4),min(c5),min(c6),min(c7),min(c8),min(c10),min(c11),min(c12),min(c13),min(c14),min(c15),min(c16),min(c17) from t_types;
min(c0)	min(c1)	min(c2)	min(c3)	min(c4)	min(c5)	min(c6)	min(c7)	min(c8)	min(c10)	min(c11)	min(c12)	min(c13)	min(c14)	min(c15)	min(c16)	min(c17)
0	1	2	3	4	5	6.0000	7	8	2022-05-16	16:52:10	2022-05-16 16:52:10	2022-05-16 16:52:10	2022	a	ab	abc
select max(c0),max(c1),max(c2),max(c3),max(c4),max(c5),max(c6),max(c7),max(c8),max(c10),max(c11),max(c12),max(c13),max(c14),max(c15),max(c16),max(c17) from t_types;
max(c0)	max(c1)	max(c2)	max(c3)	max(c4)	max(c5)	max(c6)	max(c7)	max(c8)	max(c10)	max(c11)	max(c12)	max(c13)	max(c14)	max(c15)	max(c16)	max(c17)
1	2	3	4	5	6	7.0000	8	9	2022-05-17	17:52:10	2022-05-17 16:52:10	2022-05-17 16:52:10	2023	b	bc	bcd
create table t_empty(a int) with column group (all columns, each column);
select a,min(a),max(a) from t_empty;
a	min(a)	max(a)
NULL	NULL	NULL
create table t_null1(a int) with column group (all columns, each column);
insert into t_null1 values(null),(null),(null);
select min(a),max(a) from t_null1;
min(a)	max(a)
NULL	NULL
create table t_null2(a int) with column group (all columns, each column);
insert into t_null2 values(null),(1),(2);
select a,min(a),max(a) from t_null2;
a	min(a)	max(a)
NULL	1	2
delete from t_null2 where 1=1;
insert into t_null2 values(1),(null),(2);
select a,min(a),max(a) from t_null2;
a	min(a)	max(a)
1	1	2
create table t_default1(pk int primary key, a char(5)) row_format = compact with column group (all columns, each column);
insert into t_default1 values(1,'a');
insert into t_default1(pk) values(2),(3);
select min(a),max(a) from t_default1;
min(a)	max(a)
a	a
create table t_default2(pk int primary key, a int default 10) row_format = compact with column group (all columns, each column);
insert into t_default2 values(1,9);
select min(a),max(a) from t_default2;
min(a)	max(a)
9	9
create table t_padding(pk int primary key, a char(10) default 'a') with column group (all columns, each column);
select a,min(a),max(a) from t_padding;
a	min(a)	max(a)
NULL	NULL	NULL
insert into t_padding values(1,'b');
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
select char_length(a) from t_padding;
char_length(a)
10
select a,min(a),max(a) from t_padding;
a	min(a)	max(a)
b         	b         	b         
SET sql_mode = '';
create table t1 (a bigint auto_increment primary key, b bigint, c char(100), d varchar(100), e bigint not null) row_format = compressed block_size = 2048 with column group (all columns, each column);
insert into t1 (a, b, c, d, e) values(1, 9, "a", repeat('a', 10),1);
insert into t1 (a, b, c, d, e) values(2, 2, "ab", repeat("ab", 10),1);
insert into t1 (a, b, c, d, e) values(3, 5, "abcd", repeat("ab", 10),1);
insert into t1 (a, b, c, d, e) values(4, 7, NULL, repeat("abcd", 10),1);
insert into t1 (a, b, c, d, e) values(5, NULL, "ab c ", repeat("a", 10),1);
insert into t1 (a, b, c, d, e) values(6, 9, NULL, repeat("abbb", 10),1);
insert into t1 (a, b, c, d, e) values(7, 1, "abc ", repeat("abcd", 10),1);
insert into t1 (a, b, c, d, e) values(8, 3, "abcde", NULL,1);
insert into t1 (a, b, c, d, e) values(9, 100, "abd", repeat("abc", 10),1);
insert into t1 (a, b, c, d, e) select a * 10 + 6, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) select a * 10 + 5, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) select a * 10 + 4, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) select a * 10 + 3, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) select a * 10 + 2, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) select a * 10 + 1, b + 1, c, d, e from t1;
insert into t1 (a, b, c, d, e) values(123456, 100, "abd", repeat("abc", 10),1);
create table t2(a int) with column group (all columns, each column);
alter table t2 add column b int default 11;
alter system minor freeze;
select max(b),min(a) from t1;
max(b)	min(a)
106	1
select min(a),max(a),min(b),max(b),min(c),max(c),min(d),max(d) from t1;
min(a)	max(a)	min(b)	max(b)	min(c)	max(c)	min(d)	max(d)
1	9654321	1	106	a	abd	aaaaaaaaaa	abcdabcdabcdabcdabcdabcdabcdabcdabcdabcd
select min(a),max(a),min(b),max(b),min(c),max(c),min(d),max(d) from t1 where a > 5 and b is not null;
min(a)	max(a)	min(b)	max(b)	min(c)	max(c)	min(d)	max(d)
6	9654321	1	106	a	abd	aaaaaaaaaa	abcdabcdabcdabcdabcdabcdabcdabcdabcdabcd
select min(a),max(a),min(b),max(b),min(c),max(c),min(d),max(d) from t1 where a < 1;
min(a)	max(a)	min(b)	max(b)	min(c)	max(c)	min(d)	max(d)
NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL
