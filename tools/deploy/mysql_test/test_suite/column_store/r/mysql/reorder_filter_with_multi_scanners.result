drop table if exists t1;
CREATE TABLE `t1` (
`pk` int(11) NOT NULL,
`c1` int(11) DEFAULT NULL,
`c2` int(10) unsigned DEFAULT NULL,
`c3` varchar(100) DEFAULT NULL,
PRIMARY KEY (`pk`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 2048 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by hash(pk)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`) WITH COLUMN GROUP(all columns, each column);
alter system major freeze;
alter system flush plan cache;
set ob_query_timeout=1000000000;
select /*+ no_rewrite*/ exists(select pk from (select pk, c1 from t1 where pk not like '1%' and c1=1 group by pk, c1 order by pk desc) A where A.pk >= B.pk), B.pk from t1 b ORDER BY 1, 2 limit 10;
exists(select pk from (select pk, c1 from t1 where pk not like '1%' and c1=1 group by pk, c1 order by pk desc) A where A.pk >= B.pk)	pk
0	9998
0	9999
0	10000
0	10001
0	10002
0	10003
0	10004
0	10005
0	10006
0	10007
drop table t1;
