drop table if exists ct1;
set session ob_trx_timeout=100000000000;
create table ct1(c1 int primary key, c2 int, c3 number, c4 varchar(60000), c5 varchar(60000)) ROW_FORMAT = redundant COMPRESSION = 'none' with column group (all columns, each column);
alter system major freeze;
select count(1) from ct1;
count(1)
5000
select sum(c1), sum(c2) from ct1;
sum(c1)	sum(c2)
12497500	12497500
update ct1 set c2 = c2 + 100000 where c1 < 3100 and c1 >= 3000;
select count(1) from ct1;
count(1)
5100
select sum(c1), sum(c2) from ct1;
sum(c1)	sum(c2)
13002450	23002450
alter system minor freeze;
select count(1) from ct1;
count(1)
5100
select sum(c1), sum(c2) from ct1;
sum(c1)	sum(c2)
13002450	23002450
alter system major freeze;
select count(1) from ct1;
count(1)
5100
select sum(c1), sum(c2) from ct1;
sum(c1)	sum(c2)
13002450	23002450
drop table ct1;
