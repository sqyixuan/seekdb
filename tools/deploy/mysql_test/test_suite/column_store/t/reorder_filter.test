# owner: liquanhong.lqh
# owner group: storage
# description: check reorder filter in column store

--disable_query_log
connect (conn1, $OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
set @@session.explicit_defaults_for_timestamp=off;
set session ob_trx_timeout=100000000000;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
sleep 2;
set @@recyclebin = off;
--enable_query_log

connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key, c1 int, c2 int) with column group (each column);

--disable_query_log
--let $count = 0
while($count < 10000)
{
eval insert into t1 values
($count * 10+ 0 , 0, 100 ),
($count * 10+ 1 , 1, 100 ),
($count * 10+ 2 , 2, 100 ),
($count * 10+ 3 , 3, 100 ),
($count * 10+ 4 , 4, 100 ),
($count * 10+ 5 , 5, 100 ),
($count * 10+ 6 , 6, 100 ),
($count * 10+ 7 , 7, 100 ),
($count * 10+ 8 , 8, 100 ),
($count * 10+ 9 , 9, 100 );
inc $count;
}
while($count < 20000)
{
eval insert into t1 values
($count * 10+ 0 , 0, 200 ),
($count * 10+ 1 , 1, 200 ),
($count * 10+ 2 , 2, 200 ),
($count * 10+ 3 , 3, 200 ),
($count * 10+ 4 , 4, 200 ),
($count * 10+ 5 , 5, 200 ),
($count * 10+ 6 , 6, 200 ),
($count * 10+ 7 , 7, 200 ),
($count * 10+ 8 , 8, 200 ),
($count * 10+ 9 , 9, 200 );
inc $count;
}
--enable_query_log

connection default;
alter system major freeze;
alter system flush plan cache;
# alter system set _enable_filter_reordering = 1;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;

select count(*) from t1 where c1 > 2 and c1 <= 6;
select count(*) from t1 where c1 > 3 and c1 <> 7 and c1 <> 9;
select count(*) from t1 where c1 in (1,3,5,7) and c1 in (2,4,6,8);
select count(*) from t1 where c1 in (1,3,5,7) and c1 <> 7 and c1 > 3 and c1 <> 9;
select count(*) from t1 where c1 in (1,3,5,7) or c1 <> 7 or c1 > 3 or c1 <> 9;
select count(*) from t1 where c1 in (1,3,5,7) and c1 <> 7 or c1 > 3 and c1 <> 9;

select count(*) from t1 where c1 < 6 and c2 = 100;
select count(*) from t1 where c1 > 2 and c1 < 6 and c2 = 100;
select count(*) from t1 where c1 in (1,3,5,7) and c2 in (100, 300);
select count(*) from t1 where c1 in (1,3,5,7) and c2 in (100, 300) and c1 <> 7 and c1 > 3 and c1 <> 9;
select count(*) from t1 where c1 <> 7 and c1 > 3 and c2 in (100, 300) or c1 in (1,3,5,7) and c2 > 100;

select count(*) from t1 sample(10) seed(1) where c1 = 1;

drop table t1;
--disable_query_log
connection syscon;
set @@recyclebin = on;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;
--enable_query_log
