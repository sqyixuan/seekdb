# owner group: STORAGE
# description:

--disable_query_log
--disable_warnings
set @@recyclebin = off;
drop table if exists table200;
--enable_warnings
--enable_query_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;

connection default;
CREATE TABLE table200 (
col_timestamp_unique_index timestamp NULL DEFAULT NULL,
col_decimal_20_0_unique_index decimal(20,0),
col_varchar_20_unique_index varchar(20),
pk int,
col_bigint bigint,
col_double_index double,
col_bigint_unique_index bigint,
col_double double,
col_double_unique_index double,
col_decimal_20_0_index decimal(20,0),
col_bigint_index bigint,
col_decimal_20_0 decimal(20,0),
col_timestamp timestamp NULL DEFAULT NULL,
col_varchar_20 varchar(20),
col_timestamp_index timestamp NULL DEFAULT NULL,
col_varchar_20_index varchar(20),
/*Indices*/
unique index idx14(col_timestamp_unique_index ),
unique index idx8(col_decimal_20_0_unique_index ),
unique index idx11(col_varchar_20_unique_index ),
index idx4(col_double_index ),
unique index idx2(col_bigint_unique_index ),
unique index idx5(col_double_unique_index ),
index idx7(col_decimal_20_0_index ),
index idx1(col_bigint_index ),
index idx13(col_timestamp_index ),
index idx10(col_varchar_20_index )) with column group (each column); 


alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection obsys;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;

connection default;
INSERT INTO table200 VALUES (NULL, 1, NULL, NULL, NULL, NULL, 6, 9, 0, NULL, 0, NULL, '2000-10-11 13:24:12.034447', 'bg', NULL, NULL);
select count(*) from table200;
delete from table200;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select * from table200;