# owner: ouyanghongrong.oyh
# owner group: STORAGE
# description: for testing major compaction for column group for all columns, each column into only all cg.

# Get basical information for tenant, tablet and table
connect (obsys,$OBMYSQL_MS0, root, "", oceanbase, $OBMYSQL_PORT);
connection obsys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = "sys", tenant_id, 1);
let $original_undo_retention = query_get_value(select value from __all_virtual_tenant_parameter_info where name like "%undo_retention%" and tenant_id = $tenant_id limit 1, value, 1);
# prepare for testing
connection default;
alter system set undo_retention = 0;
set global recyclebin = OFF;

--disable_query_log
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings
--enable_query_log

create table t1(c1 int not null, c2 int default 0, c3 varchar(16) collate utf16_general_ci default 'dft_c3  ', c4 char(16) collate utf16_general_ci default 'dft_c4') with column group (all columns, each column);
create table t2(c1 int not null, c2 int default 0, c3 varchar(16) collate utf16_general_ci default 'dft_c3  ', c4 char(16) collate utf16_general_ci default 'dft_c4') with column group (each column);
create table t3(c1 int not null, c2 int default 0, c3 varchar(16) collate utf16_general_ci default 'dft_c3  ', c4 char(16) collate utf16_general_ci default 'dft_c4');


--let $table=t1
--let $table_name="t1"
--source mysql_test/include/row_col_switch_add_default_column.inc

--let $table=t2
--let $table_name="t2"
--source mysql_test/include/row_col_switch_add_default_column.inc

--let $table=t3
--let $table_name="t3"
--source mysql_test/include/row_col_switch_add_default_column.inc

set sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
select c3, char_length(c3), c4, char_length(c4), c6, char_length(c6), c7, char_length(c7), c8, char_length(c8), c9, char_length(c9), c10, char_length(c10), c11, char_length(c11) from t1 limit 10;
select c3, char_length(c3), c4, char_length(c4), c6, char_length(c6), c7, char_length(c7), c8, char_length(c8), c9, char_length(c9), c10, char_length(c10), c11, char_length(c11) from t2 limit 10;
select c3, char_length(c3), c4, char_length(c4), c6, char_length(c6), c7, char_length(c7), c8, char_length(c8), c9, char_length(c9), c10, char_length(c10), c11, char_length(c11) from t3 limit 10;
--disable_query_log
--disable_warnings
eval alter system set undo_retention = $original_undo_retention;
--enable_warnings
--enable_query_log
set sql_mode = '';
