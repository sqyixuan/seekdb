select /*+no_use_column_table(t2)*/ count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t2 sample(1) seed(1234) where pk > 60000 and pk < 100000 order by pk desc;
select /*+no_use_column_table(t2)*/ count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t2 sample(1) seed(1234) where c1 < 2000 or c1 > 8000 order by pk desc;

select /*+no_use_column_table(t2)*/ pk, c1 from t2 sample(0.1) seed(1234);
