# owner: houhaojun.hhj
# owner group: storage
# description: Validate sampling functionality

--disable_query_log
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
--enable_query_log

# row store table
create table t1(pk int, c1 int, c2 varchar(10), primary key(pk));
# column store table
create table t2(pk int, c1 int, c2 varchar(10), primary key(pk)) with column group (all columns, each column);

--disable_query_log
--disable_result_log

# 80,000 rows in major sstable
--let $count = 0
while($count < 10000)
{
    --let $stmt=insert into t1 values($count, $count, "oceanbase")
    eval $stmt;
    --let $stmt=insert into t2 values($count, $count, "oceanbase")
    eval $stmt;
    inc $count;
}

--let $offset = 1
--let $times = 1
while($times <= 3)
{
    --let $stmt=insert into t1 select pk + 10000 * $offset, c1, c2 from t1
    eval $stmt;
    --let $stmt=insert into t2 select pk + 10000 * $offset, c1, c2 from t2
    eval $stmt;
    inc $times;
    let $offset = $offset * 2;
}

--enable_query_log
--enable_result_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
--disable_result_log

# 80,000 rows in memtable/mini/minor sstable
while($times <= 4)
{
    --let $stmt=insert into t1 select pk + 10000 * $offset, c1, c2 from t1
    eval $stmt;
    --let $stmt=insert into t2 select pk + 10000 * $offset, c1, c2 from t2
    eval $stmt;
    inc $times;
    let $offset = $offset * 2;
}

--enable_query_log
--enable_result_log

--result_format 4

###### sample row store table t1 ######

select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(99) seed(1234);
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(10) seed(1234);
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234);
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234) where pk > 60000 and pk < 100000;
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234) where c1 < 2000 or c1 > 8000;

select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(99) seed(1234) order by pk desc;
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(10) seed(1234) order by pk desc;
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234) order by pk desc;
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234) where pk > 60000 and pk < 100000 order by pk desc;
select count(*), avg(pk), min(pk), max(pk), avg(c1), sum(c1), min(c1), max(c1) from t1 sample(1) seed(1234) where c1 < 2000 or c1 > 8000 order by pk desc;

select pk, c1 from t1 sample(0.1) seed(1234);
select pk, c1 from t1 sample(0.01) seed(1234);
select pk, c1 from t1 sample(0.001) seed(1234);
select pk, c1 from t1 sample(0.0001) seed(1234);
select pk, c1 from t1 sample(0.00001) seed(1234);

select pk, c1 from t1 sample(0.1) seed(1234) order by pk desc;
select pk, c1 from t1 sample(0.01) seed(1234) order by pk desc;
select pk, c1 from t1 sample(0.001) seed(1234) order by pk desc;
select pk, c1 from t1 sample(0.0001) seed(1234) order by pk desc;
select pk, c1 from t1 sample(0.00001) seed(1234) order by pk desc;


