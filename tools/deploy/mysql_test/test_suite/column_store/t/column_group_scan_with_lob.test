select count(*) from t1 where c2 >= 0 or c4 like '%3%';
select count(*) from t1 where c4 is not null or c4 like '%3%';

select c1,c2 from t1 where c2 = -1 or c4 like '%3%' order by c1 desc;
select c1,c2 from t1 where c2 = 0 or c4 like '%3%' order by c1 desc;
