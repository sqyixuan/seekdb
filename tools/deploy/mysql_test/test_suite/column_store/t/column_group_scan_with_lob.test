# owner: dengzhi.ldz
# owner group: storage
# description: scan column group table with lob column 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
set session ob_trx_timeout=100000000000;
create table t1 (c1 int NOT NULL, c2 int NOT NULL, c3 int NOT NULL, c4 blob NOT NULL, PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none' with column group (all columns, each column);
create table t2 (c1 int NOT NULL, c2 int NOT NULL, c3 int NOT NULL, c4 blob NOT NULL, PRIMARY KEY (c1)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none' with column group (all columns, each column);

--let $value_2k=2
--let $bytes=2148
--let $byte=2
while($bytes)
{
  --let $value_2k=$value_2k$byte
  dec $bytes;
}

--let $value_nk=4
--let $bytes=20000
--let $byte=4
while($bytes)
{
  --let $value_nk=$value_nk$byte
  dec $bytes;
}

--disable_query_log
--let $count = 0
while($count < 1000)
{
  eval insert into t1 values($count * 10, $count * 10, 1, '$value_2k'),
                            ($count * 10 + 1, $count * 10 + 1, 1, '$value_2k'),
                            ($count * 10 + 2, $count * 10 + 2, 1, '$value_2k'),
                            ($count * 10 + 3, $count * 10 + 3, 1, '$value_2k'),
                            ($count * 10 + 4, $count * 10 + 4, 1, '$value_2k'),
                            ($count * 10 + 5, $count * 10 + 5, 1, '$value_2k'),
                            ($count * 10 + 6, $count * 10 + 6, 1, '$value_2k'),
                            ($count * 10 + 7, $count * 10 + 7, 1, '$value_2k'),
                            ($count * 10 + 8, $count * 10 + 8, 1, '$value_2k'),
                            ($count * 10 + 9, $count * 10 + 9, 1, '$value_2k');

  --inc $count
}
--let $count = 0
while($count < 1000)
{
  eval insert into t2 values($count * 10, $count * 10, 1, '$value_2k'),
                            ($count * 10 + 1, $count * 10 + 1, 1, '$value_2k'),
                            ($count * 10 + 2, $count * 10 + 2, 1, '$value_2k'),
                            ($count * 10 + 3, $count * 10 + 3, 1, '$value_2k'),
                            ($count * 10 + 4, $count * 10 + 4, 1, '$value_2k'),
                            ($count * 10 + 5, $count * 10 + 5, 1, '$value_2k'),
                            ($count * 10 + 6, $count * 10 + 6, 1, '$value_2k'),
                            ($count * 10 + 7, $count * 10 + 7, 1, '$value_2k'),
                            ($count * 10 + 8, $count * 10 + 8, 1, '$value_2k'),
                            ($count * 10 + 9, $count * 10 + 9, 1, '$value_2k');

  --inc $count
}
eval update t1 set c4 = '$value_nk' where c1 = -1;
eval update t1 set c4 = '$value_nk' where c1 = 0;
eval update t1 set c4 = '$value_nk' where c1 = 3000;
eval update t1 set c4 = '$value_nk' where c1 = 3001;
eval update t1 set c4 = '$value_nk' where c1 = 3003;
eval update t1 set c4 = '$value_nk' where c1 = 3007;
eval update t1 set c4 = '$value_nk' where c1 = 3015;
eval update t1 set c4 = '$value_nk' where c1 = 3031;
eval update t1 set c4 = '$value_nk' where c1 = 3063;
eval update t1 set c4 = '$value_nk' where c1 = 3128;
eval update t1 set c4 = '$value_nk' where c1 = 3256;
eval update t1 set c4 = '$value_nk' where c1 = 3512;
eval update t1 set c4 = '$value_nk' where c1 = 4024;
eval update t1 set c4 = '$value_nk' where c1 = 5048;
eval update t1 set c4 = '$value_nk' where c1 = 8097;
eval update t1 set c4 = '$value_nk' where c1 = 9999;
eval update t1 set c4 = '$value_nk' where c1 = 10000; 
#13~2999 3038~3060 3074~3120 3134~3252 3266~3504 3518~4020 4034~5040 5054~8088 8102~9996
#9995~8101 8087~5053 5039~4033 4019~3517 3503~3265 3251~3133 3119~3073 3059~3037 2998~12

connection default;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
--enable_query_log

connection conn1;
select * from t1 where c2 = 666 and c4 > '1';
select * from t1 where c2 = 666 and c4 > '3';
select * from t2 where c2 = 666 and c4 > '1';
select * from t2 where c2 = 666 and c4 > '3';
select c1,c2 from t1 where c2 = -1 or c4 like '%3%';
select c1,c2 from t1 where c2 = 0 or c4 like '%3%';
select c1,c2 from t1 where c2 = 1 or c4 like '%3%';
select c1,c2 from t1 where c2 = 2 or c4 like '%3%';
