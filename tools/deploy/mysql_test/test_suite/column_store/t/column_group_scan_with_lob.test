select c1,c2 from t1 where c2 = 3030 or c4 like '%3%' order by c1 desc;
select c1,c2 from t1 where c2 = 3064 or c4 like '%3%' order by c1 desc;
select c1,c2 from t1 where c2 = 9087 or c4 like '%3%' order by c1 desc;
select c1,c2 from t1 where c2 = 9999 or c4 like '%3%' order by c1 desc;
select count(*) from t1 where c2 >= 0 or c4 like '%3%' order by c1 desc;
select count(*) from t1 where c4 is not null or c4 like '%3%' order by c1 desc;

--disable_query_log
eval update t1 set c3 = 2 where c1 = 1500;
eval update t1 set c3 = 2 where c1 = 2000;
eval update t1 set c3 = 2 where c1 = 3007;
eval update t1 set c3 = 2 where c1 = 3015;
eval update t1 set c3 = 2 where c1 = 3052;
eval update t1 set c3 = 2 where c1 = 3063;
eval update t1 set c3 = 2 where c1 = 8000;
