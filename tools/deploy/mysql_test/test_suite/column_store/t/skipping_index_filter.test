# owner: dengzhi.ldz
# owner group: storage
# description: test skipping index filter for scanning column group. 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
set session ob_query_timeout=10000000000;
drop table if exists ct1;
drop table if exists ctx;
--enable_warnings

--disable_query_log
create table ct1(c0 int NOT NULL AUTO_INCREMENT, c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(10), c7 int) with column group (all columns, each column);
create table ctx(c1 int) row_format=redundant compression='none' block_size = 1024 WITH COLUMN GROUP(each column);
--let $count = 0
while($count < 10000)
{
  eval insert into ct1(c1,c2,c3,c4,c5,c6,c7) values
                                             ($count * 10,     0,    1, 1, null, 'a',     $count * 10), 
                                             ($count * 10 + 1, 1, null, 1, null, 'a', $count * 10 + 1),
                                             ($count * 10 + 2, 2,    1, 1, null, 'a', $count * 10 + 2),
                                             ($count * 10 + 3, 3, null, 1, null, 'a', $count * 10 + 3),
                                             ($count * 10 + 4, 4,    1, 1, null, 'a', $count * 10 + 4),
                                             ($count * 10 + 5, 5, null, 1, null, 'a', $count * 10 + 5),
                                             ($count * 10 + 6, 6,    1, 1, null, 'a', $count * 10 + 6),
                                             ($count * 10 + 7, 7, null, 1, null, 'a', $count * 10 + 7),
                                             ($count * 10 + 8, 8,    1, 1, null, 'a', $count * 10 + 8),
                                             ($count * 10 + 9, 9, null, 1, null, 'a', $count * 10 + 9);
  inc $count;
}
alter system set undo_retention = 0;
insert into ctx select c1 from ct1;
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(1) from ct1 where c1 = 50000;
select count(1) from ct1 where c1 != 50000;
select count(1) from ct1 where c1 <= 50000;
select count(1) from ct1 where c1 < 50000;
select count(1) from ct1 where c1 >= 50000;
select count(1) from ct1 where c1 > 50000;
select count(1) from ct1 where c1 between 50000 and 99999;
select count(1) from ct1 where c1 in (50000, 99999);
select count(1) from ct1 where c3 is null;
select count(1) from ct1 where c3 is not null;
select count(1) from ct1 where c4 is null;
select count(1) from ct1 where c4 is not null;
select count(1) from ct1 where c6 = 'a';
select count(1) from ct1 where c5 = 3;
select count(1) from ct1 where c5 < 5;

select count(1) from ct1 where c1 = 50000 or c1 is null;
select count(1) from ct1 where c1 = 50000 and c1 is not null;
select count(1) from ct1 where (c1 = 50000 and c1 is not null) or c2 in (1,3);
select count(1) from ct1 where (c2 >= 10 or c2 < 0 or c2 is null or c2 <= 5) and c2 >= -5;
select count(1) from ct1 where (c2 >= 10 or c2 < 0 or c2 is null or c2 = 5) or c2 in (1,3) or c5 = 3;
select count(1) from ct1 where c1 >= 0 and c1 <= 99999 and c2 >= 0 and c2 <= 9 and c4 >= -100 and c4 <= 100 and c7 >= 0 and c7 <= 99999 and c6 >= 'a'; 

alter system set _enable_skip_index=0;alter system flush plan cache;
select count(*) from ctx where c1 < 71950 or c1*2 > 143900;
alter system set _enable_skip_index=1;alter system flush plan cache;
select count(*) from ctx where c1 < 71950 or c1*2 > 143900;

alter system set undo_retention = 1800;
drop table if exists ct1;
drop table if exists ctx;
