# owner: yht146439
# tags: storage
# description: pushdown group by to storage layer

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--enable_query_log

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2,pt1;
--enable_warnings
--enable_query_log

create table t1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 with column group (all columns, each column);
create table pt1(pk int, c1 int, c2 int unsigned, c3 varchar(100)) block_size=2048 partition by hash(pk) partitions 4 with column group (all columns, each column);

--disable_query_log
--let $count = 0
while($count < 1000)
{
  eval insert into t1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 2,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 3,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 4,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 5,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 6,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 7,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 8,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 9,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5))),
                                  ($count * 10 + 10,mod($count, 3), mod($count, 10), concat("abcdefg", mod($count, 5)));
  eval insert into pt1(pk, c1,c2,c3) values 
                                  ($count * 10 + 1,null, mod($count * 10 + 1 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 2,mod($count * 10 + 2, 4), mod($count * 10 + 2 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 3,mod($count * 10 + 3, 4), mod($count * 10 + 3 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 4,mod($count * 10 + 4, 4), null, concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 5,mod($count * 10 + 5, 4), mod($count * 10 + 5 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 6,mod($count * 10 + 6, 4), mod($count * 10 + 6 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 7,mod($count * 10 + 7, 4), mod($count * 10 + 7 + 1, 8), null),
                                  ($count * 10 + 8,mod($count * 10 + 8, 4), mod($count * 10 + 8 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 9,mod($count * 10 + 9, 4), mod($count * 10 + 9 + 1, 8), concat("abcdefg", mod($count, 3))),
                                  ($count * 10 + 10,null, null, null);
  --inc $count
}
--enable_query_log

select count(*) from t1 group by c1 order by c1;
select c1,count(*) from t1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 group by c1 order by c1;
select count(*) from pt1 group by c1 order by c1;
select c1,count(*) from pt1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from pt1 group by c1 order by c1;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'PT1', method_opt=>'for all columns size 64', estimate_percent=>100);
--enable_query_log

alter system set _rowsets_max_rows = 2;
alter system flush plan cache;

explain select c1,count(*) from t1 group by c1 order by c1;
select count(*) from t1 group by c1 order by c1;
select c1,count(*) from t1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 group by c1 order by c1;
select count(*) from pt1 group by c1 order by c1;
select c1,count(*) from pt1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from pt1 group by c1 order by c1;

alter table t1 add column c4 bigint default 10, add column c5 bigint default null, add column c6 varchar(20) default 'abc';
alter table pt1 add column c4 bigint default 10, add column c5 bigint default null, add column c6 varchar(20) default 'abcdefghijk';
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select count(*) from t1 group by c1 order by c1;
select c1,count(*) from t1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from t1 group by c1 order by c1;
select count(*) from pt1 group by c1 order by c1;
select c1,count(*) from pt1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),min(pk),min(c1),min(c2),min(c3),max(pk),max(c1),max(c2),max(c3),sum(pk),sum(c1),sum(c2) from pt1 group by c1 order by c1;

select count(*) from t1 group by c4 order by c4;
select c4,count(*) from t1 group by c4 order by c4;
select c4,count(*),count(c1) from t1 group by c4 order by c4;
select c1,count(c4) from t1 group by c1 order by c1;
select c1,count(*),count(c1),count(c4) from t1 group by c1 order by c1;

alter system set _rowsets_max_rows = 128;
alter system flush plan cache;

select count(*) from t1 group by c5 order by c5;
select c5,count(*) from t1 group by c5 order by c5;
select c5,count(*),count(c1) from t1 group by c5 order by c5;
select c1,count(c5) from t1 group by c1 order by c1;
select c1,count(*),count(c1),count(c5) from t1 group by c1 order by c1;

select count(*) from t1 group by c6 order by c6;
select c6,count(*) from t1 group by c6 order by c6;
select c6,count(*),count(c1) from t1 group by c6 order by c6;
select c1,count(c6) from t1 group by c1 order by c1;
select c1,count(*),count(c1),count(c6) from t1 group by c1 order by c1;

select count(*) from pt1 group by c4 order by c4;
select c4,count(*) from pt1 group by c4 order by c4;
select c4,count(*),count(c1) from pt1 group by c4 order by c4;
select c1,count(c4) from pt1 group by c1 order by c1;
select c1,count(*),count(c1),count(c4) from pt1 group by c1 order by c1;

select count(*) from pt1 group by c5 order by c5;
select c5,count(*) from pt1 group by c5 order by c5;
select c5,count(*),count(c1) from pt1 group by c5 order by c5;
select c1,count(c5) from pt1 group by c1 order by c1;
select c1,count(*),count(c1),count(c5) from pt1 group by c1 order by c1;

select count(*) from pt1 group by c6 order by c6;
select c6,count(*) from pt1 group by c6 order by c6;
select c6,count(*),count(c1) from pt1 group by c6 order by c6;
select c1,count(c6) from pt1 group by c1 order by c1;
select c1,count(*),count(c1),count(c6) from pt1 group by c1 order by c1;

select c1,count(*),count(pk),count(c1),count(c2),count(c3),count(c4),count(c5),count(c6) from t1 group by c1 order by c1;
select c1,count(*),count(pk),count(c1),count(c2),count(c3),count(c4),count(c5),count(c6) from pt1 group by c1 order by c1;

--disable_query_log
connection obsys;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
--enable_query_log
alter system set _rowsets_max_rows = 256;
drop table if exists t1,pt1;