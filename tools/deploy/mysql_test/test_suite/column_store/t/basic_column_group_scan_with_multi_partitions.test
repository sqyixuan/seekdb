# owner: dengzhi.ldz 
# owner group: storage
# description: scanning columnar store with multiple partitions.

--disable_query_log
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--enable_query_log

connection conn1;
--disable_warnings
--disable_query_log
drop table if exists ct1;
--enable_query_log
--enable_warnings
create table ct1(c1 int, c2 int, primary key (c1)) PARTITION BY hash(c1) partitions 4 with column group (each column);

--disable_query_log
--let $count = 0
while($count < 100)
{
   eval insert into ct1 values
                             ($count * 10+ 1 , $count * 10 + 1 ),
                             ($count * 10+ 2 , $count * 10 + 2 ),
                             ($count * 10+ 3 , $count * 10 + 3 ),
                             ($count * 10+ 4 , $count * 10 + 4 ),
                             ($count * 10+ 5 , $count * 10 + 5 ),
                             ($count * 10+ 6 , $count * 10 + 6 ),
                             ($count * 10+ 7 , $count * 10 + 7 ),
                             ($count * 10+ 8 , $count * 10 + 8 ),
                             ($count * 10+ 9 , $count * 10 + 9 ),
                             ($count * 10+ 10, $count * 10 + 10);
   inc $count;
}
--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(1) from ct1 where c1 != 500;

--disable_query_log
drop table ct1;
--enable_query_log
