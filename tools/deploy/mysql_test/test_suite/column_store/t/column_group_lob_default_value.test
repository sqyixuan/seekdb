# owner: aozeliu.azl
# owner group: shenzhen
# description: scan column group table with lob default value 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

# 开启默认列存
connection default;

connection conn1;
create table lob_test(c1 int, c2 float, c3 varchar(100), c4 varchar(100)) with column group(each column);
insert into lob_test values (1, 1.1, '', ''), (2, 2.2, '', ''), (3, 3.3, '', ''), (4, 4.4, '', ''), (5, 5.5, '', ''), (6, 6.6, '', ''), (7, 7.7, '', ''), (8, 8.8, '', ''), (9, 9.9, '', ''), (10, 10.10, '', ''), (11, 11.11, '', ''), (12, 12.12, '', ''), (13, 13.13, '', ''), (14, 14.14, '', ''), (15, 15.15, '', ''), (16, 16.16, '', ''), (17, 17.17, '', ''), (18, 18.18, '', ''), (19, 19.19, '', ''), (20, 20.20, '', '');

# 转储，生成列存sstable
connection default;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
--enable_query_log

connection conn1;
# 第一次更新
update lob_test set c2 = 120.2222 where c1=20;
# 添加lob列
alter table lob_test add column c5 text ( 483 ) not null;
# 第二次更新触发
update lob_test set c2 = 120.3333 where c1=20;

drop table lob_test;

connection default;
