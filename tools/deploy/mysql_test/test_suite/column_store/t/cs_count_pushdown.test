# owner: fenggu.yh
# owner group: storage
# description: check count to verify cs_encoding pd_filter

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
connection default;

--disable_warnings
set session ob_query_timeout=10000000000;
drop table if exists ct1,ct2,pt1;
--enable_warnings

--disable_query_log
create table ct1 (c1 int primary key, c2 int not null, c3 int, c4 json) with column group (all columns, each column);
create table ct2(c1 int primary key, c2 varchar(100) not null, c3 varchar(1000)) block_size=2048 with column group (all columns, each column);
create table pt1 (c1 int, c2 int) partition by list(c1) (partition p1 values in(1), partition p2 values in(2)) with column group (each column);
--let $count = 0
while($count < 500)
{
  eval insert into ct1(c1,c2,c3,c4) values 
                                ($count * 20 + 1 ,$count * 20 + 1 + 1, null, '{"aop":1}'),
                                ($count * 20 + 2 ,$count * 20 + 2 + 1, null, '{"agh":1}'),
                                ($count * 20 + 3 ,$count * 20 + 3 + 1, null, '{"aew":1}'),
                                ($count * 20 + 4 ,$count * 20 + 4 + 1, null, '{"abv":1}'),
                                ($count * 20 + 5 ,$count * 20 + 5 + 1, null, '{"aaa":1}'),
                                ($count * 20 + 6 ,$count * 20 + 6 + 1, null, '{"acc":1}'),
                                ($count * 20 + 7 ,$count * 20 + 7 + 1, null, '{"a":1}'),
                                ($count * 20 + 8 ,$count * 20 + 8 + 1, null, '{"add":1}'),
                                ($count * 20 + 9 ,$count * 20 + 9 + 1, null, '{"acc":1}'),
                                ($count * 20 + 10,$count * 20 + 10+ 1, null, "[1, 2, 3]"),
                                ($count * 20 + 11,$count * 20 + 11+ 1, null, "null"),
                                ($count * 20 + 12,$count * 20 + 12+ 1, null, "[1, 5, 3]"),
                                ($count * 20 + 13,$count * 20 + 13+ 1, null, "[1, 2, 3]"),
                                ($count * 20 + 14,$count * 20 + 14+ 1, null, "[1, 0, 3]"),
                                ($count * 20 + 15,$count * 20 + 15+ 1, null, "[1, 9, 3]"),
                                ($count * 20 + 16,$count * 20 + 16+ 1, null, "[1, 3, 3]"),
                                ($count * 20 + 17,$count * 20 + 17+ 1, null, "[1, 99, 3]"),
                                ($count * 20 + 18,$count * 20 + 18+ 1, null, "[33, 2, 3]"),
                                ($count * 20 + 19,$count * 20 + 19+ 1, null, "[1, 22, 3]"),
                                ($count * 20 + 20,$count * 20 + 20+ 1, null, "null");
  eval insert into ct2(c1,c2,c3) values
                                ($count * 20 + 1 ,repeat('a',($count * 20 + 1 ) % 100),repeat('a',($count * 20 + 1 ) % 1000)),
                                ($count * 20 + 2 ,repeat('a',($count * 20 + 2 ) % 100),repeat('a',($count * 20 + 2 ) % 1000)),
                                ($count * 20 + 3 ,repeat('a',($count * 20 + 3 ) % 100),repeat('a',($count * 20 + 3 ) % 1000)),
                                ($count * 20 + 4 ,repeat('a',($count * 20 + 4 ) % 100),repeat('a',($count * 20 + 4 ) % 1000)),
                                ($count * 20 + 5 ,repeat('a',($count * 20 + 5 ) % 100),repeat('a',($count * 20 + 5 ) % 1000)),
                                ($count * 20 + 6 ,repeat('a',($count * 20 + 6 ) % 100),repeat('a',($count * 20 + 6 ) % 1000)),
                                ($count * 20 + 7 ,repeat('a',($count * 20 + 7 ) % 100),repeat('a',($count * 20 + 7 ) % 1000)),
                                ($count * 20 + 8 ,repeat('a',($count * 20 + 8 ) % 100),repeat('a',($count * 20 + 8 ) % 1000)),
                                ($count * 20 + 9 ,repeat('a',($count * 20 + 9 ) % 100),repeat('a',($count * 20 + 9 ) % 1000)),
                                ($count * 20 + 10,repeat('a',($count * 20 + 10) % 100),repeat('a',($count * 20 + 10) % 1000)),
                                ($count * 20 + 11,repeat('a',($count * 20 + 11) % 100),repeat('a',($count * 20 + 11) % 1000)),
                                ($count * 20 + 12,repeat('a',($count * 20 + 12) % 100),repeat('a',($count * 20 + 12) % 1000)),
                                ($count * 20 + 13,repeat('a',($count * 20 + 13) % 100),repeat('a',($count * 20 + 13) % 1000)),
                                ($count * 20 + 14,repeat('a',($count * 20 + 14) % 100),repeat('a',($count * 20 + 14) % 1000)),
                                ($count * 20 + 15,repeat('a',($count * 20 + 15) % 100),repeat('a',($count * 20 + 15) % 1000)),
                                ($count * 20 + 16,repeat('a',($count * 20 + 16) % 100),repeat('a',($count * 20 + 16) % 1000)),
                                ($count * 20 + 17,repeat('a',($count * 20 + 17) % 100),repeat('a',($count * 20 + 17) % 1000)),
                                ($count * 20 + 18,repeat('a',($count * 20 + 18) % 100),repeat('a',($count * 20 + 18) % 1000)),
                                ($count * 20 + 19,repeat('a',($count * 20 + 19) % 100),repeat('a',($count * 20 + 19) % 1000)),
                                ($count * 20 + 20,repeat('a',($count * 20 + 20) % 100),repeat('a',($count * 20 + 20) % 1000));
  inc $count;
}
insert into pt1 values(1, 2);
insert into pt1 values(1, 3);

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

