--echo BIT类型加约束 --> FOREIGN KEY
DROP TABLE Z0CASE;
CREATE TABLE Z1CASE(Z0_TEST2 BIT(25) PRIMARY KEY,Z0_TEST3 BIT(10));
CREATE TABLE Z0CASE(Z0_TEST0 BIT(25) ,Z0_TEST1 BIT(10),
CONSTRAINT fk_test0_test2 FOREIGN KEY(Z0_TEST0) REFERENCES Z1CASE(Z0_TEST2));

INSERT INTO Z1CASE VALUES(0,b'1101100110');
INSERT INTO Z1CASE VALUES(b'1101101000011111010010011',b'1101100110');
INSERT INTO Z0CASE VALUES(0,b'1011001010');
INSERT INTO Z0CASE VALUES(b'1101101000011111010010011',b'01100110');
SELECT BIN(Z0_TEST2),BIN(Z0_TEST3) FROM Z1CASE;
SELECT BIN(Z0_TEST0),BIN(Z0_TEST1) FROM Z0CASE;

