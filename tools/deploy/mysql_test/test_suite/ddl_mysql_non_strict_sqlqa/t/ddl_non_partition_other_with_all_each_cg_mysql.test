#设置SQL为非严格模式
SET sql_mode='';

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo 约束 PARTITION
--echo primary key
--echo 无分区 -->一级分区

CREATE TABLE Z0CASE (Z0_TEST0 INT primary key,Z0_TEST1 bigINT ) with column group (all columns, each column);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('-1.00','-111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1.00','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('2.22','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('30','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('111','111');
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc
ALTER TABLE Z0CASE PARTITION BY range (Z0_TEST0)
( PARTITION part_1 VALUES LESS THAN (20 ),
  PARTITION part_2 VALUES LESS THAN (100 ),
  PARTITION part_3 VALUES LESS THAN ( maxvalue ));
SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY PARTITION_NAME;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

