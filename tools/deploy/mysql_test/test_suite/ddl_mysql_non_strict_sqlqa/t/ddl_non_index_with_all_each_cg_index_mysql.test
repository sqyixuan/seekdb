INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)values(12 3,'aa',1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)values('123     ','BB',1);
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)values('12 3','BB',1);
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
#更新
UPDATE Z0CASE SET z0_test0='' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0='abc ' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0=' ABC ' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0='abc abc' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0='ABC ABC' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0=NULL WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0='12 3' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
UPDATE Z0CASE SET z0_test0='123     ' WHERE z0_test2=0;
SELECT * FROM Z0CASE WHERE z0_test2=0 ORDER BY Z0_TEST0;
#删除
DELETE FROM Z0CASE WHERE z0_test0='12 3';
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
DELETE FROM Z0CASE WHERE z0_test0='123     ';
DELETE FROM Z0CASE WHERE z0_test0='123';
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
DELETE FROM Z0CASE WHERE z0_test0='abc abc';
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
DELETE FROM Z0CASE WHERE z0_test0  IS NULL;
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;

