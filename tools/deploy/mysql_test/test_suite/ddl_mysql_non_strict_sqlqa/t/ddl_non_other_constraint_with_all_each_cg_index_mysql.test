DELETE FROM Z0CASE WHERE Z0_TEST0='12344556';
SELECT * FROM Z0CASE;
DELETE FROM Z0CASE WHERE Z0_TEST0='aaaa1!@#$%^&*   [];,./{}|:"<>/111';
SELECT * FROM Z0CASE;

