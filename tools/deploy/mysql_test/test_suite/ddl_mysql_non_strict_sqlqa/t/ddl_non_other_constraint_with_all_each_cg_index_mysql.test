#设置SQL为非严格模式
SET sql_mode='';

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
DROP TABLE IF EXISTS Z1CASE;
--enable_warnings

--echo CHAR FOREIGN KEY
CREATE TABLE Z1CASE(  Z1_TEST0 CHAR(100) PRIMARY KEY ) ;
CREATE TABLE Z0CASE(  Z0_TEST0 CHAR(100) PRIMARY KEY , FOREIGN KEY (Z0_TEST0) REFERENCES Z1CASE(Z1_TEST0)) ;

INSERT INTO  Z1CASE (Z1_TEST0)VALUES('1111.1111');
INSERT INTO  Z1CASE (Z1_TEST0)VALUES(2011);
INSERT INTO  Z1CASE (Z1_TEST0)VALUES(20111111);
INSERT INTO  Z1CASE (Z1_TEST0)VALUES('ABC');

INSERT INTO  Z0CASE (Z0_TEST0)VALUES('1111.1111');
INSERT INTO  Z0CASE (Z0_TEST0)VALUES(2011);
INSERT INTO  Z0CASE (Z0_TEST0)VALUES(20111111);
INSERT INTO  Z0CASE (Z0_TEST0)VALUES('ABC');
SELECT * FROM Z1CASE;
SELECT * FROM Z0CASE;

connect (conn1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
let $origin_table_id =query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='Z0CASE',table_id,1);
connection default;
ALTER TABLE Z0CASE MODIFY COLUMN z0_test0  CHAR(100);
SELECT Z0_TEST0 FROM Z0CASE;
DESC Z0CASE;
connection conn1;
let $new_table_id =query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='Z0CASE',table_id,1);
if ($origin_table_id == $new_table_id) {
  echo "table id has not changed as expected";
}
connection default;

