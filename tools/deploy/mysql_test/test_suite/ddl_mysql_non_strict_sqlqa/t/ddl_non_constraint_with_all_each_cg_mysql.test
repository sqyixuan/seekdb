#设置SQL为非严格模式
SET sql_mode='';

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo CHAR   PRIMARY KEY
CREATE TABLE Z0CASE(Z0_TEST0 CHAR(100) PRIMARY KEY , Z0_TEST1 VARCHAR(50),Z0_TEST2 INT) with column group (all columns, each column);

INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('abc ABC','abc ABC',1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('中文字符@!#$%^','中文字符@!#$%^',1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(111,111,11);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('1111.1111','1111.1111',100);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('2011-11-11 11:11:11','2011-11-11 11:11:11',20);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(20111111,20111111,1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('','',10);
SELECT * FROM Z0CASE;

--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

