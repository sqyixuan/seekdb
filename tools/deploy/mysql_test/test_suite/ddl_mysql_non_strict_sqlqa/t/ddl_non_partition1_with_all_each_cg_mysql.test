#设置SQL为非严格模式
SET sql_mode='';

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo 分区表
CREATE TABLE Z0CASE (Z0_TEST0 TINYINT,Z0_TEST1 TINYINT)
PARTITION BY RANGE (Z0_TEST0)
( PARTITION part_1 VALUES LESS THAN (20 ),
  PARTITION part_2 VALUES LESS THAN (100 ),
  PARTITION part_3 VALUES LESS THAN ( MAXVALUE )) with column group (all columns, each column);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('2','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('30','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('111','121');
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0 TINYINT;
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
DESC Z0CASE;

ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0 INT;
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
DESC Z0CASE;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0 mediumINT;
