(PARTITION part_1,  PARTITION part_2);
--error 01659
ALTER TABLE Z0CASE PARTITION BY LIST (Z0_TEST0)
( PARTITION part_1 VALUES IN ( 'abc', 'ABC' ),
  PARTITION part_2 VALUES IN ( 'cba', 'bca' ));
--error 01659
ALTER TABLE Z0CASE PARTITION BY LIST(Z0_TEST0)
SUBPARTITION BY RANGE(Z0_TEST0) SUBPARTITION template
(SUBPARTITION sp0 VALUES LESS THAN(100),
 SUBPARTITION sp1 VALUES LESS THAN(200),
 SUBPARTITION sp2 VALUES LESS THAN(MAXVALUE) )
 (PARTITION part_1 VALUES IN ( 1, 2 ),
  PARTITION part_2 VALUES IN ( 3, 4 ));

