#设置SQL为非严格模式
SET sql_mode='';

--disable_abort_on_error

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo text

CREATE TABLE Z0CASE (Z0_TEST0 TINYTEXT,Z0_TEST1 text);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('2','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('30','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('111','121');

--error 01659
ALTER TABLE Z0CASE PARTITION BY RANGE (Z0_TEST0)
( PARTITION part_1 VALUES LESS THAN (20 ),
  PARTITION part_2 VALUES LESS THAN (100 ),
  PARTITION part_3 VALUES LESS THAN ( MAXVALUE ));

UPDATE Z0CASE SET Z0_TEST0='1' WHERE Z0_TEST1='2';
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(null,null);
--error 01659
ALTER TABLE Z0CASE PARTITION BY KEY(Z0_TEST0) PARTITIONS 3;
--error 01659
ALTER TABLE Z0CASE PARTITION BY HASH(Z0_TEST0)   
(PARTITION part_1,PARTITION part_2);

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 TINYTEXT,Z0_TEST1 text);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('bca','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('abc','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('ABC','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('cba','111');

--error 01659
ALTER TABLE Z0CASE PARTITION BY LIST (Z0_TEST0)
( PARTITION part_1 VALUES IN ( 'abc', 'ABC' ),
  PARTITION part_2 VALUES IN ( 'cba', 'bca' ));

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 TINYTEXT,Z0_TEST1 text);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('2','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('30','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('111','121');

--error 01659
ALTER TABLE Z0CASE
PARTITION BY KEY(Z0_TEST0) SUBPARTITION BY KEY(Z0_TEST0)  PARTITIONS 2;

--echo set

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 set('1','2','30','111'),Z0_TEST1 enum('1','2','30','111'));
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('2','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('30','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('111','121');
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc
--error 01659
ALTER TABLE Z0CASE PARTITION BY RANGE (Z0_TEST0)
( PARTITION part_1 VALUES LESS THAN (20 ),
  PARTITION part_2 VALUES LESS THAN (100 ),
  PARTITION part_3 VALUES LESS THAN ( MAXVALUE ));

ALTER TABLE Z0CASE PARTITION BY KEY(Z0_TEST0) PARTITIONS 3;
SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY PARTITION_NAME;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

