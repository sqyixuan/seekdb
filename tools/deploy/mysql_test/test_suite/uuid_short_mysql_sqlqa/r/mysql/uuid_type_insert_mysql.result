#数据类型1-3  时间日期
#DATE		
create table test1(riqi DATE);
insert into test1 values('2021-09-01');
insert into test1 values('1000-01-01');
insert into test1 values('1500-12-31');
insert into test1 values('3000-01-09');
insert into test1 values('9999-12-31');
SELECT uuid(),uuid_short() from test1 ;
drop table test1;
#TIME		
create table test1(riqi TIME);
