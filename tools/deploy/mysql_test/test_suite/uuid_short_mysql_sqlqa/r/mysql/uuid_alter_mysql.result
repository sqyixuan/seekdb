#update修改表内数据 3-2
create table test1(id TINYINT);
insert into test1 values(100);
insert into test1 values(-98);
insert into test1 values(0.98);
insert into test1 values(0);
insert into test1 values(11.98);
SELECT uuid(),uuid_short() from test1;
update test1 set id=100 where id=70;
SELECT uuid(),uuid_short() from test1;
drop table test1;
create table test1(id SMALLINT);
insert into test1 values(9*8);
insert into test1 values(9/3);
insert into test1 values(9+6);
insert into test1 values(18-6);
insert into test1 values(6||8);
insert into test1 values(3^2);
SELECT uuid(),uuid_short() from test1;
update test1 set id=85 where id=12;
SELECT uuid(),uuid_short() from test1;
drop table test1;
create table test1(region varCHAR(20));
insert into test1 values('南京');
insert into test1 values('北京');
insert into test1 values('深圳');
insert into test1 values('上海');
insert into test1 values('南京,京,京,京,京,京,京,京,京,京');
SELECT uuid(),uuid_short() from test1 ;
update test1 set region='天宫' where region='上海';
update test1 set region='地宫' where region='深圳';
SELECT uuid(),uuid_short() from test1;
drop table test1;
create table test1(riqi YEAR);
insert into test1 values('1901');
insert into test1 values('2000');
insert into test1 values('2155');
insert into test1 values('70');
insert into test1 values('69');
SELECT uuid(),uuid_short() from test1 ;
update test1 set riqi='1982' where riqi='1901';
SELECT uuid(),uuid_short() from test1;
drop table test1;
create table test1(c2 MEDIUMBLOB);
insert into test1 values('uuid_short()');
insert into test1 values('uuid_short()');
select uuid(),uuid_short() from test1;
update test1 set c2='uuid()' where c2='uuid_short()';
select uuid(),uuid_short() from test1;
drop table test1;
# Clean up users
drop user hjw@'%' ;
