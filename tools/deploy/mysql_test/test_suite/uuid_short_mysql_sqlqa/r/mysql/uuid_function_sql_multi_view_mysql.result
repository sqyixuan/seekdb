#视图 7-1-3 update
#set order by
create view v_test3 as select * from test2;
select * from v_test3;
update v_test3 set chinese = 150 where mathematics=(SELECT mathematics from v_test3 where name='小李')order by chinese desc;
select uuid(),uuid_short() from v_test3;
#group by + having子句
update v_test3 set english = 130 where id = (select id  from v_test3 group by english limit 1);
update v_test3 set physics = 100 where id = (select id from v_test3 group by chinese having chinese>0 limit 1);
select *,uuid(),uuid_short() from v_test3;
#where
update v_test3 set biology = 100 where  id < 6;
#where +order by
update v_test3 set id =5 where biology < 100 and biology > 10 order by id asc limit 1;
select *,uuid(),uuid_short() from v_test3;
#where + group by having + order by
update v_test3 set chemistry = 100 where id = (select id from v_test3 group by chemistry having chemistry<0 limit 1);
update v_test3 set chemistry = 90 where id = (select id from v_test3 where  chemistry<> 50 and physics <> 30 group by physics having physics>0 order by physics desc limit 1);
select *,uuid(),uuid_short() from v_test3;
#约束 7-2
