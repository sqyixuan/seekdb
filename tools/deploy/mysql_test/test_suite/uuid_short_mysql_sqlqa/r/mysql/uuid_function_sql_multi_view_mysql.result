#视图约束索引 7
#视图 7-1-1
CREATE VIEW v_test1 AS select * from test1;
#view where
select uuid(),uuid_short() from v_test1 where chinese>0 and mathematics >29;
select uuid(),uuid_short() from v_test1 where english > 80 or biology <150;
select uuid(),uuid_short() from v_test1 where english > 80 or uuid() <150;
select uuid(),uuid_short() from v_test1 where english > 80 or uuid_short() <150;
#order by
select uuid(),uuid_short() from v_test1 order by english desc;
select uuid(),uuid_short() from v_test1 order by chinese asc;
select uuid(),uuid_short() from v_test1 where english > 80 or biology <150 order by english desc;
select uuid(),uuid_short() from v_test1 where chinese>0 and mathematics >29 order by chinese asc;
select uuid(),uuid_short() from v_test1 where english > 80 or biology <150 order by uuid() desc;
select uuid(),uuid_short() from v_test1 where chinese>0 and mathematics >29 order by uuid_short() asc;
#group by
select uuid(),uuid_short() from v_test1 group by mathematics;
select uuid(),uuid_short() from v_test1 group by mathematics order by mathematics desc;
select uuid(),uuid_short() from v_test1 where Physics < 150 and  Chemistry> 30 group by Chemistry;
select uuid(),uuid_short() from v_test1 where Physics < 150 and Chemistry> 30 group by Physics order by Physics asc;
select uuid(),uuid_short() from v_test1 where uuid_short()< 150 and  uuid_short()> 30 group by Chemistry;
select uuid(),uuid_short() from v_test1 where  uuid_short()< uuid() and uuid_short()> uuid() group by Physics order by Physics asc;
#group by having
select uuid(),uuid_short() from v_test1 group by Chemistry having Chemistry>0;
select uuid(),uuid_short() from v_test1 group by mathematics having mathematics>0 order by mathematics desc;
select uuid(),uuid_short() from v_test1 where chinese < 150 and  mathematics> 29 group by chinese having chinese>0;
select uuid(),uuid_short() from v_test1 where chinese <> 30 and mathematics <> 29 group by chinese having chinese>0 order by chinese desc;
select uuid(),uuid_short() from v_test1 where uuid_short() <> uuid() and uuid_short() <> uuid() group by chinese having chinese>0 order by chinese desc;
#case when
select uuid(),uuid_short(),id,name,chinese,max(mathematics) ,case mathematics  when mathematics < 130 then 120 else 130 end as mathematics from v_test1  group  by  mathematics  having mathematics > 30 order  by  mathematics desc;
select uuid(),uuid_short(),id,name,chinese,English, case English when chinese> 49 then 100 else 100 end as chinese from v_test1  where chinese <136 and English > 35 order by English desc;
select uuid(),uuid_short(),id,name,chinese,Physics, case chinese when Physics> 100 and chinese <150 then 150 else 150 end as Physics from v_test1 where chinese>10 and Physics < 11;
#distinct
select uuid(),uuid_short(),count(distinct chinese) from v_test1 where chinese > 1;
select uuid(),uuid_short(),max(distinct chinese) from v_test1 where chinese > 15 or mathematics <150 order by mathematics desc;
