drop table test1;
#静态sql  5
#静态sql  5-1  条件查询
create table test1(id int,name varchar(120),chinese SMALLINT(50),mathematics SMALLINT(50),English INTEGER(50),Physics BIGINT(50),Chemistry INTEGER(50),biology TINYINT(50));
insert into test1 values(1,'小李',145,150,149,98,99,100);
insert into test1 values(2,'阳曲',135,130,129,88,79,90);
insert into test1 values(3,'狗蛋',100,100,100,100,100,100);
insert into test1 values(4,'令狐冲',150,150,150,100,100,99);
insert into test1 values(5,'李白',50,30,150,99,99,10);
#where
SELECT uuid(),uuid_short() from test1 where chinese>80;
#and
SELECT uuid(),uuid_short() from test1 where chinese>80 and mathematics<=130;
#or
SELECT uuid(),uuid_short() from test1 where chinese>80 and mathematics<=130 or English<=130;
#group by having
SELECT uuid(),uuid_short() from test1 GROUP BY mathematics HAVING SUM(mathematics) < 600;
SELECT uuid(),uuid_short(),chinese,mathematics,English,Physics from test1 GROUP BY mathematics HAVING SUM(mathematics) < 600;
#distinct
SELECT uuid(),uuid_short(),count(distinct chinese) from test1;
#like
SELECT uuid(),uuid_short() from test1 where name like '小%';
#ORDER BY
SELECT uuid(),uuid_short() from test1 where chinese>49 ORDER by chinese desc;
SELECT uuid(),uuid_short() from test1 where Chemistry>49 ORDER by Chemistry asc;
SELECT uuid(),uuid_short() from test1 ORDER BY chinese desc;
#GROUP by
SELECT uuid(),uuid_short() from test1 GROUP by chinese;
SELECT uuid(),uuid_short(),* from test1 where mathematics=150 GROUP by mathematics;
#静态sql  5-2  子查询
#exists
select uuid(),uuid_short() from test1 where exists(select null);
select uuid(),uuid_short() from test1 where exists(select uuid() from test1 where English=150);
#all
select uuid(),uuid_short() from test1 where English>all(select name from test1 where English=150);
select uuid(),uuid_short() from test1 where English<all(select name from test1 where English=150);
select uuid(),uuid_short() from test1 where English=all(select name from test1 where English=150);
#any
select uuid(),uuid_short() from test1 where English>all(select name from test1 where English=150);
select uuid(),uuid_short() from test1 where English<all(select name from test1 where English=150);
select uuid(),uuid_short() from test1 where English<all(select name from test1 where English<all(select name from test1 where English=150));
select uuid(),uuid_short() from test1 where English=all(select English from test1 WHERE English=150);
#some
select uuid(),uuid_short() from test1 where English>SOME(select name from test1 where English=150);
select uuid(),uuid_short() from test1 where chinese<SOME(select name from test1 where chinese=100);
select uuid(),uuid_short() from test1 where chinese<SOME(select name from test1 where chinese<SOME(select name from test1 where chinese=100));
select uuid(),uuid_short() from test1 where English=SOME(select English from test1 WHERE English=150);
#ln
select uuid(),uuid_short() from test1 where English in (select English from test1 );
#where
select uuid(),uuid_short() from test1 where English=(select English from test1 LIMIT 1 );
#静态sql 5-3  聚合
select uuid(),uuid_short(),max(chinese),min(English) from test1 where exists(select null);
select uuid(),uuid_short(),min(English) from test1 where exists(select null);
select uuid(),uuid_short(),avg(English) from test1 where exists(select null);
select uuid(),uuid_short(),count(English) from test1 where exists(select null);
select uuid(),uuid_short(),sum(English) from test1 where exists(select null);
select uuid(),uuid_short(),round(English) from test1 where exists(select null);
#多表联查  6
#多表联查  6-1 条件查询
create table test2(id int,name varchar(120),chinese SMALLINT(50),mathematics SMALLINT(50),English INTEGER(50),Physics BIGINT(50),Chemistry INTEGER(50),biology TINYINT(50));
insert into test2 values(1,'小李',145,150,149,98,99,100);
insert into test2 values(2,'阳曲',135,130,129,88,79,90);
insert into test2 values(3,'狗蛋',100,100,100,100,100,100);
insert into test2 values(4,'令狐冲',150,150,150,100,100,99);
insert into test2 values(5,'李白',50,30,150,99,99,10);
create table test3(id int,banji varchar(120),school varchar(120));
insert into test3 values(1,'一年级','清华大学');
insert into test3 values(2,'二年级','北京大学');
insert into test3 values(3,'三年级','中国科学研究院');
insert into test3 values(4,'四年级','中国社会科学院研究院');
#基本连接
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id;
#LEFT JOIN
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id;
#RIGHT JOIN
SELECT uuid(),uuid_short() FROM test2 RIGHT JOIN test3 ON test2.id=test3.id;
#LEFT JOIN
SELECT uuid(),uuid_short() FROM test2 INNER JOIN test3 ON test2.id=test3.id ;
#union
SELECT uuid(),uuid_short() FROM test2 UNION all SELECT uuid(),uuid_short() FROM test3;
#where
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND chinese>80;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid()>80;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid_short()>80;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND chinese>uuid();
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND chinese>uuid_short();
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid_short()>uuid();
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid()>uuid_short();
#and
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND  chinese>80 and mathematics<=130;
#or
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND chinese>80 and mathematics<=130 or English<=130;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND chinese>80 and chinese>uuid() or uuid()<=130;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid()>80 and uuid()<=130 or uuid()<=130;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid_short()>80 and uuid_short()<=130 or uuid_short()<=130;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND uuid_short()>80 and uuid()<=130 or uuid_short()<=130;
#group by having
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id GROUP BY mathematics HAVING SUM(mathematics) < 600;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id GROUP BY mathematics HAVING SUM(uuid()) < 600;
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id GROUP BY mathematics HAVING SUM(uuid_short()) < 600;
#distinct
SELECT uuid(),uuid_short(),count(distinct chinese) FROM test2,test3 WHERE test2.id=test3.id;
SELECT uuid(),uuid_short(),count(distinct uuid()) FROM test2,test3 WHERE test2.id=test3.id;
SELECT uuid(),uuid_short(),count(distinct uuid_short()) FROM test2,test3 WHERE test2.id=test3.id;
#like
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id AND name like '小%';
#ORDER BY
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id AND chinese>49 ORDER by chinese desc;
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id AND chinese>49 ORDER by uuid() desc;
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id AND chinese>49 ORDER by uuid_short() desc;
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id AND Chemistry>49 ORDER by Chemistry asc;
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id  ORDER BY chinese desc;
#GROUP by
SELECT *,uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id  GROUP by chinese;
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id  GROUP by uuid();
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id  GROUP by uuid_short();
SELECT uuid(),uuid_short() FROM test2 LEFT JOIN test3 ON test2.id=test3.id  AND mathematics=150 GROUP by mathematics;
#多表联查  6-2 子查询
#exists
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and exists(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and exists(select uuid_short() from test1 where English=150);
#all
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English>all(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English<all(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English=all(select uuid() from test1 where English=150);
#any
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English>all(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English<all(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English<all(select uuid_short() from test1 where English<all(select uuid() from test1 where English=150));
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English=all(select English from test1 WHERE English=150);
#some
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English>SOME(select uuid() from test1 where English=150);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and chinese<SOME(select uuid_short() from test1 where chinese=100);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and uuid()<SOME(select uuid_short() from test1 where chinese=100);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and uuid_short()<SOME(select uuid_short() from test1 where chinese=100);
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and chinese<SOME(select uuid_short() from test1 where chinese<SOME(select uuid_short() from test1 where chinese=100));
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English=SOME(select English from test1 WHERE English=150);
#ln
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English in (select English from test1 );
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and uuid_short() in (select English from test1 );
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and uuid() in (select English from test1 );
#where
SELECT uuid(),uuid_short() FROM test2,test3 WHERE test2.id=test3.id and English=(select English from test1 LIMIT 1 );
