SELECT uuid(),uuid_short(),max(chinese),min(English) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short(),max(uuid()),min(uuid_short()) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and (select null);
SELECT uuid(),uuid_short(),min(chinese),avg(English) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short(),min(uuid()),avg(uuid_short()) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short(),avg(chinese),count(English) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short(),sum(chinese),round(English) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
SELECT uuid(),uuid_short(),round(chinese),count(English) FROM test2 LEFT JOIN test3 ON test2.id=test3.id and exists(select null);
