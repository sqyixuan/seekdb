#pl 9
#pl 9-1  条件语句
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(c1 double,c2 float);
create procedure pro1(c1 double)
begin
declare  i int;
set  i  =  3;
if    i<c1   then
insert into t1 values(uuid_short(),uuid_short());
end if;
insert into t1 values(uuid_short(),uuid_short());
end
/
call   pro1(uuid_short());
select *,uuid(),uuid_short() from  t1;
#pl 9-2  循环语句	
#repeat循环	
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create procedure pro1()
begin
Declare a1 double default uuid_short();
Declare sum double default uuid();
repeat
set sum=sum+degrees(a1);
set a1 = a1+0.1;
until a1>=1
end repeat;
select sum;
end
/
call pro1();
#while循环	
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa float(40),bb float(40));
create procedure pro1()
begin
declare i int;
declare a int;
set i =1;
while i<a
do
insert into t1 values(uuid_short(),uuid_short());
set i=i+1;
end while;
end
/
call pro1();
select * from t1;
#loop循环	  uuid()
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double);
create procedure pro1()
begin
Declare a int default 1;
label:loop
insert into t1 values(uuid());
set a = a + 1;
if a>10 then leave label;
end if;
end loop label;
select  * from t1;
end
/
call pro1();
select * from t1;
#loop循环	  uuid_short()
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double);
create procedure pro1()
begin
Declare a int default 1;
label:loop
insert into t1 values(uuid_short());
set a = a + 1;
if a>10 then leave label;
end if;
end loop label;
select  * from t1;
end
/
call pro1();
select *,uuid(),uuid_short() from t1;
#hash分区
create table test9(id int,bianhao bigint(20)) partition by hash(id);
insert into test9 value(1,3),(2,4),(3,6),(4,96),(5,135),(6,128),(7,100);
select *,uuid(),uuid_short() from test9;
select *,uuid(),uuid_short() from test9 where bianhao>10;
select *,uuid(),uuid_short() from test9 where uuid()>10;
select *,uuid(),uuid_short() from test9 where uuid_short()>10;
select *,uuid(),uuid_short() from test9 where bianhao<uuid_short();
drop table test9;
create table test9(id int,bianhao bigint(20)) partition by hash(id);
insert into test9 value(1,uuid_short()),(2,uuid_short()),(3,uuid_short()),(4,uuid_short());
select uuid(),uuid_short() from test9;
select uuid(),uuid_short() from test9 where bianhao <=(select uuid_short() from test9 limit 1);
select uuid(),uuid_short() from test9 where uuid()<=(select uuid() from test9 limit 1);
select uuid(),uuid_short() from test9 where uuid_short()>uuid();
select uuid(),uuid_short() from test9 where bianhao<uuid_short();
drop table test9;
#key分区
create table test9(id int,bianhao bit(20)) partition by key(id);
insert into test9 value(1,3),(2,4),(3,6);
select uuid(),uuid_short() from test9;
select uuid(),uuid_short() from test9 where bianhao<10;
select uuid(),uuid_short() from test9 where uuid()<10;
select uuid(),uuid_short() from test9 where uuid_short()>10;
select uuid(),uuid_short() from test9 where bianhao<uuid_short();
drop table test9;
create table test9(id int,bianhao bit(64)) partition by key(id);
insert into test9 value(1,uuid_short()),(2,uuid_short()),(3,uuid_short());
select uuid(),uuid_short() from test9;
select uuid(),uuid_short() from test9 where uuid()<=(select uuid_short() from test9 limit 1);
select uuid(),uuid_short() from test9 where uuid_short()>=(select uuid() from test9 limit 1);
select uuid(),uuid_short() from test9 group by uuid();
select uuid(),uuid_short() from test9 group by uuid_short();
select uuid(),uuid_short() from test9 order by uuid();
select uuid(),uuid_short() from test9 order by uuid_short();
drop table test9;
#range 分区
create table test9(id int,bianhao bigint(64)) partition by range(id)(partition p0 values less than maxvalue);
insert into test9 value(1,3),(2,4),(3,6);
select *,uuid(),uuid_short() from test9;
select uuid(),uuid_short(),log(uuid()+uuid_short()) from test9;
select uuid(),uuid_short() from test9 where bianhao<10;
select uuid(),uuid_short() from test9 where uuid_short()>10;
drop table test9;
create table test9(id int,bianhao bigint(64)) partition by range(id)(partition p0 values less than maxvalue);
insert into test9 value(1,uuid_short()),(2,uuid_short()),(3,uuid_short());
select *,uuid(),uuid_short() from test9;
select uuid(),uuid_short() from test9 where bianhao >=(select ln(uuid_short()) from test9 limit 1);
select uuid(),uuid_short() from test9 where uuid()<=(select abs(uuid()) from test9 limit 1);
select uuid(),uuid_short() from test9 where sin(uuid_short())<tan(uuid());
select uuid(),uuid_short() from test9 where bianhao>cos(uuid_short());
drop table test9;
# list分区
create table test9(id int,bianhao bigint(64)) partition by list(id)(partition p0 values in(1,2,3));
insert into test9 value(1,uuid_short()),(2,uuid_short()),(3,uuid_short());
select *,uuid(),uuid_short() from test9;
select uuid(),uuid_short() from test9 where bianhao <=(select ln(uuid_short())+abs(uuid_short()) from test9 limit 1);
select uuid(),uuid_short() from test9 where bianhao<=(select abs(uuid_short())+bin(uuid_short()) from test9 limit 1);
select uuid(),uuid_short() from test9 where sin(uuid_short())<tan(uuid());
select uuid(),uuid_short() from test9 where bianhao>cos(uuid_short());
select uuid(),uuid_short() from test9 where bianhao<=(select abs(uuid_short())*bin(uuid_short()) from test9 limit 1);
select uuid(),uuid_short() from test9 where bianhao>=(select abs(uuid_short())/bin(uuid_short()) from test9 limit 1);
drop table test9;
# Clean up users
drop user hjw@'%' ;
