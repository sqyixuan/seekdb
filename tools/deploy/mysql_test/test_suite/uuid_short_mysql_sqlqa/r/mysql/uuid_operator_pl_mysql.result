select uuid_short()*ln(9);
select uuid_short()*log10(9);
select uuid_short() * 11223344;
select uuid_short()*'aabbcccdd';
select uuid_short()*'!#$%';
select uuid_short()*uuid()*log(9)*ln(9)*11223344;
# /
