--echo  #修改数据类型 3-1-1
--echo  #数值转字符

--echo  #TINYINT=>char
create table test1(id TINYINT);
insert into test1 values(100);
insert into test1 values(-98);
insert into test1 values(0.98);
insert into test1 values(0);
insert into test1 values(11.98);
insert into test1 values(9*8);
insert into test1 values(9/3);
insert into test1 values(9+6);
insert into test1 values(18-6);
insert into test1 values(6||8);
insert into test1 values(3^2);
SELECT uuid(),uuid_short() from test1;
alter table test1 modify column id char(20);
SELECT uuid(),uuid_short() from test1;
drop table test1;


