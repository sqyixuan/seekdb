#owner:huangweixiang.hwx
#owner group:sql2
#description:数据类型、插入数据形式为uuid\uuid_short()
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--disable_result_log

--echo  #数据类型1
--echo  #数据类型1-1  数值
--error 0,1007
create database hz;
use hz;
--error 0,1051
drop table test1;


--echo  #TINYINT
create table test1(id TINYINT(255));
insert into test1 values(100);
insert into test1 values(-98);
insert into test1 values(0.98);
insert into test1 values(0);
insert into test1 values(11.98);
insert into test1 values(9*8);
insert into test1 values(9/3);
insert into test1 values(9+6);
insert into test1 values(18-6);
insert into test1 values(6||8);
insert into test1 values(3^2);
SELECT uuid(),uuid_short() from test1;
drop table test1;

