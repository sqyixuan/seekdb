# owner group: sql1
# tags: pdml,optimizer 
# test pdml with plan cahce location constraint

--disable_warnings
DROP TABLE if exists  EMP, EMP001;
--enable_warnings

CREATE TABLE emp(EMPNO int,ENAME VARCHAR(200),JOB VARCHAR(200),MGR int,HIREDATE DATE,SAL BIGINT,COMM int,DEPTNO int) partition by hash(empno) partitions 3;
INSERT INTO emp VALUES(1,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,10,20);
INSERT INTO emp VALUES(2,'SMITH','CLERK',7902,'1983-11-23 00:00:00',0,NULL,20);
INSERT INTO emp VALUES(3,'SMITH','CLERK',7902,'1983-11-23 00:00:00',null,NULL,20);
INSERT INTO emp VALUES(4,'SMITH','CLERK',7902,'1983-11-23 00:00:00',0,NULL,20);
INSERT INTO emp VALUES(5,'SMITH','CLERK',7902,'1983-11-23 00:00:00',9,50,20);
INSERT INTO emp VALUES(6,'SMITH','CLERK',7902,'1983-11-23 00:00:00',10,NULL,20);
INSERT INTO emp VALUES(7,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,NULL,20);
INSERT INTO emp VALUES(8,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,NULL,20);
INSERT INTO emp VALUES(9,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,30,20);
INSERT INTO emp VALUES(10,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,10,20);
create table EMP001 as select * from EMP where 1=1;
create or replace view view_emp AS  select * from emp001;

set @force_parallel_dml_dop_bk = @@_force_parallel_dml_dop;
set _force_parallel_dml_dop = 3;

--explain_protocol 2
--result_format 4
DELETE FROM view_emp WHERE deptno< exp((SELECT sum(ggg.aaa) FROM (SELECT sum(t.sal) aaa FROM view_emp t GROUP BY DEPTNO) ggg)/1000);
DELETE FROM emp WHERE deptno< exp((SELECT sum(ggg.aaa) FROM (SELECT sum(t.sal) aaa FROM emp t GROUP BY DEPTNO) ggg)/1000);

drop table emp, emp001;
drop view view_emp;
set _force_parallel_dml_dop = @force_parallel_dml_dop_bk;