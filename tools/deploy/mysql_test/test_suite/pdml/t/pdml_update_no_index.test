# owner: laibingzheng.lbz
# owner group: sql2
# 测试 parallel update
# tags: pdml,optimizer 
# 默认都打开pdml对应的hint

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
# 注入错误，打开PDML 不稳定feature；任意错误类型即可
alter system set_tp tp_no = 217, error_code = 1234, frequency = 1;
connection default;

--disable_warnings
drop table if exists s,p,p4,p5;
# 创建非分区表
create table s(c1 int ,c2 int ,c3 int);

# 测试单分区表删除，计划
delete from s;
insert into s values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
select * from s order by c1;
explain basic update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2;
--sorted_result
select * from s;

delete from s;
insert into s values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
select * from s order by c1;
explain basic update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2 where c1 > 1;
update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from s;

# 测试多分区表
# 4 hash 分区表
create table p4(c1 int , c2 int ,c3 int) partition by hash(c1) partitions 4;

delete from p4;
insert into p4 values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
select * from s order by c1;
explain basic update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from p4;

delete from p4;
insert into p4 values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
select * from s order by c1;
explain basic update /*+parallel(20),enable_parallel_dml*/ p4 set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from p4;

##bugfix: 
drop table if exists t1, t2;
create table t1(id int, value int);
create table t2(id int, value int);
insert into t1 values(1, 0);
insert into t1 values(1, 1);
explain basic update /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t1 left join t2 on t1.id = t2.id set t2.value = t1.value + 1;
update /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t1 left join t2 on t1.id = t2.id set t2.value = t1.value + 1;
select * from t2;

insert into t2 values(1, 10);
explain basic update /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t1 left join t2 on t1.id = t2.id set t2.value = t1.value + 1;
update /*+ USE_PX PARALLEL(8) ENABLE_PARALLEL_DML */ t1 left join t2 on t1.id = t2.id set t2.value = t1.value + 1;
select * from t2;
drop table t1, t2;

connection conn_admin;
alter system set_tp tp_no = 217, error_code = 1234, frequency = 0;
