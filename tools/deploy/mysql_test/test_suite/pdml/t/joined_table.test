# owner: laibingzheng.lbz
# owner group: sql2
# tags: optimizer,px
# desc: test pdml for joined table

--disable_warnings
drop database if exists db;
--enable_warnings
create database db;
use db;

create table src1(c1 int, c2 int);
create table src2(c1 int, c2 int) partition by hash(c1) partitions 4;
create table src3(c1 int primary key, c2 int);
create table src4(c1 int primary key, c2 int) partition by hash(c1) partitions 4;

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int) partition by hash(c1) partitions 4;
create table t3(c1 int primary key, c2 int);
create table t4(c1 int primary key, c2 int) partition by hash(c1) partitions 4;

insert into src1 values(1, 1);
insert into src1 values(2, 2);
insert into src1 values(3, 3);
insert into src1 values(4, 4);
insert into src2 select * from src1;
insert into src3 select * from src1;
insert into src4 select * from src1;

insert into t1 values(1, 10);
insert into t1 values(1, 100);
insert into t1 values(2, 20);
insert into t1 values(2, 200);
insert into t1 values(2, 2000);
insert into t1 values(3, 30);
insert into t1 values(3, 300);
insert into t2 select * from t1;

insert into t3 values(1, 10);
insert into t3 values(2, 20);
insert into t3 values(3, 30);
insert into t4 select * from t3;
set autocommit = 0;

## update
--echo hash_distinct + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src1 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src1 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src1;
rollback;

--echo hash_distinct + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src1 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src1 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src1;
rollback;

--echo distinct_none + RANDOM
explain basic update /*+ enable_parallel_dml parallel(2) */ src1 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src1 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src1;
rollback;

--echo distinct_none + RANDOM
explain basic update /*+ enable_parallel_dml parallel(2) */ src1 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src1 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src1;
rollback;



--echo hash_distinct + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src2 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src2 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src2;
rollback;

--echo hash_distinct + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src2 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src2 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src2;
rollback;

--echo best: distinct_none, actual: hash_distinct. + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src2 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src2 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src2;
rollback;

--echo best: distinct_none, actual: hash_distinct. + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src2 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src2 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src2;
rollback;



--echo hash_distinct + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src3 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src3 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src3;
rollback;

--echo hash_distinct + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src3 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src3 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src3;
rollback;

--echo distinct_none + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src3 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src3 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src3;
rollback;

--echo distinct_none + HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src3 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src3 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src3;
rollback;



--echo hash_distinct + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src4 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src4 a, t1 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src4;
rollback;

--echo hash_distinct + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src4 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src4 a, t2 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src4;
rollback;

--echo distinct_none + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src4 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src4 a, t3 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src4;
rollback;

--echo distinct_none + PARTITION_HASH
explain basic update /*+ enable_parallel_dml parallel(2) */ src4 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
update /*+ enable_parallel_dml parallel(2) */ src4 a, t4 b set a.c2 = b.c2 where a.c1 = b.c1;
select * from src4;
rollback;




## delete
--echo hash_distinct + HASH
explain basic delete /*+ enable_parallel_dml parallel(2) */ from a using src1 a, t1 b where a.c1 = b.c1;
delete /*+ enable_parallel_dml parallel(2) */ from a using src1 a, t1 b where a.c1 = b.c1;
select * from src1;
rollback;

--echo hash_distinct + HASH
explain basic delete /*+ enable_parallel_dml parallel(2) */ from a using src1 a, t2 b where a.c1 = b.c1;
delete /*+ enable_parallel_dml parallel(2) */ from a using src1 a, t2 b where a.c1 = b.c1;
select * from src1;
rollback;

