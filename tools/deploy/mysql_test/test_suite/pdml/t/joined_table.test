select * from src2;
rollback;


--echo hash_distinct + HASH
explain basic delete /*+ enable_parallel_dml parallel(2) */ from a using src3 a, t1 b where a.c1 = b.c1;
delete /*+ enable_parallel_dml parallel(2) */ from a using src3 a, t1 b where a.c1 = b.c1;
