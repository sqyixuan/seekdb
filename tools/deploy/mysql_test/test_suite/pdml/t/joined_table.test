--echo best: distinct_none, actual: hash_distinct. + PARTITION_HASH
explain basic delete /*+ enable_parallel_dml parallel(2) */ from a using src2 a, t3 b where a.c1 = b.c1;
delete /*+ enable_parallel_dml parallel(2) */ from a using src2 a, t3 b where a.c1 = b.c1;
select * from src2;
rollback;

--echo best: distinct_none, actual: hash_distinct. + PARTITION_HASH
explain basic delete /*+ enable_parallel_dml parallel(2) */ from a using src2 a, t4 b where a.c1 = b.c1;
