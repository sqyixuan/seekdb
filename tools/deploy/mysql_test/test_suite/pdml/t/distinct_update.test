# owner: laibingzheng.lbz
# owner group: sql2
# tags: optimizer
# desc: test distinct delete and its index maintainance with distinct op

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t11;
drop table if exists t22;
--enable_warnings

--echo update table without pk
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert into t1 values(1, 1), (2, 2);
insert into t2 values(1, 10), (1, 100), (2, 200), (2, 20);

explain basic update /*+ enable_parallel_dml parallel(2) */ t1 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t1 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;

--echo disable pdml if modify more than one target table
explain basic update /*+ enable_parallel_dml parallel(2) */ t1 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2, b.c2 = 1;


--echo update table with pk
create table t11(c1 int primary key, c2 int);
insert into t11 values(1, 1), (2, 2);
explain basic update /*+ enable_parallel_dml parallel(2) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
--echo no hash exchange below distinct
explain basic update /*+ enable_parallel_dml parallel(2) leading(a b) pq_distribute(b hash hash) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) leading(a b) pq_distribute(b hash hash) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;


--echo unique already, no need allocate distinct
create table t22(c1 int primary key, c2 int);
insert into t22 values(1, 10), (2, 20);
explain basic update /*+ enable_parallel_dml parallel(2) */ t11 a join t22 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t11 a join t22 b on a.c1 = b.c1 set a.c2 = b.c2;
select * from t11;

drop table t1, t2, t11, t22;

--echo partition table
--echo update table without pk
create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int) partition by hash(c1) partitions 4;
insert into t1 values(1, 1), (2, 2);
insert into t2 values(1, 10), (1, 100), (2, 200), (2, 20);
explain basic update /*+ enable_parallel_dml parallel(2) */ t1 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t1 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;

--echo update table with pk
create table t11(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
insert into t11 values(1, 1), (2, 2);
explain basic update /*+ enable_parallel_dml parallel(2) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;

--echo no hash exchange below distinct
explain basic update /*+ enable_parallel_dml parallel(2) leading(a b) pq_distribute(b hash hash) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) leading(a b) pq_distribute(b hash hash) */ t11 a join t2 b on a.c1 = b.c1 set a.c2 = b.c2;

--echo unique already, no need allocate distinct
create table t22(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
insert into t22 values(1, 10), (2, 20);
explain basic update /*+ enable_parallel_dml parallel(2) */ t11 a join t22 b on a.c1 = b.c1 set a.c2 = b.c2;
update /*+ enable_parallel_dml parallel(2) */ t11 a join t22 b on a.c1 = b.c1 set a.c2 = b.c2;
select * from t11;

drop table t1, t2, t11, t22;