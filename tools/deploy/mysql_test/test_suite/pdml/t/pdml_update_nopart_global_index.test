# owner: laibingzheng.lbz
# owner group: sql2
# 测试 parallel update
# tags: pdml,optimizer 
# 测试不带分区表的全局索引更新

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
# 注入错误，打开PDML 不稳定feature；任意错误类型即可
alter system set_tp tp_no = 217, error_code = 1234, frequency = 1;
connection default;
--disable_warnings
drop table if exists s,p,p4,p5,t1;
# 创建非分区表
create table s(c1 int ,c2 int ,c3 int, KEY idx1(c3) GLOBAL);

# 测试单分区表删除，计划
delete from s;
insert into s values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
--sorted_result
select * from s;
explain basic update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2;
--sorted_result
select * from s;
explain basic update /*+parallel(2),enable_parallel_dml*/ s set c2 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ s set c2 = c1 + c2;
--sorted_result
select * from s;

delete from s;
insert into s values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
--sorted_result
select * from s;
explain basic update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2 where c1 > 1;
update /*+parallel(2),enable_parallel_dml*/ s set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from s;

# 测试多分区表
# 4 hash 分区表
create table p4(c1 int primary key, c2 int ,c3 int, KEY idx1(c3) GLOBAL) partition by hash(c1) partitions 4;

delete from p4;
insert into p4 values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
--sorted_result
select * from p4;
explain basic update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from p4;

delete from p4;
insert into p4 values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
select * from p4 order by c1;
explain basic update /*+parallel(20),enable_parallel_dml*/ p4 set c3 = c1 + c2;
update /*+parallel(2),enable_parallel_dml*/ p4 set c3 = c1 + c2 where c1 > 1;
--sorted_result
select * from p4;

# 测试多索引分区
CREATE TABLE t1 (c1 int(11),c2 int(11),c3 int(11),c4 int(11),c5 int(11),c6 int(11),PRIMARY KEY (c1),KEY t1_i1 (c2, c1) GLOBAL,KEY t1_i2 (c3, c4) GLOBAL,KEY t1_i3 (c5) GLOBAL,KEY t1_i4 (c4, c5) GLOBAL) partition by hash(c1) partitions 3;
insert into t1 values (1,2,3,4,5,6),(10,20,30,40,50,60),(100,200,300,400,500,600),(1000,2000,3000,4000,5000,6000);
select * from p4 order by c1;
explain basic update /*+ parallel(3) enable_parallel_dml */ t1 set c4 = 9;
update /*+ parallel(3) enable_parallel_dml */ t1 set c4  = 91;
select * from t1 order by c1;
explain basic update /*+ parallel(3) enable_parallel_dml */ t1 set c4 = 9,c3=12;
update /*+ parallel(3) enable_parallel_dml */ t1 set c4  = 91,c3=12;
--sorted_result
select * from t1;

drop table t1;
create table t1(a int, b int);
insert into t1 values(1, 1), (2, 2), (3, 3);
create index i1 on t1(a, b) partition by hash(b) partitions 1;
update /*+parallel(2) enable_parallel_dml*/ t1 set a=3;
select /*+index(t1 primary)*/ a, b from t1;
select /*+index(t1 i1)*/ a, b from t1;
delete from t1;
drop table t1;
connection conn_admin;
alter system set_tp tp_no = 217, error_code = 1234, frequency = 0;
