# owner: laibingzheng.lbz
# owner group: IMF
# 测试 parallel update
# tags: pdml

--result_format 4

--disable_warnings
--error 0, 1051
drop table t1;
--enable_warnings

create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;
create index t1_i2 on t1(c2) local;
insert into t1 values(0,1), (1,1), (2,1);
select * from t1 partition(p0);
explain delete /*+enable_parallel_dml parallel(2) index(t1 t1_i2) */ from t1 partition(p0);
delete /*+enable_parallel_dml parallel(2) index(t1 t1_i2) */ from t1 partition(p0);
select * from t1 order by c1;

drop table t1;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;
create index t1_i2 on t1(c2) local;
insert into t1 values(0,1), (1,1), (2,1);
select * from t1 partition(p0);
explain update /*+enable_parallel_dml parallel(2) index(t1 t1_i2) */ t1 partition(p0) set c2 = c2 + 100;
update /*+enable_parallel_dml parallel(2) index(t1 t1_i2) */ t1 partition(p0) set c2 = c2 + 100;
select * from t1 order by c1;

drop table t1;
