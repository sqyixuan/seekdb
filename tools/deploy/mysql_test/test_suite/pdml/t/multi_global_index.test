--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: sql2
# tags: optimizer
# desc: 测试多个索引场景下的 update、insert、delete 

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
# 注入错误，打开PDML 不稳定feature；任意错误类型即可
alter system set_tp tp_no = 217, error_code = 1234, frequency = 1;
connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key (c1, c2)) partition by hash(c1) partitions 3;
create index t1_idx2 on t1 (c2) partition by hash(c2) partitions 4;
create index t1_idx3 on t1 (c3) partition by hash(c3) partitions 2;
create index t1_idx4 on t1 (c4);

insert into t1 values (1,2,3,4,5,6);
insert into t1 values (1*10,2*10,3*10,4*10,5*10,6*10);
--sorted_result
select * from t1;

explain update /*+ parallel(3) enable_parallel_dml */ t1 set c1 = c2 + c3;
update /*+ parallel(3) enable_parallel_dml */ t1 set c1 = c2 + c3;
--sorted_result
select * from t1;

explain update /*+ parallel(3) enable_parallel_dml */ t1 set c2 = 3;
update /*+ parallel(3) enable_parallel_dml */ t1 set c2 = 3;
--sorted_result
select * from t1;

explain update /*+ parallel(3) enable_parallel_dml */ t1 set c3 = 3;
update /*+ parallel(3) enable_parallel_dml */ t1 set c3 = 3;
--sorted_result
select * from t1;

explain update /*+ parallel(3) enable_parallel_dml */ t1 set c4 = 4000;
update /*+ parallel(3) enable_parallel_dml */ t1 set c4 = 3;
--sorted_result
select * from t1;

explain update /*+ parallel(3) enable_parallel_dml */ t1 set c3 = 3, c4 = 4;
update /*+ parallel(3) enable_parallel_dml */ t1 set c3 = 3, c4 = 4;
--sorted_result
select * from t1;

explain insert /*+ parallel(2) enable_parallel_dml */ into t1 select c1 * 100, c2 * 100, c3 * 100, c4 * 100, c5 * 100, c6 * 100 from t1;
insert /*+ parallel(2) enable_parallel_dml */ into t1 select c1 * 100, c2 * 100, c3 * 100, c4 * 100, c5 * 100, c6 * 100 from t1;
--sorted_result
select * from t1;

explain basic delete /*+ parallel(2) enable_parallel_dml */ from t1 where c3 = 3;
--sorted_result
select * from t1;
connection conn_admin;
alter system set_tp tp_no = 217, error_code = 1234, frequency = 0;