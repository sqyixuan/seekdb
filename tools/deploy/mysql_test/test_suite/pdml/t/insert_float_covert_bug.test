connection default;
--source mysql_test/include/ignore_drop_table_err.inc
drop table p4;
create table p4(c1 int primary key, c2 int ,c3 int, KEY idx1(c3) GLOBAL) partition by hash(c1) partitions 4;
insert into p4 values (0,0,0), (1,1,1),(2,2,2), (3,3,3);
explain basic insert /*+ parallel(3) enable_parallel_dml */ into p4 select c1+33.32, c2+4.12, 32 from p4;
insert /*+ parallel(3) enable_parallel_dml */ into p4 select c1+33.32, c2+44.12, 32 from p4;
--sorted_result
select * from p4;

# end of case. don't add any more case after this line
connection conn_admin;
