--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: DML
# description: pdml
# tags: dml,optimizer
#
# test of pdml
#
--disable_warnings
drop table if exists t1,t22;
--enable_warnings

create table t22(a int primary key, b int, c int, d timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP) partition by hash(a) partitions 5;
create index idx on t22(c, d) global;
insert into t22 values(1, 1, 1, now());
set _force_parallel_dml_dop = 3;
insert into t22 values(2,2,2,now());
insert into t22 values(3,3,3,now());
insert into t22 values(4,4,4,now());
select count(*) from t22 group by d;
--sleep 2
update t22 set b=b+1, c=1 where a>1;
select count(*) from t22 group by d;
select /*+index(t22 idx)*/ count(*) from t22 group by d;
--sleep 2
explain update t22 set d=now() where a>1;
explain update t22 set b=5, c=1 where a>1;
update t22 set b=5, c=1 where a>1;
# if buggy, would cause 4377
update t22 set b=5, c=1 where a>1;
--sleep 3
update t22 set c=c where a=1;
select count(*) from t22 group by d;
select /*+index(t22 idx)*/ count(d) from t22 group by d;
drop table t22;

create table t1(c1 int primary key, c2 int, c3 timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, c4 timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, c5 int, c6 int) partition by hash(c1) partitions 5;

create index t1_idx on t1(c2, c3, c4) global;
insert into t1 values(1,1,now(),now(),1,1);
insert into t1 values(2,2,now(),now(),2,2);
insert into t1 values(3,3,now(),now(),3,3);
select count(*) from t1 group by c1;
--sleep 3
update t1 set c2 = 10 where c1 > 0;
select count(*) from t1 group by c3;
select /*+index(t1 idx)*/ count(*) from t1 group by c3;
--sleep 3
update t1 set c2 = c2 where c1 > 0;
select count(*) from t1 group by c4;
select /*+index(t1 idx)*/ count(*) from t1 group by c3;
drop table t1;
set _force_parallel_dml_dop = 0;




