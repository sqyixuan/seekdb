--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: sql2
# tags: pdml optimizer
# desc: dont' update ts if value unchanged 

--disable_warnings

DROP TABLE IF EXISTS table2_bigint; 
CREATE TABLE table2_bigint (
col_char_20 char(20),
col_timestamp_default_current timestamp not null DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
col_bigint bigint,
pk bigint,
col_decimal_20_0 decimal(20,0),
primary key (pk) ) ; 

INSERT INTO table2_bigint VALUES  (NULL, '2009-03-28 09:17:58.021780', -12601, 1, 127) ,  ('in', '2004-08-27 09:25:21.015195', 14196, 2, 0) ;

SELECT col_decimal_20_0, pk, col_char_20 , col_timestamp_default_current , col_bigint FROM table2_bigint ORDER BY pk;

SET TIMESTAMP = ABS( 10 );

select current_timestamp;

explain basic UPDATE table2_bigint SET col_bigint = col_bigint WHERE ROUND( ABS( ROUND( ABS( ROUND( FLOOR( col_decimal_20_0 ) ) ) ) ) ) <=> col_decimal_20_0 ORDER BY pk DESC LIMIT 1;
UPDATE table2_bigint SET col_bigint = col_bigint WHERE ROUND( ABS( ROUND( ABS( ROUND( FLOOR( col_decimal_20_0 ) ) ) ) ) ) <=> col_decimal_20_0 ORDER BY pk DESC LIMIT 1 ;
SELECT col_decimal_20_0, pk, col_char_20 , col_timestamp_default_current , col_bigint FROM table2_bigint ORDER BY pk;

