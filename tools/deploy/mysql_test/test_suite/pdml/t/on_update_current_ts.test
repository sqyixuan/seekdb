UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */  table2_bigint SET col_bigint = col_bigint WHERE ROUND( ABS( ROUND( ABS( ROUND( FLOOR( col_decimal_20_0 ) ) ) ) ) ) <=> col_decimal_20_0 ORDER BY pk DESC LIMIT 1 ;
SELECT col_decimal_20_0, pk, col_char_20 , col_timestamp_default_current , col_bigint FROM table2_bigint ORDER BY pk;

