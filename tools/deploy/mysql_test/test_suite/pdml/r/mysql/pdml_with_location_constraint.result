DROP TABLE if exists  EMP, EMP001;
CREATE TABLE emp(EMPNO int,ENAME VARCHAR(200),JOB VARCHAR(200),MGR int,HIREDATE DATE,SAL BIGINT,COMM int,DEPTNO int) partition by hash(empno) partitions 3;
INSERT INTO emp VALUES(1,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,10,20);
