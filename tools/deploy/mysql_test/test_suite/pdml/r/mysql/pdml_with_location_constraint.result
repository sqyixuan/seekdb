INSERT INTO emp VALUES(8,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,NULL,20);
INSERT INTO emp VALUES(9,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,30,20);
INSERT INTO emp VALUES(10,'SMITH','CLERK',7902,'1983-11-23 00:00:00',800,10,20);
create table EMP001 as select * from EMP where 1=1;
create or replace view view_emp AS  select * from emp001;
set @force_parallel_dml_dop_bk = @@_force_parallel_dml_dop;
set _force_parallel_dml_dop = 3;
explain_protocol: 2
result_format: 4
