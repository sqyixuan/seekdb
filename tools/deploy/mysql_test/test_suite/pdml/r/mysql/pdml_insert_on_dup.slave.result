CREATE TABLE `t1` (
`c1` int(11) NOT NULL,
`c2` varchar(50) DEFAULT NULL,
`c3` int(11) GENERATED ALWAYS AS ((`c1` + 1)) STORED,
`c4` varchar(100) GENERATED ALWAYS AS (substr(`c2`,10)) VIRTUAL,
PRIMARY KEY (`c1`),
KEY `t1_c3idx` (`c3`) BLOCK_SIZE 16384 LOCAL,
KEY `t1_c4idx` (`c4`) BLOCK_SIZE 16384 LOCAL
);
CREATE TABLE `t2` (
`c1` int(11) NOT NULL AUTO_INCREMENT,
`c2` varchar(50) DEFAULT NULL
);

