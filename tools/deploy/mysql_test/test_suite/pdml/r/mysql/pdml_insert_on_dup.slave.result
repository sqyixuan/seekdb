result_format: 4
drop database if exists pdml;
create database pdml;
use pdml;

create table t(c1 int, c2 int, primary key(c1)) partition by hash(c1) partitions 4;
create table src1(c1 int, c2 int);
create table src2(c1 int, c2 int);
insert into src1 values(1, 1);
insert into src1 values(2, 2);
insert into src2 values(10, 10);
insert into src2 values(20, 20);
insert into src2 values(20, 30);

explain basic insert /*+ enable_parallel_dml parallel(2) */into t select * from src1 on duplicate key update c2 = c2 + src1.c2;
Query Plan
==============================================
|ID|OPERATOR                 |NAME           |
----------------------------------------------
|0 |DISTRIBUTED INSERT_UP    |               |
|1 |└─PX COORDINATOR         |               |
|2 |  └─EXCHANGE OUT DISTR   |:EX10000       |
|3 |    └─SUBPLAN SCAN       |ANONYMOUS_VIEW1|
|4 |      └─PX BLOCK ITERATOR|               |
|5 |        └─TABLE FULL SCAN|src1           |
==============================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t: ({t: (t.c1, t.c2)})}]), partitions(p[0-3]), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW1.c1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)]),
      update([t.c2=column_conv(INT,PS:(11,0),NULL,cast(t.c2 + ANONYMOUS_VIEW1.c2, INT(-1, 0)))])
  1 - output([ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c1]), filter(nil), rowset=16
  2 - output([ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c1]), filter(nil), rowset=16
      dop=2
  3 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2])
  4 - output([src1.c1], [src1.c2]), filter(nil), rowset=16
  5 - output([src1.c1], [src1.c2]), filter(nil), rowset=16
      access([src1.c1], [src1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([src1.__pk_increment]), range(MIN ; MAX)always true
