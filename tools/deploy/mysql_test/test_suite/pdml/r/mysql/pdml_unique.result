drop table if exists t0;
drop table if exists t1;
# expect LOCAL-UPDATE+PX / DAS+PX
CREATE TABLE t0(c1 int primary key, c0 DOUBLE  NULL COMMENT 'asdf');
CREATE UNIQUE INDEX idx1 ON t0(c0) GLOBAL;
explain basic UPDATE  /*+parallel(5) enable_parallel_dml*/ t0 SET c0=1;
Query Plan
===============================================
|ID|OPERATOR                         |NAME    |
-----------------------------------------------
|0 |PX COORDINATOR                   |        |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|
|2 |  └─UPDATE                       |        |
|3 |    └─EXCHANGE IN DISTR          |        |
|4 |      └─EXCHANGE OUT DISTR (HASH)|:EX10000|
|5 |        └─PX BLOCK ITERATOR      |        |
|6 |          └─TABLE FULL SCAN      |t0      |
===============================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=5
  2 - output(nil), filter(nil)
      table_columns([{t0: ({t0: (t0.c1, t0.c0)})}]),
      update([t0.c0=column_conv(DOUBLE,PS:(-1,-1),NULL,1)])
  3 - output([t0.c1], [t0.c0]), filter(nil), rowset=16
  4 - output([t0.c1], [t0.c0]), filter(nil), rowset=16
      (#keys=1, [t0.c1]), dop=5
  5 - output([t0.c1], [t0.c0]), filter(nil), rowset=16
  6 - output([t0.c1], [t0.c0]), filter(nil), rowset=16
      access([t0.c1], [t0.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t0.c1]), range(MIN ; MAX)always true
# expect pdml
CREATE TABLE t1(c1 int primary key, c0 DOUBLE  NULL COMMENT 'asdf') PARTITION BY HASH(c1) PARTITIONS 3;
CREATE UNIQUE INDEX idx2 ON t1(c0) GLOBAL;
explain basic UPDATE  /*+parallel(5) enable_parallel_dml*/ t1 SET c0=1;
