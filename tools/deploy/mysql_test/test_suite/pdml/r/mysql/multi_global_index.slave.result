alter system set_tp tp_no = 217, error_code = 1234, frequency = 1;
drop table if exists t1;
create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key (c1, c2)) partition by hash(c1) partitions 3;
create index t1_idx2 on t1 (c2) partition by hash(c2) partitions 4;
create index t1_idx3 on t1 (c3) partition by hash(c3) partitions 2;
create index t1_idx4 on t1 (c4);
insert into t1 values (1,2,3,4,5,6);
insert into t1 values (1*10,2*10,3*10,4*10,5*10,6*10);
select * from t1;
c1	c2	c3	c4	c5	c6
1	2	3	4	5	6
10	20	30	40	50	60
explain update /*+ parallel(3) enable_parallel_dml */ t1 set c1 = c2 + c3;
