result_format: 4
set autocommit=0;
set recyclebin=0;


#test partition by hash
drop table if exists t0;
create table if not exists t0(c0 int)  partition by hash (c0) partitions 17;
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t0 where c0 = 3;
Query Plan
======================================================
|ID|OPERATOR                                |NAME    |
------------------------------------------------------
|0 |PX COORDINATOR                          |        |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|
|2 |  └─DELETE                              |        |
|3 |    └─EXCHANGE IN DISTR                 |        |
|4 |      └─EXCHANGE OUT DISTR (PKEY RANDOM)|:EX10000|
|5 |        └─PX BLOCK ITERATOR             |        |
|6 |          └─TABLE FULL SCAN             |t0      |
======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=5
  2 - output(nil), filter(nil)
      table_columns([{t0: ({t0: (t0.__pk_increment, t0.c0)})}])
  3 - output([PARTITION_ID], [t0.__pk_increment], [t0.c0]), filter(nil), rowset=16
  4 - output([PARTITION_ID], [t0.__pk_increment], [t0.c0]), filter(nil), rowset=16
      (#keys=1, [t0.c0]), dop=5
  5 - output([t0.__pk_increment], [t0.c0]), filter(nil), rowset=16
  6 - output([t0.__pk_increment], [t0.c0]), filter([t0.c0 = 3]), rowset=16
      access([t0.__pk_increment], [t0.c0]), partitions(p3)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t0.__pk_increment]), range(MIN ; MAX)always true
delete /*+parallel(5) enable_parallel_dml*/  from t0 where c0 = 3;


#test partition by hash
drop table if exists t1;
create table if not exists t1(c0 int)  partition by hash (c0) partitions 17;
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));
Query Plan
======================================================
|ID|OPERATOR                                |NAME    |
------------------------------------------------------
|0 |PX COORDINATOR                          |        |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|
|2 |  └─DELETE                              |        |
|3 |    └─EXCHANGE IN DISTR                 |        |
|4 |      └─EXCHANGE OUT DISTR (PKEY RANDOM)|:EX10000|
|5 |        └─PX BLOCK ITERATOR             |        |
|6 |          └─TABLE FULL SCAN             |t1      |
======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=5
  2 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.__pk_increment, t1.c0)})}])
  3 - output([PARTITION_ID], [t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
  4 - output([PARTITION_ID], [t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
      (#keys=1, [t1.c0]), dop=5
  5 - output([t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
  6 - output([t1.__pk_increment], [t1.c0]), filter([1 = t1.c0]), rowset=16
      access([t1.__pk_increment], [t1.c0]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
delete /*+parallel(5) enable_parallel_dml*/  from t1 where ( exists (select 1)) and (( exists (select 1)) in (t1.c0));

#test partition by key
drop table if exists t2;
create table if not exists t2(c0 int unique)  partition by key (c0) partitions 17;
explain basic delete /*+parallel(5) enable_parallel_dml*/  from t2 where ( exists (select 1)) and (( exists (select 1)) in (t2.c0));
Query Plan
======================================================
|ID|OPERATOR                                |NAME    |
------------------------------------------------------
|0 |PX COORDINATOR                          |        |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|
|2 |  └─DELETE                              |        |
|3 |    └─EXCHANGE IN DISTR                 |        |
|4 |      └─EXCHANGE OUT DISTR (PKEY RANDOM)|:EX10000|
|5 |        └─PX BLOCK ITERATOR             |        |
|6 |          └─TABLE GET                   |t2(c0)  |
======================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=5
  2 - output(nil), filter(nil)
      table_columns([{t2: ({t2: (t2.__pk_increment, t2.c0)})}])
  3 - output([PARTITION_ID], [t2.__pk_increment], [t2.c0]), filter(nil), rowset=16
  4 - output([PARTITION_ID], [t2.__pk_increment], [t2.c0]), filter(nil), rowset=16
      (#keys=1, [t2.c0]), dop=5
  5 - output([t2.__pk_increment], [t2.c0]), filter(nil), rowset=16
  6 - output([t2.__pk_increment], [t2.c0]), filter(nil), rowset=16
      access([t2.__pk_increment], [t2.c0]), partitions(p14)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c0], [t2.shadow_pk_0]), range[1,NULL ; 1,NULL], 
      range_cond([1 = t2.c0])
delete /*+parallel(5) enable_parallel_dml*/  from t2 where ( exists (select 1)) and (( exists (select 1)) in (t2.c0));
