--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : biaonian.wcx
#owner group: storage
#desc: show storage cache policy

connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection ob_mysql;

--disable_warnings
drop table if exists test_table;
drop table if exists basic_sc;
--enable_warnings

create table test_table(log_date1 int, log_date2 bigint NOT NULL, log_date3 int)
storage_cache_policy = (boundary_column = log_date2, boundary_column_unit = "ms", hot_retention = 1 month)
partition by range(log_date2)
subpartition by list(log_date3)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);

create index idx1 on test_table (log_date2) local storage_cache_policy (global = "hot");
show create table test_table;

set _show_ddl_in_compat_mode = 1;
show create table test_table;

set _show_ddl_in_compat_mode = 0;
show create table test_table;


let $create_table = query_get_value(show create table test_table, Create Table, 1);
drop table test_table;
eval $create_table;
show create table test_table;

alter system set default_storage_cache_policy = 'auto';
create table basic_sc(c1 int, c2 char(10));
# add index to check show create table if the index storage cache policy will be shown when it is not set
create index idx_a on basic_sc (c1) local;
set _show_ddl_in_compat_mode = 1;
show create table basic_sc;

set _show_ddl_in_compat_mode = 0;
show create table basic_sc;

--echo "create table using showing create"

let $create_table = query_get_value(show create table basic_sc, Create Table, 1);
drop table basic_sc;
eval $create_table;
show create table basic_sc;

drop table test_table;
drop table basic_sc;