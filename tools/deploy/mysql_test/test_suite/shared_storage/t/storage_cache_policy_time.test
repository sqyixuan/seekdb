--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
#owner : biaonian.wcx
#owner group: storage
#desc: test partitioned table for storage cache policy

connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (ob_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection ob_sys;
let $server_count = query_get_value(SELECT COUNT(*) as server_count FROM oceanbase.__all_server, server_count, 1);
connection ob_mysql;

# Cleanup existing tables
--disable_warnings
DROP TABLE IF EXISTS test_year, test_date, test_datetime, test_timestamp, test_int, test_bigint, test_2level;
--enable_warnings

# -------------------------------------------------------------
# Case 1: Boundary Column with YEAR type (YEAR unit)
# -------------------------------------------------------------
let $year_prev3 = `SELECT YEAR(CURDATE()) - 3`;
let $year_prev2 = `SELECT YEAR(CURDATE()) - 2`;
let $year_prev1 = `SELECT YEAR(CURDATE()) - 1`;
let $year_current = `SELECT YEAR(CURDATE())`;
let $year_next1 = `SELECT YEAR(CURDATE()) + 1`;

let $hot_retention = 1;
let $target_verified_partitions = 3;
let $table_name = test_year;

# Case 1: Year type boundary column
eval CREATE TABLE test_year (
  id INT,
  event_year YEAR NOT NULL,
  data VARCHAR(100))
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_year,
  HOT_RETENTION = $hot_retention YEAR
)
PARTITION BY RANGE COLUMNS(event_year) (
  PARTITION p_prev3 VALUES LESS THAN ($year_prev3), # auto
  PARTITION p_prev2 VALUES LESS THAN ($year_prev2), # auto
  PARTITION p_prev1 VALUES LESS THAN ($year_prev1), # auto
  PARTITION p_current VALUES LESS THAN ($year_current), # hot
  PARTITION p_next1 VALUES LESS THAN ($year_next1), # hot
  PARTITION p_max VALUES LESS THAN MAXVALUE # hot
);

--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next1;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc

# -------------------------------------------------------------
# Case 2: Boundary Column with DATE type (DAY unit)
# -------------------------------------------------------------
let $date_prev3 = `SELECT UTC_DATE() - INTERVAL 3 DAY`;
let $date_prev2 = `SELECT UTC_DATE() - INTERVAL 2 DAY`;
let $date_prev1 = `SELECT UTC_DATE() - INTERVAL 1 DAY`;
let $date_current = `SELECT UTC_DATE()`;
let $date_next1 = `SELECT UTC_DATE() + INTERVAL 1 DAY`;

let $hot_retention = 1;
let $target_verified_partitions = 3;
let $table_name = test_date;

# DATE type with DAY retention
eval CREATE TABLE test_date (
  id INT,
  event_date DATE NOT NULL,
  data VARCHAR(100))
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_date,
  HOT_RETENTION = $hot_retention DAY
)
PARTITION BY RANGE COLUMNS(event_date) (
  PARTITION p_prev3 VALUES LESS THAN ("$date_prev3"), # auto
  PARTITION p_prev2 VALUES LESS THAN ("$date_prev2"), # auto
  PARTITION p_prev1 VALUES LESS THAN ("$date_prev1"), # auto
  PARTITION p_current VALUES LESS THAN ("$date_current"), # hot
  PARTITION p_next1 VALUES LESS THAN ("$date_next1"), # hot
  PARTITION p_max VALUES LESS THAN MAXVALUE # hot
);
--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next1;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc

# -------------------------------------------------------------
# Case 3: Boundary Column with DATETIME type (HOUR unit)
# -------------------------------------------------------------
let $datetime_prev3h = `SELECT UTC_TIMESTAMP() - INTERVAL 3 HOUR`;
let $datetime_prev2h = `SELECT UTC_TIMESTAMP() - INTERVAL 2 HOUR`;
let $datetime_prev1h = `SELECT UTC_TIMESTAMP() - INTERVAL 1 HOUR`;
let $datetime_current = `SELECT UTC_TIMESTAMP()`;
let $datetime_next1h = `SELECT UTC_TIMESTAMP() + INTERVAL 1 HOUR`;

let $hot_retention = 1;  # Keep hot data for 24 hours
let $target_verified_partitions = 3;
let $table_name = test_datetime;

# DATETIME type with HOUR retention
eval CREATE TABLE test_datetime (
  id INT,
  event_time DATETIME NOT NULL,
  data VARCHAR(100))
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_time,
  HOT_RETENTION = $hot_retention HOUR
)
PARTITION BY RANGE COLUMNS(event_time) (
  PARTITION p_prev3h VALUES LESS THAN ("$datetime_prev3h"), # auto
  PARTITION p_prev2h VALUES LESS THAN ("$datetime_prev2h"), # auto
  PARTITION p_prev1h VALUES LESS THAN ("$datetime_prev1h"), # auto
  PARTITION p_current VALUES LESS THAN ("$datetime_current"), # hot
  PARTITION p_next1h VALUES LESS THAN ("$datetime_next1h"), # hot
  PARTITION p_max VALUES LESS THAN MAXVALUE # hot
);

--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next1h;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc
