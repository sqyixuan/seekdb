# owner: wuxingying.wxy
# owner group: shenzhen
# description test for vector index search in shared storage

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
drop database if exists vec_idx_in_ss;
--enable_warnings

create database vec_idx_in_ss;

use vec_idx_in_ss;

--disable_warnings
DROP TABLE IF EXISTS table_with_vec;
DROP TABLE IF EXISTS table_without_vec;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 44;
sleep 3;

--result_format 2
--error 1235
CREATE TABLE table_with_vec (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    c2 vector(10),
    vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag)
);

CREATE TABLE table_without_vec (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    c2 vector(10));

--error 1235
CREATE VECTOR INDEX VEC_IDX1 ON table_without_vec (c2) with (distance=l2, type=hnsw, lib=vsag);

INSERT INTO table_without_vec (c2) VALUES
('[0.203846,0.205289,0.880265,0.824340,0.615737,0.496899,0.983632,0.865571,0.248373,0.542833]'),
('[0.735541,0.670776,0.903237,0.447223,0.232028,0.659316,0.765661,0.226980,0.579658,0.933939]'),
('[0.327936,0.048756,0.084670,0.389642,0.970982,0.370915,0.181664,0.940780,0.013905,0.628127]');

select * from table_without_vec order by id;

--error 1235
CREATE VECTOR INDEX VEC_IDX1 ON table_without_vec (c2) with (distance=l2, type=hnsw, lib=vsag);

DROP TABLE table_without_vec;

DROP DATABASE vec_idx_in_ss;
