# owner: baonian.wcx
# group: storage
# desc: test basic storage cache policy
# create table with storage cache policy
# create table with index storage cache policy
# check parallel create table with storage cache policy


--disable_warnings
drop table if exists basic_sc;
drop table if exists basic_sc_1;
drop table if exists basic_sc_2;
drop table if exists basic_sc_part;
drop table if exists basic_sc_part_2;
drop table if exists basic_sc_part_3;
drop table if exists basic_sc_part_4;
drop table if exists basic_sc_part_5;
--enable_warnings

# create table with storage cache policy
create table basic_sc(c1 int, c2 char(10)) storage_cache_policy= (global = "hot");
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create table
}

# create table with index storage cache policy
create table basic_sc_1(
c1 int, 
c2 char(10),
index basic_sc_1_idx1 (c1) storage_cache_policy = (global = "hot")
)
storage_cache_policy= (global = "hot");

let $table_storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc_1', storage_cache_policy, 1);

if ($table_storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $table_storage_cache_policy
  --echo table_storage_cache_policy is wrong when create table
}

let $index_storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%basic_sc_1_idx1%', storage_cache_policy, 1);

if ($index_storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $index_storage_cache_policy
  --echo index_storage_cache_policy is wrong when create index
}

# check parallel create table with storage cache policy
alter system set _enable_parallel_table_creation = true;
create table basic_sc_2(c1 int, c2 char(10)) storage_cache_policy= (global = "hot");
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc_2', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create table
}
alter system set _enable_parallel_table_creation = false;

# alter table storage cache policy
alter table basic_sc storage_cache_policy= (global = "auto");
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"AUTO"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

# create index with storage cache policy
create index basic_sc_idx1 on basic_sc (c1) local storage_cache_policy (global = "hot");
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%basic_sc_idx1%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

# alter index storage cache policy
alter table basic_sc alter index basic_sc_idx1 storage_cache_policy (global = "auto"); 
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%basic_sc_idx1%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"AUTO"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

# alter table add index with storage cache policy
alter table basic_sc add index basic_sc_idx2(c1, c2) local storage_cache_policy (global = "hot");
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%basic_sc_idx2%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}
 
# alter partition and subpartition storage cache policy
create table basic_sc_part(col1 int, col2 int)
partition by range(col1)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);

alter table basic_sc_part alter partition p0 p1 storage_cache_policy='hot';
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'basic_sc_part', table_id, 1);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_part where table_id = $table_id and part_name = 'p0', storage_cache_policy, 1);

if ($storage_cache_policy != 'HOT') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_part where table_id = $table_id and part_name = 'p1', storage_cache_policy, 1);

if ($storage_cache_policy != 'HOT') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

alter table basic_sc_part alter subpartition sp0 sp3 sp4 storage_cache_policy='auto';
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_sub_part where table_id = $table_id and sub_part_name = 'sp0', storage_cache_policy, 1);

if ($storage_cache_policy != 'AUTO') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_sub_part where table_id = $table_id and sub_part_name = 'sp3', storage_cache_policy, 1);
if ($storage_cache_policy != 'AUTO') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_sub_part where table_id = $table_id and sub_part_name = 'sp4', storage_cache_policy, 1);
if ($storage_cache_policy != 'AUTO') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

alter table basic_sc_part storage_cache_policy= (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc_part', storage_cache_policy, 1);

if ($storage_cache_policy != '{"COLUMN_NAME":"col1", "HOT_RETENTION_INTERVAL":1, "HOT_RETENTION_UNIT":"MONTH", "COLUMN_UNIT":"MS"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

# check default storage cache policy
alter system set default_storage_cache_policy='hot';

let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_tenant_parameter_stat where name = 'default_storage_cache_policy' and value != 'hot', count, 1);

while ($count != 0) {
  sleep 1;
  let $count = query_get_value(select count(*) as count from oceanbase.__all_virtual_tenant_parameter_stat where name = 'default_storage_cache_policy' and value != 'hot', count, 1);
}

create table basic_sc_part_2(col1 int, col2 int)
partition by range(col1)
subpartition by range(col2)
(partition p0 values less than(100)
(subpartition sp0 values less than(2020),
  subpartition sp1 values less than(2021)
),
partition p1 values less than(200)
(subpartition sp2 values less than(2020),
  subpartition sp3 values less than(2021),
  subpartition sp4 values less than(2022)
  )
);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc_part_2', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create table
}

create index idxtest_b on basic_sc_part_2(col1) local;
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_b%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

create index idxtest_d on basic_sc_part_2(col1) global;
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_d%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

create index idxtest_d2 on basic_sc_part_2(col1);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_d2%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

# alter table add index with default value
alter table basic_sc_part_2 add index idxtest_e(col1);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_e%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

alter table basic_sc_part_2 add index idxtest_e2(col1) local;
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_e2%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

alter table basic_sc_part_2 add index idxtest_e3(col1) global;
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%idxtest_e3%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when create index
}

# create table with time storage cache policy 
create table basic_sc_part_3(col1 int, col2 int)
storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
partition by range(col1)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name = 'basic_sc_part_3', storage_cache_policy, 1);

if ($storage_cache_policy != '{"COLUMN_NAME":"col1", "HOT_RETENTION_INTERVAL":1, "HOT_RETENTION_UNIT":"MONTH", "COLUMN_UNIT":"MS"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

# check for partition expr function
--error 1235
create table basic_sc_part_4(col1 int, col2 int)
storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
partition by range(col1 + 10)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);

create table basic_sc_part_4(col1 int, col2 int)
partition by range(col1 + 10)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
--error 1235
alter table basic_sc_part_4 set storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);

--disable_warnings
drop table basic_sc;
drop table basic_sc_1;
drop table basic_sc_2;
drop table basic_sc_part;
drop table basic_sc_part_2;
drop table basic_sc_part_3;
drop table basic_sc_part_4;
