--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : biaonian.wcx
#owner group: storage
#desc: check limit for storage cache policy

connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection ob_mysql;

--disable_warnings
drop table if exists basic_sc;
drop table if exists ex_ex_t1;
drop table if exists test_table;
--enable_warnings

# non-partitioned table not support time storage cache policy
--error 1235
create table basic_sc(c1 int, c2 char(10)) storage_cache_policy= (boundary_column = c1, boundary_column_unit = 'ms', hot_retention = 1 month);

create table basic_sc(c1 int, c2 char(10));
--error 1235
alter table basic_sc storage_cache_policy= (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);

# check for external table
--error 1235
create external table ex_ex_t1 (
c1 int,
c2 int,
c3 varchar(30)
)
storage_cache_policy = (global = "hot")
location='../include'
format (
type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'ex_nt.csv'
;

create external table ex_ex_t1 (
date_key date,
c2 int,
c3 varchar(30)
)
location='../include'
PARTITION_TYPE = USER_SPECIFIED
format (
type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'ex_nt.csv'
partition by range(date_key)
;

--error 1235
alter external table ex_ex_t1 storage_cache_policy = (global = "hot");

--error 1235
alter external table ex_ex_t1 alter partition p0 storage_cache_policy='hot';

--error 1235
create index idx1 on ex_ex_t1 (c1) local storage_cache_policy (global = "hot");

# check for partition and subpartition
create table test_table(log_date1 int, log_date2 bigint NOT NULL, log_date3 int)
storage_cache_policy = (boundary_column = log_date2, boundary_column_unit = "ms", hot_retention = 1 month)
partition by range(log_date2)
subpartition by list(log_date3)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);

alter table test_table alter partition p0 p1 storage_cache_policy='hot';
alter table test_table alter partition P0 P1 storage_cache_policy='hot';
alter table test_table alter subpartition sp0 sp1 storage_cache_policy='hot';
alter table test_table alter subpartition SP0 SP1 storage_cache_policy='hot';
--error 1735
alter table test_table alter partition p8 p0 storage_cache_policy='hot';
--error 1735
alter table test_table alter subpartition sp9 sp0 storage_cache_policy='hot';

# check for column
--echo "====== check alter cache_policy column ======"
--disable_warnings
drop table if exists test_table;
--enable_warnings
create table test_table(log_date1 int, log_date2 bigint NOT NULL, log_date3 int)
storage_cache_policy = (boundary_column = log_date2, boundary_column_unit = "ms", hot_retention = 1 month)
partition by range(log_date2)
subpartition by list(log_date3)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
alter table test_table change column log_date2 log_date2 bigint;
--error 1235
alter table test_table change column log_date2 log_date2 tinyint;
--error 1659
alter table test_table change column log_date2 log_date2 date;
--error 1235
alter table test_table change column LOG_DATE2 log_date2 tinyint;
--error 1659
alter table test_table change column LOG_DATE2 log_date2 date;
--error 1235
alter table test_table change column log_daté2 log_date2 tinyint;
--error 1659
alter table test_table change column log_daté2 log_date2 datetime;

--error 1235
alter table test_table modify column log_date2 tinyint;
--error 1659
alter table test_table modify column log_date2 date;
--error 1235
alter table test_table modify column LOG_DATE2 tinyint;
--error 1659
alter table test_table modify column LOG_DATE2 date;
--error 1235
alter table test_table modify column log_daté2 tinyint;
--error 1659
alter table test_table modify column log_daté2 datetime;

alter table test_table alter column log_date2 set default 0;

--error 3855
alter table test_table drop column log_date2;

create index idx1 on test_table (log_date2) local storage_cache_policy (global = "hot");

set _show_ddl_in_compat_mode = 1;
show create table test_table;

set _show_ddl_in_compat_mode = 0;
show create table test_table;

drop table basic_sc;
drop table ex_ex_t1;
drop table test_table;
