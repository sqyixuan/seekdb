# owner: yunshan.tys
# owner group: storage
# description test for fulltext search in shared storage

connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
drop database if exists fts_in_ss;
--enable_warnings

create database fts_in_ss;

use fts_in_ss;

--disable_warnings
DROP TABLE IF EXISTS table_with_fts;
DROP TABLE IF EXISTS table_without_fts;
--enable_warnings

--result_format 3

CREATE TABLE table_with_fts (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(200),
    content TEXT,
    FULLTEXT INDEX ctx(title, content)
);

# alter table offline ddl is not allow in fulltext/multi josn table
CREATE TABLE t_fts_offline (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(200),
    content TEXT,
    FULLTEXT INDEX ctx(title, content)
);
--error 1235
ALTER TABLE t_fts_offline CHANGE id id VARCHAR(128) before title;
DROP TABLE t_fts_offline;

CREATE TABLE t_multivalue_offline (
    id BIGINT NOT NULL PRIMARY KEY,
    modified BIGINT,
    custinfo JSON,
    index comp(modified, (CAST(custinfo->'$.zipcode' AS char(16) ARRAY)))
);
--error 1235
ALTER TABLE t_multivalue_offline CHANGE id id VARCHAR(128) before modified;
DROP TABLE t_multivalue_offline;

CREATE TABLE table_without_fts (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    title VARCHAR(200),
    content TEXT);

ALTER TABLE table_without_fts add FULLTEXT INDEX ctx0(title, content);

--disable_warnings
CREATE FULLTEXT INDEX ctx1 ON table_without_fts(title, content);
--enable_warnings

alter system set _enable_add_fulltext_index_to_existing_table = true;

INSERT INTO table_without_fts (title, content) VALUES
('OceanBase Tutorial', 'This is a tutorial about Oceanbase Fulltext.'),
('Fulltext Index', 'Fulltext index can be very useful.'),
('OceanBase Test Case', 'Writing test cases helps ensure quality.');

select * from table_without_fts order by id;

--disable_warnings
ALTER TABLE table_without_fts add FULLTEXT INDEX ctx2(title, content);
--enable_warnings

--disable_warnings
CREATE FULLTEXT INDEX ctx3 ON table_without_fts(title, content);
--enable_warnings

DROP TABLE table_without_fts;

DROP DATABASE fts_in_ss;
