# owner: cangming.zl
# owner group: RS
# description: zone administration command in shared-storage mode
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

use oceanbase;

--enable_warnings
--enable_query_log

# regions of all zones must keep the same in shared_storage mode
let $curr_region = query_get_value(select region from oceanbase.DBA_OB_ZONES, region, 1);

# add
eval alter system add zone 'test_zone_admin_zone1' region '$curr_region';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';

--error 1235
alter system add zone 'test_zone_admin_zone2' region 'test_zone_admin_region';

# alter
--error 1235
alter system modify zone 'test_zone_admin_zone1' set region 'region2';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';

# delete
alter system delete zone 'test_zone_admin_zone1';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';

connection default;
