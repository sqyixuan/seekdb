# owner: baonian.wcx
# owner group: cloud storage
# desc: test index-related sql statements
connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

let $table_name = basic_scp_index;
let $index_name = basic_scp_index_1;
--disable_warnings
eval drop table if exists $table_name;
--enable_warnings

let $check_scp_task_tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name = '$table_name', tablet_id, 1);

# create global index with time storage cache policy
eval CREATE TABLE $table_name(col1 INT,col2 INT);

--error 1210
eval create index $index_name on $table_name (col2) global
storage_cache_policy (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
PARTITION BY RANGE(col2)
(PARTITION p0 VALUES LESS THAN(100), 
PARTITION p1 VALUES LESS THAN(200), 
PARTITION p2 VALUES LESS THAN(300)
);

eval create index $index_name on $table_name (col2) global
storage_cache_policy (boundary_column = col2, boundary_column_unit = 'ms', hot_retention = 1 month)
PARTITION BY RANGE(col2)
(PARTITION p0 VALUES LESS THAN(100), 
PARTITION p1 VALUES LESS THAN(200), 
PARTITION p2 VALUES LESS THAN(300)
);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name%', storage_cache_policy, 1);

if ($storage_cache_policy != '{"COLUMN_NAME":"col2", "HOT_RETENTION_INTERVAL":1, "HOT_RETENTION_UNIT":"MONTH", "COLUMN_UNIT":"MS"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}


# alter table add global index with time storage cache policy
let $index_name2 = basic_scp_index_2;
eval alter table $table_name add index $index_name2(col1) global storage_cache_policy (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month) 
partition by range(col1)(partition p0 values less than maxvalue);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name2%', storage_cache_policy, 1);

--error 1210
eval alter table $table_name add index $index_name2(col1) global storage_cache_policy (boundary_column = col2, boundary_column_unit = 'ms', hot_retention = 1 month) 
partition by range(col1)(partition p0 values less than maxvalue);

# alter index with time storage cache policy
--error 1210
eval alter table $table_name alter index $index_name2 storage_cache_policy (boundary_column = col2, boundary_column_unit = 'ms', hot_retention = 1 month);
--error 1210
eval alter table $table_name alter index $index_name2 storage_cache_policy (boundary_column = col2, hot_retention = 1 month);

eval alter table $table_name alter index $index_name2 storage_cache_policy (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 day);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name2%', storage_cache_policy, 1);
if ($storage_cache_policy != '{"COLUMN_NAME":"col1", "HOT_RETENTION_INTERVAL":1, "HOT_RETENTION_UNIT":"DAY", "COLUMN_UNIT":"MS"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

let $index_name3 = basic_scp_index_3;
--error 1235
eval alter table $table_name add index $index_name3(col1) global storage_cache_policy (boundary_column = col1, hot_retention = 1 month);
eval alter table $table_name add index $index_name3(col1) global;
eval alter table $table_name alter index $index_name3 storage_cache_policy = (global = 'hot');
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name3%', storage_cache_policy, 1);
if ($storage_cache_policy != '{"GLOBAL":"HOT"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}
--error 1235
eval alter table $table_name alter index $index_name3 storage_cache_policy (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);

let $index_name4 = basic_scp_index_4;
eval alter table $table_name add c9 VARCHAR(10) DEFAULT 'a',ADD INDEX $index_name4(c9),RENAME INDEX $index_name TO ind2;
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name4%', storage_cache_policy, 1);
if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}
eval alter table $table_name add c11 VARCHAR(10) NOT NULL ,ADD CONSTRAINT uni_1 UNIQUE(c11),ADD INDEX ind1(c11);
let $storage_cache_policy = query_get_value(select storage_cache_policy from oceanbase.__all_virtual_table where table_name like '%$index_name4%', storage_cache_policy, 1);
if ($storage_cache_policy != '{"GLOBAL":"NONE"}') {
  --echo $storage_cache_policy
  --echo storage_cache_policy is wrong when alter table
}

let $index_name5 = basic_scp_index_5;
--error 1235
eval alter table $table_name ADD INDEX basic_scp_index_5(col1) storage_cache_policy (global = 'hot'), ADD INDEX basic_scp_index_6(c9);

--error 1235
eval alter table $table_name alter index basic_scp_index_5 storage_cache_policy (global = 'hot'), alter index basic_scp_index_6 storage_cache_policy (global = 'hot');

alter table basic_scp_index add index idx1(col1), add index idx2(col1);
--error 1235
alter table basic_scp_index add index idx1(col1), add index idx2(col1) storage_cache_policy = (global = 'hot');

alter table basic_scp_index rename index idx1 to idx3, alter index idx2 invisible;
--error 1235
alter table basic_scp_index rename index idx1 to idx3, alter index idx2 storage_cache_policy(global = 'hot');

alter table basic_scp_index add index idx4(col1), alter index idx2 visible;
--error 1235
alter table basic_scp_index add index idx4(col1) storage_cache_policy = (global = 'hot'), alter index idx2 visible;

--error 1235
alter table basic_scp_index add index idx4(col1) , alter index idx2 storage_cache_policy = (global = 'hot');

truncate table basic_scp_index;