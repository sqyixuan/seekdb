--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianlin.cjl
# owner group: storage
# description: test for materialized view

connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
--disable_warnings
--disable_query_log
connection default;
use test;
drop materialized view if exists mv1;
drop table if exists t1;
--enable_query_log
--enable_warnings

# in share storage mode, create materialized view is not supported
create table t1 (c1 int, c2 int);
create materialized view mv1 as select * from t1;

drop table t1;
