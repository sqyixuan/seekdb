# owner: zhuoran.zzr
# owner group: storage
# description: chekc no logging param and  archive exclusive
--result_format 4
connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection ob_mysql;

# check  no_logging and  achrive exclusive
alter system set _no_logging = false;
--error 0, 9092
alter system noarchivelog;

alter system set _no_logging = true;
sleep 2;
--error 4179
alter system archivelog;
alter system set _no_logging = false;


sleep 2;
alter system archivelog;
--error 1210
alter system set _no_logging = true;
alter system noarchivelog;
sleep 2;
alter system set _no_logging = true;

# check no pendding replay
--disable_warnings
drop table if exists t1;
--enable_warnings
set ob_query_timeout = 1000000000;
create table t1 (c1 bigint, c2 varchar(1000));
insert /*+ append enable_parallel_dml parallel(8) */ into t1 select random(), randstr(1000, random()) from table(generator(100000));
create index idx1 on t1(c1);
alter table t1 add column c3 int default 0 after c1;
sleep 5;
select count(*) from oceanbase.__all_virtual_replay_stat where pending_cnt > 0;
drop table t1;

--error 0,9092
alter system noarchivelog;
alter system set _no_logging = false;