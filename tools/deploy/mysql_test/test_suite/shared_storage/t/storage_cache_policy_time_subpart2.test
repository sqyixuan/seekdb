--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
#owner : biaonian.wcx
#owner group: storage
#desc: test sub partitioned table for storage cache policy

connect (ob_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (ob_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection ob_sys;
let $server_count = query_get_value(SELECT COUNT(*) as server_count FROM oceanbase.__all_server, server_count, 1);
connection ob_mysql;

# Cleanup existing tables
--disable_warnings
DROP TABLE IF EXISTS test_year, test_date, test_datetime, test_timestamp, test_int, test_bigint;
--enable_warnings

SET time_zone = '+00:00';
# -------------------------------------------------------------
# Case 4: TIMESTAMP type with 2-level partitioning
# -------------------------------------------------------------
let $timestamp_prev30m = `SELECT NOW() - INTERVAL 30 MINUTE`;
let $timestamp_prev15m = `SELECT NOW() - INTERVAL 15 MINUTE`;
let $timestamp_prev5m = `SELECT NOW() - INTERVAL 5 MINUTE`;
let $timestamp_current = `SELECT NOW()`;
let $timestamp_next15m = `SELECT NOW() + INTERVAL 15 MINUTE`;

let $hot_retention = 5;
let $target_verified_partitions = 3;
let $table_name = test_timestamp;

eval CREATE TABLE test_timestamp (
  id INT,
  event_ts TIMESTAMP NOT NULL,
  data VARCHAR(100),
  region INT DEFAULT 1
)
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_ts,
  HOT_RETENTION = $hot_retention MINUTE
)
PARTITION BY LIST(region)
SUBPARTITION BY RANGE COLUMNS(event_ts) (
  PARTITION p_region VALUES IN (1) (
    SUBPARTITION p_prev30m VALUES LESS THAN ("$timestamp_prev30m"), # auto
    SUBPARTITION p_prev15m VALUES LESS THAN ("$timestamp_prev15m"), # auto
    SUBPARTITION p_prev5m VALUES LESS THAN ("$timestamp_prev5m"), # auto
    SUBPARTITION p_current VALUES LESS THAN ("$timestamp_current"), # hot
    SUBPARTITION p_next15m VALUES LESS THAN ("$timestamp_next15m"), # hot
    SUBPARTITION p_max VALUES LESS THAN MAXVALUE # hot
  )
);

--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next15m;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc

# -------------------------------------------------------------
# Case 5: INT type with 2-level partitioning
# -------------------------------------------------------------
let $int_prev1800s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 1800 SECOND)`;
let $int_prev1200s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 1200 SECOND)`;
let $int_prev600s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 600 SECOND)`;
let $int_current = `SELECT UNIX_TIMESTAMP(NOW())`;
let $int_next600s = `SELECT UNIX_TIMESTAMP(NOW() + INTERVAL 600 SECOND)`;
let $int_next1200s = `SELECT UNIX_TIMESTAMP(NOW() + INTERVAL 1200 SECOND)`;

let $hot_retention = 600;
let $target_verified_partitions = 4;
let $table_name = test_int;

eval CREATE TABLE test_int (
  id INT,
  event_ts_int INT NOT NULL,
  data VARCHAR(100),
  region INT DEFAULT 1
)
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_ts_int,
  BOUNDARY_COLUMN_UNIT = 's',
  HOT_RETENTION = $hot_retention SECOND
)
PARTITION BY LIST(region)
SUBPARTITION BY RANGE COLUMNS(event_ts_int) (
  PARTITION p_region VALUES IN (1) (
    SUBPARTITION p_prev1800s VALUES LESS THAN ($int_prev1800s), # auto
    SUBPARTITION p_prev1200s VALUES LESS THAN ($int_prev1200s), # auto
    SUBPARTITION p_prev600s VALUES LESS THAN ($int_prev600s),  # auto
    SUBPARTITION p_current VALUES LESS THAN ($int_current),  # hot
    SUBPARTITION p_next600s VALUES LESS THAN ($int_next600s),  # hot
    SUBPARTITION p_next1200s VALUES LESS THAN ($int_next1200s),# hot
    SUBPARTITION p_max VALUES LESS THAN MAXVALUE            # hot
  )
);

--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next600s;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next1200s;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc

# -------------------------------------------------------------
# Case 6: BIGINT type with 2-level partitioning
# -------------------------------------------------------------
let $bigint_prev1800s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 1800 SECOND) * 1000`;
let $bigint_prev1200s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 1200 SECOND) * 1000`;
let $bigint_prev600s = `SELECT UNIX_TIMESTAMP(NOW() - INTERVAL 600 SECOND) * 1000`;
let $bigint_current = `SELECT UNIX_TIMESTAMP(NOW()) * 1000`;
let $bigint_next600s = `SELECT UNIX_TIMESTAMP(NOW() + INTERVAL 600 SECOND) * 1000`;
let $bigint_next1200s = `SELECT UNIX_TIMESTAMP(NOW() + INTERVAL 1200 SECOND) * 1000`;

let $hot_retention = 600;
let $target_verified_partitions = 4;
let $table_name = test_bigint;

eval CREATE TABLE test_bigint (
  id INT,
  event_ts_bigint BIGINT NOT NULL,
  data VARCHAR(100),
  region INT DEFAULT 1
)
STORAGE_CACHE_POLICY (
  BOUNDARY_COLUMN = event_ts_bigint,
  BOUNDARY_COLUMN_UNIT = 'ms',
  HOT_RETENTION = $hot_retention SECOND
)
PARTITION BY LIST(region)
SUBPARTITION BY RANGE COLUMNS(event_ts_bigint) (
  PARTITION p_region VALUES IN (1) (
    SUBPARTITION p_prev1800s VALUES LESS THAN ($bigint_prev1800s), # auto
    SUBPARTITION p_prev1200s VALUES LESS THAN ($bigint_prev1200s), # auto
    SUBPARTITION p_prev600s VALUES LESS THAN ($bigint_prev600s),  # auto
    SUBPARTITION p_current VALUES LESS THAN ($bigint_current),  # hot
    SUBPARTITION p_next600s VALUES LESS THAN ($bigint_next600s),  # hot
    SUBPARTITION p_next1200s VALUES LESS THAN ($bigint_next1200s),# hot
    SUBPARTITION p_max VALUES LESS THAN MAXVALUE              # hot
  )
);

--source mysql_test/include/storage_cache_check_task.inc

let $part_name = p_current;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next600s;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_next1200s;
--source mysql_test/include/storage_cache_check_verified_part.inc
let $part_name = p_max;
--source mysql_test/include/storage_cache_check_verified_part.inc
