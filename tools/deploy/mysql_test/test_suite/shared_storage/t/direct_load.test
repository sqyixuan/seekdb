--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianlin.cjl
# owner group: storage
# description: test for direct load

connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

--disable_warnings
--disable_query_log
drop table if exists t1_ins_overwrt;
drop table if exists t2_ins_overwrt;
--enable_query_log
--enable_warnings
set ob_query_timeout=1000000000;
create table t1_ins_overwrt (c1 int primary key, c2 int, c3 text) partition by range(c1)(partition p0 values less than(15), partition p1 values less than(25), partition p2 values less than(35), partition p3 values less than(45), partition p4 values less than (MAXVALUE));
create table t2_ins_overwrt (c1 int primary key, c2 int, c3 text) partition by range(c1)(partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30), partition p3 values less than (MAXVALUE));
insert overwrite t2_ins_overwrt partition(p0, p1, p3) select * from t1_ins_overwrt;
drop table t1_ins_overwrt;
drop table t2_ins_overwrt;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_true.inc
