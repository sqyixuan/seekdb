alter system set _ss_major_compaction_prewarm_level = 2;
alter system set enable_manual_storage_cache_policy = true;
alter system set default_storage_cache_policy = 'AUTO';
alter system set suspend_storage_cache_task = false;
drop table if exists basic_sc;
create table basic_sc (
c1 bigint,
c2 date,
c3 varchar(1000),
c4 bigint,
primary key (c1, c2)
)
partition by range columns(c2) (
partition p2023 values less than ('2024-01-01'),
partition p2024 values less than ('2025-01-01'),
partition p2025 values less than ('2026-01-01'),
partition p2026 values less than ('2027-01-01'),
partition p_max values less than (MAXVALUE)
);
=========== 1 insert data ===========
=========== 2 launch and wait major freeze ===========
alter system major freeze;
=========== 3 basic: trigger prewarm task ===========
alter table basic_sc alter partition p2023 storage_cache_policy = 'hot';
=========== 4 check prewarm task after update tenant params ===========
=========== 4.1 enable_manual_storage_cache_policy: true -> false, default_storage_cache_policy: AUTO ===========
alter system set enable_manual_storage_cache_policy = false;
=========== 4.2 enable_manual_storage_cache_policy: false, default_storage_cache_policy: AUTO -> HOT ===========
alter system set default_storage_cache_policy = 'HOT';
=========== 4.3 enable_manual_storage_cache_policy: false, default_storage_cache_policy: HOT -> AUTO ===========
alter system set default_storage_cache_policy = 'AUTO';
=========== 4.4 enable_manual_storage_cache_policy: false -> true, default_storage_cache_policy: AUTO ===========
=========== 4.4.1 tablet storage_cache_policy: HOT ===========
alter system set enable_manual_storage_cache_policy = true;
=========== 4.4.2 tablet storage_cache_policy: AUTO ===========
alter table basic_sc alter partition p2023 storage_cache_policy = 'auto';
alter system set enable_manual_storage_cache_policy = false;
alter system set enable_manual_storage_cache_policy = true;
=========== 4.5 enable_manual_storage_cache_policy: true, default_storage_cache_policy: AUTO -> HOT ===========
alter system set default_storage_cache_policy = 'HOT';
=========== 4.6 enable_manual_storage_cache_policy: true -> false, default_storage_cache_policy: HOT ===========
alter system set enable_manual_storage_cache_policy = false;
=========== 4.7 enable_manual_storage_cache_policy: false -> true, default_storage_cache_policy: HOT ===========
=========== 4.7.1 tablet storage_cache_policy: AUTO ===========
alter system set enable_manual_storage_cache_policy = true;
=========== 4.7.2 tablet storage_cache_policy: HOT ===========
alter system set enable_manual_storage_cache_policy = false;
alter table basic_sc alter partition p2023 storage_cache_policy = 'hot';
alter system set enable_manual_storage_cache_policy = true;
=========== 4.8 enable_manual_storage_cache_policy: true, default_storage_cache_policy: HOT -> AUTO ===========
alter system set default_storage_cache_policy = 'AUTO';
=========== reset tenant params ===========
alter system set _ss_major_compaction_prewarm_level = 0;
alter system set enable_manual_storage_cache_policy = true;
alter system set default_storage_cache_policy = 'AUTO';
alter system set suspend_storage_cache_task = false;
