drop table if exists basic_scp_index;
CREATE TABLE basic_scp_index(col1 INT,col2 INT);
create index basic_scp_index_1 on basic_scp_index (col2) global
storage_cache_policy (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
PARTITION BY RANGE(col2)
(PARTITION p0 VALUES LESS THAN(100), 
PARTITION p1 VALUES LESS THAN(200), 
PARTITION p2 VALUES LESS THAN(300)
);
