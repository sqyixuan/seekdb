drop table if exists basic_sc_part;
create table basic_sc_part (
order_id int,
order_date date,
amount decimal(10,2),
primary key (order_id, order_date)
) 
partition by range columns(order_date) (
partition p2023 values less than ('2024-01-01'),
partition p2024 values less than ('2025-01-01'),
partition p2025 values less than ('2026-01-01'),
partition p2026 values less than ('2027-01-01'),
partition p_max values less than (MAXVALUE)
);
alter table basic_sc_part alter partition p2023 storage_cache_policy='hot';
alter table basic_sc_part alter partition p2023 p2023 storage_cache_policy='hot';
ERROR HY000: duplicate partition when alter partition storage_cache_policy
alter table basic_sc_part alter partition p2023 p2023 storage_cache_policy='auto';
ERROR HY000: duplicate partition when alter partition storage_cache_policy
"=========== test partition success ==========="
drop table if exists basic_sc_sub_part;
create table basic_sc_sub_part (col1 int, col2 int)
partition by range(col1)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
alter table basic_sc_sub_part alter subpartition sp0 storage_cache_policy='hot';
alter table basic_sc_sub_part alter subpartition sp0 sp0 storage_cache_policy='hot';
ERROR HY000: duplicate subpartition when alter subpartition storage_cache_policy
alter table basic_sc_sub_part alter subpartition sp0 sp0 storage_cache_policy='auto';
ERROR HY000: duplicate subpartition when alter subpartition storage_cache_policy
