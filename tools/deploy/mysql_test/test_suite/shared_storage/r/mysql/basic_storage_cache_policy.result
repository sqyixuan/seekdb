drop table if exists basic_sc;
drop table if exists basic_sc_1;
drop table if exists basic_sc_2;
drop table if exists basic_sc_part;
drop table if exists basic_sc_part_2;
drop table if exists basic_sc_part_3;
drop table if exists basic_sc_part_4;
drop table if exists basic_sc_part_5;
create table basic_sc(c1 int, c2 char(10)) storage_cache_policy= (global = "hot");
create table basic_sc_1(
c1 int, 
c2 char(10),
index basic_sc_1_idx1 (c1) storage_cache_policy = (global = "hot")
)
storage_cache_policy= (global = "hot");
alter system set _enable_parallel_table_creation = true;
create table basic_sc_2(c1 int, c2 char(10)) storage_cache_policy= (global = "hot");
alter system set _enable_parallel_table_creation = false;
alter table basic_sc storage_cache_policy= (global = "auto");
create index basic_sc_idx1 on basic_sc (c1) local storage_cache_policy (global = "hot");
alter table basic_sc alter index basic_sc_idx1 storage_cache_policy (global = "auto");
alter table basic_sc add index basic_sc_idx2(c1, c2) local storage_cache_policy (global = "hot");
create table basic_sc_part(col1 int, col2 int)
partition by range(col1)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
alter table basic_sc_part alter partition p0 p1 storage_cache_policy='hot';
alter table basic_sc_part alter subpartition sp0 sp3 sp4 storage_cache_policy='auto';
alter table basic_sc_part storage_cache_policy= (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);
alter system set default_storage_cache_policy='hot';
create table basic_sc_part_2(col1 int, col2 int)
partition by range(col1)
subpartition by range(col2)
(partition p0 values less than(100)
(subpartition sp0 values less than(2020),
subpartition sp1 values less than(2021)
),
partition p1 values less than(200)
(subpartition sp2 values less than(2020),
subpartition sp3 values less than(2021),
subpartition sp4 values less than(2022)
)
);
create index idxtest_b on basic_sc_part_2(col1) local;
create index idxtest_d on basic_sc_part_2(col1) global;
create index idxtest_d2 on basic_sc_part_2(col1);
alter table basic_sc_part_2 add index idxtest_e(col1);
alter table basic_sc_part_2 add index idxtest_e2(col1) local;
alter table basic_sc_part_2 add index idxtest_e3(col1) global;
create table basic_sc_part_3(col1 int, col2 int)
storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
partition by range(col1)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
create table basic_sc_part_4(col1 int, col2 int)
storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month)
partition by range(col1 + 10)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
ERROR 0A000: cache policy not support part key using expr not supported
create table basic_sc_part_4(col1 int, col2 int)
partition by range(col1 + 10)
subpartition by list(col2)
(partition p0 values less than(100)
(subpartition sp0 values in (1, 2, 3),
subpartition sp1 values in (4, 5, 6)
),
partition p1 values less than(200)
(subpartition sp2 values in (1, 2, 3),
subpartition sp3 values in (4, 5, 6),
subpartition sp4 values in (7, 8, 9)
)
);
alter table basic_sc_part_4 set storage_cache_policy = (boundary_column = col1, boundary_column_unit = 'ms', hot_retention = 1 month);
ERROR 0A000: cache policy not support part key using expr not supported
drop table basic_sc;
drop table basic_sc_1;
drop table basic_sc_2;
drop table basic_sc_part;
drop table basic_sc_part_2;
drop table basic_sc_part_3;
drop table basic_sc_part_4;
