####子分区####
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 FLOAT(5,0),
c1 INT(5),
c2 VARCHAR(10))
PARTITION BY RANGE COLUMNS(c2)
SUBPARTITION BY HASH(c1) SUBPARTITIONS 4
(PARTITION r1 VALUES LESS THAN('10'),
PARTITION r2 VALUES LESS THAN('20'),
PARTITION r3 VALUES LESS THAN('30'),
PARTITION r4 VALUES LESS THAN('40'));
INSERT INTO t1 VALUES(1,1,'1'),(2,2,'2'),(3,0,'3'),(4,-20,'-5'),(5,6,'-10'),(6,-10,'11'),(7,7,'15');
