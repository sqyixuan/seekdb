ALTER TABLE t1 MODIFY c1 INT(5) PRIMARY KEY AUTO_INCREMENT;
ERROR HY000: A PRIMARY KEY must include all columns in the table's partitioning function
ALTER TABLE t1 MODIFY c1 INT(5) AUTO_INCREMENT;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` float(5,0) DEFAULT NULL,
  `c1` int(5) NOT NULL AUTO_INCREMENT,
  `c2` varchar(10) DEFAULT NULL
) ORGANIZATION INDEX AUTO_INCREMENT = 8 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(c2) subpartition by hash(c1) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`,
subpartition `p3`)
(partition `r1` values less than ('10'),
partition `r2` values less than ('20'),
partition `r3` values less than ('30'),
partition `r4` values less than ('40'))
