drop database if exists vec_idx_in_ss;
create database vec_idx_in_ss;
use vec_idx_in_ss;
DROP TABLE IF EXISTS table_with_vec;
DROP TABLE IF EXISTS table_without_vec;
alter system set ob_vector_memory_limit_percentage = 44;
result_format: 2
CREATE TABLE table_with_vec (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    c2 vector(10),
    vector index idx1(c2) with (distance=l2, type=hnsw, lib=vsag)
);
ERROR 0A000: vector index search index in shared storage mode is not supported

CREATE TABLE table_without_vec (
    id INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
    c2 vector(10));

CREATE VECTOR INDEX VEC_IDX1 ON table_without_vec (c2) with (distance=l2, type=hnsw, lib=vsag);
ERROR 0A000: vector index in shared storage mode is not supported

