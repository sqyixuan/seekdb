Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` text DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=6666
drop table t1;
create table t1(pk int primary key, c2 varchar(100), j text) DEFAULT_LOB_INROW_THRESHOLD=10000;
insert into t1 values(1, '2222', repeat('x', 8127));
select pk, md5(j) as md5 from t1;
pk	md5
1	6adf06e8c88dd93a4a7e204977d51287
alter table t1 drop column c2;
select pk, md5(j) as md5 from t1;
pk	md5
1	6adf06e8c88dd93a4a7e204977d51287
drop table t1;
create table t1(pk int primary key, c1 mediumtext, c2 longtext, c3 longtext);
alter table t1 set lob_inrow_threshold = 786433;
ERROR HY000: Incorrect arguments to lob inrow threshold, should be [0, 786432]
alter table t1 set lob_inrow_threshold = 786432;
ERROR HY000: Data too long(2359296>1572864) for column 'c3'
drop table t1;
create table t1(pk int primary key, c1 longtext);
insert into t1 values(1, repeat('1', 786432));
update t1 set c1 = repeat('2', 786432);
drop table t1;
set ob_default_lob_inrow_threshold=786433;
ERROR HY000: Incorrect arguments to lob inrow threshold, should be [0, 786432]
create table t1 (pk int primary key, c1 longtext);
drop table t1;
create table t1 (pk int primary key, c1 longtext) partition by hash(pk) partitions 4;
drop table t1;
