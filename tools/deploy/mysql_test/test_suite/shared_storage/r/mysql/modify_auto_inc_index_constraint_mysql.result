#########################大数据量的表中，修改普通列为自增列，并执行DML操作########################
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 INT);
DROP PROCEDURE IF EXISTS p1;
CREATE PROCEDURE p1()
BEGIN
DECLARE i INT DEFAULT 1;
wh1:WHILE i <= 10000 DO
IF i < 1000 THEN
INSERT INTO t1 VALUES(i,i*2);
ELSEIF i < 2000 THEN
INSERT INTO t1 VALUES(i,i-1);
ELSEIF i < 4000 THEN
INSERT INTO t1 VALUES(i,i+1);
ELSEIF i < 6000 THEN
INSERT INTO t1 VALUES(i,i-1000);
ELSEIF i < 8000 THEN
INSERT INTO t1 VALUES(i,NULL);
ELSE
INSERT INTO t1 VALUES(i,i+1000);
END IF;
SET i = i + 1;
END WHILE wh1;
END;
//
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
10000
ALTER TABLE t1 MODIFY c0 INT PRIMARY KEY AUTO_INCREMENT;
