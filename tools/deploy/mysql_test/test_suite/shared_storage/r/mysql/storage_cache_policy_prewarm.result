alter system set _ss_major_compaction_prewarm_level = 2;
drop table if exists basic_sc;
create table basic_sc(c1 bigint, c2 varchar(1000), c3 bigint) storage_cache_policy = (global = "auto");
"=========== 1. insert data ==========="
"=========== 2. launch and wait major freeze ==========="
alter system major freeze;
"=========== 3. basic: trigger prewarm task ==========="
alter table basic_sc storage_cache_policy= (global = "hot");
