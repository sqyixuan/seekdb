set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##шо╛ч╜ох╣╢цЯечЬЛх╜УхЙНхнЧчмжщЫЖшо╛ч╜о
SET NAMES latin1;
set character_set_database = 'utf16le';
set character_set_server = 'utf16le';
set character_set_results = 'utf8mb4';
show character set where Charset = 'utf16le';
Charset	Description	Default collation	Maxlen
utf16le	UTF-16LE Unicode	utf16le_general_ci	4
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	latin1
character_set_connection	latin1
character_set_database	utf16le
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf16le
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	latin1_swedish_ci
collation_database	utf16le_general_ci
collation_server	utf16le_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# хнЧчмжч▒╗хЮЛ #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16le;
use db1;

drop table test_utf16le;
CREATE TABLE test_utf16le (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET utf16le) DEFAULT CHARSET=utf16le;

DROP PROCEDURE create_utf16le;
CREATE PROCEDURE create_utf16le()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO test_utf16le (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_utf16le();

SELECT (CONVERT(_TIS620 0x00C8 USING utf16le));
