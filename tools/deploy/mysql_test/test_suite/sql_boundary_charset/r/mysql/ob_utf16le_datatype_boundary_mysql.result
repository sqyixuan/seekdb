drop table char_table;
CREATE TABLE IF NOT EXISTS char_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_value CHAR(1) CHARACTER SET utf16le
);

CREATE PROCEDURE create_utf16le2()
BEGIN
DECLARE i int DEFAULT 128;
  WHILE i < 256 DO
    INSERT INTO char_table (char_value) VALUES (char(i USING utf16le));
    set i = i + 1;
  END WHILE;
END;
/
call create_utf16le2();
