    char_0 CHAR(0) CHARACTER SET utf16le,
    char_1 CHAR(1) CHARACTER SET utf16le,
    char_255 CHAR(255) CHARACTER SET utf16le,
    char_256 CHAR(256) CHARACTER SET utf16le
) DEFAULT CHARSET=utf16le;

INSERT INTO sample_table (char_0, char_1, char_255, char_256) VALUES
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'));
