### SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET utf16le COLLATE utf16le_general_ci,
    char_1 CHAR(1) CHARACTER SET utf16le COLLATE utf16le_general_ci,
    char_255 CHAR(255) CHARACTER SET utf16le COLLATE utf16le_bin
) DEFAULT CHARSET=utf16le;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, ' ф╕н '));
SELECT * FROM sample_table;
