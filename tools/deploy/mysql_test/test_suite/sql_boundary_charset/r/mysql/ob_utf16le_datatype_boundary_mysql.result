### BINARY
DROP TABLE binary_test;
### OBцЧацКещФЩя╝МMYSQLцЬЙцКещФЩуАВ
CREATE TABLE binary_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    binary_0 BINARY(0),
    binary_1 BINARY(1),
    binary_255 BINARY(255),
    binary_256 BINARY(256)
) CHARSET=utf16le;

