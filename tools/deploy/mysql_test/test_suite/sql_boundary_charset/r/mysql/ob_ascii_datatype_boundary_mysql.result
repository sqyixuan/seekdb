### collation_name
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET ascii COLLATE ascii_general_ci,
    char_1 CHAR(1) CHARACTER SET ascii COLLATE ascii_general_ci,
    char_255 CHAR(255) CHARACTER SET ascii COLLATE ascii_bin
) DEFAULT CHARSET=ascii;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, 'дЄ≠'));
SELECT * FROM sample_table;
+--------+--------+----------+
| char_0 | char_1 | char_255 |
+--------+--------+----------+
|        | A      |          |
+--------+--------+----------+

### SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET ascii COLLATE ascii_general_ci,
    char_1 CHAR(1) CHARACTER SET ascii COLLATE ascii_general_ci,
    char_255 CHAR(255) CHARACTER SET ascii COLLATE ascii_bin
) DEFAULT CHARSET=ascii;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, ' дЄ≠ '));
SELECT * FROM sample_table;
+--------+--------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| char_0 | char_1 | char_255                                                                                                                                                                                                                                                        |
+--------+--------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
|        | A      |                                                                                                                                                                                                                                                                 |
+--------+--------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
SELECT LENGTH(char_0),OCTET_LENGTH(char_0),CHAR_LENGTH(char_0) FROM sample_table;
+----------------+----------------------+---------------------+
| LENGTH(char_0) | OCTET_LENGTH(char_0) | CHAR_LENGTH(char_0) |
+----------------+----------------------+---------------------+
|              0 |                    0 |                   0 |
+----------------+----------------------+---------------------+
SELECT LENGTH(char_1),OCTET_LENGTH(char_1),CHAR_LENGTH(char_1) FROM sample_table;
+----------------+----------------------+---------------------+
| LENGTH(char_1) | OCTET_LENGTH(char_1) | CHAR_LENGTH(char_1) |
+----------------+----------------------+---------------------+
|              1 |                    1 |                   1 |
+----------------+----------------------+---------------------+
SELECT LENGTH(char_255),OCTET_LENGTH(char_255),CHAR_LENGTH(char_255) FROM sample_table;
+------------------+------------------------+-----------------------+
| LENGTH(char_255) | OCTET_LENGTH(char_255) | CHAR_LENGTH(char_255) |
+------------------+------------------------+-----------------------+
|              255 |                    255 |                   255 |
+------------------+------------------------+-----------------------+

