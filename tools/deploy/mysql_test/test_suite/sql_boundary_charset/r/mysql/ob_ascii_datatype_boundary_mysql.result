drop table char_table;
CREATE TABLE IF NOT EXISTS char_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_value CHAR(1) CHARACTER SET ascii
);

CREATE PROCEDURE create_ascii2()
BEGIN
DECLARE i int DEFAULT 128;
  WHILE i < 256 DO
    INSERT INTO char_table (char_value) VALUES (char(i USING ascii));
    set i = i + 1;
  END WHILE;
END;
/
