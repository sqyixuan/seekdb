purge recyclebin;
result_format: 4
#Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
SET NAMES latin1;
set character_set_database = 'utf16';
set character_set_server = 'utf16';
set character_set_results = 'utf8mb4';
show character set where Charset = 'utf16';
Charset	Description	Default collation	Maxlen
utf16	UTF-16 Unicode	utf16_general_ci	4
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	latin1
character_set_connection	latin1
character_set_database	utf16
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	utf16
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	latin1_swedish_ci
collation_database	utf16_general_ci
collation_server	utf16_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# 字符串文本 #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16;
use db1;
###### 函数、表达式  ######
###### replace  ######
### 中文列名展示不稳定，暂时注释
SELECT replace('中文测试','中','文');
SELECT REPLACE('特殊符号与标点测试', '特殊符号与标点', '文');
SELECT REPLACE('数字测试0123456789', '0123456789', '文');
SELECT REPLACE('大写字母测试ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', '文');
SELECT REPLACE('小写字母测试abcdefghijklmnopqrstuvwxyz', 'abcdefghijklmnopqrstuvwxyz', '文');
SELECT REPLACE('含有各种字符测试????????????', '????????????', '文');
SELECT REPLACE('西里尔字母测试??????????', '??????????', '文');
SELECT REPLACE('汉字测试', '汉字', '文');
SELECT REPLACE('其他字符测试乀乁乄乇乑', '乀乁乄乇乑', '文');
SELECT REPLACE('各种特殊符号测试??丂丄丅丌丒丟', '??丂丄丅丌丒丟', '文');
SELECT REPLACE('组合字符测试许體_TRIG_體', '许體_TRIG_體', '文');

###### LENGTH、OCTET_LENGTH、CHAR_LENGTH  ######
###### 中文字符集
SELECT LENGTH('许'), OCTET_LENGTH('许'), CHAR_LENGTH('许');

###### 特殊字符集
SELECT LENGTH('??????龔'''), OCTET_LENGTH('??????龔'''), CHAR_LENGTH('??????龔''');

###### 希腊字符集
SELECT LENGTH('????????龔'), OCTET_LENGTH('????????龔'), CHAR_LENGTH('????????龔');

###### 希腊小写字母字符集
SELECT LENGTH('?????????????龔'), OCTET_LENGTH('?????????????龔'), CHAR_LENGTH('?????????????龔');

###### 斯拉夫字符集
SELECT LENGTH('??????????'), OCTET_LENGTH('??????????'), CHAR_LENGTH('??????????');

###### 其他斯拉夫字符集
SELECT LENGTH('???????'), OCTET_LENGTH('???????'), CHAR_LENGTH('???????');

######  常见符号字符集
SELECT LENGTH(' !"#$%&''()*+,-./'), OCTET_LENGTH(' !"#$%&''()*+,-./'), CHAR_LENGTH(' !"#$%&''()*+,-./');

###### 数字字符集
SELECT LENGTH('0123456789:;<=>??'), OCTET_LENGTH('0123456789:;<=>??'), CHAR_LENGTH('0123456789:;<=>??');

######  大写字母字符集
SELECT LENGTH('@ABCDEFGHIJKLMNO'), OCTET_LENGTH('@ABCDEFGHIJKLMNO'), CHAR_LENGTH('@ABCDEFGHIJKLMNO');

###### 其他大写字母字符集
SELECT LENGTH('PQRSTUVWXYZ[\\]^_'), OCTET_LENGTH('PQRSTUVWXYZ[\\]^_'), CHAR_LENGTH('PQRSTUVWXYZ[\\]^_');

###### 小写字母字符集
SELECT LENGTH('abcdefghijklmno'), OCTET_LENGTH('abcdefghijklmno'), CHAR_LENGTH('abcdefghijklmno');

###### 其他小写字母字符集
SELECT LENGTH('pqrstuvwxyz{|}~'), OCTET_LENGTH('pqrstuvwxyz{|}~'), CHAR_LENGTH('pqrstuvwxyz{|}~');

###### 拉丁字符集（带重音的字母）
SELECT LENGTH('?????????????????????'), OCTET_LENGTH('?????????????????????'), CHAR_LENGTH('?????????????????????');

######  拉丁字符集（带重音的后续字母）
SELECT LENGTH('????????????????????龔'), OCTET_LENGTH('????????????????????龔'), CHAR_LENGTH('????????????????????龔');

###### 其他复杂字符集
SELECT LENGTH('????????????????????????????'), OCTET_LENGTH('????????????????????????????'), CHAR_LENGTH('????????????????????????????');

######  其他小写拉丁字符集（带重音）
SELECT LENGTH('áà?????ǎā????????龔éè??'), OCTET_LENGTH('áà?????ǎā????????龔éè??'), CHAR_LENGTH('áà?????ǎā????????龔éè??');

######  其他复杂小写拉丁字符集
SELECT LENGTH('ɡ??????龔íì?龔ǐ??ī?龔'), OCTET_LENGTH('ɡ??????龔íì?龔ǐ??ī?龔'), CHAR_LENGTH('ɡ??????龔íì?龔ǐ??ī?龔');

###### 更多拉丁字符集（带重音）
SELECT LENGTH('??????龔ńň?龔óò?龔ǒ??ō???????'), OCTET_LENGTH('??????龔ńň?龔óò?龔ǒ??ō???????'), CHAR_LENGTH('??????龔ńň?龔óò?龔ǒ??ō???????');

###### 其他复杂拉丁字符集
SELECT LENGTH('??????????úùü?龔ǔ??ū?????ǘǜǚǖ???????'), OCTET_LENGTH('??????????úùü?龔ǔ??ū?????ǘǜǚǖ???????'), CHAR_LENGTH('??????????úùü?龔ǔ??ū?????ǘǜǚǖ???????');

###### 汉字字符集
SELECT LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑'),
       OCTET_LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑'),
       CHAR_LENGTH('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑');

###### 更多字符集
SELECT LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众'),
       OCTET_LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众'),
       CHAR_LENGTH('仃仐仚仛仠仡仢仨仯仱仳仵份仾仿伀伂伃伈伋伌伒伕伖众');

###### 更多混合字符集
SELECT LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘'),
       OCTET_LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘'),
       CHAR_LENGTH('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘');

###### 特殊字符集
SELECT LENGTH('許體_TRIG_體'),
       OCTET_LENGTH('許體_TRIG_體'),
       CHAR_LENGTH('許體_TRIG_體');

###### FIND_IN_SET ######
select FIND_IN_SET(_latin1'B', _latin1'a,b,c,d') from dual;
select FIND_IN_SET(_utf16 '繁體ing',_utf16 '繁體ing') as utf16_res from dual;
SELECT FIND_IN_SET(_utf16 '???????\'', _utf16 '???????\'') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '??????????ü', _utf16 '??????????ü') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '????????龔', _utf16 '????????龔') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '??????????', _utf16 '??????????') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '@ABCDEFGHIJKLMNO', _utf16 '@ABCDEFGHIJKLMNO') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 'abcdefghijklmno', _utf16 'abcdefghijklmno') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '????????????????????龔', _utf16 '????????????????????龔') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '??????龔', _utf16 '??????龔') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '丂丄丅丌丒丟丣', _utf16 '丂丄丅丌丒丟丣') AS utf16_res FROM dual;
SELECT FIND_IN_SET(_utf16 '許體_TRIG_體', _utf16 '許體_TRIG_體') AS utf16_res FROM dual;

