DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf8mb4;
use db1;

drop table test_utf8mb4;
CREATE TABLE test_utf8mb4 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET utf8mb4) DEFAULT CHARSET=utf8mb4;

DROP PROCEDURE create_utf8mb4;
CREATE PROCEDURE create_utf8mb4()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO test_utf8mb4 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_utf8mb4();

SELECT (CONVERT(_TIS620 0x00C8 USING utf8mb4));
