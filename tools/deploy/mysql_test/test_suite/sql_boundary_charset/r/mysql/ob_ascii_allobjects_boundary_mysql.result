### OB暂不支持。MYSQL支持。
CREATE TABLE `my_partitioned_table` (
    id INT NOT NULL,
    data VARCHAR(255) NOT NULL,
    PRIMARY KEY (id)
)
PARTITION BY RANGE (id) (
    PARTITION p1 VALUES LESS THAN (10) COMMENT '?????',
    PARTITION p2 VALUES LESS THAN (20) COMMENT '¤№',
    PARTITION p3 VALUES LESS THAN (30) COMMENT '?????',
