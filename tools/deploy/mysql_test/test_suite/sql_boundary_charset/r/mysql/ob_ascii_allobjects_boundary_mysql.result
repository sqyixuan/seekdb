purge recyclebin;
result_format: 4
#Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
SET NAMES ascii;
set character_set_database = 'ascii';
set character_set_server = 'ascii';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ascii';
Charset	Description	Default collation	Maxlen
ascii	US ASCII	ascii_general_ci	1
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	ascii
character_set_connection	ascii
character_set_database	ascii
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	ascii
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	ascii_general_ci
collation_database	ascii_general_ci
collation_server	ascii_general_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
