## 定义字符变量
SET @var0 = '';
SET @var1 = 'A';
SET @var64 = 'This is a string with length 64, exactly fit for the definition.';
SET @var65 = 'This is a string that exceeds sixty-four characters!';

## 查询这些变量
SELECT
    CHAR_LENGTH(@var0) AS Length_0,
    CHAR_LENGTH(@var1) AS Length_1,
    CHAR_LENGTH(@var64) AS Length_64,
    CHAR_LENGTH(@var65) AS Length_65;
+----------+----------+-----------+-----------+
| Length_0 | Length_1 | Length_64 | Length_65 |
+----------+----------+-----------+-----------+
|        0 |        1 |        64 |        52 |
+----------+----------+-----------+-----------+

