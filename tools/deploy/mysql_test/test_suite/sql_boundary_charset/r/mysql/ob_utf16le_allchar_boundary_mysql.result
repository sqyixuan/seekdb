### 布尔值测试 ###
SELECT TRUE;
+------+
| TRUE |
+------+
|    1 |
+------+
SELECT true;
+------+
| true |
+------+
|    1 |
+------+
SELECT FALSE;
+-------+
| FALSE |
+-------+
|     0 |
+-------+
SELECT false;
+-------+
| false |
+-------+
|     0 |
+-------+

### 边界值测试 ###
SELECT NULL;
+------+
| NULL |
+------+
| NULL |
+------+
SELECT '';
+--+
|  |
+--+
|  |
+--+
SELECT 'example';
+---------+
| example |
+---------+
| example |
+---------+
SELECT 0;
+---+
| 0 |
+---+
| 0 |
+---+
SELECT 1;
+---+
| 1 |
+---+
| 1 |
+---+

