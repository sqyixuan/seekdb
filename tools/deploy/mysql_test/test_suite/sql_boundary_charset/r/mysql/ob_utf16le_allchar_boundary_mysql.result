| b'0'   | b'1'   | b'10'     | b'11'     | b'100'    | b'101'    | b'110'    | b'111'    | B'0'   | B'1'   | B'10'     | B'11'     | 0b0    | 0b1    | 0b10   | 0b11   | 0B0    | 0B1    | 0B10   | 0B11   |
