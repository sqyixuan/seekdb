       (_utf16le 'b''10'''),  
       (_utf16le 'b''11'''),  
       (_utf16le 'b''100'''), 
       (_utf16le 'b''101'''), 
       (_utf16le 'b''110'''), 
       (_utf16le 'b''111'''), 
