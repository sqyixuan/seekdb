       (_utf16le 'B''1'''),   
       (_utf16le 'B''10'''),  
       (_utf16le 'B''11'''),  
       (_utf16le '0b0'),      
       (_utf16le '0b1'),      
       (_utf16le '0b10'),     
       (_utf16le '0b11'),     
       (_utf16le '0B0'),      
       (_utf16le '0B1'),      
       (_utf16le '0B10'),     
