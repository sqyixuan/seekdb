purge recyclebin;
result_format: 4
#Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
SET NAMES dec8;
set character_set_database = 'dec8';
set character_set_server = 'dec8';
set character_set_results = 'utf8mb4';
show character set where Charset = 'dec8';
Charset	Description	Default collation	Maxlen
dec8	DEC West European	dec8_swedish_ci	1
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	dec8
character_set_connection	dec8
character_set_database	dec8
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	dec8
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	dec8_swedish_ci
collation_database	dec8_swedish_ci
collation_server	dec8_swedish_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# 字符串文本 #############################
