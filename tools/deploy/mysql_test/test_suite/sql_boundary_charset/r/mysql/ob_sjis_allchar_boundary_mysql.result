purge recyclebin;
result_format: 4
#Environmental cleaning
###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

##设置并查看当前字符集设置
SET NAMES sjis;
set character_set_database = 'sjis';
set character_set_server = 'sjis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'sjis';
Charset	Description	Default collation	Maxlen
sjis	SJIS	sjis_japanese_ci	2
show variables like '%character%';
Variable_name	Value
character_sets_dir	
character_set_client	sjis
character_set_connection	sjis
character_set_database	sjis
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	sjis
character_set_system	utf8mb4
show variables like'%collation%';
Variable_name	Value
collation_connection	sjis_japanese_ci
collation_database	sjis_japanese_ci
collation_server	sjis_japanese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
############################# 字符串文本 #############################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET sjis;
use db1;

