DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET big5;
use db1;

drop table test_big5;
CREATE TABLE test_big5 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET big5) DEFAULT CHARSET=big5;

DROP PROCEDURE create_big5;
CREATE PROCEDURE create_big5()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO test_big5 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_big5();

