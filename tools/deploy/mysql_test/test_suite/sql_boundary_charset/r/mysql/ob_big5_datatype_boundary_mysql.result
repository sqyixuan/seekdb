    char_0 CHAR(0) CHARACTER SET big5 COLLATE big5_chinese_ci,
    char_1 CHAR(1) CHARACTER SET big5 COLLATE big5_chinese_ci,
    char_255 CHAR(255) CHARACTER SET big5 COLLATE big5_bin
) DEFAULT CHARSET=big5;

