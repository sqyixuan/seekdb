INSERT INTO example_table (data) VALUES (
    JSON_OBJECT(
        'key1', LPAD('A', 1677721, 'A')
    )
);
SELECT * FROM example_table;
SELECT * FROM example_table ORDER BY CAST(JSON_EXTRACT(data, '$.id') AS UNSIGNED);
