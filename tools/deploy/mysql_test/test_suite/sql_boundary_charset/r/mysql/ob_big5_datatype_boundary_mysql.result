### BLOB
DROP TABLE blob_table;
CREATE TABLE blob_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    tiny_blob1 TINYBLOB,
    blob1 BLOB,
    medium_blob1 MEDIUMBLOB,
