|  3 | {"tags": null, "count": 5, "message": "Hello, World!", "is_valid": true}                                                          |
|  4 | {"items": [1, 2, 3, 4, 5], "is_empty": false, "settings": {"theme": "dark", "notifications": true}}                               |
