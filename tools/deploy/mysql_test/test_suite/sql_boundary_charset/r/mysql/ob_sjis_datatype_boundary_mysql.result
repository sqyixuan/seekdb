JSON цХ░цНоч▒╗хЮЛ
DROP TABLE json_test;
CREATE TABLE json_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    json_data JSON
) CHARACTER SET sjis;

INSERT INTO json_test (json_data) VALUES
('{"name": "Alice", "age": 30, "is_student": false, "courses": ["Math", "Science"], "address": {"city": "Beijing", "zip": null}}'),
('{"products": [{"id": 1, "name": "Product A", "price": 100.50}, {"id": 2, "name": "Product B", "price": 150.00}], "available": true}'),
('{"message": "Hello, World!", "count": 5, "is_valid": true, "tags": null}'),
('{"is_empty": false, "items": [1, 2, 3, 4, 5], "settings": {"theme": "dark", "notifications": true}}');
SELECT * FROM json_test;
+----+-----------------------------------------------------------------------------------------------------------------------------------+
| id | json_data                                                                                                                         |
+----+-----------------------------------------------------------------------------------------------------------------------------------+
|  1 | {"age": 30, "name": "Alice", "address": {"zip": null, "city": "Beijing"}, "courses": ["Math", "Science"], "is_student": false}    |
|  2 | {"products": [{"id": 1, "name": "Product A", "price": 100.5}, {"id": 2, "name": "Product B", "price": 150.0}], "available": true} |
|  3 | {"tags": null, "count": 5, "message": "Hello, World!", "is_valid": true}                                                          |
|  4 | {"items": [1, 2, 3, 4, 5], "is_empty": false, "settings": {"theme": "dark", "notifications": true}}                               |
+----+-----------------------------------------------------------------------------------------------------------------------------------+

DROP TABLE json_test;
