### OBжЪВдЄНжФѓжМБгАВMYSQLжФѓжМБгАВ
CREATE TABLE `my_partitioned_table` (
    id INT NOT NULL,
    data VARCHAR(255) NOT NULL,
    PRIMARY KEY (id)
