SELECT LPAD('丂', 255, '丂');
--enable_result_log

### OB warnings 1301,MYSQL有报错2020
--disable_result_log
--ERROR 0,2020
SELECT LPAD('丂', 16777215, '丂');
--enable_result_log

--disable_result_log
--ERROR 0,2020
SELECT LPAD('丂', 16777215/2, '丂');
--enable_result_log

--disable_result_log
--ERROR 0,2020
SELECT LPAD('丂', 16777215/3, '丂');
--enable_result_log

--disable_result_log

SELECT (_big5 '0x5C' COLLATE big5_chinese_ci );
SELECT (_big5 '0x7C' COLLATE big5_chinese_ci );
SELECT (_big5 '@ A-Z [ \ ] ^ _ ` a-z { | } ~' COLLATE big5_chinese_ci );

