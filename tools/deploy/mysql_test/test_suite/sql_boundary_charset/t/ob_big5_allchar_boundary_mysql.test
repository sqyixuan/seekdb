# owner: sanquan.qz
# owner group: sql1
# tags: charset, big5
# description:big5 charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
SET NAMES big5;
set character_set_database = 'big5';
set character_set_server = 'big5';
set character_set_results = 'utf8mb4';
show character set where Charset = 'big5';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET big5;
use db1;

SELECT (_big5 0x0000 COLLATE big5_chinese_ci );

--disable_result_log
# 1. 有效单字节字符（ASCII 范围）
# ASCII 最后一个有效字符
SELECT _big5 0x7F COLLATE big5_chinese_ci;
# 字母 'A'
SELECT _big5 0x41 COLLATE big5_chinese_ci;

# 2. 有效双字节字符（Big5 标准区）
# 常用汉字起始（如"一"）
SELECT _big5 0xA140 COLLATE big5_chinese_ci;
# 标点符号区（如"、")
SELECT _big5 0xA3C0 COLLATE big5_chinese_ci;
# 第二字节 0x7E 边界
SELECT _big5 0xC67E COLLATE big5_chinese_ci;
# 标准区最后一个字符
SELECT _big5 0xF9D6 COLLATE big5_chinese_ci;

# 3. 边界值测试
# 第一字节边界
# 第一字节下限 (0x81)
--error 1300
SELECT _big5 0x8140 COLLATE big5_chinese_ci;
# 第一字节上限 (0xFE)
--error 1300
SELECT _big5 0xFE7E COLLATE big5_chinese_ci;
# 第二字节边界
# 第二字节 0x7F 无效区间
--error 1300
SELECT _big5 0xA17F COLLATE big5_chinese_ci;
# 第二字节 0xA1 有效起始
SELECT _big5 0xA1A1 COLLATE big5_chinese_ci;

# 4. 非法编码测试
# 第一字节 0x80 无效
--error 1300
SELECT _big5 0x8040 COLLATE big5_chinese_ci;
# 第一字节 0xFF 无效
--error 1300
SELECT _big5 0xFFA1 COLLATE big5_chinese_ci;
# 第二字节 0x3F 无效
--error 1300
SELECT _big5 0xA13F COLLATE big5_chinese_ci;
# 第二字节 0xA0 无效区间
--error 1300
SELECT _big5 0xA1A0 COLLATE big5_chinese_ci;

# 5. 多字节组合测试
# 连续合法字符（"一、"）
SELECT _big5 0xA140A3C0 COLLATE big5_chinese_ci;
# 混合单双字节（"A一"）
SELECT _big5 0x41A140 COLLATE big5_chinese_ci;

# 6. 扩展区测试（倚天扩展区 0xFA-0xFE）
# 扩展区起始
--error 1300
SELECT _big5 0xFA40 COLLATE big5_chinese_ci;
# 扩展区结束
--error 1300
SELECT _big5 0xFE7E COLLATE big5_chinese_ci;
# 标准区外延
SELECT _big5 0xF97E COLLATE big5_chinese_ci;

# 7. 错误字节长度测试
# 不完整双字节
--error 1300
SELECT _big5 0xA1 COLLATE big5_chinese_ci;
# 三字节组合（截断为双字节）
SELECT _big5 0xA14041 COLLATE big5_chinese_ci;

SELECT (_big5 '0xD7FF\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE big5_chinese_ci);
SELECT (_big5 '丂\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE big5_chinese_ci);

