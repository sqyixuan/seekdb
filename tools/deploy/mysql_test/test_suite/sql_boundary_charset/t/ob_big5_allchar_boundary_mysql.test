SELECT (_big5 '蓋' COLLATE big5_chinese_ci );
SELECT (_big5 '育' COLLATE big5_chinese_ci );
--enable_result_log

--echo ### 数值  ###
--ERROR 1064
SELECT (_big5 0);
--ERROR 1064
SELECT (_big5 HEX('dog')); 


