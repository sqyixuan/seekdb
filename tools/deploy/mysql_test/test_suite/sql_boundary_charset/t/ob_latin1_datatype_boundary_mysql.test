(LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' ')),
(LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' ')),
(LPAD(REPEAT('a', 255), 255, ' '), LPAD(REPEAT('a', 65535), 65535, ' '), LPAD(REPEAT('a', 65535), 65535, ' '), LPAD(REPEAT('a', 65535), 65535, ' ')),
(LPAD(REPEAT('a', 256), 256, ' '), LPAD(REPEAT('a', 65536), 65536, ' '), LPAD(REPEAT('a', 65535), 65535, ' '), LPAD(REPEAT('a', 65535), 65535, ' '));

INSERT INTO blob_table (tiny_blob1, blob1, medium_blob1, long_blob1) VALUES
(LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' ')),
(LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' ')),
