--echo ### 大对象和文本类型
--echo ### BLOB
--ERROR 0,1051
DROP TABLE blob_table;
CREATE TABLE blob_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    tiny_blob1 TINYBLOB,
    blob1 BLOB,
    medium_blob1 MEDIUMBLOB,
    long_blob1 LONGBLOB
) CHARSET=latin1;

### OB ERROR 1301 (HY000): Result of repeat() was larger than max_allowed_packet (16777216) - truncated
### MYSQL ERROR 1301 (HY000): Result of repeat() was larger than max_allowed_packet (67108864) - truncated

--ERROR 1301
INSERT INTO blob_table (tiny_blob1, blob1, medium_blob1, long_blob1) VALUES
(LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' '), LPAD('', 0, ' ')),
(LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' '), LPAD('a', 1, ' ')),
(LPAD(REPEAT('a', 255), 255, ' '), LPAD(REPEAT('a', 65535), 65535, ' '), LPAD(REPEAT('a', 16777215), 16777215, ' '), LPAD(REPEAT('a', 536870910), 536870910, ' ')),
