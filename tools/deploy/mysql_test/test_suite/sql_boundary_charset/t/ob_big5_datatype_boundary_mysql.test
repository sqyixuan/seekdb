SELECT CAST('Hello World' AS JSON);
--ERROR 3141
SELECT CAST('ASCII Text' AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xA55C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xB35C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xBB5C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xA87C USING big5) AS JSON);
--ERROR 3141
SELECT CAST('???????????????????' AS JSON);
