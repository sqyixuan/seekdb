    id INT AUTO_INCREMENT PRIMARY KEY,
    binary_0 VARBINARY(0),
    binary_1 VARBINARY(1),
    binary_255 VARBINARY(3227),
    binary_256 VARBINARY(3227)
);

INSERT INTO test_binary (binary_0, binary_1, binary_255, binary_256) VALUES
(BINARY(''),
 BINARY('A'),
 LPAD(('A'), 3227, ('A')),
 LPAD(('A'), 3227, ('A')));

INSERT INTO test_binary (binary_0, binary_1, binary_255, binary_256) VALUES
(BINARY(''),
 BINARY(''),
 LPAD((' '), 3227, ('A')),
 LPAD(('A'), 3227, (' ')));
INSERT INTO test_binary (binary_0, binary_1, binary_255, binary_256) VALUES
(BINARY(''),
 BINARY('A'),
 LPAD(('A'), 3227, (' ')),
 LPAD((' '), 3227, ('A')));

--disable_result_log
SELECT * FROM test_binary;
