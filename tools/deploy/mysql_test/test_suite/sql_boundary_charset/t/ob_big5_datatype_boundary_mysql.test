SELECT CAST(123.45 AS JSON);
SELECT CAST(TRUE AS JSON);
SELECT CAST(FALSE AS JSON);
SELECT CAST(NULL AS JSON);
SELECT CAST(X'01AF' AS JSON);
SELECT CAST(0x01af AS JSON);
SELECT CAST(X'0FFF' AS JSON);
SELECT CAST(0xaaF AS JSON);

