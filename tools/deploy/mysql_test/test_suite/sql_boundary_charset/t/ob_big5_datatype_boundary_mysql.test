    id INT AUTO_INCREMENT PRIMARY KEY,
    binary_0 VARBINARY(0),
    binary_1 VARBINARY(1),
    binary_255 VARBINARY(242145),
    binary_256 VARBINARY(10485760000)
);

SET sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

--ERROR 0,1051
DROP TABLE test_binary;
