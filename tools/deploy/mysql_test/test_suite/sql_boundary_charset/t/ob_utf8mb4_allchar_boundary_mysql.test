# ASCII 起始
SELECT (_utf8mb4 0x00 COLLATE utf8mb4_bin);
# ASCII 结束
SELECT (_utf8mb4 0x7F COLLATE utf8mb4_bin);
# 2字节起始
SELECT (_utf8mb4 0xC280 COLLATE utf8mb4_bin);
# 2字节结束
SELECT (_utf8mb4 0xDFBF COLLATE utf8mb4_bin);
# 3字节起始
SELECT (_utf8mb4 0xE0A080 COLLATE utf8mb4_bin);
# BMP 结束
SELECT (_utf8mb4 0xEFBFBF COLLATE utf8mb4_bin);
# 补充平面起始
SELECT (_utf8mb4 0xF0908080 COLLATE utf8mb4_bin);
# Unicode 标准上限
SELECT (_utf8mb4 0xF48FBFBF COLLATE utf8mb4_bin);
#
SELECT (_utf8mb4 0xEDA080 COLLATE utf8mb4_bin);
# 高代理起始
SELECT (_utf8mb4 0xEDA080 COLLATE utf8mb4_bin);
# 低代理结束
SELECT (_utf8mb4 0xEDBFBF COLLATE utf8mb4_bin);

# 非起始字节单独存在
--error 1300
SELECT (_utf8mb4 0x80 COLLATE utf8mb4_bin);

# 超出 Unicode 最大码点
--error 1300
SELECT (_utf8mb4 0xF4908080 COLLATE utf8mb4_bin);

# 'A' (U+0041) 被编码为 2字节
--error 1300
SELECT (_utf8mb4 0xC181 COLLATE utf8mb4_bin);


