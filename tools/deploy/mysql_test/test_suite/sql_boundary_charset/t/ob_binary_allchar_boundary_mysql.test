# owner: sanquan.qz
# owner group: sql1
# tags: charset, binary
# description:binary charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
SET NAMES binary;
set character_set_database = 'binary';
set character_set_server = 'binary';
set character_set_results = 'utf8mb4';
show character set where Charset = 'binary';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET binary;
use db1;
#  NULL 字符（ASCII 0）
SELECT (_binary 0x00);
#  单元分隔符 US (ASCII 31)
SELECT (_binary 0x1F);
#  空格 ' '
SELECT (_binary 0x20);
#  波浪号 '~'
SELECT (_binary 0x7E);
#  删除符 DEL
SELECT (_binary 0x7F);
#  欧元符号 €（实际映射依赖 binary 实现）
SELECT (_binary 0x80);
#  ÿ（带分音符的小写 y）
SELECT (_binary 0xFF);
#  单引号 '''（需注意 SQL 转义）
SELECT (_binary 0x27);
#  换行符 \n
SELECT (_binary 0x0A);

# 区分大小写,不区分大小写
SELECT
  (_binary 0x41) = (_binary 0x61),
  (_binary 0x41) = (_binary 0x61);
# 按二进制值比较结果
SELECT
  (_binary 0x80) < (_binary 0xFF);
# 应返回 'ÿ'（Unicode U+00FF）
SELECT CONVERT(_binary 0xFF USING utf8mb4);

--error 0,1051
drop table test_binary;
CREATE TABLE test_binary (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET binary) DEFAULT CHARSET=binary;
INSERT INTO test_binary (a) VALUES (_binary 0x80),(_binary 0x1F),(_binary 0x20),(_binary 0x7E),(_binary 0x7F),(_binary 0x80),(_binary 0xFF),(_binary 0x27),(_binary 0x0A);
select * from test_binary order by 1;
select hex(a) from test_binary order by 1;

