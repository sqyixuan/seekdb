### OB暂不支持。MYSQL支持。
--error 1064
CREATE TABLE `my_partitioned_table` (
    id INT NOT NULL,
    data VARCHAR(255) NOT NULL,
    PRIMARY KEY (id)
)
PARTITION BY RANGE (id) (
    PARTITION p1 VALUES LESS THAN (10) COMMENT '?????',
    PARTITION p2 VALUES LESS THAN (20) COMMENT '¤№',
    PARTITION p3 VALUES LESS THAN (30) COMMENT '?????',
    PARTITION p4 VALUES LESS THAN (40) COMMENT '??????',
    PARTITION p5 VALUES LESS THAN (50) COMMENT '????',
    PARTITION p6 VALUES LESS THAN (60) COMMENT '?????',
    PARTITION p7 VALUES LESS THAN (70) COMMENT ' !"#$%&\'()*+,-./',
    PARTITION p8 VALUES LESS THAN (80) COMMENT '0123456789:;<=>?',
    PARTITION p9 VALUES LESS THAN (90) COMMENT '@ABCDEFGHIJKLMNO',
    PARTITION p10 VALUES LESS THAN (100) COMMENT 'PQRSTUVWXYZ[\\]^_',
    PARTITION p11 VALUES LESS THAN (110) COMMENT 'abcdefghijklmno',
    PARTITION p12 VALUES LESS THAN (120) COMMENT 'pqrstuvwxyz{|}~',
    PARTITION p13 VALUES LESS THAN (130) COMMENT '?????????',
    PARTITION p14 VALUES LESS THAN (140) COMMENT '?????',
    PARTITION p15 VALUES LESS THAN (150) COMMENT '?????',
    PARTITION p16 VALUES LESS THAN (160) COMMENT '?????',
    PARTITION p17 VALUES LESS THAN (170) COMMENT '?????',
    PARTITION p18 VALUES LESS THAN (180) COMMENT '丂丄丅丌丒丟',
    PARTITION p19 VALUES LESS THAN (190) COMMENT '許體_TRIG_體'
);

