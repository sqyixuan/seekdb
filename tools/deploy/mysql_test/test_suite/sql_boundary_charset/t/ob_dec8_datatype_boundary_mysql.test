# owner group: sql1
# tags: charset, dec8
# description:dec8 charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前ňò集设置
SET NAMES dec8;
set character_set_database = 'dec8';
set character_set_server = 'dec8';
set character_set_results = 'utf8mb4';
show character set where Charset = 'dec8';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# ňò类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET dec8;
use db1;

--error 0,1051
drop table test_dec8;
CREATE TABLE test_dec8 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET dec8) DEFAULT CHARSET=dec8;

--error 0,1305
DROP PROCEDURE create_dec8;
delimiter //;
CREATE PROCEDURE create_dec8()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_dec8 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_dec8();

SELECT (CONVERT(_TIS620 0x00C8 USING dec8));
SELECT (CONVERT(_TIS620 0x00C8 USING UTF8));

--disable_result_log
SELECT _dec8 0x1A;
SELECT _dec8 0x7F;
SELECT _dec8 0x7A;
--enable_result_log

SELECT CHAR(0x1A);
SELECT CHAR(0x7F);
SELECT CHAR(0x7A);
SELECT CHAR(0x80);
SELECT CHAR(0xC8);

--error 0,1051
drop table char_table;
CREATE TABLE IF NOT EXISTS char_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_value CHAR(1) CHARACTER SET dec8
);

delimiter /;
CREATE PROCEDURE create_dec82()
BEGIN
DECLARE i int DEFAULT 128;
  WHILE i < 256 DO
    INSERT INTO char_table (char_value) VALUES (char(i USING dec8));
    set i = i + 1;
  END WHILE;
END;
/
delimiter ;/
call create_dec82();
SELECT id, CHAR_LENGTH(char_value) AS length, char_value FROM char_table;
SELECT (char(200 USING dec8));

SET sql_mode = '';
--ERROR 0,1051
DROP TABLE sample_table;

### OB与MYSQL不兼容。
CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET dec8,
    char_1 CHAR(1) CHARACTER SET dec8,
    char_255 CHAR(255) CHARACTER SET dec8,
    char_256 CHAR(256) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

INSERT INTO sample_table (char_0, char_1, char_255, char_256) VALUES
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'));
SELECT * FROM sample_table;

--ERROR 0,1051
DROP TABLE sample_table2;
--error 1074
CREATE TABLE sample_table2 (
    char_0 CHAR(0) CHARACTER SET dec8,
    char_1 CHAR(1) CHARACTER SET dec8,
    char_255 CHAR(255) CHARACTER SET dec8,
    char_257 CHAR(257) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

--ERROR 0,1051
DROP TABLE sample_table3;
--ERROR 1064
CREATE TABLE sample_table3 (
    char_0 NATIONAL CHAR(0) CHARACTER SET dec8,
    char_1 NATIONAL CHAR(1) CHARACTER SET dec8,
    char_255 NATIONAL CHAR(255) CHARACTER SET dec8,
    char_256 NATIONAL CHAR(256) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

--echo ### 使用NATIONAL
--ERROR 0,1051
DROP TABLE sample_table3;
CREATE TABLE sample_table3 (
    char_0 NATIONAL CHAR(0),
    char_1 NATIONAL CHAR(1),
    char_255 NATIONAL CHAR(255)
) DEFAULT CHARSET=dec8;
INSERT INTO sample_table3 (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, 'A'));
SELECT * FROM sample_table3;

--echo ### collation_name
--ERROR 0,1051
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    char_1 CHAR(1) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    char_255 CHAR(255) CHARACTER SET dec8 COLLATE dec8_bin
) DEFAULT CHARSET=dec8;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, '中'));
SELECT * FROM sample_table;

--echo ### SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
--ERROR 0,1051
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    char_1 CHAR(1) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    char_255 CHAR(255) CHARACTER SET dec8 COLLATE dec8_bin
) DEFAULT CHARSET=dec8;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, ' 中 '));
SELECT * FROM sample_table;
SELECT LENGTH(char_0),OCTET_LENGTH(char_0),CHAR_LENGTH(char_0) FROM sample_table;
SELECT LENGTH(char_1),OCTET_LENGTH(char_1),CHAR_LENGTH(char_1) FROM sample_table;
SELECT LENGTH(char_255),OCTET_LENGTH(char_255),CHAR_LENGTH(char_255) FROM sample_table;

--echo ### VARCHAR

SET sql_mode = '';
--ERROR 0,1051
DROP TABLE sample_table;

# gbk的varchar最大长度为524288，utf8和dec8的最大长度为262144
CREATE TABLE sample_table (
    varchar_0 VARCHAR(0) CHARACTER SET dec8,
    varchar_1 VARCHAR(1) CHARACTER SET dec8,
    varchar_262144 VARCHAR(262144) CHARACTER SET dec8,
    varchar_262145 VARCHAR(131071) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

INSERT INTO sample_table (varchar_0, varchar_1, varchar_262144, varchar_262145) VALUES
('', 'A', LPAD('', 262144, 'A'), LPAD('', 262145, 'B'));

--disable_result_log
SELECT * FROM sample_table;
--enable_result_log


--ERROR 0,1051
DROP TABLE sample_table2;
--ERROR 1074
CREATE TABLE sample_table2 (
    varchar_0 VARCHAR(0) CHARACTER SET dec8,
    varchar_1 VARCHAR(1) CHARACTER SET dec8,
    varchar_1048576 VARCHAR(1048577) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

--ERROR 0,1051
DROP TABLE sample_table2;
--ERROR 1074
CREATE TABLE sample_table2 (
    varchar_0 VARCHAR(0) CHARACTER SET dec8,
    varchar_1 VARCHAR(1) CHARACTER SET dec8,
    varchar_262144 VARCHAR(262144) CHARACTER SET dec8,
    varchar_262146 VARCHAR(262146000000) CHARACTER SET dec8
) DEFAULT CHARSET=dec8;

--echo ### 使用NATIONAL
--ERROR 0,1051
DROP TABLE sample_table3;
CREATE TABLE sample_table3 (
    varchar_0 NATIONAL VARCHAR(0),
    varchar_1 NATIONAL VARCHAR(1),
    varchar_262144 NATIONAL VARCHAR(262144)
) DEFAULT CHARSET=dec8;
INSERT INTO sample_table3 (varchar_0, varchar_1, varchar_262144) VALUES
('', 'A', LPAD('', 262144, 'A'));

--disable_result_log
SELECT * FROM sample_table3;
--enable_result_log

--echo ### SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
--ERROR 0,1051
DROP TABLE sample_table;

CREATE TABLE sample_table (
    varchar_0 VARCHAR(0) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    varchar_1 VARCHAR(1) CHARACTER SET dec8 COLLATE dec8_swedish_ci,
    varchar_262144 VARCHAR(262144) CHARACTER SET dec8 COLLATE dec8_bin
) DEFAULT CHARSET=dec8;

INSERT INTO sample_table (varchar_0, varchar_1, varchar_262144) VALUES
('', 'A', LPAD('', 262144, 'A'));
--disable_result_log
SELECT * FROM sample_table;
--enable_result_log
SELECT LENGTH(varchar_0),OCTET_LENGTH(varchar_0),CHAR_LENGTH(varchar_0) FROM sample_table;
SELECT LENGTH(varchar_1),OCTET_LENGTH(varchar_1),CHAR_LENGTH(varchar_1) FROM sample_table;
SELECT LENGTH(varchar_262144),OCTET_LENGTH(varchar_262144),CHAR_LENGTH(varchar_262144) FROM sample_table;

--echo ### BINARY
--ERROR 0,1051
DROP TABLE binary_test;
### OB无报错，MYSQL有报错。
CREATE TABLE binary_test (
    id INT AUTO_INCREMENT PRIMARY KEY,
    binary_0 BINARY(0),
    binary_1 BINARY(1),
    binary_255 BINARY(255),
    binary_256 BINARY(256)
) CHARSET=dec8;

INSERT INTO binary_test (binary_0, binary_1, binary_255, binary_256) VALUES
(BINARY(''),
 BINARY('A'),
 LPAD(('A'), 255, ('A')),
 LPAD(('A'), 256, ('A')));
SELECT * FROM binary_test;

SET sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

