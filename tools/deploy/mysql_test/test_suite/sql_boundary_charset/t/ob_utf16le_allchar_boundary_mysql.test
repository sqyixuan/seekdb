SELECT LPAD('丂', 16777215/2, '丂');
--enable_result_log

--disable_result_log
--ERROR 0,2020
SELECT LPAD('丂', 16777215/3, '丂');
--enable_result_log

--disable_result_log

SELECT (_utf16le '0x5C' COLLATE utf16le_general_ci );
SELECT (_utf16le '0x7C' COLLATE utf16le_general_ci );
SELECT (_utf16le '@ A-Z [ \ ] ^ _ ` a-z { | } ~' COLLATE utf16le_general_ci );

