# owner: sanquan.qz
# owner group: sql1
# tags: charset, utf16le
# description:utf16le charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
SET NAMES latin1;
set character_set_database = 'utf16le';
set character_set_server = 'utf16le';
set character_set_results = 'utf8mb4';
show character set where Charset = 'utf16le';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET utf16le;
use db1;

SELECT (_utf16le 0x0000 COLLATE utf16le_general_ci );

--disable_result_log
# 基本多文种平面
SELECT (_utf16le 0x0000 COLLATE utf16le_general_ci );
SELECT (_utf16le 0x0000 COLLATE utf16le_bin );

SELECT (_utf16le 0xD7FF COLLATE utf16le_general_ci );
SELECT (_utf16le 0xD7FF COLLATE utf16le_bin );

# BMP的补充
SELECT (_utf16le 0xE000 COLLATE utf16le_general_ci );
SELECT (_utf16le 0xE000 COLLATE utf16le_bin );

SELECT (_utf16le 0xFFFF COLLATE utf16le_general_ci );
SELECT (_utf16le 0xFFFF COLLATE utf16le_bin );

# 补充平面
SELECT (_utf16le 0x10000 COLLATE utf16le_general_ci );
SELECT (_utf16le 0x10000 COLLATE utf16le_bin );

SELECT (_utf16le 0x10FFFF COLLATE utf16le_general_ci );
SELECT (_utf16le 0x10FFFF COLLATE utf16le_bin );

SELECT (_utf16le '0xD7FF\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE utf16le_general_ci);
SELECT (_utf16le '丂\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE utf16le_general_ci);

