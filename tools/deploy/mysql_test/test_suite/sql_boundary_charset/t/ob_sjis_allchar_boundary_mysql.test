# owner: sanquan.qz
# owner group: sql1
# tags: charset, sjis
# description:sjis charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
SET NAMES sjis;
set character_set_database = 'sjis';
set character_set_server = 'sjis';
set character_set_results = 'utf8mb4';
show character set where Charset = 'sjis';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET sjis;
use db1;

SELECT (_sjis 0x0000 COLLATE sjis_japanese_ci );

#1. 有效单字节字符（ASCII 范围）
# ASCII 最后一个有效字符
SELECT _sjis 0x7F COLLATE sjis_japanese_ci;
# 半角片假名起始字符
SELECT _sjis 0xA1 COLLATE sjis_japanese_ci;

#2. 有效双字节字符（常规范围）
# 第一个合法双字节字符
SELECT _sjis 0x8140 COLLATE sjis_japanese_ci;
# 第一字节 0x9F 最大合法值
SELECT _sjis 0x9FFC COLLATE sjis_japanese_ci;
# 第一字节 0xE0 最小合法值
SELECT _sjis 0xE040 COLLATE sjis_japanese_ci;
# 第二字节 0x7E 有效结束值
SELECT _sjis 0xFC7E COLLATE sjis_japanese_ci;
# 第二字节 0x80 有效起始值
SELECT _sjis 0xFC80 COLLATE sjis_japanese_ci;

# 3. 边界值测试
--error 1300
SELECT _sjis 0x80 COLLATE sjis_japanese_ci;
# 半角片假名结束字符
SELECT _sjis 0xDF COLLATE sjis_japanese_ci;
--error 1300
SELECT _sjis 0xFD40 COLLATE sjis_japanese_ci;
# 第二字节 0x3F 无效
--error 1300
SELECT _sjis 0x813F COLLATE sjis_japanese_ci;
# 第二字节 0x7F 无效
--error 1300
SELECT _sjis 0x817F COLLATE sjis_japanese_ci;
SELECT _sjis 0xD7 COLLATE sjis_japanese_ci;

# 5. 多字节组合测试
# 连续合法双字节
SELECT _sjis 0x81408140 COLLATE sjis_japanese_ci;
# 第二字节 0x80 有效
SELECT _sjis 0x8180 COLLATE sjis_japanese_ci;
# 第二字节 0xFF 可能无效（依具体实现）
--error 1300
SELECT _sjis 0xFCFF COLLATE sjis_japanese_ci;

# 6. 错误字节长度测试
# 不完整双字节
--error 1300
SELECT _sjis 0x81 COLLATE sjis_japanese_ci;
# 三字节组合
SELECT _sjis 0x814041 COLLATE sjis_japanese_ci;

SELECT (_sjis '0x7F\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE sjis_japanese_ci);
SELECT (_sjis '啊\b\f\n\r\t\\\'\"\\_%\0\Z' COLLATE sjis_japanese_ci);

