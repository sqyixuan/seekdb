    varchar_0 VARCHAR(0) CHARACTER SET tis620,
    varchar_1 VARCHAR(1) CHARACTER SET tis620,
    varchar_1048577 VARCHAR(1048577) CHARACTER SET tis620
) DEFAULT CHARSET=tis620;

--ERROR 0,1051
DROP TABLE sample_table2;
--ERROR 1074
CREATE TABLE sample_table2 (
    varchar_0 VARCHAR(0) CHARACTER SET tis620,
    varchar_1 VARCHAR(1) CHARACTER SET tis620,
    varchar_262144 VARCHAR(262144) CHARACTER SET tis620,
    varchar_262146 VARCHAR(262146000000) CHARACTER SET tis620
