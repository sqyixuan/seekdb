--echo #### CAST 各种类型数据与JSON转换。
SELECT CAST("123" AS JSON);
SELECT CAST(null AS JSON);
--ERROR 3141
SELECT CAST('测试数据' AS JSON);
--ERROR 3141
SELECT CAST('Hello World' AS JSON);
--ERROR 3141
SELECT CAST('ASCII Text' AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xA55C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xB35C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xBB5C USING big5) AS JSON);
--ERROR 3141
SELECT CAST(CONVERT(0xA87C USING big5) AS JSON);
--ERROR 3141
SELECT CAST('???????????????????' AS JSON);
SELECT CAST(123 AS JSON);
SELECT CAST(123.45 AS JSON);
SELECT CAST(TRUE AS JSON);
SELECT CAST(FALSE AS JSON);
SELECT CAST(NULL AS JSON);
SELECT CAST(X'01AF' AS JSON);
SELECT CAST(0x01af AS JSON);
SELECT CAST(X'0FFF' AS JSON);
SELECT CAST(0xaaF AS JSON);

