    id INT AUTO_INCREMENT PRIMARY KEY,
    json_data JSON
) DEFAULT CHARSET=tis620;

INSERT INTO json_test (json_data) VALUES (NULL);
INSERT INTO json_test (json_data) VALUES ('{}');
--error 1292,1265
INSERT INTO json_test (json_data) VALUES (REPEAT('"key": "value",', 16777215 / 20) || '{"key": "value"}');
SELECT * FROM json_test;

