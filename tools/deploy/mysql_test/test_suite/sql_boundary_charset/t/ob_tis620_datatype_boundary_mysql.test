# owner group: sql1
# tags: charset, tis620
# description:tis620 charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前ก๊า集设置
SET NAMES tis620;
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# ก๊า类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET tis620;
use db1;

--error 0,1051
drop table test_tis620;
CREATE TABLE test_tis620 (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET tis620) DEFAULT CHARSET=tis620;

--error 0,1305
DROP PROCEDURE create_tis620;
delimiter //;
CREATE PROCEDURE create_tis620()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_tis620 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_tis620();

SELECT (CONVERT(_TIS620 0x00C8 USING tis620));
SELECT (CONVERT(_TIS620 0x00C8 USING UTF8));

--disable_result_log
SELECT _tis620 0x1A;
SELECT _tis620 0x7F;
SELECT _tis620 0x7A;
--enable_result_log

SELECT CHAR(0x1A);
SELECT CHAR(0x7F);
SELECT CHAR(0x7A);
SELECT CHAR(0x80);
SELECT CHAR(0xC8);

--error 0,1051
drop table char_table;
CREATE TABLE IF NOT EXISTS char_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_value CHAR(1) CHARACTER SET tis620
);

delimiter /;
CREATE PROCEDURE create_tis6202()
BEGIN
DECLARE i int DEFAULT 128;
  WHILE i < 256 DO
    INSERT INTO char_table (char_value) VALUES (char(i USING tis620));
    set i = i + 1;
  END WHILE;
END;
/
delimiter ;/
call create_tis6202();
SELECT id, CHAR_LENGTH(char_value) AS length, char_value FROM char_table;
SELECT (char(200 USING tis620));

SET sql_mode = '';
--ERROR 0,1051
DROP TABLE sample_table;

### OB与MYSQL不兼容。
CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET tis620,
    char_1 CHAR(1) CHARACTER SET tis620,
    char_255 CHAR(255) CHARACTER SET tis620,
    char_256 CHAR(256) CHARACTER SET tis620
) DEFAULT CHARSET=tis620;

INSERT INTO sample_table (char_0, char_1, char_255, char_256) VALUES
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'));
SELECT * FROM sample_table;

--ERROR 0,1051
DROP TABLE sample_table2;
--error 1074
CREATE TABLE sample_table2 (
    char_0 CHAR(0) CHARACTER SET tis620,
    char_1 CHAR(1) CHARACTER SET tis620,
    char_255 CHAR(255) CHARACTER SET tis620,
    char_257 CHAR(257) CHARACTER SET tis620
) DEFAULT CHARSET=tis620;

--ERROR 0,1051
DROP TABLE sample_table3;
--ERROR 1064
CREATE TABLE sample_table3 (
    char_0 NATIONAL CHAR(0) CHARACTER SET tis620,
    char_1 NATIONAL CHAR(1) CHARACTER SET tis620,
    char_255 NATIONAL CHAR(255) CHARACTER SET tis620,
    char_256 NATIONAL CHAR(256) CHARACTER SET tis620
) DEFAULT CHARSET=tis620;

--echo ### 使用NATIONAL
--ERROR 0,1051
DROP TABLE sample_table3;
CREATE TABLE sample_table3 (
    char_0 NATIONAL CHAR(0),
    char_1 NATIONAL CHAR(1),
    char_255 NATIONAL CHAR(255)
) DEFAULT CHARSET=tis620;
INSERT INTO sample_table3 (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, 'A'));
SELECT * FROM sample_table3;

--echo ### collation_name
--ERROR 0,1051
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET tis620 COLLATE tis620_thai_ci,
    char_1 CHAR(1) CHARACTER SET tis620 COLLATE tis620_thai_ci,
    char_255 CHAR(255) CHARACTER SET tis620 COLLATE tis620_bin
) DEFAULT CHARSET=tis620;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, '中'));
SELECT * FROM sample_table;

--echo ### SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
SET sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
--ERROR 0,1051
DROP TABLE sample_table;

CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET tis620 COLLATE tis620_thai_ci,
    char_1 CHAR(1) CHARACTER SET tis620 COLLATE tis620_thai_ci,
    char_255 CHAR(255) CHARACTER SET tis620 COLLATE tis620_bin
) DEFAULT CHARSET=tis620;

INSERT INTO sample_table (char_0, char_1, char_255) VALUES
('', 'A', LPAD('', 255, ' 中 '));
SELECT * FROM sample_table;
SELECT LENGTH(char_0),OCTET_LENGTH(char_0),CHAR_LENGTH(char_0) FROM sample_table;
SELECT LENGTH(char_1),OCTET_LENGTH(char_1),CHAR_LENGTH(char_1) FROM sample_table;
SELECT LENGTH(char_255),OCTET_LENGTH(char_255),CHAR_LENGTH(char_255) FROM sample_table;

--echo ### VARCHAR

SET sql_mode = '';
--ERROR 0,1051
DROP TABLE sample_table;

# gbk的varchar最大长度为524288，utf8和tis620的最大长度为262144
CREATE TABLE sample_table (
    varchar_0 VARCHAR(0) CHARACTER SET tis620,
    varchar_1 VARCHAR(1) CHARACTER SET tis620,
    varchar_262144 VARCHAR(262144) CHARACTER SET tis620,
    varchar_262145 VARCHAR(131071) CHARACTER SET tis620
) DEFAULT CHARSET=tis620;

INSERT INTO sample_table (varchar_0, varchar_1, varchar_262144, varchar_262145) VALUES
('', 'A', LPAD('', 262144, 'A'), LPAD('', 262145, 'B'));

--disable_result_log
SELECT * FROM sample_table;
--enable_result_log


--ERROR 0,1051
DROP TABLE sample_table2;

