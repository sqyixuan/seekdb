# owner: sanquan.qz
# owner group: sql1
# tags: charset, tis620
# description:tis620 charset case
# author:yanyi.yn

purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
SET NAMES tis620;
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 字符串文本 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET tis620;
use db1;

SELECT (_tis620 0x0000 COLLATE tis620_thai_ci );

--disable_result_log
