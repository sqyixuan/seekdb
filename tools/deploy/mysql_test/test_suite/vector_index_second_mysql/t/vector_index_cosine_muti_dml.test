insert into t1(c1,c2,c3) values(0, '[-0.277237, -304120, 0.637868]', '[137017, 0.78021, -41681.94, -6168.722]');
create table t2(c1 double, c2 vector(3), c3 vector(4),vector index idx1(c2) with (distance=cosine, type=hnsw));
insert into t2(c1,c2,c3) select cosine_distance(t.c2,t1.c2),t1.c2,t.c3+t1.c3 from t join t1 on t.c1=t1.c1 where t.c1%2=0 and t1.c1%2=0 order by cosine_distance(t1.c2, '[-0.253108, -0.613931, -874511]') approx limit 10;
select * from t2;
select * from t2 order by cosine_distance(c2, '[-0.253108, -0.613931, -874511]') approx limit 1;
delete from t2 where c2 ='[-0.892018,929517,0.57756]';
select t.c1,t2.c2 from t join t2 where t.c2=t2.c2;
select t1.c1,t2.c2 from t1 join t2 where t1.c2=t2.c2;

