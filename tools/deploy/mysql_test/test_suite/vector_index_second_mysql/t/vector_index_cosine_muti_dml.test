DELIMITER //;
create procedure mytest(in id int)
begin
    declare t_vec double;
    declare t1_vec double;
    select cosine_distance(c2,'[-0.884688, 98861.24, -535325]') into t_vec from t where c1<id order by cosine_distance(c2,'[-0.884688, 98861.24, -535325]') approx limit 1;
    select cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') into t1_vec from t1 where c1<id order by cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') approx limit 1;
    if t_vec + t1_vec < 1 then
        update t1 set c3='[1,1,1,1]' where c1<id order by cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') limit 1;
    else
        insert into t1 values((select count(*) + 1 from t1), '[0,0,0]', '[0,0,0,0]');
    end if;
end //
