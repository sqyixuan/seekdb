create table t(c1 int, c2 vector(2001), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/vector_data_dim_2001.inc

select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) approx limit 3;
select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) limit 3;
delete from t partition(p1) order by cosine_distance(c2, @vdata) limit 1;
select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) approx limit 1;
update t partition(p0) set c2=@vdata where c1<3 order by cosine_distance(c2, @vdata) limit 2;
select * from t partition(p0) where c1<1000 order by cosine_distance(c2, @vdata) approx limit 3;
select * from t partition(p0) where c1<1000 order by cosine_distance(c2, @vdata) limit 3;
drop index idx1 on t;
truncate t;
--source mysql_test/test_suite/vector_index_second_mysql/include/vector_data_dim_2001.inc

create vector index idx1 on t(c2) with (distance=cosine,type=hnsw);
select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) approx limit 3;
select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) limit 3;
delete from t partition(p1) order by cosine_distance(c2, @vdata) limit 1;
select * from t partition(p1) where c1<1000 order by cosine_distance(c2, @vdata) approx limit 1;

--echo
--echo
--echo "=========================================== 4096 vector index ==========================================="
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
