#alter table t modify column c1 int before c3;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c1 int after c3;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t add c1 int auto_increment primary key;
--error 1063 # Incorrect column specifier for column 'c2'
alter table t add c2 vector(3) auto_increment;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t drop primary key;
--error 1068 # Multiple primary key defined
alter table t add primary key(c1);
--error 1068 # Multiple primary key defined
alter table t add primary key(c2);
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 vector(4);
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 array(float);
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 float[];
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c1 double;
alter table t modify column c1 int;
--error 1064
alter table add column a2 vector(3) as (c2 + "[1,1,1]") stored;
--error 1064
alter table add column a3 int as (c1 + cosine_distance(c3, '[1,1,1,1]')) stored;
--error 1064
alter table drop column c3, drop column c2, add column a1 int primary key;
truncate t;
drop table t;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw));
# 插入50条数据
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

