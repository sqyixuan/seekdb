--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

# 435变成 online ddl
alter table t add a1 vector(3) first;
# 435变成 online ddl
alter table t add a2 vector(3) before c1;
# 435变成 online ddl
alter table t add a3 vector(3) after c1;
# 435变成 online ddl
alter table t add b1 int first;
# 435变成 online ddl
alter table t add b2 int before c1;
# 435变成 online ddl
alter table t add b3 int after c1;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 vector(3) first;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 vector(3) before c1;
#--error 1235 # Run this DDL operation on table with fulltext/multivalue/vector index. not supported
#alter table t modify column c2 vector(3) after c3;
