drop index idx1 on t;
alter table t partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (maxvalue));
#--error 1235 # create index on vector or array column is not supported
#create index idx1 on t(c2) with (distance=cosine, type=hnsw);
create vector index idx1 on t(c2) with (distance=cosine, type=hnsw);
alter table t drop partition p1;
delete /*+enable_parallel_dml parallel(2) index(t idx1) */ from t partition(p3);
