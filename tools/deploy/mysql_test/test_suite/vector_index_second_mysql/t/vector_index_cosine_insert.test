--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_2.inc

create table t1(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--error 1235
insert /*+ direct(true, 0, 'inc') enable_parallel_dml(3)*/ into t1 select * from t partition(p0) order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 50;
--error 1235
insert /*+ direct(false, 0, 'inc') enable_parallel_dml(4)*/ into t1 select * from t partition(p1) order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 50;
--error 1235
insert /*+ direct(true, 0, 'full') enable_parallel_dml(5)*/ into t1 select * from t partition(p2) order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 50;
--error 1235
insert /*+ direct(false, 0, 'full') enable_parallel_dml(6)*/ into t1 select * from t partition(p3) order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 50;
select t1.c1 from t,t1 where t.c3=t1.c3 order by cosine_distance(t1.c2, '[0.179629, 430819, -65217.32]') approx limit 1;

--echo
--echo
--echo "=========================================== insert into view ==========================================="
--disable_warnings
drop table if exists t;
drop view if exists v;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

create view v (a1,a2) as select c1,c2 from t partition(p0,p1) where c1<=105 order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 20;
# bug
select c1,a2 from t,v where t.c1=v.a1 and v.a1<5 order by cosine_distance(c2, '[-823198, -0.217028, 93069.8]') approx limit 3;
select c1,a2 from t,v where t.c1=v.a1 and v.a1<5 order by cosine_distance(c2, '[-823198, -0.217028, 93069.8]') limit 3;

--disable_warnings
drop table if exists t;
drop view if exists v;
drop view if exists v1;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

create view v (a1,a2) as select c1,c2 from t partition(p0,p1) where c1<=105 order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 20;
select count(*) from v;
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_2.inc

select count(*) from v;
select a1,a2 from v order by cosine_distance(a2, '[-394438, 781465, 0.472924]') approx limit 5;
select a1,a2 from v order by cosine_distance(a2, '[-394438, 781465, 0.472924]') limit 5;

create or replace view v1(b1,b2) as select a1,a2 from v where a1<10 order by cosine_distance(a2, '[-394438, 781465, 0.472924]') approx limit 5;
select a1,b2 from v,v1 where v.a1 < 5 order by cosine_distance(v1.b2, '[-394438, 781465, 0.472924]') approx limit 3;
select a1,b2 from v,v1 where v.a1 < 5 order by cosine_distance(v1.b2, '[-394438, 781465, 0.472924]') limit 3;
create or replace view v(a1,a2) as select c1,c2 from t partition(p0) where c1<=105 and c1 >3 order by cosine_distance(c2, '[0.179629, 430819, -65217.32]') approx limit 20;
select a1,b2 from v,v1 where v.a1 < 5 order by cosine_distance(v1.b2, '[-394438, 781465, 0.472924]') approx limit 3;
select a1,b2 from v,v1 where v.a1 < 5 order by cosine_distance(v1.b2, '[-394438, 781465, 0.472924]') limit 3;
select a1,b2 from v,v1 where v.a1 < 5 order by cosine_distance(v1.b2, '[-394438, 781465, 0.472924]') limit 3;
