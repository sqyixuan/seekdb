--exec rm -rf '/data/1/test.file1'
select * into outfile '/data/1/test.file1' from t;
create table t1 like t;
--error 1235 # Not supported feature or function
load data /*+ direct(true, 100, 'inc') parallel(10)*/ infile '/data/1/test.file1' into table t1;
select count(*) from t join t1 on t.c1=t1.c1 order by cosine_distance(t1.c2, '[-43769.22, 44633.55, 57298]') approx limit 3;
select count(*) from t join t1 on t.c1=t1.c1 order by cosine_distance(t1.c2, '[-43769.22, 44633.55, 57298]') limit 3;

