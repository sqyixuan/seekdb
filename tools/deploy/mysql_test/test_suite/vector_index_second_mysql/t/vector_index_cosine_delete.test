# owner: yangjiali.yjl
# owner group: shenzhen
# description: vector index cosine delete
# tags: vector index
# author: dangertao.det

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

alter system ob_vector_memory_limit_percentage=30;
select sleep(5);

--echo
--echo
--echo "=========================================== delete standard ==========================================="
--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

select * from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;
select * from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') limit 3;
delete from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') limit 3;
select * from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;
select * from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') limit 3;
create table t1(a1 int, a2 vector(3));
insert into t1 select c1,c2 from t where c1<100;
delete t from t join t1 on t.c1=t1.a1 where c1<100;
select * from t1;
select * from t;
select * from t left join t1 on t.c1%2=0 order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;
select * from t right join t1 on t.c1%2=0 order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;
select * from t inner join t1 on t.c1%2=0 order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;
select * from t full join t1 on t.c1%2=0 order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 3;

--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

create table t1(a1 int, a2 vector(3));
insert into t1 select c1,c2 from t where c1<100;
delete t,t1 from t,t1 where t.c1=t1.a1;
select * from t order by cosine_distance(c2, '[-823198, -0.217028, 93069.8]') approx limit 3;
delete from t;
--source mysql_test/test_suite/vector_index_second_mysql/include/insert_common_data_1.inc

insert into t1 select c1,c2 from t where c1<100;
delete from t,t1 using t,t1 where t.c1=t1.a1;
select * from t order by cosine_distance(c2, '[-823198, -0.217028, 93069.8]') approx limit 3;
alter system set ob_vector_memory_limit_percentage =0;