INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--d62bcb5d34fd7706942f5a89a64c5955bcf3b23ceb3e8d95c1934ba0588ee047','"敦煌拨疙瘩":"敦煌拨疙瘩是西北地区的传统小吃，以其筋道、爽口的口感和多样的食用方式受到人们的喜爱。这种面食在敦煌小吃一条街随处可见，不仅本地人常吃，还吸引了大量游客。拨疙瘩有多种口味，如鸡肉、兔肉、鸡珍、红烧肉等，适合各种口味的人群。其制作方法简单，因此也被民间称为“懒汉饭”。虽然外观可能不太吸引人，但其口感黏而不粘，吃上去有劲道，鲜美而不腻。总体来说，拨疙瘩是敦煌地方风味小吃系列中不可或缺的一部分。"

