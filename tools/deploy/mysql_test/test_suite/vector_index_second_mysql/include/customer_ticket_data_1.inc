INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--c668a1f15852c8823e5586ed391854c1d63a23e18cb85fab2c8edd4bfcb997dd','"羊肉粉汤":"羊肉粉汤是敦煌的传统小吃，以其独特的口感和滋补效果受到人们的喜爱。该美食选用敦煌本地饲养的膘肥体壮羯羊，经过宰杀、洗净和切块后，放入清水锅中煮熟。在煮的过程中，会加入各种香料如生姜、胡椒、花椒、桂皮等，使汤底味道醇厚。食用时，将熟肉和凉粉放入碗中，再舀入沸汤，撒上香菜、韭菜和葱等，呈现出红黄绿白的多彩色泽，香味扑鼻。这道菜不仅口感香辣爽口、肥而不腻，还具有滋补、发热和祛寒的功效。",','[-0.0957452,1.37384,-0.330819,0.198102,-0.744363,-2.10899,0.760985,0.0532562,-0.206353,0.0471318,0.533787,1.0016,-2.01197,0.122571,0.191829,0.144585,-0.656125,-0.908535,0.301676,-0.691077,-1.17101,0.648513,-0.858065,0.292605,-0.3328,0.0932798,-0.523323,-0.104188,0.770855,-0.35022,0.577616,0.244997,-0.621066,-1.07915,-0.313613,-0.908259,-0.832883,-0.492138,-0.670334,0.969727,0.955833,-0.775124,0.627169,0.83944,0.0102174,-0.306293,-0.84284,-0.579044,-0.621898,-0.215775,0.458023,0.234252,1.32128,-1.36441,-0.889532,0.393714,0.759647,-0.0497888,-1.51727,0.294982,0.0277546,0.252741,-0.0331411,-0.820887,-0.728689,1.1793,0.756343,0.407603,-0.90765,-0.67379,-1.22371,0.408974,0.576934,-0.630643,-0.98412,0.48562,0.0433441,0.289826,1.42239,1.17254,0.0654593,-0.389408,-0.686589,0.951054,1.02055,-0.764973,-0.484638,-0.289365,0.968253,-1.8211,0.631527,0.261455,0.436354,-1.12174,-0.729032,-0.520663,-0.882484,0.84718,1.18455,-0.683072,-0.183397,0.745498,0.0246123,-1.17171,0.594903,-0.394517,0.261964,0.89642,0.0987804,0.196274,1.15207,0.849828,-0.558961,-0.445499,0.517997,-1.81045,-0.279499,-0.597137,0.611962,0.405896,-0.123403,0.0632746,-0.487689,-0.0390724,-0.18129,0.203199,0.534402,0.810933,-0.736218,-0.266325,0.449889,0.151559,-0.405051,-0.685022,0.272359,-1.13733,1.37089,0.646969,0.242504,-1.00878,0.376649,0.0340519,-0.620985,-0.751507,1.11759,-1.46398,1.43717,-0.168313,-0.62317,-0.879047,0.824751,0.28972,0.670021,-1.16073,-0.751942,-0.0426567,1.61817,0.41001,1.55819,0.656884,1.43082,-0.00952339,0.605907,0.553538,-0.372777,-0.420238,0.262257,0.739016,-0.9274,1.01884,0.602594,-1.22196,-0.530871,0.728851,1.2718,0.361311,1.17565