INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--01011e3d530b5bc228acf0fae16c2a71a30617ba7cdfbba0910030c1958f9906','"敦煌杏皮水":"敦煌杏皮水是敦煌地区的特色饮料，以李广杏为原料，口感介于酸梅汤与柔和之间，具有物美价廉的特点，不仅好喝，还具有解暑效果。",

"胡杨焖饼":"胡杨焖饼是敦煌的传统美食，以其独特的芳香和风味深受人们喜爱。这道菜主要由羊肉和面条在高压锅中压制而成，羊肉鲜香可口，嚼劲十足，而面条则入味且美味。在敦煌，有很多餐馆提供这道菜，如“沙漠胡杨焖饼”和“大漠胡杨焖饼”，都是当地人常去的餐馆。",','[0.246988,1.24859,-0.677243,0.146262,-0.311344,-2.23412,0.0933809,-0.180473,-0.332734,0.00678881,0.173484,0.819762,-1.20367,-0.0209154,0.620872,0.711488,-0.520277,-1.28475,-0.058343,-0.791937,-0.907419,0.863542,-1.49944,-0.451972,-0.389728,0.16516,-0.728526,-0.211189,0.514202,0.0641382,0.799116,0.525757,0.48153,-1.12647,-0.242908,-0.907191,-1.3266,-1.19494,-0.791978,0.88441,0.429541,0.172617,0.262651,0.30694,-0.342697,-0.824827,-0.689936,-0.721435,-1.02907,0.503314,0.63879,-0.372649,0.630177,-1.39261,-0.0985736,-0.171381,-0.0485076,-0.774675,-2.82793,0.122732,-0.0674614,0.225718,0.630353,0.194382,-0.5098,1.49066,0.957175,1.0989,-1.61987,-0.248399,-0.714081,0.217623,0.540911,0.0666525,-1.18362,0.511201,-0.168003,0.202104,0.622548,0.824051,0.429038,-1.30579,0.0969014,0.51888,-0.249829,0.76067,-0.855248,-0.166759,0.898192,-2.06358,0.246062,-0.0734829,0.64001,-1.80186,-0.455471,0.464484,-0.403747,-0.23484,1.11767,-0.572071,-0.521731,0.81907,0.747534,-0.928245,1.07084,-0.0196495,0.771218,0.79672,1.00311,0.577052,1.07276,-0.117988,-0.718111,-0.460404,0.350484,-1.33015,-0.62437,-1.11201,0.559014,0.670872,-0.156439,1.73632,-0.377008,-0.0463581,0.471107,0.44364,0.823512,1.49334,0.157022,0.162793,1.15663,-0.209515,-0.642032,-0.108673,0.161208,-0.700359,1.36939,0.0726416,0.319608,-0.599679,0.556884,0.448949,-0.27347,-0.6463,1.75554,-1.74837,1.47076,0.125288,-0.0484522,-0.956683,1.3784,0.68269,0.665927,-1.11044,-0.365728,-1.31306,2.24666,0.920804,1.51875,-0.422029,0.266044,-0.468465,0.126501,-0.617634,-0.892993,-0.820732,0.240392,-0.386665,-0.596129,0.438766,0.201162,-0.111667,0.739912,0.469586,1.24095,-0.269869,0.770658,0.388556,-0.492499,-0.15337,-1.66426,-0.944375,0.598253,-0.179667,0.760092,0.502069,-0.152208,0.620496,0.350666,-0.0534711,-0.43201,-0.124386,1.06667,0.124946,0.0610751,0.541756,1.3051,-0.449541,-0.776562,-0.947157,0.677382,1.16641,