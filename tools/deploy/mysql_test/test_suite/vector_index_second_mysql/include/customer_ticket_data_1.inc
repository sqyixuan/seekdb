INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--df51ca66835784e4e4fdcde9754b7417e2614143cea35ed216faad2301f5d60c','"晒腰腿":{"时间":"农历六月初六","地点":"鸣沙山","简介":"晒腰腿是敦煌民间的一种习俗，来源于鸣沙山的热沙浴具有治疗风湿性关节炎的奇效。每年这时，凡有腰腿病患者，备上乌鸡汤个老黄酒，在正午以后，来到鸣沙山下喝汤，饮酒，让身体在沙中热敷3小时左右以求达到治疗效果。"},

	"中秋节":{"时间":"农历八月十五","地点":"敦煌市","简介":"不同于其他地区的中秋习俗，敦煌民间又有用锅盔献月亮、馈赠亲友的奇异习俗。中秋节这天晚上，妇女们要在庭院正中摆好桌凳，把画有民俗图案锅盔与西瓜、月饼一起有序地献在供桌上，然后燃香三柱，向月亮叩头祈福。"},','[0.395349,0.371625,-1.52733,0.135113,-0.854734,-2.28251,1.0226,0.121466,-1.64362,0.555811,0.776639,1.66877,-0.833029,-0.204604,1.43492,-0.0200782,0.64301,-1.04686,0.478346,-0.892563,-1.03584,-0.190542,-0.0404182,0.666727,-0.973244,-0.212339,-0.315577,0.195959,1.50111,0.168673,0.797222,0.229438,0.545415,-0.52816,-0.780791,-1.26028,-0.236337,-0.0131086,-1.22761,0.892815,0.0154321,-0.222046,0.932485,0.961154,-0.269869,-0.995513,0.194389,-1.20832,-0.745103,-0.567212,-0.236426,-0.663035,1.1196,-0.55941,-0.191692,0.550243,0.652025,-0.456745,-2.88259,-1.33292,-0.517868,-0.307948,-0.262256,-0.361304,-0.0986674,1.78373,0.736046,0.514925,-0.719363,-1.11459,-0.91815,-0.29253,0.266396,-1.24072,-1.23991,0.25452,-0.0214774,-0.437313,1.13035,-0.135808,0.807492,-0.74444,0.09323,0.537083,-0.241036,0.905015,-0.87231,0.9886,0.593272,-2.48767,0.655267,0.0614651,-0.633439,-1.06849,-0.1293,-0.0492736,-0.871255,-0.047443,0.323104,-0.111093,-0.000702806,0.281813,-0.0871719,-0.709349,0.517065,-0.324691,1.18593,0.904768,0.0756639,0.254304,1.09549,1.08178,-1.1723,-1.38495,0.556173,-0.435967,-0.47555,-1.70698,-0.0805205,-0.143086,-0.597733,1.16567,-0.948877,-0.45663,-0.487917,0.922006,1.10923,1.02367,-0.802867,0.601961,1.67729,-0.699349,-0.231348,-0.857394,0.686898,-0.889161,1.14996,0.696228,0.387314,-0.939162,0.320917,0.221405,-0.151138,-0.999935,1.20874,-1.05451,0.707844,-1.12564,-0.307489,-0.694525,0.770596,-0.276556,0.719103,-0.446935,-0.897505,-0.579493,0.865623,1.32986,1.55866,-0.57299,1.24508,1.02544,-0.686289,-0.39707,0.0525953,0.43014,-0.406823,1.03326,-0.768683,1.31083,0.767896,-1.15649,0.498872,-0.419297,1.24895,0.106808,1.00455,0.101398,-0.150759,-0.684425,-0.439165,-1.01,-0.0335906,0.661678,0.32341,0.358414,0.32767,0.240527,0.668839,-0.00280729,-0.890242,-0.289259,0.698276,0.60155,0.875692,0.0242286,-0.132794,-1.23553,-0.42052,-0.334417,-0