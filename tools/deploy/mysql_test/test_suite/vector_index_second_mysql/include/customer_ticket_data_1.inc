INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--1764b55f5987ead17f7d0aee0bdc5db4513e25c67e62b5184b0e92ca3d809c54','"敦煌酿皮":"敦煌酿皮是敦煌地区的传统特色小吃，冷热皆宜，尤其在夏季深受人们喜爱。这种小吃是用面粉制作的，经过特定的加工工艺，包括洗揉和蒸熟，形成半透明、颤抖悠长的饼状。刚出锅的酿皮看起来晶莹黄亮，光洁如玉，切成长条后拌上佐料，口感酸辣爽口、柔韧光滑。因其独特的制作工艺和口感，酿皮在敦煌当地深受人们喜爱，成为一道风味独特的美食。",','[-0.191498,1.78327,-0.506132,0.348316,-0.597272,-1.20083,-0.405449,0.210615,-0.144443,-0.0754333,0.217054,1.40922,-1.46374,-0.320376,0.815823,0.909052,-0.599858,-0.85707,0.107608,-0.176038,-1.2532,0.405377,-0.744346,-0.491811,-1.15886,-0.258506,-0.396018,0.0785504,0.545438,-0.762318,0.734203,0.287085,-0.184924,-1.18339,0.00438069,-0.132401,-0.979647,-0.401531,-0.409676,0.653347,0.856066,-0.211487,0.477947,0.47235,-0.447564,-0.316358,-0.948994,-0.60243,-0.677577,0.196329,0.571614,0.562947,0.491708,-1.56133,-0.623287,0.454402,-0.0240866,-1.03012,-2.01059,-0.411922,-0.0960229,0.886601,0.4951,0.163153,-0.440049,0.794287,0.624538,-0.0906224,-1.42503,0.473924,-0.841306,0.799779,0.0362597,-0.123104,-1.2044,0.363774,-0.772841,0.765447,1.44033,0.804948,0.346591,-0.935342,0.080797,0.888738,0.271657,0.646744,-1.18683,0.360244,0.367653,-1.79477,0.444862,0.361559,0.780795,-0.999951,-0.572509,0.321679,-0.907049,0.464418,0.995108,-0.620372,-0.139585,0.947194,0.802881,-1.41864,1.13809,-0.398929,0.454018,1.50342,1.22187,0.189935,1.29773,0.460069,-0.792372,-0.508924,0.661179,-1.60092,-0.723819,-0.44568,0.903953,0.343035,-0.745432,1.0294,-0.764439,0.259576,-0.142107,-0.0899226,0.920046,0.904,-0.6427,0.823231,1.66635,0.0398139,-0.48666,-0.649892,-0.244098,-0.159498,0.63662,0.447026,-0.179796,-0.795463,0.167852,0.252534,-0.229715,-0.748197,1.17804,-2.50212,1.29774,-0.165107,0.0885903,-0.438413,1.11301,1.01989,0.448553,-1.27693,0.249024,-1.04595,0.80425,0.634778,1.2055,0.588124,0.947095,-0.0241508,0.12314,0.723971,-0.427224,-0.533274,-0.0914408,0.651034,-0.856926,-0.119524,0.575945,-0.599247,0.852942,0.0657308,1.63328,0.245914,1.78203,0.210575,-0.0676874,-1.0315,-1.1