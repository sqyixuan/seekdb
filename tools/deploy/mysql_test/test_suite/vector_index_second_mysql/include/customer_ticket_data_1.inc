INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--d5e12ab325337638a91a7ca91ff5f60fd9e38b00a97ac336b071b7cb521133b1','"浆水面":"浆水面是敦煌夏季的特色小吃，以其独特的酸味和清凉效果受到当地人喜爱。这种面条以芹莱或箭杆白莱、莲花莱投入面汤，加上浆水酵子自然发酵而成，煮开后进行冰镇。其酸、辣、清香的味道别具一格，尤以芥菜为佳。浆水面不仅开胃解暑，还含有多种有益的酶，能清暑解热、增进食欲，并对高血压、肠胃病和泌尿病有一定的疗效。",

"胡羊焖饼":"胡羊焖饼是敦煌独特的民俗美食，具有独特的风味。在敦煌夜市，这道菜与掐鱼儿面和黄河王啤酒并列为受欢迎的组合。胡羊焖饼的饼子与凉皮相似，但更为夯实。加入羊肉后，使其味道更加鲜美。此外，因其“肉烂饼香”的独特口味，深受当地百姓和游客的喜爱，被誉为敦煌地道的风味美食。",','[-0.217446,1.19661,-0.828162,-0.335713,-0.290568,-1.31399,0.688601,-0.0925252,-0.973264,0.161057,0.697553,0.969007,-1.56752,-0.433572,0.853429,0.344323,-0.666681,-0.742584,0.261731,-0.73686,-1.33461,0.667581,-1.09686,0.549783,-0.103138,0.905617,-1.05219,-0.352703,0.152186,-0.756247,1.29762,0.158882,0.402626,-0.970912,0.103588,-1.09288,-1.09925,-0.928904,-0.729186,0.472917,0.120796,0.472998,0.651141,0.012213,-0.143027,-0.951389,0.232034,-0.611398,-0.702896,0.473602,0.427641,-0.130861,0.780516,-1.11083,0.0936439,0.0454683,0.084757,-0.166068,-2.36671,-0.379278,0.276078,0.831288,0.305061,-0.325633,-0.351783,1.23506,1.23523,0.719589,-1.53743,0.0531012,-0.849087,0.42411,0.972492,-0.231779,-1.13548,0.246632,0.00780751,0.358352,1.13429,0.998631,0.507502,-1.09629,0.543469,0.876795,-0.0925306,0.209169,-0.743973,0.447468,1.0073,-2.57137,-0.567874,0.197804,1.05764,-1.97269,-0.552696,0.362749,-0.857796,-0.393543,0.594788,-0.466211,-0.117001,0.695472,0.577171,-0.894318,0.338134,-0.354231,0.315629,0.361464,0.904856,0.190185,0.978585,0.183592,-0.874051,-0.426267,0.968544,-1.22988,-0.197844,-0.575563,1.01012,0.917494,-0.75714,1.3025,-0.909193,-0.0501104,0.0574764,0.56861,0.0844745,0.768283,0.0272782,0.722631,1.60471,-0.0570169,-0.894791,0.142616,0.595976,-0.400727,0.538165,-0.485822,0.576641,-0.804139,0.494517,0.290385,0.059685,-0.671348,1.38151,-1.86448,1.23987,-0.172192,0.0808596,-0.899533,1.41628,0.102832,-0.245813,-0.509916,-0.411046,-0.815694,2.22881,0.920206,0.779635,-0.409787,0.435208,-0.908071,0.520157,0.244506,-0.273101,-0.73343,-0.103592,-0.0236287,-0.587039,0.590637,0.266595,-0.565799,0.625715,0.336373,1.45822,-0.0879683,0.374143,0.320738,-0.334093,-0.568474,-1.04372,-0.983997,0.655104,0.173459,0.472479,0.657718,-0.0581171,0.436141,0.335273,0.136476,-0.257428,-0.175315,1.10715,0.496142,0.341624,-0.0286412,0.72228,-0.132694,-0.91192