INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--00b574199e7ce3b35e31941759d66f0c45e493b1dd78e9e0edb01fc63f9805e9','##  实验

 车神卡升级改版实验：实验设计是A/B测试，目标人群分为两组，一组为实验组，一组为对照组。实验组使用了升级后的车神卡，对照组使用的是旧版车神卡。需要分析的指标包括花呗笔数渗透率、花呗笔数意愿率、花呗金额意愿率、余额等。











