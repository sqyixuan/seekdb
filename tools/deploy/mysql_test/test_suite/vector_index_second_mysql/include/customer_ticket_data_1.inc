INSERT INTO asia_knowledge (`id`,`text`,`embeddings`,`metadata`) VALUES('default-app-id--726552b6c29e338bf817602a2acf2734198d72a9cfe8ab760eb01108a0ac826d','"臊子面":"臊子面是敦煌地区著名的传统手工麦面制品，其面条细长、厚薄均匀，具有很好的嚼劲。臊子的制作融合了各种新鲜蔬菜和肉类，使得汤味酸辣、筋韧且爽口。这种面条不仅色香味俱佳，还被誉为“长寿面”，在各种重要场合如生日、婚丧、节日等都有着不可或缺的地位。臊子面的制作工艺也相当讲究，特别是汤的制作，需要经过精心炒制和多种佐料的搭配，最终呈现出一种令人难以抗拒的美味。",','[0.659968,1.40857,-0.693809,-0.502348,-0.0188937,-1.24251,0.209724,-0.267908,-0.447275,0.499531,0.235906,1.25656,-0.977423,0.180056,0.785293,0.0523045,-0.632382,-1.15638,0.224749,0.0693814,-1.41329,0.480974,-0.592672,0.565254,-0.0530356,0.229502,-0.716648,0.728256,0.188879,-0.959765,0.63896,1.25271,0.0309779,-0.908072,-0.209855,0.0171795,-0.543185,-0.944413,-0.405289,0.525981,-0.00323514,0.614636,0.710721,-0.789526,0.510365,-0.814891,-0.336228,-1.13872,-0.429074,-0.460145,0.41949,-0.344921,0.637517,-0.493973,-0.233795,0.470153,0.0064682,-0.239802,-1.83585,0.122533,-0.0740482,-0.0175626,0.183616,-0.418115,-0.503631,0.839351,0.786417,0.333372,-0.479988,-0.486223,-0.559453,0.461349,-0.182892,0.195251,-1.77155,-0.204723,0.0409009,0.852037,1.30098,0.955805,0.807979,-0.719751,0.670555,0.669973,-0.419127,0.457465,-1.66989,0.240874,0.628335,-1.29268,-0.141861,0.134994,0.293586,-1.18046,-0.211197,-0.148777,-0.605131,0.0400028,0.628412,-1.16596,-0.276823,1.01287,1.23146,-0.906853,1.03975,-0.227743,0.74024,0.9937,1.4291,0.00567719,1.57149,0.544271,-0.630241,-0.326205,0.838174,-1.40959,0.119069,-0.798363,0.495558,0.573617,-0.740392,0.804871,-0.841972,-0.700052,-0.385134,-0.197775,0.441033,1.1886,-0.480682,0.0685566,1.62674,0.573569,-1.01676,-0.637028,-0.131671,-0.259214,0.959076,0.356607,0.701776,-0.615698,1.18297,-0.634643,0.21208,-0.202211,0.690589,-1.72208,1.16915,-0.530491,0.0238788,-0.566784,1.96896,1.09547,-0.321244,-0.130487,-0.23142,-0.803205,0.343574,1.02879,1.22537,0.339044,0.449234,0.446243,0.636563,0.729603,0.0689281,-1.25843,-0.473774,1.14738,-0.693097,-0.314658,0.541925,-1.21503,-0.103594,-0.448158,2.01944,0.367405,1.79739,0.2