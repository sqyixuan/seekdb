"=========================================== partition update ==========================================="
drop table if exists t;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p5 values less than (1000000));
update /*+parallel(5)*/ t partition(p0) set c2='[1,1,1]' where c1 < 10 order by cosine_distance(c2, '[-970769, -13483.01, 254267]') approx limit 10;
