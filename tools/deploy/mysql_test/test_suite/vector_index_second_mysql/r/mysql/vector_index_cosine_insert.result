"=========================================== insert overwrite ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
create table t1(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
insert into t1 select * from t where t.c1<1000 order by cosine_distance(t.c2,'[-476077, -63863.82, 473126]') limit 30;
delete from t;
insert /*+parallel(10)*/ overwrite t1 partition(p0,p2) select * from t where c1 % 2=0 order by cosine_distance(c2, '[-476077, -63863.82, 473126]') limit 30;
ERROR 0A000: insert overwrite with direct-load does not support table has generated column


