"=========================================== insert into view ==========================================="
drop table if exists t;
drop materialized view if exists mv;
drop materialized view if exists mv1;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
create materialized view mv (a1,a2,primary key(a1)) partition by range(a1) (partition p0 values less than (100), partition p1 values less than (1000), partition p2 values less than (maxvalue)) with column group(each column) refresh complete on demand as select c1,c2 from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 100;
create materialized view mv1 (a1,a2,primary key(a2)) partition by range(a1) (partition p0 values less than (100), partition p1 values less than (1000), partition p2 values less than (maxvalue)) with column group(each column) refresh complete on demand as select c1,c2 from t order by cosine_distance(c2, '[397583, 541347, -65783.73]') approx limit 100;
