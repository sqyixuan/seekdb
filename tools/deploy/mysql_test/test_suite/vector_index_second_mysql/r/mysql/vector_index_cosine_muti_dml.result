"=========================================== dml with procedure ==========================================="
drop table if exists t;
drop table if exists t1;
drop procedure if exists mytest;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
create table t1(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw)) partition by range(c1) (partition p0 values less than (100),partition p1 values less than (1000),partition p2 values less than (10000),partition p3 values less than (100000),partition p4 values less than (1000000));
insert into t1(c1,c2,c3) values(1, '[77125.02, -80265.99, -262583]', '[0.811744, -1581, -967148, -0.935191]');
insert into t1(c1,c2,c3) values(2, '[-64656.9, 79241, 0.271415]', '[20008.81, -663860, -33966.93, 30381.51]');
insert into t1(c1,c2,c3) values(3, '[-69127.82, -0.623606, -394638]', '[-0.355252, 754669, 192053, -447867]');
insert into t1(c1,c2,c3) values(4, '[-59031.19, 33294, 0.615055]', '[274783, -0.707152, -77278.36, -10037]');
insert into t1(c1,c2,c3) values(5, '[965953, 83764, -971667]', '[17127.8, 0.010879, 111400, -573896]');
insert into t1(c1,c2,c3) values(6, '[-92458.83, 0.114535, 68286.7]', '[-80259.65, 36706.27, -981281, 847266]');
insert into t1(c1,c2,c3) values(7, '[-61253.07, 0.520645, 0.663066]', '[-0.111598, 573641, -0.760578, 71516.87]');
insert into t1(c1,c2,c3) values(8, '[-0.892018, 929517, 0.57756]', '[57297.17, 33523.38, 0.819768, -0.348583]');
insert into t1(c1,c2,c3) values(9, '[-0.582307, 0.926861, -70780.13]', '[0.051316, -0.316709, -781528, -0.959348]');
insert into t1(c1,c2,c3) values(10, '[-0.277237, -304120, 0.637868]', '[137017, 0.78021, -41681.94, -6168.722]');
create procedure mytest(in id int)
begin
declare t_vec double;
declare t1_vec double;
select cosine_distance(c2,'[-0.884688, 98861.24, -535325]') into t_vec from t where c1<id order by cosine_distance(c2,'[-0.884688, 98861.24, -535325]') approx limit 1;
select cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') into t1_vec from t1 where c1<id order by cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') approx limit 1;
if t_vec + t1_vec < 1 then
update t1 set c3='[1,1,1,1]' where c1<id order by cosine_distance(c2,'[-0.582307, 0.926861, -70780.13]') limit 1;
else
insert into t1 values((select count(*) + 1 from t1), '[0,0,0]', '[0,0,0,0]');
end if;
end //
set @vec_1 = 10;
set @vec_2 = 8;
call mytest(@vec_1);
