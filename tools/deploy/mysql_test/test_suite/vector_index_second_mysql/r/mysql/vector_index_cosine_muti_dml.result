update t1 set c2= case
when cosine_distance(c2, '[-69127.82, -0.623606, -394638]') < 1 then '[0,0,0]'
        when cosine_distance(c2, '[-69127.82, -0.623606, -394638]') >=1 then '[1,1,1]'
        end
where c1%2=0;
