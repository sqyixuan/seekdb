"=========================================== create table with vector index ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw));
explain select c2, c3 from t order by cosine_distance(c2, NULL) approx limit 10;
