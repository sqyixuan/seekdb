"=========================================== all_offline_ddl ==========================================="
drop table if exists t;
drop table if exists t1;
create table t(c1 int, c2 vector(3), c3 vector(4), primary key(c1), vector index idx1(c2) with (distance=cosine, type=hnsw));
alter table t add a1 vector(3) first;
alter table t add a2 vector(3) before c1;
alter table t add a3 vector(3) after c1;
alter table t add b1 int first;
alter table t add b2 int before c1;
alter table t add b3 int after c1;
alter table t add c2 vector(3) auto_increment;
