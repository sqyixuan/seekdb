--result_format 4

--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

SET SESSION sql_mode ='ALLOW_INVALID_DATES';

##游标##
drop table if EXISTS ff01;
CREATE TABLE ff01(id int PRIMARY KEY, a date,b datetime,c timestamp);
INSERT INTO ff01 VALUES (1,'2001-2-29','2001-2-29','2001-2-29'),
                        (2,'2002/2/30','2002/2/30','2002/2/30'),
                        (3,'2003:2:31','2003:2:31','2003:2:31'),
                        (4,'2004431','2004431','2004431'),
                        (5,2005631,2005631,2005631),
                        (6,'2007-11-31','2007-11-31','2007-11-31'),
                        (7,'1900-2-29','1900-2-29','1900-2-29');
drop PROCEDURE IF EXISTS tcur;
delimiter //;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime;
	DECLARE b1 date;
	DECLARE c1 timestamp;
	DECLARE cur01 CURSOR FOR SELECT a,b,c FROM ff01;
	OPEN cur01;
	FETCH cur01 INTO a1,b1,c1;
	SELECT a1,b1,c1;
	CLOSE cur01;
END;
//
delimiter ;//
CALL tcur();

drop PROCEDURE IF EXISTS tcur;
delimiter //;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime;
	DECLARE b1 date;
	DECLARE c1 timestamp;
	DECLARE done int;
	DECLARE cur01 CURSOR FOR SELECT a,b,c FROM ff01;
	DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;
	OPEN cur01;
	posloop:LOOP
		IF done=1 THEN LEAVE posloop;
	    END IF;
		FETCH cur01 INTO a1,b1,c1;
		SELECT a1,b1,c1;
	END LOOP posloop;
	CLOSE cur01;
END;
//
delimiter ;//
CALL tcur();

drop PROCEDURE IF EXISTS tcur;
delimiter //;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime ;
	DECLARE b1 date ;
	DECLARE c1 timestamp ;
	DECLARE a2 varchar(10) ;
	DECLARE b2 varchar(10) ;
	DECLARE c2 varchar(10) ;
	DECLARE done int;
	DECLARE id int;
	DECLARE cur01 CURSOR FOR SELECT a1,b1,c1;
	DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;
    SET a1 = '2010-2-29';
    SET b1 = '2011-2-30';
    SET c1 = '2012-2-31';
    SET id = 8;
	OPEN cur01;
	posloop:LOOP
		IF done=1 THEN LEAVE posloop;
	    END IF;
	   	FETCH cur01 INTO a2,b2,c2;
		SELECT a2,b2,c2;
		INSERT INTO ff01 VALUES(id,a2,b2,c2);
		SET id = id+1;
	END LOOP posloop;
	CLOSE cur01;
END;
//
delimiter ;//
CALL tcur();

##触发器##
--disable_warnings
DROP TABLE if EXISTS ff02;
--enable_warnings
CREATE table ff02(a1 date,b1 datetime,c1 timestamp);

drop TRIGGER IF EXISTS tri01;
CREATE TRIGGER tri01 AFTER INSERT ON ff01 FOR EACH ROW
	INSERT into ff02 VALUES('1990-2-29','1991-2-30','1992-2-30');
INSERT into ff01(id) VALUES(10);
SELECT * from ff02;

drop TRIGGER IF EXISTS tri01;
delimiter //;
CREATE TRIGGER tri01 BEFORE UPDATE ON ff01 FOR EACH ROW
BEGIN
	IF day(NEW.a)<=29 || day(NEW.b)<=29 THEN
	 SET NEW.a = CONCAT(YEAR(NEW.a),'-',MONTH(NEW.a),'-',31);
	 SET NEW.b = CONCAT(YEAR(NEW.b),'-',MONTH(NEW.b),'-',31);
	END IF;
END;
//
delimiter ;//
UPDATE ff01 set a = '1992.2.31' WHERE id=7;

SELECT * from ff01;

drop TRIGGER IF EXISTS tri01;
delimiter //;
CREATE TRIGGER tri01 AFTER UPDATE ON ff01 FOR EACH ROW
BEGIN
	DECLARE a date;
	DECLARE b datetime;
	DECLARE c timestamp;
	SET a = '1990-2-29';
	SET b = '1991-2-30';
	SET c = '92.2.31';
	INSERT into ff02 VALUES(a,b,c);
END;
//
delimiter ;//
UPDATE ff01 set a = '1990.2.29' WHERE id=10;
SELECT * from ff02;

drop TRIGGER IF EXISTS tri01;
delimiter //;
CREATE TRIGGER tri01 BEFORE DELETE ON ff01 FOR EACH ROW
BEGIN
	DECLARE a date;
	DECLARE b datetime;
	DECLARE c timestamp;
	SET a = '1990-2-29';
	SET b = '1991-2-30';
	SET c = '92.2.31';
	INSERT into ff02 VALUES(a,b,c);
END;
//
delimiter ;//
DELETE from ff01 WHERE a='90.2.29';
SELECT * from ff02;

##存储过程##
drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01()
BEGIN
	DECLARE a date;
	DECLARE b datetime;
	SET a = '2001-2-29';
	SET b = '2001-2-30';
	SELECT a,b;
END;
//
delimiter ;//
CALL pro01();

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a DATE)
BEGIN
	DECLARE b datetime;
	SET b = a;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('2010-2-29');

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(OUT a DATE)
BEGIN
	DECLARE b datetime DEFAULT '1900-2-29';
	SET a = b;
END;
//
delimiter ;//
CALL pro01(@a);
SELECT @a;

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	SET b = a ;
END;
//
delimiter ;//
CALL pro01('1999-2-29',@b);
SELECT @b;

drop TABLE if EXISTS ff01;
CREATE TABLE ff01 (a date,b datetime);
drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(IN a varchar(20))
BEGIN
	INSERT into ff01 VALUES (a,a);
END;
//
delimiter ;//
CALL pro01('99.2.31');
SELECT * from ff01;

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	IF a = '99.3.1' THEN
		set b = a+2;
	ELSEIF a = '99.2.29' THEN
		SET b = a+1;
	ELSE
		SET b = a;
	END IF;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('99.2.29');

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	IF a = '99.3.1' THEN
		set b = a;
	ELSE
		SET b = a+1;
	END IF;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('99.3.31');
CALL pro01('99.4.31');
CALL pro01('99.2.28');

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	IF a > '99.2.30' THEN
		UPDATE ff01 set a = a;
	ELSE
		UPDATE ff01 set a = a+1;
	END IF;
END;
//
delimiter ;//
CALL pro01('99.2.29');
SELECT * from ff01;
CALL pro01('99.2.30');
SELECT * from ff01;
CALL pro01('99.2.31');
SELECT * from ff01;

##mysql显示2.29，ob显示3.2##
drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	CASE a
	 WHEN '1990-2-29' THEN
     	SET b = a+1;
	 ELSE
	 	SET b = a ;
	END CASE;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('1990-2-29');

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	CASE a
	 WHEN '1990-2-29' THEN
	 	SET b = a+1 ;
	 WHEN '1990-2-30' THEN
	 	SET b = a+2;
	 WHEN '1990-2-31' THEN
	 	SET b = a+3;
	 WHEN '1990-3-1' THEN
	 	SET b = a+4;
	 ELSE
	 	SET b = a ;
	END CASE;
END;
//
delimiter ;//
CALL pro01('1990-3-1',@b);
SELECT @b;

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	WHILE a < '2001-2-30' DO
		SET b = a + 1;
		SET a = a + 1;
	END WHILE;
END;
//
delimiter ;//
CALL pro01('2001.2.28',@b);
SELECT @b;
CALL pro01('2001.2.29',@b);
SELECT @b;
##mysql显示null##
CALL pro01('2001.3.1',@b);
SELECT @b;

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	REPEAT
		SET b = a + 1 ;
		SET a = a + 1 ;
		until a > '2001-2-30'
	END REPEAT;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('2001-2-29');

drop PROCEDURE IF EXISTS pro01;
delimiter //;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	loop01:LOOP
		SET b = a + 1 ;
		SET a = a + 1 ;
		IF a > '2001-2-30' THEN
			LEAVE loop01;
		END IF;
	END LOOP;
	SELECT b;
END;
//
delimiter ;//
CALL pro01('2001-2-29');

##函数##
DROP FUNCTION IF EXISTS fun01;
delimiter //;
CREATE FUNCTION fun01(a date) RETURNS date
BEGIN
	RETURN a + 1;
END;
//
delimiter ;//
SELECT fun01('2001-2-29');

DROP FUNCTION IF EXISTS fun01;
delimiter //;
CREATE FUNCTION fun01() RETURNS date
BEGIN
	RETURN '1900.2.29';
END;
//
delimiter ;//
SELECT fun01();

DROP FUNCTION IF EXISTS fun01;
delimiter //;
CREATE FUNCTION fun01() RETURNS date
BEGIN
	set @a = '1900.2-29';
	RETURN @a;
END;
//
delimiter ;//
SELECT fun01();

##mysql显示0000-00-00，mysql两个日期相加如果是非法日期会显示null##
DROP FUNCTION IF EXISTS fun01;
delimiter //;
CREATE FUNCTION fun01(a date,b date) RETURNS date
BEGIN
	set @c = a + b;
	RETURN @c;
END;
//
delimiter ;//
SELECT fun01('1999.2.29','1999.2.30');

DROP FUNCTION IF EXISTS fun01;
delimiter //;
CREATE FUNCTION fun01(a date,b date) RETURNS varchar(20)
BEGIN
	set @c = a + b;
	RETURN @c;
END;
//
delimiter ;//
SELECT fun01('1999.2.29','1999.2.30');

drop table if EXISTS ff01;

