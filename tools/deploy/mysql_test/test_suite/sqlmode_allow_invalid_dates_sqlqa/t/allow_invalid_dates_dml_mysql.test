##updatetimestamp##
##mysql时间戳类型会自动更新##
drop table if EXISTS ff01;
CREATE table ff01 (a date,b timestamp);
INSERT INTO ff01 VALUES('2001.2.29','2001.2.29');
INSERT INTO ff01(a) VALUES('2001.2.29');
SELECT * from ff01;
UPDATE ff01 set a = '02.2.30' WHERE a = '01.2.29';
select * from ff01;


drop TABLE if EXISTS ff01;

connection default;
