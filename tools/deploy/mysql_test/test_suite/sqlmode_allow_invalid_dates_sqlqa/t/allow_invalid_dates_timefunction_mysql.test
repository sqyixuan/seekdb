#owner: dachuan.sdc
#owner group: SQL2
#description: 时间函数中应用非法日期
#tags:
#author: wb-zc01084078

--result_format 4
--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

SET SESSION sql_mode ='ALLOW_INVALID_DATES';

####日期函数####
##CURDATE##
#select CURDATE(),CURRENT_DATE(),CURRENT_TIME(),CURRENT_TIMESTAMP(),CURTIME(),now();

##date##
##日期'2020-0-29'ob显示null，mysql显示2020-00-29
select date('0000-01-01'),
       date('9999-12-31'),
       date('2022-13-31'),
       date('2020-0-29'),
       date('2022-2-30'),
       date('1996-2-31'),
       date('11-11-11'),
       date('08-11-31'),
       date('111-11-31'),
       date('92-2-29'),
       date('0000-00-00'),
       date(NULL);
select date('2000-2-29'),
       date('2001-2-29'),
       date('2002-2-30'),
       date('2003-2-31'),
       date('2004-4-31'),
       date('2005-6-31'),
       date('2006-9-31'),
       date('2007-11-31'),
       date('1900-2-29');

##date_add,date_sub##
##组合时间间隔太多ob报错##
select date_add('96/2/25',INTERVAL 5 DAY),
       date_add('96/1/30',INTERVAL 1 MONTH),
       date_add('96/1/31',INTERVAL 1 QUARTER),
       date_add('97-2-29',INTERVAL -1 YEAR),
       date_add('996-2-28',INTERVAL '1 01' DAY_HOUR),
       date_add('1900/2/29',INTERVAL 1 DAY);
SELECT date_sub('96-2-30',INTERVAL 1 DAY),
       date_sub('96-3-30',INTERVAL 1 MONTH),
       date_sub('1222-5-30',INTERVAL 1 QUARTER),
       date_sub('99-2-29',INTERVAL -1 YEAR),
       date_sub('996-2-28',INTERVAL '1 01' DAY_HOUR),
       date_sub('97-2-29',INTERVAL -1 HOUR),
       date_sub('1900-3-1',INTERVAL 1 DAY);

##DATE_FORMAT##
select DATE_FORMAT('2022-2-29','%a %b %c %D %d %e %j %M %m %p %U %u %V%X %v%x %w %Y %y');
select DATE_FORMAT('20/2/30','%a %b %c %D %d %e %j %M %m %p %U %u %V%X %v%x %w %Y %y');
select DATE_FORMAT('111/11/31','%a %b %c %D %d %e %j %M %m %p %U %u %V%X %v%x %w %Y %y');
select DATE_FORMAT('1900/2/29','%a %b %c %D %d %e %j %M %m %p %U %u %V%X %v%x %w %Y %y');
SELECT DATE_FORMAT(NULL,NULL);

##datediff##
SELECT datediff('96-2-30','96-3-30'),
       datediff('996-10-31','96-3-30'),
       datediff('22/2/29','22-2-31'),
       datediff('1900-2-29','1900-2-28'),
       datediff(date('2006-9-31'),date('2007-11-31')),
       datediff(NULL,NULL);

##EXTRACT##
select EXTRACT(DAY from '2000-2-29'),
       EXTRACT(WEEK from '2001-2-29'),
       EXTRACT(MONTH from '2002-2-30'),
       EXTRACT(QUARTER from '2003-2-31'),
       EXTRACT(YEAR from '2004-4-31'),
       EXTRACT(YEAR_MONTH from '2005-6-31'),
       EXTRACT(DAY_HOUR from '2006-9-31 1:1'),
       EXTRACT(DAY from '1900-2-29'),
       EXTRACT(DAY from NULL);

##FROM_DAYS##730909
select FROM_DAYS(730909),
       FROM_DAYS(730910),
       FROM_DAYS(730909.5),
       FROM_DAYS(730544),
       FROM_DAYS(NULL);

##FROM_UNIXTIME##
select FROM_UNIXTIME(UNIX_TIMESTAMP('2000-2-29')),
       FROM_UNIXTIME(UNIX_TIMESTAMP('2003-2-31')),
       FROM_UNIXTIME(UNIX_TIMESTAMP('2002-2-30')),
       FROM_UNIXTIME(UNIX_TIMESTAMP('2001-2-29')),
       FROM_UNIXTIME(UNIX_TIMESTAMP('2004-4-31')),
       FROM_UNIXTIME(UNIX_TIMESTAMP('1900-2-29')),
       FROM_UNIXTIME(NULL);

##str_to_date,GET_FORMAT##
##格式'%Y%m%d'ob总会显示输入年份前一年的11月30号，mysql显示null##
SELECT str_to_date('2000-2-29',get_format(DATE,'USA')),
       str_to_date('2001-2-29',get_format(DATE,'JIS')),
       str_to_date('2002-2-30',get_format(DATE,'ISO')),
       str_to_date('2003-2-31',get_format(DATE,'EUR')),
       str_to_date('2004-4-31',get_format(DATE,'INTERNAL')),
       str_to_date('1900-2-29','%y/%m/%d'),
       str_to_date(NULL,NULL);

##LAST_DAY##
##ob转换成合理日期处理##
SELECT LAST_DAY('2000-2-29'),
       LAST_DAY('2001-2-29'),
       LAST_DAY('2002-2-30'),
       LAST_DAY('2003-2-31'),
       LAST_DAY('2004-4-31'),
       LAST_DAY('2005-6-31'),
       LAST_DAY('1900-2-29'),
       LAST_DAY(NULL);

##MAKEDATE##
SELECT MAKEDATE(2000,60),
       MAKEDATE(2000,366),
       MAKEDATE(1900,59),
       MAKEDATE(NULL,NULL);

##month，day，year,MONTHNAME##
##month,DAY,YEAR,MONTNNAME在直接处理日期的时候ob不会转换合法日期
SELECT MONTH('2000-2-29'),
       MONTH('2001-2-29'),
       MONTH('2002-2-30'),
       MONTH('1900-2-29'),
       MONTH('2007-11-31'),
       MONTH(date('2007-11-31')),
       MONTH(NULL);
SELECT DAY('2000-2-29'),
       DAY('2001-2-29'),
       DAY('2002-2-30'),
       DAY('1900-2-29'),
       DAY('2007-11-31'),
       DAY(date('2007-11-31')),
       DAY(NULL);
SELECT YEAR('2000-2-29'),
       YEAR('2001-2-29'),
       YEAR('2002-2-30'),
       YEAR('1900-2-29'),
       YEAR('2007-11-31'),
       YEAR(date('2007-12-32')),
       YEAR(NULL);
SELECT MONTHNAME('2000-2-29'),
       MONTHNAME('2001-2-29'),
       MONTHNAME('2002-2-30'),
       MONTHNAME('1900-2-29'),
       MONTHNAME('2007-11-31'),
       MONTHNAME(date('1900/2/29')),
       MONTHNAME(NULL);

##period_add,period_diff##
##参数月份如果是00mysql报错，ob正常执行##
SELECT PERIOD_ADD(200012,1),
       PERIOD_ADD(20001,1),
       PERIOD_ADD(4912,1),
       PERIOD_DIFF(200012,1),
       PERIOD_DIFF(NULL,NULL);

##QUARTER##
##处理逻辑同month##
SELECT QUARTER('2000-2-29'),
       QUARTER('2001-2-29'),
       QUARTER('2002-2-30'),
       QUARTER('1900-2-29'),
       QUARTER('2007-6-31'),
       QUARTER(date('00/6/31')),
       QUARTER(NULL);

##time##
select time('2000-2-29'),
       time('2001-2-29'),
       time(date('2002-2-30')),
       time('1900-2-29 11:11:11'),
       time(NULL);

##TIME_TO_USEC##
##MYSQL没有此函数##
SELECT TIME_TO_USEC('2001-3-1'),
       TIME_TO_USEC('2001-2-29'),
       TIME_TO_USEC('1900-2-29'),
       TIME_TO_USEC('2007-11-31'),
       TIME_TO_USEC(date('2001-2-29')),
       TIME_TO_USEC(NULL);

##TIMEDIFF##
select TIMEDIFF('2000-2-29','2001-2-29'),
       TIMEDIFF('2002-2-30','2003-2-31'),
       TIMEDIFF('1900-2-29','1900-2-29'),
       TIMEDIFF(date('2004-4-31'),date('2005-6-31')),
       TIMEDIFF('2006-9-31 11:11:11','2006-9-31 12:12:12'),
       TIMEDIFF(NULL,NULL);

##TIMESTAMP##
##处理逻辑与date函数相同##
SELECT TIMESTAMP('2000-2-29'),
       TIMESTAMP('2001-2-29'),
       TIMESTAMP('2005-6-31'),
       TIMESTAMP('1900-2-29'),
       TIMESTAMP(date('2007-11-31')),
       TIMESTAMP(null),
       TIMESTAMP('1900-2-29','1900-2-29'),
       TIMESTAMP(date('2003-2-31'),date('2006-9-31'));

##TIMESTAMPADD，TIMESTAMPDIFF##
##mysql不支持组合unit##
##设置了模式后TIMESTAMPADD,TIMESTAMPDIFF函数无法处理非法日期，要用date处理后才能处理，mysql可以处理非法日期##
SELECT TIMESTAMPADD(SECOND,1,'2000-2-29 23:59:59'),
       TIMESTAMPADD(HOUR,1,'2001-2-29 23:59:59'),
       TIMESTAMPADD(DAY,-1,'1900-2-29'),
       TIMESTAMPADD(WEEK,1,'2001-2-22'),
       TIMESTAMPADD(MONTH,1,'2002-4-31'),
       TIMESTAMPADD(QUARTER,-1,'2000-6-31'),
       TIMESTAMPADD(YEAR,-1,'2001-2-29'),
       TIMESTAMPADD(DAY,-1,DATE('2001-2-29')),
       TIMESTAMPADD(SECOND,NULL,NULL);
select TIMESTAMPDIFF(DAY,'1900-2-29','1900-3-1'),
       TIMESTAMPDIFF(HOUR,'2001-2-29 11:11:11','2001-3-1 12:12:12'),
       TIMESTAMPDIFF(WEEK,'2005-6-31','2006/9/31'),
       TIMESTAMPDIFF(DAY,DATE('2001-2-29'),DATE('2001/3/1')),
       TIMESTAMPDIFF(MONTH,'2001-2-29','2001/3/1'),
       TIMESTAMPDIFF(QUARTER,'2001-3-31','2001/6/31'),
       TIMESTAMPDIFF(YEAR,'2000-2-29','2001/2/29'),
       TIMESTAMPDIFF(DAY,NULL,NULL);

##TO_DAYS,TO_SECONDS##
SELECT TO_DAYS('2000-2-29'),
       TO_DAYS('2001-2-29'),
       TO_DAYS('2002-2-30'),
       TO_DAYS('1900-2-29'),
       TO_DAYS('2007-11-31'),
       TO_DAYS(date('2007-11-31')),
       TO_DAYS(NULL);
SELECT TO_SECONDS('2000-2-29'),
       TO_SECONDS('2001-2-29'),
       TO_SECONDS('2002-2-30'),
       TO_SECONDS('1900-2-29'),
       TO_SECONDS('2007-11-31'),
       TO_SECONDS(date('2007-11-31')),
       TO_SECONDS(NULL);

##UNIX_TIMESTAMP##
##非法日期都会处理为0##
SELECT UNIX_TIMESTAMP('2001-2-29 23:59:59'),
       UNIX_TIMESTAMP('2001-3-1 23:59:59'),
       UNIX_TIMESTAMP('1900-2-29'),
       UNIX_TIMESTAMP(date('2001-3-1 23:59:59')),
       UNIX_TIMESTAMP(date('2001-2-29 23:59:59')),
       UNIX_TIMESTAMP(NULL);

##week,weekday,weekofyear##
SELECT WEEK('2001-2-29'),
       WEEK('2002-2-30'),
       WEEK('1900-2-29'),
       WEEK(DATE('2007-11-31')),
       WEEK('2006/9/31'),
       WEEK(NULL);
SELECT WEEKDAY('2001-2-29'),
       WEEKDAY('2002-2-30'),
       WEEKDAY('1900-2-29'),
       WEEKDAY(DATE('2007-11-31')),
       WEEKDAY('2006/9/31'),
       WEEKDAY(NULL);
SELECT WEEKOFYEAR('2001-2-29'),
       WEEKOFYEAR('2002-2-30'),
       WEEKOFYEAR('1900-2-29'),
       WEEKOFYEAR(DATE('2007-11-31')),
       WEEKOFYEAR('2006/9/31'),
       WEEKOFYEAR(NULL);

####转换函数####
##cast##
SELECT CAST('2001-2-29' as date),
       CAST('1900/2/29' as date),
       CAST(2001-2-29 as date),
       CAST(20000229 as date),
       CAST(20000229111111 as datetime),
       CAST(20010229121212 as datetime),
       CAST(format(20010229121212.123,0) as datetime),
       CAST(ROUND(19000229.567) as datetime),
       CAST(NULL as date);
##ob显示转换后的日期，mysql为null##
SELECT CAST(date'01.2.29' as decimal);

####比较函数####
##GREATEST,LEAST##
SELECT GREATEST('2000-2-29','2001-2-29'),
       GREATEST(DATE('1900-2-29'),DATE('2001-2-29')),
       GREATEST('2001-2-29','2002-9-31'),
       GREATEST('2001-2-29','2001-3-1'),
       GREATEST(DATE('2001/2/29'),DATE('2001-3-1')),
       GREATEST('2001/2/29','2001-2-29'),
       GREATEST(NULL,NULL);
SELECT LEAST('2000-2-29','2001-2-29'),
       LEAST(DATE('1900-2-29'),DATE('2001-2-29')),
       LEAST('2001-2-29','2002-9-31'),
       LEAST('2001-2-29','2001-3-1'),
       LEAST(DATE('2001/2/29'),DATE('2001-3-1')),
       LEAST('2001/2/29','2001-2-29'),
       LEAST(NULL,NULL);

##INTERVAL##
--disable_warnings
SELECT INTERVAL('2001-6-31','2001-2-29','2001/4/31',date(2001229)),
       INTERVAL(date('1800-2-29'),'1800-2-29','1800/2/30','1800/2/31','1800/3/1');
--enable_warnings

##ISNULL##
SELECT isnull('2001-2-29'),
       isnull(date('1800-2-29')),
       isnull('2000-2-29'),
       isnull(date('2001-2-29')),
       isnull('2001/2/30'),
       isnull(NULL);

##运算##
##+，-##
SELECT '2001-2-29' + INTERVAL 1 DAY;
SELECT '1900-2-29' + '2000-2-29';
SELECT '1999.3.31' + INTERVAL 1 MONTH;
#ob先转换日期再运算，结果与mysql不一致##
SELECT '2001-2-31' + INTERVAL 2 MONTH;
SELECT '01.2.15' + INTERVAL 15 DAY;
SELECT '2001-2-30' - INTERVAL 1 DAY;
SELECT '2000-2-30' - '1900-2-29';
SELECT '1900-2-30' - '2000-2-29';
#同上#
SELECT '2001-4-31' - INTERVAL 2 MONTH;
SELECT '1999.5.31' - INTERVAL 1 MONTH;

##比较运算##
##ob会对非法日期转换，注意比较##
SELECT '01.2.29' > '01.3.1';
SELECT date'01.2.29' > date'01.3.1';
SELECT '01.2.30' >= '01.3.1';
SELECT date'01.2.30' >= date'01.3.1';
SELECT '01.2.31' < '01.3.1';
SELECT date'01.2.31' < date'01.3.1';
SELECT '01.4.31' <= '01.5.1';
SELECT date'01.4.31' <= date'01.5.1';
SELECT '2001.2.29' <=> '2001.3.1';
SELECT date'2001.2.29' <=> date'2001.3.1';
SELECT '2001.2.31' <=> NULL;
SELECT date'2001.2.31' <=> NULL;
SELECT '2001.2.32' <=> NULL;
--error 1525
SELECT date'2001.2.32' <=> NULL;
SELECT '01.2.29' IN ('01.3.1');
SELECT date'01.2.29' IN (date'01.3.1');
SELECT '01.2.30' BETWEEN '01.2.29' AND '01.3.1';
SELECT date'01.2.30' BETWEEN date'01.2.29' AND date'01.3.1';

##类型转换##
drop TABLE IF EXISTS ff01;
CREATE TABLE ff01 (a int,b varchar(20),c blob,d TINYTEXT);
INSERT into ff01 VALUES (date'01.2.29',date'01.2.29',date'01.2.29',date'01.2.29');
select * from ff01;

drop table if EXISTS ff01;
CREATE TABLE ff01 (a date,b datetime);
INSERT into ff01 VALUES ('01.2.29','01.2.29');
INSERT into ff01 VALUES (20010230,20010230);
SELECT * from ff01;

DROP TABLE IF EXISTS ff01;

connection default;
--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings

