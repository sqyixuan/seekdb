--result_format 4

--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

SET SESSION sql_mode ='ALLOW_INVALID_DATES';

####select####
--disable_warnings
drop table if EXISTS ff01;
--enable_warnings
CREATE TABLE ff01 (ye int,mo int,da int);
--disable_warnings
drop table if EXISTS ff02;
--enable_warnings
CREATE TABLE ff02 (birth date);
INSERT into ff01 VALUES (2001,2,29);
select CONCAT(ye,'-',mo,'-',da) into @birth from ff01;
INSERT into ff02 VALUES (@birth);
select * from ff02;

--disable_warnings
drop table if EXISTS ff01;
--enable_warnings
CREATE table ff01 (a date,b datetime,c timestamp,d varchar(20));
SET @birth:='2001-2-29';
INSERT into ff01 VALUES(@birth,@birth,@birth,@birth);
SELECT * from ff01;

--disable_warnings
drop table if EXISTS ff01;
--enable_warnings
CREATE TABLE ff01(id int, a date,b datetime,c timestamp);
INSERT INTO ff01 VALUES (1,'2001-2-29','2001-2-29','2001-2-29'),
                        (2,'2002/2/30','2002/2/30','2002/2/30'),
                        (3,'2003:2:31','2003:2:31','2003:2:31'),
                        (4,'2004431','2004431','2004431'),
                        (5,2005631,2005631,2005631),
                        (6,date'2006-9-31',date'2006-9-31',date'2006-9-31'),
                        (7,'2007-11-31','2007-11-31','2007-11-31'),
                        (8,'1900-2-29','1900-2-29','1900-2-29');
SELECT * from ff01;
SELECT * from ff01 where a='01.2.29';
SELECT * from ff01 where b='02.2.30';
##mysql查询结果是空表##
SELECT * from ff01 where c='2003-2-31';
SELECT * from ff01 where a>'2001-2-29';
SELECT * from ff01 where a<'2001-2-29';
SELECT * from ff01 where a>='2001-2-29';
SELECT * from ff01 where a<='2001-2-29';
SELECT * from ff01 where a!='2001-2-29';
SELECT * from ff01 where a in ('2001-2-29');
SELECT * from ff01 where a not in ('2001-2-29');

--disable_warnings
drop view if EXISTS vv01;
--enable_warnings
CREATE VIEW vv01 as select * from ff01;
SELECT * from vv01;
SELECT * from vv01 where a='01.2.29';
SELECT * from vv01 where b='02.2.30';
##mysql查询结果是空表##
SELECT * from vv01 where c='2003-2-31';
SELECT * from vv01 where a>'2001-2-29';
SELECT * from vv01 where a<'2001-2-29';
SELECT * from vv01 where a>='2001-2-29';
SELECT * from vv01 where a<='2001-2-29';
SELECT * from vv01 where a!='2001-2-29';
SELECT * from vv01 where a in ('2001-2-29');
SELECT * from vv01 where a not in ('2001-2-29');

ALTER TABLE ff01 add index in_a(a);
SELECT * from ff01 where a='01.2.29' ORDER by '2010-2-30';
SELECT * from ff01 where b='02.2.30' ORDER by '2010-2-30';
SELECT * from ff01 where a>'2001-2-29' ORDER by date('2010-2-30');
SELECT * from ff01 where a<'2001-2-29' ORDER by '2010-2-30';
SELECT * from ff01 where a>='2001-2-29' ORDER by '2010-2-30';
SELECT * from ff01 where a<='2001-2-29' ORDER by date('2010-2-30');
SELECT * from ff01 where a!='2001-2-29' ORDER by date'2010-2-30';
SELECT * from ff01 where a in ('2001-2-29') ORDER by '2010-2-30';
SELECT * from ff01 where a not in ('2001-2-29') ORDER by '2010-2-30';

ALTER TABLE ff01 MODIFY a date DEFAULT '2001-2-29';
SELECT * from ff01 where a='01.2.29' ORDER by '2010-2-30';
SELECT * from ff01 where b='02.2.30' ORDER by '2010-2-30';
SELECT * from ff01 where a>'2001-2-29' ORDER by date('2010-2-30');
SELECT * from ff01 where a<'2001-2-29' ORDER by '2010-2-30';
SELECT * from ff01 where a>='2001-2-29' ORDER by '2010-2-30';
SELECT * from ff01 where a<='2001-2-29' ORDER by date('2010-2-30');
SELECT * from ff01 where a!='2001-2-29' ORDER by date'2010-2-30';
SELECT * from ff01 where a in ('2001-2-29') ORDER by '2010-2-30';
SELECT * from ff01 where a not in ('2001-2-29') ORDER by '2010-2-30';
##虚拟列##
ALTER table ff01 add a1 date as (a);
SELECT * from ff01 where a1='01.2.29';
SELECT * from ff01 where a1>'2001-2-29';
SELECT * from ff01 where a1<'2001-2-29';
SELECT * from ff01 where a1>='2001-2-29';
SELECT * from ff01 where a1<='2001-2-29';
SELECT * from ff01 where a1!='2001-2-29';
SELECT * from ff01 where a1 in ('2001-2-29');
SELECT * from ff01 where a1 not in ('2001-2-29');

ALTER table ff01 add a2 varchar(20) as (a);
SELECT * from ff01 where a2=date('01.2.29');
SELECT * from ff01 where a2>date'2001-2-29';
SELECT * from ff01 where a2<date'2001-2-29';
SELECT * from ff01 where a2>=date'2001-2-29';
SELECT * from ff01 where a2<=date'2001-2-29';
SELECT * from ff01 where a2!=date'2001-2-29';
--error 1064
SELECT * from ff01 where a2 in date('2001-2-29');
--error 1064
SELECT * from ff01 where a2 not in date('2001-2-29');

##group by##
select * from ff01 group by a HAVING a = '2001-2-29';
select * from ff01 group by a HAVING a > '2001-2-29';
select * from ff01 group by a HAVING a < '2001-2-29';
select * from ff01 group by a HAVING a != '2001-2-29';
select * from ff01 group by b HAVING a = '2001-2-29';
select * from ff01 group by c HAVING c = '2001-2-29' ORDER by '2001-2-29';
select min(b) from ff01 group by b HAVING b = '2001-2-29' ORDER by '2001-2-29';
select avg(a) from ff01 group by a HAVING a = '2001-2-29' ORDER by '2001-2-29';
select SUM(a) from ff01 group by a HAVING a = '2001-2-29' ORDER by '2001-2-29';
select count(a) from ff01 group by a HAVING a = '2001-2-29' ORDER by '2001-2-29';
##mysql显示null##
select MAX(a) from ff01 group by a HAVING a = '2001-2-29' ORDER by '2001-2-29';
select min(a) from ff01 group by a HAVING a = '2001-2-29' ORDER by '2001-2-29';

##子查询##
SELECT * from ff01 where a = (SELECT '2001-2-29');
SELECT * from ff01 where b = (SELECT '2001-2-29');
SELECT * from ff01 where a = (SELECT b from ff01 where a = '2001-2-29' );
SELECT * from ff01 where a in (SELECT a from ff01 );
SELECT * from ff01 where a like (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a > (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a < (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a >= (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a <= (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a != (SELECT a from ff01 where a = '2001-2-29');
SELECT * from ff01 where a =all (SELECT a from ff01);
SELECT * from ff01 where a =any (SELECT a from ff01);
SELECT * from ff01 where EXISTS (SELECT '2001-2-29' from ff01 where a = '2001-2-29');
SELECT (SELECT date'2001-2-29');
SELECT (SELECT a from ff01 where a='2001-2-29') from ff01;
SELECT * from  (SELECT date'2001-2-29')a;
--error 1242
SELECT (SELECT t1.a from ff01 where a='2001-2-29') from
       (SELECT * from ff01 where a='2001-2-29') as t1 where
       a=(SELECT a from ff01 where t1.a='2001-2-29');
SELECT (SELECT a from ff01 where a='2001-2-29') from ff01 GROUP by (SELECT a from ff01 where a='2001-2-29');
SELECT (SELECT a from ff01 where a='2001-2-29') from ff01 GROUP by (SELECT a from ff01 where a='2001-2-29') HAVING
       (SELECT a from ff01 where a='2001-2-29') = date'2001-2-29' ;

##join##
--disable_warnings
drop table if EXISTS ff01;
--enable_warnings
CREATE TABLE ff01(id int PRIMARY KEY, a date,b datetime,c timestamp);
INSERT INTO ff01 VALUES (1,'2001-2-29','2001-2-29','2001-2-29'),
                        (2,'2002/2/30','2002/2/30','2002/2/30'),
                        (3,'2003:2:31','2003:2:31','2003:2:31'),
                        (4,'2004431','2004431','2004431'),
                        (5,2005631,2005631,2005631),
                        (6,'2007-11-31','2007-11-31','2007-11-31'),
                        (7,'1900-2-29','1900-2-29','1900-2-29');
--disable_warnings
drop table if EXISTS ff02;
--enable_warnings
CREATE table ff02 (id1 int,a1 date);
INSERT INTO ff02 VALUES (1,'2001-2-29'),
                        (2,'2010-2-30'),
                        (3,'2100-2-29');
select * from ff01,ff02 where a=a1 ;
select * from ff01,ff02 where a='2001-2-29' ;
select * from ff01 INNER JOIN ff02 where a=a1 ;
select * from ff01 JOIN ff02 where a='2001-2-29' ;
SELECT * from ff01 NATURAL JOIN ff02 WHERE a='2001-2-29';
SELECT * from ff01 CROSS JOIN ff02 WHERE a='2001-2-29';
SELECT * from ff01 LEFT JOIN ff02 on a='2001-2-29';
SELECT * from ff01 RIGHT JOIN ff02 on a='2001-2-29';
SELECT * from ff01 LEFT JOIN ff02 on a=a1 WHERE a='2001-2-29';
SELECT * from ff01 RIGHT JOIN ff02 on a=a1 where a = '2001-2-29';
SELECT * from ff01 WHERE a IN(SELECT a1 from ff02 WHERE a=a1);
SELECT * from ff01 WHERE a IN(SELECT a1 from ff02 WHERE a='2001-2-29');
SELECT * from ff01 WHERE a NOT IN(SELECT a1 from ff02 WHERE a=a1);
SELECT * from ff02 WHERE a1 NOT IN(SELECT a from ff01 WHERE a1='2001-2-29');
SELECT a from ff01 where a = '1900-2-29' UNION SELECT a1 from ff02 where a1='01.2.29';
SELECT a from ff01 where a = '1900-2-29' UNION ALL SELECT a1 from ff02 where a1='01.2.29';
##mysql不支持##
SELECT a from ff01 where a = '1900-2-29' EXCEPT SELECT a1 from ff02 where a1='01.2.29';
##mysqlfulljoin有问题##
SELECT * from ff01 FULL JOIN ff02 on a1='2001-2-29';
SELECT * from ff01 FULL JOIN ff02 on a1=a;


##timestamp类型列插入非法日期，查询的时候如果条件是字段为空，ob会显示所有数据##
--disable_warnings
drop table if EXISTS ff02;
--enable_warnings
CREATE table ff02 (a timestamp);
insert into ff02 values('2001-2-29');
insert into ff02 values('2002-2-30');
insert into ff02 values('2003-2-31');
insert into ff02 values('2004-4-31');
select * from ff02 where a = '';
--disable_warnings
drop table if EXISTS ff02;
--enable_warnings

##prepare##
PREPARE stmt1 FROM 'select date(?)';
SET @a = '2001-2-29';
EXECUTE stmt1 USING @a;
DROP PREPARE stmt1;
PREPARE stmt1 FROM 'select date(concat(year(?),"/",month(?),"/",day(?)))';
SET @a = '2001-2-29';
SET @b = '2001-2-29';
SET @c = '2001-2-29';
EXECUTE stmt1 USING @a,@b,@c;
DROP PREPARE stmt1;

--disable_warnings
drop table if EXISTS ff01;
--enable_warnings

connection default;
--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings

