drop PROCEDURE IF EXISTS tcur;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime ;
	DECLARE b1 date ;
	DECLARE c1 timestamp ;
	DECLARE a2 varchar(10) ;
	DECLARE b2 varchar(10) ;
	DECLARE c2 varchar(10) ;
	DECLARE done int;
	DECLARE id int;
	DECLARE cur01 CURSOR FOR SELECT a1,b1,c1;
	DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;
    SET a1 = '2010-2-29';
    SET b1 = '2011-2-30';
    SET c1 = '2012-2-31';
    SET id = 8;
	OPEN cur01;
	posloop:LOOP
		IF done=1 THEN LEAVE posloop;
	    END IF;
	   	FETCH cur01 INTO a2,b2,c2;
		SELECT a2,b2,c2;
		INSERT INTO ff01 VALUES(id,a2,b2,c2);
		SET id = id+1;
	END LOOP posloop;
	CLOSE cur01;
END;
//
CALL tcur();
+------------+------------+------------+
| a2         | b2         | c2         |
+------------+------------+------------+
+------------+------------+------------+
| a2         | b2         | c2         |
+------------+------------+------------+
| 2010-02-29 | 2011-02-30 | 0000-00-00 |
| 2010-02-29 | 2011-02-30 | 0000-00-00 |
+------------+------------+------------+
+------------+------------+------------+
