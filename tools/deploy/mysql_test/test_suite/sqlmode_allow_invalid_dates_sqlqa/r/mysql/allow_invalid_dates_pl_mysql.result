drop PROCEDURE IF EXISTS tcur;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime;
	DECLARE b1 date;
	DECLARE c1 timestamp;
	DECLARE cur01 CURSOR FOR SELECT a,b,c FROM ff01;
	OPEN cur01;
	FETCH cur01 INTO a1,b1,c1;
	SELECT a1,b1,c1;
	CLOSE cur01;
END;
//
CALL tcur();
+---------------------+------------+---------------------+
| a1                  | b1         | c1                  |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2001-02-29 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
drop PROCEDURE IF EXISTS tcur;
CREATE PROCEDURE tcur()
BEGIN
	DECLARE a1 datetime;
	DECLARE b1 date;
	DECLARE c1 timestamp;
	DECLARE done int;
	DECLARE cur01 CURSOR FOR SELECT a,b,c FROM ff01;
	DECLARE CONTINUE HANDLER FOR NOT FOUND SET done=1;
	OPEN cur01;
	posloop:LOOP
		IF done=1 THEN LEAVE posloop;
	    END IF;
		FETCH cur01 INTO a1,b1,c1;
		SELECT a1,b1,c1;
	END LOOP posloop;
	CLOSE cur01;
END;
//
CALL tcur();
