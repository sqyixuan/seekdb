##存储过程##
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01()
BEGIN
	DECLARE a date;
	DECLARE b datetime;
	SET a = '2001-2-29';
	SET b = '2001-2-30';
	SELECT a,b;
END;
//
CALL pro01();
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 2001-02-29 | 2001-02-30 00:00:00 |
+------------+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a DATE)
BEGIN
	DECLARE b datetime;
	SET b = a;
	SELECT b;
END;
//
CALL pro01('2010-2-29');
+---------------------+
| b                   |
+---------------------+
| 2010-02-29 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(OUT a DATE)
BEGIN
	DECLARE b datetime DEFAULT '1900-2-29';
	SET a = b;
END;
//
CALL pro01(@a);
SELECT @a;
+------------+
| @a         |
+------------+
| 1900-02-29 |
+------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	SET b = a ;
END;
//
CALL pro01('1999-2-29',@b);
SELECT @b;
+---------------------+
| @b                  |
+---------------------+
| 1999-02-29 00:00:00 |
+---------------------+
drop TABLE if EXISTS ff01;
CREATE TABLE ff01 (a date,b datetime);
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(IN a varchar(20))
BEGIN
	INSERT into ff01 VALUES (a,a);
END;
//
CALL pro01('99.2.31');
SELECT * from ff01;
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 1999-02-31 | 1999-02-31 00:00:00 |
+------------+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	IF a = '99.3.1' THEN
		set b = a+2;
	ELSEIF a = '99.2.29' THEN
		SET b = a+1;
	ELSE
		SET b = a;
	END IF;
	SELECT b;
END;
//
CALL pro01('99.2.29');
+---------------------+
| b                   |
+---------------------+
| 1999-02-30 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	IF a = '99.3.1' THEN
		set b = a;
	ELSE
		SET b = a+1;
	END IF;
	SELECT b;
END;
//
CALL pro01('99.3.31');
+---------------------+
| b                   |
+---------------------+
| 0000-00-00 00:00:00 |
+---------------------+
CALL pro01('99.4.31');
+---------------------+
| b                   |
+---------------------+
| 0000-00-00 00:00:00 |
+---------------------+
CALL pro01('99.2.28');
+---------------------+
| b                   |
+---------------------+
| 1999-02-29 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	IF a > '99.2.30' THEN
		UPDATE ff01 set a = a;
	ELSE
		UPDATE ff01 set a = a+1;
	END IF;
END;
//
CALL pro01('99.2.29');
SELECT * from ff01;
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 1999-02-30 | 1999-02-31 00:00:00 |
+------------+---------------------+
CALL pro01('99.2.30');
SELECT * from ff01;
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 1999-02-31 | 1999-02-31 00:00:00 |
+------------+---------------------+
CALL pro01('99.2.31');
SELECT * from ff01;
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 1999-02-31 | 1999-02-31 00:00:00 |
+------------+---------------------+
##mysql显示2.29，ob显示3.2##
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	CASE a
	 WHEN '1990-2-29' THEN
     	SET b = a+1;
	 ELSE
	 	SET b = a ;
	END CASE;
	SELECT b;
END;
//
CALL pro01('1990-2-29');
+---------------------+
| b                   |
+---------------------+
| 1990-02-30 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	CASE a
	 WHEN '1990-2-29' THEN
	 	SET b = a+1 ;
	 WHEN '1990-2-30' THEN
	 	SET b = a+2;
	 WHEN '1990-2-31' THEN
	 	SET b = a+3;
	 WHEN '1990-3-1' THEN
	 	SET b = a+4;
	 ELSE
	 	SET b = a ;
	END CASE;
END;
//
CALL pro01('1990-3-1',@b);
SELECT @b;
+---------------------+
| @b                  |
+---------------------+
| 1990-03-05 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date,OUT b datetime)
BEGIN
	WHILE a < '2001-2-30' DO
		SET b = a + 1;
		SET a = a + 1;
	END WHILE;
END;
//
CALL pro01('2001.2.28',@b);
SELECT @b;
+---------------------+
| @b                  |
+---------------------+
| 2001-02-30 00:00:00 |
+---------------------+
CALL pro01('2001.2.29',@b);
SELECT @b;
+---------------------+
| @b                  |
+---------------------+
| 2001-02-30 00:00:00 |
+---------------------+
##mysql显示null##
CALL pro01('2001.3.1',@b);
SELECT @b;
+------+
| @b   |
+------+
| NULL |
+------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	REPEAT
		SET b = a + 1 ;
		SET a = a + 1 ;
		until a > '2001-2-30'
	END REPEAT;
	SELECT b;
END;
//
CALL pro01('2001-2-29');
+---------------------+
| b                   |
+---------------------+
| 2001-02-31 00:00:00 |
+---------------------+
drop PROCEDURE IF EXISTS pro01;
CREATE PROCEDURE pro01(in a date)
BEGIN
	DECLARE b datetime;
	loop01:LOOP
		SET b = a + 1 ;
		SET a = a + 1 ;
		IF a > '2001-2-30' THEN
			LEAVE loop01;
		END IF;
	END LOOP;
	SELECT b;
END;
//
CALL pro01('2001-2-29');
+---------------------+
| b                   |
+---------------------+
| 2001-02-31 00:00:00 |
+---------------------+
##函数##
DROP FUNCTION IF EXISTS fun01;
CREATE FUNCTION fun01(a date) RETURNS date
BEGIN
	RETURN a + 1;
END;
//
SELECT fun01('2001-2-29');
+--------------------+
| fun01('2001-2-29') |
+--------------------+
| 2001-02-30         |
+--------------------+
DROP FUNCTION IF EXISTS fun01;
CREATE FUNCTION fun01() RETURNS date
BEGIN
	RETURN '1900.2.29';
END;
//
SELECT fun01();
+------------+
| fun01()    |
+------------+
| 1900-02-29 |
+------------+
DROP FUNCTION IF EXISTS fun01;
CREATE FUNCTION fun01() RETURNS date
BEGIN
	set @a = '1900.2-29';
	RETURN @a;
END;
//
SELECT fun01();
+------------+
| fun01()    |
+------------+
| 1900-02-29 |
+------------+
##mysql显示0000-00-00，mysql两个日期相加如果是非法日期会显示null##
DROP FUNCTION IF EXISTS fun01;
CREATE FUNCTION fun01(a date,b date) RETURNS date
BEGIN
	set @c = a + b;
	RETURN @c;
END;
//
SELECT fun01('1999.2.29','1999.2.30');
+--------------------------------+
| fun01('1999.2.29','1999.2.30') |
+--------------------------------+
| 0000-00-00                     |
+--------------------------------+
DROP FUNCTION IF EXISTS fun01;
CREATE FUNCTION fun01(a date,b date) RETURNS varchar(20)
BEGIN
	set @c = a + b;
	RETURN @c;
END;
//
SELECT fun01('1999.2.29','1999.2.30');
+--------------------------------+
| fun01('1999.2.29','1999.2.30') |
+--------------------------------+
| 39980459                       |
+--------------------------------+
drop table if EXISTS ff01;
