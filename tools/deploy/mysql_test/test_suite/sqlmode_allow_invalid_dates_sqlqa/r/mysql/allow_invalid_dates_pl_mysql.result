BEGIN
	DECLARE a date;
	DECLARE b datetime;
	DECLARE c timestamp;
	SET a = '1990-2-29';
	SET b = '1991-2-30';
	SET c = '92.2.31';
	INSERT into ff02 VALUES(a,b,c);
END;
