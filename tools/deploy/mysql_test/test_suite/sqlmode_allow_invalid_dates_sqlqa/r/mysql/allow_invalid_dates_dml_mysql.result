drop user 'zc_subquery_mysql'@'%';
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;


SET SESSION sql_mode ='ALLOW_INVALID_DATES';
####insert,update####
##table##
##数据date'2006-9-31',date'2006-9-31',date'2006-9-31'mysql插入后为null，null，当前时间戳##
drop table if EXISTS ff01;
CREATE TABLE ff01 (a date,b datetime,c timestamp);
INSERT INTO ff01 VALUES ('2001-2-29','2001-2-29','2001-2-29');
INSERT INTO ff01 VALUES ('2002/2/30','2002/2/30','2002/2/30');
INSERT INTO ff01 VALUES ('2003:2:31','2003:2:31','2003:2:31');
INSERT INTO ff01 VALUES ('2004431','2004431','2004431');
INSERT INTO ff01 VALUES (2005631,2005631,2005631);
INSERT INTO ff01 VALUES (date'2006-9-31',date'2006-9-31',date'2006-9-31');
INSERT INTO ff01 VALUES ('2007-11-31','2007-11-31','2007-11-31');
INSERT INTO ff01 VALUES ('1900-2-29','1900-2-29','1900-2-29');
SELECT * from ff01;
+------------+---------------------+---------------------+
| a          | b                   | c                   |
+------------+---------------------+---------------------+
| 2001-02-29 | 2001-02-29 00:00:00 | 0000-00-00 00:00:00 |
| 2002-02-30 | 2002-02-30 00:00:00 | 0000-00-00 00:00:00 |
| 2003-02-31 | 2003-02-31 00:00:00 | 0000-00-00 00:00:00 |
| 0000-00-00 | 0000-00-00 00:00:00 | 0000-00-00 00:00:00 |
| 0000-00-00 | 0000-00-00 00:00:00 | 0000-00-00 00:00:00 |
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
| 2007-11-31 | 2007-11-31 00:00:00 | 0000-00-00 00:00:00 |
| 1900-02-29 | 1900-02-29 00:00:00 | 0000-00-00 00:00:00 |
+------------+---------------------+---------------------+
UPDATE ff01 set a='1900-2-29',b='1900-2-29',c='1900-2-29' WHERE a = '2001-2-29';
UPDATE ff01 set a='2001-2-29',b='2001-2-29',c='2001-2-29' WHERE b < '2001-2-29';
UPDATE ff01 set a=date('2006-9-31'),b=date('2006-9-31'),c=date('2006-9-31') WHERE b in ('2001-2-29');
select * from ff01;
+------------+---------------------+---------------------+
| a          | b                   | c                   |
+------------+---------------------+---------------------+
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
| 2002-02-30 | 2002-02-30 00:00:00 | 0000-00-00 00:00:00 |
| 2003-02-31 | 2003-02-31 00:00:00 | 0000-00-00 00:00:00 |
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
| 2007-11-31 | 2007-11-31 00:00:00 | 0000-00-00 00:00:00 |
| 2006-09-31 | 2006-09-31 00:00:00 | 0000-00-00 00:00:00 |
+------------+---------------------+---------------------+
drop table if EXISTS ff01;
CREATE TABLE ff01 (a date PRIMARY KEY,b datetime UNIQUE KEY,c timestamp ,d date,CHECK (d > '2001-2-29' ) );
##ob转换日期主键冲突无法插入##
INSERT into ff01 VALUES ('2001-2-29','2002-2-30','2003-4-31','2001-6-31'),
                        ('2001-3-1','2002-2-31','2003-4-31','2001-6-31');
INSERT into ff01 VALUES ('2001-2-29','2002-2-30','2003-4-31','2001-3-2');
ERROR 23000: Duplicate entry '2001-02-29' for key 'PRIMARY'
INSERT into ff01 VALUES ('2001-2-30','2002-2-31','2003-4-31','2002-3-1');
ERROR 23000: Duplicate entry '2002-02-31 00:00:00.000000' for key 'b'
SELECT * from ff01;
+------------+---------------------+---------------------+------------+
| a          | b                   | c                   | d          |
+------------+---------------------+---------------------+------------+
| 2001-02-29 | 2002-02-30 00:00:00 | 0000-00-00 00:00:00 | 2001-06-31 |
| 2001-03-01 | 2002-02-31 00:00:00 | 0000-00-00 00:00:00 | 2001-06-31 |
+------------+---------------------+---------------------+------------+
##ob转换日期违反check约束无法插入##
INSERT into ff01 VALUES ('2001-2-29','2002-2-30','2003-4-31','2001-3-1');
ERROR 23000: Duplicate entry '2001-02-29' for key 'PRIMARY'
UPDATE ff01 set a='2001-2-31',b='2002-2-29',c='2003-6-31',d='2001-3-1' where a='2001-2-29';
UPDATE ff01 set a='2001-4-31',b='2002-6-31',c='2003-9-31',d='2001-11-31' ORDER by '2001-2-29' LIMIT 1;
UPDATE ff01 set d='2001-3-1' ORDER by '2001-2-29' LIMIT 1;
##mysql结果为0000-00-00##
UPDATE ff01 set c=date('2001-2-29') ORDER by '2001-2-29' LIMIT 1;
##mysql结果为当前时间戳##
UPDATE ff01 set c=date'2001-2-30' ORDER by '2001-2-29' LIMIT 1;
##mysql结果为0000-00-00##
UPDATE ff01 set c=timestamp('2001-2-29') ORDER by '2001-2-29' LIMIT 1;
SELECT * from ff01;
+------------+---------------------+---------------------+------------+
| a          | b                   | c                   | d          |
+------------+---------------------+---------------------+------------+
| 2001-03-01 | 2002-02-31 00:00:00 | 0000-00-00 00:00:00 | 2001-03-01 |
| 2001-04-31 | 2002-06-31 00:00:00 | 0000-00-00 00:00:00 | 2001-11-31 |
+------------+---------------------+---------------------+------------+
DELETE from ff01;
##视图##
drop view if EXISTS vv01;
CREATE VIEW vv01 as select a,b,c from ff01;
INSERT INTO vv01 VALUES ('2001-2-29','2001-2-29','2001-2-29'),
                        ('2002/2/30','2002/2/30','2002/2/30'),
                        ('2003:2:31','2003:2:31','2003:2:31'),
                        (2005631,2005631,2005631),
                        ('2007-11-31','2007-11-31','2007-11-31'),
                        ('1900-2-29','1900-2-29','1900-2-29');
SELECT * from vv01;
+------------+---------------------+---------------------+
| a          | b                   | c                   |
+------------+---------------------+---------------------+
| 0000-00-00 | 0000-00-00 00:00:00 | 0000-00-00 00:00:00 |
| 1900-02-29 | 1900-02-29 00:00:00 | 0000-00-00 00:00:00 |
| 2001-02-29 | 2001-02-29 00:00:00 | 0000-00-00 00:00:00 |
| 2002-02-30 | 2002-02-30 00:00:00 | 0000-00-00 00:00:00 |
| 2003-02-31 | 2003-02-31 00:00:00 | 0000-00-00 00:00:00 |
| 2007-11-31 | 2007-11-31 00:00:00 | 0000-00-00 00:00:00 |
+------------+---------------------+---------------------+
UPDATE vv01 set a='2010-2-29',b='2010-2-29',c='2010-2-29' WHERE a='2001-2-29';
UPDATE vv01 set a='11-2-30',b='11-2-30',c='11-2-30' WHERE a in ('2002-2-30');
UPDATE vv01 set a='12.2.31',b='12.2.31',c='12.2.31' WHERE a='03.2.31';
UPDATE vv01 set a='13.4.31',b='13.4.31',c='13.4.31' ORDER by '2001-2-29' LIMIT 1;
##外键表##
drop TABLE if EXISTS ff01;
CREATE TABLE ff01 (a1 date PRIMARY key,b1 datetime DEFAULT '2001-2-29');
drop TABLE if EXISTS ff02;
Warnings:
Note	1051	Unknown table 'test.ff02'
CREATE TABLE ff02 (a2 date ,CONSTRAINT fk FOREIGN KEY(a2) REFERENCES ff01(a1));
INSERT into ff01(a1) VALUES('2001-2-29');
INSERT into ff02 VALUES('2001-2-29');
##ob因为转换日期可以插入，mysql因外键约束无法插入##
INSERT into ff01(a1) VALUES('2001-2-30');
INSERT into ff02 VALUES('2001-3-2');
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
INSERT into ff01(a1) VALUES('2001-3-3');
INSERT into ff02 VALUES('2001-2-31');
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
SELECT * from ff01;
+------------+---------------------+
| a1         | b1                  |
+------------+---------------------+
| 2001-02-29 | 2001-02-29 00:00:00 |
| 2001-02-30 | 2001-02-29 00:00:00 |
| 2001-03-03 | 2001-02-29 00:00:00 |
+------------+---------------------+
SELECT * from ff02;
+------------+
| a2         |
+------------+
| 2001-02-29 |
+------------+
UPDATE ff02 set a2='01.2.29' WHERE a2='01.2.30';
UPDATE ff01 set a1='2010-2-29',b1='2010-2-29' WHERE a1='2001-2-30';
UPDATE ff01,ff02 set ff01.b1='10.6.31' where ff01.a1=ff02.a2;
UPDATE ff01,ff02 set ff01.a1='01.2.31',ff02.a2='10.2.29' where ff01.a1=ff02.a2;
UPDATE ff01,ff02 set ff01.a1='11.2.30',ff02.a2='11.2.30' where ff01.a1=ff02.a2;
DELETE from ff02 WHERE a2='01.2.30';
drop TABLE if EXISTS ff02;
##分区表##
##RANGE COLUMNS##
drop TABLE if EXISTS ff01;
CREATE TABLE ff01 (a datetime , b date ,c timestamp NOT NULL)
PARTITION BY RANGE COLUMNS(b)(PARTITION p0 VALUES less than ('2001-5-1'),
                              PARTITION p1 VALUES less than ('2002-6-1'),
                              PARTITION p2 VALUES less than ('2003-7-1'),
                              PARTITION p3 VALUES less than MAXVALUE
                              );
INSERT into ff01 PARTITION(p0) VALUES ('2001-2-29','2001-2-29','2001-2-29');
SELECT * from ff01 PARTITION(p0);
+---------------------+------------+---------------------+
| a                   | b          | c                   |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2001-02-29 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
INSERT into ff01 PARTITION(p1) VALUES ('2001-2-29','2002-4-31','2001-2-29');
SELECT * from ff01 PARTITION(p1);
+---------------------+------------+---------------------+
| a                   | b          | c                   |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2002-04-31 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
INSERT into ff01 PARTITION(p2) VALUES ('2001-2-29','2003-5-31','2001-2-29');
SELECT * from ff01 PARTITION(p2);
+---------------------+------------+---------------------+
| a                   | b          | c                   |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2003-05-31 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
INSERT into ff01 PARTITION(p3) VALUES ('2001-2-29','2100-2-29','2001-2-29');
SELECT * from ff01 PARTITION(p3);
+---------------------+------------+---------------------+
| a                   | b          | c                   |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2100-02-29 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
select * from ff01;
+---------------------+------------+---------------------+
| a                   | b          | c                   |
+---------------------+------------+---------------------+
| 2001-02-29 00:00:00 | 2001-02-29 | 0000-00-00 00:00:00 |
| 2001-02-29 00:00:00 | 2002-04-31 | 0000-00-00 00:00:00 |
| 2001-02-29 00:00:00 | 2003-05-31 | 0000-00-00 00:00:00 |
| 2001-02-29 00:00:00 | 2100-02-29 | 0000-00-00 00:00:00 |
+---------------------+------------+---------------------+
