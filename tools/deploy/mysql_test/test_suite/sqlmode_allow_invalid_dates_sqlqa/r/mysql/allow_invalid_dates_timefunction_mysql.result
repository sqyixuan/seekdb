##datediff##
SELECT datediff('96-2-30','96-3-30'),
       datediff('996-10-31','96-3-30'),
       datediff('22/2/29','22-2-31'),
       datediff('1900-2-29','1900-2-28'),
       datediff(date('2006-9-31'),date('2007-11-31')),
       datediff(NULL,NULL);
