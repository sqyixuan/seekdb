| CAST(date'01.2.29' as decimal) |
+--------------------------------+
|                       20010229 |
+--------------------------------+
####比较函数####
##GREATEST,LEAST##
SELECT GREATEST('2000-2-29','2001-2-29'),
       GREATEST(DATE('1900-2-29'),DATE('2001-2-29')),
       GREATEST('2001-2-29','2002-9-31'),
       GREATEST('2001-2-29','2001-3-1'),
       GREATEST(DATE('2001/2/29'),DATE('2001-3-1')),
       GREATEST('2001/2/29','2001-2-29'),
       GREATEST(NULL,NULL);
+-----------------------------------+-----------------------------------------------+-----------------------------------+----------------------------------+----------------------------------------------+-----------------------------------+---------------------+
| GREATEST('2000-2-29','2001-2-29') | GREATEST(DATE('1900-2-29'),DATE('2001-2-29')) | GREATEST('2001-2-29','2002-9-31') | GREATEST('2001-2-29','2001-3-1') | GREATEST(DATE('2001/2/29'),DATE('2001-3-1')) | GREATEST('2001/2/29','2001-2-29') | GREATEST(NULL,NULL) |
+-----------------------------------+-----------------------------------------------+-----------------------------------+----------------------------------+----------------------------------------------+-----------------------------------+---------------------+
| 2001-2-29                         | 2001-02-29                                    | 2002-9-31                         | 2001-3-1                         | 2001-03-01                                   | 2001/2/29                         |                NULL |
+-----------------------------------+-----------------------------------------------+-----------------------------------+----------------------------------+----------------------------------------------+-----------------------------------+---------------------+
SELECT LEAST('2000-2-29','2001-2-29'),
       LEAST(DATE('1900-2-29'),DATE('2001-2-29')),
       LEAST('2001-2-29','2002-9-31'),
       LEAST('2001-2-29','2001-3-1'),
       LEAST(DATE('2001/2/29'),DATE('2001-3-1')),
       LEAST('2001/2/29','2001-2-29'),
       LEAST(NULL,NULL);
+--------------------------------+--------------------------------------------+--------------------------------+-------------------------------+-------------------------------------------+--------------------------------+------------------+
| LEAST('2000-2-29','2001-2-29') | LEAST(DATE('1900-2-29'),DATE('2001-2-29')) | LEAST('2001-2-29','2002-9-31') | LEAST('2001-2-29','2001-3-1') | LEAST(DATE('2001/2/29'),DATE('2001-3-1')) | LEAST('2001/2/29','2001-2-29') | LEAST(NULL,NULL) |
+--------------------------------+--------------------------------------------+--------------------------------+-------------------------------+-------------------------------------------+--------------------------------+------------------+
| 2000-2-29                      | 1900-02-29                                 | 2001-2-29                      | 2001-2-29                     | 2001-02-29                                | 2001-2-29                      |             NULL |
+--------------------------------+--------------------------------------------+--------------------------------+-------------------------------+-------------------------------------------+--------------------------------+------------------+
