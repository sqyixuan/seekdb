##str_to_date,GET_FORMAT##
##格式'%Y%m%d'ob总会显示输入年份前一年的11月30号，mysql显示null##
SELECT str_to_date('2000-2-29',get_format(DATE,'USA')),
       str_to_date('2001-2-29',get_format(DATE,'JIS')),
       str_to_date('2002-2-30',get_format(DATE,'ISO')),
       str_to_date('2003-2-31',get_format(DATE,'EUR')),
       str_to_date('2004-4-31',get_format(DATE,'INTERNAL')),
       str_to_date('1900-2-29','%y/%m/%d'),
       str_to_date(NULL,NULL);
+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+------------------------------------------------------+-------------------------------------+------------------------+
| str_to_date('2000-2-29',get_format(DATE,'USA')) | str_to_date('2001-2-29',get_format(DATE,'JIS')) | str_to_date('2002-2-30',get_format(DATE,'ISO')) | str_to_date('2003-2-31',get_format(DATE,'EUR')) | str_to_date('2004-4-31',get_format(DATE,'INTERNAL')) | str_to_date('1900-2-29','%y/%m/%d') | str_to_date(NULL,NULL) |
+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+------------------------------------------------------+-------------------------------------+------------------------+
| NULL                                            | 2001-02-29 00:00:00.000000                      | 2002-02-30 00:00:00.000000                      | NULL                                            | 2004-00-00 00:00:00.000000                           | NULL                                | NULL                   |
+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+-------------------------------------------------+------------------------------------------------------+-------------------------------------+------------------------+
Warnings:
Warning	1411	Incorrect datetime value: '2000-2-29' for function str_to_date
Warning	1411	Incorrect datetime value: '2003-2-31' for function str_to_date
Warning	1411	Incorrect datetime value: '1900-2-29' for function str_to_date
