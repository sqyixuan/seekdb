result_format: 4
drop user 'zc_subquery_mysql'@'%';
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;


SET SESSION sql_mode ='ALLOW_INVALID_DATES';
####日期函数####
##CURDATE##
##date##
##日期'2020-0-29'ob显示null，mysql显示2020-00-29
select date('0000-01-01'),
       date('9999-12-31'),
       date('2022-13-31'),
       date('2020-0-29'),
       date('2022-2-30'),
       date('1996-2-31'),
       date('11-11-11'),
       date('08-11-31'),
       date('111-11-31'),
       date('92-2-29'),
       date('0000-00-00'),
       date(NULL);
+--------------------+--------------------+--------------------+-------------------+-------------------+-------------------+------------------+------------------+-------------------+-----------------+--------------------+------------+
| date('0000-01-01') | date('9999-12-31') | date('2022-13-31') | date('2020-0-29') | date('2022-2-30') | date('1996-2-31') | date('11-11-11') | date('08-11-31') | date('111-11-31') | date('92-2-29') | date('0000-00-00') | date(NULL) |
+--------------------+--------------------+--------------------+-------------------+-------------------+-------------------+------------------+------------------+-------------------+-----------------+--------------------+------------+
| 0000-01-01         | 9999-12-31         | NULL               | 2020-00-29        | 2022-02-30        | 1996-02-31        | 2011-11-11       | 2008-11-31       | 0111-11-31        | 1992-02-29      | 0000-00-00         | NULL       |
+--------------------+--------------------+--------------------+-------------------+-------------------+-------------------+------------------+------------------+-------------------+-----------------+--------------------+------------+
select date('2000-2-29'),
       date('2001-2-29'),
       date('2002-2-30'),
       date('2003-2-31'),
       date('2004-4-31'),
       date('2005-6-31'),
       date('2006-9-31'),
       date('2007-11-31'),
       date('1900-2-29');
+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+--------------------+-------------------+
| date('2000-2-29') | date('2001-2-29') | date('2002-2-30') | date('2003-2-31') | date('2004-4-31') | date('2005-6-31') | date('2006-9-31') | date('2007-11-31') | date('1900-2-29') |
+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+--------------------+-------------------+
| 2000-02-29        | 2001-02-29        | 2002-02-30        | 2003-02-31        | 2004-04-31        | 2005-06-31        | 2006-09-31        | 2007-11-31         | 1900-02-29        |
+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+-------------------+--------------------+-------------------+
##date_add,date_sub##
##组合时间间隔太多ob报错##
select date_add('96/2/25',INTERVAL 5 DAY),
       date_add('96/1/30',INTERVAL 1 MONTH),
       date_add('96/1/31',INTERVAL 1 QUARTER),
       date_add('97-2-29',INTERVAL -1 YEAR),
       date_add('996-2-28',INTERVAL '1 01' DAY_HOUR),
       date_add('1900/2/29',INTERVAL 1 DAY);
+------------------------------------+--------------------------------------+----------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+
| date_add('96/2/25',INTERVAL 5 DAY) | date_add('96/1/30',INTERVAL 1 MONTH) | date_add('96/1/31',INTERVAL 1 QUARTER) | date_add('97-2-29',INTERVAL -1 YEAR) | date_add('996-2-28',INTERVAL '1 01' DAY_HOUR) | date_add('1900/2/29',INTERVAL 1 DAY) |
+------------------------------------+--------------------------------------+----------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+
| 1996-03-01                         | 1996-02-29                           | 1996-04-30                             | 1996-03-01                           | 0996-02-29 01:00:00                           | 1900-03-02                           |
+------------------------------------+--------------------------------------+----------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+
SELECT date_sub('96-2-30',INTERVAL 1 DAY),
       date_sub('96-3-30',INTERVAL 1 MONTH),
       date_sub('1222-5-30',INTERVAL 1 QUARTER),
       date_sub('99-2-29',INTERVAL -1 YEAR),
       date_sub('996-2-28',INTERVAL '1 01' DAY_HOUR),
       date_sub('97-2-29',INTERVAL -1 HOUR),
       date_sub('1900-3-1',INTERVAL 1 DAY);
+------------------------------------+--------------------------------------+------------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+-------------------------------------+
| date_sub('96-2-30',INTERVAL 1 DAY) | date_sub('96-3-30',INTERVAL 1 MONTH) | date_sub('1222-5-30',INTERVAL 1 QUARTER) | date_sub('99-2-29',INTERVAL -1 YEAR) | date_sub('996-2-28',INTERVAL '1 01' DAY_HOUR) | date_sub('97-2-29',INTERVAL -1 HOUR) | date_sub('1900-3-1',INTERVAL 1 DAY) |
+------------------------------------+--------------------------------------+------------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+-------------------------------------+
| 1996-02-29                         | 1996-02-29                           | 1222-02-28                               | 2000-03-01                           | 0996-02-26 23:00:00                           | 1997-03-01 01:00:00                  | 1900-02-28                          |
+------------------------------------+--------------------------------------+------------------------------------------+--------------------------------------+-----------------------------------------------+--------------------------------------+-------------------------------------+
