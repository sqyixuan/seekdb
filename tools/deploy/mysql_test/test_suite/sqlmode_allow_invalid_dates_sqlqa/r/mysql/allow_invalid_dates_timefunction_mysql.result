##类型转换##
drop TABLE IF EXISTS ff01;
Warnings:
Note	1051	Unknown table 'test.ff01'
CREATE TABLE ff01 (a int,b varchar(20),c blob,d TINYTEXT);
INSERT into ff01 VALUES (date'01.2.29',date'01.2.29',date'01.2.29',date'01.2.29');
select * from ff01;
+----------+------------+------------+------------+
| a        | b          | c          | d          |
+----------+------------+------------+------------+
| 20010229 | 2001-02-29 | 2001-02-29 | 2001-02-29 |
+----------+------------+------------+------------+
drop table if EXISTS ff01;
CREATE TABLE ff01 (a date,b datetime);
INSERT into ff01 VALUES ('01.2.29','01.2.29');
INSERT into ff01 VALUES (20010230,20010230);
SELECT * from ff01;
+------------+---------------------+
| a          | b                   |
+------------+---------------------+
| 2001-02-29 | 2001-02-29 00:00:00 |
| 2001-02-30 | 2001-02-30 00:00:00 |
+------------+---------------------+
DROP TABLE IF EXISTS ff01;
