##TIMESTAMP##
##处理逻辑与date函数相同##
SELECT TIMESTAMP('2000-2-29'),
       TIMESTAMP('2001-2-29'),
       TIMESTAMP('2005-6-31'),
       TIMESTAMP('1900-2-29'),
       TIMESTAMP(date('2007-11-31')),
       TIMESTAMP(null),
       TIMESTAMP('1900-2-29','1900-2-29'),
       TIMESTAMP(date('2003-2-31'),date('2006-9-31'));
+----------------------------+----------------------------+----------------------------+----------------------------+-------------------------------+-----------------+------------------------------------+------------------------------------------------+
| TIMESTAMP('2000-2-29')     | TIMESTAMP('2001-2-29')     | TIMESTAMP('2005-6-31')     | TIMESTAMP('1900-2-29')     | TIMESTAMP(date('2007-11-31')) | TIMESTAMP(null) | TIMESTAMP('1900-2-29','1900-2-29') | TIMESTAMP(date('2003-2-31'),date('2006-9-31')) |
+----------------------------+----------------------------+----------------------------+----------------------------+-------------------------------+-----------------+------------------------------------+------------------------------------------------+
| 2000-02-29 00:00:00.000000 | 2001-02-29 00:00:00.000000 | 2005-06-31 00:00:00.000000 | 1900-02-29 00:00:00.000000 | 2007-11-31 00:00:00           | NULL            | 1900-03-01 00:19:00.000000         | 2003-03-03 00:00:00                            |
+----------------------------+----------------------------+----------------------------+----------------------------+-------------------------------+-----------------+------------------------------------+------------------------------------------------+
##TIMESTAMPADD，TIMESTAMPDIFF##
##mysql不支持组合unit##
##设置了模式后TIMESTAMPADD,TIMESTAMPDIFF函数无法处理非法日期，要用date处理后才能处理，mysql可以处理非法日期##
SELECT TIMESTAMPADD(SECOND,1,'2000-2-29 23:59:59'),
       TIMESTAMPADD(HOUR,1,'2001-2-29 23:59:59'),
       TIMESTAMPADD(DAY,-1,'1900-2-29'),
       TIMESTAMPADD(WEEK,1,'2001-2-22'),
       TIMESTAMPADD(MONTH,1,'2002-4-31'),
       TIMESTAMPADD(QUARTER,-1,'2000-6-31'),
       TIMESTAMPADD(YEAR,-1,'2001-2-29'),
       TIMESTAMPADD(DAY,-1,DATE('2001-2-29')),
       TIMESTAMPADD(SECOND,NULL,NULL);
+---------------------------------------------+-------------------------------------------+----------------------------------+----------------------------------+-----------------------------------+--------------------------------------+-----------------------------------+----------------------------------------+--------------------------------+
| TIMESTAMPADD(SECOND,1,'2000-2-29 23:59:59') | TIMESTAMPADD(HOUR,1,'2001-2-29 23:59:59') | TIMESTAMPADD(DAY,-1,'1900-2-29') | TIMESTAMPADD(WEEK,1,'2001-2-22') | TIMESTAMPADD(MONTH,1,'2002-4-31') | TIMESTAMPADD(QUARTER,-1,'2000-6-31') | TIMESTAMPADD(YEAR,-1,'2001-2-29') | TIMESTAMPADD(DAY,-1,DATE('2001-2-29')) | TIMESTAMPADD(SECOND,NULL,NULL) |
+---------------------------------------------+-------------------------------------------+----------------------------------+----------------------------------+-----------------------------------+--------------------------------------+-----------------------------------+----------------------------------------+--------------------------------+
| 2000-03-01 00:00:00                         | NULL                                      | NULL                             | 2001-03-01 00:00:00              | NULL                              | NULL                                 | NULL                              | 2001-02-28 00:00:00                    | NULL                           |
+---------------------------------------------+-------------------------------------------+----------------------------------+----------------------------------+-----------------------------------+--------------------------------------+-----------------------------------+----------------------------------------+--------------------------------+
select TIMESTAMPDIFF(DAY,'1900-2-29','1900-3-1'),
       TIMESTAMPDIFF(HOUR,'2001-2-29 11:11:11','2001-3-1 12:12:12'),
       TIMESTAMPDIFF(WEEK,'2005-6-31','2006/9/31'),
       TIMESTAMPDIFF(DAY,DATE('2001-2-29'),DATE('2001/3/1')),
       TIMESTAMPDIFF(MONTH,'2001-2-29','2001/3/1'),
       TIMESTAMPDIFF(QUARTER,'2001-3-31','2001/6/31'),
       TIMESTAMPDIFF(YEAR,'2000-2-29','2001/2/29'),
       TIMESTAMPDIFF(DAY,NULL,NULL);
+-------------------------------------------+--------------------------------------------------------------+---------------------------------------------+-------------------------------------------------------+---------------------------------------------+------------------------------------------------+---------------------------------------------+------------------------------+
