| EXTRACT(DAY from '2000-2-29') | EXTRACT(WEEK from '2001-2-29') | EXTRACT(MONTH from '2002-2-30') | EXTRACT(QUARTER from '2003-2-31') | EXTRACT(YEAR from '2004-4-31') | EXTRACT(YEAR_MONTH from '2005-6-31') | EXTRACT(DAY_HOUR from '2006-9-31 1:1') | EXTRACT(DAY from '1900-2-29') | EXTRACT(DAY from NULL) |
