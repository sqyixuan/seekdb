####转换函数####
##cast##
SELECT CAST('2001-2-29' as date),
       CAST('1900/2/29' as date),
       CAST(2001-2-29 as date),
       CAST(20000229 as date),
       CAST(20000229111111 as datetime),
       CAST(20010229121212 as datetime),
       CAST(format(20010229121212.123,0) as datetime),
       CAST(ROUND(19000229.567) as datetime),
       CAST(NULL as date);
+---------------------------+---------------------------+-------------------------+------------------------+----------------------------------+----------------------------------+------------------------------------------------+---------------------------------------+--------------------+
| CAST('2001-2-29' as date) | CAST('1900/2/29' as date) | CAST(2001-2-29 as date) | CAST(20000229 as date) | CAST(20000229111111 as datetime) | CAST(20010229121212 as datetime) | CAST(format(20010229121212.123,0) as datetime) | CAST(ROUND(19000229.567) as datetime) | CAST(NULL as date) |
+---------------------------+---------------------------+-------------------------+------------------------+----------------------------------+----------------------------------+------------------------------------------------+---------------------------------------+--------------------+
| 2001-02-29                | 1900-02-29                | NULL                    | 2000-02-29             | 2000-02-29 11:11:11              | NULL                             | NULL                                           | NULL                                  | NULL               |
+---------------------------+---------------------------+-------------------------+------------------------+----------------------------------+----------------------------------+------------------------------------------------+---------------------------------------+--------------------+
