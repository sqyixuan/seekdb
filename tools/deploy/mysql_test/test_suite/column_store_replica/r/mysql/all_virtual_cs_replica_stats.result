===============================================================
=== Step 0: create tenant with cs replica locality in z2 ======
===============================================================
===============================================================
=== Step 2: create table, prepare basic data ==================
===============================================================
drop table if exists t1,t2,t3,tload;
drop sequence if exists seq;
create table t1 (k int primary key, v1 int, v2 int, v3 int);
create table t2 (k int primary key, v1 int, v2 int, v3 int) with column group(each column);
create table t3 (k int primary key, v1 int, v2 int, v3 int) with column group(all columns, each column);
create table tload (k int primary key, v1 int, v2 int, v3 int);
create index idx1 on t1(v1);
create index idx2 on t2(v1);
create index idx3 on t3(v1);
create index idx4 on t1(v2) with column group(each column);
create index idx5 on t2(v2) with column group(each column);
create index idx6 on t3(v2) with column group(each column);
create index idx7 on t1(v3) with column group(all columns, each column);
create index idx8 on t2(v3) with column group(all columns, each column);
create index idx9 on t3(v3) with column group(all columns, each column);
create sequence seq cache 100000 noorder;
insert into tload select seq.nextval + 10, seq.nextval + 11, seq.nextval + 12, seq.nextval + 13 from table(generator(100000));
===============================================================
=== Step 3: Do full direct load  ==============================
===============================================================
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant sys;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_CONVERT_CO", error_code = 4016, frequency = 1;
set ob_query_timeout = 100000000;
insert /*+ enable_parallel_dml parallel(7) append*/ into t1 select * from tload;
insert /*+ enable_parallel_dml parallel(7) append*/ into t2 select * from tload;
insert /*+ enable_parallel_dml parallel(7) append*/ into t3 select * from tload;
select TOTAL_TABLET_CNT, AVAILABLE_TABLET_CNT, AVAILABLE from oceanbase.DBA_OB_CS_REPLICA_STATS;
