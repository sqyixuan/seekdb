===============================================================
=== Step 0: create tenant with cs replica locality in z2 ======
===============================================================
===============================================================
=== Step 2: create table, prepare basic data ==================
===============================================================
drop table if exists t1,tload;
drop sequence if exists seq;
create table t1    (k int primary key, v1 int, v2 int, v3 int);
create table tload (k int primary key, v1 int, v2 int, v3 int) partition by hash(k) partitions 8;
create sequence seq cache 100000 noorder;
insert into tload select seq.nextval + 10, seq.nextval + 11, seq.nextval + 12, seq.nextval + 13 from table(generator(100000));
===============================================================
=== Step 3: Do full direct load  ==============================
===============================================================
set ob_query_timeout = 100000000;
insert /*+ enable_parallel_dml parallel(7) append*/ into t1 select * from tload;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_query_timeout = 100000000;
DROP TABLE IF EXISTS t2;
create table t2 (k int primary key, v1 int, v2 int, v3 int) WITH COLUMN GROUP(all columns, each column);
insert /*+ enable_parallel_dml parallel(7) append*/ into t2 select * from tload;
set ob_route_policy=COLUMN_STORE_ONLY;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
select count(*) from GV$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type = 'MAJOR';
count(*)
1
select count(*) from GV$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type = 'CO_MAJOR';
count(*)
1
===============================================================
=== Step 3: Do big table offline ddl  =========================
===============================================================
set ob_query_timeout = 100000000;
DROP TABLE IF EXISTS t3;
create table t3 (k int primary key, 
v1  int, v2  int, v3  int, v4  int,  v5 int,  v6 int,  v7 int,  v8 int,  v9 int,  v10 int, 
v11 int, v12 int, v13 int, v14 int, v15 int, v16 int, v17 int, v18 int, v19 int,  v20 int);
DROP SEQUENCE IF EXISTS seq3;
create sequence seq3 cache 1000000 noorder;
insert into t3 select seq.nextval,
seq.nextval + 1, seq.nextval + 2, seq.nextval + 3, seq.nextval + 4, seq.nextval + 5, seq.nextval + 6, seq.nextval + 7, seq.nextval + 8, seq.nextval + 9, seq.nextval + 10,
seq.nextval + 1, seq.nextval + 2, seq.nextval + 3, seq.nextval + 4, seq.nextval + 5, seq.nextval + 6, seq.nextval + 7, seq.nextval + 8, seq.nextval + 9, seq.nextval + 10
from table(generator(1000000));
alter /*+ parallel(4) */ table t3 modify v2 decimal(10, 1);
select count(*) from t3;
count(*)
1000000
set ob_route_policy=COLUMN_STORE_ONLY;
===============================================================
=== Step 4: Do lob table offline ddl  =========================
===============================================================
set ob_query_timeout = 100000000;
DROP TABLE IF EXISTS t4;
create table t4(k int primary key, c1 int, c2 varchar(1024), c3 varchar(1024), c4 text);
DROP SEQUENCE IF EXISTS seq4;
create sequence seq4 cache 1000000 noorder;
insert into t4 select seq4.nextval, seq4.nextval, MD5(seq4.nextval), MD5(seq4.nextval*10), MD5(seq4.nextval*100) from table(generator(1000000));
alter /*+ parallel(2) */ table t4 modify c1 decimal(10, 2);
select count(*) from t4;
count(*)
1000000
set ob_route_policy=COLUMN_STORE_ONLY;
select count(*) from GV$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type = 'MAJOR';
count(*)
1
select count(*) from GV$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type = 'CO_MAJOR';
count(*)
0
