===============================================================
=== Step 0: create tenant with cs replica locality in z2 ======
===============================================================
drop tenant if exists tenant1 force;
DROP RESOURCE POOL if exists pool_1;
DROP RESOURCE UNIT if exists unit_1;
===============================================================
=== Step 2: create table, prepare basic data ==================
===============================================================
create table t1 (k int primary key, v1 int, v2 int);
create table t2 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 2;
create table t3 (k int primary key, v1 int, v2 int) with column group(each column);
create table t4 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 2 with column group(each column);
insert into t1 values (1, 2, 3), (2, 3, 4), (3, 4, 5), (0, 1, 2);
insert into t2 values (1, 2, 3), (2, 3, 4), (3, 4, 5), (0, 1, 2);
insert into t3 values (1, 2, 3), (2, 3, 4), (3, 4, 5), (0, 1, 2);
insert into t4 values (1, 2, 3), (2, 3, 4), (3, 4, 5), (0, 1, 2);
select * from t1;
k	v1	v2
0	1	2
1	2	3
2	3	4
3	4	5
select * from t2;
k	v1	v2
0	1	2
2	3	4
1	2	3
3	4	5
select * from t3;
k	v1	v2
0	1	2
1	2	3
2	3	4
3	4	5
select * from t4;
k	v1	v2
0	1	2
2	3	4
1	2	3
3	4	5
