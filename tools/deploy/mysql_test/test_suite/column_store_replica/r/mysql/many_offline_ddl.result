===============================================================
=== Step 0: create tenant with cs replica locality in z2 ======
===============================================================
===============================================================
=== Step 2: create table, prepare basic data ==================
===============================================================
create table t1 (k int primary key, v1 int, v2 int);
create table t2 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 4;
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
select * from t1;
k	v1	v2
1	1	1
2	2	2
===============================================================
=== Step 3: Offline DDL =======================================
=== Step 3.1: add auto inc column =============================
===============================================================
ALTER TABLE t1 MODIFY v1 int AUTO_INCREMENT;
insert into t1 (k, v2) values (0, 0);
select * from t1 order by k, v1;
k	v1	v2
0	3	0
1	1	1
2	2	2
explain select * from t1 order by k, v1;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |3       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.k], [t1.v1], [t1.v2]), filter(nil), rowset=16
      access([t1.k], [t1.v1], [t1.v2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.k]), range(MIN ; MAX)always true
set ob_route_policy=READONLY_ZONE_FIRST;
set ob_read_consistency = WEAK;
select * from t1 order by k, v1;
k	v1	v2
0	3	0
1	1	1
2	2	2
explain select * from t1 order by k, v1;
