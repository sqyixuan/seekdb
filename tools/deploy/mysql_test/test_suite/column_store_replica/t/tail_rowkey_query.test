# owner: ouyanghongrong.oyh
# owner group: STORAGE
# description: test column store replica compaction and query when there is rowkey at last

# --------------------------------------------------------------------------
# step 1: create tenant with column store replica locality
# --------------------------------------------------------------------------
let $unit1 = unit_1;
let $pool1 = pool_1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;
--disable_warnings
drop tenant if exists tenant1 force;
eval DROP RESOURCE POOL if exists $pool1;
eval DROP RESOURCE UNIT if exists $unit1;
--disable_query_log
let $z1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 1); 
let $z2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 1); 
#eval CREATE RESOURCE UNIT if not exists $unit1 MAX_CPU=1, MEMORY_SIZE='2G';
#eval create resource pool if not exists $pool1 unit='$unit1', unit_num = 1, zone_list = ('$z1', '$z2');
#eval create tenant tenant1 resource_pool_list=('$pool1'), replica_num=2, zone_list=('$z1','$z2'), locality = 'F@$z1, C@$z2' set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection conn1;

# --------------------------------------------------------------------------
# step 2: create table, prepare data and do major freeze
# --------------------------------------------------------------------------
--disable_query_log
--disable_warnings
drop table if exists t1;
drop table if exists t2;
set ob_query_timeout = 1000000000;
--enable_warnings
--enable_query_log

create table t1 (
    v0 float, 
    k1 varchar(100), 
    g1 decimal(10, 2) as (v0/10) virtual,
    v1 int, 
    v2 timestamp(5), 
    g2 bigint as (v1/100) stored,
    k2 decimal(10, 2), 
    g3 decimal(10, 2) as (k2*100) stored,
    k3 varbinary(6), 
    g4 double as (v0+v1) virtual,
    primary key (k3, k1, k2));

create table t2 (
    v0 float, 
    k1 varchar(100), 
    g1 decimal(10, 2) as (v0/10) virtual,
    v1 int, 
    v2 timestamp(5), 
    g2 bigint as (v1/100) stored,
    k2 decimal(10, 2), 
    g3 decimal(10, 2) as (k2*100) stored,
    k3 varbinary(6), 
    g4 double as (v0+v1) virtual,
    primary key (k3, k1, k2)) with column group(each column);

--disable_warnings
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key1', 1.00, 'vkey1', 1.11, 1111, '2024-09-11 10:00:11.111');
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key2', 2.00, 'vkey2', 2.22, 2222, '2024-09-11 10:00:22.222');
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key3', 3.00, 'vkey3', 3.33, 3333, '2024-09-11 10:00:33.333');

insert into t2 (k1, k2, k3, v0, v1, v2) values ('key1', 1.00, 'vkey1', 1.11, 1111, '2024-09-11 10:00:11.111');
insert into t2 (k1, k2, k3, v0, v1, v2) values ('key2', 2.00, 'vkey2', 2.22, 2222, '2024-09-11 10:00:22.222');
insert into t2 (k1, k2, k3, v0, v1, v2) values ('key3', 3.00, 'vkey3', 3.33, 3333, '2024-09-11 10:00:33.333');
--enable_warnings

--error 0,4515
select * from t1 order by k1;
select * from t1 order by k2;

connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
alter system major freeze tenant = sys;
--source mysql_test/include/wait_daily_merge.inc
connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
eval select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO where tenant_id = (select tenant_id from __all_tenant where tenant_name = "sys");

connection conn1;
--disable_warnings
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key4', 4.00, 'vkey4', 4.44, 4444, '2024-09-11 10:00:44.444');
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key5', 5.00, 'vkey5', 5.55, 5555, '2024-09-11 10:00:55.555');

insert into t2 (k1, k2, k3, v0, v1, v2) values ('key4', 4.00, 'vkey4', 4.44, 4444, '2024-09-11 10:00:44.444');
insert into t2 (k1, k2, k3, v0, v1, v2) values ('key5', 5.00, 'vkey5', 5.55, 5555, '2024-09-11 10:00:55.555');
--enable_warnings
--error 0,4515
select * from t1 order by k1;
select * from t1 order by k2;

connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
eval select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO where tenant_id = (select tenant_id from __all_tenant where tenant_name = "sys");
alter system major freeze tenant = sys;
--source mysql_test/include/wait_daily_merge.inc
connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
eval select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO where tenant_id = (select tenant_id from __all_tenant where tenant_name = "sys");

# --------------------------------------------------------------------------
# step 3: try weak consistency read from C replica
# --------------------------------------------------------------------------
connection obsys;
let $z2_ip         = query_get_value(select svr_ip     from oceanbase.__all_server where zone = '$z2', svr_ip,     1); 
let $z2_mysql_port = query_get_value(select inner_port from oceanbase.__all_server where zone = '$z2', inner_port, 1);
connect (conn2,$z2_ip,root,,test, $z2_mysql_port);

connection conn1;
--error 0,4515
select * from t1 order by k1;
select * from t2 order by k1;
select v2, v1, v0 from t1 order by k1;
select v2, v1, v0 from t2 order by k1;
select g4, g3, g2, g1 from t1 order by k2;
select g4, g3, g2, g1 from t2 order by k2;

connection conn2;
sleep 10;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
--error 0,4515,1235
select * from t1 order by k1;
--error 0,4515,1235
select * from t2 order by k1; 
#select k1, v2, v1, v0, k2 from t1 order by k1;
#select k1, v2, v1, v0, k2 from t2 order by k1;
#select g4, g3, g2, g1 from t1 order by k2;
#select g4, g3, g2, g1 from t2 order by k2;

# --------------------------------------------------------------------------
# step 4: try weak consistency read from C replica
# --------------------------------------------------------------------------
connection conn1;
alter table t1 add column v3 int default 10086;
alter table t2 add column v3 int default 10086;

--disable_warnings
insert into t1 (k1, k2, k3, v0, v1, v2) values ('key6', 6.00, 'vkey6', 6.66, 6666, '2024-09-11 10:00:06.006');
insert into t1 (k1, k2, k3, v0, v1, v2, v3) values ('key7', 7.00, 'vkey7', 7.77, 7777, '2024-09-11 10:00:06.006', 10077);

insert into t2 (k1, k2, k3, v0, v1, v2) values ('key6', 6.00, 'vkey6', 6.66, 6666, '2024-09-11 10:00:06.006');
insert into t2 (k1, k2, k3, v0, v1, v2, v3) values ('key7', 7.00, 'vkey7', 7.77, 7777, '2024-09-11 10:00:06.006', 10077);
--enable_warnings


--error 0,4515
select * from t1 order by k1;
--error 0,4515
select * from t2 order by k1;
select v2, v1, v0 from t1 order by k1;
select v2, v1, v0 from t2 order by k1;
select g4, g3, g2, g1 from t1 order by k2;
select g4, g3, g2, g1 from t2 order by k2;

connection conn2;
sleep 10;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
--error 0,4515,1235
select * from t1 order by k1;
--error 0,4515,1235
select * from t2 order by k1; 
#select k1, v2, v1, v0, k2 from t1 order by k1;
#select k1, v2, v1, v0, k2 from t2 order by k1;
#select g4, g3, g2, g1 from t1 order by k2;
#select g4, g3, g2, g1 from t2 order by k2;

connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
eval select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO where tenant_id = (select tenant_id from __all_tenant where tenant_name = "sys");
alter system major freeze tenant = sys;
--source mysql_test/include/wait_daily_merge.inc
connection obsys;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and TABLE_TYPE = 'CO_MAJOR';
eval select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO where tenant_id = (select tenant_id from __all_tenant where tenant_name = "sys");

connection conn1;
--error 0,4515
select * from t1 order by k1;
select * from t2 order by k1;
select v2, v1, v0 from t1 order by k1;
select v2, v1, v0 from t2 order by k1;
select g4, g3, g2, g1 from t1 order by k2;
select g4, g3, g2, g1 from t2 order by k2;

connection conn2;
sleep 10;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
--error 0,4515,1235
select * from t1 order by k1;
--error 0,4515,1235
select * from t2 order by k1; 
#select k1, v2, v1, v0, k2 from t1 order by k1;
#select k1, v2, v1, v0, k2 from t2 order by k1;
#select g4, g3, g2, g1 from t1 order by k2;
#select g4, g3, g2, g1 from t2 order by k2;

connection obsys;
--disable_warnings
#drop tenant if exists tenant1 force;
#eval DROP RESOURCE POOL if exists $pool1;
