# owner: ouyanghongrong.oyh
# owner group: STORAGE
# description: test column store replica offline ddl

--echo ===============================================================
--echo === Step 0: create tenant with cs replica locality in z2 ======
--echo ===============================================================

let $unit1 = unit_1;
let $pool1 = pool_1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;

let $z1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 1); 
let $z2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 3, zone, 2); 
#let $z2_ip         = query_get_value(select svr_ip     from oceanbase.__all_server where zone = '$z2', svr_ip,     1); 
#let $z2_mysql_port = query_get_value(select inner_port from oceanbase.__all_server where zone = '$z2', inner_port, 1);

--disable_warnings
#drop tenant if exists tenant1 force;
#eval DROP RESOURCE POOL if exists $pool1;
#eval DROP RESOURCE UNIT if exists $unit1;
--disable_query_log
#eval CREATE RESOURCE UNIT if not exists $unit1 MAX_CPU=1, MEMORY_SIZE='2G';
#eval create resource pool if not exists $pool1 unit='$unit1', unit_num = 1, zone_list = ('$z1', '$z2');
#eval create tenant tenant1 resource_pool_list=('$pool1'), replica_num=2, zone_list=('$z1','$z2'), locality = 'F@$z1, C@$z2' set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,root,'',test, $OBMYSQL_PORT);

--echo ===============================================================
--echo === Step 2: create table, prepare basic data ==================
--echo ===============================================================
connection conn1;

--disable_query_log
--disable_warnings
drop table if exists t1,t2,t3,t4;
set ob_query_timeout = 1000000000;
--enable_warnings
--enable_query_log

create table t1 (k int primary key, v1 int, v2 int);
create table t2 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 4;
let $table_name = t1;
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
select * from t1;
#SELECT distinct(table_id) FROM oceanbase.DBA_OB_TABLE_LOCATIONS WHERE table_name='t1';

--echo ===============================================================
--echo === Step 3: Offline DDL =======================================
--echo === Step 3.1: add auto inc column =============================
--echo ===============================================================
connection conn1;
ALTER TABLE t1 MODIFY v1 int AUTO_INCREMENT;
insert into t1 (k, v2) values (0, 0);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.2: alter column primary key ========================
--echo ===============================================================
connection conn1;
ALTER TABLE t1 DROP PRIMARY KEY, ADD PRIMARY KEY(v2);
insert into t1 values (3, 3, 3);
insert into t1 values (3, 3, 4);
--error 1062
insert into t1 values (2, 2, 4);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--error 1062
ALTER TABLE t1 DROP PRIMARY KEY, ADD PRIMARY KEY(k);
delete from t1 where k = 2 or k = 3;
ALTER TABLE t1 DROP PRIMARY KEY, ADD PRIMARY KEY(k);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.3: add/delete stored generate column ===============
--echo ===============================================================
connection conn1;
ALTER TABLE t1 ADD COLUMN (s3 INT GENERATED ALWAYS AS (3 * k) STORED);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

ALTER TABLE t1 DROP COLUMN s3;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.4: mix offline/online operation ===================
--echo ===============================================================
connection conn1;
alter table t1 modify v2 decimal(10, 1), add column v3 int default 10086;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.5: truncate table ==================================
--echo ===============================================================
connection conn1;
TRUNCATE t1;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

insert into t1 (k, v2, v3) values (1, 1, 110);
insert into t1 (k, v2) values (2, 2);
insert into t1 (k, v2) values (3, 3);
insert into t1 (k, v2, v3) values (4, 4, 440);

--echo ===============================================================
--echo === Step 3.6: row store to column store, each cg ==============
--echo ===============================================================
connection conn1;
ALTER TABLE t1 ADD COLUMN GROUP(each column);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.7: column store to row store, each cg ==============
--echo ===============================================================
connection conn1;
ALTER TABLE t1 DROP COLUMN GROUP(each column);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.8: row store to column store, all cg ===============
--echo ===============================================================
connection conn1;
ALTER TABLE t1 ADD COLUMN GROUP(all columns);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.9: column store each cg to all cg  ================
--echo ===============================================================
connection conn1;
ALTER TABLE t1 DROP COLUMN GROUP(all columns);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.10: column store all cg to each cg  ================
--echo ===============================================================
connection conn1;
ALTER TABLE t1 ADD COLUMN GROUP(all columns);
ALTER TABLE t1 ADD COLUMN GROUP(each column);
--source mysql_test/include/cs_replica_offline_ddl_query.inc
ALTER TABLE t1 DROP COLUMN GROUP(all columns);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.12: column store to row store, all cg ==============
--echo ===============================================================
connection conn1;
ALTER TABLE t1 ADD COLUMN GROUP(all columns);
ALTER TABLE t1 DROP COLUMN GROUP(each column);
--source mysql_test/include/cs_replica_offline_ddl_query.inc
ALTER TABLE t1 DROP COLUMN GROUP(all columns);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

--echo ===============================================================
--echo === Step 3.13: alter partition rule ===========================
--echo ===============================================================
let $table_name = t2;
connection conn1;
insert into t2 select k, v1, v2 from t1;
select * from t2 partition(p0);
select * from t2 partition(p1);
select * from t2 partition(p2);
select * from t2 partition(p3);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

ALTER TABLE t2 PARTITION BY RANGE(k) (PARTITION p0 VALUES LESS THAN(3), PARTITION p1 VALUES LESS THAN (MAXVALUE));
select * from t2 partition(p0);
select * from t2 partition(p1);
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo ===============================================================
--echo === Step 3.14: drop partition =================================
--echo ===============================================================
connection conn1;
ALTER TABLE t2 DROP PARTITION p1;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo ===============================================================
--echo === Step 3.15: truncate partition =============================
--echo ===============================================================
connection conn1;
ALTER TABLE t2 TRUNCATE PARTITION p0;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo ===============================================================
--echo === Step 3.15: exchange partition =============================
--echo ===============================================================
connection conn1;
create table t3 (k int primary key, v1 int, v2 int);
insert into t3 select k, v1, v2 from t1;

ALTER TABLE t2 PARTITION BY RANGE(k) (PARTITION p0 VALUES LESS THAN(3), PARTITION p1 VALUES LESS THAN (MAXVALUE));
insert into t2 select k, v1, v2 from t1;
ALTER TABLE t2 PARTITION BY RANGE(k) (PARTITION p0 VALUES LESS THAN(2), PARTITION p1 VALUES LESS THAN (MAXVALUE));
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#select * from t2 partition(p1);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

ALTER TABLE t2 EXCHANGE PARTITION p0 WITH TABLE t3 WITHOUT VALIDATION;
--source mysql_test/include/cs_replica_offline_ddl_query.inc

connection conn2;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
#select * from t2 partition(p0);
#select * from t2 partition(p1);
#explain select * from t2 partition(p0);
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

connection obsys;
--disable_warnings
drop table if exists t1,t2,t3,t4;
#drop tenant if exists tenant1 force;
#eval DROP RESOURCE POOL if exists $pool1;
#eval DROP RESOURCE UNIT if exists $unit1;
--disable_query_log

select "Finish";
