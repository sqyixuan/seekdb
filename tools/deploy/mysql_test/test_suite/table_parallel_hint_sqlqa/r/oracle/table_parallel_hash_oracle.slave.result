-------------------------------------
  0 - output([INTERNAL_FUNCTION(LYQ_TEST.COL_INT)]), filter(nil), rowset=256
      sort_keys([LYQ_TEST.COL_INT, ASC])
  1 - output([LYQ_TEST.COL_INT], [INTERNAL_FUNCTION(LYQ_TEST.COL_INT)]), filter(nil), rowset=256
      dop=4
  2 - output([LYQ_TEST.COL_INT]), filter(nil), rowset=256
      sort_keys([LYQ_TEST.COL_INT, ASC])
  3 - output([LYQ_TEST.COL_INT]), filter(nil), rowset=256
  4 - output([LYQ_TEST.COL_INT]), filter([(T_OP_NOT_IN, LYQ_TEST.COL_INT, (10, 9))]), rowset=256
      access([LYQ_TEST.COL_INT]), partitions(p[12-14], p18)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([LYQ_TEST.PK]), range[1 ; 1], [3 ; 3], [5 ; 5], [7 ; 7], 
      range_cond([LYQ_TEST.PK IN (1, 3, 5, 7)])
