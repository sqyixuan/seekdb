全局唯一索引 + 检查约束 
CREATE /*+ parallel(5) */ UNIQUE INDEX INDEX_lyq_test ON lyq_test(COL_INT) GLOBAL;
全局分区索引 + 非空约束 
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T2 ON lyq_test(COL_NUMBER_29_0)
GLOBAL PARTITION BY RANGE (COL_NUMBER_29_0)
(PARTITION INDEX_lyq_test_T2_P1 VALUES LESS THAN (3),
PARTITION INDEX_lyq_test_T2_P2 VALUES LESS THAN (5),
PARTITION INDEX_lyq_test_T2_P3 VALUES LESS THAN (MAXVALUE));
全局非分区索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(COL_TS) GLOBAL;
本地索引 + 生成列
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 ON lyq_test(COL_GENERATED) LOCAL;
唯一索引 + 外键约束
CREATE /*+ parallel(5) */ UNIQUE INDEX INDEX_lyq_test_fk ON lyq_test_fk(c1);
函数索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T5 ON lyq_test(UPPER(COL_VARCHAR2_200));
组合索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T6 ON lyq_test(COL_NCHAR,COL_RAW);
反向键索引 + 默认约束
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T7 ON lyq_test(COL_DECIMAL_21_2) REVERSE;
创建一个不可见索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T8 ON lyq_test(COL_NCHAR) INVISIBLE ;
