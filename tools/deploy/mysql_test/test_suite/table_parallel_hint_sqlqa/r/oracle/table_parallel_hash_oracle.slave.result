purge recyclebin;
环境准备
##################oboracle table hint + hash 分区表+ 约束 +索引 + 全局HINT##################
ALTER SESSION SET NLS_DATE_FORMAT='YYYY-MM-DD HH24:MI:SS';
ALTER SESSION SET NLS_TIMESTAMP_FORMAT='YYYY-MM-DD HH24:MI:SS.FF';
ALTER SESSION SET NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
drop table lyq_test_fk;
drop table lyq_test;
CREATE TABLE lyq_test(
PK INT primary key,
COL_INT INT check (COL_INT < 1000),
COL_TS TIMESTAMP,
COL_VARCHAR2_200 VARCHAR2(200),
COL_NUMBER_29_0 NUMBER(29,0) not null,
COL_DATE DATE,
COL_DECIMAL_21_2 DECIMAL(21,2) default 0,
COL_NCHAR NCHAR(10),
COL_BINARY_DOUBLE BINARY_DOUBLE,
COL_RAW RAW(10),
COL_GENERATED  GENERATED ALWAYS AS  ( PK + NVL(COL_INT,0) ) VIRTUAL ) PARALLEL 5
partition by hash(pk) 
partitions 25;
create table lyq_test_fk(
c1 INT,
c2 VARCHAR2(200),
constraint FK_lyq_test foreign key (c1) references lyq_test(PK)) NOPARALLEL;
insert into lyq_test(PK,COL_INT,COL_TS,COL_VARCHAR2_200,COL_NUMBER_29_0,COL_DATE,COL_DECIMAL_21_2,COL_NCHAR,COL_BINARY_DOUBLE,COL_RAW) 
