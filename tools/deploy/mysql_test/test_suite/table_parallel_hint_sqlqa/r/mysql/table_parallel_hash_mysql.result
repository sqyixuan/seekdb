purge recyclebin;
##################obmysql table hint + 非分区表+ 约束 +索引 + 全局HINT##################
mysql不支持并行执行，只是兼容parallel hint的语法。  obmysql模式支持并行
DROP TABLE lyq_test_fk;
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
c1 int primary key,  
c2 float, 
c3 DECIMAL(5,2) DEFAULT null, 
c4 VARCHAR(100), 
c5 bit(10),
c6 datetime, 
c7 json NOT NULL,
c8 SET('a', 'b', 'c', 'd'),
c9 timestamp,
c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列') PARALLEL 5
PARTITION BY HASH (c1) partitions 15;
