explain basic select /*+ parallel(t2 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test t2 where c1 > 2) order by c1;
explain basic select /*+ parallel(t2 4) */ c1,c2 from lyq_test where c2 > some(select c2 from lyq_test_fk t2 where c1 > 2) order by c1;
--echo 参数 并行度
set _force_parallel_query_dop = 1;
select /*+ parallel(lyq_test -1) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(lyq_test -1) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(lyq_test -4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(lyq_test a) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(lyq_test a a a) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;

purge recyclebin;
