,'[{"abs":123},"汉字123！@#$%^&*()_+",[8]]','b,d,a,c','2018-06-01 00:00:01');


create table lyq_test_fk(
c1 INT,
c2 VARCHAR(100),
constraint FK_lyq_test foreign key (c1) references lyq_test(c1)) NOPARALLEL;

insert into lyq_test_fk values(0,1);
insert into lyq_test_fk values(1,2);
insert into lyq_test_fk values(2,3);
insert into lyq_test_fk values(3,4);
insert into lyq_test_fk values(4,5);
insert into lyq_test_fk values(5,6);


--echo create-1-1 普通索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T1 ON lyq_test(c1);

#--echo create-1-2 唯一索引
#CREATE /*+ parallel(5) */ UNIQUE INDEX INDEX_lyq_test_T2 ON lyq_test(c2);

--echo create-1-3 组合索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T3 ON lyq_test(c3, c4,c5);

--echo create-1-4 hash索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T4 USING HASH ON lyq_test(c6);

--echo create-1-5 json 生成列索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T5 ON lyq_test(c10);

--echo create-1-6 全局分区索引
CREATE /*+ parallel(5) */ INDEX INDEX_lyq_test_T6 ON lyq_test(c1)
   GLOBAL   PARTITION BY RANGE (c1)(
PARTITION less_3 VALUES less than (2),
PARTITION b_3_8 VALUES less than (5),
PARTITION b_8_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);

--echo where + group by
--echo IN, NOT IN

select /*+ parallel(lyq_test 4) */ c2 from lyq_test where c1  in (1,3,5,7) group by c2 having c2 not in (10,9) order by c2;
  
explain basic select /*+ parallel(lyq_test 4) */ c2 from lyq_test where c1  in (1,3,5,7) group by c2 having c2 not in (10,9) order by c2;

--echo ANY,SOME,ALL

explain basic select /*+ parallel(lyq_test 4) */ c3 from lyq_test where c9 > any(select c9 from lyq_test where c1 > 2) 
group by c3 having c3 > 4;

select /*+ parallel(lyq_test 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
select /*+ parallel(lyq_test 4) */ c1,c3 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2) order by c1;

--echo like 
select /*+ parallel(lyq_test 4) */ c6 from lyq_test where c6 like '%2020%' 
group by c6 having c6 is not null order by c6;

--echo AND 、OR 、 NOT 、order by 、is 、 is  not  null 

select /*+ parallel(lyq_test 4) */ c1,c5 from lyq_test where c4 like '汉%' and c5 is not null order by c1;

select /*+ parallel(lyq_test 4) */ c8 from lyq_test where c4 like '汉%' OR c5 is not null 
group by c8 having c8 > 1 order by c8 desc;

explain basic select /*+ parallel(lyq_test 4) */ c8 from lyq_test where c4 like '汉%' OR c5 is not null 
group by c8 having c8 > 1 order by c8 desc;

--echo distinct

select /*+ parallel(lyq_test 4) */ distinct c10 from lyq_test where c4 like '汉%' and c5 is not null order by c10;
select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null order by c1;

--echo with ... as
with
     e as (select /*+ parallel(lyq_test 4) */ c2 from lyq_test where c4 like '汉%' OR c5 is not null 
group by c2 having c2 > 1 order by c2 desc),
     d as (select /*+ parallel(lyq_test 4) */ c2,c3 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2))
select /*+ parallel(lyq_test 4) */ e.c2 from e, d where e.c2 = d.c2 group by e.c2 having e.c2 is not null order by c2;

--echo  join
select /*+ parallel(t1 4) */ t1.c2,t1.c9 from lyq_test t1,lyq_test_fk t2 where t1.c1 = t2.c1 
group by t1.c2,t1.c9 having t1.c2 >=1 order by t1.c2;

select /*+ parallel(lyq_test_fk 2) */ t1.c2,t1.c9 from lyq_test t1 
right join lyq_test_fk t2 on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c2,t1.c9 having t1.c2 >=1 order by t1.c2;

select /*+ parallel(t2 4) */ t1.c2,t1.c9 from lyq_test t1 
left join lyq_test_fk t2 on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c2,t1.c9 having t1.c2 >=1 order by t1.c2;

select /*+ parallel(t1 2) */ t1.c2,t1.c9 from lyq_test t1 
inner join lyq_test_fk t2 on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c2,t1.c9 having t1.c2 >=1 order by t1.c2;

--echo 集合查询
select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union
select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

--echo mysql不支持，obmysql模式支持
select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
minus
select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1;
--echo mysql不支持，obmysql模式支持
select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
intersect
select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 0) 
group by c1 having c1 >1 order by c1;

--echo 嵌套子查询
select /*+ parallel(lyq_test 4) */ c2 from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

select  case when c2 = 1.1111 then 'a'  when c2 = 3.1111 then 'b' else 'c' end as cc from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

with
     e as (select /*+ parallel(lyq_test 4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1),
     d as (select /*+ parallel(lyq_test 4) */ c1,c3 from lyq_test where c3 <= some(select c3 from lyq_test where c1 > 2))
select /*+ parallel(lyq_test 4) */ e.c1 from e, d where e.c1 = d.c1 group by e.c1 having e.c1 in 
(select  distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union
select  c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1);

select /*+ parallel(t1 4) */ t1.c1,t1.c9 from lyq_test t1 
left join (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c1  in (1,3,5,7) group by c1 
having c1 not in (select c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2))) t2 
on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c1,t1.c9 having t1.c1 >=1 order by t1.c1;

--echo 优先级 HINT + TABLE HINT

select /*+ parallel(lyq_test 2) */ t1.c1,t1.c6 from lyq_test t1 
left join (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c1  in (1,3,5,7) group by c1 
having c1 not in (select c1 from lyq_test where c3 <= all(select /*+ parallel(3) */ c3 from lyq_test where c1 > 2))) t2 
on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c1,t1.c6 having t1.c1 >=1 order by t1.c1;

explain basic select /*+ parallel(lyq_test 2) */ t1.c1,t1.c6 from lyq_test t1 
left join (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c1  in (1,3,5,7) group by c1 
having c1 not in (select c1 from lyq_test where c3 <= all(select /*+ parallel(3) */ c3 from lyq_test where c1 > 2))) t2 
on t1.c1 = t2.c1 where c4 like '汉%' OR c5 is not null
group by t1.c1,t1.c6 having t1.c1 >=1 order by t1.c1;

--echo 优先级 TABLE HINT + ALTER SESSION
set _force_parallel_query_dop = 1;

