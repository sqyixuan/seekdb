--echo 优先级 TABLE HINT + TABLE DOP 单分区表

select  case when c2 = 1.1111 then 'a'  when c2 = 3.1111 then 'b' else 'c' end as cc from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

explain basic select  case when c2 = 1.1111 then 'a'  when c2 = 3.1111 then 'b' else 'c' end as cc from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

explain basic select /*+ parallel(lyq_test 3) */ case when c2 = 1.1111 then 'a'  when c2 = 3.1111 then 'b' else 'c' end as cc from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select /*+ parallel(lyq_test 4) */ c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

explain basic select  case when c2 = 1.1111 then 'a'  when c2 = 3.1111 then 'b' else 'c' end as cc from lyq_test where c1  in (1,3,5,7) group by c2 
having c2 not in (select  c1 from lyq_test where c3 <= all(select c3 from lyq_test where c1 > 2)) order by c2;

--echo 优先级 TABLE HINT + USE_PX

select /*+  USE_PX parallel(lyq_test 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;

explain basic select /*+  USE_PX parallel(lyq_test 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;

--echo 优先级 TABLE HINT  + ALTER SESSION + HINT + TABLE DOP

set _force_parallel_query_dop = 6;

select /*+ parallel(4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 3) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

select  distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 3) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

explain basic select /*+ parallel(4) */ distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 3) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

explain basic select  distinct c1 from lyq_test where c4 like '汉%' and c5 is not null
union all
select /*+ parallel(lyq_test 3) */ c1 from lyq_test where c6 > any(select c6 from lyq_test where c1 > 2) 
group by c1 having c1 >1 order by c1;

--echo 参数 表名为sql中不存在的表
select /*+ parallel(t1 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(t1 4) */ c1,c3 from lyq_test where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;

--echo 参数 表名为sql中别名命名的表
select /*+ parallel(t2 4) */ c1,c3 from lyq_test t2 where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
explain basic select /*+ parallel(t2 4) */ c1,c3 from lyq_test t2 where c3 > some(select c3 from lyq_test where c1 > 2) order by c1;
