#description: obmysql table hint + 非分区表+ 约束 +索引 + 全局HINT  
#author: wb-lyq858317
#tags: hint, optimizer

purge recyclebin;
--enable_sorted_result
--echo  ##################obmysql table hint + 非分区表+ 约束 +索引 + 全局HINT##################
--echo  mysql不支持并行执行，只是兼容parallel hint的语法。  obmysql模式支持并行
--error 0,1051
DROP TABLE lyq_test_fk;

--error 0,1051
DROP TABLE lyq_test;
CREATE TABLE lyq_test(  
  c1 int primary key,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),
  c9 timestamp,
  c10 varchar(100) GENERATED ALWAYS AS(c7) VIRTUAL COMMENT '生成列') PARALLEL 5
PARTITION BY LIST (c1)(
PARTITION p_list_unique_t_1 VALUES IN (1,2),
PARTITION p_list_unique_t_2 VALUES IN (3,4,5),
PARTITION p_list_unique_t_3 VALUES IN (0));

insert into lyq_test(c1,c2,c3,c4,c5,c6,c7,c8,c9) values(0,1.1111,2.2,'asd汉字！@#￥%……!@@^&*&*()+{}:>?|',b'1000001','2020-12-01 23:59:59.999999'
