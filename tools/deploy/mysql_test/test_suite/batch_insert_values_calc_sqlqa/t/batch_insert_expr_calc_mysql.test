##owner: laibingzheng.lbz
##owner group: SQL2
##description: values作为表达式/进行运算
##tags: batch insert
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;

alter system set ob_enable_batched_multi_statement=true;
sleep 6;



drop table if exists t1;
--echo  #floor/ceiling数学函数
create table t1(c1 int, c2 int);
delimiter //;
insert into t1 values(floor(abs(1234*66/9* -7)),ceiling(999*6/5+20));
insert into t1 values(floor(abs(2222*30/6* -8)),ceiling(666*3/5+10));//
delimiter ;//
select * from t1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
--enable_warnings

drop table t1;


alter system flush plan cache global;
drop table if exists t2;
--echo  #int、char、varchar、datetime、decimal类型表达式测试。
create table t2(c1 int primary key,c2 char(30) not null,c3 varchar(60) default 'abc',c4 datetime not null,c5 decimal(20,10));
delimiter //;
insert into t2 values((6+8*3/5)div(3+6*8/9),concat(ascii('X'),bin(3)), concat(BIT_LENGTH('text'),char(77,121,83,81,'76')),DATE_ADD('2022-10-01', INTERVAL 22 DAY),acos(asin(0.2)));
insert into t2 values((9+6*7/5)div(1+2*3/4),concat(ascii('x'),bin(6)), concat(BIT_LENGTH('asdhjk'),char(77,121,83,81,'76')),DATE_ADD('2001-01-01', INTERVAL 31 DAY),acos(asin(-0.2)));//
delimiter ;//
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 values%' order by hit_count;
--enable_warnings

delimiter //;
insert into t2 values((7*7+9)%((5 div 2)+2),format(123*31+0.71235,4),from_base64(to_base64('abc')),addtime(CONVERT_TZ('2004-01-01 12:00:00','+00:00','+10:00'),'1 1:1:1.000002'),cot(asin(0.5)));
insert into t2 values((8*8+11)%((9 div 5)+3),format(1234*10+0.56789,3),from_base64(to_base64('张三')),addtime(CONVERT_TZ('2008-08-08 08:00:00','+00:00','+10:00'),'02:00:00.999998'),cot(asin(-0.5)));//
delimiter ;//
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 values%' order by hit_count;
--enable_warnings


delimiter //;
insert into t2 values(ceil(99*7/6+mod(5,3)),insert('abcdefgh',2,4,'AAAAA'),instr(concat('日期:',DATE_FORMAT('2009-10-04 22:23:00', '%W %M %Y')),'22'),from_days(123*55+66/3),degrees(pi()/3)+exp(2));
insert into t2 values(ceil(22*20/5+mod(7,4)),insert('sssunday',1,4,'sunsun'),instr(concat('时间',DATE_FORMAT('2010-10-10 10:10:10', '%W %M %Y')),'22'),from_days(666*16+99/3),degrees(pi()/2)+exp(0));//
delimiter ;//
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 values%' order by hit_count;
--enable_warnings

drop table t2;


alter system flush plan cache global;
drop table if exists t3;
--echo  #数学函数和字符串函数、时间函数，生成列
create table t3(c1 int primary key auto_increment,c2 char(30) not null,c3 time generated always as(time('2008-08-08 08:08:08')) ,c4 varchar(60) not null,key index_c1_c2(c1,c2)) partition by hash(c1)
(partition p1,
partition p2,
partition p3
);

delimiter //;
insert into t3(c1,c2,c4) values (mod(2*2+3*20/3,10),left('123abc',length('123')),locate(lower('sk'),'basketball'));
insert into t3(c1,c2,c4) values (mod(6*6+2*10/2,15),left('qwerty',length('ccc')),locate(lower('oo'),'football'));//
delimiter ;//
select * from t3;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3(c1,c2,c4) values %' order by hit_count;
--enable_warnings

rollback;

delimiter //;
insert into t3(c1,c2,c4) values(6*6/3+9,concat(replace('Wednesday','Wednes','Sun'),reverse('iH')),DATE_FORMAT('2022-10-19 15:23:00', '%W %M %Y'));
insert into t3(c1,c2,c4) values(3*3/3+20,concat(replace('Monday','Mon','Satur'),reverse('iH')),DATE_FORMAT('2022-10-15 10:10:00', '%W %M %Y'));//
delimiter ;//
select * from t3;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3(c1,c2,c4) values%' order by hit_count;
--enable_warnings
rollback;

set @a1 = 'abcdefg';
delimiter //;
insert into t3(c1,c2,c4) values(3/2*30-10,lpad(@a1,5,'EE'),round(radians(90)+sqrt(20)));
insert into t3(c1,c2,c4) values(6/5*40-33,lpad(@a1,2,'DD'),round(radians(45)+sqrt(10)));//
delimiter ;//
select * from t3;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3(c1,c2,c4) values%' order by hit_count;
--enable_warnings

drop table t3;


alter system flush plan cache global;
drop table if exists t4;
--echo  #字符串函数和时间函数
create table t4(c1 varchar(60) not null,c2 varchar(60) default '0808',c3 char(30) unique key,c4 decimal(20,10) not null);

delimiter //;
insert into t4 values(concat(ltrim('    AA'),make_set(1 | 4,'hello','nice','world')),abs(dayofmonth('2020-10-10')-power(3,4)),extract(year_month from '2019-07-02 01:02:03'),ln(2*3-3));
insert into t4 values(concat(ltrim(' CC C'),make_set(1 | 4,'aaa','ccc','ddd')),abs(dayofmonth('2020-12-10')-power(4,3)),extract(year_month from '2019-12-02 01:02:03'),ln(3*3-8));//
delimiter ;//
select * from t4;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 values%' order by hit_count;
--enable_warnings
rollback;


--echo    #没有命中plan cache
delimiter //;
insert into t4(c1,c3,c4) values(concat_ws('$',concat('aaaa','BC'),substr('abczzz',2)),substring('！qwe￥……%',3,2),mod(crc32('de1sk')/1250,3*15.5 div 6));
insert into t4(c1,c3,c4) values(concat_ws('^',concat('wang','wu'),substr('QAZWX',3)),substring('Huanglong',3,2),mod(crc32('pk999')/1750,15*20.1 div 6));//
delimiter ;//
select * from t4;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4(c1,c3,c4) values%' order by hit_count;
--enable_warnings

drop table t4;

--echo  #转换函数 cast(expr as type),type-->date、datetime、decimal、signed、time、unsigned
alter system flush plan cache global;
drop table if exists t5;
create table t5(c1 char(60) not null,c2 varchar(60) not null);
delimiter //;
--error 1048
insert into t5 values(cast(20220101*1000000+121212 as date),cast(cot(asin(1)) as date));
insert into t5 values(cast(19850108*1000000+080808 as date),cast(cot(asin(2)) as date));//
delimiter ;//
select * from t5;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 values%' order by hit_count;
--enable_warnings
rollback;


alter system flush plan cache global;
delimiter //;
insert into t5 values(cast(concat('1999-09-09',' 18:18:18') as datetime),cast(acos(atan(0.2)) as decimal));
insert into t5 values(cast(concat('200505','05050505') as datetime),cast(acos(atan(0.5)) as decimal));//
delimiter ;//
select * from t5;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 values%' order by hit_count;
--enable_warnings
rollback;


alter system flush plan cache global;
delimiter //;
insert into t5 values(CAST(1-2+3*6/2 AS UNSIGNED), CAST(cast(9*9-11*11 AS UNSIGNED) AS SIGNED));
insert into t5 values(CAST(1-5+3*5/3 AS UNSIGNED), CAST(cast(6*6-12*12 AS UNSIGNED) AS SIGNED));//
delimiter ;//
select * from t5;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 values%' order by hit_count;
--enable_warnings
rollback;


alter system flush plan cache global;
delimiter //;
insert into t5 values(cast(13*1.0513+2151/3 as time),cast(atan2(pi(),0) as time));
insert into t5 values(cast(22*3.7752+1060/2 as time),cast(atan2(pi(),1) as time));//
delimiter ;//
select * from t5;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 values%' order by hit_count;
--enable_warnings

drop table t5;


alter system flush plan cache global;
drop table if exists t6;
--echo  #变量赋值带入进行运算
create table t6(c1 int  auto_increment,c2 varchar(60) not null,c3 char(30));
create index index_c1_c2_c3 on t6(c1,c2,c3);
set @aa = 15;
set @bb = 25;
delimiter //;
insert into t6 values(@aa*@bb div @aa+@bb,concat(@aa/@bb,'abcdefg'),floor(mod(@aa,@bb)/3));
insert into t6 values(@aa*@bb div @aa+@bb,concat(@aa/@bb,'aaccddd'),floor(mod(@aa,@bb)/4));//
delimiter ;//
select * from t6;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6 values%' order by hit_count;
--enable_warnings
rollback;


alter system flush plan cache global;
delimiter //;
insert into t6 values(mod(5*6+36-24,3*2),hex(weight_string(0x007fff level 1 reverse)),hex(weight_string(0x007fff level 1 desc reverse)));
insert into t6 values(mod(5*6+36-24,3*2),hex(weight_string(0x008eee level 1 reverse)),hex(weight_string(0x008eee level 1 desc reverse)));//
delimiter ;//
select * from t6;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6 values%' order by hit_count;
--enable_warnings

drop table t6;


alter system flush plan cache global;
drop table if exists t7;
--echo  #bit类型表达式
create table t7(c1 bit(64),c2 bit(64));
delimiter //;
insert into t7 values(mod(b'111'*6+9/b'11',1+b'1111'-3*5),b'101010'*6-27 div 12+b'10101');
insert into t7 values(mod(b'1101'*4+8/b'101',5+b'1101'-4*3),b'101110'*5-24 div 11+b'10111');//
delimiter ;//
#select bin(c1),bin(c2) from t7;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t7 values%' order by hit_count;
--enable_warnings
drop table t7;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

drop database db1;

