##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch + case when
##tags: batch insert/delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4
--enable_sorted_result

alter system flush plan cache global;
sleep 3;
set global ob_plan_cache_percentage = 10;
alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;

alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo     #case when
drop table if exists t1;
create table t1(c1 int ,c2 char(30) not null default 'AA');
insert into t1 values(1,'AA'),(2,'BB'),(3,'CC');
SET @aa:='йҳҝaaдә”';
SET @bb:='йҳҝa6';
set @cc:='йҳҝa77';
select * from t1;
delimiter //;
insert into t1 select c1,case c2 when 'AA' then 'A' when 'BB' then 'B' else 'C' end as c2 from t1;
insert into t1 select c1,case c2 when 'AA' then @aa when 'BB' then @bb else @cc end as c2 from t1;//
delimiter ;//
select * from t1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 select%' order by hit_count;
--enable_warnings
drop table t1;


--echo  #batch insert+select... дёҚж”ҜжҢҒдјҳеҢ–
alter system flush plan cache global;
drop table if exists t2;
create table t2(c1 int ,c2 char(30) not null default 'AA');
insert into t2 values(1,'AA'),(2,'BB'),(3,'CC'),(4,'DD'),(5,'EE'),(6,'FF');
delimiter //;
insert into t2 select c1,case c2 when 'AA' then 'A' when 'BB' then 'B' else 'C' end as c2 from t2;
insert into t2 select c1,case c2 when 'AA' then 'Q' when 'BB' then 'K' else 'A' end as c2 from t2;//
delimiter ;//
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 select%' order by hit_count;
--enable_warnings
drop table t2;


drop table if exists t3;
create table t3(c1 int ,c2 char(30) not null default 'AA');
insert into t3 values(1,'AA'),(2,'BB'),(3,'CC'),(4,'DD'),(5,'EE'),(6,'FF');
delimiter //;
delete from t3 where c1 = case when c1=1 then 2 else c1 end;delete from t3 where c1 = case when c1=3 then 4 else c1 end;//
delimiter ;//
select * from t3;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c1 = %' order by hit_count;
--enable_warnings
drop table t3;


--echo	#жө®зӮ№еһӢ
alter system flush plan cache global;
drop table if exists t4;
create table t4 (c1 float ,c2 double not null,c3 decimal(5,3),key index_c1_c2(c1,c2));
create index index_c3 on t4(c3);
insert into t4 values(1.111,1.111,1.111),(2.111,2.222,2.333),(3.111,3.222,3.333);
insert into t4 values(11.111,11.111,11.111),(12.111,12.222,12.333);
commit;

delimiter //;
insert into t4 select c1,c3,case c2 when 1.111 then 2 when 2.222 then 3 else 2.5 end as c2 from t4 limit 1;
insert into t4 select c1,c3,case c2 when 1.111 then 2.666 when 2.222 then 3.666 else 2.555 end as c2 from t4 limit 1;//
delimiter ;//
select * from t4;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 select %' order by hit_count;
--enable_warnings
rollback;


delimiter //;
delete from t4 where c2 = case when c2 = 1.111 then 5.111 else c2 end;delete from t4 where c2 = case when c2 = 2.222 then 1.111  else c2 end;//
delimiter ;//
select * from t4;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = %' order by hit_count;
--enable_warnings
drop table t4;



--echo #ж—¶й—ҙзұ»еһӢ
drop table if exists t5;
create table t5 (c1 datetime not null,c2 year ,c3 timestamp not null)
partition by key(c1)
partitions 3;
insert into t5 values('2000-01-01','2000','2000-01-01'),('2001-01-01','2001','2001-01-01'),('2002-01-01','2002','2002-01-01'),('2003-01-01','2003','2003-01-01'),('2004-01-01','2004','2004-01-01'),('2005-01-01','2005','2005-01-01');
commit;
select * from t5 order by c1;

delimiter //;
insert into t5 select c1,c2,case c3 when '2000-01-01' then last_day('2000-01-01') when '2001-01-01' then date_add('2001-01-01',interval 1 day) else date_sub(c3,interval 20 day) end as c3 from t5;
insert into t5 select c1,c2,case c3 when '2003-01-01' then subdate('2003-01-01',interval 31 day)  when '2004-01-01' then subdate('2004-01-01',20)  else adddate('2005-01-01',70) end as c3 from t5;//
delimiter ;//
select * from t5 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 select c1,c2,case c3 when %' order by hit_count;
--enable_warnings
rollback;


delimiter //;
delete from t5 where c2 = case when 2000 then year('2001-05-07') else c2 end;
delete from t5 where c2 = case when 2002 then extract(year from '2003-07-02') else c2 end;
delete from t5 where c2 = case when 2004 then year(date_sub('2005-01-02', interval 31 day)) else c2 end;//
delimiter ;//
select * from t5 order by c2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c2 = case when %' order by hit_count;
--enable_warnings
drop table t5;



--echo	#еӯ—з¬ҰдёІзұ»еһӢ
drop table if exists t6;
create  table t6(c1 varchar(60) not null,c2 varbinary(30),c3 binary(30) default 'Zz');
create index index_c1_c2_c3 on t6(c1,c2,c3);
insert into t6 values('еј дёү','AAA','еЈ№');
insert into t6 values('жқҺеӣӣ','BBB','иҙ°');
insert into t6 values('зҺӢдә”','CCC','еҸҒ');
commit;
select * from t6;

delimiter //;
insert into t6 select c1,c3,case c2 when 'AAA' then reverse('abc') when 'CCC' then right('QWERRYT',4) else substring('asdadasd2qwe1',8) end from t6;
insert into t6 select c1,c3,case c2 when 'AAA' then concat('еј дёү','AA') when 'CCC' then concat('жқҺеӣӣ',reverse('kxjgn')) else repeat('зҺӢдә”',2) end from t6;//
delimiter ;//
select * from t6 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6 select c1,c3,case c2 when %' order by hit_count;
--enable_warnings
rollback;


delimiter //;
delete from t6 where c1 = case c1 when 'еј дёү' then concat('жқҺ','еӣӣ') else c1 end;
delete from t6 where c1 = case c1 when 'зҺӢдә”' then concat(substr('ASDASDA',5),'asd') else c1 end;//
delimiter ;//
select * from t6 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c1 = case c1 when %' order by hit_count;
--enable_warnings
drop table t6;


--echo	#йӣҶеҗҲ
drop table if exists t7;
create table t7(c1 enum('a','b','c','1','2','3','','1.11','еҲҳ'),c2 set('еј ','зҺӢ','жқҺ','','2.222','3','6','#$@'));
insert into t7 values('1','еј '),('2','зҺӢ'),('3','жқҺ');
commit;
select * from t7;

delimiter //;
insert into t7 select c1,case c2 when 'еј ' then '3' when 'жқҺ' then '6' else '' end from t7;
insert into t7 select c1,case c2 when 'еј ' then 'зҺӢ' when 'жқҺ' then 'зҺӢ' else '2.222' end from t7;//
delimiter ;//
select * from t7 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t7 select c1,case c2 when %' order by hit_count;
--enable_warnings
rollback;


delimiter //;
delete from t7 where c1 = case c1 when '1' then '2' else c1 end;
delete from t7 where c1 = case c1 when '3' then '5' else c1 end;//
delimiter ;//
select * from t7 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 where c1 = case c1 when %' order by hit_count;
--enable_warnings
drop table t7;


--echo	#bitеһӢ
drop table if exists t8;
create table t8(c1 bit(64),c2 bit(64));
insert into t8 values(10,15),(11,16),(12,17);
commit;
select bin(c1),bin(c2) from t8;

delimiter //;
insert into t8 select c1,case c2 when b'1111' then b'11101' when b'10000' then 18 else 21 end from t8;
insert into t8 select c1,case c2 when b'1111' then 22 when b'10000' then 23 else 24 end from t8;//
delimiter ;//
select bin(c1),bin(c2) from t8;
rollback;

drop table t8;



set global ob_plan_cache_percentage = 5;
alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

drop database db1;




