#binary_float,binary_double
alter system flush plan cache global;
create table t3(c1 binary_float,c2 binary_double,c3 decimal(5,3));
create index index_t3 on t3(c1,c2,c3);
insert into t3 values(1.111,1.111,1.111);
insert into t3 values(2.111,2.222,2.333);
insert into t3 values(3.111,3.222,3.333);
insert into t3 values(11.111,11.111,11.111);
insert into t3 values(12.111,12.222,12.333);
commit;
insert into t3 select c1,c3,case c2 when 1.111 then 2 when 2.222 then 3 else 2.5 end as c2 from t3 fetch next 1 rows only;
insert into t3 select c1,c3,case c2 when 1.111 then 2.666 when 2.222 then 3.666 else 2.555 end as c2 from t3 fetch next 1 rows only;//
select * from t3;
C1	C2	C3
1.11099994E+000	1.111E+000	1.111
1.11099994E+000	1.111E+000	2
1.11099994E+000	1.111E+000	2.666
1.11110001E+001	1.1111000000000001E+001	11.111
1.21110001E+001	1.2222E+001	12.333
2.11100006E+000	2.222E+000	2.333
3.11100006E+000	3.222E+000	3.333
select hit_count, is_batched_multi_stmt, statement, query_sql from gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 select %' order by hit_count;
HIT_COUNT	IS_BATCHED_MULTI_STMT	STATEMENT	QUERY_SQL
1	0	insert into t3 select c1,c3,case c2 when ? then ? when ? then ? else ? end as c2 from t3 fetch next ? rows only;	insert into t3 select c1,c3,case c2 when 1.111 then 2 when 2.222 then 3 else 2.5 end as c2 from t3 fetch next 1 rows only;
1	0	insert into t3 select c1,c3,case c2 when ? then ? when ? then ? else ? end as c2 from t3 fetch next ? rows only;	insert into t3 select c1,c3,case c2 when ? then ? when ? then ? else ? end as c2 from t3 fetch next ? rows only;
rollback;
delete from t3 where c2 = case when c2 = 1.111 then 5.111 else c2 end;delete from t3 where c2 = case when c2 = 2.222 then 1.111  else c2 end;//
select * from t3;
C1	C2	C3
select hit_count, is_batched_multi_stmt, statement, query_sql from gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where %' order by hit_count;
HIT_COUNT	IS_BATCHED_MULTI_STMT	STATEMENT	QUERY_SQL
