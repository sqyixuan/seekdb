drop user zwc cascade;
create user zwc identified by zwc;
grant all on *.* to zwc with grant option;
grant dba to zwc;
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
alter system flush plan cache global;
set autocommit = false;
alter system set ob_enable_batched_multi_statement='true';
#number+varchar
create table t1(c1 number ,c2 varchar(30) not null);
insert into t1 values(1,'AA');
insert into t1 values(2,'BB');
insert into t1 values(3,'CC');
SET @aa:='张三';
SET @bb:='李四';
set @cc:='王五';
insert into t1 select c1,case c2 when 'AA' then 'A' when 'BB' then 'B' else 'C' end as c2 from t1;
insert into t1 select c1,case c2 when 'AA' then @aa when 'BB' then @bb else @cc end as c2 from t1;//
select hit_count, is_batched_multi_stmt, statement, query_sql from gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 select %' order by hit_count;
HIT_COUNT	IS_BATCHED_MULTI_STMT	STATEMENT	QUERY_SQL
0	0	insert into t1 select c1,case c2 when ? then ? when ? then ? else ? end as c2 from t1;	insert into t1 select c1,case c2 when 'AA' then 'A' when 'BB' then 'B' else 'C' end as c2 from t1;
0	0	insert into t1 select c1,case c2 when ? then ? when ? then ? else ? end as c2 from t1;	insert into t1 select c1,case c2 when ? then ? when ? then ? else ? end as c2 from t1;
0	0	insert into t1 select c1,case c2 when ? then @aa when ? then @bb else @cc end as c2 from t1;	insert into t1 select c1,case c2 when 'AA' then @aa when 'BB' then @bb else @cc end as c2 from t1;
0	0	insert into t1 select c1,case c2 when ? then @aa when ? then @bb else @cc end as c2 from t1;	insert into t1 select c1,case c2 when ? then @aa when ? then @bb else @cc end as c2 from t1;
drop table t1;
alter system flush plan cache global;
create table t2(c1 number ,c2 varchar(30) not null default 'AA');
insert into t2 values(1,'AA');
insert into t2 values(2,'BB');
insert into t2 values(3,'CC');
insert into t2 values(4,'DD');
insert into t2 values(5,'EE');
insert into t2 values(6,'FF');
commit;
insert into t2 select c1,case c2 when 'AA' then 'A' when 'BB' then 'B' else 'C' end as c2 from t2;
insert into t2 select c1,case c2 when 'AA' then 'Q' when 'BB' then 'K' else 'A' end as c2 from t2;//
