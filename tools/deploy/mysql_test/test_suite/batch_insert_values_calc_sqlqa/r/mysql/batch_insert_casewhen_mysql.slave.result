| c1   | c2    |
+------+-------+
| 1    | 2.222 |
| 1    | 3     |
| 1    | 张    |
| 1    | 王    |
| 2    |       |
| 2    | 2.222 |
| 2    | 2.222 |
| 2    | 王    |
| 3    | 2.222 |
| 3    | 6     |
| 3    | 李    |
| 3    | 王    |
+------+-------+
affected rows: 12

select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t7 select c1,case c2 when %' order by hit_count;
+-----------+-----------------------+----------------------------------------------------------------------------------+-----------------------------------------------------------------------------------------------+
| hit_count | is_batched_multi_stmt | statement                                                                        | query_sql                                                                                     |
+-----------+-----------------------+----------------------------------------------------------------------------------+-----------------------------------------------------------------------------------------------+
|         1 |                     0 | insert into t7 select c1,case c2 when ? then ? when ? then ? else ? end from t7; | insert into t7 select c1,case c2 when '张' then '3' when '李' then '6' else '' end from t7;   |
|         1 |                     0 | insert into t7 select c1,case c2 when ? then ? when ? then ? else ? end from t7; | insert into t7 select c1,case c2 when '张' then '3' when '李' then '6' else '' end from t7;   |
+-----------+-----------------------+----------------------------------------------------------------------------------+-----------------------------------------------------------------------------------------------+
affected rows: 2
rollback;
affected rows: 0

delete from t7 where c1 = case c1 when '1' then '2' else c1 end;
delete from t7 where c1 = case c1 when '3' then '5' else c1 end;//
affected rows: 2
affected rows: 1
select * from t7 order by c1;
+------+------+
| c1   | c2   |
+------+------+
+------+------+
affected rows: 0

select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 where c1 = case c1 when %' order by hit_count;
+-----------+-----------------------+--------------------------------------------------------------+-----------------------------------------------------------------------------------------------------------------------------------+
| hit_count | is_batched_multi_stmt | statement                                                    | query_sql                                                                                                                         |
+-----------+-----------------------+--------------------------------------------------------------+-----------------------------------------------------------------------------------------------------------------------------------+
delete from t7 where c1 = case c1 when '3' then '5' else c1 end; |
|         0 |                     1 | delete from t7 where c1 = case c1 when ? then ? else c1 end  | delete from t7 where c1 = case c1 when '1' then '2' else c1 end;
|         1 |                     0 | delete from t7 where c1 = case c1 when ? then ? else c1 end; | delete from t7 where c1 = case c1 when '1' then '2' else c1 end;                                                                  |
|         1 |                     0 | delete from t7 where c1 = case c1 when ? then ? else c1 end; | delete from t7 where c1 = case c1 when ? then ? else c1 end;                                                                      |
+-----------+-----------------------+--------------------------------------------------------------+-----------------------------------------------------------------------------------------------------------------------------------+
affected rows: 3
