affected rows: 0
Warnings:
Note	1051	Unknown table 'db1.t7'
create table t7(c1 enum('a','b','c','1','2','3','','1.11','刘'),c2 set('张','王','李','','2.222','3','6','#$@'));
affected rows: 0
insert into t7 values('1','张'),('2','王'),('3','李');
affected rows: 3
info: Records: 3  Duplicates: 0  Warnings: 0
commit;
affected rows: 0
select * from t7;
+------+------+
| c1   | c2   |
+------+------+
| 1    | 张   |
| 2    | 王   |
| 3    | 李   |
+------+------+
affected rows: 3

insert into t7 select c1,case c2 when '张' then '3' when '李' then '6' else '' end from t7;
insert into t7 select c1,case c2 when '张' then '王' when '李' then '王' else '2.222' end from t7;//
affected rows: 3
info:  Records: 3  Duplicates: 0  Warnings: 0
affected rows: 6
info: Records: 6  Duplicates: 0  Warnings: 0
select * from t7 order by c1;
