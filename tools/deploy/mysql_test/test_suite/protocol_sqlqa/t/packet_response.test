# test case about tenant, database, tablegroup, table

let $count = 38;
let $i = 0;
while ($i <= $count)
{
  eval select repeat('a', 13236+$i) from dual;
  inc $i;
}

--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(f1 int,f2 integer);
INSERT INTO test1 VALUES(1,111);
INSERT INTO test1 VALUES(2,222);
INSERT INTO test1 VALUES(3,333);
INSERT INTO test1 VALUES(NULL,NULL);
select concat(repeat('a', 13236), f1) from test1;
select concat(repeat('a', 13236), f2) from test1;

