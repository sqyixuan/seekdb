--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: yangjiali.yjl
#owner group: opensource
#description: test alter system
#tags: index usage

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

alter system set _iut_enable=true;
alter system set _iut_enable=false;
--error 1064
alter system set _iut_enable=xxx

alter system set _iut_max_entries=30000;
alter system set _iut_max_entries=0;
--error 4147
alter system set _iut_max_entries=-1;

--error 1064
alter system set _iut_stat_collection_type=sampled;
alter system set _iut_stat_collection_type='sampled';
alter system set _iut_stat_collection_type='all';

--error 4147
alter system set _iut_stat_collection_type='xxx';

