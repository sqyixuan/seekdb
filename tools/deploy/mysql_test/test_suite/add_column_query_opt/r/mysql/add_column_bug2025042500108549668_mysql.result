create table t7(a int, primary key (a)) row_format = compact with column group (all columns, each column);
create table t8(a int, primary key (a)) row_format = dynamic with column group (all columns, each column);
create table t9(a int, primary key (a)) row_format = compressed with column group (all columns, each column);
