create table t1(a int, primary key (a)) row_format = compact with column group (all columns);
create table t2(a int, primary key (a)) row_format = dynamic with column group (all columns);
create table t3(a int, primary key (a)) row_format = compressed with column group (all columns);
create table t4(a int, primary key (a)) row_format = compact with column group (each column);
create table t5(a int, primary key (a)) row_format = dynamic with column group (each column);
