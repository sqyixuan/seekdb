alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
--enable_query_log

alter table t1_many_columns add column c1_new int default 601, add column c2_new varchar(100);
alter table t1_many_columns add column c3_new char(50) as(substr(c8_1, 1, 10));
alter table t1_many_columns add column c4_new tinytext as(substr(c8_1, 1, 20)) virtual;
alter table t1_many_columns add column c5_new longblob as(repeat('C', 10000000));
alter table t1_many_columns add column c6_new char(10) default 'aaaaaaaa';
alter table t1_many_columns add column c7_new blob;

select id_1, c1_1, c2_1, c3_1, c4_1, c6_1, c7_1, c8_1, c1_new, c2_new, c3_new, c6_new from t1_many_columns where id_1 < 999298 and c6_new = 'aaaaaaaa';
select count(*) from t1_many_columns;
select count(c1_new) from t1_many_columns;
select count(c2_new) from t1_many_columns;
select count(c1_new) from t1_many_columns where c1_new > 300;
select count(c1_new) from t1_many_columns where c1_new < 30;
select count(*) from t1_many_columns where c3_1 > c1_new;
select count(*) from t1_many_columns where c1_new < c3_1;
select id_1, c2_new, count(c1_new) from t1_many_columns where c1_new > 480;
select c1_new, c2_new from t1_many_columns where c1_new > 480 and c3_1 < 999101;
select c3_1, c2_new, count(c1_new) from t1_many_columns where c1_new < 490 and id_30 < 999150;
select id_40, c1_new, count(c1_new) from t1_many_columns where id_20 < 999110 and c1_new != 80 and c1_new != 6 and c1_new + 10 > 30;
select count(c3_new), min(c3_new), max(c3_new), sum_opnsize(c3_new), approx_count_distinct(c3_new) from t1_many_columns where id_40 < 999201;
select count(*),count(id_10),min(id_20),max(id_30),sum(c3_1),count(c3_10),min(c3_20),max(c3_30),count(c1_1),min(c1_1),max(c1_1),sum(c1_1) from t1_many_columns;
select count(*),count(c1_new),min(c1_new),max(c1_new),sum(c1_new),count(c2_new),min(c2_new),max(c2_new),sum(c2_new) from t1_many_columns;
select count(*),count(c3_new),min(c3_new),max(c3_new),sum(length(c3_new)),count(c4_new),min(c4_new),max(c4_new),sum(length(c4_new)) from t1_many_columns;
select length(c5_new),count(*),count(c5_new),length(min(c5_new)),length(max(c5_new)),sum(length(c5_new)),sum_opnsize(c5_new), approx_count_distinct(c5_new) from t1_many_columns;
select count(*),count(c7_new),min(c7_new),max(c7_new),sum(c7_new),avg(c7_new) from t1_many_columns;
select distinct(c1_new) from t1_many_columns;
select distinct(c2_new) from t1_many_columns;
select distinct(c3_new) from t1_many_columns where id_40 < 999110;
select distinct(c4_new) from t1_many_columns where id_40 < 999110;

drop table t1_many_columns;