# owner: maijianhua.mjh
# owner group: STORAGE
# description:

--disable_query_log
--disable_warnings
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
connection default;
set @@recyclebin = off;
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9;
set sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';
--enable_warnings
--enable_query_log

create table t1(a int, primary key (a)) row_format = compact with column group (all columns);
create table t2(a int, primary key (a)) row_format = dynamic with column group (all columns);
create table t3(a int, primary key (a)) row_format = compressed with column group (all columns);
create table t4(a int, primary key (a)) row_format = compact with column group (each column);
create table t5(a int, primary key (a)) row_format = dynamic with column group (each column);
create table t6(a int, primary key (a)) row_format = compressed with column group (each column);
create table t7(a int, primary key (a)) row_format = compact with column group (all columns, each column);
create table t8(a int, primary key (a)) row_format = dynamic with column group (all columns, each column);
create table t9(a int, primary key (a)) row_format = compressed with column group (all columns, each column);
sleep 3;

--disable_query_log
--disable_warnings
--let $count=999100
while ($count < 999200)
{
  eval INSERT INTO t1 VALUES($count);
  eval INSERT INTO t2 VALUES($count);
  eval INSERT INTO t3 VALUES($count);
  eval INSERT INTO t4 VALUES($count);
  eval INSERT INTO t5 VALUES($count);
  eval INSERT INTO t6 VALUES($count);
  eval INSERT INTO t7 VALUES($count);
  eval INSERT INTO t8 VALUES($count);
  eval INSERT INTO t9 VALUES($count);
  inc $count;
}
--enable_warnings
--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--let $table_seq=1
while ($table_seq < 10)
{
  eval alter table t$table_seq add column c1 int default 1;
  eval alter table t$table_seq add column c2 int default 2;
  eval alter table t$table_seq add column c3 int default 3;
  eval alter table t$table_seq add column c4 int default 4;
  eval alter table t$table_seq add column c5 int default 5;
  eval alter table t$table_seq add column c6 int default 6;
  eval alter table t$table_seq add column c7 int default 7;
  inc $table_seq;
}

--let $case_seq=1
--let $count=0
--let $level=0
--let $enabled=false
--let $riched=false
while ($count < 20)
{
  if ($count == 5)
  {
    let $level=0;
    let $enabled=true;
    let $riched=false;
  }

  if ($count == 10)
  {
    let $level=0;
    let $enabled=false;
    let $riched=true;
  }

  if ($count == 15)
  {
    let $level=0;
    let $enabled=true;
    let $riched=true;
  }

  --echo case $case_seq count $count level $level enabled $enabled riched $riched
  eval alter system set _pushdown_storage_level = $level;
  eval alter system set _rowsets_enabled = $enabled;
  connection obsys;
  eval alter system set _global_enable_rich_vector_format = $riched;
  eval alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 1;
  connection default;
  eval alter system flush plan cache;
  eval set sql_mode = 'PAD_CHAR_TO_FULL_LENGTH';

  --let $table_seq=1
  while ($table_seq < 10)
  {
    eval select max(c1),max(c2),max(c3),max(c4) from t$table_seq group by c7;
    eval select c7,max(c1),max(c2),max(c3),max(c4) from t$table_seq group by c7;
    inc $table_seq;
  }

  inc $case_seq;
  inc $count;
  inc $level;
}


--disable_query_log
connection obsys;
alter system set _global_enable_rich_vector_format = true;
alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 0;
connection default;
set @@recyclebin = on;
alter system set _pushdown_storage_level = 4;
alter system set _rowsets_enabled = true;
alter system flush plan cache;
--enable_query_log
drop table t1,t2,t3,t4,t5,t6,t7,t8,t9;
