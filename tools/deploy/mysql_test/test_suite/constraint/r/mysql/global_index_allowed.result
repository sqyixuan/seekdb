drop database if exists cst;
create database cst;
use cst;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local, constraint cst check (c1 = c2)) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
