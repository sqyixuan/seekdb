drop database if exists cst;
create database cst;
use cst;
create table t1(a int primary key, b varchar(10), c varchar(10), constraint cst check (substring(b, 1, 2) = substring(c, 2, 2)));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) NOT NULL,
  `b` varchar(10) DEFAULT NULL,
  `c` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`a`),
  CONSTRAINT `cst` CHECK ((substr(`b`,1,2) = substr(`c`,2,2)))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
select * from information_schema.table_constraints where table_schema = 'cst' and table_name = 't1';
CONSTRAINT_CATALOG	CONSTRAINT_SCHEMA	CONSTRAINT_NAME	TABLE_SCHEMA	TABLE_NAME	CONSTRAINT_TYPE	ENFORCED
def	cst	PRIMARY	cst	t1	PRIMARY KEY	YES
def	cst	cst	cst	t1	CHECK	YES
drop database if exists cst;
