drop database if exists cst;
create database cst;
use cst;
create table t1(a int primary key, b varchar(10), c varchar(10), constraint cst check (substring(b, 1, 2) = substring(c, 2, 2)));
truncate table t1;
rename table t1 to t2;
alter table t2 rename to non_duplicate;
drop table non_duplicate;
drop table if exists t1;
create table t1(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2)), d varchar(10), constraint cst check (k = substring(c, 2, 2)), constraint cst2 check(k = substring(d, 2,2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table t1;
drop database if exists cst;
