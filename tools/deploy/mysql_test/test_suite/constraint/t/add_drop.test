create table tt(c1 int,c2 int,c3 int,unique index (c1,c2),unique inde(c3));
create table tt1(c1 int,c2 int,c3 int);
--error 1091
alter table tt1 drop index djs;
ALTER TABLE tt1 ADD CONSTRAINT djs FOREIGN KEY (c3) REFERENCES tt (c3);
--error 1091
alter table tt1 drop index djs;
drop table tt,tt1;


