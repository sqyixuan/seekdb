--disable_warnings
drop database if exists cst;
create database cst;
use cst;
--disable_warnings

create table t1(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'));

alter table t1 add constraint cst check(k = substring(c, 2, 2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

--error 1235
alter table t1 add constraint cst_new check(k = substring(c, 2, 2)), add constraint cst_new check(k = substring(c, 2, 2));

--error 3822
alter table t1 add constraint cst check(k = substring(c, 2, 2));

--error 3822
alter table t1 drop constraint (cst, cst);

--error 3821
alter table t1 drop constraint (cst1);

alter table t1 drop constraint (cst);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

alter table t1 add constraint cst check(k = substring(c, 2, 2));
alter table t1 add constraint cst2 check(k = substring(c, 2, 2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

alter table t1 drop constraint (cst, cst2);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;


# bugfix#
drop table t1;
create table t1(c1 int, constraint cst check(c1 = 1));
--error 1235
alter table t1 drop constraint cst, add constraint cst check(c1 = 2);
--error 1235
alter table t1 add constraint cst check(c1 = 2), drop constraint cst;
drop table t1;

