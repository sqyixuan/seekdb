#owner: dachuan.sdc
#owner group: SQL2
#description: test not null constraint
#tags: ddl

--disable_warnings
drop table if exists t;
--enable_warnings

create table t(c1 int, c2 int, c3 int not null);
desc t;


insert into t values(0, null, 0);
alter table t modify c1 int not null;
--error 1138
alter table t modify c2 int not null;
desc t;
select * from t where c1 is null;
select * from t where c1 is not null;
select * from t where c2 is null;
select * from t where c2 is not null;


connection default;
alter table t modify c1 int;
alter table t modify c2 int;
alter table t modify c3 int;
desc t;
select * from t where c1 is null;
select * from t where c1 is not null;
select * from t where c2 is null;
select * from t where c2 is not null;
select * from t where c3 is null;
select * from t where c3 is not null;

drop table t;

## test desc and show create table after modify column not null.
create table t(c1 int, c2 int not null, c3 int);
desc t;
show create table t;
alter table t modify c3 int not null;
desc t;
show create table t;
drop table t;