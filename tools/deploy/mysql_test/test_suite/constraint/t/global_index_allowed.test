--disable_warnings
drop database if exists cst;
create database cst;
use cst;
--disable_warnings


# no generated column
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local, constraint cst check (c1 = c2)) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local, constraint cst check (c1 = substring(c2, 1, 1))) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local, constraint cst check (c2 = substring(c1, 1, 1))) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));


# generated column
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 varchar(10), c2 varchar(10), c3 varchar(10) generated always as (substring(c2, 1, 2)), unique index i1 (c1) local, constraint cst check(c3 = c1)) partition by list columns (c3) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 varchar(10), c2 varchar(10), c3 varchar(10) generated always as (substring(c2, 1, 2)), unique index i1 (c1) local, constraint cst check(c3 = substring(c1,2,2))) partition by list columns (c3) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 varchar(10), c2 varchar(10), c3 varchar(10) generated always as (substring(c2, 1, 2)), unique index i1 (c1) local, constraint cst check(substring(c2,1,2) = substring(c1,2,2))) partition by list columns (c3) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 varchar(10), c2 varchar(10), c3 varchar(10) generated always as (substring(c2, 1, 2)), unique index i1 (c1) local, constraint cst check(substring(c2,1,2) = c1)) partition by list columns (c3) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 varchar(10), c2 varchar(10), c3 varchar(10) generated always as (substring(c2, 1, 2)), unique index i1 (c1) local, constraint cst check(substring(c2,2,2) = c1)) partition by list columns (c3) (partition p0 values in ('01'), partition p1 values in ('02'));

--disable_warnings
drop database if exists cst;
--disable_warnings

