--disable_warnings
drop database if exists cst;
create database cst;
use cst;
--disable_warnings


drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));

drop table if exists t1;
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create table t1 (c1 int primary key, c2 int, unique index i1 (c2) local, constraint cst check (c1 = c2)) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));

drop table if exists t1;
create table t1 (c1 int primary key, c2 int) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create unique index i1  on t1(c2) local;

drop table if exists t1;
create table t1 (c1 int primary key, c2 int, constraint cst check (c1 = c2)) partition by list columns (c1) (partition p0 values in (1), partition p1 values in (2));
--error ER_UNIQUE_KEY_NEED_ALL_FIELDS_IN_PF
create unique index i1  on t1(c2) local;


