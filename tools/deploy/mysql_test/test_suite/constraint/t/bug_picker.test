--disable_warnings
drop database if exists cst;
create database cst;
use cst;
--disable_warnings

create table t1(a int primary key, b varchar(10), c varchar(10), constraint cst check (substring(b, 1, 2) = substring(c, 2, 2)));
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

truncate table t1;
rename table t1 to t2;
alter table t2 rename to non_duplicate;
# let $recycle_obj=`select res from (select concat('__recycle_\\\$_1_', database_id, '_', table_id) res, row_number() over (order by schema_version desc) rn from oceanbase.__all_virtual_table where table_name = 'non_duplicate') a where a.rn = 1`;
#echo $recycle_obj;
drop table non_duplicate;
# --disable_query_log
# eval flashback table $recycle_obj to before drop;
# --enable_query_log
# select 1 from non_duplicate;

# multi contraint
drop table if exists t1;
create table t1(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2)), d varchar(10), constraint cst check (k = substring(c, 2, 2)), constraint cst2 check(k = substring(d, 2,2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'));
drop table t1;

--disable_warnings
drop database if exists cst;
--disable_warnings

