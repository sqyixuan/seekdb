sleep 3;


explain select * from t1 where c = '002';
explain select * from t1 where b = '01';
explain select * from t1 where k = '02';


# 使用表别名的情况
explain select * from t1 l where l.c = '002';

# 投影列不包含约束条件列的情况
explain select a from t1 l where l.c = '002';
explain select a from t1 l;


drop table t1;


# list分区有两列的情况，目前是不支持分区裁裁剪的
explain select * from t2 where a = 1 and c = '002';

drop table t2;


# 多个约束条件
explain select * from t3 where c = '002';
explain select * from t3 where c = '005';
explain select * from t3 where d = '002';

insert into t3(a,b,c,d) values(1, '01', '001', '001');
insert into t3(a,b,c,d) values(2, '02', '002', '002');
select * from t3 where d = '001';
select * from t3 where c = '002';

# 支持or表达式
explain select * from t3 where c = '002' or c = '003';
explain select * from t3 where c in ('002', '003');

select * from t3 where c in ('002', '003');

explain update t3 set c  = '003', b = '03', d = '003' where c = '002';
update t3 set c  = '003', b = '03', d = '003' where c = '002';

explain update t3 set c  = '003', b = '03', d = '003' where c = '005';
update t3 set c  = '003', b = '03', d = '003' where c = '005';

explain delete from t3 where c = '003';
delete from t3 where c = '003';

explain delete from t3 where c = '005';
delete from t3 where c = '005';

select * from t3;

 #不支持两个不同的条件
explain select * from t3 where d = '002' or c = '003';

# 对于子查询也能做分区裁剪
explain select * from (select a, count(*) as k from t3 where c = '002' group by a) l group by l.k;
explain select * from (select a, count(*) as k from t3 where d = '002' group by a) l group by l.k;


drop table t3;

# 带索引的主键的表
insert into t4(c1,c2) values('01', '01');
insert into t4(c1,c2) values('02', '02');

explain select * from t4 where c2 = '02';
select * from t4 where c2 = '02';

drop table t4;

explain select * from t5 where fund_detail_id = 'pay_comm_payment_39_3801';

drop table t5;

