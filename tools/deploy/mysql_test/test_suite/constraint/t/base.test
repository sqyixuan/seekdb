--disable_warnings
drop database if exists cst;
create database cst;
use cst;
--disable_warnings

create table t1(a int primary key, b varchar(10), c varchar(10), constraint base_cst_00 check (substring(b, 1, 2) = substring(c, 2, 2)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

# generated column
drop table if exists t1;
create table t1(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 2, 2)), constraint base_cst_0 check (k = substring(c, 2, 2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;



drop table t1;

create table t1(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2)), constraint base_cst_1 check (k = substring(c, 2, 2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'));

create table t2(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2)), constraint base_cst_2 check (k = substring(c, 2, 2))) partition by list columns(a, k) (partition p0 values in ((1, '01')), partition p1 values in ((2, '02')));

create table t3(a int, b varchar(10), c varchar(10), k varchar(10) generated always as (substring(b, 1, 2)), d varchar(10), constraint base_cst_3 check (k = substring(c, 2, 2)), constraint cst2 check(k = substring(d, 2,2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'), partition p2 values in ('03'));

create table t4 (c1 varchar(10) primary key, c2 varchar(10),  index i1 (c2) local, k varchar(10) generated always as (substring(c1,1,2)), constraint base_cst_4 check(k = substring(c2,1,2))) partition by list columns(k) (partition p0 values in ('01'), partition p1 values in ('02'), partition p2 values in ('03'));

CREATE TABLE `t5` (
  `payment_id` varchar(64) NOT NULL,
  `fund_detail_id` varchar(64) NOT NULL,
  `pay_tool_type` varchar(16) NOT NULL,
  `amount` decimal(16,0) DEFAULT NULL,
  `memo` varchar(1024) DEFAULT NULL,
  `gmt_create` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
  `partition_id` varchar(2) GENERATED ALWAYS AS (substr(`payment_id`,18,2)) VIRTUAL,
  PRIMARY KEY (`payment_id`, `pay_tool_type`, `fund_detail_id`),
  UNIQUE KEY `uk_fund_detail_id` (`fund_detail_id`, `partition_id`) LOCAL  BLOCK_SIZE 16384,
  KEY `idx_fund_detail_id` (`fund_detail_id`) LOCAL  BLOCK_SIZE 16384,
  CONSTRAINT `cst` CHECK ((`partition_id` = substr(`fund_detail_id`,18,2)))
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
 partition by list columns(partition_id)
