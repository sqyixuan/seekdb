--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# 
--error 0,1051
drop table t_46681204;



## create table add empty name cst

--error 5854
create table t_46681204(c1 int, constraint `` check(c1 > 1));

--error 1280
create table t_46681204(c1 int, constraint `` unique(c1));

--error 5854
create table t_46681204(c1 int primary key, c2 int, constraint `` foreign key (c2) references t_46681204(c1));

## primary key is not a kind of constraints in mysql, and constraint name will be ignored for primary key
create table t_46681204(c1 int, constraint `` primary key(c1));
drop table t_46681204;


## alter table add empty name cst

create table t_46681204_2(c1 int unique, c2 int);

--error 5854
alter table t_46681204_2 add constraint `` check(c1 > 1);

--error 1280
alter table t_46681204_2 add constraint `` unique(c2);

--error 5854
alter table t_46681204_2 add constraint `` foreign key (c2) references t_46681204(c1);



## clean up
drop table t_46681204_2;
