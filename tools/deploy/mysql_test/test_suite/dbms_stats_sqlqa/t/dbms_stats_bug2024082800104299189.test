--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yizhou.wyf
# owner group: SQL1
# tags: optimizer, opt_stats
--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(c1 int);
create index index_TEST1_1 on TEST1(c1);
--error 1264
call dbms_stats.gather_table_stats('TEST1','TEST1', degree=>999999999999999999);
--error 1264
call dbms_stats.gather_table_stats('TEST1','TEST1', degree=>99999999999999999);
--error 1264
call dbms_stats.gather_table_stats('TEST1','TEST1', degree=>9999999999999999999);
--error 1264
call dbms_stats.gather_index_stats('TEST1','index_TEST1_1',degree=>999999999999999999.999999);
--error 1264
call dbms_stats.gather_index_stats('TEST1','index_TEST1_1',degree=>9999999999999999999.999999);
--error 1264
call dbms_stats.gather_index_stats('TEST1','index_TEST1_1',degree=>99999999999999999.999999);
--error 1264
call dbms_stats.gather_schema_stats('TEST1',degree=>999999999999999999.999999);
--error 1264
call dbms_stats.gather_schema_stats('TEST1',degree=>9999999999999999999.999999);
--error 1264
call dbms_stats.gather_schema_stats('TEST1',degree=>99999999999999999.999999);