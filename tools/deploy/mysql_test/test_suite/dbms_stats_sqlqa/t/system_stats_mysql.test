#owner: zhenling.zzg
#owner group: sql1
#description: dbms_stats包下函数/过程测试
#tags: gather_system_stats、delete_system_stats、set_system_stats

connect(sys_mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_mysql;

--result_format 3

select * from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.gather_system_stats();

select count(*) from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('cpu_speed', '100');

select "cpu_speed(MHz)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('cpu_speed', '200');

select "cpu_speed(MHz)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('disk_seq_read_speed', '300');

select "disk_seq_read_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('disk_seq_read_speed', '400');

select "disk_seq_read_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('disk_rnd_read_speed', '500');

select "disk_rnd_read_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('disk_rnd_read_speed', '600');

select "disk_rnd_read_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('network_speed', '700');

select "network_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.set_system_stats('network_speed', '800');

select "network_speed(MB/s)" from OCEANBASE.DBA_OB_AUX_STATISTICS;

call dbms_stats.delete_system_stats();

select * from OCEANBASE.DBA_OB_AUX_STATISTICS;

connection default;

--error 5935
call dbms_stats.gather_system_stats();

