--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yizhou.wyf
# owner group: SQL1
# tags: optimizer, opt_stats
--disable_warnings
drop table if exists test1_1;
--enable_warnings

## degree bug
create table test1_1(id INT) partition by hash(id) subpartition by hash(id) subpartitions 5 partitions 5;
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>-2147483649,estimate_percent=>0.01,granularity=>'partition');
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>-1,estimate_percent=>0.01,granularity=>'partition');
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>1,estimate_percent=>0.01,granularity=>'partition');
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>2147483644,estimate_percent=>0.01,granularity=>'partition');
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>2147483649,estimate_percent=>0.01,granularity=>'partition');
call dbms_stats.gather_table_stats('test','test1_1',method_opt=>'for all columns size 1',degree=>9999999999,estimate_percent=>0.01,granularity=>'partition');
select h.properties from oceanbase.__all_virtual_table_opt_stat_gather_history h,oceanbase.__all_table t WHERE  h.table_id = t.table_id and t.table_name='test1_1' ORDER  BY h.start_time desc limit 10;
drop table test1_1;


