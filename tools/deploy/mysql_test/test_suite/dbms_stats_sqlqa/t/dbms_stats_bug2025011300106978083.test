--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

## gather_schema_stats bug
call dbms_stats.gather_schema_stats('oceanbase',estimate_percent=>10);
call dbms_stats.gather_schema_stats('oceanbase');
call dbms_stats.gather_schema_stats('mysql',estimate_percent=>40);

connect (oboracle,$OBMYSQL_MS0,admin@oracle,admin,test,$OBMYSQL_PORT);
connection oboracle;
call dbms_stats.gather_schema_stats('SYS',estimate_percent=>10);
call dbms_stats.gather_schema_stats('SYS');
disconnect oboracle;

