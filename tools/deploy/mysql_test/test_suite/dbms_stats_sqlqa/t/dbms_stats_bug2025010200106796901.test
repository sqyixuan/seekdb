--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yizhou.wyf
# owner group: SQL1
# tags: optimizer, opt_stats
--disable_warnings
drop table if exists `test1``test2```;
drop table if exists t;
--enable_warnings

## pack sql string bug
set _enable_storage_cardinality_estimation = OFF;

CREATE TABLE `test1``test2``` (i INT);
insert into `test1``test2``` select random(10)%100 from table(generator(100));
call dbms_stats.gather_table_stats('test','test1`test2`',method_opt=>'for all columns size 1');
select table_name, num_rows from oceanbase.DBA_TAB_STATISTICS where table_name = 'test1`test2`';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
explain extended_noaddr select /*+no_rewrite*/ * from `test1``test2```;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
explain extended_noaddr select /*+dynamic_sampling(1) no_rewrite */ * from `test1``test2```;
drop table `test1``test2```;

CREATE TABLE t(`test1``test2``` INT);
insert into t select random(10)%100 from table(generator(1000));
call dbms_stats.gather_table_stats('test','t',method_opt=>'for all columns size 1');
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
explain extended_noaddr select /*+no_rewrite*/ * from t where t.`test1``test2``` = 1 group by t.`test1``test2```;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
explain extended_noaddr select /*+dynamic_sampling(1) no_rewrite */ * from t where t.`test1``test2``` = 1 group by t.`test1``test2```;
drop table t;

set _enable_storage_cardinality_estimation = ON;

