# owner: linyi.cl
# owner group: 技术部-SQL-外表
# tags: external_table
# description: test select into outfile parquet partition by

--result_format 4
PURGE RECYCLEBIN;

--source mysql_test/include/oss_config_for_import.inc

let $RANDOM_NUM=query_get_value(select abs(random()) ran from dual,ran,1);
let $DATA_FOLDER_NAME = antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/zhch_external_table_data/outfile_data_parquet_$RANDOM_NUM;

####oss场景，分区导出场景####
--disable_result_log
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump_oss.inc
--enable_result_log

--error 0,1051
drop table t1;
CREATE table t1(c1 int,c2 varchar(50),c3 DATE);
INSERT INTO t1 VALUES(1,'a','0001-01-01');
INSERT INTO t1 VALUES(2,'b','0002-02-02');
INSERT INTO t1 VALUES(3,'c','0003-03-03');

let $FILE_PREFIX = tmp_parquet;
--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
format(
type = 'parquet'
) single = true;

--error 0,1051
drop table ex_par;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval create external table ex_par(c1 int ,c2 varchar(50),c3 date)
format(type = 'parquet') location 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@cn-heyuan-alipay-b.oss-alipay.aliyuncs.com/$DATA_FOLDER_NAME/' pattern = 'tmp_par';

select * from ex_par;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc


##分区导出
let $FILE_PREFIX = par;
--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY concat('par_',c2)
format(
type = 'parquet'
)  single = FALSE;

alter external table ex_par refresh;
SELECT * FROM ex_par;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY concat('par',cast(c1 as char))
format(
type = 'parquet'
)  single = FALSE;

alter external table ex_par refresh;
SELECT * FROM ex_par;


####其他类型
--error 0,1051
drop table zct2;
CREATE TABLE zct2(c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT,c4 int,c5 BIGINT,c6 DECIMAL(10,2),c7 float(5,2),c8 double(5,2),c9 bit(6),c10 TINYINT(255) UNSIGNED,c11 SMALLINT(255) ZEROFILL,c12 MEDIUMINT(255) UNSIGNED,c13 int (255) UNSIGNED,c14 bigint(255) ZEROFILL,c15 decimal UNSIGNED,c16 float(5,2) UNSIGNED,c17 double(5,2) ZEROFILL,c18 datetime,c19 timestamp,c20 date,c21 time,c22 year,c23 char,c24 varchar(50),c25 binary,c26 varbinary(50),c27 TINYBLOB,c28 BLOB,c29 MEDIUMBLOB,c30 LONGBLOB,c31 TINYTEXT,c32 TEXT,c33 MEDIUMTEXT,c34 LONGTEXT,c35 ENUM('','a','1','中') CHARACTER SET utf16 ,c36 set('a', '1','','中') CHARACTER SET utf16,c37 json,c38 GEOMETRY);

