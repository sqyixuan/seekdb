--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2)*/ c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16,c17,c18,c19,c20,c21,c22,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34 from zct2 into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY 'part'
format(
type = 'parquet'
)  single = FALSE;

--error 0,1051
drop table ex_par;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval create external table ex_par(
c1 TINYINT as (get_path(external\$filerow, 'c1')),
c2 SMALLINT as (get_path(external\$filerow, 'c2')),
c3 MEDIUMINT as (get_path(external\$filerow, 'c3')),
c4 int as (get_path(external\$filerow, 'c4')),
c5 bigint as (get_path(external\$filerow, 'c5')),
c6 decimal(10,2) as (get_path(external\$filerow, 'c6')),
c7 float(5,2) as (get_path(external\$filerow, 'c7')),
c8 double(5,2) as (get_path(external\$filerow, 'c8')),
c9 bigint UNSIGNED as (get_path(external\$filerow, 'c9')),
c10 TINYINT(255) UNSIGNED as (get_path(external\$filerow, 'c10')),
c11 SMALLINT(255) ZEROFILL as (get_path(external\$filerow, 'c11')),
c12 MEDIUMINT(255) UNSIGNED as (get_path(external\$filerow, 'c12')),
c13 int  UNSIGNED as (get_path(external\$filerow, 'c13')),
c14 bigint UNSIGNED as (get_path(external\$filerow, 'c14')),
c16 float as (get_path(external\$filerow, 'c16')),
c17 double as (get_path(external\$filerow, 'c17')),
c18 timestamp as (get_path(external\$filerow, 'c18')),
c19 timestamp as (get_path(external\$filerow, 'c19')),
c20 date as (get_path(external\$filerow, 'c20')),
c21 time as (get_path(external\$filerow, 'c21')),
c22 year as (get_path(external\$filerow, 'c22')),
c23 char as (get_path(external\$filerow, 'c23')),
c24 varchar(50) as (get_path(external\$filerow, 'c24')),
c25 binary as (get_path(external\$filerow, 'c25')),
c26 varbinary(50) as (get_path(external\$filerow, 'c26')),
c27 varbinary(50) as (get_path(external\$filerow, 'c27')),
c28 varbinary(50) as (get_path(external\$filerow, 'c28')),
c29 varbinary(50) as (get_path(external\$filerow, 'c29')),
c30 varbinary(50) as (get_path(external\$filerow, 'c30')),
c31 varbinary(50) as (get_path(external\$filerow, 'c31')),
c32 varbinary(50) as (get_path(external\$filerow, 'c32')),
c33 varbinary(50) as (get_path(external\$filerow, 'c33')),
c34 varbinary(50) as (get_path(external\$filerow, 'c34')))
format(type = 'parquet') location 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@cn-heyuan-alipay-b.oss-alipay.aliyuncs.com/$DATA_FOLDER_NAME/' pattern = 'tmp_par';

select * from ex_par;

