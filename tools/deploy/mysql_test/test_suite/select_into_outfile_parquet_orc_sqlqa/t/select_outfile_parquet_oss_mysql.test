--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3) query_timeout(100000000)*/ c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16,c17,c18,c19,c20,c21,c22,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34 from zct2 where c1 is not null into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY concat('par_',c1)
format(
type = 'parquet'
ROW_GROUP_SIZE = '1MB'
) single = FALSE MAX_FILE_SIZE = '1MB';

alter external table ex_par refresh;
SELECT count(*) FROM ex_par;


####大数据分区导出不同压缩parquet，并用外表分区读取####
drop table t1;
create table t1(a int,b char(10),c bigint,d varbinary(3000));
--error 0,4298
drop SEQUENCE s1;
CREATE SEQUENCE s1 START WITH 1  INCREMENT BY 1 ;
insert /*+ append enable_parallel_dml parallel(8) query_timeout(100000000)*/ into t1 select s1.nextval, 'oceanbase', random(), randstr(3000, random()) from table(generator(10000));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5) query_timeout(100000000)*/ a,b,c,d from t1 into outfile 'oss://$DATA_FOLDER_NAME/tmp_parquet?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY concat('par_',a%10)
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = FALSE MAX_FILE_SIZE = '256MB';

--error 0,1051
drop table ex_par;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval create external table ex_par(
c0 INT as (get_path(external\$filerow, 'a')) COMMENT '账号',
c1 char(10) as (get_path(external\$filerow, 'b')),
c2 bigint as (get_path(external\$filerow, 'c')),
c3 varbinary(3000) as (get_path(external\$filerow, 'd')),
PAR VARCHAR(50) AS(SUBSTR(SUBSTR(metadata\$fileurl,instr(metadata\$fileurl, '%') + 1),1,6))
)
format (type = 'PARQUET') location 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@cn-heyuan-alipay-b.oss-alipay.aliyuncs.com/$DATA_FOLDER_NAME/'
PATTERN = "tmp_parquet" PARTITION BY(PAR);

alter external table ex_par refresh;
SELECT count(*) FROM ex_par;

