####format
##COMPRESSION(lz0 not support)
let $FILE_NAME = tmp_parquet;
--source mysql_test/include/select_into_outfile/delete_file.inc
select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet.snappy'
format(
type = 'parquet'
COMPRESSION = 'SNAPPY'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet.gz'
format(
type = 'parquet'
COMPRESSION = 'GZIP'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet.lz4'
format(
type = 'parquet'
COMPRESSION = 'LZ4'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet.zstd'
format(
type = 'parquet'
COMPRESSION = 'ZSTD'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet.brotli'
format(
type = 'parquet'
COMPRESSION = 'BROTLI'
ROW_GROUP_SIZE = '1MB'
) single = true;

##external table read compressed parquet
--error 0,1051
drop table ex_par;
create external table ex_par(
c1 INT as (get_path(external$filerow, 'c4')),
c2 BIGINT as (get_path(external$filerow, 'c5')),
c3 FLOAT as (get_path(external$filerow, 'c7')),
c4 DOUBLE as (get_path(external$filerow, 'c8')),
c5 INT UNSIGNED as (get_path(external$filerow, 'c13')),
c6 datetime as (get_path(external$filerow, 'c18')),
c7 timestamp as (get_path(external$filerow, 'c19')),
c8 date as (get_path(external$filerow, 'c20')),
c9 time as (get_path(external$filerow, 'c21')),
c10 char as (get_path(external$filerow, 'c23')),
c11 varchar(50) as (get_path(external$filerow, 'c24')),
c12 binary as (get_path(external$filerow, 'c25')),
c13 varbinary(50) as (get_path(external$filerow, 'c26'))
)
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_parquet$';

select count(*) from ex_par;
SELECT * FROM ex_par LIMIT 10;

