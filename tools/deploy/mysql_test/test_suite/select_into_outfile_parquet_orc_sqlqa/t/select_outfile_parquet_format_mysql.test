####异常场景####
##空location
--source mysql_test/include/select_into_outfile/delete_file.inc
--error 1210
select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile ''
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true;
##空compression
--error 1235
select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = ''
ROW_GROUP_SIZE = '1MB'
) single = true;
##空type
--error 1235
select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = ''
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true;
--error 1064
select c4,c5,c6,c7,c8,c13,c15,c18,c19,c20,c21,c23,c24,c25,c26 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = null
ROW_GROUP_SIZE = '1MB'
) single = true;

