--result_format 4
PURGE RECYCLEBIN;
--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = outfile_data_parquet;
--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

####single false####
##分配文件优先级:##
##parallel>batch(alter system set _rowsets_max_rows修改)>max file size##
##select stmt中包含lob列batch为1##
--error 0,1051
drop table zct1;
create table zct1(a int , B varchar(50), c date, D datetime, e timestamp, F time, g smallint, H blob(10), i text, J float, k double, L decimal(10, 2), m bigint);
insert into zct1 values(1, '一', '2020-01-01', '2020-01-01 00:00:00', '2020-01-01 00:00:00', '00:00:00', 2020, 'blob', 'text', 1.1, 2.2, 3.3, 1 );
insert into zct1 values(2, ' ', '2020-01-02', '2020-01-02 00:00:00', '2020-01-02 00:00:00', '00:00:01', 2021, 'Blob', 'Text', 2.1, 3.2, 4.3, 2 );
insert into zct1 values(3, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL );
insert into zct1 values(4, '', '2020-01-04', '2020-01-04 00:00:00', '2020-01-04 00:00:00', '00:00:03', 2023, 'bloB', 'TexT', 4.1, 5.2, 6.3, 4 );
insert into zct1 values(5, '!@#$%^&*()', '2020-01-05', '2020-01-05 00:00:00', '2020-01-05 00:00:00', '00:00:04', 2024, 'BLOB', 'TEXT', 5.1, 6.2, 7.3, 5 );

alter table zct1 add index idx_zct1(a,b);

##10##
insert into zct1 select * from zct1;
##20##
insert into zct1 select * from zct1;
##40##
insert into zct1 select * from zct1;
##80##
insert into zct1 select * from zct1;
##160##
insert into zct1 select * from zct1;

##导出3个文件，一个文件1547，目前meta data不参与max file计算
let $FILE_NAME = tmp_parquet;
--source mysql_test/include/select_into_outfile/delete_files.inc
select /*+parallel(3)*/ a,b,c,d,f from zct1 t into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = false MAX_FILE_SIZE = '10B' BUFFER_SIZE = '1MB';
--source mysql_test/include/select_into_outfile/list_dir.inc

--error 0,1051
drop table ex_par;
create external table ex_par(
c1 INT as (get_path(external$filerow, 'a')),
c2 varchar(50) as (get_path(external$filerow, 'b')),
c3 date as (get_path(external$filerow, 'c')),
c4 datetime as (get_path(external$filerow, 'd')),
c6 time as (get_path(external$filerow, 'f'))
)
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_parquet';
select substr(file_url,instr(file_url,'%')+1) from oceanbase.__all_external_table_file,oceanbase.__all_table
where delete_version=9223372036854775807 and __all_table.table_id = __all_external_table_file.table_id
and __all_table.table_name='ex_par';

SELECT count(*) FROM ex_par;
SELECT * FROM ex_par limit 10;

##parallel(1) true->单文件##
--source mysql_test/include/select_into_outfile/delete_files.inc
select /*+parallel(1)*/ a,b,c,d,f from zct1 t into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true MAX_FILE_SIZE = '10B' BUFFER_SIZE = '1MB';
--source mysql_test/include/select_into_outfile/list_dir.inc

alter external table ex_par refresh;
select substr(file_url,instr(file_url,'%')+1) from oceanbase.__all_external_table_file,oceanbase.__all_table
where delete_version=9223372036854775807 and __all_table.table_id = __all_external_table_file.table_id
and __all_table.table_name='ex_par';
SELECT count(*) FROM ex_par;

