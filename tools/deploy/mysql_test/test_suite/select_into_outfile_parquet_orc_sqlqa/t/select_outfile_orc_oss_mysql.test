####大数据分区导出不同压缩orc，并用外表分区读取####
drop table t1;
create table t1(a int,b char(10),c bigint,d varbinary(3000));
--error 0,4298
drop SEQUENCE s1;
CREATE SEQUENCE s1 START WITH 1  INCREMENT BY 1 ;
insert /*+ append enable_parallel_dml parallel(8) query_timeout(100000000)*/ into t1 select s1.nextval, 'oceanbase', random(), randstr(3000, random()) from table(generator(10000));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5) query_timeout(100000000000)*/ a,b,c,d from t1 into outfile 'oss://$DATA_FOLDER_NAME/tmp_orc?host=cn-heyuan-alipay-b.oss-alipay.aliyuncs.com&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY'
PARTITION BY concat('par_',a%10)
format(
type = 'orc'
COMPRESSION = 'UNCOMPRESSED'
COMPRESSION_BLOCK_SIZE = '256kB'
STRIPE_SIZE = '1mb'
ROW_INDEX_STRIDE = 10
) single = FALSE MAX_FILE_SIZE = '256MB';

--error 0,1051
drop table ex_par;
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval create external table ex_par(
c0 INT as (get_path(external\$filerow, 'a')) COMMENT '账号',
c1 char(10) as (get_path(external\$filerow, 'b')),
c2 bigint as (get_path(external\$filerow, 'c')),
c3 varbinary(3000) as (get_path(external\$filerow, 'd')),
PAR VARCHAR(50) AS(SUBSTR(SUBSTR(metadata\$fileurl,instr(metadata\$fileurl, '%') + 1),1,6))
)
format (type = 'orc') location 'oss://$OSS_ACCESS_ID:$OSS_ACCESS_KEY@cn-heyuan-alipay-b.oss-alipay.aliyuncs.com/$DATA_FOLDER_NAME/'
PATTERN = "tmp_orc" PARTITION BY(PAR);

alter external table ex_par refresh;
SELECT /*+parallel(5) query_timeout(1000000000000)*/count(*) FROM ex_par;

