####format
##COMPRESSION("UNCOMPRESSED", "SNAPPY", "ZLIB"，"LZO"，"LZ4"，"ZSTD")
let $FILE_NAME = tmp_orc;
--source mysql_test/include/select_into_outfile/delete_files.inc
select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true;

select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc.snappy'
format(
type = 'orc'
COMPRESSION = 'SNAPPY'
) single = true;

select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc.zlib'
format(
type = 'orc'
COMPRESSION = 'ZLIB'
ROW_GROUP_SIZE = '1MB'
) single = true;

##报4016,已修复
#--error 4016
select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc.lz4'
format(
type = 'orc'
COMPRESSION = 'LZ4'
) single = true;

select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc.zstd'
format(
type = 'orc'
COMPRESSION = 'ZSTD'
ROW_GROUP_SIZE = '1MB'
) single = true;
##lz0 not support
--error 1235
select c1,c2,c3,c4,c5,c6,c7,c8,c18,c19,c20,c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34,c35,c36 from zct2 into outfile 'outfile_data_orc/tmp_orc.lz0'
format(
type = 'orc'
COMPRESSION = 'LZO'
ROW_GROUP_SIZE = '1MB'
) single = true;

##external table read compressed orc
--error 0,1051
drop table ex_par;
create external table ex_par(
c1 TINYINT as (get_path(external$filerow, 'c1')),
c2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 MEDIUMINT as (get_path(external$filerow, 'c3')),
c4 int as (get_path(external$filerow, 'c4')),
c5 BIGINT as (get_path(external$filerow, 'c5')),
c6 DECIMAL(5,2) as (get_path(external$filerow, 'c6')),
c7 float(5,2) as (get_path(external$filerow, 'c7')),
c8 double(5,2) as (get_path(external$filerow, 'c8')),
c9 datetime as (get_path(external$filerow, 'c18')),
c10 timestamp as (get_path(external$filerow, 'c19')),
c11 date as (get_path(external$filerow, 'c20')),
c12 char as (get_path(external$filerow, 'c23')),
c13 varchar(50) as (get_path(external$filerow, 'c24')),
c14 binary as (get_path(external$filerow, 'c25')),
c15 varbinary(50) as (get_path(external$filerow, 'c26')),
c16 varbinary(50) as (get_path(external$filerow, 'c27')),
c17 varbinary(50) as (get_path(external$filerow, 'c28')),
c18 varbinary(50) as (get_path(external$filerow, 'c29')),
c19 varbinary(50) as (get_path(external$filerow, 'c30')),
c20 varbinary(50) as (get_path(external$filerow, 'c31')),
c21 varbinary(50) as (get_path(external$filerow, 'c32')),
c22 varbinary(50) as (get_path(external$filerow, 'c33')),
c23 varbinary(50) as (get_path(external$filerow, 'c34')),
c24 ENUM('','a','1','中') as (get_path(external$filerow, 'c35')),
c25 set('a', '1','','中') as (get_path(external$filerow, 'c36'))
)
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc$';

select count(*) from ex_par;
