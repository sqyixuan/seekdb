##subquery
select /*+parallel(3)*/ (select /*+parallel(3)*/
 (select a from zct1 where a = 1)
 from zct1 where a = 1) from zct1 t into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
COMPRESSION = 'UNCOMPRESSED'
ROW_GROUP_SIZE = '1MB'
) single = true;
drop table ex_par;
create external table ex_par(
c1 bigint as (get_path(external$filerow,
'(select /*+parallel(3)*/\n (select a from zct1 where a = 1)\n from zct1 where a = 1)'))
)
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_parquet$';
