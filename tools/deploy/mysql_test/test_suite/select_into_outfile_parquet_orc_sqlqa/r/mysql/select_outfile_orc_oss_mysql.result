drop table ex_par;
create external table ex_par(
c1 TINYINT as (get_path(external$filerow, 'c1')),
c2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 MEDIUMINT as (get_path(external$filerow, 'c3')),
c4 int as (get_path(external$filerow, 'c4')),
c5 BIGINT as (get_path(external$filerow, 'c5')),
c6 DECIMAL(10,2) as (get_path(external$filerow, 'c6')),
c7 float(5,2) as (get_path(external$filerow, 'c7')),
c8 double(5,2) as (get_path(external$filerow, 'c8')),
c9 datetime as (get_path(external$filerow, 'c18')),
c10 timestamp as (get_path(external$filerow, 'c19')),
c11 date as (get_path(external$filerow, 'c20')),
c12 char as (get_path(external$filerow, 'c23')),
c13 varchar(50) as (get_path(external$filerow, 'c24')),
c14 binary as (get_path(external$filerow, 'c25')),
c15 varbinary(50) as (get_path(external$filerow, 'c26')),
c16 varbinary(50) as (get_path(external$filerow, 'c27')),
c17 varbinary(50) as (get_path(external$filerow, 'c28')),
c18 varbinary(50) as (get_path(external$filerow, 'c29')),
c19 varbinary(50) as (get_path(external$filerow, 'c30')),
c20 varbinary(50) as (get_path(external$filerow, 'c31')),
c21 varbinary(50) as (get_path(external$filerow, 'c32')),
c22 varbinary(50) as (get_path(external$filerow, 'c33')),
c23 varbinary(50) as (get_path(external$filerow, 'c34')),
c24 ENUM('','a','1','中') as (get_path(external$filerow, 'c35')),
c25 set('a', '1','','中') as (get_path(external$filerow, 'c36')))
format(type = 'orc') location '#DATA_FOLDER_NAME#/?#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#' pattern = 'tmp_orc';
