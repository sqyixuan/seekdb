PURGE RECYCLEBIN;
####oss场景，分区导出场景####
drop table t1;
CREATE table t1(c1 int,c2 varchar(50),c3 DATE);
INSERT INTO t1 VALUES(1,'a','0001-01-01');
INSERT INTO t1 VALUES(2,'b','0002-02-02');
INSERT INTO t1 VALUES(3,'c','0003-03-03');
