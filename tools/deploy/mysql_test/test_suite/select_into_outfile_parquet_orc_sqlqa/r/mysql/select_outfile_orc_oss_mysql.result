select /*+parallel(3)*/ * from t1 into outfile '#DATA_FOLDER_NAME#/?#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#'
format(
type = 'orc'
) single = true;
drop table ex_par;
create external table ex_par(c1 int ,c2 varchar(50),c3 date)
format(type = 'orc') location '#DATA_FOLDER_NAME#/?#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#' pattern = 'tmp_orc';
