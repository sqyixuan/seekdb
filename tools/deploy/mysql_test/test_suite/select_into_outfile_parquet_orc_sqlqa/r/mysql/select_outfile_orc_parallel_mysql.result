drop table ex_par;
create external table ex_par(
c1 INT as (get_path(external$filerow, 'a')),
c2 varchar(50) as (get_path(external$filerow, 'b')),
c3 date as (get_path(external$filerow, 'c')),
c4 datetime as (get_path(external$filerow, 'd')),
c6 varbinary(50) as (get_path(external$filerow, 'f')),
c7 smallint as (get_path(external$filerow, 'g')),
c8 varchar(50) as (get_path(external$filerow, 'h')),
c9 varchar(50) as (get_path(external$filerow, 'i'))
)
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc_0_4_0';
