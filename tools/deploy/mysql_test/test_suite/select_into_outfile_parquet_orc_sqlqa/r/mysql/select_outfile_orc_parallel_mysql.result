##parallel(2) false 2行数据->两个1行数据的文件##
drop table zct2;
create table zct2(a int , B varchar(50), c date, D datetime, e timestamp, F varbinary(50), g smallint, H blob(10), i text, J float, k double, L decimal(10, 2), m bigint);
insert into zct2 values(1, '一', '2020-01-01', '2020-01-01 00:00:00', '2020-01-01 00:00:00', '00:00:00', 2020, 'blob', 'text', 1.1, 2.2, 3.3, 1 );
insert into zct2 values(2, ' ', '2020-01-02', '2020-01-02 00:00:00', '2020-01-02 00:00:00', '00:00:01', 2021, 'Blob', 'Text', 2.1, 3.2, 4.3, 2 );
select /*+parallel(2)*/ a,b,c,d,f from zct2 t  into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
COMPRESSION = 'UNCOMPRESSED'
COMPRESSION_BLOCK_SIZE = '5kb'
STRIPE_SIZE = '1B'
ROW_INDEX_STRIDE = 10
) single = false MAX_FILE_SIZE = '256B' BUFFER_SIZE = '1MB';
alter external table ex_par refresh;
SELECT * FROM ex_par;
