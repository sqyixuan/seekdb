select c37 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
ERROR 0A000: unsupported column type in orc file not supported
select c38 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
