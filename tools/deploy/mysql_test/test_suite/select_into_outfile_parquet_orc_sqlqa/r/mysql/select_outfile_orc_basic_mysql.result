##数值类型
#############################################################
#### TINYINT>tinyint                                     ####
#### SMALLINT>smallint                                   ####
#### MEDIUMINT>int                                       ####
#### int>int                                             ####
#### BIGINT>bigint                                       ####
#### DECIMAL(5,2)>decimal(5,2)                           ####
#### float>float                                         ####
#### double>double                                       ####
#### bit>not supported                                   ####
#############################################################
select c1,c2,c3,c4,c5,c6,c7,c8 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
drop table ex_par;
create external table ex_par(c1 TINYINT as (get_path(external$filerow, 'c1')),c2 SMALLINT as (get_path(external$filerow, 'c2')),c3 MEDIUMINT as (get_path(external$filerow, 'c3')),c4 int as (get_path(external$filerow, 'c4')),c5 BIGINT as (get_path(external$filerow, 'c5')),c7 float(5,2) as (get_path(external$filerow, 'c7')),c8 double(5,2) as (get_path(external$filerow, 'c8')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+------+--------+----------+-------------+----------------------+---------+---------+
| c1   | c2     | c3       | c4          | c5                   | c7      | c8      |
+------+--------+----------+-------------+----------------------+---------+---------+
|    1 |  32767 |  8388607 |  2147483647 |  9223372036854775807 |  123.45 |  123.45 |
|   -1 | -32768 | -8388608 | -2147483648 | -9223372036854775808 | -123.45 | -123.45 |
|    0 |      0 |        0 |           0 |                    0 |    0.00 |    0.00 |
| NULL |   NULL |     NULL |        NULL |                 NULL |    NULL |    NULL |
+------+--------+----------+-------------+----------------------+---------+---------+
##decimal类型报超范围，已修复
drop table ex_par;
create external table ex_par(c6 decimal(5,2) as (get_path(external$filerow, 'c6')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+---------+
| c6      |
+---------+
|  123.45 |
| -123.45 |
|    0.00 |
|    NULL |
+---------+
##不支持bit类型，报错4016，已修复
select c9 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
ERROR 0A000: unsupported column type in orc file not supported
drop table ex_par;
create external table ex_par(c9 bit(64) as (get_path(external$filerow, 'c9')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+------+
| c9   |
+------+
+------+
##UNSIGNED
##orc无法导出带unsigned属性的字段
##double,float报4016，已修复
select c10,c11,c12,c13,c14,c16,c17 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
ERROR 0A000: unsupported column type in orc file not supported
##UNSIGNED decimal有问题不报错，已修复
select c15 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
##日期类型
##################################################
#### datetime>timestamp                       ####
#### timestamp>timestamp with local time zone ####
#### date>date                                ####
#### time>4016                                ####
#### year>int                                 ####
##################################################
##不支持time
select c21 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
ERROR 0A000: unsupported column type in orc file not supported
select c18,c19,c20,c22 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
##year类型导出是int型，orc外表无法用year类型读回去,已修复
drop table ex_par;
create external table ex_par(c18 datetime,c19 timestamp,c20 date,c22 year)
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+---------------------+---------------------+------------+------+
| c18                 | c19                 | c20        | c22  |
+---------------------+---------------------+------------+------+
| 2021-10-29 12:00:00 | 2021-10-29 12:00:00 | 2021-10-29 | 2021 |
| 2021-10-29 12:00:00 | 2021-10-29 12:00:00 | 2021-10-29 | 2021 |
| 1970-01-01 00:00:00 | 1970-01-01 00:00:00 | 1970-01-01 | 1970 |
| NULL                | NULL                | NULL       | NULL |
+---------------------+---------------------+------------+------+
##字符类型
#######################################
#### char>char(1)                  ####
#### varchar(50)>varchar(50)       ####
#### binary>binary                 ####
#### varbinary(50)>binary          ####
#### TINYBLOB>binary               ####
#### BLOB>binary                   ####
#### MEDIUMBLOB>binary             ####
#### LONGBLOB>binary               ####
#### TINYTEXT>string               ####
#### TEXT>string                   ####
#### MEDIUMTEXT>string             ####
#### LONGTEXT>string               ####
#######################################
select c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
##orc外表不支持blob，text类型，可以用其他字符类型读回去
drop table ex_par;
create external table ex_par(
c23 char as (get_path(external$filerow, 'c23')),
c24 varchar(50) as (get_path(external$filerow, 'c24')),
c25 binary as (get_path(external$filerow, 'c25')),
c26 varbinary(50) as (get_path(external$filerow, 'c26')),
c27 varbinary(50) as (get_path(external$filerow, 'c27')),
c28 varbinary(50) as (get_path(external$filerow, 'c28')),
c29 varbinary(50) as (get_path(external$filerow, 'c29')),
c30 varbinary(50) as (get_path(external$filerow, 'c30')),
c31 varchar(50) as (get_path(external$filerow, 'c31')),
c32 char(50) as (get_path(external$filerow, 'c32')),
c33 varbinary(50) as (get_path(external$filerow, 'c33')),
c34 varbinary(50) as (get_path(external$filerow, 'c34')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
| c23  | c24     | c25  | c26  | c27      | c28  | c29        | c30      | c31      | c32  | c33        | c34      |
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
| a    | varchar | i    | i    | tinyblob | blob | mediumblob | longblob | tinytext | text | mediumtext | longtext |
| a    | varchar | i    | i    | tinyblob | blob | mediumblob | longblob | tinytext | text | mediumtext | longtext |
|      |         |      |      |          |      |            |          |          |      |            |          |
| NULL | NULL    | NULL | NULL | NULL     | NULL | NULL       | NULL     | NULL     | NULL | NULL       | NULL     |
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
##其他类型
##############################
#### ENUM>varchar(1)(可变) ####
#### SET>varchar(9)(可变)  ####
#### JSON>NOT SUPPORT     ####
#### GEOMETRY>NOT SUPPORT ####
##############################
select c35 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
drop table ex_par;
create external table ex_par(
c35 ENUM('','a','1','中') CHARACTER SET utf16 as (get_path(external$filerow, 'c35')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+------+
| c35  |
+------+
| a    |
| a    |
|      |
| NULL |
+------+
select c36 from zct2 into outfile 'outfile_data_orc/tmp_orc'
format(
type = 'orc'
) single = true;
drop table ex_par;
create external table ex_par(
c36 set('a', '1','','中') CHARACTER SET utf16 as (get_path(external$filerow, 'c36')))
format(type = 'orc') location 'outfile_data_orc/' pattern = 'tmp_orc';
select * from ex_par;
+------+
| c36  |
+------+
| a    |
| a    |
|      |
| NULL |
+------+
