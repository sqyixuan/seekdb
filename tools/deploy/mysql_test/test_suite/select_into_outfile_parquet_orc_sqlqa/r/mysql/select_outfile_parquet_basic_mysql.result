##字符类型
##########################
#### 导出类型都为       ####
#### binary (STRING)  ####
##########################
select c23,c24,c25,c26,c27,c28,c29,c30,c31,c32,c33,c34 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
) single = true;
##433报4016，测试包会core，ob字符类型导出parquet都是binary (STRING)类型，ob外表没法读只能用char,varchar，binary,varbinary，TINYBLOB，TINYTEXT读回去
##已修复
drop table ex_par;
create external table ex_par(c23 char,c24 varchar(50),c25 binary,c26 varbinary(50),c27 TINYBLOB,c28 BLOB,c29 MEDIUMBLOB,c30 LONGBLOB,c31 TINYTEXT,c32 TEXT,c33 MEDIUMTEXT,c34 LONGTEXT)
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_par';
select * from ex_par;
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
| c23  | c24     | c25  | c26  | c27      | c28  | c29        | c30      | c31      | c32  | c33        | c34      |
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
| a    | varchar | i    | i    | tinyblob | blob | mediumblob | longblob | tinytext | text | mediumtext | longtext |
| a    | varchar | i    | i    | tinyblob | blob | mediumblob | longblob | tinytext | text | mediumtext | longtext |
|      |         |      |      |          |      |            |          |          |      |            |          |
| NULL | NULL    | NULL | NULL | NULL     | NULL | NULL       | NULL     | NULL     | NULL | NULL       | NULL     |
+------+---------+------+------+----------+------+------------+----------+----------+------+------------+----------+
##其他类型
##############################
#### ENUM>binary (STRING) ####
#### SET>binary (STRING)  ####
#### JSON>NOT SUPPORT     ####
#### GEOMETRY>NOT SUPPORT ####
##############################
##ENUM,set类型报4013，但会生成文件，已修复
select c35,c36 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
) single = true;
drop table ex_par;
##导出的parquet为string类型，无法用外表的enum和set读回去,已修复
create external table ex_par(c35 ENUM('','a','1','中') CHARACTER SET utf16 as (get_path(external$filerow, 'c35')),c36 set('a', '1','','中') CHARACTER SET utf16 as (get_path(external$filerow, 'c36')))
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_parquet$';
##报4016，已修复
select * from ex_par;
+------+------+
| c35  | c36  |
+------+------+
| a    | a    |
| a    | a    |
|      |      |
| NULL | NULL |
+------+------+
##json,gis不支持，不会生成文件
select c37 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
) single = true;
