| c15  |
+------+
|  123 |
|  123 |
|    0 |
| NULL |
+------+
##日期类型
##################################################
#### datetime>int64 (TIMESTAMP(MICROS,false)) ####
#### timestamp>int64 (TIMESTAMP(MICROS,true)) ####
#### date>int32 (DATE)                        ####
#### time>int64 (TIME(MICROS,false))          ####
#### year>int32 (INTEGER(8,false))            ####
##################################################
select c18,c19,c20,c21,c22 from zct2 into outfile 'outfile_data_parquet/tmp_parquet'
format(
type = 'parquet'
) single = true;
drop table ex_par;
create external table ex_par(c18 timestamp,c19 timestamp,c20 date,c21 time,c22 year)
format(type = 'parquet') location 'outfile_data_parquet/' pattern = 'tmp_par';
##year类型数据处理的有问题,已修复
select * from ex_par;
+---------------------+---------------------+------------+----------+------+
| c18                 | c19                 | c20        | c21      | c22  |
+---------------------+---------------------+------------+----------+------+
| 2021-10-29 12:00:00 | 2021-10-29 12:00:00 | 2021-10-29 | 12:00:00 | 2021 |
| 2021-10-29 12:00:00 | 2021-10-29 12:00:00 | 2021-10-29 | 12:00:00 | 2021 |
| 1970-01-01 00:00:00 | 1970-01-01 00:00:00 | 1970-01-01 | 00:00:00 | 1970 |
| NULL                | NULL                | NULL       | NULL     | NULL |
