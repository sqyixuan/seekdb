# owner: linyi.cl
# owner group: SQL3
# tags: external_table
# description: test external catalog ddls

--disable_warnings
drop catalog if exists ca1;
drop catalog if exists ca2;
drop catalog if exists ca3;
drop catalog if exists cafe;
--enable_warnings

create external catalog ca1 properties (type='odps' project_name='test');
create external catalog if not exists ca1 properties (type='odps' project_name='test');
create external catalog CA2 properties (type='odps' project_name='test');
# ignore case
--error 11079
create external catalog ca2 properties (type='odps' project_name='test');

create external catalog cafe properties (type='odps' project_name='test');
--error 11079
create external catalog café properties (type='odps' project_name='test');

show catalogs;

# show create
show create catalog ca1;
show create catalog CA1;
show create catalog ca2;
show create catalog café;

drop catalog café;
show catalogs;

drop catalog if exists ca3;
--error 11080
drop catalog ca3;
# ignore case
drop catalog CA1;

show catalogs;

--error 11080
set catalog ca1;

set catalog cA2;
select current_catalog();

# drop default catalog
drop catalog ca2;

select current_catalog();
show catalogs;

set catalog internal;
select current_catalog();

--error 11082
drop catalog internal;
--error 11082
create external catalog internal properties=(type='odps');

show create catalog internal;
