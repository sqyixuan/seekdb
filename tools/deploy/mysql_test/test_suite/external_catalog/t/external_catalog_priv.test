# owner: linyi.cl
# owner group: SQL3
# tags: external_table
# description: test external catalog priv

--disable_warnings
drop user if exists linyi;
--enable_warnings

--disable_warnings
drop catalog if exists ca1;
drop catalog if exists ca2;
drop catalog if exists ca3;
drop catalog if exists cafe;
--enable_warnings

create user linyi;
show grants for 'linyi'@'%';

connect(conn_linyi1, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi1;
--error 1227
create external catalog ca1 properties=(type='odps');


--echo ## user level
--echo ## create catalog or drop catalog need 'create catalog' priv
connection default;
grant create catalog on *.* to 'linyi'@'%';
show grants for 'linyi'@'%';

connect(conn_linyi2, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi2;
create external catalog ca1 properties=(type='odps');
--echo ## catalog creator has 'use catalog' priv
show grants;
show catalogs;
set catalog ca1;
show create catalog ca1;

connection default;
revoke create catalog on *.* from 'linyi'@'%';
--echo ## although create_catalog has been revoked，but use_catalog still exists
show grants for 'linyi'@'%';

connect(conn_linyi3, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi3;
--error 1227
drop catalog ca1;
show catalogs;
set catalog ca1;
show create catalog ca1;

connection default;
grant create catalog on *.* to 'linyi'@'%';
show grants for 'linyi'@'%';

connect(conn_linyi4, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi4;
drop catalog ca1;

--echo ## access catalog need 'use catalog' priv
connection default;
grant use catalog on *.* to 'linyi'@'%';
show grants for 'linyi'@'%';
create external catalog CA2 properties=(type='odps');
create external catalog café properties=(type='odps');

connect(conn_linyi5, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi5;
show catalogs;
set catalog ca2;
show create catalog cafe;

connection default;
revoke use catalog on *.* from 'linyi'@'%';
show grants for 'linyi'@'%';

connect(conn_linyi6, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi6;
show catalogs;
--error 11083
set catalog ca2;
--error 11083
show create catalog cafe;


--echo ## catalog level
--echo ## access catalog need 'use catalog' priv

connection default;
grant use catalog on catalog ca2 to 'linyi'@'%';
show grants for 'linyi'@'%';
connect(conn_linyi7, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi7;
show catalogs;
set catalog ca2;
show create catalog ca2;
--error 11083
set catalog caFE;

connection default;
revoke use catalog on catalog ca2 from 'linyi'@'%';
show grants for 'linyi'@'%';
connect(conn_linyi8, $OBMYSQL_MS0, linyi, '', *NO-ONE*, $OBMYSQL_PORT);
connection conn_linyi8;
show catalogs;
--error 11083
set catalog ca2;

connection default;
--result_format 4
desc oceanbase.__all_catalog;
desc oceanbase.__all_catalog_history;
desc oceanbase.__all_catalog_privilege;
desc oceanbase.__all_catalog_privilege_history;
select catalog_name from oceanbase.__all_catalog where catalog_name = 'ca1' or catalog_name = 'ca2' or catalog_name = 'cafe';
show grants for 'linyi'@'%';

--enable_sorted_result
select user.user_name, priv.catalog_name, priv.priv_set from oceanbase.__all_catalog_privilege as priv, oceanbase.__all_user as user
    where user.user_id = priv.user_id and user.user_name = 'linyi';

select user_name, PRIV_CREATE_CATALOG, PRIV_USE_CATALOG from oceanbase.DBA_OB_USERS where user_name = 'linyi';
select * from information_schema.USER_PRIVILEGES where grantee like '%linyi%';
select OBJECT_NAME,SUBOBJECT_NAME,DATA_OBJECT_ID,OBJECT_TYPE,STATUS,TEMPORARY,SECONDARY,NAMESPACE,EDITION_NAME
    from oceanbase.dba_objects, oceanbase.__all_catalog where object_name = catalog_name and object_id = catalog_id;

connect (sys,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);
select user_name, PRIV_CREATE_CATALOG, PRIV_USE_CATALOG from oceanbase.CDB_OB_USERS where user_name = 'linyi' and tenant_id=1004;
desc oceanbase.__all_virtual_catalog;
desc oceanbase.__all_virtual_catalog_history;
desc oceanbase.__all_virtual_catalog_privilege;
desc oceanbase.__all_virtual_catalog_privilege_history;
select catalog_name from oceanbase.__all_virtual_catalog where catalog_name = 'ca1' or catalog_name = 'ca2' or catalog_name = 'cafe';
select user.user_name, priv.catalog_name, priv.priv_set from oceanbase.__all_virtual_catalog_privilege as priv, oceanbase.__all_virtual_user as user
    where user.user_id = priv.user_id and user.user_name = 'linyi';
select OBJECT_NAME,SUBOBJECT_NAME,DATA_OBJECT_ID,OBJECT_TYPE,STATUS,TEMPORARY,SECONDARY,NAMESPACE,EDITION_NAME
    from oceanbase.cdb_objects, oceanbase.__all_virtual_catalog where object_name = catalog_name and object_id = catalog_id;

connection default;
drop catalog ca2;
drop catalog cafe;
show catalogs;

drop user linyi;

select user.user_name, priv.catalog_name, priv.priv_set from oceanbase.__all_catalog_privilege as priv, oceanbase.__all_user as user
    where user.user_id = priv.user_id and user.user_name = 'linyi';
--disable_sorted_result
