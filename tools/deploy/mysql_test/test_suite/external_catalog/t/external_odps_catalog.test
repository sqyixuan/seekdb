# owner: chendingchao.cdc
# owner group: SQL3
# tags: external_catalog, odps
# description: test odps catalog function
--result_format 4

--source mysql_test/include/odps_config_for_cloud.inc

--disable_warnings
drop catalog if exists odps_catalog;
drop catalog if exists odps_wrong_catalog;
drop database if exists internal_catalog_db;
--enable_warnings

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval create external catalog odps_catalog properties (
  TYPE = 'ODPS',
  ACCESSID = '$ODPS_ACCESSID',
  ACCESSKEY = '$ODPS_ACCESSKEY',
  ENDPOINT = '$ODPS_ENDPOINT',
  PROJECT_NAME = 'mysqltest_regression_sqlqa'
);

############# test in wrong catalog #############
create external catalog odps_wrong_catalog properties (
  TYPE = 'ODPS',
  ACCESSID = 'xxxx',
  ACCESSKEY = 'yyyy',
  ENDPOINT = 'yyyy',
  PROJECT_NAME = 'mysqltest_regression_sqlqa'
);
set catalog odps_wrong_catalog;
show databases;
--error 11050
show tables from `default`;

############# test for select sql #############
set catalog odps_catalog;
show databases;
show tables from `default` like 'chendingchao_catalog_partition_test';
use `default`;
select * from `default`.chendingchao_catalog_partition_test order by 1;

prepare stmt from "select * from chendingchao_catalog_partition_test order by 1;";
execute stmt;

--error 1146
select * from `default`.chendingchao_never_existed_table order by 1;
set catalog internal;
select * from `odps_catalog`.`default`.`chendingchao_catalog_partition_test`;

############# test for CTAS #############
use test;
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
create table t1 as select * from odps_catalog.default.chendingchao_catalog_partition_test;
select * from t1;
create view v1 as select * from odps_catalog.default.chendingchao_catalog_partition_test;
select * from v1;
drop table t1;
drop view v1;

############# test for insert sql #############
set catalog internal;
create database internal_catalog_db;
use internal_catalog_db;
create table import_tbl (c1 string, c2 int, c3 double, year string, month int);
insert into import_tbl select * from odps_catalog.default.chendingchao_catalog_partition_test;
select * from import_tbl order by 1;

############# test for show sql #############
set catalog odps_catalog;
desc `default`.chendingchao_catalog_partition_test;
show create table `default`.chendingchao_catalog_partition_test;
set catalog internal;
desc odps_catalog.default.chendingchao_catalog_partition_test;
show create table odps_catalog.default.chendingchao_catalog_partition_test;

############# test for use sql #############
use `internal`.`internal_catalog_db`;
select database();
use `odps_catalog`.`default`;
select database();

############# test for forbidden sql #############
set catalog odps_catalog;

# test for database ddl
--error 1235
create database dummy;
--error 1235
alter database `default` character set utf8mb4;
--error 1235
drop database `default`;

# test for table dml
use `default`;
--error 1235
drop table `default`.chendingchao_catalog_dummy_test;
--error 1235
insert into `default`.chendingchao_catalog_dummy_test values ("ni"), ("hao");
--error 1235
replace into chendingchao_catalog_dummy_test values ("1");
--error 1235
delete from chendingchao_catalog_dummy_test where a=1;
--error 1235
update chendingchao_catalog_dummy_test set a = 1 where a = 1;
--error 1235
alter table chendingchao_catalog_dummy_test add column email string;
--error 1235
truncate table chendingchao_catalog_dummy_test;

use `internal`.`internal_catalog_db`;
--error 1235
load data from (select * from source(TYPE = 'ODPS')) into table odps_catalog.default.chendingchao_catalog_dummy_test;
--error 1235
analyze table odps_catalog.default.chendingchao_catalog_dummy_test;
--error 1235
drop SEQUENCE if exists odps_catalog.default.chendingchao_catalog_dummy_test;
--error 1235
CREATE SEQUENCE odps_catalog.default.chendingchao_catalog_dummy_test START WITH 1 MINVALUE 1 MAXVALUE 10 INCREMENT BY 2 NOCYCLE NOORDER CACHE 30;
--error 1235
DROP OUTLINE odps_catalog.default.chendingchao_catalog_dummy_test;
--error 1235
show create function odps_catalog.default.p1;
--error 1235
show create procedure odps_catalog.default.p1;
--error 1235
show create function odps_catalog.default.code;
--error 1235
show create procedure odps_catalog.default.code;
--error 1235
show create trigger odps_catalog.default.t1;
--error 1235
show FUNCTION CODE odps_catalog.default.p1;
--error 1235
show procedure CODE odps_catalog.default.p1;
drop catalog odps_catalog;
drop catalog odps_wrong_catalog;