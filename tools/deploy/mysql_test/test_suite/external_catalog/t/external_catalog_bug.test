# owner: linyi.cl
# owner group: SQL3
# tags: external_table
--result_format 4

# bug: 2025040900108116245

--disable_warnings
drop catalog if exists odps_catalog;
drop table if exists t1;
drop view if exists v1, v2, v3;
--enable_warnings

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval create external catalog odps_catalog properties (
  TYPE = 'ODPS',
  ACCESSID = '$ODPS_ACCESSID',
  ACCESSKEY = '$ODPS_ACCESSKEY',
  ENDPOINT = '$ODPS_ENDPOINT',
  PROJECT_NAME = 'mysqltest_regression_sqlqa'
);

create table t1(c1 int);
insert into t1 values(1);
use odps_catalog.default;
set @a=(select count(*) from internal.test.t1);
select @a;

ANALYZE TABLE internal.test.t1 UPDATE HISTOGRAM ON c1 with 30 buckets;

create view internal.test.v1 as select t1.c1,year,month from internal.test.t1, chendingchao_catalog_partition_test;
show create view internal.test.v1;
select * from internal.test.v1;
create view internal.test.v2 as select * from internal.test.v1;
show create view internal.test.v2;

use internal.test;
create view v3 as select t1.c1,year,month from t1, odps_catalog.default.chendingchao_catalog_partition_test;
select * from v1;
select * from v2;
select * from v3;
use odps_catalog.default;
select * from internal.test.v3;

use internal.test;
drop catalog odps_catalog;
drop table t1;
drop view v1, v2;
