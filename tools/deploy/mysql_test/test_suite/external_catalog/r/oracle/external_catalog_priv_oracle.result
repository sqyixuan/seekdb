drop catalog ca1;
drop catalog ca2;
drop user linyi cascade;
create user linyi IDENTIFIED BY abc;
grant create session to linyi;
drop user linyi1 cascade;
create user linyi1 IDENTIFIED BY abc;
grant create session to linyi1;
result_format: 4
create external catalog ca1 properties(type='odps');
ERROR HY000: insufficient privileges

grant create catalog to linyi with admin option;
select * from sys.dba_sys_privs where GRANTEE='LINYI';
+---------+----------------+--------------+
| GRANTEE | PRIVILEGE      | ADMIN_OPTION |
+---------+----------------+--------------+
| LINYI   | CREATE SESSION | NO           |
| LINYI   | CREATE CATALOG | YES          |
+---------+----------------+--------------+

create external catalog ca1 properties(type='odps');
select * from sys.user_tab_privs;
+---------+-------+------------+---------+-------------+-----------+-----------+
| GRANTEE | OWNER | TABLE_NAME | GRANTOR | PRIVILEGE   | GRANTABLE | HIERARCHY |
+---------+-------+------------+---------+-------------+-----------+-----------+
| LINYI   | SYS   | CA1        | SYS     | USE CATALOG | NO        | NO        |
+---------+-------+------------+---------+-------------+-----------+-----------+
set catalog ca1;
select current_catalog() from dual;
+-------------------+
| CURRENT_CATALOG() |
+-------------------+
| CA1               |
+-------------------+
show catalogs;
Catalog
CA1
INTERNAL
show create catalog ca1;
Catalog	Create Catalog
CA1	CREATE EXTERNAL CATALOG "CA1"
PROPERTIES = (
  TYPE = 'ODPS',
  ACCESSTYPE = '',
  ACCESSID = '********',
  ACCESSKEY = '********',
  STSTOKEN = '********',
  ENDPOINT = '',
  TUNNEL_ENDPOINT = '',
  PROJECT_NAME = '',
  QUOTA_NAME = '',
  COMPRESSION_CODE = '',
  REGION = ''
) 
drop catalog ca1;
select * from sys.user_tab_privs;
+---------+-------+------------+---------+-----------+-----------+-----------+
| GRANTEE | OWNER | TABLE_NAME | GRANTOR | PRIVILEGE | GRANTABLE | HIERARCHY |
+---------+-------+------------+---------+-----------+-----------+-----------+
+---------+-------+------------+---------+-----------+-----------+-----------+
grant create catalog to linyi1;

select * from sys.user_sys_privs;
+----------+----------------+--------------+
| USERNAME | PRIVILEGE      | ADMIN_OPTION |
+----------+----------------+--------------+
| LINYI1   | CREATE SESSION | NO           |
| LINYI1   | CREATE CATALOG | NO           |
+----------+----------------+--------------+
create external catalog ca2 properties(type='odps');
show catalogs;
Catalog
CA2
INTERNAL

show catalogs;
Catalog
INTERNAL
grant use catalog on catalog ca2 to linyi;
show catalogs;
Catalog
CA2
INTERNAL

select * from sys.dba_sys_privs where GRANTEE='LINYI' or GRANTEE='LINYI1';
+---------+----------------+--------------+
| GRANTEE | PRIVILEGE      | ADMIN_OPTION |
+---------+----------------+--------------+
| LINYI   | CREATE SESSION | NO           |
| LINYI   | CREATE CATALOG | YES          |
| LINYI1  | CREATE SESSION | NO           |
| LINYI1  | CREATE CATALOG | NO           |
+---------+----------------+--------------+
select * from sys.dba_tab_privs where GRANTEE='LINYI' or GRANTEE='LINYI1';
+---------+-------+------------+---------+-------------+-----------+-----------+
| GRANTEE | OWNER | TABLE_NAME | GRANTOR | PRIVILEGE   | GRANTABLE | HIERARCHY |
+---------+-------+------------+---------+-------------+-----------+-----------+
| LINYI1  | SYS   | CA2        | SYS     | USE CATALOG | NO        | NO        |
| LINYI   | SYS   | CA2        | SYS     | USE CATALOG | NO        | NO        |
+---------+-------+------------+---------+-------------+-----------+-----------+
select object_name from sys.DBA_OBJECTS, sys.all_virtual_catalog_real_agent where catalog_id = object_id and catalog_name = object_name;
+-------------+
| OBJECT_NAME |
+-------------+
| CA2         |
+-------------+
select object_name from sys.ALL_OBJECTS, sys.all_virtual_catalog_real_agent where catalog_id = object_id and catalog_name = object_name;
+-------------+
| OBJECT_NAME |
+-------------+
| CA2         |
+-------------+
select object_name from sys.USER_OBJECTS, sys.all_virtual_catalog_real_agent where catalog_id = object_id and catalog_name = object_name;
+-------------+
| OBJECT_NAME |
+-------------+
| CA2         |
+-------------+
revoke create catalog from linyi;
revoke use catalog on catalog ca2 from linyi1;

select * from sys.dba_sys_privs where GRANTEE='LINYI' or GRANTEE='LINYI1';
