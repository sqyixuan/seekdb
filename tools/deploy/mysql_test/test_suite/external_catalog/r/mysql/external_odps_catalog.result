show create table `default`.chendingchao_catalog_partition_test;
Table	Create Table
chendingchao_catalog_partition_test	CREATE EXTERNAL TABLE `chendingchao_catalog_partition_test` (
  `c1` string CHARACTER SET utf8mb4 GENERATED ALWAYS AS (external$tablecol1),
  `c2` int GENERATED ALWAYS AS (external$tablecol2),
  `c3` double GENERATED ALWAYS AS (external$tablecol3),
  `year` string CHARACTER SET utf8mb4 GENERATED ALWAYS AS (metadata$partition_list_col1),
  `month` int GENERATED ALWAYS AS (metadata$partition_list_col2)
) 
AUTO_REFRESH = OFF
PROPERTIES (
  TYPE = 'ODPS',
  ACCESSTYPE = '',
  ACCESSID = '********',
  ACCESSKEY = '********',
  ENDPOINT = 'http://service.cn-hangzhou.maxcompute.aliyun.com/api',
  TUNNEL_ENDPOINT = '',
  PROJECT_NAME = 'mysqltest_regression_sqlqa',
  SCHEMA_NAME = 'DEFAULT',
  TABLE_NAME = 'chendingchao_catalog_partition_test',
  QUOTA_NAME = '',
  COMPRESSION_CODE = '',
  COLLECT_STATISTICS_ON_CREATE = FALSE,
  REGION = '',
  API_MODE = 'tunnel_api'
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin LOB_INROW_THRESHOLD=4096
 partition by (year,month)
