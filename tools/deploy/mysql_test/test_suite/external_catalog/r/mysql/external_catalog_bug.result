result_format: 4
drop catalog if exists odps_catalog;
drop table if exists t1;
drop view if exists v1, v2, v3;
create external catalog odps_catalog properties (
  TYPE = 'ODPS',
  ACCESSID='#ODPS_ACCESSID#',
  ACCESSKEY='#ODPS_ACCESSKEY#',
  ENDPOINT='#ODPS_ENDPOINT#',
  PROJECT_NAME = 'mysqltest_regression_sqlqa'
);

create table t1(c1 int);
insert into t1 values(1);
use odps_catalog.default;
set @a=(select count(*) from internal.test.t1);
select @a;
+------+
| @a   |
+------+
|    1 |
+------+

ANALYZE TABLE internal.test.t1 UPDATE HISTOGRAM ON c1 with 30 buckets;

create view internal.test.v1 as select t1.c1,year,month from internal.test.t1, chendingchao_catalog_partition_test;
show create view internal.test.v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `test`.`t1`.`c1` AS `c1`,`DEFAULT`.`chendingchao_catalog_partition_test`.`year` AS `year`,`DEFAULT`.`chendingchao_catalog_partition_test`.`month` AS `month` from `test`.`t1`,`odps_catalog`.`DEFAULT`.`chendingchao_catalog_partition_test`	utf8mb4	utf8mb4_general_ci
select * from internal.test.v1;
+------+------+-------+
| c1   | year | month |
+------+------+-------+
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
+------+------+-------+
create view internal.test.v2 as select * from internal.test.v1;
show create view internal.test.v2;
View	Create View	character_set_client	collation_connection
v2	CREATE VIEW `v2` AS select `test`.`v1`.`c1` AS `c1`,`test`.`v1`.`year` AS `year`,`test`.`v1`.`month` AS `month` from `test`.`v1`	utf8mb4	utf8mb4_general_ci

use internal.test;
create view v3 as select t1.c1,year,month from t1, odps_catalog.default.chendingchao_catalog_partition_test;
select * from v1;
+------+------+-------+
| c1   | year | month |
+------+------+-------+
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
+------+------+-------+
select * from v2;
+------+------+-------+
| c1   | year | month |
+------+------+-------+
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
+------+------+-------+
select * from v3;
+------+------+-------+
| c1   | year | month |
+------+------+-------+
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
+------+------+-------+
use odps_catalog.default;
select * from internal.test.v3;
+------+------+-------+
| c1   | year | month |
+------+------+-------+
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     1 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
|    1 | 2012 |     2 |
