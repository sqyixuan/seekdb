drop user if exists linyi;
drop catalog if exists ca1;
drop catalog if exists ca2;
drop catalog if exists ca3;
drop catalog if exists cafe;
create user linyi;
show grants for 'linyi'@'%';
Grants for linyi@%
GRANT USAGE ON *.* TO 'linyi'
create external catalog ca1 properties=(type='odps');
ERROR 42501: Access denied; you need (at least one of) the CREATE CATALOG privilege(s) for this operation
## user level
## create catalog or drop catalog need 'create catalog' priv
grant create catalog on *.* to 'linyi'@'%';
show grants for 'linyi'@'%';
Grants for linyi@%
GRANT CREATE CATALOG ON *.* TO 'linyi'
create external catalog ca1 properties=(type='odps');
## catalog creator has 'use catalog' priv
show grants;
Grants for linyi@%
GRANT CREATE CATALOG ON *.* TO 'linyi'
GRANT USE CATALOG ON CATALOG `ca1` TO 'linyi'
show catalogs;
Catalog
ca1
internal
set catalog ca1;
show create catalog ca1;
Catalog	Create Catalog
ca1	CREATE EXTERNAL CATALOG IF NOT EXISTS `ca1`
PROPERTIES = (
  TYPE = 'ODPS',
  ACCESSTYPE = '',
  ACCESSID = '********',
  ACCESSKEY = '********',
  STSTOKEN = '********',
  ENDPOINT = '',
  TUNNEL_ENDPOINT = '',
  PROJECT_NAME = '',
  QUOTA_NAME = '',
  COMPRESSION_CODE = '',
  REGION = ''
) 
revoke create catalog on *.* from 'linyi'@'%';
## although create_catalog has been revoked，but use_catalog still exists
show grants for 'linyi'@'%';
Grants for linyi@%
GRANT USAGE ON *.* TO 'linyi'
GRANT USE CATALOG ON CATALOG `ca1` TO 'linyi'
drop catalog ca1;
ERROR 42501: Access denied; you need (at least one of) the CREATE CATALOG privilege(s) for this operation
show catalogs;
