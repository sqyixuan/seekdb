============================================
drop table if exists t_fk_child_fork;
Warnings:
Note	1051	Unknown table 'db_fork_basic.t_fk_child_fork'
drop table if exists t_fk_child;
Warnings:
Note	1051	Unknown table 'db_fork_basic.t_fk_child'
