15. 视图不支持Fork测试
============================================
drop table if exists t_view_base;
Warnings:
Note	1051	Unknown table 'db_fork_basic.t_view_base'
drop view if exists v_test;
Warnings:
Note	1051	Unknown table 'db_fork_basic.v_test'
drop view if exists v_test_fork;
Warnings:
Note	1051	Unknown table 'db_fork_basic.v_test_fork'
# 创建基础表
create table t_view_base (
id int primary key,
name varchar(50),
age int
);
insert into t_view_base values (1, 'Alice', 25);
insert into t_view_base values (2, 'Bob', 30);
# 创建视图
create view v_test as select id, name, age from t_view_base where age > 20;
# 验证源视图存在
select * from v_test;
id	name	age
1	Alice	25
2	Bob	30
# 尝试Fork视图（预期不支持）bug ER_NOT_SUPPORTED_YET
fork table v_test to v_test_fork;
ERROR HY000: 'db_fork_basic.v_test' is not BASE TABLE
# 验证源视图仍然存在且可用
select * from v_test;
id	name	age
1	Alice	25
2	Bob	30
# 验证目标视图不存在
select * from v_test_fork;
ERROR 42S02: Table 'db_fork_basic.v_test_fork' doesn't exist
drop view v_test;
drop table t_view_base;
