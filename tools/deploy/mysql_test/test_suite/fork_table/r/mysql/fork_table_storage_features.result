============================================
2. 存储方式测试
============================================
# 2.1 行存表（WITH COLUMN GROUP(all columns)）
drop table if exists t_storage_row;
Warnings:
Note	1051	Unknown table 'db_fork_storage.t_storage_row'
drop table if exists t_storage_row_fork;
Warnings:
Note	1051	Unknown table 'db_fork_storage.t_storage_row_fork'
create table t_storage_row (
id int primary key,
name varchar(50),
value int,
data varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(all columns);
# 插入初始数据
insert into t_storage_row values (1, 'Row1', 100, 'Data1');
insert into t_storage_row values (101, 'Row2', 200, 'Data2');
insert into t_storage_row values (50, 'Row3', 300, 'Data3');
# 验证源表存储方式设置
show create table t_storage_row;
Table	Create Table
t_storage_row	CREATE TABLE `t_storage_row` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 验证源表数据
select count(*) as cnt from t_storage_row;
cnt
3
select * from t_storage_row order by id;
id	name	value	data
1	Row1	100	Data1
50	Row3	300	Data3
101	Row2	200	Data2
# Fork表
fork table t_storage_row to t_storage_row_fork;
# 验证目标表存储方式设置（应与源表一致）
show create table t_storage_row_fork;
Table	Create Table
t_storage_row_fork	CREATE TABLE `t_storage_row_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 验证目标表数据
select count(*) as cnt from t_storage_row_fork;
cnt
3
select * from t_storage_row_fork order by id;
id	name	value	data
1	Row1	100	Data1
50	Row3	300	Data3
101	Row2	200	Data2
# 验证数据一致性
select (select count(*) from t_storage_row) as src_cnt, (select count(*) from t_storage_row_fork) as fork_cnt;
src_cnt	fork_cnt
3	3
# 在源表和目标表插入相同主键数据（验证数据隔离）
insert into t_storage_row values (2, 'Source_Row2', 150, 'Source_Data2');
insert into t_storage_row_fork values (2, 'Fork_Row2', 250, 'Fork_Data2');
# 验证插入后数据隔离
select id, name, value, data from t_storage_row where id = 2;
id	name	value	data
2	Source_Row2	150	Source_Data2
select id, name, value, data from t_storage_row_fork where id = 2;
id	name	value	data
2	Fork_Row2	250	Fork_Data2
# DML操作测试：更新源表
update t_storage_row set value = 120, data = 'Updated_Source_Data1' where id = 1;
select id, name, value, data from t_storage_row where id = 1;
id	name	value	data
1	Row1	120	Updated_Source_Data1
# DML操作测试：更新目标表
update t_storage_row_fork set value = 220, data = 'Updated_Fork_Data1' where id = 1;
select id, name, value, data from t_storage_row_fork where id = 1;
id	name	value	data
1	Row1	220	Updated_Fork_Data1
# DML操作测试：删除源表数据
delete from t_storage_row where id = 50;
select count(*) as cnt from t_storage_row;
cnt
3
select count(*) as cnt from t_storage_row_fork;
cnt
4
# DML操作测试：删除目标表数据
delete from t_storage_row_fork where id = 101;
select count(*) as cnt from t_storage_row;
cnt
3
select count(*) as cnt from t_storage_row_fork;
cnt
3
# DDL操作测试：在源表添加列
alter table t_storage_row add column new_col varchar(50) default 'default_value';
show create table t_storage_row;
Table	Create Table
t_storage_row	CREATE TABLE `t_storage_row` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  `new_col` varchar(50) DEFAULT 'default_value',
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(all columns)
show create table t_storage_row_fork;
Table	Create Table
t_storage_row_fork	CREATE TABLE `t_storage_row_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(all columns)
# DDL操作测试：在目标表添加列
alter table t_storage_row_fork add column fork_col int default 999;
show create table t_storage_row;
Table	Create Table
t_storage_row	CREATE TABLE `t_storage_row` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
