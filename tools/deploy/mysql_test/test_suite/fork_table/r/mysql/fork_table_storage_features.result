drop database if exists db_fork_storage;
create database db_fork_storage;
use db_fork_storage;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '5s';
============================================
1. 压缩算法测试
============================================
# 1.1 不使用压缩算法
drop table if exists t_compression_none;
Warnings:
Note	1051	Unknown table 'db_fork_storage.t_compression_none'
drop table if exists t_compression_none_fork;
Warnings:
Note	1051	Unknown table 'db_fork_storage.t_compression_none_fork'
create table t_compression_none (
id int primary key,
name varchar(100),
data varchar(500)
) COMPRESSION = 'none' partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) ;
insert into t_compression_none values (1, 'Test1', repeat('A', 200));
insert into t_compression_none values (101, 'Test2', repeat('B', 200));
insert into t_compression_none values (50, 'Test3', repeat('C', 200));
# 验证源表压缩算法设置
show create table t_compression_none;
Table	Create Table
t_compression_none	CREATE TABLE `t_compression_none` (
  `id` int(11) NOT NULL,
  `name` varchar(100) DEFAULT NULL,
  `data` varchar(500) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'compression_value' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证源表数据
select count(*) as cnt from t_compression_none;
cnt
3
select id, name, length(data) as data_len from t_compression_none order by id;
id	name	data_len
1	Test1	200
50	Test3	200
101	Test2	200
# Fork表
fork table t_compression_none to t_compression_none_fork;
# 验证目标表压缩算法设置（应与源表一致）
show create table t_compression_none_fork;
Table	Create Table
t_compression_none_fork	CREATE TABLE `t_compression_none_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(100) DEFAULT NULL,
  `data` varchar(500) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'compression_value' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证目标表数据
select count(*) as cnt from t_compression_none_fork;
cnt
3
select id, name, length(data) as data_len from t_compression_none_fork order by id;
id	name	data_len
1	Test1	200
50	Test3	200
101	Test2	200
# 验证数据一致性
select (select count(*) from t_compression_none) as src_cnt, (select count(*) from t_compression_none_fork) as fork_cnt;
src_cnt	fork_cnt
3	3
# 注意：压缩算法验证说明
# 1. show create table 只能验证表结构中的压缩算法配置，不能验证存储层实际压缩效果
# 2. 压缩算法在存储层的实际生效需要数据落盘（major freeze/minor freeze）后才能体现
# 3. 要验证实际压缩效果，需要：
#    - 触发major freeze让数据落盘：alter system major freeze;
#    - 查询系统表查看压缩信息（需要存储层支持）
#    - 或比较不同压缩算法下的存储空间使用情况
# 4. 当前测试主要验证fork后表结构中的压缩算法配置是否正确继承
drop table t_compression_none;
drop table t_compression_none_fork;
