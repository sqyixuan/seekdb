# 创建带HNSW索引的向量查询表
create table t_vec_query (
c1 int primary key, 
c2 vector(3),
vector index idx1(c2) with (distance=inner_product, type=hnsw, lib=vsag)
) partition by range(c1) (
partition p0 values less than (100),
partition p1 values less than (200)
);
