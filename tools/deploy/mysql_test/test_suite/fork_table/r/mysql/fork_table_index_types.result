# 验证近似查询和精确查询结果一致性
# 源表：比较近似查询和精确查询的前3条记录的ID是否一致
select count(*) as match_count from (
select id from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as tmp1
inner join (
select id from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as tmp2 on tmp1.id = tmp2.id;
match_count
3
# 目标表：比较近似查询和精确查询的前3条记录的ID是否一致
select count(*) as match_count from (
select id from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as tmp1
inner join (
select id from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as tmp2 on tmp1.id = tmp2.id;
match_count
3
# 更详细的一致性验证：显示匹配的具体记录
select 
approx.id as approx_id,
exact.id as exact_id,
case when approx.id = exact.id then 'MATCH' else 'MISMATCH' end as status
from (
select id, row_number() over() as rn 
from t_hnsw_with_index 
order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as approx
full outer join (
select id, row_number() over() as rn 
from t_hnsw_with_index 
order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as exact on approx.rn = exact.rn;
approx_id	exact_id	status
1	1	MATCH
101	101	MATCH
50	50	MATCH
select 
approx.id as approx_id,
exact.id as exact_id,
case when approx.id = exact.id then 'MATCH' else 'MISMATCH' end as status
from (
select id, row_number() over() as rn 
from t_hnsw_with_index_fork 
order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as approx
full outer join (
select id, row_number() over() as rn 
from t_hnsw_with_index_fork 
order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as exact on approx.rn = exact.rn;
approx_id	exact_id	status
1	1	MATCH
101	101	MATCH
50	50	MATCH
