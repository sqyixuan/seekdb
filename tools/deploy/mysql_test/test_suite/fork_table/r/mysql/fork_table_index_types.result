drop database if exists db_fork_index_types;
create database db_fork_index_types;
use db_fork_index_types;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
# 启用debug sync
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '5s';
set ob_global_debug_sync = 'reset';
# 设置向量索引内存限制
alter system set ob_vector_memory_limit_percentage = 20;
============================================
1. 普通索引（Normal Index）
============================================
# 1.1 随表创建普通索引
drop table if exists t_normal_with_index;
Warnings:
Note	1051	Unknown table 'db_fork_index_types.t_normal_with_index'
drop table if exists t_normal_with_index_fork;
Warnings:
Note	1051	Unknown table 'db_fork_index_types.t_normal_with_index_fork'
create table t_normal_with_index (
id int primary key,
name varchar(50),
age int,
email varchar(100),
index idx_name(name),
index idx_age(age),
index idx_email(email)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_normal_with_index values (1, 'Alice', 25, 'alice@example.com');
insert into t_normal_with_index values (101, 'Bob', 30, 'bob@example.com');
insert into t_normal_with_index values (50, 'Charlie', 35, 'charlie@example.com');
# Fork表
fork table t_normal_with_index to t_normal_with_index_fork;
# 验证fork后源表和目标表的索引结构
show create table t_normal_with_index;
Table	Create Table
t_normal_with_index	CREATE TABLE `t_normal_with_index` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `age` int(11) DEFAULT NULL,
  `email` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_name` (`name`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_age` (`age`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_email` (`email`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200))
show create table t_normal_with_index_fork;
Table	Create Table
t_normal_with_index_fork	CREATE TABLE `t_normal_with_index_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `age` int(11) DEFAULT NULL,
  `email` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_name` (`name`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_age` (`age`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_email` (`email`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证fork后源表的索引功能
show indexes from t_normal_with_index;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t_normal_with_index	0	PRIMARY	1	id	A	NULL	NULL	NULL		BTREE	available		YES	NULL
t_normal_with_index	1	idx_name	1	name	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
t_normal_with_index	1	idx_age	1	age	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
t_normal_with_index	1	idx_email	1	email	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
select * from t_normal_with_index where name = 'Alice';
id	name	age	email
1	Alice	25	alice@example.com
select * from t_normal_with_index where age = 30;
id	name	age	email
101	Bob	30	bob@example.com
select * from t_normal_with_index where email = 'charlie@example.com';
id	name	age	email
50	Charlie	35	charlie@example.com
explain select * from t_normal_with_index where name = 'Alice';
Query Plan
==================================================================================
|ID|OPERATOR                 |NAME                         |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------------------
|0 |PX COORDINATOR           |                             |1       |16          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000                     |1       |14          |
|2 |  └─PX PARTITION ITERATOR|                             |1       |12          |
|3 |    └─TABLE RANGE SCAN   |t_normal_with_index(idx_name)|1       |12          |
==================================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_normal_with_index.id, t_normal_with_index.name, t_normal_with_index.age, t_normal_with_index.email)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_normal_with_index.id, t_normal_with_index.name, t_normal_with_index.age, t_normal_with_index.email)]), filter(nil), rowset=16
      dop=1
  2 - output([t_normal_with_index.id], [t_normal_with_index.name], [t_normal_with_index.age], [t_normal_with_index.email]), filter(nil), rowset=16
      force partition granule
  3 - output([t_normal_with_index.id], [t_normal_with_index.name], [t_normal_with_index.age], [t_normal_with_index.email]), filter(nil), rowset=16
      access([t_normal_with_index.id], [t_normal_with_index.name], [t_normal_with_index.age], [t_normal_with_index.email]), partitions(p[0-1])
      is_index_back=true, is_global_index=false, 
      range_key([t_normal_with_index.name], [t_normal_with_index.id]), range(Alice,MIN ; Alice,MAX), 
      range_cond([t_normal_with_index.name = 'Alice'])
