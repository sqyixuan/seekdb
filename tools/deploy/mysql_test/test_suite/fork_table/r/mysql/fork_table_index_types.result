name varchar(50),
vec vector(3),
vector index idx_vec(vec) with (distance=l2, type=hnsw, lib=vsag, m=16, ef_construction=200, ef_search=200)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
