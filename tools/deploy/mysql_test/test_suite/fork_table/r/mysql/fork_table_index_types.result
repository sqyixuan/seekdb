============================================
2. 全局索引（Global Index）
============================================
# 2.1 随表创建全局索引
drop table if exists t_global_with_index;
Warnings:
Note	1051	Unknown table 'db_fork_index_types.t_global_with_index'
drop table if exists t_global_with_index_fork;
Warnings:
Note	1051	Unknown table 'db_fork_index_types.t_global_with_index_fork'
create table t_global_with_index (
a int,
b varchar(150),
c int,
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
create index gidx_c on t_global_with_index(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
insert into t_global_with_index values (1, 'Alice', 10);
insert into t_global_with_index values (101, 'Bob', 110);
insert into t_global_with_index values (50, 'Charlie', 50);
# Fork表
fork table t_global_with_index to t_global_with_index_fork;
# 验证fork后源表和目标表的全局索引功能
