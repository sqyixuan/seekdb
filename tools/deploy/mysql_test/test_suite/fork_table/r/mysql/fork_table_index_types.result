create table t_normal_post_index (
id int primary key,
name varchar(50),
age int,
email varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_normal_post_index values (1, 'Alice', 25, 'alice@example.com');
insert into t_normal_post_index values (101, 'Bob', 30, 'bob@example.com');
# Fork表
fork table t_normal_post_index to t_normal_post_index_fork;
# 在源表上后建索引
create index idx_name_src on t_normal_post_index(name);
create index idx_age_src on t_normal_post_index(age);
# 在目标表上后建索引
create index idx_name_fork on t_normal_post_index_fork(name);
create index idx_age_fork on t_normal_post_index_fork(age);
# 验证源表和目标表的后建索引功能
