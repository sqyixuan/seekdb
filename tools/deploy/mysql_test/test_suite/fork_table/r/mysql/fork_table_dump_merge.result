drop table t_mid_dump_merge;
drop table t_mid_dump_merge_fork;
============================================
3. Fork后：转储合并操作
============================================
drop table if exists t_post_dump_merge;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_post_dump_merge'
drop table if exists t_post_dump_merge_fork;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_post_dump_merge_fork'
