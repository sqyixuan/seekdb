drop database if exists db_fork_dump_merge;
create database db_fork_dump_merge;
use db_fork_dump_merge;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
# 启用debug sync
alter system set debug_sync_timeout = '120s';
# 设置DDL超时为1秒
alter system set _ob_ddl_timeout = '50s';
set ob_global_debug_sync = 'reset';
# 加速major freeze
alter system set merger_check_interval = '10s' tenant sys;
alter system set ob_compaction_schedule_interval = '3s' tenant sys;
============================================
1. Fork前：转储合并操作
============================================
drop table if exists t_pre_dump_merge;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_pre_dump_merge'
drop table if exists t_pre_dump_merge_fork;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_pre_dump_merge_fork'
create table t_pre_dump_merge (
id int primary key,
name varchar(50),
value int,
data text
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# Fork前：插入数据并触发major freeze（转储）
insert into t_pre_dump_merge values (1, 'PreMajor1', 100, repeat('A', 500));
insert into t_pre_dump_merge values (101, 'PreMajor2', 200, repeat('B', 500));
alter system major freeze;
# 验证Fork前major freeze后的数据
select count(*) as cnt from t_pre_dump_merge;
cnt
2
select id, name, value, length(data) as data_len from t_pre_dump_merge order by id;
id	name	value	data_len
1	PreMajor1	100	500
101	PreMajor2	200	500
# Fork前：插入数据并触发minor freeze（转储）
# 注意：确保之前的数据已清理，避免主键冲突
delete from t_pre_dump_merge where id in (2, 102);
insert into t_pre_dump_merge values (2, 'PreMinor1', 300, repeat('C', 500));
insert into t_pre_dump_merge values (102, 'PreMinor2', 400, repeat('D', 500));
alter system minor freeze;
# 验证Fork前minor freeze后的数据
select count(*) as cnt from t_pre_dump_merge;
cnt
4
select id, name, value, length(data) as data_len from t_pre_dump_merge order by id;
id	name	value	data_len
1	PreMajor1	100	500
2	PreMinor1	300	500
101	PreMajor2	200	500
102	PreMinor2	400	500
# Fork表
fork table t_pre_dump_merge to t_pre_dump_merge_fork;
# 验证Fork后源表和目标表数据
select count(*) as src_cnt from t_pre_dump_merge;
src_cnt
4
select count(*) as fork_cnt from t_pre_dump_merge_fork;
fork_cnt
4
select id, name, value, length(data) as data_len from t_pre_dump_merge order by id;
id	name	value	data_len
1	PreMajor1	100	500
2	PreMinor1	300	500
101	PreMajor2	200	500
102	PreMinor2	400	500
select id, name, value, length(data) as data_len from t_pre_dump_merge_fork order by id;
id	name	value	data_len
1	PreMajor1	100	500
2	PreMinor1	300	500
101	PreMajor2	200	500
102	PreMinor2	400	500
drop table t_pre_dump_merge;
drop table t_pre_dump_merge_fork;
============================================
2. Fork中：转储合并操作
============================================
drop table if exists t_mid_dump_merge;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_mid_dump_merge'
drop table if exists t_mid_dump_merge_fork;
Warnings:
Note	1051	Unknown table 'db_fork_dump_merge.t_mid_dump_merge_fork'
create table t_mid_dump_merge (
id int primary key,
name varchar(50),
value int,
data text
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建初始数据
insert into t_mid_dump_merge values (1, 'Init1', 10, repeat('I', 500));
insert into t_mid_dump_merge values (101, 'Init2', 20, repeat('J', 500));
# 在fork开始前，先确保之前的merge已完成，并记录初始状态
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	0
# 记录执行freeze前的last_scn值（用于后续比较）
select last_scn as last_scn_before from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
last_scn_before
LAST_SCN_BEFORE
# 设置debug sync point在FORK_TABLE_BUILD_DATA阶段暂停
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for dump_merge_signal execute 10000';
# 执行Fork命令（会在BUILD_DATA阶段暂停）
fork table t_mid_dump_merge to t_mid_dump_merge_fork;
# 等待fork进入BUILD_DATA阶段
# Fork中：对源表执行major freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_mid_dump_merge values (2, 'MidSrcMajor1', 100, repeat('K', 500));
insert into t_mid_dump_merge values (102, 'MidSrcMajor2', 200, repeat('L', 500));
alter system major freeze;
# 等待一小段时间，确保系统已经处理freeze命令并更新frozen_scn
# 验证Fork中源表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as src_cnt from t_mid_dump_merge;
src_cnt
4
select id, name, value, length(data) as data_len from t_mid_dump_merge order by id;
id	name	value	data_len
1	Init1	10	500
2	MidSrcMajor1	100	500
101	Init2	20	500
102	MidSrcMajor2	200	500
# 验证major merge确实被阻塞
# 说明：执行alter system major freeze后，有两种可能的情况：
# 1. 如果frozen_scn != last_scn（merge_pending=1），说明新的freeze已设置，但merge尚未完成（被fork阻塞）
# 2. 如果frozen_scn == last_scn（merge_pending=0），可能是新的freeze还没有被处理（因为fork阻塞了freeze的处理）
# 无论哪种情况，都说明merge操作被阻塞，无法继续完成
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	MERGE_PENDING
# Fork中：对目标表执行major freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_mid_dump_merge_fork values (10, 'MidForkMajor1', 1000, repeat('M', 500));
insert into t_mid_dump_merge_fork values (110, 'MidForkMajor2', 2000, repeat('N', 500));
alter system major freeze;
Warnings:
Warning	4744	larger frozen_scn already exist, prev merge may not finish
# 验证Fork中目标表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as fork_cnt from t_mid_dump_merge_fork;
fork_cnt
4
select id, name, value, length(data) as data_len from t_mid_dump_merge_fork order by id;
id	name	value	data_len
1	Init1	10	500
10	MidForkMajor1	1000	500
101	Init2	20	500
110	MidForkMajor2	2000	500
# 再次验证major merge确实被阻塞
# 说明：执行alter system major freeze后，有两种可能的情况：
# 1. 如果frozen_scn != last_scn（merge_pending=1），说明新的freeze已设置，但merge尚未完成（被fork阻塞）
# 2. 如果frozen_scn == last_scn（merge_pending=0），可能是新的freeze还没有被处理（因为fork阻塞了freeze的处理）
# 无论哪种情况，都说明merge操作被阻塞，无法继续完成
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	MERGE_PENDING
# Fork中：对源表执行minor freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_mid_dump_merge values (3, 'MidSrcMinor1', 300, repeat('O', 500));
insert into t_mid_dump_merge values (103, 'MidSrcMinor2', 400, repeat('P', 500));
alter system minor freeze;
# 验证Fork中源表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as src_cnt from t_mid_dump_merge;
src_cnt
6
select id, name, value, length(data) as data_len from t_mid_dump_merge order by id;
id	name	value	data_len
1	Init1	10	500
2	MidSrcMajor1	100	500
3	MidSrcMinor1	300	500
101	Init2	20	500
102	MidSrcMajor2	200	500
103	MidSrcMinor2	400	500
# 验证minor merge确实被阻塞（存在is_active='NO'的memstore表示minor merge尚未完成）
select count(*) as pending_minor_merge from oceanbase.__all_virtual_memstore_info where is_active='NO';
pending_minor_merge
COUNT_VALUE
# Fork中：对目标表执行minor freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_mid_dump_merge_fork values (11, 'MidForkMinor1', 3000, repeat('Q', 500));
insert into t_mid_dump_merge_fork values (111, 'MidForkMinor2', 4000, repeat('R', 500));
alter system minor freeze;
# 验证Fork中目标表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as fork_cnt from t_mid_dump_merge_fork;
fork_cnt
6
select id, name, value, length(data) as data_len from t_mid_dump_merge_fork order by id;
id	name	value	data_len
1	Init1	10	500
10	MidForkMajor1	1000	500
11	MidForkMinor1	3000	500
101	Init2	20	500
110	MidForkMajor2	2000	500
111	MidForkMinor2	4000	500
# 再次验证minor merge确实被阻塞（存在is_active='NO'的memstore表示minor merge尚未完成）
select count(*) as pending_minor_merge from oceanbase.__all_virtual_memstore_info where is_active='NO';
pending_minor_merge
COUNT_VALUE
# 继续Fork执行
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal dump_merge_signal';
# 验证Fork完成后源表和目标表数据
select count(*) as src_cnt from t_mid_dump_merge;
src_cnt
6
select count(*) as fork_cnt from t_mid_dump_merge_fork;
fork_cnt
6
select id, name, value, length(data) as data_len from t_mid_dump_merge order by id;
id	name	value	data_len
1	Init1	10	500
2	MidSrcMajor1	100	500
3	MidSrcMinor1	300	500
101	Init2	20	500
102	MidSrcMajor2	200	500
103	MidSrcMinor2	400	500
select id, name, value, length(data) as data_len from t_mid_dump_merge_fork order by id;
id	name	value	data_len
1	Init1	10	500
10	MidForkMajor1	1000	500
11	MidForkMinor1	3000	500
101	Init2	20	500
110	MidForkMajor2	2000	500
111	MidForkMinor2	4000	500
# 等待major merge完成（在fork过程中执行的major freeze需要等待fork完成后才能继续）
# 等待minor merge完成（在fork过程中执行的minor freeze需要等待fork完成后才能继续）
# 验证Fork完成后major、minor freeze后的数据
select count(*) as src_cnt from t_mid_dump_merge;
src_cnt
6
select count(*) as fork_cnt from t_mid_dump_merge_fork;
fork_cnt
6
select id, name, value, length(data) as data_len from t_mid_dump_merge order by id;
id	name	value	data_len
1	Init1	10	500
2	MidSrcMajor1	100	500
3	MidSrcMinor1	300	500
101	Init2	20	500
102	MidSrcMajor2	200	500
103	MidSrcMinor2	400	500
select id, name, value, length(data) as data_len from t_mid_dump_merge_fork order by id;
id	name	value	data_len
1	Init1	10	500
10	MidForkMajor1	1000	500
11	MidForkMinor1	3000	500
101	Init2	20	500
