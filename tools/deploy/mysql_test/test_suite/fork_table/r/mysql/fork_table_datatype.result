repeat(x'45', 30000),                                 -- longblob (30KB)
repeat('Second TinyText ', 8),                        -- tinytext
repeat('Second Text LOB ', 150),                      -- text
repeat('Second MediumText ', 1000),                   -- mediumtext
repeat('Second LongText ', 5000),                     -- longtext
repeat('Second large varchar ', 100)                  -- 大varchar
);
