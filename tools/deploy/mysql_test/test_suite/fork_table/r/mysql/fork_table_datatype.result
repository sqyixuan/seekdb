# Step 2: 删除Fork表数据，准备独立测试
delete from t_numeric_fork;
# 验证Fork表已清空，源表数据未受影响
select  count(*) as cnt from t_numeric_fork;
cnt
0
select count(*) as cnt from t_numeric;
cnt
3
