# 创建包含LOB类型的源表
create table t_lob (
id int primary key,
-- BLOB类型
col_tinyblob tinyblob,
col_blob blob,
col_mediumblob mediumblob,
col_longblob longblob,
-- TEXT类型（作为LOB处理）
col_tinytext_lob tinytext,
col_text_lob text,
col_mediumtext_lob mediumtext,
col_longtext_lob longtext,
-- 大容量数据字段
col_large_varchar varchar(5000)
);
# 插入LOB数据 - 使用十六进制和长字符串
insert into t_lob values (
1,
x'0102030405060708',                                  -- tinyblob
x'112233445566778899AABBCCDDEEFF',                    -- blob
repeat(x'42', 10000),                                 -- mediumblob (10KB)
repeat(x'43', 50000),                                 -- longblob (50KB)
repeat('TinyText LOB data ', 10),                     -- tinytext
repeat('Regular Text LOB data ', 200),                -- text (约4KB)
repeat('Medium Text LOB data ', 2000),                -- mediumtext (约40KB)
repeat('Long Text LOB data ', 10000),                 -- longtext (约200KB)
repeat('Large varchar data ', 150)                    -- 大varchar
);
