3. 字符串类型Fork测试
============================================
drop table if exists t_string;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_string'
drop table if exists t_string_fork;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_string_fork'
# 创建包含所有字符串类型的源表
create table t_string (
id int primary key,
-- 定长字符串
col_char char(10),
col_char_bin char(10) binary,
-- 变长字符串
col_varchar varchar(100),
col_varchar_bin varchar(100) binary,
-- 文本类型
col_tinytext tinytext,
col_text text,
col_mediumtext mediumtext,
col_longtext longtext,
-- 二进制字符串
col_binary binary(10),
col_varbinary varbinary(100),
-- 枚举和集合类型
col_enum enum('small','medium','large'),
col_set set('red','green','blue','yellow')
);
# 插入各种字符串数据
insert into t_string values (
1,
'char', 'CHARBIN',                                     -- char类型
'varchar data', 'VARCHAR BIN',                         -- varchar类型
'This is tinytext data',                               -- tinytext
'This is regular text data that can be quite long',    -- text
repeat('Medium text data ', 50),                       -- mediumtext
repeat('Long text data ', 200),                        -- longtext
'binary', 'varbinary data',                            -- 二进制类型
'large',                                               -- enum类型
'red,green,blue'                                       -- set类型
);
insert into t_string values (
2,
'test', 'TESTBIN',                                     -- char类型
'another varchar', 'ANOTHER BIN',                      -- varchar类型
'Another tinytext',                                    -- tinytext
'Another text field with different content',           -- text
repeat('Different medium ', 40),                       -- mediumtext
repeat('Different long ', 150),                        -- longtext
'bin2', 'varbin2',                                     -- 二进制类型
'small',                                               -- enum类型
'yellow,red'                                           -- set类型
);
# 边界值测试
insert into t_string values (
3,
'', '',                                                -- 空字符串
'', '',                                                -- 空varchar
'', '', '', '',                                        -- 空text类型
'', '',                                                -- 空二进制
'medium',                                              -- enum默认值
''                                                     -- 空set
);
# 执行Fork Table
fork table t_string to t_string_fork;
# 验证Fork后的字符串数据
select count(*) as cnt from t_string_fork;
cnt
3
select id, col_char, col_char_bin, col_varchar, col_varchar_bin, col_enum, col_set from t_string_fork order by id;
id	col_char	col_char_bin	col_varchar	col_varchar_bin	col_enum	col_set
1	char	CHARBIN	varchar data	VARCHAR BIN	large	red,green,blue
2	test	TESTBIN	another varchar	ANOTHER BIN	small	red,yellow
3					medium	
