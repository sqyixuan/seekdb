# 创建模拟数组的表（使用JSON存储数组）
create table t_array (
id int primary key,
col_int_array json,          -- 整数数组
col_str_array json,          -- 字符串数组
col_mixed_array json,        -- 混合类型数组
col_2d_array json,           -- 二维数组
col_array_of_objects json    -- 对象数组
);
# 插入数组数据
insert into t_array values (
1,
'[1, 2, 3, 4, 5, 10, 20, 30, 40, 50]',                          -- 整数数组
'["apple", "banana", "cherry", "date", "elderberry"]',           -- 字符串数组
'[1, "two", 3.0, true, null, {"key": "value"}]',                -- 混合数组
'[[1, 2, 3], [4, 5, 6], [7, 8, 9]]',                            -- 二维数组
'[{"name": "John", "age": 30}, {"name": "Jane", "age": 25}]'     -- 对象数组
);
insert into t_array values (
2,
'[100, 200, 300, 400, 500]',                                    -- 大整数数组
'["red", "green", "blue", "yellow", "purple", "orange"]',        -- 颜色数组
'[false, 123.456, "string value", [1,2,3]]',                    -- 复杂混合数组
'[[10, 20], [30, 40], [50, 60], [70, 80]]',                     -- 二维数组2
'[{"id": 1, "value": "A"}, {"id": 2, "value": "B"}, {"id": 3, "value": "C"}]' -- 对象数组2
);
# 执行Fork Table
fork table t_array to t_array_fork;
# 验证Fork后的数组数据
select count(*) as cnt from t_array_fork;
cnt
2
