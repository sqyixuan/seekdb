2	5	6	4	3
# 验证数组内容
select id,
col_int_array->'$[0]' as first_int,
col_str_array->'$[1]' as second_str,
col_2d_array->'$[0][0]' as matrix_00,
col_array_of_objects->'$[0].name' as first_obj_name
from t_array_fork where id = 1;
id	first_int	second_str	matrix_00	first_obj_name
