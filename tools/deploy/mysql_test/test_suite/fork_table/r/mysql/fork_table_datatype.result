drop database if exists db_fork_datatype;
create database db_fork_datatype;
use db_fork_datatype;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 数值类型Fork测试
============================================
drop table if exists t_numeric;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_numeric'
drop table if exists t_numeric_fork;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_numeric_fork'
# 创建包含所有数值类型的源表
create table t_numeric (
id int primary key,
-- 整数类型
col_tinyint tinyint,
col_smallint smallint,
col_mediumint mediumint,
col_int int,
col_bigint bigint,
-- 定点数类型
col_decimal decimal(10,2),
col_numeric numeric(10,3),
-- 浮点数类型
col_float float(8,3),
col_double double(15,5),
col_real real(10,2),
-- 无符号整数
col_utinyint tinyint unsigned,
col_usmallint smallint unsigned,
col_umediumint mediumint unsigned,
col_uint int unsigned,
col_ubigint bigint unsigned,
-- 位类型
col_bit bit(8),
-- 布尔类型
col_bool boolean,
col_boolean boolean
);
# 插入各种数值类型数据
insert into t_numeric values (
10,
127, 32767, 8388607, 2147483647, 9223372036854775807, -- 有符号整数最大值
1234567.89, 987654.321,                                -- 定点数
12345.678, 123456789.12345, 123456.78,                -- 浮点数
255, 65535, 16777215, 4294967295, 18446744073709551615, -- 无符号整数最大值
b'10101010',                                          -- 位类型
true, false                                           -- 布尔类型
);
insert into t_numeric values (
11,
-128, -32768, -8388608, -2147483648, -9223372036854775808, -- 有符号整数最小值
-1234567.89, -987654.321,                               -- 定点数负数
-12345.678, -123456789.12345, -123456.78,               -- 浮点数负数
0, 0, 0, 0, 0,                                         -- 无符号零值
b'01010101',                                           -- 位类型
false, true                                            -- 布尔类型
);
# 边界值测试
insert into t_numeric values (
12,
0, 0, 0, 0, 0,                                        -- 零值
0.00, 0.000,                                          -- 定点数零值
0.0, 0.00000, 0.0,                                    -- 浮点数零值
0, 0, 0, 0, 0,                                        -- 无符号零值
b'00000000',                                          -- 位类型零值
false, true                                           -- 布尔类型
);
# 执行Fork Table
fork table t_numeric to t_numeric_fork;
# 验证Fork后的表结构
show create table t_numeric_fork;
Table	Create Table
t_numeric_fork	CREATE TABLE `t_numeric_fork` (
  `id` int(11) NOT NULL,
  `col_tinyint` tinyint(4) DEFAULT NULL,
  `col_smallint` smallint(6) DEFAULT NULL,
  `col_mediumint` mediumint(9) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_decimal` decimal(10,2) DEFAULT NULL,
  `col_numeric` decimal(10,3) DEFAULT NULL,
  `col_float` float(8,3) DEFAULT NULL,
  `col_double` double(15,5) DEFAULT NULL,
  `col_real` double(10,2) DEFAULT NULL,
  `col_utinyint` tinyint(3) unsigned DEFAULT NULL,
  `col_usmallint` smallint(5) unsigned DEFAULT NULL,
  `col_umediumint` mediumint(8) unsigned DEFAULT NULL,
  `col_uint` int(10) unsigned DEFAULT NULL,
  `col_ubigint` bigint(20) unsigned DEFAULT NULL,
  `col_bit` bit(8) DEFAULT NULL,
  `col_bool` tinyint(1) DEFAULT NULL,
  `col_boolean` tinyint(1) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show create table t_numeric;
Table	Create Table
t_numeric	CREATE TABLE `t_numeric` (
  `id` int(11) NOT NULL,
  `col_tinyint` tinyint(4) DEFAULT NULL,
  `col_smallint` smallint(6) DEFAULT NULL,
  `col_mediumint` mediumint(9) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_decimal` decimal(10,2) DEFAULT NULL,
  `col_numeric` decimal(10,3) DEFAULT NULL,
  `col_float` float(8,3) DEFAULT NULL,
  `col_double` double(15,5) DEFAULT NULL,
  `col_real` double(10,2) DEFAULT NULL,
  `col_utinyint` tinyint(3) unsigned DEFAULT NULL,
  `col_usmallint` smallint(5) unsigned DEFAULT NULL,
  `col_umediumint` mediumint(8) unsigned DEFAULT NULL,
  `col_uint` int(10) unsigned DEFAULT NULL,
  `col_ubigint` bigint(20) unsigned DEFAULT NULL,
  `col_bit` bit(8) DEFAULT NULL,
  `col_bool` tinyint(1) DEFAULT NULL,
  `col_boolean` tinyint(1) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
# Step 1: 验证Fork后数据与源表完全一致
# 验证记录数一致
select  count(*) as cnt from t_numeric
union all
select count(*) as cnt from t_numeric_fork;
cnt
3
3
# 验证数据内容完全一致
select s.id, 
s.col_tinyint = f.col_tinyint as tinyint_match,
s.col_smallint = f.col_smallint as smallint_match,
s.col_int = f.col_int as int_match,
s.col_bigint = f.col_bigint as bigint_match,
abs(s.col_decimal - f.col_decimal) < 0.01 as decimal_match,
abs(s.col_float - f.col_float) < 0.001 as float_match
from t_numeric s
join t_numeric_fork f on s.id = f.id
order by s.id;
id	tinyint_match	smallint_match	int_match	bigint_match	decimal_match	float_match
10	1	1	1	1	1	1
11	1	1	1	1	1	1
12	1	1	1	1	1	1
