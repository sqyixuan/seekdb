7. 混合类型综合Fork测试
============================================
drop table if exists t_comprehensive;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_comprehensive'
drop table if exists t_comprehensive_fork;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_comprehensive_fork'
# 创建包含所有类型的综合表
create table t_comprehensive (
id int primary key,
-- 数值类型
col_num_int int,
col_num_decimal decimal(10,2),
col_num_double double,
-- 时间类型
col_date date,
col_datetime datetime,
col_timestamp timestamp,
-- 字符串类型
col_varchar varchar(100),
col_text text,
-- LOB类型
col_blob blob,
col_json json,
-- 数组类型（JSON模拟）
col_array json
);
# 插入综合数据
insert into t_comprehensive values (
1,
12345, 9999.99, 123.456,                    -- 数值类型
'2023-12-25', '2023-12-25 12:30:45', current_timestamp, -- 时间类型
'Sample varchar data',                       -- 字符串
'This is a text field with some content',    -- 文本
x'0102030405060708090A0B0C0D0E0F',          -- BLOB
'{"name": "Test", "values": [1,2,3]}',      -- JSON
'[1, 2, 3, 4, 5]'                           -- 数组
);
insert into t_comprehensive values (
2,
-6789, -1234.56, -78.901,                   -- 负数数值
'1970-01-01', '1970-01-01 00:00:00', '1970-01-01 00:00:01', -- 边界时间
'Another varchar string',                    -- 字符串
repeat('Long text content ', 50),            -- 长文本
repeat(x'42', 1000),                         -- 大BLOB
'{"negative": true, "data": {"nested": "value"}}', -- 复杂JSON
'["a", "b", "c", "d", "e"]'                  -- 字符串数组
);
# 执行Fork Table
fork table t_comprehensive to t_comprehensive_fork;
# 验证Fork后的综合数据
select count(*) as cnt from t_comprehensive_fork;
cnt
2
select id, col_num_int, col_num_decimal, col_date, col_varchar, 
length(col_text) as text_len, length(col_blob) as blob_len,
json_length(col_json) as json_len, json_length(col_array) as array_len
from t_comprehensive_fork order by id;
id	col_num_int	col_num_decimal	col_date	col_varchar	text_len	blob_len	json_len	array_len
1	12345	9999.99	2023-12-25	Sample varchar data	38	15	2	5
2	-6789	-1234.56	1970-01-01	Another varchar string	900	1000	2	5
# 验证源表数据未受影响
select count(*) as cnt from t_comprehensive;
cnt
2
select id, col_num_int, col_num_decimal, col_date, col_varchar, 
length(col_text) as text_len, length(col_blob) as blob_len,
json_length(col_json) as json_len, json_length(col_array) as array_len
from t_comprehensive order by id;
id	col_num_int	col_num_decimal	col_date	col_varchar	text_len	blob_len	json_len	array_len
1	12345	9999.99	2023-12-25	Sample varchar data	38	15	2	5
2	-6789	-1234.56	1970-01-01	Another varchar string	900	1000	2	5
# 综合类型数据隔离测试
# 在源表和Fork表中分别插入不同数据
insert into t_comprehensive values (
3,
333, 333.33, 333.333,
'2024-01-01', '2024-01-01 01:01:01', current_timestamp,
'Source new data',
'Source text content',
x'3333333333333333',
'{"source": "new data"}',
'[3, 3, 3]'
);
insert into t_comprehensive_fork values (
4,
444, 444.44, 444.444,
'2024-02-02', '2024-02-02 02:02:02', current_timestamp,
'Fork new data',
'Fork text content',
x'4444444444444444',
'{"fork": "new data"}',
'[4, 4, 4]'
);
# 验证数据隔离
select id, col_num_int, col_varchar, col_json->>'$.source' as source_data 
from t_comprehensive where id in (3,4) order by id;
id	col_num_int	col_varchar	source_data
3	333	Source new data	new data
select id, col_num_int, col_varchar, col_json->>'$.fork' as fork_data 
from t_comprehensive_fork where id in (3,4) order by id;
id	col_num_int	col_varchar	fork_data
4	444	Fork new data	new data
============================================
8. 清理测试环境
============================================
drop table if exists t_numeric;
drop table if exists t_numeric_fork;
drop table if exists t_datetime;
drop table if exists t_datetime_fork;
drop table if exists t_string;
drop table if exists t_string_fork;
drop table if exists t_lob;
drop table if exists t_lob_fork;
drop table if exists t_json;
drop table if exists t_json_fork;
drop table if exists t_array;
drop table if exists t_array_fork;
drop table if exists t_comprehensive;
drop table if exists t_comprehensive_fork;
drop database if exists db_fork_datatype;
alter system set _ob_enable_truncate_partition_preserve_global_index = false;
