# 在源表插入数据，验证不影响Fork表
insert into t_numeric values (
20,
127,  -- TINYINT 最大值 (修正：原255超出范围)
32700,  -- SMALLINT 范围内
8000000,  -- MEDIUMINT 范围内  
2000000000,  -- INT 范围内
9000000000000000000,  -- BIGINT 范围内
999999.99, 888888.888,  -- DECIMAL/NUMERIC 范围内
54321.123, 1234567.89012, 98765.43,  -- 浮点数范围内
128,  -- TINYINT UNSIGNED 范围内 (0-255)
32000,  -- SMALLINT UNSIGNED 范围内
8000000,  -- MEDIUMINT UNSIGNED 范围内  
2000000000,  -- INT UNSIGNED 范围内
9000000000000000000,  -- BIGINT UNSIGNED 范围内
b'10100101',
true, false
);
