============================================
2. 时间日期类型Fork测试
============================================
drop table if exists t_datetime;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_datetime'
drop table if exists t_datetime_fork;
Warnings:
Note	1051	Unknown table 'db_fork_datatype.t_datetime_fork'
# 创建包含所有时间日期类型的源表
create table t_datetime (
id int primary key,
-- 日期时间类型
col_date date,
col_time time,
col_datetime datetime,
col_timestamp timestamp,
col_year year,
-- 时间精度类型
col_datetime6 datetime(6),
col_timestamp6 timestamp(6),
col_time6 time(6)
);
# 插入各种时间日期数据
insert into t_datetime values (
1,
'2023-12-25',                              -- date
'12:30:45',                                -- time
'2023-12-25 12:30:45',                     -- datetime
'2023-12-25 12:30:45',                     -- timestamp
2023,                                      -- year
'2023-12-25 12:30:45.123456',              -- datetime(6)
'2023-12-25 12:30:45.654321',              -- timestamp(6)
'12:30:45.987654'                          -- time(6)
);
insert into t_datetime values (
2,
'1970-01-01',                              -- 最小日期
'00:00:00',                                -- 最小时间
'1970-01-01 00:00:00',                     -- 最小datetime
'1970-01-01 00:00:01',                     -- timestamp不能为0
1901,                                      -- 最小year
'1970-01-01 00:00:00.000000',              -- 最小datetime(6)
'1970-01-01 00:00:01.000000',              -- timestamp(6)不能为0
'00:00:00.000000'                          -- 最小time(6)
);
insert into t_datetime values (
3,
'9999-12-31',                              -- 最大日期
'23:59:59',                               -- 最大时间
'9999-12-31 23:59:59',                     -- 最大datetime
'2038-01-19 03:14:07',                     -- 最大timestamp
2155,                                      -- 最大year
'9999-12-31 23:59:59.999999',              -- 最大datetime(6)
'2038-01-19 03:14:07.999999',              -- 最大timestamp(6)
'23:59:59.999999'                         -- 最大time(6)
);
# 执行Fork Table
fork table t_datetime to t_datetime_fork;
# 验证Fork后的时间日期数据
select count(*) as cnt from t_datetime_fork;
cnt
3
