fork table t_idx_base to t_idx_base_fork;
# 查询内部索引辅助表（如果存在）
# 注意：内部表的命名规则可能不同，这里仅做示例
# 查找可能的索引辅助表
select table_name, table_type from oceanbase.__all_virtual_table where data_table_id = base_table_id and table_type in ('INDEX', 'AUX_LOB_META', 'AUX_LOB_PIECE') limit 10;
table_name	table_type
