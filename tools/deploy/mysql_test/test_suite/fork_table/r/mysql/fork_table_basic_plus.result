# 创建父表
create table t_complex_parent (
id int primary key,
name varchar(50)
);
insert into t_complex_parent values (1, 'Parent1');
# 创建子表（含外键和Trigger）
create table t_complex_child (
id int primary key,
parent_id int,
name varchar(50),
created_time datetime,
foreign key (parent_id) references t_complex_parent(id)
);
# 创建Trigger
create trigger trg_complex_insert before insert on t_complex_child
for each row set new.created_time = now();
insert into t_complex_child(id, parent_id, name) values (1, 1, 'Child1');
# 验证源表外键和Trigger
show create table t_complex_child;
