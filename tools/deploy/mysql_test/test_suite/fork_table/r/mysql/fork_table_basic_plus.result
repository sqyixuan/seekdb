Warnings:
Note	1051	Unknown table 'db_fork_basic.t_auto_fork'
create table t_auto (
id int auto_increment primary key,
name varchar(20)
);
insert into t_auto(name) values ('A1'), ('A2');
fork table t_auto to t_auto_fork;
