drop table t_col_ddl_fork;
============================================
Case 6: 列存 Fork - Build_Data 阶段写入验证
============================================
drop table if exists t_col_cow;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_cow'
drop table if exists t_col_cow_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_cow_fork'
create table t_col_cow (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(each column);
insert into t_col_cow values (1, 'COW1', 10), (101, 'COW2', 20), (50, 'COW3', 30);
alter system major freeze;
# 卡在 BUILD_DATA 阶段
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for signal_col_cow execute 10000';
fork table t_col_cow to t_col_cow_fork;
# 等待 fork 任务到达 BUILD_DATA 阶段
# 在 BUILD_DATA 阶段向 fork 表插入全新的行（不依赖原有 CO SSTable 数据的读操作）
insert into t_col_cow_fork values (2, 'Fork_During_Build', 99);
insert into t_col_cow_fork values (3, 'Fork_During_Build2', 88);
# 向源表也插入新行，验证互不影响
insert into t_col_cow values (4, 'Src_During_Build', 77);
insert into t_col_cow values (5, 'Src_During_Build2', 66);
# 放开 BUILD_DATA 卡点，等待 fork 完成
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal signal_col_cow';
# 验证 BUILD_DATA 期间写入的新行在 fork 完成后仍然存在
select * from t_col_cow order by id;
id	name	value
1	COW1	10
4	Src_During_Build	77
5	Src_During_Build2	66
50	COW3	30
101	COW2	20
select * from t_col_cow_fork order by id;
id	name	value
1	COW1	10
2	Fork_During_Build	99
3	Fork_During_Build2	88
50	COW3	30
101	COW2	20
# fork 完成后验证：对原有行的 update/delete 隔离
update t_col_cow set value = 999 where id = 1;
update t_col_cow_fork set value = 888 where id = 1;
select id, value from t_col_cow where id = 1;
id	value
1	999
select id, value from t_col_cow_fork where id = 1;
id	value
1	888
delete from t_col_cow where id = 50;
select count(*) as src_cnt from t_col_cow;
src_cnt
4
select count(*) as fork_cnt from t_col_cow_fork;
fork_cnt
5
# 验证源表和 fork 表的新插入行互不影响
select id, name from t_col_cow where id in (2, 3, 4, 5) order by id;
id	name
4	Src_During_Build
5	Src_During_Build2
select id, name from t_col_cow_fork where id in (2, 3, 4, 5) order by id;
id	name
2	Fork_During_Build
3	Fork_During_Build2
drop table t_col_cow;
drop table t_col_cow_fork;
============================================
清理
============================================
set ob_global_debug_sync = 'reset';
drop database if exists db_fork_col_storage;
