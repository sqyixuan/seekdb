drop database if exists db_fork_col_storage;
create database db_fork_col_storage;
use db_fork_col_storage;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
alter system set debug_sync_timeout = '120s';
set ob_global_debug_sync = 'reset';
alter system set merger_check_interval = '10s' tenant sys;
alter system set ob_compaction_schedule_interval = '3s' tenant sys;
============================================
Case 1: 基本列存 Fork - memtable 数据
============================================
drop table if exists t_col_basic;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_basic'
drop table if exists t_col_basic_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_basic_fork'
create table t_col_basic (
id int primary key,
name varchar(50),
value int,
data varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(each column);
# 验证源表为列存
show create table t_col_basic;
Table	Create Table
t_col_basic	CREATE TABLE `t_col_basic` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 插入初始数据（仅在 memtable）
insert into t_col_basic values (1, 'Col1', 100, 'Data1');
insert into t_col_basic values (101, 'Col2', 200, 'Data2');
insert into t_col_basic values (50, 'Col3', 300, 'Data3');
select count(*) as cnt from t_col_basic;
cnt
3
select * from t_col_basic order by id;
id	name	value	data
1	Col1	100	Data1
50	Col3	300	Data3
101	Col2	200	Data2
# Fork 列存表
fork table t_col_basic to t_col_basic_fork;
# 验证 fork 表也是列存
show create table t_col_basic_fork;
Table	Create Table
t_col_basic_fork	CREATE TABLE `t_col_basic_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 验证数据完整性
select count(*) as cnt from t_col_basic_fork;
cnt
3
select * from t_col_basic_fork order by id;
id	name	value	data
1	Col1	100	Data1
50	Col3	300	Data3
101	Col2	200	Data2
# 验证数据一致性
select (select count(*) from t_col_basic) = (select count(*) from t_col_basic_fork) as data_consistent;
data_consistent
1
# 验证数据隔离：向源表和目标表分别写入不同数据
insert into t_col_basic values (2, 'Src_New', 150, 'Src_Data');
insert into t_col_basic_fork values (2, 'Fork_New', 250, 'Fork_Data');
select id, name, value from t_col_basic where id = 2;
id	name	value
2	Src_New	150
select id, name, value from t_col_basic_fork where id = 2;
id	name	value
2	Fork_New	250
# 验证更新隔离
update t_col_basic set value = 999 where id = 1;
select id, value from t_col_basic where id = 1;
id	value
1	999
select id, value from t_col_basic_fork where id = 1;
id	value
1	100
# 验证删除隔离
delete from t_col_basic where id = 50;
select count(*) as src_cnt from t_col_basic;
src_cnt
3
select count(*) as fork_cnt from t_col_basic_fork;
fork_cnt
4
drop table t_col_basic;
drop table t_col_basic_fork;
============================================
Case 2: 列存 Fork - Major SSTable 数据（CO SSTable 重用）
============================================
drop table if exists t_col_major;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_major'
drop table if exists t_col_major_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_major_fork'
create table t_col_major (
id int primary key,
name varchar(50),
value int,
data varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(each column);
# 插入数据并触发 major freeze，产生 CO SSTable
insert into t_col_major values (1, 'Major_Col1', 100, 'Data1');
insert into t_col_major values (101, 'Major_Col2', 200, 'Data2');
insert into t_col_major values (50, 'Major_Col3', 300, 'Data3');
alter system major freeze;
select count(*) as cnt from t_col_major;
cnt
3
select * from t_col_major order by id;
id	name	value	data
1	Major_Col1	100	Data1
50	Major_Col3	300	Data3
101	Major_Col2	200	Data2
# Fork 含有 CO SSTable 的列存表
fork table t_col_major to t_col_major_fork;
# 验证 fork 表也是列存
show create table t_col_major_fork;
Table	Create Table
t_col_major_fork	CREATE TABLE `t_col_major_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `data` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 验证数据完整性
select count(*) as cnt from t_col_major_fork;
cnt
3
select * from t_col_major_fork order by id;
id	name	value	data
1	Major_Col1	100	Data1
50	Major_Col3	300	Data3
101	Major_Col2	200	Data2
# 验证数据内容与源表一致
select a.id, a.name = b.name as name_eq, a.value = b.value as val_eq
from t_col_major a join t_col_major_fork b on a.id = b.id
order by a.id;
id	name_eq	val_eq
1	1	1
50	1	1
101	1	1
# 验证数据隔离
insert into t_col_major values (2, 'Src_After', 111, 'Src');
insert into t_col_major_fork values (2, 'Fork_After', 222, 'Fork');
select id, name, value from t_col_major where id = 2;
id	name	value
2	Src_After	111
select id, name, value from t_col_major_fork where id = 2;
id	name	value
2	Fork_After	222
drop table t_col_major;
drop table t_col_major_fork;
============================================
Case 3: 列存 Fork - 混合 SSTable（Major + Minor + Memtable）
============================================
drop table if exists t_col_mixed;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_mixed'
drop table if exists t_col_mixed_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_mixed_fork'
create table t_col_mixed (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(each column);
# Step 1: Major SSTable
insert into t_col_mixed values (1, 'Major1', 10), (101, 'Major2', 20);
alter system major freeze;
# Step 2: Minor SSTable
insert into t_col_mixed values (2, 'Minor1', 30), (102, 'Minor2', 40);
alter system minor freeze;
# Step 3: Memtable
insert into t_col_mixed values (3, 'Mem1', 50), (103, 'Mem2', 60);
select count(*) as cnt from t_col_mixed;
cnt
6
select * from t_col_mixed order by id;
id	name	value
1	Major1	10
2	Minor1	30
3	Mem1	50
101	Major2	20
102	Minor2	40
103	Mem2	60
# Fork 含多种 SSTable 的列存表
fork table t_col_mixed to t_col_mixed_fork;
# 验证 fork 表是列存
show create table t_col_mixed_fork;
Table	Create Table
t_col_mixed_fork	CREATE TABLE `t_col_mixed_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200)) WITH COLUMN GROUP(column_group_type)
# 验证所有数据（来自 Major、Minor、Memtable）均被正确 fork
select count(*) as cnt from t_col_mixed_fork;
cnt
6
select * from t_col_mixed_fork order by id;
id	name	value
1	Major1	10
2	Minor1	30
3	Mem1	50
101	Major2	20
102	Minor2	40
103	Mem2	60
# 验证数据一致性（行数相同）
select (select count(*) from t_col_mixed) = (select count(*) from t_col_mixed_fork) as data_consistent;
data_consistent
1
drop table t_col_mixed;
drop table t_col_mixed_fork;
============================================
Case 4: 列存 Fork - 分区表各分区数据验证
============================================
drop table if exists t_col_partition;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_partition'
drop table if exists t_col_partition_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_partition_fork'
create table t_col_partition (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (50),
partition p1 values less than (100),
partition p2 values less than (150),
partition p3 values less than (200)
) WITH COLUMN GROUP(each column);
insert into t_col_partition values (10, 'P0_1', 1), (20, 'P0_2', 2);
insert into t_col_partition values (60, 'P1_1', 3), (70, 'P1_2', 4);
insert into t_col_partition values (110, 'P2_1', 5), (120, 'P2_2', 6);
insert into t_col_partition values (160, 'P3_1', 7), (170, 'P3_2', 8);
# 落盘触发 CO SSTable
alter system major freeze;
select count(*) as cnt from t_col_partition;
cnt
8
select * from t_col_partition order by id;
id	name	value
10	P0_1	1
20	P0_2	2
60	P1_1	3
70	P1_2	4
110	P2_1	5
120	P2_2	6
160	P3_1	7
170	P3_2	8
fork table t_col_partition to t_col_partition_fork;
# 验证各分区数据完整
select count(*) as cnt from t_col_partition_fork;
cnt
8
select * from t_col_partition_fork order by id;
id	name	value
10	P0_1	1
20	P0_2	2
60	P1_1	3
70	P1_2	4
110	P2_1	5
120	P2_2	6
160	P3_1	7
170	P3_2	8
# 验证分区级别数据一致性
select a.id, a.name = b.name as name_eq, a.value = b.value as val_eq
from t_col_partition a join t_col_partition_fork b on a.id = b.id
order by a.id;
id	name_eq	val_eq
10	1	1
20	1	1
60	1	1
70	1	1
110	1	1
120	1	1
160	1	1
170	1	1
drop table t_col_partition;
drop table t_col_partition_fork;
============================================
Case 5: 列存 Fork - Fork 后 DDL 操作
============================================
drop table if exists t_col_ddl;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_ddl'
drop table if exists t_col_ddl_fork;
Warnings:
Note	1051	Unknown table 'db_fork_col_storage.t_col_ddl_fork'
create table t_col_ddl (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
) WITH COLUMN GROUP(each column);
insert into t_col_ddl values (1, 'DDL1', 100), (101, 'DDL2', 200), (50, 'DDL3', 300);
alter system major freeze;
fork table t_col_ddl to t_col_ddl_fork;
# 在源表添加列，不影响 fork 表
alter table t_col_ddl add column extra_src varchar(30) default 'src_default';
show create table t_col_ddl;
