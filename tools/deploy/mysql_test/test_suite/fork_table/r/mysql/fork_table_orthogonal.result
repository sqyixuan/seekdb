3. Online DDL：添加分区（fork前/中/后）
============================================
drop table if exists t_online_part;
Warnings:
Note	1051	Unknown table 'db_fork_orthogonal.t_online_part'
drop table if exists t_online_part_fork;
Warnings:
Note	1051	Unknown table 'db_fork_orthogonal.t_online_part_fork'
create table t_online_part (
id int primary key,
name varchar(20)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_online_part values (1, 'A');
insert into t_online_part values (101, 'B');
# fork前：源表添加分区
alter table t_online_part add partition (partition p_pre values less than (300));
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for part_signal execute 10000';
fork table t_online_part to t_online_part_fork;
# fork中：目标表添加分区（特殊标注，预期被阻塞）
# fork中：对fork表添加分区
alter table t_online_part_fork add partition (partition p_mid values less than (400));
ERROR HY000: Timeout
# fork中：对源表添加分区
alter table t_online_part add partition (partition p_mid_src values less than (350));
ERROR HY000: Timeout
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal part_signal';
# fork后：目标表添加分区
# fork后：对fork表添加分区
alter table t_online_part_fork add partition (partition p_post values less than (500));
show create table t_online_part_fork;
Table	Create Table
t_online_part_fork	CREATE TABLE `t_online_part_fork` (
  `id` int(11) NOT NULL,
  `name` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p_pre` values less than (300),
partition `p_post` values less than (500))
# fork后：对源表添加分区
alter table t_online_part add partition (partition p_post_src values less than (450));
show create table t_online_part;
