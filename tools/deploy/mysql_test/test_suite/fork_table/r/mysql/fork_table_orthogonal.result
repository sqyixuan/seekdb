rename table t_online_rename_fork to t_online_rename_fork_r;
select * from t_online_rename_fork_r;
id	name
1	A
rename table t_online_rename_fork_r to t_online_rename_fork;
# fork后：对源表改名
rename table t_online_rename to t_online_rename_src_post;
select * from t_online_rename_src_post;
id	name
1	A
rename table t_online_rename_src_post to t_online_rename;
