============================================
3. 复杂存储形态：Fork前中后都进行合并转储
============================================
drop table if exists t_complex3;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex3'
drop table if exists t_complex3_fork;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex3_fork'
create table t_complex3 (
id int primary key,
name varchar(50),
value int,
data text
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# Fork前：构造复杂存储形态
# 插入数据并触发major freeze（转储）
insert into t_complex3 values (1, 'PreMajor1', 10, repeat('A', 500));
insert into t_complex3 values (101, 'PreMajor2', 20, repeat('B', 500));
alter system major freeze;
# 验证Fork前major freeze后的数据
select count(*) as cnt from t_complex3;
cnt
2
select id, name, value, length(data) as data_len from t_complex3 order by id;
id	name	value	data_len
1	PreMajor1	10	500
101	PreMajor2	20	500
# Fork前：插入数据并触发minor freeze（转储）
# 注意：确保之前的数据已清理，避免主键冲突
delete from t_complex3 where id in (2, 102);
insert into t_complex3 values (2, 'PreMinor1', 100, repeat('C', 500));
insert into t_complex3 values (102, 'PreMinor2', 200, repeat('D', 500));
alter system minor freeze;
# 验证Fork前minor freeze后的数据
select count(*) as cnt from t_complex3;
cnt
4
select id, name, value, length(data) as data_len from t_complex3 order by id;
id	name	value	data_len
1	PreMajor1	10	500
2	PreMinor1	100	500
101	PreMajor2	20	500
102	PreMinor2	200	500
# 在fork开始前，先确保之前的merge已完成，并记录初始状态
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	0
# 设置debug sync point在FORK_TABLE_BUILD_DATA阶段暂停
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for complex_signal execute 10000';
# 执行Fork命令（会在BUILD_DATA阶段暂停）
fork table t_complex3 to t_complex3_fork;
# 等待fork进入BUILD_DATA阶段
# Fork中：对源表执行major freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
delete from t_complex3 where id in (4, 104);
insert into t_complex3 values (4, 'MidSrcMajor1', 300, repeat('E', 500));
insert into t_complex3 values (104, 'MidSrcMajor2', 400, repeat('F', 500));
alter system major freeze;
# 等待一小段时间，确保系统已经处理freeze命令并更新frozen_scn
# 验证Fork中源表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as src_cnt from t_complex3;
src_cnt
6
select id, name, value, length(data) as data_len from t_complex3 order by id;
id	name	value	data_len
1	PreMajor1	10	500
2	PreMinor1	100	500
4	MidSrcMajor1	300	500
101	PreMajor2	20	500
102	PreMinor2	200	500
104	MidSrcMajor2	400	500
# 验证major merge确实被阻塞
# 说明：执行alter system major freeze后，有两种可能的情况：
# 1. 如果frozen_scn != last_scn（merge_pending=1），说明新的freeze已设置，但merge尚未完成（被fork阻塞）
# 2. 如果frozen_scn == last_scn（merge_pending=0），可能是新的freeze还没有被处理（因为fork阻塞了freeze的处理）
# 无论哪种情况，都说明merge操作被阻塞，无法继续完成
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	MERGE_PENDING
# Fork中：对目标表执行major freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_complex3_fork values (10, 'MidForkMajor1', 1000, repeat('G', 500));
insert into t_complex3_fork values (110, 'MidForkMajor2', 2000, repeat('H', 500));
alter system major freeze;
Warnings:
Warning	4744	larger frozen_scn already exist, prev merge may not finish
# 验证Fork中目标表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as fork_cnt from t_complex3_fork;
fork_cnt
6
select id, name, value, length(data) as data_len from t_complex3_fork order by id;
id	name	value	data_len
1	PreMajor1	10	500
2	PreMinor1	100	500
10	MidForkMajor1	1000	500
101	PreMajor2	20	500
102	PreMinor2	200	500
110	MidForkMajor2	2000	500
# 再次验证major merge确实被阻塞
# 说明：执行alter system major freeze后，有两种可能的情况：
# 1. 如果frozen_scn != last_scn（merge_pending=1），说明新的freeze已设置，但merge尚未完成（被fork阻塞）
# 2. 如果frozen_scn == last_scn（merge_pending=0），可能是新的freeze还没有被处理（因为fork阻塞了freeze的处理）
# 无论哪种情况，都说明merge操作被阻塞，无法继续完成
select tenant_id, frozen_scn, last_scn, (frozen_scn != last_scn) as merge_pending from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = 1;
tenant_id	frozen_scn	last_scn	merge_pending
1	FROZEN_SCN	LAST_SCN	MERGE_PENDING
# Fork中：对源表执行minor freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
delete from t_complex3 where id in (5, 105);
insert into t_complex3 values (5, 'MidSrcMinor1', 500, repeat('I', 500));
insert into t_complex3 values (105, 'MidSrcMinor2', 600, repeat('J', 500));
alter system minor freeze;
# 验证Fork中源表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as src_cnt from t_complex3;
src_cnt
8
select id, name, value, length(data) as data_len from t_complex3 order by id;
id	name	value	data_len
1	PreMajor1	10	500
2	PreMinor1	100	500
4	MidSrcMajor1	300	500
5	MidSrcMinor1	500	500
101	PreMajor2	20	500
102	PreMinor2	200	500
104	MidSrcMajor2	400	500
105	MidSrcMinor2	600	500
# 验证minor merge确实被阻塞（存在is_active='NO'的memstore表示minor merge尚未完成）
select count(*) as pending_minor_merge from oceanbase.__all_virtual_memstore_info where is_active='NO';
pending_minor_merge
COUNT_VALUE
# Fork中：对目标表执行minor freeze命令（merge操作会被阻塞，等待fork完成后才能继续）
insert into t_complex3_fork values (11, 'MidForkMinor1', 3000, repeat('K', 500));
insert into t_complex3_fork values (111, 'MidForkMinor2', 4000, repeat('L', 500));
alter system minor freeze;
# 验证Fork中目标表数据（此时merge操作尚未完成，只是验证插入的数据）
select count(*) as fork_cnt from t_complex3_fork;
fork_cnt
8
select id, name, value, length(data) as data_len from t_complex3_fork order by id;
id	name	value	data_len
1	PreMajor1	10	500
2	PreMinor1	100	500
10	MidForkMajor1	1000	500
11	MidForkMinor1	3000	500
101	PreMajor2	20	500
102	PreMinor2	200	500
110	MidForkMajor2	2000	500
111	MidForkMinor2	4000	500
# 再次验证minor merge确实被阻塞（存在is_active='NO'的memstore表示minor merge尚未完成）
select count(*) as pending_minor_merge from oceanbase.__all_virtual_memstore_info where is_active='NO';
pending_minor_merge
COUNT_VALUE
# 继续Fork执行
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal complex_signal';
# 验证Fork完成后源表和目标表数据
select count(*) as src_cnt from t_complex3;
src_cnt
