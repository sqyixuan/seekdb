============================================
4. 复杂存储形态：更新和删除操作->合并转储->Fork
============================================
drop table if exists t_complex4;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex4'
drop table if exists t_complex4_fork;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex4_fork'
create table t_complex4 (
id int primary key,
name varchar(50),
value int,
data text
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# Step 1: 初始写入
insert into t_complex4 values (1, 'Init1', 10, repeat('A', 500));
insert into t_complex4 values (2, 'Init2', 20, repeat('B', 500));
insert into t_complex4 values (101, 'Init3', 30, repeat('C', 500));
insert into t_complex4 values (102, 'Init4', 40, repeat('D', 500));
# Step 2: Major freeze
alter system major freeze;
# Step 3: 更新和删除操作
update t_complex4 set value = 100, data = repeat('E', 500) where id = 1;
update t_complex4 set value = 200, data = repeat('F', 500) where id = 101;
delete from t_complex4 where id = 2;
# Step 4: Minor freeze
alter system minor freeze;
# Step 5: 继续写入
insert into t_complex4 values (3, 'AfterUpdate1', 300, repeat('G', 500));
insert into t_complex4 values (103, 'AfterUpdate2', 400, repeat('H', 500));
# 验证复杂操作后的数据
select count(*) as complex_cnt from t_complex4;
complex_cnt
5
select id, name, value, length(data) as data_len from t_complex4 order by id;
id	name	value	data_len
1	Init1	100	500
3	AfterUpdate1	300	500
101	Init3	200	500
102	Init4	40	500
103	AfterUpdate2	400	500
# Fork表（包含更新、删除后的多种存储形态）
fork table t_complex4 to t_complex4_fork;
# 验证Fork后源表和目标表数据完整性
select count(*) as src_cnt from t_complex4;
src_cnt
5
select count(*) as fork_cnt from t_complex4_fork;
fork_cnt
5
select id, name, value, length(data) as data_len from t_complex4 order by id;
id	name	value	data_len
1	Init1	100	500
3	AfterUpdate1	300	500
101	Init3	200	500
102	Init4	40	500
103	AfterUpdate2	400	500
select id, name, value, length(data) as data_len from t_complex4_fork order by id;
id	name	value	data_len
1	Init1	100	500
3	AfterUpdate1	300	500
101	Init3	200	500
102	Init4	40	500
103	AfterUpdate2	400	500
# 验证更新和删除操作的正确性
select * from t_complex4 where id = 1;
id	name	value	data
1	Init1	100	
select * from t_complex4_fork where id = 1;
id	name	value	data
1	Init1	100	
select * from t_complex4 where id = 2;
id	name	value	data
select * from t_complex4_fork where id = 2;
id	name	value	data
select * from t_complex4 where id = 101;
id	name	value	data
101	Init3	200	
select * from t_complex4_fork where id = 101;
id	name	value	data
101	Init3	200	
drop table t_complex4;
drop table t_complex4_fork;
