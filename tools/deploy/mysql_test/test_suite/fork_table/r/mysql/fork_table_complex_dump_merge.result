drop database if exists db_fork_complex_dump;
create database db_fork_complex_dump;
use db_fork_complex_dump;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
# 启用debug sync
alter system set debug_sync_timeout = '120s';
# 设置DDL超时为5秒
alter system set _ob_ddl_timeout = '50s';
set ob_global_debug_sync = 'reset';
# 加速major freeze
alter system set merger_check_interval = '10s' tenant sys;
alter system set ob_compaction_schedule_interval = '3s' tenant sys;
============================================
1. 复杂存储形态：合并->转储->写入->Fork
============================================
drop table if exists t_complex1;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex1'
drop table if exists t_complex1_fork;
Warnings:
Note	1051	Unknown table 'db_fork_complex_dump.t_complex1_fork'
create table t_complex1 (
id int primary key,
name varchar(50),
value int,
data text,
extra_info varchar(200)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300)
);
# Step 1: 初始写入数据
insert into t_complex1 values (1, 'Step1_Init1', 10, repeat('A', 500), 'Initial data');
insert into t_complex1 values (101, 'Step1_Init2', 20, repeat('B', 500), 'Initial data');
insert into t_complex1 values (201, 'Step1_Init3', 30, repeat('C', 500), 'Initial data');
# 验证Step1数据
select count(*) as step1_cnt from t_complex1;
step1_cnt
3
select id, name, value, length(data) as data_len from t_complex1 order by id;
id	name	value	data_len
1	Step1_Init1	10	500
101	Step1_Init2	20	500
201	Step1_Init3	30	500
# Step 2: 触发major freeze（合并）
alter system major freeze;
# 验证Step2 major freeze后的数据
select count(*) as step2_cnt from t_complex1;
step2_cnt
3
select id, name, value, length(data) as data_len from t_complex1 order by id;
id	name	value	data_len
1	Step1_Init1	10	500
101	Step1_Init2	20	500
201	Step1_Init3	30	500
# Step 3: 写入新数据
insert into t_complex1 values (2, 'Step3_New1', 100, repeat('D', 500), 'After major freeze');
insert into t_complex1 values (102, 'Step3_New2', 200, repeat('E', 500), 'After major freeze');
insert into t_complex1 values (202, 'Step3_New3', 300, repeat('F', 500), 'After major freeze');
# 验证Step3数据
select count(*) as step3_cnt from t_complex1;
step3_cnt
6
select id, name, value, length(data) as data_len from t_complex1 order by id;
id	name	value	data_len
1	Step1_Init1	10	500
2	Step3_New1	100	500
101	Step1_Init2	20	500
102	Step3_New2	200	500
201	Step1_Init3	30	500
202	Step3_New3	300	500
# Step 4: 触发minor freeze（转储）
alter system minor freeze;
# 验证Step4 minor freeze后的数据
select count(*) as step4_cnt from t_complex1;
step4_cnt
6
select id, name, value, length(data) as data_len from t_complex1 order by id;
id	name	value	data_len
1	Step1_Init1	10	500
2	Step3_New1	100	500
101	Step1_Init2	20	500
102	Step3_New2	200	500
201	Step1_Init3	30	500
202	Step3_New3	300	500
# Step 5: 继续写入数据（Memtable）
insert into t_complex1 values (3, 'Step5_Mem1', 400, repeat('G', 500), 'After minor freeze');
insert into t_complex1 values (103, 'Step5_Mem2', 500, repeat('H', 500), 'After minor freeze');
insert into t_complex1 values (203, 'Step5_Mem3', 600, repeat('I', 500), 'After minor freeze');
# 验证Step5数据（包含Major SSTable + Minor SSTable + Memtable）
select count(*) as step5_cnt from t_complex1;
step5_cnt
9
select id, name, value, length(data) as data_len from t_complex1 order by id;
id	name	value	data_len
1	Step1_Init1	10	500
2	Step3_New1	100	500
3	Step5_Mem1	400	500
101	Step1_Init2	20	500
102	Step3_New2	200	500
103	Step5_Mem2	500	500
201	Step1_Init3	30	500
202	Step3_New3	300	500
203	Step5_Mem3	600	500
# Step 6: Fork表（此时表包含多种存储形态）
fork table t_complex1 to t_complex1_fork;
# 验证Fork后源表和目标表数据完整性
select count(*) as src_cnt from t_complex1;
src_cnt
9
select count(*) as fork_cnt from t_complex1_fork;
fork_cnt
9
select id, name, value, length(data) as data_len, extra_info from t_complex1 order by id;
id	name	value	data_len	extra_info
1	Step1_Init1	10	500	Initial data
2	Step3_New1	100	500	After major freeze
3	Step5_Mem1	400	500	After minor freeze
101	Step1_Init2	20	500	Initial data
102	Step3_New2	200	500	After major freeze
103	Step5_Mem2	500	500	After minor freeze
201	Step1_Init3	30	500	Initial data
202	Step3_New3	300	500	After major freeze
203	Step5_Mem3	600	500	After minor freeze
