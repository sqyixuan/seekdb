drop database if exists db_fork_bypass;
create database db_fork_bypass;
use db_fork_bypass;
# 启用debug sync
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
# 准备数据文件目录
============================================
1. 全量旁路导入测试
============================================
# 1.0 提前设置短_ob_ddl_timeout，使1.3中「Fork中」LOAD DATA 在锁冲突时较快超时返回，
#      避免第一个（源表）卡住过久导致 debug_sync 释放、第二个无法在 fork 暂停期间执行
alter system set _ob_ddl_timeout = '5s';
# 1.1 Fork前：全量旁路导入到源表
drop table if exists t_full_bypass;
Warnings:
Note	1051	Unknown table 'db_fork_bypass.t_full_bypass'
drop table if exists t_full_bypass_fork;
Warnings:
Note	1051	Unknown table 'db_fork_bypass.t_full_bypass_fork'
create table t_full_bypass (
id int primary key,
name varchar(50),
value int,
data varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (300)
);
# 创建Fork前全量旁路导入数据文件
# 使用LOAD DATA进行全量旁路导入
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_pre.csv' into table t_full_bypass fields terminated by ',' lines terminated by '\n';
# 验证Fork前源表数据
select count(*) as cnt from t_full_bypass;
cnt
4
select * from t_full_bypass order by id;
id	name	value	data
1	Alice	100	Data1
2	Bob	200	Data2
3	Charlie	300	Data3
50	David	400	Data4
# 1.2 Fork表
fork table t_full_bypass to t_full_bypass_fork;
# 验证Fork后源表和目标表数据
select count(*) as src_cnt from t_full_bypass;
src_cnt
4
select count(*) as fork_cnt from t_full_bypass_fork;
fork_cnt
4
select * from t_full_bypass order by id;
id	name	value	data
1	Alice	100	Data1
2	Bob	200	Data2
3	Charlie	300	Data3
50	David	400	Data4
select * from t_full_bypass_fork order by id;
id	name	value	data
1	Alice	100	Data1
2	Bob	200	Data2
3	Charlie	300	Data3
50	David	400	Data4
# 1.3 Fork中：全量旁路导入到源表和目标表
# 创建新表用于Fork中测试
drop table if exists t_full_bypass_mid;
Warnings:
Note	1051	Unknown table 'db_fork_bypass.t_full_bypass_mid'
drop table if exists t_full_bypass_mid_fork;
Warnings:
Note	1051	Unknown table 'db_fork_bypass.t_full_bypass_mid_fork'
create table t_full_bypass_mid (
id int primary key,
name varchar(50),
value int,
data varchar(100)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (300)
);
# 创建初始数据文件
# 导入初始数据
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_mid_init.csv' into table t_full_bypass_mid fields terminated by ',' lines terminated by '\n';
# 验证初始数据
select count(*) as cnt from t_full_bypass_mid;
cnt
2
select * from t_full_bypass_mid order by id;
id	name	value	data
1	Init1	10	InitData1
101	Init2	20	InitData2
# 设置 debug sync point 在 FORK_TABLE_BUILD_DATA 阶段暂停（_ob_ddl_timeout 已在 1.0 设为 5s）
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for full_bypass_signal execute 10000';
# 创建Fork中全量旁路导入数据文件（源表）
# 创建Fork中全量旁路导入数据文件（目标表）没被锁
# 执行Fork命令（会在BUILD_DATA阶段暂停）
fork table t_full_bypass_mid to t_full_bypass_mid_fork;
# 等待fork进入BUILD_DATA阶段
# Fork中：全量旁路导入到源表（预期被阻塞，返回锁冲突）
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_mid_src.csv' into table t_full_bypass_mid fields terminated by ',' lines terminated by '\n';
ERROR HY000: Timeout
# 验证Fork中源表数据（LOAD DATA 被锁阻塞后超时 4012，数据未变化）
select count(*) as src_cnt from t_full_bypass_mid;
src_cnt
2
select * from t_full_bypass_mid order by id;
id	name	value	data
1	Init1	10	InitData1
101	Init2	20	InitData2
# Fork中：全量旁路导入到目标表（当前仅源表被锁，目标表未被锁，旁路导入可成功；若后续产品对目标表加锁则此处应返回 4012）
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_mid_fork.csv' into table t_full_bypass_mid_fork fields terminated by ',' lines terminated by '\n';
ERROR HY000: Timeout
# 验证Fork中目标表数据（目标表未被锁时已有新导入数据：初始 2 行 + 本次 2 行）
select count(*) as fork_cnt from t_full_bypass_mid_fork;
fork_cnt
2
select * from t_full_bypass_mid_fork order by id;
id	name	value	data
1	Init1	10	InitData1
101	Init2	20	InitData2
# 恢复_ob_ddl_timeout默认值
alter system set _ob_ddl_timeout = '5s';
# 继续Fork执行
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal full_bypass_signal';
# 验证Fork完成后源表和目标表数据
select count(*) as src_cnt from t_full_bypass_mid;
src_cnt
2
select count(*) as fork_cnt from t_full_bypass_mid_fork;
fork_cnt
2
select * from t_full_bypass_mid order by id;
id	name	value	data
1	Init1	10	InitData1
101	Init2	20	InitData2
select * from t_full_bypass_mid_fork order by id;
id	name	value	data
1	Init1	10	InitData1
101	Init2	20	InitData2
drop table t_full_bypass_mid;
drop table t_full_bypass_mid_fork;
# 1.4 Fork后：全量旁路导入到源表和目标表（使用1.2中fork的表）
# 创建Fork后全量旁路导入数据文件（源表）
# 创建Fork后全量旁路导入数据文件（目标表）
# Fork后：全量旁路导入到源表
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_post_src.csv' into table t_full_bypass fields terminated by ',' lines terminated by '\n';
# 验证Fork后源表数据（导入后）
select count(*) as src_cnt from t_full_bypass;
src_cnt
6
select * from t_full_bypass order by id;
id	name	value	data
1	Alice	100	Data1
2	Bob	200	Data2
3	Charlie	300	Data3
50	David	400	Data4
150	PostSrc1	1500	PostData1
151	PostSrc2	1600	PostData2
# Fork后：全量旁路导入到目标表
load data /*+ direct(true, 0) */ infile '\$OBSERVER_DIR/data_for_mysqltest_loaddata/full_bypass_post_fork.csv' into table t_full_bypass_fork fields terminated by ',' lines terminated by '\n';
# 验证Fork后目标表数据（导入后）
select count(*) as fork_cnt from t_full_bypass_fork;
fork_cnt
6
select * from t_full_bypass_fork order by id;
id	name	value	data
1	Alice	100	Data1
2	Bob	200	Data2
3	Charlie	300	Data3
50	David	400	Data4
199	PostFork1	1900	PostDataFork1
200	PostFork2	2000	PostDataFork2
drop table t_full_bypass;
drop table t_full_bypass_fork;
