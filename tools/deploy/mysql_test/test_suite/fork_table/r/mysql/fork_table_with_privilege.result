1	CrossDB_Src1	100	db_fork_other
101	CrossDB_Src2	200	db_fork_other
# 跨数据库fork: db_fork_other.t_cross_db_src -> db_fork_other2.t_cross_db_dst
fork table t_cross_db_src to db_fork_other2.t_cross_db_dst;
show create table t_cross_db_src;
