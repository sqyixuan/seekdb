============================================
5. fork关键字检查，不可作为变量名(p1)
============================================
# 5.1 尝试使用fork作为表名
# 注意：fork可能不是保留关键字，但作为DDL关键字，可能不能直接作为表名
# 测试使用fork作为表名（可能需要反引号）
create table `fork` (
id int primary key,
name varchar(50)
);
# 验证可以使用反引号创建fork表
select count(*) as cnt from `fork`;
cnt
0
insert into `fork` values (1, 'Test');
select * from `fork`;
id	name
1	Test
drop table `fork`;
# 5.2 尝试使用fork作为列名
create table t_keyword (
id int primary key,
`fork` varchar(50)
);
# 验证可以使用反引号创建fork列
insert into t_keyword values (1, 'ForkColumn');
select id, `fork` from t_keyword;
id	fork
1	ForkColumn
drop table t_keyword;
# 5.3 尝试使用fork作为变量名（在存储过程中）
# 创建存储过程，尝试使用fork作为变量名
CREATE PROCEDURE test_fork_keyword()
begin
declare `fork` int default 1;
select `fork` as fork_value;
end;
//
# 调用存储过程验证
call test_fork_keyword();
fork_value
1
# 清理存储过程
drop procedure if exists test_fork_keyword;
# 5.4 验证fork作为DDL关键字，在查询中可以使用反引号作为别名
create table t_keyword (
id int primary key,
name varchar(50)
);
insert into t_keyword values (1, 'Test');
# 使用反引号可以绕过关键字限制
select id as `fork` from t_keyword;
fork
1
# 验证fork关键字在DDL语句中的使用
# fork table是DDL关键字，不能作为普通标识符使用
# 但可以通过反引号绕过限制
drop table if exists t_keyword;
