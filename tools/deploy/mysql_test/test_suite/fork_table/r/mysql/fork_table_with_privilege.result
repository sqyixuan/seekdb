drop database if exists db_fork_other;
drop database if exists db_fork_other2;
drop user if exists 'test_user_a'@'%';
drop user if exists 'test_user_b'@'%';
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 多版本回收策略影响，undo_retention=0极端条件(p0)
============================================
# 设置undo_retention=0（极端条件）
alter system set undo_retention = 0;
drop table if exists t_undo_retention;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_undo_retention'
drop table if exists t_undo_retention_fork;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_undo_retention_fork'
create table t_undo_retention (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 插入初始数据
insert into t_undo_retention values (1, 'Init1', 100);
insert into t_undo_retention values (101, 'Init2', 200);
# 验证初始数据
select count(*) as cnt from t_undo_retention;
cnt
2
select * from t_undo_retention order by id;
id	name	value
1	Init1	100
101	Init2	200
# Fork表（在undo_retention=0的条件下）
# 注意：undo_retention=0可能导致fork table需要更长时间，增加超时时间
fork table t_undo_retention to t_undo_retention_fork;
# 验证Fork后源表数据
select count(*) as src_cnt from t_undo_retention;
src_cnt
2
select * from t_undo_retention order by id;
id	name	value
1	Init1	100
101	Init2	200
# 验证Fork后目标表数据
select count(*) as fork_cnt from t_undo_retention_fork;
fork_cnt
2
select * from t_undo_retention_fork order by id;
id	name	value
1	Init1	100
101	Init2	200
# 验证数据一致性
select (select count(*) from t_undo_retention) as src_cnt, (select count(*) from t_undo_retention_fork) as fork_cnt;
src_cnt	fork_cnt
2	2
# 在undo_retention=0条件下，继续对源表进行操作
insert into t_undo_retention values (50, 'AfterFork1', 150);
update t_undo_retention set value = 101 where id = 1;
# 验证源表数据更新
select count(*) as src_cnt from t_undo_retention;
src_cnt
3
select * from t_undo_retention order by id;
id	name	value
1	Init1	101
50	AfterFork1	150
101	Init2	200
# 验证目标表数据未受影响（数据隔离）
select count(*) as fork_cnt from t_undo_retention_fork;
fork_cnt
2
select * from t_undo_retention_fork order by id;
id	name	value
1	Init1	100
101	Init2	200
# 恢复undo_retention设置（使用默认值或合理值）
alter system set undo_retention = 1800;
drop table t_undo_retention;
drop table t_undo_retention_fork;
drop database if exists db_fork_other;
drop database if exists db_fork_other2;
drop user if exists 'test_user_a'@'%';
drop user if exists 'test_user_b'@'%';
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
2. 权限检查(p1)
============================================
# 2.1 用户对a表的权限是否带到a_fork表中
# 准备测试环境
create user 'test_user_a'@'%' identified by 'test123';
create user 'test_user_b'@'%' identified by 'test123';
drop table if exists t_perm_a;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_perm_a'
drop table if exists t_perm_a_fork;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_perm_a_fork'
create table t_perm_a (
id int primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_perm_a values (1, 'Data1', 100);
insert into t_perm_a values (101, 'Data2', 200);
# 首先检查test_user_a的初始权限（确保没有database级别的权限）
# 检查test_user_a对database的权限
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
# 验证test_user_a初始状态下对源表没有权限
# 注意：需要先授予USAGE权限才能连接到数据库，但USAGE权限不会自动授予表权限
grant usage on db_fork_other.* to 'test_user_a'@'%';
# 现在可以连接数据库，但验证对源表没有权限（预期失败）
connect(127.0.0.1,test_user_a@sys,test123,db_fork_other,2887,);
ERROR 42000: Access denied for user 'test_user_a'@'%' to database 'db_fork_other'
# 授予test_user_a对源表的SELECT和INSERT权限
grant select, insert on db_fork_other.t_perm_a to 'test_user_a'@'%';
# 再次检查test_user_a的权限（确认只有对源表的显式权限）
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
GRANT INSERT, SELECT ON `db_fork_other`.`t_perm_a` TO 'test_user_a'
# 验证test_user_a对源表的权限
select count(*) as cnt from t_perm_a;
cnt
2
select * from t_perm_a order by id;
id	name	value
1	Data1	100
101	Data2	200
# 使用root用户执行Fork操作
fork table t_perm_a to t_perm_a_fork;
# Fork后再次检查test_user_a的权限（确认权限没有变化）
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
GRANT INSERT, SELECT ON `db_fork_other`.`t_perm_a` TO 'test_user_a'
# 验证test_user_a对源表的权限仍然有效
select count(*) as cnt from t_perm_a;
cnt
2
select * from t_perm_a order by id;
id	name	value
1	Data1	100
101	Data2	200
# 验证test_user_a对fork表的权限（权限不应自动迁移）
select * from t_perm_a_fork order by id;
ERROR 42000: SELECT command denied to user 'test_user_a'@'%' for table 't_perm_a_fork'
# 结论：用户对源表的权限不会自动带到fork表中
============================================
# 2.2 用户未显式授权，是否对本用户fork的表拥有权限
============================================
# test_user_a自己fork表
# 清理环境
drop table if exists t_self_fork;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_self_fork'
drop table if exists t_self_fork_fork;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_self_fork_fork'
# 重新建立干净的连接以确保权限状态
# 重新连接root用户，确保权限授予的准确性
# 重要修改：清理之前的权限，重新授予最小权限（为2.2准备「仅USAGE+CREATE TABLE」的干净起点）
# 仅收回2.1的表级权限（t_perm_a）；不执行revoke usage on db_fork_other.*，因部分环境会报5133且对2.2结论无影响，后续grant会得到USAGE+CREATE TABLE
revoke insert, select on db_fork_other.t_perm_a from 'test_user_a'@'%';
grant usage on db_fork_other.* to 'test_user_a'@'%';
# 关键修改：授予库级CREATE权限（OceanBase 库级仅支持 CREATE，不支持 create table 语法）
grant create on db_fork_other.* to 'test_user_a'@'%';
# 重新连接test_user_a
# 验证test_user_a的当前权限状态
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
GRANT CREATE ON `db_fork_other`.* TO 'test_user_a'
# test_user_a创建表
create table t_self_fork (
id int primary key,
name varchar(50)
) partition by range(id) (
partition p0 values less than (100)
);
# 授予对源表的INSERT和SELECT权限（由root用户执行）
grant insert, select on db_fork_other.t_self_fork to 'test_user_a'@'%';
# Fork前检查test_user_a的权限（确认只有对源表的显式权限）
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
GRANT CREATE ON `db_fork_other`.* TO 'test_user_a'
GRANT INSERT, SELECT ON `db_fork_other`.`t_self_fork` TO 'test_user_a'
# 切换到test_user_a执行数据操作
insert into t_self_fork values (1, 'Self1');
insert into t_self_fork values (50, 'Self2');
# 验证对源表的权限
select * from t_self_fork order by id;
id	name
1	Self1
50	Self2
# 检查当前权限详情
SELECT 
TABLE_SCHEMA,
TABLE_NAME, 
PRIVILEGE_TYPE,
GRANTEE
FROM information_schema.TABLE_PRIVILEGES 
WHERE GRANTEE LIKE '%test_user_a%' 
AND TABLE_SCHEMA = 'db_fork_other'
ORDER BY TABLE_NAME, PRIVILEGE_TYPE;
TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	GRANTEE
db_fork_other	t_self_fork	INSERT	'test_user_a'@'%'
db_fork_other	t_self_fork	SELECT	'test_user_a'@'%'
# test_user_a自己执行fork操作
fork table t_self_fork to t_self_fork_fork;
# Fork后立即检查权限状态
show grants for 'test_user_a'@'%';
Grants for test_user_a@%
GRANT USAGE ON *.* TO 'test_user_a'
GRANT CREATE ON `db_fork_other`.* TO 'test_user_a'
GRANT INSERT, SELECT ON `db_fork_other`.`t_self_fork` TO 'test_user_a'
# 检查FORK表的权限分布
SELECT 
TABLE_SCHEMA,
TABLE_NAME, 
PRIVILEGE_TYPE,
GRANTEE
FROM information_schema.TABLE_PRIVILEGES 
WHERE TABLE_SCHEMA = 'db_fork_other'
AND TABLE_NAME LIKE 't_self_fork%'
ORDER BY TABLE_NAME, GRANTEE, PRIVILEGE_TYPE;
TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	GRANTEE
db_fork_other	t_self_fork	INSERT	'test_user_a'@'%'
db_fork_other	t_self_fork	SELECT	'test_user_a'@'%'
# 验证test_user_a对自己fork的表是否有权限（预期应该失败）
select * from t_self_fork_fork order by id;
ERROR 42000: SELECT command denied to user 'test_user_a'@'%' for table 't_self_fork_fork'
# 2.3 用户A对用户B的表是否支持fork，授权create后是否支持fork？
drop table if exists t_user_b;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_user_b'
drop table if exists t_user_b_fork;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_user_b_fork'
# 使用test_user_b真实创建表（用户B的表）
# 授予test_user_b对数据库的CREATE、INSERT、SELECT权限（用于创建表和插入数据）
grant create, insert, select on db_fork_other.* to 'test_user_b'@'%';
# 创建test_user_b的连接
create table t_user_b (
id int primary key,
name varchar(50),
owner varchar(50) default 'user_b'
) partition by range(id) (
partition p0 values less than (100)
);
insert into t_user_b values (1, 'UserB_Data1', 'user_b');
insert into t_user_b values (50, 'UserB_Data2', 'user_b');
# 测试场景1：只有CREATE权限，没有SELECT权限
# 只授予test_user_a的CREATE权限（不授予SELECT权限）
grant create on db_fork_other.* to 'test_user_a'@'%';
# 重新连接以确保权限生效
# test_user_a尝试fork用户B的表（只有CREATE权限）
fork table t_user_b to t_user_b_fork;
ERROR 42000: SELECT command denied to user 'test_user_a'@'%' for table 't_user_b'
# 使用root授予test_user_a对db_fork_other的SELECT权限后，test_user_a才能fork用户B的表
grant select on db_fork_other.* to 'test_user_a'@'%';
# 重连test_user_a以使新权限生效，再执行一次fork
fork table t_user_b to t_user_b_fork;
# 验证fork操作成功（只要有CREATE权限就可以fork）
select count(*) as cnt from t_user_b_fork;
cnt
2
select * from t_user_b_fork order by id;
id	name	owner
1	UserB_Data1	user_b
50	UserB_Data2	user_b
# 验证test_user_a对fork表的权限（需要显式授权）
# 授予test_user_a对fork表的SELECT权限
# 验证授权后可以访问
# 结论：用户A对用户B的表，只要有CREATE权限就可以fork，但fork后需要显式授权才能访问
# 清理权限测试相关表
drop table if exists t_user_b;
drop user 'test_user_a'@'%';
drop user 'test_user_b'@'%';
drop table if exists t_perm_a, t_perm_a_fork, t_self_fork, t_self_fork_fork;
drop database db_fork_other;
drop database db_fork_other2;
============================================
3. 链式fork以及并行fork验证，检查各级目标表都相互独立(p1)
============================================
# 重建库供 section 3 及后续跨库 fork（section 2 结尾已 drop db_fork_other/db_fork_other2）
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;
# 3.1 链式fork验证（A -> B -> C）
drop table if exists t_chain_a;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_chain_a'
drop table if exists t_chain_b;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_chain_b'
drop table if exists t_chain_c;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_chain_c'
create table t_chain_a (
id int primary key,
name varchar(50),
value int,
level varchar(10) default 'A'
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_chain_a values (1, 'Chain_A1', 100, 'A');
insert into t_chain_a values (101, 'Chain_A2', 200, 'A');
# 第一次fork: A -> B
fork table t_chain_a to t_chain_b;
# 验证第一次fork
select * from t_chain_a order by id;
id	name	value	level
1	Chain_A1	100	A
101	Chain_A2	200	A
select * from t_chain_b order by id;
id	name	value	level
1	Chain_A1	100	A
101	Chain_A2	200	A
# 第二次fork: B -> C
fork table t_chain_b to t_chain_c;
# 验证第二次fork
show create table t_chain_a;
