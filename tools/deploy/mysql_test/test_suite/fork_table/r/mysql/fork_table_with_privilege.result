4. 跨数据库fork表(p1)
============================================
drop table if exists t_cross_db_src;
Warnings:
Note	1051	Unknown table 'db_fork_other.t_cross_db_src'
drop table if exists db_fork_other2.t_cross_db_dst;
Warnings:
Note	1051	Unknown table 'db_fork_other2.t_cross_db_dst'
# 在db_fork_other数据库中创建源表
use db_fork_other;
create table t_cross_db_src (
id int primary key,
name varchar(50),
value int,
db_name varchar(50) default 'db_fork_other'
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_cross_db_src values (1, 'CrossDB_Src1', 100, 'db_fork_other');
insert into t_cross_db_src values (101, 'CrossDB_Src2', 200, 'db_fork_other');
