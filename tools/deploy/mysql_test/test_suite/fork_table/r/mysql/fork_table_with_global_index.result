9. Global Index with Range Columns
============================================
drop table if exists t15;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t15'
drop table if exists t15_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t15_fork'
create table t15 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建全局索引（使用 range columns）
create index gidx_cd on t15(c, d) global partition by range columns(c, d) (
partition p0 values less than (100, 'M'),
partition p1 values less than (MAXVALUE, MAXVALUE)
);
insert into t15 values (1, 'Alice', 10, 'data1');
insert into t15 values (101, 'Bob', 110, 'data2');
insert into t15 values (50, 'Charlie', 50, 'data3');
# Fork表
fork table t15 to t15_fork;
# 验证Fork表的全局索引（range columns）
show create table t15_fork;
Table	Create Table
t15_fork	CREATE TABLE `t15_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `gidx_cd` (`c`, `d`) BLOCK_SIZE 16384 GLOBAL
 partition by range columns(c, d)
(partition `p0` values less than (100,'M'),
partition `p1` values less than (MAXVALUE,MAXVALUE))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证通过全局索引（range columns）查询
select * from t15_fork where c = 10 and d = 'data1';
a	b	c	d
1	Alice	10	data1
select * from t15_fork where c = 110 and d = 'data2';
a	b	c	d
101	Bob	110	data2
