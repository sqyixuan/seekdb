6. Random Index Creation Order Test
============================================
# 测试索引创建顺序随机，验证Fork表索引顺序一致性
drop table if exists t12;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t12'
drop table if exists t12_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t12_fork'
create table t12 (
a int,
b varchar(150),
c int,
d varchar(4000),
e int,
f varchar(100),
g int,
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 随机顺序创建多个索引（局部/全局混合）
# 顺序：全局 -> 局部 -> 全局 -> 局部 -> 全局 -> 局部
create index gidx_c on t12(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
create index lidx_d on t12(d) local;
create index gidx_e on t12(e) global;
create index lidx_f on t12(f) local;
create index gidx_g on t12(g) global partition by range(g) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
create index lidx_cd on t12(c, d) local;
insert into t12 values (1, 'Alice', 10, 'data1', 100, 'field1', 50);
insert into t12 values (101, 'Bob', 110, 'data2', 200, 'field2', 150);
insert into t12 values (50, 'Charlie', 50, 'data3', 150, 'field3', 75);
# Fork表
fork table t12 to t12_fork;
# 验证Fork表的索引结构（验证索引顺序一致性）
show create table t12_fork;
Table	Create Table
t12_fork	CREATE TABLE `t12_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  `e` int(11) DEFAULT NULL,
  `f` varchar(100) DEFAULT NULL,
  `g` int(11) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `gidx_c` (`c`) BLOCK_SIZE 16384 GLOBAL
 partition by range(c)
(partition `p0` values less than (100),
partition `p1` values less than (MAXVALUE)),
  KEY `lidx_d` (`d`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_e` (`e`) BLOCK_SIZE 16384 GLOBAL
 ,
  KEY `lidx_f` (`f`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_g` (`g`) BLOCK_SIZE 16384 GLOBAL
 partition by range(g)
(partition `p0` values less than (100),
partition `p1` values less than (MAXVALUE)),
  KEY `lidx_cd` (`c`, `d`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
