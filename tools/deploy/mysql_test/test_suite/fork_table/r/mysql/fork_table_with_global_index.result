 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证所有索引查询功能
select * from t4_fork where c = 10;
a	b	c	d
1	Alice	10	data1
select * from t4_fork where d = 'data1';
