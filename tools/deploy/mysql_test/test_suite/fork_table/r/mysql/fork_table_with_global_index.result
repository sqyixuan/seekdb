create table t14 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300)
);
# 创建全局索引（多个分区）
create index gidx_c on t14(c) global partition by range(c) (
partition p0 values less than (50),
partition p1 values less than (100),
partition p2 values less than (150),
partition p3 values less than MAXVALUE
);
insert into t14 values (1, 'Alice', 10, 'data1');
insert into t14 values (101, 'Bob', 110, 'data2');
insert into t14 values (201, 'Charlie', 210, 'data3');
insert into t14 values (50, 'David', 50, 'data4');
insert into t14 values (150, 'Eve', 150, 'data5');
# Fork表
fork table t14 to t14_fork;
# 验证Fork表全局索引分区结构
select count(*) from oceanbase.__all_virtual_part where table_id = gidx_id;
count(*)
4
select part_name, high_bound_val from oceanbase.__all_virtual_part where table_id = gidx_id order by part_id;
part_name	high_bound_val
p0	50
p1	100
p2	150
p3	MAXVALUE
# 验证全局索引各分区的查询功能
select * from t14_fork where c = 10;
a	b	c	d
1	Alice	10	data1
select * from t14_fork where c = 50;
a	b	c	d
50	David	50	data4
select * from t14_fork where c = 110;
a	b	c	d
101	Bob	110	data2
select * from t14_fork where c = 150;
a	b	c	d
150	Eve	150	data5
select * from t14_fork where c = 210;
a	b	c	d
201	Charlie	210	data3
