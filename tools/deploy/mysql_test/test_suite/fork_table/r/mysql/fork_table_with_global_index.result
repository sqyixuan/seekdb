7. Global Index Isolation Test
============================================
# 验证Fork表全局索引修改不影响源表
drop table if exists t13;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t13'
drop table if exists t13_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t13_fork'
create table t13 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
create index gidx_c on t13(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
insert into t13 values (1, 'Alice', 10, 'data1');
insert into t13 values (101, 'Bob', 110, 'data2');
insert into t13 values (50, 'Charlie', 50, 'data3');
# Fork表
fork table t13 to t13_fork;
# 在Fork表中插入数据并验证全局索引
insert into t13_fork values (99, 'Fork_New', 90, 'fork_data');
select * from t13_fork where c = 90;
a	b	c	d
99	Fork_New	90	fork_data
# 验证源表全局索引不受影响
select * from t13 where c = 90;
a	b	c	d
# 在源表中插入数据并验证全局索引
insert into t13 values (88, 'Source_New', 80, 'source_data');
select * from t13 where c = 80;
a	b	c	d
88	Source_New	80	source_data
# 验证Fork表全局索引不受影响
select * from t13_fork where c = 80;
a	b	c	d
# 修改Fork表中的数据并验证全局索引
update t13_fork set c = 95 where a = 1;
select * from t13_fork where c = 95;
a	b	c	d
1	Alice	95	data1
# 验证源表全局索引不受影响
select * from t13 where c = 95;
a	b	c	d
# 修改源表中的数据并验证全局索引
update t13 set c = 85 where a = 50;
select * from t13 where c = 85;
a	b	c	d
50	Charlie	85	data3
# 验证Fork表全局索引不受影响
select * from t13_fork where c = 85;
a	b	c	d
