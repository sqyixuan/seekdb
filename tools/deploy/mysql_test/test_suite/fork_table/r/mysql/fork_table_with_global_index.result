drop database if exists db_fork_global_index;
create database db_fork_global_index;
use db_fork_global_index;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. Fork Table with Single Global Index
============================================
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t1'
drop table if exists t1_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t1_fork'
create table t1 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300)
);
# 创建全局索引
create index gidx_c on t1(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than MAXVALUE
);
insert into t1 values (1, 'Alice', 10, 'data1');
insert into t1 values (101, 'Bob', 110, 'data2');
insert into t1 values (201, 'Charlie', 210, 'data3');
insert into t1 values (50, 'David', 50, 'data4');
insert into t1 values (150, 'Eve', 150, 'data5');
# Fork表
fork table t1 to t1_fork;
# 验证Fork表的全局索引结构
show create table t1_fork;
Table	Create Table
t1_fork	CREATE TABLE `t1_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `gidx_c` (`c`) BLOCK_SIZE 16384 GLOBAL
 partition by range(c)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p2` values less than (MAXVALUE))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p2` values less than (300))
# 验证全局索引分区结构
select count(*) from oceanbase.__all_virtual_part where table_id = gidx_id;
count(*)
3
select part_name, high_bound_val from oceanbase.__all_virtual_part where table_id = gidx_id order by part_id;
part_name	high_bound_val
p0	100
p1	200
p2	MAXVALUE
# 验证通过全局索引查询
select * from t1_fork where c = 10;
a	b	c	d
1	Alice	10	data1
select * from t1_fork where c = 110;
a	b	c	d
101	Bob	110	data2
select * from t1_fork where c = 210;
a	b	c	d
201	Charlie	210	data3
# 验证全局索引查询计划
explain select * from t1_fork where c = 10;
Query Plan
=======================================================================
|ID|OPERATOR                    |NAME           |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |DISTRIBUTED TABLE RANGE SCAN|t1_fork(gidx_c)|1       |31          |
=======================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1_fork.a], [t1_fork.b], [t1_fork.c], [t1_fork.d]), filter(nil), rowset=16
      access([t1_fork.a], [t1_fork.b], [t1_fork.c], [t1_fork.d]), partitions(p0)
      is_index_back=true, is_global_index=true, 
      range_key([t1_fork.c], [t1_fork.a], [t1_fork.b]), range(10,MIN,MIN ; 10,MAX,MAX), 
      range_cond([t1_fork.c = 10])
============================================
2. Fork Table with Multiple Global Indexes
============================================
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t2'
drop table if exists t2_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t2_fork'
create table t2 (
a int,
b varchar(150),
c int,
d varchar(4000),
e int,
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建多个全局索引
create index gidx_c on t2(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
create index gidx_d on t2(d) global partition by range columns(d) (
partition p0 values less than ('M'),
partition p1 values less than MAXVALUE
);
create index gidx_e on t2(e) global;
insert into t2 values (1, 'Alice', 10, 'data1', 100);
insert into t2 values (101, 'Bob', 110, 'data2', 200);
insert into t2 values (50, 'Charlie', 50, 'data3', 150);
# Fork表
fork table t2 to t2_fork;
# 验证Fork表的多个全局索引
show create table t2_fork;
Table	Create Table
t2_fork	CREATE TABLE `t2_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  `e` int(11) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `gidx_c` (`c`) BLOCK_SIZE 16384 GLOBAL
 partition by range(c)
(partition `p0` values less than (100),
partition `p1` values less than (MAXVALUE)),
  KEY `gidx_d` (`d`) BLOCK_SIZE 16384 GLOBAL
 partition by range columns(d)
(partition `p0` values less than ('M'),
partition `p1` values less than (MAXVALUE)),
  KEY `gidx_e` (`e`) BLOCK_SIZE 16384 GLOBAL
 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证所有全局索引查询功能
select * from t2_fork where c = 10;
a	b	c	d	e
1	Alice	10	data1	100
select * from t2_fork where d = 'data1';
a	b	c	d	e
1	Alice	10	data1	100
select * from t2_fork where e = 100;
a	b	c	d	e
1	Alice	10	data1	100
============================================
3. Global Index + Local Index Combination
============================================
# 3.1 先创建局部索引，后创建全局索引
drop table if exists t3;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t3'
drop table if exists t3_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t3_fork'
create table t3 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 先创建局部索引
create index lidx_c on t3(c) local;
create index lidx_d on t3(d) local;
# 后创建全局索引
create index gidx_c on t3(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
insert into t3 values (1, 'Alice', 10, 'data1');
insert into t3 values (101, 'Bob', 110, 'data2');
insert into t3 values (50, 'Charlie', 50, 'data3');
# Fork表
fork table t3 to t3_fork;
# 验证Fork表的索引结构（局部+全局）
show create table t3_fork;
Table	Create Table
t3_fork	CREATE TABLE `t3_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `lidx_c` (`c`) BLOCK_SIZE 16384 LOCAL,
  KEY `lidx_d` (`d`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_c` (`c`) BLOCK_SIZE 16384 GLOBAL
 partition by range(c)
(partition `p0` values less than (100),
partition `p1` values less than (MAXVALUE))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证局部索引查询
select * from t3_fork where c = 10;
a	b	c	d
1	Alice	10	data1
select * from t3_fork where d = 'data1';
a	b	c	d
1	Alice	10	data1
# 验证全局索引查询
select * from t3_fork where c = 110;
a	b	c	d
101	Bob	110	data2
# 3.2 先创建全局索引，后创建局部索引
drop table if exists t4;
Warnings:
