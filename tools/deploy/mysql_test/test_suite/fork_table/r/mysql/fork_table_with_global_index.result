============================================
5. Global Index + Composite Index Combination
============================================
# 5.1 全局复合索引
drop table if exists t9;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t9'
drop table if exists t9_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t9_fork'
create table t9 (
a int,
b varchar(150),
c int,
d varchar(4000),
e int,
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建全局复合索引
create index gidx_cd on t9(c, d) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
insert into t9 values (1, 'Alice', 10, 'data1', 100);
insert into t9 values (101, 'Bob', 110, 'data2', 200);
insert into t9 values (50, 'Charlie', 50, 'data3', 150);
# Fork表
fork table t9 to t9_fork;
# 验证Fork表的全局复合索引
show create table t9_fork;
