partition p0 values less than (100),
partition p1 values less than (200)
);
# 先创建全局索引
create index gidx_c on t4(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
# 后创建局部索引
create index lidx_d on t4(d) local;
create index lidx_c on t4(c) local;
insert into t4 values (1, 'Alice', 10, 'data1');
