# 3.3 混合创建索引（局部、全局、局部、全局...）
drop table if exists t5;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t5'
drop table if exists t5_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t5_fork'
create table t5 (
a int,
b varchar(150),
c int,
d varchar(4000),
e int,
f varchar(100),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 混合创建索引顺序：局部 -> 全局 -> 局部 -> 全局
create index lidx_c on t5(c) local;
create index gidx_d on t5(d) global partition by range columns(d) (
partition p0 values less than ('M'),
partition p1 values less than MAXVALUE
);
create index lidx_e on t5(e) local;
create index gidx_f on t5(f) global;
insert into t5 values (1, 'Alice', 10, 'data1', 100, 'field1');
insert into t5 values (101, 'Bob', 110, 'data2', 200, 'field2');
insert into t5 values (50, 'Charlie', 50, 'data3', 150, 'field3');
# Fork表
fork table t5 to t5_fork;
# 验证Fork表的混合索引结构
show create table t5_fork;
Table	Create Table
t5_fork	CREATE TABLE `t5_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  `e` int(11) DEFAULT NULL,
  `f` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  KEY `lidx_c` (`c`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_d` (`d`) BLOCK_SIZE 16384 GLOBAL
 partition by range columns(d)
(partition `p0` values less than ('M'),
partition `p1` values less than (MAXVALUE)),
  KEY `lidx_e` (`e`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_f` (`f`) BLOCK_SIZE 16384 GLOBAL
 
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证所有索引查询功能
select * from t5_fork where c = 10;
a	b	c	d	e	f
1	Alice	10	data1	100	field1
select * from t5_fork where d = 'data1';
a	b	c	d	e	f
1	Alice	10	data1	100	field1
select * from t5_fork where e = 100;
a	b	c	d	e	f
1	Alice	10	data1	100	field1
select * from t5_fork where f = 'field1';
a	b	c	d	e	f
1	Alice	10	data1	100	field1
============================================
4. Global Index + Unique Index Combination
============================================
# 4.1 全局唯一索引
drop table if exists t6;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t6'
drop table if exists t6_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t6_fork'
create table t6 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建全局唯一索引
create unique index gidx_uk_c on t6(c) global partition by range(c) (
partition p0 values less than (100),
partition p1 values less than MAXVALUE
);
insert into t6 values (1, 'Alice', 10, 'data1');
insert into t6 values (101, 'Bob', 110, 'data2');
insert into t6 values (50, 'Charlie', 50, 'data3');
# Fork表
fork table t6 to t6_fork;
# 验证Fork表的全局唯一索引
show create table t6_fork;
Table	Create Table
t6_fork	CREATE TABLE `t6_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  UNIQUE KEY `gidx_uk_c` (`c`) BLOCK_SIZE 16384 GLOBAL
 partition by range(c)
(partition `p0` values less than (100),
partition `p1` values less than (MAXVALUE))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证全局唯一索引约束在Fork表中独立
insert into t6_fork values (2, 'Alice2', 10, 'data2');
ERROR 23000: Duplicate entry '10' for key 'gidx_uk_c'
# 在Fork表中插入新的唯一值
insert into t6_fork values (2, 'Alice2', 20, 'data2');
# 验证源表的唯一约束仍然有效（fork操作不影响源表约束）
insert into t6 values (3, 'Alice3', 10, 'data3');
ERROR 23000: Duplicate entry '10' for key 'gidx_uk_c'
# 4.2 局部唯一索引 + 全局普通索引
drop table if exists t7;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t7'
drop table if exists t7_fork;
Warnings:
Note	1051	Unknown table 'db_fork_global_index.t7_fork'
create table t7 (
a int,
b varchar(150),
c int,
d varchar(4000),
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200)
);
# 创建局部唯一索引（必须包含分区键a）
create unique index lidx_uk_c on t7(a, c) local;
# 创建全局普通索引
create index gidx_d on t7(d) global partition by range columns(d) (
partition p0 values less than ('M'),
partition p1 values less than MAXVALUE
);
insert into t7 values (1, 'Alice', 10, 'data1');
insert into t7 values (101, 'Bob', 110, 'data2');
# Fork表
fork table t7 to t7_fork;
# 验证Fork表的索引结构
show create table t7_fork;
Table	Create Table
t7_fork	CREATE TABLE `t7_fork` (
  `a` int(11) NOT NULL,
  `b` varchar(150) NOT NULL,
  `c` int(11) DEFAULT NULL,
  `d` varchar(4000) DEFAULT NULL,
  PRIMARY KEY (`a`, `b`),
  UNIQUE KEY `lidx_uk_c` (`a`, `c`) BLOCK_SIZE 16384 LOCAL,
  KEY `gidx_d` (`d`) BLOCK_SIZE 16384 GLOBAL
 partition by range columns(d)
(partition `p0` values less than ('M'),
partition `p1` values less than (MAXVALUE))
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
# 验证局部唯一索引约束（(a, c)组合唯一）
insert into t7_fork values (1, 'Alice2', 10, 'data2');
ERROR 23000: Duplicate entry '1-10' for key 'lidx_uk_c'
# 验证全局索引查询
select * from t7_fork where d = 'data1';
a	b	c	d
1	Alice	10	data1
