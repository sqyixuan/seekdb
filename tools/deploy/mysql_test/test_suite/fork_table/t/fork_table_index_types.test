--echo ============================================
--echo 10. 语义索引（Semantic Index）
--echo ============================================

--echo # 10.1 随表创建语义索引
drop table if exists t_semantic_with_index;
drop table if exists t_semantic_with_index_fork;

--error 1064
CREATE TABLE t_semantic_with_index (
    id int primary key,
    name varchar(50),
    text_embedding vector(768),
    VECTOR INDEX idx_semantic(text_embedding)
    WITH (
        distance=cosine,
        lib=vsag,
        type=hnsw,
        model="mymodel",  
        dim=768,
        sync_mode=immediate
    )
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);


