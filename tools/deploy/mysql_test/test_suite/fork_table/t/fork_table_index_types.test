drop table if exists t_spiv_complex;
drop table if exists t_spiv_complex_fork;
--echo # 创建带额外字段的稀疏向量表
create table t_spiv_complex (
    id int primary key,
    name varchar(50),
    features sparsevector,
    created_time timestamp default current_timestamp
);
--echo # 插入数据并测试Fork
insert into t_spiv_complex (id, name, features) values 
(1, 'Document1', '{0:0.8, 5:0.6, 10:0.9, 50:0.7}'),
(2, 'Document2', '{1:0.7, 6:0.8, 11:0.5, 51:0.9}'),
(3, 'Document3', '{2:0.9, 7:0.4, 12:0.8, 52:0.6}'),
(4, 'Document4', '{3:0.6, 8:0.9, 13:0.7, 53:0.8}'),
(101, 'Document5', '{4:0.8, 9:0.7, 14:0.9, 54:0.5}'),
(50, 'Document6', '{5:0.7, 10:0.8, 15:0.6, 55:0.9}');
fork table t_spiv_complex to t_spiv_complex_fork;
--echo # 验证复杂表Fork
select count(*) as cnt from t_spiv_complex_fork;
select id, name, features from t_spiv_complex_fork order by id;
--echo # 稀疏向量操作测试（只使用支持的基本操作）
--echo # 1. 基本SELECT查询
select id, name, features from t_spiv_complex_fork where id = 1;
--echo # 2. 范围查询
select id, name, features from t_spiv_complex_fork where id between 1 and 3 order by id;
--echo # 3. 名称模式查询
select id, name, features from t_spiv_complex_fork where name like 'Document%' order by id;
--echo # 4. 排序查询
select id, name from t_spiv_complex_fork order by name;
--echo # 5. 统计查询
select count(*) as total_docs, 
       min(id) as min_id, 
       max(id) as max_id,
       count(distinct name) as unique_names
from t_spiv_complex_fork;
--echo # 稀疏向量更新测试
update t_spiv_complex_fork set name = 'Updated_Doc1' where id = 1;
--echo # 验证更新结果
select id, name, features from t_spiv_complex_fork where id = 1;

--echo # 验证源表数据未受影响
select id, name, features from t_spiv_complex where id = 1;

--echo # 11.7 边界值测试
insert into t_spiv_basic values (8, '{}'); 

--echo # 测试单元素稀疏向量
insert into t_spiv_basic_fork values (9, '{1000:1.0}');  

--echo # 验证边界值数据
select id, sv from t_spiv_basic where id in (8);

select '边界值测试 - Fork表:' as test_type;
select id, sv from t_spiv_basic_fork where id in (9);

--echo # 11.8 稀疏向量查询功能测试
--echo # 基本查询功能
select id, sv from t_spiv_basic_fork where id between 1 and 3 order by id;

--echo # 按向量特性查询（如果支持）

--echo # 11.9 性能对比测试（数据量较大时）
insert into t_spiv_basic_fork values 
(10, '{6:1.1, 60:2.1, 600:3.1}'),
(11, '{7:1.2, 70:2.2, 700:3.2}'),
(12, '{8:1.3, 80:2.3, 800:3.3}'),
(13, '{9:1.4, 90:2.4, 900:3.4}');

--echo # 验证批量插入后数据完整性
select count(*) as total_count from t_spiv_basic_fork;
select id, sv from t_spiv_basic_fork where id >= 10 order by id;

--echo # 11.10 清理测试表
drop table if exists t_spiv_basic;
drop table if exists t_spiv_basic_fork;
drop table if exists t_spiv_complex;
drop table if exists t_spiv_complex_fork;



--echo ============================================
--echo 13. 混合索引隔离测试 - Fork后源表和目标表索引独立
--echo ============================================

--echo # 验证fork后，源表和目标表的索引修改互不影响
drop table if exists t_isolation_test;
drop table if exists t_isolation_test_fork;

create table t_isolation_test (
    id int primary key,
    name varchar(50) not null,
    age int not null,
    vec vector(3) not null,
    index idx_name(name) ,
    index idx_age(age) ,
    vector index idx_vec(vec) with (distance=l2, type=hnsw, lib=vsag, m=16, ef_construction=200)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_isolation_test values (1, 'Alice', 25, '[0.1,0.1,0.1]');
insert into t_isolation_test values (101, 'Bob', 30, '[0.2,0.2,0.2]');

--echo # Fork表
fork table t_isolation_test to t_isolation_test_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表上插入新数据并验证索引
insert into t_isolation_test values (50, 'Charlie', 35, '[0.3,0.3,0.3]');
select * from t_isolation_test where name = 'Charlie';
select * from t_isolation_test where age = 35;
explain select * from t_isolation_test where name = 'Charlie';
explain select * from t_isolation_test where age = 35;
select * from t_isolation_test order by l2_distance(vec, [0.3,0.3,0.3]) APPROXIMATE limit 3;

--echo # 验证目标表索引不受源表影响
select * from t_isolation_test_fork where name = 'Charlie';
select * from t_isolation_test_fork where age = 35;
explain select * from t_isolation_test_fork where name = 'Charlie';
explain select * from t_isolation_test_fork where age = 35;

--echo # 在目标表上插入新数据并验证索引
insert into t_isolation_test_fork values (99, 'Fork_User', 40, '[0.4,0.4,0.4]');
select * from t_isolation_test_fork where name = 'Fork_User';
select * from t_isolation_test_fork where age = 40;
explain select * from t_isolation_test_fork where name = 'Fork_User';
explain select * from t_isolation_test_fork where age = 40;
select * from t_isolation_test_fork order by l2_distance(vec, [0.4,0.4,0.4]) APPROXIMATE limit 3;

--echo # 验证源表索引不受目标表影响
select * from t_isolation_test where name = 'Fork_User';
select * from t_isolation_test where age = 40;
explain select * from t_isolation_test where name = 'Fork_User';
explain select * from t_isolation_test where age = 40;

--echo # 在源表上后建新索引
ALTER TABLE t_isolation_test ADD COLUMN email VARCHAR(100);
create index idx_email_src on t_isolation_test(email) ;
--echo # 验证源表有新索引
show indexes from t_isolation_test;
insert into t_isolation_test values (2, 'Test2', 20, '[0.5,0.5,0.5]', 'test2@example.com');
select * from t_isolation_test where email = 'test2@example.com';
explain select * from t_isolation_test where email = 'test2@example.com';

--echo # 验证目标表没有新索引（索引独立）
show indexes from t_isolation_test_fork;

--echo # 在目标表上后建新索引
ALTER TABLE t_isolation_test_fork ADD COLUMN email VARCHAR(100);
create index idx_email_fork on t_isolation_test_fork(email) ;
--echo # 验证目标表有新索引
show indexes from t_isolation_test_fork;
insert into t_isolation_test_fork values (3, 'Test3', 25, '[0.6,0.6,0.6]', 'test3@example.com');
select * from t_isolation_test_fork where email = 'test3@example.com';
explain select * from t_isolation_test_fork where email = 'test3@example.com';

--echo # 验证源表索引不受影响
show indexes from t_isolation_test;

drop table t_isolation_test;
drop table t_isolation_test_fork;

--echo ============================================
--echo 14. 清理
--echo ============================================

drop database if exists db_fork_index_types;

--echo # 恢复向量索引内存限制
alter system set ob_vector_memory_limit_percentage = 0;