    select id from t_hnsw_sq_with_index order by l2_distance(vec, '[0.1, 0.1, 0.1]') asc APPROXIMATE limit 3
) as approx
inner join (
    select id from t_hnsw_sq_with_index order by l2_distance(vec, '[0.1, 0.1, 0.1]') asc limit 3  
) as exact on approx.id = exact.id;
select count(*) as match_count from (
    select id from t_hnsw_sq_with_index_fork order by l2_distance(vec, '[0.1, 0.1, 0.1]') asc APPROXIMATE limit 3
) as approx
inner join (
    select id from t_hnsw_sq_with_index_fork order by l2_distance(vec, '[0.1, 0.1, 0.1]') asc limit 3
) as exact on approx.id = exact.id;
