##owner: chenminsi.cms
##owner group: 底层引擎部-轻量版
##description: Fork Table各种索引类型功能测试（fork后源表和目标表的索引功能验证）
##tags: fork_table index_types normal_index spatial_index global_index local_index fulltext_index json_index hnsw_index ivf_index semantic_index sparse_index hybrid_index
##author: chenminsi.cms

--disable_warnings
drop database if exists db_fork_index_types;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_index_types;
use db_fork_index_types;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo # 启用debug sync
connection obsys;
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '5s';
sleep 3;
set ob_global_debug_sync = 'reset';
connection default;

--echo # 设置向量索引内存限制
alter system set ob_vector_memory_limit_percentage = 20;
sleep 3;

--echo ============================================
--echo 1. 普通索引（Normal Index）
--echo ============================================

--echo # 1.1 随表创建普通索引
drop table if exists t_normal_with_index;
drop table if exists t_normal_with_index_fork;

create table t_normal_with_index (
    id int primary key,
    name varchar(50),
    age int,
    email varchar(100),
    index idx_name(name),
    index idx_age(age),
    index idx_email(email)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_normal_with_index values (1, 'Alice', 25, 'alice@example.com');
insert into t_normal_with_index values (101, 'Bob', 30, 'bob@example.com');
insert into t_normal_with_index values (50, 'Charlie', 35, 'charlie@example.com');

--echo # Fork表
fork table t_normal_with_index to t_normal_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_normal_with_index;
show create table t_normal_with_index_fork;

--echo # 验证fork后源表的索引功能
show indexes from t_normal_with_index;
select * from t_normal_with_index where name = 'Alice';
select * from t_normal_with_index where age = 30;
select * from t_normal_with_index where email = 'charlie@example.com';
explain select * from t_normal_with_index where name = 'Alice';

--echo # 验证fork后目标表的索引功能
show indexes from t_normal_with_index_fork;
select * from t_normal_with_index_fork where name = 'Alice';
select * from t_normal_with_index_fork where age = 30;
select * from t_normal_with_index_fork where email = 'charlie@example.com';
explain select * from t_normal_with_index_fork where name = 'Alice';

--echo # 1.2 后建普通索引
drop table if exists t_normal_post_index;
drop table if exists t_normal_post_index_fork;

create table t_normal_post_index (
    id int primary key,
    name varchar(50),
    age int,
    email varchar(100)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_normal_post_index values (1, 'Alice', 25, 'alice@example.com');
insert into t_normal_post_index values (101, 'Bob', 30, 'bob@example.com');

--echo # Fork表
fork table t_normal_post_index to t_normal_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表上后建索引
create index idx_name_src on t_normal_post_index(name);
create index idx_age_src on t_normal_post_index(age);

--echo # 在目标表上后建索引
create index idx_name_fork on t_normal_post_index_fork(name);
create index idx_age_fork on t_normal_post_index_fork(age);

--echo # 验证源表和目标表的后建索引功能
show indexes from t_normal_post_index;
show indexes from t_normal_post_index_fork;
select * from t_normal_post_index where name = 'Alice';
select * from t_normal_post_index_fork where name = 'Alice';
explain select * from t_normal_post_index where name = 'Alice';
explain select * from t_normal_post_index_fork where name = 'Alice';

drop table t_normal_with_index;
drop table t_normal_with_index_fork;
drop table t_normal_post_index;
drop table t_normal_post_index_fork;


--echo ============================================
--echo 2. 全局索引（Global Index）
--echo ============================================

--echo # 2.1 随表创建全局索引
drop table if exists t_global_with_index;
drop table if exists t_global_with_index_fork;

create table t_global_with_index (
    a int,
    b varchar(150),
    c int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

create index gidx_c on t_global_with_index(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

insert into t_global_with_index values (1, 'Alice', 10);
insert into t_global_with_index values (101, 'Bob', 110);
insert into t_global_with_index values (50, 'Charlie', 50);

--echo # Fork表
fork table t_global_with_index to t_global_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的全局索引功能
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_global_with_index;
show create table t_global_with_index_fork;
show indexes from t_global_with_index;
show indexes from t_global_with_index_fork;
select * from t_global_with_index where c = 10;
select * from t_global_with_index_fork where c = 10;
explain select * from t_global_with_index where c = 10;
explain select * from t_global_with_index_fork where c = 10;

--echo # 2.2 后建全局索引
drop table if exists t_global_post_index;
drop table if exists t_global_post_index_fork;

create table t_global_post_index (
    a int,
    b varchar(150),
    c int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_global_post_index values (1, 'Alice', 10);
insert into t_global_post_index values (101, 'Bob', 110);

--echo # Fork表
fork table t_global_post_index to t_global_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建全局索引
create index gidx_c_src on t_global_post_index(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);
create index gidx_c_fork on t_global_post_index_fork(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

--echo # 验证后建全局索引功能
show indexes from t_global_post_index;
show indexes from t_global_post_index_fork;
select * from t_global_post_index where c = 10;
select * from t_global_post_index_fork where c = 10;
explain select * from t_global_post_index where c = 10;
explain select * from t_global_post_index_fork where c = 10;

drop table t_global_with_index;
drop table t_global_with_index_fork;
drop table t_global_post_index;
drop table t_global_post_index_fork;

--echo ============================================
--echo 3. 局部索引（Local Index）
--echo ============================================

--echo # 3.1 随表创建局部索引
drop table if exists t_local_with_index;
drop table if exists t_local_with_index_fork;

create table t_local_with_index (
    a int,
    b varchar(150),
    c int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

create index lidx_c on t_local_with_index(c) local;

insert into t_local_with_index values (1, 'Alice', 10);
insert into t_local_with_index values (101, 'Bob', 110);
insert into t_local_with_index values (50, 'Charlie', 50);

--echo # Fork表
fork table t_local_with_index to t_local_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的局部索引功能
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_local_with_index;
show create table t_local_with_index_fork;
show indexes from t_local_with_index;
show indexes from t_local_with_index_fork;
select * from t_local_with_index where c = 10;
select * from t_local_with_index_fork where c = 10;
explain select * from t_local_with_index where c = 10;
explain select * from t_local_with_index_fork where c = 10;

--echo # 3.2 后建局部索引
drop table if exists t_local_post_index;
drop table if exists t_local_post_index_fork;

create table t_local_post_index (
    a int,
    b varchar(150),
    c int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_local_post_index values (1, 'Alice', 10);
insert into t_local_post_index values (101, 'Bob', 110);

--echo # Fork表
fork table t_local_post_index to t_local_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建局部索引
create index lidx_c_src on t_local_post_index(c) local;
create index lidx_c_fork on t_local_post_index_fork(c) local;

--echo # 验证后建局部索引功能
show indexes from t_local_post_index;
show indexes from t_local_post_index_fork;
select * from t_local_post_index where c = 10;
select * from t_local_post_index_fork where c = 10;
explain select * from t_local_post_index where c = 10;
explain select * from t_local_post_index_fork where c = 10;

drop table t_local_with_index;
drop table t_local_with_index_fork;
drop table t_local_post_index;
drop table t_local_post_index_fork;

--echo ============================================
--echo 4. 全文索引（Fulltext Index）
--echo ============================================

--echo # 4.1 随表创建全文索引
drop table if exists t_fulltext_with_index;
drop table if exists t_fulltext_with_index_fork;

create table t_fulltext_with_index (
    id int primary key,
    title varchar(200),
    content text,
    fulltext index idx_content(content)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_fulltext_with_index values (1, 'Title1', 'This is a test content for fulltext search');
insert into t_fulltext_with_index values (101, 'Title2', 'Another test content with different words');
insert into t_fulltext_with_index values (50, 'Title3', 'Search functionality testing');

--echo # Fork表
fork table t_fulltext_with_index to t_fulltext_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的全文索引功能
show indexes from t_fulltext_with_index;
show indexes from t_fulltext_with_index_fork;
select * from t_fulltext_with_index where match(content) against('test' in natural language mode);
select * from t_fulltext_with_index_fork where match(content) against('test' in natural language mode);
explain select * from t_fulltext_with_index where match(content) against('test' in natural language mode);
explain select * from t_fulltext_with_index_fork where match(content) against('test' in natural language mode);

--echo # 4.2 后建全文索引
drop table if exists t_fulltext_post_index;
drop table if exists t_fulltext_post_index_fork;

create table t_fulltext_post_index (
    id int primary key,
    title varchar(200),
    content text
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_fulltext_post_index values (1, 'Title1', 'This is a test content for fulltext search');
insert into t_fulltext_post_index values (101, 'Title2', 'Another test content with different words');

--echo # Fork表
fork table t_fulltext_post_index to t_fulltext_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建全文索引
create fulltext index idx_content_src on t_fulltext_post_index(content);
create fulltext index idx_content_fork on t_fulltext_post_index_fork(content);

--echo # 验证后建全文索引功能
show indexes from t_fulltext_post_index;
show indexes from t_fulltext_post_index_fork;
select * from t_fulltext_post_index where match(content) against('test' in natural language mode);
select * from t_fulltext_post_index_fork where match(content) against('test' in natural language mode);
explain select * from t_fulltext_post_index where match(content) against('test' in natural language mode);
explain select * from t_fulltext_post_index_fork where match(content) against('test' in natural language mode);

drop table t_fulltext_with_index;
drop table t_fulltext_with_index_fork;
drop table t_fulltext_post_index;
drop table t_fulltext_post_index_fork;

--echo ============================================
--echo 5. JSON多值索引（JSON Multi-Value Index）
--echo ============================================

--echo # 5.1 随表创建JSON多值索引
drop table if exists t_json_with_index;
drop table if exists t_json_with_index_fork;

create table t_json_with_index (
    id int primary key,
    name varchar(50),
    tags json,
    index idx_tags ((cast(tags->'$[*]' as char(100) array)))
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_json_with_index values (1, 'Item1', '["tag1", "tag2", "tag3"]');
insert into t_json_with_index values (101, 'Item2', '["tag2", "tag4"]');
insert into t_json_with_index values (50, 'Item3', '["tag1", "tag5"]');

--echo # Fork表
fork table t_json_with_index to t_json_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的JSON多值索引功能
--replace_regex /__doc_id_[0-9]+/__doc_id_DOC_ID/g
show indexes from t_json_with_index;
--replace_regex /__doc_id_[0-9]+/__doc_id_DOC_ID/g
show indexes from t_json_with_index_fork;
select * from t_json_with_index where json_contains(tags, '"tag1"');
select * from t_json_with_index_fork where json_contains(tags, '"tag1"');
explain select * from t_json_with_index where json_contains(tags, '"tag1"');
explain select * from t_json_with_index_fork where json_contains(tags, '"tag1"');

--echo # 5.2 后建JSON多值索引
drop table if exists t_json_post_index;
drop table if exists t_json_post_index_fork;

create table t_json_post_index (
    id int primary key,
    name varchar(50),
    tags json
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_json_post_index values (1, 'Item1', '["tag1", "tag2", "tag3"]');
insert into t_json_post_index values (101, 'Item2', '["tag2", "tag4"]');

--echo # Fork表
fork table t_json_post_index to t_json_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建JSON多值索引
--error 1235
create index idx_tags_src on t_json_post_index((cast(tags->'$[*]' as char(100) array)));
--error 1235
create index idx_tags_fork on t_json_post_index_fork((cast(tags->'$[*]' as char(100) array)));

--echo # 验证后建JSON多值索引功能
show indexes from t_json_post_index;
show indexes from t_json_post_index_fork;


drop table t_json_with_index;
drop table t_json_with_index_fork;
drop table t_json_post_index;
drop table t_json_post_index_fork;

--echo ============================================
--echo 6. HNSW索引（重点关注）
--echo ============================================

--echo # 6.1 随表创建HNSW索引
drop table if exists t_hnsw_with_index;
drop table if exists t_hnsw_with_index_fork;

create table t_hnsw_with_index (
    id int primary key,
    name varchar(50),
    vec vector(3),
    vector index idx_vec(vec) with (distance=l2, type=hnsw, lib=vsag, m=16, ef_construction=200, ef_search=200)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);


insert into t_hnsw_with_index values (1, 'Vec1', '[0.1,0.1,0.1]');
insert into t_hnsw_with_index values (101, 'Vec2', '[0.2,0.2,0.2]');
insert into t_hnsw_with_index values (50, 'Vec3', '[0.3,0.3,0.3]');

--echo # Fork表
fork table t_hnsw_with_index to t_hnsw_with_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的HNSW索引功能
show indexes from t_hnsw_with_index;
show indexes from t_hnsw_with_index_fork;
--echo # 源表、目标表HNSW索引查询（近似查询和精确查询）
select * from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;
select * from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;
select * from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) limit 3;
select * from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) limit 3;
--echo # 验证近似查询和精确查询结果一致性
--echo # 源表：比较近似查询和精确查询的前3条记录的ID是否一致
select count(*) as match_count from (
    select id from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as tmp1
inner join (
    select id from t_hnsw_with_index order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as tmp2 on tmp1.id = tmp2.id;
--echo # 目标表：比较近似查询和精确查询的前3条记录的ID是否一致
select count(*) as match_count from (
    select id from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as tmp1
inner join (
    select id from t_hnsw_with_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as tmp2 on tmp1.id = tmp2.id;
--echo # 更详细的一致性验证：显示匹配的具体记录
select 
    approx.id as approx_id,
    exact.id as exact_id,
    case when approx.id = exact.id then 'MATCH' else 'MISMATCH' end as status
from (
    select id, row_number() over() as rn 
    from t_hnsw_with_index 
    order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as approx
full outer join (
    select id, row_number() over() as rn 
    from t_hnsw_with_index 
    order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as exact on approx.rn = exact.rn;
select 
    approx.id as approx_id,
    exact.id as exact_id,
    case when approx.id = exact.id then 'MATCH' else 'MISMATCH' end as status
from (
    select id, row_number() over() as rn 
    from t_hnsw_with_index_fork 
    order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3
) as approx
full outer join (
    select id, row_number() over() as rn 
    from t_hnsw_with_index_fork 
    order by l2_distance(vec, [0.1,0.1,0.1]) limit 3
) as exact on approx.rn = exact.rn;

--echo # 6.2 后建HNSW索引
drop table if exists t_hnsw_post_index;
drop table if exists t_hnsw_post_index_fork;

create table t_hnsw_post_index (
    id int primary key,
    name varchar(50),
    vec vector(3)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_hnsw_post_index values (1, 'Vec1', '[0.1,0.1,0.1]');
insert into t_hnsw_post_index values (101, 'Vec2', '[0.2,0.2,0.2]');

--echo # Fork表
fork table t_hnsw_post_index to t_hnsw_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建HNSW索引
create vector index idx_vec_src on t_hnsw_post_index(vec) with (distance=l2, type=hnsw, lib=vsag, m=16, ef_construction=200, ef_search=200);
create vector index idx_vec_fork on t_hnsw_post_index_fork(vec) with (distance=l2, type=hnsw, lib=vsag, m=16, ef_construction=200, ef_search=200);

--echo # 等待索引构建完成
sleep 5;

--echo # 验证后建HNSW索引功能
show indexes from t_hnsw_post_index;
show indexes from t_hnsw_post_index_fork;
select * from t_hnsw_post_index order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;
select * from t_hnsw_post_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;

--echo # 验证HNSW索引重建功能
call dbms_vector.rebuild_index('idx_vec_src', 't_hnsw_post_index', 'vec');
call dbms_vector.rebuild_index('idx_vec_fork', 't_hnsw_post_index_fork', 'vec');
sleep 5;
select * from t_hnsw_post_index order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;
select * from t_hnsw_post_index_fork order by l2_distance(vec, [0.1,0.1,0.1]) APPROXIMATE limit 3;

drop table t_hnsw_with_index;
drop table t_hnsw_with_index_fork;
drop table t_hnsw_post_index;
drop table t_hnsw_post_index_fork;

--echo ============================================
--echo 7. 向量查询表HNSW内积距离索引测试（重点关注）
--echo ============================================

--echo # 7.1 随表创建HNSW索引（内积距离）
drop table if exists t_vec_query;
drop table if exists t_vec_query_fork;

--echo # 创建带HNSW索引的向量查询表
create table t_vec_query (
    c1 int primary key, 
    c2 vector(3),
    vector index idx1(c2) with (distance=inner_product, type=hnsw, lib=vsag)
) partition by range(c1) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 插入向量数据（使用内积距离有意义的数据）
insert into t_vec_query values (1, '[1.0, 0.0, 0.0]');   
insert into t_vec_query values (2, '[0.0, 1.0, 0.0]');   
insert into t_vec_query values (3, '[0.0, 0.0, 1.0]');   
insert into t_vec_query values (4, '[0.5, 0.5, 0.0]');   
insert into t_vec_query values (5, '[0.5, 0.0, 0.5]');   
insert into t_vec_query values (101, '[0.0, 0.5, 0.5]'); 
insert into t_vec_query values (50, '[0.7, 0.7, 0.0]');  

--echo # Fork表
fork table t_vec_query to t_vec_query_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的HNSW索引
show indexes from t_vec_query;
show indexes from t_vec_query_fork;

--echo # 源表HNSW索引查询（内积距离近似查询和精确查询）
--echo # 查询与X轴向量最相似的向量（内积越大越相似）
select c1, c2, inner_product(c2, '[1.0, 0.0, 0.0]') as similarity 
from t_vec_query order by inner_product(c2, '[1.0, 0.0, 0.0]') desc APPROXIMATE limit 3;

select '源表精确查询（内积距离）:' as query_type;  
select c1, c2, inner_product(c2, '[1.0, 0.0, 0.0]') as similarity
from t_vec_query order by inner_product(c2, '[1.0, 0.0, 0.0]') desc limit 3;

--echo # 目标表HNSW索引查询（内积距离近似查询和精确查询）
select c1, c2, inner_product(c2, '[1.0, 0.0, 0.0]') as similarity
from t_vec_query_fork order by inner_product(c2, '[1.0, 0.0, 0.0]') desc APPROXIMATE limit 3;


select c1, c2, inner_product(c2, '[1.0, 0.0, 0.0]') as similarity
from t_vec_query_fork order by inner_product(c2, '[1.0, 0.0, 0.0]') desc limit 3;

--echo # 验证近似查询和精确查询结果一致性（内积距离）
select count(*) as match_count from (
    select c1 from t_vec_query order by inner_product(c2, '[1.0, 0.0, 0.0]') desc APPROXIMATE limit 3
) as approx
inner join (
    select c1 from t_vec_query order by inner_product(c2, '[1.0, 0.0, 0.0]') desc limit 3  
) as exact on approx.c1 = exact.c1;

select count(*) as match_count from (
    select c1 from t_vec_query_fork order by inner_product(c2, '[1.0, 0.0, 0.0]') desc APPROXIMATE limit 3
) as approx
inner join (
    select c1 from t_vec_query_fork order by inner_product(c2, '[1.0, 0.0, 0.0]') desc limit 3
) as exact on approx.c1 = exact.c1;

--echo # 7.2 后建HNSW索引（内积距离）
drop table if exists t_vec_query_post_index;
drop table if exists t_vec_query_post_index_fork;

--echo # 创建不带索引的向量查询表
create table t_vec_query_post_index (
    c1 int primary key,
    c2 vector(3)
) partition by range(c1) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 插入测试数据
insert into t_vec_query_post_index values (1, '[0.8, 0.2, 0.0]');
insert into t_vec_query_post_index values (2, '[0.2, 0.8, 0.0]');
insert into t_vec_query_post_index values (3, '[0.0, 0.2, 0.8]');
insert into t_vec_query_post_index values (4, '[0.6, 0.3, 0.1]');
insert into t_vec_query_post_index values (101, '[0.1, 0.6, 0.3]'); 
insert into t_vec_query_post_index values (50, '[0.3, 0.1, 0.6]');

--echo # Fork表
fork table t_vec_query_post_index to t_vec_query_post_index_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 在源表和目标表上后建HNSW索引（内积距离）
create vector index idx_vec_query_src on t_vec_query_post_index(c2) with (distance=inner_product, type=hnsw, lib=vsag);
create vector index idx_vec_query_fork on t_vec_query_post_index_fork(c2) with (distance=inner_product, type=hnsw, lib=vsag);

--echo # 等待索引构建完成
sleep 5;

--echo # 验证后建HNSW索引功能
show indexes from t_vec_query_post_index;
show indexes from t_vec_query_post_index_fork;

--echo # 源表后建索引查询测试

select c1, c2, inner_product(c2, '[0.8, 0.2, 0.0]') as similarity
from t_vec_query_post_index order by inner_product(c2, '[0.8, 0.2, 0.0]') desc APPROXIMATE limit 3;

--echo # 目标表后建索引查询测试  
select c1, c2, inner_product(c2, '[0.8, 0.2, 0.0]') as similarity
from t_vec_query_post_index_fork order by inner_product(c2, '[0.8, 0.2, 0.0]') desc APPROXIMATE limit 3;

--echo # 8.3 验证HNSW索引重建功能（内积距离）
--echo # 重建源表索引
call dbms_vector.rebuild_index('idx_vec_query_src', 't_vec_query_post_index', 'c2');
--echo # 重建目标表索引
call dbms_vector.rebuild_index('idx_vec_query_fork', 't_vec_query_post_index_fork', 'c2');

--echo # 等待索引重建完成
sleep 5;

--echo # 验证重建后索引功能
