--echo # 源表HNSW_SQ索引查询（L2距离近似查询和精确查询）
select id, name, vec, l2_distance(vec, '[0.1, 0.1, 0.1]') as distance 
from t_hnsw_sq_with_index order by l2_distance(vec, '[0.1, 0.1, 0.1]') asc APPROXIMATE limit 3; 
