insert into t_spiv_basic values (50, '{3:0.9, 30:1.9, 300:2.9}');     

--echo # Fork表
fork table t_spiv_basic to t_spiv_basic_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork后源表和目标表的表结构
