##owner: chenminsi.cms
##owner group: 底层引擎部-轻量版
##description: Fork Table其他场景测试（undo_retention、权限、链式fork、跨数据库、关键字检查）
##tags: fork_table undo_retention privilege chain cross_database keyword
##author: chenminsi.cms

--disable_warnings
drop database if exists db_fork_other;
drop database if exists db_fork_other2;
drop user if exists 'test_user_a'@'%';
drop user if exists 'test_user_b'@'%';
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. 多版本回收策略影响，undo_retention=0极端条件(p0)
--echo ============================================

--echo # 设置undo_retention=0（极端条件）
connection obsys;
alter system set undo_retention = 0;
sleep 2;
connection default;

drop table if exists t_undo_retention;
drop table if exists t_undo_retention_fork;

create table t_undo_retention (
    id int primary key,
    name varchar(50),
    value int
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 插入初始数据
insert into t_undo_retention values (1, 'Init1', 100);
insert into t_undo_retention values (101, 'Init2', 200);

--echo # 验证初始数据
select count(*) as cnt from t_undo_retention;
select * from t_undo_retention order by id;

--echo # Fork表（在undo_retention=0的条件下）
--echo # 注意：undo_retention=0可能导致fork table需要更长时间，增加超时时间
let $wait_timeout= 120;
fork table t_undo_retention to t_undo_retention_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证Fork后源表数据
select count(*) as src_cnt from t_undo_retention;
select * from t_undo_retention order by id;

--echo # 验证Fork后目标表数据
select count(*) as fork_cnt from t_undo_retention_fork;
select * from t_undo_retention_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_undo_retention) as src_cnt, (select count(*) from t_undo_retention_fork) as fork_cnt;

--echo # 在undo_retention=0条件下，继续对源表进行操作
insert into t_undo_retention values (50, 'AfterFork1', 150);
update t_undo_retention set value = 101 where id = 1;

--echo # 验证源表数据更新
select count(*) as src_cnt from t_undo_retention;
select * from t_undo_retention order by id;

--echo # 验证目标表数据未受影响（数据隔离）
select count(*) as fork_cnt from t_undo_retention_fork;
select * from t_undo_retention_fork order by id;

--echo # 恢复undo_retention设置（使用默认值或合理值）
connection obsys;
alter system set undo_retention = 1800;
sleep 2;
connection default;

drop table t_undo_retention;
drop table t_undo_retention_fork;

--disable_warnings
drop database if exists db_fork_other;
drop database if exists db_fork_other2;
drop user if exists 'test_user_a'@'%';
drop user if exists 'test_user_b'@'%';
--enable_warnings

disconnect obsys;
connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 2. 权限检查(p1)
--echo ============================================

--echo # 2.1 用户对a表的权限是否带到a_fork表中
--echo # 准备测试环境
connection obsys;
create user 'test_user_a'@'%' identified by 'test123';
create user 'test_user_b'@'%' identified by 'test123';
connection default;

drop table if exists t_perm_a;
drop table if exists t_perm_a_fork;

create table t_perm_a (
    id int primary key,
    name varchar(50),
    value int
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_perm_a values (1, 'Data1', 100);
insert into t_perm_a values (101, 'Data2', 200);

--echo # 首先检查test_user_a的初始权限（确保没有database级别的权限）
--echo # 检查test_user_a对database的权限
show grants for 'test_user_a'@'%';

--echo # 验证test_user_a初始状态下对源表没有权限
--echo # 注意：需要先授予USAGE权限才能连接到数据库，但USAGE权限不会自动授予表权限
connection default;
grant usage on db_fork_other.* to 'test_user_a'@'%';

--echo # 现在可以连接数据库，但验证对源表没有权限（预期失败）
--replace_regex /connect\([^,]+,[^,]+,[^,]+,[^,]+,([0-9]+),\)/connect(host,user,pass,db,port,)/g
--error 1044
connect (conn_user_a,$OBMYSQL_MS0,test_user_a@sys,test123,db_fork_other,$OBMYSQL_PORT);

--echo # 授予test_user_a对源表的SELECT和INSERT权限
grant select, insert on db_fork_other.t_perm_a to 'test_user_a'@'%';

--echo # 再次检查test_user_a的权限（确认只有对源表的显式权限）
show grants for 'test_user_a'@'%';

--echo # 验证test_user_a对源表的权限
connect (conn_user_a,$OBMYSQL_MS0,test_user_a@sys,test123,db_fork_other,$OBMYSQL_PORT);
connection conn_user_a;
select count(*) as cnt from t_perm_a;
select * from t_perm_a order by id;

--echo # 使用root用户执行Fork操作
connection default;
fork table t_perm_a to t_perm_a_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # Fork后再次检查test_user_a的权限（确认权限没有变化）
show grants for 'test_user_a'@'%';

--echo # 验证test_user_a对源表的权限仍然有效
connection conn_user_a;
select count(*) as cnt from t_perm_a;
select * from t_perm_a order by id;

--echo # 验证test_user_a对fork表的权限（权限不应自动迁移）
--error 1142
select * from t_perm_a_fork order by id;

--echo # 结论：用户对源表的权限不会自动带到fork表中

--echo ============================================
--echo # 2.2 用户未显式授权，是否对本用户fork的表拥有权限
--echo ============================================

--echo # test_user_a自己fork表
connection default;

--echo # 清理环境
drop table if exists t_self_fork;
drop table if exists t_self_fork_fork;

--echo # 重新建立干净的连接以确保权限状态
disconnect conn_user_a;

--echo # 重新连接root用户，确保权限授予的准确性
connection default;

--echo # 重要修改：清理之前的权限，重新授予最小权限（为2.2准备「仅USAGE+CREATE TABLE」的干净起点）
--echo # 仅收回2.1的表级权限（t_perm_a）；不执行revoke usage on db_fork_other.*，因部分环境会报5133且对2.2结论无影响，后续grant会得到USAGE+CREATE TABLE
revoke insert, select on db_fork_other.t_perm_a from 'test_user_a'@'%';
grant usage on db_fork_other.* to 'test_user_a'@'%';

--echo # 关键修改：授予库级CREATE权限（OceanBase 库级仅支持 CREATE，不支持 create table 语法）
grant create on db_fork_other.* to 'test_user_a'@'%';

--echo # 重新连接test_user_a
connect (conn_user_a,$OBMYSQL_MS0,test_user_a@sys,test123,db_fork_other,$OBMYSQL_PORT);
connection conn_user_a;

--echo # 验证test_user_a的当前权限状态
show grants for 'test_user_a'@'%';

--echo # test_user_a创建表
create table t_self_fork (
    id int primary key,
    name varchar(50)
) partition by range(id) (
    partition p0 values less than (100)
);

--echo # 授予对源表的INSERT和SELECT权限（由root用户执行）
connection default;
grant insert, select on db_fork_other.t_self_fork to 'test_user_a'@'%';

--echo # Fork前检查test_user_a的权限（确认只有对源表的显式权限）
show grants for 'test_user_a'@'%';

--echo # 切换到test_user_a执行数据操作
connection conn_user_a;
insert into t_self_fork values (1, 'Self1');
insert into t_self_fork values (50, 'Self2');

--echo # 验证对源表的权限
select * from t_self_fork order by id;

--echo # 检查当前权限详情
connection default;
SELECT 
    TABLE_SCHEMA,
    TABLE_NAME, 
    PRIVILEGE_TYPE,
    GRANTEE
FROM information_schema.TABLE_PRIVILEGES 
WHERE GRANTEE LIKE '%test_user_a%' 
AND TABLE_SCHEMA = 'db_fork_other'
ORDER BY TABLE_NAME, PRIVILEGE_TYPE;

--echo # test_user_a自己执行fork操作
connection conn_user_a;
fork table t_self_fork to t_self_fork_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # Fork后立即检查权限状态
connection default;
show grants for 'test_user_a'@'%';

--echo # 检查FORK表的权限分布
SELECT 
    TABLE_SCHEMA,
    TABLE_NAME, 
    PRIVILEGE_TYPE,
    GRANTEE
FROM information_schema.TABLE_PRIVILEGES 
WHERE TABLE_SCHEMA = 'db_fork_other'
AND TABLE_NAME LIKE 't_self_fork%'
ORDER BY TABLE_NAME, GRANTEE, PRIVILEGE_TYPE;

--echo # 验证test_user_a对自己fork的表是否有权限（预期应该失败）
connection conn_user_a;
--error 1142
select * from t_self_fork_fork order by id;

--echo # 2.3 用户A对用户B的表是否支持fork，授权create后是否支持fork？
connection default;
drop table if exists t_user_b;
drop table if exists t_user_b_fork;

--echo # 使用test_user_b真实创建表（用户B的表）
--echo # 授予test_user_b对数据库的CREATE、INSERT、SELECT权限（用于创建表和插入数据）
grant create, insert, select on db_fork_other.* to 'test_user_b'@'%';
--echo # 创建test_user_b的连接
connect (conn_user_b,$OBMYSQL_MS0,test_user_b@sys,test123,db_fork_other,$OBMYSQL_PORT);
connection conn_user_b;

create table t_user_b (
    id int primary key,
    name varchar(50),
    owner varchar(50) default 'user_b'
) partition by range(id) (
    partition p0 values less than (100)
);

insert into t_user_b values (1, 'UserB_Data1', 'user_b');
insert into t_user_b values (50, 'UserB_Data2', 'user_b');

--echo # 测试场景1：只有CREATE权限，没有SELECT权限
connection default;
--echo # 只授予test_user_a的CREATE权限（不授予SELECT权限）
grant create on db_fork_other.* to 'test_user_a'@'%';
--echo # 重新连接以确保权限生效
disconnect conn_user_a;
connect (conn_user_a,$OBMYSQL_MS0,test_user_a@sys,test123,db_fork_other,$OBMYSQL_PORT);
connection conn_user_a;

--echo # test_user_a尝试fork用户B的表（只有CREATE权限）
--error 1142
fork table t_user_b to t_user_b_fork;

--echo # 使用root授予test_user_a对db_fork_other的SELECT权限后，test_user_a才能fork用户B的表
connection default;
grant select on db_fork_other.* to 'test_user_a'@'%';

--echo # 重连test_user_a以使新权限生效，再执行一次fork
disconnect conn_user_a;
connect (conn_user_a,$OBMYSQL_MS0,test_user_a@sys,test123,db_fork_other,$OBMYSQL_PORT);
connection conn_user_a;
fork table t_user_b to t_user_b_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证fork操作成功（只要有CREATE权限就可以fork）
connection default;
select count(*) as cnt from t_user_b_fork;
select * from t_user_b_fork order by id;

--echo # 验证test_user_a对fork表的权限（需要显式授权）
#connection conn_user_a;
#--error 1142
#select * from t_user_b_fork order by id;

--echo # 授予test_user_a对fork表的SELECT权限
#connection default;
#grant select on db_fork_other.t_user_b_fork to 'test_user_a'@'%';

--echo # 验证授权后可以访问
#connection conn_user_a;
#select * from t_user_b_fork order by id;

--echo # 结论：用户A对用户B的表，只要有CREATE权限就可以fork，但fork后需要显式授权才能访问

--echo # 清理权限测试相关表
connection default;
disconnect conn_user_b;

drop table if exists t_user_b;
#drop table if exists t_user_b_fork;
drop user 'test_user_a'@'%';
drop user 'test_user_b'@'%';
drop table if exists t_perm_a, t_perm_a_fork, t_self_fork, t_self_fork_fork;
drop database db_fork_other;
drop database db_fork_other2;

--echo ============================================
--echo 3. 链式fork以及并行fork验证，检查各级目标表都相互独立(p1)
--echo ============================================

--echo # 重建库供 section 3 及后续跨库 fork（section 2 结尾已 drop db_fork_other/db_fork_other2）
create database db_fork_other;
create database db_fork_other2;
use db_fork_other;

--echo # 3.1 链式fork验证（A -> B -> C）
drop table if exists t_chain_a;
drop table if exists t_chain_b;
drop table if exists t_chain_c;

create table t_chain_a (
    id int primary key,
    name varchar(50),
    value int,
    level varchar(10) default 'A'
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_chain_a values (1, 'Chain_A1', 100, 'A');
insert into t_chain_a values (101, 'Chain_A2', 200, 'A');

--echo # 第一次fork: A -> B
fork table t_chain_a to t_chain_b;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证第一次fork
select * from t_chain_a order by id;
select * from t_chain_b order by id;

--echo # 第二次fork: B -> C
fork table t_chain_b to t_chain_c;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证第二次fork
show create table t_chain_a;
show create table t_chain_b;
show create table t_chain_c;
select * from t_chain_a order by id;
select * from t_chain_b order by id;
select * from t_chain_c order by id;

--echo # 修改表A（验证B和C不受影响）
insert into t_chain_a values (3, 'Chain_A4', 301, 'A');

--echo # 修改表B（验证A和C不受影响）
insert into t_chain_b values (3, 'Chain_B2', 401, 'B');

--echo # 修改表C（验证A和B不受影响）
insert into t_chain_c values (3, 'Chain_C1', 501, 'C');

--echo # 验证三级表数据完全独立
select count(*) as a_cnt from t_chain_a;
select count(*) as b_cnt from t_chain_b;
select count(*) as c_cnt from t_chain_c;
select * from t_chain_a order by id;
select * from t_chain_b order by id;
select * from t_chain_c order by id;

--echo # 验证数据一致性：各级目标表都相互独立
select (select count(*) from t_chain_a) as a_cnt, 
       (select count(*) from t_chain_b) as b_cnt, 
       (select count(*) from t_chain_c) as c_cnt;

drop table t_chain_a;
drop table t_chain_b;
drop table t_chain_c;

--echo # 3.2 并行fork验证（A -> B, A -> C）
drop table if exists t_parallel_a;
drop table if exists t_parallel_b;
drop table if exists t_parallel_c;

create table t_parallel_a (
    id int primary key,
    name varchar(50),
    value int,
    source varchar(10) default 'A'
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_parallel_a values (1, 'Parallel_A1', 100, 'A');
insert into t_parallel_a values (101, 'Parallel_A2', 200, 'A');

--echo # 并行fork: A -> B
fork table t_parallel_a to t_parallel_b;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 并行fork: A -> C（从同一个源表fork）
fork table t_parallel_a to t_parallel_c;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证并行fork
show create table t_parallel_a;
show create table t_parallel_b;
show create table t_parallel_c;
select * from t_parallel_a order by id;
select * from t_parallel_b order by id;
select * from t_parallel_c order by id;

--echo # 修改源表A（验证B和C不受影响）
insert into t_parallel_a values (50, 'Parallel_A3', 150, 'A');
update t_parallel_a set value = 101 where id = 1;

--echo # 修改表B（验证A和C不受影响）
insert into t_parallel_b values (2, 'Parallel_B1', 201, 'B');
insert into t_parallel_b values (50, 'Parallel_B1', 201, 'B');
--echo # 修改表C（验证A和B不受影响）bug
insert into t_parallel_c values (2, 'Parallel_C1', 301, 'C');
#insert into t_parallel_b values (50, 'Parallel_C1', 201, 'C');

--echo # 验证并行fork的表数据完全独立
select count(*) as a_cnt from t_parallel_a;
select count(*) as b_cnt from t_parallel_b;
select count(*) as c_cnt from t_parallel_c;
select * from t_parallel_a order by id;
select * from t_parallel_b order by id;
select * from t_parallel_c order by id;

--echo # 验证数据一致性：并行fork的表都相互独立
select (select count(*) from t_parallel_a) as a_cnt, 
       (select count(*) from t_parallel_b) as b_cnt, 
       (select count(*) from t_parallel_c) as c_cnt;

drop table t_parallel_a;
drop table t_parallel_b;
drop table t_parallel_c;

--echo ============================================
--echo 4. 跨数据库fork表(p1)
--echo ============================================

drop table if exists t_cross_db_src;
drop table if exists db_fork_other2.t_cross_db_dst;

--echo # 在db_fork_other数据库中创建源表
use db_fork_other;
create table t_cross_db_src (
    id int primary key,
    name varchar(50),
    value int,
    db_name varchar(50) default 'db_fork_other'
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_cross_db_src values (1, 'CrossDB_Src1', 100, 'db_fork_other');
insert into t_cross_db_src values (101, 'CrossDB_Src2', 200, 'db_fork_other');

--echo # 验证源表数据
select count(*) as cnt from t_cross_db_src;
select * from t_cross_db_src order by id;

--echo # 跨数据库fork: db_fork_other.t_cross_db_src -> db_fork_other2.t_cross_db_dst
fork table t_cross_db_src to db_fork_other2.t_cross_db_dst;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

show create table t_cross_db_src;
--echo # 验证目标表在另一个数据库中
use db_fork_other2;
show create table t_cross_db_dst;
select count(*) as cnt from t_cross_db_dst;
select * from t_cross_db_dst order by id;

--echo # 验证源表数据未受影响
use db_fork_other;
select count(*) as cnt from t_cross_db_src;
select * from t_cross_db_src order by id;
--error 1146
select count(*) as cnt from t_cross_db_dst;
--error 1146
select * from t_cross_db_dst order by id;


--echo # 修改源表（验证目标表不受影响）
insert into t_cross_db_src values (50, 'CrossDB_Src3', 150, 'db_fork_other');
update t_cross_db_src set value = 101 where id = 1;

--echo # 修改目标表（验证源表不受影响）
use db_fork_other2;
insert into t_cross_db_dst values (50, 'CrossDB_Dst1', 201, 'db_fork_other2');
insert into t_cross_db_dst values (2, 'CrossDB_Dst1', 201, 'db_fork_other2');
update t_cross_db_dst set value = 102 where id = 1;

--echo # 验证跨数据库fork的表数据完全独立
use db_fork_other;
select count(*) as src_cnt from t_cross_db_src;
select * from t_cross_db_src order by id;

use db_fork_other2;
select count(*) as dst_cnt from t_cross_db_dst;
select * from t_cross_db_dst order by id;

--echo # 验证数据一致性
use db_fork_other;
select (select count(*) from t_cross_db_src) as src_cnt;
use db_fork_other2;
select (select count(*) from t_cross_db_dst) as dst_cnt;

--echo # 清理跨数据库fork测试
use db_fork_other;
drop table t_cross_db_src;
use db_fork_other2;
drop table t_cross_db_dst;

--echo ============================================
--echo 5. fork关键字检查，不可作为变量名(p1)
--echo ============================================

--echo # 5.1 尝试使用fork作为表名
--echo # 注意：fork可能不是保留关键字，但作为DDL关键字，可能不能直接作为表名
--echo # 测试使用fork作为表名（可能需要反引号）
create table `fork` (
    id int primary key,
    name varchar(50)
);

--echo # 验证可以使用反引号创建fork表
select count(*) as cnt from `fork`;
insert into `fork` values (1, 'Test');
select * from `fork`;

drop table `fork`;

--echo # 5.2 尝试使用fork作为列名
create table t_keyword (
    id int primary key,
    `fork` varchar(50)
);

--echo # 验证可以使用反引号创建fork列
insert into t_keyword values (1, 'ForkColumn');
select id, `fork` from t_keyword;

drop table t_keyword;

--echo # 5.3 尝试使用fork作为变量名（在存储过程中）
--echo # 创建存储过程，尝试使用fork作为变量名
DELIMITER //;
CREATE PROCEDURE test_fork_keyword()
begin
    declare `fork` int default 1;
    select `fork` as fork_value;
end;
//
DELIMITER ;//

--echo # 调用存储过程验证
call test_fork_keyword();

--echo # 清理存储过程
drop procedure if exists test_fork_keyword;

--echo # 5.4 验证fork作为DDL关键字，在查询中可以使用反引号作为别名
create table t_keyword (
    id int primary key,
    name varchar(50)
);
insert into t_keyword values (1, 'Test');

--echo # 使用反引号可以绕过关键字限制
select id as `fork` from t_keyword;

--echo # 验证fork关键字在DDL语句中的使用
--echo # fork table是DDL关键字，不能作为普通标识符使用
--echo # 但可以通过反引号绕过限制

drop table if exists t_keyword;


--echo ============================================
--echo 6. 清理
--echo ============================================

connection default;
use db_fork_other;

--disable_warnings
drop table if exists t_undo_retention;
drop table if exists t_undo_retention_fork;
drop table if exists t_perm_a;
drop table if exists t_perm_a_fork;
drop table if exists t_self_fork;
drop table if exists t_self_fork_fork;
drop table if exists t_user_b;
drop table if exists t_user_b_fork;
drop table if exists t_chain_a;
drop table if exists t_chain_b;
drop table if exists t_chain_c;
drop table if exists t_parallel_a;
drop table if exists t_parallel_b;
drop table if exists t_parallel_c;
drop table if exists t_cross_db_src;
drop table if exists t_keyword;
drop database if exists db_fork_other;
drop database if exists db_fork_other2;
drop user if exists 'test_user_a'@'%';
drop user if exists 'test_user_b'@'%';
--enable_warnings

disconnect conn_user_a;

