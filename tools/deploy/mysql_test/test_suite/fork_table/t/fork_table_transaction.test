drop table t_large_trx_post_fork;

--echo ============================================
--echo 3. 对源表进行频繁的事务操作后进行fork
--echo ============================================

drop table if exists t_frequent_trx;
drop table if exists t_frequent_trx_fork;

create table t_frequent_trx (
    id int primary key,
    name varchar(50),
    value int,
    counter int default 0
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than (300)
);

--echo # 插入初始数据
insert into t_frequent_trx values (1, 'Init1', 100, 0);
insert into t_frequent_trx values (101, 'Init2', 200, 0);
insert into t_frequent_trx values (201, 'Init3', 300, 0);

--echo # 验证初始数据
select count(*) as cnt from t_frequent_trx;
select * from t_frequent_trx order by id;

--echo # 对源表进行频繁的事务操作（提交）
--echo # 执行多次事务提交操作
start transaction;
insert into t_frequent_trx values (2, 'Freq1', 201, 1);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_frequent_trx values (3, 'Freq2', 202, 2);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_frequent_trx values (4, 'Freq3', 203, 3);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_frequent_trx values (5, 'Freq4', 204, 4);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_frequent_trx values (6, 'Freq5', 205, 5);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

--echo # 验证频繁事务操作后的源表数据
select count(*) as cnt from t_frequent_trx;
select * from t_frequent_trx order by id;

--echo # 对源表进行频繁的事务操作（部分回滚）
start transaction;
insert into t_frequent_trx values (7, 'Freq6', 206, 6);
update t_frequent_trx set counter = counter + 1 where id = 1;
rollback;

start transaction;
insert into t_frequent_trx values (8, 'Freq7', 207, 7);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_frequent_trx values (9, 'Freq8', 208, 8);
update t_frequent_trx set counter = counter + 1 where id = 1;
rollback;

start transaction;
insert into t_frequent_trx values (10, 'Freq9', 209, 9);
update t_frequent_trx set counter = counter + 1 where id = 1;
commit;

--echo # 验证频繁事务操作后的源表数据（应包含提交的数据，不包含回滚的数据）
select count(*) as cnt from t_frequent_trx;
select * from t_frequent_trx order by id;

--echo # Fork表
fork table t_frequent_trx to t_frequent_trx_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证Fork后源表和目标表数据
--echo # 源表应包含所有提交的事务数据
select count(*) as src_cnt from t_frequent_trx;
select * from t_frequent_trx order by id;
--echo # 目标表应包含fork时的数据（所有提交的事务数据）
select count(*) as fork_cnt from t_frequent_trx_fork;
select * from t_frequent_trx_fork order by id;

--echo # 验证数据一致性（fork时的数据应该一致）
select (select count(*) from t_frequent_trx) as src_cnt, (select count(*) from t_frequent_trx_fork) as fork_cnt;
select (select sum(counter) from t_frequent_trx) as src_sum, (select sum(counter) from t_frequent_trx_fork) as fork_sum;

drop table t_frequent_trx;
drop table t_frequent_trx_fork;

--echo ============================================
--echo 4. 对目标表进行频繁的事务操作，无预期外报错
--echo ============================================

drop table if exists t_fork_frequent_trx;
drop table if exists t_fork_frequent_trx_fork;

create table t_fork_frequent_trx (
    id int primary key,
    name varchar(50),
    value int,
    counter int default 0
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than (300)
);

--echo # 插入初始数据
insert into t_fork_frequent_trx values (1, 'Init1', 100, 0);
insert into t_fork_frequent_trx values (101, 'Init2', 200, 0);
insert into t_fork_frequent_trx values (201, 'Init3', 300, 0);

--echo # Fork表
fork table t_fork_frequent_trx to t_fork_frequent_trx_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证Fork后初始数据
select count(*) as src_cnt from t_fork_frequent_trx;
select count(*) as fork_cnt from t_fork_frequent_trx_fork;
select * from t_fork_frequent_trx order by id;
select * from t_fork_frequent_trx_fork order by id;

--echo # 对目标表进行频繁的事务操作（提交）
--echo # 执行多次事务提交操作，验证无预期外报错
start transaction;
insert into t_fork_frequent_trx_fork values (2, 'ForkFreq1', 201, 1);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (3, 'ForkFreq2', 202, 2);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (4, 'ForkFreq3', 203, 3);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (5, 'ForkFreq4', 204, 4);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (6, 'ForkFreq5', 205, 5);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

--echo # 对目标表进行频繁的事务操作（部分回滚）
start transaction;
insert into t_fork_frequent_trx_fork values (7, 'ForkFreq6', 206, 6);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
rollback;

start transaction;
insert into t_fork_frequent_trx_fork values (8, 'ForkFreq7', 207, 7);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (9, 'ForkFreq8', 208, 8);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
rollback;

start transaction;
insert into t_fork_frequent_trx_fork values (10, 'ForkFreq9', 209, 9);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

--echo # 验证频繁事务操作后的目标表数据（应包含提交的数据，不包含回滚的数据）
select count(*) as cnt from t_fork_frequent_trx_fork;
select * from t_fork_frequent_trx_fork order by id;

--echo # 验证源表数据未受影响
select count(*) as src_cnt from t_fork_frequent_trx;
select * from t_fork_frequent_trx order by id;

--echo # 验证数据隔离：源表和目标表数据独立
select (select count(*) from t_fork_frequent_trx) as src_cnt, (select count(*) from t_fork_frequent_trx_fork) as fork_cnt;
select (select sum(counter) from t_fork_frequent_trx) as src_sum, (select sum(counter) from t_fork_frequent_trx_fork) as fork_sum;

--echo # 继续对目标表进行更多频繁操作，验证无预期外报错
--echo # 执行更多事务操作
start transaction;
insert into t_fork_frequent_trx_fork values (11, 'ForkFreq10', 210, 10);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (12, 'ForkFreq11', 211, 11);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

start transaction;
insert into t_fork_frequent_trx_fork values (13, 'ForkFreq12', 212, 12);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
rollback;

start transaction;
insert into t_fork_frequent_trx_fork values (14, 'ForkFreq13', 213, 13);
update t_fork_frequent_trx_fork set counter = counter + 1 where id = 1;
commit;

--echo # 最终验证：目标表频繁事务操作后数据正确
select count(*) as cnt from t_fork_frequent_trx_fork;
select * from t_fork_frequent_trx_fork order by id;

--echo # 最终验证：源表数据未受影响
select count(*) as src_cnt from t_fork_frequent_trx;
select * from t_fork_frequent_trx order by id;

drop table t_fork_frequent_trx;
drop table t_fork_frequent_trx_fork;

--echo ============================================
--echo 5. 清理
--echo ============================================

drop database if exists db_fork_transaction;