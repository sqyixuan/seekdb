--echo # 可能需要等待major freeze或minor freeze后新数据才使用新压缩算法
--echo # 这里仅验证表结构设置，实际压缩效果需要存储层确认

drop table t_compression_zstd_138;
drop table t_compression_zstd_138_fork;

--echo ============================================
--echo 2. 存储方式测试
--echo ============================================

--echo # 2.1 行存（ORGANIZATION INDEX）
drop table if exists t_storage_row;
drop table if exists t_storage_row_fork;

create table t_storage_row (
    id int primary key,
    name varchar(50),
    value int,
    data varchar(100)
)ORGANIZATION INDEX partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
) ;

insert into t_storage_row values (1, 'Row1', 100, 'Data1');
insert into t_storage_row values (101, 'Row2', 200, 'Data2');
insert into t_storage_row values (50, 'Row3', 300, 'Data3');

--echo # 验证源表存储方式设置
--replace_regex /ORGANIZATION [A-Z]*/ORGANIZATION storage_type/g
show create table t_storage_row;

--echo # 验证源表数据
select count(*) as cnt from t_storage_row;
select * from t_storage_row order by id;

--echo # Fork表
fork table t_storage_row to t_storage_row_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表存储方式设置（应与源表一致）
--replace_regex /ORGANIZATION [A-Z]*/ORGANIZATION storage_type/g
show create table t_storage_row_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_storage_row_fork;
select * from t_storage_row_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_storage_row) as src_cnt, (select count(*) from t_storage_row_fork) as fork_cnt;

--echo # 注意：fork后修改存储方式，需要确认存储方式实际更改的时间
--echo # 可能需要等待major freeze或minor freeze后新数据才使用新存储方式

drop table t_storage_row;
drop table t_storage_row_fork;

--echo # 2.2 列存（ORGANIZATION COLUMN）不支持
drop table if exists t_storage_column;
drop table if exists t_storage_column_fork;

--error 1064
create table t_storage_column (
    id int primary key,
    name varchar(50),
    value int,
    data varchar(100)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
) ORGANIZATION COLUMN;



--echo # 2.3 混合存储（ROW_FORMAT = DYNAMIC）
drop table if exists t_storage_mixed;
drop table if exists t_storage_mixed_fork;

create table t_storage_mixed (
    id int primary key,
    name varchar(50),
    value int,
    data varchar(100)
)ROW_FORMAT = DYNAMIC partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_storage_mixed values (1, 'Mixed1', 100, 'Data1');
insert into t_storage_mixed values (101, 'Mixed2', 200, 'Data2');
insert into t_storage_mixed values (50, 'Mixed3', 300, 'Data3');

--echo # 验证源表存储方式设置
--replace_regex /ORGANIZATION [A-Z]*/ORGANIZATION storage_type/g
show create table t_storage_mixed;

--echo # 验证源表数据
select count(*) as cnt from t_storage_mixed;
select * from t_storage_mixed order by id;

--echo # Fork表
fork table t_storage_mixed to t_storage_mixed_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表存储方式设置
--replace_regex /ORGANIZATION [A-Z]*/ORGANIZATION storage_type/g
show create table t_storage_mixed_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_storage_mixed_fork;
select * from t_storage_mixed_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_storage_mixed) as src_cnt, (select count(*) from t_storage_mixed_fork) as fork_cnt;

drop table t_storage_mixed;
drop table t_storage_mixed_fork;

--echo ============================================
--echo 3. 字符集类型测试
--echo ============================================

--echo # 3.1 utf8mb4字符集
drop table if exists t_charset_utf8mb4;
drop table if exists t_charset_utf8mb4_fork;

create table t_charset_utf8mb4 (
    id int primary key,
    name varchar(50) charset utf8mb4,
    data varchar(100) charset utf8mb4
) DEFAULT CHARSET = utf8mb4 partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
) ;

insert into t_charset_utf8mb4 values (1, '测试UTF8MB4', '数据1');
insert into t_charset_utf8mb4 values (101, 'TestUTF8MB4', 'Data2');
insert into t_charset_utf8mb4 values (50, '😀🎉测试', 'Emoji数据');

--echo # 验证源表字符集设置
--replace_regex /DEFAULT CHARSET = [a-z0-9_]*/DEFAULT CHARSET = charset_name/g
show create table t_charset_utf8mb4;

--echo # 验证源表数据
select count(*) as cnt from t_charset_utf8mb4;
select * from t_charset_utf8mb4 order by id;

--echo # Fork表
fork table t_charset_utf8mb4 to t_charset_utf8mb4_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表字符集设置
--replace_regex /DEFAULT CHARSET = [a-z0-9_]*/DEFAULT CHARSET = charset_name/g
show create table t_charset_utf8mb4_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_charset_utf8mb4_fork;
select * from t_charset_utf8mb4_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_charset_utf8mb4) as src_cnt, (select count(*) from t_charset_utf8mb4_fork) as fork_cnt;

drop table t_charset_utf8mb4;
drop table t_charset_utf8mb4_fork;

