--echo ============================================
--echo 4. 约束测试
--echo ============================================

--echo # 4.1 非空约束
drop table if exists t_constraint_notnull;
drop table if exists t_constraint_notnull_fork;

create table t_constraint_notnull (
    id int primary key,
    name varchar(50) not null,
    value int not null,
    data varchar(100)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_constraint_notnull values (1, 'Test1', 100, 'Data1');
insert into t_constraint_notnull values (101, 'Test2', 200, NULL);
insert into t_constraint_notnull values (50, 'Test3', 300, 'Data3');

--echo # 验证源表约束
show create table t_constraint_notnull;

--echo # 验证源表数据
select count(*) as cnt from t_constraint_notnull;
select * from t_constraint_notnull order by id;

--echo # 测试非空约束（预期失败）
--error ER_BAD_NULL_ERROR
insert into t_constraint_notnull values (2, NULL, 100, 'Data');

--echo # Fork表
fork table t_constraint_notnull to t_constraint_notnull_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表约束（应与源表一致）
show create table t_constraint_notnull_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_constraint_notnull_fork;
select * from t_constraint_notnull_fork order by id;

--echo # 测试目标表非空约束（预期失败）
--error ER_BAD_NULL_ERROR
insert into t_constraint_notnull_fork values (3, NULL, 100, 'Data');

--echo # 验证数据一致性
select (select count(*) from t_constraint_notnull) as src_cnt, (select count(*) from t_constraint_notnull_fork) as fork_cnt;

drop table t_constraint_notnull;
drop table t_constraint_notnull_fork;

--echo # 4.2 唯一性约束
drop table if exists t_constraint_unique;
drop table if exists t_constraint_unique_fork;

--echo # 注意：分区表中的唯一索引必须包含分区键，因此使用非分区表来测试email的唯一性约束
create table t_constraint_unique (
    id int primary key,
    name varchar(50),
    email varchar(100) unique,
    value int
);

insert into t_constraint_unique values (1, 'Test1', 'test1@example.com', 100);
insert into t_constraint_unique values (101, 'Test2', 'test2@example.com', 200);
insert into t_constraint_unique values (50, 'Test3', 'test3@example.com', 300);

--echo # 验证源表约束
show create table t_constraint_unique;
show indexes from t_constraint_unique;

--echo # 验证源表数据
select count(*) as cnt from t_constraint_unique;
select * from t_constraint_unique order by id;

--echo # 测试唯一性约束（预期失败）
--error ER_DUP_ENTRY
insert into t_constraint_unique values (2, 'Test4', 'test1@example.com', 400);

--echo # Fork表
fork table t_constraint_unique to t_constraint_unique_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表约束（应与源表一致）
show create table t_constraint_unique_fork;
show indexes from t_constraint_unique_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_constraint_unique_fork;
select * from t_constraint_unique_fork order by id;

--echo # 测试目标表唯一性约束（预期失败）
--error ER_DUP_ENTRY
insert into t_constraint_unique_fork values (3, 'Test5', 'test1@example.com', 500);

--echo # 验证数据一致性
select (select count(*) from t_constraint_unique) as src_cnt, (select count(*) from t_constraint_unique_fork) as fork_cnt;

drop table t_constraint_unique;
drop table t_constraint_unique_fork;

--echo # 4.3 主键约束
drop table if exists t_constraint_pk;
drop table if exists t_constraint_pk_fork;

create table t_constraint_pk (
    id int primary key,
    name varchar(50),
    value int
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_constraint_pk values (1, 'Test1', 100);
insert into t_constraint_pk values (101, 'Test2', 200);
insert into t_constraint_pk values (50, 'Test3', 300);

--echo # 验证源表主键约束
show create table t_constraint_pk;
show indexes from t_constraint_pk;

--echo # 验证源表数据
select count(*) as cnt from t_constraint_pk;
select * from t_constraint_pk order by id;

--echo # 测试主键约束（预期失败）
--error ER_DUP_ENTRY
insert into t_constraint_pk values (1, 'Test4', 400);

--echo # 测试主键非空约束（预期失败）
--error ER_BAD_NULL_ERROR
insert into t_constraint_pk values (NULL, 'Test5', 500);

--echo # Fork表
fork table t_constraint_pk to t_constraint_pk_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表主键约束（应与源表一致）
show create table t_constraint_pk_fork;
show indexes from t_constraint_pk_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_constraint_pk_fork;
select * from t_constraint_pk_fork order by id;

--echo # 测试目标表主键约束（预期失败）
--error ER_DUP_ENTRY
insert into t_constraint_pk_fork values (1, 'Test6', 600);

--echo # 验证数据一致性
select (select count(*) from t_constraint_pk) as src_cnt, (select count(*) from t_constraint_pk_fork) as fork_cnt;

drop table t_constraint_pk;
drop table t_constraint_pk_fork;

--echo # 4.4 外键约束
drop table if exists t_constraint_fk_child_fork;
drop table if exists t_constraint_fk_child;
drop table if exists t_constraint_fk_parent_fork;
drop table if exists t_constraint_fk_parent;

create table t_constraint_fk_parent (
    id int primary key,
    name varchar(50)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

create table t_constraint_fk_child (
    id int primary key,
    parent_id int,
    name varchar(50),
    foreign key (parent_id) references t_constraint_fk_parent(id)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_constraint_fk_parent values (1, 'Parent1');
insert into t_constraint_fk_parent values (101, 'Parent2');

insert into t_constraint_fk_child values (1, 1, 'Child1');
insert into t_constraint_fk_child values (101, 101, 'Child2');
insert into t_constraint_fk_child values (50, 1, 'Child3');

--echo # 验证源表外键约束
show create table t_constraint_fk_child;
show indexes from t_constraint_fk_child;

--echo # 验证源表数据
select count(*) as cnt from t_constraint_fk_parent;
select count(*) as cnt from t_constraint_fk_child;
select * from t_constraint_fk_parent order by id;
select * from t_constraint_fk_child order by id;

--echo # 测试外键约束（预期失败）
--error ER_NO_REFERENCED_ROW_2
insert into t_constraint_fk_child values (2, 999, 'InvalidChild');

--echo # Fork父表
fork table t_constraint_fk_parent to t_constraint_fk_parent_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # Fork子表
fork table t_constraint_fk_child to t_constraint_fk_child_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表外键约束
--echo # 注意：fork后外键约束可能不会fork，需要验证
show create table t_constraint_fk_child_fork;
show indexes from t_constraint_fk_child_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_constraint_fk_parent_fork;
select count(*) as cnt from t_constraint_fk_child_fork;
select * from t_constraint_fk_parent_fork order by id;
select * from t_constraint_fk_child_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_constraint_fk_parent) as src_cnt, (select count(*) from t_constraint_fk_parent_fork) as fork_cnt;
select (select count(*) from t_constraint_fk_child) as src_cnt, (select count(*) from t_constraint_fk_child_fork) as fork_cnt;

--echo # 注意：如果fork后外键约束被保留，测试外键约束（预期失败）
--echo # 如果fork后外键约束不被保留，可以插入无效外键值
--echo # 这里先测试是否可以插入无效外键值（根据实际行为调整）
insert into t_constraint_fk_child_fork values (2, 999, 'InvalidChildFork');
select * from t_constraint_fk_child_fork where id = 2;

drop table t_constraint_fk_child;
drop table t_constraint_fk_child_fork;
drop table t_constraint_fk_parent;
drop table t_constraint_fk_parent_fork;

--echo # 4.5 Check约束
drop table if exists t_constraint_check;
drop table if exists t_constraint_check_fork;

create table t_constraint_check (
    id int primary key,
    name varchar(50),
    value int,
    status int,
    constraint chk_value check (value > 0),
    constraint chk_status check (status in (0, 1, 2))
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_constraint_check values (1, 'Test1', 100, 1);
insert into t_constraint_check values (101, 'Test2', 200, 2);
insert into t_constraint_check values (50, 'Test3', 300, 0);

--echo # 验证源表Check约束
show create table t_constraint_check;

--echo # 验证源表数据
select count(*) as cnt from t_constraint_check;
select * from t_constraint_check order by id;

--echo # 测试Check约束（预期失败）
--error 3819
insert into t_constraint_check values (2, 'Test4', -1, 1);

--error 3819
insert into t_constraint_check values (3, 'Test5', 100, 5);

--echo # Fork表
fork table t_constraint_check to t_constraint_check_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表Check约束（应与源表一致）
show create table t_constraint_check_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_constraint_check_fork;
select * from t_constraint_check_fork order by id;

--echo # 测试目标表Check约束（预期失败）
--error 3819
insert into t_constraint_check_fork values (4, 'Test6', -1, 1);

--error 3819
insert into t_constraint_check_fork values (5, 'Test7', 100, 5);

--echo # 验证数据一致性
select (select count(*) from t_constraint_check) as src_cnt, (select count(*) from t_constraint_check_fork) as fork_cnt;

drop table t_constraint_check;
drop table t_constraint_check_fork;

--echo ============================================
--echo 5. 清理
--echo ============================================

drop database if exists db_fork_storage;

