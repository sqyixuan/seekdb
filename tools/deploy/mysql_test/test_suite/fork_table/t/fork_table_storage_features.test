##owner: chenminsi.cms
##owner group: 底层引擎部-轻量版
##description: Fork Table存储特性测试（压缩算法、存储方式、字符集、约束）
##tags: fork_table compression storage charset constraint
##author: chenminsi.cms

--disable_warnings
drop database if exists db_fork_storage;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_storage;
use db_fork_storage;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. 压缩算法测试
--echo ============================================

--echo # 1.1 不使用压缩算法
drop table if exists t_compression_none;
drop table if exists t_compression_none_fork;

create table t_compression_none (
    id int primary key,
    name varchar(100),
    data varchar(500)
) COMPRESSION = 'none' partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
) ;

insert into t_compression_none values (1, 'Test1', repeat('A', 200));
insert into t_compression_none values (101, 'Test2', repeat('B', 200));
insert into t_compression_none values (50, 'Test3', repeat('C', 200));

--echo # 验证源表压缩算法设置
--replace_regex /COMPRESSION = '[^']*'/COMPRESSION = 'compression_value'/g
show create table t_compression_none;

--echo # 验证源表数据
select count(*) as cnt from t_compression_none;
select id, name, length(data) as data_len from t_compression_none order by id;

--echo # Fork表
fork table t_compression_none to t_compression_none_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表压缩算法设置（应与源表一致）
--replace_regex /COMPRESSION = '[^']*'/COMPRESSION = 'compression_value'/g
show create table t_compression_none_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_compression_none_fork;
select id, name, length(data) as data_len from t_compression_none_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_compression_none) as src_cnt, (select count(*) from t_compression_none_fork) as fork_cnt;

--echo # 注意：压缩算法验证说明
--echo # 1. show create table 只能验证表结构中的压缩算法配置，不能验证存储层实际压缩效果
--echo # 2. 压缩算法在存储层的实际生效需要数据落盘（major freeze/minor freeze）后才能体现
--echo # 3. 要验证实际压缩效果，需要：
--echo #    - 触发major freeze让数据落盘：alter system major freeze;
--echo #    - 查询系统表查看压缩信息（需要存储层支持）
--echo #    - 或比较不同压缩算法下的存储空间使用情况
--echo # 4. 当前测试主要验证fork后表结构中的压缩算法配置是否正确继承

drop table t_compression_none;
drop table t_compression_none_fork;

--echo # 1.2 lz4_1.0压缩算法
drop table if exists t_compression_lz4;
drop table if exists t_compression_lz4_fork;

create table t_compression_lz4 (
    id int primary key,
    name varchar(100),
    data varchar(500)
) COMPRESSION = 'lz4_1.0'  partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
) ;

insert into t_compression_lz4 values (1, 'Test1', repeat('A', 200));
insert into t_compression_lz4 values (101, 'Test2', repeat('B', 200));
insert into t_compression_lz4 values (50, 'Test3', repeat('C', 200));

--echo # 验证源表压缩算法设置
--replace_regex /COMPRESSION = '[^']*'/COMPRESSION = 'compression_value'/g
show create table t_compression_lz4;

--echo # 验证源表数据
select count(*) as cnt from t_compression_lz4;
select id, name, length(data) as data_len from t_compression_lz4 order by id;

--echo # Fork表
fork table t_compression_lz4 to t_compression_lz4_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证目标表压缩算法设置
--replace_regex /COMPRESSION = '[^']*'/COMPRESSION = 'compression_value'/g
show create table t_compression_lz4_fork;

--echo # 验证目标表数据
select count(*) as cnt from t_compression_lz4_fork;
select id, name, length(data) as data_len from t_compression_lz4_fork order by id;

--echo # 验证数据一致性
select (select count(*) from t_compression_lz4) as src_cnt, (select count(*) from t_compression_lz4_fork) as fork_cnt;

drop table t_compression_lz4;
drop table t_compression_lz4_fork;

