##owner: chenminsi.cms
##owner group: 底层引擎部-轻量版
##description: Fork Table基础功能测试
##tags: fork_table basic
##author: chenminsi.cms

--disable_warnings
drop database if exists db_fork_basic;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_basic;
use db_fork_basic;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
--echo ============================================
--echo 11. 交叉增删改隔离测试（有主键，源表/Fork表互不影响）
--echo ============================================

drop table if exists t_cross;
drop table if exists t_cross_fork;

create table t_cross (
    id int primary key,
    name varchar(50),
    v int
);

insert into t_cross values (1, 'S_A', 10), (2, 'S_B', 20), (3, 'S_C', 30);
fork table t_cross to t_cross_fork;

--echo # Fork表：更新/删除/插入
update t_cross_fork set name = 'F_A', v = 11 where id = 1;
delete from t_cross_fork where id = 2;
insert into t_cross_fork values (99, 'F_NEW', 99);

--echo # 源表：更新/删除/插入
update t_cross set name = 'S_C_U', v = 31 where id = 3;
delete from t_cross where id = 1;
insert into t_cross values (88, 'S_NEW', 88);

--echo # 校验数量与数据隔离
select count(*) as cnt from t_cross;
select count(*) as cnt from t_cross_fork;
select * from t_cross order by id;
select * from t_cross_fork order by id;

--echo # 同ID分别写入不同内容，主键问题
insert into t_cross values (100, 'S_100', 100);
insert into t_cross_fork values (100, 'F_100', 1000);
select * from t_cross where id = 100;
select * from t_cross_fork where id = 100;

drop table if exists t_cross;
drop table if exists t_cross_fork;

--echo ============================================
--echo 12. 堆表Fork测试（无主键）
--echo ============================================

drop table if exists t_heap;
drop table if exists t_heap_fork;

create table t_heap (
    c1 int,
    c2 varchar(20)
);

insert into t_heap values (1, 'H_A'), (2, 'H_B'), (3, 'H_C');
fork table t_heap to t_heap_fork;

--echo # 校验Fork表数据与源表一致
select count(*) as cnt from t_heap;
select count(*) as cnt from t_heap_fork;

--echo # Fork表新增/更新，源表删除
insert into t_heap_fork values (4, 'H_FORK');
update t_heap_fork set c2 = 'H_B_U' where c1 = 2;
delete from t_heap where c1 = 1;


--echo # 同ID分别写入不同内容
insert into t_heap values (100, 'S_100');
insert into t_heap_fork values (100, 'F_100');
select * from t_heap where c1 = 100;
select * from t_heap_fork where c1 = 100;

--echo # 校验隔离
select count(*) as cnt from t_heap;
select count(*) as cnt from t_heap_fork;
select * from t_heap order by c1;
select * from t_heap_fork order by c1;

--echo ============================================
--echo 13. 无主键但有唯一索引的Fork测试
--echo ============================================

drop table if exists t_nopk_unique;
drop table if exists t_nopk_unique_fork;

create table t_nopk_unique (
    c1 int,
    c2 varchar(20),
    unique key uk_c1(c1)
);

insert into t_nopk_unique values (1, 'U_A'), (2, 'U_B');
fork table t_nopk_unique to t_nopk_unique_fork;

--echo # Fork表唯一约束生效，源表、目标表受约束
--error 1062
insert into t_nopk_unique_fork values (1, 'U_DUP');
insert into t_nopk_unique_fork values (3, 'U_C');
--error 1062
insert into t_nopk_unique values (1, 'U_DUP');
insert into t_nopk_unique values (3, 'U_C_A');
select * from t_nopk_unique order by c1;
select * from t_nopk_unique_fork order by c1;

--echo ============================================
--echo 14. Fork表自增列：手动插入与递增验证
--echo ============================================

drop table if exists t_auto;
drop table if exists t_auto_fork;

create table t_auto (
    id int auto_increment primary key,
    name varchar(20)
);

insert into t_auto(name) values ('A1'), ('A2');
fork table t_auto to t_auto_fork;

--echo # Fork表手动插入较大ID，验证后续自增
insert into t_auto_fork values (1000, 'F_1000');
insert into t_auto_fork(name) values ('F_NEXT');
select * from t_auto_fork order by id;
select * from t_auto order by id;

--echo ============================================
--echo 15. 视图不支持Fork测试
--echo ============================================

drop table if exists t_view_base;
drop view if exists v_test;
drop view if exists v_test_fork;

--echo # 创建基础表
create table t_view_base (
    id int primary key,
    name varchar(50),
    age int
);

insert into t_view_base values (1, 'Alice', 25);
insert into t_view_base values (2, 'Bob', 30);

--echo # 创建视图
create view v_test as select id, name, age from t_view_base where age > 20;

--echo # 验证源视图存在
select * from v_test;

--echo # 尝试Fork视图（预期不支持）
--error 1347
fork table v_test to v_test_fork;

--echo # 验证源视图仍然存在且可用
select * from v_test;

--echo # 验证目标视图不存在
--error 1146
select * from v_test_fork;

drop view v_test;
drop table t_view_base;

--echo ============================================
--echo 16. 物化视图不支持Fork测试
--echo ============================================

drop table if exists t_mv_base;
drop table if exists base_t1;
drop table if exists base_t2;
drop table if exists mv;
drop table if exists mv_fork;

--echo # 创建基础表（完全复制提供的语法）
create table base_t1(a int primary key, b int);
create table base_t2(c int primary key, d int);

--echo # 创建物化视图日志（完全复制提供的语法）
create materialized view log on base_t1 with(b);
create materialized view log on base_t2 with(d);

--echo # 创建物化视图（完全复制提供的语法）
create materialized view mv 
REFRESH fast 
START WITH sysdate() 
NEXT sysdate() + INTERVAL 1 second 
as 
select a,b,c,d 
from base_t1 
join base_t2 on base_t1.a=base_t2.c;

--echo # 插入测试数据（完全复制提供的语法）
insert into base_t1 values(1, 10);
insert into base_t2 values(1, 100);

--echo # 测试对物化视图进行fork操作 
--error 1347
fork table mv to mv_fork;

--echo # 验证fork结果
--error 1146
select * from mv_fork;

--echo # 清理
drop table if exists mv_fork;
drop materialized view if exists mv;
drop materialized view log on base_t1;
drop materialized view log on base_t2;
drop table if exists base_t1;
drop table if exists base_t2;

--echo ============================================
--echo 17. 临时表不支持Fork测试
--echo ============================================

drop table if exists t_temp;
drop table if exists t_temp_fork;

--echo # 创建临时表
--error 1235
create temporary table t_temp (
    id int primary key,
    name varchar(50)
);



--echo ============================================
--echo 18. 含外键的表Fork测试（外键信息不Fork）
--echo ============================================

drop table if exists t_fk_child_fork;
drop table if exists t_fk_child;
drop table if exists t_fk_parent_fork;
drop table if exists t_fk_parent;

--echo # 创建父表
create table t_fk_parent (
    id int primary key,
    name varchar(50)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (300)
);

insert into t_fk_parent values (1, 'Parent1');
insert into t_fk_parent values (101, 'Parent2');

--echo # 创建子表（含外键）
create table t_fk_child (
    id int primary key,
    parent_id int,
    name varchar(50),
    foreign key (parent_id) references t_fk_parent(id)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (300)
);

insert into t_fk_child values (1, 1, 'Child1');
insert into t_fk_child values (101, 101, 'Child2');

--echo # 验证源表外键约束
--replace_regex /OBFK_[0-9]+/OBFK_FK_ID/g
show create table t_fk_child;
--echo # 验证外键约束生效
--error 1452
insert into t_fk_child values (2, 999, 'Invalid');

--echo # Fork父表
fork table t_fk_parent to t_fk_parent_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # Fork子表
fork table t_fk_child to t_fk_child_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证源表外键信息仍然存在
show create table t_fk_parent;
--replace_regex /OBFK_[0-9]+/OBFK_FK_ID/g
show create table t_fk_child;

--echo # 验证目标表结构（外键信息不应被Fork）
show create table t_fk_parent_fork;
--replace_regex /OBFK_[0-9]+/OBFK_FK_ID/g
show create table t_fk_child_fork;

--echo # 验证源表外键约束仍然有效
--error 1452
insert into t_fk_child values (3, 999, 'Invalid_Src');

--echo # 验证目标表没有外键约束（可以插入无效外键值）
insert into t_fk_child_fork values (3, 999, 'Invalid_Fork');
select * from t_fk_child_fork where id = 3;

--echo # 验证源表和目标表数据隔离
select * from t_fk_parent order by id;
select * from t_fk_parent_fork order by id;
select * from t_fk_child order by id;
select * from t_fk_child_fork order by id;

--echo # 在源表中插入数据，验证外键约束
insert into t_fk_parent values (50, 'Parent3');
insert into t_fk_child values (50, 50, 'Child3');
select * from t_fk_child where id = 50;

--echo # 验证目标表不受影响
select * from t_fk_child_fork where id = 50;

--echo # 在目标表中插入数据（无外键约束）
insert into t_fk_parent_fork values (200, 'Parent_Fork');
insert into t_fk_child_fork values (200, 200, 'Child_Fork');
select * from t_fk_child_fork where id = 200;

--echo # 验证源表不受影响
select * from t_fk_child where id = 200;

drop table t_fk_child;
drop table t_fk_child_fork;
drop table t_fk_parent;
drop table t_fk_parent_fork;

--echo ============================================
--echo 19. 含Trigger的表Fork测试（Trigger信息不Fork）
--echo ============================================

drop table if exists t_trigger_fork;
drop table if exists t_trigger;
drop trigger if exists trg_before_insert;
drop trigger if exists trg_before_insert_fork;

--echo # 创建表
create table t_trigger (
    id int primary key,
    name varchar(50),
    created_time datetime,
    updated_count int default 0
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建Trigger
create trigger trg_before_insert before insert on t_trigger
for each row set new.created_time = now(), new.updated_count = 0;

insert into t_trigger(id, name) values (1, 'Trigger_Test1');
insert into t_trigger(id, name) values (101, 'Trigger_Test2');

--echo # 验证源表Trigger生效
select id, name, created_time is not null as has_time, updated_count from t_trigger;

--echo # 验证源表Trigger信息
--replace_regex /[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]+/TIMESTAMP/g
show triggers like 't_trigger';

--echo # Fork表
fork table t_trigger to t_trigger_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证源表Trigger信息仍然存在
--replace_regex /[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]+/TIMESTAMP/g
show triggers like 't_trigger';

--echo # 验证目标表Trigger信息（Trigger不应被Fork）
show triggers like 't_trigger_fork';

--echo # 验证源表Trigger仍然有效
insert into t_trigger(id, name) values (50, 'Trigger_Src');
select id, name, created_time is not null as has_time, updated_count from t_trigger where id = 50;

--echo # 验证目标表没有Trigger（插入时不会自动设置created_time）
insert into t_trigger_fork(id, name) values (50, 'Trigger_Fork');
select id, name, created_time is null as no_time, updated_count from t_trigger_fork where id = 50;

--echo # 验证源表和目标表数据隔离
select count(*) as cnt from t_trigger;
select count(*) as cnt from t_trigger_fork;
--replace_column 3 TIMESTAMP
select * from t_trigger order by id;
--replace_column 3 TIMESTAMP
select * from t_trigger_fork order by id;

drop trigger trg_before_insert;
drop table t_trigger;
drop table t_trigger_fork;

--echo ============================================
--echo 20. 系统表不支持Fork测试
--echo ============================================

--echo # 尝试Fork系统表（预期不支持）
--error 1347
fork table oceanbase.__all_table to __all_table_fork;

--echo # 尝试Fork其他系统表
--error 1347
fork table information_schema.tables to tables_fork;

--echo # 验证系统表仍然存在且可用
select count(*) > 0 from oceanbase.__all_table limit 1;
select count(*) > 0 from information_schema.tables limit 1;

--echo ============================================
--echo 21. 内部表（索引辅助表）不支持Fork测试
--echo ============================================

drop table if exists t_idx_base;
drop table if exists t_idx_base_fork;

--echo # 创建带索引的表
create table t_idx_base (
    id int primary key,
    name varchar(50),
    email varchar(100),
    index idx_name(name),
    index idx_email(email)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_idx_base values (1, 'Alice', 'alice@example.com');
insert into t_idx_base values (101, 'Bob', 'bob@example.com');

--echo # Fork基础表
fork table t_idx_base to t_idx_base_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 查询内部索引辅助表（如果存在）
--echo # 注意：内部表的命名规则可能不同，这里仅做示例
connection obsys;
let $base_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='t_idx_base' and database_id=(select database_id from oceanbase.__all_virtual_database where database_name='db_fork_basic'), table_id, 1);
--echo # 查找可能的索引辅助表
--replace_regex /table_id = [0-9]*/table_id = base_table_id/g
eval select table_name, table_type from oceanbase.__all_virtual_table where data_table_id = $base_table_id and table_type in ('INDEX', 'AUX_LOB_META', 'AUX_LOB_PIECE') limit 10;

connection default;

--echo # 尝试Fork索引辅助表（预期不支持或不存在）
--echo # 注意：内部表通常不可见或不可直接访问，这里测试fork操作会失败
--error ER_NOT_SUPPORTED_YET
--error 1146
fork table __idx_name_aux to __idx_name_aux_fork;

--echo # 验证源表索引仍然可用
select * from t_idx_base where name = 'Alice';
select * from t_idx_base where email = 'alice@example.com';

--echo # 验证目标表索引可用
select * from t_idx_base_fork where name = 'Alice';
select * from t_idx_base_fork where email = 'alice@example.com';

--echo # 验证源表和目标表索引独立
show indexes from t_idx_base;
show indexes from t_idx_base_fork;

drop table t_idx_base;
drop table t_idx_base_fork;

--echo ============================================
--echo 22. 含外键和Trigger的复合场景测试
--echo ============================================

drop table if exists t_complex_child_fork;
drop table if exists t_complex_child;
drop table if exists t_complex_parent_fork;
drop table if exists t_complex_parent;

--echo # 创建父表
create table t_complex_parent (
    id int primary key,
    name varchar(50)
);

insert into t_complex_parent values (1, 'Parent1');

--echo # 创建子表（含外键和Trigger）
create table t_complex_child (
    id int primary key,
    parent_id int,
    name varchar(50),
    created_time datetime,
    foreign key (parent_id) references t_complex_parent(id)
);

--echo # 创建Trigger
create trigger trg_complex_insert before insert on t_complex_child
for each row set new.created_time = now();

insert into t_complex_child(id, parent_id, name) values (1, 1, 'Child1');

--echo # 验证源表外键和Trigger
--replace_regex /OBFK_[0-9]+/OBFK_FK_ID/g
show create table t_complex_child;
--replace_regex /[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]+/TIMESTAMP/g
show triggers like 't_complex_child';
select id, parent_id, name, created_time is not null as has_time from t_complex_child;

--echo # Fork父表和子表
fork table t_complex_parent to t_complex_parent_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc
fork table t_complex_child to t_complex_child_fork;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo # 验证源表外键和Trigger仍然存在
--replace_regex /OBFK_[0-9]+/OBFK_FK_ID/g
show create table t_complex_child;
--replace_regex /[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]+/TIMESTAMP/g
show triggers like 't_complex_child';

--echo # 验证目标表没有外键和Trigger
show create table t_complex_child_fork;
show triggers like 't_complex_child_fork';

--echo # 验证源表外键约束仍然有效
--error 1452
insert into t_complex_child(id, parent_id, name) values (2, 999, 'Invalid');

--echo # 验证源表Trigger仍然有效
insert into t_complex_child(id, parent_id, name) values (2, 1, 'Child2');
select id, parent_id, name, created_time is not null as has_time from t_complex_child where id = 2;

--echo # 验证目标表没有外键约束（可以插入无效外键）
insert into t_complex_child_fork(id, parent_id, name) values (2, 999, 'Invalid_Fork');
select id, parent_id, name, created_time is null as no_time from t_complex_child_fork where id = 2;

--echo # 验证目标表没有Trigger（插入时不会自动设置created_time）
insert into t_complex_child_fork(id, parent_id, name) values (3, 1, 'Child3');
select id, parent_id, name, created_time is null as no_time from t_complex_child_fork where id = 3;

--echo # 验证源表和目标表数据隔离
select * from t_complex_parent order by id;
select * from t_complex_parent_fork order by id;
--replace_column 4 TIMESTAMP
select * from t_complex_child order by id;
--replace_column 4 TIMESTAMP
select * from t_complex_child_fork order by id;

drop trigger trg_complex_insert;
drop table t_complex_child;
drop table t_complex_child_fork;
drop table t_complex_parent;
drop table t_complex_parent_fork;

--echo ============================================
--echo 23. fixbug
--echo ============================================
--disable_warnings
DROP TABLE IF EXISTS tbl_5;
DROP TABLE IF EXISTS tbl_14;

--enable_warnings
CREATE TABLE tbl_5 ( 
    col_97 mediumtext NOT NULL,
    col_98 enum('Alice','Bob','Charlie','David'),
    col_99 year DEFAULT '2020',
    col_100 double NOT NULL DEFAULT 9802.972125060098,
    col_101 double,
    col_102 datetime NOT NULL DEFAULT '1973-08-10',
    col_103 float,
    col_104 vector(85) NOT NULL,
    col_105 bigint unsigned NOT NULL,
    col_106 json NOT NULL,
    col_107 char(134) NOT NULL,
    col_108 boolean DEFAULT 1,
    col_109 time,
    col_110 mediumtext NOT NULL,
    col_111 json,
    col_112 ARRAY(int) NOT NULL,
    col_113 bit(60) NOT NULL,
    col_114 enum('Alice','Bob','Charlie','David') NOT NULL DEFAULT 'Alice',
    col_115 blob(161) NOT NULL,
    col_116 decimal(36,3) DEFAULT 7028.936,
    col_117 bit(59) NOT NULL DEFAULT 44555708410085836,
    col_118 tinyint,
    col_119 bigint unsigned NOT NULL DEFAULT 2398105313438364456,
    col_120 tinyint unsigned,
    col_121 set('Alice','Bob','Charlie','David'),
    col_122 bit(16) NOT NULL DEFAULT 30239,
    col_123 mediumint NOT NULL,
    col_124 mediumint DEFAULT -6576803,
    col_125 bit(22) NOT NULL DEFAULT 2066873,
    col_126 decimal(5,3) NOT NULL,
    
    FULLTEXT KEY fulltext_idx_31 (col_97(5)) WITH PARSER NGRAM2 PARSER_PROPERTIES(min_ngram_size=10, max_ngram_size=12) LOCAL,
    FULLTEXT INDEX fulltext_idx_32 (col_107(1)) WITH PARSER NGRAM PARSER_PROPERTIES(ngram_token_size=2) LOCAL,
    KEY idx_33 (col_107(1), col_103) GLOBAL,
    FULLTEXT KEY fulltext_idx_34 (col_110(3)) WITH PARSER NGRAM LOCAL,
    FULLTEXT KEY fulltext_idx_35 (col_110(4)) WITH PARSER SPACE PARSER_PROPERTIES(min_token_size=14, max_token_size=47) LOCAL,
    FULLTEXT KEY fulltext_idx_36 (col_97(4)) WITH PARSER IK PARSER_PROPERTIES(ik_mode='smart') LOCAL,
    FULLTEXT INDEX fulltext_idx_37 (col_97(2)) WITH PARSER SPACE PARSER_PROPERTIES(min_token_size=14, max_token_size=45) LOCAL,
    FULLTEXT KEY fulltext_idx_38 (col_107(4)) WITH PARSER SPACE PARSER_PROPERTIES(min_token_size=7, max_token_size=79) LOCAL,
    FULLTEXT INDEX fulltext_idx_39 (col_97(5)) WITH PARSER NGRAM2 PARSER_PROPERTIES(min_ngram_size=1, max_ngram_size=10) LOCAL,
    FULLTEXT INDEX fulltext_idx_40 (col_107(4)) WITH PARSER IK LOCAL,
    FULLTEXT KEY fulltext_idx_41 (col_110(5)) WITH PARSER IK PARSER_PROPERTIES(ik_mode='max_word') LOCAL,
    FULLTEXT KEY fulltext_idx_42 (col_107) WITH PARSER NGRAM PARSER_PROPERTIES(ngram_token_size=9) LOCAL,
    FULLTEXT INDEX fulltext_idx_43 (col_107) WITH PARSER BENG PARSER_PROPERTIES(min_token_size=8, max_token_size=35) LOCAL,
    FULLTEXT KEY fulltext_idx_44 (col_107) WITH PARSER IK LOCAL,
    FULLTEXT KEY fulltext_idx_45 (col_97(3)) WITH PARSER NGRAM2 PARSER_PROPERTIES(min_ngram_size=6, max_ngram_size=13) LOCAL,
    FULLTEXT KEY fulltext_idx_46 (col_110(4)) WITH PARSER SPACE PARSER_PROPERTIES(min_token_size=2, max_token_size=22) LOCAL,
