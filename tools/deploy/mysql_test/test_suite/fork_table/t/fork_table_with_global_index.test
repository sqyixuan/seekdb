##owner: fankun.fan
##owner group: 底层引擎部-轻量版
##description: Fork Table全局索引处理测试
##tags: fork_table global_index
##author: fankun.fan

--disable_warnings
drop database if exists db_fork_global_index;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;
create database db_fork_global_index;
use db_fork_global_index;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. Fork Table with Single Global Index
--echo ============================================

drop table if exists t1;
drop table if exists t1_fork;

create table t1 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than (300)
);

--echo # 创建全局索引
create index gidx_c on t1(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than MAXVALUE
);

insert into t1 values (1, 'Alice', 10, 'data1');
insert into t1 values (101, 'Bob', 110, 'data2');
insert into t1 values (201, 'Charlie', 210, 'data3');
insert into t1 values (50, 'David', 50, 'data4');
insert into t1 values (150, 'Eve', 150, 'data5');

--echo # Fork表
fork table t1 to t1_fork;

--echo # 验证Fork表的全局索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1_fork;

--echo # 验证全局索引分区结构
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='t1_fork', table_id, 1);
let $gidx_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name like '%gidx_c%' and data_table_id = $table_id, table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = gidx_id/g
eval select count(*) from oceanbase.__all_virtual_part where table_id = $gidx_id;
--replace_regex /table_id = [0-9]*/table_id = gidx_id/g
eval select part_name, high_bound_val from oceanbase.__all_virtual_part where table_id = $gidx_id order by part_id;

connection default;
--echo # 验证通过全局索引查询
select * from t1_fork where c = 10;
select * from t1_fork where c = 110;
select * from t1_fork where c = 210;

--echo # 验证全局索引查询计划
explain select * from t1_fork where c = 10;

--echo ============================================
--echo 2. Fork Table with Multiple Global Indexes
--echo ============================================

drop table if exists t2;
drop table if exists t2_fork;

create table t2 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建多个全局索引
create index gidx_c on t2(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);
create index gidx_d on t2(d) global partition by range columns(d) (
    partition p0 values less than ('M'),
    partition p1 values less than MAXVALUE
);
create index gidx_e on t2(e) global;

insert into t2 values (1, 'Alice', 10, 'data1', 100);
insert into t2 values (101, 'Bob', 110, 'data2', 200);
insert into t2 values (50, 'Charlie', 50, 'data3', 150);

--echo # Fork表
fork table t2 to t2_fork;

--echo # 验证Fork表的多个全局索引
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t2_fork;

--echo # 验证所有全局索引查询功能
select * from t2_fork where c = 10;
select * from t2_fork where d = 'data1';
select * from t2_fork where e = 100;

--echo ============================================
--echo 3. Global Index + Local Index Combination
--echo ============================================

--echo # 3.1 先创建局部索引，后创建全局索引
drop table if exists t3;
drop table if exists t3_fork;

create table t3 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 先创建局部索引
create index lidx_c on t3(c) local;
create index lidx_d on t3(d) local;

--echo # 后创建全局索引
create index gidx_c on t3(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

insert into t3 values (1, 'Alice', 10, 'data1');
insert into t3 values (101, 'Bob', 110, 'data2');
insert into t3 values (50, 'Charlie', 50, 'data3');

--echo # Fork表
fork table t3 to t3_fork;

--echo # 验证Fork表的索引结构（局部+全局）
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3_fork;

--echo # 验证局部索引查询
select * from t3_fork where c = 10;
select * from t3_fork where d = 'data1';

--echo # 验证全局索引查询
select * from t3_fork where c = 110;

--echo # 3.2 先创建全局索引，后创建局部索引
drop table if exists t4;
drop table if exists t4_fork;

create table t4 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 先创建全局索引
create index gidx_c on t4(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

--echo # 后创建局部索引
create index lidx_d on t4(d) local;
create index lidx_c on t4(c) local;

insert into t4 values (1, 'Alice', 10, 'data1');
insert into t4 values (101, 'Bob', 110, 'data2');
insert into t4 values (50, 'Charlie', 50, 'data3');

--echo # Fork表
fork table t4 to t4_fork;

--echo # 验证Fork表的索引结构（全局+局部）
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t4_fork;

--echo # 验证所有索引查询功能
select * from t4_fork where c = 10;
select * from t4_fork where d = 'data1';

--echo # 3.3 混合创建索引（局部、全局、局部、全局...）
drop table if exists t5;
drop table if exists t5_fork;

create table t5 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    f varchar(100),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 混合创建索引顺序：局部 -> 全局 -> 局部 -> 全局
create index lidx_c on t5(c) local;
create index gidx_d on t5(d) global partition by range columns(d) (
    partition p0 values less than ('M'),
    partition p1 values less than MAXVALUE
);
create index lidx_e on t5(e) local;
create index gidx_f on t5(f) global;

insert into t5 values (1, 'Alice', 10, 'data1', 100, 'field1');
insert into t5 values (101, 'Bob', 110, 'data2', 200, 'field2');
insert into t5 values (50, 'Charlie', 50, 'data3', 150, 'field3');

--echo # Fork表
fork table t5 to t5_fork;

--echo # 验证Fork表的混合索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t5_fork;

--echo # 验证所有索引查询功能
select * from t5_fork where c = 10;
select * from t5_fork where d = 'data1';
select * from t5_fork where e = 100;
select * from t5_fork where f = 'field1';

--echo ============================================
--echo 4. Global Index + Unique Index Combination
--echo ============================================

--echo # 4.1 全局唯一索引
drop table if exists t6;
drop table if exists t6_fork;

create table t6 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建全局唯一索引
create unique index gidx_uk_c on t6(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

insert into t6 values (1, 'Alice', 10, 'data1');
insert into t6 values (101, 'Bob', 110, 'data2');
insert into t6 values (50, 'Charlie', 50, 'data3');

--echo # Fork表
fork table t6 to t6_fork;

--echo # 验证Fork表的全局唯一索引
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t6_fork;

--echo # 验证全局唯一索引约束在Fork表中独立
--error 1062
insert into t6_fork values (2, 'Alice2', 10, 'data2');

--echo # 在Fork表中插入新的唯一值
insert into t6_fork values (2, 'Alice2', 20, 'data2');

--echo # 验证源表的唯一约束仍然有效（fork操作不影响源表约束）
--error 1062
insert into t6 values (3, 'Alice3', 10, 'data3');

--echo # 4.2 局部唯一索引 + 全局普通索引
drop table if exists t7;
drop table if exists t7_fork;

create table t7 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建局部唯一索引（必须包含分区键a）
create unique index lidx_uk_c on t7(a, c) local;

--echo # 创建全局普通索引
create index gidx_d on t7(d) global partition by range columns(d) (
    partition p0 values less than ('M'),
    partition p1 values less than MAXVALUE
);

insert into t7 values (1, 'Alice', 10, 'data1');
insert into t7 values (101, 'Bob', 110, 'data2');

--echo # Fork表
fork table t7 to t7_fork;

--echo # 验证Fork表的索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t7_fork;

--echo # 验证局部唯一索引约束（(a, c)组合唯一）
--error 1062
insert into t7_fork values (1, 'Alice2', 10, 'data2');

--echo # 验证全局索引查询
select * from t7_fork where d = 'data1';

--echo # 4.3 全局唯一索引 + 局部普通索引
drop table if exists t8;
drop table if exists t8_fork;

create table t8 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建全局唯一索引
create unique index gidx_uk_c on t8(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

--echo # 创建局部普通索引
create index lidx_d on t8(d) local;

insert into t8 values (1, 'Alice', 10, 'data1');
insert into t8 values (101, 'Bob', 110, 'data2');

--echo # Fork表
fork table t8 to t8_fork;

--echo # 验证Fork表的索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t8_fork;

--echo # 验证全局唯一索引约束
--error 1062
insert into t8_fork values (2, 'Alice2', 10, 'data2');

--echo # 验证局部索引查询
select * from t8_fork where d = 'data1';

--echo ============================================
--echo 5. Global Index + Composite Index Combination
--echo ============================================

--echo # 5.1 全局复合索引
drop table if exists t9;
drop table if exists t9_fork;

create table t9 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建全局复合索引
create index gidx_cd on t9(c, d) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

insert into t9 values (1, 'Alice', 10, 'data1', 100);
insert into t9 values (101, 'Bob', 110, 'data2', 200);
insert into t9 values (50, 'Charlie', 50, 'data3', 150);

--echo # Fork表
fork table t9 to t9_fork;

--echo # 验证Fork表的全局复合索引
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t9_fork;

--echo # 验证通过全局复合索引查询
select * from t9_fork where c = 10 and d = 'data1';
select * from t9_fork where c = 110 and d = 'data2';

--echo # 5.2 局部复合索引 + 全局单列索引
drop table if exists t10;
drop table if exists t10_fork;

create table t10 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建局部复合索引
create index lidx_cd on t10(c, d) local;

--echo # 创建全局单列索引
create index gidx_e on t10(e) global partition by range(e) (
    partition p0 values less than (150),
    partition p1 values less than MAXVALUE
);

insert into t10 values (1, 'Alice', 10, 'data1', 100);
insert into t10 values (101, 'Bob', 110, 'data2', 200);
insert into t10 values (50, 'Charlie', 50, 'data3', 150);

--echo # Fork表
fork table t10 to t10_fork;

--echo # 验证Fork表的索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t10_fork;

--echo # 验证局部复合索引查询
select * from t10_fork where c = 10 and d = 'data1';

--echo # 验证全局单列索引查询
select * from t10_fork where e = 100;

--echo # 5.3 全局复合索引 + 局部单列索引
drop table if exists t11;
drop table if exists t11_fork;

create table t11 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建全局复合索引
create index gidx_cd on t11(c, d) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

--echo # 创建局部单列索引
create index lidx_e on t11(e) local;

insert into t11 values (1, 'Alice', 10, 'data1', 100);
insert into t11 values (101, 'Bob', 110, 'data2', 200);
insert into t11 values (50, 'Charlie', 50, 'data3', 150);

--echo # Fork表
fork table t11 to t11_fork;

--echo # 验证Fork表的索引结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t11_fork;

--echo # 验证全局复合索引查询
select * from t11_fork where c = 10 and d = 'data1';

--echo # 验证局部单列索引查询
select * from t11_fork where e = 100;

--echo ============================================
--echo 6. Random Index Creation Order Test
--echo ============================================

--echo # 测试索引创建顺序随机，验证Fork表索引顺序一致性
drop table if exists t12;
drop table if exists t12_fork;

create table t12 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    e int,
    f varchar(100),
    g int,
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 随机顺序创建多个索引（局部/全局混合）
--echo # 顺序：全局 -> 局部 -> 全局 -> 局部 -> 全局 -> 局部
create index gidx_c on t12(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);
create index lidx_d on t12(d) local;
create index gidx_e on t12(e) global;
create index lidx_f on t12(f) local;
create index gidx_g on t12(g) global partition by range(g) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);
create index lidx_cd on t12(c, d) local;

insert into t12 values (1, 'Alice', 10, 'data1', 100, 'field1', 50);
insert into t12 values (101, 'Bob', 110, 'data2', 200, 'field2', 150);
insert into t12 values (50, 'Charlie', 50, 'data3', 150, 'field3', 75);

--echo # Fork表
fork table t12 to t12_fork;

--echo # 验证Fork表的索引结构（验证索引顺序一致性）
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t12_fork;

--echo # 验证所有索引查询功能不受创建顺序影响
select * from t12_fork where c = 10;
select * from t12_fork where d = 'data1';
select * from t12_fork where e = 100;
select * from t12_fork where f = 'field1';
select * from t12_fork where g = 50;
select * from t12_fork where c = 10 and d = 'data1';

--echo ============================================
--echo 7. Global Index Isolation Test
--echo ============================================

--echo # 验证Fork表全局索引修改不影响源表
drop table if exists t13;
drop table if exists t13_fork;

create table t13 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

create index gidx_c on t13(c) global partition by range(c) (
    partition p0 values less than (100),
    partition p1 values less than MAXVALUE
);

insert into t13 values (1, 'Alice', 10, 'data1');
insert into t13 values (101, 'Bob', 110, 'data2');
insert into t13 values (50, 'Charlie', 50, 'data3');

--echo # Fork表
fork table t13 to t13_fork;

--echo # 在Fork表中插入数据并验证全局索引
insert into t13_fork values (99, 'Fork_New', 90, 'fork_data');
select * from t13_fork where c = 90;

--echo # 验证源表全局索引不受影响
select * from t13 where c = 90;

--echo # 在源表中插入数据并验证全局索引
insert into t13 values (88, 'Source_New', 80, 'source_data');
select * from t13 where c = 80;

--echo # 验证Fork表全局索引不受影响
select * from t13_fork where c = 80;

--echo # 修改Fork表中的数据并验证全局索引
update t13_fork set c = 95 where a = 1;
select * from t13_fork where c = 95;

--echo # 验证源表全局索引不受影响
select * from t13 where c = 95;

--echo # 修改源表中的数据并验证全局索引
update t13 set c = 85 where a = 50;
select * from t13 where c = 85;

--echo # 验证Fork表全局索引不受影响
select * from t13_fork where c = 85;

--echo ============================================
--echo 8. Global Index Partition Structure Verification
--echo ============================================

drop table if exists t14;
drop table if exists t14_fork;

create table t14 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than (300)
);

--echo # 创建全局索引（多个分区）
create index gidx_c on t14(c) global partition by range(c) (
    partition p0 values less than (50),
    partition p1 values less than (100),
    partition p2 values less than (150),
    partition p3 values less than MAXVALUE
);

insert into t14 values (1, 'Alice', 10, 'data1');
insert into t14 values (101, 'Bob', 110, 'data2');
insert into t14 values (201, 'Charlie', 210, 'data3');
insert into t14 values (50, 'David', 50, 'data4');
insert into t14 values (150, 'Eve', 150, 'data5');

--echo # Fork表
fork table t14 to t14_fork;

--echo # 验证Fork表全局索引分区结构
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='t14_fork', table_id, 1);
let $gidx_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name like '%gidx_c%' and data_table_id = $table_id, table_id, 1);
--replace_regex /table_id = [0-9]*/table_id = gidx_id/g
eval select count(*) from oceanbase.__all_virtual_part where table_id = $gidx_id;
--replace_regex /table_id = [0-9]*/table_id = gidx_id/g
eval select part_name, high_bound_val from oceanbase.__all_virtual_part where table_id = $gidx_id order by part_id;

connection default;
--echo # 验证全局索引各分区的查询功能
select * from t14_fork where c = 10;
select * from t14_fork where c = 50;
select * from t14_fork where c = 110;
select * from t14_fork where c = 150;
select * from t14_fork where c = 210;

--echo ============================================
--echo 9. Global Index with Range Columns
--echo ============================================

drop table if exists t15;
drop table if exists t15_fork;

create table t15 (
    a int,
    b varchar(150),
    c int,
    d varchar(4000),
    primary key(a, b)
) partition by range(a) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

--echo # 创建全局索引（使用 range columns）
create index gidx_cd on t15(c, d) global partition by range columns(c, d) (
    partition p0 values less than (100, 'M'),
    partition p1 values less than (MAXVALUE, MAXVALUE)
);

insert into t15 values (1, 'Alice', 10, 'data1');
insert into t15 values (101, 'Bob', 110, 'data2');
insert into t15 values (50, 'Charlie', 50, 'data3');

--echo # Fork表
fork table t15 to t15_fork;

--echo # 验证Fork表的全局索引（range columns）
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t15_fork;

--echo # 验证通过全局索引（range columns）查询
