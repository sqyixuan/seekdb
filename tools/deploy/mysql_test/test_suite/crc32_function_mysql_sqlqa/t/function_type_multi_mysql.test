INSERT INTO test1 VALUES(2,'韩信','二班',110);
INSERT INTO test1 VALUES(3,'凯','二班',100);
INSERT INTO test1 VALUES(4,NULL,NULL,NULL);
CREATE TABLE test2(b1 int,b2 varchar(30));
INSERT INTO test2 VALUES(1,'中国人民大学');
INSERT INTO test2 VALUES(2,'中国航空航天大学');
INSERT INTO test2 VALUES(3,'北京理工大学');
INSERT INTO test2 VALUES(4,NULL);

SELECT * from test1 ORDER by b1 asc;
SELECT * from test2 ORDER by b1 asc;

--echo  #基本连接
select * from test1,test2 where test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
--echo  #左连接
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
--echo  #右连接
select * from test1 right  JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
--echo  #内连接
select * from test1 INNER  JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
--echo  #交叉连接
select * from test1,test2 order by test1.b1,test2.b1 asc;

--echo  #crc32-5-2    条件dml执行
--echo  #select
select crc32(test1.b1<3),crc32(test1.b2<3),crc32(test1.b3>'a') from test1,test2 where test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
SELECT (test1.b1>=3 OR test1.b1 IS NULL),(test1.b2>=3 OR test1.b2 IS NULL),(test1.b3<='a' OR test1.b3 IS NULL) FROM test1,test2 where test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
--echo  #and
select * from test1,test2 where test1.b1=test2.b1 and test1.b3='二班' and crc32(test1.b3=null)ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b3='二班' and crc32(test1.b3=null)ORDER by test1.b1 asc;
--echo  #where
select crc32(test1.b1<3),crc32(test1.b2<3),crc32(test1.b3>'a') from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
select crc32(max(b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4=100) order by test1.b1,test2.b1 asc;
select crc32(test1.b1<3),crc32(test1.b2<3),crc32(test1.b3>'a'),crc32(test1.b4 IS NULL) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(b4=100) order by test1.b1,test2.b1 asc;
--echo  #or
select crc32(test1.b1) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2<3 or crc32(test1.b3=null)ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2='韩信' or crc32(b3=null) ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2='凯' or crc32(b3='一班') ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2='凯' or crc32(b3=(select crc32(b2<8) from test1 where b3='一班' ))ORDER by test1.b1 asc;

--echo  #like
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 WHERE b3 LIKE '%班';
select crc32(test1.b1) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2='李白' or crc32(test1.b3 LIKE '%班')ORDER by test1.b1 asc;


--echo  #group by
--error 0,1064
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 group by test1.b2 ORDER by test1.b1 asc
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 group by crc32(test1.b2) ORDER by test1.b1 asc;
select crc32(test1.b1<3),crc32(test1.b2='二班'),crc32(test1.b3>90),crc32(test1.b4 IS NULL) from test1 LEFT JOIN test2 on test1.b1=test2.b1 group by crc32(test1.b2) ORDER by test1.b1 asc; 
select crc32(test1.b1<3),crc32(test1.b2='二班'),crc32(test1.b3>100),crc32(b4 IS NULL) from test1 LEFT JOIN test2 on test1.b1=test2.b1;
select crc32(test1.b1<3),crc32(test1.b2='二班'),crc32(test1.b3>100),crc32(b4 IS NULL) from test1 LEFT JOIN test2 on test1.b1=test2.b1 group by crc32(test1.b2+test1.b1+test1.b3) ORDER by test1.b1 asc;


--echo  #ordey by
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by crc32(test1.b1) asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by crc32((SELECT test1.b1 from test1 LIMIT 1)) asc;
select crc32(test1.b1<3) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by crc32((SELECT test1.b1 from test1 LIMIT 1)) asc;
select crc32((SELECT test1.b1 from test1 LIMIT 1)) from test1 LEFT JOIN test2 on test1.b1=test2.b1;

--echo  #聚合
select sum(crc32(test1.b1)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by test1.b1 asc;
select sum(crc32(test1.b1)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4<150) ORDER by test1.b1 asc;
select max(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by test1.b1 asc;
select max(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4<150) ORDER by test1.b1 asc;
select min(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by test1.b1 asc;
select min(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4<150) ORDER by test1.b1 asc;
select avg(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by test1.b1 asc;
select avg(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4<150) ORDER by test1.b1 asc;
select count(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 ORDER by test1.b1 asc;
select count(crc32(test1.b4)) from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b4<150) ORDER by test1.b1 asc;

--echo  #crc32-5-3    子查询
--echo  #and
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2=crc32((select test1.b2 from test1 where test1.b2='李白'))and test1.b2='李白' ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=(select test1.b2 from test1 where test1.b2='李白' and b2='李白')) ORDER by test1.b1 asc;
--echo  #where
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2=crc32((select test1.b2 from test1 where test1.b2='李白' or b2='韩信' LIMIT 1)) ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=(select test1.b2 from test1 where test1.b2='李白' or test1.b2='韩信' LIMIT 1)) ORDER by test1.b1 asc;
--echo  #from
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where test1.b2=crc32((select crc32(test1.b2) from test1 LIMIT 1)) ORDER by test1.b1 asc;
--echo  #exists
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(exists(select test1.b2 from test1 LIMIT 1)) ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(exists(select crc32(test1.b2) from test1 LIMIT 1)) ORDER by test1.b1 asc;
--echo  #distinct
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32((select distinct test1.b2 from test1 LIMIT 1)) ORDER by test1.b1 asc;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(crc32((select distinct test1.b2 from test1 LIMIT 1))) ORDER by test1.b1 asc;
--echo  #all
--error 0,1064
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=all(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2<all(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(crc32(test1.b2=all(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;



--error 0,1064
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2<all(crc32(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;
--echo  #some
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=some(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2<some(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2>some(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(crc32(test1.b2=some(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;
--error 0,1064
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=some(crc32(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;
--echo  #any
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=any(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2<any(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2>any(SELECT test1.b2 from test1)) ORDER by test1.b1 asc;
--error 0,1064
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(test1.b2=any(crc32(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;
select test1.b2 from test1 LEFT JOIN test2 on test1.b1=test2.b1 where crc32(crc32(test1.b2=any(SELECT test1.b2 from test1))) ORDER by test1.b1 asc;

--echo   #insert
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(test1.b1) VALUES(crc32(-20));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(b1) VALUES((SELECT min(test1.b1) FROM test1 WHERE crc32(test1.b2 IS NULL)));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(b1) VALUES((SELECT min(b1) FROM test1 WHERE crc32(test1.b2 IS NOT NULL)));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(b3) VALUES((SELECT test1.b1 FROM test1 WHERE crc32(test1.b2 IS NULL) GROUP BY test1.b1 HAVING crc32(test1.b1<3)));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(b4) VALUES((SELECT '20171212' FROM test1 WHERE crc32(test1.b2 IS NULL) GROUP BY b1 HAVING crc32(test1.b1<3)));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1 VALUES((SELECT min(b1) FROM test1 WHERE crc32(test1.b2 IS NULL)),NULL,(SELECT b1 FROM test1 WHERE crc32(test1.b2 IS NULL) GROUP BY test1.b1 HAVING crc32(test1.b1<3)),(SELECT '20171212' FROM test1 WHERE crc32(test1.b2 IS  NULL) GROUP BY test1.b1 HAVING crc32(test1.b1<3)));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;
INSERT INTO test1(b2) SELECT b1 FROM test1 WHERE crc32(test1.b2 IS NULL) GROUP BY test1.b1 HAVING crc32(test1.b1<3);
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
DELETE FROM test1 WHERE 1=1;


--echo  #update
INSERT INTO test1 VALUES(3,4,'cde','20171212');
UPDATE test1 SET b1=(SELECT max(b2) FROM test1 WHERE crc32(b1>2)) WHERE b2 IS NOT NULL;
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
UPDATE test1 SET b2=(SELECT avg(m) FROM (SELECT b2||'5.5544' m FROM test1 WHERE crc32(b1>2) GROUP BY b2 HAVING crc32(b2>=2) OR crc32(b2<=2) ORDER BY 1) t1 limit 1) WHERE b2 IS NULL;
UPDATE test1 SET b1='6' WHERE b2 = (SELECT max(b2) FROM test1 WHERE crc32(b1>2));
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
UPDATE test1 SET b1='7' WHERE b2+9.9 < (SELECT avg(m) FROM (SELECT 10+b2 m FROM test1 WHERE crc32(b1>4) GROUP BY b2 HAVING crc32(b2>=2) OR crc32(b2<=2) ORDER BY 1) t1 limit 1) AND crc32(b1 IS NULL);
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
UPDATE test1 SET b1='6' WHERE crc32((SELECT max(b2) FROM test1 WHERE crc32(b1>2)) IS NULL);
select * from test1 LEFT JOIN test2 on test1.b1=test2.b1 order by test1.b1,test2.b1 asc;
UPDATE test1 SET b1='7' WHERE crc32(b2+9.9<(SELECT avg(m)||12 FROM (SELECT 10+b2 m FROM test1 WHERE crc32(b1>4) GROUP BY b2 HAVING crc32(b2>=2) OR crc32(b2<=2) ORDER BY 1) t1 limit 1));
DELETE FROM test1 WHERE 1=1;
drop table test1;

--echo  #delete
CREATE TABLE test1(f1 int,f2 bigint,f3 varchar(5),f4 date);
INSERT INTO test1 VALUES(1,2,'abc','20151001');
INSERT INTO test1 VALUES(2,3,'bcd','20161001');
INSERT INTO test1 VALUES(3,4,'cde','20171001');
INSERT INTO test1 VALUES(NULL,NULL,NULL,NULL);
select * from test1 LEFT JOIN test2 on test1.f1=test2.b1 order by test1.f1,test2.b1 asc;
DELETE FROM test1 WHERE f3>(SELECT f3 FROM test1 WHERE crc32(f2>2) AND f3 IS NOT NULL LIMIT 1);
DELETE FROM test1 WHERE f3 BETWEEN (SELECT f3 FROM test1 WHERE crc32(f2>2) AND f3 IS NOT NULL LIMIT 1) AND (SELECT max(f3) FROM test1 WHERE crc32(f2<2) AND f3 IS NOT NULL LIMIT 1);
DELETE FROM test1 WHERE crc32((SELECT max(f2) FROM test1 WHERE crc32(f1>2)) IS NULL);
drop table test1,test2;




