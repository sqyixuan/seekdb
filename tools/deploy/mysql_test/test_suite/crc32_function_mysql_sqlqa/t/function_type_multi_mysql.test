#description:crc32、数据类型、基本sql、多表联查
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo  #crc32-3       数据类型
--echo  #crc32-4       基本sql
--echo  #crc32-5       多表联查


--error 0,1007
create database hz;
use hz;
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;


--echo  #crc32-3-1  数值类型  
--echo  #TINYINT、SMALLINT、MEDIUMINT、int、INTEGER
create table test1(b1 TINYINT,b2 SMALLINT,b3 MEDIUMINT,b4 int,b5 INTEGER);
insert into test1 values(1,25,35,45,58);
insert into test1 values(2,46,56,66,76);
insert into test1 values(3,null,null,null,null);
select * from test1 ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2>=2) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((CASE WHEN b2>2 THEN 10 ELSE 0 END)<='2') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3=(SELECT max(b3) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)!=((3,333))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3)=(SELECT max(b2),max(b3) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1=any(SELECT min(b1) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2=SOME(SELECT b2 FROM test1 WHERE crc32(b2>2))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3=ALL(SELECT min(b2) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2<ALL(SELECT b1 FROM test1 WHERE crc32(b2<2))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)=ANY(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)!=ALL(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 LIKE '%5') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3 NOT LIKE NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 LIKE (SELECT b1 FROM test1 WHERE b2=46)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 regexp '1.*') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 regexp NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT null FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT * FROM test1 WHERE b1=0)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3 IS NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 IS NOT NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((SELECT min(b3) FROM test1) IS NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 IN (1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b4 IN (1,NULL)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b4 NOT IN (SELECT min(b4) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3) NOT IN ((1,111))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3) IN (SELECT b2,b3 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 BETWEEN 1 AND 5) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(NOT b1<2) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1<2 AND b2<5) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1<2 OR b2<5) ORDER by b1 asc;
drop table test1;





--echo  #BIGINT、BIGINT、DOUBLE、DOUBLE、DOUBLE
create table test1(b1 BIGINT,b2 BIGINT,b3 DOUBLE,b4 DOUBLE,b5 DOUBLE);
insert into test1 values(1,3,5,7,9);
insert into test1 values(2,4,6,8,10);
insert into test1 values(3,null,null,null,null);
select * from test1 ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2>=2) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((CASE WHEN b2>2 THEN 10 ELSE 0 END)<='2') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3=(SELECT max(b3) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)!=((3,333))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3)=(SELECT max(b2),max(b3) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1=any(SELECT min(b1) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2=SOME(SELECT b2 FROM test1 WHERE crc32(b2>2))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3=ALL(SELECT min(b2) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2<ALL(SELECT b1 FROM test1 WHERE crc32(b2<2))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)=ANY(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b1,b2)!=ALL(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 LIKE '%5') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3 NOT LIKE NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 LIKE (SELECT b1 FROM test1 WHERE b2=4)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 regexp '1.*') ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 regexp NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT null FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT * FROM test1 WHERE b1=0)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b3 IS NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 IS NOT NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((SELECT min(b3) FROM test1) IS NULL) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1 IN (1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b4 IN (1,NULL)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b4 NOT IN (SELECT min(b4) FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3) NOT IN ((1,111))) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32((b2,b3) IN (SELECT b2,b3 FROM test1)) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b2 BETWEEN 1 AND 5) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(NOT b1<2) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1<2 AND b2<5) ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1<2 OR b2<5) ORDER by b1 asc;
drop table test1;



--echo  #float
CREATE TABLE test1(b1 float(5,3),b2 float(5,3));
INSERT INTO test1 VALUES(1.222,11);
INSERT INTO test1 VALUES(2.222,22);
INSERT INTO test1 VALUES(3.222,33);
INSERT INTO test1 VALUES(NULL,NULL);
SELECT b2 FROM test1 WHERE crc32(b1>='2') ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((CASE WHEN b1>2 THEN 10 ELSE 0 END)<='2') ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1=(SELECT max(b1) FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)!=((3.222,333))) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)=(SELECT max(b1),max(b2) FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1=any(SELECT min(b1) FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1=SOME(SELECT b1 FROM test1 WHERE crc32(b1>2))) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1=ALL(SELECT min(b1) FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1<ALL(SELECT b1 FROM test1 WHERE crc32(b1<2))) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)=ANY(SELECT b1,b2 FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)!=ALL(SELECT b1,b2 FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b2 LIKE '%5') ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 NOT LIKE NULL) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 LIKE (SELECT b1 FROM test1 WHERE b2=111)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 regexp '1.*') ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 regexp NULL) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(EXISTS(SELECT null FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(EXISTS(SELECT * FROM test1 WHERE 1=0)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IS NULL) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IS NOT NULL) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((SELECT min(b1) FROM test1) IS NULL) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IN (1.222)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE (b1 IN (1.222)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IN (1.222,NULL)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 NOT IN (SELECT min(b1) FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2) NOT IN ((1.222,11.000))) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2) IN (SELECT b1,b2 FROM test1)) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE (b1,b2) IN (SELECT b1,b2 FROM test1) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1 BETWEEN 1 AND 5) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(NOT b1<1) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1<1 AND b2<5) ORDER by b2 asc;
SELECT b2 FROM test1 WHERE crc32(b1<1 OR b2<5) ORDER by b2 asc;
drop table test1;


--echo  #crc32-3-2  字符串
--echo  #char
CREATE TABLE test1(b1 int,b2 char(20),b3 char(20));
INSERT INTO test1 VALUES(1,'张三','李四');
INSERT INTO test1 VALUES(2,'王五','小刘');
INSERT INTO test1 VALUES(3,'黑七','虎八');
INSERT INTO test1 VALUES(4,NULL,NULL);
SELECT * from test1 ORDER by b1 asc;
SELECT * FROM test1 WHERE crc32(b1=3) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32((CASE WHEN b3='小刘' THEN 10 ELSE 0 END)<='2') ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1=(SELECT max(b1) FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)!=((3.222,333))) ORDER by b1 asc;
