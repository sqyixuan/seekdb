--echo  #crc32-4       基本sql
--echo  #crc32-4-1     条件dml执行
CREATE TABLE test1(b1 int,b2 double(5,3),b3 varchar(5),b4 date);
INSERT INTO test1 VALUES(1,1.555,'abc','20211001');
INSERT INTO test1 VALUES(2,2.555,'bcd','20201001');
INSERT INTO test1 VALUES(3,3.555,'cde','20191001');
INSERT INTO test1 VALUES(4,NULL,NULL,NULL);

--echo  #select
select * from test1 ORDER by b1 asc;
SELECT crc32(b1<3),crc32(b2<3),crc32(b3>'a'),crc32(b4 IS NULL) FROM test1 ORDER by b1 asc;
SELECT (b1>=3 OR b1 IS NULL),(b2>=3 OR b2 IS NULL),(b3<='a' OR b3 IS NULL),(b4 IS NOT NULL) FROM test1 ORDER by b1 asc;
--echo  #and
SELECT crc32(b1) FROM test1 where b2<3 and crc32(b3=null)ORDER by b1 asc;
SELECT * FROM test1 where b2<3 and crc32(b3=null)ORDER by b1 asc;
SELECT * FROM test1 where b2<10 and crc32(b3='bcd')ORDER by b1 asc;
SELECT * FROM test1 where b2<10 and crc32(b3=(select crc32(b2<8) from test1 where b3='abc' ))ORDER by b1 asc;
--echo  #where
SELECT crc32(b1<3),crc32(b2<3),crc32(b3>'a'),crc32(b4 IS NULL) FROM test1 where b4=(SELECT crc32(max(b4)) from test1 where crc32(b4)) ORDER by b1 asc;
SELECT crc32(max(b4)) from test1 where crc32(b4='20211001') ORDER by b1 asc;
SELECT crc32(b1<3),crc32(b2<3),crc32(b3>'a'),crc32(b4 IS NULL) FROM test1 where crc32(b4='20211001')ORDER by b1 asc;
--echo  #or
SELECT crc32(b1) FROM test1 where b2<3 or crc32(b3=null)ORDER by b1 asc;
SELECT * FROM test1 where b2<3 or crc32(b3=null)ORDER by b1 asc;
SELECT * FROM test1 where b2<10 or crc32(b3='bcd')ORDER by b1 asc;
SELECT * FROM test1 where b2<10 or crc32(b3=(select crc32(b2<8) from test1 where b3='abc' ))ORDER by b1 asc;
--echo  #like
SELECT * FROM test1 WHERE b3 LIKE 'b%';
SELECT crc32(b1) FROM test1 where b2<3 or crc32(b3 LIKE 'b%')ORDER by b1 asc;
SELECT crc32(b1) FROM test1 where b2<3 and crc32(b3 LIKE 'b%')ORDER by b1 asc;
--echo  #group by
SELECT * FROM test1 group by b2 ORDER by b1 asc;
SELECT * FROM test1 group by crc32(b2) ORDER by b1 asc;
SELECT crc32(b1<3),crc32(b2<3),crc32(b3>'a'),crc32(b4 IS NULL) FROM test1 group by crc32(b2) ORDER by b1 asc;
SELECT crc32(b1<3),crc32(b2<3),crc32(b3>'a'),crc32(b4 IS NULL) FROM test1 group by crc32(b2+b1+b3) ORDER by b1 asc;
--echo  #ordey by
SELECT * FROM test1  ORDER by crc32(b1) asc;
SELECT * FROM test1  ORDER by crc32((SELECT b1 from test1 LIMIT 1)) asc;
SELECT crc32(b1<3) FROM test1  ORDER by crc32((SELECT b1 from test1 LIMIT 1)) asc;
SELECT crc32((SELECT b1 from test1 LIMIT 1)) FROM test1 LIMIT 1 ;

--echo  #聚合
SELECT sum(crc32(b1))from test1 ORDER by b1 asc;
SELECT sum(crc32(b1)) from test1 where crc32(b4<'20251001') ORDER by b1 asc;
SELECT max(crc32(b4))from test1 ORDER by b1 asc;
SELECT max(crc32(b4)) from test1 where crc32(b4<'20251001') ORDER by b1 asc;
SELECT min(crc32(b4))from test1 ORDER by b1 asc;
SELECT min(crc32(b4)) from test1 where crc32(b4<'20251001') ORDER by b1 asc;
SELECT avg(crc32(b4))from test1 ORDER by b1 asc;
SELECT avg(crc32(b4)) from test1 where crc32(b4<'20251001') ORDER by b1 asc;
SELECT count(crc32(b1))from test1 ORDER by b1 asc;
SELECT count(crc32(b1)) from test1 where crc32(b4<'20251001') ORDER by b1 asc;
drop table test1;



