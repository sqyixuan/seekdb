--echo  #delete
CREATE TABLE test1(f1 int,f2 bigint,f3 varchar(5),f4 date);
INSERT INTO test1 VALUES(1,2,'abc','20151001');
INSERT INTO test1 VALUES(2,3,'bcd','20161001');
INSERT INTO test1 VALUES(3,4,'cde','20171001');
INSERT INTO test1 VALUES(NULL,NULL,NULL,NULL);
DELETE FROM test1 WHERE crc32(crc32(f4>'20161212'));
SELECT * FROM test1 order by f1 asc ;
DELETE FROM test1 WHERE f3>(SELECT f3 FROM test1 WHERE crc32(f2>2) AND f3 IS NOT NULL);
INSERT INTO test1 VALUES(2,2.555,'bcd','20161212');
INSERT INTO test1 VALUES(3,3.555,'cde','20171212');
DELETE FROM test1 WHERE f3 BETWEEN (SELECT f3 FROM test1 WHERE crc32(f2>2) AND f3 IS NOT NULL LIMIT 1) AND (SELECT max(f3) FROM test1 WHERE crc32(f2<2) AND f3 IS NOT NULL LIMIT 1);
DELETE FROM test1 WHERE crc32((SELECT max(f2) FROM test1 WHERE crc32(f1>2)) IS NULL);
drop table test1;


--echo  #crc32-5       多表联查
--echo  #crc32-5-1       多表连接
CREATE TABLE test1(b1 int,b2 varchar(30),b3 varchar(20),b4 int);
