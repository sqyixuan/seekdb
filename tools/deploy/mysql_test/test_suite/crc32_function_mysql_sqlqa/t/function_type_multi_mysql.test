SELECT b2 FROM test1 WHERE crc32(b1=any(SELECT min(b1) FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1=SOME(SELECT b1 FROM test1 WHERE crc32(b1>2))) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1=ALL(SELECT min(b1) FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1<ALL(SELECT b1 FROM test1 WHERE crc32(b1<2))) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)=ANY(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32((b1,b2)!=ALL(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b2 LIKE '%5') ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 NOT LIKE NULL) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 LIKE (SELECT b1 FROM test1 WHERE b2='王五')) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 regexp '1.*') ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 regexp NULL) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(EXISTS(SELECT null FROM test1)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(EXISTS(SELECT * FROM test1 WHERE 1=0)) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IS NULL) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IS NOT NULL) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32((SELECT min(b1) FROM test1) IS NULL) ORDER by b1 asc;
SELECT b2 FROM test1 WHERE crc32(b1 IN (1.222)) ORDER by b1 asc;
drop table test1;



