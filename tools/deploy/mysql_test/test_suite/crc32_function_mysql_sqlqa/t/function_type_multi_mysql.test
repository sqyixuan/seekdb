--echo  #crc32-4-2    子查询
CREATE TABLE test1(f1 int,f2 bigint,f3 varchar(5),f4 date);
INSERT INTO test1 VALUES(1,2,'abc','20151212');
INSERT INTO test1 VALUES(2,3,'bcd','20161212');
INSERT INTO test1 VALUES(3,4,'cde','20171212');
INSERT INTO test1 VALUES(4,NULL,NULL,NULL);
SELECT * FROM test1 order by f1 asc;
--echo  #and
SELECT * from test1 where f2=crc32((select f2 from test1 where f2=2))and f2=2;
SELECT * from test1 where crc32(f2=(select f2 from test1 where f2=2 and f2=2));
--echo  #where
SELECT * from test1 where f2=crc32((select f2 from test1 where f2=2 or f2=3 LIMIT 1));
SELECT * from test1 where crc32(f2=(select f2 from test1 where f2=2 or f2=3 LIMIT 1));
--echo  #from
SELECT f2 from test1 where f2=crc32((select crc32(f2) from test1 LIMIT 1));
--echo  #exists
SELECT * from test1 where crc32(exists(select f2 from test1 LIMIT 1));
SELECT * from test1 where crc32(exists(select crc32(f2) from test1 LIMIT 1));
--echo  #distinct
SELECT * from test1 where crc32((select distinct f2 from test1 LIMIT 1));
SELECT * from test1 where crc32(crc32((select distinct f2 from test1 LIMIT 1)));
--echo  #all
SELECT f2 from test1 where crc32(f2=all(SELECT f2 from test1));
SELECT f2 from test1 where crc32(f2<all(SELECT f2 from test1));
SELECT f2 from test1 where crc32(crc32(f2=all(SELECT f2 from test1)));

--error 0,1064
SELECT f2 from test1 where crc32(f2<all(crc32(SELECT f2 from test1)));
--echo  #some
SELECT f2 from test1 where crc32(f2=some(SELECT f2 from test1));
SELECT f2 from test1 where crc32(f2<some(SELECT f2 from test1));
SELECT f2 from test1 where crc32(f2>some(SELECT f2 from test1));
SELECT f2 from test1 where crc32(crc32(f2=some(SELECT f2 from test1)));
--error 0,1064
SELECT f2 from test1 where crc32(f2=some(crc32(SELECT f2 from test1)));
--echo  #any
SELECT f2 from test1 where crc32(f2=any(SELECT f2 from test1));
SELECT f2 from test1 where crc32(f2<any(SELECT f2 from test1));
SELECT f2 from test1 where crc32(f2>any(SELECT f2 from test1));
--error 0,1064
SELECT f2 from test1 where crc32(f2=any(crc32(SELECT f2 from test1)));
SELECT f2 from test1 where crc32(crc32(f2=any(SELECT f2 from test1)));



