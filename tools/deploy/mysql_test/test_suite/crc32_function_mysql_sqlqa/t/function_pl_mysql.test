#description:crc32、存储过程、函数
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo  #crc32-9       pl/sql
--echo  #crc32-9-1      存储过程
--echo  #crc32-9-2      函数



--error 0,1007
create database hz;
use hz;
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 0,1051
drop table test;

--echo  #crc32-9-1      存储过程
--echo  #循环语句
--echo  # while循环
create table test1(id int(5) ,name bigint);
drop procedure if exists test_process;
delimiter /;
create procedure test_process()
begin
	declare i int default 1;
	while i<10
	do
		insert into test1 values(i,concat(crc32(-20),i));
		set i=i+1;
	end while;
	commit;
end /
delimiter ;/
select * from test1 ORDER by id asc;
call test_process();
select * from test1 ORDER by id asc;
drop PROCEDURE test_process;
drop table test1;


--echo  # repeat
create table test1(id bigint ,name bigint);
drop procedure if exists test_process;
delimiter /;
create procedure test_process()
begin
    declare i int;
    set i = crc32(-20);
    repeat
        insert into test1 values (i,crc32(-18));
        set i = i + 1;
    until i > 10 end repeat;
    select * from test1;
end
/
delimiter ;/
SELECT * from test1 ORDER by id asc;
call test_process();
SELECT * from test1 ORDER by id asc;
drop PROCEDURE test_process;
drop tables test1;

--echo  # loop
create table test1(id bigint);
drop procedure if exists test_process;
delimiter /;
create procedure test_process()
begin
    declare i int;
    set i = crc32(null);
    lp : loop
        insert into test1 values (i);
        set i = i + 1;
        if i > 10 then
            leave lp;
        end if; 
    end loop;
    select * from test1;
end
/
delimiter ;/
select * from test1 ORDER by id asc;
drop PROCEDURE test_process;
drop tables test1;

--echo  #if条件语句
create table test1(id int(10),fenshu int(10));
insert into test1 value (1,6);
insert into test1 value (2,2);
select * from test1 order by id asc;
--error 0,1305
DROP FUNCTION test1;
delimiter /;
CREATE FUNCTION test1() RETURNS int
BEGIN
        DECLARE i int;
        IF crc32(i<1) THEN
                INSERT INTO test1 VALUES(3,4);
        END IF;
        RETURN 5;
END;
/
delimiter ;/
SELECT * FROM test1 ORDER by id asc;
drop FUNCTION test1;
drop tables test1;


--echo  #游标
CREATE TABLE test1(f1 bigint,f2 bigint);
INSERT INTO test1 VALUES('20.1','10');
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES(NULL,NULL);
CREATE TABLE test2(f1 bigint,f2 bigint);
--error 0,1305
DROP PROCEDURE test1_pro;
delimiter /;
create procedure test1_pro()
begin
	DECLARE v1 bigint;
	DECLARE v2 bigint;
	DECLARE done INT DEFAULT 0;
	DECLARE youbiao CURSOR FOR SELECT avg(f2),f1 from test1 GROUP by f1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN youbiao;
	FETCH youbiao INTO v1,v2;
	WHILE done<>1 DO
		INSERT INTO test1 VALUES(crc32(-20),crc32(-19));
		FETCH youbiao INTO v1,v2;
	END WHILE;
	CLOSE youbiao;
END;
/
delimiter ;/
SELECT* from test1 ORDER by  f1 asc;
CALL test1_pro();
SELECT * FROM test1 ORDER by  f1 asc;
SELECT * FROM test2 ORDER by  f1 asc; 
drop PROCEDURE test1_pro;
drop tables test1;
drop tables test2;


--echo  #crc32-9-2      函数
--echo  #循环语句
--echo  # while循环
CREATE TABLE test1(f1 bigint, f2 bigint);
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(crc32(-20),2.8);
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
CREATE TABLE test2(f1 bigint,f2 bigint);
--error 0,1305
drop FUNCTION test_func;
delimiter /;
CREATE FUNCTION test_func() RETURNS int
begin
	DECLARE v1 bigint;
	DECLARE v2 bigint;
	DECLARE done INT DEFAULT 0;
	DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN result_cursor;
      FETCH result_cursor INTO v1,v2;
      WHILE done<>1 DO
		IF v1>10 THEN
			INSERT INTO test2 SELECT * FROM test1 WHERE crc32(-20);
		ELSEIF v1<10 THEN
			INSERT INTO test2(f2) SELECT f1 FROM test1 WHERE crc32(NULL) GROUP BY f1 HAVING crc32(null)<(3);
		ELSE
			INSERT INTO test2 VALUES(v1||'1234567890',v2);
		END IF;
		FETCH result_cursor INTO v1,v2;
        END WHILE;
        CLOSE result_cursor;
        RETURN 5;
END;
/
delimiter ;/
SELECT * FROM test1 order by f1 asc;
SELECT * FROM test2 order by f1 asc;
DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP FUNCTION test_func;
delimiter /;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE v1 bigint DEFAULT 20;
        WHILE ln(v1)>crc32(-16) DO
                INSERT INTO test2 VALUES(1,2);
                SET v1=v1+5;
        END WHILE;
        RETURN 5;
END;
/
delimiter ;/
SELECT  test_func();
SELECT * FROM test2 order by f1 asc;
drop FUNCTION test_func;
drop table test1;
drop table test2;


--echo  # repeat
CREATE TABLE test(f1 bigint);
INSERT INTO test VALUES(crc32(50));
INSERT INTO test VALUES(crc32(0));
INSERT INTO test VALUES(crc32(1));
INSERT INTO test VALUES(crc32(null));
--error 0,1305
DROP FUNCTION test_func;
drop procedure if exists test;
delimiter /;
create procedure test()
begin
    declare i int;
    set i = crc32(-17);
    repeat
        insert into test values (i);
        set i = i + 1;
    until i > 10 end repeat;
    select * from test;
end
/
delimiter ;/
SELECT * FROM test order by f1 asc ;
SELECT * FROM test order by f1 asc;
--error 0,1305
drop FUNCTION test_func;
drop table test;



--echo  # loop
CREATE TABLE test1(f1 bigint, f2 bigint);
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 bigint,f2 bigint);
--error 0,1305
DROP FUNCTION test_func;
delimiter /;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE v_in int DEFAULT 2;
        loop1:LOOP
                IF v_in<0 THEN
                        UPDATE test1 SET f2=11 WHERE crc32(f2)<2 AND f1 IS NOT NULL;
                        LEAVE loop1;
                END IF;
                SET v_in = v_in-2;
        END LOOP;
        RETURN 5;
END;
/
delimiter ;/
SELECT  test_func();
SELECT * FROM test1 order by f1 asc;
drop FUNCTION test_func;

--echo  #if条件语句
DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP FUNCTION test_func;
delimiter /;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE i int;
        IF crc32(i)<1 THEN
                INSERT INTO test2 VALUES(1,2);
        END IF;
        RETURN 5;
END;
/
delimiter ;/
SELECT  test_func();
SELECT * FROM test2;

--echo  #游标

DELETE FROM test1 WHERE 1=1;
DELETE FROM test2 WHERE 1=1;
INSERT INTO test1 VALUE(50,100);
INSERT INTO test1 VALUE(2.7,2);
INSERT INTO test1 VALUE(exp(1),2.8);
INSERT INTO test1(f1) VALUE(10.1);
INSERT INTO test1(f2) VALUE(10.1);
--error 0,1305
DROP FUNCTION test_func;
delimiter /;
CREATE FUNCTION test_func() RETURNS int
BEGIN
        DECLARE out_1 decimal(5,1);
	DECLARE out_2 decimal(5,1);
        DECLARE done int DEFAULT 0;
        DECLARE result_cursor CURSOR FOR SELECT f1 a,(CASE WHEN crc32(f2)>10 THEN 1 WHEN crc32(f2)>30 THEN 2 ELSE 3 END) b FROM test1;
        DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
        OPEN result_cursor;
        FETCH result_cursor INTO out_1,out_2;
        WHILE done<>1 DO
                INSERT INTO test2 VALUES(out_1,out_2);
                FETCH result_cursor INTO out_1,out_2;
        END WHILE;
        CLOSE result_cursor;
        RETURN 5;
END;
/
delimiter ;/
SELECT  test_func();
SELECT * FROM test1 ORDER by f1 asc;
SELECT * FROM test2 ORDER by f1 asc;
drop table test1,test2;
drop FUNCTION test_func;

