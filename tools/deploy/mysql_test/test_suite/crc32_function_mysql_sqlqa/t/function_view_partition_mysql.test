--echo  #crc32-6       运算符
--echo  #crc32-6-1     算术运算符
--echo  #crc32-6-2     逻辑运算符
--echo  #crc32-6-3     比较运算符


--echo  #crc32-6-1     算术运算符
--echo  #加法
SELECT crc32(-1+1) from dual;
SELECT crc32(-1+0) from dual;
SELECT crc32(-1+null) from dual;
SELECT crc32(null+null) from dual;
--echo  #减法
SELECT crc32(-1-1) from dual;
SELECT crc32(-1-0) from dual;
SELECT crc32(-1-null) from dual;
SELECT crc32(null-1) from dual;
SELECT crc32(-1-(null)) from dual;
--echo  #乘法
SELECT crc32(-1*1) from dual;
SELECT crc32(-1*0) from dual;
SELECT crc32(-1*null) from dual;
SELECT crc32(null*0) from dual;
--error 0,1054
SELECT crc32(gu*@yh) from dual;
SELECT crc32(1*@yh) from dual;
SELECT crc32(null*@yh) from dual;
--echo  #除法
SELECT crc32(-1/1) from dual;
SELECT crc32(-1/0) from dual;
SELECT crc32(-1/null) from dual;
SELECT crc32(null/0) from dual;
--error 0,1054
SELECT crc32(gu/@yh) from dual;
--error 0,1054
SELECT crc32(1/yh) from dual;
SELECT crc32(null/@yh) from dual;
--error 0,1582
SELECT crc32(crc32()/crc32()) from dual;
SELECT 'a' FROM dual WHERE crc32(1=1)+2-3*2/10>1;
SELECT 'a' FROM dual WHERE crc32(1!=NULL)+2-3*2/10>1;
SELECT 'a' FROM dual WHERE crc32(1=1)-100+2-3*2/10>1;
SELECT 'a' FROM dual WHERE crc32(1!=NULL)-11+2-3*2/10>1;


--echo  #crc32-6-2     逻辑运算符
SELECT crc32(1!=1) AND crc32(2<1) FROM dual;
SELECT crc32(1!=NULL) && crc32(2<1) FROM dual;
SELECT crc32(1!=NULL) && crc32(2>1) FROM dual;
SELECT crc32(1!=NULL) OR crc32(2<1) FROM dual;
SELECT crc32(1=1) || crc32(2<1) FROM dual;
SELECT crc32(1=1) || crc32(2>1) FROM dual;
SELECT NOT crc32(1=1) FROM dual ;
SELECT ! crc32(1!=NULL) FROM dual ;
SELECT crc32(1!=NULL) XOR crc32(2<1) FROM dual;
SELECT crc32(1!=NULL) XOR crc32(2>1) FROM dual ;
SELECT crc32(1=1) IS NULL FROM dual ;
SELECT crc32(1!=NULL) IS NULL FROM dual ;
SELECT crc32(1=1) IS NOT NULL FROM dual ;
SELECT crc32(1!=NULL) IS NOT NULL FROM dual ;
SELECT crc32(1=1) IN (1,NULL) FROM dual ;
SELECT crc32(1!=NULL) IN (1,NULL) FROM dual ;
SELECT crc32(1=1) NOT IN (1,NULL) FROM dual ;
SELECT crc32(1!=NULL) NOT IN (1,NULL) FROM dual ;
SELECT crc32(1=1) BETWEEN 1 AND 2 FROM dual;
SELECT crc32(1!=NULL) BETWEEN 1 AND NULL FROM dual ;
SELECT crc32(1=1) NOT BETWEEN 1 AND NULL FROM dual;
SELECT crc32(1!=NULL) NOT BETWEEN 1 AND 5 FROM dual;


--echo  #crc32-6-3     比较运算符
SELECT crc32(1=1)>1 FROM dual;
SELECT crc32(1!=NULL)>1 FROM dual ;
SELECT crc32(1=1)>=1 FROM dual ;
SELECT crc32(1!=NULL)>=1 FROM dual;
SELECT crc32(1=1)<1 FROM dual ;
SELECT crc32(1!=NULL)<1 FROM dual;
SELECT crc32(1=1)<=1 FROM dual;
SELECT crc32(1!=NULL)<=1 FROM dual;
SELECT crc32(1=1)=1 FROM dual;
SELECT crc32(1!=NULL)=1 FROM dual ;
SELECT crc32(1=1)<=>1 FROM dual;
SELECT crc32(1!=NULL)<=>NULL FROM dual ;
SELECT crc32(1=1)!=1 FROM dual;
SELECT crc32(1!=NULL)!=1 FROM dual ;
SELECT crc32(1=1)<>1 FROM dual;
SELECT crc32(1!=NULL)<>1 FROM dual;
SELECT crc32('@')<1 FROM dual;
SELECT crc32(12*'ghy')<1 FROM dual;
--error 0,1064
SELECT crc32(12*!)<1 FROM dual;
--error 0,1064
SELECT crc32(100%)=1 FROM dual;


--echo  #crc32-7       视图索引约束
--echo  #crc32-7-1    视图
create table test1(b1 int,b2 varchar(20),b3 bigint,b4 bigint);
insert into test1 values(1,'鲁班',98,70);
insert into test1 values(2,'王者',100,100);
insert into test1 values(3,'韩信',70,60);
insert into test1 values(4,'null',null,null);
CREATE view v1 as SELECT * from test1;
SELECT * from v1 order by b1 asc;
--echo   #insert
INSERT INTO v1(b1) VALUES(crc32(-15));
SELECT * from v1 order by b1 asc;
INSERT INTO v1(b2) VALUES(crc32('瑶'!='妲己'));
SELECT * from v1 order by b1 asc;
INSERT INTO v1(b3) VALUES(crc32(90>2));
SELECT * from v1 order by b1 asc;
INSERT INTO v1(b4) VALUES(crc32(20191212!=20191212));
SELECT * from v1 order by b1 asc;
INSERT INTO v1(b4) VALUES(crc32(20191212!=null));
SELECT * from v1 order by b1 asc;
INSERT INTO v1 VALUES(crc32(-10),crc32('瑶'!='妲己'),crc32(crc32(90>2)),crc32(20191212!=null));
SELECT * FROM v1 order by b1 asc;
INSERT INTO v1(b4) VALUES((SELECT 100 FROM v1 WHERE crc32(b2 IS NULL) GROUP BY b1 HAVING crc32(b1<3) LIMIT 1));
SELECT * FROM v1 order by b1 asc;


--echo   #select
SELECT crc32(b1<3),crc32(b2='王者'),crc32(b3>30),crc32(b4 IS NULL) FROM v1;
SELECT * FROM (SELECT * FROM v1 WHERE crc32(b1<3) AND crc32(b2='王者') AND NOT crc32(90>2) OR crc32(b4 IS NULL)) test1 WHERE crc32(b1!=2) ORDER BY b1 asc;
SELECT * FROM v1 WHERE crc32(b1<3) AND crc32(b2='韩信') AND NOT crc32(b3>45) OR crc32(b4 IS NOT NULL) ORDER BY b1 asc;
SELECT * FROM v1 WHERE crc32(b3=100) GROUP BY crc32(b4>45) ORDER BY b1 asc;
SELECT b2,b3 FROM v1 WHERE crc32(b1>2.5) GROUP BY b2,b3 HAVING crc32(b3=100) OR crc32(b3=70) ORDER BY b1 asc;
SELECT * FROM v1 ORDER BY crc32(b3>75 or b3>null) asc ;
SELECT (CASE WHEN crc32(b1>2) THEN b1 ELSE b1+1 END) FROM v1 ORDER BY b1 asc;
SELECT (CASE WHEN crc32(b1 IS NULL) THEN b1 ELSE 2 END) FROM v1 ORDER BY b1 asc;
SELECT (CASE crc32(b1 IS NULL) WHEN 1 THEN b1 WHEN NULL THEN 2 ELSE 3 END) FROM v1  ORDER BY b1 asc;
SELECT DISTINCT crc32(b1 IS NOT NULL) FROM v1 ORDER BY b1 asc;



--echo   #update
--error 0,1264
UPDATE v1 SET b1=crc32(b1<2) WHERE b1 IS NOT NULL;
UPDATE v1 SET b1=(SELECT max(b1) FROM v1 WHERE crc32(b1>2)) WHERE b2 IS NOT NULL;
SELECT * FROM v1 order by b1 asc;
UPDATE v1 SET b1=(SELECT avg(b3) FROM (SELECT b2||'5.5544' b2 FROM v1 WHERE crc32(b1>2) GROUP BY b2 HAVING crc32(b1>=2) OR crc32(b1<=2) ORDER BY 1) test1 limit 1) WHERE b2 IS NULL;
UPDATE v1 SET b1='5' WHERE crc32(b3<101) AND b1 IS NOT NULL;
SELECT * FROM v1 order by b1 asc;
UPDATE v1 SET b1='6' WHERE b2 = (SELECT max(b2) FROM v1 WHERE crc32(b1>2));
SELECT * FROM v1 order by b1 asc;
--error 0,1292
UPDATE v1 SET b1='7' WHERE b2+9.9 < (SELECT avg(b1) FROM (SELECT 10+b2 b1 FROM v1 WHERE crc32(b1>4) GROUP BY b2 HAVING crc32(b2>=2) OR crc32(b1<=2) ORDER BY 1) test1 limit 1) AND crc32(b1 IS NULL);
UPDATE v1 SET b1='6' WHERE crc32((SELECT max(b3) FROM v1 WHERE crc32(b1>2)) IS NULL);
SELECT * FROM v1 order by b1 asc;
UPDATE v1 SET b1='7' WHERE crc32(b3+9.9<(SELECT avg(b4)||12 FROM (SELECT 10+b3 b4 FROM v1 WHERE crc32(b1>4) GROUP BY b2 HAVING crc32(b3>=2) OR crc32(b4<=200) ORDER BY 1) test1 limit 1));
SELECT * FROM v1 order by b1 asc;
DROP table test1;
DROP view v1;

--echo   #delete
create table test1(b1 int,b2 varchar(20),b3 bigint,b4 bigint);
insert into test1 values(1,'鲁班',98,70);
insert into test1 values(2,'王者',100,100);
insert into test1 values(3,'韩信',70,60);
insert into test1 values(4,'null',null,null);
CREATE view v1 as SELECT * from test1;
SELECT * FROM v1 order by b1 asc;
DELETE FROM v1 WHERE crc32(crc32(b4<65));
SELECT * FROM v1 order by b1 asc;
DELETE FROM v1 WHERE b3=(SELECT b3 FROM v1 WHERE crc32(b3=null) AND b3 IS NOT NULL);
SELECT * FROM v1 order by b1 asc;
delete from v1;
insert into test1 values(1,'鲁班',98,70);
insert into test1 values(2,'王者',100,100);
insert into test1 values(3,'韩信',70,60);
insert into test1 values(4,'null',null,null);
--error 0,1292
DELETE FROM v1 WHERE b3 BETWEEN (SELECT b3 FROM v1 WHERE crc32(b2>2) AND b3 IS NOT NULL) AND (SELECT max(b3) FROM v1 WHERE crc32(b2<2) AND b3 IS NOT NULL);
DELETE FROM v1 WHERE b3+9.9 < (SELECT avg(b3) FROM (SELECT 10+b3 FROM v1 WHERE crc32(b1>4) GROUP BY b3 HAVING crc32(b3>=2) OR crc32(b3<=2) ORDER BY 1) test1 limit 1) AND crc32(b1 IS NULL);
DELETE FROM v1 WHERE crc32((SELECT max(b3) FROM v1 WHERE crc32(b3=null)) IS NULL);
SELECT * FROM v1 order by b1 asc;
drop table test1;
drop view v1;


--echo  #crc32-7-2     索引
CREATE TABLE test1(b1 decimal(5,1), b2 decimal(5,1));
CREATE INDEX index_test1 ON test1(b1);
CREATE INDEX index_test2 ON test1(b2);
INSERT INTO test1(b1) SELECT 5 FROM dual WHERE crc32(1!=1);
SELECT * FROM test1;
UPDATE test1 SET b1 = (SELECT 6 FROM dual WHERE crc32(1!=1)) WHERE crc32(b2 IS NOT NULL);
SELECT * FROM test1;
DELETE FROM test1 WHERE crc32(b2=3);
DELETE FROM test1 WHERE crc32(b2=null);
drop table test1;



--echo  #crc32-7-3   约束
--echo  #crc32-7-3-1    非空约束
create table test1(a1 int ,name varchar(20),chinese BIGINT not null,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
SELECT * from test1 order by a1 asc;
--error 0,1048
insert into test1 values(1,'小明',null,125,98);
insert into test1 values(2,'小明',0,125,98);
insert into test1 values(3,'小明',-1,125,98);
SELECT * from test1 order by a1 asc;
INSERT INTO test1(chinese) SELECT 5 FROM dual WHERE crc32(null);
SELECT * from test1 order by a1 asc;
--error 0,1048
insert into test1 values(4,'小明',crc32(null),125,98);
--error 0,1048
UPDATE test1 set chinese=crc32(null) where chinese=0;
UPDATE test1 set chinese=crc32(1) where chinese=0;
SELECT * from test1 order by a1 asc;
DELETE FROM test1 where chinese=crc32(1);
SELECT * from test1 order by a1 asc;
drop table test1;

--echo  #unique   唯一约束
create table test1(a1 int,name varchar(20),chinese BIGINT UNIQUE Key,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
--error 0,1062
insert into test1 values(2,'小明',101,125,98);
insert into test1 values(2,'小明',102,125,98);
SELECT * from test1 order by a1 asc;
insert into test1 values(2,'小明',crc32(102),125,98);
SELECT * from test1 order by a1 asc;
UPDATE test1 set chinese=crc32(101) where chinese=crc32(102);
SELECT * from test1 order by a1 asc;
DELETE from test1 where crc32(crc32(101));
SELECT * from test1 order by a1 asc;
drop table test1;



--echo  #PRIMARY KEY 主键
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
SELECT * from test1 order by a1 asc;
insert into test1 values(2,'小明',100,125,98);
insert into test1 values(3,'小明',102,125,98);
SELECT * from test1 order by a1 asc;
UPDATE test1 set a1=1 where a1=crc32(1);
DELETE from test1 where crc32(a1<4);
drop table test1;

--echo  #FOREIGN KEY   外键约束
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create table test2(a1 int,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER,constraint fk_test1_test2_a1 FOREIGN key(a1) REFERENCES test1(a1));
insert into test1 values(5,'小张',91,121,80);
SELECT * from test1 order by a1 asc;
insert into test1 values(2,'小草',99,124,78);
insert into test1 values(3,'小明',103,124,78);
insert into test1 values(4,'小王',103,124,78);
--error 0,1062
insert into test1 values(5,'小草',110,130,70);
SELECT * from test1 order by a1 asc;
UPDATE test2 set a1=1 where a1=crc32(1);
--error 0,1264
UPDATE test2 set a1=crc32(1);
--error 0,1235
DELETE from test1 where a1=crc32(1);
DELETE from test2;
drop table test2;
drop table test1;



--echo  #crc32-8       分区表
--echo  #hash   分区
create table test1(a1 int,chinese int,math int,english int)partition by hash(a1);
insert INTO test1 partition(p0) VALUES(1,110,101,119);
insert  INTO test1 partition(p0) VALUES(2,112,150,100);
insert  INTO test1 partition(p0) VALUES(3,118,140,115);
SELECT * from test1 order by a1 asc;
delete from test1 partition(p0) where crc32(english=100) LIMIT 1;
SELECT * from test1 order by a1 asc;
delete from test1 partition(p0) where english<(SELECT english from test1 where crc32(english=(SELECT english from test1 where crc32(english=115) LIMIT 1) )LIMIT 1);
SELECT * from test1 order by a1 asc;
--error 0,1064
update test1 partition(p0) set crc32(english=120) where crc32(english=115);
update test1 partition(p0) set english=120 where crc32(english=115);
SELECT * from test1 order by a1 asc;
--error 0,1064
update test1  partition(p0) set crc32(english=120) LIMIT 1;
update test1  partition(p0) set english=crc32(120) LIMIT 1;
SELECT * from test1 order by a1 asc;
drop table test1;


--echo  #list   分区
create table test1(a1 int,chinese int,math int,english int)partition by list(a1)(partition p2 values in(1,2));
insert INTO test1 partition(p2) VALUES(1,112,150,100);
insert INTO test1 partition(p2) VALUES(2,110,101,119);
SELECT * from test1 order by a1 asc;
UPDATE test1 partition(p2) set english=crc32(math-1);
SELECT * from test1 partition(p2) order by a1 asc;
UPDATE test1 partition(p2) set english=crc32(english-2);
SELECT * from test1 partition(p2) order by a1 asc;
delete from test1 partition(p2) where math=some(SELECT math from test1 where crc32(math=101));
delete from test1 partition(p2) where math>(SELECT math from test1 where crc32(math=101));
SELECT * from test1 partition(p2) order by a1 asc;
UPDATE test1 partition(p2) set english=crc32(null);
SELECT * from test1 partition(p2) order by a1 asc;
UPDATE test1 partition(p2) set english=crc32(english=119);
SELECT * from test1 partition(p2) order by a1 asc;
UPDATE test1 partition(p2) set english=crc32(english+119);
drop table test1;

--echo  #range  分区
create table test1(a1 int,chinese int,math int,english int)partition by range(a1)(partition p0 VALUES less than MAXVALUE);
insert INTO test1 partition(p0) VALUES(1,110,101,119);
insert  INTO test1 partition(p0) VALUES(2,112,150,100);
insert  INTO test1 partition(p0) VALUES(3,118,140,115);
SELECT * from test1 partition(p0) order by a1 asc;
delete from test1 partition(p0) where crc32(english=100) LIMIT 1;
SELECT * from test1 partition(p0) order by a1 asc;
delete from test1 partition(p0) where english<(SELECT english from test1 where english=(SELECT english from test1 where crc32(english=115) LIMIT 1));
SELECT * from test1 partition(p0) order by a1 asc;
update test1 partition(p0) set english=120 where crc32(english=115);
update test1 partition(p0) set english=119 where english=crc32(115+115);
SELECT * from test1 partition(p0) order by a1 asc;
update test1 partition(p0) set english=crc32(101) LIMIT 1;
SELECT * from test1 partition(p0) order by a1 asc;
drop table test1;

--echo  #key    分区
create table test1(a1 int,chinese int,math int,english int)partition by key(a1);
insert INTO test1 partition(p0) VALUES(1,110,101,119);
insert  INTO test1 partition(p0) VALUES(2,112,150,100);
insert  INTO test1 partition(p0) VALUES(3,118,140,115);
SELECT * from test1 partition(p0) order by a1 asc;
delete from test1  partition(p0) where crc32(english=100) LIMIT 1;
SELECT * from test1 partition(p0) order by a1 asc;
delete from test1 partition(p0) where english<(SELECT english from test1 where crc32(english=(SELECT english from test1 where english=115 LIMIT 1) )LIMIT 1);
SELECT * from test1 partition(p0) order by a1 asc;
update test1 partition(p0) set english=crc32(120) where english=115;
update test1  partition(p0) set english=crc32(english+109) where english=(SELECT english from test1 where english=119 LIMIT 1 );
SELECT * from test1 partition(p0) order by a1 asc;
update test1 partition(p0) set english=crc32(english+101) LIMIT 1;
SELECT * from test1 partition(p0) order by a1 asc;
drop table test1;




