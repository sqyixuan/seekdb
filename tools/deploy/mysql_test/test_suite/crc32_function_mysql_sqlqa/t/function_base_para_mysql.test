SELECT crc32('') from dual;
SELECT crc32(' ') from dual;
SELECT crc32('' '') from dual;
SELECT crc32(' ' ' ') from dual;
SELECT crc32(' '*' ') from dual;
--error 0,1583
SELECT crc32('' "") from dual;
--error 0,1583
SELECT crc32('' """""") from dual;
SELECT crc32(' ' ''' ''') from dual;
SELECT crc32('' ''' ''') from dual;
SELECT crc32('' '''''') from dual;


