--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo  #crc32-1       参数设置
--echo  #crc32-2       函数嵌套


--error 0,1007
create database hz;
use hz;

--echo  #crc32-1-1     有效参数
--echo  #参数为纯汉字
--echo  #参数为纯数字
--echo  #参数为纯字母+网址
--echo  #参数为组合+null
--echo  #参数为结合+、-、*、/、%
