SELECT crc32(1=1)>1 FROM dual;
crc32(1=1)>1
1
SELECT crc32(1!=NULL)>1 FROM dual ;
crc32(1!=NULL)>1
NULL
SELECT crc32(1=1)>=1 FROM dual ;
crc32(1=1)>=1
1
SELECT crc32(1!=NULL)>=1 FROM dual;
crc32(1!=NULL)>=1
NULL
SELECT crc32(1=1)<1 FROM dual ;
crc32(1=1)<1
0
SELECT crc32(1!=NULL)<1 FROM dual;
crc32(1!=NULL)<1
NULL
SELECT crc32(1=1)<=1 FROM dual;
crc32(1=1)<=1
0
SELECT crc32(1!=NULL)<=1 FROM dual;
crc32(1!=NULL)<=1
NULL
SELECT crc32(1=1)=1 FROM dual;
crc32(1=1)=1
0
SELECT crc32(1!=NULL)=1 FROM dual ;
crc32(1!=NULL)=1
NULL
SELECT crc32(1=1)<=>1 FROM dual;
crc32(1=1)<=>1
0
SELECT crc32(1!=NULL)<=>NULL FROM dual ;
crc32(1!=NULL)<=>NULL
1
SELECT crc32(1=1)!=1 FROM dual;
crc32(1=1)!=1
1
SELECT crc32(1!=NULL)!=1 FROM dual ;
crc32(1!=NULL)!=1
NULL
SELECT crc32(1=1)<>1 FROM dual;
crc32(1=1)<>1
1
SELECT crc32(1!=NULL)<>1 FROM dual;
crc32(1!=NULL)<>1
NULL
