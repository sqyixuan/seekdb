#crc32-6       运算符
#crc32-6-1     算术运算符
#crc32-6-2     逻辑运算符
#crc32-6-3     比较运算符
#crc32-6-1     算术运算符
#加法
SELECT crc32(-1+1) from dual;
crc32(-1+1)
4108050209
SELECT crc32(-1+0) from dual;
crc32(-1+0)
808273962
SELECT crc32(-1+null) from dual;
crc32(-1+null)
NULL
SELECT crc32(null+null) from dual;
crc32(null+null)
NULL
#减法
SELECT crc32(-1-1) from dual;
crc32(-1-1)
2837715344
SELECT crc32(-1-0) from dual;
crc32(-1-0)
808273962
SELECT crc32(-1-null) from dual;
crc32(-1-null)
NULL
SELECT crc32(null-1) from dual;
crc32(null-1)
NULL
SELECT crc32(-1-(null)) from dual;
crc32(-1-(null))
NULL
#乘法
SELECT crc32(-1*1) from dual;
crc32(-1*1)
808273962
SELECT crc32(-1*0) from dual;
crc32(-1*0)
4108050209
SELECT crc32(-1*null) from dual;
crc32(-1*null)
NULL
SELECT crc32(null*0) from dual;
crc32(null*0)
NULL
SELECT crc32(gu*@yh) from dual;
SELECT crc32(1*@yh) from dual;
crc32(1*@yh)
NULL
SELECT crc32(null*@yh) from dual;
crc32(null*@yh)
NULL
#除法
SELECT crc32(-1/1) from dual;
crc32(-1/1)
2936985889
SELECT crc32(-1/0) from dual;
crc32(-1/0)
NULL
SELECT crc32(-1/null) from dual;
crc32(-1/null)
NULL
SELECT crc32(null/0) from dual;
crc32(null/0)
NULL
SELECT crc32(gu/@yh) from dual;
SELECT crc32(1/yh) from dual;
SELECT crc32(null/@yh) from dual;
crc32(null/@yh)
NULL
SELECT crc32(crc32()/crc32()) from dual;
SELECT 'a' FROM dual WHERE crc32(1=1)+2-3*2/10>1;
a
a
SELECT 'a' FROM dual WHERE crc32(1!=NULL)+2-3*2/10>1;
a
SELECT 'a' FROM dual WHERE crc32(1=1)-100+2-3*2/10>1;
a
a
SELECT 'a' FROM dual WHERE crc32(1!=NULL)-11+2-3*2/10>1;
a
#crc32-6-2     逻辑运算符
SELECT crc32(1!=1) AND crc32(2<1) FROM dual;
crc32(1!=1) AND crc32(2<1)
1
SELECT crc32(1!=NULL) && crc32(2<1) FROM dual;
crc32(1!=NULL) && crc32(2<1)
NULL
SELECT crc32(1!=NULL) && crc32(2>1) FROM dual;
crc32(1!=NULL) && crc32(2>1)
NULL
SELECT crc32(1!=NULL) OR crc32(2<1) FROM dual;
crc32(1!=NULL) OR crc32(2<1)
1
SELECT crc32(1=1) || crc32(2<1) FROM dual;
crc32(1=1) || crc32(2<1)
1
SELECT crc32(1=1) || crc32(2>1) FROM dual;
crc32(1=1) || crc32(2>1)
1
SELECT NOT crc32(1=1) FROM dual ;
NOT crc32(1=1)
0
SELECT ! crc32(1!=NULL) FROM dual ;
! crc32(1!=NULL)
NULL
SELECT crc32(1!=NULL) XOR crc32(2<1) FROM dual;
crc32(1!=NULL) XOR crc32(2<1)
NULL
SELECT crc32(1!=NULL) XOR crc32(2>1) FROM dual ;
crc32(1!=NULL) XOR crc32(2>1)
NULL
SELECT crc32(1=1) IS NULL FROM dual ;
crc32(1=1) IS NULL
0
SELECT crc32(1!=NULL) IS NULL FROM dual ;
crc32(1!=NULL) IS NULL
1
SELECT crc32(1=1) IS NOT NULL FROM dual ;
crc32(1=1) IS NOT NULL
1
SELECT crc32(1!=NULL) IS NOT NULL FROM dual ;
crc32(1!=NULL) IS NOT NULL
0
SELECT crc32(1=1) IN (1,NULL) FROM dual ;
crc32(1=1) IN (1,NULL)
NULL
SELECT crc32(1!=NULL) IN (1,NULL) FROM dual ;
crc32(1!=NULL) IN (1,NULL)
NULL
SELECT crc32(1=1) NOT IN (1,NULL) FROM dual ;
crc32(1=1) NOT IN (1,NULL)
NULL
SELECT crc32(1!=NULL) NOT IN (1,NULL) FROM dual ;
crc32(1!=NULL) NOT IN (1,NULL)
NULL
SELECT crc32(1=1) BETWEEN 1 AND 2 FROM dual;
crc32(1=1) BETWEEN 1 AND 2
0
SELECT crc32(1!=NULL) BETWEEN 1 AND NULL FROM dual ;
crc32(1!=NULL) BETWEEN 1 AND NULL
NULL
SELECT crc32(1=1) NOT BETWEEN 1 AND NULL FROM dual;
crc32(1=1) NOT BETWEEN 1 AND NULL
NULL
SELECT crc32(1!=NULL) NOT BETWEEN 1 AND 5 FROM dual;
crc32(1!=NULL) NOT BETWEEN 1 AND 5
NULL
