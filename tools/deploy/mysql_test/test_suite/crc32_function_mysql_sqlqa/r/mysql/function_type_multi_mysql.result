#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#crc32-3       数据类型
#crc32-4       基本sql
#crc32-5       多表联查
create database hz;
use hz;
drop table test1;
drop table test2;
#crc32-3-1  数值类型  
#TINYINT、SMALLINT、MEDIUMINT、int、INTEGER
create table test1(b1 TINYINT,b2 SMALLINT,b3 MEDIUMINT,b4 int,b5 INTEGER);
insert into test1 values(1,25,35,45,58);
insert into test1 values(2,46,56,66,76);
insert into test1 values(3,null,null,null,null);
select * from test1 ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b2>=2) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((CASE WHEN b2>2 THEN 10 ELSE 0 END)<='2') ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b3=(SELECT max(b3) FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b1,b2)!=((3,333))) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b2,b3)=(SELECT max(b2),max(b3) FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b1=any(SELECT min(b1) FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b2=SOME(SELECT b2 FROM test1 WHERE crc32(b2>2))) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b3=ALL(SELECT min(b2) FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b2<ALL(SELECT b1 FROM test1 WHERE crc32(b2<2))) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b1,b2)=ANY(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b1,b2)!=ALL(SELECT b1,b2 FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b2 LIKE '%5') ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b3 NOT LIKE NULL) ORDER by b1 asc;
b1	b2	b3	b4	b5
SELECT * FROM test1 WHERE crc32(b2 LIKE (SELECT b1 FROM test1 WHERE b2=46)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b1 regexp '1.*') ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b1 regexp NULL) ORDER by b1 asc;
b1	b2	b3	b4	b5
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT null FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(EXISTS(SELECT * FROM test1 WHERE b1=0)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b3 IS NULL) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b1 IS NOT NULL) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32((SELECT min(b3) FROM test1) IS NULL) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b1 IN (1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b4 IN (1,NULL)) ORDER by b1 asc;
b1	b2	b3	b4	b5
SELECT * FROM test1 WHERE crc32(b4 NOT IN (SELECT min(b4) FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b2,b3) NOT IN ((1,111))) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32((b2,b3) IN (SELECT b2,b3 FROM test1)) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(b2 BETWEEN 1 AND 5) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
SELECT * FROM test1 WHERE crc32(NOT b1<2) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b1<2 AND b2<5) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
3	NULL	NULL	NULL	NULL
SELECT * FROM test1 WHERE crc32(b1<2 OR b2<5) ORDER by b1 asc;
b1	b2	b3	b4	b5
1	25	35	45	58
2	46	56	66	76
drop table test1;
