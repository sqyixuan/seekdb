grant all on *.* to hjw WITH GRANT OPTION;
#crc32-9       pl/sql
#crc32-9-1      存储过程
#crc32-9-2      函数
create database hz;
use hz;
drop table test1;
drop table test2;
drop table test;
#crc32-9-1      存储过程
#循环语句
# while循环
create table test1(id int(5) ,name bigint);
drop procedure if exists test_process;
create procedure test_process()
begin
declare i int default 1;
while i<10
do
insert into test1 values(i,concat(crc32(-20),i));
set i=i+1;
end while;
commit;
end /
select * from test1 ORDER by id asc;
id	name
call test_process();
select * from test1 ORDER by id asc;
id	name
1	753276121
2	753276122
3	753276123
4	753276124
5	753276125
6	753276126
7	753276127
8	753276128
9	753276129
drop PROCEDURE test_process;
drop table test1;
# repeat
create table test1(id bigint ,name bigint);
drop procedure if exists test_process;
create procedure test_process()
begin
declare i int;
set i = crc32(-20);
repeat
insert into test1 values (i,crc32(-18));
set i = i + 1;
until i > 10 end repeat;
select * from test1;
end
/
SELECT * from test1 ORDER by id asc;
id	name
call test_process();
id	name
75327612	562803597
SELECT * from test1 ORDER by id asc;
id	name
75327612	562803597
drop PROCEDURE test_process;
drop tables test1;
# loop
create table test1(id bigint);
drop procedure if exists test_process;
create procedure test_process()
begin
declare i int;
set i = crc32(null);
lp : loop
insert into test1 values (i);
set i = i + 1;
if i > 10 then
leave lp;
end if; 
end loop;
select * from test1;
end
/
select * from test1 ORDER by id asc;
id
drop PROCEDURE test_process;
drop tables test1;
