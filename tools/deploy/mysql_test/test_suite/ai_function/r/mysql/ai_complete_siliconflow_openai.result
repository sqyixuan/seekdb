call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "Qwen/QwQ-32B"
  }');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_complete_endpoint');
call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT ('ob_complete_endpoint', '{"ai_model_name": "ob_complete","scope": "all","url": "http://0.0.0.0:8000/v1/chat/completions","access_key": "abcdefghijklmnopqrstuvwxyz","provider": "siliconflow"}');;
select ai_complete("ob_complete","你的任务是对提供的文本进行情感分析，判断其情感倾向为正面还是负面。以下是需要分析的文本：<text>天气真好啊</text>判断标准如下：如果文本表达的是正面情感，输出1；如果文本表达的是负面情感，输出 -1。不要输出其他东西.\n") as ans;
ans
硅基流动聊天接口测试成功
select ai_complete("ob_complete","你是一个翻译大师，请将以下文本翻译成英文：你好世界，输出仅包含翻译结果") as ans;
ans
