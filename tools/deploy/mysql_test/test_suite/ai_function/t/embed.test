connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;


# aliyun-openAI 模型
## text-embedding-v1
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('aliyun_embedding_v1');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'aliyun_embedding_v1', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('aliyun_embedding_v1_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'aliyun_embedding_v1_endpoint', '{
    "ai_model_name": "aliyun_embedding_v1",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/embeddings",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openai"
  }');

