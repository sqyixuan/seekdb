#owner: fengsun.cx
##owner group: shenzhen

connection default;
########################################
#####服务端不存在的模型
########################################
## 服务端不存在的模型
## aliyun-openAI
####################################
# 确保清除模型
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "not_exist"
  }');

# 确保清除endpoint
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_complete_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_complete_endpoint', '{
    "ai_model_name": "ob_complete",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/chat/completions",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openAI"
  }');

--error 4216
select ai_complete("ob_complete", "hi");

# 清理信息
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_complete_endpoint');

