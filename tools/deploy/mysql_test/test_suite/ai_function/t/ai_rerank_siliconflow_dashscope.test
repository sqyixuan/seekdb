#owner: ouji.yhd
#owner group: shenzhen

connection default;

########################################################
# 测试rerank模型
# 测试模型：BAAI/bge-reranker-v2-m3
# 测试provider：siliconflow
########################################################

--let $url=http://0.0.0.0:8000/v1/rerank
--let $access_key=abcdefghijklmnopqrstuvwxyz
--let $provider=siliconflow

# 添加rerank模型
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_rerank');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_rerank_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_rerank', '{
    "type": "rerank",
    "model_name": "BAAI/bge-reranker-v2-m3"
  }');

--eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT ('ob_rerank_endpoint', '{"ai_model_name": "ob_rerank","scope": "all","url": "$url","access_key": "$access_key","provider": "$provider"}');

# 无参数
--error 1582
select ai_rerank();

# 字符串model名
--error 1210
select ai_rerank("", "Apple", '["apple","banana","fruit","vegetable"]');

# 不存在的model名
--error 1210
select ai_rerank("empty", "Apple", '["apple","banana","fruit","vegetable"]');

--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/embeddings",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openAI"
  }');

# 指定不同类型的model名
--error 1210
select ai_rerank("ob_embed", "Apple", '["apple","banana","fruit","vegetable"]');

# 空query
--error 1210
select ai_rerank("ob_rerank","", '["apple","banana","fruit","vegetable"]');

# 空query和空document
--error 3141
select ai_rerank("ob_rerank","","");

# 空document
--error 3141
select ai_rerank("ob_rerank","Apple", '');

# 输入空document
--error 1582
select ai_rerank("ob_rerank","Apple");


# 输入正确model，query和document
select ai_rerank("ob_rerank","Apple",'["apple","banana","fruit","vegetable"]');

# 参数query为NULL
--error 1210
select ai_rerank("ob_rerank",NULL,'["apple","banana","fruit","vegetable"]');

# 参数documents为NULL
--error 1210
select ai_rerank("ob_rerank","Apple",NULL);

# 参数model_key为NULL
--error 1210
select ai_rerank(NULL,"Apple",'["apple","banana","fruit","vegetable"]');

# 测试非法json格式
--error 3141
select ai_rerank("ob_rerank","Apple","apple");

# 测试不同内容的文档
select ai_rerank("ob_rerank","搜索引擎",'["搜索引擎是信息检索系统","数据库是结构化数据管理系统","人工智能是计算机科学的一个分支"]');

--error 3141
select ai_rerank("ob_rerank","搜索引擎",'{"搜索引擎是信息检索系统","数据库是结构化数据管理系统","人工智能是计算机科学的一个分支"}');



select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'ob_rerank'; 
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME = 'ob_rerank_endpoint'; 
connect (sys_conn,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys_conn;
# select TENANT_ID from oceanbase.CDB_OB_AI_MODELS; 
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('my_ai_model_3');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_ai_model_endpoint_3');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'my_ai_model_3', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT(
  'my_ai_model_endpoint_3', '{
    "ai_model_name": "my_ai_model_3",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/chat/completions",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openAI"
  }');

select NAME, TYPE, MODEL_NAME from oceanbase.CDB_OB_AI_MODELS WHERE NAME in ('my_ai_model_3', 'ob_rerank') ORDER BY NAME;
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME in ('my_ai_model_endpoint_3', 'ob_rerank_endpoint');


connection default;

# 删除模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_rerank');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_rerank_endpoint');

call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');
