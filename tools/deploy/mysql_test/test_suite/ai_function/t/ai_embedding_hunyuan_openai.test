# owner: ouji.yhd
# owner group: shenzhen

connection default;

########################################################
# 测试embedding模型
# 测试模型：hunyuan-embedding
# 测试provider：hunyuan-openAI
########################################################

--let $url=http://0.0.0.0:8000/hunyuan/v1/embeddings
--let $access_key=abcdefghijklmnopqrstuvwxyz
--let $provider=hunyuan-openAI


--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "hunyuan-embedding"
  }');

--eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT ('ob_embed_endpoint', '{"ai_model_name": "ob_embed","scope": "all","url": "$url","access_key": "$access_key","provider": "$provider"}');

########################################################
# 测试ai_embed表达式
########################################################

# valid input
select ai_embed("ob_embed","你好") as ans;

select ai_embed("ob_embed","Hello World") as ans;

select ai_embed("ob_embed","Hello 世界") as mixed_embedding;

select ai_embed("ob_embed","12345") as number_embedding;

# 输入空字符串
--error 1210
select ai_embed("ob_embed","") as empty_embedding;

# 不输入参数
--error 1582
select ai_embed();

# 输入空model名
--error 1582
select ai_embed("");


--error 1210
select ai_embed("","");

# 输入空model名
--error 1210
select ai_embed("","你好") as ans;

# 输入错误的model名
--error 1210
select ai_embed("ob_embed_not_exist", "Hello World");


--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "qwen3-32b"

  }');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_complete_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_complete_endpoint', '{
    "ai_model_name": "ob_complete",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/chat/completions",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-dashscope"
  }');

--error 1210
select ai_embed("ob_complete", "hi");





# 只输入model名
--error 1582
select ai_embed("ob_embed") as missing_param_test;


# 指定embedding维度
# TODO：暂时不支持指定embedding维度
# --error 4216
# select ai_embed("ob_embed","Hello World",768) as dimension_embedding;

# 用字符串指定embedding维度
--error 1210
select ai_embed("ob_embed","Hello World","768") as dimension_embedding;


--error 1210
select ai_embed("ob_embed","Hello World", -1) as negative_dimension_test;

--error 1210
select ai_embed("ob_embed","Hello World", "string") as invalid_dimension_test;

--error 1210
select ai_embed("ob_embed","Hello World", 1.2) as float_dimension_test;



select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'ob_embed'; 
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME = 'ob_embed_endpoint'; 
connect (sys_conn,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys_conn;
# select TENANT_ID from oceanbase.CDB_OB_AI_MODELS; 
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('my_ai_model_3');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_ai_model_endpoint_3');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'my_ai_model_3', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');

--eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT('my_ai_model_endpoint_3', '{"ai_model_name": "my_ai_model_3","scope": "all","url": "$url","access_key": "$access_key","provider": "$provider"}');


# 视图
select NAME, TYPE, MODEL_NAME from oceanbase.CDB_OB_AI_MODELS WHERE NAME in ('my_ai_model_3', 'ob_embed') ORDER BY NAME;
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME in ('my_ai_model_endpoint_3', 'ob_embed_endpoint');

connection default;

# 删除embedding模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');
