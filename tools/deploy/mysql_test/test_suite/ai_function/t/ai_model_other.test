#owner: shenyunlong.syl
#owner group: shenzhen

### 1. Test when tenant not in rs, create/drop ai model should work
### issue 2025090100110751562

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys;

let $zone = query_get_value(select zone from oceanbase.DBA_OB_SERVERS order by with_rootserver asc limit 1, zone, 1);
let $unit_num = query_get_value(select count(*) as c from oceanbase.DBA_OB_SERVERS where zone = '$zone', c, 1);

--disable_query_log
--disable_warnings
#drop tenant if exists tenant_ai_model FORCE;
#drop resource pool if exists pool_ai_model;
#drop resource unit if exists unit_ai_model;

--echo # begin to create tenant_ai_model
#eval CREATE RESOURCE UNIT unit_ai_model MAX_CPU=1, MEMORY_SIZE='2G';
#eval CREATE RESOURCE POOL pool_ai_model UNIT='unit_ai_model', UNIT_NUM=$unit_num, ZONE_LIST=('$zone');
#eval CREATE TENANT tenant_ai_model, REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('pool_ai_model') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
--echo # finish create tenant_ai_model

let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn_ai_model_root, $TE_SERVER_IP, root,,test, $TE_SERVER_PORT);
connection conn_ai_model_root;
--enable_query_log

--echo # begin to create/drop ai model
call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'my_ai_model_1', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');

call DBMS_AI_SERVICE.DROP_AI_MODEL('my_ai_model_1');

--echo # finish create/drop ai model

connection sys;
--disable_query_log
#drop tenant tenant_ai_model force;
#drop resource pool pool_ai_model;
#drop resource unit unit_ai_model;
--enable_query_log
