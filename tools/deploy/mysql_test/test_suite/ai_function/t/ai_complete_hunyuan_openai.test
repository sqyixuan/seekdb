# owner: ouji.yhd
# owner group: qa

connection default;

########################################################
# 测试ai_complete
# 测试模型：hunyuan-turbos-latest
# 测试provider：hunyuan-openAI
########################################################

--let $url=http://0.0.0.0:8000/hunyuan/v1/chat/completions
--let $access_key=abcdefghijklmnopqrstuvwxyz
--let $provider=hunyuan-openAI

# 确保清除模型
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "hunyuan-turbos-latest"
  }');

# 确保清除endpoint
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_complete_endpoint');

--eval call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT ('ob_complete_endpoint', '{"ai_model_name": "ob_complete","scope": "all","url": "$url","access_key": "$access_key","provider": "$provider"}');

# 情感判断
select ai_complete("ob_complete","你的任务是对提供的文本进行情感分析，判断其情感倾向为正面还是负面。以下是需要分析的文本：<text>天气真好啊</text>判断标准如下：如果文本表达的是正面情感，输出1；如果文本表达的是负面情感，输出 -1。不要输出其他东西.\n") as ans;

# 翻译
select ai_complete("ob_complete","你是一个翻译大师，请将以下文本翻译成英文：你好世界，输出仅包含翻译结果") as ans;

# 不输入参数
--error 1582
select ai_complete();

# 只输入空model名
--error 1582
select ai_complete("");

# 输入空model名和空prompt
--error 1210
select ai_complete("", "");

# 输入空model名和空prompt和空parameters
--error 3141
select ai_complete("", "", "");

# 输入错误的model名
--error 1582
select ai_complete("complete");

# 只输入正确model名
--error 1582
select ai_complete("ob_complete");

# 输入正确model名，输入空prompt
--error 1210
select ai_complete("ob_complete", "");

# 输入不存在的model名
--error 1210
select ai_complete("ob_complete_not_exist", "hi");

# 输入正确model名和prompt
select ai_complete("ob_complete", "hi");

# 是否支持可选参数
select ai_complete("ob_complete", "将苹果，菠萝，香蕉按拼音升序排列并用逗号连接", "{
  \"temperature\": 0.7,
  \"top_p\": 0.9,
  \"presence_penalty\": 0.0,
  \"extra_body\": {
    \"top_k\": 50
  }
}");

--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/embeddings",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openAI"
  }');

--error 1210
select ai_complete("ob_embed", "hello");

call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_embed');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_embed_endpoint');


select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'ob_complete'; 
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME = 'ob_complete_endpoint'; 
connect (sys_conn,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys_conn;
# select TENANT_ID from oceanbase.CDB_OB_AI_MODELS; 
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('my_ai_model_3');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_ai_model_endpoint_3');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'my_ai_model_3', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT(
  'my_ai_model_endpoint_3', '{
    "ai_model_name": "my_ai_model_3",
    "scope": "all",
    "url": "http://0.0.0.0:8000/compatible-mode/v1/chat/completions",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-openAI"
  }');

select NAME, TYPE, MODEL_NAME from oceanbase.CDB_OB_AI_MODELS WHERE NAME in ('my_ai_model_3', 'ob_complete') ORDER BY NAME;
select ENDPOINT_NAME, SCOPE, URL, PROVIDER from oceanbase.DBA_OB_AI_MODEL_ENDPOINTS where ENDPOINT_NAME in ('my_ai_model_endpoint_3', 'ob_complete_endpoint');


connection default;

# 删除completion模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('ob_complete_endpoint');
