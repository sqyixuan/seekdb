#owner: shenyunlong.syl
#owner group: shenzhen

### Test when lower_case_table_names = 1, cafe, CAFE, café are the same

connection default;
### By default tenant's lower_case_table_names = 1
SHOW VARIABLES LIKE 'lower_case_table_names';
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('cafe');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'cafe', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'cafe';

--error 11119 
call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'café', '{
    "type": "sparse_embedding",
    "model_name": "text-embedding-v1"
  }');

--error 11119 
call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'CAFE', '{
    "type": "sparse_embedding",
    "model_name": "text-embedding-v1"
  }');

call DBMS_AI_SERVICE.DROP_AI_MODEL('CAFE');
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'cafe';

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'cafe', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'café';
call DBMS_AI_SERVICE.DROP_AI_MODEL('café');  
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'cafe';

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'café', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'CAFE';
call DBMS_AI_SERVICE.DROP_AI_MODEL('CAFE');  
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'cafe';

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
  'cafe', '{
    "type": "dense_embedding",
    "model_name": "text-embedding-v1"
  }');
select NAME, TYPE, MODEL_NAME from oceanbase.DBA_OB_AI_MODELS where NAME = 'cafe';

# check ai model endpoint CREATE and update, can not CREATE two endpoint with the same ai model name
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint1');
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint2');
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint3');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
  'my_model_endpoint1', '{
    "ai_model_name": "cafe",
    "url": "https://www.baidu.com/",
    "access_key": "sk-xxxxxxxxxxxx",
    "request_model_name": "text-embedding-v2",
    "provider": "openai"
  }');

--error 0,11113
call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
  'my_model_endpoint2', '{
    "ai_model_name": "CAFE",
    "scope": "all",
    "url": "https://www.baidu.com/",
    "access_key": "sk-xxxxxxxxxxxx",
    "request_model_name": "text-embedding-v2",
    "provider": "openai"
  }');

--error 0,11113
call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
  'my_model_endpoint3', '{
    "ai_model_name": "café",
    "url": "https://www.baidu.com/",
    "access_key": "sk-xxxxxxxxxxxx",
    "request_model_name": "text-embedding-v2",
    "provider": "openai"
  }');

# 主要check alter情况，这里大小写不敏感， cafe 和 Cafe认为相同
# 这里相当于自己改自己 不报错
call DBMS_AI_SERVICE.ALTER_AI_MODEL_ENDPOINT (
  'my_model_endpoint1', '{
    "ai_model_name": "Cafe",
  }');

# 这里相当于自己改自己 不报错
call DBMS_AI_SERVICE.ALTER_AI_MODEL_ENDPOINT (
  'my_model_endpoint1', '{
    "ai_model_name": "café",
  }');


call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint1');
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint2');
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('my_model_endpoint3');