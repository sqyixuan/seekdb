connection default;

########################################################
# 测试create_ai_model
########################################################

--let $url=http://0.0.0.0:8000/compatible-mode/v1/chat/completions
--let $access_key=abcdefghijklmnopqrstuvwxyz
--let $provider=aliyun-openAI

# 确保清除模型
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

# 创建模型，参数正确，type为completion
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');

# 清除模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

# 创建模型，缺少type
--error 11114
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "model_name": "qwen3-32b"
  }');

--error 1318
call DBMS_AI_SERVICE.CREATE_AI_MODEL('{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');

--error 1318
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete');

--error 3141
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }}');



# 创建模型，缺少model_name
--error 11114
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion"
  }');

# 创建模型，参数正确，type为dense_embedding
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "dense_embedding",
    "model_name": "qwen3-32b"
  }');

# 清除模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

# 创建模型，参数正确，type为sparse_embedding
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "sparse_embedding",
    "model_name": "qwen3-32b"
  }');

# 清除模型
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

# 创建模型，参数正确，type为rerank
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "rerank",
    "model_name": "qwen3-32b"
  }');


# 创建模型，但name为空
--error 11114
call DBMS_AI_SERVICE.CREATE_AI_MODEL('', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');

# 创建模型，但name已经存在（确保已存在：上上步已成功创建 ob_complete）
--error 11119
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": "qwen3-32b"
  }');



# 清除模型以进行后续测试
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete');

# 创建模型，type为空
--error 11116
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "",
    "model_name": "qwen3-32b"
  }');

# 创建模型，type不存在
--error 11116
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "VL",
    "model_name": "qwen3-32b"
  }');

# 创建模型，但model name为空
--error 11114
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_complete', '{
    "type": "completion",
    "model_name": ""
  }');


########################################################
# 测试drop_ai_model
########################################################

# 清除模型，但name为空
--error 11114
call DBMS_AI_SERVICE.DROP_AI_MODEL('');


# 清除不存在的模型
--error 11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('ob_complete_not_exist');

# 缺参数
--error 1318
call DBMS_AI_SERVICE.DROP_AI_MODEL();


