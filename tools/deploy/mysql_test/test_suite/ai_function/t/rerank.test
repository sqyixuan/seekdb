## model_name 存在和不存在
# 存在
select ai_rerank("aliyun_rerank_v2","Apple",'["apple","banana","fruit","vegetable"]');
select ai_rerank("silicon_bge_reranker_v2_m3","Apple",'["apple","banana","fruit","vegetable"]');
select ai_rerank("silicon_qwen3_reranker_8b","Apple",'["apple","banana","fruit","vegetable"]');
select ai_rerank("silicon_qwen3_reranker_4b","Apple",'["apple","banana","fruit","vegetable"]');
select ai_rerank("silicon_qwen3_reranker_06b","Apple",'["apple","banana","fruit","vegetable"]');

# 不存在，对于不存在的模型
--error 0,4216
select ai_rerank("unknow_aliyun_rerank_v2","Apple",'["apple","banana","fruit","vegetable"]');
--error 0,4216
select ai_rerank("unknow_silicon_reranker","Apple",'["apple","banana","fruit","vegetable"]');


