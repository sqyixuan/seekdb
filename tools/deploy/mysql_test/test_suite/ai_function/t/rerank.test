#owner: fengsun.cx
#owner group: shenzhen

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

# aliyun-dashscope rerank 模型
## gte-rerank-v2
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('aliyun_rerank_v2');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'aliyun_rerank_v2', '{
    "type": "rerank",
    "model_name": "gte-rerank-v2"
  }');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('aliyun_rerank_v2_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'aliyun_rerank_v2_endpoint', '{
    "ai_model_name": "aliyun_rerank_v2",
    "scope": "all",
    "url": "http://0.0.0.0:8000/api/v1/services/rerank/text-rerank/text-rerank",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-dashscope"
  }');

## 不存在的模型
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL('unknow_aliyun_rerank_v2');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'unknow_aliyun_rerank_v2', '{
    "type": "rerank",
    "model_name": "unknow_gte-rerank-v2"
  }');

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT('unknow_aliyun_rerank_v2_endpoint');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'unknow_aliyun_rerank_v2_endpoint', '{
    "ai_model_name": "unknow_aliyun_rerank_v2",
    "scope": "all",
    "url": "http://0.0.0.0:8000/api/v1/services/rerank/text-rerank/text-rerank",
    "access_key": "abcdefghijklmnopqrstuvwxyz",
    "provider": "aliyun-dashscope"
  }');

