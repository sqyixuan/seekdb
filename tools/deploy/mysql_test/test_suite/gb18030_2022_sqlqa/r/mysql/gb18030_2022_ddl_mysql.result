drop table if exists t_student;
drop table if exists t_class;
create table t_class(
cno int(10) primary key,
cname varchar(128) character set gb18030_2022 not null unique
)DEFAULT CHARACTER SET = gb18030_2022;
create table t_student(
sno int(10) primary key auto_increment,
sname varchar(32) character set gb18030_2022 not null,
classno int(3),
foreign key(classno) references t_class(cno)
)DEFAULT CHARACTER SET = gb18030_2022;
insert into t_class(cno,cname) values(100,'你你你以以');
insert into t_class(cno,cname) values(200,'哈哈哈哈哈');
insert into t_student(sname,classno) values('黨',100);
insert into t_student(sname,classno) values('𢿤',100);
insert into t_student(sname,classno) values('好1231@#',200);
select s.*,c.* from t_student s join t_class c on s.classno=c.cno order by sno;
sno	sname	classno	cno	cname
1	黨	100	100	你你你以以
2	𢿤	100	100	你你你以以
3	好1231@#	200	200	哈哈哈哈哈
select s.*,c.*,hex(sname) from t_student s join t_class c on s.classno=c.cno order by sno;
sno	sname	classno	cno	cname	hex(sname)
1	黨	100	100	你你你以以	FC68
2	𢿤	100	100	你你你以以	9631DE36
3	好1231@#	200	200	哈哈哈哈哈	BAC3313233314023
drop table if exists user_test;
create table user_test(uid int auto_increment,data varchar(10) character set gb18030_2022,primary key(uid))DEFAULT CHARACTER SET = gb18030_2022;
insert into user_test values (NULL,'沈阳');
insert into user_test values (NULL,'日本');
alter table user_test add user_name varchar(20) generated always as (data);
alter table user_test add index idx_name(user_name);
