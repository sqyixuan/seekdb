id INT AUTO_INCREMENT,
fileuploadercode VARCHAR(128) character set gb18030_2022,
projectid INT,
filename VARCHAR (512) character set gb18030_2022,
fileurl VARCHAR (512) character set gb18030_2022,
filesize BIGINT,
PRIMARY KEY (id),
UNIQUE INDEX (projectid),
INDEX (fileuploadercode)
)DEFAULT CHARSET = gb18030_2022;
