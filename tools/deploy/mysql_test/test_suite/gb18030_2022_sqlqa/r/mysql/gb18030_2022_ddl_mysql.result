select * from user_test where user_name='沈阳';
uid	data	user_name
1	沈阳	沈阳
select * from user_test;
uid	data	user_name
1	沈阳	沈阳
2	日本	日本
3	四川	四川
drop table if exists user_test;
CREATE TABLE user_test
(
id INT(11) PRIMARY KEY,
name VARCHAR(22) character set gb18030_2022,
location VARCHAR(50) character set gb18030_2022 DEFAULT '北京'
)DEFAULT CHARACTER SET = gb18030_2022;
DESC user_test;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(22)	YES		NULL	
location	varchar(50)	YES		北京	
ALTER TABLE user_test
CHANGE COLUMN location
location VARCHAR(50) DEFAULT '上海';
DESC user_test;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(22)	YES		NULL	
location	varchar(50)	YES		上海	
