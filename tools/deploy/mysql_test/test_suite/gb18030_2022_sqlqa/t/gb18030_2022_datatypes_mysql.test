SET NAMES gb18030_2022;
--echo ##整数类型
--echo ##int，bigint、MEDIUMINT、SMALLINT、TINYINT、bit

create table t1(c1 int,c2 bigint,c3 MEDIUMINT,c4 SMALLINT,c5 TINYINT,c6 bit)DEFAULT CHARACTER SET = gb18030_2022;
insert into t1 values (1,1.1,112,14,115,1 );
select c1,hex(c1),c2,hex(c2),c3,hex(c3),c4,hex(c4),c5,hex(c5),c6,hex(c6) from t1;

--echo ##浮点数和定点数

create table t2(c1 Float(6,2),c2 Double(6,2),c3 Decimal(6,2))DEFAULT CHARACTER SET = gb18030_2022;
insert into t2 values (1.1123,99.1,1.9565);
select c1,hex(c1) from t2;

--echo ##日期类型
create table t3(c1 date,c2 datetime,c3 timestamp,c4 time,c5 year)DEFAULT CHARACTER SET = gb18030_2022;
insert into t3 values ('2022-10-10','2022-10-10','2022-10-10 14:15:10.9999999','2022','2023');
select c1,hex(c1) from t3;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

--echo ##字符串类型
create table t1(c1 BIT(64),c2 blob,c3 char(200) character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into t1 values(' 字龠 ',' 字龠 ',' 字龠 ');
select c1,hex(c1) from t1;

create table t2(c1 enum('哈','呵','龠') character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into t2 values('龠');
select c1,hex(c1) from t2;

create table t3(c1 set('哈','呵','龠') character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into t3 values('龠');
insert into t3 values('龠,呵');
select c1,hex(c1) from t3;

--echo ##json类型
create table t4(c1 json )DEFAULT CHARACTER SET = gb18030_2022;
insert into t4 values('{"name": "John", "age": 30}');
insert into t4 values('{"gb18030_2022": "郎", "十六进制": "0xFD9C"}');
