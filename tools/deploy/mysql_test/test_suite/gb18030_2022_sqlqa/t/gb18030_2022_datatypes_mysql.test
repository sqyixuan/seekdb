SET NAMES gb18030_2022;

--echo ##函数
create table t1(c1 int,c2 TINYTEXT character set gb18030_2022,c3 timestamp,c4 date,c5 char(200) character set gb18030_2022,c6 varchar(200) character set gb18030_2022,c7 decimal(6,2),c8 varchar(120) generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gb18030_2022;
insert into t1(c1,c2,c3,c4,c5,c6,c7) values(1,'二亠人儿入八冂冖冫','2020-05-21 02:02:02','2022-05-21','金長門阜隶隹雨靑非','黃黍黑黹',9.11135);
create table t2(c1 char(255) character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into t2 values('先帝创业未半而中道崩殂，今天下三分，益州疲弊，此诚危急存亡之秋也。然侍卫之臣不懈于内，忠志之士忘身于外者，盖追先帝之殊遇，欲报之于陛下也。诚宜开张圣听，以光先帝遗德，恢弘志士之气，不宜妄自菲薄，引喻失义，以塞忠谏之路也。');

insert into t1(c1,c2,c3,c4,c5,c6,c7) select 1,substr(c1,1*20,10),'2020-05-21 01:01:01','2020-05-21 02:02:02',substr(c1,1*20+1,10),substr(c1,1*20+2,10),1*4+1/7 from t1;

select * from t1;
select * from t2;

drop table  IF EXISTS  t1;
drop table  IF EXISTS  t2;

create table t1(c1 char(2) character set gb18030_2022,c2 varchar(2) character set gb18030_2022,c3 varchar(1) character set gb18030_2022,c4 TINYTEXT character set gb18030_2022,c5 decimal(1),c6 date)DEFAULT CHARACTER SET = gb18030_2022;
insert into t1 values('哈','哈','哈','哈',1,'2020-05-21 01:01:01');
delimiter //;
CREATE  FUNCTION  f1(c5_id INT )  
         RETURNS VARCHAR(20)  
         BEGIN  
             RETURN  (SELECT hex(c2) 
             FROM  t1
             WHERE  c5=c5_id );  
         END //
delimiter ;//

select  f1(1) from dual;
select * from t1;

drop function IF EXISTS  f1;
drop table  IF EXISTS  t1;

--echo ##存储过程
create table t1(c1 char(2) character set gb18030_2022,c2 varchar(2) character set gb18030_2022,c3 varchar(1) character set gb18030_2022,c4 TINYTEXT character set gb18030_2022,c5 decimal(1),c6 date)DEFAULT CHARACTER SET = gb18030_2022;
insert into t1 values('哈','哈','哈','哈',1,'2020-05-21 01:01:01');
delimiter //;
##CREATE  PROCEDURE  p1(IN c5_id INT, OUT count_num TINYTEXT)  
CREATE  PROCEDURE  p1(IN c5_id INT, OUT count_num varchar(20))  
        BEGIN  
           SELECT hex(c2) INTO  count_num  
             FROM  t1
             WHERE  c5=c5_id;  
         END //
delimiter ;//

set @p_out='ABCD';
call p1(1,@p_out);
select @p_out;
select * from t1;

drop procedure IF EXISTS  p1;
drop table  IF EXISTS  t1;


--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1  character set gb18030_2022;
use db1;

SET NAMES gb18030_2022;
###--character_set gb18030_2022

--disable_warnings
drop table if exists user;
drop table if exists user_history;
drop TRIGGER if exists tri_insert_user;
drop TRIGGER if exists tri_update_user;
drop TRIGGER if exists tri_delete_user;
--enable_warnings

--echo ##触发器
CREATE TABLE `user` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `account` varchar(255) character set gb18030_2022 DEFAULT NULL,
  `name` varchar(255) character set gb18030_2022 DEFAULT NULL,
  `address` varchar(255) character set gb18030_2022 DEFAULT NULL,
  PRIMARY KEY (`id`)
)DEFAULT CHARACTER SET = gb18030_2022;

CREATE TABLE `user_history` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `user_id` bigint(20) NOT NULL,
  `operatetype` varchar(200) character set gb18030_2022 NOT NULL,
  `operatetime` datetime NOT NULL,
  PRIMARY KEY (`id`)
)DEFAULT CHARACTER SET = gb18030_2022;


DELIMITER //;
CREATE TRIGGER `tri_insert_user` AFTER INSERT ON `user` FOR EACH ROW begin
    INSERT INTO user_history(user_id, operatetype, operatetime) VALUES (new.id, 'add a user',  now());
end
//
DELIMITER ;//

DELIMITER //;
CREATE TRIGGER `tri_update_user` AFTER UPDATE ON `user` FOR EACH ROW begin
    INSERT INTO user_history(user_id,operatetype, operatetime) VALUES (new.id, 'update a user', now());
end
//
DELIMITER ;//

DELIMITER //;
CREATE TRIGGER `tri_delete_user` AFTER DELETE ON `user` FOR EACH ROW begin
    INSERT INTO user_history(user_id, operatetype, operatetime) VALUES (old.id, 'delete a user', now());
end
//
DELIMITER ;//

INSERT INTO user(account, name, address) VALUES ('用户1', '用户1', '用户1');
INSERT INTO user(account, name, address) VALUES ('用户2', '用户2', '用户2');
UPDATE user SET name = '用户3', account = '用户3', address='用户3' where name='用户1';
DELETE FROM `user` where name = '用户2';


