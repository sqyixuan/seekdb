--echo ##comment

drop table if exists t1;

create table t1
(
c1 varchar(100) character set gb18030_2022 comment '123中文321.' 
)DEFAULT CHARACTER SET = gb18030_2022 comment='𬴃';

insert into t1 values('123中文321.');
alter table t1 comment '𬴃2';
alter table t1 modify column c1 varchar(10) comment '123中文321.';

ALTER TABLE t1 CHANGE c1 中文123 char(20);

