drop table if exists test1;
create table test1(
id int(10),
name varchar(32) character set gb18030_2022 not null,
email varchar(128) character set gb18030_2022,
unique(name,email)
)DEFAULT CHARACTER SET = gb18030_2022;
 
insert into test1(id,name,email) values(1,'xxx','qq.com');
