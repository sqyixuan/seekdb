--disable_warnings
drop table if exists user_test;
drop view if exists user_test_view;
drop view if exists user_test_view2;
--enable_warnings
 
create table user_test(uid int auto_increment,data varchar(10) character set gb18030_2022,primary key(uid))DEFAULT CHARACTER SET = gb18030_2022;
insert into user_test values (NULL,'沈阳');
insert into user_test values (NULL,'日本');
alter table user_test add user_name varchar(20) generated always as (data);
alter table user_test add index idx_name(user_name);
insert into user_test(uid,data) values (NULL,'四川');
 
create view user_test_view as select * from user_test;
create view user_test_view2 as select t.uid as view1,t.data as view2 from user_test t;
 

select * from user_test where user_name='沈阳';
select * from user_test;
select * from user_test_view where user_name='沈阳';
select * from user_test_view;
select * from user_test_view2 where view2='沈阳';
select * from user_test_view2;

