#三字节插入报错
--error 1406
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x414243);
--error 1300
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x81398B);
#utf8下三字节插入显示
#国，在utf8下是3个字节，gb18030_2022下2个字节
INSERT INTO db1.t2 VALUES (_utf8 0xE59BBD);
#가，在utf8下是3个字节，gb18030_2022下4个字节
#aone:49210591# INSERT INTO db1.t2 VALUES (_utf8 0xEAB080);

SELECT a,hex(a),hex(weight_string(a)),length(a) FROM db1.t2 WHERE a='国';
SELECT a,hex(a),hex(weight_string(a)),length(a) FROM db1.t2 WHERE a='가';
select a,convert(a, char(1) CHARACTER SET utf8) from db1.t2 order by 1, hex(a);
select a,convert(a, char(1) CHARACTER SET utf8) from db1.t2 order by 2, hex(a);


DROP DATABASE IF EXISTS db1;
DROP DATABASE IF EXISTS db2;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user ljh@'%' ;
--enable_warnings


