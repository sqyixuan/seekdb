#owner: wuyuming.wym
#owner group: 技术部-SQL-SQL1组
#description: gb18030-2022 charset test
#tags: basic
#auther:wb-ljh01399065

--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user ljh@'%';
--enable_warnings
create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh,ljh,test,$OBMYSQL_PORT);

set names 'gb18030_2022';
set character_set_database = 'gb18030_2022';
set character_set_server = 'gb18030_2022';

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


--disable_warnings
DROP DATABASE IF EXISTS db1;
DROP DATABASE IF EXISTS db2;
--enable_warnings
CREATE DATABASE db1 CHARACTER SET gb18030_2022;
CREATE DATABASE db2 CHARACTER SET gb18030;

CREATE TABLE db1.t1 (a char(1));
CREATE TABLE db2.t1 (a char(1));                                                                                                                                                                    

--echo 1.1.映射关系改变的18个字符,转换为 utf8mb4 之类的其他字符集会有变化
INSERT INTO db1.t1 VALUES (_gb18030_2022 0xA6D9),(_gb18030_2022 0xA6DA),(_gb18030_2022 0xA6DB),(_gb18030_2022 0xA6DC);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0xA6DD),(_gb18030_2022 0xA6DE),(_gb18030_2022 0xA6DF),(_gb18030_2022 0xA6EC);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0xA6ED),(_gb18030_2022 0xA6F3),(_gb18030_2022 0xFE59),(_gb18030_2022 0xFE61);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0xFE66),(_gb18030_2022 0xFE67),(_gb18030_2022 0xFE6D),(_gb18030_2022 0xFE7E);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0xFE90),(_gb18030_2022 0xFEA0);

INSERT INTO db2.t1 VALUES (_gb18030 0x84318236),(_gb18030 0x84318238),(_gb18030 0x84318237),(_gb18030 0x84318239);
INSERT INTO db2.t1 VALUES (_gb18030 0x84318330),(_gb18030 0x84318331),(_gb18030 0x84318332),(_gb18030 0x84318333);
INSERT INTO db2.t1 VALUES (_gb18030 0x84318334),(_gb18030 0x84318335),(_gb18030 0x82359037),(_gb18030 0x82359038);
INSERT INTO db2.t1 VALUES (_gb18030 0x82359039),(_gb18030 0x82359130),(_gb18030 0x82359131),(_gb18030 0x82359132);
INSERT INTO db2.t1 VALUES (_gb18030 0x82359133),(_gb18030 0x82359134);

--error 1267
select count(*) from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using utf8mb4))=hex(convert(db2.t1.a using utf8mb4));
select count(*) from db1.t1,db2.t1 where db1.t1.a=convert(db2.t1.a using gb18030_2022);
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using gb18030)=db2.t1.a;
truncate db1.t1;
truncate db2.t1;

INSERT INTO db1.t1 VALUES (_gb18030_2022 0x84318236),(_gb18030_2022 0x84318238),(_gb18030_2022 0x84318237),(_gb18030_2022 0x84318239);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0x84318330),(_gb18030_2022 0x84318331),(_gb18030_2022 0x84318332),(_gb18030_2022 0x84318333);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0x84318334),(_gb18030_2022 0x84318335),(_gb18030_2022 0x82359037),(_gb18030_2022 0x82359038);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0x82359039),(_gb18030_2022 0x82359130),(_gb18030_2022 0x82359131),(_gb18030_2022 0x82359132);
INSERT INTO db1.t1 VALUES (_gb18030_2022 0x82359133),(_gb18030_2022 0x82359134);

INSERT INTO db2.t1 VALUES (_gb18030 0xA6D9),(_gb18030 0xA6DA),(_gb18030 0xA6DB),(_gb18030 0xA6DC);
INSERT INTO db2.t1 VALUES (_gb18030 0xA6DD),(_gb18030 0xA6DE),(_gb18030 0xA6DF),(_gb18030 0xA6EC);
INSERT INTO db2.t1 VALUES (_gb18030 0xA6ED),(_gb18030 0xA6F3),(_gb18030 0xFE59),(_gb18030 0xFE61);
INSERT INTO db2.t1 VALUES (_gb18030 0xFE66),(_gb18030 0xFE67),(_gb18030 0xFE6D),(_gb18030 0xFE7E);
INSERT INTO db2.t1 VALUES (_gb18030 0xFE90),(_gb18030 0xFEA0);

--error 1267
select count(*) from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using utf8mb4))=hex(convert(db2.t1.a using utf8mb4));
select count(*) from db1.t1,db2.t1 where db1.t1.a=convert(db2.t1.a using gb18030_2022);
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using gb18030)=db2.t1.a;

--echo 1.2.字符删除
# 二进制排序
CREATE TABLE db1.t2 (a char(1))collate gb18030_2022_bin;
CREATE TABLE db2.t2 (a char(1))collate gb18030_bin;

--echo #插入删除多余映射关系的6个字符
INSERT INTO db1.t2 VALUES (_gb18030_2022 0xFE51),(_gb18030_2022 0xFE52),(_gb18030_2022 0xFE53),(_gb18030_2022 0xFE6C),(_gb18030_2022 0xFE76),(_gb18030_2022 0xFE91);
INSERT INTO db2.t2 VALUES (_gb18030 0xFE51),(_gb18030 0xFE52),(_gb18030 0xFE53),(_gb18030 0xFE6C),(_gb18030 0xFE76),(_gb18030 0xFE91);

--echo #插入字形被删除的9个字符
INSERT INTO db1.t2 VALUES (_gb18030_2022 0xFD9C),(_gb18030_2022 0xFD9D),(_gb18030_2022 0xFD9E),(_gb18030_2022 0xFD9F),(_gb18030_2022 0xFDA0),(_gb18030_2022 0xFE40),(_gb18030_2022 0xFE41),(_gb18030_2022 0xFE47),(_gb18030_2022 0xFE49);
INSERT INTO db2.t2 VALUES (_gb18030 0xFD9C),(_gb18030 0xFD9D),(_gb18030 0xFD9E),(_gb18030 0xFD9F),(_gb18030 0xFDA0),(_gb18030 0xFE40),(_gb18030 0xFE41),(_gb18030 0xFE47),(_gb18030 0xFE49);

--echo #插入二字节中文'啊'
INSERT INTO db1.t2 VALUES (_gb18030_2022 0xB0A1);
INSERT INTO db2.t2 VALUES (_gb18030 0xB0A1);

--echo #二进制排序不受影响
select a,hex(a) from db1.t2 order by a;
select a,hex(a) from db2.t2 order by a;

# 拼音序
# 拼音序，大小写不敏感
CREATE TABLE db1.t3 (a char(1))collate gb18030_2022_chinese_ci;
INSERT INTO db1.t3 SELECT * FROM db1.t2;
CREATE TABLE db2.t3 (a char(1))collate gb18030_chinese_ci;
INSERT INTO db2.t3 SELECT * FROM db2.t2;
# 拼音序，大小写敏感
CREATE TABLE db1.t4 (a char(1))collate gb18030_2022_chinese_cs;
INSERT INTO db1.t4 SELECT * FROM db1.t2;

--echo #拼音序排序受影响
select a,hex(a),hex(weight_string(a)) from db1.t3 order by a;
select a,hex(a),hex(weight_string(a)) from db2.t3 order by a;
select a,hex(a),hex(weight_string(a)) from db1.t4 order by a;

# 部首笔画序
# 部首笔画序，大小写不敏感
CREATE TABLE db1.t5 (a char(1))collate gb18030_2022_radical_ci;
INSERT INTO db1.t5 SELECT * FROM db1.t2;
# 部首笔画序，大小写敏感
CREATE TABLE db1.t6 (a char(1))collate gb18030_2022_radical_cs;
INSERT INTO db1.t6 SELECT * FROM db1.t2;

--echo #部首笔画序排序受影响
select a,hex(a),hex(weight_string(a)) from db1.t5 order by a;
select a,hex(a),hex(weight_string(a)) from db1.t6 order by a;

# 笔画序
# 笔画序，大小写不敏感
CREATE TABLE db1.t7 (a char(1))collate gb18030_2022_stroke_ci;
INSERT INTO db1.t7 SELECT * FROM db1.t2;
# 笔画序，大小写敏感
CREATE TABLE db1.t8 (a char(1))collate gb18030_2022_stroke_cs;
INSERT INTO db1.t8 SELECT * FROM db1.t2;

--echo #笔画序排序受影响
select a,hex(a),hex(weight_string(a)) from db1.t7 order by a;
select a,hex(a),hex(weight_string(a)) from db1.t8 order by a;

truncate db1.t2;
truncate db1.t3;
truncate db1.t4;
truncate db1.t5;
truncate db1.t6;
truncate db1.t7;
truncate db1.t8;
--echo 1.3.新增字符
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x82358F33),(_gb18030_2022 0x82359636);
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x9835F738),(_gb18030_2022 0x98399E36);
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x98399F38),(_gb18030_2022 0x9839B539);
INSERT INTO db1.t2 VALUES (_gb18030_2022 0x9839B632),(_gb18030_2022 0x9933FE33);
