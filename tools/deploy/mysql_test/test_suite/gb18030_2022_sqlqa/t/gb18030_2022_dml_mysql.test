--enable_warnings
 
create table t01(col1 int,col2 varchar(10)character set  gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into t01 values(4,'男');

select * from t01;
select col2, hex(col2) from t01;
select length(col2) from t01;
 
select * from t01 where col2 like '%女%';
select * from t01 where col2 like '%男%';
select * from t01 where col2 like '%1%';
select * from t01 where col2 = '男';

--disable_warnings
drop table if exists nvarchar_gb18030_2022_1;
--enable_warnings
 
create table nvarchar_gb18030_2022_1(c1 varchar(1) character set gb18030_2022,c2 int)DEFAULT CHARACTER SET = gb18030_2022;
insert into nvarchar_gb18030_2022_1 values('啊',1);
insert into nvarchar_gb18030_2022_1 values('a',2);
insert into nvarchar_gb18030_2022_1 values('A',3);
insert into nvarchar_gb18030_2022_1 values('^',4);
insert into nvarchar_gb18030_2022_1 values('.',5);
insert into nvarchar_gb18030_2022_1 values('''',6);
insert into nvarchar_gb18030_2022_1 values(' ',7);
insert into nvarchar_gb18030_2022_1 values(null,8);
insert into nvarchar_gb18030_2022_1 values('',9);
insert into nvarchar_gb18030_2022_1 values('體',10);
insert into nvarchar_gb18030_2022_1 values('ん',11);
 
select c2,c1,length(c1),ascii(c1),hex(c1) from nvarchar_gb18030_2022_1 order by c2;
alter table nvarchar_gb18030_2022_1 modify c1 char(1);
select c2,c1,length(c1),ascii(c1),hex(c1) from nvarchar_gb18030_2022_1 order by c2;
 
--disable_warnings
drop table if exists nvarchar_gb18030_2022_1;
--enable_warnings

--disable_warnings
drop table if exists char_nchar_blend1;
drop table if exists char_to_2;
--enable_warnings
 
create table char_nchar_blend1(c1 char(2) character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into char_nchar_blend1 values('a');
insert into char_nchar_blend1 values('A');
insert into char_nchar_blend1 values('蛤');
insert into char_nchar_blend1 values('!');
create table char_to_2(c1 varchar(2));
insert into char_to_2 select * from char_nchar_blend1;
 
 
select c1,length(c1),ascii(c1),hex(c1) from char_nchar_blend1 order by c1;
select c1,length(c1),ascii(c1),hex(c1) from char_to_2 order by c1;
 
 
--disable_warnings
drop table if exists char_nchar_blend1;
drop table if exists char_to_2;
--enable_warnings

--echo ##join
--disable_warnings
drop table if exists gb18030_2022_datatype_join1;
drop table if exists gb18030_2022_datatype_join2;
drop table if exists gb18030_2022_datatype_join3;
--enable_warnings

--echo 创建数据基表，插入《出师表》
create table gb18030_2022_datatype_join2(c1 varchar(2000)character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022;
insert into gb18030_2022_datatype_join2 values('先帝创业未半而中道崩殂，今天下三分，益州疲弊，此诚危急存亡之秋也。然侍卫之臣不懈于内，忠志之士忘身于外者，盖追先帝之殊遇，欲报之于陛下也。诚宜开张圣听，以光先帝遗德，恢弘志士之气，不宜妄自菲薄，引喻失义，以塞忠谏之路也。
宫中府中，俱为一体，陟罚臧否，不宜异同。若有作奸犯科及为忠善者，宜付有司论其刑赏，以昭陛下平明之理，不宜偏私，使内外异法也。
侍中、侍郎郭攸之、费祎、董允等，此皆良实，志虑忠纯，是以先帝简拔以遗陛下。愚以为宫中之事，事无大小，悉以咨之，然后施行，必能裨补阙漏，有所广益。
将军向宠，性行淑均，晓畅军事，试用于昔日，先帝称之曰能，是以众议举宠为督。愚以为营中之事，悉以咨之，必能使行阵和睦，优劣得所。
亲贤臣，远小人，此先汉所以兴隆也；亲小人，远贤臣，此后汉所以倾颓也。先帝在时，每与臣论此事，未尝不叹息痛恨于桓、灵也。侍中、尚书、长史、参军，此悉贞良死节之臣，愿陛下亲之信之，则汉室之隆，可计日而待也。
臣本布衣，躬耕于南阳，苟全性命于乱世，不求闻达于诸侯。先帝不以臣卑鄙，猥自枉屈，三顾臣于草庐之中，咨臣以当世之事，由是感激，遂许先帝以驱驰。后值倾覆，受任于败军之际，奉命于危难之间，尔来二十有一年矣。
先帝知臣谨慎，故临崩寄臣以大事也。受命以来，夙夜忧叹，恐托付不效，以伤先帝之明，故五月渡泸，深入不毛。今南方已定，兵甲已足，当奖率三军，北定中原，庶竭驽钝，攘除奸凶，兴复汉室，还于旧都。此臣所以报先帝而忠陛下之职分也。至于斟酌损益，进尽忠言，则攸之、祎、允之任也。
愿陛下托臣以讨贼兴复之效，不效，则治臣之罪，以告先帝之灵。若无兴德之言，则责攸之、祎、允等之慢，以彰其咎；陛下亦宜自谋，以咨诹善道，察纳雅言，深追先帝遗诏，臣不胜受恩感激。
今当远离，临表涕零，不知所言。;');
create table gb18030_2022_datatype_join1(c1 int,c2 varchar(20) character set gb18030_2022,c3 timestamp,c4 date,c5 char(20) character set gb18030_2022,c6 varchar(20) character set gb18030_2022,c7 decimal(6,2),c8 varchar(60) character set gb18030_2022 generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gb18030_2022;

insert into gb18030_2022_datatype_join1(c1,c2,c3,c4,c5,c6,c7) select 1,substr(c1,10,10),'1970-01-01','1970-01-01 00:00:00',substr(c1,10+1,10),substr(c1,10+2,10),11 from gb18030_2022_datatype_join2;
 
--echo 创建关联表
create table gb18030_2022_datatype_join3(c1 int,c2 char(20) character set gb18030_2022,c3 timestamp,c4 date,c5 char(20) character set gb18030_2022,c6 varchar(20) character set gb18030_2022,c7 decimal(6,2),c8 varchar(120) character set gb18030_2022 generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gb18030_2022;
 
delimiter //;
drop procedure if exists test_procedure;
create procedure test_procedure()
BEGIN
DECLARE i int DEFAULT 0;
WHILE i< 30 DO
insert into gb18030_2022_datatype_join1(c1,c2,c3,c4,c5,c6,c7) select i,substr(c1,i*10,10),'2000-01-01','1970-01-01 00:00:00',substr(c1,i*10+1,10),substr(c1,i*10+2,10),i*4+i/7 from gb18030_2022_datatype_join2;
SET i= i + 1;
END WHILE;
END
//
delimiter ;//
call test_procedure();

delimiter //;
drop procedure if exists test_procedure2;
create procedure test_procedure2()
BEGIN
DECLARE i int DEFAULT 0;
WHILE i< 30 DO
insert into gb18030_2022_datatype_join3(c1,c2,c3,c4,c5,c6,c7) select i,substr(c1,i*20,10),'2000-01-01','1970-01-01 00:00:00',substr(c1,i*20+1,10),substr(c1,i*20+2,10),i*4+i/7 from gb18030_2022_datatype_join2;
SET i= i + 1;
END WHILE;
END
//
delimiter ;//
call test_procedure2();
 
insert into gb18030_2022_datatype_join3(c1,c2,c3,c4,c5,c6,c7) select c1,c2,c3,c4,c5,c6,c7 from gb18030_2022_datatype_join1 where mod(c1,20)=1;
 
 
select a.c1 as c1,a.c2 as c2 from gb18030_2022_datatype_join1 a join gb18030_2022_datatype_join3 b on a.c2=b.c2 and a.c5=b.c5 and a.c6=b.c6 order by c1 desc;
select * from (select a.c1 as c1,a.c2 as c2 from gb18030_2022_datatype_join1 a join gb18030_2022_datatype_join3 b on a.c2=b.c2 and a.c5=b.c5 and a.c6=b.c6 order by c1 desc) minus
select * from (select a.c1 as c1,a.c2 as c2 from gb18030_2022_datatype_join1 a join gb18030_2022_datatype_join3 b on a.c2=b.c2 and a.c5=b.c5 and a.c6=b.c6 order by c1);
select * from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) WHERE c2=c5;
select c2,c5,c6 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4)  WHERE c2 in ('先帝创业未半而中道崩','漏，有所广益。
将军') and c5='军，北定中原，庶竭驽' and c6<>'阵和睦，优劣得所。
';
select distinct c2,(select count(*) from gb18030_2022_datatype_join1) from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c2=(select c2 from gb18030_2022_datatype_join1 where c1=(select max(c1) from gb18030_2022_datatype_join1));
select distinct c2,(select count(*) from gb18030_2022_datatype_join1,gb18030_2022_datatype_join3) from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c2=(select c2 from gb18030_2022_datatype_join1 where c1=(select min(c1) from gb18030_2022_datatype_join1));
select c2 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c2=(select c2 from gb18030_2022_datatype_join1 where c1=(select avg(c1) from gb18030_2022_datatype_join1));
select distinct c5 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c5=(select c5 from gb18030_2022_datatype_join1 where c1=(select max(c1) from gb18030_2022_datatype_join1));
select distinct c5 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c6=(select c6 from gb18030_2022_datatype_join1 where c1=(select min(c1) from gb18030_2022_datatype_join1));
select distinct c5 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c2=(select c5 from gb18030_2022_datatype_join1 where c1=(select avg(c1) from gb18030_2022_datatype_join1));
select distinct c6 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c6=(select c6 from gb18030_2022_datatype_join1 where c1=(select max(c1) from gb18030_2022_datatype_join1));
select distinct c6 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c6=(select c6 from gb18030_2022_datatype_join1 where c1=(select min(c1) from gb18030_2022_datatype_join1));
select distinct c6 from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) where c6=(select c6 from gb18030_2022_datatype_join1 where c1=(select avg(c1) from gb18030_2022_datatype_join1));
select count(*) from (select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) a,(select a.c1,a.c2,b.c5,b.c6 from gb18030_2022_datatype_join1 a,gb18030_2022_datatype_join3 b where a.c3=b.c4) b;
select c2||c5||c6,length(concat(c2||c5,c6)) from gb18030_2022_datatype_join1;
 
select * from gb18030_2022_datatype_join1;
select * from gb18030_2022_datatype_join2;
select * from gb18030_2022_datatype_join3;
 
--disable_warnings
drop table if exists gb18030_2022_datatype_join1;
drop table if exists gb18030_2022_datatype_join2;
drop table if exists gb18030_2022_datatype_join3;
drop procedure if exists test_procedure;
drop procedure if exists test_procedure2;
--enable_warnings

 
select CONV("a",16,2);
select CONV("6E",18,8);
select CONV(-17,10,-18);
select CONV(10+"10"+'10'+0xa,10,10);
select CONV("好的",16,2);
 
select BIN(12);
select OCT(12);
select HEX(255);
 
select CONCAT('My', 'S', 'QL');
select CONCAT('My', NULL, 'QL');
select CONCAT(14.3);
 
SELECT ISNULL(NULL);
SELECT LAST_INSERT_ID();
SELECT NULLIF(25, 25);
 
select LOCATE('bar', 'foobarbar',5);
select INSTR('foobarbar', 'bar');
select INSTR('xbar', 'foobar');
 
select LPAD('hi',4,'??');
select RPAD('hi',5,'?');
 
select LEFT('foobarbar', 5);
select RIGHT('foobarbar', 4);
 
select SUBSTRING('Quadratically',5,6);
select SUBSTRING('Quadratically',5);
select SUBSTRING('foobarbar' FROM 4);

select unhex('C6D8C1') from dual;
SELECT unhex('d3cebfcd') from dual;

SELECT hex(CONVERT( '游客' USING gb18030_2022 ));
SELECT CONVERT( unhex('d3cebfcd') USING gb18030_2022);

