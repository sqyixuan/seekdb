--error 0,1396
drop user ljh@'%';
--enable_warnings
create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh,ljh,test,$OBMYSQL_PORT);

set names 'gb18030_2022';
set character_set_database = 'gb18030_2022';
set character_set_server = 'gb18030_2022';

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;


--echo ##通配符/别名
create table mail
(
t decimal(6,2),
srcuser varchar(8) character set gb18030_2022,
srchost varchar(20) character set gb18030_2022,
dstuser varchar(8) character set gb18030_2022,
dsthost varchar(20) character set gb18030_2022,
size BIGINT,
index(t)
)DEFAULT CHARACTER SET = gb18030_2022;
 
insert into mail values(1,'中文测试1','中文测试2','中文测试3','中文测试4',100);
insert into mail values(2,'中文测试5','中文测试6','中文测试7','中文测试8',100);

select * from mail t;
select t.srcuser as '中文测试ing' from mail t;
select t.srcuser as 中文测试ing from mail t;
select t.srcuser as a from mail t;

--echo ##with as
with 
cr as 
( 
select t.srcuser as 中文测试ing from mail t
)
select * from cr;

select '33','!',ascii('!') from dual union all
select '34','"',ascii('"') from dual;

--echo ##where过滤
select t.srcuser as 中文测试ing from mail t where t.srcuser ='中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser !='中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser <>'中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser <'中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser >='中文测试1';

select t.srcuser as 中文测试ing from mail t where t.srcuser in ('中文测试1');
select t.srcuser as 中文测试ing from mail t where t.srcuser not in ('中文测试1');
select t.srcuser as 中文测试ing from mail t where t.srcuser >='中文测试1' and t.srcuser <='中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser >='中文测试1' or t.srcuser <='中文测试1';
select t.srcuser as 中文测试ing from mail t where t.srcuser like'中文测试%';
select t.srcuser as 中文测试ing from mail t where t.srcuser like'中文测试 %';
select t.srcuser as 中文测试ing from mail t where t.srcuser like'%';

