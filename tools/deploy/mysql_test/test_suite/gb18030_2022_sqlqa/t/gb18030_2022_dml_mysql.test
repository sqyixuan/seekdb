select * from cast_test_table;
select cast(c1 as char(2)) as empno from cast_test_table;
select cast(c1 as char(3)) as empno from cast_test_table;
 
select * from cast_test_table1;
SELECT c.c1,c.c2,b.c1,b.c3 FROM (SELECT c.*,ROW_NUMBER() OVER(ORDER BY c2 DESC) rn FROM cast_test_table c) c ,(SELECT b.c1,b.c3,ROW_NUMBER() OVER(ORDER BY b.c1) rn FROM cast_test_table1 b ) b WHERE c.rn=b.rn;
SELECT CAST('123.447654' AS decimal(5,2)) as result from dual;
SELECT CAST('123.4' AS decimal) as result from dual;

select length(concat('看v有-','么看完')||'23') from dual;
select lower('AaBbCcDd枯竭'),upper('AaBbCcDd枯竭'),length(lower('AaBbCcDd枯竭')) from dual;
select upper('哈哈') upper from dual;
select lower('哈哈') upper from dual;
select lpad(rpad('gao偶然客户',10,'*'),17,'*'),length(lpad(rpad('gao',10,'*'),17,'*')) from dual;
select replace('看i给客人 是 二万人','看i给客人','g.pnhl【哦哦') from dual;
select trim('蛤' from '蛤蟆蛤么蛤嘛') from dual;
select substr('零五七九二哦i觉得萨芬离开你的萨拉九分',3,8),length(substr('零五七九二哦i觉得萨芬离开你的萨拉九分',3,8)) from dual;
select abs(100),abs(-100) from dual;
select floor(3.1415927),floor(-3.1415927) from dual;
select ceil(3.1415927),ceil(-3.1415927) from dual;
SELECT ROUND (55.655, 2), ROUND (55.654, 2), ROUND (45.654, -1), ROUND (45.654, -2), ROUND (55.654, -2) FROM   DUAL;
select ifnull('撒赖打开附件里的萨克','啊撒旦范德萨分') from dual;
select ifnull('','啊撒旦范德萨分') from dual;

