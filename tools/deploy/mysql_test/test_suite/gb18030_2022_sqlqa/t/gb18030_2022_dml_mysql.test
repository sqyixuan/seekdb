--echo ##分区表

--disable_warnings
drop table if exists t01;
--enable_warnings

CREATE TABLE t01 (c1 int , c2 varchar(10) character set gb18030_2022)DEFAULT CHARACTER SET = gb18030_2022 
PARTITION BY RANGE(c1)
SUBPARTITION BY HASH(c1)
SUBPARTITIONS 2 (
    PARTITION p0 VALUES LESS THAN (1990),
    PARTITION p1 VALUES LESS THAN (2000),
    PARTITION p2 VALUES LESS THAN MAXVALUE
);

--disable_query_log
 insert into t01 values (1,'分区1');
--enable_query_log

select c2, hex(c2) from t01;
drop table if exists t01;

