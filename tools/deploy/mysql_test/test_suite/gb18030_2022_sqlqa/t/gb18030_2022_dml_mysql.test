--echo ##聚合函数
select sum(t.srcuser) as 中文测试ing from mail t where t.srcuser ='中文测试1';
select count(t.srcuser) as 中文测试ing from mail t where t.srcuser ='中文测试1';
select max(t.srcuser) as 中文测试ing from mail t where t.srcuser ='中文测试1';
select min(t.srcuser) as 中文测试ing from mail t where t.srcuser ='中文测试1';
select avg(t.srcuser) as 中文测试ing from mail t where t.srcuser ='中文测试1';

