table-1  新建表判断是否存在 MySQL支持
CREATE TABLE IF NOT EXISTS my_table1(num INT,name varchar(200),money char(20));
SELECT COUNT(*) from my_table1;
COUNT(*)
6
INDEX-1 
create index my_ind on my_table1(money);
SELECT * FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND name = 'Ross';
num	name	money
4	Ross	NULL
SELECT * FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 1000) AND name = 'Ross';
num	name	money
