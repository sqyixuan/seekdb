DROP TABLE my_table1;
DROP TABLE my_table2;
DROP TABLE my_table3;
DROP TABLE my_table;
DROP TABLE my_table11;
DROP FUNCTION my_func;
DROP PROCEDURE my_pro;
DROP VIEW my_vi ;
CREATE TABLE my_table1(num INT,name varchar(200),money char(20));
INSERT INTO my_table1 VALUES(1,'Bing',-100);
INSERT INTO my_table1 VALUES(2,'Bob',+10);
INSERT INTO my_table1 VALUES(3,'Reachl',-0.23566000);
INSERT INTO my_table1 VALUES(4,'Ross',NULL);
INSERT INTO my_table1 VALUES(5,'friends','');
INSERT INTO my_table1 VALUES(6,'@#￥！%……&*~',0);
CREATE TABLE my_table2(num INT,food char(20),price varchar(200));
INSERT INTO my_table2 VALUES(1,'面包',-5.12315);
INSERT INTO my_table2 VALUES(2,'牛奶','');
INSERT INTO my_table2 VALUES(3,'奶牛奶',-1200);
INSERT INTO my_table2 VALUES(4,'奶奶牛',NULL);
DML-select-1 join
select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1) 
AND t1.name = 'Ross';
name
Ross
select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
name
select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE NOT EXISTS (SELECT 1 FROM my_table1) 
AND t1.name = 'Ross';
name
select t1.name from my_table1 t1 
RIGHT join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1)
AND t1.name = 'Ross';
name
Ross
select t1.name from my_table1 t1 
RIGHT join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
name
select t1.name from my_table1 t1 
INNER join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1)
AND t1.name = 'Ross';
name
Ross
select t1.name from my_table1 t1 
INNER join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
name
DML-select-2  create as 
CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE EXISTS (SELECT 1 FROM my_table1);
SELECT * FROM my_table3 where name = 'Bing';
name	money
Bing	-100
DROP TABLE my_table3;
CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
SELECT * FROM my_table3 where name = 'Bing';
name	money
DROP TABLE my_table3;
CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE NOT EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
SELECT * FROM my_table3 where name = 'Bing';
name	money
Bing	-100
DROP TABLE my_table3;
