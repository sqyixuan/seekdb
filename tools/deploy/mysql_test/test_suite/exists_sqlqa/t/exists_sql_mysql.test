CREATE TABLE my_table1(num INT,name varchar(200),money char(20));
INSERT INTO my_table1 VALUES(1,'Bing',-100);
INSERT INTO my_table1 VALUES(2,'Bob',+10);
INSERT INTO my_table1 VALUES(3,'Reachl',-0.23566000);
INSERT INTO my_table1 VALUES(4,'Ross',NULL);
INSERT INTO my_table1 VALUES(5,'friends','');
INSERT INTO my_table1 VALUES(6,'@#￥！%……&*~',0);

CREATE TABLE my_table2(num INT,food char(20),price varchar(200));
INSERT INTO my_table2 VALUES(1,'面包',-5.12315);
INSERT INTO my_table2 VALUES(2,'牛奶','');
INSERT INTO my_table2 VALUES(3,'奶牛奶',-1200);
INSERT INTO my_table2 VALUES(4,'奶奶牛',NULL);


--echo DML-select-1 join
select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1) 
AND t1.name = 'Ross';

select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);

select t1.name from my_table1 t1 
left join my_table2 t2 
ON t1.num = t2.num 
WHERE NOT EXISTS (SELECT 1 FROM my_table1) 
AND t1.name = 'Ross';

select t1.name from my_table1 t1 
RIGHT join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1)
AND t1.name = 'Ross';

select t1.name from my_table1 t1 
RIGHT join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);

select t1.name from my_table1 t1 
INNER join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT 1 FROM my_table1)
AND t1.name = 'Ross';

select t1.name from my_table1 t1 
INNER join my_table2 t2 
ON t1.num = t2.num 
WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);

--echo DML-select-2  create as 
CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE EXISTS (SELECT 1 FROM my_table1);

SELECT * FROM my_table3 where name = 'Bing';
DROP TABLE my_table3;
CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
SELECT * FROM my_table3 where name = 'Bing';
DROP TABLE my_table3;

CREATE TABLE my_table3 AS SELECT name,money FROM my_table1 WHERE NOT EXISTS (SELECT * FROM my_table1 WHERE money = 10000);
SELECT * FROM my_table3 where name = 'Bing';
DROP TABLE my_table3;

--echo DML-select-4 distinct、cast、dual
SELECT 1 FROM dual WHERE EXISTS (SELECT DISTINCT money FROM my_table1);
SELECT name FROM my_table1 WHERE EXISTS (SELECT DISTINCT money FROM my_table1 WHERE money IS NULL);

SELECT 1 FROM dual WHERE EXISTS (SELECT DISTINCT money FROM my_table1 WHERE money = 10000);
SELECT 1 FROM dual WHERE NOT EXISTS (SELECT DISTINCT money FROM my_table1 WHERE money = 10000);
SELECT 1 FROM dual WHERE NOT EXISTS (SELECT DISTINCT money FROM my_table1);

SELECT name FROM my_table1 WHERE EXISTS (SELECT CAST(money AS char(10)) FROM my_table1);
SELECT name FROM my_table1 WHERE EXISTS (SELECT CAST(money AS char(10)) FROM my_table1 WHERE name = '11');

--echo DML-select-4 多个EXISTS/NOT EXISTS
SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1 WHERE 
		EXISTS(SELECT money FROM my_table1));
SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1 WHERE 
		EXISTS(SELECT money FROM my_table1 WHERE 
			EXISTS (SELECT money FROM my_table1 WHERE 
			EXISTS (SELECT money FROM my_table1))));

SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1)
AND EXISTS (SELECT money FROM my_table1);

SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1)
OR  EXISTS (SELECT money FROM my_table1);

SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1 WHERE money = 1000000)
OR  EXISTS (SELECT money FROM my_table1 WHERE money = 1000000);

SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1 WHERE 
		EXISTS(SELECT money FROM my_table1 WHERE 
			EXISTS (SELECT money FROM my_table1 WHERE money = 1000000)));
SELECT name FROM my_table1 WHERE 
EXISTS (SELECT money FROM my_table1 WHERE 
		EXISTS(SELECT money FROM my_table1 WHERE 
			NOT EXISTS (SELECT money FROM my_table1 WHERE money = 1000000)));
		
--echo DML-select-5 group by  having 子句
SELECT t1.money FROM my_table1 t1 
GROUP BY t1.money
HAVING EXISTS(SELECT money FROM my_table1);

SELECT t1.money FROM my_table1 t1 
GROUP BY t1.money
HAVING EXISTS(SELECT money FROM my_table1 WHERE money = 10000);

SELECT *
FROM my_table1
WHERE EXISTS (SELECT NULL)
ORDER BY money ASC;

SELECT *
FROM my_table1
WHERE not EXISTS (SELECT NULL)
ORDER BY money ASC;

--echo DML-select-6 case when
SELECT name FROM my_table1 WHERE 
EXISTS (SELECT CASE WHEN money>10 THEN 1 ELSE 0 END FROM my_table1);

--echo DML-select-6-1 mysql支持
SELECT IF(EXISTS(
             SELECT *
             FROM my_table1 t1
             WHERE t1.name = 'Bing'), 1, 0);
SELECT EXISTS(
         SELECT *
          FROM my_table1 t1
             WHERE t1.name = 'Bing');

--echo DML-select-7-0 null
SELECT name FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money IS NULL);
SELECT name FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 100000);

