--echo   DML-update-1
--error 1093
--echo 已知问题
UPDATE my_table1 SET name = 'Joey' WHERE EXISTS (SELECT * FROM my_table1) AND name = 'Bob';
SELECT COUNT(*) FROM my_table1;

UPDATE my_table1 SET name = 'Joey' WHERE EXISTS (SELECT * FROM my_table2) AND name = 'Bob';
SELECT * FROM my_table1 where name = 'Joey';

UPDATE my_table1 SET name = (SELECT food FROM my_table2 WHERE EXISTS (SELECT * FROM my_table2) AND num = 2) 
WHERE EXISTS (SELECT * FROM my_table2) AND name = 'Ross';
SELECT * FROM my_table1 where name = '牛奶';

--echo   DML-delete-1
DELETE FROM my_table1 WHERE EXISTS (SELECT * FROM my_table2) AND num = 1;
SELECT COUNT(*) FROM my_table1;

--echo   Constraints-1 not null 非空约束
--error 0, 1051
drop table my_table1 ;
create table my_table1(a char(10) not null);
insert into my_table1 values('-10');
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1);
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1 WHERE a = 100);

--echo   Constraints-2 unique 唯一性约束
--error 0, 1051
drop table my_table1;
create table my_table1(a char(10) unique);
insert into my_table1 values('-10');
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1);
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1 WHERE a = 100);

--echo   Constraints-3 primary key 主键约束 
--error 0, 1051
drop table my_table1;
create table my_table1(a char(10) not null primary key);
insert into my_table1 values('-10');
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1);
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1 WHERE a = 100);

--echo   Constraints-4 foreign key 外键约束 
--error 0, 1051
drop table my_table1;
CREATE TABLE my_table11(a1 char(10) not null primary key);
insert into my_table11 values('-10');
create table my_table1(a char(10) NOT NULL,FOREIGN KEY (a)  references my_table11(a1));
insert into my_table1 values('-10');
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1);
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1 WHERE a = 100);

--echo   Constraints-6 default 约束 
--error 0, 1051
drop table my_table1;
create table my_table1(a CHAR(10) default '-10',b char(10));
insert into my_table1(b) values('-50.23');
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1);
SELECT a FROM my_table1 WHERE EXISTS (SELECT a FROM my_table1 WHERE a = 100);
   

