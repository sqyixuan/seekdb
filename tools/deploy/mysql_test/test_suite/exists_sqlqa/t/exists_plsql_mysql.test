--disable_warnings
--error 0,1051
DROP TABLE my_table1;
--error 0,1051
DROP TABLE my_table2;
--error 0,1051
DROP TABLE my_table3;
--error 0,1051
DROP TABLE my_table;
--error 1305
DROP FUNCTION my_func;
--error 1305
DROP PROCEDURE my_pro;
--error 0,1051
DROP VIEW my_vi ;


CREATE TABLE my_table1(num INT,name varchar(200),money char(20));
INSERT INTO my_table1 VALUES(1,'Bing',-100);
INSERT INTO my_table1 VALUES(2,'Bob',+10);
INSERT INTO my_table1 VALUES(3,'Reachl',-0.23566000);
INSERT INTO my_table1 VALUES(4,'Ross',NULL);
INSERT INTO my_table1 VALUES(5,'friends','');
INSERT INTO my_table1 VALUES(6,'@#￥！%……&*~',0);

CREATE TABLE my_table2(num INT,food char(20),price varchar(200));
INSERT INTO my_table2 VALUES(1,'面包',-5.12315);
INSERT INTO my_table2 VALUES(2,'牛奶','');
INSERT INTO my_table2 VALUES(3,'奶牛奶',-1200);
INSERT INTO my_table2 VALUES(4,'奶奶牛',NULL);

--echo   table-1  新建表判断是否存在 MySQL支持
CREATE TABLE IF NOT EXISTS my_table1(num INT,name varchar(200),money char(20));
SELECT COUNT(*) from my_table1;

--echo   INDEX-1 
create index my_ind on my_table1(money);

SELECT * FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND name = 'Ross';
SELECT * FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 1000) AND name = 'Ross';
SELECT * FROM my_table1 WHERE NOT EXISTS (SELECT money FROM my_table1 WHERE money = 1000) AND name = 'Ross';
SELECT * FROM my_table1 WHERE NOT EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND name = 'Ross';

--echo   VIEW-1
delimiter //;
CREATE OR REPLACE VIEW  my_vi(num,money) 
AS
    SELECT num,CASE WHEN money IS NULL  THEN 0 ELSE  money END AS money
    FROM  my_table1 
    WHERE EXISTS (SELECT * FROM dual);
//
delimiter ;//

SELECT * FROM my_vi WHERE EXISTS (SELECT money FROM my_vi WHERE money = 10) AND money = -100;
SELECT * FROM my_vi WHERE EXISTS (SELECT money FROM my_vi WHERE money = 1000) AND money = -100;
SELECT * FROM my_vi WHERE NOT EXISTS (SELECT money FROM my_vi WHERE money = 10) AND money = -100;
SELECT * FROM my_vi WHERE NOT EXISTS (SELECT money FROM my_vi WHERE money = 1000) AND money = -100;

--echo   procedure-1
--echo 无参数的存储过程
delimiter //;
--error 0,1305
drop procedure my_pro;//
CREATE PROCEDURE my_pro()
BEGIN
	declare a varchar(200);
	SELECT  money FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND money = 10 into a;
    INSERT INTO my_table1 VALUES(a,'Joey',-0.12);
END;
//
delimiter ;//

CALL my_pro();
SELECT * FROM my_table1 WHERE name = 'Joey';

--echo procedure-2
--echo in out 的存储过程
delimiter //;
drop procedure my_pro;//
CREATE  PROCEDURE my_pro( inout proc varchar(200))
BEGIN
    SELECT  name  FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 11) AND money = 10 INTO proc;
    INSERT INTO my_table1 VALUES(10,'Monica',-0.1);
END ;
//

delimiter ;//
set @proc =18;
call my_pro(@proc);

SELECT * FROM my_table1 WHERE name = 'Monica';

--echo procedure-3
--echo drop procedure if exists MySQL支持

drop procedure if EXISTS my_pro;


--echo FUNCTION-1
--echo 定义一个无参的函数
delimiter //;
--error 1305
drop FUNCTION my_func;//
CREATE  FUNCTION my_func()
RETURNS varchar(200)
BEGIN
	DECLARE a varchar(200);
	SELECT  money  FROM my_table1  WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND money = -100 INTO a;
RETURN(a);
END ;
//
delimiter ;//
SELECT  my_func();
SELECT  my_func()  FROM  dual where EXISTS(SELECT 1 from DUAL);
SELECT  my_func()  FROM  dual where not EXISTS(SELECT 1 from DUAL);


--echo FUNCTION-2
--echo 定义一个有参的函数
delimiter //;
drop FUNCTION my_func;//
CREATE FUNCTION my_func(func varchar(200))
RETURNS varchar(200)
BEGIN
	DECLARE a varchar(200);
	SELECT  money  FROM my_table1 WHERE EXISTS (SELECT money FROM my_table1 WHERE money = 10) AND money = func INTO a;
RETURN(a);
END;
//
delimiter ;//

SELECT  my_func(100)  FROM  dual;
SELECT  my_func(-100);
SELECT  my_func(-100)  FROM  dual where EXISTS(SELECT 1 from DUAL);
SELECT  my_func(-100)  FROM  dual where not EXISTS(SELECT 1 from DUAL);
