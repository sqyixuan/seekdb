select t2.*,map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c) from vtt1 t1  join vtt2 t2 on map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)=map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c);

