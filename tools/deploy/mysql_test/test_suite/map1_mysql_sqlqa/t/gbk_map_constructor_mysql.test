#union
select t2.*,map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c) from tt1 t1 inner join tt2 t2 on map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)=map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c) union select t2.*,map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c) from tt1 t1 inner join tt2 t2 on map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)=map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c);
select t2.*,map(t2.c,t1.v) from tt1 t1 left join tt2 t2 on  map(t2.c,t1.v)=map(t1.id1,[1,2]) MINUS select t2.*,map(t2.c,t1.v) from tt1 t1 left join tt2 t2 on  map(t2.c,t1.v)=map(t1.id1,[1,2]);
select t2.*,map(t2.c,t1.d) from tt1 t1 left join tt2 t2 on  map(t2.c,t1.v)!=map(t1.id1,t2.a) UNION ALL select t2.*,map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c) from vtt1 t1  join vtt2 t2 on map(1,1)=map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c);
select t2.*,map(t2.c,t1.a) from tt1 t1 right join tt2 t2 on  map(t2.c,t1.a)=map(1,[1,2]) INTERSECT select t2.*,map(t2.c,t1.a) from tt1 t1 right join tt2 t2 on  map(t2.c,t1.a)=map(1,[1,2]);

