--error 5083
select map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d,c,v) from tt1;

select v, map(c,v,id1,v) from tt1;
select v, map(c,a,id1,a) from tt1;

select v, map(id1,v) from tt1;
select a, map(id1,a) from tt1;
select  map(id1,id1), map(id2,id2),map(id3,id3),map(id4,id4),map(id5,id5),map(id6,id6),map(id7,id7),map(id8,id8),map(id9,id9),map(f,f),map(d,d),map(d,a) ,map(d,v)  from tt1;
select  map(id1,id1), map(id2,id2),map(id3,id3),map(id4,id4),map(id5,id5),map(id6,id6),map(id7,id7),map(id8,id8),map(id9,id9),map(f,f),map(d,d),map(d,a) ,map(d,v)  from tt2;
select  map(id1,id1), map(id2,id2),map(id3,id3),map(id4,id4),map(id5,id5),map(id6,id6),map(id7,id7),map(id8,id8),map(id9,id9),map(f,f),map(d,d),map(d,a) ,map(d,v)  from vtt1;
select  map(id1,id1), map(id2,id2),map(id3,id3),map(id4,id4),map(id5,id5),map(id6,id6),map(id7,id7),map(id8,id8),map(id9,id9),map(f,f),map(d,d),map(d,a) ,map(d,v)  from vtt2;


select map_keys(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f)) from tt1;
select map_keys(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d)) from tt1;
select map_keys(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d)) from tt1;
select map_keys(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d,c,c)) from tt1;
select map_keys(map(c,v,id1,v)) from tt1;
select map_keys(map(c,a,id1,a)) from tt1;

select map_values(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f)) from tt1;
select map_values(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d)) from tt1;
select map_values(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d)) from tt1;
select map_values(map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d,c,c)) from tt1;
select map_values(map(c,v,id1,v)) from tt1;
select map_values(map(c,a,id1,a)) from tt1;

select  map_keys(map(id1,id1)), map_keys(map(id2,id2)),map_keys(map(id3,id3)),map_keys(map(id4,id4)),map_keys(map(id5,id5)),map_keys(map(id6,id6)),map_keys(map(id7,id7)),map_keys(map(id8,id8)),
map_keys(map(id9,id9)),map_keys(map(f,f)),map_keys(map(d,d)),map_keys(map(d,a)) ,map_keys(map(d,v))  from tt1;
select  map_keys(map(id1,id1)), map_keys(map(id2,id2)),map_keys(map(id3,id3)),map_keys(map(id4,id4)),
map_keys(map(id5,id5)),map_keys(map(id6,id6)),map_keys(map(id7,id7)),map_keys(map(id8,id8)),map_keys(map(id9,id9)),map_keys(map(f,f)),map_keys(map(d,d)),map_keys(map(d,a)) ,map_keys(map(d,v))  from vtt2;

select  map_values(map(id1,id1)), map_values(map(id2,id2)),map_values(map(id3,id3)),map_values(map(id4,id4)),map_values(map(id5,id5)),map_values(map(id6,id6)),map_values(map(id7,id7)),map_values(map(id8,id8)),
map_values(map(id9,id9)),map_values(map(f,f)),map_values(map(d,d)),map_values(map(d,a)) ,map_values(map(d,v))  from vtt1;
select  map_values(map(id1,id1)), map_values(map(id2,id2)),map_values(map(id3,id3)),map_values(map(id4,id4)),
map_values(map(id5,id5)),map_values(map(id6,id6)),map_values(map(id7,id7)),map_values(map(id8,id8)),map_values(map(id9,id9)),map_values(map(f,f)),map_values(map(d,d)),map_values(map(d,a)) ,map_values(map(d,v))  from tt2;


select map(tt1.id1,tt2.id2,tt1.id3,tt1.id4,tt2.id5,tt2.id6,tt2.id7,tt1.id8) from tt1,tt2;
select map(tt1.id1,tt2.id2,tt1.id3,tt1.id4,tt2.id5,tt2.id6,tt2.id7,tt1.id8,tt2.f,tt1.d,tt1.d,tt2.f) from tt1,tt2;
select map(tt1.id1,tt2.id2,tt1.id3,tt1.id4,tt2.id5,tt2.id6,tt2.id7,tt1.id8,tt2.f,tt1.d,tt1.d,tt2.f,tt1.c,tt2.c) from tt1,tt2;

select *, map_keys(map(tt1.id1,tt2.id2,tt1.id3,tt1.id4,tt2.id5,tt2.id6,tt2.id7,tt1.id8,tt2.f,tt1.d,tt1.d,tt2.f,tt1.c,tt2.c)) from tt1,tt2;
select *, map_values(map(tt1.id1,tt2.id2,tt1.id3,tt1.id4,tt2.id5,tt2.id6,tt2.id7,tt1.id8,tt2.f,tt1.d,tt1.d,tt2.f,tt1.c,tt2.c)) from tt1,tt2;

select map(vtt1.id1,vtt2.a,vtt2.c,vtt1.a) from vtt1,vtt2;
select map(vtt1.id1,vtt2.v,vtt2.c,vtt1.v) from vtt1,vtt2;

select map_keys(map(vtt1.id1,vtt2.a,vtt2.c,vtt1.a)) from vtt1,vtt2;
select map_values(map(tt1.id1,tt2.v,tt2.c,tt1.v)) from tt1,tt2;


