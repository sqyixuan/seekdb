#owner group: 多模组
#description:map构造函数 
#tags:array
#author: wb-lrp01026356
purge recyclebin;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp character set gbk;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
--sorted_result
--result_format 4
set names gbk;
drop table if EXISTS tt1;
create table tt1(id1 int primary key,id2 bool,id3 boolean,id4 TINYINT ,id5  smallint ,id6 int,id7 INTEGER,id8 BIGINT,id9 SERIAL,f float,d double,c varchar(100),a array(int),v vector(2),m map(int,varchar(10))) character set gbk;
insert into tt1 values(1,127,127,127,32767,2147483647,2147483647,9223372036854775807,18446744073709551615,3.402823466E+38,1.7976931348623157E+308,'test1',[1,2],[1,2],map(1,'test'));
insert into tt1 values(2,-128,-128,-128,-32768,-2147483648,-2147483648,-9223372036854775808,18446744073709551614,-3.402823466E+38,-1.7976931348623157E+308,'test2',[1,2],[1,2],map(1,'test'));
insert into tt1 values(3,1,2,3,4,5,6,7,8,-1.175494351E-38,-2.2250738585072014E-308,'test3',[-1,-2],[1,2],map(1,'test'));
insert into tt1 values(4,0,0,0,0,0,0,0,9,1.175494351E-38,2.2250738585072014E-308,'test4',[-1,-2],[1,2],map(1,'test'));
insert into tt1 values(5,null,null,null,null,null,null,null,10,null,null,'test4','[]',null,map(1,'test'));
drop view if EXISTS vtt1;
create view vtt1 as select * from tt1;


drop table if EXISTS tt2;
create table tt2(id1 int ,id2 bool,id3 boolean,id4 TINYINT UNSIGNED ,id5  smallint UNSIGNED ,id6 int UNSIGNED,id7 INTEGER UNSIGNED,id8 BIGINT UNSIGNED,id9 SERIAL,f float UNSIGNED,d double UNSIGNED,c varchar(100),a array(int UNSIGNED),v vector(2),m map(int,varchar(10))) character set gbk
PARTITION BY range COLUMNS(id9)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,127,127,255,65535,4294967295,4294967294,18446744073709551615,1,3.402823466E+38,1.7976931348623157E+308,'test1',[1,2],[1,2],map(1,'test'));
insert into tt2 values(22,0,0,0,0,0,0,0,28,1.175494351E-38,2.2250738585072014E-308,'test4',[1,2],[1,2],map(1,'test'));
insert into tt2 values(31,null,null,null,null,null,null,null,29,null,null,'test4','[]',null,map(1,'test'));
insert into tt2 values(20,0,0,0,0,0,0,0,5,111E-1,4.5E+1,'test4',[1,2],[1,2],map(1,'test'));
drop view if EXISTS vtt2;
create view vtt2 as select * from tt2;

select map(id1,id2,id3,id4,id5,id6,id7,id8) from tt1;
select map(id2,id3,id4,id5,id6,id7,id8,id9) from tt1;
select *,map(id1,id2,id3,id4,id5,id6,id7,id8) from tt1;
select *,map(id1,id2,id3,id4,id5,id6,id7,id8) a from tt1;

select map(id1,id2,id3,id4,id5,id6,id7,id8) from tt2;
select map(id2,id3,id4,id5,id6,id7,id8,id9) from tt2;
select *,map(id1,id2,id3,id4,id5,id6,id7,id8) from tt2;
select *,map(id1,id2,id3,id4,id5,id6,id7,id8) a from tt2;

select map_keys(m),map_values(m) from tt2;
select map_keys(m),map_values(m) from vtt2;
select map_keys(m), /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */map_values(m) from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ map_keys(m),map_values(m) from vtt1;

select map_keys(map(id1,id2,id3,id4,id5,id6,id7,id8)) from tt1;
select map_values(map(id1,id2,id3,id4,id5,id6,id7,id8)) from tt1;

select map(id1,id2,id3,id4,id5,id6,id7,id8,f,f) from tt1;
select map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d) from tt1;
select map(id1,id2,id3,id4,id5,id6,id7,id8,f,f,d,d) from tt1;
