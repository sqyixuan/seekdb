DROP MATERIALIZED VIEW LOG ON tt4;
drop table if EXISTS tt4;
create table tt4(id int primary key,m1 map(int,int),m2 map(bigint unsigned,varchar(100)),m3 map(varchar(100),array(varchar(100))),m4 map(double ,float unsigned),
m5 map(bigint,array(array(int unsigned))),m6 map(bigint,vector(2)));
insert into tt4 select id1, map(id1,id6) m1,map(id9,c) m2,map(c,[c]) m3,map(d,f) m4,map(id8,[a]) m5,map(id8,v) m6 from tt3;
CREATE MATERIALIZED VIEW LOG ON tt4 WITH PRIMARY KEY, ROWID,SEQUENCE(m1,m2,m3,m4,m5,m6) INCLUDING NEW VALUES;

DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as i ,t2.id as i1 ,map(t1.id,t2.id) m0,t1.m1,t2.m2,t2.m3,t1.m6 from tt4 t1 inner join tt4 t2 on map(t1.id,t1.id)=map(t2.id,t2.id);
