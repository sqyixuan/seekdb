select * from mv1;
--sorted_result
select map_keys(m0) m0,map_keys(m1) m1,map_keys(m2) m2,map_keys(m3) m3,map_keys(m6) m6 from mv1;
--sorted_result
select map_values(m0) m0,map_values(m1) m1,map_values(m2) m2,map_values(m3) m3,map_values(m6) m6 from mv1;
--sorted_result
select /*+enable_parallel_dml parallel(2) */ map_values(m1) m1,map_values(m2) m2,map_values(m3) m3,map_values(m6) m6 from mv1;
