drop table if EXISTS tt2;
create table tt2(id int,m1 map(tinyint unsigned,  tinyint unsigned),m2 map(boolean ,boolean ),m3 map(bool ,bool),m4 map(int unsigned ,int unsigned),
m5 map(INTEGER unsigned,INTEGER unsigned),m6 map(SMALLINT unsigned,SMALLINT unsigned),m7 map(BIGINT unsigned,BIGINT unsigned),m8 map(varchar(50),varchar(50)),
m9 map(double unsigned,array(array(double unsigned))),m10 map(float unsigned,float unsigned),m11 map(double unsigned,double unsigned) ,m12 map(float unsigned,vector(2))) character set gbk
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
drop view if EXISTS vtt2;
create view vtt2 as select * from tt2;
insert into tt2 values(1,map(1,1,4,5),map(0,1,1,0,1,1),map(0,1,1,0,1,1),map(2147483647,2147483647,1,0,2147483647,2147483647),
