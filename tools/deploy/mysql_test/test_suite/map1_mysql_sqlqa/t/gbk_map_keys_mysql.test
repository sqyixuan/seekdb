MAP(3.402823466E+38,1.175494351E-38,1.175494351E-38,3.402823466E+38,0,0,1.2,1.2),map(1.7976931348623157E+308, 2.2250738585072014E-308,0,0,2.2250738585072014E-308,1.7976931348623157E+308,1.3,18.78),
