select map_keys(tt1.m1),map_keys(tt2.m2),map_values(tt1.m9),map_values(tt2.m12) from tt1,tt2;
--sorted_result
select /*+enable_parallel_dml parallel(2) */ map_keys(m1)  from tt1;
#select /*+read_consistency(weak) */ map_keys(m1)  from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */map_keys(m8)  from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ map_keys(m9)  from tt1;
--sorted_result
select /*+enable_parallel_dml parallel(2) */ map_keys(m1)  from tt2;
#select /*+read_consistency(weak) */ map_keys(m1)  from tt2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */map_keys(m8)  from tt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ map_keys(m9)  from tt2;
#map_keys 返回整数
select map_keys(map(1,2));
select map_keys(map(18446744073709551615,2,1,2));
select map_keys(map(true,true,false,false,null,null));
select map_keys(map(-9223372036854775808,-9223372036854775808,-9223372036854775808,-9223372036854775808));
select map_keys(map(-9223372036854775808,-9223372036854775808,9223372036854775807,9223372036854775807));
select map_keys(map(-9223372036854775808,0,0,-1,-2,2,9223372036854775807,1));
select map_keys(map(id,id)) from tt1;
select map_values(map(id,id)) from tt1;
select map_values(map(1,[array_range(0)],2,[['test']],3,[[3,145E-2]]));
select map_keys(map(9223372036854775808,9223372036854775808,9223372036854775808,1,-1,'test','-1','test2'));

#返回浮点元素
select map_keys(map(1.2,1.2));
select map_keys(map(-3.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38));
select map_keys(map(-4.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38));

select map_keys(map(-4.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38));

select map_keys(map(-4.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38,1.2,1,-1.2834,'test',-1.2834,'test1'));
select map_values(map(-4.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38,1.2,1,-1.2834,'test',-1.2834,'test1'));

select map_keys(map(1.175494351E-38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38,0,1));
select map_values(map(1.175494351E-38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38,0,1));
select map_keys(map(-4.402823466E+38, -1.175494351E-38,0,0,1.175494351E-38,3.402823466E+38));

#返回字符元素
select map_keys(map('test','test1','test','test2','Test','TEST4'));
select map_keys(map("test","test1","test","test2","Test","TEST4"));
select map_values(map("test1","test2","test2","test2","Test","TEST4"));
select map_keys(map(NULL,"test1",FALSE,"test2",TRUE,"TEST4",'TEST','TEST'));
select map_keys(map(NULL,"test1",FALSE,"test2",false,"TEST4",null,'TEST'));
select map_keys(map(NULL,"test1",FALSE,"test2",TRUE,"TEST4",154e-2,154e-2));
select map_values(map(NULL,NULL,FALSE,false,TRUE,true,154e-2,'esteestt'));
select map_values(map(NULL,NULL,FALSE,false,TRUE,true,154e-2,'esteestt',2,true));
select map(true, 1,1 ,0,FALSE,3,0,4);

#数组
--error 1235
select map_keys(map([1],1,[1],2));

select map_values(map(1,[1],2,['test',null]));
select map_values(map(1,[[null,[[1],[12424E+5]]]],2,[[null,[[1],[12424E-5]]]]));
select map_values(map(1,[[null,[[1],[12424E+5],['teste']]]],2,[[null,[[1],[12424E-5]]]]));

select map_values(map(1,[null,[[null,[[1],[12424E+5],['teste']]]]],2,[[[null,[[1],[12424E-5]]]]]));
--error 1235
select map_values(map(1,[[null,[[null,[[1],[12424E+5],['teste']]]]]],2,[[[[null,[[1],[12424E-5]]]]]]));
#向量
select map_keys(m12) from tt1;
select map_values(m12) from tt1;
#输出10000个key
drop table if EXISTS tt3;
create table tt3(m1 map(int,int),m2 map(varchar(20),varchar(20)));
insert into tt3 values((select concat('{',result,'}') from (select GROUP_CONCAT(number SEPARATOR ',') AS result
FROM (
     SELECT concat(FLOOR(1 + RAND() * 10000),':', FLOOR(1 + RAND() * 10000)) AS number
    FROM TABLE(GENERATOR(10000))
) AS random_numbers)),(select concat('{',result,'}') from (select GROUP_CONCAT(number SEPARATOR ',') AS result
FROM (
     SELECT concat('"test',FLOOR(1 + RAND() * 10000),'"',':"test"') AS number
    FROM TABLE(GENERATOR(10000))
) AS random_numbers)));
--disable_result_log
select map_keys(m1),map_keys(m2) from tt3;
--enable_result_log
