#owner group: 多模组
#description:map_keys()语法和场景测试
#tags:array
#author: wb-lrp01026356
purge recyclebin;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp character set gbk;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
--sorted_result
--result_format 4
set names gbk;
drop table if EXISTS tt1;
create table tt1(id int primary key,m1 map(tinyint,  tinyint),m2 map(boolean ,boolean),m3 map(bool ,bool),m4 map(int ,int),
m5 map(INTEGER,INTEGER),m6 map(SMALLINT,SMALLINT),m7 map(BIGINT,BIGINT),m8 map(varchar(50),varchar(50)),
m9 map(double,array(array(double))),m10 map(float,float),m11 map(double,double) ,m12 map(float,vector(2))) character set gbk;
drop view if EXISTS vtt1;
create view vtt1 as select * from tt1;
