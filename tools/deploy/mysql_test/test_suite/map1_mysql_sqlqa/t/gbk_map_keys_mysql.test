#order by
--error 5083
select * from tt1 order by map_keys(map(id1,a));
--error 5083
select * from tt1 order by map_keys(map(id1,a)),map_keys(map(f,d)),map_keys(map(id2,c)) desc;
--error 5083
select * from tt1 order by map_keys(map(id1,a)),id2;
select * ,map_keys(map(id1,a)) from tt1 order by id1 limit 1;
select * ,map_keys(map(id1,a)) from tt1 order by id1 limit 2;


#group by 
--error 5083
select *,map_keys(map(id1,a)) from tt1 group by map_keys(map(id1,a)),map_keys(m);
select *,map_keys(map(id1,a)) from tt1 group by id2 having map_keys(map(id1,id2))=map_keys(m);
select *,map_keys(map(id1,a)) from tt1 group by id2 having map_keys(m)!=map_keys(map(id1,id2));
select *,map_keys(map(id1,a)) from tt1 group by id2 having map_keys(map(id1,id2))=map_keys(map(id1,id2));
select *,map_keys(m) from tt1  group by id2 having map_keys(map(id1,id2))<>map_keys(m) order by id1;

#distinct
--error 5083
select distinct map_keys(m) from tt2;

#limit
select *, map_keys(map(id1,a)) b from tt1 limit 1;
select *, map_keys(map(t1.id1,t1.a))  b from tt2 t1 inner join tt2 t2 on map_keys(map(t1.id1,t1.a))  =map_keys(map(t2.id1,t2.a) ) limit 2;


#with as
WITH Alice_Students AS (
 select map_keys(map(1,'test',2,'test1'))
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
 select map_keys(map(id1,id1,id2,id2)),map_keys(map(c,c,id3,id3)),map_keys(map(c,a,id3,a)),map_keys(m) from tt2
)
SELECT * FROM Alice_Students;

#case when
SELECT CASE map_keys(map(id1,id2)) WHEN  map_keys(map(id1,id2)) THEN   map_keys(map(id1,id2)) WHEN  map_keys(map(id1,c)) THEN  map_keys(map(id1,c)) END from tt1;
SELECT CASE when map_keys(map(id1,id2))!= map_keys(map(id1,id2)) THEN   map_keys(m) else   map_keys(map(id1,c)) END from tt1;

SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN   map_keys(map(1,1)) WHEN  map_keys(map(1,'test')) THEN  map_keys(map(1,'test')) END ;
SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN   map_keys(map(1,1))WHEN  map_keys(map(1,2)) THEN  map_keys(map(1,2)) END ;

SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN   map_keys(map(1,1)) WHEN  map_keys(map(1,2)) THEN  map_keys(map(1,2)) END ;


SELECT CASE 1 WHEN  1 THEN   map_keys(map(1,1)) WHEN  2 THEN  map_keys(map(1,2)) END ;
SELECT CASE 1 WHEN  2 THEN   map_keys(map(1,1)) WHEN  1 THEN  map_keys(map(1,2)) END ;
SELECT CASE 1 WHEN  2 THEN   map_keys(map(1,1)) WHEN  1 THEN  map_keys(map(1,2)) else map_keys(map(1,3)) END ;
SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN  1 WHEN  map_keys(map(1,2)) THEN  2 END ;

SELECT CASE WHEN map_keys(map(1,1))=map_keys(map(1,1))   THEN 1 ELSE 2 END;

SELECT CASE WHEN map_keys(map(1,1))=map_keys(map(1,1))   THEN map_keys(map(1,1)) ELSE map_keys(map(1,2)) END;


SELECT CASE WHEN map_keys(map(1,1))=map_keys(map(1,1))   THEN map_keys(map(1,1)) ELSE map_keys(map(1,2)) END;
SELECT CASE WHEN map_keys(map(1,1))!=map_keys(map(1,1))   THEN map_keys(map(1,1)) ELSE map_keys(map(1,2)) END;

SELECT CASE 1 WHEN  1 THEN   map_keys(map(1,1)) WHEN  2 THEN  map_keys(map(1,2)) END ;
SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN  1 WHEN  map_keys(map(1,2)) THEN  2 END ;
SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,1)) THEN   map_keys(map(1,1)) WHEN  map_keys(map(1,2)) THEN  map_keys(map(1,2)) END ;
SELECT CASE map_keys(map(1,1))  WHEN  map_keys(map(1,3)) THEN   map_keys(map(1,1)) WHEN  map_keys(map(1,2)) THEN  map_keys(map(1,2)) else  map_keys(map(1,3)) END ;

SELECT CASE 'test'  WHEN 'test' THEN   map_keys(map(1,1)) WHEN  'test1' THEN  map_keys(map(1,'test')) END ;
SELECT CASE 'test'  WHEN 'test' THEN   map_keys(map(1,[1])) WHEN  'test1' THEN  map_keys(map(1,'test')) END ;

SELECT CASE map_keys(map(1,1,2,3))  WHEN  map_keys(map(1,1,2,4)) THEN   map_keys(map(1,[1],2,[3])) WHEN  map_keys(map(1,'test',3,5)) THEN  map_keys(map(1,['test'])) else map_keys(map(1,[1],2,[3E+3])) END ;


#where
select * from tt1 where map_keys(map(id1,id1,id2,id2))=map_keys(map(id1,id1,id2,id2)) and map_keys(map(d,d))=map_keys(map(d,d)) or map_keys(map(c,c))=map_keys(map(c,c)) and map_keys(map(c,v))=map_keys(map(c,v));
select * from tt1 where map_keys(map(id1,id1,id2,id2))<>map_keys(map(id1,id1,id2,id2,c,f));
select * from tt1 where map_keys(map(id1,id1,id2,id2))!=map_keys(map(id1,id1,id2,id2,c,f));
select * from tt1 where map_keys(map(id1,id1,id2,id2))=map_keys(map(id1,id1,id2,id2,c,f));
select 1 from dual where map_keys(map(1,['test']))=map_keys(map(1,['test']));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2))<=map_keys(map(id1,id1,id2,id2));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) in (map_keys(map(id1,id1,id2,id2,c,c)),map_keys(map(id1,id1,id2,id2,c,c)));

select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) not in (map_keys(map(id1,id1,id2,id2,c,c)));
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) in (map_keys(map(id1,id1,id2,id2,c,c)));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) not in (map_keys(map(id1,id1,id2,id2,c,c)),map_keys(map(id1,id1,id2,id2,c,c)));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) BETWEEN map_keys(map(id1,id1,id2,id2,c,c)) AND map_keys(map(id1,id1,id2,id2,c,c));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) not  BETWEEN map_keys(map(id1,id1,id2,id2,c,c)) AND map_keys(map(id1,id1,id2,id2,c,c));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) like map_keys(map(id1,id1,id2,id2,c,c));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) not like map_keys(map(id1,id1,id2,id2,c,c));
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) is true;
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c))  is not true;
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c))  is false;
--error 5083
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c)) is not false;
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c))  is null;
select * from tt1 where map_keys(map(id1,id1,id2,id2,c,c))  is not null;

select * from tt1 where map_keys(map(1,2))  is null;
select * from tt1 where map_keys(map('test','test'))  is not null;
#join
select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from tt1 t1 inner join tt2 t2 on map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c));
select t2.*,map_keys(map(t2.c,t1.a)) from tt1 t1 right join tt2 t2 on  map_keys(map(t2.c,t1.a))=map_keys(map(1,[1,2]));
select t2.*,map_keys(map(t2.c,t1.v)) from tt1 t1 left join tt2 t2 on  map_keys(map(t2.c,t1.v))!=map_keys(map(t1.id1,t2.a));
select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from vtt1 t1  join vtt2 t2 on map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c));

select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from vtt1 t1  join vtt2 t2 on map_keys(map(1,1))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c));
#union
select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from tt1 t1 inner join tt2 t2 on map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) union select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from tt1 t1 inner join tt2 t2 on map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c));
select t2.*,map_keys(map(t2.c,t1.v)) from tt1 t1 left join tt2 t2 on  map_keys(map(t2.c,t1.v))=map_keys(map(t1.id1,[1,2])) MINUS select t2.*,map_keys(map(t2.c,t1.v)) from tt1 t1 left join tt2 t2 on  map_keys(map(t2.c,t1.v))=map_keys(map(t1.id1,[1,2]));
select t2.*,map_keys(map(t2.c,t1.d)) from tt1 t1 left join tt2 t2 on  map_keys(map(t2.c,t1.v))!=map_keys(map(t1.id1,t2.a)) UNION ALL select t2.*,map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c)) from vtt1 t1  join vtt2 t2 on map_keys(map(1,1))=map_keys(map(t1.id1,t2.f,t1.f,t2.d,t2.d,t1.c));
select t2.*,map_keys(map(t2.c,t1.a)) from tt1 t1 right join tt2 t2 on  map_keys(map(t2.c,t1.a))=map_keys(map(1,[1,2])) INTERSECT select t2.*,map_keys(map(t2.c,t1.a)) from tt1 t1 right join tt2 t2 on  map_keys(map(t2.c,t1.a))=map_keys(map(1,[1,2]));

#子查询
select map_keys(b) a from (select map(1,2) b);

select m, map_keys((select map(id1,id2,id3,id4,f,d,c,c) from tt1 where id1=1)) from tt2;
select *, map_keys((select map(id1,id2,id3,id4,f,d,c,c) from tt1 where id1=1)) from tt2;

SELECT map_keys(map(id1,id2,id3,id4,f,d,c,c)) FROM tt1 WHERE map_keys(map(id1,id2,id3,id4,f,d,c,c))= (SELECT map_keys(map(1,1,2,3)));

