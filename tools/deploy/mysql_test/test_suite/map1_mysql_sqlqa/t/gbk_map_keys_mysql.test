#sql
drop table if EXISTS tt1;
create table tt1(id1 int primary key,id2 bool,id3 boolean,id4 TINYINT ,id5  smallint ,id6 int,id7 INTEGER,id8 BIGINT,id9 SERIAL,f float,d double,c varchar(100),a array(int),v vector(2),m map(int,varchar(10)));
insert into tt1 values(1,127,127,127,32767,2147483647,2147483647,9223372036854775807,18446744073709551615,3.402823466E+38,1.7976931348623157E+308,'test1',[1,2],[1,2],map(1,'test'));
insert into tt1 values(2,-128,-128,-128,-32768,-2147483648,-2147483648,-9223372036854775808,18446744073709551614,-3.402823466E+38,-1.7976931348623157E+308,'test2',[1,2],[1,2],map(1,'test'));
insert into tt1 values(3,1,2,3,4,5,6,7,8,-1.175494351E-38,-2.2250738585072014E-308,'test3',[-1,-2],[1,2],map(1,'test'));
insert into tt1 values(4,0,0,0,0,0,0,0,9,1.175494351E-38,2.2250738585072014E-308,'test4',[-1,-2],[1,2],map(1,'test'));
insert into tt1 values(5,null,null,null,null,null,null,null,10,null,null,'test4','[]',null,map(1,'test'));
drop view if EXISTS vtt1;
create view vtt1 as select * from tt1;


drop table if EXISTS tt2;
create table tt2(id1 int ,id2 bool,id3 boolean,id4 TINYINT UNSIGNED ,id5  smallint UNSIGNED ,id6 int UNSIGNED,id7 INTEGER UNSIGNED,id8 BIGINT UNSIGNED,id9 SERIAL,f float UNSIGNED,d double UNSIGNED,c varchar(100),a array(int UNSIGNED),v vector(2),m map(int,varchar(10)))
PARTITION BY range COLUMNS(id9)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
