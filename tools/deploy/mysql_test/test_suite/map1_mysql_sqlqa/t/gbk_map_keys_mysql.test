ALTER TABLE tt4 ADD PRIMARY KEY (id1);
CREATE MATERIALIZED VIEW LOG ON tt4 WITH PRIMARY KEY, ROWID,SEQUENCE(m1,m2,m3,m4,m5,m6) INCLUDING NEW VALUES;
DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id1 as i ,t2.id1 as i1 ,map_keys(map(t1.id1,t2.id1)) m0,t1.m1,t2.m2,t2.m3,t1.m6 from tt4 t1 inner join tt4 t2 on map_keys(map(t1.id1,t1.id1))=map_keys(map(t2.id1,t2.id1));
desc mv1;
