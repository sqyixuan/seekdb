#insert/replace/ ON DUPLICATE KEY UPDATE/update/delete
drop table if exists tt3;
create table tt3(id int primary key,id1 bigint unsigned,a varchar(50)[],b bigint unsigned[]);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
