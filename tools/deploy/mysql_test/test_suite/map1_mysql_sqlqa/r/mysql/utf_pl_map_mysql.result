purge recyclebin;
drop database IF EXISTS oblrp;
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
result_format: 4
drop PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
select map(1,1);
select map('test','test','test','test1','test2','test2');
select map(1.2,1.2,5354E+2,543E-2);
select map(1.2,[1.2],5354E+2,[543E-2]);
end;
//
call p_test01();
+----------+
| map(1,1) |
+----------+
+---------------------------------------------------+
| map('test','test','test','test1','test2','test2') |
+---------------------------------------------------+
+-----------------------------+
| map(1.2,1.2,5354E+2,543E-2) |
+-----------------------------+
+---------------------------------+
| map(1.2,[1.2],5354E+2,[543E-2]) |
+---------------------------------+
| {1:1}    |
| {"test":"test1","test2":"test2"}                  |
| {1.2:1.2,535400:5.43}       |
| {1.2:[1.2],535400:[5.43]}       |
+----------+
+---------------------------------------------------+
+-----------------------------+
+---------------------------------+
drop PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
select map_keys(map(1,1));
select map_keys(map('test','test','test','test1','test2','test2'));
select map_keys(map(1.2,1.2,5354E+2,543E-2));
select map_keys(map(1.2,[1.2],5354E+2,[543E-2]));

select map_values(map(1,1));
select map_values(map('test','test','test','test1','test2','test2'));
select map_values(map(1.2,1.2,5354E+2,543E-2));
select map_values(map(1.2,[1.2],5354E+2,[543E-2]));
end;
//
call p_test01();
+--------------------+
| map_keys(map(1,1)) |
+--------------------+
+-------------------------------------------------------------+
| map_keys(map('test','test','test','test1','test2','test2')) |
+-------------------------------------------------------------+
+---------------------------------------+
| map_keys(map(1.2,1.2,5354E+2,543E-2)) |
+---------------------------------------+
+-------------------------------------------+
| map_keys(map(1.2,[1.2],5354E+2,[543E-2])) |
+-------------------------------------------+
+----------------------+
| map_values(map(1,1)) |
+----------------------+
+---------------------------------------------------------------+
| map_values(map('test','test','test','test1','test2','test2')) |
+---------------------------------------------------------------+
+-----------------------------------------+
| map_values(map(1.2,1.2,5354E+2,543E-2)) |
+-----------------------------------------+
+---------------------------------------------+
| map_values(map(1.2,[1.2],5354E+2,[543E-2])) |
+---------------------------------------------+
| [1]                |
| ["test","test2"]                                            |
| [1.2,535400]                          |
| [1.2,535400]                              |
| [1]                  |
| ["test1","test2"]                                             |
| [1.2,5.43]                              |
| [[1.2],[5.43]]                              |
+--------------------+
+-------------------------------------------------------------+
+---------------------------------------+
+-------------------------------------------+
+----------------------+
+---------------------------------------------------------------+
+-----------------------------------------+
+---------------------------------------------+
