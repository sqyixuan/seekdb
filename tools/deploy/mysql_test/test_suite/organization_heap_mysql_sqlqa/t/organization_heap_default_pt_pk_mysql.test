INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(20, 2.71, b'0', '2023-09-15 10:00:00', 'char2', 'varchar text 2', 'blob data 2', 'text data 2', '{"key2": "value2"}');

INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(30, 1.61, b'1', '2023-08-25 18:45:30', 'char3', 'varchar text 3', 'blob data 3', 'text data 3', '{"key3": "value3"}');

--echo 禁掉其他涉及到primary key的修改操作 预期报错
--echo 	主键约束操作 删除主键
--error 0,1235
ALTER TABLE heap_1 DROP PRIMARY KEY;
--error 3855
alter table heap_1 drop column id;

--echo 	修改列为主键
--error 1503,1235
ALTER TABLE heap_1 ADD PRIMARY KEY (int_column);

--echo 	修改主键列类型（非小改大）
--error 0,1235
ALTER TABLE heap_1 MODIFY id VARCHAR(255);

alter table heap_1 modify column id BIGINT NOT NULL;
--error 1235
alter table heap_1 modify column id INT NOT NULL;

--echo 	加主键列
--error 1235
ALTER TABLE heap_1 ADD PRIMARY KEY (id,int_column);

--echo 	修改主键为自增列
--error 0,1235
ALTER TABLE heap_1 MODIFY id INT AUTO_INCREMENT;
ALTER TABLE heap_1 AUTO_INCREMENT = 10;

--echo 修改主键列为null
--error 1235
ALTER TABLE heap_1 MODIFY id INT NULL;

--echo  DDL功能改造
--echo  DDL功能改造   online ddl  索引 增加索引
--echo 增加普通索引
CREATE INDEX index1 ON heap_1 (int_column ASC);

--echo 增加唯一索引
--error 1503
CREATE UNIQUE INDEX index2 ON heap_1 (int_column ASC);
--error 1503
CREATE UNIQUE INDEX index3 ON heap_1 (float_column);

--echo 增加局部唯一索引 
--error 1503
CREATE UNIQUE INDEX index4 ON heap_1 (int_column ASC) LOCAL;
--error 1503
CREATE UNIQUE INDEX index5 ON heap_1 (float_column) LOCAL;

--echo 增加复合索引
CREATE INDEX index6 ON heap_1 (int_column,char_column ASC) LOCAL;
CREATE INDEX index7 ON heap_1 (id,char_column) LOCAL;

--echo 删除索引
DROP INDEX index1 ON heap_1;

--echo 重命名索引
ALTER TABLE heap_1 RENAME INDEX index6 TO index8;

--echo 修改索引可见性

SHOW INDEX FROM heap_1;
--error 1235
ALTER TABLE heap_1 ALTER INDEX id INVISIBLE;
ALTER TABLE heap_1 ALTER INDEX index7 INVISIBLE;
SHOW INDEX FROM heap_1;

--echo 混合索引操作
--error 4179
alter table heap_1 add index index9(char_column,id,int_column), drop index index8, rename index index8 to index10;

alter table heap_1 add index index9(char_column,id,int_column), rename index index7 to index3;

SHOW INDEX FROM heap_1;

--echo online ddl 列操作 
--echo 末尾加列

ALTER TABLE heap_1 ADD c1 INT;

--echo 添加virtual列

ALTER TABLE heap_1 ADD COLUMN c2 VARCHAR(255) AS (id * int_column) VIRTUAL;

ALTER TABLE heap_1 ADD COLUMN c3 VARCHAR(255) AS (float_column * int_column) VIRTUAL;

--echo 修改列为not null

ALTER TABLE heap_1 MODIFY float_column FLOAT NOT NULL;
desc heap_1;

--echo 修改列为null	如修改主键列为null，则报错

ALTER TABLE heap_1 MODIFY float_column FLOAT NULL;
--error 1235
ALTER TABLE heap_1 MODIFY id int NULL;
desc heap_1;

--echo 设列默认值
ALTER TABLE heap_1 MODIFY varchar_column VARCHAR(255) DEFAULT 'new_default_value';
desc heap_1;

--echo 删除列默认值

ALTER TABLE heap_1 ALTER COLUMN varchar_column DROP DEFAULT;

ALTER TABLE heap_1 ALTER COLUMN id DROP DEFAULT;
ALTER TABLE heap_1 ALTER COLUMN float_column DROP DEFAULT;
ALTER TABLE heap_1 ALTER COLUMN int_column DROP DEFAULT;

desc heap_1;

--echo 修改自增列值
show create table heap_1;
ALTER TABLE heap_1 AUTO_INCREMENT = 60;
show create table heap_1;

--echo 重命名列
--error 3855
ALTER TABLE heap_1 RENAME COLUMN id TO idd;
ALTER TABLE heap_1 RENAME COLUMN json_column TO json_column1;
ALTER TABLE heap_1 RENAME COLUMN json_column1 TO json_column;
show create table heap_1;

--echo 增加列类型长度或精度	
--echo int的增长
--error 1235
ALTER TABLE heap_1 MODIFY COLUMN id INT(12);
ALTER TABLE heap_1 MODIFY COLUMN int_column INT(12);

ALTER TABLE heap_1 MODIFY COLUMN float_column INT(12);

--echo varchar的变长
ALTER TABLE heap_1 MODIFY COLUMN varchar_column VARCHAR(300);
ALTER TABLE heap_1 MODIFY COLUMN char_column CHAR(20);

--echo 混合列操作
ALTER TABLE heap_1 ALTER COLUMN varchar_column DROP DEFAULT,MODIFY COLUMN char_column VARCHAR(30);

--echo 外键约束操作
--echo 增加外键、check/not null 
--error 0,1051
drop table heap_2;
CREATE TABLE heap_2 (
    id bigint(20),
    int_column bigint(20) PRIMARY KEY,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) organization heap;

ALTER TABLE heap_2 ADD CONSTRAINT fk_heap2_to_heap1 FOREIGN KEY (int_column) REFERENCES heap_1(id);

ALTER TABLE heap_1 ADD CONSTRAINT chk_int_column CHECK (int_column >= 0);

--echo 删除外键、check约束 
ALTER TABLE heap_2 DROP FOREIGN KEY fk_heap2_to_heap1;
ALTER TABLE heap_1 DROP CONSTRAINT chk_int_column;

--echo 表操作
--echo 重命名表
--error 1050
RENAME TABLE heap_1 TO heap_2;
RENAME TABLE heap_1 TO heap_11;
RENAME TABLE heap_11 TO heap_1;

--echo 修改字符集
SELECT TABLE_NAME, TABLE_COLLATION FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 CONVERT TO CHARACTER SET gbk;
SELECT TABLE_NAME, TABLE_COLLATION FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 CONVERT TO CHARACTER SET gb18030_2022;
SELECT TABLE_NAME, TABLE_COLLATION FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 CONVERT TO CHARACTER SET utf8mb4;
SELECT TABLE_NAME, TABLE_COLLATION FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';

--echo 修改行格式
SELECT TABLE_NAME, ROW_FORMAT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 ROW_FORMAT = COMPACT;
SELECT TABLE_NAME, ROW_FORMAT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 ROW_FORMAT = REDUNDANT;
SELECT TABLE_NAME, ROW_FORMAT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 ROW_FORMAT = COMPRESSED;
SELECT TABLE_NAME, ROW_FORMAT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 ROW_FORMAT = DYNAMIC;
SELECT TABLE_NAME, ROW_FORMAT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';

--echo 修改压缩算法

SHOW CREATE TABLE heap_1;
ALTER TABLE heap_1   COMPRESSION 'none';
ALTER TABLE heap_1   COMPRESSION 'zstd_1.0';
SHOW CREATE TABLE heap_1;
ALTER TABLE heap_1   COMPRESSION 'lz4_1.0';
ALTER TABLE heap_1   COMPRESSION 'snappy_1.0';
ALTER TABLE heap_1   COMPRESSION 'lz4_1.9.1';
SHOW CREATE TABLE heap_1;
ALTER TABLE heap_1   COMPRESSION 'zstd_1.3.8';
SHOW CREATE TABLE heap_1;

--echo 修改表注释
SELECT TABLE_COMMENT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';
ALTER TABLE heap_1 COMMENT = 'This is a sample table comment';
SELECT TABLE_COMMENT FROM information_schema.TABLES WHERE TABLE_NAME = 'heap_1';

--echo 优化表空间
OPTIMIZE TABLE heap_1;

--echo   offline ddl
--echo 列操作
--echo 中间加列（before/after/first）

ALTER TABLE heap_1 ADD COLUMN new_col INT FIRST;
ALTER TABLE heap_1 ADD COLUMN new_col2 VARCHAR(50) BEFORE new_col;
ALTER TABLE heap_1 ADD COLUMN new_col3 VARCHAR(50) NOT NULL AFTER new_col;

DESCRIBE heap_1;

--echo 添加stored生成列
ALTER TABLE heap_1 ADD COLUMN storedc2 VARCHAR(255) AS (float_column * int_column) stored;
DESCRIBE heap_1;

--echo 重排列（before/after/first）

ALTER TABLE heap_1 MODIFY COLUMN new_col3 VARCHAR(50) FIRST;
ALTER TABLE heap_1 MODIFY COLUMN new_col2 VARCHAR(50) BEFORE new_col3;
ALTER TABLE heap_1 MODIFY COLUMN new_col VARCHAR(50) AFTER new_col2;
DESCRIBE heap_1;

--echo 修改列类型（非小改大）
alter table heap_1 modify column new_col BIGINT;

--echo 修改列字符集（非小改大）

SHOW FULL COLUMNS FROM heap_1;
ALTER TABLE heap_1 MODIFY COLUMN new_col2 varchar(50) CHARACTER SET gbk COLLATE gbk_chinese_ci;
SHOW FULL COLUMNS FROM heap_1;

--echo 删列
ALTER TABLE heap_1 DROP COLUMN new_col2;
ALTER TABLE heap_1 DROP COLUMN new_col;
ALTER TABLE heap_1 DROP COLUMN new_col3;
DESCRIBE heap_1;

drop table heap_1;

--echo DML

CREATE TABLE heap_1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    int_column INT,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) PARTITION BY key (id) PARTITIONS 10;


INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(10, 3.14, b'1', '2023-10-05 12:34:56', 'char1', 'varchar text 1', 'blob data 1', 'text data 1', '{"key1": "value1"}');

INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(20, 2.71, b'0', '2023-09-15 10:00:00', 'char2', 'varchar text 2', 'blob data 2', 'text data 2', '{"key2": "value2"}');

INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(30, 1.61, b'1', '2023-08-25 18:45:30', 'char3', 'varchar text 3', 'blob data 3', 'text data 3', '{"key3": "value3"}');

UPDATE heap_1  SET int_column = int_column*10  WHERE id > 2  ORDER BY float_column DESC  LIMIT 2;
select int_column from heap_1 order by 1;

UPDATE IGNORE heap_1  SET int_column = int_column*10  WHERE id > 2  ORDER BY float_column DESC  LIMIT 2;
select int_column from heap_1 order by 1;

UPDATE heap_1 PARTITION(p0, p1) SET float_column = 111;

SELECT * FROM heap_1 PARTITION(p0, p1);
--error 0,1051
drop table heap_2;
CREATE TABLE heap_2 (
    id INT,
    int_column INT PRIMARY KEY,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) organization heap;

insert into heap_2 select * from heap_1;

REPLACE INTO heap_1(id,char_column) VALUES (1, '1'),(2, '2');
select id,char_column from heap_1 order by 1,2;

--echo 普通视图
--error 0,1051
drop VIEW heap_1_v;
CREATE VIEW heap_1_v AS SELECT id,int_column,char_column FROM  heap_1;
select * from heap_1_v;
drop VIEW heap_1_v;

--echo 物化视图
--echo 创建普通物化视图
CREATE MATERIALIZED VIEW mv_heap_1 DISABLE ON QUERY COMPUTATION  AS SELECT id,int_column,char_column  FROM heap_1 WHERE int_column >= 10;
select * from mv_heap_1 order by 1;

--echo 创建嵌套物化视图
CREATE MATERIALIZED VIEW mv_mv_heap_1 REFRESH COMPLETE AS SELECT id,int_column FROM mv_heap_1;
select * from mv_mv_heap_1 order by 1;

--echo 创建实时物化视图
DROP MATERIALIZED VIEW mv_heap_1;
DROP MATERIALIZED VIEW mv_mv_heap_1;

CREATE MATERIALIZED VIEW LOG ON heap_1 WITH PRIMARY KEY, ROWID, SEQUENCE (id,int_column,char_column) INCLUDING NEW VALUES;

CREATE MATERIALIZED VIEW mv_heap_1 ENABLE ON QUERY COMPUTATION AS SELECT id,count(*) FROM heap_1 GROUP BY id;

select * from mv_heap_1 order by 1;
SELECT MVIEW_NAME, ON_QUERY_COMPUTATION FROM oceanbase.DBA_MVIEWS WHERE MVIEW_NAME = 'mv_heap_1';

--echo 创建开启查询改写的物化视图

CREATE MATERIALIZED VIEW mv_heap_11 ENABLE QUERY REWRITE AS SELECT * FROM heap_1;
select * from mv_heap_11 order by 1,2,3;
SELECT MVIEW_NAME, REWRITE_ENABLED FROM oceanbase.DBA_MVIEWS WHERE MVIEW_NAME = 'mv_heap_11';

--echo 创建列存格式物化视图
DROP MATERIALIZED VIEW mv_heap_11;
CREATE MATERIALIZED VIEW mv_heap_11  WITH COLUMN GROUP(each column)  AS SELECT * FROM heap_1;
select * from mv_heap_11 order by 1,2,3;

--echo 创建物化视图时添加主键
DROP MATERIALIZED VIEW mv_heap_11;
CREATE MATERIALIZED VIEW mv_heap_11(v_id, v_name, PRIMARY KEY(v_id)) AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
select * from mv_heap_11 order by 1;
desc mv_heap_11;

--echo 创建物化视图时添加表选项和分区选项
DROP MATERIALIZED VIEW mv_heap_11;
CREATE MATERIALIZED VIEW mv_heap_11 PARALLEL 5 PARTITION BY HASH(id) PARTITIONS 8 AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
select * from mv_heap_11 order by 1;
desc mv_heap_11;

--echo 物化视图添加索引
CREATE INDEX idx1_mv_heap_11 ON mv_heap_11(int_column);

--echo 创建全量刷新物化视图
DROP MATERIALIZED VIEW mv_heap_11;
CREATE MATERIALIZED VIEW mv_heap_11 REFRESH COMPLETE AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
select * from mv_heap_11 order by 1;

--echo 创建增量刷新物化视图
DROP MATERIALIZED VIEW mv_heap_11;

CREATE MATERIALIZED VIEW mv_heap_11 REFRESH FAST AS  SELECT id,count(*) FROM heap_1 GROUP BY id;

select * from mv_heap_11 order by 1;
--echo 创建永不刷新物化视图
CREATE MATERIALIZED VIEW mv_heap_111 NEVER REFRESH AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
select * from mv_heap_111 order by 1;
--echo 创建自动刷新物化视图
DROP MATERIALIZED VIEW mv_heap_111;
CREATE MATERIALIZED VIEW mv_heap_111  REFRESH COMPLETE START WITH sysdate() NEXT sysdate() + interval 1 day AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
select * from mv_heap_111 order by 1;

DROP MATERIALIZED VIEW LOG ON heap_1;
DROP MATERIALIZED VIEW mv_heap_1;
DROP MATERIALIZED VIEW mv_heap_11;
DROP MATERIALIZED VIEW mv_heap_111;

--echo 查询
--echo cte
WITH cte1 AS ( SELECT id, int_column  FROM heap_1  WHERE int_column >= 20) SELECT * FROM cte1;
        
select id from heap_1  group by id WITH ROLLUP having id > 2 order by 1;

select t1.id,t2.id from heap_1 t1 INNER JOIN heap_2 t2 ON t1.id = t2.id;

select t1.id,t2.id from heap_1 t1 INNER JOIN (select id from heap_1  group by id WITH ROLLUP having id > 2) t2 ON t1.id = t2.id;

--echo truncate表
TRUNCATE TABLE heap_1;
select * from heap_1;
--echo 删表
DELETE FROM heap_1;

--error 0,1051
drop table heap_1;
--error 0,1051
drop table heap_2;

alter system set default_table_organization='INDEX';
sleep 5;
