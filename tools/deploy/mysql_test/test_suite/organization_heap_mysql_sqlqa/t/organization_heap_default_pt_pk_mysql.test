--result_format 4
purge recyclebin;

--echo 分区  堆表  主键索引

alter system set default_table_organization='HEAP';
sleep 5;

--echo 优先级低于表级选项organization
--error 0,1051
drop table heap_1;
CREATE TABLE heap_1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    int_column INT,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) organization index PARTITION BY key (id) PARTITIONS 10;

SHOW CREATE TABLE heap_1;

--error 0,1051
drop table heap_1;
CREATE TABLE heap_1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    int_column INT,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) PARTITION BY key (id) PARTITIONS 10;

