物化视图
创建普通物化视图
CREATE MATERIALIZED VIEW mv_heap_1 DISABLE ON QUERY COMPUTATION  AS SELECT id,int_column,char_column  FROM heap_1 WHERE int_column >= 10;
select * from mv_heap_1 order by 1;
+------+------------+-------------+
| id   | int_column | char_column |
+------+------------+-------------+
|    3 |       3000 | char3       |
+------+------------+-------------+
创建嵌套物化视图
CREATE MATERIALIZED VIEW mv_mv_heap_1 REFRESH COMPLETE AS SELECT id,int_column FROM mv_heap_1;
select * from mv_mv_heap_1 order by 1;
+------+------------+
| id   | int_column |
+------+------------+
|    3 |       3000 |
+------+------------+
创建实时物化视图
DROP MATERIALIZED VIEW mv_heap_1;
DROP MATERIALIZED VIEW mv_mv_heap_1;
CREATE MATERIALIZED VIEW LOG ON heap_1 WITH PRIMARY KEY, ROWID, SEQUENCE (id,int_column,char_column) INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW mv_heap_1 ENABLE ON QUERY COMPUTATION AS SELECT id,count(*) FROM heap_1 GROUP BY id;
select * from mv_heap_1 order by 1;
