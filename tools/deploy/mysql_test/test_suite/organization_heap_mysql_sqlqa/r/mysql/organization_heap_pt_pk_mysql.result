result_format: 4
purge recyclebin;
分区  a. organization = heap：堆表  主键索引
drop table heap_1;
CREATE TABLE heap_1 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    int_column INT,
    float_column FLOAT,
    bit_column BIT(1),
    datetime_column DATETIME,
    char_column CHAR(10),
    varchar_column VARCHAR(255),
    blob_column BLOB,
    text_column TEXT,
    json_column JSON
) organization heap PARTITION BY RANGE (id) (
    PARTITION p0 VALUES LESS THAN (1),
    PARTITION p1 VALUES LESS THAN (2),
    PARTITION p2 VALUES LESS THAN (5),
    PARTITION p3 VALUES LESS THAN (1000)
) ;
INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(10, 3.14, b'1', '2023-10-05 12:34:56', 'char1', 'varchar text 1', 'blob data 1', 'text data 1', '{"key1": "value1"}');
INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(20, 2.71, b'0', '2023-09-15 10:00:00', 'char2', 'varchar text 2', 'blob data 2', 'text data 2', '{"key2": "value2"}');
INSERT INTO heap_1 (int_column, float_column, bit_column, datetime_column, char_column, varchar_column, blob_column, text_column, json_column) VALUES
(30, 1.61, b'1', '2023-08-25 18:45:30', 'char3', 'varchar text 3', 'blob data 3', 'text data 3', '{"key3": "value3"}');
禁掉其他涉及到primary key的修改操作 预期报错
主键约束操作 删除主键
ALTER TABLE heap_1 DROP PRIMARY KEY;
ERROR 0A000: can't DROP 'PRIMARY', DROP 'PRIMARY' in the heap organized table not supported
alter table heap_1 drop column id;
ERROR HY000: Column 'id' has a partitioning function dependency and cannot be dropped or renamed.
修改列为主键
ALTER TABLE heap_1 ADD PRIMARY KEY (int_column);
ERROR 0A000: add primary key in heap organized table not supported
修改主键列类型（非小改大）
ALTER TABLE heap_1 MODIFY id VARCHAR(255);
ERROR HY000: Field 'id' is of a not allowed type for this type of partitioning
alter table heap_1 modify column id BIGINT NOT NULL;
alter table heap_1 modify column id INT NOT NULL;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
加主键列
ALTER TABLE heap_1 ADD PRIMARY KEY (id,int_column);
ERROR 0A000: add primary key in heap organized table not supported
修改主键为自增列
ALTER TABLE heap_1 MODIFY id INT AUTO_INCREMENT;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
ALTER TABLE heap_1 AUTO_INCREMENT = 10;
修改主键列为null
ALTER TABLE heap_1 MODIFY id INT NULL;
ERROR 0A000: performing offline DDL operations on primary key columns or changing primary key columns to be NOT NULL in a heap table is not supported
