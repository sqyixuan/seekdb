查询
cte
WITH cte1 AS ( SELECT id, int_column  FROM heap_1  WHERE int_column >= 20) SELECT * FROM cte1;
+----+------------+
| id | int_column |
+----+------------+
|  3 |       3000 |
+----+------------+
select id from heap_1  group by id WITH ROLLUP having id > 2 order by 1;
+----+
| id |
+----+
|  3 |
+----+
select t1.id,t2.id from heap_1 t1 INNER JOIN heap_2 t2 ON t1.id = t2.id;
+----+------+
| id | id   |
+----+------+
|  1 |    1 |
|  2 |    2 |
|  3 |    3 |
+----+------+
select t1.id,t2.id from heap_1 t1 INNER JOIN (select id from heap_1  group by id WITH ROLLUP having id > 2) t2 ON t1.id = t2.id;
+----+----+
| id | id |
+----+----+
|  3 |  3 |
+----+----+
