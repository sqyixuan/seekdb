Show Create Table 语法改造
show create table heap_1;
Table	Create Table
heap_1	CREATE TABLE `heap_1` (
  `id` bigint(20) NOT NULL,
  `int_column` int(11) DEFAULT NULL,
  `float_column` float DEFAULT NULL,
  `bit_column` bit(1) DEFAULT NULL,
  `datetime_column` datetime DEFAULT NULL,
  `char_column` char(10) DEFAULT NULL,
  `varchar_column` varchar(255) DEFAULT NULL,
  `blob_column` blob DEFAULT NULL,
  `text_column` text DEFAULT NULL,
  `json_column` json DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (1),
partition `p1` values less than (2),
partition `p2` values less than (5),
partition `p3` values less than (1000))
DDL功能改造
DDL功能改造   online ddl  索引 增加索引
增加普通索引
CREATE INDEX index1 ON heap_1 (int_column ASC);
增加唯一索引
CREATE UNIQUE INDEX index2 ON heap_1 (int_column ASC);
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
CREATE UNIQUE INDEX index3 ON heap_1 (float_column);
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
增加局部唯一索引 
CREATE UNIQUE INDEX index4 ON heap_1 (int_column ASC) LOCAL;
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
CREATE UNIQUE INDEX index5 ON heap_1 (float_column) LOCAL;
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
增加复合索引
CREATE INDEX index6 ON heap_1 (int_column,char_column ASC) LOCAL;
CREATE INDEX index7 ON heap_1 (id,char_column) LOCAL;
删除索引
DROP INDEX index1 ON heap_1;
重命名索引
ALTER TABLE heap_1 RENAME INDEX index6 TO index8;
