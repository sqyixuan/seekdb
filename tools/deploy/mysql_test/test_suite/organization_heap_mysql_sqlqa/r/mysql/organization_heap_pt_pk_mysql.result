创建自动刷新物化视图
DROP MATERIALIZED VIEW mv_heap_111;
CREATE MATERIALIZED VIEW mv_heap_111  REFRESH COMPLETE START WITH sysdate() NEXT sysdate() + interval 1 day AS SELECT id, int_column  FROM heap_1  WHERE int_column >= 20;
