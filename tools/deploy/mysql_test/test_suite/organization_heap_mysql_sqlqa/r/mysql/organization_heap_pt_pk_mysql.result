online ddl 列操作 
末尾加列
ALTER TABLE heap_1 ADD c1 INT;
添加virtual列
ALTER TABLE heap_1 ADD COLUMN c2 VARCHAR(255) AS (id * int_column) VIRTUAL;
ALTER TABLE heap_1 ADD COLUMN c3 VARCHAR(255) AS (float_column * int_column) VIRTUAL;
