修改自增列值
show create table heap_1;
Table	Create Table
heap_1	CREATE TABLE `heap_1` (
  `id` bigint(20) NOT NULL,
  `int_column` int(11) DEFAULT NULL,
  `float_column` float DEFAULT NULL,
  `bit_column` bit(1) DEFAULT NULL,
  `datetime_column` datetime DEFAULT NULL,
  `char_column` char(10) DEFAULT NULL,
  `varchar_column` varchar(255) DEFAULT NULL,
  `blob_column` blob DEFAULT NULL,
  `text_column` text DEFAULT NULL,
  `json_column` json DEFAULT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` varchar(255) GENERATED ALWAYS AS ((`id` * `int_column`)) VIRTUAL,
  `c3` varchar(255) GENERATED ALWAYS AS ((`float_column` * `int_column`)) VIRTUAL,
  PRIMARY KEY (`id`),
  KEY `index8` (`int_column`, `char_column`) BLOCK_SIZE 16384 LOCAL,
  KEY `index3` (`id`, `char_column`) BLOCK_SIZE 16384 LOCAL /*!80000 INVISIBLE */,
  KEY `index9` (`char_column`, `id`, `int_column`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
