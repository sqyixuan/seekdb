# 二级分区表与一级分区表之间交换，list分区值不同
drop table t1;
drop table t2;
create table t1 (col1 int, col2 varchar(50), col3 int)
partition by list (col1)
subpartition by list (col3) (
partition p0 values (100, 200) (
subpartition sp0 values (1, 2, 3),
subpartition sp1 values (4, 5, 6)
),
partition p1 values (300, 400) (
subpartition sp2 values (7, 8, 9),
subpartition sp3 values (10, 11, 12)
)
);
create table t2 (col1 int, col2 varchar(50), col3 int)
partition by list (col3)
(
partition p0 values (1,2,3),
partition p1 values (4,5,13)
);
