# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for testing exchange partition in oracle mode
#

 
 # test simple table partition exchange

--error 0, 942
drop table pt;
--error 0, 942
drop table nt;
# 分区交换的两张表都是非分区表, 报错
create table pt (c1 number, c2 number);
create table nt (c1 number, c2 number);
--error 600
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 分区交换的两张表都是分区表, 报错
create table pt (c1 number, c2 number) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number, c2 number) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
--error 600
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 分区交换一张表是分区表、一张表是非分区表, 且指定WITHOUT VALIDATION, 交换成功
create table pt (c1 number, c2 number) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number, c2 number);
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# Oracle模式下, 分区表和非分区表做分区交换, 除了INCLUDING INDEXES WITHOUT VALIDATION, 指定了其他语法，报错
create table pt (c1 number, c2 number) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number, c2 number);
--error 900
alter table pt exchange partition M1 with table nt WITH VALIDATION;
--error 900
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
--error 900
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION UPDATE GLOBAL INDEXES;
--error 900
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION UPDATE GLOBAL INDEXES;
drop table pt;
drop table nt;

# 交换的分区表的一级分区不存在
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
--error 2149
alter table pt exchange partition M111 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 交换的分区表的二级分区不存在
CREATE TABLE pt(c1 INT,c2 INT) PARTITION BY RANGE(c1) 
       SUBPARTITION BY RANGE(c1)
       SUBPARTITION TEMPLATE
       (SUBPARTITION mp1 VALUES LESS THAN(100),
        SUBPARTITION mp2 VALUES LESS THAN(200),
        SUBPARTITION mp3 VALUES LESS THAN(300)
        )
       (PARTITION p0 VALUES LESS THAN(2020),
        PARTITION p1 VALUES LESS THAN(2021),
        PARTITION p2 VALUES LESS THAN(2022)
        );
CREATE TABLE nt(c1 INT,c2 INT);
--error 14251
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
alter table pt exchange partition p0smp1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 一级分区表不是range分区

CREATE TABLE pt(
     c1 VARCHAR2(10),
     c2 VARCHAR2(20)
)PARTITION BY LIST(c1)
(
      PARTITION PART_01 VALUES('ME','PE','QC','RD'),
      PARTITION PART_02 VALUES('SMT','SALE')
);
CREATE TABLE nt(c1 VARCHAR2(10), c2 VARCHAR2(20));
--error 600
alter table pt exchange partition PART_01 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 二级分区表不是range分区
CREATE TABLE pt(c1 INT,c2 INT) 
       PARTITION BY LIST(c1)
       SUBPARTITION BY LIST(c2)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION mp0 VALUES (2),
         SUBPARTITION mp1 VALUES (5),
         SUBPARTITION mp2 VALUES (8)
        )
        (PARTITION p0 VALUES (1,3),
         PARTITION p1 VALUES (4,6),
         PARTITION p2 VALUES (7,9)
        );
CREATE TABLE nt(c1 INT,c2 INT);
--error 600
alter table pt exchange partition p0smp0 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 测试主键表之间的交换
create table pt (c1 number not null primary key, c2 number) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number not null primary key, c2 number);
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

### 分区交换作为旁路导入功能案例
# 创建一张分区表pt
create table pt (c1 int, c2 int, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (20));
insert into pt(c1, c2) values(1,1);
insert into pt(c1, c2) values(2,2);
insert into pt(c1, c2) values(3,3);
insert into pt(c1, c2) values(4,4);
insert into pt(c1, c2) values(5,5);
insert into pt(c1, c2) values(6,6);
insert into pt(c1, c2) values(7,7);
insert into pt(c1, c2) values(8,8);
insert into pt(c1, c2) values(9,9);
insert into pt(c1, c2) values(10,10);
insert into pt(c1, c2) values(11,11);
insert into pt(c1, c2) values(12,12);
insert into pt(c1, c2) values(13,13);
insert into pt(c1, c2) values(14,14);
insert into pt(c1, c2) values(15,15);
create index pt_local_idx on pt(c1, c2) local;
create index pt_global_idx on pt(c2) global;
select * from pt order by c1;
# 创建一张和分区表格式相同的非分区表nt
create table nt (c1 int, c2 int, c3 blob);
insert into nt(c1, c2) values(21,21);
insert into nt(c1, c2) values(22,22);
insert into nt(c1, c2) values(23,23);
insert into nt(c1, c2) values(24,24);
insert into nt(c1, c2) values(25,25);
insert into nt(c1, c2) values(26,26);
insert into nt(c1, c2) values(27,27);
insert into nt(c1, c2) values(28,28);
insert into nt(c1, c2) values(29,29);
insert into nt(c1, c2) values(30,30);
insert into nt(c1, c2) values(31,31);
insert into nt(c1, c2) values(32,32);
insert into nt(c1, c2) values(33,33);
insert into nt(c1, c2) values(34,34);
insert into nt(c1, c2) values(35,35);
create index nt_local_idx on nt(c1, c2);
select * from nt order by c1;
# 在分区表中新增加符合非分区表nt的分区
ALTER TABLE pt ADD PARTITION  M4 VALUES LESS THAN(40);
select * from pt order by c1;
select * from nt order by c1;
# pt表的分区M4和非分区表nt执行分区交换操作
alter table pt exchange partition M4 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;
# 向pt表中插入新的数据
insert into pt(c1, c2) values(36,36);
insert into pt(c1, c2) values(37,37);
insert into pt(c1, c2) values(38,38);
insert into pt(c1, c2) values(39,39);
select * from pt order by c1;
# 向nt表中插入新的数据
insert into nt(c1, c2) values(1,1);
insert into nt(c1, c2) values(2,2);
insert into nt(c1, c2) values(3,3);
insert into nt(c1, c2) values(4,4);
insert into nt(c1, c2) values(5,5);
insert into nt(c1, c2) values(6,6);
insert into nt(c1, c2) values(7,7);
insert into nt(c1, c2) values(8,8);
insert into nt(c1, c2) values(9,9);
insert into nt(c1, c2) values(10,10);
select * from nt order by c1;
# 在pt表中更新数据
update pt set c2 = -10 where c1 = 10;
update pt set c2 = -11 where c1 = 11;
update pt set c2 = -12 where c1 = 12;
select * from pt order by c1;
# 在nt表中更新数据
update nt set c2 = -1 where c1 = 1;
update nt set c2 = -2 where c1 = 2;
update nt set c2 = -3 where c1 = 3;
select * from nt order by c1;
# 在pt表中删除数据
delete from pt where c1 > 10;
select * from pt order by c1;
# 在nt表中删除数据
delete from nt where c1 > 5;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;

# 分区交换作为二级分区旁路导入功能案例
