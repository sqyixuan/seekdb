# 9、默认值校验
CREATE TABLE pt(c1 INT PRIMARY KEY, c2 int DEFAULT 2) PARTITION BY RANGE(c1) (
                                                                     PARTITION p1 VALUES LESS THAN (10),
                                                                     PARTITION p2 VALUES LESS THAN (20),
                                                                     PARTITION p3 VALUES LESS THAN (30));
CREATE TABLE nt (c1 INT primary KEY, c2 int DEFAULT 2);
alter table pt exchange partition p1 with table nt including indexes without validation;
#default定义不同
