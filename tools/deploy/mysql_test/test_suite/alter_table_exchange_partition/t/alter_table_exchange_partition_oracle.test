# rename partition
create table pt (c1 number, c2 number) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number, c2 number);
INSERT INTO nt (c1) VALUES (3);
INSERT INTO nt (c1) VALUES (4);
INSERT INTO nt (c1) VALUES (5);
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
ALTER TABLE pt rename partition M1 TO M888; 
select * from pt partition (M888) order by c1;

# column id不同，列其他属性完全相同, 允许分区交换
--error 0, 942
drop table heap;
--error 0, 942
drop table heap_incre;
CREATE TABLE heap( c1  char(10) default NULL, c2 date default NULL, c3 BINARY_DOUBLE  default NULL, c4  date default NULL, c5 int default null, c6 number default null, c7 nvarchar2(60), c8 raw(20) default null, c9 timestamp default null, c10 varchar(10) default null, c11 varchar2(20) default null, c12 blob default null) partition by range(c3) (partition p0 values less than (10),partition p1 values less than (20),partition p2 values less than (30),partition p3 values less than (MAXVALUE));
create unique index test42 on heap(c1,upper(c7),c3) local;
create index heap2 on heap(c10) reverse local;
CREATE TABLE heap_incre( c1  char(10) default NULL, c2 date default NULL, c3 BINARY_DOUBLE  default NULL, c4  date default NULL, c5 int default null, c6 number default null, c7 nvarchar2(60), c8 raw(20) default null, c9 timestamp default null, c10 varchar(10) default null, c11 varchar2(20) default null, c12 blob default null);
create unique index test412 on heap_incre(c1,upper(c7),c3) local;
create index heap12 on heap_incre(c10) reverse local;
ALTER TABLE heap EXCHANGE PARTITION p3 WITH TABLE heap_incre INCLUDING INDEXES WITHOUT VALIDATION;
drop  index heap12;
create index heap12 on heap_incre(c10) reverse local;
ALTER TABLE heap EXCHANGE PARTITION p3 WITH TABLE heap_incre INCLUDING INDEXES WITHOUT VALIDATION;
drop  index test42;
create unique index test42 on heap(c1,upper(c7));
drop  index test42;
create unique index test42 on heap(c1,upper(c7),c3) local;
ALTER TABLE heap EXCHANGE PARTITION p3 WITH TABLE heap_incre INCLUDING INDEXES WITHOUT VALIDATION;
drop table heap;
drop table heap_incre;

connect (connsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connection default;
--echo # 一级分区表与一级分区表交换，不支持
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
--error 600
alter table t1 exchange partition p3 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与二级分区表交换，不支持
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
--error 600
alter table t1 exchange partition p1 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
--error 600
alter table t1 exchange partition p1sp3 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表交换，其中二级分区表的一级分区为hash分区，不支持
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int)
partition by hash(c1)
subpartition by hash(c1) subpartitions 5
(
  partition p0,
  partition p1,
  partition p2,
  partition p3,
  partition p4,
  partition p5,
  partition p6,
  partition p7,
  partition p8,
  partition p9
);
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
--error 600
alter table t1 exchange partition p1 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
--error 600
alter table t1 exchange partition p1sp3 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;

insert into t1 values (11, 30), (14, 40), (26, 150), (29, 160);
insert into t2 values (12, 20), (16, 110), (17, 170), (19, 120);
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);

--echo #一级分区表与二级分区表交换，不支持
--error 600
alter table t2 exchange partition p1 with table t1 INCLUDING INDEXES WITHOUT VALIDATION;

--echo #二级分区表与一级分区表交换，成功
alter table t1 exchange partition p1 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，带索引
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
create index k1 on t1(c1, c2) local;
create index k2 on t2(c1, c2) local;

insert into t1 values (11, 30), (14, 40), (26, 150), (29, 160);
insert into t2 values (12, 20), (16, 110), (17, 170), (19, 120);
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
connection connsys;
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 't1'), table_name, 1);
let $idx2 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 't2'), table_name, 1);

connection default;
set ob_enable_index_direct_select=1;
--disable_query_log
eval select * from \"$idx1\";
eval select * from \"$idx2\";
--enable_query_log

alter table t1 exchange partition p1 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
--disable_query_log
eval select * from \"$idx1\";
eval select * from \"$idx2\";
--enable_query_log
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，带lob列
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int primary key, c2 int, c3 clob)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int, c3 clob)
partition by hash(c1) partitions 5;

insert into t1 values (11, 30, RANDSTR(5000, 1)), (14, 40, RANDSTR(3000, 1)), (26, 150, RANDSTR(4000, 1)), (29, 160, RANDSTR(1000, 1));
insert into t2 values (12, 20, RANDSTR(3000, 2)), (16, 110, RANDSTR(4000, 2)), (17, 170, RANDSTR(5000, 2)), (19, 120, RANDSTR(6000, 2));
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);

alter table t1 exchange partition p1 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，分区键不同
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (c1 int, c2 varchar(50), c3 int)
partition by range (c1)
subpartition by hash (c3) subpartitions 2
(
    partition p0 values less than (100000),
    partition p1 values less than (MAXVALUE)
);
create table t2 (c1 int, c2 varchar(50), c3 int)
partition by hash (c1) partitions 2;
insert into t2 values(1,'part1', 2), (90009,'part2', 4);
--error 600
alter table t1 exchange partition p0 with table t2 INCLUDING INDEXES WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，list分区值不同
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (col1 int, col2 varchar(50), col3 int)
partition by list (col1)
subpartition by list (col3) (
  partition p0 values (100, 200) (
    subpartition sp0 values (1, 2, 3),
    subpartition sp1 values (4, 5, 6)
  ),
  partition p1 values (300, 400) (
    subpartition sp2 values (7, 8, 9),
    subpartition sp3 values (10, 11, 12)
  )
);
create table t2 (col1 int, col2 varchar(50), col3 int)
partition by list (col3)
(
  partition p0 values (1,2,3),
  partition p1 values (4,5,13)
);
insert into t2 values (100, 'list partition', 13);
--error 600
alter table t1 exchange partition p0 with table t2 including indexes without validation;
drop table t1;
drop table t2;

--echo #二级分区表与一级分区表之间交换，range分区范围不同
--source mysql_test/include/ignore_drop_table_err.inc
drop table t1;
--source mysql_test/include/ignore_drop_table_err.inc
drop table t2;
create table t1 (col1 int, col2 varchar(50), col3 int)
partition by list (col1)
subpartition by range (col3) (
  partition p0 values (100, 200) (
    subpartition sp0 values less than (10),
    subpartition sp1 values less than (20)
  ),
  partition p1 values (300, 400) (
    subpartition sp2 values less than (30),
    subpartition sp3 values less than (40)
  )
);
create table t2 (col1 int, col2 varchar(50), col3 int)
partition by range (col3)
(
  partition sp0 values less than (10),
  partition sp1 values less than (30)
);
insert into t2 values(100, 'range partition', 23);
--error 600
alter table t1 exchange partition p0 with table t2 including indexes without validation;
drop table t1;
drop table t2;