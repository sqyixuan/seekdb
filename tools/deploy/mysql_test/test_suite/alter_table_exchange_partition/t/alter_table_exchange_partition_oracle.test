drop table nt;

# 8、identity列校验
create table pt(c1 int generated always as identity, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt(c1 int , c2 int);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
create table nt(c1 int generated always as identity, c2 int);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
