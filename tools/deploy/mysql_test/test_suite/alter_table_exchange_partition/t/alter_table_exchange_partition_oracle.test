### 列级属性校验
# 1、交换的两表的stored列定义需要一致
# pt(number, char, number) <-> nt(char, number, number)
# 列类型不一致, 交换失败
create table pt(c1 number, c2 char(10), c3 number) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 char(10), c2 number, c3 number);
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
# 一期要求列名相同, 才能执行分区交换, 大小写不敏感
create table nt(c2 char(10), c1 number, c3 number);
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
create table nt(c3 number, c2 char(10), c1 number);
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
create table nt(c1 number, c2 char(10), c3 number);
insert into pt(c1, c2, c3) values(50, 51, 52);
insert into nt(c3, c2, c1) values(60, 61, 62);
select * from pt;
select * from nt;
alter table pt exchange partition M1 with table nt including indexes without validation;
select * from pt;
select * from nt;
drop table pt;
drop table nt;
create table pt(c1 number, c2 char(10), c3 number) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 number, c2 char(10), C3 number);
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 2、生成列列名、顺序、类型在nt、pt表需要一一对应, 但表达式不作要求
create table pt(c1 number, c2 char(10), c3 number generated always as (c1+10), c4 char(20), c5 number generated always as(c2+100)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 number, c2 char(10), c3 number generated always as (c1+1), c4 number generated always as(c2+1), c5 char(20));
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
create table nt(c1 number, c2 char(10), c3 number generated always as (c1+1), c4 char(20), c5 number generated always as(c2+10));
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 3、主键位置校验
create table pt (c1 int, c2 int, primary key (c1)) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# rowkey的个数不一样, 不允许交换
create table pt(c1 int, c2 char(10), primary key(c1,c2)) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, C2 char(10), primary key(c1));
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# 4、数据长度
create table pt (c1 int, c2 char(20)) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 char(10));
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 5、精度不同
--error 0, 600, 942
drop table pt_decimal_test1;
--error 0, 600, 942
drop table nt_decimal_test1;
CREATE TABLE pt_decimal_test1 (c1 INT PRIMARY KEY , c2 decimal(10,5))PARTITION BY RANGE(c1) (
                                                                     PARTITION p1 VALUES LESS THAN (10),
                                                                     PARTITION p2 VALUES LESS THAN (20),
                                                                     PARTITION p3 VALUES LESS THAN (30));
CREATE TABLE nt_decimal_test1 (c1 INT primary KEY, c2 decimal(10,5));
#精度相同交换
ALTER TABLE pt_decimal_test1 EXCHANGE PARTITION p2 WITH TABLE nt_decimal_test1 including indexes without validation;
#精度不相同交换
drop table nt_decimal_test1;
CREATE TABLE nt_decimal_test1 (c1 INT primary KEY, c2 decimal(10,3));
--error 14097
ALTER TABLE pt_decimal_test1 EXCHANGE PARTITION p2 WITH TABLE nt_decimal_test1 including indexes without validation;
drop table pt_decimal_test1;
drop table nt_decimal_test1;

# 6、数据尺度不同
