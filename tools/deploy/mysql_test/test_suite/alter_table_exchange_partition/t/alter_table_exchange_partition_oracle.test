### 索引相关
# 1、索引之间的交换不需要索引名字;
# 2、同结构索引, 索引列的之间顺序也需要完全一致, 否则, 交换失败;
# 3、不支持存在唯一约束创建的索引
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create unique index idx on pt(c1, c2) local;
create unique index idx2 on nt(c1, c2) local;
insert into pt values(1, 1);
insert into nt values(2, 2);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 索引类型不一致, 交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create unique index idx on pt(c1, c2);
create index idx1 on nt(c1, c2);
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

#索引定义不一致, 交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2);
create index idx1 on nt(c1);
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 跳过全局索引, 局部存储的索引需要一一对应
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2) global;
create index idx1 on pt(c1) local;
create index idx2 on nt(c1) local;
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 若两表的索引数量和结构都相同,且都为全局索引，交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2) global;
create index idx1 on nt(c1, c2) global;
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 不支持存在唯一约束
create table pt(c1 int, c2 char(10), unique (c1)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), unique (c1));
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

### 约束相关校验
# 1、Unique约束
# oracle 模式下,unique约束会创建全局唯一索引, 如果两张表的局部存储的索引不能一一对应,则交换失败
create table pt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3)) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
insert into pt values(50, 50, 50);
insert into nt values(60, 60, 60);
select * from pt order by c1;
select * from nt order by c1;
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;
create table pt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3)) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int);
# oracle 模式下,unique约束会创建全局唯一索引, 局部存储的索引能够一一对应,则交换成功, 全局索引状态设置为Unusable
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# unique 约束数量不一致, 交换失败
create table pt(c1 int primary key, c2 char(10), c3 int) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# unique 约束表达式不一致, 交换失败
create table pt(c1 int primary key, c2 char(10), c3 int) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
create unique index pt_test on pt(c3,c1) local;
--error 14098
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# unique 约束表达式一致, 交换成功
create table pt(c1 int primary key, c2 char(10), c3 int) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
create unique index pt_test on pt(c1,c3) local;
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# 2、NOT NULL约束
create table pt(c1 int, c2 char(10), c3 int not null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10) not null, c3 int);
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
create table pt(c1 int, c2 char(10), c3 int not null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int);
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
create table pt(c1 int, c2 char(10) not null, c3 int) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# 修改not null 属性, not null相关属性不同, 不允许交换
create table pt(c1 int, c2 char(10), c3 int default null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int default null);
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table nt modify c3 int not null;
--error 14097
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
CREATE TABLE pt (c1 int, c2 int, c3 int, primary key(c1, c3)) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
CREATE TABLE nt (c1 int, c2 int, c3 int, primary key(c1, c3));
alter table pt exchange partition M1 with table nt including indexes without validation;
Alter table pt modify primary key(c1,c2);
Alter table nt modify primary key(c1,c2);
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# CHECK约束(要求check表达式完全一样,否则交换失败，不兼容mysql, 在mysql中支持check表达式不一致)
# check约束表达式不一样, 不允许交换
create table pt(c1 int, c2 char(10), c3 int, check(c1=50)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, check(c2=c3));
--error 14118
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# check约束表达式相同, 约束状态不同, 不允许交换
create table pt(c1 int, c2 char(10), c3 int) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int);
alter table pt add constraint pt_constraint check(c2=50);
alter table nt add constraint nt_constraint check(c2=50);
alter table pt disable constraint pt_constraint;
--error 14118
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
# check约束相同, 状态相同, 表达式相同, 允许交换, 且交换后约束不变
create table pt(c1 int, c2 char(10), c3 int, check(c1=50)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, check(c1=50));
insert into pt values(50, 50, 50);
insert into nt values(50, 50, 50);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;

#alter table增加唯一约束,unique约束为全局索引
--error 0, 942
drop table exchange_pt_test;
--error 0, 942
drop table exchange_nt_test;
CREATE TABLE exchange_pt_test(
c1 NUMBER(10,2),
c2 varchar2(30)
) PARTITION BY RANGE (c1)
(
  PARTITION c1_15 VALUES LESS THAN (15),
  PARTITION c1_35 VALUES LESS THAN (35),
  PARTITION c1_50 VALUES LESS THAN (50)
);
insert into exchange_pt_test(c1) values(1);
insert into exchange_pt_test(c1) values(32);
insert into exchange_pt_test(c1) values(45);
CREATE TABLE exchange_nt_test(
c1 NUMBER(10,2),
c2 varchar2(30)
);
insert into exchange_nt_test(c1) values (3);
insert into exchange_nt_test(c1) values (18);
insert into exchange_nt_test(c1) values (33);
ALTER TABLE exchange_pt_test EXCHANGE PARTITION c1_15 WITH TABLE exchange_nt_test INCLUDING INDEXES WITHOUT VALIDATION;
ALTER TABLE exchange_pt_test MODIFY c1 NUMBER(10,2) UNIQUE;
ALTER TABLE exchange_pt_test EXCHANGE PARTITION c1_15 WITH TABLE exchange_nt_test INCLUDING INDEXES WITHOUT VALIDATION;
drop table exchange_pt_test;
drop table exchange_nt_test;

# 约束的状态必须完全一致, 否则不能进行分区交换
CREATE TABLE exchange_pt_test(
c1 NUMBER(10,2),
c2 varchar2(30)
)
PARTITION BY RANGE (c1)
(
  PARTITION c1_15 VALUES LESS THAN (15) COMPRESS basic,
  PARTITION c1_35 VALUES LESS THAN (35) COMPRESS basic,
  PARTITION c1_50 VALUES LESS THAN (50) COMPRESS basic
);
insert into exchange_pt_test values(1,1);
CREATE TABLE exchange_nt_test(
c1 NUMBER(10,2),
c2 varchar2(30)
);
insert into exchange_nt_test values (3,3);
ALTER TABLE exchange_pt_test ADD CONSTRAINT pt_check CHECK (c1 > 0);
ALTER TABLE exchange_nt_test ADD CONSTRAINT nt_check CHECK (c1 > 0);
ALTER TABLE exchange_pt_test MODIFY CONSTRAINT pt_check DISABLE;
--error 14118
ALTER TABLE exchange_pt_test EXCHANGE PARTITION c1_15 WITH TABLE exchange_nt_test INCLUDING INDEXES WITHOUT VALIDATION;

### 外键相关
# 检查外键(pt表和nt表都不允许用外键约束, 否则交换失败)
# 1、pt表不支持作为外键子表
--error 0, 942
drop table pt;
--error 0, 942
drop table nt;
--error 0, 942
drop table t0;
--error 0, 942
drop table t1;
create table nt(c1 int primary key, c2 int);
create table t0(c1 int primary key, c2 int);
create table pt(c1 int primary key, c2 int, constraint cs_pt foreign key (c2) references t0(c1)) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
drop table pt;
drop table t0;
# 2、pt表不支持作为外键父表;
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references pt(c1));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table t0;
drop table pt;
drop table nt;
# 3、nt表不支持作为外键子表
create table t0(c1 int primary key, c2 int);
create table nt(c1 int primary key, c2 int, constraint cs_nt foreign key (c2) references t0(c1));
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
drop table t0;
drop table pt;
# 4、nt表不支持作为外键父表
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references nt(c1));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table t0;
drop table pt;
drop table nt;
# 5、pt表和nt表都有外键约束不能执行分区交换
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references nt(c1));
create table t1(c1 int, c2 int, foreign key (c1) references pt(c1));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table t0;
drop table t1;
drop table pt;
drop table nt;

### 其他部分校验
# 列存校验
#cg 的偏移和cg的属性以及包含的列完全一致, 允许分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100)) WITH COLUMN GROUP(all columns, each column);
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30)) WITH COLUMN GROUP(all columns, each column);
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
#一个存在cg, 一个不存在cg, 不能执行分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100)) WITH COLUMN GROUP(all columns, each column);
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30));
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
#cg的个数不同, 不允许执行分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100)) WITH COLUMN GROUP(all columns, each column);
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30)) WITH COLUMN GROUP(all columns);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table nt;
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30)) WITH COLUMN GROUP(each column);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
#cg的id相等, 顺序相等的场景, 允许执行分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100));
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30));
alter table pt add column group (each column);
alter table nt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
#cg的id不等, 顺序相等的场景, 允许执行分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100));
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30));
alter table pt add column group (each column);
alter table nt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table nt drop column group (all columns);
alter table nt add column group (all columns);
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;
#cg的id相等, 顺序不相等的场景, 不允许执行分区交换, 目前已有的语法不能构造此场景
#cg的id不相等, 顺序不相等的场景, 不允许执行分区交换
CREATE TABLE pt(col1 NUMBER, col2 VARCHAR2(30)) partition by range(col1) (partition M1 values less than(10), partition M2 values less than(100));
CREATE TABLE nt(col1 NUMBER, col2 VARCHAR2(30));
alter table pt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table nt add column group (each column);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
drop table pt;
drop table nt;

# 相同定义的列存, cg id应该保持一致, 可以执行分区交换
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int) WITH COLUMN GROUP(all columns, each column);
alter table pt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table nt drop COLUMN GROUP(all columns, each column);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table nt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table pt drop COLUMN GROUP(all columns, each column);
--error 600
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table pt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M1 with table nt including indexes without validation;
alter table pt drop COLUMN GROUP(all columns);
