alter table pt exchange partition sp4 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;

###PT表和NT表的表级定义条件校验
 #两个不同表空间下的表进行分区交换
--error 0,600,959
drop tablespace pt_space;
--error 0,600,959
drop tablespace nt_space;
--error 0, 1543
create tablespace pt_space;
--error 0, 1543
create tablespace nt_space;
# 不同tablespace的表不支持分区交换
create table pt(c1 int primary key, c2 int) tablespace pt_space partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt(c1 int primary key, c2 int) tablespace nt_space;
--error 600
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 相同tablespace的表支持分区交换
create table pt(c1 int primary key, c2 int) tablespace pt_space partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt(c1 int primary key, c2 int) tablespace pt_space;
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# invisible列
create table pt (c1 number, c2 number invisible) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 number, c2 number);
--error 14097
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table nt;
create table nt (c1 number, c2 number invisible);
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 支持触发器
--error 0, 942
drop table employees;
--error 0, 942
drop table emp_msg;
CREATE TABLE employees (id INT, name VARCHAR2(20), WORK_YEAR int);
CREATE TABLE emp_msg (id INT PRIMARY KEY, name VARCHAR2(20), address VARCHAR2(100));
delimiter /;
CREATE OR REPLACE TRIGGER tri_emp_msg BEFORE INSERT OR UPDATE OR DELETE ON emp_msg
FOR EACH ROW
BEGIN
  IF INSERTING THEN
    INSERT INTO employees VALUES (:NEW.id, :NEW.name, 0);
  ELSIF DELETING THEN
    DELETE FROM employees WHERE id = :OLD.id;
  ELSE 
    UPDATE employees SET name = :NEW.name WHERE id = :NEW.id;
  END IF;
END;
/
delimiter ;/
CREATE TABLE pt (id INT PRIMARY KEY, name VARCHAR2(20), address VARCHAR2(100)) partition by range(id) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
alter table pt exchange partition M1 with table emp_msg INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table emp_msg;
drop table employees;

# 支持存储过程调用
--error 0, 942
drop table pt;
--error 0, 942
drop table nt;
CREATE TABLE pt (c1 int, log int DEFAULT 1) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
CREATE TABLE nt(c1 int, log int DEFAULT 1);
INSERT INTO nt (c1) VALUES (1);
INSERT INTO pt (c1) VALUES (1);
INSERT INTO nt (c1) VALUES (2);
INSERT INTO pt (c1) VALUES (2);
INSERT INTO nt (c1) VALUES (3);
INSERT INTO pt (c1) VALUES (3);
INSERT INTO nt (c1) VALUES (4);
INSERT INTO pt (c1) VALUES (4);
INSERT INTO nt (c1) VALUES (5);
INSERT INTO pt (c1) VALUES (5);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
delimiter /;
CREATE OR REPLACE PROCEDURE pro 
      IS
  BEGIN
      INSERT INTO nt (c1) VALUES (100);
      INSERT INTO pt (c1) VALUES (100);
  END;
  /
delimiter ;/
call pro();
select * from nt order by c1;
select * from pt order by c1;
drop table pt;
drop table nt;

# 支持函数调用
--error 0, 942
drop table obdept;
--error 0, 942
drop table partitioned_obdept;
CREATE TABLE obdept(  
    deptno           NUMBER(10,0),
    dname            VARCHAR(15),  
    loc            VARCHAR(20)
  );

CREATE TABLE partitioned_obdept(  
    deptno           NUMBER(10,0),  
    dname            VARCHAR(15),  
    loc              VARCHAR(20)
  )partition by range(deptno) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));

insert into partitioned_obdept values(1,1,1);
insert into partitioned_obdept values(2,1,1);
insert into partitioned_obdept values(3,1,1);
insert into partitioned_obdept values(4,1,1);
insert into partitioned_obdept values(5,1,1);
insert into partitioned_obdept values(6,1,1);
insert into partitioned_obdept values(7,1,1);
insert into partitioned_obdept values(8,1,1);
insert into partitioned_obdept values(9,1,1);

Select * from partitioned_obdept order by deptno;
Select * from obdept order by deptno;
alter table partitioned_obdept exchange partition M1 with table obdept INCLUDING INDEXES WITHOUT VALIDATION;

Select * from partitioned_obdept order by deptno;
Select * from obdept order by deptno;

delimiter /;
CREATE OR REPLACE PACKAGE obdemo_pack
    IS
        obDeptRec obdept%ROWTYPE;
        FUNCTION add_obdept(dept_no NUMBER, dept_name VARCHAR2, location VARCHAR2)
          RETURN NUMBER;
    END obdemo_pack;
    /

CREATE OR REPLACE PACKAGE BODY obdemo_pack
    IS 
FUNCTION add_obdept(dept_no NUMBER, dept_name VARCHAR2, location VARCHAR2)
    RETURN NUMBER
    IS 
    deptno_remaining EXCEPTION;
        PRAGMA EXCEPTION_INIT(deptno_remaining, -1);  -- -1 是违反唯一约束条件的错误代码 
BEGIN
    INSERT INTO obdept VALUES(dept_no, dept_name, location);
    IF SQL%FOUND THEN
        RETURN 1;
    END IF;
EXCEPTION
        WHEN deptno_remaining THEN 
        RETURN 0;
    WHEN OTHERS THEN
        RETURN -1;
END add_obdept;
  BEGIN
          Null;
  END obdemo_pack;
  /

DECLARE
    Var NUMBER;
BEGIN
    Var := obdemo_pack.add_obdept(900,'Administration', 'Beijing');
    IF var =-1 THEN
        DBMS_OUTPUT.PUT_LINE(SQLCODE||'----'||SQLERRM);
    ELSIF var =0 THEN
        DBMS_OUTPUT.PUT_LINE('该部门记录已经存在！');
    ELSE
        DBMS_OUTPUT.PUT_LINE('添加记录成功！');
    END IF;
END;
/
delimiter ;/
Select * from partitioned_obdept order by deptno;
Select * from obdept order by deptno;
drop table obdept;
drop table partitioned_obdept;

# PT表和NT表的table_type必须为用户表
CREATE TABLE t1 (id INT,  name VARCHAR(20));
INSERT INTO t1 VALUES (1, 'name1');
CREATE TABLE t2 (id INT, age INT);
INSERT INTO t2 VALUES (1, 23);
CREATE VIEW nt AS SELECT name, age FROM t1, t2 WHERE t1.id = t2.id; 
create table pt (name VARCHAR(20), age INT) partition by range(age)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
--error 600
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table t1;
drop table t2;
drop view nt;
drop table pt;

# rowkey column num必须相同
create table pt (c1 int, c2 int, primary key(c1)) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int, primary key(c1, c2));
--error 14098
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

#index column num必须相同
create table pt (c1 int, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
create index idx on nt(c2);
--error 14098
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 是否具有identity列
create table pt(c1 int generated always as identity, c2 int)partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt(c1 int, c2 int);
--error 600
alter table pt exchange partition M1 with table nt INCLUDING INDEXES WITHOUT VALIDATION;
drop table pt;
