### 索引相关
# 1、索引之间的交换通过索引名关联, 没有同名索引的话, 交换失败;
# 2、同名索引, 索引列的之间顺序也需要完全一致, 否则, 交换失败;
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create unique index idx on pt(c1, c2);
create unique index idx2 on nt(c1, c2);
insert into pt values(1, 1);
insert into nt values(2, 2);
select * from pt order by c1;
select * from nt order by c1;
--error 1736
alter table pt exchange partition M1 with table nt without validation;
alter table nt drop index idx2;
create unique index idx on nt(c1, c2);
alter table pt exchange partition M1 with table nt without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;

# 索引类型不一致, 交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create unique index idx on pt(c1, c2);
create index idx on nt(c1, c2);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;

#索引定义不一致, 交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2);
create index idx on nt(c1);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;

# 跳过全局索引, 局部存储的索引需要一一对应
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2) global;
create index idx1 on pt(c1);
create index idx1 on nt(c1);
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;

# 若两表的索引数量和结构都相同,且都为全局索引，交换失败
create table pt(c1 int, c2 char(10)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10));
create index idx on pt(c1, c2) global;
create index idx on nt(c1, c2) global;
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;
# 索引其他
drop table if exists pt_index_test1;
CREATE TABLE pt_index_test1 (c1 INT NOT NULL,c2 VARCHAR(50) NOT NULL,PRIMARY KEY (c1))
                            PARTITION BY RANGE(c1) (
                            PARTITION p1 VALUES LESS THAN (10),
                            PARTITION p2 VALUES LESS THAN (20),
                            PARTITION p3 VALUES LESS THAN (30));
drop table if exists nt_index_test1;
CREATE TABLE nt_index_test1 (c1 INT primary key NOT NULL,c2 VARCHAR(50) NOT NULL);
#NT表创建 普通索引 交换 PT无索引分区表, 预期报错
CREATE INDEX index_nt_c1 ON nt_index_test1 (c1);
--error 1736
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;
# NT普通索引 与PT 普通索引 分区交换, 索引名称不同
CREATE INDEX index_pt_c1 ON pt_index_test1 (c1);
--error 1736
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;
drop index index_pt_c1 on pt_index_test1;
#索引名字相同，分区交换成功。
CREATE INDEX index_nt_c1 ON pt_index_test1 (c1);
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;
#NT局部唯一索引与PT普通索引分区交换, 预期报错
CREATE UNIQUE INDEX idx_uq_nt_c1 ON nt_index_test1 (c1);
--error 1736
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;
#NT局部唯一索引与PT局部唯一索引分区交换, 索引名不同, 预期报错
CREATE UNIQUE INDEX idx_uq_pt_c1 ON pt_index_test1 (c1);
--error 1736
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;
drop index idx_uq_pt_c1 on pt_index_test1;
#索引名相同, 局部唯一索引交换分区, 成功交换
CREATE UNIQUE INDEX idx_uq_nt_c1 ON pt_index_test1 (c1);
ALTER TABLE pt_index_test1 EXCHANGE PARTITION p2 WITH TABLE nt_index_test1 WITHOUT VALIDATION;


### 约束相关校验
# 1、Unique约束
create table pt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3)) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
insert into pt values(50, 50, 50);
insert into nt values(60, 60, 60);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;
create table pt(c1 int primary key, c2 char(10), c3 int, unique(c1)) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3));
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;
create table pt(c1 int primary key, c2 char(10), c3 int, unique(c1, c3)) partition by range(c1)(partition M1 values less than(60), partition M2 values less than(100));
create table nt(c1 int primary key, c2 char(10), c3 int, unique(c3));
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;
# 2、NOT NULL约束
create table pt(c1 int, c2 char(10), c3 int not null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10) not null, c3 int);
--error 1736
alter table pt exchange partition M2 with table nt without validation;
drop table pt;
drop table nt;
create table pt(c1 int, c2 char(10), c3 int not null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int);
--error 1736
alter table pt exchange partition M2 with table nt without validation;
drop table pt;
create table pt(c1 int, c2 char(10) not null, c3 int) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
--error 1736
alter table pt exchange partition M2 with table nt without validation;
drop table pt;
drop table nt;
# 修改not null 属性, not null属性不同, 不允许交换
create table pt(c1 int, c2 char(10), c3 int default null) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int default null);
alter table pt exchange partition M2 with table nt without validation;
alter table nt modify c3 int not null;
--error 1736
alter table pt exchange partition M2 with table nt without validation;
drop table pt;
drop table nt;

# CHECK约束(要求check表达式完全一样,否则交换失败，不兼容mysql, 在mysql中支持check表达式不一致)
create table pt(c1 int, c2 char(10), c3 int, check(c1=50)) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, check(c2=c3));
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
# check约束相同, 允许交换, 且交换后约束不变
create table nt(c1 int, c2 char(10), c3 int, check(c1=50));
insert into pt values(50, 50, 50);
insert into nt values(50, 50, 50);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt without validation;
select * from pt order by c1;
select * from nt order by c1;
drop table pt;
drop table nt;


### 外键相关
# 检查外键(pt表和nt表都不允许用外键约束, 否则交换失败)
# 1、pt表不支持作为外键子表
create table nt(c1 int primary key, c2 int);
create table t0(c1 int primary key, c2 int);
create table pt(c1 int primary key, c2 int, constraint foreign key (c2) references t0(c1)) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
drop table pt;
drop table t0;
# 2、pt表不支持作为外键父表;
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references pt(c1));
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table t0;
drop table pt;
drop table nt;
# 3、nt表不支持作为外键子表
create table t0(c1 int primary key, c2 int);
create table nt(c1 int primary key, c2 int, constraint foreign key (c2) references t0(c1));
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
drop table t0;
drop table pt;
# 4、nt表不支持作为外键父表
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references nt(c1));
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table t0;
drop table pt;
drop table nt;
# 5、pt表和nt表都有外键约束不能执行分区交换
create table pt(c1 int primary key, c2 int) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int primary key, c2 int);
create table t0(c1 int, c2 int, foreign key (c1) references nt(c1));
create table t1(c1 int, c2 int, foreign key (c1) references pt(c1));
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table t0;
drop table t1;
drop table pt;
drop table nt;

