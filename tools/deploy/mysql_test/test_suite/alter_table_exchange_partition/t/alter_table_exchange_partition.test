connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync='BEFORE_ALTER_TABLE_EXCHANGE_PARTITION wait_for continue_signal'; 
connection conn1;
use database1;
send alter table pt exchange partition M3 with table nt without validation;
sleep 2;
connection conn2;
use database1;
send alter table pt drop column c3;
sleep 2;
connection obsys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
connection conn1;
reap;
connection conn2;
reap;

