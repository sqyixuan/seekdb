# 防止并行DDL操作
connection obsys;
alter system set debug_sync_timeout = '60s';
sleep 5;
set ob_global_debug_sync = 'reset';
connection conn1;
use database1;
create table pt (c1 bigint primary key , c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (500000), partition M2 VALUES LESS THAN (1000000), partition M3 VALUES LESS THAN (20000000));
