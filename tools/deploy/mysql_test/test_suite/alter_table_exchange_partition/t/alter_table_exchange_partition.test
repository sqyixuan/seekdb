### 分区交换作为增量旁路导入功能案例
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
# 创建一张分区表pt
create table pt (c1 int, c2 int, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (20));
insert into pt(c1, c2) values(1,1);
insert into pt(c1, c2) values(2,2);
insert into pt(c1, c2) values(3,3);
insert into pt(c1, c2) values(4,4);
insert into pt(c1, c2) values(5,5);
insert into pt(c1, c2) values(6,6);
insert into pt(c1, c2) values(7,7);
insert into pt(c1, c2) values(8,8);
insert into pt(c1, c2) values(9,9);
insert into pt(c1, c2) values(10,10);
insert into pt(c1, c2) values(11,11);
insert into pt(c1, c2) values(12,12);
insert into pt(c1, c2) values(13,13);
insert into pt(c1, c2) values(14,14);
insert into pt(c1, c2) values(15,15);
create index local_idx on pt(c1, c2);
create index pt_global_idx on pt(c2) global;
select * from pt order by c1;
# 创建一张和分区表格式相同的非分区表nt
create table nt (c1 int, c2 int, c3 blob);
insert into nt(c1, c2) values(21,21);
insert into nt(c1, c2) values(22,22);
insert into nt(c1, c2) values(23,23);
insert into nt(c1, c2) values(24,24);
insert into nt(c1, c2) values(25,25);
insert into nt(c1, c2) values(26,26);
insert into nt(c1, c2) values(27,27);
insert into nt(c1, c2) values(28,28);
insert into nt(c1, c2) values(29,29);
insert into nt(c1, c2) values(30,30);
insert into nt(c1, c2) values(31,31);
insert into nt(c1, c2) values(32,32);
insert into nt(c1, c2) values(33,33);
insert into nt(c1, c2) values(34,34);
insert into nt(c1, c2) values(35,35);
create index local_idx on nt(c1, c2);
select * from nt;
# 在分区表中新增加符合非分区表nt的分区
ALTER TABLE pt ADD PARTITION (PARTITION M4 VALUES LESS THAN(40));
select * from pt order by c1;
select * from nt order by c1;
# pt表的分区M4和非分区表nt执行分区交换操作
alter table pt exchange partition M4 with table nt WITHOUT VALIDATION;
select * from pt order by c1;
select * from nt order by c1;
# 向pt表中插入新的数据
insert into pt(c1, c2) values(36,36);
insert into pt(c1, c2) values(37,37);
insert into pt(c1, c2) values(38,38);
insert into pt(c1, c2) values(39,39);
select * from pt order by c1;
# 向nt表中插入新的数据
insert into nt(c1, c2) values(1,1);
insert into nt(c1, c2) values(2,2);
insert into nt(c1, c2) values(3,3);
insert into nt(c1, c2) values(4,4);
insert into nt(c1, c2) values(5,5);
insert into nt(c1, c2) values(6,6);
insert into nt(c1, c2) values(7,7);
insert into nt(c1, c2) values(8,8);
insert into nt(c1, c2) values(9,9);
insert into nt(c1, c2) values(10,10);
select * from nt order by c1;
# 在pt表中更新数据
update pt set c2 = -10 where c1 = 10;
update pt set c2 = -11 where c1 = 11;
update pt set c2 = -12 where c1 = 12;
select * from pt order by c1;
# 在nt表中更新数据
update nt set c2 = -1 where c1 = 1;
update nt set c2 = -2 where c1 = 2;
update nt set c2 = -3 where c1 = 3;
select * from nt order by c1;
# 在pt表中删除数据
delete from pt where c1 > 10;
select * from pt order by c1;
# 在nt表中删除数据
delete from nt where c1 > 5;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
select * from pt order by c1;
select * from nt order by c1;
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings

# 分区交换作为二级分区旁路导入功能案例
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings

CREATE TABLE pt(c1 INT,c2 INT)
       PARTITION BY RANGE(c1)
       SUBPARTITION BY RANGE(c2)
        (PARTITION p0 VALUES LESS THAN(100)
          (SUBPARTITION sp0 VALUES LESS THAN(2020),
           SUBPARTITION sp1 VALUES LESS THAN(2120)
          ),
         PARTITION p1 VALUES LESS THAN(200)
          (SUBPARTITION sp2 VALUES LESS THAN(2320),
           SUBPARTITION sp3 VALUES LESS THAN(2420),
           SUBPARTITION sp4 VALUES LESS THAN(2520)
           )
         );
insert into pt(c1, c2) values(1,2011);
insert into pt(c1, c2) values(2,2012);
insert into pt(c1, c2) values(3,2013);
insert into pt(c1, c2) values(4,2014);
insert into pt(c1, c2) values(5,2015);
insert into pt(c1, c2) values(6,2016);
insert into pt(c1, c2) values(7,2017);
insert into pt(c1, c2) values(8,2018);
insert into pt(c1, c2) values(9,2019);
insert into pt(c1, c2) values(10,2020);
insert into pt(c1, c2) values(11,2021);
insert into pt(c1, c2) values(12,2022);
insert into pt(c1, c2) values(13,2023);
insert into pt(c1, c2) values(14,2024);
insert into pt(c1, c2) values(15,2025);
create index local_idx on pt(c1, c2);
create index pt_global_idx on pt(c2) global;
select * from pt order by c1;
CREATE TABLE nt(c1 INT,c2 INT);
insert into nt(c1, c2) values(121,2421);
insert into nt(c1, c2) values(122,2422);
insert into nt(c1, c2) values(123,2423);
insert into nt(c1, c2) values(124,2424);
insert into nt(c1, c2) values(125,2425);
insert into nt(c1, c2) values(126,2426);
insert into nt(c1, c2) values(127,2427);
insert into nt(c1, c2) values(128,2428);
create index local_idx on nt(c1, c2);
select * from nt order by c1;
alter table pt exchange partition sp4 with table nt WITHOUT VALIDATION;
select * from pt order by c1;
select * from nt order by c1;
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings


###PT表和NT表的表级定义条件校验
# 测试跨DB的表进行交换
connection conn2;
--disable_warnings
drop database if exists database2;
create database database2;
use database2;
alter database database2 CHARACTER SET UTF8;
alter database database2 collate utf8mb4_general_ci;
alter database database2 CHARACTER SET UTF8 collate utf8mb4_general_ci;
--enable_warnings
create table nt (c1 int not null auto_increment primary key, c2 int);
connection conn1;
use database1;
create table pt (c1 int not null auto_increment primary key, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
--error 1235
alter table pt exchange partition M1 with table database2.nt WITHOUT VALIDATION;
drop table pt;

# 支持存储过程调用
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
CREATE TABLE pt (c1 int,update_time int NOT NULL DEFAULT 1 ) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
CREATE TABLE nt(c1 int, update_time int NOT NULL DEFAULT 1 );
INSERT INTO nt (c1) VALUES (1);
INSERT INTO pt (c1) VALUES (1);
INSERT INTO nt (c1) VALUES (2);
INSERT INTO pt (c1) VALUES (2);
INSERT INTO nt (c1) VALUES (3);
INSERT INTO pt (c1) VALUES (3);
INSERT INTO nt (c1) VALUES (4);
INSERT INTO pt (c1) VALUES (4);
INSERT INTO nt (c1) VALUES (5);
INSERT INTO pt (c1) VALUES (5);
select * from pt order by c1;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
delimiter /;
CREATE PROCEDURE pro()
BEGIN
    INSERT INTO nt (c1) VALUES (100);
    INSERT INTO pt (c1) VALUES (100);
END ;
/
delimiter ;/
call pro();
select * from nt order by c1;
select * from pt order by c1;
drop table pt;
drop table nt;

# 支持函数调用
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
create table pt(
  pid  int primary key,
  pname varchar(30)
) partition by range(pid)(
  partition M1 values less than(1000) ,
  partition M2 values less than(2000) ,
  partition M3 values less than(maxvalue)
);
insert into pt (pid, pname) values (1, '瑶瑶');
insert into pt (pid, pname) values (1500, '倩倩');
insert into pt (pid, pname) values (1400, '倩倩');
insert into pt (pid, pname) values (3000, '小花');
create table nt(
  pid  int primary key,
  pname varchar(30)
);
insert into nt (pid, pname) values (100, '张三');
insert into nt (pid, pname) values (101, '李四');
insert into nt (pid, pname) values (102, '王五');
select * from pt order by pid;
select * from nt order by pid;
alter table pt exchange partition M2 with table nt WITHOUT VALIDATION;
select * from pt order by pid;
select * from nt order by pid;
--disable_warnings
drop table if exists t2;
drop function  IF EXISTS n_1;
--enable_warnings
create table t2(id int ,s1 int, s2 int);
delimiter /;
create function n_1() returns int deterministic
begin
  insert into t2 values(1,0,1);
  return 1500;
end/
delimiter ;/
select n_1() from pt partition (M2) where pid <n_1();
#select * from t2 order by id;

# 支持触发器
--disable_warnings
drop table if exists test;
drop table if exists pt;
--enable_warnings
CREATE TABLE test (user_id INT, user_num DECIMAL(10,2));
create table pt (user_id INT, user_num DECIMAL(10,2)) partition by range(user_id)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
DELIMITER /;
CREATE TRIGGER test_trg BEFORE UPDATE ON test
FOR EACH ROW
BEGIN
IF NEW.user_num < 1 THEN
SET NEW.user_num  = 1;
ELSEIF NEW.user_num > 45 THEN
SET NEW.user_num= 45;
END IF;
END; 
/
DELIMITER ;/
alter table pt exchange partition M1 with table test WITHOUT VALIDATION;
drop table test;
# PT表和NT表的table_type必须为用户表
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists nt;
drop table if exists pt;
--enable_warnings
CREATE TABLE t1 (id INT,  name VARCHAR(20));
INSERT INTO t1 VALUES (1, 'name1');
CREATE TABLE t2 (id INT, age INT);
INSERT INTO t2 VALUES (1, 23);
CREATE VIEW nt AS SELECT name, age FROM t1, t2 WHERE t1.id = t2.id; 
create table pt (name VARCHAR(20), age INT) partition by range(age)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
--error 1235
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table t1;
drop table t2;
drop view nt;
drop table pt;

# rowkey column num必须相同
create table pt (c1 int, c2 int, primary key(c1)) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int, primary key(c1, c2));
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

#index column num必须相同
create table pt (c1 int, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
create index idx on nt(c2);
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 是否具有自增列
create table pt (c1 int auto_increment, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
--error 1235
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
drop table if exists pt_auto_test1;
CREATE TABLE pt_auto_test1 (c1 INT PRIMARY KEY auto_increment, c2 int) PARTITION BY RANGE(c1) (
                                                                    PARTITION p1 VALUES LESS THAN (10),
                                                                    PARTITION p2 VALUES LESS THAN (20),
                                                                    PARTITION p3 VALUES LESS THAN (30));
drop table if exists nt_auto_test1;
CREATE TABLE nt_auto_test1 (c1 INT primary KEY auto_increment, c2 int);
--error 1235
ALTER TABLE pt_auto_test1 EXCHANGE PARTITION p2 WITH TABLE nt_auto_test1 WITHOUT VALIDATION;

# read only属性
create table pt (c1 int, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
ALTER TABLE nt set READ ONLY;
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# compress_func_name 是否相同
#row_format=compressed
drop table if exists pt_compressed;
CREATE TABLE pt_compressed(c1 int primary key, c2 varchar(30))row_format=compressed PARTITION BY RANGE (c1)(
                                                                                    PARTITION c1_15 VALUES LESS THAN (15),
                                                                                    PARTITION c1_35 VALUES LESS THAN (35),
                                                                                    PARTITION c1_50 VALUES LESS THAN (50));
insert into pt_compressed(c1) values(20),(29),(35),(40),(15),(18);
drop table if exists nt_compressed;
CREATE TABLE nt_compressed(
    c1 int primary key,
    c2 varchar(30))row_format=compressed;
insert into nt_compressed values(200,'AA'),(90,null),(32,'SE'),(15,'GG');
select * from pt_compressed;
select * from nt_compressed;

ALTER TABLE pt_compressed EXCHANGE PARTITION c1_35 WITH TABLE nt_compressed WITHOUT VALIDATION;

select * from pt_compressed;
select * from pt_compressed partition(c1_35);
select * from nt_compressed;

#row_format=redundant
drop table if exists pt_redundant;
CREATE TABLE pt_redundant(c1 int primary key, c2 varchar(30))row_format=redundant PARTITION BY RANGE (c1) (
                                                                                  PARTITION c1_15 VALUES LESS THAN (15),
                                                                                  PARTITION c1_35 VALUES LESS THAN (35),
                                                                                  PARTITION c1_50 VALUES LESS THAN (50));
insert into pt_redundant(c1) values(20),(29),(35),(40),(15),(18);
drop table if exists nt_redundant;
CREATE TABLE nt_redundant(c1 int primary key, c2 varchar(30))row_format=redundant;
