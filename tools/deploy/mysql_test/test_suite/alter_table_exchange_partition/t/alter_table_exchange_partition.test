# 列存校验
connection conn1;
use database1;
# start test exchange partition
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
set ob_query_timeout = 100000000000000;
#一个存在cg, 一个不存在cg, 不能执行分区交换
create table pt (c1 bigint primary key, c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (50000), partition M2 VALUES LESS THAN (100000), partition M3 VALUES LESS THAN (200000));
create table nt (c1 bigint primary key, c2 bigint, c3 blob);
ALTER TABLE nt ADD COLUMN GROUP(each column);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE pt ADD COLUMN GROUP(each column);
#cg 的偏移和cg的属性以及包含的列完全一致, 允许分区交换
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE nt drop COLUMN GROUP(each column);
#一个存在cg, 一个不存在cg, 不能执行分区交换
--error 1731
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE pt drop COLUMN GROUP(each column);
#都不存在cg, 能执行分区交换
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE nt ADD COLUMN GROUP(all columns, each column);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE pt ADD COLUMN GROUP(all columns, each column);
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE nt drop COLUMN GROUP(each column);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
ALTER TABLE pt drop COLUMN GROUP(each column);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
#cg的id相等, 顺序相等的场景, 允许执行分区交换
create table pt (c1 bigint primary key, c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (50000), partition M2 VALUES LESS THAN (100000), partition M3 VALUES LESS THAN (200000));
create table nt (c1 bigint primary key, c2 bigint, c3 blob);
alter table pt add column group (each column);
alter table nt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
#cg的id不等, 顺序相等的场景, 允许执行分区交换
create table pt (c1 bigint primary key, c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (50000), partition M2 VALUES LESS THAN (100000), partition M3 VALUES LESS THAN (200000));
create table nt (c1 bigint primary key, c2 bigint, c3 blob);
alter table pt add column group (each column);
alter table nt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table nt drop column group (all columns);
alter table nt add column group (all columns);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
#cg的id相等, 顺序不相等的场景, 不允许执行分区交换, 目前已有的语法不能构造此场景
#cg的id不相等, 顺序不相等的场景, 不允许执行分区交换
# after v435, the cg id and cg order are not affected by the order of `add column group`
create table pt (c1 bigint primary key, c2 bigint, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (50000), partition M2 VALUES LESS THAN (100000), partition M3 VALUES LESS THAN (200000));
create table nt (c1 bigint primary key, c2 bigint, c3 blob);
alter table pt add column group (each column);
alter table pt add column group (all columns);
alter table nt add column group (all columns);
alter table nt add column group (each column);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
# 相同定义的列存, cg id应该保持一致, 可以执行分区交换
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int) WITH COLUMN GROUP(all columns, each column);
alter table pt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M3 with table nt without validation;
alter table nt drop COLUMN GROUP(all columns, each column);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
alter table nt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M3 with table nt without validation;
alter table pt drop COLUMN GROUP(all columns, each column);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
alter table pt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M3 with table nt without validation;
alter table pt drop COLUMN GROUP(all columns);
--error 1731
alter table pt exchange partition M3 with table nt without validation;
alter table pt add COLUMN GROUP(all columns);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int) WITH COLUMN GROUP(all columns, each column);
alter table pt add COLUMN GROUP(all columns, each column);
alter table pt exchange partition M3 with table nt without validation;
alter table pt drop COLUMN GROUP(each column);
alter table pt add COLUMN GROUP(each column);
alter table pt exchange partition M3 with table nt without validation;
alter table pt drop COLUMN GROUP(all columns);
alter table pt add COLUMN GROUP(all columns);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
alter table pt exchange partition M3 with table nt without validation;
alter table pt add COLUMN GROUP(each column);
alter table nt add COLUMN GROUP(each column);
alter table pt exchange partition M3 with table nt without validation;
alter table pt add COLUMN GROUP(all columns);
alter table nt add COLUMN GROUP(all columns);
alter table pt exchange partition M3 with table nt without validation;
alter table nt drop COLUMN GROUP(all columns);
alter table pt drop COLUMN GROUP(all columns);
alter table pt exchange partition M3 with table nt without validation;
alter table pt add COLUMN GROUP(all columns);
alter table nt add COLUMN GROUP(all columns);
alter table pt exchange partition M3 with table nt without validation;
alter table nt drop COLUMN GROUP(each column);
alter table pt drop COLUMN GROUP(each column);
alter table pt exchange partition M3 with table nt without validation;
alter table nt add COLUMN GROUP(each column);
alter table pt add COLUMN GROUP(each column);
alter table pt exchange partition M3 with table nt without validation;
drop table pt;
drop table nt;

# 主表列的column_id 不同, 列的其他属性相同, 允许进行分区交换
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
create table pt(c1 int, c2 char(10), primary key(c1,c2)) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), primary key(c1,c2));
create index pt_index on pt(c2(5));
create index pt_index on nt(c2(5));
alter table pt exchange partition M1 with table nt without validation;
alter table pt drop index pt_index;
create index pt_index on pt(c2(5));
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;

--echo # 一级分区表与一级分区表交换，不支持
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
--error 1235
alter table t1 exchange partition p3 with table t2 WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与二级分区表交换，不支持
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
--error 1235
alter table t1 exchange partition p1 with table t2 WITHOUT VALIDATION;
--error 1235
alter table t1 exchange partition p1sp3 with table t2 WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表交换，其中二级分区表的一级分区为hash分区，不支持
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int)
partition by hash(c1) partitions 10
subpartition by hash(c1) subpartitions 5;
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
--error 1235
alter table t1 exchange partition p1 with table t2 WITHOUT VALIDATION;
--error 1235
alter table t1 exchange partition p1sp3 with table t2 WITHOUT VALIDATION;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;

insert into t1 values (11, 30), (14, 40), (26, 150), (29, 160);
insert into t2 values (12, 20), (16, 110), (17, 170), (19, 120);
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);

--echo #一级分区表与二级分区表交换，不支持
--error 1235
alter table t2 exchange partition p1 with table t1 WITHOUT VALIDATION;

--echo #二级分区表与一级分区表交换，成功
alter table t1 exchange partition p1 with table t2 WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，带索引
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int)
partition by hash(c1) partitions 5;
create index k1 on t1(c1, c2) local;
create index k1 on t2(c1, c2) local;

insert into t1 values (11, 30), (14, 40), (26, 150), (29, 160);
insert into t2 values (12, 20), (16, 110), (17, 170), (19, 120);
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
set ob_enable_index_direct_select=1;
let $idx1 = query_get_value(select table_name from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't1'), table_name, 1);
let $idx2 = query_get_value(select table_name from oceanbase.__all_table where data_table_id = (select table_id from oceanbase.__all_table where table_name = 't2'), table_name, 1);
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

alter table t1 exchange partition p1 with table t2 WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，带lob列
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int, c3 text)
partition by range(c1)
subpartition by hash(c1) subpartitions 5
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
Partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int, c3 text)
partition by hash(c1) partitions 5;

insert into t1 values (11, 30, repeat('1', 5000)), (14, 40, repeat('1', 3000)), (26, 150, repeat('1', 4000)), (29, 160, repeat('1', 1000));
insert into t2 values (12, 20, repeat('2', 3000)), (16, 110, repeat('2', 4000)), (17, 170, repeat('2', 5000)), (19, 120, repeat('2', 6000));
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);

alter table t1 exchange partition p1 with table t2 WITHOUT VALIDATION;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，分区键不同
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int, c2 varchar(50), c3 int)
partition by range (c1)
subpartition by key (c3) subpartitions 2
(
    partition p0 values less than (100000),
    partition p1 values less than (MAXVALUE)
);
create table t2 (c1 int, c2 varchar(50), c3 int)
partition by key (c1) partitions 2;
insert into t2 values(1,'part1', 2), (90009,'part2', 4);
--error 1235
alter table t1 exchange partition p0 with table t2 without validation;
drop table t1;
drop table t2;

--echo # 二级分区表与一级分区表之间交换，list分区值不同
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (col1 int, col2 varchar(50), col3 int)
partition by list (col1)
subpartition by list (col3) (
  partition p0 values in (100, 200) (
    subpartition sp0 values in (1, 2, 3),
    subpartition sp1 values in (4, 5, 6)
  ),
  partition p1 values in (300, 400) (
    subpartition sp2 values in (7, 8, 9),
    subpartition sp3 values in (10, 11, 12)
  )
);
create table t2 (col1 int, col2 varchar(50), col3 int)
partition by list (col3)
(
  partition p0 values in (1,2,3),
  partition p1 values in (4,5,13)
);
insert into t2 values (100, 'list partition', 13);
--error 1235
alter table t1 exchange partition p0 with table t2 without validation;
drop table t1;
drop table t2;

--echo #二级分区表与一级分区表之间交换，range分区范围不同
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (col1 int, col2 varchar(50), col3 int)
partition by list (col1)
subpartition by range (col3) (
  partition p0 values in (100, 200) (
    subpartition sp0 values less than (10),
    subpartition sp1 values less than (20)
  ),
  partition p1 values in (300, 400) (
    subpartition sp2 values less than (30),
    subpartition sp3 values less than (40)
  )
);
create table t2 (col1 int, col2 varchar(50), col3 int)
partition by range (col3)
(
  partition sp0 values less than (10),
  partition sp1 values less than (30)
);
insert into t2 values(100, 'range partition', 23);
--error 1235
alter table t1 exchange partition p0 with table t2 without validation;
drop table t1;
drop table t2;
