### 分区交换基本语法执行
# 分区交换的两张表都是非分区表, 报错
create table pt (c1 int, c2 int);
create table nt (c1 int, c2 int);
--error 1505
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 分区交换一张表是分区表、一张表是非分区表, 且指定WITHOUT VALIDATION, 交换成功
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
#
# Mysql模式下, 分区表和非分区表做分区交换, 除了WITHOUT VALIDATION, 指定了其他语法，报错
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
--error 1064
alter table pt exchange partition M1 with table nt WITH VALIDATION;
drop table pt;
drop table nt;
--disable_warnings
drop table if exists test1;
--enable_warnings
CREATE TABLE test1(c1 int primary key, c2 varchar(30))PARTITION BY RANGE (c1)(
                                                     PARTITION c1_15 VALUES LESS THAN (15),
                                                     PARTITION c1_35 VALUES LESS THAN (35),
                                                     PARTITION c1_50 VALUES LESS THAN (50));
insert into test1(c1) values(1);
insert into test1(c1) values(2);
insert into test1(c1) values(36);
insert into test1(c1) values(38);
insert into test1(c1) values(40);
insert into test1(c1) values(45);
select * from test1;
drop table if exists test2;
CREATE TABLE test2(
    c1 int primary key,
    c2 varchar(30));
insert into test2(c1) values(40),(60);
select * from test2;
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITHOUT VALIDATION;
select * from test1 partition(c1_35);
#显示指定 INCLUDING INDEXES, 预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 INCLUDING INDEXES WITHOUT VALIDATION;
#不加 without validation,预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2;
#带有update indexes 预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE INDEXES;
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE GLOBAL INDEXES;
#with VALIDATION 预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITH VALIDATION;
# 交换的分区表的一级分区不存在
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
--error 1735
alter table pt exchange partition M111 with table nt WITHOUT VALIDATION;
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 交换的分区表的二级分区不存在
CREATE TABLE pt(c1 INT,c2 INT) PARTITION BY RANGE(c1) 
       SUBPARTITION BY RANGE(c1)
       SUBPARTITION TEMPLATE
       (SUBPARTITION mp1 VALUES LESS THAN(100),
        SUBPARTITION mp2 VALUES LESS THAN(200),
        SUBPARTITION mp3 VALUES LESS THAN(300)
        )
       (PARTITION p0 VALUES LESS THAN(2020),
        PARTITION p1 VALUES LESS THAN(2021),
        PARTITION p2 VALUES LESS THAN(2022)
        );
CREATE TABLE nt(c1 INT,c2 INT);
--error 1735,5830
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
alter table pt exchange partition p0smp1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 二级分区表交换一级分区
CREATE TABLE pt(c1 INT,c2 INT) PARTITION BY RANGE(c1)
       SUBPARTITION BY RANGE(c1)
       SUBPARTITION TEMPLATE
       (SUBPARTITION mp1 VALUES LESS THAN(100),
        SUBPARTITION mp2 VALUES LESS THAN(200),
        SUBPARTITION mp3 VALUES LESS THAN(300)
        )
       (PARTITION p0 VALUES LESS THAN(2020),
        PARTITION p1 VALUES LESS THAN(2021),
        PARTITION p2 VALUES LESS THAN(2022)
        );
CREATE TABLE nt(c1 INT,c2 INT);
--error 1734
alter table pt exchange partition p0 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 一级分区表不是range分区
CREATE TABLE pt (c1 BIGINT PRIMARY KEY,c2 VARCHAR(50))
       PARTITION BY LIST(c1) 
        (PARTITION p0 VALUES IN (1, 2, 3),
         PARTITION p1 VALUES IN (5, 6),
         PARTITION p2 VALUES IN (DEFAULT)
        );
CREATE TABLE nt (c1 BIGINT PRIMARY KEY,c2 VARCHAR(50));
--error 1235
alter table pt exchange partition p0 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;
# 二级分区表不是range分区
CREATE TABLE pt(c1 INT,c2 INT) 
       PARTITION BY LIST COLUMNS(c1)
       SUBPARTITION BY LIST COLUMNS(c2)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION mp0 VALUES IN(2),
         SUBPARTITION mp1 VALUES IN(5),
         SUBPARTITION mp2 VALUES IN(8)
        )
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9)
        );
CREATE TABLE nt(c1 INT,c2 INT);
--error 1235
alter table pt exchange partition p0smp0 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 测试主键表之间的交换
create table pt (c1 int not null auto_increment primary key, c2 int) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int not null auto_increment primary key, c2 int);
--error 1235
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

