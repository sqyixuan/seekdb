# BLOCK_SIZE 是否相同
--disable_warnings
drop table if exists pt;
drop table if exists nt;
--enable_warnings
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
ALTER TABLE pt BLOCK_SIZE = 2048;
ALTER TABLE nt BLOCK_SIZE = 1024;
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# collation_type 是否相同
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int);
ALTER TABLE pt CHARACTER SET = utf8mb4 COLLATE = utf8mb4_bin;
ALTER TABLE nt CHARACTER SET = utf8mb4 COLLATE = utf8mb4_general_ci;
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# table group 是否相同
--disable_warnings
drop tablegroup if exists myTableGroup1;
drop tablegroup if exists myTableGroup2;
--enable_warnings
CREATE TABLEGROUP myTableGroup1;
CREATE TABLEGROUP myTableGroup2;
create table pt (c1 int, c2 int) TABLEGROUP = myTableGroup1 partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int) TABLEGROUP = myTableGroup2;
--error 1736
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;

# 复制表
create table pt (c1 int, c2 int) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
create table nt (c1 int, c2 int) ;
--error 0,4179
alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
drop table pt;
drop table nt;


### 列级属性校验
# 1、交换两表的列名需要一一对应(Mysql模式大小写不敏感)
# pt:c1->c2->c3->c4
# nt: c1->c2
create table pt(c1 int, c2 char(10)) partition by range(c1) (partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, C2 char(10));
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c2 char(10), c1 int, c3 int);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c1 int, c2 int, c3 int);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c1 int, c22 char(10), c33 int);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c1 int, c2 char(10), c3 int);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;
#列名 不一致交换
drop table if exists test1;
CREATE TABLE test1(c1 int primary key, c2 varchar(30))PARTITION BY RANGE (c1)(PARTITION p1 VALUES LESS THAN (20),PARTITION p2 VALUES LESS THAN (40),PARTITION p3 VALUES LESS THAN (60));
insert into test1(c1) values(19),(20),(22),(36),(40),(59);
drop table if exists test2;
CREATE TABLE test2(cl1 int primary key, c2 varchar(30));
insert into test2 values(-80,'ADX'),(9999,'CD'),(0,'ZXV');
--error 1736
ALTER TABLE test1 EXCHANGE PARTITION p2 WITH TABLE test2 WITHOUT VALIDATION;
#列名大小写不一致
drop table if exists test3;
CREATE TABLE test3(C1 int primary key, c2 varchar(30));
insert into test3 values(666,'ADX'),(9999,'CD'),(0123,'ZXV');
ALTER TABLE test1 EXCHANGE PARTITION p2 WITH TABLE test3 WITHOUT VALIDATION;
select * from test1;
select * from test1 partition(p2);
select * from test3;

# 2、虚拟生成列列名、顺序、类型在nt、pt表需要一一对应, 但表达式不作要求
# pt:c1->c2->c3->c4(c1+1)(virtual)
# nt:c1->c2->c3->c5(c1+1)(virtual)
create table pt(c1 int, c2 char(10), c3 int, c4 int generated always as(c1+1) virtual) partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, c5 int generated always as(c1+1) virtual);
--error 1736
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c1 int, c2 char(10), c3 int, c4 int generated always as(c2+1) virtual);
alter table pt exchange partition M1 with table nt without validation;
# 3、存储生成列要求表达式和列类, 列名完全对应
drop table pt;
drop table nt;
create table pt(c1 int, c2 char(10), c3 int, c4 int generated always as(c1+1) stored)partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, c4 int generated always as(c2+1) stored);
--error 1235
alter table pt exchange partition M1 with table nt without validation;
drop table nt;
create table nt(c1 int, c2 char(10), c3 int, c4 int generated always as(c1+1) stored);
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;
# 4、存储列和生成列不能交换
create table pt(c1 int, c2 char(10), c3 int, c4 int generated always as(c1+1) virtual)partition by range(c1)(partition M1 values less than(10), partition M2 values less than(100));
create table nt(c1 int, c2 char(10), c3 int, c4 int generated always as(c1+1) stored);
--error 3106
alter table pt exchange partition M1 with table nt without validation;
drop table pt;
drop table nt;

