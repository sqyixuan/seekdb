# owner: zuojiao.hzj
# owner group: sql2
# description: 【系统租户下修改配置 - MYSQL生成列（虚拟列/存储列）】 
# tags: ddl
# author: whh01047778

--echo # 环境清理
purge recyclebin;
--result_format 4


--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);


--echo # oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 1
connection conn1;
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 1 tenant sys;
alter system set _rowsets_max_rows = 1 tenant all_user;
alter system set _rowsets_max_rows = 1 tenant all_meta;
alter system flush plan cache global;
connection default;
--source mysql_test/test_suite/generate_addcase_mysql_oracle_sqlqa/t/generate_addcase_mysql.inc


connection conn1;
--echo # oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 2
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 2 tenant sys;
alter system set _rowsets_max_rows = 2 tenant all_user;
alter system set _rowsets_max_rows = 2 tenant all_meta;
alter system flush plan cache global;
connection default;
--source mysql_test/test_suite/generate_addcase_mysql_oracle_sqlqa/t/generate_addcase_mysql.inc


connection conn1;
--echo # oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 4
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 4 tenant sys;
alter system set _rowsets_max_rows = 4 tenant all_user;
alter system set _rowsets_max_rows = 4 tenant all_meta;
alter system flush plan cache global;
connection default;
--source mysql_test/test_suite/generate_addcase_mysql_oracle_sqlqa/t/generate_addcase_mysql.inc


connection conn1;
--echo # oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 8
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 8 tenant sys;
alter system set _rowsets_max_rows = 8 tenant all_user;
alter system set _rowsets_max_rows = 8 tenant all_meta;
alter system flush plan cache global;
connection default;
--source mysql_test/test_suite/generate_addcase_mysql_oracle_sqlqa/t/generate_addcase_mysql.inc


connection conn1;
--echo # oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 16
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 16 tenant sys;
alter system set _rowsets_max_rows = 16 tenant all_user;
alter system set _rowsets_max_rows = 16 tenant all_meta;
alter system flush plan cache global;
connection default;
--source mysql_test/test_suite/generate_addcase_mysql_oracle_sqlqa/t/generate_addcase_mysql.inc

purge recyclebin;

connection conn1;
alter system set _rowsets_max_rows = 256 tenant sys;
alter system set _rowsets_max_rows = 256 tenant all_user;
alter system set _rowsets_max_rows = 256 tenant all_meta;
disconnect conn1;

