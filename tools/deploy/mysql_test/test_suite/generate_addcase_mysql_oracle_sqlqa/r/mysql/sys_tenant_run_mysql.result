|      10 |      10 |      10 |      20 |      30 |      40 |      50 |      60 |       10 |       20 |       30 |       40 |       50 |       60 |      70 |      80 |       70 |       80 |
|      20 |      20 |      20 |      40 |      60 |      80 |     100 |     120 |       20 |       40 |       60 |       80 |      100 |      120 |     140 |     160 |      140 |      160 |
|      20 |      20 |      20 |      40 |      60 |      80 |     100 |     120 |       20 |       40 |       60 |       80 |      100 |      120 |     140 |     160 |      140 |      160 |
|      30 |      30 |      30 |      60 |      90 |     120 |     150 |     180 |       30 |       60 |       90 |      120 |      150 |      180 |     210 |     240 |      210 |      240 |
|      30 |      30 |      30 |      60 |      90 |     120 |     150 |     180 |       30 |       60 |       90 |      120 |      150 |      180 |     210 |     240 |      210 |      240 |
