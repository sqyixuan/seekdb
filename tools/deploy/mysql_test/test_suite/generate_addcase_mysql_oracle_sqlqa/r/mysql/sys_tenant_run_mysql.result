| z0_col1  | int(11) | YES  |     | NULL            |                   |
| z0_col2  | int(11) | YES  |     | (`z0_col0` * 1) | VIRTUAL GENERATED |
| z0_col3  | int(11) | YES  |     | (`z0_col0` * 2) | VIRTUAL GENERATED |
| z0_col4  | int(11) | YES  |     | (`z0_col0` * 3) | VIRTUAL GENERATED |
| z0_col5  | int(11) | YES  |     | (`z0_col0` * 4) | VIRTUAL GENERATED |
| z0_col6  | int(11) | YES  |     | (`z0_col0` * 5) | VIRTUAL GENERATED |
| z0_col7  | int(11) | YES  |     | (`z0_col0` * 6) | VIRTUAL GENERATED |
| z0_col10 | int(11) | YES  |     | (`z0_col1` * 1) | STORED GENERATED  |
| z0_col11 | int(11) | YES  |     | (`z0_col1` * 2) | STORED GENERATED  |
| z0_col12 | int(11) | YES  |     | (`z0_col1` * 3) | STORED GENERATED  |
| z0_col13 | int(11) | YES  |     | (`z0_col1` * 4) | STORED GENERATED  |
| z0_col14 | int(11) | YES  |     | (`z0_col1` * 5) | STORED GENERATED  |
| z0_col15 | int(11) | YES  |     | (`z0_col1` * 6) | STORED GENERATED  |
| z0_col8  | int(11) | YES  |     | (`z0_col0` * 7) | VIRTUAL GENERATED |
| z0_col9  | int(11) | YES  |     | (`z0_col0` * 8) | VIRTUAL GENERATED |
| z0_col16 | int(11) | YES  |     | (`z0_col1` * 7) | STORED GENERATED  |
| z0_col17 | int(11) | YES  |     | (`z0_col1` * 8) | STORED GENERATED  |
+----------+---------+------+-----+-----------------+-------------------+
drop user whh@'%';
drop database IF EXISTS whh ;
PURGE RECYCLEBIN;
# oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 2
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 2 tenant sys;
alter system set _rowsets_max_rows = 2 tenant all_user;
alter system set _rowsets_max_rows = 2 tenant all_meta;
alter system flush plan cache global;
# 环境清理
purge recyclebin;
result_format: 4
drop user whh@'%';
drop database if exists whh ;
create user whh identified by 'whh';
create database whh ;
grant all on *.* to whh WITH GRANT OPTION;


