|      20 |      20 |      20 |      40 |      60 |      80 |     100 |     120 |       20 |       40 |       60 |       80 |      100 |      120 |
|      30 |      30 |      30 |      60 |      90 |     120 |     150 |     180 |       30 |       60 |       90 |      120 |      150 |      180 |
+---------+---------+---------+---------+---------+---------+---------+---------+----------+----------+----------+----------+----------+----------+
alter table test_table1 add z0_col8 int as (z0_col0*7) virtual;
