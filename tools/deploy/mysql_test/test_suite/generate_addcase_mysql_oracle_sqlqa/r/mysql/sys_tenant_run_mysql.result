drop view view1;
create view view1 as select t1.z0_col0,t1.z0_col1,t1.z0_col2,t2.z1_col0,t2.z1_col1,t2.z1_col2 from virtual_table1 t1 inner join stored_table2 t2 on t1.id=t2.id order by 1;
