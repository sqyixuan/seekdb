############ mysql_genrate-1-5 PL/SQL
### 函数
drop table test_table1;
create table test_table1(
z0_col0 int primary key,
z0_col1 int,
z0_col2 int as(z0_col0+z0_col1) virtual,
z0_col3 int as(z0_col0*z0_col1) stored
);
