|    1 | NULL           | NULL    | NULL              |
|    0 | 0              | 0       | 00                |
|    3 | 100            | 10.00   | 10010.00          |
|    2 | virtual_table1 | one     | virtual_table1one |
+------+----------------+---------+-------------------+
drop table stored_table2;
create  table stored_table2 (
id int,
z1_col0 char(100), 
z1_col1 varchar(100),
z1_col2 varchar(100) as (concat(z1_col0,z1_col1)) stored);
