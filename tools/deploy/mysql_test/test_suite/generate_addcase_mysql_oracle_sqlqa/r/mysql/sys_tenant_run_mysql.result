# 环境清理
purge recyclebin;
result_format: 4


# oracle_genrate-1-1 系统租户下修改配置 _rowsets_max_rows = 1
alter system set _rowsets_enabled = true tenant sys;
alter system set _rowsets_enabled = true tenant all_user;
alter system set _rowsets_enabled = true tenant all_meta;
alter system set _rowsets_max_rows = 1 tenant sys;
alter system set _rowsets_max_rows = 1 tenant all_user;
alter system set _rowsets_max_rows = 1 tenant all_meta;
alter system flush plan cache global;
# 环境清理
purge recyclebin;
result_format: 4
drop user whh@'%';
drop database if exists whh ;
create user whh identified by 'whh';
create database whh ;
grant all on *.* to whh WITH GRANT OPTION;


#############################################################################################
############ mysql_genrate-1-2 作为分区键
### key分区
drop table virtual_table;
create table virtual_table(
z0_col0 int, 
z0_col1 int,
z0_col2 int as(z0_col0+z0_col1)) 
partition by key(z0_col2) partitions 2;
insert into virtual_table (z0_col0,z0_col1) values (0,0),(NULL,NULL),(1.111,222),(10,10);
select z0_col0,z0_col1,z0_col2 from virtual_table partition(p0) order by z0_col2;
+---------+---------+---------+
| z0_col0 | z0_col1 | z0_col2 |
+---------+---------+---------+
|      10 |      10 |      20 |
|       1 |     222 |     223 |
+---------+---------+---------+
select z0_col0,z0_col1,z0_col2 from virtual_table partition(p1) order by z0_col2;
+---------+---------+---------+
| z0_col0 | z0_col1 | z0_col2 |
+---------+---------+---------+
|    NULL |    NULL |    NULL |
|       0 |       0 |       0 |
+---------+---------+---------+
explain select z0_col0,z0_col1,z0_col2 from virtual_table where z0_col2 = 0 order by z0_col2;
Query Plan
========================================================
|ID|OPERATOR       |NAME         |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |TABLE FULL SCAN|virtual_table|1       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([virtual_table.z0_col0], [virtual_table.z0_col1], [column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1,
       0)))]), filter([column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0))) = 0])
      access([virtual_table.z0_col0], [virtual_table.z0_col1]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([virtual_table.__pk_increment]), range(MIN ; MAX)always true
explain select z0_col0,z0_col1,z0_col2 from virtual_table where z0_col0+z0_col1 = 0 order by z0_col2;
Query Plan
====================================================================
|ID|OPERATOR                   |NAME         |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT  |             |1       |7           |
|1 |└─EXCHANGE OUT DISTR       |:EX10000     |1       |6           |
|2 |  └─SORT                   |             |1       |5           |
|3 |    └─PX PARTITION ITERATOR|             |1       |5           |
|4 |      └─TABLE FULL SCAN    |virtual_table|1       |5           |
====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(virtual_table.z0_col0, virtual_table.z0_col1, column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1,
       INT(-1, 0))))]), filter(nil)
      sort_keys([column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0))), ASC])
  1 - output([column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0)))], [INTERNAL_FUNCTION(virtual_table.z0_col0,
       virtual_table.z0_col1, column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0))))]), filter(nil)
      dop=1
  2 - output([column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0)))], [virtual_table.z0_col0], [virtual_table.z0_col1]), filter(nil)
      sort_keys([column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1, 0))), ASC])
  3 - output([virtual_table.z0_col0], [virtual_table.z0_col1], [column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1,
       0)))]), filter(nil)
      force partition granule
  4 - output([virtual_table.z0_col0], [virtual_table.z0_col1], [column_conv(INT,PS:(11,0),NULL,cast(virtual_table.z0_col0 + virtual_table.z0_col1, INT(-1,
       0)))]), filter([virtual_table.z0_col0 + virtual_table.z0_col1 = 0])
      access([virtual_table.z0_col0], [virtual_table.z0_col1]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([virtual_table.__pk_increment]), range(MIN ; MAX)always true
