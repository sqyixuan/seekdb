drop table t1;
drop procedure calc_index_cost;
create procedure calc_index_cost(ddl_sql varchar(1000))
begin
declare u_bytes decimal;
declare a_bytes decimal;
call dbms_space.create_index_cost (
ddl => ddl_sql,
used_bytes => u_bytes,
alloc_bytes => a_bytes);
select a_bytes as 'actual bytes';
# u_bytes is unstable, do not print it.
end;
//
create table t1(c1 int, c2 float, c3 varchar(100), c4 char(100), c5 date, c6 longtext);
insert into t1 values (1, 1.0, '1000000000', '1000000000', now(), '10000000000000000000');
alter system minor freeze;
#### without optimizer statistics
## single column index
call calc_index_cost('create index i1 on t1(c1)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c2)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c3)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c4)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c5)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c6)');
actual bytes
2097152
#### multi column index
call calc_index_cost('create index i1 on t1(c1,c2)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c3)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c4)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c5)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c6)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5,c6)');
actual bytes
2097152
#### with optimizer statistics
call dbms_stats.gather_table_stats(null, 'T1');
call calc_index_cost('create index i1 on t1(c1)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c2)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c3)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c4)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c5)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c6)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c4)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c5)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c6)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3)');
actual bytes
2097152
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4)');
