#### insert 100K rows
drop table lineitem;
create table lineitem(
l_orderkey           number NOT NULL ,
l_partkey            number NOT NULL ,
l_suppkey            number NOT NULL ,
l_linenumber         number NOT NULL ,
l_quantity           number NOT NULL ,
l_extendedprice      number(10,2) NOT NULL ,
l_discount           number(10,2) NOT NULL ,
l_tax                number(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44)
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
select count(*) from lineitem;
count(*)
1000000
alter system minor freeze;
call dbms_stats.gather_table_stats(null, 'LINEITEM');
call calc_index_cost('create index i1 on lineitem(l_orderkey)');
actual bytes
2097152
call calc_index_cost('create index i1 on lineitem(l_linenumber)');
actual bytes
2097152
call calc_index_cost('create index i1 on lineitem(l_shipdate)');
actual bytes
2097152
call calc_index_cost('create index i1 on lineitem(l_comment)');
actual bytes
4194304
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey)');
actual bytes
2097152
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey, l_suppkey)');
actual bytes
4194304
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey, l_suppkey, l_comment)');
actual bytes
8388608
drop table t1;
drop table lineitem;
drop procedure calc_index_cost;
