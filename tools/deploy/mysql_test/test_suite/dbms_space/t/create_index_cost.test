# owner: jianyun.sjy
# owner group: ddl
# tags: ddl, create_index

--source mysql_test/test_suite/dbms_space/include/copy_data_for_dbms_space.inc
--enable_result_log
--error 0, 1051
drop table t1;
--error 0, 1305
drop procedure calc_index_cost;

delimiter //;
create procedure calc_index_cost(ddl_sql varchar(1000))
begin
declare u_bytes decimal;
declare a_bytes decimal;
call dbms_space.create_index_cost (
    ddl => ddl_sql,
    used_bytes => u_bytes,
    alloc_bytes => a_bytes);
select a_bytes as 'actual bytes';
# u_bytes is unstable, do not print it.
end;
//
delimiter ;//

create table t1(c1 int, c2 float, c3 varchar(100), c4 char(100), c5 date, c6 longtext);
insert into t1 values (1, 1.0, '1000000000', '1000000000', now(), '10000000000000000000');
--source mysql_test/include/minor_merge_tenant.inc
--echo #### without optimizer statistics
--echo ## single column index
call calc_index_cost('create index i1 on t1(c1)');
call calc_index_cost('create index i1 on t1(c2)');
call calc_index_cost('create index i1 on t1(c3)');
call calc_index_cost('create index i1 on t1(c4)');
call calc_index_cost('create index i1 on t1(c5)');
call calc_index_cost('create index i1 on t1(c6)');

--echo #### multi column index
call calc_index_cost('create index i1 on t1(c1,c2)');
call calc_index_cost('create index i1 on t1(c1,c3)');
call calc_index_cost('create index i1 on t1(c1,c4)');
call calc_index_cost('create index i1 on t1(c1,c5)');
call calc_index_cost('create index i1 on t1(c1,c6)');
call calc_index_cost('create index i1 on t1(c1,c2,c3)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5,c6)');

--echo #### with optimizer statistics
call dbms_stats.gather_table_stats(null, 'T1');
call calc_index_cost('create index i1 on t1(c1)');
call calc_index_cost('create index i1 on t1(c2)');
call calc_index_cost('create index i1 on t1(c3)');
call calc_index_cost('create index i1 on t1(c4)');
call calc_index_cost('create index i1 on t1(c5)');
call calc_index_cost('create index i1 on t1(c6)');
call calc_index_cost('create index i1 on t1(c1,c2)');
call calc_index_cost('create index i1 on t1(c1,c4)');
call calc_index_cost('create index i1 on t1(c1,c5)');
call calc_index_cost('create index i1 on t1(c1,c6)');
call calc_index_cost('create index i1 on t1(c1,c2,c3)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5)');
call calc_index_cost('create index i1 on t1(c1,c2,c3,c4,c5,c6)');

--echo #### insert 100K rows
--error 0,1051
drop table lineitem;
create table lineitem(
    l_orderkey           number NOT NULL ,
    l_partkey            number NOT NULL ,
    l_suppkey            number NOT NULL ,
    l_linenumber         number NOT NULL ,
    l_quantity           number NOT NULL ,
    l_extendedprice      number(10,2) NOT NULL ,
    l_discount           number(10,2) NOT NULL ,
    l_tax                number(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44)
);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
--disable_query_log
eval load data /*+ direct(true,0) parallel(2) load_batch_size(100) */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem-1m.tbl' into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
select count(*) from lineitem;

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 'LINEITEM');
call calc_index_cost('create index i1 on lineitem(l_orderkey)');
call calc_index_cost('create index i1 on lineitem(l_linenumber)');
call calc_index_cost('create index i1 on lineitem(l_shipdate)');
call calc_index_cost('create index i1 on lineitem(l_comment)');
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey)');
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey, l_suppkey)');
call calc_index_cost('create index i1 on lineitem(l_orderkey, l_partkey, l_suppkey, l_comment)');

drop table t1;
drop table lineitem;
drop procedure calc_index_cost;
