#owner: sean.yyj
#owner group: SQL-优化器
#description: mysql case迁移
#tags: ddl,dml,pl



--echo # privileges

--disable_warnings
--error 0,1396
drop user user1@'%';
drop database if exists mysqltest1;
--enable_warnings

create database mysqltest1;
CREATE USER user1 identified by 'Mysql@20230710';
grant all on *.* to user1 WITH GRANT OPTION;
use mysqltest1;

--error 0,1051
DROP TABLE t1;
create table t1(pub int, priv int);
insert into t1 values(1,2);
#analyze table t1;

#--error 1064
GRANT SELECT (pub) ON mysqltest1.t1 TO user1;

#connect (user1, localhost, user1, ,);

--source mysql_test/include/check_schema_sync.inc
connect(user1,$OBMYSQL_MS0,user1,Mysql@20230710,mysqltest1,$OBMYSQL_PORT);
connection user1;

use mysqltest1;

--sorted_result
select pub from t1;
#--error 1143
select priv from t1;

--sorted_result
select * from (select pub from t1) as dt;
--disable_result_log
explain select * from (select pub from t1) as dt;
--enable_result_log
#--error 1143
select /*+ merge(dt) */ * from (select priv from t1) as dt;
#--error 1143
select /*+ no_merge(dt) */ * from (select priv from t1) as dt;
#--error 1143
--disable_result_log
explain select * from (select priv from t1) as dt;
--enable_result_log

--sorted_result
with qn as (select pub from t1) select * from qn;
--disable_result_log
explain with qn as (select pub from t1) select * from qn;
--enable_result_log
#--error 1143
with qn as (select priv from t1) select /*+ merge(qn) */ * from qn;
#--error 1143
with qn as (select priv from t1) select /*+ no_merge(qn) */ * from qn;
#--error 1143
--disable_result_log
explain with qn as (select priv from t1) select * from qn;
--enable_result_log

--sorted_result
with qn2 as (with qn as (select pub from t1) select * from qn)
select * from qn2;
#--error 1143
with qn2 as (with qn as (select priv from t1) select * from qn)
select * from qn2;

connection default;
disconnect user1;
drop user user1;
drop database mysqltest1;
