#owner: sean.yyj
#owner group: SQL-优化器
#description: mysql case迁移
#tags: ddl,dml,pl


--echo #
--echo # Bug #30628160: DYNAMIC PRIVILEGES CAN BE GRANTED AT PROCEDURE/FUNCTION LEVEL
--echo #

CREATE SCHEMA if not exists B30628160;
--error 0,1396
DROP USER B30628160;

--error 0,1305
DROP PROCEDURE B30628160.p1;
CREATE PROCEDURE B30628160.p1() SELECT 1;

CREATE USER B30628160 identified by 'Mysql@20230710';

--echo # The test: must fail.
#--error ER_ILLEGAL_PRIVILEGE_LEVEL
--error 1149
GRANT xyzzy ON PROCEDURE B30628160.p1 TO B30628160;

DROP USER B30628160;
DROP SCHEMA B30628160;

--echo # End of 8.0 tests
