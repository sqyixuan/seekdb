#owner: dachuan.sdc
#owner group: SQL-执行器
#description: mysql case迁移
#tags: ddl,dml,datatype,timestamp


#--source mysql_test/test_suite/mysql8_t_2/include/force_myisam_default.inc
#--source mysql_test/test_suite/mysql8_t_2/include/have_myisam.inc

SET sql_mode = 'NO_ENGINE_SUBSTITUTION';

--error 0,1051
DROP TABLE t1;
CREATE TABLE t1 (
`id` int(11) NOT NULL auto_increment,
`username` varchar(80) NOT NULL default '',
`posted_on` timestamp NOT NULL default '0000-00-00 00:00:00',
PRIMARY KEY (`id`)
) ENGINE=MyISAM DEFAULT CHARSET=latin1 AUTO_INCREMENT=1;

show fields from t1;
--disable_warnings
select is_nullable from INFORMATION_SCHEMA.COLUMNS where TABLE_NAME='t1' and COLUMN_NAME='posted_on' and TABLE_SCHEMA= database();
--enable_warnings
drop table t1;
