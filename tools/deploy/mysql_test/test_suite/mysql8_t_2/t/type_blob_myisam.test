#owner: chaser.ch
#owner group: 底层引擎部-存储-单机引擎
#description: mysql case迁移
#tags: ddl,dml,datatype


# This test can't be run with running server (--extern) as this uses
# load_file() on a file in the tree.
#
#--source mysql_test/test_suite/mysql8_t_2/include/force_myisam_default.inc
#--source mysql_test/test_suite/mysql8_t_2/include/have_myisam.inc
#
# Basic cleanup
#
#
--disable_warnings
drop table if exists t1;
--enable_warnings
SET sql_mode = 'NO_ENGINE_SUBSTITUTION';

--error 0,1051
DROP TABLE t1;
#-- error 1071
create table t1 (a text, unique (a(2100))) engine=myisam; # should give an error

--error 0,1051
DROP TABLE t1;
create table t1 (a text, key (a(2100))) engine=myisam;    # key is auto-truncated
show create table t1;
drop table t1;

