#owner group: 开源业务部-开源布道
#description: mysql case迁移
#tags: ddl,dml,pl


#--source mysql_test/test_suite/mysql8_t_2/include/force_myisam_default.inc
#--source mysql_test/test_suite/mysql8_t_2/include/have_myisam.inc

--echo #-----------------------------------------------------------------------
--echo # Test case to verify alter operations on non-transactional SE table
--echo # with check constraints.
--echo #-----------------------------------------------------------------------
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(f1 INT CHECK (f1 < 10)) ENGINE = myisam;
--disable_result_log
SHOW CREATE TABLE t1;
--enable_result_log

--error 1064
ALTER TABLE t1 ADD f2 INT, ALGORITHM=copy;

--disable_result_log
SHOW CREATE TABLE t1;
--enable_result_log

--error 1064
ALTER TABLE t1 ALTER f1 SET DEFAULT 10, ALGORITHM=INPLACE;

--disable_result_log
SHOW CREATE TABLE t1;
--enable_result_log

DROP TABLE t1;

