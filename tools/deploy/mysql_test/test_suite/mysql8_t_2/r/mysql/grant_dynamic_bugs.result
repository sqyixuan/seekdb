#
# Bug #30628160: DYNAMIC PRIVILEGES CAN BE GRANTED AT PROCEDURE/FUNCTION LEVEL
#
CREATE SCHEMA if not exists B30628160;
DROP USER B30628160;
DROP PROCEDURE B30628160.p1;
CREATE PROCEDURE B30628160.p1() SELECT 1;
CREATE USER B30628160 identified by 'Mysql@20230710';
# The test: must fail.
GRANT xyzzy ON PROCEDURE B30628160.p1 TO B30628160;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use
DROP USER B30628160;
DROP SCHEMA B30628160;
# End of 8.0 tests
