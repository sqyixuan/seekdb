# 
# WL#8971: Deprecate and remove partitioning storage engine
# 
# Tests to verify that partition related SQL statements
# for engines not supporting native partitioning return
# an error.
# 
# 
# Test recursively for various storage engines.
# 
# 
# WL#8971: Deprecate and remove partitioning storage engine
# 
# Tests to verify that partition related SQL statements
# for engines not supporting native partitioning return
# an error.
# 
# 
# Test recursively for various storage engines.
# 
# 
# 1. Create partitioned table.
# 
DROP TABLE t1;
CREATE TABLE t1 (i INTEGER)
ENGINE Archive
PARTITION BY HASH (i) PARTITIONS 2;
Warnings:
Warning	1286	Unknown storage engine 'Archive'
# 
# 2. Create subpartitioned table.
# 
DROP TABLE t1;
CREATE TABLE t1 (i INTEGER)
ENGINE Archive
PARTITION BY LIST (i) SUBPARTITION BY HASH (i)
(PARTITION p0 VALUES IN (0)
(SUBPARTITION s0,
SUBPARTITION s1,
SUBPARTITION s2),
PARTITION p1 VALUES IN (1)
(SUBPARTITION s3,
SUBPARTITION s4,
SUBPARTITION s5));
Warnings:
Warning	1286	Unknown storage engine 'Archive'
# 
# 3. Alter a table to have partitions.
# 
DROP TABLE t1;
CREATE TABLE t1 (i INTEGER NOT NULL)
ENGINE Archive;
Warnings:
Warning	1286	Unknown storage engine 'Archive'
ALTER TABLE t1
PARTITION BY HASH (i) PARTITIONS 2;
DROP TABLE t1;
# 
# 4. Alter a table to have subpartitions.
# 
DROP TABLE t1;
CREATE TABLE t1 (i INTEGER NOT NULL)
ENGINE Archive;
Warnings:
Warning	1286	Unknown storage engine 'Archive'
ALTER TABLE t1
PARTITION BY RANGE (i) SUBPARTITION BY HASH (i)
(PARTITION p0 VALUES LESS THAN (50)
(SUBPARTITION s0,
SUBPARTITION s1),
PARTITION p1 VALUES LESS THAN (100)
(SUBPARTITION s2,
SUBPARTITION s3));
DROP TABLE t1;
# 
# 5. Alter engine from an SE supporting native partitioning.
# 
DROP TABLE t1;
CREATE TABLE t1 (i INTEGER NOT NULL)
ENGINE InnoDB;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
ALTER TABLE t1 ENGINE Archive
PARTITION BY HASH (i) PARTITIONS 2;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'PARTITION BY HASH (i) PARTITIONS 2' at line 2
ALTER TABLE t1
PARTITION BY HASH (i) PARTITIONS 2;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `i` int(11) NOT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(i)
(partition `p0`,
partition `p1`)
ALTER TABLE t1 ENGINE Archive;
Warnings:
Warning	1286	Unknown storage engine 'Archive'
DROP TABLE t1;
