(
f1 int(11) DEFAULT NULL,
KEY f1 (f1)
);
CREATE TABLE t2
(
f1 int(11) DEFAULT NULL,
f2 varchar(255) CHARACTER SET utf8 DEFAULT NULL,
KEY f2 (f2),
KEY f1 (f1)
);
CREATE TABLE t3 (
f1 int(11) DEFAULT NULL,
f2 varchar(255) DEFAULT NULL,
KEY f1 (f1),
KEY f2 (f2)
);
