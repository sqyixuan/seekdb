set max_heap_table_size=1024*2014*1024;
           set tmp_table_size = @@max_heap_table_size;
           EXPLAIN ANALYZE SELECT COUNT(*) FROM (SELECT i,d,c FROM t EXCEPT SELECT i,d,c FROM t) derived
