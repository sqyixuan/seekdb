#
# WL#11864 Implement I_S.VIEW_TABLE_USAGE and I_S.VIEW_ROUTINE_USAGE
#
# Basic schema definition used by test cases.
drop database if exists db1;
CREATE DATABASE db1;
USE db1;
DROP TABLE t1;
CREATE TABLE t1 (c1 INT);
DROP FUNCTION f1;
CREATE FUNCTION f1() RETURNS INT RETURN 1;
DROP FUNCTION f2;
CREATE FUNCTION f2() RETURNS INT RETURN 2;
DROP VIEW v1;
CREATE VIEW v1 AS SELECT f1() AS f1;
DROP VIEW v2;
CREATE VIEW v2 AS SELECT f1, f2() AS f2  FROM v1;
DROP VIEW v3;
CREATE VIEW v3 AS SELECT c1, f2 FROM t1, v2;
# Case 1: Show table and views used by view v2 and v3.
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v2	db1	def
def	db1	v3	db1	def
def	db1	v3	db1	def
# Case 2: Show routines used by views.
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
# Case 3: Rename the column of t1 and list view dependency.
# The query should throw warning on view v3.
ALTER TABLE t1 RENAME COLUMN c1 TO c2;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' AND VIEW_NAME='v3';
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v3	db1	def
def	db1	v3	db1	def
ALTER TABLE t1 RENAME COLUMN c2 TO c1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' AND VIEW_NAME='v3';
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v3	db1	def
def	db1	v3	db1	def
# Case 4: Drop function f1 and list dependency.
# The query should throw warning on view v1.
DROP FUNCTION f1;
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1' AND TABLE_NAME='v1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
CREATE FUNCTION f1() RETURNS INT return 1;
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1' AND TABLE_NAME='v1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
# Case 5: Access checks.
drop user testuser@'%';
CREATE USER 'testuser'@'%';
# 5.1 Grant permission on v2, but not v1. VIEW_TABLE_USAGE will not
# list any entry because user has no permission on v1.
GRANT ALL ON db1.v2 TO 'testuser';
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v2	db1	def
# 5.2 Give permission on v1 and that VIEW_TABLE_USAGE shows v2 entry.
GRANT ALL ON db1.v1 TO 'testuser';
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v2	db1	def
# 5.3 VIEW_ROUTINE_USAGE does not list v1, as it have no grant on f1.
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
# 5.4 Grant access to f1 and check that VIEW_ROUTINE_USAGE shows it.
GRANT EXECUTE ON FUNCTION db1.f1 TO 'testuser';
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
# 5.5 Grant access on v3, see that dependency 't1' is not listed.
GRANT ALL ON db1.v3 TO 'testuser';
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v2	db1	def
def	db1	v3	db1	def
def	db1	v3	db1	def
# 5.6 Grant access on t1, see that dependency 't1' is listed.
GRANT SELECT on db1.t1 TO 'testuser';
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v2	db1	def
def	db1	v3	db1	def
def	db1	v3	db1	def
DROP USER 'testuser'@'%';
# Cleanup
DROP FUNCTION f1;
DROP FUNCTION f2;
DROP VIEW v1, v2, v3;
DROP TABLE t1;
# Case 6:
# 6.1 Rename table t1 to t2 and list view dependency.
# The query should throw warning on view v1.
CREATE TABLE t1 (c1 INT);
CREATE VIEW v1 AS SELECT c1 FROM t1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
RENAME TABLE t1 to t2;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
RENAME TABLE t2 to t1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
# 6.2 Drop table t1 and list view dependency.
DROP TABLE t1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	__recyclebin	def
DROP VIEW v1;
# Case 7: List dependent table and function names
# that are permitted to the current user.
CREATE USER testuser1;
GRANT CREATE ON db1.* TO testuser1;
GRANT SELECT ON db1.* TO testuser1;
GRANT CREATE VIEW ON db1.* TO testuser1;
GRANT CREATE ROUTINE ON db1.* TO testuser1;
GRANT DROP ON db1.* TO testuser1;
CREATE USER testuser2;
GRANT CREATE ON db1.* TO testuser2;
GRANT SELECT ON db1.* TO testuser2;
GRANT CREATE VIEW ON db1.* TO testuser2;
GRANT CREATE ROUTINE ON db1.* TO testuser2;
GRANT DROP ON db1.* TO testuser2;
drop table if exists t1;
drop VIEW if exists v1,v2;
DROP FUNCTION f1;
ERROR 42000: ALTER ROUTINE command denied to user 'testuser1'@'%' for routine 'f1'
CREATE TABLE t1(c1 INT);
CREATE VIEW v1 AS SELECT c1 FROM t1;
CREATE FUNCTION f1() RETURNS INT RETURN 1;
CREATE VIEW v2 AS SELECT f1();
drop table if exists t2;
drop VIEW if exists v3,v4;
DROP FUNCTION f2;
ERROR 42000: ALTER ROUTINE command denied to user 'testuser2'@'%' for routine 'f2'
CREATE TABLE t2(c1 INT);
CREATE VIEW v3 AS SELECT c1 FROM t2;
CREATE FUNCTION f2() RETURNS INT RETURN 1;
CREATE VIEW v4 AS SELECT f2();
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
def	db1	v3	db1	def
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
def	db1	v3	db1	def
SELECT * FROM INFORMATION_SCHEMA.VIEW_ROUTINE_USAGE
WHERE TABLE_SCHEMA='db1';
ERROR 42S02: Unknown table 'view_routine_usage' in information_schema
DROP VIEW v1,v2;
DROP FUNCTION f1;
DROP TABLE t1;
DROP VIEW v3,v4;
DROP FUNCTION f2;
DROP TABLE t2;
DROP USER testuser1;
DROP USER testuser2;
# Case 8: Revoke view privilege
CREATE USER testuser1;
CREATE TABLE t1(c1 INT);
CREATE VIEW v1 AS SELECT c1 FROM t1;
GRANT ALL ON db1.v1 TO testuser1;
GRANT ALL ON db1.t1 TO testuser1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
def	db1	v1	db1	def
REVOKE ALL ON db1.v1 FROM testuser1;
SELECT VIEW_CATALOG,VIEW_SCHEMA,VIEW_NAME,TABLE_SCHEMA,TABLE_CATALOG FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE
WHERE VIEW_SCHEMA='db1' ORDER BY VIEW_NAME, TABLE_NAME;
VIEW_CATALOG	VIEW_SCHEMA	VIEW_NAME	TABLE_SCHEMA	TABLE_CATALOG
REVOKE ALL ON db1.t1 FROM testuser1;
DROP USER testuser1;
DROP VIEW v1;
DROP TABLE t1;
DROP DATABASE db1;
