# ========== parameters.1 ==========
USE INFORMATION_SCHEMA;
SHOW CREATE TABLE INFORMATION_SCHEMA.PARAMETERS;
SELECT * FROM information_schema.columns
WHERE table_schema = 'information_schema'
  AND table_name   = 'PARAMETERS'
ORDER BY ordinal_position;
DESCRIBE INFORMATION_SCHEMA.PARAMETERS;
Field	Type	Null	Key	Default	Extra
SPECIFIC_CATALOG	varchar(512)	NO			
SPECIFIC_SCHEMA	varchar(128)	NO			
SPECIFIC_NAME	varchar(64)	NO		NULL	
ORDINAL_POSITION	bigint(20)	NO		NULL	
PARAMETER_MODE	varchar(5)	NO			
PARAMETER_NAME	varchar(64)	YES			
DATA_TYPE	varchar(64)	NO			
CHARACTER_MAXIMUM_LENGTH	bigint(20)	NO			
CHARACTER_OCTET_LENGTH	bigint(20)	NO			
NUMERIC_PRECISION	bigint(20) unsigned	NO			
NUMERIC_SCALE	bigint(20)	NO			
DATETIME_PRECISION	bigint(20) unsigned	NO			
CHARACTER_SET_NAME	varchar(64)	NO			
COLLATION_NAME	varchar(64)	NO			
DTD_IDENTIFIER	longtext	NO			
ROUTINE_TYPE	varchar(9)	NO			
