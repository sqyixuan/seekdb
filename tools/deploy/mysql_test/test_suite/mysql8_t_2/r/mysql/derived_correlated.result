#
# Bug#30887665 ASSERT: `SELECT_LEX->IS_RECURSIVE()' IN JOIN::MAKE_JOIN_PLAN()
#
CREATE TABLE t1 (c1 VARCHAR(1));
CREATE VIEW v1 AS SELECT * FROM t1;
SELECT 1 FROM
v1 AS table1 RIGHT OUTER JOIN LATERAL
(SELECT 1 FROM v1 AS table2 RIGHT OUTER JOIN LATERAL
( SELECT 1 FROM v1 AS table3 ) AS table4
ON table1.c1 = 1) AS table5
ON 1;
ERROR 42S22: Unknown column 'table1.c1' in 'on clause'
DROP VIEW v1;
DROP TABLE t1;
#
# Bug #32113029: WRONG RESULT PRODUCED WHEN LEFT JOINING INFORMATION_SCHEMA TABLES
#
CREATE TABLE t1 ( id INTEGER );
INSERT INTO t1 VALUES (1);
CREATE TABLE t2 ( table_id integer );
INSERT INTO t2 VALUES (363);
CREATE TABLE t3 ( id integer );
INSERT INTO t3 VALUES (362);
INSERT INTO t3 VALUES (363);
set optimizer_switch='derived_merge=off';
Warnings:
Warning	1235	This system variable now is mock not supported
SELECT *
FROM t1
LEFT JOIN (
t3, LATERAL (
SELECT * FROM t2 WHERE table_id = t3.id
) l1
) ON TRUE;
ERROR 42S22: Unknown column 't3.id' in 'where clause'
SELECT *
FROM t1
LEFT JOIN (
t3, LATERAL (
SELECT * FROM t2 WHERE table_id = t3.id
) l1
) ON TRUE and t3.id=363;
ERROR 42S22: Unknown column 't3.id' in 'where clause'
set optimizer_switch=DEFAULT;
Warnings:
Warning	1235	This system variable now is mock not supported
DROP TABLE t1, t2, t3;
#
# Bug #32729739: ASSERTION `PATH != NULLPTR' FAILED|SQL/SQL_EXECUTOR.CC
#
CREATE TABLE t1 ( a INTEGER );
SELECT *
FROM
t1
LEFT JOIN (
t1 AS t2
LEFT JOIN t1 AS t3 ON TRUE
) ON TRUE,
LATERAL (
SELECT SUM(t1.a), t2.a FROM t1
) AS d1;
a	a	a	SUM(t1.a)	a
DROP TABLE t1;
#
# Bug 32407774 - MANY INFORMATION_SCHEMA.TABLE_CONSTRAINTS
#                RELATED QUERIES ARE BROKEN
#
CREATE TABLE t1(id int NOT NULL);
INSERT into t1 VALUES (364), (365);
CREATE TABLE t2 (id int NOT NULL);
INSERT into t2 VALUES (365);
SELECT * FROM t1 AS tbl1
LEFT JOIN t1 AS tbl3 ON FALSE WHERE tbl1.id NOT IN
(SELECT id FROM t1 AS tbl2 JOIN LATERAL
(SELECT 1 FROM t2 WHERE id = tbl2.id LIMIT 10) AS d1);
id	id
364	NULL
365	NULL
SELECT /*+ JOIN_PREFIX(tbl1, tbl2) */ * FROM t1 AS tbl1
LEFT JOIN t1 AS tbl3 ON FALSE WHERE tbl1.id NOT IN
(SELECT id FROM t1 AS tbl2 JOIN LATERAL
(SELECT 1 FROM t2 WHERE id = tbl2.id LIMIT 10) AS d1);
id	id
364	NULL
365	NULL
DROP TABLE t1, t2;
#
# Bug#34190101: Hypergraph Assert in FindBestQueryPlan
#               on derived_condition_pushdown
#
CREATE TABLE t(x INT, b BLOB);
INSERT INTO t VALUES (0, 'zero'), (1, 'one'), (2, 'two');
SELECT t3.b
FROM
t AS t1,
t AS t2,
LATERAL (SELECT DISTINCT * FROM t WHERE t2.x <> 0) AS t3
WHERE t1.x = t2.x AND t2.x = t3.x ORDER BY t3.x;
b
one
two
DROP TABLE t;
purge recyclebin;
