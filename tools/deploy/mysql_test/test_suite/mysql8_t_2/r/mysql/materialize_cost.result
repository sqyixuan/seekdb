DROP TABLE t1;
CREATE TABLE t1(i INT, j INT);
INSERT INTO t1 VALUES (0,0),(1,1),(2,2),(3,3),(4,4);
#
# Bug#34302461: EXPLAIN cost and row estimates are wrong for UNION
#
EXPLAIN FORMAT=traditional SELECT i FROM t1 UNION SELECT 7 ORDER BY i;
EXPLAIN FORMAT=traditional SELECT * FROM (SELECT i FROM t1 UNION SELECT 7) d1
ORDER BY i;
EXPLAIN FORMAT=traditional SELECT * FROM t1 UNION SELECT * FROM t1 ORDER BY i;
EXPLAIN FORMAT=traditional SELECT * FROM (SELECT * FROM t1 UNION SELECT * FROM t1)
d1 ORDER BY i;
#
# Bug#33834146: 'EXPLAIN ANALYZE' cost + elapsed time not cumulative
# when using materialization
#
EXPLAIN FORMAT=traditional INSERT INTO t1 SELECT MAX(i), 3 FROM
(SELECT * FROM t1 ORDER BY j LIMIT 5) AS d1;
DROP TABLE t1;
