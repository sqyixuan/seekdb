----------------------------------------------------------------------
-    SUM, AVG, COUNT with frames
----------------------------------------------------------------------
try the same as a view
CREATE VIEW v AS
SELECT id, SUM(id) OVER w, sex FROM t1
WINDOW w AS (PARTITION BY sex ORDER BY id
ROWS BETWEEN 2 PRECEDING AND 1 PRECEDING);
SHOW CREATE VIEW v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select `test`.`t1`.`id` AS `id`,sum(`test`.`t1`.`id`) over( PARTITION BY `test`.`t1`.`sex` ORDER BY `test`.`t1`.`id` ASC  ROWS BETWEEN 2 PRECEDING  AND 1 PRECEDING ) AS `SUM(id) OVER w`,`test`.`t1`.`sex` AS `sex` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
DROP VIEW v;
