Single partition, no sorting
With LIMIT
Single ordered partition
View with window function
DROP VIEW v;
CREATE VIEW v AS
SELECT i, j, SUM(i+j) OVER (ORDER BY j DESC ROWS UNBOUNDED PRECEDING) foo FROM t;
SHOW CREATE VIEW v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select `test`.`t`.`i` AS `i`,`test`.`t`.`j` AS `j`,sum((`test`.`t`.`i` + `test`.`t`.`j`)) over( ORDER BY `test`.`t`.`j` DESC  ROWS BETWEEN  UNBOUNDED  PRECEDING  AND  CURRENT ROW ) AS `foo` from `test`.`t`	utf8mb4	utf8mb4_general_ci
DROP VIEW v;
