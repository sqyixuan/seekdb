CREATE VIEW v AS
SELECT id, FIRST_VALUE(id) OVER w FROM t1 WINDOW w AS (ORDER BY id RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING);
SHOW CREATE VIEW v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select `test`.`t1`.`id` AS `id`,nth_value(`test`.`t1`.`id`,1) from first respect nulls over( ORDER BY `test`.`t1`.`id` ASC  RANGE BETWEEN  CURRENT ROW  AND  UNBOUNDED  FOLLOWING ) AS `FIRST_VALUE(id) OVER w` from `test`.`t1`	utf8mb4	utf8mb4_general_ci
DROP VIEW v;
