# privileges
drop user user1@'%';
drop database if exists mysqltest1;
create database mysqltest1;
CREATE USER user1 identified by 'Mysql@20230710';
grant all on *.* to user1 WITH GRANT OPTION;
use mysqltest1;
DROP TABLE t1;
create table t1(pub int, priv int);
insert into t1 values(1,2);
GRANT SELECT (pub) ON mysqltest1.t1 TO user1;
use mysqltest1;
select pub from t1;
pub
1
select priv from t1;
priv
2
