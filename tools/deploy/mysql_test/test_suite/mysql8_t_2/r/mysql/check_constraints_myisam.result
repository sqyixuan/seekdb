#-----------------------------------------------------------------------
# Test case to verify alter operations on non-transactional SE table
# with check constraints.
#-----------------------------------------------------------------------
DROP TABLE t1;
CREATE TABLE t1(f1 INT CHECK (f1 < 10)) ENGINE = myisam;
Warnings:
Warning	1286	Unknown storage engine 'myisam'
SHOW CREATE TABLE t1;
ALTER TABLE t1 ADD f2 INT, ALGORITHM=copy;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'ALGORITHM=copy' at line 1
SHOW CREATE TABLE t1;
ALTER TABLE t1 ALTER f1 SET DEFAULT 10, ALGORITHM=INPLACE;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'ALGORITHM=INPLACE' at line 1
SHOW CREATE TABLE t1;
DROP TABLE t1;
