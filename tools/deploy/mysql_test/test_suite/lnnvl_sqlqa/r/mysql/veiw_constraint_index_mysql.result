f1	f2	f3	f4
INSERT INTO test2 VALUES(1,1.555,'abc','20151212');
INSERT INTO test2 VALUES(2,2.555,'bcd','20161212');
INSERT INTO test2 VALUES(3,3.555,'cde','20171212');
