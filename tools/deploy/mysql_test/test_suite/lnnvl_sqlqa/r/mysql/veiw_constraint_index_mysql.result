#lnnvl-7-2	约束：存在约束时进行dml操作
DROP TABLE test1;
CREATE TABLE test1(f1 decimal(5,1) UNIQUE, f2 decimal(5,1) UNIQUE);
INSERT INTO test1(f1) SELECT 5 FROM dual WHERE lnnvl(1!=1);
SELECT * FROM test1;
f1	f2
5.0	NULL
INSERT INTO test1(f1) SELECT 1 FROM dual WHERE lnnvl(1!=1);
INSERT INTO test1(f1) SELECT 1 FROM dual WHERE lnnvl(1!=1);
ERROR 23000: Duplicate entry '1.0' for key 'f1'
UPDATE test1 SET f1 = (SELECT 6 FROM dual WHERE lnnvl(1!=1)) WHERE lnnvl(f2 IS NOT NULL);
ERROR 23000: Duplicate entry '6.0' for key 'f1'
DELETE FROM test1 WHERE f1=1;
UPDATE test1 SET f1 = (SELECT 11 FROM dual WHERE lnnvl(1!=1)) WHERE lnnvl(f2 IS NOT NULL);
SELECT * FROM test1;
f1	f2
11.0	NULL
SELECT * FROM test1 WHERE lnnvl(f2=3);
f1	f2
11.0	NULL
DELETE FROM test1 WHERE lnnvl(f2=3);
SELECT * FROM test1;
f1	f2
#lnnvl-7-3	索引：存在索引时进行dml操作
DROP TABLE test1;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
CREATE INDEX index_test1 ON test1(f1);
CREATE INDEX index_test2 ON test1(f2);
INSERT INTO test1(f1) SELECT 5 FROM dual WHERE lnnvl(1!=1);
SELECT * FROM test1;
f1	f2
5.0	NULL
UPDATE test1 SET f1 = (SELECT 6 FROM dual WHERE lnnvl(1!=1)) WHERE lnnvl(f2 IS NOT NULL);
SELECT * FROM test1;
f1	f2
6.0	NULL
SELECT * FROM test1 WHERE lnnvl(f2=3);
f1	f2
6.0	NULL
DELETE FROM test1 WHERE lnnvl(f2=3);
SELECT * FROM test1;
f1	f2
drop user 'yyl_lnnvl_mysql'@'%';
