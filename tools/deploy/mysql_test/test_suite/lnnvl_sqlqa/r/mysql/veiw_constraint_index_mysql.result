DELETE FROM v2 WHERE lnnvl(f2+9.9<(SELECT avg(m)+12 FROM (SELECT 10+f2 m FROM v1 WHERE lnnvl(f1>4) GROUP BY f2 HAVING lnnvl(f2>=2) OR lnnvl(f2<=2) ORDER BY 1) t1 limit 1));
SELECT * FROM v2;
