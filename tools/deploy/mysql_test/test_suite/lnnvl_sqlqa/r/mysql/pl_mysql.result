grant all on *.* to 'yyl_lnnvl_mysql'@'%' WITH GRANT OPTION;
#lnnvl-6	pl/sql
#lnnvl-6-1	存储过程
#lnnvl-6-1-1	循环语句
#lnnvl-6-1-1-1、lnnvl-6-1-2	while循环--dml、if条件语句--dml
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
Warnings:
Warning	1265	Data truncated for column 'f1' at row 1
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
DROP PROCEDURE test_pro;
CREATE PROCEDURE test_pro()
BEGIN
DECLARE v1 decimal(5,1);
DECLARE v2 decimal(5,1);
DECLARE done INT DEFAULT 0 ;
DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN result_cursor;
FETCH result_cursor INTO v1,v2;
WHILE done<>1 DO
IF v1>10 THEN 
INSERT INTO test2 SELECT * FROM test1 WHERE lnnvl(f2 IS NULL);
ELSEIF v1<10 THEN
INSERT INTO test2(f2) SELECT f1 FROM test1 WHERE lnnvl(f2 IS NULL) GROUP BY f1 HAVING lnnvl(f1<3);
ELSE 
INSERT INTO test2 VALUES(v1||'1234567890',v2);
END IF;
FETCH result_cursor INTO v1,v2;
END WHILE;
CLOSE result_cursor;
END;
//
CALL test_pro();
SELECT * FROM test1;
f1	f2
