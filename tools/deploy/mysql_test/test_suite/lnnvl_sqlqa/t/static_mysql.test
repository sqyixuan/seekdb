--echo #lnnvl-5	静态sql
--echo #lnnvl-5-1	select
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(f1 int,f2 double(5,3),f3 varchar(5),f4 date);
INSERT INTO test1 VALUES(1,1.555,'abc','20151212');
INSERT INTO test1 VALUES(2,2.555,'bcd','20161212');
INSERT INTO test1 VALUES(3,3.555,'cde','20171212');
INSERT INTO test1 VALUES(NULL,NULL,NULL,NULL);
--echo #lnnvl-5-1-1	select
SELECT lnnvl(f1<3),lnnvl(f2<3),lnnvl(f3>'a'),lnnvl(f4 IS NULL) FROM test1;
#SELECT (f1>=3 OR f1 IS NULL),(f2>=3 OR f2 IS NULL),(f3<='a' OR f3 IS NULL),(f4 IS NOT NULL) FROM test1;

--echo #lnnvl-5-1-2	from
SELECT * FROM (SELECT * FROM test1 WHERE lnnvl(f1<3) AND lnnvl(f2<3) AND NOT lnnvl(f3='abc') OR lnnvl(f4 IS NULL)) t1 WHERE lnnvl(f1!=2) ORDER BY 2 desc;
#SELECT * FROM (SELECT * FROM test1 WHERE (f1>=3 OR f1 IS null) AND (f2>=3 OR f2 IS NULL) AND NOT (f3!='abc' OR f3 IS null) OR (f4 IS NOT NULL)) t1 WHERE (f1=2 OR f1 IS NULL) ORDER BY 2 DESC;

--echo #lnnvl-5-1-3	where
SELECT * FROM test1 WHERE lnnvl(f1<3) AND lnnvl(f2<3) AND NOT lnnvl(f3='abc') OR lnnvl(f4 IS NOT NULL);
#SELECT * FROM test1 WHERE (f1>=3 OR f1 IS NULL ) AND (f2>=3 OR f2 IS NULL ) AND NOT (f3!='abc' OR f3 IS NULL) OR (f4 IS NULL);

#--echo #lnnvl-5-1-4	group by
#SELECT * FROM test1 WHERE lnnvl(f3='abc') GROUP BY lnnvl(f4>'20161212');
#SELECT * FROM test1 WHERE (f3!='abc' OR f3 IS null) GROUP BY (f4<='20161212' OR f4 IS NULL);

--echo #lnnvl-5-1-5	having
SELECT f2,f3 FROM test1 WHERE lnnvl(f1>2.5) GROUP BY f2,f3 HAVING lnnvl(f3='abc') OR lnnvl(f3='bcd');
#SELECT f2,f3 FROM test1 WHERE (f1<=2.5 OR f1 IS NULL) GROUP BY f2,f3 HAVING (f3!='abc' OR f3 IS NULL) OR (f3!='bcd' OR f3 IS NULL);

#--echo #lnnvl-5-1-6	order by
#SELECT * FROM test1 ORDER BY lnnvl(f3='abc');
#SELECT * FROM test1 ORDER BY (f3!='abc' OR f3 IS null);

--echo #lnnvl-5-1-7	case when
SELECT (CASE WHEN lnnvl(f1>2) THEN f1 ELSE f1+1 END) FROM test1;
#SELECT (CASE WHEN (f1<=2 OR f1 IS null) THEN f1 ELSE f1+1 END) FROM test1;

SELECT (CASE WHEN lnnvl(f1 IS NULL) THEN f1 ELSE 2 END) FROM test1;
#SELECT (CASE WHEN (f1 IS NOT NULL) THEN f1 ELSE 2 END) FROM test1;

SELECT (CASE lnnvl(f1 IS NULL) WHEN 1 THEN f1 WHEN NULL THEN 2 ELSE 3 END) FROM test1;
#SELECT (CASE (f1 IS NOT NULL) WHEN 1 THEN f1 WHEN NULL THEN 2 ELSE 3 END) FROM test1;

--echo #lnnvl-5-1-8	distinct
SELECT DISTINCT lnnvl(f1 IS NOT NULL) FROM test1;
#SELECT DISTINCT (f1 IS NULL) FROM test1;

