--echo #lnnvl-5-3-1-1	直接嵌套被测函数
--error 0,1051
DROP TABLE test2;
CREATE TABLE test2 AS SELECT * FROM test1 WHERE 1=1;
UPDATE test2 SET f1=lnnvl(f1>2) WHERE f1 IS NOT NULL;
SELECT * FROM test2;
#UPDATE test2 SET f1=(f1<=2 OR f1 IS NULL) WHERE f1 IS NOT NULL;
#SELECT * FROM test2;

--echo #lnnvl-5-3-1-2	嵌套包含被测函数的select语句
UPDATE test2 SET f1=(SELECT max(f2) FROM test1 WHERE lnnvl(f1>2)) WHERE f2 IS NOT NULL;
SELECT * FROM test2;
#UPDATE test2 SET f1=(SELECT max(f2) FROM test1 WHERE (f1<=2 OR f1 IS NULL)) WHERE f2 IS NOT NULL;
#SELECT * FROM test2;

UPDATE test2 SET f2=(SELECT avg(m) FROM (SELECT f2||'5.5544' m FROM test1 WHERE lnnvl(f1>2) GROUP BY f2 HAVING lnnvl(f2>=2) OR lnnvl(f2<=2) ORDER BY 1) t1 limit 1) WHERE f2 IS NULL;
SELECT * FROM test2;
#UPDATE test2 SET f2=(SELECT avg(m) FROM (SELECT f2||'5.5544' m FROM test1 WHERE (f1<=2 OR f1 IS NULL) GROUP BY f2 HAVING (f2<2 OR f2 IS NULL) OR (f2>2 OR f2 IS NULL) ORDER BY 1) t1 limit 1) WHERE f2 IS NULL;
