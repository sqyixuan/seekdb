UPDATE test2 SET f1='7' WHERE f2+9.9 < (SELECT avg(m) FROM (SELECT 10+f2 m FROM test1 WHERE lnnvl(f1>4) GROUP BY f2 HAVING lnnvl(f2>=2) OR lnnvl(f2<=2) ORDER BY 1) t1 limit 1) AND lnnvl(f1 IS NULL);
SELECT * FROM test2;
#UPDATE test2 SET f1='7' WHERE f2+9.9 < (SELECT avg(m) FROM (SELECT 10+f2 m FROM test1 WHERE (f1<=4 OR f1 IS NULL) GROUP BY f2 HAVING (f2<2 OR f2 IS NULL) OR (f2>2 OR f2 IS NULL) ORDER BY 1) t1 limit 1) AND (f1 IS NOT NULL);
#SELECT * FROM test2;

UPDATE test2 SET f1='6' WHERE lnnvl((SELECT max(f2) FROM test1 WHERE lnnvl(f1>2)) IS NULL);
SELECT * FROM test2;
#UPDATE test2 SET f1='6' WHERE ((SELECT max(f2) FROM test1 WHERE (f1<=2 OR f1 IS NULL)) IS NOT NULL);
#SELECT * FROM test2;

UPDATE test2 SET f1='7' WHERE lnnvl(f2+9.9<(SELECT avg(m)||12 FROM (SELECT 10+f2 m FROM test1 WHERE lnnvl(f1>4) GROUP BY f2 HAVING lnnvl(f2>=2) OR lnnvl(f2<=2) ORDER BY 1) t1 limit 1));
SELECT * FROM test2;
