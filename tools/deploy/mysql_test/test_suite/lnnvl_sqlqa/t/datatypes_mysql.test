--echo #lnnvl-4	数据类型
--echo #lnnvl-4-1	int/integer
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(f1 int,f2 integer);
INSERT INTO test1 VALUES(1,111);
INSERT INTO test1 VALUES(2,222);
INSERT INTO test1 VALUES(3,333);
INSERT INTO test1 VALUES(NULL,NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1>='2');
SELECT f2 FROM test1 WHERE lnnvl((CASE WHEN f1>2 THEN 10 ELSE 0 END)<='2');
SELECT f2 FROM test1 WHERE lnnvl(f1=(SELECT max(f1) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2)!=((3,333)));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2)=(SELECT max(f1),max(f2) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(f1=any(SELECT min(f1) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(f1=SOME(SELECT f1 FROM test1 WHERE lnnvl(f1>2)));
SELECT f2 FROM test1 WHERE lnnvl(f1=ALL(SELECT min(f1) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(f1<ALL(SELECT f1 FROM test1 WHERE lnnvl(f1<2)));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2)=ANY(SELECT f1,f2 FROM test1));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2)!=ALL(SELECT f1,f2 FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(f1 LIKE '%5');
SELECT f2 FROM test1 WHERE lnnvl(f1 NOT LIKE NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 LIKE (SELECT f1 FROM test1 WHERE f2=111));
SELECT f2 FROM test1 WHERE lnnvl(f1 regexp '1.*');
SELECT f2 FROM test1 WHERE lnnvl(f1 regexp NULL);
SELECT f2 FROM test1 WHERE lnnvl(EXISTS(SELECT null FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(EXISTS(SELECT * FROM test1 WHERE 1=0));
SELECT f2 FROM test1 WHERE lnnvl(f1 IS NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 IS NOT NULL);
SELECT f2 FROM test1 WHERE lnnvl((SELECT min(f1) FROM test1) IS NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 IN (1));
SELECT f2 FROM test1 WHERE lnnvl(f1 IN (1,NULL));
SELECT f2 FROM test1 WHERE lnnvl(f1 NOT IN (SELECT min(f1) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2) NOT IN ((1,111)));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2) IN (SELECT f1,f2 FROM test1));
#SELECT f2 FROM test1 WHERE lnnvl(f1 BETWEEN 1 AND 5);
#SELECT f2 FROM test1 WHERE lnnvl(NOT f1<1);
#SELECT f2 FROM test1 WHERE lnnvl(f1<1 AND f2<5);
#SELECT f2 FROM test1 WHERE lnnvl(f1<1 OR f2<5);

