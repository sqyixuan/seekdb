SELECT f2 FROM test1 WHERE lnnvl(f1 NOT LIKE NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 LIKE (SELECT f1 FROM test1 WHERE f2='fsr'));
SELECT f2 FROM test1 WHERE lnnvl(f1 regexp '1.*');
SELECT f2 FROM test1 WHERE lnnvl(f1 regexp NULL);
SELECT f2 FROM test1 WHERE lnnvl(EXISTS(SELECT null FROM test1));
SELECT f2 FROM test1 WHERE lnnvl(EXISTS(SELECT * FROM test1 WHERE 1=0));
SELECT f2 FROM test1 WHERE lnnvl(f1 IS NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 IS NOT NULL);
SELECT f2 FROM test1 WHERE lnnvl((SELECT min(f1) FROM test1) IS NULL);
SELECT f2 FROM test1 WHERE lnnvl(f1 IN ('2gfsg'));
SELECT f2 FROM test1 WHERE lnnvl(f1 IN ('2gfsg',NULL));
SELECT f2 FROM test1 WHERE lnnvl(f1 NOT IN (SELECT min(f1) FROM test1));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2) NOT IN (('2gfsg','fsr')));
SELECT f2 FROM test1 WHERE lnnvl((f1,f2) IN (SELECT f1,f2 FROM test1));
#SELECT f2 FROM test1 WHERE lnnvl(f1 BETWEEN '2gfsg' AND 'hgfsg');
#SELECT f2 FROM test1 WHERE lnnvl(NOT f1<'2gfsg');
#SELECT f2 FROM test1 WHERE lnnvl(f1<'2gfsg' AND f2<'fsr');
#SELECT f2 FROM test1 WHERE lnnvl(f1<'2gfsg' OR f2<'fsr');




