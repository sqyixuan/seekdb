#owner: dachuan.sdc
#owner group: sql2
#description: lnnvl函数
#tags: 参数要求、lnnvl之外使用运算符、常用函数嵌套等
#author:wb-yyl765463

--disable_warnings
--error 0,1396
drop user 'yyl_lnnvl_mysql'@'%';
--enable_warnings
create user 'yyl_lnnvl_mysql'@'%' IDENTIFIED BY 'yyl_lnnvl_mysql';
grant all on *.* to 'yyl_lnnvl_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,yyl_lnnvl_mysql,yyl_lnnvl_mysql,test,$OBMYSQL_PORT);
connection conn;


--echo #lnnvl-1	参数要求
--echo #lnnvl-1-1	参数类型要求
--echo #lnnvl-1-1-1	 参数为condition(含condition中有子查询或表达式列表的测试)
--echo #lnnvl-1-1-1-1	>、>=、<、<=、=、<=>、!=、<>
SELECT 'a' FROM dual WHERE lnnvl(1+4>2);
SELECT 'a' FROM dual WHERE lnnvl(1+1>2);
SELECT 'a' FROM dual WHERE lnnvl(1+1>NULL);
SELECT 'a' FROM dual WHERE lnnvl(NULL>1+1);
SELECT 'a' FROM dual WHERE lnnvl(NULL-3>NULL);

SELECT 'b' FROM dual WHERE lnnvl(5-1>=0);
SELECT 'b' FROM dual WHERE lnnvl(5-1>=6);
SELECT 'b' FROM dual WHERE lnnvl(5-1>=NULL);
SELECT 'b' FROM dual WHERE lnnvl(NULL>=5-1);
SELECT 'b' FROM dual WHERE lnnvl(NULL-2>=NULL);

SELECT 'c' FROM dual WHERE lnnvl(2*11<25);
SELECT 'c' FROM dual WHERE lnnvl(2*11<1);
SELECT 'c' FROM dual WHERE lnnvl(2*11<NULL);
SELECT 'c' FROM dual WHERE lnnvl(NULL*11<1-2);
SELECT 'c' FROM dual WHERE lnnvl(NULL<2*NULL);

SELECT 'd' FROM dual WHERE lnnvl(1<=2/2);
SELECT 'd' FROM dual WHERE lnnvl(11<=11/2);
SELECT 'd' FROM dual WHERE lnnvl(12/2<=NULL);
SELECT 'd' FROM dual WHERE lnnvl(NULL/2<=1);
SELECT 'd' FROM dual WHERE lnnvl(NULL<=NULL/2);

SELECT 'e1' FROM dual WHERE lnnvl(16=16);
SELECT 'e1' FROM dual WHERE lnnvl(12=1);
SELECT 'e1' FROM dual WHERE lnnvl(12=NULL);
SELECT 'e1' FROM dual WHERE lnnvl(NULL=14);
SELECT 'e1' FROM dual WHERE lnnvl(NULL=NULL);

SELECT 'e2' FROM dual WHERE lnnvl(16<=>16);
SELECT 'e2' FROM dual WHERE lnnvl(12<=>1);
SELECT 'e2' FROM dual WHERE lnnvl(12<=>NULL);
SELECT 'e2' FROM dual WHERE lnnvl(NULL<=>14);
SELECT 'e2' FROM dual WHERE lnnvl(NULL<=>NULL);

SELECT 'f' FROM dual WHERE lnnvl(1+2*3-5/3!=12);
SELECT 'f' FROM dual WHERE lnnvl(2!=1+2*3-5/1);
SELECT 'f' FROM dual WHERE lnnvl(1!=NULL);
SELECT 'f' FROM dual WHERE lnnvl(NULL!=1);
SELECT 'f' FROM dual WHERE lnnvl(NULL!=NULL);

SELECT 'g' FROM dual WHERE lnnvl(1<>2);
SELECT 'g' FROM dual WHERE lnnvl(1<>1);
SELECT 'g' FROM dual WHERE lnnvl(1<>NULL);
SELECT 'g' FROM dual WHERE lnnvl(NULL<>1);
SELECT 'g' FROM dual WHERE lnnvl(NULL<>NULL);

SELECT 'h' FROM dual WHERE lnnvl((CASE power(2,3) WHEN 1 THEN 2 WHEN 0 THEN 3 ELSE 0 END)>=5);
SELECT 'h' FROM dual WHERE lnnvl(1<(SELECT 1 FROM dual));
SELECT 'h' FROM dual WHERE lnnvl((1,2)=((1,2)));
SELECT 'h' FROM dual WHERE lnnvl((1,2)!=(SELECT 1,2 FROM dual));

--echo #lnnvl-1-1-1-2	any，some，all
SELECT 'a' FROM dual WHERE lnnvl(1+4>ANY(SELECT 11 FROM dual UNION SELECT 5 FROM dual));
SELECT 'a' FROM dual WHERE lnnvl(1+4>ANY(SELECT NULL FROM dual UNION SELECT 1 FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(11=SOME(SELECT 11 FROM dual UNION SELECT 5 FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(NULL=SOME(SELECT 11 FROM dual UNION SELECT NULL FROM dual));
SELECT 'c' FROM dual WHERE lnnvl(11<=ALL(SELECT 11 FROM dual UNION SELECT 5 FROM dual));
SELECT 'c' FROM dual WHERE lnnvl(2<=ALL(SELECT NULL FROM dual UNION SELECT 5 FROM dual));

--echo #在mysql中如下有些语句（去掉lnnvl）也执行不通，但ob均可以执行通过
SELECT 'a' FROM dual WHERE lnnvl((1,2)=ANY(SELECT 1,1 FROM dual UNION SELECT 1,2 FROM dual UNION SELECT NULL,2 FROM dual));
SELECT 'a' FROM dual WHERE lnnvl((1,2)!=ANY(SELECT 1,1 FROM dual UNION SELECT 1,2 FROM dual UNION SELECT NULL,2 FROM dual));
SELECT 'b' FROM dual WHERE lnnvl((1,2)!=SOME(SELECT 1,1 FROM dual UNION SELECT 1,2 FROM dual UNION SELECT NULL,2 FROM dual));
SELECT 'b' FROM dual WHERE lnnvl((1,2)=SOME(SELECT 1,1 FROM dual UNION SELECT 1,3 FROM dual UNION SELECT NULL,2 FROM dual));
SELECT 'b' FROM dual WHERE lnnvl((NULL,NULL)=SOME(SELECT 1,1 FROM dual UNION SELECT 1,3 FROM dual UNION SELECT NULL,NULL FROM dual));
SELECT 'c' FROM dual WHERE lnnvl((1,2)=ALL(SELECT 1,1 FROM dual UNION SELECT 1,2 FROM dual UNION SELECT NULL,2 FROM dual));
SELECT 'c' FROM dual WHERE lnnvl((1,2)!=ALL(SELECT 1,1 FROM dual UNION SELECT 1,2 FROM dual UNION SELECT NULL,2 FROM dual));

--echo #lnnvl-1-1-1-3	like/regexp
SELECT 'a' FROM dual WHERE lnnvl('ac' LIKE 'a%');
SELECT 'a' FROM dual WHERE lnnvl('ab' LIKE '_bv');
SELECT 'a' FROM dual WHERE lnnvl('ad' LIKE NULL);
SELECT 'a' FROM dual WHERE lnnvl(NULL LIKE 'a%');
SELECT 'a' FROM dual WHERE lnnvl(NULL LIKE NULL);
SELECT 'a' FROM dual WHERE lnnvl('' LIKE '');

SELECT 'b' FROM dual WHERE lnnvl('ac' NOT LIKE 'a%');
SELECT 'b' FROM dual WHERE lnnvl('ab' NOT LIKE 'ab');
SELECT 'b' FROM dual WHERE lnnvl('ad' NOT LIKE NULL);
SELECT 'b' FROM dual WHERE lnnvl(NULL NOT LIKE 'a%');
SELECT 'b' FROM dual WHERE lnnvl(NULL NOT LIKE NULL);
SELECT 'b' FROM dual WHERE lnnvl('' NOT LIKE 'a');

SELECT 'c' FROM dual WHERE lnnvl('abc' LIKE (SELECT 'a%' FROM dual));
SELECT 'c' FROM dual WHERE lnnvl('' LIKE (SELECT 'a%' FROM dual));
SELECT 'c' FROM dual WHERE lnnvl((SELECT 'abc' FROM dual) NOT LIKE 'a%');
SELECT 'c' FROM dual WHERE lnnvl((SELECT '' FROM dual) NOT LIKE '');

--error 3995
SELECT 'd' FROM dual WHERE lnnvl('abc234' REGEXP BINARY '^A[b2].*4$');
SELECT 'd' FROM dual WHERE lnnvl('abc234' REGEXP NULL);
SELECT 'd' FROM dual WHERE lnnvl('' REGEXP '^A[b2].*4$');
SELECT 'd' FROM dual WHERE lnnvl('abc234' REGEXP '^A[b2].*4$');
SELECT 'd' FROM dual WHERE lnnvl('abc234' REGEXP '.');
SELECT 'd' FROM dual WHERE lnnvl(NULL REGEXP '^A[b2].*4$');

--echo #lnnvl-1-1-1-4	exists
SELECT 'a' FROM dual WHERE lnnvl(EXISTS(SELECT '' FROM dual));
SELECT 'a' FROM dual WHERE lnnvl(EXISTS(SELECT null FROM dual));
SELECT 'a' FROM dual WHERE lnnvl(EXISTS(SELECT 2 FROM dual WHERE 1=0));

--echo #lnnvl-1-1-1-5	is [not] null
SELECT 'a' FROM dual WHERE lnnvl(''+2 IS NULL);
SELECT 'a' FROM dual WHERE lnnvl(NULL-3 IS NULL);
SELECT 'a' FROM dual WHERE lnnvl('r''4' IS NULL);

SELECT 'b' FROM dual WHERE lnnvl((SELECT 'r' FROM dual) IS NULL);
SELECT 'b' FROM dual WHERE lnnvl((SELECT 'r' FROM dual WHERE 1=0) IS NULL);
SELECT 'b' FROM dual WHERE lnnvl((SELECT null FROM dual) IS NULL);

SELECT 'c' FROM dual WHERE lnnvl(''*3 IS NOT NULL);
SELECT 'c' FROM dual WHERE lnnvl(NULL/5 IS NOT NULL);
SELECT 'c' FROM dual WHERE lnnvl('r' IS NOT NULL);

SELECT 'd' FROM dual WHERE lnnvl((SELECT 'r' FROM dual) IS NOT NULL);
SELECT 'd' FROM dual WHERE lnnvl((SELECT 'r' FROM dual WHERE 1=0) IS NOT NULL);
SELECT 'd' FROM dual WHERE lnnvl((SELECT null FROM dual) IS NOT NULL);

--echo #lnnvl-1-1-1-6	[not] in
SELECT 'a' FROM dual WHERE lnnvl('x' IN ('x'));
SELECT 'a' FROM dual WHERE lnnvl('y' IN ('x'));
SELECT 'a' FROM dual WHERE lnnvl('' IN (''));
SELECT 'a' FROM dual WHERE lnnvl('x' IN (NULL));
SELECT 'a' FROM dual WHERE lnnvl(NULL IN ('x'));
SELECT 'b' FROM dual WHERE lnnvl('x' IN (SELECT 'x' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' IN (SELECT 'y' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' IN (SELECT '' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' IN (SELECT null FROM dual));

SELECT 'a' FROM dual WHERE lnnvl('x' NOT IN ('x'));
SELECT 'a' FROM dual WHERE lnnvl('y' NOT IN ('x'));
SELECT 'a' FROM dual WHERE lnnvl(NULL NOT IN (NULL));
SELECT 'a' FROM dual WHERE lnnvl('' NOT IN (NULL));
SELECT 'a' FROM dual WHERE lnnvl(NULL NOT IN ('x'));
SELECT 'b' FROM dual WHERE lnnvl('x' NOT IN (SELECT 'x' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('y' NOT IN (SELECT 'x' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' NOT IN (SELECT '' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' NOT IN (SELECT null FROM dual));

SELECT 'a' FROM dual WHERE lnnvl('x' IN ('x','Y',NULL));
SELECT 'a' FROM dual WHERE lnnvl(NULL IN ('x','Y',NULL));
SELECT 'a' FROM dual WHERE lnnvl('x' NOT IN ('x','Y',NULL));
SELECT 'a' FROM dual WHERE lnnvl(NULL NOT IN ('x','Y',NULL));
SELECT 'b' FROM dual WHERE lnnvl('x' IN (SELECT 'x' FROM dual UNION SELECT 'Y' FROM dual UNION SELECT null FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(NULL IN (SELECT 'x' FROM dual UNION SELECT 'Y' FROM dual UNION SELECT null FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('x' NOT IN (SELECT 'x' FROM dual UNION SELECT 'Y' FROM dual UNION SELECT null FROM dual));
SELECT 'b' FROM dual WHERE lnnvl('' NOT IN (SELECT 'x' FROM dual UNION SELECT 'Y' FROM dual UNION SELECT null FROM dual));

SELECT 'a' FROM dual WHERE lnnvl(('x','1') IN (('Y','1')));
SELECT 'a' FROM dual WHERE lnnvl((NULL,NULL) IN (('x','1'),('Y','1'),(NULL,NULL)));
SELECT 'a' FROM dual WHERE lnnvl(('x','1') NOT IN (('x','1'),('Y','1'),(NULL,'1')));
SELECT 'a' FROM dual WHERE lnnvl((NULL,NULL) NOT IN ((NULL,NULL)));
SELECT 'b' FROM dual WHERE lnnvl(('x','1') IN (SELECT 'x','1' FROM dual UNION SELECT 'Y','1' FROM dual UNION SELECT null,'1' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl((NULL,NULL) IN (SELECT 'x','1' FROM dual UNION SELECT 'Y','1' FROM dual UNION SELECT null,null FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(('x','1') NOT IN (SELECT 'x','1' FROM dual UNION SELECT 'Y','1' FROM dual UNION SELECT null,'5' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(('y','1') NOT IN (SELECT 'x','1' FROM dual UNION SELECT 'Y','1' FROM dual UNION SELECT null,'5' FROM dual));
SELECT 'b' FROM dual WHERE lnnvl(('','') NOT IN (SELECT 'x','1' FROM dual UNION SELECT 'Y','1' FROM dual UNION SELECT null,null FROM dual));

--echo #lnnvl-1-1-1-7	[not] between and
SELECT 'a' FROM dual WHERE lnnvl(2 BETWEEN 1 AND 5);
SELECT 'a' FROM dual WHERE lnnvl(2 BETWEEN (SELECT 3 FROM dual) AND (SELECT 5 FROM dual));
SELECT 'a' FROM dual WHERE lnnvl(2 NOT BETWEEN 3 AND 5);
SELECT 'a' FROM dual WHERE lnnvl(2 NOT BETWEEN (SELECT 1 FROM dual) AND (SELECT 5 FROM dual));

--echo #lnnvl-1-1-1-8	and、or、not(&&、||、!)以及xor
--echo #oracle官方文档中：The condition can evaluate any scalar values but cannot be a compound condition containing AND, OR, or BETWEEN.
SELECT 'a' FROM dual WHERE lnnvl(NOT 1<1);
SELECT 'a' FROM dual WHERE lnnvl(! 0>1);
SELECT 'a' FROM dual WHERE lnnvl(1<1 AND 4<5);
SELECT 'a' FROM dual WHERE lnnvl(1<1 && 4<5);
SELECT 'a' FROM dual WHERE lnnvl(1<1 OR 4<5);
SELECT 'a' FROM dual WHERE lnnvl(1<1 || 4<5);
SELECT 'a' FROM dual WHERE lnnvl(1<1 XOR 4<5);

--echo #lnnvl-1-1-2	参数不为condition
--echo #lnnvl-1-1-2-1	为单个数据
SELECT 'a' FROM dual WHERE lnnvl(1);
SELECT 'a' FROM dual WHERE lnnvl('?');
--echo #lnnvl-1-1-2-2	为表达式	
SELECT 'a' FROM dual WHERE lnnvl('2018-04-10 12:12:10'+10);
SELECT 'a' FROM dual WHERE lnnvl(47+3*3/2-24);
SELECT 'a' FROM dual WHERE lnnvl(CASE WHEN 1>1 THEN 1 ELSE 2 END);


--echo #lnnvl-1-2	参数个数要求
--echo #lnnvl-1-2-1	单个参数
SELECT 'a' FROM dual WHERE lnnvl('a'<'b');
--echo #lnnvl-1-2-2	多个参数
--error 1582
SELECT 'a' FROM dual WHERE lnnvl(1<1,'a'>'b');
--error 1582
SELECT 'a' FROM dual WHERE lnnvl(3>2,'a'>'b',1<1);


--echo #lnnvl-2	lnnvl之外使用运算符
--echo #lnnvl-2-1	>、>=、<、<=、=、<=>、!=、<>
SELECT 'a' FROM dual WHERE lnnvl(1=1)>1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)>1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)>=1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)>=1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)<1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)<1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)<=1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)<=1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)=1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)=1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)<=>1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)<=>NULL;
SELECT 'a' FROM dual WHERE lnnvl(1=1)!=1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)!=1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)<>1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)<>1;

--echo #lnnvl-2-2	any，some，all
SELECT 'a' FROM dual WHERE lnnvl(1=1)=ANY(SELECT null from dual union SELECT 1 from dual);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)=SOME(SELECT null from dual union SELECT 1 from dual);
SELECT 'a' FROM dual WHERE lnnvl(1=1)=ALL(SELECT null from dual);

--echo #lnnvl-2-3	like/regexp
SELECT 'a' FROM dual WHERE lnnvl(1=1) LIKE '';
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) LIKE NULL;
SELECT 'a' FROM dual WHERE lnnvl(1=1) regexp '.';
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) regexp 'a%';

--echo #lnnvl-2-4	exists
SELECT 'a' FROM dual WHERE EXISTS(SELECT 1 FROM dual WHERE lnnvl(1=1));
SELECT 'a' FROM dual WHERE EXISTS(SELECT 1 FROM dual WHERE lnnvl(1!=NULL));

--echo #lnnvl-2-5	is [not] null
SELECT 'a' FROM dual WHERE lnnvl(1=1) IS NULL;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) IS NULL;
SELECT 'a' FROM dual WHERE lnnvl(1=1) IS NOT NULL;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) IS NOT NULL;

--echo #lnnvl-2-6	[not] in
SELECT 'a' FROM dual WHERE lnnvl(1=1) IN (1,NULL);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) IN (1,NULL);
SELECT 'a' FROM dual WHERE lnnvl(1=1) NOT IN (1,NULL);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) NOT IN (1,NULL);

--echo #lnnvl-2-7	[not] between and
SELECT 'a' FROM dual WHERE lnnvl(1=1) BETWEEN 1 AND 2;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) BETWEEN 1 AND NULL;
SELECT 'a' FROM dual WHERE lnnvl(1=1) NOT BETWEEN 1 AND NULL;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) NOT BETWEEN 1 AND 5;

--echo #lnnvl-2-8	and、or、not(&&、||、!)以及xor
SELECT 'a' FROM dual WHERE lnnvl(1!=1) AND lnnvl(2<1);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) && lnnvl(2<1);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) && lnnvl(2>1);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) OR lnnvl(2<1);
SELECT 'a' FROM dual WHERE lnnvl(1=1) || lnnvl(2<1);
SELECT 'a' FROM dual WHERE lnnvl(1=1) || lnnvl(2>1);
SELECT 'a' FROM dual WHERE NOT lnnvl(1=1);
SELECT 'a' FROM dual WHERE ! lnnvl(1!=NULL);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) XOR lnnvl(2<1);
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL) XOR lnnvl(2>1);

--echo #lnnvl-2-9	+-*/
SELECT 'a' FROM dual WHERE lnnvl(1=1)+2-3*2/10>1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)+2-3*2/10>1;
SELECT 'a' FROM dual WHERE lnnvl(1=1)-100+2-3*2/10>1;
SELECT 'a' FROM dual WHERE lnnvl(1!=NULL)-11+2-3*2/10>1;


--echo #lnnvl-3	常用函数嵌套
--echo #lnnvl-3-1	嵌套自身lnnvl
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(1=1));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(1!=NULL));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(lnnvl(1!=NULL)));

--echo #lnnvl-3-2	嵌套其它函数
--echo #lnnvl-3-2-1	mod
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(MOD(9,4)=1));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(MOD(9,4)!=NULL));
select MOD(lnnvl(1=1),9) from dual;

--echo #lnnvl-3-2-2	round
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(ROUND(0.6)=1));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(ROUND(0.6)!=NULL));
select round(lnnvl(1=1)) from dual;

--echo #lnnvl-3-2-3	sum/min
--error 0,1051
DROP TABLE test1;
CREATE TABLE test1(f1 int);
INSERT INTO test1 VALUES(2);
INSERT INTO test1 VALUES(4);
INSERT INTO test1 VALUES(null);
SELECT * FROM test1 WHERE lnnvl((SELECT sum(f1) FROM test1)=6);
SELECT * FROM test1 WHERE lnnvl((SELECT sum(f1) FROM test1)!=null);
SELECT * FROM test1 WHERE lnnvl((SELECT min(f1) FROM test1)=2);
SELECT * FROM test1 WHERE lnnvl((SELECT min(f1) FROM test1)!=null);
select sum(lnnvl(f1=1)) from test1;

--echo #lnnvl-3-2-4	truncate
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(truncate(1.4,2)=1));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(truncate(1.4,2)!=NULL));
select truncate(lnnvl(1=1),2) from dual;

--echo #lnnvl-3-2-5	power
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(round(power(0.6,5),5)=0.07776));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(power(0.6,5)!=NULL));
select power(lnnvl(1=1),3) from dual;

--echo #lnnvl-3-2-6	upper/lower
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(upper('aBcD')='ABCD'));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(upper('aBcD')!=NULL));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(lower('aBcD')='abcd'));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(lower('aBcD')!=NULL));
select upper(lnnvl(1=1)) from dual;
select lower(lnnvl(1=1)) from dual;

--echo #lnnvl-3-2-7	length
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(length('1')=1));
SELECT 'a' FROM dual WHERE lnnvl(lnnvl(length('1')!=NULL));
select length(lnnvl(1=1)) from dual;




connection default;
--disable_warnings
--error 0,600
drop user 'yyl_lnnvl_mysql'@'%';
--enable_warnings

