--echo #lnnvl-6	pl/sql
--echo #lnnvl-6-1	存储过程
--echo #lnnvl-6-1-1	循环语句
--echo #lnnvl-6-1-1-1、lnnvl-6-1-2	while循环--dml、if条件语句--dml
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE v1 decimal(5,1);
	DECLARE v2 decimal(5,1);
	DECLARE done INT DEFAULT 0 ;
	DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN result_cursor;
	FETCH result_cursor INTO v1,v2;
	WHILE done<>1 DO
		IF v1>10 THEN 
			INSERT INTO test2 SELECT * FROM test1 WHERE lnnvl(f2 IS NULL);
		ELSEIF v1<10 THEN
			INSERT INTO test2(f2) SELECT f1 FROM test1 WHERE lnnvl(f2 IS NULL) GROUP BY f1 HAVING lnnvl(f1<3);
		ELSE 
			INSERT INTO test2 VALUES(v1||'1234567890',v2);
		END IF;
		FETCH result_cursor INTO v1,v2;
	END WHILE;
	CLOSE result_cursor;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test1;
SELECT * FROM test2;


DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE v1 int DEFAULT 20;
	WHILE lnnvl(v1>30) DO
		INSERT INTO test2 VALUES(1,2);
		SET v1=v1+5;
	END WHILE;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test2;


--echo #lnnvl-6-1-1-2	repeat循环--dml
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
--error 0,1051
DROP TABLE test3;
CREATE TABLE test1(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
CREATE TABLE test3(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test3 VALUES(50,100);
INSERT INTO test3 VALUES(2.7,2);
INSERT INTO test3 VALUES(exp(1),2.8);
INSERT INTO test3(f1) VALUES(10.1);
INSERT INTO test3(f2) VALUES(10.1);
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN 
	DECLARE v1 decimal(5,1);
	DECLARE v2 decimal(5,1);
	DECLARE done INT DEFAULT 0 ;
	DECLARE result_cursor CURSOR FOR SELECT f1,f2 FROM test1;
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN result_cursor;
	FETCH result_cursor INTO v1,v2;
	REPEAT
		IF v1=10.1 THEN 
			DELETE FROM test1 WHERE lnnvl(lnnvl(f1>30));
			DELETE FROM test1 WHERE f2 BETWEEN (SELECT f2 FROM test3 WHERE lnnvl(f2>2) AND f2 IS NOT NULL) AND (SELECT max(f2) FROM test3 WHERE lnnvl(f2<2) AND f2 IS NOT NULL);
			DELETE FROM test1 WHERE lnnvl(f2+9.9<(SELECT avg(m)+12 FROM (SELECT 10+f2 m FROM test3 WHERE lnnvl(f1>4) GROUP BY f2 HAVING lnnvl(f2>=2) OR lnnvl(f2<=2) ORDER BY 1) t1 LIMIT 1));
			INSERT INTO test2 VALUES(v1,v2);
		ELSEIF v1 IS NULL THEN 
			INSERT INTO test1 VALUES(5,5);
			INSERT INTO test1 VALUES(10,2);
			INSERT INTO test1 VALUES(NULL,NULL);
			UPDATE test1 SET f1=(SELECT max(f2) FROM test3 WHERE lnnvl(f1<2)) WHERE f2 IS NOT NULL AND lnnvl(f2!=2);
			INSERT INTO test2 VALUES(v1,v2);
		END IF;
		FETCH result_cursor INTO v1,v2;
	UNTIL done=1 END REPEAT;
	CLOSE result_cursor;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test1;
SELECT * FROM test2;
SELECT * FROM test3;


DELETE FROM test2 WHERE 1=1;
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN 
	DECLARE i int DEFAULT 1;
	REPEAT
		INSERT INTO test2 VALUES(1,2);
		SET i=i+1;
	UNTIL lnnvl(i!=4) END REPEAT;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test2;


