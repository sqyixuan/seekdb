INSERT INTO test1 VALUES(50,100);
INSERT INTO test1 VALUES(2.7,2);
INSERT INTO test1 VALUES(exp(1),2.8);
INSERT INTO test1(f1) VALUES(10.1);
INSERT INTO test1(f2) VALUES(10.1);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
CREATE TABLE test3(f1 decimal(5,1), f2 decimal(5,1));
INSERT INTO test3 VALUES(50,100);
INSERT INTO test3 VALUES(2.7,2);
INSERT INTO test3 VALUES(exp(1),2.8);
INSERT INTO test3(f1) VALUES(10.1);
INSERT INTO test3(f2) VALUES(10.1);
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE v_in int DEFAULT 2;
	loop1:LOOP 
		IF v_in<0 THEN
			UPDATE test1 SET f2=11 WHERE lnnvl(f2<2) AND f1 IS NOT NULL;
			UPDATE test1 SET f1='6' WHERE lnnvl((SELECT max(f2) FROM test3 WHERE lnnvl(f1>2)) IS NULL);
			LEAVE loop1;
		END IF;
		SET v_in = v_in-2;
	END LOOP;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test1;
SELECT * FROM test3;


--echo #lnnvl-6-1-2	 if条件语句--dml
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro() 
BEGIN 
	DECLARE i int DEFAULT 5;
	IF lnnvl(i<1) THEN
		INSERT INTO test2 VALUES(1,2);
	END IF;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test2;


--echo #lnnvl-6-1-3	游标
--error 0,1051
DROP TABLE test1;
--error 0,1051
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1),f2 decimal(5,1));
INSERT INTO test1 VALUES('20.1','10');
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES(NULL,NULL);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
--error 0,1305
DROP PROCEDURE test_pro;
delimiter //;
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE v1 decimal(5,1);
	DECLARE v2 decimal(5,1);
	DECLARE done INT DEFAULT 0;
	DECLARE result_cursor CURSOR FOR SELECT DISTINCT f1,f2 FROM test1 WHERE lnnvl(f2>30) GROUP BY f1,f2 HAVING lnnvl(f1!=20.1);
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	OPEN result_cursor;
	FETCH result_cursor INTO v1,v2;
	WHILE done<>1 DO
		INSERT INTO test2 VALUES(v1,v2);
		FETCH result_cursor INTO v1,v2;
	END WHILE;
	CLOSE result_cursor;
END;
//
delimiter ;//
CALL test_pro();
SELECT * FROM test1;
SELECT * FROM test2;


