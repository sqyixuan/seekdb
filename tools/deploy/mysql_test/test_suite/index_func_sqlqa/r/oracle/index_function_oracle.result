CREATE INDEX t1_01 on t1(a);
select index_name,index_type,UNIQUENESS,TABLE_NAME from user_indexes;
INDEX_NAME	INDEX_TYPE	UNIQUENESS	TABLE_NAME
T1_01	NORMAL	NONUNIQUE	T1
analyze table t1 compute statistics;
explain SELECT /*+ index (T1 t1_01) */ COUNT(*) FROM t1 WHERE a=2;
Query Plan
=======================================================
|ID|OPERATOR          |NAME     |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |SCALAR GROUP BY   |         |1       |3           |
|1 |└─TABLE RANGE SCAN|T1(T1_01)|1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
  1 - output([T_FUN_COUNT(*)]), filter(nil), rowset=16
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.A], [T1.__pk_increment]), range(2,MIN ; 2,MAX), 
      range_cond([T1.A = 2]), 
      pushdown_aggregation([T_FUN_COUNT(*)])
alter table T1 tablegroup='';
DROP tablegroup tgp;
DROP TABLE T1;
create tablegroup tgp;
CREATE TABLE T1(
t1_id NUMBER NOT NULL,
first_name VARCHAR2(50),
last_name VARCHAR2(50),
sex VARCHAR2(20) CHECK(sex ='男' or sex='女')
) tablegroup tgp partition by hash (first_name)
(
partition part_1,
partition part_2
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四','男');
INSERT INTO T1 VALUES (3,'ve2l2i22t','id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
本地散列非前缀索引
CREATE INDEX T1_PARTITION_1 ON T1(t1_id) local;
