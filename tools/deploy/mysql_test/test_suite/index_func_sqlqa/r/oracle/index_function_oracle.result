      equal_conds([T1.ID = T2.ID]), other_conds(nil)
      merge_directions([ASC])
  2 - output([T1.ID], [T1.SAL], [T1.CONSUMER]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.ID], [T1.SAL], [T1.CONSUMER]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([T1.ID], [T1.shadow_pk_0]), range(MIN,MIN ; MAX,MAX)always true
  3 - output([T2.PRICE], [T2.ID]), filter(nil), rowset=16
      sort_keys([T2.ID, ASC])
  4 - output([T2.ID], [T2.PRICE]), filter(nil), rowset=16
      access([T2.ID], [T2.PRICE]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
