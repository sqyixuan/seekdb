TABLE_NAME	LOCALITY	PARTITIONING_TYPE	ALIGNMENT
T1	LOCAL	HASH	NON_PREFIXED
SELECT INDEX_NAME,PARTITION_NAME FROM user_ind_partitions;
INDEX_NAME	PARTITION_NAME
T1_PARTITION_1	PART_1
T1_PARTITION_1	PART_2
analyze table t1 compute statistics;
TABLE SCAN T1(T1_PARTITION_1)
explain SELECT  first_name FROM t1 WHERE t1_id>2 AND T1_ID<4 ORDER BY t1.T1_ID;
Query Plan
=========================================================================
|ID|OPERATOR                   |NAME              |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT  |                  |1       |12          |
|1 |└─EXCHANGE OUT DISTR       |:EX10000          |1       |12          |
|2 |  └─SORT                   |                  |1       |12          |
|3 |    └─PX PARTITION ITERATOR|                  |1       |11          |
|4 |      └─TABLE RANGE SCAN   |T1(T1_PARTITION_1)|1       |11          |
=========================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(T1.FIRST_NAME)]), filter(nil), rowset=16
      sort_keys([T1.T1_ID, ASC])
  1 - output([T1.T1_ID], [INTERNAL_FUNCTION(T1.FIRST_NAME)]), filter(nil), rowset=16
      dop=1
  2 - output([T1.T1_ID], [T1.FIRST_NAME]), filter(nil), rowset=16
      sort_keys([T1.T1_ID, ASC]), local merge sort
  3 - output([T1.FIRST_NAME], [T1.T1_ID]), filter(nil), rowset=16
      force partition granule
  4 - output([T1.FIRST_NAME], [T1.T1_ID]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.FIRST_NAME], [T1.T1_ID]), partitions(p[0-1])
      is_index_back=true, is_global_index=false, 
      range_key([T1.T1_ID], [T1.__pk_increment]), range(2,MAX ; 4,MIN), 
      range_cond([T1.T1_ID > 2], [T1.T1_ID < 4])
DROP INDEX T1_PARTITION_1;
