DROP TABLE T1;
DROP TABLE T2;
CREATE TABLE T1 (
ID NUMBER,
CONSUMER CHAR(20),
BRAND VARCHAR2(20),
SAL NUMBER
);
INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',-4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',0);
INSERT INTO t1 VALUES(4,'流苏','huawei',NULL);
INSERT INTO t1 VALUES(5,'玻璃','LG',6000);
CREATE VIEW t2 AS SELECT *  FROM t1;
CREATE INDEX t2_index ON t2(BRAND);
DROP INDEX t2_index;
CREATE UNIQUE INDEX t2_uniq_idx ON t2(ID) ;
CREATE UNIQUE INDEX t2_uniq_idx_dou ON t2(ID,CONSUMER);
CREATE INDEX t2_func_idx ON T2(SUBSTR(BRAND,0,2));
DROP INDEX t2_func_idx;
CREATE INDEX t2_reve_idx ON T2(BRAND) reverse;
DROP TABLE T1;
DROP VIEW T2;
CREATE TABLE T1(
t1_id NUMBER NOT NULL,
first_name VARCHAR2(50),
last_name VARCHAR2(50),
sex VARCHAR2(20) CHECK(sex ='男' or sex='女')
)PARTITION BY RANGE(t1_id)
(
PARTITION id_part1 values less than (3),
PARTITION id_part2 values less than (8),
PARTITION id_part3 values less than (MAXVALUE)
);
INSERT INTO T1 VALUES (1,'张','三','男');
INSERT INTO T1 VALUES (2,'李','四','男');
INSERT INTO T1 VALUES (3,'ve2l2i22t','id','女');
INSERT INTO T1 VALUES (4,'dolor','ut','男');
INSERT INTO T1 VALUES (5,'sed','dolore ','女');
INSERT INTO T1 VALUES (6,'eiusmod','dolor sit','男');
INSERT INTO T1 VALUES (7,'reprehenderit','Lorem','女');
INSERT INTO T1 VALUES (8,'velit','labor','男');
INSERT INTO T1 VALUES (9,'proident','Excepteur','女');
INSERT INTO T1 VALUES (10,'magna','enim','男');
CREATE INDEX t1_partition_1 ON T1(first_name) local;
alter index t1_partition_1 drop partition id_part1;
CREATE INDEX T1_PARTITION_2 ON T1(t1_id)
GLOBAL PARTITION BY RANGE (t1_id)(
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (MAXVALUE)
);
alter index t1_partition_2 drop partition p1;
alter table t1 drop partition id_part1 update indexes;
DROP TABLE T1;
CREATE tablegroup tgp;
CREATE TABLE t1 (a number, b varchar2(20)) tablegroup tgp;
insert into t1 values(1, '张三');
insert into t1 values(2, '李四');
insert into t1 values(3, '王五');
