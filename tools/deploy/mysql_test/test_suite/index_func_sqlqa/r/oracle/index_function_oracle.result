全局范围分区索引
CREATE INDEX T1_PARTITION_1 ON T1(t1_id)
GLOBAL PARTITION BY RANGE (t1_id)(
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (MAXVALUE)
);
select t2.locality,t1.index_name,t2.table_name,t2.PARTITIONING_TYPE,t2.ALIGNMENT,t1.partition_name,t1.status,t1.tablespace_name from user_ind_partitions t1, user_part_indexes t2 where t1.index_name in ('T1_PARTITION_1') order by index_name,partition_name;
