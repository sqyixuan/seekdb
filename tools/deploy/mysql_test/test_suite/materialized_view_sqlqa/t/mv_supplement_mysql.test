--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';



--echo ##物化视图上的索引操作，如增删索引，重命名，改并行度
--echo ##修改物化视图并行度
create table t1 (c1 number(10),c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1  parallel 9 refresh fast on demand as select c1 as c1, count(*) cnt from t1 group by c1;
ALTER MATERIALIZED VIEW mv1 PARALLEL 100;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 number(10),c2 number(10), c3 number, c4 number);
create materialized view mv1   refresh complete on demand as select c1 as c1, count(*) cnt from t1 group by c1;
--error 1235
alter table mv1 PARALLEL 100;


--echo ##违反约束创建唯一索引
drop table t1;
drop materialized view mv1;
create table t1 (c1 number(10),c2 number(10), c3 number, c4 number);
insert into t1 values(1,1,1,1);
create materialized view mv1  parallel 9 refresh complete on demand as select * from t1;
insert into t1 values(1,1,1,1);
CREATE UNIQUE INDEX index_name ON mv1 (c1,c3);
CREATE UNIQUE INDEX index_name1 ON mv1 (c2);
--error 1064
alter index index_name parallel 100;
--error 1064
alter index index_name1 parallel 100;




--echo ##mysql语法不支持修改索引的并行度
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX index_name ON mv1 (id) parallel 10;
--error 1064
alter index index_name parallel 2;



--echo ##重命名索引(相同索引名)
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
--error 1061
ALTER table mv1 RENAME INDEX idx_name TO idx_name ;
drop index idx_name on mv1;



--echo ##重命名索引(中文数字字母)
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100));
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
ALTER table mv1 RENAME INDEX idx_name TO 中文ing123 ;
SHOW INDEX FROM mv1;


DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100));
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX 中文ing123 ON mv1 (id,name,age,email) parallel 100;
ALTER table mv1 RENAME INDEX 中文ing123 TO idx_name ;
SHOW INDEX FROM mv1;

--echo ##重命名索引(已存在对象)
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100));
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX mv1 ON mv1 (id,name,age,email) parallel 100;
ALTER table mv1 RENAME INDEX mv1 TO idx_name ;
SHOW INDEX FROM mv1;


--echo ##重命名索引(错误名)
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100));
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 1000;
--error 1064
ALTER table mv1 RENAME INDEX idx_name TO null ;


--echo ##索引名的长度
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX 中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文 ON mv1 (id,name,age,email) parallel 100;
show index from mv1;
drop index 中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文中文 on mv1;


--echo ##索引名为关键字
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
--error 1064
CREATE INDEX dual ON mv1 (id,name,age,email) parallel 100;



--echo ##删除查看索引是否存在
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
drop index idx_name on mv1;
show index from mv1;




--echo ##创建不同索引名的相同列
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
CREATE INDEX idx_name1 ON mv1 (id,name,age,email) parallel 100;
drop index idx_name on mv1;
drop index idx_name1 on mv1;



--echo ##创建相同索引名的相同列
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
--error 1061
CREATE INDEX idx_name ON mv1 (id,name,age,email) parallel 100;
drop index idx_name on mv1;



--echo ##创建相同索引名的不同列名
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name) parallel 100;
--error 1061
CREATE INDEX idx_name ON mv1 (email) parallel 100;
drop index idx_name on mv1;

--echo ##创建不同索引名的不同列名
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX idx_name ON mv1 (id,name) parallel 100;
CREATE INDEX idx_name1 ON mv1 (email) parallel 100;
drop index idx_name on mv1;
drop index idx_name1 on mv1;


--echo ##增量更新
--echo ##创建不同索引名的相同列

DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER primary key,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
create materialized view log on t1  with  primary key,rowid,sequence(name,age,email) including new values;
CREATE MATERIALIZED VIEW  mv1 refresh fast on demand  AS SELECT id id,count(*) cnt FROM t1 group by id;
CREATE INDEX idx_name ON mv1 (id,cnt) parallel 100;
CREATE INDEX idx_name1 ON mv1 (id,cnt) parallel 100;
#show index from mv1;


--echo ##创建相同索引名的相同列
DROP MATERIALIZED VIEW LOG ON  t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER primary key,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
create materialized view log on t1  with  primary key,rowid,sequence(name,age,email) including new values;
CREATE MATERIALIZED VIEW  mv1 refresh fast on demand  AS SELECT id id,count(*) cnt FROM t1 group by id;
CREATE INDEX idx_name ON mv1 (id,cnt)  parallel 100;
--error 1061
CREATE INDEX idx_name ON mv1 (id,cnt)  parallel 100;
#show index from mv1;



--echo ##创建相同索引名的不同列名
DROP MATERIALIZED VIEW LOG ON  t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER primary key,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
create materialized view log on t1  with  primary key,rowid,sequence(name,age,email) including new values;
CREATE MATERIALIZED VIEW  mv1 refresh fast on demand  AS SELECT id id,count(*) cnt FROM t1 group by id;
CREATE INDEX idx_name ON mv1 (id) parallel 100;
--error 1061
CREATE INDEX idx_name ON mv1 (cnt) parallel 100;
#show index from mv1;

--echo ##创建不同索引名的不同列名
DROP MATERIALIZED VIEW LOG ON  t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  id NUMBER primary key,
  name VARCHAR(100),
  age NUMBER,
  email VARCHAR(100)
);
create materialized view log on t1  with  primary key,rowid,sequence(name,age,email) including new values;
CREATE MATERIALIZED VIEW  mv1 refresh fast on demand  AS SELECT id id,count(*) cnt FROM t1 group by id;
CREATE INDEX idx_name ON mv1 (id) parallel 100;
CREATE INDEX idx_name1 ON mv1 (cnt) parallel 100;
#show index from mv1;



--echo  ########清空回收站，删除测试数据库，表等 ##########
--disable_warnings
drop database  IF EXISTS db1;

