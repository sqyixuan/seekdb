--echo ##重复值验证
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number ,c2 char(10), c3 char(20), c4 char(20));
insert into t1 values(null,'null','null',null);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
insert into t1 values(1,lpad('a',10,'b'),lpad('a',20,'b'),lpad('a',20,'b'));
insert into t1 values(1,lpad('a',10,'b'),lpad('a',20,'b'),lpad('a',20,'b'));
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from t1 order by c1;
delete from t1 where c1 is not null;

--echo ##异常情况验证
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number ,c2 char(10) default 'zhongwen', c3 char(20), c4 char(20));
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
insert into t1 values(null,null,lpad('a',22,''),lpad('a',22,''));
insert into t1(c1,c3) values(99,'true');
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from t1 order by c1;


--echo ##基表存在约束验证
--echo ##主键约束
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number primary key,c2 char(10) default 'zhongwen', c3 char(20), c4 char(20));
insert into t1 values(1,'null','null',null);
insert into t1 values(2,'null','null',null);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
--error 1062
insert into t1 values('1',null,lpad('a',-1,'1'),lpad('a',20,'1'));
CALL DBMS_MVIEW.REFRESH('mv1','f');
select ROUND(min(cnt),5) from mv1;
select * from t1 order by c1;


--echo ##唯一约束
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number ,c2 char(10) default 'zhongwen', c3 char(20), c4 char(20),UNIQUE (c1, c2));
insert into t1 values(1,'null','null',null);
insert into t1 values(2,'null','null',null);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
CALL DBMS_MVIEW.REFRESH('mv1','f');
--error 1062
insert into t1 values(2,'null','null',null);
select * from mv1 order by c1;
select * from t1 order by c1;


--echo ##not null
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number not null ,c2 char(10) default 'zhongwen', c3 char(20), c4 char(20));
insert into t1 values(1,'zhongwen','中文','中文ing12');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
--error 1048
insert into t1 values(lpad('',null,'1'),'null','null',null);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
select * from t1;

--echo ##check
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number check (c1>10 and c1<100) ,c2 char(10) default 'zhongwen', c3 char(20), c4 char(20));
insert into t1 values(11,'zhongwen','中文','中文ing12');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3 from t1 group by c1;
insert into t1 values(lpad('1',2,'1'),'null','null',null);
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
select * from t1 order by c2;


--echo ##FOREIGN KEY
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number,constraint fk_c2 foreign key(c2) references t1(c1));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view mv1 refresh fast start with sysdate() + interval 1 second next sysdate() + interval 10 second as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t1 values(1,null,3,4);
insert into t1(c1,c3,c4) values(2,3,4);
insert into t1(c1,c3,c4) values(5,5,4);
insert into t1 values(-1,-1,3,4);
insert into t1 values(-321,-321,3,4);
insert into t1 values(0,0,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');
delete from t1 where c2 is null;
select * from mv1 order by c2;
select * from t1 order by c2;



--echo ##基表join 暂不支持
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number,constraint fk_c2 foreign key(c2) references t1(c1));
CREATE TABLE t2 (a1 number(10) primary key,a2 number(10), a3 number, a4 number,constraint fk_a2 foreign key(a2) references t2(a1));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view log on t2 parallel 9 with rowid, sequence (a2,a4,a3) including new values;
create materialized view mv1 refresh fast start with sysdate() + interval 1 second next sysdate() + interval 10 second as select c2 as c2, count(*) cnt, count(c2) cnt_c2  from t1,t2  group by c2;


--echo ##验证多个mv连接
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) ,c2 number(10), c3 number, c4 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c4,c3) including new values;
create materialized view mv1 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv2 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);
insert into t1 values(6,2,3,4);
insert into t1 values(7,2,3,4);
insert into t1 values(8,null,3,4);
insert into t1 values(0,0,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');
CALL DBMS_MVIEW.REFRESH('mv2','f');

select * from mv1 order by c2;
select * from mv2 order by c2;
select max(c2),min(c2),sum(c2),avg(c2),count(c2) from mv2;
select mv1.CNT from mv1 inner join mv2 on mv1.avg_c3=mv2.c2 where mv2.c2 in (select c2 from mv2)  order by cnt;


--echo ##多个mv共享一个mlog
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP MATERIALIZED VIEW mv2;

CREATE TABLE t1 (c1 number(10) primary key,c2 number(10), c3 number, c4 number,constraint fk_c2 foreign key(c2) references t1(c1));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view mv1 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv2 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv3 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv4 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv5 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv6 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv7 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv8 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv9 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv10 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv11 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv12 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv13 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv14 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;
create materialized view mv15 parallel 9 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3  from t1 group by c2;

insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);
insert into t1 values(6,2,3,4);
insert into t1 values(7,2,3,4);
insert into t1 values(8,null,3,4);
