--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

--enable_sorted_result

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';

--echo ##增量刷新验证
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
insert into t1 values(1,1,1,1);
insert into t2 values(1,1,1,1);
create materialized view log on t1 with primary key, rowid, sequence (c2, c3) including new values;
create materialized view log on t2 with primary key, rowid, sequence (c2, c3) including new values;

## can not fast refresh
--error 9760
create materialized view t1_mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
--error 9760
create materialized view t1_mv1 refresh fast on demand as select c2 as c2, count(*) cnt, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
--error 9760
create materialized view t1_mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c4) cnt_c4, sum(c3) sum_c3 from t1 group by c2;
--error 9760
create materialized view t1_mv1 refresh fast on demand as select c4 as c4, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c4;

## fast refresh test 
create materialized view t1_mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view t1_mv2 refresh fast on demand as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view t1_mv3 refresh fast on demand as select count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view t1_mv4 refresh fast on demand as select c2 as c2, c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2, c3;
create materialized view t1_mv5 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;

insert into t1 values(2,2,3,4);
insert into t1 values(3,2,3,4);
insert into t1 values(4,2,3,4);
insert into t1 values(5,2,3,4);

CALL DBMS_MVIEW.REFRESH('t1_mv1','f');
CALL DBMS_MVIEW.REFRESH('t1_mv2','f');
CALL DBMS_MVIEW.REFRESH('t1_mv3','f');
CALL DBMS_MVIEW.REFRESH('t1_mv4','f');
CALL DBMS_MVIEW.REFRESH('t1_mv5','f');


select * from t1_mv1 order by c2;
select * from t1_mv2;
select * from t1_mv3;
select * from t1_mv4 order by c2;
select * from t1_mv5 order by c2;


DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON t2;
drop table t1;
drop table t2;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
drop materialized view t1_mv3;
drop materialized view t1_mv4;
drop materialized view t1_mv5;

--echo ##针对空表进行验证
--echo ##物化视图中存在数据,进行刷新
--echo ##边界条件测试：测试在边界条件下的增量更新行为，例如测试在分区切换、分区维护、索引重建等情况下的表现。
--echo ##重复执行测试：多次执行增量更新操作，以确保在重复执行过程中不会出现数据重复、丢失或不一致的情况。

--echo ##dml操作验证
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values ;
create materialized view mv1 refresh fast start with sysdate() + interval 1 second next sysdate() + interval 1 second  as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;

insert into t1 values(2,3,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','f');


update t1 set c2 = 1 where c1=2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;


delete from t1 where c1 =2;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;

DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv1;
create table t1(c1 number primary key, c2 number, c3 number, c4 number);
create materialized view mv1 refresh complete start with sysdate() + interval 1 second next sysdate() + interval 1 second as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;

insert into t1 values(2,3,3,4);
CALL DBMS_MVIEW.REFRESH('mv1','c');


update t1 set c2 = 1 where c1=2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1;


delete from t1 where c1 =2;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1;

