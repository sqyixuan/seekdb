--echo ##创建存在虚拟列的mv
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
  c1 INT,
  c2 VARCHAR(50),
  c3 VARCHAR(50),
  c2_c3 VARCHAR(100) AS (CONCAT(c2, ' ', c3)) VIRTUAL
);

insert into t1(c1,c2,c3) values(11,'zhongwen','中文');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 9760
create materialized view mv1 refresh fast on demand  as select c2_c3 as c2_c3, count(*) cnt, count(c2_c3) cnt_c23 from t1 group by c2_c3;


--echo ##创建使用存储列的mv
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;

CREATE TABLE t1 (
  c1 INT,
  c2 VARCHAR(50),
  c3 VARCHAR(50),
  c2_c3 VARCHAR(100) AS (CONCAT(c2, ' ', c3)) STORED
);

insert into t1(c1,c2,c3) values(11,'zhongwen','中文');
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
--error 9760
create materialized view mv1 refresh fast on demand  as select c2_c3 as c2_c3, count(*) cnt, count(c2_c3) cnt_c23 from t1 group by c2_c3;


--echo ##边界值验证
--echo ##字符类型的边界值
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
CREATE TABLE t1 (c1 char(10) primary key,c2 char(10), c3 char(20), c4 char(20));
insert into t1 values('ab','中文','123','中文ing123');
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c4,c3) including new values;
create materialized view mv1 refresh fast on demand  as select c1 as c1, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c1;
insert into t1 values(lpad('a',10,'b'),lpad('a',10,'b'),lpad('3',2,'1'),lpad('a',20,'b'));
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by c1;
select * from t1 order by c1;

--echo ##空值验证
