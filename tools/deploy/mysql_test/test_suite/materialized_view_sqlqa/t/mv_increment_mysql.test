CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mlog$_t1 order by SEQUENCE$$;

--echo ##增量更新hash分区 
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key,c2 int, c3 int, c4 int) partition by hash(c1) partitions 5;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 partition by hash(c1) partitions 10  refresh fast on demand as select c1 as c1, count(*) cnt, count(c1) cnt_c1, sum(c1) sum_c1 ,avg(c1) avg_c1 from t1 group by c1;
insert into t1 values(8,null,3,4);
insert into t1 values(0,0,3,4);
delete from t1 where c2 is null ;
update t1 set c2=abs(-999) where c1=0;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
select * from t1;


--echo ##增量更新range分区 
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key,c2 int, c3 int, c4 int) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 partition by range(c1) (PARTITION partition_1 VALUES LESS THAN (2), PARTITION partition_2 VALUES LESS THAN (4)) refresh fast on demand as select c1 as c1, count(*) cnt, count(c1) cnt_c1, sum(c1) sum_c1 ,avg(c1) avg_c1 from t1 group by c1;

insert into t1 values(8,null,3,4);
insert into t1 values(0,0,3,4);
delete from t1 where c2 is null ;
update t1 set c2=abs(-999) where c1=0;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1;
select * from t1;

--echo ##增量更新list分区 
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key,c2 int, c3 int, c4 int) ;
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 partition by list(c1) (PARTITION p1 VALUES in(1,null,3),PARTITION p2 VALUES in(4,5)) refresh fast on demand as select c1 as c1, count(*) cnt, count(c1) cnt_c1, sum(c1) sum_c1 ,avg(c1) avg_c1 from t1 group by c1;

--echo ##list分区中若不存在的值,刷新时报错4014;
##insert into t1 values(2,2,3,4);
insert into t1 values(1,2,3,4);
CALL DBMS_MVIEW.REFRESH('mv1');

select * from mv1;
select * from t1;


