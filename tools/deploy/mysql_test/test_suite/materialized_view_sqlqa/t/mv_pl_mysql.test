--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;



--echo ##存储过程中对基表执行dml操作验证物化视图数据
--echo ##无参存储过程
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
delimiter /;
CREATE  PROCEDURE p1() 
BEGIN
	insert into t1 values(1,3,4);
	call DBMS_MVIEW.REFRESH('mv1','f');
END;
/
delimiter ;/
call p1();
select * from t1;
select * from mv1;
select * from mlog$_t1;



DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int);
create materialized view mv1 refresh complete on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
delimiter /;
CREATE  PROCEDURE p1() 
BEGIN
	insert into t1 values(1,3,4);
	call DBMS_MVIEW.REFRESH('mv1','c');
END;
/
delimiter ;/
call p1();
select * from t1;
select * from mv1;


--echo ##in参数
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 number(10) ,c2 number(10), c3 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t1 values(1,3,4);
delimiter /;
CREATE  PROCEDURE p1(IN a int,IN b int)
BEGIN
  UPDATE t1 SET c1 = a WHERE c2 = b;
  call DBMS_MVIEW.REFRESH('mv1','f');
END;
/
delimiter ;/
call p1(3,3);
select * from t1;
select * from mv1;
select * from mlog$_t1;

DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 number(10) primary key,c2 number(10), c3 number);
create materialized view mv1 refresh complete on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t1 values(1,3,4);
delimiter /;
CREATE  PROCEDURE p1(IN a int,IN b int)
BEGIN
  UPDATE t1 SET c1 = a WHERE c2 = b;
  call DBMS_MVIEW.REFRESH('mv1','c');
END;
/
delimiter ;/
call p1(3,3);
call p1(3,3);
select * from t1;
select * from mv1;


--echo ##out参数
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int,c4 varchar(20));
create materialized view log on t1 parallel 9 with rowid, sequence (c1,c2,c3,c4) including new values;
create materialized view mv1 refresh fast on demand as select  c4 as c4 ,count(*) cnt, count(c4) cnt_c4 from t1 group by c4;
delimiter /;
CREATE  PROCEDURE p1 (OUT mv1 VARCHAR(20))
BEGIN
   insert into t1 values(1,2,3,@mv1);
   call DBMS_MVIEW.REFRESH('mv1','f');
END;
/
delimiter ;/
set @mv1 = upper('Hello, World!');
call p1(@mv1);
select * from t1;
select * from mv1;
select * from mlog$_t1;


DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int,c4 varchar(20));
create materialized view mv1 refresh complete on demand as select  c4 as c4 ,count(*) cnt, count(c4) cnt_c4 from t1 group by c4;
delimiter /;
CREATE  PROCEDURE p1 (OUT mv1 VARCHAR(20))
BEGIN
   set @mv1 = upper('Hello, World!');
   insert into t1 values(1,2,3,@mv1);
   call DBMS_MVIEW.REFRESH('mv1','c');
END;
/
delimiter ;/
call p1(@mv1);
select * from t1;
select * from mv1;

--echo ##in out参数
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int,c4 varchar(20));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 refresh fast on demand as select  c4 as c4 ,count(*) cnt, count(c4) cnt_c4 from t1 group by c4;
insert into t1 values(8,null,3,'中文ing');
insert into t1 values(0,0,3,'abs22');
insert into t1 values(1,1,3,'abs22');
insert into t1 values(3,2,3,'abs22');
delimiter /;
CREATE PROCEDURE p1(IN a varchar(20), INOUT b int)
BEGIN
    UPDATE t1 SET c4 = a WHERE c2 = b;
	call DBMS_MVIEW.REFRESH('mv1','f');
    SET b = b * 2;
END;
/
delimiter ;/
SET @c1 = '先帝创业未半而中道崩殂,今天下三分';
SET @c2 = 2;
CALL p1(@c1, @c2);
select * from t1 order by c1;
select * from mv1 order by c4;


DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP PROCEDURE if exists p1;
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int,c4 varchar(20));
create materialized view mv1 refresh complete on demand as select  c4 as c4 ,count(*) cnt, count(c4) cnt_c4 from t1 group by c4;
insert into t1 values(8,null,3,'中文ing');
insert into t1 values(0,0,3,'abs22');
insert into t1 values(1,1,3,'abs22');
insert into t1 values(3,2,3,'abs22');

delimiter /;
CREATE PROCEDURE p1(IN a varchar(20), INOUT b int)
BEGIN
    UPDATE t1 SET c4 = a WHERE c2 = b;
	call DBMS_MVIEW.REFRESH('mv1','c');
    SET b = b * 2;
END;
/
delimiter ;/
SET @c1 = '先帝创业未半而中道崩殂,今天下三分';
SET @c2 = 2;
CALL p1(@c1, @c2);
select * from t1 order by c1;
select * from mv1 order by c4;



--echo ##自定义函数

DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP function if exists f1;
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int,c4 varchar(20));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3,c4) including new values;
create materialized view mv1 refresh fast on demand as select  c4 as c4 ,count(*) cnt, count(c4) cnt_c4 from t1 group by c4;
insert into t1 values(8,null,3,'中文ing');
insert into t1 values(0,0,3,'abs22');
insert into t1 values(1,1,3,'abs22');
insert into t1 values(3,2,3,'abs22');
delimiter /;
CREATE FUNCTION f1()
RETURNS INT
BEGIN
    DECLARE record_count INT;
    SELECT COUNT(*) INTO record_count FROM t1;
    RETURN record_count;
END;
/
delimiter ;/
call DBMS_MVIEW.REFRESH('mv1','f');
select f1() from dual;
select * from t1 order by c1;
select * from mv1 order by cnt;




--echo ##触发器中使用
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
DROP trigger if exists tr1;
CREATE TABLE t1 (c1 int primary key,c2 int, c3 int,c4 varchar(20));
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t1 values(8,null,3,'中文ing');
insert into t1 values(0,0,3,'abs22');
insert into t1 values(1,1,3,'abs22');
insert into t1 values(3,2,3,'abs22');

--echo ##不支持在mv创建触发器

delimiter /;
--error 1235
CREATE  TRIGGER tr1
AFTER INSERT ON mv1
FOR EACH ROW
BEGIN
	insert into t1 values(1,3,4);
END;
/
delimiter ;/
call DBMS_MVIEW.REFRESH('mv1', 'f'); 


--echo ##insert触发器
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int ,c2 int, c3 int);
CREATE TABLE t2 (c1 int ,c2 int, c3 int);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t1 values(2,2,4);
delimiter /;
CREATE TRIGGER tr1
AFTER INSERT ON t2
FOR EACH ROW
BEGIN
	insert into t1 values(1,3,4);
END;
/
delimiter ;/
insert into t2 values(2,3,4);
call DBMS_MVIEW.REFRESH('mv1', 'f'); 
select * from t1 order by c1;
select * from t2;
select * from mv1 order by c2;


--echo ##update触发器
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP TABLE t2;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) ,c2 number(10), c3 number);
CREATE TABLE t2 (c1 number(10) ,c2 number(10), c3 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t2 values(2,2,4);
delimiter /;
CREATE  TRIGGER tr1
AFTER update ON t2
FOR EACH ROW
BEGIN
	insert into t1 values(1,3,4);
END;
/
delimiter ;/
update t2 set c2=1 where c3 =4;
call DBMS_MVIEW.REFRESH('mv1', 'f'); 
select * from t1;
select * from t2;
select * from mv1;

--echo ##delete触发器
DROP MATERIALIZED VIEW LOG ON t1;
DROP TABLE t1;
DROP TABLE t2;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 number(10) ,c2 number(10), c3 number);
CREATE TABLE t2 (c1 number(10) ,c2 number(10), c3 number);
create materialized view log on t1 parallel 9 with rowid, sequence (c2,c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c2) cnt_c2, sum(c2) sum_c3 ,avg(c2) avg_c3 from t1 group by c2;
insert into t2 values(2,2,4);
insert into t2 values(null,2,4);
delimiter /;
CREATE  TRIGGER tr1
AFTER delete ON t2
FOR EACH ROW
BEGIN
	insert into t1 values(1,3,4);
END;
/
delimiter ;/
delete from t2 where c1 is null;
call DBMS_MVIEW.REFRESH('mv1', 'f'); 
select * from t1;
select * from t2;
select * from mv1;


--echo  ########清空回收站，删除测试数据库，表等 ##########
--disable_warnings
drop database  IF EXISTS ljh;
