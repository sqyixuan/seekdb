--echo ##datatypes
--echo ##验证所有数据类型创建物化视图
CREATE TABLE my_table (
   int_col INT,
   bigint_col BIGINT,
   mediumint_col MEDIUMINT,
   smallint_col SMALLINT,
   tinyint_col TINYINT,
   bit_col BIT,
   float_col FLOAT(6, 2),
   double_col DOUBLE(6, 2),
   decimal_col DECIMAL(6, 2),
   char_col CHAR(10),
   varchar_col VARCHAR(255),
   blob_col BLOB,
   text_col TEXT,
   enum_col ENUM('Value1', 'Value2', 'Value3'),
   set_col SET('Option1', 'Option2', 'Option3'),
   date_col DATE,
   datetime_col DATETIME,
   timestamp_col TIMESTAMP,
   time_col TIME,
   year_col YEAR
);

create materialized view mv1    as select * from my_table ;

--echo ##创建存储过程插入一千条数据
DELIMITER //;

CREATE PROCEDURE insert_random_data()
BEGIN
   DECLARE counter INT DEFAULT 0;
   
   WHILE counter < 10000 DO
      INSERT INTO my_table (int_col, bigint_col, mediumint_col, smallint_col, tinyint_col, bit_col, float_col, double_col, decimal_col, char_col, varchar_col, blob_col, text_col, enum_col, set_col, date_col, datetime_col, timestamp_col, time_col, year_col)
      VALUES (FLOOR(RAND() * 1000), FLOOR(RAND() * 10000000), FLOOR(RAND() * 5000), FLOOR(RAND() * 1000), FLOOR(RAND() * 10), FLOOR(RAND() + 0.5), RAND(), RAND(), RAND(), 'RandomChar', CONCAT('Random', FLOOR(RAND() * 1000)), 'RandomBlob', 'RandomText', ELT(FLOOR(RAND() * 3) + 1, 'Value1', 'Value2', 'Value3'), ELT(FLOOR(RAND() * 3) + 1, 'Option1', 'Option2', 'Option3'), CURDATE() - INTERVAL FLOOR(RAND() * 365) DAY, NOW() - INTERVAL FLOOR(RAND() * 365) DAY, CURRENT_TIMESTAMP, SEC_TO_TIME(FLOOR(RAND() * 86400)), YEAR(CURDATE() - INTERVAL FLOOR(RAND() * 100) YEAR));
      
      SET counter = counter + 1;
   END WHILE;
   
   SELECT 'Random data insertion completed.' AS Result;
END //

DELIMITER ;//

CALL insert_random_data();
call DBMS_MVIEW.REFRESH('mv1');
select count(*) from my_table;
select count(*) from mv1;


