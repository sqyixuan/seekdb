--echo ##全量刷新
drop materialized view mv1;
drop table t1;
create table t1 (c1 number ,c2 number);
create materialized view mv1  refresh complete on demand  as select c1,c2 from t1 ;

DELIMITER //;
CREATE PROCEDURE insert_data()
BEGIN
    DECLARE i INT DEFAULT 1;
    
    WHILE i <= 10000 DO
        INSERT INTO t1 (c1, c2) VALUES (i, i);
        SET i = i + 1;
    END WHILE;
    
    SELECT 'Data inserted successfully.';
END 
//
DELIMITER ;//

CALL insert_data();
CALL DBMS_MVIEW.REFRESH('mv1','c');
select count(*) from t1;
select count(*) from mv1;

--echo ##增量刷新
SET @@sql_mode='';
drop materialized view mv1;
drop table t1;
create table t1 (c1 number,c2 number);
create materialized view log on t1 with rowid, sequence (c2) including new values ;
create materialized view mv1  REFRESH FAST ON demand  as select c2 as c2,count(*) e from t1 group by c2 ;
insert into t1 values(10,10);
insert into t1 values(1,10);
update t1 set c1 = '' where c1 = 1;
delete from t1 where c1 = '';
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from t1 order by c1;
select * from mv1 order by c2;
select * from mlog$_t1 order by SEQUENCE$$;


--echo ##基表dml操作对物化视图日志的影响
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 int primary key,c2 int);
create materialized view log on t1 ;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = 1 where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;
select * from t1 order by c1;

SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
--echo ##基表创建索引
CREATE INDEX index_name ON t1(c2);
ALTER TABLE t1 RENAME INDEX index_name TO new_index_name;
--echo ##修改列名 --不支持
--error 1235
ALTER TABLE t1 RENAME COLUMN c1 TO new_c1;


--echo ##hash分区表指定物化视图为hash分区方式
SET @@sql_mode='';
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 5;
create materialized view log on t1 ;
create materialized view mv1(c1, c2) partition by hash(c1) partitions 2 as select * from t1;

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
select * from mv1 order by c1;

--echo ##hash分区表指定物化视图为range分区方式
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 5;
create materialized view log on t1 ;
create materialized view mv1(c1, c2) partition by range(c1) (PARTITION partition_1 VALUES LESS THAN (2), PARTITION partition_2 VALUES LESS THAN (4)) as select * from t1;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;
--error 1526
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
select * from mv1 order by c1;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 5;
create materialized view log on t1 ;
create materialized view mv1(c1, c2) partition by range(c1) (PARTITION partition_1 VALUES LESS THAN (889), PARTITION partition_2 VALUES LESS THAN (1000)) as select * from t1;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
select * from mv1 order by c1;



--echo ##hash分区表指定物化视图为list分区方式
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 5;
create materialized view log on t1 ;
create materialized view mv1(c1, c2) partition by list(c1) (PARTITION partition_1 VALUES in(1,888,999),PARTITION partition_2 VALUES in(2,null)) as select * from t1;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
select * from mv1 order by c1;


--echo ##修改时区
set time_zone='+09:00';
DROP MATERIALIZED VIEW LOG ON  t1;
drop materialized view mv1;
drop table t1;
create table t1 (c1 number ,c2 number);
insert into t1 values(30,10);
create materialized view mv1  refresh complete start with sysdate() + interval 1 second  as select c1,c2 from t1 ;
select * from t1 order by c1;
select * from mv1 order by c1;


drop table t1;
drop materialized view mv1;
create table t1 (c1 int, c2 int);
create materialized view log on t1 with rowid,sequence(c1,c2) including new values;
create materialized view mv1(c1, c2) partition by hash(c1) partitions 2 as select * from t1;

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
select * from mlog$_t1 order by SEQUENCE$$;


