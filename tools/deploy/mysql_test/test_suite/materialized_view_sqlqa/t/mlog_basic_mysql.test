--echo ##IMMEDIATE
drop table t1;
create table t1 (c1 number primary key,c2 number );
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence( c2) including new values purge IMMEDIATE;
create materialized view mv1  REFRESH FAST ON demand  as select count(*) e from t1 ;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
select * from mlog$_t1;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mlog$_t1 order by SEQUENCE$$;


--echo ##SYNCHRONOUS
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 number primary key,c2 number );
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values purge IMMEDIATE SYNCHRONOUS;
create materialized view mv1  REFRESH FAST ON demand  as select c1 as c1, count(*) e from t1 group by c1;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
select * from mlog$_t1;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mlog$_t1 order by SEQUENCE$$;

--echo ##ASYNCHRONOUS
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
drop materialized view mv1;
create table t1 (c1 number primary key,c2 number );
--error 1235
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1, c2) including new values purge IMMEDIATE ASYNCHRONOUS;
