--echo ##物化视图日志的数据类型验证
--echo ##不支持lob
drop table t1;
create table t1 (c1 number primary key,c2 BLOB );
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values purge  start with sysdate() + interval 1 second next sysdate() + interval 10 second ;


--echo ##其他数据类型验证
CREATE TABLE my_table (
   int_col INT,
   bigint_col BIGINT,
   mediumint_col MEDIUMINT,
   smallint_col SMALLINT,
   tinyint_col TINYINT,
   bit_col BIT,
   float_col FLOAT(6, 2),
   double_col DOUBLE(6, 2),
   decimal_col DECIMAL(6, 2),
   char_col CHAR(10),
   varchar_col VARCHAR(255),
   enum_col ENUM('Value1', 'Value2', 'Value3'),
   set_col SET('Option1', 'Option2', 'Option3'),
   date_col DATE,
   datetime_col DATETIME,
   timestamp_col TIMESTAMP,
   time_col TIME,
   year_col YEAR
);

create materialized view log on my_table parallel 9 with PRIMARY KEY,rowid,sequence(int_col, bigint_col, mediumint_col, smallint_col, tinyint_col, bit_col, float_col, double_col, decimal_col, char_col, varchar_col, enum_col, set_col, date_col, datetime_col, timestamp_col, time_col, year_col) including new values ;

INSERT INTO my_table (int_col, bigint_col, mediumint_col, smallint_col, tinyint_col, bit_col, float_col, double_col, decimal_col, char_col, varchar_col, enum_col, set_col, date_col, datetime_col, timestamp_col, time_col, year_col)
VALUES (1, 1234567890, 12345, 1234, 123, b'1', 12.34, 56.78, 12.34, 'Hello', 'World', 'Value1', 'Option1, Option2', '2021-01-01', '2021-01-01 12:34:56', '2021-01-01 12:34:56', '12:34:56', '2021'),
       (2, 9876543210, 54321, 4321, 321, b'0', 98.76, 54.32, 98.76, 'Foo', 'Bar', 'Value2', 'Option2, Option3', '2022-02-02', '2022-02-02 23:59:59', '2021-01-01 12:34:56', '23:59:59', '2022');

select * from mlog$_my_table order by SEQUENCE$$;


--echo ##mlog存在相同列
drop materialized view log on t1;
drop table t1;
create table t1 (c1 INT primary key, c2 INT);
--error 1060
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c2) including new values purge  start with sysdate() + interval 1 second ;

--echo ##不支持生成列创建mlog
drop table t1;
create table t1 (c1 FLOAT(20) primary key, c2 FLOAT(20),c3  int GENERATED ALWAYS AS (c1 * c2) VIRTUAL);
--error 1235
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c3) including new values ;

--echo ##自引用外键创建mlog
drop table t1;
create table t1 (c1 FLOAT(20) primary key, c2 FLOAT(20));
alter table t1 add constraint fk_c2 foreign key(c2) references t1(c1);
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;


--echo ##删除表报错
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
--error 1235
drop table t1;

--echo ##清空表删除
DROP MATERIALIZED VIEW LOG ON  t1;
DROP MATERIALIZED VIEW mv1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
create materialized view mv1  REFRESH FAST ON demand  as select count(*) e from t1 ;
insert into t1 select 888,999 from dual;
CALL DBMS_MVIEW.REFRESH('mv1','f');
delete from t1;
--error 1235
drop table t1;


--echo ##基表的dml操作
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
insert into t1 values(1,2);
insert into t1 values(2,3);
delete from t1 where c1 =1;
update t1 set c2=2 where c1=2;
select * from mlog$_t1 t order by SEQUENCE$$;


--echo ##基表修改数据类型
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values ;
--error 1235
alter table t1 MODIFY c2 float DEFAULT null;


--echo ##基表创建普通索引
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20), c2 number(20),c3 char(20));
create materialized view log on t1 parallel 9 with rowid,sequence(c1,c2,c3) including new values ;
CREATE INDEX index_name ON t1 (c1);
CREATE INDEX index_name1 ON t1 (c2);
drop index index_name on t1;

--disable_result_log
desc t1;
desc mlog$_t1;
--enable_result_log

--echo ##基表创建唯一索引
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 int(20), c2 int(20),c3 int(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1,c2,c3) including new values;
CREATE UNIQUE INDEX index_name ON t1 (c1,c2,c3);
insert into t1 values(1,2,3);
insert into t1 values(1,null,2);
insert into t1 values(3,null,2);
select * from t1 order by c1;
select * from mlog$_t1 order by SEQUENCE$$;
drop index index_name on t1;


--echo ##基表创建函数索引
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20), c2 number(20),c3 char(20));
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c1,c2,c3) including new values ;
CREATE INDEX index_name ON t1 ((upper(c3)));
insert into t1 values(1,2,'asd');
insert into t1 values(2,3,'gf中文');
insert into t1 values(3,5,null);
select * from t1 order by c1;
drop index index_name on t1;


--disable_result_log
desc t1;
desc mlog$_t1;
--enable_result_log

select * from mlog$_t1 order by SEQUENCE$$;


DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20),c3 number(20));
insert into t1 values(-10,99,44);
create materialized view mv5 refresh complete on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;

--echo ##增量更新支持范围
DROP MATERIALIZED VIEW mv1;
DROP MATERIALIZED VIEW mv5;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20),c3 number(20));
create materialized view log on t1  with PRIMARY KEY,rowid,sequence(c2,c3) including new values;
insert into t1 values(10,1222,22);
insert into t1 values(100,19999,33);
insert into t1 values(-10000000000000000000,99999999999999999999,44);
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view mv2 refresh fast on demand as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view mv3 refresh fast on demand as select count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view mv4 refresh fast on demand as select c2 as c2, c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2, c3;
create materialized view mv5 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
select * from mlog$_t1 order by SEQUENCE$$;
CALL DBMS_MVIEW.REFRESH('mv1','?');
CALL DBMS_MVIEW.REFRESH('mv2','?');
CALL DBMS_MVIEW.REFRESH('mv3','?');
CALL DBMS_MVIEW.REFRESH('mv4','?');
CALL DBMS_MVIEW.REFRESH('mv5','?');
select * from mlog$_t1 order by SEQUENCE$$;

select count(c2),count(cnt) from mv1 order by c2;
select sum(c2),sum(cnt) from mv1 order by c2;
select avg(c2),avg(cnt) from mv1 order by c2;
select max(c2),max(cnt) from mv1 order by c2;
select min(c2),min(cnt) from mv1 order by c2;
select distinct c2 from mv1 order by c2;

select count(cnt),count(cnt_c3) from mv2 order by cnt_c3;
select sum(cnt),sum(cnt_c3) from mv2 order by cnt_c3;
select avg(cnt),avg(cnt_c3) from mv2 order by cnt_c3;
select max(cnt),max(cnt_c3) from mv2 order by cnt_c3;
select min(cnt),min(cnt_c3) from mv2 order by cnt_c3;
select distinct cnt from mv2 order by cnt;


select count(cnt_c3),count(cnt_c3) from mv3 order by cnt_c3;
select sum(cnt_c3),sum(cnt_c3) from mv3 order by cnt_c3;
select avg(cnt_c3),avg(cnt_c3) from mv3 order by cnt_c3;
select max(cnt_c3),max(cnt_c3) from mv3 order by cnt_c3;
select min(cnt_c3),min(cnt_c3) from mv3 order by cnt_c3;
select distinct cnt_c3 from mv3 order by cnt_c3;


select count(c2),count(cnt) from mv4 order by c2;
select sum(c2),sum(cnt) from mv4 order by c2;
select avg(c2),avg(cnt) from mv4 order by c2;
select max(c2),max(cnt) from mv4 order by c2;
select min(c2),min(cnt) from mv4 order by c2;
select distinct c2 from mv4 order by c2;


select count(c2),count(cnt) from mv5 order by c2;
select sum(c2),sum(cnt) from mv5 order by c2;
select avg(c2),avg(cnt) from mv5 order by c2;
select max(c2),max(cnt) from mv5 order by c2;
select min(c2),min(cnt) from mv5 order by c2;
select distinct c2 from mv5 order by c2;

--echo ##混合刷新模式
DROP MATERIALIZED VIEW LOG ON  t1;
DROP MATERIALIZED VIEW mv1;
DROP MATERIALIZED VIEW mv2;
DROP MATERIALIZED VIEW mv3;
DROP MATERIALIZED VIEW mv4;
DROP MATERIALIZED VIEW mv5;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20),c3 number(10));
create materialized view log on t1  with PRIMARY KEY,rowid,sequence(c2,c3) including new values;
insert into t1 values(10,1222,22);
insert into t1 values(100,19999,33);
insert into t1 values(-10000000000000000000,99999999999999999999,44);
create materialized view mv1 refresh force on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view mv2 refresh force on demand as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view mv3 refresh force on demand as select count(c3) cnt_c3, sum(c3) sum_c3 from t1;
create materialized view mv4 refresh force on demand as select c2 as c2, c3 as c3, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2, c3;
create materialized view mv5 refresh force on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3, avg(c3) avg_c3, avg(c3) * sum(c3)/c2 calc1, c2+sum(c3) calc2 from t1 group by c2;
select * from mlog$_t1 order by SEQUENCE$$;

CALL DBMS_MVIEW.REFRESH('mv1','?');
CALL DBMS_MVIEW.REFRESH('mv2','?');
CALL DBMS_MVIEW.REFRESH('mv3','?');
CALL DBMS_MVIEW.REFRESH('mv4','?');
CALL DBMS_MVIEW.REFRESH('mv5','?');

select count(c2),count(cnt) from mv1 order by c2;
select sum(c2),sum(cnt) from mv1 order by c2;
select avg(c2),avg(cnt) from mv1 order by c2;
select max(c2),max(cnt) from mv1 order by c2;
select min(c2),min(cnt) from mv1 order by c2;
select distinct c2 from mv1 order by c2;

--echo ##普通表使用join
DROP MATERIALIZED VIEW LOG ON  t1;
DROP MATERIALIZED VIEW mv1;
drop table t1;
create table t1 (c1 number(20) primary key, c2 number(20),c3 number(10));
create table t2 (a1 number(20) primary key, a2 number(20),a3 number(10));
create materialized view mv1 refresh complete on demand as select sum(c2) s, count(c2) as c, count(a3) a from t1,t2 where c3=a3 group by a1;
insert into t1 values(10,1222,22);
insert into t1 values(100,19999,'');
insert into t1 values(-10000000000000000000,99999999999999999999,44);
insert into t2 values(10,1222,'');
insert into t2 values(-10000000000000000000,'',44);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from mv1 order by s;



--echo ##分区表与普通表
DROP MATERIALIZED VIEW mv1;
drop table t1;
drop table t2;
create table t1 (c1 int primary key, c2 int,c3 int);
create table t2 (a1 int primary key, a2 int,a3 int)PARTITION BY HASH(a1) PARTITIONS 200;
create materialized view mv1 refresh complete on demand as select count(a3) a from t1,t2 where c3=a3 group by a1;
insert into t1 values(10,1222,22);
insert into t1 values(100,19999,'');
insert into t1 values(-10000000000000000000,99999999999999999999,44);
insert into t2 values(10,1222,'');
insert into t2 values(-10000000000000000000,'',44);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from mv1;


