--disable_warnings
drop database  IF EXISTS  ljh;
--enable_warnings
create database ljh;
use ljh;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='';


--echo ##parallel创建日志
create table t1 (c1 number ,c2 number);
create materialized view log on t1 parallel 9;

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c1 =888;
select * from mlog$_t1 order by SEQUENCE$$;


--echo ##primary key
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number primary key,c2 number );
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence( c2);

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c1 =888;
select * from mlog$_t1 order by SEQUENCE$$;

--echo ##rowid
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number ,c2 number);
create materialized view log on t1 parallel 9 with ROWID(c1, c2);

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c1 =888;
select * from mlog$_t1 order by SEQUENCE$$;


--echo ##sequence
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number primary key,c2 number );
create materialized view log on t1 parallel 9 with sequence( c2);

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c1 =888;
select * from mlog$_t1 order by SEQUENCE$$;


--echo ##including new values
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number primary key,c2 number );
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence( c2) including new values;

insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c1 =888;
select * from mlog$_t1 order by SEQUENCE$$;

--echo ##including new values
DROP MATERIALIZED VIEW LOG ON  t1;
drop table t1;
create table t1 (c1 number primary key,c2 number );
--error 1235
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence( c2) excluding new values;

