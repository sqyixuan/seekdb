--echo ##表对象为普通视图
drop table t1;
create table t1 (c1 number primary key,c2 number );
create view v1 as select * from t1;
--error 1235
create materialized view log on v1 parallel 9 with PRIMARY KEY,rowid,sequence(c1, c2) including new values purge  start with sysdate() + interval 1 second next sysdate() + interval 1 second ;

--echo ##表对象为物化视图
drop table t1;
create table t1 (c1 number primary key,c2 number );
create materialized view mv1  as select * from t1 ;
create materialized view log on mv1 parallel 9 with PRIMARY KEY,rowid,sequence(c1, c2) including new values purge  start with sysdate() + interval 1 second next sysdate() + interval 1 second ;
drop materialized view log on mv1;

