##对物化视图的基表做相应的DDL操作
##创建索引
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
id int,
name VARCHAR(100),
age int,
email VARCHAR(100),
created_date TIMESTAMP
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX index_name ON mv1 (name);
show index from mv1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
mv1	1	index_name	1	name	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
INSERT INTO t1 (id, name, age, email, created_date) VALUES (1, 'John', 25, 'john@example.com', '1970-01-01 10:10:10');
INSERT INTO t1 (id, name, age, email, created_date) VALUES (2, 'Jane', 30, 'jane@example.com', '2023-11-10 23:59:59');
INSERT INTO t1 (id, name, age, email, created_date) VALUES (3, 'Je', 39, 'Je@example.com', null);
UPDATE t1 SET name = 'John Doe' WHERE id = 1;
DELETE FROM t1 WHERE created_date is null;
call DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by id;
id	name	age	email	created_date
1	John Doe	25	john@example.com	1970-01-01 10:10:10
2	Jane	30	jane@example.com	2023-11-10 23:59:59
select * from mv1 order by id;
id	name	age	email	created_date
1	John Doe	25	john@example.com	1970-01-01 10:10:10
2	Jane	30	jane@example.com	2023-11-10 23:59:59
##增加索引
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
id int,
name VARCHAR(100),
age int,
email VARCHAR(100),
created_date TIMESTAMP
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
ALTER TABLE t1 ADD INDEX idx1(email);
INSERT INTO t1 (id, name, age, email, created_date) VALUES (1, 'John', 25, 'john@example.com', '1970-01-01 10:10:10');
INSERT INTO t1 (id, name, age, email, created_date) VALUES (2, 'Jane', 30, 'jane@example.com', '2023-11-10 23:59:59');
INSERT INTO t1 (id, name, age, email, created_date) VALUES (3, 'Je', 39, 'Je@example.com', null);
UPDATE t1 SET name = 'John Doe' WHERE id = 1;
DELETE FROM t1 WHERE created_date is null;
call DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by id;
id	name	age	email	created_date
1	John Doe	25	john@example.com	1970-01-01 10:10:10
2	Jane	30	jane@example.com	2023-11-10 23:59:59
select * from mv1 order by id;
id	name	age	email	created_date
1	John Doe	25	john@example.com	1970-01-01 10:10:10
2	Jane	30	jane@example.com	2023-11-10 23:59:59
##删除索引
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (
id int,
name VARCHAR(100),
age int,
email VARCHAR(100),
created_date TIMESTAMP,
CONSTRAINT pk_my_table PRIMARY KEY (id),
CONSTRAINT idx_name UNIQUE (name)
);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
CREATE INDEX index_name ON mv1 (name);
show index from mv1;
