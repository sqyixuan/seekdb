create materialized view log on t1 ;
create materialized view mv1(c1, c2) partition by range(c1) (PARTITION partition_1 VALUES LESS THAN (2), PARTITION partition_2 VALUES LESS THAN (4)) as select * from t1;
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
update t1 set c2 = '' where c1 = 999;
delete from t1 where c2 =888;
