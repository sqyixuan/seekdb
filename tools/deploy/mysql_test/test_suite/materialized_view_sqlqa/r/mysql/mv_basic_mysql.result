##列操作
##末尾增加列
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
alter table t1 add c3 int;
CALL DBMS_MVIEW.REFRESH('mv1');
insert into t1 values(1,null,2);
insert into t1 values(null,2,3);
CALL DBMS_MVIEW.REFRESH('mv1');
update t1 set c1=99 where c3=3;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2	c3
1	NULL	2
99	2	3
select * from mv1 order by c1;
c1	c2
1	NULL
99	2
##添加虚拟列
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int,c2 int,c3 DECIMAL(4,2) AS (c1 * 0.1 * c2) VIRTUAL);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2,c3 FROM t1;
insert into t1(c1,c2) values(1,null);
insert into t1(c1,c2) values(null,2);
insert into t1(c1,c2) values(0,2);
CALL DBMS_MVIEW.REFRESH('mv1');
insert into t1(c1,c2) values(3,2);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2	c3
0	2	0.00
1	NULL	NULL
3	2	0.60
NULL	2	NULL
select * from mv1 order by c1;
c1	c2	c3
0	2	0.00
1	NULL	NULL
3	2	0.60
NULL	2	NULL
##删除虚拟列
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int,c2 int,c3 DECIMAL(4,2) AS (c1 * 0.1 * c2) VIRTUAL);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2,c3 FROM t1;
insert into t1(c1,c2) values(3,2);
CALL DBMS_MVIEW.REFRESH('mv1');
ALTER TABLE t1 drop column c3;
CALL DBMS_MVIEW.REFRESH('mv1');
ERROR 42S22: Unknown column 'db1.t1.c3' in 'field list'
insert into t1(c1,c2) values(1,null);
select * from t1 order by c1;
c1	c2
1	NULL
3	2
select * from mv1 order by c1;
c1	c2	c3
3	2	0.60
##修改列为null
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
ALTER TABLE t1 MODIFY c1 int DEFAULT null;
insert into t1(c1,c2) values(1,null);
insert into t1(c1,c2) values(null,2);
insert into t1(c1,c2) values(0,2);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
0	2
1	NULL
NULL	2
select * from mv1 order by c1;
c1	c2
0	2
1	NULL
NULL	2
##设置默认值
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int,c2 int);
insert into t1(c2) values(1);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
ALTER TABLE t1 MODIFY c1 int DEFAULT 10;
insert into t1(c2) values(3);
insert into t1(c2) values(null);
update t1 set c1 =999 where c2=1;
delete from t1 where c2 is null;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
10	3
999	1
select * from mv1 order by c1;
c1	c2
10	3
999	1
##修改列默认值
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int DEFAULT 10,c2 int);
insert into t1(c2) values(1);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
ALTER TABLE t1 MODIFY c1 int DEFAULT 20;
insert into t1(c2) values(3);
insert into t1(c2) values(null);
update t1 set c1 =999 where c2=3;
insert into t1(c2) values(1);
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
10	1
20	1
20	NULL
999	3
select * from mv1 order by c1;
c1	c2
10	1
20	1
20	NULL
999	3
##修改自增列值
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int AUTO_INCREMENT PRIMARY KEY,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
insert into t1(c2) values(3);
insert into t1(c2) values(null);
insert into t1(c2) values(0);
insert into t1(c2) values(99999);
insert into t1(c2) values(1);
update t1 set c1 =-99999999 where c2=3;
delete from t1 where c2 is null;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
-99999999	3
3	0
4	99999
5	1
select * from mv1 order by c1;
c1	c2
-99999999	3
3	0
4	99999
5	1
##重命名列 --不支持
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int DEFAULT 10,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT * FROM t1;
ALTER TABLE t1 CHANGE COLUMN c1 cc1 int;
insert into t1 values(1,2);
insert into t1 values(null,2);
insert into t1(cc1) values(2);
CALL DBMS_MVIEW.REFRESH('mv1','c');
ERROR 42S22: Unknown column 'db1.t1.c1' in 'field list'
select * from t1 order by cc1;
cc1	c2
1	2
2	NULL
NULL	2
select * from mv1 order by c1;
c1	c2
##增加列类型长度或精度
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int DEFAULT 10,c2 varchar(10));
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
ALTER TABLE t1 MODIFY COLUMN c1 int(20);
insert into t1 values(1,2);
insert into t1 values(null,2);
insert into t1 values(2,9);
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by c1;
c1	c2
1	2
2	9
NULL	2
select * from mv1 order by c1;
c1	c2
1	2
2	9
NULL	2
ALTER TABLE t1 MODIFY COLUMN c2 varchar(20);
CALL DBMS_MVIEW.REFRESH('mv1','c');
ERROR 0A000: refresh mv after column types change is not supported
##增加外键约束
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int primary key,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
alter table t1 add constraint fk_c2 foreign key(c2) references t1(c1);
insert into t1 values(10,10);
insert into t1 values(1,10);
insert into t1 values(2,null);
delete from t1 where c1 =1;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
10	10
2	NULL
select * from mv1 order by c1;
c1	c2
10	10
2	NULL
##删除外键约束
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int primary key,c2 int,constraint fk_c2 foreign key(c2) references t1(c1));
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1;
insert into t1 values(10,10);
insert into t1 values(1,10);
insert into t1 values(2,null);
delete from t1 where c2 is null;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
1	10
10	10
select * from mv1 order by c1;
c1	c2
1	10
10	10
alter table  t1 drop constraint fk_c2;
insert into t1 values(12,10);
delete from t1 where c2 = 10 limit 2;
CALL DBMS_MVIEW.REFRESH('mv1');
select * from t1 order by c1;
c1	c2
12	10
select * from mv1 order by c1;
c1	c2
12	10
##重命名表
DROP TABLE t1;
DROP MATERIALIZED VIEW mv1;
CREATE TABLE t1 (c1 int DEFAULT 10,c2 int);
CREATE MATERIALIZED VIEW mv1  AS SELECT c1,c2 FROM t1 t_t1;
alter table t1 rename to t_t1;
insert into t_t1 values(10,10);
insert into t_t1 values(1,10);
insert into t_t1 values(2,null);
delete from t_t1 where c2 is null;
CALL DBMS_MVIEW.REFRESH('mv1');
ERROR 42S02: Table 'db1.t1' doesn't exist
select * from t_t1 order by c1;
c1	c2
1	10
10	10
select * from mv1 order by c1;
c1	c2
##创建全量mv和增量mv后基表创建索引刷新会报错;
drop materialized view mv1;
create table t1 (c1 int primary key,c2 int );
insert into t1 select 999,999 from dual;
insert into t1 select 888,999 from dual;
create materialized view mv1 refresh complete on demand   as  select count(*) as cnt,c1 as c1 from t1 group by c1;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by c1 ;
cnt	c1
1	888
1	999
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2) including new values;
create materialized view mv2 refresh fast on demand   as  select count(*) as cnt,c1 as c1 from t1 group by c1;
CREATE INDEX idx_c2 ON t1 (c2);
CALL DBMS_MVIEW.REFRESH('mv2','f');
DROP MATERIALIZED VIEW LOG ON  t1;
select * from mv2 order by c1 ;
cnt	c1
1	888
1	999
select * from t1 order by c1 ;
c1	c2
888	999
999	999
##结合start with next
##后接null报错1210
drop materialized view mv1;
drop table t1;
create table t1 (c1 int ,c2 int);
create materialized view mv1  refresh complete  start with null next null as select c1,c2 from t1 ;
ERROR HY000: Incorrect arguments to datetime expression
##设置过短的时间
drop table t1;
create table t1 (c1 number ,c2 number);
create materialized view mv1  refresh complete  start with sysdate() + interval 1 second next sysdate() + interval 1 second  as select c1,c2 from t1 ;
insert into t1 values(10,10);
select * from t1;
c1	c2
10	10
select * from mv1;
c1	c2
drop materialized view mv1;
##next设置为错误值
drop table t1;
create table t1 (c1 number ,c2 number);
create materialized view mv1  refresh complete  start with sysdate() + interval 1 second next null as select c1,c2 from t1 ;
ERROR HY000: Incorrect arguments to datetime expression
create materialized view mv1  refresh complete  start with sysdate() + interval 1 second next '中文' as select c1,c2 from t1 ;
ERROR HY000: Incorrect arguments to datetime expression
