##range分区
##直接增量更新结果不符合预期
drop table t1;
drop materialized view mv2;
CREATE TABLE t1 (
id INT,
name VARCHAR(50),
age INT,
salary DECIMAL(10,2),
is_active TINYINT
)
PARTITION BY RANGE (age) (
PARTITION p1 VALUES LESS THAN (30),
PARTITION p2 VALUES LESS THAN (40),
PARTITION p3 VALUES LESS THAN (50),
PARTITION p4 VALUES LESS THAN MAXVALUE
);
create materialized view log on t1 with (id,name,age,salary,is_active);
create materialized view mv2 refresh fast on demand   as  select count(*) as cnt,name as name from t1 group by name;
INSERT INTO t1 (id, name, age, salary, is_active)
