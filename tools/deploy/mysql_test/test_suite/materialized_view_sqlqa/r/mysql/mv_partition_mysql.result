drop database  IF EXISTS  ljh;
create database ljh;
use ljh;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='';
##hash分区
CREATE TABLE t1(id INT,name VARCHAR(50),age INT,salary DECIMAL(10,2),is_active TINYINT)PARTITION BY HASH(id) PARTITIONS 20;
create materialized view log on t1 with (id,name,age,salary,is_active);
create materialized view mv2 refresh fast on demand   as  select count(*) as cnt,name as name from t1 group by name;
INSERT INTO t1 (id, name, age, salary, is_active) VALUES
(1, 'John', 25, 5000.00, 1),
(2, 'Alice', 30, 6000.00, 0),
(3, 'Bob', 35, 7000.00, 1),
(4, 'Sarah', 28, 5500.00, 1),
(5, 'Mike', 32, 8000.00, 0);
CALL DBMS_MVIEW.REFRESH('mv2','c');
CALL DBMS_MVIEW.REFRESH('mv2','f');
select * from mv2 order by name;
cnt	name
1	Alice
1	Bob
1	John
1	Mike
1	Sarah
##创建索引
CREATE INDEX idx_cnt  ON mv2 (cnt);
CREATE INDEX idx_name ON mv2 (name);
INSERT INTO t1  VALUES (6, null, 25, 5000.00, 1);
CALL DBMS_MVIEW.REFRESH('mv2','f');
select * from mv2 order by name;
cnt	name
1	NULL
1	Alice
1	Bob
1	John
1	Mike
1	Sarah
##创建复制表
create table tt1 select * from t1;
create materialized view log on tt1 with (id,name,age,salary,is_active);
create materialized view mv3 refresh fast on demand   as  select count(*) as cnt,name as name from tt1 group by name;
CALL DBMS_MVIEW.REFRESH('mv3','f');
select * from mv3 order by name;
cnt	name
1	NULL
1	Alice
1	Bob
1	John
1	Mike
1	Sarah
##直接增量刷新结果不符合预期；
DROP MATERIALIZED VIEW LOG ON t1;
DROP MATERIALIZED VIEW LOG ON tt1;
drop table t1;
drop table tt1;
drop materialized view mv2;
drop materialized view mv3;
