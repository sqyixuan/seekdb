##dml验证
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv2;
CREATE TABLE t1 (
id INT,
name VARCHAR(50),
age INT,
gender ENUM('Male', 'Female'),
salary DECIMAL(10,2),
is_active TINYINT
)
PARTITION BY RANGE (age)
SUBPARTITION BY HASH(age)
SUBPARTITIONS 2 (
PARTITION p1 VALUES LESS THAN (30) (
SUBPARTITION s1,
SUBPARTITION s2
),
PARTITION p2 VALUES LESS THAN (40) (
SUBPARTITION s3,
SUBPARTITION s4
),
PARTITION p3 VALUES LESS THAN MAXVALUE (
SUBPARTITION s5,
SUBPARTITION s6
)
);
create materialized view log on t1 with (id,name,age,gender,salary,is_active);
INSERT INTO t1 (id, name, age, gender, salary, is_active) VALUES
(1, 'John', 25, 'Male', 5000.00, 1),
(2, 'Alice', 35, 'Female', 6000.00, 0),
(3, 'Bob', 45, 'Male', 7000.00, 1),
(4, 'Sarah', 28, 'Female', 5500.00, 1),
(5, 'Mike', 32, 'Male', 8000.00, 0);
update t1 set gender='Male' where salary > 7000;
delete from t1 where id is null;
create materialized view mv1 refresh fast on demand   as  select count(*) as cnt,gender as gender from t1 group by gender;
CALL DBMS_MVIEW.REFRESH('mv1','f');
select * from mv1 order by gender ;
cnt	gender
3	Male
2	Female
select * from t1 order by id ;
