##list分区
##直接增量刷新结果不符合预期
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
drop materialized view mv2;
CREATE TABLE t1 (
id INT,
name VARCHAR(50),
age INT,
salary DECIMAL(10,2),
is_active TINYINT
)
PARTITION BY LIST (id) (
PARTITION p1 VALUES IN (1, 2),
PARTITION p2 VALUES IN (3, 4),
PARTITION p3 VALUES IN (5, 6),
PARTITION p4 VALUES IN (7, 8),
PARTITION p5 VALUES IN (9, 10)
);
create materialized view log on t1 with (id,name,age,salary,is_active);
create materialized view mv2 refresh fast on demand   as  select count(*) as cnt,name as name from t1 group by name;
