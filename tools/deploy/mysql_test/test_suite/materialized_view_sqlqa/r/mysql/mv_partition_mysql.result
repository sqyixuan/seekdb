##子分区
drop table t1;
drop materialized view mv2;
CREATE TABLE t1 (
id INT,
name VARCHAR(50),
age INT,
gender ENUM('Male', 'Female'),
salary DECIMAL(10,2),
is_active TINYINT
)
PARTITION BY RANGE (age)
SUBPARTITION BY HASH(age)
SUBPARTITIONS 2 (
PARTITION p1 VALUES LESS THAN (30) (
SUBPARTITION s1,
SUBPARTITION s2
),
PARTITION p2 VALUES LESS THAN (40) (
SUBPARTITION s3,
SUBPARTITION s4
),
PARTITION p3 VALUES LESS THAN MAXVALUE (
SUBPARTITION s5,
SUBPARTITION s6
)
);
create materialized view log on t1 with (id,name,age,gender,salary,is_active);
INSERT INTO t1 (id, name, age, gender, salary, is_active) VALUES
(1, 'John', 25, 'Male', 5000.00, 1),
(2, 'Alice', 35, 'Female', 6000.00, 0),
(3, 'Bob', 45, 'Male', 7000.00, 1),
(4, 'Sarah', 28, 'Female', 5500.00, 1),
(5, 'Mike', 32, 'Male', 8000.00, 0);
##全量更新
create materialized view mv1 refresh complete on demand   as  select count(*) as cnt,name as name from t1 group by name;
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from t1 order by id ;
id	name	age	gender	salary	is_active
1	John	25	Male	5000.00	1
2	Alice	35	Female	6000.00	0
3	Bob	45	Male	7000.00	1
4	Sarah	28	Female	5500.00	1
5	Mike	32	Male	8000.00	0
select * from mv1 order by name ;
cnt	name
1	Alice
1	Bob
1	John
1	Mike
1	Sarah
##增量更新
drop materialized view mv1;
create materialized view mv2 refresh fast on demand   as  select count(*) as cnt,name as name from t1 group by name;
CALL DBMS_MVIEW.REFRESH('mv2','f');
select * from mv2 order by name ;
cnt	name
1	Alice
1	Bob
1	John
1	Mike
1	Sarah
