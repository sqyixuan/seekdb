------------------------- еҺӢзј©/и§ЈеҺӢеҮҪж•°-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
### з”ЁдҫӢпјҡcompress-5 compress(str)/uncompressed(str)/uncompressed_length(str) - иҝҗз®—з¬Ұ
-----------------------------------------------------------------------------------------------------------------
### ж Үзӯҫпјҡcompress-5-1 з®—жңҜиҝҗз®—з¬Ұ
SELECT id,name,hex(compress(no + 20 - 5 * 4 / 2)) compress,uncompress(compress(no + 20 - 5 * 4 / 2)) uncompress,uncompressed_length(compress(no + 20 - 5 * 4 / 2)) length FROM compress_table2 ORDER BY id;
+----+--------+------------------------------------+------------+--------+
| id | name   | compress                           | uncompress | length |
+----+--------+------------------------------------+------------+--------+
|  1 | ж¬ўж¬ў   | 05000000789C3334303032040002DF00F5 | 10021      |      5 |
|  2 | жҲҳжҲҳ   | 05000000789C3334303032020002E000F6 | 10022      |      5 |
+----+--------+------------------------------------+------------+--------+
SELECT id,name,compress(no) + compress(no) '+', uncompress(compress(no)) - uncompress(compress(no)) '-', uncompressed_length(compress(no)) * uncompressed_length(compress(no)) '*', uncompress(compress(no)) / uncompress(compress(no)) '/' FROM compress_table2;
+----+--------+------+------+------+------+
| id | name   | +    | -    | *    | /    |
+----+--------+------+------+------+------+
|  1 | ж¬ўж¬ў   |    0 |    0 |   25 |    1 |
|  2 | жҲҳжҲҳ   |    0 |    0 |   25 |    1 |
+----+--------+------+------+------+------+
SELECT id,name,compress(no MOD 2) ,uncompress(compress(no)) DIV uncompressed_length(compress(no)) FROM compress_table2;
+----+--------+--------------------+----------------------------------------------------------------+
| id | name   | compress(no MOD 2) | uncompress(compress(no)) DIV uncompressed_length(compress(no)) |
+----+--------+--------------------+----------------------------------------------------------------+
|  1 | ж¬ўж¬ў   |    xң3  2 2       |                                                           2002 |
|  2 | жҲҳжҲҳ   |    xң3   1 1       |                                                           2002 |
+----+--------+--------------------+----------------------------------------------------------------+
