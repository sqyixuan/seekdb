#CASE WHEN
SELECT id,name,compress(CASE WHEN id >3  THEN NULL ELSE id END) compress FROM compress_table1  ORDER BY id;
+----+--------+---------------+
| id | name   | compress      |
+----+--------+---------------+
|  1 | ж¬ўж¬ў   |    xң3  2 2  |
|  2 | жҲҳжҲҳ   |    xң3  3 3  |
|  3 | й—№й—№   |    xң3  4 4  |
|  4 | жҜӣжҜӣ   | NULL          |
+----+--------+---------------+
SELECT id,name,CASE uncompress(content) WHEN uncompress(compress('зҹҘзҰҸзҰҸеёёеңЁпјҢйҡҸзјҳзјҳиҮӘжқҘгҖӮ')) THEN 'ж¬ўж¬ўзҡ„еҶ…е®№'  ELSE 'е…¶д»–дәәзҡ„еҶ…е®№' END ranks FROM compress_table1 ORDER BY id;
+----+--------+--------------------+
| id | name   | ranks              |
+----+--------+--------------------+
|  1 | ж¬ўж¬ў   | ж¬ўж¬ўзҡ„еҶ…е®№         |
|  2 | жҲҳжҲҳ   | е…¶д»–дәәзҡ„еҶ…е®№       |
|  3 | й—№й—№   | е…¶д»–дәәзҡ„еҶ…е®№       |
|  4 | жҜӣжҜӣ   | е…¶д»–дәәзҡ„еҶ…е®№       |
+----+--------+--------------------+
SELECT id,name,(CASE uncompressed_length(content) WHEN 36 THEN 'еҺӢзј©еүҚеҶ…е®№й•ҝеәҰе°Ҹ' WHEN 89 THEN 'еҺӢзј©еүҚеҶ…е®№й•ҝеәҰдёӯ' ELSE 'еҺӢзј©еүҚеҶ…е®№й•ҝеәҰй«ҳ' END) ranks FROM compress_table1 GROUP BY (CASE compress(content) WHEN compress(5000) THEN 'е·Ҙиө„дҪҺ' WHEN compress(6000) THEN 'е·Ҙиө„дёҖиҲ¬' ELSE 'е·Ҙиө„й«ҳ' END),id ORDER BY id ;
+----+--------+--------------------------+
| id | name   | ranks                    |
+----+--------+--------------------------+
|  1 | ж¬ўж¬ў   | еҺӢзј©еүҚеҶ…е®№й•ҝеәҰе°Ҹ         |
|  2 | жҲҳжҲҳ   | еҺӢзј©еүҚеҶ…е®№й•ҝеәҰй«ҳ         |
|  3 | й—№й—№   | еҺӢзј©еүҚеҶ…е®№й•ҝеәҰдёӯ         |
|  4 | жҜӣжҜӣ   | еҺӢзј©еүҚеҶ…е®№й•ҝеәҰй«ҳ         |
+----+--------+--------------------------+
