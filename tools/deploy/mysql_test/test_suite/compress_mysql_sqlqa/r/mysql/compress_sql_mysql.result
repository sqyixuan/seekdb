------------------------- еҺӢзј©/и§ЈеҺӢеҮҪж•°-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
### з”ЁдҫӢпјҡcompress-2 compress(str)/uncompressed(str)/uncompressed_length(str) - Sql
-----------------------------------------------------------------------------------------------------------------
DROP TABLE compress_table1;
CREATE TABLE `compress_table1` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT 'е§“еҗҚ',
  `content` blob NOT NULL COMMENT 'еҺӢзј©еҶ…е®№',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table1 VALUES(1,'ж¬ўж¬ў',COMPRESS('зҹҘзҰҸзҰҸеёёеңЁпјҢйҡҸзјҳзјҳиҮӘжқҘгҖӮ'));
INSERT INTO compress_table1 VALUES(2,'жҲҳжҲҳ',COMPRESS('UNCOMPRESS(string_to_uncompress)пјҡи§ЈеҺӢзј©з”ұ COMPRESS()еҮҪж•°еҺӢзј©зҡ„еӯ—з¬ҰдёІгҖӮеҰӮжһңеҸӮж•°дёҚжҳҜеҺӢзј©еҖјпјҢеҲҷз»“жһңдёә NULL. '));
INSERT INTO compress_table1 VALUES(3,'й—№й—№',COMPRESS('UNCOMPRESSED_LENGTH(compressed_string)пјҡиҝ”еӣһеҺӢзј©еӯ—з¬ҰдёІеңЁеҺӢзј©д№ӢеүҚзҡ„й•ҝеәҰгҖӮ'));
INSERT INTO compress_table1 VALUES(4,'жҜӣжҜӣ',COMPRESS('COMPRESS(string_to_compress)пјҡеҺӢзј©еӯ—з¬ҰдёІе№¶е°Ҷз»“жһңдҪңдёәдәҢиҝӣеҲ¶еӯ—з¬ҰдёІиҝ”еӣһгҖӮжӯӨеҠҹиғҪиҰҒжұӮ MySQL е·ІдҪҝз”ЁеҺӢзј©еә“зј–иҜ‘пјҢдҫӢеҰӮzlib. еҗҰеҲҷпјҢиҝ”еӣһеҖје§Ӣз»ҲдёәNULLгҖӮ'));
DROP TABLE compress_table2;
CREATE TABLE `compress_table2` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT 'е§“еҗҚ',
  `no` varchar(255) NOT NULL DEFAULT '' COMMENT 'е·ҘеҸ·',
  `tel` varchar(255) NOT NULL COMMENT 'з”өиҜқ',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table2 VALUES(1,'ж¬ўж¬ў','10011','666000');
INSERT INTO compress_table2 VALUES(2,'жҲҳжҲҳ','10012','666111');
INSERT INTO compress_table2 VALUES(3,'й—№й—№','10013','666222');
INSERT INTO compress_table2 VALUES(5,'еә·еә·','10015','666444');
DROP TABLE compress_table3;
DROP TABLE compress_table4;
CREATE TABLE `compress_table4` (
  `id` int(10),
  `name` varchar(255),
  `compress` blob,
  `uncompress` varchar(255),
  `length` varchar(255)
);
### ж Үзӯҫпјҡcompress-2-1 SELECT
##еӨҡеҲ—/еҚ•еҲ—
SELECT id,uncompress(content) uncompress,LENGTH(compress(name)) length_new,uncompressed_length(content) length_old FROM compress_table1 ORDER BY id;
+----+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+------------+------------+
| id | uncompress                                                                                                                                                                                 | length_new | length_old |
+----+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+------------+------------+
|  1 | зҹҘзҰҸзҰҸеёёеңЁпјҢйҡҸзјҳзјҳиҮӘжқҘгҖӮ                                                                                                                                                                   |         18 |         36 |
|  2 | UNCOMPRESS(string_to_uncompress)пјҡи§ЈеҺӢзј©з”ұ COMPRESS()еҮҪж•°еҺӢзј©зҡ„еӯ—з¬ҰдёІгҖӮеҰӮжһңеҸӮж•°дёҚжҳҜеҺӢзј©еҖјпјҢеҲҷз»“жһңдёә NULL.                                                                                  |         18 |        134 |
|  3 | UNCOMPRESSED_LENGTH(compressed_string)пјҡиҝ”еӣһеҺӢзј©еӯ—з¬ҰдёІеңЁеҺӢзј©д№ӢеүҚзҡ„й•ҝеәҰгҖӮ                                                                                                                   |         18 |         89 |
|  4 | COMPRESS(string_to_compress)пјҡеҺӢзј©еӯ—з¬ҰдёІе№¶е°Ҷз»“жһңдҪңдёәдәҢиҝӣеҲ¶еӯ—з¬ҰдёІиҝ”еӣһгҖӮжӯӨеҠҹиғҪиҰҒжұӮ MySQL е·ІдҪҝз”ЁеҺӢзј©еә“зј–иҜ‘пјҢдҫӢеҰӮzlib. еҗҰеҲҷпјҢиҝ”еӣһеҖје§Ӣз»ҲдёәNULLгҖӮ                                                |         18 |        186 |
+----+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+------------+------------+
