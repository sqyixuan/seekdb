--echo ### 标签：compress-1-2  compress(str)/uncompress(str)/uncompressed_length(str) 参数类型
--echo ## 参数 - 参数类型 - 数值类型
--error 0,1051
DROP TABLE compress_table1;
CREATE TABLE compress_table1( 
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 DECIMAL(5,2), 
  c9 bit(10)
);

insert into compress_table1 values(127,32767,8388607,2147483647,12345678912345678,1.1111,123.1231123,1.1,b'1000001');

