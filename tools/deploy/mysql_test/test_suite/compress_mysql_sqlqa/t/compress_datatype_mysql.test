--echo ### 标签：compress-1-1，compress-1-2  compress(str)/uncompress(str), compress2(str, hash_length)
--echo ## 参数 - 参数类型 - 字符串类型
--error 0,1051
DROP TABLE compress_table1;
CREATE TABLE compress_table1( 
  c1 CHAR(10), 
  c2 VARCHAR(100), 
  c3 BLOB(100), 
  c4 TEXT, 
  c5 BINARY(100),
  c6 VARBINARY(100), 
  c7 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c8 SET('a', 'b', 'c', 'd', 'e')
)default character set = 'utf8mb4';

insert into compress_table1 values('char-类型','VARCHAR-类型',0x01020304FFFFFFFF0000000CAACB0000,'TEXT-类型','BINARY-类型','VARBINARY-类型','星期一','a,b,c');

select hex(compress(c1)) compress,uncompress(compress(c1)) uncompress,uncompressed_length(compress(c1)) length from compress_table1;
