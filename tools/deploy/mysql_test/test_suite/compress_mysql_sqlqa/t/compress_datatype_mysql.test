purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-1 compress(str)/uncompress(str)/uncompressed_length(str) - 参数 
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：compress-1-1  compress(str)/uncompress(str)/uncompressed_length(str) 参数个数
--echo ## 参数 - 参数个数 - 0个参数
--error 1582
select compress() from dual;
--error 1582
select uncompress() from dual;
--error 1582
select uncompressed_length() from dual;


--echo ## 参数 - 参数个数 - 1个参数
--echo #  compress(string_to_compress) 压缩函数
select hex(compress(null)),hex(compress('null')),hex(compress('Null')) from dual;
select compress(''),hex(compress(' ')),hex(compress('	')),hex(compress('           ')) from dual;
select hex(compress('!@#$%^&*''()_+-=?:;"<>/\{}[]~')) from dual;
select hex(compress('……——，。 ?‘’')) from dual;
select hex(compress('true')),hex(compress('false')) from dual;
select hex(compress(true)),hex(compress(false)) from dual;
select hex(compress(' a王 ')),hex(compress(' ａ王 ')) from dual;
select hex(compress(' 123 ')),hex(compress(' １２３ ')) from dual;
select hex(compress(' !@#$%^&*()_+ ')),hex(compress(' ！＠＃＄％＾＆＊（）＿＋ ')) from dual;
select hex(compress('_φ(?_?? 人丑就要多读书')) from dual;
select hex(compress('▲▼●◆■★????????????♂??????√▉▓')) from dual;
select hex(compress('	')) 'a',hex(compress('
')) 'b' from dual;
select hex(compress('\n')),hex(compress('\r')),hex(compress('\t')) from dual;
select hex(compress("中國")),hex(compress('中国')),hex(compress("中国")) from dual;
--error 1054
select compress(中国) from dual;
select hex(compress('压缩/解压函数:
md5(data) 返回32位的消息摘要(Message Digest)，由数字+小写字母组成。
compress(data) 返回40位的、经安全哈希算法(Security Hash Algorithm)计算出的结果值数字+小写字母。
password(data) 返回41位，由*开头的字符串(从第二位开始由数值与大写字母组成)。
MySQL账户密码(mysql库.user表.password列)用函数password(data)进行处理
MySQL的加密和解密函数个人分为两类：
1.只支持正向加密不支持反向解密的函数：
MD5()、uncompress()|compress()、compress2()
针对此类加密的算法MySQL不提供解密，

但是我们可以通过网站
http://www.cmd5.com/ 反向解密。
改网站支持MD5、compress、compress256、compress512等解密。 ')) compress from dual;
--echo # 4194304个字符  当字符串长度大于4194304时，mysql成功，ob警告。 Result of rpad() was larger than max_allowed_packet (4194304) - truncated
--echo # select hex(compress(rpad('1',4194305,'0'))) compress_value from dual;
select hex(compress(rpad('10000个中文',10000,'good')))  from dual;
select hex(compress('https://dev.mysql.com/doc/refman/5.7/en/drop-index.html')) from dual;
select hex(compress(' abcd ')), hex(compress(' ABCD ')) from dual;
select hex(compress('wanghuanhuan 1994               ')) from dual;
select hex(compress('           wanghuanhuan 1994')) from dual;
select hex(compress('wanghuanhuan        1994')) from dual;
--error 1054
select compress(abc123) from dual;
select hex(compress(0)),hex(compress(123)) from dual;
select hex(compress(0.07)),hex(compress(3.1415926)) from dual;
select hex(compress(-0.07)),hex(compress(-123456)) from dual;
select hex(compress('1.99714E13')),hex(compress("-123456.789456465")) from dual;
select hex(compress(1.0E10)),hex(compress(-1.99714E13)) from dual;
select hex(compress(-+1.23-1)),hex(compress(+1.23-1)) from dual;
select hex(compress(10)) from dual;
select hex(compress(1+2+3+4)),hex(compress(11-1)) from dual;
select hex(compress(2*5)),hex(compress(20/2)) from dual;
select hex(compress(1 & 2 | !3 )),hex(compress(0 & 2)) from dual;
--disable_warnings
select hex(compress('ab')),hex(compress('a' || 'b')) from dual;
--enable_warnings
select hex(compress(1 and 0 or not 2)) from dual;
select hex(compress(4>=2)),hex(compress(4<=2)) from dual;
select hex(compress(4<>2)),hex(compress(4!=2)) from dual;
select hex(compress(1^3)),hex(compress(1^3)) from dual;
select hex(compress(3>>3)),hex(compress(3<<3)) from dual;
select hex(compress('12:00')),hex(compress('20220311')) from dual;
select hex(compress('2022-03-28 15:32:22')),hex(compress('2022/03/28 15:32:22')) from dual;
--echo # 系统时间会变，所以预期执行结果也会不一样，知道sql语句支持就好，暂时注释掉
--echo # select hex(compress(sysdate())) from dual;
select hex(compress('你好')),hex(compress('hello')) from dual;
select hex(compress('こんにちは')),hex(compress('안녕하세요')) from dual;


--echo #  uncompress/uncompressed_length 解压函数
--echo #  参数是压缩值
select uncompress(compress('compress 压缩字符串')) uncompress,uncompressed_length(compress('compress 压缩字符串')) length from dual;
select uncompress(compress(null)) uncompress,uncompressed_length(compress(null)) length from dual;
select uncompress(compress('null')) uncompress,uncompressed_length(compress('null')) length from dual;
select uncompress(compress('')) uncompress,uncompressed_length(compress('')) length from dual;
select uncompress(compress(' ')) uncompress,uncompressed_length(compress(' ')) length from dual;
select uncompress(compress('	')) uncompress,uncompressed_length(compress('	')) length from dual;
select uncompress(compress('        ')) uncompress,uncompressed_length(compress('        ')) length from dual;
select uncompress(compress('!@#$%^&*''()_+-=?:;"<>/\{}[]~')) uncompress,uncompressed_length(compress('!@#$%^&*''()_+-=?:;"<>/\{}[]~')) length from dual;
select uncompress(compress('……——，。 ?‘’')) uncompress,uncompressed_length(compress('……——，。 ?‘’')) length from dual;
select uncompress(compress('true')) uncompress,uncompressed_length(compress('true')) length from dual;
select uncompress(compress('false')) uncompress,uncompressed_length(compress('false')) length from dual;
select uncompress(compress(true)) uncompress,uncompressed_length(compress(true)) length from dual;
select uncompress(compress(false)) uncompress,uncompressed_length(compress(false)) length from dual;
select uncompress(compress(' a王 ')) uncompress,uncompressed_length(compress(' a王 ')) length from dual;
select uncompress(compress(' ａ王 ')) uncompress,uncompressed_length(compress(' ａ王 ')) length from dual;
select uncompress(compress(' 123 ')) uncompress,uncompressed_length(compress(' 123 ')) length from dual;
select uncompress(compress(' １２３ ')) uncompress,uncompressed_length(compress(' １２３ ')) length from dual;
select uncompress(compress(' !@#$%^&*()_+ ')) uncompress,uncompressed_length(compress(' !@#$%^&*()_+ ')) length from dual;
select uncompress(compress(' ！＠＃＄％＾＆＊（）＿＋ ')) uncompress,uncompressed_length(compress(' ！＠＃＄％＾＆＊（）＿＋ ')) length from dual;
select uncompress(compress('_φ(?_?? 人丑就要多读书')) uncompress,uncompressed_length(compress('_φ(?_?? 人丑就要多读书')) length from dual;
select uncompress(compress('▲▼●◆■★????????????♂??????√▉▓')) uncompress,uncompressed_length(compress('▲▼●◆■★????????????♂??????√▉▓')) length from dual;
select uncompress(compress('
')) uncompress,uncompressed_length(compress('
')) length from dual;
select uncompress(compress('	')) uncompress,uncompressed_length(compress('	')) length from dual;
select uncompress(compress('\n')) uncompress,uncompressed_length(compress('\n')) length from dual;
select uncompress(compress('\r')) uncompress,uncompressed_length(compress('\r')) length from dual;
select uncompress(compress('\t')) uncompress,uncompressed_length(compress('\t')) length from dual;
select uncompress(compress('中國')) uncompress,uncompressed_length(compress('中國')) length from dual;
select uncompress(compress('中国')) uncompress,uncompressed_length(compress('中国')) length from dual;
select uncompress(compress("中国")) uncompress,uncompressed_length(compress("中国")) length from dual;
select uncompress(compress(" 中国 ")) uncompress,uncompressed_length(compress(" 中国 ")) length from dual;

--error 1054
select uncompress(compress(中国)) uncompress  from dual;
--error 1054
select uncompressed_length(compress(中国)) length from dual;
select uncompress(compress('压缩/解压函数:
md5(data) 返回32位的消息摘要(Message Digest)，由数字+小写字母组成。
compress(data) 返回40位的、经安全哈希算法(Security Hash Algorithm)计算出的结果值数字+小写字母。
password(data) 返回41位，由*开头的字符串(从第二位开始由数值与大写字母组成)。
MySQL账户密码(mysql库.user表.password列)用函数password(data)进行处理
MySQL的加密和解密函数个人分为两类：
1.只支持正向加密不支持反向解密的函数：
MD5()、uncompress()|compress()、compress2()
针对此类加密的算法MySQL不提供解密，
                                 
但是我们可以通过网站
http://www.cmd5.com/ 反向解密。
改网站支持MD5、compress、compress256、compress512等解密。 ')) uncompress,
uncompressed_length(compress('压缩/解压函数:
md5(data) 返回32位的消息摘要(Message Digest)，由数字+小写字母组成。
compress(data) 返回40位的、经安全哈希算法(Security Hash Algorithm)计算出的结果值数字+小写字母。
password(data) 返回41位，由*开头的字符串(从第二位开始由数值与大写字母组成)。
MySQL账户密码(mysql库.user表.password列)用函数password(data)进行处理
MySQL的加密和解密函数个人分为两类：
1.只支持正向加密不支持反向解密的函数：
MD5()、uncompress()|compress()、compress2()
针对此类加密的算法MySQL不提供解密，
                                 
但是我们可以通过网站
http://www.cmd5.com/ 反向解密。
改网站支持MD5、compress、compress256、compress512等解密。 ')) length from dual;
select uncompress(compress(rpad('10000个中文',10000,'good'))) uncompress,
       uncompressed_length(compress(rpad('10000个中文',10000,'good'))) length,
	   length(compress(rpad('10000个中文',10000,'good'))) compress_length from dual;
--echo # 4194304个文字  当字符串长度大于4194304时，mysql成功，ob警告。 Result of rpad() was larger than max_allowed_packet (4194304) - truncated
--echo # select uncompress(compress(rpad('1',4194304,'0'))) uncompress,uncompressed_length(compress(rpad('1',4194304,'0'))) length from dual;
select uncompress(compress('https://dev.mysql.com/doc/refman/5.7/en/drop-index.html'))  uncompress,
       uncompressed_length(compress('https://dev.mysql.com/doc/refman/5.7/en/drop-index.html')) length from dual;
select uncompress(compress(' abcd ')) uncompress,uncompressed_length(compress(' abcd ')) length from dual;	   
select uncompress(compress(' ABCD ')) uncompress,uncompressed_length(compress(' ABCD ')) length from dual;	   
select uncompress(compress('wanghuanhuan 1994               ')) uncompress,uncompressed_length(compress('wanghuanhuan 1994               ')) length from dual;
select uncompress(compress('           wanghuanhuan 1994')) uncompress,uncompressed_length(compress('           wanghuanhuan 1994')) length from dual;
select uncompress(compress('wanghuanhuan        1994')) uncompress,uncompressed_length(compress('wanghuanhuan        1994')) length from dual;
