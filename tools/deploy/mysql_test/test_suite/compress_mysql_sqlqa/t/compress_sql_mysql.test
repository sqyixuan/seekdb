# owner group: sql-sql4
# description: mysql压缩/解压函数-sql操作，运算符，函数间嵌套
# tags: compress
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-2 compress(str)/uncompressed(str)/uncompressed_length(str) - Sql
--echo -----------------------------------------------------------------------------------------------------------------

--error 0,1051
DROP TABLE compress_table1;
CREATE TABLE `compress_table1` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '姓名',
  `content` blob NOT NULL COMMENT '压缩内容',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table1 VALUES(1,'欢欢',COMPRESS('知福福常在，随缘缘自来。'));
INSERT INTO compress_table1 VALUES(2,'战战',COMPRESS('UNCOMPRESS(string_to_uncompress)：解压缩由 COMPRESS()函数压缩的字符串。如果参数不是压缩值，则结果为 NULL. '));
INSERT INTO compress_table1 VALUES(3,'闹闹',COMPRESS('UNCOMPRESSED_LENGTH(compressed_string)：返回压缩字符串在压缩之前的长度。'));
INSERT INTO compress_table1 VALUES(4,'毛毛',COMPRESS('COMPRESS(string_to_compress)：压缩字符串并将结果作为二进制字符串返回。此功能要求 MySQL 已使用压缩库编译，例如zlib. 否则，返回值始终为NULL。'));

--error 0,1051
DROP TABLE compress_table2;
CREATE TABLE `compress_table2` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '姓名',
  `no` varchar(255) NOT NULL DEFAULT '' COMMENT '工号',
  `tel` varchar(255) NOT NULL COMMENT '电话',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table2 VALUES(1,'欢欢','10011','666000');
INSERT INTO compress_table2 VALUES(2,'战战','10012','666111');
INSERT INTO compress_table2 VALUES(3,'闹闹','10013','666222');
INSERT INTO compress_table2 VALUES(5,'康康','10015','666444');

--error 0,1051
DROP TABLE compress_table3;

--error 0,1051
DROP TABLE compress_table4;
CREATE TABLE `compress_table4` (
  `id` int(10),
  `name` varchar(255),
  `compress` blob,
  `uncompress` varchar(255),
  `length` varchar(255)
);


--echo ### 标签：compress-2-1 SELECT
--echo ##多列/单列
SELECT id,uncompress(content) uncompress,LENGTH(compress(name)) length_new,uncompressed_length(content) length_old FROM compress_table1 ORDER BY id;
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 ORDER BY id;
SELECT id,hex(compress(CONCAT(id,name))) compress,uncompress(compress(CONCAT(id,name))) uncompress,uncompressed_length(compress(CONCAT(id,name))) length FROM compress_table1 ORDER BY id;

--echo ##where 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE compress(name) = compress('欢欢');
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) like '%UNCOMPRESS%' ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) > 100 ORDER BY id;

--echo ##order by 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 ORDER BY compress(id);
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 ORDER BY compress(id) DESC;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 ORDER BY uncompress(content) ;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 ORDER BY uncompressed_length(content) DESC;

--echo ##group by having 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 GROUP BY compress(name),id ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 GROUP BY uncompress(content),id HAVING compress(id) <> '' ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 GROUP BY uncompressed_length(content),id ORDER BY id ;

--echo #DISTINCT
SELECT distinct hex(compress(name)) compress,id,name FROM compress_table1 e ORDER BY id;
SELECT distinct uncompress(content) uncompress,id,name FROM compress_table1 e ORDER BY id;
SELECT distinct uncompressed_length(content) length,id,name FROM compress_table1 e ORDER BY id;

--echo #CASE WHEN
SELECT id,name,compress(CASE WHEN id >3  THEN NULL ELSE id END) compress FROM compress_table1  ORDER BY id;
SELECT id,name,CASE uncompress(content) WHEN uncompress(compress('知福福常在，随缘缘自来。')) THEN '欢欢的内容'  ELSE '其他人的内容' END ranks FROM compress_table1 ORDER BY id; 
SELECT id,name,(CASE uncompressed_length(content) WHEN 36 THEN '压缩前内容长度小' WHEN 89 THEN '压缩前内容长度中' ELSE '压缩前内容长度高' END) ranks FROM compress_table1 GROUP BY (CASE compress(content) WHEN compress(5000) THEN '工资低' WHEN compress(6000) THEN '工资一般' ELSE '工资高' END),id ORDER BY id ; 


--echo ##连接查询
SELECT e.id,p.no,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e, compress_table2 p WHERE e.id = p.id ORDER BY e.id;
SELECT e.id,p.no,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e LEFT JOIN compress_table2 p ON e.id = p.id ORDER BY e.id;
SELECT e.id,p.no,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e RIGHT JOIN compress_table2 p ON e.id = p.id ORDER BY e.id;
SELECT e.id,p.no,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e INNER JOIN compress_table2 p ON e.id = p.id ORDER BY e.id;


--echo ##select嵌套
--echo #SELECT
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM (SELECT id,name,content FROM compress_table1 WHERE id < 3) e ORDER BY e.id;

--echo #EXISTS / NOT EXISTS
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE EXISTS (SELECT compress(p.id) FROM compress_table2 p WHERE p.name like '%欢%' ) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE NOT EXISTS (SELECT compress(p.id) FROM compress_table2 p WHERE p.name like '%欢%' ) ORDER BY e.id;

--echo #ANY
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE compress(e.id) = ANY (SELECT compress(p.id) FROM compress_table2 p) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE uncompress(e.content) < ANY (SELECT p.name FROM compress_table2 p) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE uncompressed_length(e.content) > ANY (SELECT p.id FROM compress_table2 p) ORDER BY e.id;

--echo #ALL 
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE compress(e.id) = ALL (SELECT compress(p.id) FROM compress_table2 p WHERE p.id = 1) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE uncompress(e.content) < ALL (SELECT p.name FROM compress_table2 p) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE uncompressed_length(e.content) > ALL (SELECT p.id FROM compress_table2 p) ORDER BY e.id;

--echo #CREATE AS 
CREATE TABLE compress_table3 AS SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e; 
SELECT * FROM compress_table3 ORDER BY id;

--echo #INSERT INTO AS
INSERT INTO compress_table3 SELECT id,hex(compress(tel)) compress,uncompress(compress(tel)) uncompress,uncompressed_length(compress(tel)) length FROM compress_table2 WHERE id = 5;
SELECT * FROM compress_table3 ORDER BY id;

--echo #UPDATE SET
UPDATE compress_table3 e INNER JOIN  compress_table2 p ON e.id = p.id SET e.length=0 where e.id = 5;
SELECT * FROM compress_table3 ORDER BY id;

--echo #WITH AS的SELECT
WITH a AS (SELECT id,name,hex(compress(name)) compress FROM compress_table1 WHERE id<3) SELECT a.id,a.name,a.compress FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,uncompress(content) uncompress FROM compress_table1 WHERE id<4) SELECT a.id,a.name,a.uncompress FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,uncompressed_length(content) length FROM compress_table1 WHERE id<5) SELECT a.id,a.name,a.length FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,e.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE compress(e.name) LIKE '%Y%' ORDER BY e.id;
SELECT e.id,e.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e WHERE uncompress(e.content) NOT LIKE '%福%' ORDER BY e.id;
SELECT e.id,e.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM compress_table1 e LEFT JOIN compress_table2 p ON e.id = p.id WHERE uncompressed_length(e.content) LIKE '%1%' ORDER BY e.id;


--echo ### 标签：compress-2-2 insert
INSERT INTO compress_table4 VALUES(1,'苹果',compress('￥9000'),uncompress(compress('￥9000')),uncompressed_length(compress('￥9000')));
INSERT INTO compress_table4 VALUES(2,'华为',compress('￥8000'),uncompress(compress('￥8000')),uncompressed_length(compress('￥8000'))),(3,'荣耀',compress('￥7000'),uncompress(compress('￥7000')),uncompressed_length(compress('￥7000')));
INSERT INTO compress_table4 SELECT id,name,content,uncompress(content),uncompressed_length(content) FROM compress_table1 WHERE id=1 ORDER BY id;
SELECT id,name,hex(compress),uncompress,length FROM compress_table4 ORDER BY id;


--echo ### 标签：compress-2-3 update
UPDATE compress_table1 SET name = uncompress(compress('欢欢-update')) WHERE compress(id) = compress('1');
UPDATE compress_table1 SET name = '闹闹-update' WHERE uncompress(content) like '%长度%' ORDER BY uncompress(content) DESC;
UPDATE compress_table1 SET name = (SELECT no FROM compress_table2 WHERE no > '10014' GROUP BY id,uncompressed_length(compress(no)) HAVING uncompressed_length(compress(no)) = 5 ORDER BY uncompress(id)) WHERE id = 2;
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;


--echo ### 标签：compress-2-4 delete
SELECT * FROM  compress_table2 ORDER BY id;
DELETE FROM compress_table2 WHERE uncompress(compress(no)) > '10012' ORDER BY compress(no);
SELECT * FROM  compress_table2 ORDER BY id;


--echo ### 标签：compress-2-5 replace   
replace into compress_table1 values(uncompressed_length(compress('12345')),uncompress(compress('冰墩墩replace1')),compress('冰墩墩replace1'));
select * from compress_table1 where id = 5;

replace into compress_table1 values(uncompressed_length(compress('12345')),uncompress(compress('冰墩墩replace2')),compress('冰墩墩replace2'));
select * from compress_table1 where id = 5;


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-5 compress(str)/uncompressed(str)/uncompressed_length(str) - 运算符
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：compress-5-1 算术运算符
SELECT id,name,hex(compress(no + 20 - 5 * 4 / 2)) compress,uncompress(compress(no + 20 - 5 * 4 / 2)) uncompress,uncompressed_length(compress(no + 20 - 5 * 4 / 2)) length FROM compress_table2 ORDER BY id;
--disable_warnings
SELECT id,name,compress(no) + compress(no) '+', uncompress(compress(no)) - uncompress(compress(no)) '-', uncompressed_length(compress(no)) * uncompressed_length(compress(no)) '*', uncompress(compress(no)) / uncompress(compress(no)) '/' FROM compress_table2;
SELECT id,name,compress(no MOD 2) ,uncompress(compress(no)) DIV uncompressed_length(compress(no)) FROM compress_table2;
--enable_warnings

--echo ### 标签：compress-5-2 比较运算符
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE compress(name) = compress('毛毛')  ORDER BY compress(id);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) < uncompress(compress('uncompress'))  ORDER BY uncompress(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) > 100  ORDER BY uncompressed_length(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) >= 36  ORDER BY uncompressed_length(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) <= 150  ORDER BY uncompressed_length(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) != 17  ORDER BY uncompressed_length(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) <> 0 ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) in (17,36,89) ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) not in (17,36,89) ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE compress(name) IS NULL ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) IS NOT NULL ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) BETWEEN 100 AND 150 ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) NOT BETWEEN 100 AND 150 ORDER BY uncompressed_length(content); 
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) <=> 36  ORDER BY compress(id);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) LIKE '%长度%' ORDER BY uncompress(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) REGEXP '^U' ORDER BY uncompress(content);
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompress(content) RLIKE '^UNCOMPRESS' ORDER BY compress(id);

--echo ### 标签：compress-5-3 逻辑运算符
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE  not uncompressed_length(content) = 0 ORDER BY id;
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE  compress(name) <> ''  and uncompress(content) LIKE '%NULL%' ORDER BY id;
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE  uncompress(content) = '冰墩墩replace2' or uncompress(content) LIKE '%UNCOMPRESS%' ORDER BY id;
--disable_warnings
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM compress_table1 WHERE uncompressed_length(content) xor 0 ORDER BY id;
--enable_warnings

--echo ### 标签：compress-5-4 位运算符
--disable_warnings
SELECT id,name,hex(compress(id)) & 1001 FROM compress_table1 ORDER BY uncompressed_length(content);
SELECT id,name,uncompressed_length(content) | 2 FROM compress_table1 ORDER BY uncompress(content);
SELECT id,name,uncompressed_length(id)^3 FROM compress_table1 ORDER BY uncompress(content);
SELECT id,name,!uncompressed_length(content) FROM compress_table1 ORDER BY uncompressed_length(content);
SELECT id,name,uncompressed_length(content)<<1 FROM compress_table1 ORDER BY uncompressed_length(content);
SELECT id,name,uncompressed_length(content)>>1 FROM compress_table1 ORDER BY uncompressed_length(content);
--enable_warnings


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-6  compress(str)/uncompress(str)/uncompressed_length(str) - 函数间嵌套
--echo -----------------------------------------------------------------------------------------------------------------

--echo ### 标签：compress-6-1,compress-6-3 函数嵌套,被函数嵌套
--echo ##数字函数
--disable_warnings
SELECT id,name,ABS(hex(compress(id))),ABS(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(ABS(id))) compress,uncompress(compress(ABS(id))) uncompress,uncompressed_length(compress(ABS(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,AVG(hex(compress(id))),AVG(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(AVG(id))) compress,uncompress(compress(AVG(id))) uncompress,uncompressed_length(compress(AVG(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,CEIL(hex(compress(id))),CEIL(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(CEIL(id))) compress,uncompress(compress(CEIL(id))) uncompress,uncompressed_length(compress(CEIL(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,SIN(hex(compress(id))),SIN(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(SIN(id))) compress,uncompress(compress(SIN(id))) uncompress,uncompressed_length(compress(SIN(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,COS(hex(compress(id))),COS(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(COS(id))) compress,uncompress(compress(COS(id))) uncompress,uncompressed_length(compress(COS(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,SIGN(hex(compress(id))),SIGN(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(SIGN(id))) compress,uncompress(compress(SIGN(id))) uncompress,uncompressed_length(compress(SIGN(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,FLOOR(hex(compress(id))),FLOOR(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(FLOOR(id))) compress,uncompress(compress(FLOOR(id))) uncompress,uncompressed_length(compress(FLOOR(id))) length FROM compress_table1 ORDER BY id;
--enable_warnings

SELECT id,name,POWER(hex(compress(id)),2),POWER(uncompressed_length(content),2) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(POWER(id,2))) compress,uncompress(compress(POWER(id,2))) uncompress,uncompressed_length(compress(POWER(id,2))) length FROM compress_table1 ORDER BY id;

SELECT id,name,MAX(hex(compress(id))),MAX(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(MAX(id))) compress,uncompress(compress(MAX(id))) uncompress,uncompressed_length(compress(MAX(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,MIN(hex(compress(id))),MIN(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(MIN(id))) compress,uncompress(compress(MIN(id))) uncompress,uncompressed_length(compress(MIN(id))) length FROM compress_table1 ORDER BY id;

--disable_warnings
SELECT id,name,MOD(hex(compress(id)),2),MOD(uncompressed_length(content),2) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(MOD(id,2))) compress,uncompress(compress(MOD(id,2))) uncompress,uncompressed_length(compress(MOD(id,2))) length FROM compress_table1 ORDER BY id;

SELECT id,name,ROUND(hex(compress(id))),ROUND(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(ROUND(id))) compress,uncompress(compress(ROUND(id))) uncompress,uncompressed_length(compress(ROUND(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,TRUNCATE(hex(compress(id)),2),TRUNCATE(uncompressed_length(content),2) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(TRUNCATE(id,2))) compress,uncompress(compress(TRUNCATE(id,2))) uncompress,uncompressed_length(compress(TRUNCATE(id,2))) length FROM compress_table1 ORDER BY id;

SELECT id,name,SQRT(hex(compress(id))),SQRT(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(SQRT(id))) compress,uncompress(compress(SQRT(id))) uncompress,uncompressed_length(compress(SQRT(id))) length FROM compress_table1 ORDER BY id;

SELECT id,name,SUM(hex(compress(id))),SUM(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(SUM(id))) compress,uncompress(compress(SUM(id))) uncompress,uncompressed_length(compress(SUM(id))) length FROM compress_table1 ORDER BY id;
--enable_warnings


--echo ##字符函数
SELECT id,name,UPPER(hex(compress(name))) compress,UPPER(uncompress(content)) uncompress,UPPER(uncompressed_length(content)) length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(UPPER(name))) compress,uncompress(UPPER(content)) uncompress,uncompressed_length(UPPER(content)) length FROM compress_table1 ORDER BY id;

SELECT id,name,LOWER(hex(compress(name))),LOWER(uncompress(content)),LOWER(uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(LOWER(name))),uncompress(LOWER(content)),uncompressed_length(LOWER(content)) FROM compress_table1 ORDER BY id;

SELECT id,name,INSTR(compress(name),'b'),INSTR(uncompress(content),'e'),INSTR(uncompressed_length(content),'1') FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(INSTR(content,'b'))),uncompress(compress(INSTR(content,'e'))),uncompressed_length(compress(INSTR(content,'e'))) FROM compress_table1 ORDER BY id;

SELECT id,name,LENGTH(hex(compress(name))) compress,LENGTH(uncompress(content)) uncompress,LENGTH(uncompressed_length(content)) length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(LENGTH(content))) compress,uncompress(compress(LENGTH(content))) uncompress,uncompressed_length(compress(LENGTH(content))) length FROM compress_table1 ORDER BY id;

SELECT id,name,REPLACE(hex(compress(name)),'0','$') compress,REPLACE(uncompress(content),'。','$') uncompress,REPLACE(uncompressed_length(content),'1','$') length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(REPLACE('100123','0','$'))) compress,uncompress(REPLACE(content,'。','$')) uncompress,uncompressed_length(REPLACE(content,'。','$')) length FROM compress_table1 ORDER BY id;

SELECT id,name,SUBSTR(hex(compress(name)),5,10) compress,SUBSTR(uncompress(content),5,11) uncompress,SUBSTR(uncompressed_length(content),1,10) length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(SUBSTR(name,1,2))) compress,uncompress(compress(SUBSTR(name,1,2))) uncompress,uncompressed_length(compress(SUBSTR(name,1,2))) length FROM compress_table1 ORDER BY id;

SELECT id,name,CONCAT(hex(compress(name)),'$') compress,CONCAT(uncompress(content),'$') uncompress,CONCAT(uncompressed_length(content),'$') length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(CONCAT(name,'$'))) compress,uncompress(CONCAT(content,'0')) uncompress,uncompressed_length(CONCAT(content,'0')) length FROM compress_table1 ORDER BY id;


--echo ##日期函数
SELECT id,name,FROM_DAYS(hex(compress(name))),FROM_DAYS(3900*uncompressed_length(content)) FROM compress_table1 ORDER BY id;
SELECT hex(compress(FROM_DAYS(729575))),uncompress(compress(FROM_DAYS(729575))),uncompressed_length(compress(FROM_DAYS(729575))) FROM dual;

--echo # 系统时间会变，所以预期执行结果也会不一样，知道sql语句支持就好，暂时注释掉
--echo # SELECT SYSDATE(),compress(SYSDATE()),uncompress(compress(SYSDATE())),uncompressed_length(compress(SYSDATE())) FROM dual;


--echo ##通用函数
SELECT from_base64(uncompress(compress(to_base64(true)))) FROM dual;
SELECT id,name,IFNULL(NULL,hex(compress(name))) compress,IFNULL(uncompress(content),NULL) uncompress,IFNULL(NULL,uncompressed_length(content)) length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(IFNULL(NULL,name))) compress,uncompress(IFNULL(NULL,content)) uncompress,uncompressed_length(IFNULL(NULL,content)) length FROM compress_table1 ORDER BY id;

SELECT id,name,COALESCE(NULL,hex(compress(name))),COALESCE(uncompress(content),NULL) uncompress,COALESCE(NULL,uncompressed_length(content)) length FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(COALESCE(NULL,name))),uncompress(COALESCE(NULL,content)) uncompress,uncompressed_length(COALESCE(NULL,content)) length FROM compress_table1 ORDER BY id;

SELECT hex(compress(MD5('testing'))),uncompress(compress(MD5('testing'))),uncompressed_length(compress(MD5('testing'))) from dual;
SELECT MD5(uncompress(compress(MD5('testing')))),MD5(uncompressed_length(compress(MD5('testing')))) from dual;


--echo ### 标签：compress-6-2 多级函数嵌套
select hex(compress(compress('compress - compress'))) compress from dual;
select hex(compress(uncompress(compress('compress - uncompress')))) compress from dual;
select hex(compress(uncompressed_length(compress('compress - uncompressed_length')))) compress from dual;

select uncompress(compress('uncompress - compress')) uncompress from dual;
select uncompress(compress(compress('uncompress - compress - compress'))) uncompress from dual;
select uncompress(compress(uncompress(compress('uncompress - compress - uncompress')))) uncompress from dual;
select uncompress(compress(uncompressed_length(compress('uncompress - compress - uncompressed_length')))) uncompress from dual;

select uncompressed_length(compress('uncompressed_length - compress')) length from dual;
select uncompressed_length(compress(compress('uncompressed_length - compress - compress'))) length from dual;
select uncompressed_length(compress(uncompress(compress('uncompressed_length - compress - uncompress')))) length from dual;
select uncompressed_length(compress(uncompressed_length(compress('uncompressed_length - compress - uncompressed_length')))) length from dual;


SELECT id,name,hex(compress(name)) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(compress(compress(name))) FROM compress_table1 ORDER BY  id;
SELECT id,name,hex(compress(compress(compress(name)))) FROM compress_table1 ORDER BY  id;
SELECT id,name,hex(compress(compress(compress(compress(name))))) FROM compress_table1 ORDER BY  id;

SELECT id,name,hex(uncompress(compress(name))) FROM compress_table1 ORDER BY id;
SELECT id,name,hex(uncompress(compress(compress(name)))) FROM compress_table1 ORDER BY  id;
SELECT id,name,hex(uncompress(compress(compress(compress(name))))) FROM compress_table1 ORDER BY  id;
SELECT id,name,hex(uncompress(compress(compress(compress(compress(name)))))) FROM compress_table1 ORDER BY  id;

SELECT id,name,uncompressed_length(compress(name)) FROM compress_table1 ORDER BY id;
SELECT id,name,uncompressed_length(compress(compress(name))) FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompressed_length(compress(compress(compress(name)))) FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompressed_length(compress(compress(compress(compress(name))))) FROM compress_table1 ORDER BY  id;

SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompress(compress(uncompress(content))) FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompress(compress(uncompress(compress(uncompress(content))))) FROM compress_table1 ORDER BY  id;

SELECT id,name,uncompressed_length(content) length FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompressed_length(compress(uncompressed_length(content))) length FROM compress_table1 ORDER BY  id;
SELECT id,name,uncompressed_length(compress(uncompressed_length(uncompressed_length(uncompress(content))))) length FROM compress_table1 ORDER BY  id;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
