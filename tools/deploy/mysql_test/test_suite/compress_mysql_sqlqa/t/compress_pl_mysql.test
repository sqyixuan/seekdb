purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

DELIMITER //;

--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompress(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-3 compress(str)/uncompress(str)/uncompressed_length(str) - pl/sql
--echo -----------------------------------------------------------------------------------------------------------------

--error 0,1051
DROP TABLE compress_table1;//
CREATE TABLE `compress_table1` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '姓名',
  `content` blob NOT NULL COMMENT '压缩内容',
  PRIMARY KEY (`id`)
);//
INSERT INTO compress_table1 VALUES(1,'mary',COMPRESS('上海 设计师 622110'));//
INSERT INTO compress_table1 VALUES(2,'lisa',COMPRESS('北京 营养师 733110'));//
INSERT INTO compress_table1 VALUES(3,'jack',COMPRESS('深圳 建筑师 844110'));//
INSERT INTO compress_table1 VALUES(4,'rose',COMPRESS('广州 工程师 955110'));//


--error 0,1051
DROP TABLE compress_table2;//
CREATE TABLE `compress_table2` (
  `id` int(10),
  `compress` blob,
  `uncompress` varchar(255),
  `length` varchar(255)
);//


--echo ### 标签：compress-3-1 存储过程
--echo ##无参数的存储过程
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress()
begin
	declare a blob;
	declare b varchar(255);
	declare c varchar(255);
	declare i int default 5;
	SELECT compress(name),uncompress(content),uncompressed_length(content) into a,b,c FROM compress_table1 WHERE compress(name) = compress('jack');
    INSERT INTO compress_table2 VALUES(1,a,b,c);
	WHILE i <= 6 do
	  INSERT INTO compress_table1 VALUES(i,'pro-add1',COMPRESS(CONCAT('i = ',i)));
	  SET i := i + 1;
	END while;
END;
//

SELECT COUNT(*) FROM compress_table1;//
SELECT COUNT(*) FROM compress_table2;//
CALL p_compress();//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
SELECT id,uncompress(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo ##只有一个in参数的存储过程
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress(in invalue blob)
begin
	declare a blob;
	declare b varchar(255);
	declare c varchar(255);
    declare i int default 7;
	SELECT compress(name),uncompress(content),uncompressed_length(content) into a,b,c FROM compress_table1 WHERE compress(name) = invalue;
	INSERT INTO compress_table2 VALUES(2,a,b,c);
   	REPEAT
	  INSERT INTO compress_table1 VALUES(i,'pro-add2',COMPRESS(CONCAT('i = ',i)));
	  SET i := i+1;
	until i > 8	
	END  REPEAT;
END;
//

SELECT COUNT(*) FROM compress_table1;//
SELECT COUNT(*) FROM compress_table2;//
CALL p_compress(compress('rose'));//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
SELECT id,uncompress(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo ##包含out参数的存储过程
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE  PROCEDURE p_compress(out outa blob,OUT outb varchar(200),OUT outc varchar(200))
begin
    declare i int default 9;
	SELECT compress(name),uncompress(content),uncompressed_length(content) into outa,outb,outc FROM compress_table1 WHERE uncompress(content) like '%上海%';
	WHILE i <= 10 do
	   INSERT INTO compress_table1 VALUES(i,'pro-add3',COMPRESS(CONCAT('i = ',i)));
	SET i := i + 1;
	END WHILE;
END;
//

SELECT COUNT(*) FROM compress_table1;//
CALL p_compress(@outa,@outb,@outc);//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
SELECT uncompress(@outa),@outb,@outc FROM dual;//


--echo ##包含inout参数的存储过程
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE  PROCEDURE p_compress(INOUT inouta blob,OUT outb varchar(200),OUT outc varchar(200))
begin
    declare invalue blob;
    declare i int default 11;
	set invalue := inouta;
	SELECT compress(name),uncompress(content),uncompressed_length(content) into inouta,outb,outc FROM compress_table1 WHERE compress(name) = invalue;
	WHILE i <= 12 do
	  INSERT INTO compress_table1 VALUES(i,'pro-add4',COMPRESS(CONCAT('i = ',i)));
	  set i := i+1;
	END WHILE;
END;
//

SELECT COUNT(*) FROM compress_table1;//
SET @inouta := compress('lisa');//
CALL p_compress(@inouta,@outb,@outc);//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
SELECT uncompress(@inouta),@outb,@outc FROM dual;//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress(IN invalue blob,IN ina blob,IN inb varchar(200),IN inc varchar(200))
begin
    IF uncompress(invalue) = 'compress_table1' THEN 
	   INSERT INTO compress_table1 VALUES(13,'pro-add5',ina);
    ELSE 
	   INSERT INTO compress_table2 VALUES(3,ina,inb,inc);
    END IF;
END;
//

SELECT COUNT(*) FROM compress_table1;//
SELECT COUNT(*) FROM compress_table2;//
SET @invalue := compress('compress_table1');//
SET @ina := compress('PROCEDURE-If条件');//
SET @inb := uncompress(compress('PROCEDURE-If条件'));//
SET @inc := uncompressed_length(compress('PROCEDURE-If条件'));//
CALL p_compress(@invalue,@ina,@inb,@inc);//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//

SET @invalue := compress('compress_table2');//
SET @ina := compress('PROCEDURE-If条件2');//
SET @inb := uncompress(compress('PROCEDURE-If条件2'));//
SET @inc := uncompressed_length(compress('PROCEDURE-If条件2'));//
CALL p_compress(@invalue,@ina,@inb,@inc);//
SELECT id,uncompress(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress()
begin
    declare i int default 14;
    WHILE i <= 15 do
      INSERT INTO compress_table1 VALUES(i,'WHILE-add6',COMPRESS(CONCAT('i = ',i)));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO compress_table1 VALUES(i,'LOOP-add6',COMPRESS(CONCAT('i = ',i)));
      SET i := i+1;
      IF i > 17 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO compress_table1 VALUES(i,'REPEAT-add6',COMPRESS(CONCAT('i = ',i)));
      SET i := i+1;
      until i > 19	
    END REPEAT;
END;
//

SELECT COUNT(*) FROM compress_table1;//
CALL p_compress();//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//


--echo ##游标
--error 0,1305
DROP PROCEDURE test_pro;//
CREATE PROCEDURE test_pro()
BEGIN
	DECLARE a blob;
	DECLARE b blob;
    DECLARE i int default 4;
	DECLARE done INT DEFAULT 0;
	DECLARE compress_cursor CURSOR FOR SELECT compress(name),content FROM compress_table1 WHERE id < 5 and uncompressed_length(content) > 20 GROUP BY id HAVING uncompress(content) like '%11%';
	DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
	
	OPEN compress_cursor;
	FETCH compress_cursor INTO a,b;
	WHILE done<>1 DO
      INSERT INTO compress_table2 VALUES(i,a,uncompress(b),uncompressed_length(b));
      FETCH compress_cursor INTO a,b;
	  SET i := i+1;
	END WHILE;
	CLOSE compress_cursor;
END;
//

SELECT COUNT(*) FROM compress_table2;//
CALL test_pro();//
SELECT id,uncompress(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo ##动态sql
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress()
BEGIN
  SET @s = 'INSERT INTO compress_table1 VALUES(?,"PREPARE-add7",?);';
  PREPARE stmcompress_table1 FROM @s;
  SET @a = 20;
  SET @b = compress('动态sql插入的数据');
  EXECUTE stmcompress_table1 USING @a,@b;

  SET @s = 'SELECT id,name,uncompress(content) FROM compress_table1 WHERE uncompress(content) = ?';
  PREPARE stmt2 FROM @s;
  SET @a = '动态sql插入的数据';
  EXECUTE stmt2 USING @a; 
END;
//

SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
CALL p_compress();//


--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress()
BEGIN
  SET @s = 'update compress_table1 set name = ? WHERE compress(id) = ?;';
  PREPARE stmcompress_table1 FROM @s;
  SET @a = 'PREPARE-add7-update';
  SET @b = compress(20);
  EXECUTE stmcompress_table1 USING @a,@b;

  SET @s = 'SELECT id,name,uncompress(content),uncompressed_length(content) FROM compress_table1 WHERE uncompress(content) = ?';
  PREPARE stmt2 FROM @s;
  SET @a = '动态sql插入的数据';
  EXECUTE stmt2 USING @a; 
  
  SET @s = 'delete FROM compress_table1 WHERE id = ?;';
  PREPARE stmcompress_table1 FROM @s;
  SET @a = uncompress(compress(20));
  EXECUTE stmcompress_table1 USING @a;

  SET @s = 'SELECT id,name,uncompress(content),uncompressed_length(content) FROM compress_table1 WHERE compress(id) = ?';
  PREPARE stmt2 FROM @s;
  SET @a = compress(20);
  EXECUTE stmt2 USING @a;  
END;
//

CALL p_compress();//


--echo ##函数返回值作为存储过程的参数传递
--error 0,1305
DROP FUNCTION f_compress;//
CREATE FUNCTION f_compress() RETURNS blob READS SQL DATA 
BEGIN
	declare a blob;
	update compress_table1 set name = 'mary-2' where compress(id) = compress(1);
	SELECT compress(name) into a FROM compress_table1 WHERE compress(id) = compress(1);
	RETURN a;
END;
//

--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress()
begin
    declare infun blob;
    select f_compress() into infun from dual;
  	INSERT INTO compress_table2 VALUES(8,infun,uncompress(infun),uncompressed_length(infun));
END;
//

SELECT COUNT(*) FROM compress_table2;//
CALL p_compress();//
SELECT id,hex(compress),uncompress,length FROM compress_table2 ORDER BY id;//


-- echo #自定义变量，全局变量，in 参数作为compress函数的参数
--error 0,1305
DROP PROCEDURE p_compress;//
CREATE PROCEDURE p_compress(IN ina varchar(200),IN inb blob,IN inc blob)
begin
  declare a varchar(200) default '自定义变量a';
  declare b blob default compress('自定义变量b');
  declare c blob default compress('自定义变量c');
  INSERT INTO compress_table2 VALUES(9,compress(a),uncompress(b),uncompressed_length(c));
  INSERT INTO compress_table2 VALUES(10,compress(@mya),uncompress(@myb),uncompressed_length(@myc));
  INSERT INTO compress_table2 VALUES(11,compress(ina),uncompress(inb),uncompressed_length(inc));
END;
//

SET @mya := '全局变量a';//
SET @myb := compress('全局变量b');//
SET @myc := compress('全局变量c');//
CALL p_compress('参数变量a',compress('参数变量b'),compress('参数变量c'));//
SELECT id,uncompress(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo ### 标签：compress-3-2 函数      
--echo #定义一个无参的函数
--error 0,1305
drop function f_compress;//
CREATE FUNCTION f_compress() returns blob READS SQL DATA 
begin
	declare a blob;
	SELECT compress(name) into a FROM compress_table1 WHERE uncompress(content) like '%844110%';
	return a;
END;
//

SELECT uncompress(f_compress()) FROM dual;//


--echo #定义一个有参的函数
--error 0,1305
DROP FUNCTION f_compress;//
CREATE FUNCTION f_compress(invalue blob) returns  varchar(255) READS SQL DATA 
begin
	declare a varchar(255);
	SELECT uncompress(content) into a FROM compress_table1 WHERE name = uncompress(invalue);
	return a;
END ;
//

SELECT f_compress(compress('lisa'));//


--echo ##dml语句
--echo #条件语句
--error 0,1305
DROP FUNCTION f_compress;//
CREATE FUNCTION f_compress(invalue blob,ina blob)returns varchar(200) DETERMINISTIC
begin
    DELETE FROM compress_table1 WHERE id = 20;
    IF invalue = compress('compress_table1') THEN 
	   INSERT INTO compress_table1 VALUES(20,'fun-add7',invalue);
    ELSE 
	   INSERT INTO compress_table2 VALUES(12,ina,uncompress(ina),uncompressed_length(ina));
    END IF;
    return concat('传入参数解密：',uncompress(invalue));
END;
//

SELECT COUNT(*) FROM compress_table1;//
SELECT COUNT(*) FROM compress_table2;//
SET @invalue := compress('compress_table1');//
SET @ina := compress('fun-add7');//
SELECT f_compress(@invalue,@ina);//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//

SET @invalue := compress('compress_table2');//
SET @ina := compress('fun-add7');//
SELECT f_compress(@invalue,@ina);//
SELECT id,hex(compress),uncompress,length FROM compress_table2 ORDER BY id;//


--echo #循环语句
--error 0,1305
DROP FUNCTION f_compress;//
CREATE FUNCTION f_compress(invalue varchar(200)) returns blob
begin
	declare a blob;
    declare i int default 21;
	SELECT compress(name) into a FROM compress_table1 WHERE uncompress(content) like concat('%',invalue,'%');
	
    WHILE i <= 22 do
      INSERT INTO compress_table1 VALUES(i,'FUNCTION-While循环',compress(concat('i =',i)));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO compress_table1 VALUES(i,'FUNCTION-Loop循环',compress(concat('i =',i)));
      SET i := i+1;
      IF i > 24 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO compress_table1 VALUES(i,'FUNCTION-Repeat循环',compress(concat('i =',i)));
      SET i := i+1;
      until i > 26	
    END  REPEAT;
	return a;
END;
//

SELECT COUNT(*) FROM compress_table1;//
SELECT uncompress(f_compress('622110'));//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//


--echo ### 标签：compress-3-3 触发器    
--error 0,1360
DROP TRIGGER tri_compress;//
CREATE TRIGGER tri_compress BEFORE INSERT
ON compress_table1 FOR EACH ROW
BEGIN
	DECLARE a int default 20;
	DECLARE b VARCHAR(200);
	DECLARE c VARCHAR(200);
	set b = '触发器-插入数据 insert';
	set c = '触发器-更新数据 update';
	-- 循环insert插入5条数据(20,21,22,23,24)，id=23数据delete删除，id=24数据update修改
	loop1: LOOP
	  if a < 25 then
	    INSERT INTO compress_table2 VALUES(a,compress(b),uncompress(compress(b)),uncompressed_length(compress(b)));
	  elseif a = 26 then
	    UPDATE compress_table2 set compress = compress(c), uncompress = uncompress(compress(c)),length=uncompressed_length(compress(c)) WHERE id = 24;
	    LEAVE loop1;
	  else
	    DELETE FROM compress_table2 WHERE compress(id) = compress(23);	
	  end if;
	  set a = a + 1;
	end LOOP loop1;
END;
//

SELECT COUNT(*)  FROM compress_table1 ORDER BY id;//
SELECT COUNT(*)  FROM compress_table2 ORDER BY id;//
INSERT INTO compress_table1 VALUES(27,'触发触发器插入数据',compress('触发触发器插入数据'));//
SELECT id,name,uncompress(content) FROM compress_table1 ORDER BY id;//
SELECT id,hex(compress),uncompress,length FROM compress_table2 ORDER BY id;//



--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 压缩/解压函数-compress(str)/uncompressed(str)/uncompressed_length(str)-----------------
--echo ### 用例：compress-4 compress(str)/uncompress(str)/uncompressed_length(str) - 视图，索引，约束
--echo -----------------------------------------------------------------------------------------------------------------

--echo #################################################################################
--echo ### 表，视图创建

DELIMITER ;//

--error 0,1051
DROP TABLE compress_table1;
CREATE TABLE `compress_table1` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '名称',
  `content` blob NOT NULL COMMENT '压缩内容',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table1 VALUES(1,'A',COMPRESS('原子性：一个事务（transaction）中的所有操作，要么全部完成，要么全部不完成，不会结束在中间某个环节。'));
INSERT INTO compress_table1 VALUES(2,'C',COMPRESS('一致性：在事务开始之前和事务结束以后，数据库的完整性没有被破坏。'));
INSERT INTO compress_table1 VALUES(3,'I',COMPRESS('隔离性：数据库允许多个并发事务同时对其数据进行读写和修改的能力，隔离性可以防止多个事务并发执行时由于交叉执行而导致数据的不一致。'));
INSERT INTO compress_table1 VALUES(4,'D',COMPRESS('持久性：事务处理结束后，对数据的修改就是永久的，即便系统故障也不会丢失。'));

--error 0,1051
DROP TABLE compress_table2;
CREATE TABLE `compress_table2` (
  `id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `name` varchar(255) NOT NULL DEFAULT '' COMMENT '名称',
  `no` varchar(255) NOT NULL DEFAULT '' COMMENT '编号',
  `url` varchar(255) NOT NULL COMMENT '地址',
  PRIMARY KEY (`id`)
);
INSERT INTO compress_table2 VALUES(1,'原子性','10011','mysql/mysql-transaction1.html');
INSERT INTO compress_table2 VALUES(2,'一致性','10012','mysql/mysql-transaction2.html');
INSERT INTO compress_table2 VALUES(3,'隔离性','10013','mysql/mysql-transaction3.html');
INSERT INTO compress_table2 VALUES(5,'事务特性','10015','mysql/mysql-transaction5.html');

--error 0,1051
DROP TABLE compress_table3;

--error 0,1051
DROP TABLE compress_table4;
CREATE TABLE compress_table4(id int,c1 varchar(200),c2 varchar(200),c3 varchar(200));

--error 0,1051
DROP VIEW t1_view;
CREATE VIEW t1_view AS SELECT * FROM compress_table1 WHERE compress(id) <= compress(3);

--error 0,1051
DROP VIEW t2_view;
CREATE VIEW t2_view AS SELECT * FROM compress_table2 WHERE compress(id) <= compress(3);

--error 0,1051
DROP VIEW t3_view;

SELECT id,name,uncompress(content) FROM t1_view ORDER BY id;
SELECT * FROM t2_view ORDER BY id;

--echo #################################################################################

--echo ### 标签：compress-4-1 视图
--echo ### SELECT
--echo ##多列/单列
SELECT id,hex(compress(name)) compress,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view ORDER BY id;
SELECT id,hex(compress(CONCAT(id,name))) compress,uncompress(compress(CONCAT(id,name))) uncompress,uncompressed_length(compress(CONCAT(id,name))) length FROM t1_view ORDER BY id;

--echo ##WHERE 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view WHERE compress(name) = compress('A');
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view WHERE uncompress(content) like '%一致性%' ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view WHERE uncompressed_length(content) > 100 ORDER BY id;

--echo ##order by 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view ORDER BY compress(id);
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view ORDER BY compress(id) DESC;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view ORDER BY uncompress(content) ;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view ORDER BY uncompressed_length(content) DESC;

--echo ##group by having 子句
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view GROUP BY compress(name),id ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view GROUP BY uncompress(content),id HAVING compress(id) > compress(4) ORDER BY id;
SELECT id,name,uncompress(content) uncompress,uncompressed_length(content) length FROM t1_view GROUP BY uncompressed_length(content),id ORDER BY id ;

--echo #DISTINCT
SELECT distinct hex(compress(name)) compress,id,name FROM t1_view e ORDER BY id;
SELECT distinct uncompress(content) uncompress,id,name FROM t1_view e ORDER BY id;
SELECT distinct uncompressed_length(content) length,id,name FROM t1_view e ORDER BY id;

--echo #CASE WHEN
SELECT id,name,compress(CASE WHEN id >3 THEN NULL ELSE id END) compress,uncompress(compress(CASE WHEN id >3 THEN NULL ELSE id END)) uncompress FROM t1_view  ORDER BY id;
SELECT id,name,CASE uncompress(content) WHEN uncompress(compress('一致性：在事务开始之前和事务结束以后，数据库的完整性没有被破坏。')) THEN '事务的一致性'  ELSE '事务其他特性' END ranks FROM t1_view ORDER BY id; 
SELECT id,name,(CASE uncompressed_length(content) WHEN 96 THEN '压缩前内容长度小' WHEN 108 THEN '压缩前内容长度中' ELSE '压缩前内容长度高' END) ranks FROM t1_view GROUP BY id ORDER BY id ; 


--echo ##连接查询
SELECT e.id,p.name,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e, t2_view p WHERE e.id = p.id ORDER BY e.id;
SELECT e.id,p.name,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
SELECT e.id,p.name,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id;
SELECT e.id,p.name,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e INNER JOIN t2_view p ON e.id = p.id WHERE uncompressed_length(e.content) > 100  ORDER BY e.id;


--echo ##SELECT嵌套
--echo #SELECT
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM (SELECT id,name,content FROM t1_view WHERE uncompressed_length(content) > 100) e ORDER BY e.id;

--echo #EXISTS / NOT EXISTS
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE EXISTS (SELECT compress(p.name) FROM t2_view p WHERE p.name like '%持久性%' ) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE NOT EXISTS (SELECT compress(p.id) FROM t2_view p WHERE p.name like '%持久性%' ) ORDER BY e.id;

--echo #ANY
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE compress(e.id) = ANY (SELECT compress(p.id) FROM t2_view p) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE uncompress(e.content) < ANY (SELECT uncompress(compress(p.name)) FROM t2_view p) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE uncompressed_length(e.content) > ANY (SELECT uncompressed_length(compress(p.url)) FROM t2_view p) ORDER BY e.id;

--echo #ALL 
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE compress(e.id) = ALL (SELECT compress(p.id) FROM t2_view p WHERE p.id = 1) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE uncompress(e.content) <= ALL (SELECT uncompress(compress(p.url)) FROM t2_view p WHERE p.id <= 2) ORDER BY e.id;
SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE uncompressed_length(e.content) >= ALL (SELECT uncompressed_length(compress(p.url)) FROM t2_view p) ORDER BY e.id;

--echo #CREATE AS 
CREATE VIEW t3_view AS SELECT e.id,hex(compress(e.name)) compress,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e; 
SELECT * FROM t3_view ORDER BY id;


--echo #WITH AS的SELECT
WITH a AS (SELECT id,name,hex(compress(name)) compress FROM t1_view WHERE id<3) SELECT a.id,a.name,a.compress FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,uncompress(content) uncompress FROM t1_view WHERE id<4) SELECT a.id,a.name,a.uncompress FROM a ORDER BY a.id;
WITH a AS (SELECT id,name,uncompressed_length(content) length FROM t1_view WHERE id<5) SELECT a.id,a.name,a.length FROM a ORDER BY a.id;

--echo #模糊查询like 
SELECT e.id,e.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE compress(e.name) LIKE '%B%' ORDER BY e.id;
SELECT e.id,e.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e WHERE uncompress(e.content) NOT LIKE '%完整%' ORDER BY e.id;
SELECT e.id,e.name,p.name,uncompress(e.content) uncompress,uncompressed_length(e.content) length FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id WHERE uncompressed_length(e.content) > 100 ORDER BY e.id;


--echo ### update
UPDATE t1_view SET name = 'A:原子性' WHERE compress(id) = compress('1');
UPDATE t1_view SET name = 'C:一致性' WHERE uncompress(content) like '%一致性%' ORDER BY uncompress(content) DESC;
UPDATE t1_view SET name = (SELECT name FROM t2_view WHERE uncompress(compress(id)) = 3) WHERE id = 3;
SELECT id,name,uncompress(content) FROM t1_view ORDER BY id;


--echo ###delete
SELECT * FROM  t2_view ORDER BY id;
DELETE FROM t2_view WHERE uncompress(compress(no)) > '10012' ORDER BY compress(no);
SELECT * FROM  t2_view ORDER BY id;


--echo ### 标签：compress-4-2 索引
--error 0,1091
DROP INDEX `compress_index1` ON compress_table1;
--error 0,1091
DROP INDEX `compress_index2` ON compress_table1;

CREATE INDEX compress_index1 ON compress_table1(id);
ALTER TABLE compress_table1 ADD INDEX compress_index2 (name);

--echo #insert 
insert into compress_table1 SELECT id+1,name,content FROM compress_table1 e WHERE compress(e.id) = compress(4);
SELECT id,name,uncompress(content)  FROM compress_table1 ORDER BY id;

--echo #update 
UPDATE compress_table1 set name = '索引-update' WHERE compress(id) = compress(4);
SELECT id,name,uncompress(content)  FROM compress_table1 ORDER BY id;
UPDATE compress_table1 set content = compress('添加索引属性-update修改数据') WHERE uncompress(content) = uncompress(compress('一致性：在事务开始之前和事务结束以后，数据库的完整性没有被破坏。'));
SELECT id,name,uncompress(content)  FROM compress_table1 ORDER BY id;

--echo #SELECT 
SELECT id,hex(compress(e.id)),uncompress(e.content),uncompressed_length(e.content) FROM compress_table1 e WHERE compress(e.id) < compress(2) ORDER BY e.id;
SELECT id,hex(compress(e.id)),uncompress(e.content),uncompressed_length(e.content) FROM compress_table1 e WHERE compress(e.name) like '%f1%' order by compress(e.id) desc;

--echo #delete 
DELETE FROM compress_table1 WHERE compress(name) = compress('索引-update');
SELECT id,name,uncompress(content)  FROM compress_table1 ORDER BY id;


--echo ### 标签：compress-4-3 约束
--error 0,1051
DROP TABLE compress_table1;
CREATE TABLE `compress_table1` (
  `id` int(10) PRIMARY KEY,
  `name` varchar(255) UNIQUE,
  `compress` blob NOT NULL,
  `uncompress` varchar(255),
  `length` varchar(255)
);

--echo #insert 
INSERT INTO compress_table1 VALUES(1,'楠楠',compress('RANDOM_BYTES()Return a random byte vector'),uncompress(compress('RANDOM_BYTES()Return a random byte vector')),uncompressed_length(compress('RANDOM_BYTES()Return a random byte vector')));
INSERT INTO compress_table1 VALUES(2,'康康',compress('COMPRESS()Return result as a binary string'),uncompress(compress('COMPRESS()Return result as a binary string')),uncompressed_length(compress('COMPRESS()Return result as a binary string')));
INSERT INTO compress_table1 VALUES(3,'灰灰',compress('UNCOMPRESS()Uncompress a string compressed'),uncompress(compress('UNCOMPRESS()Uncompress a string compressed')),uncompressed_length(compress('UNCOMPRESS()Uncompress a string compressed')));
INSERT INTO compress_table1 VALUES(4,'瑶瑶',compress('UNCOMPRESSED_LENGTH()Return the length of a string before compression'),uncompress(compress('UNCOMPRESSED_LENGTH()Return the length of a string before compression')),uncompressed_length(compress('UNCOMPRESSED_LENGTH()Return the length of a string before compression')));
SELECT id,name,hex(compress),uncompress,length  FROM compress_table1 ORDER BY id;

--echo #update 
UPDATE compress_table1 set name = '瑶瑶-update' WHERE compress(id) = compress(4);
SELECT id,name,hex(compress),uncompress,length  FROM compress_table1 ORDER BY id;

--echo #SELECT 
SELECT id,hex(compress(e.name)),uncompress(e.compress),uncompressed_length(e.compress) FROM compress_table1 e WHERE compress(e.id) < compress(2) ORDER BY e.id;
SELECT e.id,hex(e.name2),uncompress(e.name2),uncompressed_length(e.name2) FROM (SELECT id,compress(name) name2  FROM compress_table1 WHERE compress(id) > compress(2)) e ORDER BY compress(e.id) desc;

--echo #delete 
DELETE FROM compress_table1 WHERE uncompress(compress) like '%Return%' and uncompressed_length(compress) > 50;
SELECT id,name,hex(compress),uncompress,length  FROM compress_table1 ORDER BY id;


