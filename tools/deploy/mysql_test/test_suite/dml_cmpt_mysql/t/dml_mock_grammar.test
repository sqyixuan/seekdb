# owner: linyi.cl
# owner group: sql3
# tags: parser

--disable_warnings
drop table if exists t1;
create table t1(c1 int);
drop table if exists quick;
create table quick(c1 int);
--enable_warnings

select high_priority id from (select 1 as id from dual union all select 2 from dual) ss;
select high_priority c1 from t1;
select all high_priority sql_cache c1 from t1;
--error 1064
select low_priority c1 from t1;

select sql_big_result c1,count(1) from t1 group by c1;
select sql_small_result c1,count(1) from t1 group by c1;
select sql_buffer_result c1,count(1) from t1 group by c1;
select all high_priority sql_small_result sql_no_cache c1,count(1) from t1 group by c1;
select distinct high_priority sql_small_result sql_no_cache c1 from t1;

insert low_priority into t1 values (1);
insert high_priority into t1 values (2);
insert low_priority ignore into t1 values (3);

replace low_priority into t1 values(4);
--error 1064
replace high_priority into t1 values(4);

update low_priority t1 set c1 = 2;
update low_priority ignore t1 set c1 = 3;
--error 1064
update high_priority t1 set c1 = 2;

delete low_priority from t1;
delete quick from t1;
delete low_priority quick from t1;
delete quick low_priority quick from t1;
delete quick low_priority quick quick from t1;
--error 1064
delete high_priority from t1;

# quick会优先识别为opt 所以语法报错 和mysql兼容
--error 1064
delete quick quick from t1 join quick;
--error 1064
delete quick from t1 join quick;
--error 1064
delete quick,t1 from quick join t1;
delete t1,quick from quick join t1;
# from后面是表名 不报错
delete quick from quick;
# 前面的quick都是opt
delete quick quick from t1;

drop table t1,quick;