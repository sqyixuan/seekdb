select extractvalue(c1, '//comment()') from xml_test where id = 5;
select extractvalue(c1, '//processing-instruction()') from xml_test where id = 5;
select extractvalue(c1, '/bookstore/comment()') from xml_test where id = 3;
select extractvalue(c1, '/node/comment()') from xml_test where id = 5;
select extractvalue(c1, '/note/text()') from xml_test where id = 5;

