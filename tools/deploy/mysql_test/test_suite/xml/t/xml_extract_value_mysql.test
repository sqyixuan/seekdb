drop table xml_test;
create table xml_test(id int, c1 varchar(2000));
insert into xml_test values(1, '<a/>');
insert into xml_test values(2, '<a><b/></a>');
insert into xml_test values(3, '<?xml version="1.0" ?>
<!-- comment -->
<bookstore>
<book att="old"></book>
<book>abc</book>
<author>carrot</author>
</bookstore>');
insert into xml_test values(4, '<a xmlns="ns1" xmlns:f="ns2">
<f:b b1="b1" b2="b2">bbb1</f:b>
<b b1="b1" b2="b2">bbb2</b>
</a>');
insert into xml_test values (5, '<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<note ls="ccc">
<?xml-stylesheet type="text"?>
<?xml-stylesheet type="text/css"?>
<h:table xmlns:h="mingming"><h:td>Bananas</h:td></h:table>
<f:table xmlns:f="w3"></f:table>
<to>子元素</to>
<!-- 这是注释 -->
<from>Jani</from>
<heading>Reminder</heading>
<![CDATA[<greeting>CDATA区>&quot;</greeting>]]>
</note>');

select extractvalue(c1, '//book') from xml_test where id = 3;
select extractvalue(c1, '/bookstore/comment()') from xml_test where id = 3;
