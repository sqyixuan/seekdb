SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a/text()', 'bbb') ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '//text()', 'bbb') ;

SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a/text()', NULL) ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a/text()', '<a>bbb</a>') ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', '<a>bbb</a>') ;

SELECT UPDATEXML('<root><a><![CDATA[<>><]]></a></root>', '//text()', 'abc');
SELECT UPDATEXML('<root><a><![CDATA[<>><]]></a></root>', '/root/a/text()', 'abc');

SELECT UPDATEXML('<root><?xml-stylesheet type="text"?><a>aaa</a></root>', '//processing-instruction()', 'abc');
SELECT UPDATEXML('<root><?xml-stylesheet type="text"?><a>aaa</a></root>', '/root/processing-instruction()', 'abc');
SELECT UPDATEXML('<root><a><?xml-stylesheet type="text"?>aaa</a></root>', '/root/a/processing-instruction()', 'abc');

SELECT UPDATEXML('<root><a>aaa<!--xyz--></a></root>', '//comment()', 'abc');
SELECT UPDATEXML('<root><a>aaa<!--xyz--></a></root>', '/root/a/comment()', 'abc');

SELECT UPDATEXML('<root a1="aaa"><a>aaa</a></root>', '/root/@a1', 'bbb');
SELECT UPDATEXML('<root a1="aaa"><a>aaa</a></root>', '/root/@a1', 'x="bbb"');
SELECT UPDATEXML('<root a1="aaa" b1="bbb"><a>aaa</a></root>', '/root/@a1', 'x="bbb"');
SELECT UPDATEXML('<root a1="aaa" b1="bbb"><a>aaa</a></root>', '/root/@*', 'x="bbb"');
SELECT UPDATEXML('<root a1="aaa"><a>aaa</a></root>', '/root/@a1', NULL);
SELECT UPDATEXML('<root a1="aaa"><a>aaa</a></root>', '/root/@a1', '<a>aa</a>');

SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', NULL) ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', '<>') ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', '<?xml version="1.0"?><a></a>') ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', '<b>bbb</b>') ;
SELECT UPDATEXML('<root><a>aaa</a></root>', '/root/a', '<b>bbb</b>');
SELECT UPDATEXML('<root><a>aaa</a></root>','/root', 1)  from dual;
SELECT UPDATEXML('<root><a>aaa</a></root>', '//*', '<b>bbb</b>');

SET @xml='<a>a1<b>b1<c>c1</c>b2</b>a2</a>';
select UpdateXML('<a>a1<b>b1<c>c1</c>b2</b>a2</a>','/a/b/c','+++++++++');
select UpdateXML('<a>a1<b>b1<c>c1</c>b2</b>a2</a>','/a/b/c','<c1>+++++++++</c1>');
select UpdateXML('<a>a1<b>b1<c>c1</c>b2</b>a2</a>','/a/b/c','<c1/>');

SET @xml='<a><b>bb</b></a>';
select UpdateXML(@xml, '/a/b', '<b>ccc</b>');

SET @xml='<a aa1="aa1" aa2="aa2"><b bb1="bb1" bb2="bb2">bb</b></a>';
select UpdateXML(@xml, '/a/b', '<b>ccc</b>');
select UpdateXML(@xml, '/a/@aa1', '');
select UpdateXML(@xml, '/a/@aa1', 'aa3="aa3"');
select UpdateXML(@xml, '/a/@aa2', '');
select UpdateXML(@xml, '/a/@aa2', 'aa3="aa3"');
select UpdateXML(@xml, '/a/b/@bb1', '');
select UpdateXML(@xml, '/a/b/@bb1', 'bb3="bb3"');
select UpdateXML(@xml, '/a/b/@bb2', '');
select UpdateXML(@xml, '/a/b/@bb2', 'bb3="bb3"');

select updatexml('<div><div><span>1</span><span>2</span></div></div>',
                 '/','<tr><td>1</td><td>2</td></tr>') as upd1;
select updatexml('', '/', '') as upd2;

