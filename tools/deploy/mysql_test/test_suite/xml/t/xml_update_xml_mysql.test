select updatexml('<a/>', '/a', 'abc');
select updatexml('<bb', '/a', NULL);
select updatexml('<bb', '/a', '');
select updatexml('<a/>', '/b', '');
select updatexml('', '/a', '/a');
select updatexml(NULL, '/a', '/a');
SELECT UPDATEXML(NULL,'/a', 'abc');
SELECT UPDATEXML('<root><a>aaa</a></root>', 1, 1)  from dual;
SELECT UPDATEXML('<root><a>aaa</a></root>', 1, 'abc')  from dual;
SELECT UPDATEXML('<root><a>aaa</a></root>', NULL, 1)  from dual;

SELECT UPDATEXML(1,'/a', 'abc')  from dual;

