drop table t1;
create table t1 (c1 varchar(200), c2 text, c3 int);
insert into t1 values('<a/>', '<a/>', 1);
SELECT UPDATEXML(c1,'/a', 'abc')  from t1;
UPDATEXML(c1,'/a', 'abc')
abc
SELECT UPDATEXML(c2,'/a', 'abc')  from t1;
UPDATEXML(c2,'/a', 'abc')
abc
SELECT UPDATEXML(c3,'/a', 'abc')  from t1;
UPDATEXML(c3,'/a', 'abc')
1
select updatexml('<a>a</a>', c1, 'ab') from t1;
ERROR 42000: Only constant XPATH queries are supported
select updatexml('<a>a</a>', c1, 'ab') from t1;
