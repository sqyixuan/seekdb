# ----------------------------------------------------------------------
# Test of updatexml for mysql
# ----------------------------------------------------------------------
select updatexml('<a/>', '/a', 'abc');
updatexml('<a/>', '/a', 'abc')
abc
select updatexml('<bb', '/a', NULL);
updatexml('<bb', '/a', NULL)
NULL
select updatexml('<bb', '/a', '');
updatexml('<bb', '/a', '')
NULL
Warnings:
Warning	1525	Incorrect XML value
select updatexml('<a/>', '/b', '');
updatexml('<a/>', '/b', '')
<a/>
select updatexml('', '/a', '/a');
updatexml('', '/a', '/a')

select updatexml(NULL, '/a', '/a');
updatexml(NULL, '/a', '/a')
NULL
