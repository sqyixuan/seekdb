select extractvalue('', '/a');
extractvalue('', '/a')

select extractvalue('<a>', '/a');
extractvalue('<a>', '/a')
NULL
Warnings:
Warning	1525	Incorrect XML value
select extractvalue('<a><b>x</b><b>y</b></a>', '/a/b');
extractvalue('<a><b>x</b><b>y</b></a>', '/a/b')
x y
select extractvalue('<a><b>x</b><b>y</b></a>', '/a');
extractvalue('<a><b>x</b><b>y</b></a>', '/a')

select extractvalue('<a><b>x<c/>y</b><b>x<c/>y</b></a>', '/a/b');
extractvalue('<a><b>x<c/>y</b><b>x<c/>y</b></a>', '/a/b')
x y x y
SELECT EXTRACTVALUE( '<?xml version="1.0"?><a><b>bbb</b></a>', '/') as RES;
RES

select EXTRACTVALUE('<!-- test --><!-- test -->', '/comment()') as res;
res

select extractvalue('<b/><a>aaa</a><c/>', '/a');
extractvalue('<b/><a>aaa</a><c/>', '/a')
aaa
select extractvalue(concat('<b/><a>aaa</a><c/>', '<d>dd</d>'), '//text()');
extractvalue(concat('<b/><a>aaa</a><c/>', '<d>dd</d>'), '//text()')
aaa dd
select extractvalue(concat('<b/><a>aaa</a><c/>', '<d>dd</d>'), concat('//', 'text()'));
extractvalue(concat('<b/><a>aaa</a><c/>', '<d>dd</d>'), concat('//', 'text()'))
aaa dd
drop table carrot;
create table carrot(id int, a varchar(200), c text);
insert into carrot values(1, '<a>a</a>', '<a>b</a>');
select extractvalue(a, '/a') from carrot;
extractvalue(a, '/a')
a
select extractvalue(c, '/a') from carrot;
extractvalue(c, '/a')
b
drop table carrot;
select extractvalue('<a/>', '');
