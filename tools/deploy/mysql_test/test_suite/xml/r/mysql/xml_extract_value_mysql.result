select extractvalue('<a/>', '//@');
ERROR 42000: XPATH syntax error: ''
DROP TABLE xml_test;
CREATE TABLE xml_test (id int, c1 varchar(200));
insert into xml_test values (1, '<a>aaa</a>');
insert into xml_test values (2, '<a><b>aaa</b><b>bbb</b></a>');
insert into xml_test values (3, '<a a1="a1">aaa</a>');
insert into xml_test values (4, '<a><b b1="b1" b2="b2">bbb</b></a>');
insert into xml_test values (5, '<a><b b1="b1">bbb1</b><b b2="b2">bbb2</b></a>');
insert into xml_test values (6, '/a');
SELECT EXTRACTVALUE(c1, '/a') as RES from xml_test where id = 1;
RES
aaa
SELECT EXTRACTVALUE(c1, '/b') as RES from xml_test where id = 1;
RES

SELECT EXTRACTVALUE(c1, '/a/b') as RES from xml_test where id = 1;
RES

SELECT EXTRACTVALUE(c1, '/a/b') as RES from xml_test where id = 2;
RES
aaa bbb
SELECT EXTRACTVALUE(c1, '/a/b/text()') as RES from xml_test where id = 2;
RES
aaa bbb
SELECT EXTRACTVALUE(c1, '/a/b/text()') as RES from xml_test where id = 5;
RES
bbb1 bbb2
SELECT EXTRACTVALUE(c1, '/a/@*') as RES from xml_test where id = 3;
RES
a1
SELECT EXTRACTVALUE(c1, '/a/attribute::*') as RES from xml_test where id = 3;
RES
a1
SELECT EXTRACTVALUE(c1, '/a/b/attribute::*') as RES from xml_test where id = 5;
RES
b1 b2
SELECT EXTRACTVALUE(c1, '/a/attribute::a1') as RES from xml_test where id = 3;
RES
a1
SELECT EXTRACTVALUE(c1, '/a/attribute::a2') as RES from xml_test where id = 3;
RES

SELECT EXTRACTVALUE(c1, '/a/b/@*') as RES from xml_test where id = 4;
RES
b1 b2
SELECT EXTRACTVALUE(c1, '/a/b/@b2') as RES from xml_test where id = 4;
RES
b2
SELECT EXTRACTVALUE(c1, '/a/b/@*') as RES from xml_test where id = 5;
RES
b1 b2
SELECT EXTRACTVALUE('<a>a</a>', c1) as RES from xml_test where id = 6;
