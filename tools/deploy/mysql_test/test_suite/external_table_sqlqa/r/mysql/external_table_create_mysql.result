result_format: 4
SET NAMES utf8mb4;
##location##
create external table ex_t1 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'test.csv'
;
select * from ex_t1;
+--------+-----------+--------+--------+-------------+
| id     | name      | mon    | age    | tel_number  |
+--------+-----------+--------+--------+-------------+
| 工号   | 姓名      | 工资   | 年龄   | 手机号      |
| 1      | 王小明    | 3500   | 25     | 13000000000 |
| 2      | 李大鹏    | 3000   | 30     | 13000000001 |
| 3      | 张红霞    | 6000   | 28     | 13000000002 |
| 4      | 赵芳芳    | 4500   | 35     | 13000000003 |
| 5      | 邓玉林    | 4000   | 40     | 13000000004 |
| 6      |           |        |        |             |
+--------+-----------+--------+--------+-------------+
##可以查看外表的信息
##指定不存在的location##
create external table ex_t2 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number CHAR (20)
)
location='/external_table_sqlqa/data1'
format (
    type = 'csv'
)
;
select * from ex_t2;
+------+------+------+------+------------+
| id   | name | mon  | age  | tel_number |
+------+------+------+------+------------+
+------+------+------+------+------------+
##指定location为空##
create external table ex_t3 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number CHAR (20)
)
location= ''
format (
    type = 'csv'
)
;
ERROR HY000: Directory not exist
##pattern正则匹配##
create external table ex_t4 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number CHAR (20)
)
location= 'mysqltest_data_for_external_table'
format (
    type = 'csv'
)
pattern = '.*\.csv'
;
select * from ex_t4;
ERROR 22001: Data too long for column
##FIELD_DELIMITER列分割##
create external table ex_t5 (
FIELD_NAME VARCHAR(100),
FUN_NAME varchar(100),
PRO_NAME VARCHAR (100),
PAC_NAME VARCHAR (100),
PAC_NOBO_NAME VARCHAR (100),
TYP_NAME VARCHAR(100)
)
location= 'mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
)
pattern = '.*\.dat'
;
select * from ex_t5 limit 10;
+--------------------------+-----------------------+--------------------------------+-----------------------------------------------------------------------------------------------+---------------------------------------------+---------------------------------------------------------------------------+
| FIELD_NAME               | FUN_NAME              | PRO_NAME                       | PAC_NAME                                                                                      | PAC_NOBO_NAME                               | TYP_NAME                                                                  |
+--------------------------+-----------------------+--------------------------------+-----------------------------------------------------------------------------------------------+---------------------------------------------+---------------------------------------------------------------------------+
| 文件名（cas用户）        | function              | procedure                      | package                                                                                       | 无body部分（package）                       | 无body部分（type）                                                        |
| a1                       | "ADVANCE_PTD	"        |                                | CD                                                                                            | FCN                                         | NULL                                                                      |
|                          | DAY                   |                                |                                                                                               | WRK                                         | NULL                                                                      |
|                          | ADD_DATE              |                                |                                                                                               | DO                                          | NULL                                                                      |
| a2                       | GET_CAS_SYS_DT        |                                | CTL_PARM                                                                                      | CAS_SYS                                     | NULL                                                                      |
|                          | GET_REAL_CAS_DT       |                                | FCN                                                                                           | TERR_FCN                                    | NULL                                                                      |
| a3                       | SF_IS_PA_PLAN         | " INSERT_FND_TRXN 				"        | CAS_PLAN（自定义type函数不兼容问题，先注释）                                                  | CAS_RISK_CALC                               | CAS_TYPE_CVG_BNFT_REC                                                     |
|                          | SF_IS_PA_RIDER        | " INSERT_FND_TTRXN_HISTORIES	" | WRK（包头通过，包体报4013，需调大内存resource unit，调大ob_query_timeout）                    | CAS_PRODUCT                                 | CAS_TYPE_CVG_BNFT_TAB（force需要放到typename后，仅语法兼容）              |
|                          | IS_STAT_GRP_IN_FORCE  |  INSERT_TTRXN_HISTORIES        |                                                                                               | CAS_USER(GP_TYPE_STR_TAB暂时无法找到)       | CAS_TYPE_CLI_ADDR_REC                                                     |
|                          | IS_STAT_GRP_PENDING   |  S_SUSP_HISTORIES              |                                                                                               | CAS_PLAN_CD                                 | CAS_TYPE_CLI_BANK_REC                                                     |
+--------------------------+-----------------------+--------------------------------+-----------------------------------------------------------------------------------------------+---------------------------------------------+---------------------------------------------------------------------------+
