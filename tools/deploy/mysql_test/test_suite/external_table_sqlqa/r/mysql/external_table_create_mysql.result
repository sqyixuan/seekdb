create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = '"'
)
PATTERN = 'test03.csv'
;
