##location##
create external table ex_t1 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'test.csv'
;
