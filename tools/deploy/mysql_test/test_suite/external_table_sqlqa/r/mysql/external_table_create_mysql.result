PRO_NAME VARCHAR (100) AS (LOWER(METADATA$FILECOL3)),
PAC_NAME VARCHAR (100) AS (SUBSTR(METADATA$FILECOL4,0,3)),
PAC_NOBO_NAME VARCHAR (100) AS (LENGTH(METADATA$FILECOL5)),
TYP_NAME VARCHAR(100) AS (REPLACE(METADATA$FILECOL6,METADATA$FILECOL6,'TYPE'))
)
