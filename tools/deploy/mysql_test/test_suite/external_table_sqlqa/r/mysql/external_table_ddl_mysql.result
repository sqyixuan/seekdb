result_format: 4
SET NAMES utf8mb4;
##根据外表来创建table，view##
create external table ex_t1 (
id NUMBER  as (metadata$filecol1),
name VARCHAR(50) as (metadata$filecol2),
mon FLOAT as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir DATE as (metadata$filecol6))
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	ENCODING = 'UTF8MB4'
	FIELD_DELIMITER = ','
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test06.csv';
##RENAME##
RENAME TABLE EX_t1 TO EX_T2;
RENAME TABLE EX_t2 TO EX_T1;
select ID,NAME,MON,AGE,TEL_NUMBER from ex_t1;
+------+------+---------+------+-------------+
| ID   | NAME | MON     | AGE  | TEL_NUMBER  |
+------+------+---------+------+-------------+
|    1 | wxm  |    3500 | 25   | 13000000000 |
|    2 | ldp  | 3000.01 | 30   | 13000000001 |
|    3 | zhx  | 6000.05 | 28   | 13000000002 |
| NULL | NULL |    NULL | NULL | NULL        |
|    4 | zff  | 4500.12 | 35   | 13000000003 |
|    5 | dyl  |   -4000 | 40   | 13000000004 |
+------+------+---------+------+-------------+
CREATE TABLE T1 AS SELECT ID,NAME,MON FROM EX_T1;
SELECT * FROM T1;
+------+------+---------+
| ID   | NAME | MON     |
+------+------+---------+
|    1 | wxm  |    3500 |
|    2 | ldp  | 3000.01 |
|    3 | zhx  | 6000.05 |
| NULL | NULL |    NULL |
|    4 | zff  | 4500.12 |
|    5 | dyl  |   -4000 |
+------+------+---------+
CREATE VIEW EX_V1 AS SELECT ID,NAME,TEL_NUMBER FROM EX_T1;
SELECT * FROM EX_V1;
+------+------+-------------+
| ID   | NAME | TEL_NUMBER  |
+------+------+-------------+
|    1 | wxm  | 13000000000 |
|    2 | ldp  | 13000000001 |
|    3 | zhx  | 13000000002 |
| NULL | NULL | NULL        |
|    4 | zff  | 13000000003 |
|    5 | dyl  | 13000000004 |
+------+------+-------------+
##对table进行dml，预期不影响外表##
INSERT INTO T1 VALUES (6,'TEST',6666);
SELECT * FROM T1;
+------+------+---------+
| ID   | NAME | MON     |
+------+------+---------+
|    1 | wxm  |    3500 |
|    2 | ldp  | 3000.01 |
|    3 | zhx  | 6000.05 |
| NULL | NULL |    NULL |
|    4 | zff  | 4500.12 |
|    5 | dyl  |   -4000 |
|    6 | TEST |    6666 |
+------+------+---------+
UPDATE T1 SET MON = 0 WHERE ID = 6;
SELECT * FROM T1;
+------+------+---------+
| ID   | NAME | MON     |
+------+------+---------+
|    1 | wxm  |    3500 |
|    2 | ldp  | 3000.01 |
|    3 | zhx  | 6000.05 |
| NULL | NULL |    NULL |
|    4 | zff  | 4500.12 |
|    5 | dyl  |   -4000 |
|    6 | TEST |       0 |
+------+------+---------+
DELETE FROM T1 ;
SELECT * FROM T1;
+------+------+------+
| ID   | NAME | MON  |
+------+------+------+
+------+------+------+
