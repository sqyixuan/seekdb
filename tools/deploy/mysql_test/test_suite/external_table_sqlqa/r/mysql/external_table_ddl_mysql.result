SHOW CREATE TABLE EX_T1;
Table	Create Table
ex_t1	CREATE EXTERNAL TABLE `ex_t1` (
  `id` decimal(10,0) GENERATED ALWAYS AS (metadata$filecol1),
  `name` varchar(50) GENERATED ALWAYS AS (metadata$filecol2),
  `mon` float GENERATED ALWAYS AS (metadata$filecol3),
  `age` varchar(50) GENERATED ALWAYS AS (metadata$filecol4),
  `tel_number` varchar(50) GENERATED ALWAYS AS (metadata$filecol5),
  `bir` date GENERATED ALWAYS AS (metadata$filecol6)
) 
LOCATION='file://mysqltest_data_for_external_table'
PATTERN='test04.csv'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'CSV',
  FIELD_DELIMITER = ',',
  FIELD_OPTIONALLY_ENCLOSED_BY = char(34),
  ENCODING = 'utf8mb4',
  EMPTY_FIELD_AS_NULL = TRUE
) DEFAULT CHARSET = utf8mb4
