####数据清洗####
create external table ex_t10 (
id CHAR (10) AS (metadata$filecol1),
name CHAR (10) ,
mon CHAR (10) ,
age CHAR (10) ,
tel_number varCHAR (15)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
)
PATTERN = 'test.csv';

select * from ex_t10;

drop table ex_t10;

##data type##
##外表目前无法alter##
create external table ex_t10 (
id INT  ,
name VARCHAR(10) ,
mon FLOAT  ,
age INT ,
tel_number VARCHAR(15) ,
bir date
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select * from ex_t10;
