# description: test create external table

--result_format 4
--source mysql_test/test_suite/external_table_sqlqa/include/copy_data_for_external_table.inc

connection default;
SET NAMES utf8mb4;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--error 0,1051
drop table ex_t5;
--error 0,1051
drop table ex_t6;
--error 0,1051
drop table ex_t7;
--error 0,1051
drop table ex_t8;
--error 0,1051
drop table ex_t9;
--error 0,1051
drop table ex_t10;
--error 0,1051
drop table ex_t11;

--enable_query_log

##location##
create external table ex_t1 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'test.csv'
;

select * from ex_t1;

##可以查看外表的信息
#select * from  oceanbase.__all_external_table_file;


