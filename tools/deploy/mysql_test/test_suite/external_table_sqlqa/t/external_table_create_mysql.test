##定义列多于数据文件列##
create external table ex_t11 (
id NUMBER  as (metadata$filecol1),
name VARCHAR(50) as (metadata$filecol2),
mon FLOAT as (metadata$filecol3),
age DOUBLE as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir date as (metadata$filecol6),
id_2 NUMBER  as (metadata$filecol1),
name_2 VARCHAR(50) as (metadata$filecol2),
mon_2 FLOAT as (metadata$filecol3),
age_2 DOUBLE as (metadata$filecol4),
tel_number_2 VARCHAR(50) as (metadata$filecol5),
bir_2 date as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 1
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select * from ex_t11;

drop table ex_t11;


##嵌套表达式##
create external table ex_t11 (
id NUMBER  as (metadata$filecol1),
name VARCHAR(50) as (concat(metadata$filecol2,metadata$filecol1)),
mon FLOAT as (metadata$filecol3),
age DOUBLE as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir DATE as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select * from ex_t11;

drop table ex_t11;

#trim#
create external table ex_t11 (
id VARCHAR(10)  as (trim(metadata$filecol1)),
name VARCHAR(20) as (concat(metadata$filecol2,metadata$filecol1)),
mon VARCHAR(20) as (metadata$filecol3),
age VARCHAR(20) as (metadata$filecol4),
tel_number VARCHAR(20) as (metadata$filecol5)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test03.csv';

select * from ex_t11;

drop table ex_t11;

#其他表达式#
create external table ex_t11 (
FIELD_NAME VARCHAR(100) AS (UPPER(METADATA$FILECOL1)),
FUN_NAME varchar(100) AS (LOWER(METADATA$FILECOL2)),
PRO_NAME VARCHAR (100) AS (LOWER(METADATA$FILECOL3)),
PAC_NAME VARCHAR (100) AS (SUBSTR(METADATA$FILECOL4,0,3)),
PAC_NOBO_NAME VARCHAR (100) AS (LENGTH(METADATA$FILECOL5)),
TYP_NAME VARCHAR(100) AS (REPLACE(METADATA$FILECOL6,METADATA$FILECOL6,'TYPE'))
)
location= 'mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
)
pattern = '.*\.dat'
;

select * from ex_t11 limit 10;

drop table ex_t11;

#其他表达式#
create external table ex_t11 (
id NUMBER  as (metadata$filecol1+0),
name varchar(50) as (cast(metadata$filecol2 as char(10))),
mon VARCHAR(50) as (round(metadata$filecol3,1)),
age VARCHAR(50) as (metadata$filecol2||metadata$filecol4),
tel_number VARCHAR(50) as (cast(metadata$filecol5 as DECIMAL(15))),
bir date as (cast(metadata$filecol6 as date))
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select ID,NAME,MON,AGE,BIR from ex_t11;

drop table ex_t11;

#条件表达式#
create external table ex_t11 (
mon VARCHAR(50) as (case when metadata$filecol3 > 4000 then 'Y' else 'N' end)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
)
PATTERN = 'test05.csv';

select * from ex_t11;

drop table ex_t11;

##外表处理空字符串与表处理空串的逻辑不一致##
create external table ex_t11 (
mon VARCHAR(50) as (nvl(metadata$filecol3,'kong')))
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select * from ex_t11;

drop table ex_t11;








