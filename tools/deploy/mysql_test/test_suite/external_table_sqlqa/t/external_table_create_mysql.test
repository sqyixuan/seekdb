##伪列##
create external table ex_t11 (
id NUMBER  as (metadata$filecol1),
name VARCHAR(50) as (metadata$filecol2),
mon FLOAT as (metadata$filecol3),
age DOUBLE as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir DATE as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 1
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select * from ex_t11;

drop table ex_t11;

##列顺序与数据顺序随机##
create external table ex_t11 (
id NUMBER  as (metadata$filecol6),
name VARCHAR(50) as (metadata$filecol5),
mon FLOAT as (metadata$filecol4),
age DOUBLE as (metadata$filecol3),
tel_number VARCHAR(50) as (metadata$filecol2),
bir NUMBER as (metadata$filecol1)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 1
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv';

select name,mon,age,tel_number,bir from ex_t11;

drop table ex_t11;

