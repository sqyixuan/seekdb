##NULL_IF##
##定义双引号也会无法查询##
create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	NULL_IF = ('.*')
)
PATTERN = 'test03.csv';

select * from ex_t10;

drop table ex_t10;

##双引号无法查询，用test建外表##
create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	ESCAPE = '\\'
	ENCODING = 'UTF8MB4'
	NULL_IF = ('工号','姓名','工资','年龄','手机号','')
)
PATTERN = 'test.csv';

select * from ex_t10;

#select EXTERNAL_FILE_FORMAT from  sys.ALL_VIRTUAL_TABLE_REAL_AGENT where table_name='EX_T10';

drop table ex_t10;

#表达式#
create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	ESCAPE = '\\'
	ENCODING = 'UTF8MB4'
	NULL_IF = (13000000000+0,13000000000+1,13000000000+2,13000000000+3,13000000000+4)
)
PATTERN = 'test.csv';

select * from ex_t10;

drop table ex_t10;

create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	ESCAPE = '\\'
	ENCODING = 'UTF8MB4'
	NULL_IF = (round(3500.1))
)
PATTERN = 'test.csv';

select * from ex_t10;

drop table ex_t10;

##SKIP_HEADER##
#目前跳过会处理为空，待修复#
#已修复#
create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	NULL_IF = ('')
	SKIP_HEADER = 1
)
PATTERN = 'test03.csv';

select * from ex_t10;

drop table ex_t10;

##SKIP_BLANK_LINES##
#true和false都没有处理空行，都为null#
#已修复#
create external table ex_t10 (
id CHAR (50),
name CHAR (50),
mon CHAR (50),
age CHAR (50),
tel_number varCHAR (50)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	NULL_IF = ('')
	SKIP_HEADER = 1
	SKIP_BLANK_LINES = true
)
PATTERN = 'test03.csv';

select * from ex_t10;

drop table ex_t10;

##TRIM_SPACE##
##已修复##
create external table ex_t10 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (15)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	LINE_DELIMITER = char(10)
	FIELD_DELIMITER = ','
	ESCAPE = '\\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	NULL_IF = ('')
	SKIP_HEADER = 0
	SKIP_BLANK_LINES = FALSE
	TRIM_SPACE = TRUE
)
PATTERN = 'test03.csv';

select * from ex_t10;

