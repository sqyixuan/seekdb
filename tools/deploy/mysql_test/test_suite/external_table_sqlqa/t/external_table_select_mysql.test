# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test select external table

--result_format 4
--source mysql_test/test_suite/external_table_sqlqa/include/copy_data_for_external_table.inc

SET NAMES utf8mb4;

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table t1;
--error 0,1051
drop table ex_t2;

--enable_query_log

create external table ex_t1 (
id CHAR(10)  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir VARCHAR(50) as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select * from ex_t1;

--error 0,1051
drop table T1;
#CREATE TABLE T1 LIKE EX_T1;
#INSERT INTO T1 SELECT * FROM EX_T1;
CREATE TABLE T1 AS SELECT * FROM EX_T1;

SELECT * FROM T1;

##SIMPLE SELECT##

SELECT NULL FROM EX_T1;

SELECT ID C1,NAME C2,MON C3,AGE C4,TEL_NUMBER C5,BIR C6 FROM EX_T1;

select DISTINCT ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 order by 1;

#select UNIQUE ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 order by 1;

select ALL ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 order by 1;

SELECT MON*10,ID+10 FROM EX_T1;

SELECT NAME || '-' || AGE AS NG FROM EX_T1;

SELECT MON,CASE WHEN MON >= 4000 THEN 'H' WHEN MON >= 3000 THEN 'N' ELSE 'L' END AS T FROM EX_T1;

##WHERE##

SELECT ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 WHERE ID < 3;

SELECT ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 WHERE AGE = 40;

SELECT ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 WHERE MON > 4000 AND ID >3 ;

SELECT ID,NAME,MON,AGE,TEL_NUMBER,BIR FROM EX_T1 WHERE MON > 4000 OR ID >3 ;

##GROUP BY##

SELECT ID,MAX(MON),MIN(AGE) FROM EX_T1 GROUP BY ID ORDER BY ID;

SELECT ID,MAX(MON),MIN(AGE) FROM EX_T1 GROUP BY ID HAVING ID > 3 AND SUM(MON) > 4000 ORDER BY ID ASC;

SELECT ID,NAME,COUNT(*) FROM EX_T1 GROUP BY ID,NAME WITH ROLLUP ORDER BY ID;

SELECT ID,NAME,COUNT(*) FROM EX_T1 GROUP BY ID,NAME,MON,AGE,TEL_NUMBER,BIR ORDER BY ID,NAME,MON,AGE,TEL_NUMBER,BIR;

##ORDER BY##

SELECT * FROM EX_T1 WHERE ID > 1 ORDER BY EX_T1.ID;

SELECT NAME,COUNT(*) FROM EX_T1 GROUP BY NAME ORDER BY EX_T1.NAME;

SELECT MON,COUNT(*) FROM EX_T1 WHERE ID >1 GROUP BY MON ORDER BY EX_T1.MON;

SELECT AGE,COUNT(*) FROM EX_T1 WHERE ID >1 GROUP BY AGE HAVING AGE <30 ORDER BY EX_T1.AGE;

SELECT * FROM EX_T1 ORDER BY EX_T1.TEL_NUMBER;

SELECT * FROM EX_T1 ORDER BY EX_T1.BIR;


##FOR UPDATE##
##目前不支持##
--error 1235
SELECT * FROM EX_T1 WHERE ID=1 FOR UPDATE;

##伪列##
--error 1054
SELECT metadata$filecol1 FROM EX_T1;
--error 1054
SELECT * FROM EX_T1 WHERE metadata$filecol1 = '2';

##行列转换##
#SELECT * FROM EX_T1 PIVOT(MAX(TEL_NUMBER) FOR ID IN (1 AS P1,2 AS P2,3 AS P3));

#SELECT * FROM (SELECT * FROM EX_T1 PIVOT(MAX(TEL_NUMBER) FOR ID IN (1 AS P1,2 AS P2,3 AS P3))) V UNPIVOT(TEL_NUMBER FOR ID IN (P1 AS 1,P2 AS 2,P3 AS 3));

##分页查询##
SELECT ID,NAME FROM EX_T1 ORDER BY ID LIMIT 3 ;

SELECT ID,NAME FROM EX_T1 ORDER BY ID LIMIT 1,3 ;

SELECT ID,NAME FROM EX_T1 ORDER BY MON LIMIT 0;

SELECT ID,NAME FROM EX_T1 ORDER BY MON LIMIT 0,0;

##层次查询##
#SELECT ID,NAME,MON,LEVEL FROM EX_T1 START WITH ID IS NULL CONNECT BY PRIOR ID = TEL_NUMBER;


##复合查询##
##UNION##

SELECT ID,NAME FROM EX_T1 UNION SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM EX_T1 UNION SELECT ID,NAME FROM T1;

SELECT ID,NAME FROM T1 UNION SELECT ID,NAME FROM EX_T1;

##UNION ALL目前会报错，待修复##
##已修复##

SELECT ID,NAME FROM EX_T1 UNION ALL SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM T1 UNION ALL SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM EX_T1 UNION ALL SELECT ID,NAME FROM T1;

##INTERSECT##

(SELECT ID,NAME FROM EX_T1) INTERSECT (SELECT ID,NAME FROM EX_T1);

SELECT ID,NAME FROM T1 INTERSECT SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM EX_T1 INTERSECT SELECT ID,NAME FROM T1;

##MINUS##

SELECT ID,NAME FROM EX_T1 MINUS SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM T1 MINUS SELECT ID,NAME FROM EX_T1;

SELECT ID,NAME FROM EX_T1 MINUS SELECT ID,NAME FROM T1;


##JOIN查询##

SELECT * FROM EX_T1 TA ,EX_T1 TB WHERE TA.NAME = TB.NAME;

SELECT TA.ID , TA.NAME , TB.ID , TB.NAME FROM EX_T1 TA INNER JOIN EX_T1 TB ON TA.ID = TB.ID;

SELECT * FROM EX_T1 A LEFT JOIN EX_T1 B ON A.ID = B.ID WHERE A.ID IS NOT NULL;

SELECT  A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A LEFT JOIN  EX_T1 B ON A.ID = B.ID;

SELECT A.ID AS A_ID, A.name AS A_ID, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A,EX_T1 B WHERE A.MON = B.MON;

SELECT * FROM EX_T1 A RIGHT JOIN EX_T1 B ON A.ID = B.ID WHERE A.MON >4000;

SELECT  A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A RIGHT JOIN EX_T1 B ON A.NAME = B.NAME;

SELECT A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A,EX_T1 B WHERE A.ID = B.ID;

SELECT  A.ID AS A_ID,A.name AS A_NAME,B.ID AS B_ID,B.name AS B_NAME FROM EX_T1 A CROSS JOIN EX_T1 B ON A.ID = B.ID;

SELECT  A.ID AS A_ID,A.name AS A_NAME,B.ID AS B_ID,B.name AS B_NAME FROM EX_T1 A NATURAL JOIN EX_T1 B ;

#和正常表连接#

SELECT * FROM EX_T1 TA ,T1 TB WHERE TA.NAME = TB.NAME;

SELECT TA.ID , TA.NAME , TB.ID , TB.NAME FROM EX_T1 TA INNER JOIN T1 TB ON TA.ID = TB.ID;

SELECT * FROM EX_T1 A LEFT JOIN T1 B ON A.ID = B.ID WHERE A.ID IS NOT NULL;

SELECT  A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A LEFT JOIN  T1 B ON A.ID = B.ID;

SELECT A.ID AS A_ID, A.name AS A_ID, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A,T1 B WHERE A.MON = B.MON;

SELECT * FROM EX_T1 A RIGHT JOIN T1 B ON A.ID = B.ID WHERE A.MON >4000;

SELECT  A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A RIGHT JOIN T1 B ON A.NAME = B.NAME;

SELECT A.ID AS A_ID, A.name AS A_NAME, B.ID AS B_ID, B.name AS B_NAME FROM EX_T1 A,T1 B WHERE A.ID = B.ID;

SELECT  A.ID AS A_ID,A.name AS A_NAME,B.ID AS B_ID,B.name AS B_NAME FROM EX_T1 A CROSS JOIN T1 B ON A.ID = B.ID;

##三表连接##
create external table EX_T2 (
id INT as (metadata$filecol1),
name VARCHAR(50) as (metadata$filecol2),
mon FLOAT as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir DATE as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	ENCODING = 'UTF8MB4'
	FIELD_DELIMITER = ','
	SKIP_HEADER = 1
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test04.csv'
;

SELECT * FROM EX_T2;

SELECT A.TEL_NUMBER,B.TEL_NUMBER,C.TEL_NUMBER FROM EX_T1 A , EX_T2 B , EX_T2 C WHERE A.tel_number = B.tel_number AND A.ID IN (NULL) OR A.AGE > NULL AND A.tel_number = C.tel_number AND C.AGE IN ('1000','') OR A.ID IS NULL;

SELECT A.TEL_NUMBER,B.ID,C.NAME FROM EX_T1 A INNER JOIN EX_T2 B ON A.tel_number = B.tel_number AND B.MON <= A.AGE OR B.TEL_NUMBER LIKE '%' CROSS JOIN EX_T1 C ON A.tel_number = C.tel_number AND A.AGE NOT IN (NULL) OR A.NAME LIKE 'b%';

SELECT A.ID,B.AGE,C.AGE FROM EX_T1 A RIGHT JOIN EX_T2 B ON A.name = B.name AND B.NAME NOT LIKE '%%' OR A.MON >= B.AGE CROSS JOIN EX_T1 C ON A.name = C.name AND C.MON IS NULL OR A.ID <> C.MON;

SELECT A.AGE,B.TEL_NUMBER,C.MON FROM EX_T2 A LEFT JOIN EX_T1 B ON A.age = B.age AND A.MON IN ('1000') OR B.MON < 9999999999999999999999999999999999999999 CROSS JOIN EX_T2 C ON B.age = C.age AND C.TEL_NUMBER LIKE '%_F%' OR A.ID < -1.25;

SELECT A.NAME,B.MON,C.TEL_NUMBER FROM EX_T2 A , EX_T1 B , EX_T1 C WHERE A.tel_number = B.tel_number AND A.ID <= B.ID OR A.AGE != 100000 AND A.tel_number = C.tel_number AND A.TEL_NUMBER LIKE '%%' OR A.TEL_NUMBER LIKE ' B%';

SELECT A.TEL_NUMBER,B.NAME,C.NAME FROM EX_T1 A , EX_T1 B , EX_T1 C WHERE A.name = B.name AND A.ID IN ('1000') OR A.MON <= B.AGE AND A.name = C.name AND C.MON BETWEEN '1' AND '10000' OR C.MON NOT IN (NULL);

SELECT A.TEL_NUMBER,B.NAME,C.MON FROM EX_T1 A RIGHT JOIN EX_T1 B ON A.id = B.id AND A.AGE <> B.AGE OR A.ID IN (NULL) CROSS JOIN EX_T2 C ON B.id = C.id AND C.TEL_NUMBER LIKE '%%' OR A.ID NOT IN (NULL);

SELECT A.NAME,B.NAME,C.TEL_NUMBER FROM EX_T2 A , EX_T1 B , EX_T2 C WHERE A.tel_number = B.tel_number AND B.NAME LIKE '%F%' OR A.NAME LIKE 'b%' AND A.tel_number = C.tel_number AND C.MON IS NULL OR C.MON != A.AGE;

SELECT A.AGE,B.AGE,C.AGE FROM EX_T2 A , EX_T1 B , EX_T1 C WHERE A.tel_number = B.tel_number AND A.AGE IN ('1000') OR A.MON <> 1 AND A.tel_number = C.tel_number AND C.AGE = A.MON OR C.TEL_NUMBER NOT LIKE '%NULL';

SELECT A.TEL_NUMBER,B.NAME,C.TEL_NUMBER FROM EX_T2 A , EX_T2 B , EX_T2 C WHERE A.age = B.age AND A.ID = B.ID OR B.MON NOT IN ('1000') AND A.age = C.age AND A.TEL_NUMBER LIKE '%b%' OR C.MON BETWEEN '1' AND '10000';



##子查询##

SELECT   AGE,TEL_NUMBER,BIR FROM EX_T1 A WHERE TEL_NUMBER BETWEEN (SELECT  MAX(LOWER(BIR)) FROM EX_T1 B) AND (SELECT COUNT(MON) FROM EX_T1 B WHERE MON NOT IN ('1000') OR (ID IN (NULL) AND MON IS NOT NULL) OR NAME LIKE '%');

SELECT   BIR,MON,NAME,BIR FROM EX_T1 A WHERE TEL_NUMBER NOT IN (SELECT  MIN(ROUND(TEL_NUMBER)) FROM EX_T1 B WHERE (NAME LIKE 'NULL%' OR ID <> -1) AND ID IN ('1000',''));

#非相关子查询#

SELECT * FROM EX_T1 A WHERE A.ID = (SELECT B.ID FROM EX_T1 B WHERE B.MON = 3000 );

SELECT * FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B WHERE B.NAME IS NOT NULL );

SELECT * FROM EX_T1 A WHERE A.ID NOT IN (SELECT B.ID FROM EX_T1 B WHERE B.NAME IS NULL );

SELECT * FROM EX_T1 A WHERE EXISTS (SELECT B.ID FROM EX_T1 B WHERE B.NAME IS NOT NULL );

SELECT * FROM EX_T1 A WHERE NOT EXISTS (SELECT B.ID FROM EX_T1 B WHERE B.NAME IS NULL );

SELECT * FROM EX_T1 A WHERE A.ID =ALL (SELECT B.ID FROM EX_T1 B WHERE B.MON >4000 );

SELECT * FROM EX_T1 A WHERE A.ID =SOME (SELECT B.ID FROM EX_T1 B WHERE B.BIR IS NOT NULL );

SELECT * FROM EX_T1 A WHERE A.ID !=ANY (SELECT B.ID FROM EX_T1 B WHERE B.AGE < 40 );

SELECT * FROM (SELECT * FROM EX_T1) A WHERE A.ID IN (SELECT ID FROM EX_T1 B WHERE B.ID >1);

SELECT * FROM (SELECT * FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B)) C;

SELECT (SELECT ID FROM EX_T1 WHERE ID = 1) C1 FROM EX_T1;

SELECT (SELECT A.ID FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B WHERE B.ID = 1 )) C1 FROM EX_T1 WHERE NAME IN (SELECT NAME FROM EX_T1 WHERE ID = 1);

#相关子查询#

SELECT * FROM EX_T1 A WHERE A.ID = (SELECT B.ID FROM EX_T1 B WHERE A.MON = 3000 );

SELECT * FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B WHERE A.NAME IS NOT NULL );

SELECT * FROM EX_T1 A WHERE A.ID NOT IN (SELECT B.ID FROM EX_T1 B WHERE A.NAME IS NULL );

SELECT * FROM EX_T1 A WHERE EXISTS (SELECT B.ID FROM EX_T1 B WHERE A.NAME IS NOT NULL );

SELECT * FROM EX_T1 A WHERE NOT EXISTS (SELECT B.ID FROM EX_T1 B WHERE A.NAME IS NULL );

SELECT * FROM EX_T1 A WHERE A.ID =ALL (SELECT B.ID FROM EX_T1 B WHERE A.MON >4000 );

SELECT * FROM EX_T1 A WHERE A.ID =SOME (SELECT B.ID FROM EX_T1 B WHERE A.BIR IS NOT NULL );

SELECT * FROM EX_T1 A WHERE A.ID !=ANY (SELECT B.ID FROM EX_T1 B WHERE A.AGE < 40 );

SELECT * FROM (SELECT * FROM EX_T1) A WHERE A.ID IN (SELECT ID FROM EX_T1 B WHERE A.ID >1);

SELECT * FROM (SELECT * FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B WHERE A.ID = 1)) C;

SELECT (SELECT ID FROM EX_T1 WHERE ID = 1) C1 FROM EX_T1;

SELECT (SELECT A.ID FROM EX_T1 A WHERE A.ID IN (SELECT B.ID FROM EX_T1 B WHERE A.ID = 1 )) C1 FROM EX_T1 WHERE NAME IN (SELECT NAME FROM EX_T1 WHERE ID = 1);

##PARALLEL/*+ USE_PX PARALLEL(4)*/##
--sorted_result
SELECT /*+ USE_PX PARALLEL(4)*/ COUNT(*) FROM EX_T1 A JOIN EX_T1 B ON A.ID = B.ID WHERE A.ID IS NULL OR B.ID IS NOT NULL GROUP BY A.ID HAVING A.ID = 1 ORDER BY A.ID;
--sorted_result
SELECT /*+ USE_PX PARALLEL(4)*/ COUNT(*) FROM EX_T1 A , EX_T1 B WHERE A.ID IS NULL OR B.ID IS NOT NULL GROUP BY A.ID HAVING A.ID = 1 ORDER BY A.ID;
--sorted_result
SELECT /*+ USE_PX PARALLEL(4)*/ COUNT(*) FROM EX_T1 A, EX_T1 B,EX_T1 C WHERE A.ID = B.ID AND A.ID IS NULL OR B.ID IS NOT NULL GROUP BY A.ID HAVING A.ID = 1 ORDER BY A.ID;


##bug sql##
##待验证##
##已验证##

SELECT  * FROM EX_T1 A FULL JOIN (SELECT  * FROM EX_T1 B WHERE ID IS NULL OR AGE IS NOT NULL) B ON A.ID = B.ID WHERE A.NAME = B.MON;

SELECT * FROM EX_T1 A LEFT JOIN (SELECT  * FROM EX_T1 B WHERE NAME NOT LIKE 'b'  OR ID < 40) B ON A.AGE = B.AGE;
--sorted_result
SELECT /*+ USE_PX PARALLEL(2)*/ COUNT(*) FROM EX_T1 A RIGHT JOIN EX_T1 B ON A.AGE = B.AGE WHERE A.NAME IS NULL OR B.BIR NOT LIKE '%' GROUP BY A.NAME;
--sorted_result
SELECT /*+ USE_PX PARALLEL(2)*/ COUNT(*) FROM EX_T1 A,EX_T1 B,T1 C WHERE A.AGE = B.AGE AND A.TEL_NUMBER = C.TEL_NUMBER AND A.BIR IS NOT NULL OR C.BIR LIKE '%';


--disable_query_log
--error 0,1051
DROP TABLE EX_T1;
--error 0,1051
drop table t1;
--error 0,1051
drop table ex_t2;
--enable_query_log

