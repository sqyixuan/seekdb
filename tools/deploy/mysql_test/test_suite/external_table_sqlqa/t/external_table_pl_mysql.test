# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test external table pl

--result_format 4
--source mysql_test/test_suite/external_table_sqlqa/include/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table t1;
--enable_query_log


create external table ex_t1 (
id NUMBER  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir date as (metadata$filecol6)
)
location='mysqltest_data_for_external_table'
format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = 'test05.csv';

select * from ex_t1;

CREATE TABLE T1 AS SELECT ID,NAME,MON FROM EX_T1;
SELECT * FROM T1;

##PL内查表##

DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  SELECT * FROM EX_T1;
END
//
DELIMITER ;//
CALL EX_PRO();

DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO(IN TABLE_NAME VARCHAR(50))
BEGIN
  SET @SQL = CONCAT('SELECT * FROM ',TABLE_NAME);
  PREPARE stmt FROM @sql;
  EXECUTE stmt;
  DEALLOCATE PREPARE stmt;
END
//
DELIMITER ;//
CALL EX_PRO('EX_T1');

DROP FUNCTION IF EXISTS EX_FUN;
DELIMITER //;
CREATE FUNCTION EX_FUN() RETURNS VARCHAR(10)
BEGIN
  DECLARE A VARCHAR(10);
  SELECT  NAME INTO A FROM EX_T1 WHERE ID = 1;
  RETURN A;
END
//
DELIMITER ;//
SELECT EX_FUN();

##PREPARE##
DROP TABLE IF EXISTS EX_T1;
PREPARE STMT1 FROM 'create external table EX_T1 (
id NUMBER  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir date as (metadata$filecol6)
)
location=\'mysqltest_data_for_external_table\'
format (
    type = \'csv\'
	FIELD_DELIMITER = \',\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = \'UTF8MB4\'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = \'test05.csv\'';


EXECUTE STMT1 ;
DEALLOCATE PREPARE STMT1;

PREPARE STMT2 FROM 'SELECT * FROM EX_T1 WHERE ID = ?';

SET @A = 2;

EXECUTE STMT2 USING @A ;
DEALLOCATE PREPARE STMT2;

--error 1235
PREPARE STMT1 FROM 'CREATE INDEX IN_A ON EX_T1(ID)';
--error 1235
PREPARE STMT1 FROM 'INSERT INTO EX_T1(ID) VALUES(6) ';
--error 1235
PREPARE STMT1 FROM 'ALTER TABLE EX_T1 ADD SEX VARCHAR(10)';


##pl内对外表进行ddl，dml##
##DDL##
#CREATE EXTERNAL TABLE#
#过程中无法直接创建，要使用prepare语句#
DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
--error 1064
CREATE PROCEDURE EX_PRO()
BEGIN
  DROP TABLE IF EXISTS EX_T1;
  create external table ex_t1 (
  id NUMBER  as (metadata$filecol1),
  name varchar(50) as (metadata$filecol2),
  mon VARCHAR(50) as (metadata$filecol3),
  age VARCHAR(50) as (metadata$filecol4),
  tel_number VARCHAR(50) as (metadata$filecol5),
  bir date as (metadata$filecol6)
  )
  location='mysqltest_data_for_external_table'
  format (
    type = 'csv'
	FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	EMPTY_FIELD_AS_NULL = true
  )
  PATTERN = 'test05.csv';
END
//
DELIMITER ;//


DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  DROP TABLE IF EXISTS EX_T1;
  PREPARE STMT1 FROM 'create external table EX_T1 (
id NUMBER  as (metadata$filecol1),
name varchar(50) as (metadata$filecol2),
mon VARCHAR(50) as (metadata$filecol3),
age VARCHAR(50) as (metadata$filecol4),
tel_number VARCHAR(50) as (metadata$filecol5),
bir date as (metadata$filecol6)
)
location=\'mysqltest_data_for_external_table\'
format (
    type = \'csv\'
	FIELD_DELIMITER = \',\'
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = \'UTF8MB4\'
	EMPTY_FIELD_AS_NULL = true
)
PATTERN = \'test05.csv\'';
EXECUTE STMT1 ;
DEALLOCATE PREPARE STMT1;
END
//
DELIMITER ;//
CALL EX_PRO();

#CREATE INDEX#
DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  CREATE INDEX IN_A ON EX_T1(ID);
END
//
DELIMITER ;//
--error 1235
CALL EX_PRO();

