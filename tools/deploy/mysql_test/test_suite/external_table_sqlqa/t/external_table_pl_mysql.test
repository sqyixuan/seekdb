##DML##
DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  DECLARE V_ID INT DEFAULT 6;
  INSERT INTO EX_T1(ID) VALUES (V_ID);
END
//
DELIMITER ;//
--error 1235
CALL EX_PRO();

DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  UPDATE EX_T1 SET ID = 6;
END
//
DELIMITER ;//
--error 3105
CALL EX_PRO();

DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  DELETE FROM EX_T1;
END
//
DELIMITER ;//
--error 1235
CALL EX_PRO();

DROP PROCEDURE IF EXISTS EX_PRO;

##CURSOR##
DROP PROCEDURE IF EXISTS EX_PRO;
DELIMITER //;
CREATE PROCEDURE EX_PRO()
BEGIN
  DECLARE DONE INT DEFAULT FALSE;
  DECLARE cur_name varchar(20);
  DECLARE ex_cur CURSOR FOR SELECT name FROM EX_T1;
  DECLARE CONTINUE HANDLER FOR NOT FOUND SET DONE = TRUE;
  OPEN ex_cur;
  READ_LOOP:LOOP
   IF DONE THEN
    LEAVE READ_LOOP;
   END IF;
   FETCH ex_cur INTO cur_name;
   SELECT cur_name;
  END LOOP;
  CLOSE EX_CUR;
END
//
DELIMITER ;//

CALL EX_PRO();

##TRIGGER##
DELIMITER //;
CREATE TRIGGER EX_TRI AFTER INSERT ON T1 FOR EACH ROW
BEGIN
	INSERT INTO EX_T1(ID) VALUES(NEW.ID);
END;
//
DELIMITER ;//

--error 1235
INSERT INTO T1(ID) VALUES (6);

DROP TRIGGER IF EXISTS EX_TRI;
DELIMITER //;
CREATE TRIGGER EX_TRI BEFORE INSERT ON T1 FOR EACH ROW
BEGIN
	DELETE FROM EX_T1;
END;
//
DELIMITER ;//

--error 1235
INSERT INTO T1(ID) VALUES (6);

DROP TRIGGER IF EXISTS EX_TRI;
DELIMITER //;
--error 1235
CREATE TRIGGER EX_TRI BEFORE INSERT ON EX_T1 FOR EACH ROW
BEGIN
	DELETE FROM T1;
END;
//
DELIMITER ;//

DELIMITER //;
--error 1235
CREATE TRIGGER EX_TRI AFTER INSERT ON EX_T1 FOR EACH ROW
BEGIN
	DELETE FROM T1;
END;
//
DELIMITER ;//

DELIMITER //;
--error 1235
CREATE TRIGGER EX_TRI BEFORE UPDATE ON EX_T1 FOR EACH ROW
BEGIN
	DELETE FROM T1;
END;
//
DELIMITER ;//

DELIMITER //;
--error 1235
CREATE TRIGGER EX_TRI AFTER UPDATE ON EX_T1 FOR EACH ROW
BEGIN
	DELETE FROM T1;
END;
//
DELIMITER ;//

DELIMITER //;
--error 1235
CREATE TRIGGER EX_TRI AFTER DELETE ON EX_T1 FOR EACH ROW
BEGIN
	DELETE FROM T1;
END;
//
DELIMITER ;//


--disable_query_log
