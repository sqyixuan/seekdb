drop table if exists s1;
drop table if exists s2;
drop table if exists s3;
drop table if exists t1;
drop table if exists t2;
create table s1 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table s2 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table s3 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
insert into s1 values (1,1,1),(2,2,2),(3,3,3);
insert into s2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
