      equal_conds([t1.c_sensitive = cast(t2.c_insensitive, VARCHAR(1048576))]), other_conds(nil)
  2 - output([t2.c_insensitive]), filter(nil), rowset=16
      access([t2.c_insensitive]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c_insensitive], [t2.id]), range(MIN,MIN ; MAX,MAX)always true
  3 - output([t1.c_sensitive], [t1.c2]), filter(nil), rowset=16
      access([t1.c_sensitive], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.id]), range(MIN ; MAX)always true
