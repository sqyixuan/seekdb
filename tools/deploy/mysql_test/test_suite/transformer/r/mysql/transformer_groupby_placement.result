## inner join tables
EXPLAIN select min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
Query Plan
==================================================================
|ID|OPERATOR                 |NAME         |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------------
|0 |MERGE GROUP BY           |             |1       |35          |
|1 |└─MERGE JOIN             |             |100     |30          |
|2 |  ├─SORT                 |             |10      |21          |
|3 |  │ └─SUBPLAN SCAN       |VIEW1        |10      |20          |
|4 |  │   └─HASH GROUP BY    |             |10      |20          |
|5 |  │     └─TABLE FULL SCAN|l            |100     |6           |
|6 |  └─TABLE FULL SCAN      |r(T2_100_TEN)|100     |4           |
==================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_MIN(VIEW1.T_FUN_MIN(l.THOUSAND))], [T_FUN_MAX(VIEW1.T_FUN_MAX(l.THOUSAND))]), filter([T_FUN_MIN(VIEW1.T_FUN_MIN(l.THOUSAND)) > cast(0,
       DECIMAL_INT(10, 0))]), rowset=256
      group([VIEW1.l.TEN]), agg_func([T_FUN_MIN(VIEW1.T_FUN_MIN(l.THOUSAND))], [T_FUN_MAX(VIEW1.T_FUN_MAX(l.THOUSAND))])
  1 - output([VIEW1.l.TEN], [VIEW1.T_FUN_MIN(l.THOUSAND)], [VIEW1.T_FUN_MAX(l.THOUSAND)]), filter(nil), rowset=256
      equal_conds([VIEW1.l.TEN = r.TEN]), other_conds(nil)
      merge_directions([ASC])
  2 - output([VIEW1.l.TEN], [VIEW1.T_FUN_MIN(l.THOUSAND)], [VIEW1.T_FUN_MAX(l.THOUSAND)]), filter(nil), rowset=256
      sort_keys([VIEW1.l.TEN, ASC])
  3 - output([VIEW1.l.TEN], [VIEW1.T_FUN_MIN(l.THOUSAND)], [VIEW1.T_FUN_MAX(l.THOUSAND)]), filter(nil), rowset=256
      access([VIEW1.l.TEN], [VIEW1.T_FUN_MIN(l.THOUSAND)], [VIEW1.T_FUN_MAX(l.THOUSAND)])
  4 - output([l.TEN], [T_FUN_MIN(l.THOUSAND)], [T_FUN_MAX(l.THOUSAND)]), filter(nil), rowset=256
      group([l.TEN]), agg_func([T_FUN_MIN(l.THOUSAND)], [T_FUN_MAX(l.THOUSAND)])
  5 - output([l.TEN], [l.THOUSAND]), filter(nil), rowset=256
      access([l.TEN], [l.THOUSAND]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([l.__pk_increment]), range(MIN ; MAX)always true
  6 - output([r.TEN]), filter(nil), rowset=256
      access([r.TEN]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([r.TEN], [r.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
