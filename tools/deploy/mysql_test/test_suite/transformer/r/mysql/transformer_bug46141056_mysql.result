drop table if exists t1, t2;
create table t1(pk int primary key, c1 int);
create table t2(c1 int);
explain_protocol: 2
result_format: 4
EXPLAIN select * from t1 as t1_a left join t1 as t1_b on t1_a.c1 = t1_b.c1 where not exists (select 1 from t2 where t2.c1 = t1_a.pk) and t1_b.pk is NULL;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |MERGE ANTI JOIN    |    |1       |5           |
|1 |├─TABLE FULL SCAN  |t1_a|1       |3           |
|2 |└─SORT             |    |1       |3           |
|3 |  └─TABLE FULL SCAN|t2  |1       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1_a.pk], [t1_a.c1], [cast(NULL, INT(11, 0))], [cast(NULL, INT(11, 0))]), filter(nil), rowset=16
      equal_conds([t2.c1 = t1_a.pk]), other_conds(nil)
      merge_directions([ASC])
  1 - output([t1_a.pk], [t1_a.c1]), filter([t1_a.c1 IS NULL]), rowset=16
      access([t1_a.pk], [t1_a.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1_a.pk]), range(MIN ; MAX)always true
  2 - output([t2.c1]), filter(nil), rowset=16
      sort_keys([t2.c1, ASC])
  3 - output([t2.c1]), filter(nil), rowset=16
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
