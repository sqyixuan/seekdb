drop table if exists t1, t2, t3;
alter system set _inlist_rewrite_threshold = 1;
create table t2 (c1 int, index i1(c1));
insert into t2 values (1),(2);
create table t1 (c1 int, c2 int, c3 int, index i2(c2), index i3(c3)) partition by key(c2) partitions 2;
insert into t1 values (1,1,2);
insert into t1 values (2,1,1);
insert into t1 values (1,1,4);
insert into t1 values (2,1,3);
insert into t1 values (1,1,5);
insert into t1 values (2,2,9);
insert into t1 values (1,2,7);
insert into t1 values (2,2,8);
insert into t1 values (1,2,10);
insert into t1 values (2,2,6);
insert into t1 values (1,1,2);
insert into t1 values (2,1,1);
insert into t1 values (1,1,4);
insert into t1 values (2,1,3);
insert into t1 values (1,1,5);
