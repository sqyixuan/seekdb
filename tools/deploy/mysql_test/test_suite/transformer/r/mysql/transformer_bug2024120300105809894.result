insert into t1 values (1,2,7);
insert into t1 values (2,2,8);
insert into t1 values (1,2,10);
insert into t1 values (2,2,6);
result_format: 4
explain_protocol: 1
EXPLAIN BASIC select /*+no_expand*/ c2, c3, rownum from (select *, row_number() over (partition by c2 order by c1) as rownum from t1) where c2 in (select c1 from t2) or c3 not in (0);
