drop table if exists t_kms_a_key_version, t10n9let, t_mon_eps_hour, t1dnkisz, t_log_exception_detail, putong_index, cool_bill_20180919, t_kms_user_info, range_columns_test;
CREATE TABLE `t_kms_a_key_version` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `key_id` varchar(64) NOT NULL COMMENT '密钥ID',
  `public_key` longtext NOT NULL COMMENT '公钥',
  `private_key` longtext NOT NULL COMMENT '私钥',
  `update_date` varchar(128) NOT NULL COMMENT '更新时间',
  `update_by` varchar(50) NOT NULL COMMENT '更新者',
  `key_version` int(5) NOT NULL COMMENT '版本号',
  `key_algorithm` varchar(32) NOT NULL,
  PRIMARY KEY (`id`),
  KEY `keyId` (`key_id`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 2 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0   ;

CREATE TABLE `t10n9let` (
  `c1` varchar(1) DEFAULT NULL,
  `c2` varchar(1) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `t_mon_eps_hour` (
  `epsID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'epsID',
  `monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP,
  `algorithm` varchar(20) DEFAULT NULL COMMENT '加密算法名称',
  `max` double(20,0) DEFAULT NULL COMMENT '统计时间段内最大的加密次数',
  `avg` double(20,0) DEFAULT NULL COMMENT '统计时间段内平均的加密次数',
  `hsmUUID` varchar(50) CHARACTER SET utf8mb4 DEFAULT NULL,
  `vsmUUID` varchar(50) CHARACTER SET utf8mb4 DEFAULT NULL,
  PRIMARY KEY (`epsID`)
) AUTO_INCREMENT = 1012982 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = gbk ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `t1dnkisz` (
  `c1` char(1) DEFAULT NULL,
  `c2` char(1) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `t_log_exception_detail` (
  `detail_ID` int(11) NOT NULL AUTO_INCREMENT,
  `exceptDetail` text DEFAULT NULL COMMENT '异常详情',
  PRIMARY KEY (`detail_ID`)
) AUTO_INCREMENT = 1000085 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 ;

CREATE TABLE `putong_index` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL,
  PRIMARY KEY (`name`),
  KEY `hehe` (`age`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4;

CREATE TABLE `cool_bill_20180919` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL,
  `app_id` varchar(20) DEFAULT NULL,
  `mch_id` varchar(30) DEFAULT NULL,
  `sub_mch` varchar(30) DEFAULT NULL,
  `device_id` varchar(50) DEFAULT NULL,
  `wx_order` varchar(50) DEFAULT NULL,
  `order_no` varchar(50) DEFAULT NULL,
  `openid` varchar(50) DEFAULT NULL,
  `trade_type` varchar(50) DEFAULT NULL,
  `trade_status` varchar(50) DEFAULT NULL,
  `bank` varchar(100) DEFAULT NULL,
  `cny` varchar(20) DEFAULT NULL,
  `total_money` varchar(20) DEFAULT NULL,
  `redpacket_money` varchar(20) DEFAULT NULL,
  `aprefund_time` varchar(30) DEFAULT NULL,
  `surefund_time` varchar(30) DEFAULT NULL,
  `wxrefund_no` varchar(50) DEFAULT NULL,
  `mcrefund_no` varchar(50) DEFAULT NULL,
  `refund_money` varchar(20) DEFAULT NULL,
  `redpacket_refund_money` varchar(20) DEFAULT NULL,
  `refund_type` varchar(20) DEFAULT NULL,
  `refund_status` varchar(20) DEFAULT NULL,
  `product_target_name` varchar(100) DEFAULT NULL,
  `data_packet` varchar(255) DEFAULT NULL,
  `fee` varchar(20) DEFAULT NULL,
  `rate` varchar(20) DEFAULT NULL,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL,
  `agent_fr_fee` varchar(100) DEFAULT NULL,
  `qd_fr_fee` varchar(100) DEFAULT NULL,
  `td_cost_fee` varchar(100) DEFAULT NULL,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL,
  `activity_type` varchar(30) DEFAULT NULL,
  `pay_log_id` varchar(40) DEFAULT NULL,
  `user_id` varchar(11) DEFAULT NULL,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`, `trade_type`, `wxrefund_no`) BLOCK_SIZE 16384 LOCAL,
  KEY `mch_id_idx` (`mch_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `agent_id_idx` (`agent_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `bill_time_idx` (`bill_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `trade_time_idx` (`trade_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `business_id_idx` (`business_id`) BLOCK_SIZE 16384 LOCAL
) ;

CREATE TABLE `t_kms_user_info` (
  `userId` int(11) NOT NULL AUTO_INCREMENT,
  `userName` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `passwd` varchar(32) DEFAULT NULL COMMENT '密码',
  `roleId` int(11) DEFAULT NULL COMMENT '角色id',
  `lastLoginTime` varchar(32) DEFAULT NULL COMMENT '上次登录时间',
  `status` int(1) DEFAULT NULL COMMENT '状态1启用0禁用',
  `updateTime` varchar(32) DEFAULT NULL COMMENT '更新时间',
  `ukeySN` varchar(16) DEFAULT NULL COMMENT 'UKEY序列号',
  `manage_pub` varchar(255) DEFAULT NULL COMMENT 'ukey管理员公钥',
  `createTime` varchar(32) DEFAULT NULL,
  PRIMARY KEY (`userId`),
  KEY `roleId` (`roleId`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 1000003 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `range_columns_test` (
  `id` int(11) NOT NULL,
  `departno` bigint(20) NOT NULL,
  PRIMARY KEY (`id`, `departno`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
