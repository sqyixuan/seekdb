drop table if exists t1, t2;
create table t1(c1 int);
create table t2(c1 blob, c2 int, c3 varchar(10), c4 year);
explain_protocol: 2
result_format: 4
## test always false elimination
EXPLAIN select * from t1 left join t2 on 1 = 0;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [cast(NULL, TEXT(65536))], [cast(NULL, INT(11, 0))], [cast(NULL, VARCHAR(10))], [cast(NULL, YEAR(4, 0))]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 left join t2 on 1 = 0;
+------+------+------+------+------+
| c1   | c1   | c2   | c3   | c4   |
+------+------+------+------+------+
+------+------+------+------+------+
## test another issue assocated with always false elimination: 
EXPLAIN select concat(t2.c3, t2.c4) from t1 left join t2 on 1 = 0;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([concat(cast(NULL, VARCHAR(10)), cast(cast(NULL, YEAR(4, 0)), VARCHAR(1048576)))]), filter(nil), rowset=16
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select concat(t2.c3, t2.c4) from t1 left join t2 on 1 = 0;
+----------------------+
| concat(t2.c3, t2.c4) |
+----------------------+
+----------------------+

## test left to anti
EXPLAIN select * from t1 left join t2 on t1.c1 = t2.c2 where t2.c2 is null;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH ANTI JOIN   |    |1       |5           |
|1 |├─TABLE FULL SCAN|t1  |1       |3           |
|2 |└─TABLE FULL SCAN|t2  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [cast(NULL, TEXT(65536))], [cast(NULL, INT(11, 0))], [cast(NULL, VARCHAR(10))], [cast(NULL, YEAR(4, 0))]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c2]), other_conds(nil)
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c2]), filter(nil), rowset=16
      access([t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select * from t1 left join t2 on t1.c1 = t2.c2 where t2.c2 is null;
+------+------+------+------+------+
| c1   | c1   | c2   | c3   | c4   |
+------+------+------+------+------+
+------+------+------+------+------+

explain_protocol: 0
drop table if exists t1, t2;
