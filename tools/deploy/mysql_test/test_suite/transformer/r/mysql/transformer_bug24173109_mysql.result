drop table if exists cus_rate_batch;
create table cus_rate_batch (
serno varchar(100) not null comment 'abc',
netincome decimal(18,2) default null comment 'abc',
net_assets decimal(18,2) default null comment 'abc',
cus_id varchar(32) default null comment 'abc',
create_time varchar(20) default null comment 'abc',
primary key(serno));
result_format: 4
explain_protocol: 2
EXPLAIN select temp.rank
from 
(
select ta.serno,ta.netincome,ta.net_assets,ta.cus_id,
@index := @index+1,@rank:=(
case
when @temp_netincome = ta.netincome then @rank
else @index end) as rank,
@temp_netincome := ta.netincome
from 
(select * from cus_rate_batch
order by netincome desc) as ta,
(select @rank:=0,@temp_netincome=null,@rowtotal:=null,@index:=1) 
r) as temp where serno='';
Query Plan
=========================================================================
|ID|OPERATOR                       |NAME          |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |SUBPLAN SCAN                   |temp          |1       |3           |
|1 |└─NESTED-LOOP JOIN CARTESIAN   |              |1       |3           |
|2 |  ├─SUBPLAN SCAN               |r             |1       |1           |
|3 |  │ └─EXPRESSION               |              |1       |1           |
|4 |  └─DISTRIBUTED TABLE FULL SCAN|cus_rate_batch|1       |3           |
=========================================================================
Outputs & filters:
-------------------------------------
  0 - output([temp.rank]), filter([temp.serno = ''])
      access([temp.serno], [temp.rank])
  1 - output([cus_rate_batch.serno], [cus_rate_batch.netincome], [cus_rate_batch.net_assets], [cus_rate_batch.cus_id], [(T_OP_ASSIGN, 'index', cast(('index'),
       DOUBLE(-1, -1)) + cast(1, DOUBLE(-1, -1)))], [(T_OP_ASSIGN, 'rank', CASE WHEN cast(('temp_netincome'), DECIMAL_INT(18, 2)) = cus_rate_batch.netincome THEN 
      ('rank') ELSE ('index') END)], [(T_OP_ASSIGN, 'temp_netincome', cus_rate_batch.netincome)]), filter(nil)
      conds(nil), nl_params_(nil), use_batch=false
  2 - output(nil), filter(nil)
      access(nil)
  3 - output([(T_OP_ASSIGN, 'rank', 0)], [('temp_netincome') = cast(NULL, VARCHAR(1048576))], [(T_OP_ASSIGN, 'rowtotal', cast(NULL, VARCHAR(0)))], [(T_OP_ASSIGN,
       'index', 1)]), filter(nil)
      values({(T_OP_ASSIGN, 'rank', 0), ('temp_netincome') = cast(NULL, VARCHAR(1048576)), (T_OP_ASSIGN, 'rowtotal', cast(NULL, VARCHAR(0))), (T_OP_ASSIGN,
       'index', 1)})
  4 - output([cus_rate_batch.serno], [cus_rate_batch.netincome], [cus_rate_batch.net_assets], [cus_rate_batch.cus_id]), filter(nil)
      access([cus_rate_batch.serno], [cus_rate_batch.netincome], [cus_rate_batch.net_assets], [cus_rate_batch.cus_id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([cus_rate_batch.serno]), range(MIN ; MAX)always true
select temp.rank
from 
(
select ta.serno,ta.netincome,ta.net_assets,ta.cus_id,
@index := @index+1,@rank:=(
case
when @temp_netincome = ta.netincome then @rank
else @index end) as rank,
@temp_netincome := ta.netincome
from 
(select * from cus_rate_batch
order by netincome desc) as ta,
(select @rank:=0,@temp_netincome=null,@rowtotal:=null,@index:=1) 
r) as temp where serno='';
