DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ OUTR FROM B AS OUTR WHERE ( OUTR . col_varchar_20 , OUTR . col_varchar_20_key ) IN ( SELECT DISTINCT INNR . col_varchar_20 AS X , INNR . col_varchar_20 AS Y FROM BB AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . col_varchar_10 < INNR . col_varchar_20_key ) WHERE INNR . col_datetime = INNR . col_date_key OR OUTR . pk < 5 ORDER BY INNR . pk ) AND OUTR . col_varchar_10_key IS NOT NULL ;

DROP TABLE IF EXISTS b;
DROP TABLE IF EXISTS bb;
