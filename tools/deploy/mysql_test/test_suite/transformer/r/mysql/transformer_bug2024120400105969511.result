drop table if exists t1,t2;
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by hash(c1) partitions 2;
create table t2(c2 int, c3 int, primary key(c2)) duplicate_scope = "cluster" duplicate_read_consistency='weak';
result_format: 4
explain_protocol: 1
EXPLAIN BASIC select /*+opt_param('hidden_column_visible', 'true')*/t1.* from t1 join t2 on t1.c2=t2.c2 where ((t1.ora_rowscn>1733248804789747000 and t1.`old_new$$`='F') or (t2.ora_rowscn>1733248804789747000 and t2.`old_new$$`='F'));
