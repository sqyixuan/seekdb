drop table if exists t1,t2;
create table t1(c1 varchar(10) collate utf8mb4_general_ci, c2 int);
create table t2(c1 varchar(10) collate utf8mb4_general_ci, c2 int);
insert into t1 values('a', 1);
insert into t2 values('a ', 1);
result_format: 4
explain_protocol: 1
# predicate pullup
------------------------------------------------------------
EXPLAIN BASIC select * from t1 where c1 = 'a' intersect select * from t2;
Query Plan
=================================
|ID|OPERATOR               |NAME|
---------------------------------
|0 |HASH INTERSECT DISTINCT|    |
|1 |├─TABLE FULL SCAN      |t1  |
|2 |└─TABLE FULL SCAN      |t2  |
=================================
Outputs & filters:
-------------------------------------
  0 - output([INTERSECT([1])], [INTERSECT([2])]), filter(nil), rowset=16
  1 - output([t1.c1], [t1.c2]), filter([t1.c1 = 'a']), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c1], [t2.c2]), filter([t2.c1 = 'a']), rowset=16
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where c1 = 'a' intersect select * from t2;
