f_14 where case when 82 < 97 then cast(null as CHAR) else cast(null as CHAR) end  not  in ( cast(null as CHAR),  cast(null as CHAR)) limit 169) , ref_2.c7 , 44 ) ,  ref_1.c5,  (select c1 from t4 order by 1 limit 1 offset 47) ,  cast(nullif(91, ref_1.c1) as DECIMAL)) limit 110;
