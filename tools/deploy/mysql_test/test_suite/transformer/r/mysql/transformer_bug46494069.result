result_format: 4
create table t1 (c1 BINARY(72) ,c2 INTEGER(127)  auto_increment,c3 VARCHAR(86) ,c4 BIT(29) ,c5 TIME,c6 YEAR(4) ,c7 TIME,c8 DATETIME,c9 VARBINARY(52) ,c10 VARCHAR(86) , primary key(c3,c9,c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin;

create table t2 (c1 NUMERIC(64,29) ,c2 DATETIME,c3 VARCHAR(86) ,c4 NUMERIC(64,24) ,c5 DATE,c6 YEAR(4) ,c7 INT(127) ,c8 VARBINARY(54) ,c9 INTEGER(127) ,c10 TIMESTAMP(1)  NOT NULL default 0,c11 YEAR(4) ,c12 YEAR(4) , primary key(c3,c7,c8,c1))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c3) PARTITIONS 10;

create table t3 (c1 INTEGER(127) ,c2 INTEGER(127)  auto_increment,c3 DATE,c4 TIME,c5 INTEGER(127) ,c6 YEAR(4) ,c7 DECIMAL(64,28) ,c8 DATE,c9 INT(127) ,c10 INTEGER(127) ,c11 BIGINT(127) ,c12 INTEGER(127) ,c13 BINARY(77) , primary key(c2,c10,c5))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c2) PARTITIONS 10;

create table t4 (c1 INTEGER(127) ,c2 INTEGER(127)  auto_increment,c3 DATE,c4 TIME,c5 INTEGER(127) ,c6 YEAR(4) ,c7 DECIMAL(64,28) ,c8 DATE,c9 INT(127) ,c10 INTEGER(127) ,c11 BIGINT(127) ,c12 INTEGER(127) ,c13 BINARY(77) , primary key(c2,c10,c5))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c2) PARTITIONS 10;

create table t5 (c1 TIMESTAMP(4)  NOT NULL default 0,c2 BIT(1) ,c3 VARBINARY(73) ,c4 INTEGER(127) ,c5 CHAR(152) ,c6 NUMERIC(64,0) ,c7 BIGINT(127) ,c8 INTEGER(127) ,c9 INTEGER(127) ,c10 TIME,c11 BIT(17) ,c12 TIME,c13 VARCHAR(86) ,c14 VARBINARY(53) ,c15 DATE, primary key(c11,c14,c3,c9,c6))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;

create table t6 (c1 INTEGER(127) ,c2 VARBINARY(83) ,c3 DATE,c4 BIT(51) ,c5 DECIMAL(64,16) ,c6 TIME,c7 DATETIME,c8 VARCHAR(86) ,c9 CHAR(152) ,c10 YEAR(4) ,c11 NUMERIC(64,9) ,c12 DATETIME,c13 DATE,c14 YEAR(4) ,c15 YEAR(4) , primary key(c11,c8,c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;

create table t7 (c1 BIT(58) ,c2 VARCHAR(86) ,c3 DATETIME,c4 VARBINARY(72) ,c5 INT(127)  auto_increment,c6 TIMESTAMP(4)  NOT NULL default 0,c7 BIGINT(127) ,c8 BINARY(91) ,c9 VARBINARY(82) ,c10 DATETIME,c11 DECIMAL(64,0) ,c12 DECIMAL(64,13) ,c13 TIME,c14 DATETIME,c15 VARCHAR(86) ,c16 VARCHAR(86) ,c17 YEAR(4) ,c18 CHAR(152) , primary key(c11,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c7) PARTITIONS 10;

create table t8 (c1 BIT(58) ,c2 VARCHAR(86) ,c3 DATETIME,c4 VARBINARY(72) ,c5 INT(127)  auto_increment,c6 TIMESTAMP(4)  NOT NULL default 0,c7 BIGINT(127) ,c8 BINARY(91) ,c9 VARBINARY(82) ,c10 DATETIME,c11 DECIMAL(64,0) ,c12 DECIMAL(64,13) ,c13 TIME,c14 DATETIME,c15 VARCHAR(86) ,c16 VARCHAR(86) ,c17 YEAR(4) ,c18 CHAR(152) , primary key(c11,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c7) PARTITIONS 10;

create table t9 (c1 BIT(58) ,c2 VARCHAR(86) ,c3 DATETIME,c4 VARBINARY(72) ,c5 INT(127)  auto_increment,c6 TIMESTAMP(4)  NOT NULL default 0,c7 BIGINT(127) ,c8 BINARY(91) ,c9 VARBINARY(82) ,c10 DATETIME,c11 DECIMAL(64,0) ,c12 DECIMAL(64,13) ,c13 TIME,c14 DATETIME,c15 VARCHAR(86) ,c16 VARCHAR(86) ,c17 YEAR(4) ,c18 CHAR(152) , primary key(c11,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c7) PARTITIONS 10;

create table t10 (c1 INT(127)  auto_increment,c2 DECIMAL(64,4) ,c3 VARCHAR(86) ,c4 TIME,c5 INTEGER(127) ,c6 DATE,c7 CHAR(152) ,c8 INT(127) ,c9 DECIMAL(64,12) ,c10 DATE,c11 INT(127) ,c12 TIME,c13 BINARY(52) ,c14 BINARY(104) ,c15 VARCHAR(86) ,c16 BIT(6) ,c17 NUMERIC(64,1) ,c18 CHAR(152) , primary key(c11,c3,c17,c18,c7,c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c11) PARTITIONS 10;

select 1 from (t10 as ref_0) left join t9 as ref_2 on ((select 1 from t10 as ref_3) not in (ref_0.c11, 65));
