  2 - output([CASE WHEN ANONYMOUS_VIEW1.c1 = 1 THEN 0 ELSE T_FUN_MIN(ANONYMOUS_VIEW1.c2) END], [CASE WHEN ANONYMOUS_VIEW1.c1 = 2 THEN 0 ELSE T_FUN_MIN(ANONYMOUS_VIEW1.c2) 
      END], [CASE WHEN ANONYMOUS_VIEW1.c1 = 3 THEN 0 ELSE T_FUN_MIN(ANONYMOUS_VIEW1.c2) END], [ANONYMOUS_VIEW1.c1]), filter(nil), rowset=256
