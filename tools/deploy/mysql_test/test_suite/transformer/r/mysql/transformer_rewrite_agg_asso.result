drop table if exists t1, t_null, t2,t3;
create table t1(c1 bigint, c2 int);
create table t_null(c1 bigint);
create table t2(c1 double);
create table t3(c1 decimal(20,1));
insert into t1 values(1, 2),(2, 1),(3, -1),(-1, 4);
insert into t_null values(1),(null),(null),(2),(3);
insert into t2 values(1.0), (1.7976931348623157E+308), (1.7976931348623157E+308);
insert into t3 values(1),(1.2),(-2.3);
result_format: 4
explain_protocol: 2
######################################## normal cases
