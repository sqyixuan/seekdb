drop table if exists t1,t2;
create table t1(c1 int unsigned, c2 int);
create table t2(c1 int unsigned, c2 int);
create index i2 on t2(c2);
insert into t2 values(1,2);
result_format: 4
explain_protocol: 2
set autocommit=0;
EXPLAIN insert into t1 select 1,1 from t2 where c1 = -1 and c1 + 1 = 2;
