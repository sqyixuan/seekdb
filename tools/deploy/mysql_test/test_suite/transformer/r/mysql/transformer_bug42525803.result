drop table if exists t1,t2,t3;
create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);

EXPLAIN SELECT if(not EXISTS (SELECT 1 FROM t1 AS ref_7) , subq_0.sc1 , 10) as a
FROM (SELECT CASE WHEN EXISTS (SELECT 1 FROM t2 AS ref_1 where ref_1.c1 ) THEN 24 ELSE 6 END AS sc1 FROM t3 AS ref_0) AS subq_0
WHERE subq_0.sc1 != (22);
