set autocommit = 1;

drop table if exists t1, t2, t3, t4, t5, t6, t7;
drop table if exists is_c1, is_c3;
create table t1(a int primary key, b int, c int);
create table is_c3(a int , b int, c int);
create table is_c1(a int);
create table t2(a int primary key, b int, c int);
create table t3(c1 int primary key, c2 int);
create table t4(c1 int primary key, c2 int, c3 varchar(32));
create table t5(c1 int primary key, c2 int, c3 varchar(32));
create table t6(c1 int , c2 int , c3 int, c4 int,
 index idx_t6 (c2, c3) local
);
create table t7(c1 int, c2 int, c3 int, c4 int,
 primary key (c1, c2, c3)
);

