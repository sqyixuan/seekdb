insert into is_c3 select /*+NO_REWRITE*/* from t1 where t1.b in (select count(*) from t2 where exists (select * from t2 v where v.a = t1.a));
select/**/ * from is_c3;
a	b	c
8	8	1
rollback;

set autocommit = 1;
drop table t1, t2, t3, t4, t5, t6, t7, is_c1, is_c3;

USE DB_ANY_ALL;
drop database DB_ANY_ALL;
