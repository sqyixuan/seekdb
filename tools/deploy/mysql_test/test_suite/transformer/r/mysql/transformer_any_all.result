result_format: 4
explain_protocol: 2
DROP DATABASE IF EXISTS DB_ANY_ALL;
CREATE DATABASE DB_ANY_ALL;
USE DB_ANY_ALL;

drop table if exists t1, t2, is_t1;
create table t1(c1 int not null, c2 int, key idx_c1(c2));
create table t2(c1 int not null, c2 int, key idx_c2(c1));
create table is_t1(c1 int);

insert/*trace*/ into t1 values(1,2),(2,3),(3,3), (4,3),(4,4),(6,5),(6,5),(10,20);
insert/*trace*/ into t2 values(1,2),(2,3),(3,3), (4,3),(4,4),(6,5),(6,5),(10,20);

set autocommit = 0;



# case 1
****** val > ANY(SELECT col_item ...)  <==> val > ANY(SELECT MIN(col_item) ...);

EXPLAIN select c1 from t1 where c1 >ANY(select c1 from t2);
