SELECT
(
SELECT
t2.col_decimal_20_0_index
FROM
table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null AS t2
WHERE
t2.col_bigint_index > t1.col_bigint_unique_index
AND t2.col_double_unique_index <= 5
ORDER BY
1
LIMIT
1
) AS mm,
(
SELECT
t2.col_bigint_unique_index
FROM
table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null AS t2
WHERE
t2.pk = mm
AND t2.col_double_index > t1.col_bigint_index
AND t1.col_bigint_unique_index > 8
ORDER BY
1 ASC
LIMIT
1
) AS nn,
(
SELECT
t2.col_decimal_20_0
FROM
table10_int_not_null AS t2
WHERE
t2.col_bigint_unique_index = t1.col_bigint_index
AND t2.col_decimal_20_0 <= t1.col_bigint_unique_index
AND t1.col_bigint <= 6
ORDER BY
1 DESC
LIMIT
1
)
OR (
SELECT
t2.col_decimal_20_0_index
FROM
table10_key_pk_parts_10_int_not_null AS t2
WHERE
t2.col_bigint_index = mm
AND t2.col_decimal_20_0 < 0
ORDER BY
1 DESC
LIMIT
1
)
AND (
SELECT
t2.col_double
FROM
table10_hash_pk_parts_10_int_not_null AS t2
WHERE
t2.col_varchar_20_index >= mm
AND t2.col_double >= 7
ORDER BY
1
LIMIT
1
)
AND (
SELECT
t2.col_decimal_20_0_unique_index
FROM
table10_key_pk_parts_10_int_not_null AS t2
WHERE
t2.pk <= nn
AND t1.col_varchar_20_unique_index <= 'l'
    ORDER BY
1 ASC
LIMIT
1
) as kk
FROM
table10_int_not_null AS t1
ORDER BY
1,
2,
3;
mm	nn	kk
