DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c1 int);
INSERT INTO t1 VALUES(100),(200),(300);
result_format: 4
explain_protocol: 2
EXPLAIN SELECT s1, s2 FROM (SELECT c1 AS s1, c1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;
Query Plan
================================================================
|ID|OPERATOR             |NAME           |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |HASH GROUP BY        |               |3       |4           |
|1 |└─EXPANSION          |               |6       |3           |
|2 |  └─SUBPLAN SCAN     |ANONYMOUS_VIEW1|3       |3           |
|3 |    └─TABLE FULL SCAN|t1             |3       |3           |
================================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.s1], [ANONYMOUS_VIEW1.s2]), filter(nil), rowset=16
      group([ANONYMOUS_VIEW1.s1], [GROUPING_ID]), agg_func(nil)
  1 - output([ANONYMOUS_VIEW1.s1], [GROUPING_ID], [ANONYMOUS_VIEW1.s2]), filter(nil), rowset=16
      repeat(2)[(ANONYMOUS_VIEW1.s1), (NULL)]
  2 - output([ANONYMOUS_VIEW1.s1], [ANONYMOUS_VIEW1.s2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.s1], [ANONYMOUS_VIEW1.s2])
  3 - output([t1.c1], [t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
