drop table t1;
drop table t2;
CREATE TABLE T1(C1 INT, C2 INT);
CREATE TABLE T2(C1 INT, C2 INT);
explain
SELECT
(SELECT MIN(C1)
FROM T1
ORDER BY MAX ((SELECT MAX(C1) FROM T2))) AS S1
FROM T1;
