                 RIGHT JOIN bb AS SUBQUERY1_t2 
                         ON ( SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int` ) ) 
        WHERE  SUBQUERY1_t1 . `pk` < 7) AS table1 
         RIGHT OUTER JOIN d AS table2 
                       ON ( table2 . `pk` = table1 . `col_int_key` 
                            AND ( 9, 7 ) IN (SELECT Sum(SUBQUERY2_t1 . 
