drop table if exists t0;
drop procedure if exists InsertData;
CREATE TABLE `t0` (
`c0` decimal(47,0) unsigned zerofill NOT NULL SKIP_INDEX(MIN_MAX, SUM),
`c1` text DEFAULT NULL COMMENT 'asdf',
`c2` datetime DEFAULT NULL COMMENT 'asdf' SKIP_INDEX(MIN_MAX),
PRIMARY KEY (`c0`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by key(c0) subpartition by key(c0) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`,
subpartition `p3`,
subpartition `p4`,
subpartition `p5`,
subpartition `p6`,
subpartition `p7`,
subpartition `p8`,
subpartition `p9`)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`,
partition `p10`,
partition `p11`,
partition `p12`) WITH COLUMN GROUP(all columns, each column);
CREATE PROCEDURE InsertData()
BEGIN
DECLARE i INT DEFAULT 0;
WHILE i < 10 DO
SET @c0 = LPAD(i, 47, '0');
SET @c1 = CONCAT('Random text ', i + 1);
SET @c2 = DATE_ADD('2023-01-01', INTERVAL i MINUTE);
INSERT INTO `t0` (`c0`, `c1`, `c2`) VALUES (@c0, @c1, @c2);
SET i = i + 1;
END WHILE;
END$$
CALL InsertData();
explain SELECT SUM(1) AS AF, * FROM t0 GROUP BY t0.c2 HAVING ( 1 >= 1 OR NOT (1 > 1)) IN (AF, 0);
