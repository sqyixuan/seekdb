      is_index_back=false, is_global_index=false, 
      range_key([p.__pk_increment]), range(MIN ; MAX)always true
  5 - output([VIEW2.u.city], [VIEW2.T_FUN_COUNT(*)], [VIEW1.o.product_id], [VIEW1.T_FUN_SUM(o.amount)]), filter(nil), rowset=16
