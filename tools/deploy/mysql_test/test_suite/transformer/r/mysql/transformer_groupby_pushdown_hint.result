SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "p"@"SEL$1" "u"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;
