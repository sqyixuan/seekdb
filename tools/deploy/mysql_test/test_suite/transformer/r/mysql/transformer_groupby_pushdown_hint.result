      access([VIEW3.p.product_id], [VIEW3.p.category], [VIEW3.T_FUN_COUNT(*)])
  3 - output([p.product_id], [p.category], [T_FUN_COUNT(*)]), filter(nil), rowset=16
      group([p.product_id], [p.category]), agg_func([T_FUN_COUNT(*)])
