# 指定 hint, group by 会下压到 (o, p, u) 构成的视图上
EXPLAIN SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "p"@"SEL$1" "u"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;
Query Plan
==============================================================
|ID|OPERATOR                     |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |HASH GROUP BY                |     |1       |15          |
|1 |└─NESTED-LOOP JOIN CARTESIAN |     |9       |13          |
|2 |  ├─SUBPLAN SCAN             |VIEW1|3       |11          |
|3 |  │ └─HASH GROUP BY          |     |3       |11          |
|4 |  │   └─HASH JOIN            |     |4       |10          |
|5 |  │     ├─TABLE FULL SCAN    |p    |3       |3           |
|6 |  │     └─HASH JOIN          |     |4       |6           |
|7 |  │       ├─TABLE FULL SCAN  |u    |3       |3           |
|8 |  │       └─TABLE FULL SCAN  |o    |4       |3           |
|9 |  └─MATERIAL                 |     |3       |3           |
|10|    └─TABLE FULL SCAN        |p2   |3       |3           |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output([VIEW1.u.city], [VIEW1.p.category], [cast(T_FUN_SUM(VIEW1.T_FUN_SUM(o.amount)), DECIMAL_INT(33, 0))]), filter([T_FUN_MIN(VIEW1.T_FUN_MIN(o.amount 
      + p.price)) > 1]), rowset=16
      group([VIEW1.u.city], [VIEW1.p.category]), agg_func([T_FUN_SUM(VIEW1.T_FUN_SUM(o.amount))], [T_FUN_MIN(VIEW1.T_FUN_MIN(o.amount + p.price))])
  1 - output([VIEW1.u.city], [VIEW1.p.category], [VIEW1.T_FUN_SUM(o.amount)], [VIEW1.T_FUN_MIN(o.amount + p.price)]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  2 - output([VIEW1.u.city], [VIEW1.p.category], [VIEW1.T_FUN_SUM(o.amount)], [VIEW1.T_FUN_MIN(o.amount + p.price)]), filter(nil), rowset=16
      access([VIEW1.u.city], [VIEW1.p.category], [VIEW1.T_FUN_SUM(o.amount)], [VIEW1.T_FUN_MIN(o.amount + p.price)])
  3 - output([u.city], [p.category], [T_FUN_SUM(o.amount)], [T_FUN_MIN(o.amount + p.price)]), filter(nil), rowset=16
      group([u.city], [p.category]), agg_func([T_FUN_SUM(o.amount)], [T_FUN_MIN(o.amount + p.price)])
  4 - output([u.city], [p.category], [o.amount], [p.price]), filter(nil), rowset=16
      equal_conds([o.product_id = p.product_id]), other_conds(nil)
  5 - output([p.product_id], [p.category], [p.price]), filter(nil), rowset=16
      access([p.product_id], [p.category], [p.price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([p.__pk_increment]), range(MIN ; MAX)always true
  6 - output([u.city], [o.amount], [o.product_id]), filter(nil), rowset=16
      equal_conds([o.user_id = u.user_id]), other_conds(nil)
  7 - output([u.user_id], [u.city]), filter(nil), rowset=16
