      ELSE 1 END, DECIMAL_INT(20, 0)) * cast(CASE WHEN VIEW3.T_FUN_COUNT(*) IS NOT NULL THEN VIEW3.T_FUN_COUNT(*) ELSE 1 END, DECIMAL_INT(20, 0))), DECIMAL_INT(33,
       0))]), filter(nil), rowset=16
      group([VIEW2.u.city], [VIEW3.p.category]), agg_func([T_FUN_SUM(VIEW1.T_FUN_SUM(o.amount) * cast(CASE WHEN VIEW2.T_FUN_COUNT(*) IS NOT NULL THEN VIEW2.T_FUN_COUNT(*) 
