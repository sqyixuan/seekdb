  1 - output([VIEW2.u.city], [VIEW3.p.category], [VIEW2.T_FUN_COUNT(*)], [VIEW3.T_FUN_COUNT(*)], [VIEW1.T_FUN_SUM(o.amount)]), filter(nil), rowset=16
      equal_conds([VIEW1.o.product_id = VIEW3.p.product_id]), other_conds(nil)
