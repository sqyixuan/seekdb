EXPLAIN select 
  aid,
  aid_name,
  case
  when cid = '1' then '音乐'
  when cid = '3' then 'MV'
end
  as cid,
  count(distinct deviceid, dev_uuid) as play_cnt
from
  dmp_market_media_play_rank_dbmusic_xiaomi_mm_pm_test_2
where
  ym = 202410
group by
  aid,
  aid_name,
  cid;
