drop table if exists t1, t2, t3;
drop table if exists dmp_market_media_play_rank_dbmusic_xiaomi_mm_pm_test_2;
drop sequence if exists seq1;
create sequence seq1;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
insert /*+query_timeout(30000000)*/ into t1 select seq1.nextval % 11, seq1.currval % 7 , seq1.currval % 13 from table(generator(5000));
insert /*+query_timeout(30000000)*/ into t2 select seq1.nextval % 7, seq1.currval % 13 , seq1.currval % 11 from table(generator(5000));
result_format: 4
explain_protocol: 2
