  6 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter([tt.c6 = 'bbbb'], [lnnvl(cast(tt.c1 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c2 
      = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c3 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c4 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c5 = 1, TINYINT(-1, 0)))]), rowset=16
