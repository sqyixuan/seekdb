create table tt2(a int, b varchar(30), key ia(a), key ib(b(5)));
# 预期可以走 or expansion, b 列会走前缀索引
explain outline select * from tt2 where a = 1 or b = 'aaa';
Query Plan
=====================================================
|ID|OPERATOR          |NAME   |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |UNION ALL         |       |1       |14          |
|1 |├─TABLE RANGE SCAN|tt2(ia)|1       |7           |
|2 |└─TABLE RANGE SCAN|tt2(ib)|0       |7           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
  1 - output([tt2.a], [tt2.b]), filter(nil), rowset=16
      access([tt2.__pk_increment], [tt2.b], [tt2.a]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([tt2.a], [tt2.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([tt2.a = 1])
  2 - output([tt2.a], [tt2.b]), filter([lnnvl(cast(tt2.a = 1, TINYINT(-1, 0)))], [tt2.b = 'aaa']), rowset=16
      access([tt2.__pk_increment], [tt2.b], [tt2.a]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,false], 
      range_key([tt2.__substr5_17], [tt2.__pk_increment]), range(aaa,MIN ; aaa,MAX), 
      range_cond([tt2.__substr5_17 = substr('aaa', 1, 5)])
Outline Data: 
-------------------------------------
  /*+
      BEGIN_OUTLINE_DATA
      INDEX(@"SEL$8556E4CE_1" "test"."tt2"@"SEL$8556E4CE_1" "ia")
      INDEX(@"SEL$8556E4CE_2" "test"."tt2"@"SEL$8556E4CE_2" "ib")
      USE_CONCAT(@"SEL$1" 'tt2.a = ? OR tt2.b = ?')
      OPTIMIZER_FEATURES_ENABLE('')
      END_OUTLINE_DATA
  */
alter system set_tp tp_name = "EN_CBQT_IGNORE_COST", error_code = 0, frequency = 0;
drop table tt, tt2;
