  1 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter(nil), rowset=16
      access([tt.__pk_increment], [tt.c6], [tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([tt.c1], [tt.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([tt.c1 = 1])
  2 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter([lnnvl(cast(tt.c1 = 1, TINYINT(-1, 0)))]), rowset=16
      access([tt.__pk_increment], [tt.c6], [tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([tt.c2], [tt.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([tt.c2 = 1])
  3 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter([lnnvl(cast(tt.c1 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c2 = 1, TINYINT(-1, 
      0)))]), rowset=16
      access([tt.__pk_increment], [tt.c6], [tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,false], 
      range_key([tt.c3], [tt.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([tt.c3 = 1])
  4 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter([lnnvl(cast(tt.c1 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c2 = 1, TINYINT(-1, 
      0)))], [lnnvl(cast(tt.c3 = 1, TINYINT(-1, 0)))]), rowset=16
      access([tt.__pk_increment], [tt.c6], [tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([tt.c4], [tt.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([tt.c4 = 1])
  5 - output([tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5], [tt.c6]), filter([lnnvl(cast(tt.c1 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c2 = 1, TINYINT(-1, 
      0)))], [lnnvl(cast(tt.c3 = 1, TINYINT(-1, 0)))], [lnnvl(cast(tt.c4 = 1, TINYINT(-1, 0)))]), rowset=16
      access([tt.__pk_increment], [tt.c6], [tt.c1], [tt.c2], [tt.c3], [tt.c4], [tt.c5]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,false,false,false], 
