  /*+
      BEGIN_OUTLINE_DATA
      INDEX(@"SEL$8556E4CE_1" "test"."tt"@"SEL$8556E4CE_1" "i1")
      INDEX(@"SEL$8556E4CE_2" "test"."tt"@"SEL$8556E4CE_2" "i2")
      INDEX(@"SEL$8556E4CE_3" "test"."tt"@"SEL$8556E4CE_3" "i3")
