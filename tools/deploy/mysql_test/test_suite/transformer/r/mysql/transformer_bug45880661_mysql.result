DROP TABLE IF EXISTS t1, t2;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int);
insert into t1 values(1,2,3), (1,3,4), (4,5,6), (null,7,8);
insert into t2 values(1);
