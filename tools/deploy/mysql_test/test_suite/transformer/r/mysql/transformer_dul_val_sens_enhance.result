drop table if exists t1, t2, t3, t4, t5, t6;
drop sequence if exists s1;
drop sequence if exists s2;
drop sequence if exists s3;
drop sequence if exists s4;
CREATE TABLE t1(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t2(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t3(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t4(c1 int primary key, c2 int, c3 varchar(32));
create table t5(
c1 int,
c2 int,
c3 int,
primary key(c1,c2)
);
create table t6(
c1 int,
c2 int,
c3 int,
c4 int,
primary key(c1, c2)
);
create index t1_i1 on t1(c2);
create index t3_i1 on t3(c2);
create index t4_i1 on t4(c2);
create unique index t4_i2 on t4(c2,c3);
create sequence s1 cache 10000 noorder;
create sequence s2 cache 10000 noorder;
create sequence s3 cache 10000 noorder;
create sequence s4 cache 10000 noorder;
result_format: 4
explain_protocol: 2
EXPLAIN select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |NESTED-LOOP JOIN     |     |11      |166         |
|1 |├─SUBPLAN SCAN       |VIEW2|10      |5           |
|2 |│ └─HASH DISTINCT    |     |10      |5           |
|3 |│   └─TABLE FULL SCAN|t2   |10      |3           |
|4 |└─TABLE GET          |t1   |1       |16          |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      conds(nil), nl_params_([VIEW2.VIEW1.t2.c2(:0)]), use_batch=true
  1 - output([VIEW2.VIEW1.t2.c2]), filter(nil), rowset=16
      access([VIEW2.VIEW1.t2.c2])
  2 - output([t2.c2]), filter(nil), rowset=16
      distinct([t2.c2])
  3 - output([t2.c2]), filter(nil), rowset=16
      access([t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(MIN ; MAX)always true
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([GROUP_ID], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX), 
      range_cond([t1.c1 = :0])
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  1 |    1 | test |
|  2 |    2 | test |
|  3 |    3 | test |
|  4 |    4 | test |
|  5 |    5 | test |
|  6 |    6 | test |
|  7 |    7 | test |
|  8 |    8 | test |
|  9 |    9 | test |
| 10 |   10 | test |
+----+------+------+

