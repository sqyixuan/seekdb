drop table if exists t1, t2;
result_format: 4
create table t1 as (SELECT 1 as c1, 1 AS c2) INTERSECT (SELECT null AS c1, null AS c2 UNION SELECT null, null UNION select 1.0, 1.0);
select * from t1;
+-----+-----+
| c1  | c2  |
+-----+-----+
| 1.0 | 1.0 |
+-----+-----+
desc t1;
+-------+---------------+------+-----+---------+-------+
| Field | Type          | Null | Key | Default | Extra |
+-------+---------------+------+-----+---------+-------+
| c1    | decimal(21,1) | NO   |     | NULL    |       |
| c2    | decimal(21,1) | NO   |     | NULL    |       |
+-------+---------------+------+-----+---------+-------+

create table t2 as (SELECT 1) INTERSECT (SELECT null UNION SELECT null);
select * from t2;
+---+
| 1 |
+---+
+---+
desc t2;
+-------+------------+------+-----+---------+-------+
| Field | Type       | Null | Key | Default | Extra |
+-------+------------+------+-----+---------+-------+
| 1     | bigint(20) | NO   |     | NULL    |       |
+-------+------------+------+-----+---------+-------+

drop table t1, t2;
