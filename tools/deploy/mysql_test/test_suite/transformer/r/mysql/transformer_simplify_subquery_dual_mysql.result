drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 16;
create table t2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 16;
create index i1 on t1(c1);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, NULL);
insert into t1 values (3, NULL, NULL);
insert into t1 values (4, NULL, NULL);
insert into t1 values (5, 5, 5);
insert into t1 values (5, NULL, NULL);
insert into t1 values (5, 5, NULL);
insert into t1 values (NULL, NULL, NULL);
insert into t2 values (1, 1, 1);
insert into t2 values (2, 2, 2);
insert into t2 values (3, 3, 3);
insert into t2 values (4, 4, 4);
insert into t2 values (5, 5, 5);
explain_protocol: 2
result_format: 4
