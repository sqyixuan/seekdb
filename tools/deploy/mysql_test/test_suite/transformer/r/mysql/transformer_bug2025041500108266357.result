drop table if exists t0, t1;
CREATE TABLE t0(c0 TINYINT(244)  , c1 VARCHAR(500) , c2 DATETIME  COMMENT 'asdf' , c3 VARCHAR(500) , PRIMARY KEY(c0)) USE_BLOOM_FILTER =  true  PARTITION BY RANGE (c0) SUBPARTITION BY HASH(c0)  subpartitions 19(partition p0 VALUES LESS THAN(0), partition p1 VALUES LESS THAN(1000000000), partition p2 VALUES LESS THAN(maxvalue));
CREATE TABLE t1(c0 DECIMAL , c1 FLOAT(18, 2)  UNIQUE NOT NULL , PRIMARY KEY(c1))  PARTITION BY KEY (c1) partitions 5;
