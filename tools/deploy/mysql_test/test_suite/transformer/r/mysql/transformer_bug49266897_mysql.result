drop table if exists t1;
create table t1(a int, b int);
create index i1 on t1(a);
create index i2 on t1(b);
insert into t1 values (1,1);
insert into t1 values (1,2);
insert into t1 values (2,1);
insert into t1 values (3,3);
insert into t1 values (4,4);
insert into t1 values (5,1);
result_format: 4
explain_protocol: 2
EXPLAIN select /*+use_concat*/ * from t1 where a=1 or b=1;
Query Plan
====================================================
|ID|OPERATOR          |NAME  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |UNION ALL         |      |5       |22          |
|1 |├─TABLE RANGE SCAN|t1(i1)|2       |10          |
|2 |└─TABLE RANGE SCAN|t1(i2)|3       |12          |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
  1 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.a], [t1.b]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.a], [t1.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([t1.a = 1])
  2 - output([t1.a], [t1.b]), filter([lnnvl(cast(t1.a = 1, TINYINT(-1, 0)))]), rowset=16
      access([t1.__pk_increment], [t1.a], [t1.b]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.b], [t1.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([t1.b = 1])
select /*+use_concat*/ * from t1 where a=1 or b=1;
+------+------+
| a    | b    |
+------+------+
|    1 |    1 |
|    1 |    2 |
|    2 |    1 |
|    5 |    1 |
+------+------+
