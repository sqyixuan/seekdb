alter system set_tp tp_no = 556, error_code = 23088, frequency = 1;
DROP TABLE IF EXISTS t0, t1, t2;
CREATE TABLE t0(c0 FLOAT(5, 1) ZEROFILL  NULL, c1 FLOAT(6, 4)  , c2 VARCHAR(500) , PRIMARY KEY(c1))  BLOCK_SIZE =  32768  PARTITION BY KEY (c1) SUBPARTITION BY KEY (c1) subpartitions 1 partitions 7;
CREATE TABLE t1(c0 LONGTEXT , c1 DATETIME , c2 VARCHAR(500) ) USE_BLOOM_FILTER =  true  PARTITION BY KEY (c1) partitions 10;
CREATE TABLE t2 PARTITION BY KEY (c1, c2) partitions 12 AS SELECT * FROM t1;
