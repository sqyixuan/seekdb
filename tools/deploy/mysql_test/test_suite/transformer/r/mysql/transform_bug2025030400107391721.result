drop table if exists orders, users, products;
create table users(user_id int, city varchar(20), age int);
create table products(product_id int, category varchar(20), price int);
create table orders(order_id int, user_id int, product_id int, quantity int, amount int);
INSERT INTO users VALUES (1, 'New York', 30);
INSERT INTO users VALUES (2, 'Los Angeles', 25);
INSERT INTO users VALUES (3, 'Chicago', 40);
INSERT INTO products VALUES (1, 'Electronics', 500);
INSERT INTO products VALUES (2, 'Books', 20);
INSERT INTO products VALUES (3, 'Clothing', 100);
INSERT INTO orders VALUES (1, 1, 1, 2, 1000);
INSERT INTO orders VALUES (2, 2, 2, 5, 100);
INSERT INTO orders VALUES (4, 1, 2, 3, 60);
INSERT INTO orders VALUES (5, 2, 1, 1, 500);
alter system flush plan cache;
result_format: 4
explain_protocol: 2
# no_rewrite, do not push count star to p
EXPLAIN SELECT /*+no_rewrite*/
  u.city,
  o.product_id,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
, products p
GROUP BY u.city, o.product_id
HAVING total_sales > 3.5
ORDER BY total_sales;
Query Plan
===============================================================
|ID|OPERATOR                       |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |SORT                           |    |1       |11          |
|1 |└─HASH GROUP BY                |    |1       |11          |
|2 |  └─NESTED-LOOP JOIN CARTESIAN |    |12      |9           |
|3 |    ├─HASH RIGHT OUTER JOIN    |    |4       |6           |
|4 |    │ ├─TABLE FULL SCAN        |u   |3       |3           |
|5 |    │ └─TABLE FULL SCAN        |o   |4       |3           |
|6 |    └─MATERIAL                 |    |3       |3           |
|7 |      └─TABLE FULL SCAN        |p   |3       |3           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([u.city], [o.product_id], [T_FUN_SUM(o.amount)]), filter(nil), rowset=16
      sort_keys([T_FUN_SUM(o.amount), ASC])
  1 - output([T_FUN_SUM(o.amount)], [u.city], [o.product_id]), filter([T_FUN_SUM(o.amount) > cast(3.5, DECIMAL_INT(33, 0))]), rowset=16
      group([u.city], [o.product_id]), agg_func([T_FUN_SUM(o.amount)])
  2 - output([u.city], [o.product_id], [o.amount]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  3 - output([u.city], [o.product_id], [o.amount]), filter(nil), rowset=16
      equal_conds([o.user_id = u.user_id]), other_conds(nil)
  4 - output([u.user_id], [u.city]), filter(nil), rowset=16
      access([u.user_id], [u.city]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([u.__pk_increment]), range(MIN ; MAX)always true
  5 - output([o.user_id], [o.product_id], [o.amount]), filter(nil), rowset=16
      access([o.user_id], [o.product_id], [o.amount]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([o.__pk_increment]), range(MIN ; MAX)always true
  6 - output(nil), filter(nil), rowset=16
  7 - output(nil), filter(nil), rowset=16
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([p.__pk_increment]), range(MIN ; MAX)always true
SELECT /*+no_rewrite*/
  u.city,
  o.product_id,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
, products p
GROUP BY u.city, o.product_id
HAVING total_sales > 3.5
ORDER BY total_sales;
