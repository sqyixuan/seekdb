SELECT/*+PLACE_GROUP_BY*/
  o.user_id,
  SUM(o.amount),
  SUM(o.quantity)
FROM
  orders o
  INNER JOIN products p ON (p.product_id = o.product_id)
WHERE
  o.product_id = 2  AND o.user_id = 2
GROUP BY
