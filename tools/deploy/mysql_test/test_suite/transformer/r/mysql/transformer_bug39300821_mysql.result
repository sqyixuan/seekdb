  1 - output([INTERNAL_FUNCTION(concat(cast(t0.c0, VARCHAR(12)), ''))]), filter(nil), rowset=16
      dop=1
  2 - output([t0.c0]), filter(nil), rowset=16
      force partition granule
  3 - output([t0.c0]), filter([cast(NULL, DOUBLE(-1, -1)) OR cast(concat(cast(t0.c0, VARCHAR(12)), ''), DOUBLE(-1, -1))]), rowset=16
