result_format: 4
explain_protocol: 2
EXPLAIN REPLACE INTO  tt1 SELECT
     seller_code,
     prd_code,
     real_prd_code,
     seller_fee_rate,
     20181026,
     reserve1,
     reserve2,
     reserve3,
     fee_type,
     seller_rate,
     manager_rate,
     asset_rate 
FROM tt2 a 
WHERE STATUS <> '1' AND valid_date = (SELECT max( valid_date ) FROM tt2 b WHERE a.real_prd_code = b.real_prd_code AND a.seller_code = b.seller_code AND a.fee_type = b.fee_type AND b.valid_date <= 20181026);
