drop table if exists employees;
drop table if exists orders;
CREATE TABLE employees (
id INT PRIMARY KEY,
name VARCHAR(50),
department ENUM('HR', 'IT', 'Sales', 'Marketing', 'Finance'),
skills SET('Java', 'Python', 'SQL', 'C++', 'JavaScript'),
salary DECIMAL(10, 2)
);
CREATE TABLE orders (
order_id INT PRIMARY KEY,
customer_id INT,
status ENUM('Pending', 'Shipped', 'Delivered', 'Cancelled'),
order_date DATE,
total_amount DECIMAL(10, 2)
);
INSERT INTO employees VALUES
(1, 'John Doe', 'IT', 'Java,Python', 75000),
(2, 'Jane Smith', 'HR', 'SQL', 65000),
(3, 'Mike Johnson', 'Sales', 'JavaScript', 80000),
(4, 'Emily Brown', 'Marketing', 'Python,SQL', 70000),
(5, 'David Lee', 'IT', 'Java,C++', 78000);
INSERT INTO orders VALUES
(1, 101, 'Shipped', '2023-01-15', 500.00),
(2, 102, 'Delivered', '2023-01-20', 750.50),
(3, 101, 'Pending', '2023-02-01', 300.25),
(4, 103, 'Cancelled', '2023-02-05', 1000.00),
(5, 102, 'Shipped', '2023-02-10', 450.75);
result_format: 4
