result_format: 4
explain_protocol: 0
drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int, c4 int);
create index idx1 on t1(c1);
create index idx2 on t1(c2);
create table t2(c1 int, c2 int, c3 int, c4 int);
create index idx21 on t2(c1);
create index idx22 on t2(c2);
explain_protocol: 2
EXPLAIN SELECT count(a.c3)
FROM t1 a, t1 b, t2 c
where a.c1 = b.c2 AND b.c1 = c.c2
   and a.c2 in (SELECT d.c3
   FROM t2 d
   WHERE d.c2 = 100
   union all
   SELECT e.c3
   FROM t2 e
   WHERE e.c2 = 100);
