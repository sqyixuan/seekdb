EXPLAIN SELECT /*+no_semi_to_inner*/count(a.c3)
FROM t1 a, t1 b, t2 c
where a.c1 = b.c2 AND b.c1 = c.c2
   and a.c2 in (SELECT d.c3
   FROM t2 d
   WHERE d.c2 >100
   union all
   SELECT e.c3
   FROM t2 e
   WHERE e.c1 >100);
