CREATE TABLE `datax_down_reconciliation_xy_zy` (
`id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
`table_name` varchar(128) NOT NULL COMMENT '表名',
`cd_batch` varchar(32) DEFAULT NULL COMMENT '批次号',
`cd_count` int(11) NOT NULL COMMENT '数据量',
`cd_time` timestamp NOT NULL DEFAULT current_timestamp() ON UPDATE current_timestamp() COMMENT '同步时间',
PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=20200907111722 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='下行数据对账表(祥云TO正元)';
