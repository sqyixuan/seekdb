Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `cool_mcc_zfb_cate` (
`mcc_zfb_cate_id` int(10) unsigned NOT NULL AUTO_INCREMENT,
`cate_name` varchar(100) DEFAULT NULL ,
`cate_superior_id` int(10) DEFAULT NULL ,
`mcc_code` varchar(10) DEFAULT NULL ,
`mcc` varchar(10) DEFAULT NULL,
PRIMARY KEY (`mcc_zfb_cate_id`),
KEY `cate_superior_id` (`cate_superior_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=410 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `cool_fenrun_agent` (
`Id` int(11) NOT NULL AUTO_INCREMENT,
`agent_id` varchar(50) DEFAULT NULL ,
`total_money` varchar(255) DEFAULT NULL ,
`agent_fr_money` varchar(255) DEFAULT NULL ,
`pay_pass` varchar(100) DEFAULT NULL ,
`regtime` int(11) DEFAULT NULL ,
`created_at` int(11) DEFAULT NULL ,
PRIMARY KEY (`Id`),
KEY `index_a` (`agent_id`),
KEY `index_p` (`pay_pass`),
KEY `index_r` (`regtime`)
) ENGINE=InnoDB AUTO_INCREMENT=1794 DEFAULT CHARSET=utf8 ;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `cool_admin_menu` (
`id` int(11) NOT NULL AUTO_INCREMENT,
`name` varchar(100) DEFAULT NULL ,
`sort` int(3) DEFAULT NULL ,
`parent_id` int(5) DEFAULT NULL ,
`roles` varchar(255) DEFAULT NULL ,
`icon` varchar(255) DEFAULT NULL ,
`url` varchar(255) DEFAULT NULL ,
`regtime` int(11) DEFAULT NULL ,
PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=116 DEFAULT CHARSET=utf8 ;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE
ALGORITHM = UNDEFINED
VIEW `menu_parent`
  AS
SELECT
`name`, `id`
FROM
`cool_admin_menu`
WHERE
(`parent_id` = 0)
ORDER BY
`sort`;
create table `shuju_default` (
