drop table if exists t1, t2, t3;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int unique key not null,
c2 int,
c3 varchar(10));
CREATE TABLE t3 (c1 int, c2 decimal(4,2));
result_format: 4
explain_protocol: 2
##basic test
