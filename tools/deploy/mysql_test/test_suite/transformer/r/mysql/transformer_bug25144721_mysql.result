DROP TABLE IF EXISTS `c`, `d`, `cc`, `bb`, t1, t2, t3;
CREATE TABLE `c` (
`col_varchar_10_key` varchar(10) DEFAULT NULL,
`col_varchar` varchar(1) DEFAULT NULL,
`col_int` int(11) DEFAULT NULL,
`col_varchar_key` varchar(1) DEFAULT NULL,
`col_varchar_10` varchar(10) DEFAULT NULL,
`col_varchar_20_key` varchar(20) DEFAULT NULL,
`col_int_key` int(11) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
`pk` int(11) NOT NULL,
PRIMARY KEY (`pk`),
KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
) ;
CREATE TABLE `d` (
`col_int` int(11) DEFAULT NULL,
`col_varchar_10` varchar(10) DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_varchar_10_key` varchar(10) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
`col_varchar_key` varchar(1) DEFAULT NULL,
`col_varchar` varchar(1) DEFAULT NULL,
`col_int_key` int(11) DEFAULT NULL,
`col_varchar_20_key` varchar(20) DEFAULT NULL,
PRIMARY KEY (`pk`),
KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL
) ;
CREATE TABLE `cc` (
`col_varchar_10_key` varchar(10) DEFAULT NULL,
`col_varchar_key` varchar(1) DEFAULT NULL,
`col_varchar` varchar(1) DEFAULT NULL,
`col_int` int(11) DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_int_key` int(11) DEFAULT NULL,
`col_varchar_10` varchar(10) DEFAULT NULL,
`col_varchar_20_key` varchar(20) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
PRIMARY KEY (`pk`),
KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL
) ;
CREATE TABLE `bb` (
`col_varchar_key` varchar(1) DEFAULT NULL,
`col_varchar_20_key` varchar(20) DEFAULT NULL,
`col_int_key` int(11) DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_varchar_10` varchar(10) DEFAULT NULL,
`col_varchar_10_key` varchar(10) DEFAULT NULL,
`col_int` int(11) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
`col_varchar` varchar(1) DEFAULT NULL,
PRIMARY KEY (`pk`),
KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL
) ;
create table t1 (pk int primary key, c1 int, c2 int);
create table t2 (pk int primary key, c1 int, c2 int);
create table t3 (pk int primary key, c1 int, c2 int);
result_format: 4
explain_protocol: 2
## 完整case
EXPLAIN SELECT
  (SELECT DISTINCT MAX(SUBQUERY1_t2 . `col_int_key`) AS SUBQUERY1_field1
   FROM (CC AS SUBQUERY1_t1
         LEFT OUTER JOIN D AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_key`))
   WHERE (SUBQUERY1_t1 . `col_int` != 226
          AND SUBQUERY1_t1 . `col_varchar_20` <= SUBQUERY1_t2 . `col_varchar_10_key`) ) AS field1,
       COUNT(table1 . `col_varchar_20_key`) AS field2,

  (SELECT 2
   FROM DUAL) AS field3,
       table2 . `col_varchar` AS field4
FROM (C AS table1
      LEFT OUTER JOIN
        (SELECT SUBQUERY3_t1 . *
         FROM CC AS SUBQUERY3_t1
         WHERE (SUBQUERY3_t1 . `pk` <> SUBQUERY3_t1 . `pk`
                AND SUBQUERY3_t1 . `pk` != SUBQUERY3_t1 . `pk`) ) AS table2 ON (table2 . `pk` = table1 . `col_int_key`))
WHERE (table1 . `pk` <=
         (SELECT MIN(SUBQUERY4_t1 . `pk`) AS SUBQUERY4_field1
          FROM BB AS SUBQUERY4_t1))
  OR (table1 . `pk` = 199
      OR table1 . `col_varchar_key` = table1 . `col_varchar_key`)
GROUP BY field1,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4;
