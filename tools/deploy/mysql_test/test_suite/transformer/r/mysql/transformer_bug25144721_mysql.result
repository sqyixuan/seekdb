## 简化case
EXPLAIN SELECT /*+PLACE_GROUP_BY*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk), t3
WHERE t1.c2 = t3.c1
GROUP BY field4;
