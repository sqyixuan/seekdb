drop table if exists t1, t2, t3;
create table t1 (a1 int, b1 int);
create table t2 (a2 int, b2 int);
create table t3 (a3 int, b3 int);
insert into t1 select uniform(1,5,random(1)), uniform(1,10,random(1)) from table(generator(20));
insert into t1 values (NULL, NULL), (NULL, NULL);
insert into t2 select uniform(1,5,random(2)), uniform(1,10,random(2)) from table(generator(20));
insert into t2 values (NULL, NULL), (NULL, NULL);
insert into t3 select uniform(1,5,random(3)), uniform(1,10,random(3)) from table(generator(20));
