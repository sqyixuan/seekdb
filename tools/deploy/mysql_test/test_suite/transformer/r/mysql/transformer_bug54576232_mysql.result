drop table if exists t1, t2;
set names gb18030;
create table t1(c1 mediumtext);
CREATE TABLE `t2` (
`c0` mediumtext DEFAULT NULL COMMENT 'asdf',
`c1` float unsigned zerofill DEFAULT NULL,
`c2` float(26,0) DEFAULT NULL COMMENT 'asdf',
`c3` bigint(180) unsigned zerofill DEFAULT NULL COMMENT 'asdf'
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 32768 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 DUPLICATE_SCOPE = 'CLUSTER'
partition by hash(c3)
