       [cast(t1.c1, DECIMAL_INT(33, 0))], [cast(cast(cast(t1.c1, DECIMAL_INT(33, 0)), DECIMAL_INT(65, 32)) / cast(1, DECIMAL_INT(20, 0)), DECIMAL(15, 4))], [ESTIMATE_NDV(T_FUN_APPROX_COUNT_DISTINCT_SYNOPSIS(
      t1.c1))]), filter(nil), rowset=256
