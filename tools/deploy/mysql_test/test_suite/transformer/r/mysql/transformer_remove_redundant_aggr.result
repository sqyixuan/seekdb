set session autocommit = 1;
set session optimizer_features_enable="4.3.5.0";
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c1 int primary key, c2 real, c3 varchar(10), c4 int);
INSERT INTO t1(c1, c2, c3, c4)
VALUES
(1, 1.1, 'Text1', 10),
(2, NULL, 'Text2', 20),
(3, 2.2, NULL, 30),
(4, 3.3, 'Text4', NULL),
(5, 4.4, 'Text5', 50),
(6, 5.5, 'Text6', 60),
(7, 9.9, 'Text10', 70),
(8, 10.10, '11', 80),
(9, 1.1, 'Text1', 10),    -- # duplicate
(10, NULL, NULL, NULL),   -- # nulls
(11, 11.11, NULL, NULL),  -- # nulls
(12, NULL, '12_', NULL),  -- # nulls
(13, NULL, NULL, 16),     -- # nulls
(14, 0.0, '', 0),         -- # empty string
(-1, -1.1, 'Negative', -10), -- # negative
(-2, -1.2, 'Negative', -10), -- # negative, dup
(-3, -1.2, 'Negative', NULL) -- # negative, dup, null
;
result_format: 4
explain_protocol: 2
# eliminate all aggrs except for approx_count_distinct for c1 (int, not nullable)
EXPLAIN SELECT c1, min(c1), max(c1), bit_or(c1), bit_and(c1), count(distinct c1), group_concat(distinct c1), sum(distinct c1), avg(distinct c1), approx_count_distinct(c1) FROM t1 GROUP BY c1;
