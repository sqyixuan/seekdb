  1 - output([t1.c1], [t1.c2], [t1.c4]), filter([cast(CASE WHEN cos(t1.c2) IS NOT NULL THEN 1 ELSE 0 END, DECIMAL_INT(2, 1)) < 1.0]), rowset=16
      access([t1.c1], [t1.c2], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
