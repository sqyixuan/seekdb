# aggr with function param can also be eliminated
EXPLAIN SELECT 
  c2, c4,
  min(abs(c2)), 
  count(distinct floor(c2)), 
  avg(distinct ceiling(c2 + 1.0)), 
  sum(distinct abs(c2) + pow(c4, 2)),
  max(abs(c2 + c1)) -- can not be eliminate
FROM t1 GROUP BY c2, c4
HAVING count(distinct cos(c2)) < 1.0;
