      WHEN ceiling(t1.c2 + cast(1.0, DOUBLE(2, 1))) IS NOT NULL THEN 1 ELSE 0 END, DOUBLE(-1, -1))], [abs(t1.c2) + pow(cast(t1.c4, DOUBLE(-1, -1)), cast(2, DOUBLE(-1,
       -1)))], [T_FUN_MAX(abs(t1.c2 + cast(t1.c1, DOUBLE(-1, -1))))]), filter(nil), rowset=16
