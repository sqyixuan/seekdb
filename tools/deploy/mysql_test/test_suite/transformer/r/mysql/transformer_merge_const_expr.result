CREATE TABLE res_view (
  id varchar(200) NOT NULL,
  snap_date date NOT NULL ,
  market_name varchar(200) NOT NULL ,
  pdt varchar(200) NOT NULL ,
  subcategory varchar(200) NOT NULL ,
  snap_month date DEFAULT NULL,
  update_brand varchar(200) DEFAULT NULL ,
  is_brand tinyint(1) DEFAULT NULL ,
  is_asin tinyint(1) DEFAULT NULL ,
  price_by_rate double DEFAULT NULL ,
  end_price_by_rate double DEFAULT NULL ,
  price double DEFAULT NULL ,
  end_price double DEFAULT NULL ,
  coupon_revenue double DEFAULT NULL,
  sales_volume_revision double DEFAULT NULL
)
PARTITION BY RANGE COLUMNS (snap_date)
SUBPARTITION BY KEY(market_name, pdt, subcategory) SUBPARTITIONS 14
(PARTITION  p202101 VALUES LESS THAN('2021/02/01')
, PARTITION p202201 VALUES LESS THAN('2022/02/01')
, PARTITION p202301 VALUES LESS THAN('2023/02/01')
, PARTITION p202401 VALUES LESS THAN('2024/02/01')
, PARTITION p202501 VALUES LESS THAN('2025/02/01')
);

EXPLAIN SELECT
  price_range AS _col_3,
  avg(CAST(rank_price AS DECIMAL(27, 9))) AS _col_9
FROM 
(
  WITH price_range_info AS
       (
         SELECT 0 AS min_price,
                0 + ceil((100 - 0) / 20) * 20 AS max_price,
                20 AS price_step
       ),
       listing_info AS
       (
         SELECT a.snap_month AS snap_date,
                a.update_brand AS brand,
                CASE WHEN a.price_by_rate< b.max_price AND a.price_by_rate>= b.min_price 
                     THEN '[0-100]'
                     ELSE '' END AS price_range,
                CASE WHEN a.price_by_rate< b.max_price AND a.price_by_rate>= b.min_price 
                     THEN 1
                     ELSE 0 END AS min_price
         FROM res_view a
         LEFT JOIN price_range_info b ON 1=1  # outer to inner 会把这个连接改为笛卡尔积
         WHERE 
           a.snap_date <= DATE_ADD(CAST('2024-10-29' AS DATE), INTERVAL -1 DAY)
           AND (
                 CASE WHEN '原价'= "折后价" THEN a.end_price_by_rate 
                      WHEN '原价'= "原价" THEN a.price 
                      ELSE a.end_price END
               ) >= b.min_price
           AND a.end_price_by_rate >=0
           AND a.end_price>=0
           AND a.market_name = 'amazon'
           AND a.subcategory = 'Portable Charger'
           AND a.pdt = 'Battery'
         GROUP BY 1, 2
      )
  SELECT a.snap_date,
         a.price_range,
         a.brand,
         rank() over(ORDER BY min_price ASC) rank_price
  FROM listing_info a
) AS dc_1;
Query Plan
=============================================================================
|ID|OPERATOR                                 |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------------
|0 |SCALAR GROUP BY                          |        |1       |11          |
|1 |└─SUBPLAN SCAN                           |dc_1    |1       |11          |
|2 |  └─WINDOW FUNCTION                      |        |1       |11          |
|3 |    └─PX COORDINATOR MERGE SORT          |        |1       |11          |
|4 |      └─EXCHANGE OUT DISTR               |:EX10001|1       |11          |
|5 |        └─SORT                           |        |1       |11          |
|6 |          └─HASH GROUP BY                |        |1       |11          |
|7 |            └─EXCHANGE IN DISTR          |        |1       |11          |
|8 |              └─EXCHANGE OUT DISTR (HASH)|:EX10000|1       |11          |
|9 |                └─HASH GROUP BY          |        |1       |11          |
|10|                  └─PX PARTITION ITERATOR|        |1       |11          |
|11|                    └─TABLE FULL SCAN    |a       |1       |11          |
=============================================================================
Outputs & filters:
-------------------------------------
  0 - output([dc_1.price_range], [cast(cast(T_FUN_SUM(cast(dc_1.rank_price, DECIMAL(27, 9))), DECIMAL_INT(81, 41)) / cast(T_FUN_COUNT(cast(dc_1.rank_price,
       DECIMAL(27, 9))), DECIMAL_INT(20, 0)), DECIMAL(31, 13))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(cast(dc_1.rank_price, DECIMAL(27, 9)))], [T_FUN_COUNT(cast(dc_1.rank_price, DECIMAL(27, 9)))])
  1 - output([dc_1.price_range], [cast(dc_1.rank_price, DECIMAL(27, 9))]), filter(nil), rowset=16
      access([dc_1.price_range], [dc_1.rank_price])
  2 - output([CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1, -1)) AND a.price_by_rate 
      >= cast(0, DOUBLE(-1, -1)) THEN '[0-100]' ELSE '' END], [T_WIN_FUN_RANK()]), filter(nil), rowset=16
      win_expr(T_WIN_FUN_RANK()), partition_by(nil), order_by([CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4,
       0))) * 20, DOUBLE(-1, -1)) AND a.price_by_rate >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  3 - output([a.price_by_rate], [CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1,
       -1)) AND a.price_by_rate >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END]), filter(nil), rowset=16
      sort_keys([CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1, -1)) AND a.price_by_rate 
      >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END, ASC])
  4 - output([a.price_by_rate], [CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1,
       -1)) AND a.price_by_rate >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END]), filter(nil), rowset=16
      dop=1
  5 - output([a.price_by_rate], [CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1,
       -1)) AND a.price_by_rate >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END]), filter(nil), rowset=16
      sort_keys([CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1, -1)) AND a.price_by_rate 
      >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END, ASC])
  6 - output([a.price_by_rate], [CASE WHEN a.price_by_rate < cast(0 + ceil(cast(100 + 0, DECIMAL_INT(21, 16)) / cast(20, DECIMAL_INT(4, 0))) * 20, DOUBLE(-1,
       -1)) AND a.price_by_rate >= cast(0, DOUBLE(-1, -1)) THEN 1 ELSE 0 END]), filter(nil), rowset=16
      group([a.snap_month], [a.update_brand]), agg_func(nil)
  7 - output([a.price_by_rate], [a.snap_month], [a.update_brand]), filter(nil), rowset=16
  8 - output([a.price_by_rate], [a.snap_month], [a.update_brand]), filter(nil), rowset=16
      (#keys=2, [a.snap_month], [a.update_brand]), dop=1
  9 - output([a.price_by_rate], [a.snap_month], [a.update_brand]), filter(nil), rowset=16
      group([a.snap_month], [a.update_brand]), agg_func(nil)
 10 - output([a.snap_month], [a.update_brand], [a.price_by_rate]), filter(nil), rowset=16
      force partition granule
 11 - output([a.snap_month], [a.update_brand], [a.price_by_rate]), filter([a.end_price_by_rate >= cast(0, DOUBLE(-1, -1))], [a.end_price >= cast(0, DOUBLE(-1,
       -1))], [CASE WHEN '原价' = '折后价' THEN a.end_price_by_rate WHEN '原价' = '原价' THEN a.price ELSE a.end_price END >= cast(0, DOUBLE(-1, -1))],
       [a.snap_date <= date_add(cast('2024-10-29', DATE(0, 0)), cast(-1, VARCHAR(1048576)), 4)], [a.market_name = 'amazon'], [a.subcategory = 'Portable Charger'],
       [a.pdt = 'Battery']), rowset=16
      access([a.snap_date], [a.market_name], [a.pdt], [a.subcategory], [a.end_price_by_rate], [a.price], [a.end_price], [a.snap_month], [a.update_brand],
       [a.price_by_rate]), partitions(p0sp13, p1sp13, p2sp13, p3sp13, p4sp13)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false,false,false,false,false], 
      range_key([a.__pk_increment]), range(MIN ; MAX)always true
SELECT
  price_range AS _col_3,
  avg(CAST(rank_price AS DECIMAL(27, 9))) AS _col_9
FROM 
(
  WITH price_range_info AS
       (
         SELECT 0 AS min_price,
                0 + ceil((100 - 0) / 20) * 20 AS max_price,
                20 AS price_step
       ),
       listing_info AS
       (
         SELECT a.snap_month AS snap_date,
                a.update_brand AS brand,
                CASE WHEN a.price_by_rate< b.max_price AND a.price_by_rate>= b.min_price 
                     THEN '[0-100]'
                     ELSE '' END AS price_range,
                CASE WHEN a.price_by_rate< b.max_price AND a.price_by_rate>= b.min_price 
                     THEN 1
                     ELSE 0 END AS min_price
         FROM res_view a
         LEFT JOIN price_range_info b ON 1=1  # outer to inner 会把这个连接改为笛卡尔积
         WHERE 
           a.snap_date <= DATE_ADD(CAST('2024-10-29' AS DATE), INTERVAL -1 DAY)
           AND (
                 CASE WHEN '原价'= "折后价" THEN a.end_price_by_rate 
                      WHEN '原价'= "原价" THEN a.price 
                      ELSE a.end_price END
               ) >= b.min_price
           AND a.end_price_by_rate >=0
           AND a.end_price>=0
           AND a.market_name = 'amazon'
           AND a.subcategory = 'Portable Charger'
           AND a.pdt = 'Battery'
         GROUP BY 1, 2
      )
  SELECT a.snap_date,
         a.price_range,
         a.brand,
         rank() over(ORDER BY min_price ASC) rank_price
  FROM listing_info a
) AS dc_1;
