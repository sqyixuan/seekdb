# semi join, can not merge view
EXPLAIN BASIC SELECT t1.* FROM t1 LEFT JOIN LATERAL (SELECT t2.* FROM t2 WHERE t2.c1 IN (SELECT t3.c1 FROM t3 WHERE t3.c1 = t1.c1 + t2.c1)) v ON t1.c2 = v.c2;
