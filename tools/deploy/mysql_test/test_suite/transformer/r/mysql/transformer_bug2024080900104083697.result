DROP TABLE IF EXISTS t1, t2, t3;
CREATE TABLE t1(c1 INT, c2 INT);
CREATE TABLE t2(c1 INT, c2 INT);
CREATE TABLE t3(c1 INT, c2 INT);
explain_protocol: 1
result_format: 4
# join
# can merge view
EXPLAIN BASIC SELECT * FROM t1, lateral (SELECT t2.c1 + t1.c1 FROM t2 LEFT JOIN t3 ON t2.c2 = t3.c2);
