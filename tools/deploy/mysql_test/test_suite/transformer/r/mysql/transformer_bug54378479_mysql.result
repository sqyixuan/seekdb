      access([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[true,true], 
      range_key([t1.c1], [t1.c2], [t1.__pk_increment]), range(1,2,MAX ; 2,4,MIN), 
      range_cond([(t1.c1, t1.c2) > (1, 2)], [(t1.c1, t1.c2) < (2, 4)])
explain select * from t1 where (c1,c2) > (1,2) and (c1,c2) < (2,4) and c1=1;
