drop table if exists `project`, `project_member_role`;
CREATE TABLE `project` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '项目 ID',
`tenant_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '租户 id',
`create_user_name` varchar(127) NOT NULL COMMENT '创建者 姓名',
`owner_user_name` varchar(127) NOT NULL COMMENT '责任人 姓名',
`name` varchar(127) NOT NULL COMMENT '项目名称',
`description` longtext DEFAULT NULL COMMENT '项目描述',
`type` tinyint(4) NOT NULL COMMENT '项目类型: 公开、私有',
`region` tinyint(4) NOT NULL COMMENT '项目所在机房',
`review` tinyint(4) NOT NULL COMMENT '项目是否 review',
`review_user_name` varchar(1000) DEFAULT NULL,
`emergency_user_name` varchar(1000) DEFAULT NULL,
`status` tinyint(4) NOT NULL COMMENT '项目状态',
`conf` longtext DEFAULT NULL COMMENT '项目配置（JSON）',
`security` longtext DEFAULT NULL COMMENT '项目数据安全配置项',
`max_parallelism` int(11) NOT NULL DEFAULT '-1' COMMENT '最大并行度限制（-1：无限制）',
`department_name` varchar(127) NOT NULL DEFAULT '',
`create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
`update_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON
UPDATE
CURRENT_TIMESTAMP COMMENT '更新时间',
PRIMARY KEY (`id`)
) ;
CREATE TABLE `project_member_role` (
`id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT 'project_member_role ID，自增主键',
`tenant_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '租户 id',
`project_id` bigint(20) NOT NULL COMMENT '项目 ID',
`member_name` varchar(127) NOT NULL COMMENT '成员名',
`role_id` tinyint(4) NOT NULL COMMENT '角色 ID',
`member_type` tinyint(4) NOT NULL COMMENT '区分用户和部门 0为用户，1为部门',
`department_id` bigint(20) DEFAULT NULL COMMENT '部门id',
PRIMARY KEY (`id`),
KEY `idx_project_member_role_project_id_member_name` (`project_id`, `member_name`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_project_member_role_project_id` (`project_id`) BLOCK_SIZE 16384 LOCAL
);
result_format: 4
explain_protocol: 1
EXPLAIN BASIC SELECT
  count(0)
FROM
  (
    SELECT
      a.*,
      GROUP_CONCAT(b.role_id) AS roleIds
    FROM
      (
        SELECT
          project.id AS id,
          project.name AS name,
          project.owner_user_name AS ownerUserName,
          project.create_time AS createTime,
          project.description AS description,
          project.type AS type,
          project.region AS region,
          project.review AS review,
          project.review_user_name AS reviewUserName,
          project.emergency_user_name AS emergencyUserName,
          project.status AS status,
          project.conf AS conf,
          project.max_parallelism AS maxParallelism,
          project.department_name AS department_name
        FROM
          project
        WHERE
          project.id IN (
            SELECT
              project_id
            FROM
              project_member_role
            WHERE
              member_name = 'zzm'
              AND role_id = 12
              AND member_type = 0
          )
          AND status != 1
        UNION
        SELECT
          project.id AS id,
          project.name AS name,
          project.owner_user_name AS ownerUserName,
          project.create_time AS createTime,
          project.description AS description,
          project.type AS type,
          project.region AS region,
          project.review AS review,
          project.review_user_name AS reviewUserName,
          project.emergency_user_name AS emergencyUserName,
          project.status AS status,
          project.conf AS conf,
          project.max_parallelism AS maxParallelism,
          project.department_name AS department_name
        FROM
          project
        WHERE
          project.id IN (
            SELECT
              project_id
            FROM
              project_member_role
            WHERE
              department_id = 123
              AND role_id = 12
              AND member_type = 0
          )
          AND status != 1
      ) a
      LEFT JOIN (
        SELECT
          *
        FROM
          project_member_role
        WHERE
          member_name = 'zongmei.zzm'
          OR department_id = 123
      ) b ON a.id = b.project_id
    GROUP BY
      a.id
    ORDER BY
      convert(a.name USING gbk)
  ) tmp_count;
