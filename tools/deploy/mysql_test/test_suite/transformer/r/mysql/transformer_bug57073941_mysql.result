set ob_query_timeout=100000000;
drop table if exists t1, t2;
create table t1 (c1 varchar(48));
create table t2 (c1 varchar(48), c2 int);
create index idx1 on t2(c1(12));
create index idx2 on t2((concat('BM_',c1)));
create index idx3 on t2(c2, c1(12));
insert into t2 values ('abcde', 1), ('BM_abcd', 2), ('abcd', 3), (null, null), ('', null);
insert into t2 select randstr(3,random(1)), uniform(1, 10000, random(1)) from table(generator(10000));
insert into t1 values ('abcd'), (null), (''), ('BM_abcd'), ('ab%cd');
insert into t1 select randstr(4,random(2)) from table(generator(10));
call dbms_stats.gather_table_stats(null,'t1');
call dbms_stats.gather_table_stats(null,'t2');
explain_protocol: 2
result_format: 4

EXPLAIN select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;
Query Plan
======================================================
|ID|OPERATOR          |NAME    |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |NESTED-LOOP JOIN  |        |23      |338         |
|1 |├─TABLE FULL SCAN |t1      |15      |3           |
|2 |└─TABLE RANGE SCAN|t2(idx1)|2       |22          |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t2.c1], [t1.c1]), filter(nil), rowset=16
      conds(nil), nl_params_([t1.c1(:0)]), use_batch=true
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c1]), filter([t2.c1 = :0]), rowset=16
      access([GROUP_ID], [t2.__pk_increment], [t2.c1]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__substr12_16], [t2.__pk_increment]), range(MIN ; MAX), 
      range_cond([t2.__substr12_16 = substr(:0, 1, 12)])
select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;
