drop table if exists t1, t2, t3;
create table t1(C1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
insert into t3 select uniform(50,150,random(1)), uniform(50,150,random(1)) from table(generator(10));
insert into t2 select uniform(1,100,random(1)), uniform(1,100,random(1)) from table(generator(1000));
alter system set _rowsets_enabled=FALSE;
explain_protocol: 1
result_format: 4
EXPLAIN BASIC SELECT 
/*+                                                                        
  BEGIN_OUTLINE_DATA     
  LEADING(@"SEL$05DE41AF" ( "VIEW1"@"SEL$1" "test"."t1"@"SEL$1"))      
  tracing(2)                              
  SIMPLIFY_GROUP_BY(@"SEL$2")                            
	REPLACE_CONST(@"SEL$1")                                
	UNNEST(@"SEL$3")                                       
	UNNEST(@"SEL$4")                                       
	WIN_MAGIC(@"SEL$F280F2F4" "VIEW1"@"SEL$1" "B"@"SEL$1") 
	PRED_DEDUCE(@"SEL$A1325A36")                           
	PRED_DEDUCE(@"SEL$F5618A85")       
	NO_PROJECT_PRUNE(@"SEL$ED434F45")                                                        
  xEND_OUTLINE_DATA                                                       
*/                                                                         
 view1.*
FROM t3,
t2 B,
(SELECT count(0) AS aggr, C.c2 FROM t2 C where C.c1 <>all (SELECT D.c1 FROM t1 D ) GROUP BY C.c2) VIEW1
WHERE  B.c1 <>all (SELECT F.c1 FROM t1 F ) and view1.c2 = B.c2 and view1.c2 = 1;
Query Plan
==========================================
|ID|OPERATOR                       |NAME |
------------------------------------------
|0 |NESTED-LOOP JOIN CARTESIAN     |     |
|1 |├─SUBPLAN SCAN                 |VIEW1|
|2 |│ └─MONITORING DUMP            |     |
|3 |│   └─WINDOW FUNCTION          |     |
|4 |│     └─HASH RIGHT ANTI JOIN NA|     |
|5 |│       ├─TABLE FULL SCAN      |D    |
|6 |│       └─TABLE FULL SCAN      |C    |
|7 |└─MATERIAL                     |     |
|8 |  └─TABLE FULL SCAN            |t3   |
==========================================
Outputs & filters:
-------------------------------------
  0 - output([VIEW1.aggr], [VIEW1.c2]), filter(nil)
      conds(nil), nl_params_(nil), use_batch=false
  1 - output([VIEW1.c2], [VIEW1.aggr]), filter(nil)
      access([VIEW1.c2], [VIEW1.aggr])
  2 - output([T_FUN_COUNT(*)], [C.c2], [C.__pk_increment], [C.c1]), filter(nil)
  3 - output([T_FUN_COUNT(*)], [C.c2], [C.__pk_increment], [C.c1]), filter(nil)
      win_expr(T_FUN_COUNT(*)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  4 - output([C.c2], [C.__pk_increment], [C.c1]), filter(nil)
      equal_conds([C.c1 = D.C1]), other_conds(nil)
  5 - output([D.C1]), filter(nil)
      access([D.C1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([D.__pk_increment]), range(MIN ; MAX)always true
  6 - output([C.__pk_increment], [C.c1], [C.c2]), filter([1 = C.c2])
      access([C.__pk_increment], [C.c1], [C.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([C.__pk_increment]), range(MIN ; MAX)always true
  7 - output(nil), filter(nil)
  8 - output(nil), filter(nil)
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t3.__pk_increment]), range(MIN ; MAX)always true
