drop table t1;
drop table t2;
create table t1 (c1 int, c2 int, c3 varchar(10));
select c1, c2 from t1 where c1 > ora_decode(1, 0, 0, 1/0, c1, c2);
c1	c2
insert into t1 values(1,10,'aa'),(2,20,'bb'),(3,30,'cc'),(4,40,'dd');
select c1, c2 from t1 where c1 > ora_decode(1, 0, 0, 1/0, c1, c2);
c1	c2
create table t2 (c1 int, c2 timestamp(0), c3 date);
insert into t2 values(1, timestamp'2010-10-20 11:11:11', date'2017-01-20');
result_format: 4
explain_protocol: 2
