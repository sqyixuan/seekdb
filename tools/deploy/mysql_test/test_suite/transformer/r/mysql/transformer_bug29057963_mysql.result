DROP TABLE IF EXISTS B, BB, t1, t2;
CREATE TABLE B (
col_date_key date,
col_int int,
pk int,
col_varchar_20 varchar(20),
col_datetime datetime,
col_varchar_10 varchar(10),
col_varchar_20_key varchar(20),
col_datetime_key datetime,
col_varchar_10_key varchar(10),
col_int_key int,
col_date date,
/*Indices*/
key idx7(pk, col_date_key ),
primary key (pk) ,
key idx5(pk, col_varchar_20_key ),
key idx9(pk, col_datetime_key ),
key idx3(pk, col_varchar_10_key ),
key idx1(pk, col_int_key )) ;
CREATE TABLE BB (
col_date date,
col_datetime datetime,
col_varchar_20 varchar(20),
col_int int,
col_date_key date,
col_varchar_10 varchar(10),
col_datetime_key datetime,
pk int,
col_int_key int,
col_varchar_20_key varchar(20),
col_varchar_10_key varchar(10),
/*Indices*/
key idx7(pk, col_date_key ),
key idx9(pk, col_datetime_key ),
primary key (pk) ,
key idx1(pk, col_int_key ),
key idx5(pk, col_varchar_20_key ),
key idx3(pk, col_varchar_10_key )) ;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
result_format: 4
explain_protocol: 2
## 完整case
EXPLAIN SELECT DISTINCT OUTR . `col_int` AS X
FROM B AS OUTR
WHERE (OUTR . `col_int`,
       OUTR . `col_int`) IN
    (SELECT INNR . `pk` AS X,
            INNR . `pk` AS Y
     FROM BB AS INNR
     WHERE INNR . `pk` = 1
     ORDER BY INNR . `col_int_key`)
  OR (OUTR . `pk` >= 1
      OR OUTR . `col_datetime` IS NULL)
HAVING X = '2003-06-01 12:06:35'
ORDER BY 1 DESC,
         OUTR . `col_datetime` ,
         OUTR . `pk` DESC
;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |TOP-N SORT         |    |1       |7           |
|1 |└─SUBPLAN FILTER   |    |1       |7           |
|2 |  ├─TABLE FULL SCAN|OUTR|1       |3           |
|3 |  └─TABLE GET      |INNR|1       |5           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([OUTR.col_int]), filter(nil), rowset=16
      sort_keys([OUTR.col_datetime, ASC], [OUTR.pk, DESC]), topn(1)
  1 - output([OUTR.col_datetime], [OUTR.pk], [OUTR.col_int]), filter([(T_OP_OR, (T_OP_EXISTS, subquery(1)), OUTR.pk >= 1, OUTR.col_datetime IS NULL)]), rowset=16
      exec_params_([OUTR.col_int(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  2 - output([OUTR.pk], [OUTR.col_int], [OUTR.col_datetime]), filter([cast(OUTR.col_int, DECIMAL(11, 0)) = cast('2003-06-01 12:06:35', DECIMAL(1, -1))]), rowset=16
      access([OUTR.pk], [OUTR.col_int], [OUTR.col_datetime]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([OUTR.pk]), range(MIN ; MAX)always true
  3 - output([1]), filter(nil), startup_filter([1 = :0]), rowset=16
      access(nil), partitions(p0)
      limit(1), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([INNR.pk]), range[1 ; 1], 
      range_cond([INNR.pk = 1])
