FROM B AS OUTR
WHERE OUTR . `col_int` IN
    (SELECT `pk`
     FROM BB
     WHERE `pk` = 1)
  OR OUTR . `pk` >= 1
HAVING X = '2003-06-01 12:06:35'
ORDER BY OUTR . `col_datetime`
;
