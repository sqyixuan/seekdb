EXPLAIN select c1 
from (
  select c1, c2, c3 from t1 
  union all 
  select c1, c2, c3 from t2
  order by c2)
;
Query Plan
================================================================
|ID|OPERATOR             |NAME           |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |SUBPLAN SCAN         |ANONYMOUS_VIEW1|6       |6           |
|1 |└─SORT               |               |6       |6           |
|2 |  └─UNION ALL        |               |6       |5           |
|3 |    ├─TABLE FULL SCAN|t1             |3       |3           |
|4 |    └─TABLE FULL SCAN|t2             |3       |3           |
================================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.c1]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1])
  1 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
      sort_keys([UNION([2]), ASC])
  2 - output([UNION([2])], [UNION([1])]), filter(nil), rowset=16
  3 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t2.c1], [t2.c2]), filter(nil), rowset=16
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select c1 
from (
  select c1, c2, c3 from t1 
  union all 
  select c1, c2, c3 from t2
  order by c2)
;
