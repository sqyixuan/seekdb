drop table if exists t1,t2;
create table t1 (`qzkh_id` int, `mphone` varchar(600));
create index i1 on t1(mphone);
insert into t1 select uniform(1,10000, random(1)) as c1, concat('test', uniform(1,10000, random(1))) as c2 from table(generator(10000));
select count(*) from t1;
count(*)
10000
create table t2 (`id` int, `remark_name` varchar(300));
explain_protocol: 2
result_format: 4
隐式 cast 出现在连接条件中，能做下推
EXPLAIN select * from t1, t2 where mphone = RIGHT(FROM_BASE64(remark_name), 11);
Query Plan
====================================================
|ID|OPERATOR          |NAME  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |NESTED-LOOP JOIN  |      |2       |25          |
|1 |├─TABLE FULL SCAN |t2    |1       |3           |
|2 |└─TABLE RANGE SCAN|t1(i1)|2       |22          |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.qzkh_id], [t1.mphone], [t2.id], [t2.remark_name]), filter(nil), rowset=16
      conds(nil), nl_params_([t2.remark_name(:0)]), use_batch=true
  1 - output([t2.remark_name], [t2.id]), filter(nil), rowset=16
      access([t2.remark_name], [t2.id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t1.mphone], [t1.qzkh_id]), filter([cast(t1.mphone, VARCHAR(1048576)) = right(FROM_BASE64(cast(:0, VARCHAR(1048576))), 11)]), rowset=16
      access([GROUP_ID], [t1.__pk_increment], [t1.mphone], [t1.qzkh_id]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[true], 
      range_key([t1.mphone], [t1.__pk_increment]), range(MIN ; MAX), 
      range_cond([cast(t1.mphone, VARCHAR(1048576)) = right(FROM_BASE64(cast(:0, VARCHAR(1048576))), 11)])
select * from t1, t2 where mphone = RIGHT(FROM_BASE64(remark_name), 11);
+---------+--------+------+-------------+
| qzkh_id | mphone | id   | remark_name |
+---------+--------+------+-------------+
+---------+--------+------+-------------+

不做子查询提升，能抽隐式 cast range
EXPLAIN select * from t2 where exists (select /*+no_unnest*/ 1 from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));
