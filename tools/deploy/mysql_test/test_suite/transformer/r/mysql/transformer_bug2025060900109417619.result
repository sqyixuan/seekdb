  1 - output([t2.remark_name], [t2.id]), filter(nil), rowset=16
      access([t2.remark_name], [t2.id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  2 - output([1]), filter([cast(t1.mphone, VARCHAR(1048576)) = right(FROM_BASE64(cast(:0, VARCHAR(1048576))), 11)]), rowset=16
      access([t1.mphone]), partitions(p0)
      limit(1), offset(nil), is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.mphone], [t1.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true, 
      range_cond([cast(t1.mphone, VARCHAR(1048576)) = right(FROM_BASE64(cast(:0, VARCHAR(1048576))), 11)])
select * from t2 where exists (select /*+no_unnest*/ 1 from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));
