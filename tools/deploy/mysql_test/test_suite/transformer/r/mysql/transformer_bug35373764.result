drop table t_k_dfhko;
drop table t200;
drop table t3;
create table t_k_dfhko (
c_mn INTEGER NOT NULL,
c_d4i TEXT ,
c_lngdt TEXT NOT NULL,
c_c3v INTEGER ,
c_m TEXT NOT NULL,
primary key(c_mn)
);
CREATE TABLE t200 (
`c1` binary(150) NOT NULL,
`c2` mediumint(34) DEFAULT NULL,
`c3` decimal(11,10) DEFAULT NULL,
`c4` int(42) NOT NULL,
`c5` varbinary(63) DEFAULT NULL,
`c6` int(96) DEFAULT NULL,
`c7` tinyint(107) DEFAULT NULL,
PRIMARY KEY (`c1`, `c4`),
KEY `i_kOKCyfuUr` (`c2`, `c7`, `c3`) 
BLOCK_SIZE 16384 GLOBAL
);
CREATE TABLE t3 (
`c1` binary(96) NOT NULL,
`c2` tinyint(100) DEFAULT NULL,
`c3` decimal(23,6) DEFAULT NULL,
`c4` decimal(6,2) NOT NULL,
`c5` decimal(50,15) DEFAULT NULL,
`c6` char(14) COLLATE utf8mb4_bin DEFAULT NULL,
`c7` binary(104) DEFAULT NULL,
`c8` binary(88) DEFAULT NULL,
`c9` tinyint(18) DEFAULT NULL,
`c10` char(150) COLLATE utf8mb4_bin DEFAULT NULL,
`c11` char(95) COLLATE utf8mb4_bin NOT NULL,
`c12` binary(13) DEFAULT NULL,
`c13` varchar(63) COLLATE utf8mb4_bin DEFAULT NULL,
`c14` decimal(19,5) DEFAULT NULL,
`c15` decimal(11,0) DEFAULT NULL,
`c16` int(117) NOT NULL,
`c17` int(102) DEFAULT NULL,
PRIMARY KEY (`c16`, `c4`, `c1`, `c11`),
UNIQUE KEY `u_JV` (`c17`, `c8`) BLOCK_SIZE 16384 GLOBAL,
KEY `i_k` (`c3`, `c12`) BLOCK_SIZE 16384 GLOBAL
);
result_format: 4
select distinct case when subq_0.c1 = subq_0.c3 then subq_0.c6 else subq_0.c6 end
from
  (select
        (select c_mn from t_k_dfhko order by c_mn limit 1 offset 1) as c1,
        c_c3v as c3,
        c_mn as c6
      from t_k_dfhko) as subq_0
where subq_0.c3 is not NULL
      or (subq_0.c3 < subq_0.c1 and subq_0.c3 = (select subq_0.c6 from t_k_dfhko));
+-------------------------------------------------------------------+
| case when subq_0.c1 = subq_0.c3 then subq_0.c6 else subq_0.c6 end |
+-------------------------------------------------------------------+
+-------------------------------------------------------------------+

## https://github.com/oceanbase/oceanbase/issues/136
select distinct 
  case when subq_0.c1 = cast(nullif(subq_0.c1,
        subq_0.c5) as SIGNED) then subq_0.c6 else subq_0.c6 end
     as c0, 
  subq_0.c3 as c1, 
  case when ((((EXISTS (
                select  
                    ref_7.c_c3v as c0, 
                    ref_7.c_d4i as c1, 
                    subq_0.c2 as c2, 
                    ref_7.c_mn as c3
                  from 
                    t_k_dfhko as ref_7
                  where subq_0.c0 > ( 
                    select  
                          subq_0.c3 as c0
                        from 
                          t_k_dfhko as ref_8
                        where ref_7.c_mn between ref_8.c_mn and ref_7.c_mn
                      union
                      select  
                          ref_9.c_mn as c0
                        from 
                          t_k_dfhko as ref_9
                        where subq_0.c6 = ref_7.c_mn) limit 10)) 
              or ((subq_0.c0 <= subq_0.c5) 
                or (subq_0.c0 < (select c_mn from t_k_dfhko order by c_mn limit 1 offset 2)
                    ))) 
            or (subq_0.c5 not in (
              select  
                  ref_10.c_mn as c0
                from 
                  t_k_dfhko as ref_10
                where 1=1))) 
          and (subq_0.c3 < subq_0.c5) OR subq_0.c3 = subq_0.c0) not in (
      select distinct 
          ref_11.c_mn between ref_11.c_mn and ref_11.c_mn as c0
        from 
          t_k_dfhko as ref_11
        where ref_11.c_mn > ref_11.c_mn AND ref_11.c_d4i not like 'g4%wnl') then subq_0.c4 else subq_0.c4 end
     as c2, 
  subq_0.c6 as c3
from 
  (select  
        ref_0.c_c3v as c0, 
        (select c_mn from t_k_dfhko order by c_mn limit 1 offset 1)
           as c1, 
        ref_0.c_d4i as c2, 
        ref_0.c_c3v as c3, 
        ref_0.c_lngdt as c4, 
        ref_0.c_mn as c5, 
        ref_0.c_mn as c6, 
        ref_0.c_lngdt as c7, 
        ref_0.c_d4i as c8
      from 
        t_k_dfhko as ref_0
      where ref_0.c_c3v = ( 
        select  
            ref_0.c_mn as c0
          from 
            t_k_dfhko as ref_1
          where EXISTS (
            select  
                (select count(c_d4i) from t_k_dfhko)
                   as c0
              from 
                t_k_dfhko as ref_2
              where 0<>0
              order by c0 asc limit 134) limit 51)) as subq_0
where ((subq_0.c5 + cast(coalesce(case when (subq_0.c5 >= subq_0.c5) 
            and (subq_0.c0 >= ( 
              select  
                    subq_0.c5 as c0
                  from 
                    t_k_dfhko as ref_3
                  where 1=1
                union
                select  
                    subq_0.c5 as c0
                  from 
                    t_k_dfhko as ref_4
                  where subq_0.c8 like 'esd4%g4%k')) then subq_0.c1 else subq_0.c1 end
          ,
        subq_0.c5) as SIGNED)) is not NULL) 
  or ((subq_0.c3 < (subq_0.c1 >> subq_0.c3)) 
      and (subq_0.c0 = ( 
        select  
            subq_0.c6 as c0
          from 
            t_k_dfhko as ref_5
          where EXISTS (
            select  
                ref_6.c_lngdt as c0, 
                ref_6.c_mn as c1, 
                subq_0.c3 as c2, 
                (select c_lngdt from t_k_dfhko order by c_lngdt limit 1 offset 4)
                   as c3, 
                ref_6.c_d4i as c4, 
                subq_0.c2 as c5
              from 
                t_k_dfhko as ref_6
              where 0<>0
              order by c0, c1, c2, c3, c4, c5 desc))) AND subq_0.c4 like 'n0%c5');
+----+------+----+----+
| c0 | c1   | c2 | c3 |
+----+------+----+----+
+----+------+----+----+

SELECT Sum(t200_113.c2) 
FROM   (SELECT t200_113.c1, 
               (SELECT t200_113.c2 
                FROM   t200 AS t200_113 
                ORDER  BY 1 
                LIMIT  1) AS c2, 
               t200_113.c3, 
               t200_113.c4, 
               t200_113.c5, 
               t200_113.c6, 
               t200_113.c7 
        FROM   t200 AS t200_113) AS t200_113 
       INNER JOIN t3 AS t3_1502 
               ON t200_113.c1 < 384 
                   OR t200_113.c4 = 884 
                      AND t200_113.c3 = 580 
                   OR t200_113.c1 > 973 
WHERE  t200_113.c1 = 'TLWoTmCMJRNNhERRvwzXZT' 
        OR t200_113.c2 >= t200_113.c7 
GROUP  BY t200_113.c4 
ORDER  BY 1;
+------------------+
| Sum(t200_113.c2) |
+------------------+
+------------------+

SELECT Sum(t200_113.c2 + 1) 
FROM   (SELECT t200_113.c1, 
               (SELECT t200_113.c2 
                FROM   t200 AS t200_113 
                ORDER  BY 1 
                LIMIT  1) AS c2, 
               t200_113.c3, 
               t200_113.c4, 
               t200_113.c5, 
               t200_113.c6, 
               t200_113.c7 
        FROM   t200 AS t200_113) AS t200_113 
       INNER JOIN t3 AS t3_1502 
               ON t200_113.c1 < 384 
                   OR t200_113.c4 = 884 
                      AND t200_113.c3 = 580 
                   OR t200_113.c1 > 973 
WHERE  t200_113.c1 = 'TLWoTmCMJRNNhERRvwzXZT' 
        OR t200_113.c2 >= t200_113.c7 
GROUP  BY t200_113.c4 
ORDER  BY 1;
+----------------------+
| Sum(t200_113.c2 + 1) |
+----------------------+
+----------------------+

SELECT Sum(t200_114.c2) 
FROM   (SELECT t200_113.c1, 
               (SELECT t200_113.c1
                FROM   t200 AS t200_113 
                ORDER  BY 1 
                LIMIT  1) AS c2, 
               t200_113.c7 
        FROM   t200 AS t200_113) AS t200_114
WHERE  t200_114.c1 = 'TLWoTmCMJRNNhERRvwzXZT' 
        OR t200_114.c2 >= t200_114.c7 
GROUP  BY t200_114.c7;
+------------------+
| Sum(t200_114.c2) |
+------------------+
+------------------+

SELECT Sum(t200_114.c2 + 1) 
FROM   (SELECT t200_113.c1, 
               (SELECT t200_113.c1
                FROM   t200 AS t200_113 
                ORDER  BY 1 
                LIMIT  1) AS c2, 
               t200_113.c7 
        FROM   t200 AS t200_113) AS t200_114
WHERE  t200_114.c1 = 'TLWoTmCMJRNNhERRvwzXZT' 
        OR t200_114.c2 >= t200_114.c7 
GROUP  BY t200_114.c7;
+----------------------+
| Sum(t200_114.c2 + 1) |
+----------------------+
+----------------------+

drop table t_k_dfhko;
drop table t200;
drop table t3;
