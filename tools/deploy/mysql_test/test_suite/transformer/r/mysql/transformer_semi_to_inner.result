EXPLAIN SELECT * 
FROM   t5 d 
WHERE  EXISTS(SELECT a.level_no 
              FROM   t6 a, 
                     t6 b, 
                     t5 c 
              WHERE  a.task_id = 105 
                     AND a.task_flow_id = b.task_flow_id 
                     AND a.level_no <= b.level_no 
                     AND b.task_id = c.task_id 
                     AND b.task_seq = c.task_seq 
                     AND c.task_id = d.task_id 
                     AND c.task_seq = d.task_seq) 
LIMIT  1;
