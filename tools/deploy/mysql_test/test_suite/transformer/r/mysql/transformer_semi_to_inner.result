);

CREATE INDEX IDX_PSIFLOWSTOCKOUT_RELAID ON PSI_FLOW_STOCKOUT(RELA_ID);

EXPLAIN SELECT t.flow_id     flow_id, 
       t.region      region, 
       t.supplier_id supplier_id, 
       e.res_type_id res_type_id, 
       e.inv_id      inv_id, 
       e.status      inv_status, 
       t.flow_status flow_status 
FROM   psi_flow_stockbill_entity e, 
       psi_flow_apply t 
WHERE  e.region = 999 
       AND e.out_bill_id IN (SELECT f.stock_bill_id 
                             FROM   psi_flow_stockout f 
                             WHERE  f.rela_id = t.flow_id 
                                    AND f.region = 999) 
       AND t.create_date >= ('2020-11-01 00:00:00') 
       AND t.create_date <= ('2020-11-17 23:59:59') 
       AND t.src_org_id = 'SD.LU.01.01' 
       AND t.apply_type IN ( 'CATA_MOBAPPLY_AGENTSELL', 'MOBTEL_APPLY_CTRM', 
                             'CATA_MOBALLPY_AGENTPRESELL', 
                                                 'CATA_MOBALLPY_SELFSELL', 
                             'CATA_MOBAPPLY_PUBLIC_SELL_FAN', 
                                 'CATA_MOBAPPLYFORRETURN_RTTERM', 
                                                 'CATA_MOBAPPLY_PUBLIC_SELL_A2S' 
                             , 
                                                 'CATA_MOBAPPLY_PUBLIC_SELL', 
                             'CATA_MOBAPPLY_PUBLIC_SELL_NEW', 
                                 'CATA_MOBAPPLY_PUBLIC_SELL_SEC', 
                                                 'CATA_MOBAPPLY_GROUP_SELL_A2S', 
                                 'CATA_MOBAPPLY_GROUP_SELL' 
                                                 , 
                             'CATA_MOBAPPLY_SELFSELL_A2S', 
                             'CATA_MOBAPPLY_ECHANNEL_SELL' );
