FILE_NAME VARCHAR(256),
UNIFIED_FILE_NAME VARCHAR(64),
COLOR VARCHAR(32),
BOX_SEQNO NUMBER(8,0),
STOCK_NUM NUMBER(10,0) DEFAULT 1,
END_INV_ID VARCHAR(32),
ERROR_CODE VARCHAR(32)
);

CREATE INDEX IDX_STOCKENTITY_OUTBATCHID ON PSI_FLOW_STOCKBILL_ENTITY(REGION, OUT_BILL_ID);

CREATE TABLE PSI_FLOW_APPLY
(
REGION NUMBER(5,0) NOT NULL ,
