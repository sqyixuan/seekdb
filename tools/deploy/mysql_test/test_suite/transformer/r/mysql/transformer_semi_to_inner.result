LDSTORE_TYPE VARCHAR(32),
SETTLE_MODE VARCHAR(32),
PROJECT_ID VARCHAR(32),
CHANNEL_TYPE VARCHAR(32),
TRANSPORT_ID VARCHAR(32),
PURPOSE VARCHAR(32),
TRANSPORT_NAME VARCHAR(64),
DES_REGION NUMBER(5,0),
FILE_NAME VARCHAR(256),
UNIFIED_FILE_NAME VARCHAR(64),
LOGISTICS_SUPPLIER VARCHAR(32),
LOGISTICS_TYPE VARCHAR(32),
EMERGENCY_LEVEL NUMBER(8,0),
CREATE_ORG_ID VARCHAR(32),
SRC_OPER VARCHAR(32),
SRC_DELIVERY_TIME DATE,
DELIVERY_OPER VARCHAR(32),
DELIVERY_OPER_PHONE VARCHAR(20),
DELIVERY_VEHICLE_INFO VARCHAR(32),
LOGISTICS_CONFIRM_TIME DATE,
