APPLY_CLASS VARCHAR(32),
CHANNEL_TYPE VARCHAR(32) NOT NULL ,
PROJECT_ID VARCHAR(64),
IF_BASE VARCHAR(32),
PARENT_FLOW_ID VARCHAR(32),
LINK_MAN VARCHAR(64),
CONTACT_PHONE VARCHAR(32),
RECEIVE_DATE DATE,
RECEIVE_LAST_DATE DATE,
CREATE_DATE DATE,
CREATE_OPER VARCHAR(32),
CREATE_ORG_ID VARCHAR(32),
DES_ORG_ID VARCHAR(32),
MEMO VARCHAR(512),
LOCK_STATUS VARCHAR(32) NOT NULL ,
STATUS_DATE DATE NOT NULL ,
DES_REGION NUMBER(5,0),
DES_STORE_ID VARCHAR(32),
SRC_STORE_ID VARCHAR(32),
SRC_ORG_ID VARCHAR(32),
SUM_PRICE VARCHAR(32),
PAY_TYPE VARCHAR(32),
PAY_OID VARCHAR(64),
SUM_APPLY_NUM NUMBER(9,0),
PAY_PRICE VARCHAR(32),
ADDRESS VARCHAR(256),
ORDER_PRIV_ID VARCHAR(32),
ORDER_PRIV_DESC VARCHAR(128),
ORDER_PRIV_DISC NUMBER(10,0),
PAY_STATUS VARCHAR(32),
UNLOCKED_EXPDATE DATE,
OTHER_COUPONS NUMBER(10,0),
ALREADY_PAY_PRICE NUMBER(12,0),
PAYPLAT_TYPE VARCHAR(32),
COUNTY_ID VARCHAR(32) DEFAULT NULL,
SUPPLIER_ID VARCHAR(32),
SETTLE_MODE VARCHAR(32),
CLOSE_FLAG VARCHAR(32),
ADD_STATUS VARCHAR(32) DEFAULT NULL,
COMMENT_TIMES NUMBER(2,0) DEFAULT 0,
OUT_ORDER_ID VARCHAR(32)
);

CREATE INDEX IDX_FLOWAPPLY_CREATEDATE ON PSI_FLOW_APPLY(CREATE_DATE);

CREATE TABLE PSI_FLOW_STOCKOUT
(
REGION NUMBER(5,0) NOT NULL ,
STOCK_BILL_ID VARCHAR(32) NOT NULL ,
RES_KIND_ID VARCHAR(32) NOT NULL ,
RELA_ID VARCHAR(512),
RELA_ID_TYPE VARCHAR(32),
STOCK_BILL_TYPE VARCHAR(32) NOT NULL ,
DETAIL_FLAG VARCHAR(32),
STATUS VARCHAR(32) NOT NULL ,
STATUS_DATE DATE NOT NULL ,
SRC_ORG_ID VARCHAR(32) NOT NULL ,
DES_ORG_ID VARCHAR(32),
SUPPLIER_ID VARCHAR(32),
CREATE_DATE DATE,
END_DATE DATE,
OPER_ID VARCHAR(32),
MEMO VARCHAR(256),
LOCK_STATUS VARCHAR(32),
LINK_MAN VARCHAR(64),
LINK_PHONE VARCHAR(32),
LINK_SEC_MAN VARCHAR(32),
