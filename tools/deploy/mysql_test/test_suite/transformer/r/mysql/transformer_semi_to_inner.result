set autocommit=1;
drop table if exists t1, t2, t3, t4, t5, t6;
drop table if exists PSI_FLOW_STOCKBILL_ENTITY, PSI_FLOW_APPLY, PSI_FLOW_STOCKOUT;
CREATE TABLE PSI_FLOW_STOCKBILL_ENTITY
(
REGION NUMBER(5,0) NOT NULL ,
RES_TYPE_ID VARCHAR(32) NOT NULL ,
INV_ID VARCHAR(32) NOT NULL ,
OUT_BILL_ID VARCHAR(32) NOT NULL ,
OUT_BATCH_ID VARCHAR(32) NOT NULL ,
IN_BILL_ID VARCHAR(32),
IN_BATCH_ID VARCHAR(32),
CREATE_DATE DATE,
STATUS VARCHAR(32),
STATUS_DATE DATE,
REASON VARCHAR(256),
