EXPLAIN select a.da_item_id PayDetailid, a.img_id photold, b.folder photoURL,
GROUP_CONCAT(b.img_gps_lng,",",b.img_gps_lat) Photops, b.deviation StorePhotoDistance,a.is_remake isRemake, a.is_similarity isSimilarity
from cm_cost_sign_payment_item_img a 
left join image_list b on a.img_id = b.img_id
where a.da_id ='a8156c37-d960-4a0a-a176-52758b14a2e5'
group by a.da_item_id_img;
Query Plan
=====================================================================
|ID|OPERATOR                   |NAME          |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |MERGE GROUP BY             |              |1       |19          |
|1 |└─PARTITION SORT           |              |1       |18          |
|2 |  └─MERGE RIGHT OUTER JOIN |              |1       |17          |
|3 |    ├─TABLE FULL SCAN      |b             |1       |9           |
|4 |    └─SORT                 |              |1       |8           |
|5 |      └─TABLE RANGE SCAN   |a(da_id_index)|1       |8           |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([a.da_item_id], [a.img_id], [b.folder], [T_FUN_GROUP_CONCAT(cast(b.img_gps_lng, VARCHAR(65536)), ',', cast(b.img_gps_lat, VARCHAR(65536)))],
       [b.deviation], [a.is_remake], [a.is_similarity]), filter(nil), rowset=16
      group([a.da_item_id_img]), agg_func([T_FUN_GROUP_CONCAT(cast(b.img_gps_lng, VARCHAR(65536)), ',', cast(b.img_gps_lat, VARCHAR(65536)))])
  1 - output([a.da_item_id_img], [a.da_item_id], [a.img_id], [b.folder], [b.deviation], [a.is_remake], [a.is_similarity], [b.img_gps_lng], [b.img_gps_lat]), filter(nil), rowset=16
      sort_keys([HASH(a.da_item_id_img), ASC], [a.da_item_id_img, ASC])
  2 - output([a.da_item_id_img], [a.da_item_id], [a.img_id], [b.folder], [b.deviation], [a.is_remake], [a.is_similarity], [b.img_gps_lng], [b.img_gps_lat]), filter(nil), rowset=16
      equal_conds([a.img_id = b.img_id]), other_conds(nil)
      merge_directions([ASC])
  3 - output([b.img_id], [b.folder], [b.img_gps_lng], [b.img_gps_lat], [b.deviation]), filter(nil), rowset=16
      access([b.img_id], [b.folder], [b.img_gps_lng], [b.img_gps_lat], [b.deviation]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([b.img_id]), range(MIN ; MAX)always true
  4 - output([a.da_item_id_img], [a.da_item_id], [a.img_id], [a.is_remake], [a.is_similarity]), filter(nil), rowset=16
      sort_keys([a.img_id, ASC])
  5 - output([a.da_item_id_img], [a.img_id], [a.da_item_id], [a.is_remake], [a.is_similarity]), filter(nil), rowset=16
      access([a.da_item_id_img], [a.img_id], [a.da_item_id], [a.is_remake], [a.is_similarity]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([a.da_id], [a.da_item_id_img]), range(a8156c37-d960-4a0a-a176-52758b14a2e5,MIN ; a8156c37-d960-4a0a-a176-52758b14a2e5,MAX), 
      range_cond([a.da_id = cast('a8156c37-d960-4a0a-a176-52758b14a2e5', VARCHAR(1048576))])
select a.da_item_id PayDetailid, a.img_id photold, b.folder photoURL,
GROUP_CONCAT(b.img_gps_lng,",",b.img_gps_lat) Photops, b.deviation StorePhotoDistance,a.is_remake isRemake, a.is_similarity isSimilarity
from cm_cost_sign_payment_item_img a 
left join image_list b on a.img_id = b.img_id
where a.da_id ='a8156c37-d960-4a0a-a176-52758b14a2e5'
group by a.da_item_id_img;
+-------------+---------+----------+---------+--------------------+----------+--------------+
