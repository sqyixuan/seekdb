drop table if exists `t1`;
drop table if exists `image_list`;
drop table if exists `cm_cost_sign_payment_item_img`;
DROP TABLE IF EXISTS `table30_bigint`;
create table t1(pk int primary key, c1 int);
insert into t1 values (1,1);
insert into t1 values (2,2);
CREATE TABLE `cm_cost_sign_payment_item_img` (
`da_item_id_img` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '主键',
`da_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '协议主表id',
`da_item_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '协议子表主键',
`img_id` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '图片id',
`type` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '类型',
`visit_date` varchar(15) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '拜访时间',
`create_time` datetime DEFAULT NULL COMMENT '时间',
`is_remake` int(1) DEFAULT NULL COMMENT '是否翻拍：0-否，1-是',
`is_similarity` int(1) DEFAULT NULL COMMENT '是否相似：0-否，1-是',
PRIMARY KEY (`da_item_id_img`),
KEY `da_id_index` (`da_id`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_daitemid_imgid` (`da_item_id`, `img_id`) BLOCK_SIZE 16384 LOCAL,
KEY `index_daid` (`da_id`) BLOCK_SIZE 16384 LOCAL,
KEY `index_imgid` (`img_id`) BLOCK_SIZE 16384 LOCAL
);
CREATE TABLE `image_list` (
`img_id` varchar(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL COMMENT '文件记录标识',
`img_name` varchar(100) DEFAULT NULL COMMENT '文件名',
`img_ext_name` varchar(10) DEFAULT NULL COMMENT '文件扩展名',
`img_size` decimal(10,2) DEFAULT NULL COMMENT '图片大小(KB)',
`resolution` varchar(50) DEFAULT NULL COMMENT '图片分辨率',
`folder` text DEFAULT NULL COMMENT '所属文件夹路径',
`gps` varchar(100) DEFAULT NULL COMMENT '拍摄GPS',
`address` varchar(100) DEFAULT NULL COMMENT '拍摄地址',
`shooting_time` datetime DEFAULT NULL COMMENT '拍摄时间',
`finger_print` text DEFAULT NULL COMMENT '图片指纹',
`upload_time` datetime DEFAULT NULL COMMENT '上传时间',
`img_class` int(11) DEFAULT NULL COMMENT '图片分类',
`is_similarity_check` int(11) DEFAULT NULL COMMENT '是否相似度检查',
`similarity_check_date` datetime DEFAULT NULL COMMENT '相似度检查时间',
`is_remake` int(11) DEFAULT NULL COMMENT '是否疑似翻拍',
`uploader` varchar(50) DEFAULT NULL COMMENT '上传人',
`deviation` int(11) DEFAULT NULL COMMENT '偏差',
`device_orientation` varchar(10) DEFAULT NULL COMMENT '设备方向',
`device_orientation_x` varchar(50) DEFAULT NULL,
`device_orientation_y` varchar(50) DEFAULT NULL,
`device_orientation_z` varchar(50) DEFAULT NULL,
`original_folder` text DEFAULT NULL COMMENT '原始图片',
`img_gps_lat` double(100,10) DEFAULT NULL COMMENT '照片GPS纬度',
`img_gps_lng` double(100,10) DEFAULT NULL COMMENT '照片GPS经度',
`is_similarity` int(1) DEFAULT NULL COMMENT '是否相似：0-否，1-是',
`remake_rate` decimal(18,4) DEFAULT NULL COMMENT '翻拍率',
`water_mark_status` varchar(50) DEFAULT NULL COMMENT '水印是否成功（1：成功，2：失败）',
`water_mark_error` text DEFAULT NULL COMMENT '水印报错信息',
`row` tinyint(1) DEFAULT NULL COMMENT '行',
`column` tinyint(1) DEFAULT NULL COMMENT '列',
`is_same_resolution` int(1) DEFAULT NULL COMMENT '是否和抵达照片相同分辨率  0-否 ，1-是',
`is_suspected_screenshot` int(1) DEFAULT NULL COMMENT '1-疑似截图',
`is_joint` int(1) DEFAULT NULL COMMENT '是否拼接图片 0-否；1-是',
PRIMARY KEY (`img_id`),
KEY `uploaderIndex` (`uploader`) BLOCK_SIZE 16384 LOCAL,
KEY `uploader_index` (`uploader`) BLOCK_SIZE 16384 LOCAL,
KEY `upload_time_index` (`upload_time`) BLOCK_SIZE 16384 LOCAL
);
CREATE TABLE table30_bigint (
col_decimal_30_5_key decimal(30,5),
col_integer_key integer,
col_decimal_20_0_key decimal(20,0),
col_mediumint mediumint,
col_char_20 char(20),
col_tinyint tinyint,
col_tinyint_key tinyint,
col_timestamp_key timestamp NULL DEFAULT NULL,
col_varchar_10_key varchar(10),
col_datetime datetime,
col_char_30 char(30),
col_integer integer,
col_bigint bigint,
col_datetime_key datetime,
col_decimal_20_0 decimal(20,0),
col_char_30_key char(30),
pk bigint,
col_smallint smallint,
col_date date,
col_timestamp timestamp NULL DEFAULT NULL,
col_smallint_key smallint,
col_char_20_key char(20),
col_decimal_30_5 decimal(30,5),
col_date_key date,
col_mediumint_key mediumint,
col_varchar_10 varchar(10),
col_int_key int,
col_bigint_key bigint,
col_int int,
/*Indices*/
key idx15(pk, col_decimal_30_5_key ),
key idx9(pk, col_integer_key ),
key idx13(pk, col_decimal_20_0_key ),
key idx1(pk, col_tinyint_key ),
key idx27(pk, col_timestamp_key ),
key idx21(pk, col_varchar_10_key ),
key idx25(pk, col_datetime_key ),
key idx19(pk, col_char_30_key ),
primary key (pk) ,
key idx3(pk, col_smallint_key ),
key idx17(pk, col_char_20_key ),
key idx23(pk, col_date_key ),
key idx5(pk, col_mediumint_key ),
key idx7(pk, col_int_key ),
key idx11(pk, col_bigint_key ))    ;
