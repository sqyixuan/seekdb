drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1, c2);
create table t2(c3 int);
call dbms_stats.gather_table_stats('test', 't1');
#之前因为or param count > 10不改写,现在因为or expr classify count <= 10会改写
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4;
