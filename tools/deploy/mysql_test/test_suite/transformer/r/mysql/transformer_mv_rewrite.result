set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
create materialized view t1_mav_2 refresh complete enable query rewrite as select count(c2) cnt, avg(c2) avg,  c1 c1 from t1 group by c1;
create materialized view t1_mav_3 refresh complete enable query rewrite as select sum(c1) sc1, sum(c2) sc2, count(c1) cc1 from t1;
create materialized view t1_mav_4 refresh complete enable query rewrite as select sum(c1+c2) sc1, sum(c2) sc2, count(c1+c2) cc1 from t1;
create materialized view t1_mav_5 refresh complete enable query rewrite as select sum(c2) sc2, sum(distinct c2) sdc2, count(c2) cc2, count(distinct c2) cdc2, MAX(c2) mc2, MAX(distinct c2) maxdc2, MIN(distinct c2) mindc2, BIT_AND(c2) bc2, c1 from t1 group by c1;
create materialized view t1_t2_mv3 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c1 t2c1, t2.c2 t2c2 from t1 left join t2 on t1.c1 = t2.c2;
create materialized view t1_t2_mv4 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c1 t2c1, t2.c2 t2c2 from t1 full outer join t2 on t1.c1 = t2.c2 where t1.c1 > 1;
create materialized view multi_t1_mv1 refresh complete enable query rewrite as select a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, a3.c2 a3c2 from t1 a1, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
create materialized view multi_t1_t2_mv1 refresh complete enable query rewrite as select a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1;
create materialized view multi_t1_t2_mv2 refresh complete enable query rewrite as select a2.c1 a2c1, a2.c2 a2c2, b1.c1 b1c1, b1.c2 b1c2, b2.c2 b2c2, a4.c1 a4c1 from t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a2.c1 = b1.c2;
create materialized view t1_t2_rt_mav_1 refresh fast on demand enable on query computation enable query rewrite as
select a.c1 as group_col, count(*) cnt, sum(b.c1), count(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1;
create materialized view t1_t2_rt_mav_2 refresh fast on demand enable on query computation enable query rewrite as
select a.c1 as group_col1, b.c2 as group_col2, c.c1 as group_col3, count(*) cnt, sum(b.c1), count(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1, b.c2, c.c1;

