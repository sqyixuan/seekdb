set query_rewrite_enabled = 'TRUE';
set query_rewrite_integrity = 'ENFORCED';

drop materialized view log on collect_info;
drop table collect_info;
drop materialized view log on collect_item;
drop table collect_item;
drop materialized view collect_mv;

create table collect_info(
  user_id int,
  item_id int,
  user_name varchar(1000),
  primary key(user_id, item_id)
  ) partition by hash(user_id) partitions 1024;

create table collect_item(
  item_id int,
  item_type int,
  price int,
  pic_url varchar(1000),
  primary key(item_id)
  ) partition by hash(item_id) partitions 16;

create materialized view log on collect_info with primary key, rowid, sequence (user_name) including new values;
create materialized view log on collect_item with primary key, rowid, sequence (item_type, price, pic_url) including new values;
create materialized view collect_mv refresh complete enable on query computation enable query rewrite as select collect_info.user_id uid, collect_info.item_id uiid, collect_item.item_id iid, collect_item.item_type itype, collect_item.price price, collect_item.pic_url pic from collect_info, collect_item where collect_info.item_id = collect_item.item_id;
create index idx_collect_mv on collect_mv(uid);

EXPLAIN BASIC select collect_info.user_id uid, collect_item.* from collect_info, collect_item where collect_info.item_id = collect_item.item_id and user_id = 10010;
