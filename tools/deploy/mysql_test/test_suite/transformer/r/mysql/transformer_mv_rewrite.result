create materialized view t2_mv1 refresh complete enable query rewrite as select * from t2 where t2.c1 > 1 order by t2.c2;
create materialized view t2_mv2 refresh complete enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > 1);
create materialized view t2_mv3 refresh complete enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > t2.c1);
create materialized view t2_mv4 refresh complete enable query rewrite as select * from t2 where t2.c1 >= 2;
create materialized view t1_t2_mv1 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;
create materialized view t1_t2_mv2 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 1;
create materialized view t1_t2_rt_mjv refresh complete enable on query computation enable query rewrite as select t1.c1 t1c1, t2.c1 t2c1, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;
create materialized view t3_mv1 refresh complete enable query rewrite as select c1 c1, c2+c3 c2p3, c3+1 c31, 5*c4 c4t5 from t3;
create materialized view t3_mav_1 refresh complete enable query rewrite as select c1, c2, c3, sum(c4) sc4, count(c4) cc4 from t3 group by c1, c2, c3;
create materialized view t3_rt_mav_1 refresh fast on demand enable on query computation enable query rewrite as select count(1) cntc1, count(c3), c1 c1, count(*) from t3 group by c1;
create materialized view t3_rt_mav_2 refresh fast on demand enable on query computation enable query rewrite as select count(c3) cntc1, sum(c3), c1 c1, c2, count(*) from t3 group by c1, c2;
result_format: 4
explain_protocol: 1
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';

