CREATE TABLE bug_fix_col_info(c1 int,c2 int,PRIMARY KEY(c2)) PARTITION by hash(c2) partitions 10;
CREATE TABLE bug_fix_col_item(c1 int PRIMARY KEY,c2 int,c3 VARCHAR(1000),FOREIGN KEY(C1) REFERENCES bug_fix_col_info(C2)) PARTITION by hash(c1) partitions 16;

CREATE TABLE bug_fix_col_info_no_part(c1 int,c2 int,PRIMARY KEY(c2));
CREATE TABLE bug_fix_col_item_no_part(c1 int PRIMARY KEY,c2 int,c3 VARCHAR(1000),FOREIGN KEY(C1) REFERENCES bug_fix_col_info_no_part(C2));

CREATE MATERIALIZED VIEW LOG ON bug_fix_col_info_no_part parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(c1)INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW LOG ON bug_fix_col_item_no_part parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c2,c3) INCLUDING NEW VALUES;

CREATE MATERIALIZED VIEW LOG ON bug_fix_col_info parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(c1)INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW LOG ON bug_fix_col_item parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c2,c3) INCLUDING NEW VALUES;

