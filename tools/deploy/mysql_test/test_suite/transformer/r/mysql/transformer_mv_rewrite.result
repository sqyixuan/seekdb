create materialized view ZC_RTMV3 PARTITION BY RANGE(C2) subpartition by hash(C2)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4
from bug_fix_col_item ZT2 inner join bug_fix_col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 >10;

create materialized view ZC_RTMV4 PARTITION BY RANGE(C2) subpartition by hash(C2)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
refresh complete enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4
from bug_fix_col_item_no_part ZT2 inner join bug_fix_col_info_no_part zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 >10;

create materialized view ZC_RTMV4_no_part
refresh complete enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4
from bug_fix_col_item_no_part ZT2 inner join bug_fix_col_info_no_part zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 >0;

create index mv4_no_part_idx ON ZC_RTMV4_no_part (C2) GLOBAL PARTITION BY hash(C2);

set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'ENFORCED';

