CREATE TABLE t0(c0 BIGINT ZEROFILL , c1 DATETIME , c2 VARCHAR(500) )  PARTITION BY KEY (c2, c0) SUBPARTITION BY RANGE (c0) subpartition template (subpartition sp0 VALUES LESS THAN(0), subpartition sp1 VALUES LESS THAN(1000000000), subpartition sp2 VALUES LESS THAN(maxvalue)) partitions 18;
CREATE MATERIALIZED VIEW LOG on t0 parallel 9 with rowid, sequence(c0, c1, c2) including new values;
CREATE MATERIALIZED VIEW mv_t0 parallel 9 refresh force on demand enable QUERY rewrite AS select c0, c1, c2 from t0;
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
EXPLAIN BASIC SELECT MIN(t0.c0) AS AF0 FROM t0 HAVING AF0 > 0;
