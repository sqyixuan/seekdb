set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';

CREATE TABLE bug_t5(c0 DECIMAL ZEROFILL  UNIQUE COMMENT 'asdf'   NOT NULL, c1 DATETIME , c2 VARCHAR(500) , PRIMARY KEY(c0))  DUPLICATE_SCOPE = 'CLUSTER'  PARTITION BY KEY (c0) SUBPARTITION BY KEY (c0) subpartitions 19 partitions 13;
CREATE TABLE bug_t6 LIKE bug_t5;
CREATE MATERIALIZED VIEW LOG on bug_t5 parallel 9 with rowid, sequence(c1, c2) including new values;
CREATE MATERIALIZED VIEW LOG on bug_t6 parallel 9 with rowid, sequence(c1, c2) including new values;
CREATE MATERIALIZED VIEW mv_t5 parallel 9 refresh force on demand enable QUERY rewrite AS select t0.c0 AS C0, t0.c1 AS C1, t0.c2 AS C2, t1.c0 AS C3, t1.c1 AS C4, t1.c2 AS C5 from bug_t5 t0, bug_t6 t1;
CREATE MATERIALIZED VIEW mv_t6 parallel 9 refresh force on demand enable QUERY rewrite AS select c0, c1, c2 from bug_t6;
CREATE VIEW v_t0 AS select /*+no_mv_rewrite*/ t0.c0 AS C0, t0.c1 AS C1, t0.c2 AS C2, t1.c0 AS C3, t1.c1 AS C4, t1.c2 AS C5 from bug_t5 t0, bug_t6 t1;
CREATE VIEW v_t1 AS select /*+no_mv_rewrite*/ c0, c1, c2 from bug_t6;
