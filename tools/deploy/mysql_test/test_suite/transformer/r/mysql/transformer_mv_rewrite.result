create materialized view t4_t5_mv1 refresh complete enable query rewrite as
select t4.c1 t4c1, t5.c1 t5c1, t5.c2 t5c2, count(1), count(t5.c3) from t4 left join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c1, t5.c2;

