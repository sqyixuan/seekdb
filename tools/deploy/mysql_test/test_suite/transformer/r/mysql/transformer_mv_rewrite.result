drop materialized view log on bug_col_item;
drop table bug_col_item;
drop materialized view log on bug_col_info;
drop table bug_col_info;
drop materialized view ZC_RTMV2;
drop materialized view ZC_RTMV3;

CREATE table bug_col_info(c1 int,c2 int,PRIMARY KEY(c2)) PARTITION by hash(c2) partitions 10;
CREATE TABLE bug_col_item(c1 int PRIMARY KEY,c2 int,c3 VARCHAR(20),FOREIGN KEY(C1) REFERENCES bug_col_info(C2)) PARTITION by hash(c1) partitions 16;

CREATE MATERIALIZED VIEW LOG ON bug_col_info parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(c1)INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW LOG ON bug_col_item parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_RTMV2 REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5
from bug_col_item ZT2 inner join bug_col_info zt1
ON zt1.c2 = zt2.c1;

create materialized view ZC_RTMV3 (PRIMARY KEY(c2))
REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4
from bug_col_item ZT2 inner join bug_col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 >10;

set query_rewrite_enabled = 'TRUE';
set query_rewrite_integrity = 'ENFORCED';

