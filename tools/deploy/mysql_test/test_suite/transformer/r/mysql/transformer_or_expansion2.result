                         ref_3.skey_id           AS c20,
                         ref_3.skey_version      AS c21
                  FROM   test.t_kms_encrypt_key  AS ref_3
                  WHERE  59
                  OR
                         (
                                SELECT gid
                                FROM   test.t_operation_relation_init limit 1 offset 4) limit 103) AS subq_1
INNER JOIN test.cool_crontime                                                                      AS ref_4
ON         ((
                                 ref_4.crontime_id - ref_4.crontime_id)
           OR         ((
                                        SELECT bill_id
                                        FROM   test.cool_bill_20180919 limit 1 offset 6) | ref_4.end_time)))
INNER JOIN test.cool_mch_order_map AS ref_5
ON         (((
                                            ref_4.crontime_id & ref_4.crontime_id)
                      AND        (
                                            ref_4.end_time * ref_4.crontime_id))
           AND        (
                                 ref_4.crontime_id / ref_4.end_time)))
ON         ((
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)
           AND        (
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)))
LEFT JOIN  (test.t1u4htee     AS ref_6
INNER JOIN test.shuju_notnull AS ref_7
ON         (
                      ref_6.c3 > ref_7.c05))
ON         (
                      EXISTS
                      (
                             SELECT ref_5.from_business_trade_id AS c0,
                                    subq_0.c0                    AS c1,
                                    ref_0.mch_code               AS c2,
                                    ref_8.type                   AS c3
                             FROM   test.t_kms_server_api        AS ref_8
                             WHERE  ref_0.door_delete_id | ref_7.c06)))
WHERE      ref_7.c01 - ref_6.c3 limit 10;
+------+----+
| c0   | c1 |
+------+----+
+------+----+

