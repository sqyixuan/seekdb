result_format: 4
explain_protocol: 2
## or expansion log plan check for topK & multi index
drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 int, index idx_c1_c2(c1, c2));
create table t2(c1 int, c2 int, c3 int, index idx_c1(c1), index idx_c2(c2));

