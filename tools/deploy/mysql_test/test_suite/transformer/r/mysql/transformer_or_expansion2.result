EXPLAIN SELECT /*+use_concat*/ 1
FROM t5 AS t5_678 RIGHT OUTER JOIN t29 AS t29_17035
                     ON t5_678.c3 = t29_17035.c4 OR t5_678.c7 = t29_17035.c3
WHERE t5_678.c5 <= (SELECT t5_678.c5 FROM   t5 AS t5_678)
      AND NOT EXISTS (SELECT 
                          Min(t11_925.c12)
                   FROM   (SELECT t11_925.c5,
                                  (SELECT t11_925.c12
                                   FROM   t11 AS t11_925
                                   ORDER  BY 1
                                   LIMIT  1) AS c12,
                                  t11_925.c17
                           FROM   t11 AS t11_925) AS t11_925
                   GROUP  BY t11_925.c5
                   HAVING Sum(t11_925.c17) > 365);
