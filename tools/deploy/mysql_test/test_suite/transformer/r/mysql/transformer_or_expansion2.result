EXPLAIN SELECT     ref_6.c3 AS c0,
           99       AS c1
FROM       (((test.cool_door_delete AS ref_0
RIGHT JOIN
           (
                  SELECT ref_1.c16          AS c0,
                         ref_1.c18          AS c1
                  FROM   test.shuju_notnull AS ref_1
                  WHERE  30 = ref_1.c01 limit 140) AS subq_0
ON         ((
                                 subq_0.c0 IS NOT NULL)
           OR         ((
                                            EXISTS
                                            (
                                                   SELECT ref_0.change_time AS c0,
                                                          ref_0.status      AS c1,
                                                          subq_0.c0         AS c2,
                                                          ref_2.cmdname     AS c3,
                                                          subq_0.c1         AS c4,
                                                          subq_0.c1         AS c5,
                                                          (
                                                                 SELECT title
                                                                 FROM   test.cool_business_delete_record limit 1 offset 3) AS c6,
                                                          ref_0.contact_tel                                                AS c7,
                                                          subq_0.c1                                                        AS c8,
                                                          ref_2.cmdcategoryid                                              AS c9,
                                                          ref_0.contact_tel                                                AS c10,
                                                          100                                                              AS c11,
                                                          subq_0.c0                                                        AS c12,
                                                          subq_0.c1                                                        AS c13
                                                   FROM   test.t_sys_cmd                                                   AS ref_2
                                                   WHERE  ref_2.cmdcategoryid <=
                                                          (
                                                                 SELECT id
                                                                 FROM   test.t1nroc8e limit 1 offset 100) limit 95))
                      OR         (
                                            0))))
LEFT JOIN  ((
           (
                  SELECT ref_3.update_date       AS c0,
                         ref_3.cek_value         AS c1,
                         ref_3.cek_name          AS c2,
                         ref_3.cek_name          AS c3,
                         ref_3.cek_check         AS c4,
                         ref_3.cek_check         AS c5,
                         ref_3.skey_id           AS c6,
                         ref_3.cek_desc          AS c7,
                         ref_3.cek_name          AS c8,
                         ref_3.create_date       AS c9,
                         ref_3.cek_name          AS c10,
                         ref_3.update_date       AS c11,
                         ref_3.skey_name_version AS c12,
                         ref_3.skey_name_version AS c13,
                         ref_3.create_date       AS c14,
                         ref_3.skey_version      AS c15,
                         ref_3.create_date       AS c16,
                         ref_3.update_date       AS c17,
                         ref_3.instance_id       AS c18,
                         ref_3.update_by         AS c19,
                         ref_3.skey_id           AS c20,
                         ref_3.skey_version      AS c21
                  FROM   test.t_kms_encrypt_key  AS ref_3
                  WHERE  59
                  OR
                         (
                                SELECT gid
                                FROM   test.t_operation_relation_init limit 1 offset 4) limit 103) AS subq_1
INNER JOIN test.cool_crontime                                                                      AS ref_4
ON         ((
                                 ref_4.crontime_id - ref_4.crontime_id)
           OR         ((
                                        SELECT bill_id
                                        FROM   test.cool_bill_20180919 limit 1 offset 6) | ref_4.end_time)))
INNER JOIN test.cool_mch_order_map AS ref_5
ON         (((
                                            ref_4.crontime_id & ref_4.crontime_id)
                      AND        (
                                            ref_4.end_time * ref_4.crontime_id))
           AND        (
                                 ref_4.crontime_id / ref_4.end_time)))
ON         ((
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)
           AND        (
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)))
LEFT JOIN  (test.t1u4htee     AS ref_6
INNER JOIN test.shuju_notnull AS ref_7
ON         (
                      ref_6.c3 > ref_7.c05))
ON         (
                      EXISTS
                      (
                             SELECT ref_5.from_business_trade_id AS c0,
                                    subq_0.c0                    AS c1,
                                    ref_0.mch_code               AS c2,
                                    ref_8.type                   AS c3
                             FROM   test.t_kms_server_api        AS ref_8
                             WHERE  ref_0.door_delete_id | ref_7.c06)))
WHERE      ref_7.c01 - ref_6.c3 limit 10;
