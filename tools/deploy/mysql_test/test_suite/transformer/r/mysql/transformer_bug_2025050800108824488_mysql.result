## having的子表达式存在对rollup对引用以及having推到where之后的结果对比
## 反例，rollup([t2.c2 + 1]),filter([t2.c2 + 1 + 1 > 0]),但filter被下压,由于共享表达式可能存在bug，val与c2+1未共享指针，导致find_item失效
EXPLAIN BASIC select /*+opt_param('USE_HASH_ROLLUP', 'disabled') no_simplify_group_by*/* from (select c1, c2+1 val, sum(c3) from t2 group by val, c2+1 with rollup)
    where val + 1 > 4;
Query Plan
=============================
|ID|OPERATOR           |NAME|
-----------------------------
|0 |MERGE GROUP BY     |    |
|1 |└─PARTITION SORT   |    |
|2 |  └─TABLE FULL SCAN|t2  |
=============================
Outputs & filters:
-------------------------------------
  0 - output([t2.c1], [t2.c2 + 1], [T_FUN_SUM(t2.c3)]), filter(nil), rowset=16
      group([t2.c2 + 1]), rollup([t2.c2 + 1]), agg_func([T_FUN_SUM(t2.c3)])
  1 - output([t2.c2 + 1], [t2.c2 + 1], [t2.c1], [t2.c3]), filter(nil), rowset=16
      sort_keys([HASH(t2.c2 + 1), ASC], [t2.c2 + 1, ASC], [t2.c2 + 1, ASC])
  2 - output([t2.c1], [t2.c3], [t2.c2 + 1], [t2.c2 + 1]), filter([t2.c2 + 1 + 1 > 4]), rowset=16
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+opt_param('USE_HASH_ROLLUP', 'disabled') no_simplify_group_by*/* from (select c1, c2+1 val, sum(c3) from t2 group by val, c2+1 with rollup)
    where val + 1 > 4;
