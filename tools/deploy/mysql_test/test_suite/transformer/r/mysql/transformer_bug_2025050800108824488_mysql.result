drop table if exists t1, t2, t3;
create table if not exists t1 (c1 int primary key, c2 int, c3 date);
create table if not exists t2 (c1 int, c2 int, c3 int);
insert into t2 values(1,2,3);
insert into t2 values(2,2,3);
insert into t2 values(3,3,4);
insert into t2 values(4,3,4);
insert into t2 values(5,4,5);
create table if not exists t3(c1 int);
drop FUNCTION if EXISTS func_1;
CREATE FUNCTION func_1(n int)
RETURNS int
BEGIN
insert into t3 values(1);
RETURN (select count(*) from t3);
END /
result_format: 4
explain_protocol: 1
## issue中用例
EXPLAIN BASIC select * from (select /*+ no_merge */ t1.c2, date_format(t1.c3, '%Y-%M-%D') date, count(t1.c1)
    from t1 left join t1 d on t1.c2 = d.c2 group by t1.c2, date_format(t1.c3, '%Y-%M-%D') ) v where v.date = date_format(now(), '%Y-%M-%D');
Query Plan
====================================
|ID|OPERATOR                  |NAME|
------------------------------------
|0 |SUBPLAN SCAN              |v   |
|1 |└─HASH GROUP BY           |    |
|2 |  └─HASH RIGHT OUTER JOIN |    |
|3 |    ├─TABLE FULL SCAN     |d   |
|4 |    └─TABLE FULL SCAN     |t1  |
====================================
Outputs & filters:
-------------------------------------
  0 - output([v.c2], [v.date], [v.count(t1.c1)]), filter(nil), rowset=16
      access([v.date], [v.c2], [v.count(t1.c1)])
  1 - output([t1.c2], [date_format(t1.c3, '%Y-%M-%D')], [T_FUN_COUNT(t1.c1)]), filter(nil), rowset=16
      group([t1.c2]), agg_func([T_FUN_COUNT(t1.c1)])
  2 - output([t1.c2], [date_format(t1.c3, '%Y-%M-%D')], [t1.c1]), filter(nil), rowset=16
      equal_conds([t1.c2 = d.c2]), other_conds(nil)
  3 - output([d.c2]), filter(nil), rowset=16
      access([d.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([d.c1]), range(MIN ; MAX)always true
  4 - output([t1.c1], [t1.c2], [date_format(t1.c3, '%Y-%M-%D')]), filter([date_format(t1.c3, '%Y-%M-%D') = date_format(current_timestamp(), '%Y-%M-%D')]), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1]), range(MIN ; MAX)always true
select * from (select /*+ no_merge */ t1.c2, date_format(t1.c3, '%Y-%M-%D') date, count(t1.c1)
    from t1 left join t1 d on t1.c2 = d.c2 group by t1.c2, date_format(t1.c3, '%Y-%M-%D') ) v where v.date = date_format(now(), '%Y-%M-%D');
+------+------+--------------+
| c2   | date | count(t1.c1) |
+------+------+--------------+
+------+------+--------------+
