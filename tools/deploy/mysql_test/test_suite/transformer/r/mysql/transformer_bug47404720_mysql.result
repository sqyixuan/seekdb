drop table if exists tnbqega, sys_role, cool_admin_menu, bit_pk;
create table if not exists `tnbqega` (
`c1` int(11) not null,
`c2` int(11) not null,
primary key (`c1`, `c2`)
);
CREATE TABLE `sys_role` (
`sys_role_id` int(11) NOT NULL AUTO_INCREMENT,
`name` char(32) DEFAULT NULL,
PRIMARY KEY (`sys_role_id`)
);
CREATE TABLE `cool_admin_menu` (
`id` int(11) PRIMARY KEY
);
create table `bit_pk` (
`c04` bit(64),
`c05` tinyint(255),
`c08` bigint,
primary key(`c04`));
explain_protocol: 1
result_format: 4
EXPLAIN BASIC select subq_0.c1, subq_0.c1 from ( select ( select c2 from test.tnbqega limit 1 ) as c1 from test.sys_role as ref_0 where ( EXISTS ( select ( select 1 from test.cool_admin_menu ) as c3, ref_0.name as c6 from test.bit_pk as ref_1 where ( ref_1.c08 ) or (ref_1.c05 = ref_0.sys_role_id) ) ) ) as subq_0 limit 159;
