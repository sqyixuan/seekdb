drop table if exists table0_bigint, table2_bigint, table10_bigint, table100_bigint;
CREATE TABLE `table0_bigint` (
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`pk` bigint(20) NOT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
PRIMARY KEY (`pk`)
) ;
CREATE TABLE `table2_bigint` (
`pk` bigint(20) NOT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
PRIMARY KEY (`pk`)
) ;
CREATE TABLE `table10_bigint` (
`col_bigint` bigint(20) DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`pk` bigint(20) NOT NULL,
PRIMARY KEY (`pk`)
) ;
CREATE TABLE `table100_bigint` (
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`pk` bigint(20) NOT NULL,
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
PRIMARY KEY (`pk`)
) ;
result_format: 4
explain_protocol: 2
## 完整case
EXPLAIN SELECT coalesce(
      (SELECT COUNT(5842)
       FROM table10_bigint
       WHERE (pk, col_decimal_20_0, pk) NOT IN
           (SELECT col_decimal_20_0, col_bigint, col_decimal_20_0
            FROM table0_bigint
            WHERE (col_bigint, col_bigint) IN
                (SELECT col_bigint, pk
                 FROM table100_bigint
                 WHERE pk IN (-100, 6429, -10, 136, 207)
                 ORDER BY pk ASC , col_timestamp_6 ASC , pk ASC)
            ORDER BY pk ASC , col_decimal_20_0 , pk ASC)
       ORDER BY col_bigint DESC , pk),
      (SELECT SUM(ROUND(ABS(99999)))
       FROM table2_bigint
       WHERE (col_decimal_20_0 = -25866
              OR NOT UPPER(SUBSTR('ez', 1, 20)) NOT LIKE UPPER(SUBSTR('neztewhl', 1, 20)) ESCAPE 'a')
         OR (col_decimal_20_0 != -25866
             OR NOT (UPPER(TRIM(SUBSTR(TRIM(LEADING SUBSTR(SUBSTR('cnezte', 1, 20), 1, 2)
                                            FROM SUBSTR('f', 1, 20)), 1, 20))) NOT LIKE UPPER('_a%') ESCAPE 'a'))
         OR (1=0)
       ORDER BY col_char_20 , pk DESC), -12223);
