alter system set _enable_defensive_check = 2;
drop table if exists t1, t2, t3;
set session sql_mode='';
create table t1 (a bit(3) primary key) partition by hash (a) partitions 3;
create table t2 (a bit(4) primary key) partition by hash (a) partitions 3;
create table t3 (a bit(3) primary key) partition by hash (a) partitions 3;
insert into t2 values(8);
insert into t3 values(6);
set autocommit=0;
result_format: 4
explain_protocol: 2
EXPLAIN insert into t1 select 8;
Query Plan
=============================================================
|ID|OPERATOR          |NAME           |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |DISTRIBUTED INSERT|               |1       |13          |
|1 |└─SUBPLAN SCAN    |ANONYMOUS_VIEW1|1       |1           |
|2 |  └─EXPRESSION    |               |1       |1           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.a)})}]), partitions(p1), 
      column_values([column_conv(BIT,PS:(3,0),NOT NULL,cast(ANONYMOUS_VIEW1.8, BIT(-1, -1)))])
  1 - output([ANONYMOUS_VIEW1.8]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.8])
  2 - output([8]), filter(nil)
      values({8})
insert into t1 select 8;
rollback;

EXPLAIN insert into t1 select * from t2;
