|ID|OPERATOR                     |NAME           |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------------------
|0 |DISTRIBUTED INSERT           |               |1       |20          |
|1 |└─PX COORDINATOR             |               |1       |7           |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000       |1       |7           |
|3 |    └─SUBPLAN SCAN           |ANONYMOUS_VIEW1|1       |7           |
|4 |      └─PX PARTITION ITERATOR|               |1       |7           |
|5 |        └─TABLE FULL SCAN    |t2             |1       |7           |
========================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.a)})}]), partitions(p[0-2]), 
      column_values([column_conv(BIT,PS:(3,0),NOT NULL,ANONYMOUS_VIEW1.a)])
  1 - output([ANONYMOUS_VIEW1.a]), filter(nil), rowset=16
  2 - output([ANONYMOUS_VIEW1.a]), filter(nil), rowset=16
      dop=1
  3 - output([ANONYMOUS_VIEW1.a]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.a])
  4 - output([t2.a]), filter(nil), rowset=16
      force partition granule
  5 - output([t2.a]), filter(nil), rowset=16
      access([t2.a]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t2.a]), range(MIN ; MAX)always true
insert into t1 select * from t2;
rollback;

