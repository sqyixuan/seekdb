# 不应该触发 pred deduce, enum 列的等值条件不能传递到另一个条件上
EXPLAIN select
  /*+USE_HASH_SET(@"SET")*/ min(col_set_unique_index)
from
  t1
where
  col_enum_unique_index > pk
  and col_enum_index = pk
group by
  col_set_unique_index;
