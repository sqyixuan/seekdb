drop table if exists t1;
CREATE TABLE `t1` (
`col_enum` enum('asd','123','#','$') DEFAULT NULL,
`col_enum_index` enum('asd','123','#','$') DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_set_index` set('asd','123','#','$') DEFAULT NULL,
`col_set` set('asd','123','#','$') DEFAULT NULL,
`col_set_unique_index` set('asd','123','#','$') DEFAULT NULL,
`col_enum_unique_index` enum('asd','123','#','$') DEFAULT NULL,
`col_set_key` set('asd','123','#','$') DEFAULT NULL,
`col_enum_key` enum('asd','123','#','$') DEFAULT NULL,
PRIMARY KEY (`pk`),
UNIQUE KEY `idx7` (`pk`, `col_set_unique_index`) BLOCK_SIZE 16384 LOCAL,
UNIQUE KEY `idx3` (`pk`, `col_enum_unique_index`) BLOCK_SIZE 16384 LOCAL,
KEY `idx2` (`pk`, `col_enum_index`) BLOCK_SIZE 16384 LOCAL,
KEY `idx6` (`pk`, `col_set_index`) BLOCK_SIZE 16384 LOCAL,
KEY `idx5` (`pk`, `col_set_key`) BLOCK_SIZE 16384 LOCAL,
KEY `idx1` (`pk`, `col_enum_key`) BLOCK_SIZE 16384 LOCAL
);
