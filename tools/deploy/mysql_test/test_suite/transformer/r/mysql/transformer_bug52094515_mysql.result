drop table if exists t1;
create table t1(pk int primary key, a int, b int);
create index i1 on t1(a);
create index i2 on t1(b);
insert into t1 select n,n,n from (select row_number() over () as n from table(generator(10000)));
result_format: 4
explain_protocol: 2
EXPLAIN select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte where pk = 1 union all select * from cte where pk = 2);
