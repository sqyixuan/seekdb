CREATE SEQUENCE seq CACHE 4000 ORDER;
INSERT INTO T2 SELECT seq.nextval FROM TABLE(GENERATOR(1000));
INSERT INTO T3 SELECT seq.nextval FROM TABLE(GENERATOR(1000));
INSERT INTO T4 SELECT seq.nextval, seq.nextval FROM TABLE(GENERATOR(1000));
DROP SEQUENCE seq;
CREATE SEQUENCE seq CACHE 100 INCREMENT BY 100;
INSERT INTO T1 SELECT seq.nextval FROM TABLE(GENERATOR(100));
