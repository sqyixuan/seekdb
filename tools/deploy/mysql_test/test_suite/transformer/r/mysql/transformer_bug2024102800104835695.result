explain 
select 
/*+
BEGIN_OUTLINE_DATA
USE_CONCAT(@"SEL$2" 't1.c1 = ? OR t2.c1 = ?')
MERGE(@"SET$DE41DCE6" < "SEL$DE41DCE6")
PROJECT_PRUNE(@"SET$00E866D7")
PARALLEL( AUTO )
OPTIMIZER_FEATURES_ENABLE('4.2.5.1')
END_OUTLINE_DATA
*/
count(*) 
from (
select
t1.c1 as t1c1, t2.c1 as t2c1 
from t1, t2 
where t1.c1 = 1 or t2.c1 = 1 
order by t2.c1+t1.c1
);
