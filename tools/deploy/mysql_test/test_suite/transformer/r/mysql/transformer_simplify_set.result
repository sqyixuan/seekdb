drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1 (c1 int, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int);
create table t3 (c1 int, c2 int, c3 int, c4 int);
create table t4 (c1 int, c2 int, c3 int, c4 int);
insert into t1 values (1,1,1,1);
insert into t1 values (1,2,2,2);
insert into t2 values (2,2,2,2);
insert into t2 values (2,2,3,3);
insert into t3 values (3,3,3,3);
insert into t3 values (3,3,3,4);
insert into t4 values (4,4,4,4);
explain_protocol: 2
