EXPLAIN BASIC select 
  EXISTS (
    select 
      subq_0.c as c0
    from 
      test.pindexesdg0n as ref_3 
    where 
      (
        EXISTS (
          select 
            subq_0.c as c1 
          from 
            test.wechat_info as ref_4 
          where 
            ref_3.c1 > ref_3.c1
        )
      ) 
      or (ref_3.c1 < ref_3.c1)
  ) as c0 
from 
