drop table if exists `pindexesdg0n`;
drop table if exists `wechat_info`;
drop table if exists `t2koj1cl`;
drop table if exists `t_mon_load`;
drop table if exists `t1flic85`;
create table if not exists `pindexesdg0n` (
`c1` int(11),
`c2` int(11),
`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (c1)
(
PARTITION `p0`,
PARTITION `p1`,
PARTITION `p2`,
PARTITION `p3`
);
create index `iemgaod` on `pindexesdg0n` (`c2` ASC) ;
CREATE TABLE `wechat_info` (
`wechat_info_id` int(11) NOT NULL AUTO_INCREMENT ,
`wechat_access_token` varchar(32) NOT NULL ,
`wechat_expire_time` varchar(16) NOT NULL ,
`wechat_app_id` varchar(32) NOT NULL ,
PRIMARY KEY (`wechat_info_id`),
UNIQUE KEY `wechat_app_id` (`wechat_app_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8mb4;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `t2koj1cl` (
`a` int(11),
`b` int(11),
`c` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
CREATE TABLE `t_mon_load` (
`loadID` int(11) NOT NULL AUTO_INCREMENT COMMENT '负载ID',
`monitorID` int(11) DEFAULT NULL COMMENT '监控ID',
`load1` double(20,0) DEFAULT NULL COMMENT '1分钟的平均系统负载',
`load5` double(20,0) DEFAULT NULL COMMENT '5分钟的平均系统负载',
`load15` double(20,0) DEFAULT NULL COMMENT '15分钟的平均系统负载',
PRIMARY KEY (`loadID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `t1flic85` (
`pk` int(11) not null,
`v1` varchar(10),
`v2` varchar(10),
primary key (`pk`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `idx_t1isjw4o` on `t1flic85` (`v2` ASC) GLOBAL;
