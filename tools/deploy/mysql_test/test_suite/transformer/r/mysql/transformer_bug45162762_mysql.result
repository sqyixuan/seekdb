drop table if exists t1, t11, t14;
drop table if exists pp, table10_hash_pk_parts_1_bigint, table5_hash_pk_parts_1_bigint, table2_bigint, v, e;
create table t1(c8 int);
create table t11(c1 int);
create table t14(c10 int);
create table pp(col_int_key int);
create table table10_hash_pk_parts_1_bigint(c1 int);
create table table5_hash_pk_parts_1_bigint(c1 int);
create table table2_bigint(c1 int);
create table v(c1 int);
create table e(col_int int);
insert into e values(1);
insert into pp values(1);
insert into pp values(2);
result_format: 4
explain_protocol: 2

EXPLAIN SELECT subq_0.sc1 AS sc0
FROM   (
              SELECT Cast(NULLIF(90, 8) AS DECIMAL) AS sc1
              FROM   pp                             AS ref_0 
              ) AS subq_0
WHERE  EXISTS
       (
                SELECT   71                         AS sc0
                FROM     e                          AS ref_4
                WHERE    subq_0.sc1 IN (IF(
                                        CASE
                                                 WHEN EXISTS
                                                          (
                                                                 SELECT 78                            AS sc0
                                                                 FROM   table5_hash_pk_parts_1_bigint AS ref_5
                                                          ) THEN 8 ELSE 77
                                        END IN ( 20,47,62,50,0) , ref_4.col_int , 27 ) , 90));
