SELECT prc.setldoc_id, 
       prc.setl_sumpric 
FROM   (SELECT setldoc_id, 
               admdvs, 
               setl_sumpric 
        FROM   dw_drug_ord_detl 
        GROUP  BY setldoc_id) prc 
       LEFT JOIN dw_drug_ord_detl setl 
              ON prc.setldoc_id = setl.setldoc_id 
WHERE  prc.admdvs = '410000' 
ORDER  BY setl_sumpric DESC 
LIMIT  10;
+------------+--------------+
| setldoc_id | setl_sumpric |
+------------+--------------+
+------------+--------------+

EXPLAIN SELECT prc.setldoc_id, city_name, optins_name AS nhsa, delventp_name, setl_time_ym
        , prc.paydoc_stas, paydoc_time, paydoc_crte_time
        , Round(setl_sumpric, 2) AS setl_sumpric
        , Round(paydoc_sumpric, 2) AS paid_amt
        , Round(setl_sumpric - paydoc_sumpric, 2) AS non_paid_amt
        , Round(paydoc_sumpric / setl_sumpric * 100, 2) AS paid_amt_prop
FROM (
        SELECT setldoc_id, admdvs, admdvs_name AS city_name, admorg_name AS optins_name, delventp_name
                , IF(paydoc_stas = '0'
                        OR paydoc_stas = '1', 1, paydoc_stas) AS paydoc_stas
                , SUM(setl_sumpric) AS setl_sumpric, SUM(CASE
                        WHEN paydoc_stas = 2 THEN setl_sumpric
                        ELSE 0
                END) AS paydoc_sumpric
        FROM dw_drug_ord_detl
        WHERE Length(setldoc_id) > 0
        GROUP BY setldoc_id, admdvs, admdvs_name, optins_name, delventp_name, paydoc_stas
) prc
        LEFT JOIN (
                SELECT DISTINCT setldoc_id, Date_format(setl_time, '%Y%m') AS setl_time_ym
                        , IF(paydoc_stas = '0'
                                OR paydoc_stas = '1', 1, paydoc_stas) AS paydoc_stas
                        , paydoc_time, paydoc_crte_time
                FROM dw_drug_ord_detl
        ) setl
        ON prc.setldoc_id = setl.setldoc_id
                AND prc.paydoc_stas = setl.paydoc_stas
WHERE prc.admdvs = '410000'
ORDER BY setl_sumpric DESC
LIMIT 10;
