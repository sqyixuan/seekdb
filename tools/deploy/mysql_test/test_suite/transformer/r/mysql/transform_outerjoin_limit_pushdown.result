      sort_keys([VIEW1.prc.setl_sumpric, DESC]), topn(10)
  1 - output([VIEW1.prc.setl_sumpric], [VIEW1.prc.setldoc_id]), filter(nil), rowset=16
      equal_conds([VIEW1.prc.setldoc_id = setl.setldoc_id]), other_conds(nil)
