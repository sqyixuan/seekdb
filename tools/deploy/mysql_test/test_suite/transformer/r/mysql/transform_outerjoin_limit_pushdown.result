CREATE TABLE `dw_drug_ord_detl` (
`ship_id` varchar(50) NOT NULL COMMENT '配送单号',
`ord_code` varchar(50) DEFAULT NULL COMMENT '订单代码',
`purc_plan_code` varchar(50) DEFAULT NULL COMMENT '采购单号',
`setldoc_id` varchar(50) DEFAULT NULL COMMENT '结算单号',
`drug_code` varchar(50) DEFAULT '' COMMENT '药品编码',
`drug_name` varchar(200) DEFAULT '' COMMENT '药品名称',
`genname` varchar(200) DEFAULT '' COMMENT '通用名称',
`dosform_name` varchar(100) DEFAULT '' COMMENT '剂型名称',
`rute_name` varchar(6) DEFAULT '' COMMENT '给药途径名称',
`spec_name` varchar(100) DEFAULT '' COMMENT '规格名称',
`prodentp_name` varchar(200) DEFAULT '' COMMENT '生产企业名称',
`prxy_entp_name` varchar(200) DEFAULT '' COMMENT '代理企业名称',
`sco_pac_entp_name` varchar(200) DEFAULT '' COMMENT '分包装企业名称',
`pac` varchar(20) DEFAULT '' COMMENT '包装（转换比+最小使用单位/最小包装单位）',
`minunt_name` varchar(10) DEFAULT '' COMMENT '最小使用单位名称',
`minpacunt_name` varchar(10) DEFAULT '' COMMENT '最小包装单位名称',
`min_sel_emp_name` varchar(30) DEFAULT '' COMMENT '最小销售单位名称',
`pacmatl_name` varchar(100) DEFAULT '' COMMENT '包装材质名称',
`prod_type_name` varchar(100) DEFAULT '' COMMENT '产品类型名称',
`prod_souc_name` varchar(100) DEFAULT '' COMMENT '产品来源名称',
`city_name` varchar(50) DEFAULT '' COMMENT '城市名称',
`optins_name` varchar(200) DEFAULT NULL COMMENT '经办机构名称',
`medins_name` varchar(200) DEFAULT NULL COMMENT '医疗机构名称',
`medins_code` varchar(50) DEFAULT NULL COMMENT '医疗机构名称',
`delventp_name` varchar(200) DEFAULT NULL COMMENT '配送企业名称',
`splm_inpt` varchar(3) DEFAULT NULL COMMENT '补录标志 1-补录采购 0-正常采购',
`purcpric` decimal(18,4) DEFAULT '0.0000' COMMENT '采购价',
`ord_sumamt` decimal(18,4) DEFAULT '0.0000' COMMENT '订单总金额',
`send_time` datetime DEFAULT NULL COMMENT '发送时间',
`read_time` datetime DEFAULT NULL COMMENT '已读时间',
`purc_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '采购数量',
`shp_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '发货数量',
`shp_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '发货金额',
`shp_time` datetime DEFAULT NULL COMMENT '发货时间',
`undo_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '撤销数量',
`undo_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '撤销金额',
`shpp_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '收货数量',
`shpp_time` datetime DEFAULT NULL COMMENT '收货时间',
`shpp_pric` decimal(18,4) DEFAULT '0.0000' COMMENT '收货金额',
`retn_time` datetime DEFAULT NULL COMMENT '退货时间',
`appy_retn_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '申请退货数量',
`cnfm_retn_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '确认退货数量',
`retn_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '退货金额',
`sbmt_setl_appy_time` datetime DEFAULT NULL COMMENT '提交结算申请时间',
`setl_cnt` decimal(18,4) DEFAULT NULL COMMENT '结算数量',
`setl_pric` decimal(18,4) DEFAULT NULL COMMENT '结算价格',
`setl_sumpric` decimal(18,4) DEFAULT NULL COMMENT '结算金额',
`setl_time` datetime DEFAULT NULL COMMENT '结算时间',
`setl_appy_stats` varchar(3) DEFAULT NULL COMMENT '结算申请状态：1 配送企业提交结算申请金额,2 医院财务待审核金额,3 医院财务审核金额,4 医院财务审核不通过金额, 5 医院自付结算金额,6 计算中心待复核金额,7 结算中心复核金额,8 结算中心复核不通过金额',
`paydoc_sumpric` decimal(18,4) DEFAULT NULL COMMENT '支付单总价',
`paydoc_stas` varchar(3) DEFAULT NULL COMMENT '支付单状态：0未生成支付单，1已生成支付单，2已支付',
`paydoc_time` datetime DEFAULT NULL COMMENT '支付时间',
`outsto_flag` varchar(3) DEFAULT NULL COMMENT '缺货标志 1-缺货 0不缺货',
`cncl_type` varchar(3) DEFAULT NULL COMMENT '作废类型 1:医疗机构主动作废 2:配送企业超7日未发送 3:补录单作废',
`setl_way` varchar(3) DEFAULT NULL COMMENT '结算方式 1-医疗机构自付，2-医疗机构委托银行账户代扣，3-医保基金统一代付',
`paydoc_crte_time` datetime DEFAULT NULL COMMENT '支付单生成时间',
`convrat` int(11) DEFAULT '0' COMMENT '转换比(包装)',
`essdrug_flag` varchar(3) DEFAULT '' COMMENT '基药标志',
`hi_nego_drug_flag` varchar(3) DEFAULT '' COMMENT '医保谈判药品标志',
`pubonln_prc` decimal(18,4) DEFAULT '0.0000' COMMENT '挂网价格',
`hi_pay_std` varchar(10) DEFAULT '' COMMENT '医保支付标准',
`high_sel_lmtpric` decimal(18,4) DEFAULT '0.0000' COMMENT '最高销售限价',
`admdvs` varchar(6) DEFAULT '' COMMENT '医保区划代码',
`admdvs_name` varchar(100) DEFAULT '' COMMENT '医保区划名称',
`admorg_code` varchar(50) DEFAULT '' COMMENT '管理单位代码',
`admorg_name` varchar(200) DEFAULT '' COMMENT '管理单位名称',
`item_codg` varchar(50) DEFAULT '' COMMENT '项目编码',
`itemname` varchar(200) DEFAULT '' COMMENT '项目名称',
`ot_upad_stas` varchar(3) DEFAULT NULL COMMENT '超时未付款状态：0否，1超时未付款，2超时已付款',
`all_setl_sumamt` decimal(18,4) DEFAULT NULL COMMENT '全部结算总价',
PRIMARY KEY (`ship_id`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '药品订单统计';
create table s1(c2 int);
create table s2(c2 int, c9 int, c12 int, c13 int, c16 int);
CREATE TABLE t2 (
c1 decimal(8,0) DEFAULT NULL,
c2 varchar(14) COLLATE utf8mb4_bin DEFAULT NULL,
c3 int(18) DEFAULT NULL
);
CREATE TABLE t4 (
c1 decimal(24,23) DEFAULT NULL,
c2 decimal(63,21) DEFAULT NULL,
c3 binary(101) DEFAULT NULL,
c4 bigint(88) DEFAULT NULL,
c5 mediumint(7) DEFAULT NULL,
c6 int(108) DEFAULT NULL,
c7 bigint(47) DEFAULT NULL,
c8 smallint(116) DEFAULT NULL,
c9 char(50) COLLATE utf8mb4_bin DEFAULT NULL,
c10 tinyint(96) DEFAULT NULL,
c11 int(77) DEFAULT NULL,
c12 tinyint(114) NOT NULL,
c13 tinyint(38) DEFAULT NULL,
c14 binary(132) NOT NULL,
c15 decimal(6,3) DEFAULT NULL,
c16 binary(34) DEFAULT NULL,
PRIMARY KEY (c12, c14)
);
CREATE TABLE t7 (
c1 char(87) COLLATE utf8mb4_bin DEFAULT NULL,
c2 int(41) NOT NULL,
c3 char(76) COLLATE utf8mb4_bin DEFAULT NULL,
c4 decimal(30,20) NOT NULL,
c5 smallint(7) DEFAULT NULL,
c6 decimal(60,10) NOT NULL,
c7 int(51) DEFAULT NULL,
c8 binary(23) DEFAULT NULL,
c9 varchar(76) COLLATE utf8mb4_bin DEFAULT NULL,
c10 int(58) NOT NULL,
c11 binary(102) NOT NULL,
c12 char(42) COLLATE utf8mb4_bin NOT NULL,
c13 binary(122) DEFAULT NULL,
c14 tinyint(120) NOT NULL,
