EXPLAIN SELECT t7_4.c10 
FROM   t7 AS t7_4 
WHERE  EXISTS (SELECT t4_42.c2 
               FROM   (SELECT t4_42.c2, 
                              (SELECT t4_42.c9 
                               FROM   t4 AS t4_42 
                               ORDER  BY 1 
                               LIMIT  1) AS c9, 
                              t4_42.c13, 
                              t4_42.c16 
                       FROM   t4 AS t4_42) AS t4_42 
                      LEFT OUTER JOIN t2 
                                   ON t4_42.c9 = t2.c2 
                                      AND t4_42.c13 = t2.c2 
               WHERE  t4_42.c2 < 367 
                      AND t4_42.c9 < t4_42.c16) 
        OR t7_4.c10 < 1;
