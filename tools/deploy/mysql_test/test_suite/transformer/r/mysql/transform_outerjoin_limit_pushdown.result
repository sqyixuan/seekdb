from (
	select t4_42.c2,
	(select t4_42.c9 from s2 as t4_42 order by 1 limit 1) as c9,
	t4_42.c16 from s2 as t4_42
) t4_42
left outer join s1 on 1 = 1
where t4_42.c2 < 367 and t4_42.c9 < t4_42.c16 limit 1;
