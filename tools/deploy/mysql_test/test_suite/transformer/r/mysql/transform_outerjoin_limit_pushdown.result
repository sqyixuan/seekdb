PRIMARY KEY (c10, c14, c11, c2, c4, c12, c6, c15)
);
CREATE TABLE t15 (
c1 varbinary(47) DEFAULT NULL,
c2 varbinary(45) DEFAULT NULL,
c3 int(14) NOT NULL,
c4 tinyint(87) NOT NULL,
c5 bigint(117) DEFAULT NULL,
c6 varchar(28) COLLATE utf8mb4_bin NOT NULL,
c7 varchar(17) COLLATE utf8mb4_bin DEFAULT NULL,
c8 binary(21) DEFAULT NULL,
c9 int(11) NOT NULL,
c10 varbinary(22) DEFAULT NULL,
c11 mediumint(26) DEFAULT NULL,
PRIMARY KEY (c9, c6, c3, c4)
);
explain_protocol: 2
result_format: 4

EXPLAIN SELECT prc.setldoc_id, 
       prc.setl_sumpric 
FROM   (SELECT setldoc_id, 
               admdvs, 
               setl_sumpric 
        FROM   dw_drug_ord_detl 
        GROUP  BY setldoc_id) prc 
       LEFT JOIN dw_drug_ord_detl setl 
              ON prc.setldoc_id = setl.setldoc_id 
WHERE  prc.admdvs = '410000' 
ORDER  BY setl_sumpric DESC 
LIMIT  10;
