result_format: 4
EXPLAIN select 
  * 
from 
  (
    select 
      /*+ NO_LEFT_TO_ANTI NO_MERGE */
      table1.col_int as table1_col_int, 
      table2.col_int as table2_col_int, 
      table3.col_int as table3_col_int, 
      table2.col_varchar_20_key as table2_col_varchar_20_key 
    from 
      (
        (
          select 
            * 
          from 
            cc 
          where 
            col_int > 1
        ) as table1 
        right outer join cc as table2 on table2.col_varchar_10_key = table1.col_varchar_10_key
      ) 
      left outer join cc as table3 on table3.`col_int` = table2.`col_int_key`
  ) v 
where 
  (
    v.table2_col_varchar_20_key > 'm' 
    and v.`table1_col_int` IS NULL
  );
