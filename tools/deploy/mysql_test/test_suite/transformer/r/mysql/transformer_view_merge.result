alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
drop database if exists view_merge_db;
create database view_merge_db;
use view_merge_db;
create table nn1(c1 int, c2 int, c3 varchar(10));
create table nn2(d1 int, d2 int, d3 varchar(10));
### parallel hints only exist in outer query, plan should be parallel  ###
explain outline  select /*+ parallel(2) */ * from (select * from nn1, nn2 where c1 = d2);
