      equal_conds([child1.pk = grandparent1.col_int_key]), other_conds(nil)
      merge_directions([ASC])
  1 - output([child1.pk]), filter(nil), rowset=16
      access([child1.pk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([child1.pk]), range(MIN ; MAX)always true
  2 - output([grandparent1.col_varchar_10], [grandparent1.col_int_key]), filter(nil), rowset=16
      sort_keys([grandparent1.col_int_key, ASC])
  3 - output([grandparent1.col_varchar_10], [grandparent1.col_int_key]), filter(nil), rowset=16
      equal_conds([parent1.col_int = grandparent1.pk]), other_conds(nil)
      merge_directions([ASC])
  4 - output([grandparent1.pk], [grandparent1.col_int_key], [grandparent1.col_varchar_10]), filter(nil), rowset=16
      access([grandparent1.pk], [grandparent1.col_int_key], [grandparent1.col_varchar_10]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([grandparent1.pk]), range(MIN ; MAX)always true
  5 - output([parent1.col_int]), filter(nil), rowset=16
      sort_keys([parent1.col_int, ASC])
  6 - output([parent1.col_int]), filter(nil), rowset=16
