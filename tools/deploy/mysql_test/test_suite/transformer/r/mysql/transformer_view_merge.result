  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384
) ;
CREATE TABLE `cc` (
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384
) ;
EXPLAIN SELECT table1 . col_int_key AS field1,
       table1 . col_int_key AS field2
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (C AS SUBQUERY1_t1
               LEFT OUTER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
         WHERE SUBQUERY1_t1 . `pk` = 4 ) AS table1
      INNER JOIN
        (SELECT DISTINCT SUBQUERY2_t1 . *
         FROM (C AS SUBQUERY2_t1
               RIGHT  JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `pk` = SUBQUERY2_t1 . `pk`))
         WHERE (EXISTS
                  (SELECT CHILD_SUBQUERY1_t1 . `pk` AS CHILD_SUBQUERY2_field1
                   FROM (CC AS CHILD_SUBQUERY1_t1
                         INNER JOIN C AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `col_int_key` = CHILD_SUBQUERY1_t1 . `col_int`))
                   WHERE CHILD_SUBQUERY1_t2 . `col_varchar` >= SUBQUERY2_t1 . `col_varchar_10_key`
                     AND CHILD_SUBQUERY1_t2 . `col_varchar_20_key` = SUBQUERY2_t2 . `col_varchar_10` )
                AND SUBQUERY2_t1 . `col_varchar_20` >= 'l') ) AS table2 ON (table2 . `col_int_key` = table1 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY3_t1 . `col_varchar_20_key` AS SUBQUERY3_field1
          FROM C AS SUBQUERY3_t1
          WHERE SUBQUERY3_t1 . `col_int_key` <> table1 . `col_int_key`
            AND SUBQUERY3_t1 . `col_varchar_key` <> table2 . `col_varchar_20_key` ))
  AND (table1 . `col_varchar_key` = 'a'
       OR table1 . `col_int_key` = 174)
ORDER BY 1,
         field1,
         field2
LIMIT 1000;
