explain
select grandparent1.col_varchar_10 as g1
from gg as grandparent1 left join kk as grandparent2 using ( col_varchar_10 )
where ( grandparent1.pk , grandparent1.col_int ) in
(select parent1.col_int as p1 , parent1.col_int_key as p2
from gg as parent1 left join t as parent2 on ( parent1.col_varchar_10 >= parent2.col_varchar_10 )
where grandparent1.col_int_key in ( select child1.pk as c1 from j as child1 where ( ( child1.col_int = child1.col_int_key ) or not ( ( ( ( grandparent1.pk > 2 or grandparent1.col_int_key = 5 ) and grandparent1.col_int_key < 0 ) or grandparent1.col_datetime_key <> '2009-11-17' ) or not grandparent1.col_date >= '2005-02-28' ) ) )
and ( grandparent1.col_varchar_10_key = 'w' ))
and (((grandparent1.col_varchar_10 is unknown or grandparent1.col_datetime_key between '2007-02-16' and '2003-11-22') and grandparent1.col_varchar_10 is null ) or grandparent1.col_varchar_10 is not null )
group by grandparent1.col_varchar_10 having g1 >= '2008-12-16' order by grandparent1.col_varchar_10;
