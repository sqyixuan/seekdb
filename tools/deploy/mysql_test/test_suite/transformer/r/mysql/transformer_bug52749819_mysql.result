drop table if exists t1, t2;
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
result_format: 4
explain_protocol: 2
EXPLAIN select * from 
(select t1.c1, (exists(select 1 from t2 where (t1.c1 = t2.c1))) as c2 from t1) v 
where v.c2 is true;
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |HASH JOIN            |     |1       |5           |
|1 |├─SUBPLAN SCAN       |VIEW1|1       |3           |
|2 |│ └─HASH DISTINCT    |     |1       |3           |
|3 |│   └─TABLE FULL SCAN|t2   |1       |3           |
|4 |└─TABLE FULL SCAN    |t1   |1       |3           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [VIEW1.t2.c1 IS NOT NULL]), filter(nil), rowset=16
      equal_conds([t1.c1 = VIEW1.t2.c1]), other_conds(nil)
  1 - output([VIEW1.t2.c1]), filter(nil), rowset=16
      access([VIEW1.t2.c1])
  2 - output([t2.c1]), filter(nil), rowset=16
      distinct([t2.c1])
  3 - output([t2.c1]), filter([t2.c1 IS NOT NULL IS 1]), rowset=16
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from 
(select t1.c1, (exists(select 1 from t2 where (t1.c1 = t2.c1))) as c2 from t1) v 
where v.c2 is true;
+------+----+
| c1   | c2 |
+------+----+
+------+----+

EXPLAIN select * from (select 1 a, exists(select 1 from t2 where t1.c1=t2.c1) b from t1 
union all select c1,c2 from t1) v 
where b is true;
Query Plan
========================================================
|ID|OPERATOR               |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |UNION ALL              |     |1       |7           |
|1 |├─HASH JOIN            |     |1       |5           |
|2 |│ ├─SUBPLAN SCAN       |VIEW1|1       |3           |
|3 |│ │ └─HASH DISTINCT    |     |1       |3           |
|4 |│ │   └─TABLE FULL SCAN|t2   |1       |3           |
|5 |│ └─TABLE FULL SCAN    |t1   |1       |3           |
|6 |└─TABLE FULL SCAN      |t1   |1       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
  1 - output([1], [VIEW1.t2.c1 IS NOT NULL]), filter(nil), rowset=16
      equal_conds([t1.c1 = VIEW1.t2.c1]), other_conds(nil)
  2 - output([VIEW1.t2.c1]), filter(nil), rowset=16
      access([VIEW1.t2.c1])
  3 - output([t2.c1]), filter(nil), rowset=16
      distinct([t2.c1])
  4 - output([t2.c1]), filter([t2.c1 IS NOT NULL IS 1]), rowset=16
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  5 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  6 - output([cast(t1.c1, BIGINT(20, 0))], [t1.c2]), filter([t1.c2 IS 1]), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from (select 1 a, exists(select 1 from t2 where t1.c1=t2.c1) b from t1 
union all select c1,c2 from t1) v 
where b is true;
+------+------+
| a    | b    |
+------+------+
+------+------+

drop table t1, t2;
