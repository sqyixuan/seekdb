drop table if exists table10_bigint;
CREATE TABLE table10_bigint (
col_mediumint_key mediumint,
col_char_20_key char(20),
col_smallint smallint,
col_integer_key integer,
col_datetime_key datetime,
col_int_key int,
col_bigint_key bigint,
col_decimal_30_5_key decimal(30,5),
col_varchar_10_key varchar(10),
col_decimal_30_5 decimal(30,5),
col_tinyint_key tinyint,
col_mediumint mediumint,
col_decimal_20_0_key decimal(20,0),
col_integer integer,
col_date_key date,
col_tinyint tinyint,
col_char_30_key char(30),
col_int int,
col_timestamp_key timestamp NULL DEFAULT NULL,
col_timestamp timestamp NULL DEFAULT NULL,
col_decimal_20_0 decimal(20,0),
col_char_30 char(30),
col_char_20 char(20),
pk bigint,
col_date date,
col_bigint bigint,
col_datetime datetime,
col_varchar_10 varchar(10),
col_smallint_key smallint,
/*Indices*/
key idx5(pk, col_mediumint_key ),
key idx17(pk, col_char_20_key ),
key idx9(pk, col_integer_key ),
key idx25(pk, col_datetime_key ),
key idx7(pk, col_int_key ),
key idx11(pk, col_bigint_key ),
key idx15(pk, col_decimal_30_5_key ),
key idx21(pk, col_varchar_10_key ),
key idx1(pk, col_tinyint_key ),
key idx13(pk, col_decimal_20_0_key ),
key idx23(pk, col_date_key ),
key idx19(pk, col_char_30_key ),
key idx27(pk, col_timestamp_key ),
primary key (pk) ,
key idx3(pk, col_smallint_key ))    ;
