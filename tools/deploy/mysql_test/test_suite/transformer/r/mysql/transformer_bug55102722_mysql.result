SELECT
MIN(-39984)
FROM
table10_bigint
WHERE COL_INT_KEY IS NULL
AND COL_INT_KEY IS NOT NULL
GROUP BY
COL_INT_KEY
HAVING
CASE WHEN (
SELECT
COUNT(*)
FROM
table10_bigint B
) > 0
THEN 1
ELSE COL_INT_KEY
END > 0;
MIN(-39984)
SELECT
MIN(-39984)
FROM
table10_bigint
WHERE COL_INT_KEY IS NULL
AND COL_INT_KEY IS NOT NULL
GROUP BY
COL_INT_KEY,
COL_SMALLINT_KEY
HAVING
ISNULL(CASE
WHEN COL_INT_KEY BETWEEN (
SELECT 
COUNT(COL_SMALLINT_KEY)
FROM
table10_bigint B
WHERE
COL_INT_KEY <> 40
ORDER BY
1 DESC
LIMIT
1
)
AND (
SELECT 
COUNT(*)
FROM
table10_bigint B
WHERE
COL_INT_KEY < 2
ORDER BY
1 DESC
LIMIT
1
)
THEN COUNT(-1)
ELSE COL_INT_KEY
END) NOT LIKE '%'
ORDER BY
1 ASC;
MIN(-39984)
drop table table10_bigint;
