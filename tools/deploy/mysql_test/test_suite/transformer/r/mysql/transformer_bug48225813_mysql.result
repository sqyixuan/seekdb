CREATE TABLE `table1` (
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
`tenant_id` bigint(20) NOT NULL,
`table_id` bigint(20) NOT NULL,
`tablet_id` bigint(20) NOT NULL,
`last_inserts` bigint(20) DEFAULT '0',
`last_updates` bigint(20) DEFAULT '0',
`last_deletes` bigint(20) DEFAULT '0',
`inserts` bigint(20) DEFAULT '0',
`updates` bigint(20) DEFAULT '0',
`deletes` bigint(20) DEFAULT '0',
`flags` bigint(20) DEFAULT NULL,
PRIMARY KEY (`tenant_id`, `table_id`, `tablet_id`)
);
CREATE TABLE `table2` (
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
`tenant_id` bigint(20) NOT NULL,
`table_id` bigint(20) NOT NULL,
`part_id` bigint(20) NOT NULL,
`part_name` varchar(64) NOT NULL DEFAULT '',
`schema_version` bigint(20) NOT NULL,
`high_bound_val` varchar(4096) DEFAULT NULL,
`b_high_bound_val` varchar(8192) DEFAULT NULL,
`sub_part_num` bigint(20) DEFAULT NULL,
`sub_part_space` bigint(20) DEFAULT NULL,
`new_sub_part_space` bigint(20) DEFAULT NULL,
`sub_part_interval` varchar(4096) DEFAULT NULL,
`sub_interval_start` varchar(4096) DEFAULT NULL,
`new_sub_part_interval` varchar(4096) DEFAULT NULL,
`new_sub_interval_start` varchar(4096) DEFAULT NULL,
`block_size` bigint(20) DEFAULT NULL,
`compress_func_name` varchar(128) DEFAULT NULL,
`status` bigint(20) DEFAULT NULL,
`spare1` bigint(20) DEFAULT NULL,
`spare2` bigint(20) DEFAULT NULL,
`spare3` varchar(65536) DEFAULT NULL,
`comment` varchar(1024) DEFAULT NULL,
`list_val` varchar(4096) DEFAULT NULL,
`b_list_val` varchar(8192) DEFAULT NULL,
`part_idx` bigint(20) DEFAULT NULL,
`source_partition_id` varchar(4096) DEFAULT '',
`tablespace_id` bigint(20) NOT NULL DEFAULT '-1',
`partition_type` bigint(20) NOT NULL DEFAULT '0',
`tablet_id` bigint(20) NOT NULL DEFAULT '0',
PRIMARY KEY (`tenant_id`, `table_id`, `part_id`),
KEY `idx_part_name` (`part_name`) BLOCK_SIZE 16384 LOCAL
);
CREATE TABLE `table3` (
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
`tenant_id` bigint(20) NOT NULL,
`table_id` bigint(20) NOT NULL,
`part_id` bigint(20) NOT NULL,
`sub_part_id` bigint(20) NOT NULL,
`sub_part_name` varchar(64) NOT NULL DEFAULT '',
`schema_version` bigint(20) NOT NULL,
`high_bound_val` varchar(4096) DEFAULT NULL,
`b_high_bound_val` varchar(8192) DEFAULT NULL,
`block_size` bigint(20) DEFAULT NULL,
`compress_func_name` varchar(128) DEFAULT NULL,
`status` bigint(20) DEFAULT NULL,
`spare1` bigint(20) DEFAULT NULL,
`spare2` bigint(20) DEFAULT NULL,
`spare3` varchar(65536) DEFAULT NULL,
`comment` varchar(1024) DEFAULT NULL,
`list_val` varchar(4096) DEFAULT NULL,
`b_list_val` varchar(8192) DEFAULT NULL,
`tablespace_id` bigint(20) NOT NULL DEFAULT '-1',
`sub_part_idx` bigint(20) NOT NULL DEFAULT '-1',
`source_partition_id` varchar(4096) NOT NULL DEFAULT '',
`partition_type` bigint(20) NOT NULL DEFAULT '0',
`tablet_id` bigint(20) NOT NULL DEFAULT '0',
PRIMARY KEY (`tenant_id`, `table_id`, `part_id`, `sub_part_id`),
KEY `idx_sub_part_name` (`sub_part_name`) BLOCK_SIZE 16384 LOCAL
);
