result_format: 4

#Part1: Single Semi Info Test
==> reject rewrite: no matched index on right, cross-stmt condition
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 > T2.C2);
