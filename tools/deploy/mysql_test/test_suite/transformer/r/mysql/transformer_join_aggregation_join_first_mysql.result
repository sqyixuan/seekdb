SELECT /*+no_rewrite*/CONCAT (table1 . `col_varchar_key`,
               table1 . `col_varchar_10`) AS field1
FROM (
        (SELECT DISTINCT SUBQUERY1_t2 . *
         FROM (BB AS SUBQUERY1_t1
               INNER JOIN (C AS SUBQUERY1_t2
                           INNER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`)) ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`))
         WHERE (SUBQUERY1_t1 . `col_varchar_key` <= SUBQUERY1_t3 . `col_varchar_10_key`
                AND EXISTS (
                              (SELECT CHILD_SUBQUERY1_t2 . `col_int` AS CHILD_SUBQUERY1_field1
                               FROM (C AS CHILD_SUBQUERY1_t1
                                     LEFT OUTER JOIN ((D AS CHILD_SUBQUERY1_t2
                                                       LEFT  JOIN C AS CHILD_SUBQUERY1_t3 ON (CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar`))) ON (CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar`))
                               WHERE CHILD_SUBQUERY1_t2 . `col_varchar_key` = 's' ))) ) AS table1
      INNER JOIN ((CC AS table2
                   LEFT OUTER JOIN C AS table3 ON (table3 . `col_varchar_10_key` = table2 . `col_varchar_key`))) ON (table3 . `pk` = table2 . `pk`))
WHERE (table3 . `col_varchar_key` >
         (SELECT COUNT(SUBQUERY2_t1 . `col_varchar_10`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                LEFT  JOIN (C AS SUBQUERY2_t2
                            INNER JOIN C AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_int_key` = SUBQUERY2_t2 . `pk`)) ON (SUBQUERY2_t3 . `col_varchar_key` = SUBQUERY2_t2 . `col_varchar_10`
                                                                                                                      OR (SUBQUERY2_t1 . `col_int_key`,
                                                                                                                          SUBQUERY2_t3 . `col_int_key`) IN
                                                                                                                        (SELECT CHILD_SUBQUERY2_t1 . `pk` AS CHILD_SUBQUERY2_field1,
                                                                                                                                CHILD_SUBQUERY2_t2 . `col_int_key` AS child_subquery2_field2
                                                                                                                         FROM (C AS CHILD_SUBQUERY2_t1
                                                                                                                               INNER JOIN C AS CHILD_SUBQUERY2_t2 ON (CHILD_SUBQUERY2_t2 . `col_varchar_key` = CHILD_SUBQUERY2_t1 . `col_varchar_key`)))))
          WHERE (SUBQUERY2_t3 . `col_varchar_key` = SUBQUERY2_t2 . `col_varchar_20`
                 AND SUBQUERY2_t1 . `col_varchar_key` NOT IN
                   (SELECT CHILD_SUBQUERY3_t2 . `col_varchar_20_key` AS CHILD_SUBQUERY2_field1
                    FROM (CC AS CHILD_SUBQUERY3_t1
                          INNER JOIN CC AS CHILD_SUBQUERY3_t2 ON (CHILD_SUBQUERY3_t2 . `col_int_key` = CHILD_SUBQUERY3_t1 . `col_int`))
                    WHERE CHILD_SUBQUERY3_t2 . `col_varchar_20_key` <= SUBQUERY2_t3 . `col_varchar_key` )) ))
  AND (table1 . `col_varchar_key` = 'v'
       OR table1 . `col_int_key` = table3 . `pk`)
GROUP BY field1
HAVING field1 <= 'nc'
ORDER BY 1,
         field1
LIMIT 1;
