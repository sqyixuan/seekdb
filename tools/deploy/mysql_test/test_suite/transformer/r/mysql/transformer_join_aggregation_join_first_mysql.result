EXPLAIN SELECT (SELECT MIN(SUBQUERY1_t1.pk) AS SUBQUERY1_field1 FROM BB AS SUBQUERY1_t1 WHERE SUBQUERY1_t1.pk < table1.pk) AS field1
FROM CC AS table1
WHERE table1.col_varchar_20 != ALL (SELECT SUBQUERY2_t1.col_varchar_10_key AS SUBQUERY2_field1
          FROM C AS SUBQUERY2_t1 LEFT  JOIN CC AS SUBQUERY2_t2 ON SUBQUERY2_t2.col_int_key = SUBQUERY2_t1.pk GROUP BY SUBQUERY2_field1);
