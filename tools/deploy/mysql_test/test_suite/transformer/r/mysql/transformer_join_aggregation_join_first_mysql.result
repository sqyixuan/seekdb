# spj with [not] exists
EXPLAIN SELECT *
FROM lineitem l1 
WHERE EXISTS (SELECT *
              FROM lineitem l2 
              WHERE l2.l_orderkey = l1.l_orderkey AND l2.l_suppkey <> l1.l_suppkey 
              HAVING Sum(CASE WHEN l2.l_receiptdate > l2.l_commitdate THEN 1 ELSE 0 END) = 0);
