drop table if exists t1, t2, t3, t4, t5, t6, t7, lineitem, t_insert;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int);
create table t3 (c1 int, c2 int, c3 int, c4 int);
create table t4 (c1 int primary key, c2 int, c3 int, c4 int);
create table t5 (c1 int, c2 int, c3 int);
create table t6 (c1 int primary key, c2 int, c3 int);
create table t7 (c1 int, c2 int, c3 int, primary key (c1, c2));
create table t_insert (c1 int, c2 int, c3 int, c4 int);
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      number(10,2) NOT NULL ,
l_discount           number(10,2) NOT NULL ,
l_tax                number(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER)
);
alter system minor freeze;
analyze table t1 compute statistics for all columns size auto;
analyze table t2 compute statistics for all columns size auto;
analyze table t3 compute statistics for all columns size auto;
analyze table t4 compute statistics for all columns size auto;
analyze table t5 compute statistics for all columns size auto;
analyze table t6 compute statistics for all columns size auto;
analyze table t7 compute statistics for all columns size auto;
analyze table t_insert compute statistics for all columns size auto;
analyze table lineitem compute statistics for all columns size auto;
set autocommit=0;
explain_protocol: 2
result_format: 4
# spj with different subquery comparision op
EXPLAIN select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
Query Plan
====================================================
|ID|OPERATOR            |NAME|EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |HASH GROUP BY       |    |2       |213         |
|1 |└─NESTED-LOOP JOIN  |    |285     |167         |
|2 |  ├─TABLE FULL SCAN |t2  |10      |3           |
|3 |  └─TABLE RANGE SCAN|t1  |14      |16          |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter([cast(2 * t1.c2, DECIMAL(15, 0)) > cast(cast(T_FUN_SUM(t2.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t2.c2),
       DECIMAL_INT(20, 0)), DECIMAL(15, 4))]), rowset=16
      group([t1.c1]), agg_func([T_FUN_SUM(t2.c2)], [T_FUN_COUNT(t2.c2)])
  1 - output([t1.c1], [t2.c2], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      conds(nil), nl_params_([t2.c1(:0)]), use_batch=true
  2 - output([t2.c1], [t2.c2]), filter(nil), rowset=16
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      access([GROUP_ID], [t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX), 
      range_cond([:0 > t1.c1])
