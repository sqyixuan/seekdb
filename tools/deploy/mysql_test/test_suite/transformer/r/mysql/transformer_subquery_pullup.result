  `col_varchar_10` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `cc` (
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL
);

EXPLAIN SELECT table1 . `col_varchar_key` AS field1,
       table1 . col_varchar_key AS field2,
       table1 . col_varchar_key AS field3
FROM (C AS table1
      INNER JOIN ((D AS table2
                   INNER JOIN A AS table3 ON (table3 . `col_int_key` = table2 . `col_int`))) ON (table3 . `col_int_key` = table2 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY1_t1 . `col_int_key` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                RIGHT  JOIN (C AS SUBQUERY1_t2
                             LEFT OUTER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`)) ON (SUBQUERY1_t3 . `col_varchar_20_key` = SUBQUERY1_t2 . `col_varchar_key`))
          WHERE SUBQUERY1_t2 . `pk` = table1 . `pk`
            AND SUBQUERY1_t2 . `col_varchar_20` < table3 . `col_varchar_key` ))
  AND table1 . `pk` = 140
  OR (table1 . `col_varchar` IS NULL
      AND table2 . `col_varchar_10` = table2 . `col_varchar_10`)
ORDER BY field1,
         field2,
         field3;
