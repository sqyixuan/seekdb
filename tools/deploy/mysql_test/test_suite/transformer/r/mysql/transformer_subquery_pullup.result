## do not pullup subquery in semi join condition
DROP TABLE IF EXISTS C, CC;
CREATE TABLE C (
    col_int_key int,
    col_varchar_10 varchar(10),
    col_varchar_20_key varchar(20),
    pk int,
    col_int int,
    col_varchar_key varchar (1),
    col_varchar_10_key varchar(10),
    col_varchar varchar (1),
    col_varchar_20 varchar(20),
    /*Indices*/
    key idx1(pk, col_int_key ),
    key idx7(pk, col_varchar_20_key ),
    primary key (pk) ,
    key idx3(pk, col_varchar_key ),
    key idx5(pk, col_varchar_10_key ));

CREATE TABLE CC (
    col_varchar_key varchar (1),
    col_varchar_20 varchar(20),
    col_varchar varchar (1),
    col_int int,
    col_varchar_10_key varchar(10),
    col_varchar_20_key varchar(20),
    col_int_key int,
    pk int,
    col_varchar_10 varchar(10),
    /*Indices*/
    key idx3(pk, col_varchar_key ),
    key idx5(pk, col_varchar_10_key ),
    key idx7(pk, col_varchar_20_key ),
    key idx1(pk, col_int_key ),
    primary key (pk) );

