CREATE TABLE `cm_merchant` (
    `merchant_id` bigint(20) NOT NULL COMMENT '商户ID',
    `external_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外部商户编号',
    `customer_id` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '所属的cif客户id（customerId）',
    `mer_type` char(1) COLLATE utf8mb4_bin NOT NULL COMMENT '身份类型  P:个人  E:企业',
    `biz_type` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '商户类型  P:平台商  B:商户  A:协作商  S:系统商 L:线上合作伙伴 F:线上普通商户  R:线下代理商  C:线下合作伙伴 O:线下预付卡 H线下核身核销',
    `name` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '商户名称',
    `cert_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '如果类型是企业，则是营业执照号;如果是个人，则是身份证号码',
    `state` bigint(20) NOT NULL COMMENT '6种状态  1:未签约 2:未续签 3:签约 4:禁止续签 5:清退 6:作废',
    `grade_type` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '商户等级  V:VIP N:普通',
    `source` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '来源，如果是表同步，则需要记录外部数据源名称；手工录入: NULL；Leads: leads的来源；表同步：外部数据源id ；其他：其他外部可区分的id',
    `source_type` bigint(20) DEFAULT NULL COMMENT '来源类型  1:手工录入 2:Leads转化 3:表同步 4:文件导入 5:其他 6:旧数据导入 7:支付宝网站WS 9:系统商URL引导',
    `industry_0` bigint(20) DEFAULT NULL COMMENT '行业大类 比如：100：线上实物；200：线上虚拟；300：线下行业',
    `industry_1` bigint(20) DEFAULT NULL COMMENT '行业小类 比如：101：数码;；102：时尚',
    `country` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '国家代码',
    `province` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '省',
    `city` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '市',
    `address` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '详细地址',
    `fax` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '传真号',
    `zip_code` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '邮政编码',
    `memo` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '备注信息',
    `creator` bigint(20) DEFAULT NULL COMMENT '创建人编号',
    `modifier` bigint(20) DEFAULT NULL COMMENT '最后更新人',
    `gmt_create` datetime(6) NOT NULL COMMENT '创建时间',
    `gmt_modified` datetime(6) NOT NULL COMMENT '最后更新时间',
    `creator_type` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '创建人类型。SALES:内部小二，MER:外部商户',
    `modifier_type` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '最后更新人类型。SALES:内部小二，MER:外部商户',
    `area` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '区县',
    `gmt_certvalid` datetime(6) DEFAULT NULL COMMENT '证件生效时间',
    `gmt_certinvalid` datetime(6) DEFAULT NULL COMMENT '证件失效时间',
    `mcc_industry_0` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'MCC一级分类',
    `mcc_industry_1` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'MCC二级分类',
    `mcc_code` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'MCC码',
    `alias_name` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '商户别名',
    `logo_url` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '商户图像地址',
    `country_code` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '国家编码',
    `province_code` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '省份编码',
    `city_code` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '城市编码',
    `district_code` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '区县编码',
    `new_mer_type` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '新商户类型：企业 EP，个人 PS，个体工商户 PB',
    PRIMARY KEY (`merchant_id`),
    KEY `idx_cm_merchant_certno` (`cert_no`) BLOCK_SIZE 16384,
    KEY `idx_cm_merchant_cid` (`customer_id`) BLOCK_SIZE 16384,
    KEY `idx_cm_merchant_eid` (`external_id`) BLOCK_SIZE 16384,
    KEY `idx_cm_merchant_name` (`name`) BLOCK_SIZE 16384,
    KEY `IDX_CM_MERCHANT_GMT` (`gmt_modified`) BLOCK_SIZE 16384,
    KEY `idx_MERCHANT_name` (`name`, `gmt_create`, `state`) BLOCK_SIZE 16384
);

CREATE TABLE `cm_attachment` (
    `id` bigint(20) NOT NULL COMMENT 'ID',
    `source_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '附件所属的主体(订单号或者商户id)',
    `source_type` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '附件所属主体的类型 MERCHANT:商户  ORDER:订单',
    `file_url` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '附件存放地址',
    `file_name` varchar(128) COLLATE utf8mb4_bin NOT NULL COMMENT '附件名称',
    `file_real_name` varchar(128) COLLATE utf8mb4_bin NOT NULL COMMENT '附件的真实名称',
    `memo` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '附件备注',
    `gmt_create` datetime(6) NOT NULL COMMENT '附件的创建时间',
    `gmt_modified` datetime(6) NOT NULL COMMENT '附件的修改时间',
    `del_flag` bigint(20) NOT NULL DEFAULT '0' COMMENT '是否逻辑删除，0：否；值为对应的ID：是(逻辑删除时填入该条记录对应的id)',
    `creator` bigint(20) NOT NULL COMMENT '创建者',
    `creator_type` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '创建者类型，SALES:内部小二，MER:外部商户',
    `industory_pool` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '行业池，用以区分无线和普通的商户属性',
    `file_ext_info` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '附件描述信息',
    PRIMARY KEY (`id`),
    UNIQUE KEY `uk_attachment_furl_dflag` (`file_url`, `del_flag`) BLOCK_SIZE 16384,
    KEY `idx_attachment_source_id` (`source_id`) BLOCK_SIZE 16384
);

