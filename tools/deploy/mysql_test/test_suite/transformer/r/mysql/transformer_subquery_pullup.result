CREATE TABLE C (
 col_datetime datetime DEFAULT NULL,
 col_int_key int(11) DEFAULT NULL,
 col_varchar_20 varchar(20) DEFAULT NULL,
 col_datetime_key datetime DEFAULT NULL,
 col_varchar_10 varchar(10) DEFAULT NULL,
 col_date_key date DEFAULT NULL,
 pk int(11) NOT NULL,
 col_date date DEFAULT NULL,
 col_int int(11) DEFAULT NULL,
 col_varchar_10_key varchar(10) DEFAULT NULL,
 col_varchar_20_key varchar(20) DEFAULT NULL,
 PRIMARY KEY (pk),
 KEY idx1 (col_int_key) BLOCK_SIZE 16384,
 KEY idx9 (col_datetime_key) BLOCK_SIZE 16384,
 KEY idx7 (col_date_key) BLOCK_SIZE 16384,
 KEY idx3 (col_varchar_10_key) BLOCK_SIZE 16384,
 KEY idx5 (col_varchar_20_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE BB (
 col_int int(11) DEFAULT NULL,
 col_date date DEFAULT NULL,
 col_varchar_10_key varchar(10) DEFAULT NULL,
 col_varchar_20 varchar(20) DEFAULT NULL,
 pk int(11) NOT NULL,
 col_datetime_key datetime DEFAULT NULL,
 col_date_key date DEFAULT NULL,
 col_datetime datetime DEFAULT NULL,
 col_varchar_20_key varchar(20) DEFAULT NULL,
 col_int_key int(11) DEFAULT NULL,
 col_varchar_10 varchar(10) DEFAULT NULL,
 PRIMARY KEY (pk),
 KEY idx3 (col_varchar_10_key) BLOCK_SIZE 16384,
 KEY idx9 (col_datetime_key) BLOCK_SIZE 16384,
 KEY idx7 (col_date_key) BLOCK_SIZE 16384,
 KEY idx5 (col_varchar_20_key) BLOCK_SIZE 16384,
 KEY idx1 (col_int_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

EXPLAIN SELECT DISTINCT OUTR.col_int AS X
   FROM C OUTR
   WHERE (OUTR.pk IN (
   SELECT INNR.pk AS Y
   FROM BB INNR
   WHERE INNR.col_datetime < INNR.col_datetime
   OR NOT OUTR.col_datetime_key >= '2008-02-22'
)
AND OUTR.col_date_key BETWEEN '2003-02-21' AND '2009-04-18'
AND OUTR.col_int IS NULL)
ORDER BY OUTR.col_varchar_20_key, OUTR.pk;
Query Plan
============================================================
|ID|OPERATOR              |NAME      |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------
|0 |TOP-N SORT            |          |1       |10          |
|1 |└─MERGE JOIN          |          |1       |10          |
|2 |  ├─TABLE FULL SCAN   |INNR      |1       |3           |
|3 |  └─SORT              |          |1       |8           |
|4 |    └─TABLE RANGE SCAN|OUTR(idx7)|1       |8           |
============================================================
Outputs & filters:
-------------------------------------
  0 - output([OUTR.col_int]), filter(nil), rowset=16
      sort_keys([OUTR.col_varchar_20_key, ASC], [OUTR.pk, ASC]), topn(1)
  1 - output([OUTR.col_varchar_20_key], [OUTR.pk], [OUTR.col_int]), filter(nil), rowset=16
      equal_conds([OUTR.pk = INNR.pk]), other_conds([INNR.col_datetime < INNR.col_datetime OR OUTR.col_datetime_key < cast('2008-02-22', MYSQL_DATETIME(-1,
       -1))])
      merge_directions([ASC])
  2 - output([INNR.pk], [INNR.col_datetime]), filter(nil), rowset=16
      access([INNR.pk], [INNR.col_datetime]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([INNR.pk]), range(MIN ; MAX)always true
  3 - output([OUTR.col_varchar_20_key], [OUTR.pk], [OUTR.col_int], [OUTR.col_datetime_key]), filter(nil), rowset=16
      sort_keys([OUTR.pk, ASC])
  4 - output([OUTR.pk], [OUTR.col_datetime_key], [OUTR.col_int], [OUTR.col_varchar_20_key]), filter([OUTR.col_int IS NULL]), rowset=16
      access([OUTR.pk], [OUTR.col_datetime_key], [OUTR.col_int], [OUTR.col_varchar_20_key]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([OUTR.col_date_key], [OUTR.pk]), range(2003-02-21,MIN ; 2009-04-18,MAX), 
      range_cond([OUTR.col_date_key >= demote_cast('2003-02-21', MYSQL_DATE(10, 0))], [OUTR.col_date_key <= demote_cast('2009-04-18', MYSQL_DATE(10, 0))])
