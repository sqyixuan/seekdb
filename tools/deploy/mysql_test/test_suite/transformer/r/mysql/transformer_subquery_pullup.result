      columns([{uniq_varchar: ({uniq_varchar: (uniq_varchar.pk)})}]), 
      column_values([column_conv(VARCHAR,utf8mb4_general_ci,length:32,NOT NULL,__values.pk)])
  1 - output([__values.pk]), filter(nil)
      values({'0'}, {'00'}, {'000'}, {'0000'}, {'00000'}, {'000000'})

