      equal_conds([VIEW1.SUBQUERY1_t3.col_varchar_10 = table2.col_varchar_10_key]), other_conds([(T_OP_OR, table2.col_int >= VIEW1.SUBQUERY1_t1.col_int,
       table2.col_int IS NULL, VIEW1.SUBQUERY1_t1.col_int IS NULL)])
