###bug:
drop table if exists t_abc, t_xyz, t_ccc;
create table t_abc (a int primary key, b int, c int, index idx_b(b), unique idx_c(c));
create table t_xyz (x int primary key, y int, z int, index idx_y(y), unique idx_z(z));
create table t_ccc (c1 int primary key, c2 int, c3 int, index idx_c2(c2), unique idx_c3(c3));

