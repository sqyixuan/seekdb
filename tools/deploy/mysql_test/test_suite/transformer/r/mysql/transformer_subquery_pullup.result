);

EXPLAIN SELECT table1.col_varchar_key AS field1 , table1.col_varchar_key AS field2 FROM ((SELECT SUBQUERY1_t1 . * FROM (BB AS SUBQUERY1_t1 LEFT JOIN 
  C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int` = SUBQUERY1_t1 . `col_int_key`  )) WHERE SUBQUERY1_t2 . `col_int_key` = 7 ) AS table1 RIGHT
  OUTER JOIN B AS table2 ON (table2 . `pk` = table1 . `pk` )) WHERE (( 'g', 'y' )  IN (SELECT MAX(  SUBQUERY2_t1 . `col_varchar` ) AS 
  SUBQUERY2_field1 , COUNT(  SUBQUERY2_t1 . `col_varchar_10_key` ) AS SUBQUERY2_field2 FROM C AS SUBQUERY2_t1 WHERE  SUBQUERY2_t1 . `pk` > ANY 
  ( SELECT   CHILD_SUBQUERY1_t1 . `col_int_key` AS CHILD_SUBQUERY2_field1 FROM (C AS CHILD_SUBQUERY1_t1 INNER JOIN C AS CHILD_SUBQUERY1_t2 ON 
  (CHILD_SUBQUERY1_t2 . `col_int_key` = CHILD_SUBQUERY1_t1 . `col_int` )) WHERE CHILD_SUBQUERY1_t2 . `pk` >= SUBQUERY2_t1 . `col_int_key`))) 
  OR ( table1 . `pk`  BETWEEN 87 AND ( 87 + 191 ) OR table1 . `pk` > 87 AND table1 . `pk` < (87 + 61))   ORDER BY 1, field1, field2 ;
