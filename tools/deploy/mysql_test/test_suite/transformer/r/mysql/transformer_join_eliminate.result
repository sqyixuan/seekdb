### 普通索引 + group-by, order-by, having
EXPLAIN select sum(A.b), min(B.b), max(C.b)
         from t6 as A, t6 As B, t6 as C
          where A.a = B.a
            and A.b = C.b
            and B.c = C.c
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
