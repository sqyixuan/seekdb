### unique key + group-by, order-by, having
EXPLAIN select sum(A.b), min(B.b), max(C.b)
          from t5 as A, t5 As B, t5 as C
          where A.a = B.a
            and A.b = C.b
            and B.c = C.c
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
