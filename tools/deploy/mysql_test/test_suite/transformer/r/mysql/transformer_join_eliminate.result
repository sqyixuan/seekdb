## 单主键 + group by + order by + having
EXPLAIN select sum(C.b), min(P1.a), max(P2.a)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.a = P2.a
    group by C.b
    having min(P1.a) > 0
    order by max(P2.a);
