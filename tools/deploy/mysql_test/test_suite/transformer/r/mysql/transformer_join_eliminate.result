      group([C.b]), agg_func([T_FUN_SUM(C.c)], [T_FUN_MAX(C.d)])
  2 - output([C.b], [C.c], [C.d]), filter([C.b > 0], [C.c IS NOT NULL], [C.d IS NOT NULL]), rowset=16
      access([C.b], [C.c], [C.d]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([C.a], [C.b]), range(MIN,MIN ; MAX,MAX)always true
