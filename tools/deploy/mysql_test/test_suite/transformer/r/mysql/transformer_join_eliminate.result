## 联合主键 + order by + group by + having
EXPLAIN select sum(C.c), min(P1.b), max(P2.b)
    from tf134 as C, t13 as P1, t14 as P2
    where C.a = P1.a and C.b = P1.b and C.c = P2.a and C.d = P2.b
    group by C.b
    having min(P1.b) > 0
    order by max(P2.b);
