  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) 
) ;
EXPLAIN SELECT ((table1 . `col_int`) - (table2 . `col_int_key`)) AS field1,
       table2 . col_varchar_key AS field2
FROM (CC AS table1
      RIGHT OUTER JOIN CC AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10`))
