      group(nil), agg_func([T_FUN_MIN(t1.c1)], [T_FUN_MAX(t1.c1)])
  1 - output([t1.c1]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c3]), other_conds(nil)
      merge_directions([ASC])
