      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
  3 - output([t2.c3]), filter(nil), rowset=16
      sort_keys([t2.c3, ASC])
  4 - output([t2.c3]), filter(nil), rowset=16
      access([t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select min(c1),max(c1) from t1 where c1 = any (select c3 from t2);
