drop table t1,t2,t3,t4,t5,t6,pt1,pt2,pt3;
drop sequence s1;

create table t1(c1 int, c2 int);
create index i1 on t1(c1);
create table t2(c3 int);
EXPLAIN select min(c1),max(c1) from t1 where c1 = any (select c3 from t2);
