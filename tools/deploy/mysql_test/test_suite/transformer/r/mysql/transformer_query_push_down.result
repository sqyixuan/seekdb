##https://github.com/oceanbase/oceanbase/issues/129
create table t_sq ( 
  c_mn INTEGER NOT NULL,
  c_d4q INTEGER NOT NULL,
  c_b7xq TEXT ,
  c_gfwq INTEGER ,
  primary key(c_d4q),
  unique(c_gfwq, c_mn)
);

EXPLAIN select  
    subq_0.c8 as c2
  from 
    (select  
          (select c_mn from t_sq limit 1) as c5, 
          t_sq.c_d4q as c8
        from t_sq)
    as subq_0
  where subq_0.c8 >= ( 
    select subq_0.c5 as c0
        from t_sq);
