EXPLAIN select  
    subq_0.c1 as c0, 
    (select c_b7xq from t_sq order by c_b7xq limit 1 offset 1)
       as c1, 
    subq_0.c9 as c2
  from 
    (select  
          ref_0.c_mn as c0, 
          ref_0.c_b7xq as c1, 
          72 as c2, 
          ref_0.c_mn as c3, 
          39 as c4, 
          (select c_mn from t_sq order by c_mn limit 1 offset 1)
             as c5, 
          ref_0.c_b7xq as c6, 
          ref_0.c_b7xq as c7, 
          ref_0.c_d4q as c8, 
          ref_0.c_b7xq as c9, 
          (select c_mn from t_sq order by c_mn limit 1 offset 4)
             as c10, 
          ref_0.c_b7xq as c11
        from 
          t_sq as ref_0
        where ref_0.c_b7xq like '%847jixcs') as subq_0
  where subq_0.c8 >= ( 
    select  
          subq_0.c5 as c0
        from 
          t_sq as ref_1
        where subq_0.c9 is NULL
      union
      select distinct 
          71 as c0
        from 
          t_sq as ref_2
        where (select count(c_mn) from t_sq)
             not in (
          select  
                ref_3.c_d4q as c0
              from 
                t_sq as ref_3
              where ref_3.c_b7xq like '_'
            union
            select  
                ref_4.c_d4q as c0
              from 
                t_sq as ref_4
              where 0<>0))
union
select  
    case when ref_5.c_b7xq like '%ds' AND ref_5.c_d4q < ref_5.c_d4q then ref_5.c_b7xq else ref_5.c_b7xq end
       as c0, 
    ref_5.c_b7xq as c1, 
    ref_5.c_b7xq as c2
  from 
    t_sq as ref_5
  where ref_5.c_d4q > ref_5.c_mn;
