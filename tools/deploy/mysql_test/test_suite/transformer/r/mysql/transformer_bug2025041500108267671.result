drop table if exists t1, t2;
create table t1 (pk int primary key, c1 int, c2 int);
create table t2 (pk int primary key, c1 int, c2 int);
insert into t1 values (1,1,1);
insert into t2 values (1,1,1);
result_format: 4
explain_protocol: 2
# t2.pk != t2.pk 这个条件不应该被丢弃
EXPLAIN SELECT /*+PLACE_GROUP_BY*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk) 
group by field4;
