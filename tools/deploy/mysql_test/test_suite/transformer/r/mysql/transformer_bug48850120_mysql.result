drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
create table t1(c0 varchar(100)collate gb18030_chinese_ci) character set gb18030;
insert into t1 values('中文abc字符');
insert into t1 values('中文ABC字符');
create table t2(c0 varchar(100) collate gb18030_chinese_ci primary key) character set gb18030;
insert into t2 values('中文abc字符');
alter table t1 add constraint 外键 foreign key (c0) references t2(c0);
create table t3(c0 varchar(100), c1 int) character set utf8mb4;
insert into t3 values('中文abc字符', 1);
insert into t3 values('中文ABC字符', 1);
create table t4(c0 varchar(100), c1 int, primary key(c0,c1)) character set utf8mb4;
insert into t4 values('中文abc字符', 1);
alter table t3 add constraint fk2 foreign key (c0, c1) references t4(c0, c1);
result_format: 4
explain_protocol: 2
EXPLAIN select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |MERGE JOIN         |    |2       |5           |
|1 |├─TABLE FULL SCAN  |e   |1       |3           |
|2 |└─SORT             |    |2       |3           |
|3 |  └─TABLE FULL SCAN|p   |2       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([p.c0], [e.c0]), filter(nil), rowset=16
      equal_conds([e.c0 = p.c0]), other_conds(nil)
      merge_directions([ASC])
  1 - output([e.c0]), filter(nil), rowset=16
      access([e.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([e.c0]), range(MIN ; MAX)always true
  2 - output([p.c0]), filter(nil), rowset=16
      sort_keys([p.c0, ASC])
  3 - output([p.c0]), filter(nil), rowset=16
      access([p.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([p.__pk_increment]), range(MIN ; MAX)always true
select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0;
+-----------------+-----------------+
| c0              | c0              |
+-----------------+-----------------+
| 中文abc字符     | 中文abc字符     |
| 中文ABC字符     | 中文abc字符     |
+-----------------+-----------------+

