EXPLAIN update t1,t2 set t1.c0 = t2.c0 where t1.c0 = t2.c0;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |DISTRIBUTED UPDATE   |    |1       |37          |
|1 |└─MERGE JOIN         |    |1       |5           |
|2 |  ├─TABLE FULL SCAN  |t2  |1       |3           |
|3 |  └─SORT             |    |2       |3           |
|4 |    └─TABLE FULL SCAN|t1  |2       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.__pk_increment, t1.c0)})}]),
      update([t1.c0=column_conv(VARCHAR,gb18030_chinese_ci,length:100,NULL,t2.c0)])
  1 - output([t1.__pk_increment], [t1.c0], [t2.c0]), filter(nil), rowset=16
      equal_conds([t1.c0 = t2.c0]), other_conds(nil)
      merge_directions([ASC])
  2 - output([t2.c0]), filter(nil), rowset=16
      access([t2.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c0]), range(MIN ; MAX)always true
  3 - output([t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
      sort_keys([t1.c0, ASC])
  4 - output([t1.__pk_increment], [t1.c0]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
update t1,t2 set t1.c0 = t2.c0 where t1.c0 = t2.c0;

