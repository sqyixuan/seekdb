result_format: 4
explain_protocol: 2
USE OPT_WISCONSIN;
drop table if exists t1;
create table t1(c1 double, c2 decimal(10,0), c3 double);

set autocommit=0;
##basic result
select/**/ count(*) from t1;
+----------+
| count(*) |
+----------+
|        3 |
+----------+
select/**/ stddev(ten) from t1_100;
+--------------------+
| stddev(ten)        |
+--------------------+
| 2.8722813232690143 |
+--------------------+
select/**/ stddev(ten) from t1_100;
+--------------------+
| stddev(ten)        |
+--------------------+
| 2.8722813232690143 |
+--------------------+

## exists and not exists
EXPLAIN select l.numeric from t1_100 l where exists (select 1 from t2_100 r1 where l.ten = r1.ten) and not exists (select 1 from t2_100 r2 where l.ten = r2.ten and l.hundred = r2.hundred) order by l.numeric limit 5;
Query Plan
===================================================================
|ID|OPERATOR                 |NAME          |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |TOP-N SORT               |              |2       |62          |
|1 |└─HASH SEMI JOIN         |              |2       |62          |
|2 |  ├─HASH RIGHT ANTI JOIN |              |2       |48          |
|3 |  │ ├─TABLE FULL SCAN    |r2            |100     |6           |
|4 |  │ └─TABLE FULL SCAN    |l             |100     |8           |
|5 |  └─TABLE FULL SCAN      |r1(T2_100_TEN)|100     |4           |
===================================================================
