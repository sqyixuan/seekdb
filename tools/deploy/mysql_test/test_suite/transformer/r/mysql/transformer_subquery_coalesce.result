drop table if exists t1,t2,test1,test2;
drop sequence sq;
drop sequence sq1;
create table t1(c1 int, c2 int, c3 int);
create table t2(co1 int, co2 int);
CREATE TABLE`test1`( `id1` int(11) NOT NULL, `name`varchar(45)DEFAULT NULL);
CREATE TABLE`test2`(`id2` int (11) NOT NULL, `name` varchar (45)DEFAULT NULL);

insert into t1 values(1,0,1);
insert into t2 values(1,0);
INSERT INTO`test1`(`id1`,`name`) VALUES (1,'a'),(2,'x'),(2, 'y') , (3,'b' );
INSERT INTO `test2`(`id2`,`name`) VALUES (1,'m' ) ,(2,'n');

create sequence sq increment by 1 start with 1 maxvalue 1000 nocycle nocache;
create sequence sq1 increment by -1 start with 1000 maxvalue 1000 minvalue -1 nocycle nocache;

