      equal_conds([l.TEN = r1.TEN]), other_conds(nil)
  2 - output([l.NUMERIC], [l.TEN]), filter(nil), rowset=256
      equal_conds([l.TEN = r2.TEN], [l.HUNDRED = r2.HUNDRED]), other_conds(nil)
