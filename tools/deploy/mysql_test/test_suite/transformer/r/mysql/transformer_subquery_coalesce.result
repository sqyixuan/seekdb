      access([r2.TEN], [r2.HUNDRED]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([r2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([l.TEN], [l.HUNDRED], [l.NUMERIC]), filter(nil), rowset=256
      access([l.TEN], [l.HUNDRED], [l.NUMERIC]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([l.__pk_increment]), range(MIN ; MAX)always true
  5 - output([r1.TEN]), filter(nil), rowset=256
      access([r1.TEN]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([r1.TEN], [r1.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
