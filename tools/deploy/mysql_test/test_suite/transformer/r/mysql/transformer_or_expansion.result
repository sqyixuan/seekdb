                                     ) )
                 WHERE  SUBQUERY1_t2 . `col_int` <= table1 . `col_int_key`
                        AND SUBQUERY1_t3 . `col_varchar_key` >= table1 .
                            `col_varchar_10`) AS
                field7,
                Min(table1 . `col_varchar`)
                AS field8,
                (SELECT Min(SUBQUERY2_t2 . `col_int`) AS SUBQUERY2_field1
                 FROM   ( cc AS SUBQUERY2_t1
                          RIGHT JOIN c AS SUBQUERY2_t2
                                  ON ( SUBQUERY2_t2 . `col_varchar_10` =
