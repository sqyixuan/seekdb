SELECT table1 . `col_varchar_20_key` AS field1,
       table1 . col_varchar_20_key AS field2,
       table2 . `pk` AS field3,
       table1 . col_varchar_10_key AS field4,
       table1 . col_varchar_10_key AS field5,
       table1 . col_varchar_key AS field6,
       table1 . col_varchar_key AS field7,
       table2 . col_varchar_key AS field8,
       table1 . `col_varchar_10` AS field9,
       table1 . col_varchar_20_key AS field10,
       table1 . col_varchar_key AS field11
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (CC AS SUBQUERY1_t1
               RIGHT  JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `pk`))
         WHERE SUBQUERY1_t1 . `col_varchar_10_key` >= 'w' ) AS table1
      INNER JOIN ((C AS table2
                   INNER JOIN CC AS table3 ON (table3 . `col_int` = table2 . `col_int_key`))) ON (table3 . `col_int_key` = table2 . `pk`))
WHERE (table2 . `col_int` =
         (SELECT MAX(SUBQUERY2_t1 . `pk`) AS SUBQUERY2_field1
          FROM CC AS SUBQUERY2_t1))
  OR (table2 . `pk` <> ALL
        (SELECT SUBQUERY3_t2 . `pk` AS SUBQUERY3_field1
         FROM (C AS SUBQUERY3_t1
               INNER JOIN A AS SUBQUERY3_t2 ON (SUBQUERY3_t2 . `col_varchar_10_key` = SUBQUERY3_t1 . `col_varchar_key`))
         WHERE SUBQUERY3_t2 . `col_varchar_20_key` >= table2 . `col_varchar` )) ;
