EXPLAIN SELECT DISTINCT OUTR.pk AS X
FROM   c AS OUTR2 LEFT JOIN b AS OUTR ON ( OUTR2.col_varchar_10 <> OUTR.col_varchar_10 )
  WHERE  ( OUTR.col_int_key, OUTR.col_int ) IN (SELECT INNR.pk AS X,
      INNR.col_int AS Y
      FROM   cc AS INNR2
      LEFT JOIN cc AS INNR
      ON ( INNR2.col_date <= INNR.col_date )
      WHERE
      INNR.col_varchar_20 >= INNR.col_varchar_10
      OR INNR.col_int_key = INNR.col_int)
  AND OUTR.col_varchar_20_key > 'm'
  OR OUTR.col_datetime < '2009-04-17'
  ORDER  BY OUTR.col_date,
  OUTR.pk;
