CREATE TABLE `c` (
    `col_varchar_10_key` varchar(10) DEFAULT NULL,
    `col_varchar_20` varchar(20) DEFAULT NULL,
    `pk` int(11) NOT NULL,
    `col_varchar` varchar(1) DEFAULT NULL,
    `col_varchar_20_key` varchar(20) DEFAULT NULL,
    `col_varchar_10` varchar(10) DEFAULT NULL,
    `col_varchar_key` varchar(1) DEFAULT NULL,
    `col_int` int(11) DEFAULT NULL,
    `col_int_key` int(11) DEFAULT NULL,
    PRIMARY KEY (`pk`),
    KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384,
    KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384,
    KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384,
    KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384
    )
;

EXPLAIN SELECT table1 . `col_varchar` AS field2,
       table2 . col_int_key AS field3,
       table2 . col_varchar_key AS field4,
       table2 . col_varchar_key AS field5
       FROM (
           (SELECT SUBQUERY1_t1 . * FROM C AS SUBQUERY1_t1) AS table1
           RIGHT OUTER JOIN
           (SELECT SUBQUERY2_t2 . * FROM (C SUBQUERY2_t2) ) AS table2 ON (table2 . `col_int` = table1 . `pk`))
  WHERE (EXISTS (SELECT SUBQUERY3_t1 . `col_varchar_20` AS SUBQUERY3_field1 FROM C AS SUBQUERY3_t1 WHERE SUBQUERY3_t1 . `col_int_key` < table1 . `col_int_key`))
  AND (table1 . `col_int_key` >= table1 . `col_int_key` OR table1 . `col_varchar_10` IS NULL) ;
