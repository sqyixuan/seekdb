CREATE TABLE `cc` (
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

EXPLAIN SELECT DISTINCT table2 . col_varchar_key
                AS
                field1,
                Count(DISTINCT table1 . `col_varchar_10`)
                AS field2,
                Count(table1 . `pk`)
                AS field3,
                Sum(table2 . `col_varchar_20`)
                AS field4,
                table1 . `col_int`
                AS field5,
                table1 . col_int_key
                AS field6,
                (SELECT DISTINCT Max(DISTINCT SUBQUERY1_t1 . `col_int_key`) AS
                                 SUBQUERY1_field1
                 FROM   ( d AS SUBQUERY1_t1
                          INNER JOIN ( c AS SUBQUERY1_t2
                                       INNER JOIN c AS SUBQUERY1_t3
                                               ON ( SUBQUERY1_t3 .
                                                    `col_varchar_key` =
                                                    SUBQUERY1_t2 . `col_varchar`
                                                  ) )
                                  ON ( SUBQUERY1_t3 . `col_varchar_key` =
                                       SUBQUERY1_t2 . `col_varchar_10`
                                     ) )
                 WHERE  SUBQUERY1_t2 . `col_int` <= table1 . `col_int_key`
                        AND SUBQUERY1_t3 . `col_varchar_key` >= table1 .
                            `col_varchar_10`) AS
                field7,
                Min(table1 . `col_varchar`)
                AS field8,
                (SELECT Min(SUBQUERY2_t2 . `col_int`) AS SUBQUERY2_field1
                 FROM   ( cc AS SUBQUERY2_t1
                          RIGHT JOIN c AS SUBQUERY2_t2
                                  ON ( SUBQUERY2_t2 . `col_varchar_10` =
                                       SUBQUERY2_t1 . `col_varchar_key`
                                     ) )
                 WHERE  SUBQUERY2_t1 . `pk` > table1 . `col_int_key`)
                AS field9,
                table2 . `pk`
                AS field10,
                (SELECT Max(DISTINCT SUBQUERY3_t1 . `pk`) AS SUBQUERY3_field1
                 FROM   a AS SUBQUERY3_t1
                 WHERE  SUBQUERY3_t1 . `col_int` <= table1 . `pk`)
                AS field11,
                table1 . col_int_key
                AS field12
FROM   ( c AS table1
         INNER JOIN cc AS table2
                 ON ( table2 . `col_int` = table1 . `pk` ) )
WHERE  ( ( table2 . `pk`, table2 . `pk` ) IN (SELECT
                  Sum(SUBQUERY4_t1 . `col_int_key`)      AS SUBQUERY4_field1,
                                                     Sum(DISTINCT SUBQUERY4_t1 .
                                                                  `col_int`)
                  AS SUBQUERY4_field2
                                              FROM   cc AS SUBQUERY4_t1
                                              WHERE
         SUBQUERY4_t1 . `col_varchar_10` <=
         'a') )
       AND ( table1 . `col_int_key` = 52
             AND table1 . `col_int_key` = 167 )
        OR ( table1 . `pk` IS NULL
             AND table1 . `pk` != table1 . `pk` )
GROUP  BY field1,
          field5,
          field6,
          field7,
          field9,
          field10,
          field11,
          field12
HAVING ( ( field9 < 'a'
            OR field4 < 74 )
          OR field3 <= 1 )
ORDER  BY field1,
          field2,
          field3,
          field4,
          field5,
          field6,
          field7,
          field8,
          field9,
          field10,
          field11,
          field12;
