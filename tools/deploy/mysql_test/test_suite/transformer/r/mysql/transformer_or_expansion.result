FROM BB table1
 INNER JOIN C table2 ON table2.col_varchar_key = table1.col_varchar
WHERE table2.col_int_key >= SOME (
  SELECT SUBQUERY1_t1.pk AS SUBQUERY1_field1
  FROM BB SUBQUERY1_t1
  WHERE SUBQUERY1_t1.col_varchar_key != table1.col_varchar_10
   OR SUBQUERY1_t1.col_int < table2.col_int_key
 )
 OR (table1.pk > 86
  AND table1.pk < 86 + 23
  OR table1.pk > 86
  AND table1.pk < 86 + 82)
ORDER BY field2 DESC, field1, field2;
