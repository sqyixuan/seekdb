EXPLAIN SELECT   DISTINCT   table2 . col_varchar_key AS field1 FROM ( CC AS table1 INNER JOIN ( ( CC AS table2 LEFT  JOIN CC AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_20`  ) ) ) ON (table3 . `col_varchar_10` = table2 . `col_varchar_key`  ) ) WHERE (  NOT EXISTS ( ( SELECT   SUBQUERY1_t1 . `col_varchar_20` AS SUBQUERY1_field1 FROM C AS SUBQUERY1_t1  GROUP BY SUBQUERY1_field1 ) ) ) AND ( table1 . `col_varchar_key` = 'g' AND table1 . `pk` = 250 ) OR   EXISTS ( SELECT   SUBQUERY2_t2 . `col_varchar_20_key` AS SUBQUERY2_field1 FROM ( CC AS SUBQUERY2_t1 INNER JOIN C AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `pk` = SUBQUERY2_t1 . `col_int_key`  ) ) WHERE SUBQUERY2_t1 . `col_varchar_20_key` >= table1 . `col_varchar_10` )   ORDER BY 1, field1 LIMIT 1 OFFSET 2;
