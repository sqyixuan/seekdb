drop table if exists t1, t2, t3, t4, t5, tpart, t, is_t1;
create table t1(a int, b int, c int, d int, e int, index idx_a(a), index idx_b(b), index idx_c(c), index idx_d(d));
create table t2(a int, b int, c int, d int, e int);
create table t3(a int, b int, c int, d int, e int);
create table t4(a int, b int, c int, d int, e int);
create table t5(a int, b int, c int, d int, e int, index idx_a(a, b));
create table tpart (id int primary key, k int) partition by hash(id) partitions 100;
create index k_1 on tpart (k, id) local;
create table is_t1(a int, b int, c int);
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T2', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T3', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T4', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T5', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'TPART', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'IS_T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T4', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T5', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'TPART', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'IS_T1', method_opt=>'for all columns size 64', estimate_percent=>100);
result_format: 4
explain_protocol: 2
set autocommit = 0;

