drop table if exists cb_dep_acctdep_40,cb_dep_acctbal_40,cb_gl_rpt_gl_extractdata_batch,cb_dep_deprtxn_40;
CREATE TABLE `cb_dep_acctdep_40` (
    `acctnbr` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '系统账号',
    `branchnbr` varchar(12) COLLATE utf8mb4_bin NOT NULL COMMENT '开户机构',
    `currencycd` char(3) COLLATE utf8mb4_bin NOT NULL COMMENT '账户币种',
    `instrumenttypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账号钞汇标志',
    `termunitcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '存期单位',
    `termunitvalue` bigint(20) DEFAULT NULL COMMENT '存期数值',
    `ownertypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '所有人类型',
    `ownernbr` char(10) COLLATE utf8mb4_bin NOT NULL COMMENT '开户人号码',
    `acctname` varchar(180) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账号名称',
    `mediid` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '电子账号',
    `mjaccttypcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '产品大类',
    `currmiaccttypcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '可根据需要添加',
    `proptypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品性质代码',
    `acctholdyn` int(11) NOT NULL DEFAULT '0' COMMENT '账户是否存在冻结信息',
    `acctctrlyn` int(11) NOT NULL DEFAULT '0' COMMENT '账户是否存在控制信息',
    `acctbfyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否账户不付',
    `acctbsyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否账户不收',
    `autorepayodyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否自动偿还透支透支',
    `curracctstatcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '当前账户状态',
    `contractdate` date NOT NULL COMMENT '开户日期',
    `datemat` date DEFAULT NULL COMMENT '到期日期',
    `firstrtxndate` date DEFAULT NULL COMMENT '首次存入日期',
    `firstrtxnamt` decimal(18,2) DEFAULT NULL COMMENT '首次存入金额',
    `lastcontactdate` date NOT NULL COMMENT '上次动户日，具体设置和rtxntyp表中的updlastcontactyn相关,客户主动发生交易，用于统计',
    `closedate` date DEFAULT NULL COMMENT '销户日期',
    `closereasoncd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '销户原因',
    `partialwthcnt` bigint(20) DEFAULT NULL COMMENT '累计部提次数',
    `acctstatyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否自动转不动户',
    `renewyn` int(11) NOT NULL DEFAULT '0' COMMENT '定期到期销户后是否续开账户',
    `transfertypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '转存方式，如果转他行账号则需要登记约定转存登记簿',
    `transferamttypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '本金，本息',
    `transfermediid` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '可能是外系统账号',
    `transferacctnbr` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '转存系统账号',
    `tranacctyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否结算账号标志',
    `stmtacctyn` int(11) NOT NULL DEFAULT '0' COMMENT '账号是否可出对账单',
    `stmtacctnbr` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '当前账号可归集的对账单账号',
    `validyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否通过了账户层的有效性检查',
    `openfundsourcecd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '开户资金来源',
    `nextrtxnnbr` bigint(20) NOT NULL COMMENT '账号的下一笔交易号',
    `foreignacctauthid` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外汇账户核准件编号',
    `foreignacctspclorgid` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外汇账户特殊机构代码',
    `acctnote` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '开立客户时填写',
    `version` bigint(20) NOT NULL DEFAULT '1' COMMENT '版本号',
    `mainttellerid` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '维护柜员',
    `maintbranchnbr` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '维护机构',
    `bankorgnbr` char(4) COLLATE utf8mb4_bin NOT NULL DEFAULT '7001' COMMENT '法人编号',
    `gmt_create` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护日期',
    `gmt_modified` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护时间',
    `mjmiid` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '业务产品码',
    `virtualyn` int(11) NOT NULL DEFAULT '0' COMMENT '是否虚账户',
    `platformmainacctnbr` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '平台主帐号',
    `platformcd` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '平台代码',
    PRIMARY KEY (`acctnbr`),
    KEY `idx_acctdep_mediid` (`mediid`) BLOCK_SIZE 16384,
    KEY `idx_acctdep_ownernbr` (`ownernbr`) BLOCK_SIZE 16384
    );

CREATE TABLE `cb_dep_acctbal_40` (
    `acctnbr` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '账号',
    `balcatcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '余额类别代码',
    `baltypcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '余额类型代码',
    `preeffdate` date DEFAULT NULL COMMENT '上次生效日期',
    `preamt` decimal(21,5) DEFAULT '0.00000' COMMENT '上次金额',
    `effdate` date NOT NULL COMMENT '余额生效日期',
    `amt` decimal(21,5) NOT NULL DEFAULT '0.00000' COMMENT '账户金额',
    `maxoverdraftamt` decimal(18,2) DEFAULT NULL COMMENT '最大透支金额',
    `holdsumamt` decimal(18,2) DEFAULT '0.00' COMMENT '冻结汇总金额',
    `ctrlsumamt` decimal(18,2) DEFAULT '0.00' COMMENT '控制汇总金额',
    `mainttellerid` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '维护柜员',
    `maintbranchnbr` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '维护机构',
    `gmt_create` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护日期',
    `gmt_modified` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护时间',
    `nextratechangedate` date DEFAULT NULL COMMENT '下个利率变更日期',
    `txsumamt` decimal(18,2) NOT NULL DEFAULT '0.00' COMMENT '分布式事务预留金额',
    PRIMARY KEY (`acctnbr`, `balcatcd`, `baltypcd`),
    KEY `idx_acctbal_acctnbr_effdate_balcatcd_baltypcd` (`acctnbr`, `effdate`, `balcatcd`, `baltypcd`) BLOCK_SIZE 16384,
    KEY `idx_acctbal_acctnbr_preeffdate_balcatcd_baltypcd` (`acctnbr`, `preeffdate`, `balcatcd`, `baltypcd`) BLOCK_SIZE 16384
    );

CREATE TABLE `cb_gl_rpt_gl_extractdata_batch` (
    `rtxnid` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '序列号',
    `txnseqid` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '系统交易流水',
    `postdate` date DEFAULT NULL COMMENT '交易日期',
    `txndatetime` datetime NOT NULL COMMENT '交易时间',
    `reversaltypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '冲正方式',
    `currrtxnstatcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '交易状态',
    `origtxnseqid` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '原系统交易流水号',
    `channelid` varchar(7) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '发起渠道代码',
    `channelseqno` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '端流水号',
    `glseqno` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账套号',
    `channeldate` datetime DEFAULT NULL COMMENT '端发起时间',
    `bizprodcode` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '本层产品码',
    `bizeventcode` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '本层事件码',
    `traceid` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易跟踪号',
    `rtxndesc` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '摘要',
    `rtxnnbr` bigint(20) NOT NULL COMMENT '交易序号',
    `acctnbr` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '账号',
    `acctname` varchar(180) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账户名称',
    `rtxntypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易类型',
    `fundtypcd` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '资金类型',
    `fundtypdtlcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '资金类型明细',
    `currencycd` char(3) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '币种',
    `tranamt` decimal(18,5) DEFAULT NULL COMMENT '交易金额',
    `mjaccttypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品大类代码',
    `miaccttypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品小类代码',
    `balcatcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '余额类别',
    `baltypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '余额类型',
    `branchnbr` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '机构代码',
    `bankorgnbr` char(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '法人代码',
    `debitcreditflag` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '借贷标志',
    `glaccttitlename` varchar(90) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '科目名称',
    `glaccttitlenbr` bigint(20) DEFAULT NULL COMMENT '科目编号',
    `glaccttypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '科目类型',
    `gmt_create` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '新建时间',
    `gmt_modified` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '修改时间',
    `exglacctnbr` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '科目代号',
    `flag` char(1) COLLATE utf8mb4_bin DEFAULT '0' COMMENT '标识位',
    `glacctid` bigint(20) DEFAULT NULL COMMENT '科目ID',
    `mediid` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '电子帐号',
    `sysid` varchar(10) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '系统编号',
    `spflag` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '特殊标识',
    `shardingkey` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分片号',
    PRIMARY KEY (`rtxnid`),
    KEY `cb_gl_rpt_gl_extractdata_batch_glaccttypcd_postdate_idx` (`glaccttypcd`, `postdate`) BLOCK_SIZE 16384,
    KEY `idx_cb_gl_extractdata_batch_postdate_flag_exglacctnbr_bankorgnb2` (`postdate`, `flag`, `exglacctnbr`, `bankorgnbr`, `branchnbr`, `debitcreditflag`, `tranamt`, `currencycd`) BLOCK_SIZE 16384,
    KEY `idx_rpt_gl_extractdata_batch_postdate_glseqno` (`postdate`, `glseqno`) BLOCK_SIZE 16384,
    KEY `idx_rpt_gl_extractdata_batch_postdate_acctnbr` (`postdate`, `acctnbr`) BLOCK_SIZE 16384,
    KEY `idx_rpt_gl_extractdata_batch_postdate_bankorgnbr_branchnbr` (`postdate`, `bankorgnbr`, `branchnbr`) BLOCK_SIZE 16384,
    KEY `idx_extractdata_batch_pdate_flg_acnbr_rtxnnbr_amt_dflg_glseqno` (`postdate`, `flag`, `acctnbr`, `rtxnnbr`, `tranamt`, `debitcreditflag`, `glseqno`) BLOCK_SIZE 16384,
    KEY `idx_cb_gl_rpt_gl_extractdata_batch_postdate_flag` (`postdate`, `flag`) BLOCK_SIZE 16384,
    KEY `idx_cb_gl_rpt_gl_extractdata_batch_postdate_fundtypcd` (`postdate`, `fundtypcd`) BLOCK_SIZE 16384,
    KEY `idx_cb_gl_rpt_gl_extractdata_batch_postdate` (`postdate`) BLOCK_SIZE 16384
    );

create table cb_dep_deprtxn_40 (
    `rtxntypcd` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '交易类型',
    `currrtxnstatcd` varchar(4) COLLATE utf8mb4_bin NOT NULL COMMENT '交易状态',
    `acctnbr` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '账号',
    `postdate` date DEFAULT NULL COMMENT '交易日期'
    );

EXPLAIN SELECT A.acctnbr,
       A.curracctstatcd,
       D.balcatcd,
       'GINT' BALTYP
       FROM   cb_dep_acctdep_40 A,
       cb_dep_acctbal_40 D
       WHERE  A.acctnbr = D.acctnbr
       AND D.baltypcd = 'GINT'
       AND ( A.curracctstatcd IN ( 'ACT' )
           OR ( A.curracctstatcd IN ( 'CLS' )
             AND EXISTS (SELECT 'x'
               FROM   cb_dep_deprtxn_40
               WHERE  rtxntypcd IN ( 'CLS', 'CLST' )
               AND currrtxnstatcd = 'C'
               AND acctnbr = A.acctnbr
               AND postdate = '2018-12-18 00:00:00') ) )
       AND A.firstrtxnamt > 0
       AND NOT EXISTS (SELECT acctnbr
           FROM   cb_dep_acctbal_40 E
           WHERE  D.acctnbr = E.acctnbr
           AND D.balcatcd = E.balcatcd
           AND D.baltypcd = E.baltypcd
           AND E.effdate = '2018-12-18 00:00:00')
       LIMIT  0, 500;
