  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
) ;

CREATE TABLE `bb` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `cc` (
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
) ;

EXPLAIN SELECT table1 . col_varchar_key AS field1,
       table1 . col_varchar_key AS field2
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (C AS SUBQUERY1_t1
               INNER JOIN BB AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int_key` = SUBQUERY1_t1 . `col_int`))
         WHERE (SUBQUERY1_t1 . `col_varchar_10_key` >= SUBQUERY1_t1 . `col_varchar_20`
                OR SUBQUERY1_t1 . `col_varchar_20` >= 's') ) AS table1
      INNER JOIN ((CC AS table2
                   RIGHT OUTER JOIN B AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_20_key`
                                                    OR (table2 . `col_varchar_key`,
                                                        table3 . `col_varchar_10`) IN
                                                      (SELECT SUBQUERY2_t1 . `col_varchar_10_key` AS SUBQUERY2_field1,
                                                              SUBQUERY2_t2 . `col_varchar_20` AS SUBQUERY2_field2
                                                       FROM (CC AS SUBQUERY2_t1
                                                             RIGHT  JOIN (C AS SUBQUERY2_t2
                                                                          INNER JOIN C AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `pk` = SUBQUERY2_t2 . `col_int`)) ON (SUBQUERY2_t3 . `pk` = SUBQUERY2_t2 . `col_int`))
                                                       WHERE (SUBQUERY2_t3 . `col_varchar_10` IN
                                                                (SELECT 241
                                                                 UNION SELECT 5)
                                                              OR EXISTS (
                                                                           (SELECT DISTINCT CHILD_SUBQUERY2_t1 . `pk` AS CHILD_SUBQUERY2_field1
                                                                            FROM (B AS CHILD_SUBQUERY2_t1
                                                                                  INNER JOIN ((C AS CHILD_SUBQUERY2_t2
                                                                                               RIGHT  JOIN CC AS CHILD_SUBQUERY2_t3 ON (CHILD_SUBQUERY2_t3 . `col_varchar_key` = CHILD_SUBQUERY2_t2 . `col_varchar_key`))) ON (CHILD_SUBQUERY2_t3 . `col_int_key` = CHILD_SUBQUERY2_t2 . `col_int_key`))
                                                                            WHERE CHILD_SUBQUERY2_t1 . `col_varchar_20` != CHILD_SUBQUERY2_t1 . `col_varchar` ))) )))) ON (table3 . `col_int_key` = table2 . `pk`))
WHERE (table1 . `col_varchar_20` >
         (SELECT MIN(DISTINCT SUBQUERY3_t2 . `col_varchar_10`) AS SUBQUERY3_field1
          FROM (C AS SUBQUERY3_t1
                LEFT OUTER JOIN C AS SUBQUERY3_t2 ON (SUBQUERY3_t2 . `col_int_key` = SUBQUERY3_t1 . `col_int`))))
  AND (table3 . `pk` NOT IN
         (SELECT SUBQUERY4_t1 . `pk` AS SUBQUERY4_field1
          FROM (B AS SUBQUERY4_t1
                INNER JOIN (CC AS SUBQUERY4_t2
                            INNER JOIN B AS SUBQUERY4_t3 ON (SUBQUERY4_t3 . `pk` = SUBQUERY4_t2 . `pk`)) ON (SUBQUERY4_t3 . `col_varchar_key` = SUBQUERY4_t2 . `col_varchar_key`))
          GROUP BY SUBQUERY4_field1)
       AND table1 . `col_varchar_20_key` IS NOT NULL)
GROUP BY field1,
         field2
ORDER BY 1,
         field1,
         field2;
