EXPLAIN SELECT 1
FROM   (   cc AS table1
    INNER JOIN ( ( a AS table2 RIGHT JOIN (SELECT col_varchar_key, col_varchar, col_int_key FROM c) AS table3
        ON ( table3 . `col_varchar_key` = table2 . `col_varchar_key` ) ) ) ON ( table3 . `col_varchar` = table2 . `col_varchar_key` OR table3 . `col_int_key` =2 ) )
  WHERE  ( EXISTS (SELECT 1 FROM  c WHERE  `col_int_key` > table1 . `pk`) );
