  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL
) ;

CREATE TABLE `cc` (
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL
) ;

EXPLAIN SELECT DISTINCT table2 . col_varchar_key AS field1,
                table2 . col_varchar_10_key AS field2,
                MAX(table1 . `col_int`) AS field3,
                MIN(table1 . `col_varchar_10_key`) AS field4,
                MAX(table2 . `col_int`) AS field5,
                MAX(table2 . `pk`) AS field6
FROM (B AS table1
      INNER JOIN BB AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10_key`))
WHERE (NOT EXISTS
         (SELECT SUBQUERY1_t1 . `col_int` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                RIGHT  JOIN (B AS SUBQUERY1_t2
                             INNER JOIN BB AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`)) ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int`))
          WHERE SUBQUERY1_t1 . `col_varchar` >= table1 . `col_varchar_20_key`
            AND SUBQUERY1_t2 . `col_varchar_20_key` = SUBQUERY1_t3 . `col_varchar_key` ))
  OR (table1 . `col_int_key` > 74
      AND table1 . `col_int_key` < (74 + 60)
      OR table1 . `col_int_key` > 74
      AND table1 . `col_int_key` < (74 + 117))
  AND (table1 . `col_int_key` > table1 . `col_int`
       AND table1 . `pk` >= table2 . `pk`)
GROUP BY field1,
         field2
HAVING table2 . `col_varchar_10_key` != ANY
  (SELECT SUBQUERY2_t1 . `col_varchar_10_key` AS SUBQUERY2_field1
   FROM (CC AS SUBQUERY2_t1
         INNER JOIN D AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_10`))
   GROUP BY SUBQUERY2_field1)
ORDER BY 1,
         field1,
         field2,
         field3,
         field4,
         field5,
         field6;
