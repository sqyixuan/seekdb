EXPLAIN SELECT /*+ TOPK (50 50)  */ ALL concat(t1.c0,'') FROM  t1 LEFT  OUTER JOIN t3 ON CAST((! (((NOT (concat(t1.c0,'')))) IS TRUE)) AS SIGNED),  t0 LEFT  OUTER JOIN t2 ON concat(t2.c0,'') WHERE t0.c1;
