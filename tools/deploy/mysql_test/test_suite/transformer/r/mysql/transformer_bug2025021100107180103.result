drop table if exists t1, t2;
create table t1(a int, b int, c int);
create table t2(d int, e int, f int);
result_format: 4
# 所有 join 条件中都包含 generated table 的聚合列, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |HASH JOIN            |    |1       |6           |
|1 |├─TABLE FULL SCAN    |t1  |1       |3           |
|2 |└─SUBPLAN SCAN       |v   |1       |3           |
|3 |  └─HASH GROUP BY    |    |1       |3           |
|4 |    └─TABLE FULL SCAN|t2  |1       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [v.total_f]), filter(nil), rowset=16
      equal_conds([t1.a = v.max_e + v.d], [cast(t1.b, DECIMAL_INT(33, 0)) = v.total_f]), other_conds(nil)
  1 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([v.max_e], [v.d], [v.total_f]), filter(nil), rowset=16
      access([v.max_e], [v.d], [v.total_f])
  3 - output([t2.d], [T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)]), filter(nil), rowset=16
      group([t2.d]), agg_func([T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)])
  4 - output([t2.d], [t2.e], [t2.f]), filter(nil), rowset=16
      access([t2.d], [t2.e], [t2.f]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true

# 有一个 join 条件只包含 generated table 的非聚合列, 可以做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c = v.d
;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |HASH GROUP BY      |    |1       |6           |
|1 |└─HASH JOIN        |    |1       |5           |
|2 |  ├─TABLE FULL SCAN|t1  |1       |3           |
|3 |  └─TABLE FULL SCAN|t2  |1       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [T_FUN_SUM(t2.f)]), filter([t1.a = T_FUN_MAX(t2.e) + t2.d], [cast(t1.b, DECIMAL_INT(33, 0)) = T_FUN_SUM(t2.f)]), rowset=16
      group([t1.__pk_increment]), agg_func([T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)])
  1 - output([t1.__pk_increment], [t1.a], [t2.d], [t1.b], [t2.e], [t2.f]), filter(nil), rowset=16
      equal_conds([t1.c = t2.d]), other_conds(nil)
  2 - output([t1.__pk_increment], [t1.a], [t1.b], [t1.c]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([t2.d], [t2.e], [t2.f]), filter(nil), rowset=16
      access([t2.d], [t2.e], [t2.f]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true

#  t1.c > v.d 只包含 generated table 的非聚合列, 但它不是 join (等值) 条件, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c > v.d
;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |HASH JOIN            |    |1       |6           |
|1 |├─TABLE FULL SCAN    |t1  |1       |3           |
|2 |└─SUBPLAN SCAN       |v   |1       |3           |
|3 |  └─HASH GROUP BY    |    |1       |3           |
|4 |    └─TABLE FULL SCAN|t2  |1       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [v.total_f]), filter(nil), rowset=16
      equal_conds([t1.a = v.max_e + v.d], [cast(t1.b, DECIMAL_INT(33, 0)) = v.total_f]), other_conds([t1.c > v.d])
  1 - output([t1.a], [t1.b], [t1.c]), filter(nil), rowset=16
      access([t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([v.max_e], [v.d], [v.total_f]), filter(nil), rowset=16
      access([v.max_e], [v.d], [v.total_f])
  3 - output([t2.d], [T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)]), filter(nil), rowset=16
      group([t2.d]), agg_func([T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)])
  4 - output([t2.d], [t2.e], [t2.f]), filter(nil), rowset=16
      access([t2.d], [t2.e], [t2.f]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true

# v.d > 0 只包含 generated table 的非聚合列, 但它不是 join (等值) 条件, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and v.d > 0
;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |HASH JOIN            |    |1       |5           |
|1 |├─SUBPLAN SCAN       |v   |1       |3           |
|2 |│ └─HASH GROUP BY    |    |1       |3           |
|3 |│   └─TABLE FULL SCAN|t2  |1       |3           |
|4 |└─TABLE FULL SCAN    |t1  |1       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [v.total_f]), filter(nil), rowset=16
      equal_conds([t1.a = v.max_e + v.d], [cast(t1.b, DECIMAL_INT(33, 0)) = v.total_f]), other_conds(nil)
  1 - output([v.max_e], [v.d], [v.total_f]), filter(nil), rowset=16
      access([v.max_e], [v.d], [v.total_f])
  2 - output([t2.d], [T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)]), filter(nil), rowset=16
      group([t2.d]), agg_func([T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)])
  3 - output([t2.d], [t2.e], [t2.f]), filter([t2.d > 0]), rowset=16
      access([t2.d], [t2.e], [t2.f]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

# 优化器版本号低于 4.3.5.2 时, 上述场景都会做 groupby pullup
explain select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.5.1') */ t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
;
Query Plan
=============================================================
|ID|OPERATOR                     |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |HASH GROUP BY                |    |1       |5           |
|1 |└─NESTED-LOOP JOIN CARTESIAN |    |1       |5           |
|2 |  ├─TABLE FULL SCAN          |t2  |1       |3           |
|3 |  └─MATERIAL                 |    |1       |3           |
|4 |    └─TABLE FULL SCAN        |t1  |1       |3           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [T_FUN_SUM(t2.f)]), filter([t1.a = T_FUN_MAX(t2.e) + t2.d], [cast(t1.b, DECIMAL_INT(33, 0)) = T_FUN_SUM(t2.f)]), rowset=16
      group([t1.__pk_increment], [t2.d]), agg_func([T_FUN_MAX(t2.e)], [T_FUN_SUM(t2.f)])
  1 - output([t1.__pk_increment], [t2.d], [t1.a], [t2.e], [t2.f], [t1.b]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  2 - output([t2.d], [t2.e], [t2.f]), filter(nil), rowset=16
      access([t2.d], [t2.e], [t2.f]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  3 - output([t1.__pk_increment], [t1.a], [t1.b]), filter(nil), rowset=16
  4 - output([t1.__pk_increment], [t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

