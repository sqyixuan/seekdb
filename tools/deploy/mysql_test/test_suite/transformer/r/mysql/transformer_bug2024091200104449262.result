      sort_keys([cast(t1.id, CHAR(1048576)), ASC])
  1 - output([cast(t1.id, CHAR(1048576))], [timestamp(t2.real_time)]), filter(nil), rowset=16
      equal_conds([t1.id = t3.id]), other_conds(nil)
  2 - output([cast(t1.id, CHAR(1048576))], [t1.id], [timestamp(t2.real_time)]), filter(nil), rowset=16
      equal_conds([t1.id = t2.id]), other_conds(nil)
  3 - output([t2.id], [timestamp(t2.real_time)]), filter([timestamp(t2.real_time) >= timestamp(cast('2024-09-01 00:00:00.0', MYSQL_DATETIME(-1, -1)))]), rowset=16
      access([t2.id], [t2.real_time]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t1.id], [cast(t1.id, CHAR(1048576))]), filter([cast(t1.id, CHAR(1048576)) IS NOT NULL]), rowset=16
      access([t1.id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([t3.id]), filter(nil), rowset=16
