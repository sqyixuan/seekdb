drop table if exists t1, t2;
drop table if exists comm_selfbalancerule, comm_funduse, comm_selfbalanceitem;
create table t1(c1 int, c2 int, c3 int, unique index i1(c1));
create table t2(c1 int, c2 int, c3 int, unique index i1(c1));
insert into t1 values (1,1,1),(2,2,2);
insert into t2 values (1,1,1),(2,2,2);
CREATE TABLE comm_selfbalancerule(
fundusecode VARCHAR(20) NOT NULL,
fundprop CHAR(1) NOT NULL,
market VARCHAR(2),
checkmode CHAR(1),
acctflag CHAR(1),
dvpflag CHAR(1),
tradesiteflag CHAR(1),
checkclearflag CHAR(1),
difrange NUMERIC(20,2),
fundpurposecodedif VARCHAR(20),
fundpurposecodeerro VARCHAR(20),
PRIMARY KEY (fundusecode,fundprop)
);
CREATE TABLE comm_funduse(
fundusecode VARCHAR(20) NOT NULL,
fundusename VARCHAR(128),
fundsetttype VARCHAR(20),
market VARCHAR(2),
funduseclass CHAR(1),
fundusesource CHAR(1),
acctflag CHAR(1),
manualflag CHAR(1),
auxtype CHAR(1),
creditbusitype CHAR(1),
remark VARCHAR(128),
PRIMARY KEY (fundusecode)
);
CREATE TABLE comm_selfbalanceitem(
fundusecode VARCHAR(20) NOT NULL,
fundusecodecheck VARCHAR(20) NOT NULL,
fundprop CHAR(1) NOT NULL,
PRIMARY KEY (fundusecode,fundusecodecheck,fundprop)
);
