select a.*  from comm_selfbalancerule a 
left join comm_funduse b on a.fundusecode = b.fundusecode    
WHERE  1=1  
and a.fundusecode = '010002' 
and b.fundusename = '交易清算印花税'
and a.fundusecode in (select c.fundusecode from comm_selfbalanceitem c        
left join comm_funduse d on c.fundusecodecheck = d.fundusecode 
where 1=1  
and c.fundusecodecheck = '110000' 
and d.fundusename = '国债交易清算'
)    
order by a.fundusecode;
