       [a.fundpurposecodeerro]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  1 - output([a.fundusecode], [a.fundprop], [a.market], [a.checkmode], [a.acctflag], [a.dvpflag], [a.tradesiteflag], [a.checkclearflag], [a.difrange], [a.fundpurposecodedif],
       [a.fundpurposecodeerro]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  2 - output([a.fundusecode], [a.fundprop], [a.market], [a.checkmode], [a.acctflag], [a.dvpflag], [a.tradesiteflag], [a.checkclearflag], [a.difrange], [a.fundpurposecodedif],
       [a.fundpurposecodeerro]), filter(nil), rowset=16
      access([a.fundusecode], [a.fundprop], [a.market], [a.checkmode], [a.acctflag], [a.dvpflag], [a.tradesiteflag], [a.checkclearflag], [a.difrange], [a.fundpurposecodedif],
       [a.fundpurposecodeerro]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([a.fundusecode], [a.fundprop]), range(010002,MIN ; 010002,MAX), 
      range_cond([a.fundusecode = '010002'])
