drop table if exists t1, t2;
create table t1(c1 varchar(10) collate utf8mb4_bin primary key);
create table t2(c1 varchar(10) collate utf8mb4_bin, foreign key f1 (c1) references t1(c1));
insert into t1 values (' ');
insert into t2 values ('   ');
select length(t1.c1)  from t1,t2 where t1.c1 = t2.c1;
length(t1.c1)
1
select /*+no_rewrite*/ length(t1.c1)  from t1,t2 where t1.c1 = t2.c1;
length(t1.c1)
1
drop table t1, t2;
