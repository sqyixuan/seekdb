drop table if exists timepk, cool_deal_record_201810, t1n213sk, t_sys_menu;
create table timepk(id int, classtime time, primary key(classtime));
insert into timepk values(1,'10:30:00');
CREATE TABLE `cool_deal_record_201810` (
`deal_record_id` int(11) NOT NULL AUTO_INCREMENT,
`business_id` varchar(11) DEFAULT NULL,
`door_id` varchar(11) DEFAULT NULL,
`out_trade_id` varchar(50) DEFAULT NULL,
`pay_type` varchar(10) DEFAULT NULL,
`pay_pass` varchar(10) NOT NULL DEFAULT '010',
`money` varchar(100) DEFAULT NULL,
`regtime` varchar(20) DEFAULT NULL,
`from_business_trade_id` varchar(128) DEFAULT NULL,
`openpl_secret_id` varchar(100) DEFAULT NULL,
`order_type` int(2) DEFAULT NULL ,
`status` int(11) DEFAULT '0' ,
`device_id` int(11) DEFAULT NULL ,
`attach` varchar(255) DEFAULT NULL ,
`pay_log_id` varchar(40) DEFAULT NULL ,
`remark_one_value` varchar(255) DEFAULT NULL ,
`remark_two_value` varchar(255) DEFAULT NULL ,
`remark_three_value` varchar(255) DEFAULT NULL ,
`user_id` varchar(11) DEFAULT NULL ,
`body` varchar(255) DEFAULT NULL ,
PRIMARY KEY (`deal_record_id`),
UNIQUE KEY `uiq_out_trade_id` (`out_trade_id`),
UNIQUE KEY `business_trade_id` (`business_id`,`from_business_trade_id`),
KEY `origin_trade_no` (`from_business_trade_id`),
KEY `pay_log_id` (`pay_log_id`)
) ENGINE=InnoDB AUTO_INCREMENT=320914 DEFAULT CHARSET=utf8 ;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `t1n213sk` (
`c1` varbinary(1),
`c2` varbinary(1),
`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
CREATE TABLE `t_sys_menu` (
`menuID` int(11) NOT NULL AUTO_INCREMENT COMMENT '菜单标识',
`parentID` int(11) DEFAULT NULL COMMENT '父级菜单标识',
`menuName` varchar(300) NOT NULL COMMENT '菜单名',
`menuURL` varchar(300) DEFAULT NULL COMMENT '菜单地址',
`status` int(11) DEFAULT '1' COMMENT '状态\n            1 正常\n            2 删除',
`menuLevel` int(11) NOT NULL COMMENT '菜单级别',
`menuOrder` int(11) NOT NULL COMMENT '菜单显示顺序',
`menuResourceKey` varchar(300) DEFAULT NULL COMMENT '菜单资源文件key，用于国际化',
`moduleName` varchar(300) DEFAULT NULL COMMENT '模块标识',
`iconName` varchar(300) DEFAULT NULL COMMENT '菜单图标名称',
`isVirtualMenu` tinyint(4) DEFAULT '0',
`menuKey` char(100) DEFAULT NULL COMMENT '菜单Key 用于定位菜单使用',
PRIMARY KEY (`menuID`)
) ENGINE=InnoDB AUTO_INCREMENT=141 DEFAULT CHARSET=utf8 COMMENT='菜单表\r\nWebServer：读/写 ';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
explain outline SELECT     subq_1.c0 AS c0
FROM       (
(
SELECT
CASE
WHEN 8 + ref_0.id THEN ref_0.classtime
ELSE ref_0.classtime
END         AS c0,
22          AS c1,
ref_0.id    AS c2
FROM   test.timepk AS ref_0
WHERE  ref_0.id >= 93 limit 112) AS subq_0
RIGHT JOIN
(
SELECT     ref_1.out_trade_id AS c0
FROM       (test.cool_deal_record_201810 AS ref_1
INNER JOIN test.t1n213sk                 AS ref_2
ON         (
ref_1.order_type = ref_2.c3 ))
WHERE      (
ref_1.status / ref_1.order_type)
AND        (
ref_1.pay_type IS NULL)) AS subq_1
ON         (((
subq_0.c1 <> subq_0.c1)
AND        (
subq_0.c1 & subq_0.c2))
OR         (((
subq_0.c1
OR         subq_0.c2)
AND        (
subq_0.c1 +
(
SELECT menuid
FROM   test.t_sys_menu limit 1 offset 2) ))
AND        (
28 IS NULL))))
WHERE      (
length( cast(subq_1.c0 AS char)) | subq_0.c2)
AND        (
subq_0.c0 IS NULL) limit 80 FOR UPDATE ;
