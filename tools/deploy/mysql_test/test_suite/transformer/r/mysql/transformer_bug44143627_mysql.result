drop table if exists t1;
drop table if exists t2;
drop function if exists n_1;
create table t1(id int , s1 int, s2 int);
insert into t1(id,s1,s2) values (1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
create table t2(id int(9) ,s1 int, s2 int);
create function n_1() returns int not deterministic
begin
insert into t2 values(1,0,1);
return 6;
end
