      exec_params_(nil), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  2 - output(nil), filter(nil)
      conds(nil), nl_params_(nil), use_batch=false
  3 - output(nil), filter(nil)
      access(nil)
  4 - output([(T_OP_ASSIGN, 'a', '01110')]), filter(nil)
      values({(T_OP_ASSIGN, 'a', '01110')})
  5 - output(nil), filter(nil)
      access(nil)
  6 - output([1]), filter(nil)
      access(nil), partitions(p0)
      limit(4), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  7 - output([t.c1]), filter([cast(t.c1, DECIMAL(11, 0)) = cast(('a'), DECIMAL(-1, -1))])
      access([t.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t.__pk_increment]), range(MIN ; MAX)always true
  8 - output([(T_OP_ASSIGN, 'a', tt.c2)]), filter([cast(tt.c2, DECIMAL(11, 0)) = cast(('a'), DECIMAL(-1, -1))])
      access([tt.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([tt.__pk_increment]), range(MIN ; MAX)always true
