EXPLAIN select T3.* from (select @codes as blorgNosYYY, (select @codes := GROUP_CONCAT(BLORG_NO) from FM_BRANCH where FIND_IN_SET( AFLT_SUPER_NO, @codes)) as T1 from FM_BRANCH, (select @codes := 1359) T4 where @codes is not null) T2, FM_BRANCH T3 where FIND_IN_SET( T3.BLORG_NO, T2.blorgNosYYY ) order by BLORG_NO;
Query Plan
==========================================================================
|ID|OPERATOR                             |NAME     |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------------
|0 |NESTED-LOOP JOIN                     |         |5       |60          |
|1 |├─DISTRIBUTED TABLE FULL SCAN        |T3       |3       |3           |
|2 |└─MATERIAL                           |         |3       |58          |
|3 |  └─SUBPLAN SCAN                     |T2       |3       |57          |
|4 |    └─SUBPLAN FILTER                 |         |3       |57          |
|5 |      ├─NESTED-LOOP JOIN             |         |3       |3           |
|6 |      │ ├─SUBPLAN SCAN               |T4       |1       |1           |
|7 |      │ │ └─EXPRESSION               |         |1       |1           |
|8 |      │ └─DISTRIBUTED TABLE FULL SCAN|FM_BRANCH|3       |3           |
|9 |      └─SCALAR GROUP BY              |         |1       |18          |
|10|        └─DISTRIBUTED TABLE FULL SCAN|FM_BRANCH|3       |18          |
==========================================================================
