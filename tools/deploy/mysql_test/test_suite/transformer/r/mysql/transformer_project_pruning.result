result_format: 4
explain_protocol: 2
##test hierarchical query
drop table if exists t1;
drop table if exists t2;
drop table if exists fm_branch;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

##bug: 
EXPLAIN select risk_class
from (
         select (select c1
                 from t1 t
                 where t.c1 = @a) risk_class,
                (select @a := tt.c2
                 from t2 tt
                 where tt.c2 = @a) parent_class
         from (select 1 from t2 limit 4) vir,
              (select @a := '01110') vars
     ) x;
Query Plan
===================================================================
|ID|OPERATOR                           |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |SUBPLAN SCAN                       |x   |3       |111         |
|1 |└─SUBPLAN FILTER                   |    |3       |111         |
|2 |  ├─NESTED-LOOP JOIN CARTESIAN     |    |3       |3           |
|3 |  │ ├─SUBPLAN SCAN                 |vars|1       |1           |
|4 |  │ │ └─EXPRESSION                 |    |1       |1           |
|5 |  │ └─SUBPLAN SCAN                 |vir |3       |3           |
|6 |  │   └─DISTRIBUTED TABLE FULL SCAN|t2  |3       |3           |
|7 |  ├─DISTRIBUTED TABLE FULL SCAN    |t   |3       |18          |
|8 |  └─DISTRIBUTED TABLE FULL SCAN    |tt  |3       |18          |
===================================================================
