);
explain SELECT COUNT(table2 . `pk`) AS field1,
table1 . col_varchar_20_key AS field2
FROM (
(SELECT SUBQUERY1_t2 . *
FROM (C AS SUBQUERY1_t1
RIGHT  JOIN (CC AS SUBQUERY1_t2
INNER JOIN C AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `col_varchar_20` = SUBQUERY1_t2 . `col_varchar_key`)) ON (SUBQUERY1_t3 . `col_varchar_key` = SUBQUERY1_t2 . `col_varchar_key`))
WHERE SUBQUERY1_t1 . `col_int_key` <= 6 ) AS table1
LEFT OUTER JOIN
(SELECT SUBQUERY2_t1 . *
FROM (BB AS SUBQUERY2_t1
INNER JOIN B AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_int_key` = SUBQUERY2_t1 . `pk`))
WHERE SUBQUERY2_t2 . `col_varchar_10_key` >= SUBQUERY2_t1 . `col_varchar_20_key` ) AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar`))
WHERE (table1 . `col_int_key` !=
(SELECT MIN(SUBQUERY3_t1 . `pk`) AS SUBQUERY3_field1
FROM C AS SUBQUERY3_t1
WHERE SUBQUERY3_t1 . `col_varchar` IN
(SELECT CHILD_SUBQUERY1_t1 . `col_varchar_20` AS CHILD_SUBQUERY3_field1
FROM (CC AS CHILD_SUBQUERY1_t1
RIGHT OUTER JOIN ((C AS CHILD_SUBQUERY1_t2
INNER JOIN CC AS CHILD_SUBQUERY1_t3 ON (CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar_key`))) ON (CHILD_SUBQUERY1_t3 . `col_varchar_10_key` = CHILD_SUBQUERY1_t2 . `col_varchar_key`))
WHERE CHILD_SUBQUERY1_t2 . `pk` > SUBQUERY3_t1 . `pk` ) ))
AND (table1 . `pk` NOT BETWEEN 241 AND (241 + 167)
OR table1 . `pk` BETWEEN 241 AND (241 + 54))
OR (table1 . `pk` != table1 . `col_int_key`
      AND table1 . `col_varchar_10` > table2 . `col_varchar_key`)
GROUP BY field2
ORDER BY 1,
field1,
field2
;
