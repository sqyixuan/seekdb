CREATE TABLE table0_bigint(
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`pk` bigint(20) NOT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
PRIMARY KEY (`pk`)
);
SELECT CAST(CONCAT(CAST(CONCAT(col_char_20, SUBSTR('v', 1, 20)) AS CHAR(100)), col_char_20) AS CHAR(100))
FROM table0_bigint
WHERE CAST(CONCAT(col_char_20, SUBSTR((
SELECT GROUP_CONCAT(99 ORDER BY (
SELECT coalesce((
SELECT SUM(2335)
FROM table0_bigint
WHERE EXISTS (
SELECT *
FROM table0_bigint table1
INNER JOIN table0_bigint table2 USING (pk)
WHERE table1.col_bigint > ROUND(CEIL(-100))
ORDER BY table1.pk DESC, table1.col_decimal_20_0 ASC, table1.pk
LIMIT 6
)
ORDER BY pk DESC, col_timestamp_6, col_char_20 DESC, pk DESC
), (
SELECT SUM(ROUND(FLOOR(-99999)))
FROM table0_bigint
WHERE SUBSTR('vunm', 1, 20) <> CAST(CONCAT(col_char_20, SUBSTR('g', 1, 20)) AS CHAR(100))
ORDER BY col_decimal_20_0, col_timestamp_6 DESC, col_char_20 ASC, pk
), -100)
) ASC, pk ASC SEPARATOR '')
FROM table0_bigint
WHERE ROUND(ABS(col_decimal_20_0)) > col_decimal_20_0
ORDER BY pk DESC, col_bigint ASC, pk ASC, pk ASC
LIMIT 5, 3
), 1, 20)) AS CHAR(100)) <=> COALESCE(col_char_20, col_char_20, col_char_20)
FOR UPDATE;
