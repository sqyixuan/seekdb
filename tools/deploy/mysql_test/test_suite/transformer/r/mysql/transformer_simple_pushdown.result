drop table if exists t1, t2;
drop view if exists t1_sum, t1_sum_count, t1_sum_with_limit, t1_sum_with_win_func;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
create view t1_sum as (select c1, c2, sum(c3) as agg, case when c2 >= 0 then '+' else '-' end as sign from t1 where c1 < 10 group by c1,c2);
create view t1_sum_count as (select c1, c2, count(agg) as agg_count from t1_sum where sign = '+' group by c2);
create view t1_sum_with_limit as (select c1, c2, sum(c3) as agg, case when c2 >= 0 then '+' else '-' end as sign from t1 where c1 < 10 group by c1,c2 limit 5);
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1', method_opt=>'for all columns size auto');
call dbms_stats.gather_table_stats('TEST', 't2', method_opt=>'for all columns size auto');
explain_protocol: 2
result_format: 4
EXPLAIN select * from t1_sum where c1 = 2 and c2 < 5 and sign = '+';
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |1       |4           |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [T_FUN_SUM(t1.c3)], [CASE WHEN t1.c2 >= 0 THEN '+' ELSE '-' END]), filter(nil), rowset=16
      group([t1.c2]), agg_func([T_FUN_SUM(t1.c3)])
  1 - output([t1.c1], [t1.c2], [t1.c3], [t1.c2 >= 0]), filter([t1.c1 = 2], [t1.c2 < 5], [t1.c2 >= 0]), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1_sum where c1 = 2 and c2 < 5 and sign = '+';
