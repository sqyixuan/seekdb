drop table if exists t1, t2;
create table t1(c1 enum('col1', 'col2'), c2 int);
create table t2(c1 char, c2 int, c3 varchar(10));
insert into t1 values('col1', 2);
insert into t1 values('col2', 3);
insert into t2 values('1', 2, 'col1');
insert into t2 values('2', 2, 'col2');
explain_protocol: 2
result_format: 4
EXPLAIN SELECT /*+use_concat*/ Sum(1)            AS c1,
                       Nullif(T1.C1, 33) AS c2
FROM   T1
WHERE  ( T1.C2 = 1
          OR EXISTS (SELECT 1
                     FROM   DUAL
                     LIMIT  1) );
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |SCALAR GROUP BY  |    |1       |3           |
|1 |└─TABLE FULL SCAN|t1  |2       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(1)], [Nullif(enum_to_inner_type('', t1.c1), cast(33, BIGINT UNSIGNED(-1, 0)))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(1)])
  1 - output([t1.c1]), filter([t1.c2 = 1 OR 1]), rowset=16
      access([t1.c2], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
SELECT /*+use_concat*/ Sum(1)            AS c1,
                       Nullif(T1.C1, 33) AS c2
FROM   T1
WHERE  ( T1.C2 = 1
          OR EXISTS (SELECT 1
                     FROM   DUAL
                     LIMIT  1) );
