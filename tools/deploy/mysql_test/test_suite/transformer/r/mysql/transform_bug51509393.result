drop table if exists `cool_deal_20180817`;
drop table if exists `tenant_obs`;
drop table if exists `cool_refund_card`;
drop table if exists `t_policy`;
drop table if exists `t1h5a3vs`;
drop table if exists `uc_staff_job_info`;
drop table if exists `uc_corporator_account`;
CREATE TABLE `cool_deal_20180817` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=4007427 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

create TABLE `tenant_obs` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `version` int(10) DEFAULT 1 COMMENT '版本号',
  `create_time` timestamp NOT NULL DEFAULT current_timestamp() ON update current_timestamp() COMMENT '创建时间',
  `update_time` timestamp NOT NULL DEFAULT current_timestamp() COMMENT '修改时间',
  `app_id` varchar(32) DEFAULT NULL COMMENT '应用ID',
  `access_code` varchar(52) NOT NULL COMMENT '接入码',
  `bucket_name` varchar(64) NOT NULL COMMENT '桶名',
  `access_key` varchar(64) NOT NULL COMMENT '桶key',
  `secret_key` varchar(64) NOT NULL COMMENT '桶密钥',
  `update_user_id` bigint(20) DEFAULT NULL COMMENT '修改人',
  `create_user_id` bigint(20) DEFAULT NULL COMMENT '创建人',
  `description` varchar(255) DEFAULT NULL COMMENT '备注',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='租户对象存储表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

CREATE TABLE `cool_refund_card` (
  `refund_card_id` int(11) NOT NULL AUTO_INCREMENT ,
  `status` varchar(10) DEFAULT '' ,
  `refund_money` decimal(14,2) DEFAULT '0.00' ,
  `out_trade_id` varchar(35) DEFAULT NULL ,
  `mch_no_sft` varchar(15) DEFAULT '' ,
  `terminal_id` varchar(8) DEFAULT '' ,
  `trace_no` varchar(6) DEFAULT '' ,
  `order_id_sft` varchar(12) DEFAULT '' ,
  `regtime` int(11) DEFAULT '0' ,
  `trade_ref` varchar(20) DEFAULT '' ,
  `trade_result` varchar(2) DEFAULT '0' ,
  `orig_trade_ref` varchar(50) DEFAULT '' ,
  PRIMARY KEY (`refund_card_id`)
) ENGINE=InnoDB AUTO_INCREMENT=34 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

CREATE TABLE `t_policy` (
  `policyID` int(11) NOT NULL AUTO_INCREMENT COMMENT '策略ID',
  `hsmMonitorPeriod` int(11) DEFAULT NULL COMMENT 'HSM性能数据同步时间间隔',
  `vsmMonitorPeriod` int(11) DEFAULT NULL COMMENT 'VSM性能数据同步时间间隔',
  `hsmLogPeriod` int(11) DEFAULT NULL COMMENT 'HSM日志同步时间间隔',
  `vsmLogPeriod` int(11) DEFAULT NULL COMMENT 'VSM日志同步时间间隔',
  PRIMARY KEY (`policyID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='策略表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

CREATE TABLE `uc_corporator_account` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `version` int(11) NOT NULL DEFAULT 1 COMMENT '版本号',
  `create_time` datetime NOT NULL COMMENT '创建时间',
  `create_user_id` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '创建人',
  `certificate_sno` varchar(64) COLLATE utf8_bin NOT NULL COMMENT '统一信用代码',
  `acct_type` varchar(64) COLLATE utf8_bin NOT NULL COMMENT '账号类型',
  `trust_acct_no` varchar(64) COLLATE utf8_bin NOT NULL COMMENT '账号类型为 2001 时，填法定代表人身份证号；账号类型为 2002时，填 Ukey 唯一标识号；账号类型为 2003时，填电子营业执照标识号；账号类型为2004时，填经办人\r\n            ',
  `trust_acct_no_key` varchar(128) COLLATE utf8_bin DEFAULT NULL COMMENT '信任身份标识账号散列值',
  `agent_mobile` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '经办人手机号',
  `agent_name` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '经办人姓名',
  `agent_cert` varchar(64) COLLATE utf8_bin DEFAULT NULL COMMENT '经办人证件号码',
  `agent_cert_key` varchar(128) COLLATE utf8_bin DEFAULT NULL COMMENT '经办人证件号码散列值',
  `agent_cert_type` varchar(12) COLLATE utf8_bin DEFAULT NULL COMMENT '经办人证件类型',
  `agent_cert_begin_date` varchar(12) COLLATE utf8_bin DEFAULT NULL COMMENT '证件有效期起始日期',
  `agent_cert_end_date` varchar(12) COLLATE utf8_bin DEFAULT NULL COMMENT '证件有效期到期日期',
  `agent_channel` varchar(6) COLLATE utf8_bin DEFAULT NULL COMMENT '账号来源代码字段由四位数字组成。其中，第 1、2 位代表省份，代码集为“区划代码”；第 3、4 位代表部委，代码集为“中央部门编码”。部委上报时第 1、2 位为 00，省份上报时第3、4 位为 00',
  `agent_eff_date` varchar(8) COLLATE utf8_bin DEFAULT NULL COMMENT '有效起始日期',
  `agent_exp_date` varchar(8) COLLATE utf8_bin DEFAULT NULL COMMENT '有效结束日期',
  `agent_cert_status` int(11) DEFAULT NULL COMMENT '1，长期，2时间段',
  `agent_accredit_status` int(11) DEFAULT NULL COMMENT '1，长期，2时间段',
  `registered_channel` varchar(6) COLLATE utf8_bin DEFAULT NULL COMMENT '注册渠道（0线上，1线下）',
  `update_time` datetime NOT NULL COMMENT '修改时间',
  `update_user_id` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '修改人',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_certificate_sno` (`certificate_sno`)
) ENGINE=InnoDB AUTO_INCREMENT=47266 DEFAULT CHARSET=utf8 COLLATE=utf8_bin COMMENT='法人账号信息';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

create table if not exists `t1h5a3vs` (
    `c1` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `uc_staff_job_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `version` int(10) NOT NULL DEFAULT 1 COMMENT '版本号',
  `create_time` datetime NOT NULL COMMENT '创建时间',
  `create_user_id` bigint(20) DEFAULT NULL COMMENT '创建人',
  `job_name` varchar(255) NOT NULL COMMENT '岗位名称',
  `sort` bigint(20) DEFAULT NULL COMMENT '排序',
  `org_id` bigint(20) NOT NULL COMMENT '组织ID',
  `job_status` varchar(6) NOT NULL DEFAULT 'US01' COMMENT '状态:US01-生效,US02-失效',
  `update_time` datetime NOT NULL COMMENT '更新时间',
  `update_user_id` bigint(20) DEFAULT NULL COMMENT '更新人',
  `description` varchar(255) DEFAULT NULL COMMENT '备注',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=68 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='系统管理岗位信息';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'

