drop table if exists t_inc_policy,t_dsb_dashboardprivilege;
CREATE TABLE `t_inc_policy` (
`incPolicyID` int(11) NOT NULL AUTO_INCREMENT COMMENT '关联策略标识，流水号',
`incPolicyName` varchar(300) NOT NULL COMMENT '关联策略名称',
`responseType` varchar(20) NOT NULL COMMENT '策略响应类型，使用int，16位掩码方式区分。\n            现有5种方式，预留11位。',
`originType` int(11) NOT NULL COMMENT '数据来源：1. 监控\n    2. 管控日志   3. 系统日志   4.\n  用户日志 7 运行监控',
`description` text COMMENT '规则描述',
`status` int(11) DEFAULT '1' COMMENT '标志：\n            1.正常\n            2.删除            3.旧版本数据',
`enableStatus` int(11) DEFAULT '1' COMMENT '是否起效：\n            1.起效\n            2.停用',
`isSysDefault` tinyint(1) NOT NULL DEFAULT '0' COMMENT '是否是系统缺省告警策略。0：不是，1：是。\n            缺省值为0。',
`incRspDuration` int(11) DEFAULT '0' COMMENT '追加告警响应时长，单位为分钟',
`filterContent` text COMMENT '过滤器内容',
`filterJsonSrc` text,
`updateTime` datetime DEFAULT NULL COMMENT '更新时间，第一次创建既是创建事件。',
`groupID` int(11) DEFAULT NULL,
`version` int(20) DEFAULT '1' COMMENT '版本',
`accumulationType` int(10) DEFAULT '1' COMMENT '时间间隔表达式， 0：禁用, 1:持续型， 2.累加型',
`accumulationTimeInterval` int(50) DEFAULT '0' COMMENT '时间间隔, 以秒为单位',
`accumulationCount` int(50) DEFAULT '0' COMMENT '时间间隔内次数',
PRIMARY KEY (`incPolicyID`)
);
create TABLE `t_dsb_dashboardprivilege` (
`dashboardID` int(11) NOT NULL COMMENT '仪表板流水号',
`userID` int(11) NOT NULL COMMENT '用户流水号',
`displayOrder` int(11) NOT NULL COMMENT '仪表板显示顺序，数值越小越在前面',
`isDisplay` tinyint(4) DEFAULT NULL COMMENT '是否显示',
PRIMARY KEY (`dashboardID`,`userID`)
);
result_format: 4
