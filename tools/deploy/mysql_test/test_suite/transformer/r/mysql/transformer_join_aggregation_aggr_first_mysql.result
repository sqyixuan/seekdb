  2 - output([t1.c1], [t1.c2], [t1.c3]), filter([cast(2 * t1.c2, DECIMAL(15, 0)) > cast(cast(T_FUN_SUM(t2.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t2.c2),
       DECIMAL_INT(20, 0)), DECIMAL(15, 4))]), rowset=256
      group([t1.__pk_increment]), agg_func([T_FUN_SUM(t2.c2)], [T_FUN_COUNT(t2.c2)])
  3 - output([t1.__pk_increment], [t2.c2], [t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
