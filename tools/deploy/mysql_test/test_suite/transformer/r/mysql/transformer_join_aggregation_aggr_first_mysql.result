drop table if exists t1, t2, t3, t4, t5, t_insert;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
create table t3 (c1 int, c2 int, c3 int);
create table t_insert (c1 int, c2 int, c3 int);
create table t4 (c1 varchar(10) collate  utf8_bin, c2 int);
insert into t4 values ('a', 2);
insert into t4 values ('A', 2);
insert into t4 values ('C', 0);
insert into t4 values ('D', 0);
create table t5 (c1 varchar(10) collate utf8_general_ci, c2 int);
insert into t5 values ('a', 1);
insert into t5 values ('A', 4);
alter system minor freeze;
analyze table t1 compute statistics for all columns size auto;
analyze table t2 compute statistics for all columns size auto;
analyze table t3 compute statistics for all columns size auto;
analyze table t_insert compute statistics for all columns size auto;
analyze table t4 compute statistics for all columns size auto;
analyze table t5 compute statistics for all columns size auto;
set autocommit=0;
explain_protocol: 2
result_format: 4
# different subquery comparision op
EXPLAIN select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |HASH JOIN            |     |5       |16          |
|1 |├─SUBPLAN SCAN       |VIEW1|5       |5           |
|2 |│ └─HASH GROUP BY    |     |5       |5           |
|3 |│   └─TABLE FULL SCAN|t2   |10      |3           |
|4 |└─TABLE FULL SCAN    |t1   |50      |6           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      equal_conds([VIEW1.t2.c1 = t1.c1]), other_conds([cast(2 * t1.c2, DECIMAL(15, 0)) > VIEW1.avg(c2)])
  1 - output([VIEW1.avg(c2)], [VIEW1.t2.c1]), filter(nil), rowset=256
      access([VIEW1.avg(c2)], [VIEW1.t2.c1])
  2 - output([cast(cast(T_FUN_SUM(t2.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t2.c2), DECIMAL_INT(20, 0)), DECIMAL(15, 4))], [t2.c1]), filter(nil), rowset=256
      group([t2.c1]), agg_func([T_FUN_SUM(t2.c2)], [T_FUN_COUNT(t2.c2)])
  3 - output([t2.c1], [t2.c2]), filter(nil), rowset=256
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|   10 |   10 |   10 |
|   20 |   20 |   20 |
|   30 |   30 |   30 |
|   40 |   40 |   40 |
|   50 |   50 |   50 |
+------+------+------+
EXPLAIN select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/avg(c2) from t2 where t2.c1 = t1.c1);
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |SUBPLAN FILTER     |    |17      |906         |
|1 |├─TABLE FULL SCAN  |t1  |50      |6           |
|2 |└─SCALAR GROUP BY  |    |1       |18          |
|3 |  └─TABLE FULL SCAN|t2  |2       |18          |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter([cast(2 * t1.c2, DECIMAL(15, 0)) > subquery(1)]), rowset=256
      exec_params_([t1.c1(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([cast(cast(T_FUN_SUM(T_FUN_SUM(t2.c2)), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT_SUM(T_FUN_COUNT(t2.c2)), DECIMAL_INT(20, 0)), DECIMAL(15, 4))]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_SUM(T_FUN_SUM(t2.c2))], [T_FUN_COUNT_SUM(T_FUN_COUNT(t2.c2))])
  3 - output([T_FUN_SUM(t2.c2)], [T_FUN_COUNT(t2.c2)]), filter([t2.c1 = :0]), rowset=256
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true, 
      pushdown_aggregation([T_FUN_SUM(t2.c2)], [T_FUN_COUNT(t2.c2)])
select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/avg(c2) from t2 where t2.c1 = t1.c1);
