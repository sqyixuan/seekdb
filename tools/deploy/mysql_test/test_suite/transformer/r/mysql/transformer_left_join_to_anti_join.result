drop table if exists t1, t2, t3, t4, t5, t6;
create table t1(a int, b int, c int);
create table t2(a int primary key, b int, c int);
create table t3(a int, b int not null, c int);
create table t4(a int, b int);
create table t5(a int, b int, c int, primary key(a, b, c)) partition by hash(a) partitions 4;
create table t6(a int, b int, c int, primary key(a, b, c)) partition by hash(a) partitions 4;
insert into t1 values (NULL, NULL, NULL), (1, NULL, 2), (2, 2, 2), (2, 3, 3), (3, 3, NULL), (4, 4, 5);
insert into t2 values (1, 1, 1), (2, 2, 3), (3, NULL, NULL);
insert into t3 values (NULL, 1, NULL), (2, 2, 2), (1, 3, NULL), (4, 5, 6);
insert into t5 values (0, 1, 1), (2, 3, 4), (3, 4, 5);
insert into t6 values (1, 1, 1), (2, 3, 4), (5, 4, 5);
explain_protocol: 2
result_format: 4
### on condition含一个表达式，且有一个where is null，要求where条件中至少有一列满足以下两种条件之一：1）在on condtion的右侧列出现；2）是右表中的列且有not null的限制
### 在on condition中出现，测试where带非null条件以及order by
EXPLAIN select * from t1 left join t2 on t1.a = t2.a where t2.a is null and t1.b > 0 order by t1.a;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |MERGE ANTI JOIN    |    |2       |6           |
|1 |├─SORT             |    |4       |4           |
|2 |│ └─TABLE FULL SCAN|t1  |4       |3           |
|3 |└─TABLE FULL SCAN  |t2  |3       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [t1.c], [cast(NULL, INT(11, 0))], [cast(NULL, INT(11, 0))], [cast(NULL, INT(11, 0))]), filter(nil), rowset=16
      equal_conds([t1.a = t2.a]), other_conds(nil)
      merge_directions([ASC])
  1 - output([t1.a], [t1.b], [t1.c]), filter(nil), rowset=16
      sort_keys([t1.a, ASC])
  2 - output([t1.a], [t1.b], [t1.c]), filter([t1.b > 0]), rowset=16
      access([t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([t2.a]), filter(nil), rowset=16
      access([t2.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.a]), range(MIN ; MAX)always true
select * from t1 left join t2 on t1.a = t2.a where t2.a is null and t1.b > 0 order by t1.a;
+------+------+------+---+------+------+
| a    | b    | c    | a | b    | c    |
+------+------+------+---+------+------+
|    4 |    4 |    5 | NULL | NULL | NULL |
+------+------+------+---+------+------+
EXPLAIN select /*+NO_REWRITE*/ * from t1 left join t2 on t1.a = t2.a where t2.a is null and t1.b > 0 order by t1.a;
