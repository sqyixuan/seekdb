DROP TABLE IF EXISTS t1, t2, t3;
result_format: 4
create table t1 as select 1 > 0;
create table t2 as select not 1 > 0;
create table t3 as select not 0.25;

desc t1;
+-------+--------+------+-----+---------+-------+
| Field | Type   | Null | Key | Default | Extra |
+-------+--------+------+-----+---------+-------+
| 1 > 0 | int(1) | NO   |     | 0       |       |
+-------+--------+------+-----+---------+-------+
desc t2;
+-----------+--------+------+-----+---------+-------+
| Field     | Type   | Null | Key | Default | Extra |
+-----------+--------+------+-----+---------+-------+
| not 1 > 0 | int(1) | NO   |     | 0       |       |
+-----------+--------+------+-----+---------+-------+
desc t3;
+----------+--------+------+-----+---------+-------+
| Field    | Type   | Null | Key | Default | Extra |
+----------+--------+------+-----+---------+-------+
| not 0.25 | int(1) | NO   |     | 0       |       |
+----------+--------+------+-----+---------+-------+

drop table t1, t2, t3;
