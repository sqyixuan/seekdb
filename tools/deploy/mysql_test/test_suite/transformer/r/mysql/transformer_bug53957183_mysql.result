drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int);
create table t2(a int, b int, c int);
insert into t1 values (1,1,1);
explain_protocol: 2
result_format: 4
explain with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |RECURSIVE UNION ALL|    |2       |4           |
|1 |├─TABLE FULL SCAN  |t1  |1       |3           |
|2 |└─TABLE FULL SCAN  |cte |1       |1           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])]), filter(nil), rowset=16
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([column_conv(INT,PS:(11,0),NULL,cast(cte.c1 + 1, INT(-1, 0)))], [column_conv(INT,PS:(11,0),NULL,cast(cte.c2 + 1, INT(-1, 0)))]), filter([cte.c1 
      < 10], [cte.c2 = 4 OR cte.c1 = 1]), rowset=16
      access([cte.c2], [cte.c1])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key(nil), range(MIN ; MAX)
with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
+------+------+

explain with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte left join t2 on (1=1) where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;
