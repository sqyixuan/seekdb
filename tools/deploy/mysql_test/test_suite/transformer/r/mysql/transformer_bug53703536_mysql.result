# test const propagate
EXPLAIN BASIC select * from t2 where (@a := c1) and (c1 = 1);
Query Plan
=====================================
|ID|OPERATOR                   |NAME|
-------------------------------------
|0 |DISTRIBUTED TABLE FULL SCAN|t2  |
=====================================
Outputs & filters:
-------------------------------------
  0 - output([t2.c1]), filter([t2.c1 = 1], [(T_OP_ASSIGN, 'a', t2.c1)])
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select * from t2 where (@a := c1) and (c1 = 1);
+------+
| c1   |
+------+
|    1 |
+------+
EXPLAIN BASIC select @a;
Query Plan
====================
|ID|OPERATOR  |NAME|
--------------------
|0 |EXPRESSION|    |
====================
Outputs & filters:
-------------------------------------
  0 - output([('a')]), filter(nil)
      values({('a')})
select @a;
+------+
| @a   |
+------+
|    1 |
+------+

# both transform can happend when the query block does not contain assignment
EXPLAIN BASIC select /*+no_pred_deduce*/ * from (select /*+no_merge*/ c1, c2, c3, case when c2 = 1 then c1 + 3 else c3 + 4 end as expr_to_pullup, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where c1 = 1 and rn <= 3) where c3 > 0;
Query Plan
======================================================
|ID|OPERATOR                         |NAME           |
------------------------------------------------------
|0 |SUBPLAN SCAN                     |ANONYMOUS_VIEW2|
|1 |└─SUBPLAN SCAN                   |ANONYMOUS_VIEW1|
|2 |  └─SORT                         |               |
|3 |    └─DISTRIBUTED TABLE FULL SCAN|t1             |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW2.c1], [ANONYMOUS_VIEW2.c2], [ANONYMOUS_VIEW2.c3], [CASE WHEN ANONYMOUS_VIEW2.c2 = 1 THEN cast(1, INT(11, 0)) + 3 ELSE ANONYMOUS_VIEW2.c3 
      + 4 END], [ANONYMOUS_VIEW2.rn]), filter([ANONYMOUS_VIEW2.c3 > 0])
      access([ANONYMOUS_VIEW2.c1], [ANONYMOUS_VIEW2.c2], [ANONYMOUS_VIEW2.c3], [ANONYMOUS_VIEW2.rn])
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.rn]), filter([ANONYMOUS_VIEW1.rn <= 3], [ANONYMOUS_VIEW1.c1 
      = 1])
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.rn], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3])
  2 - output([t1.c1], [t1.c2], [t1.c3], [CASE WHEN ('part') = t1.c1 THEN (T_OP_ASSIGN, 'rn', ('rn') + 1) ELSE (T_OP_ASSIGN, 'rn', 1) END], [(T_OP_ASSIGN,
       'part', t1.c1)]), filter(nil)
      sort_keys([t1.c1, ASC], [t1.c2, ASC])
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil)
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select /*+no_pred_deduce*/ * from (select /*+no_merge*/ c1, c2, c3, case when c2 = 1 then c1 + 3 else c3 + 4 end as expr_to_pullup, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where c1 = 1 and rn <= 3) where c3 > 0;
+------+------+------+----------------+------+
| c1   | c2   | c3   | expr_to_pullup | rn   |
+------+------+------+----------------+------+
|    1 |    1 |    1 |              4 |    1 |
|    1 |    2 |    2 |              6 |    2 |
|    1 |    3 |    3 |              7 |    3 |
+------+------+------+----------------+------+

drop table t1, t2;
