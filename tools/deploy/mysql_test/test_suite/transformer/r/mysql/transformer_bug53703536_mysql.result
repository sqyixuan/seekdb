drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(2,3,3), (2,4,4), (2,2,2), (2,5,5), (1,3,3), (1,4,4), (1,2,2), (1,1,1);
create table t2(c1 int);
insert into t2 values(1), (2), (3);
set @part = null;
set @rn = 100;
set @a = 0;
explain_protocol: 1
result_format: 4
# test expr pullup
EXPLAIN BASIC select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2);
Query Plan
====================================================
|ID|OPERATOR                       |NAME           |
----------------------------------------------------
|0 |SUBPLAN SCAN                   |ANONYMOUS_VIEW1|
|1 |└─SORT                         |               |
|2 |  └─DISTRIBUTED TABLE FULL SCAN|t1             |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.rn]), filter(nil)
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.rn])
  1 - output([t1.c1], [t1.c2], [t1.c3], [CASE WHEN cast(('part'), DECIMAL(-1, -1)) = cast(t1.c1, DECIMAL(11, 0)) THEN (T_OP_ASSIGN, 'rn', ('rn') + 1) ELSE 
      (T_OP_ASSIGN, 'rn', 1) END], [(T_OP_ASSIGN, 'part', t1.c1)]), filter(nil)
      sort_keys([t1.c1, ASC], [t1.c2, ASC])
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil)
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2);
+------+------+------+------+
| c1   | c2   | c3   | rn   |
+------+------+------+------+
|    1 |    1 |    1 |    1 |
|    1 |    2 |    2 |    2 |
|    1 |    3 |    3 |    3 |
|    1 |    4 |    4 |    4 |
|    2 |    2 |    2 |    1 |
|    2 |    3 |    3 |    2 |
|    2 |    4 |    4 |    3 |
|    2 |    5 |    5 |    4 |
+------+------+------+------+
EXPLAIN BASIC select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where rn <= 3;
Query Plan
====================================================
|ID|OPERATOR                       |NAME           |
----------------------------------------------------
|0 |SUBPLAN SCAN                   |ANONYMOUS_VIEW1|
|1 |└─SORT                         |               |
|2 |  └─DISTRIBUTED TABLE FULL SCAN|t1             |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3], [ANONYMOUS_VIEW1.rn]), filter([ANONYMOUS_VIEW1.rn <= 3])
      access([ANONYMOUS_VIEW1.rn], [ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.c3])
  1 - output([t1.c1], [t1.c2], [t1.c3], [CASE WHEN ('part') = t1.c1 THEN (T_OP_ASSIGN, 'rn', ('rn') + 1) ELSE (T_OP_ASSIGN, 'rn', 1) END], [(T_OP_ASSIGN,
       'part', t1.c1)]), filter(nil)
      sort_keys([t1.c1, ASC], [t1.c2, ASC])
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil)
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where rn <= 3;
+------+------+------+------+
| c1   | c2   | c3   | rn   |
+------+------+------+------+
|    1 |    1 |    1 |    1 |
|    1 |    2 |    2 |    2 |
|    1 |    3 |    3 |    3 |
|    2 |    2 |    2 |    1 |
|    2 |    3 |    3 |    2 |
|    2 |    4 |    4 |    3 |
+------+------+------+------+
EXPLAIN BASIC select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where c1 = 1 and rn <= 3;
