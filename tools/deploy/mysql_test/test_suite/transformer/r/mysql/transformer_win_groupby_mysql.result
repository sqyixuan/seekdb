drop table if exists t1, t1_part;
create table t1(a int, b int, c int, primary key(a,b));
create table t1_part(a int, b int, c int, primary key(a,b)) partition by hash(b) partitions 4;
result_format: 4
explain_protocol: 2
##basic test
EXPLAIN select a, win_value1, sum(b) from (select a, b, sum(c) over() as win_value1 from t1) temp group by a having sum(b) < win_value1;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |MERGE GROUP BY       |    |1       |12          |
|1 |└─SUBPLAN SCAN       |temp|10      |11          |
|2 |  └─WINDOW FUNCTION  |    |10      |11          |
|3 |    └─TABLE FULL SCAN|t1  |10      |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([temp.a], [temp.win_value1], [T_FUN_SUM(temp.b)]), filter([T_FUN_SUM(temp.b) < temp.win_value1]), rowset=16
      group([temp.a]), agg_func([T_FUN_SUM(temp.b)])
  1 - output([temp.a], [temp.win_value1], [temp.b]), filter(nil), rowset=16
      access([temp.a], [temp.win_value1], [temp.b])
  2 - output([t1.a], [t1.b], [T_FUN_SUM(t1.c)]), filter(nil), rowset=16
      win_expr(T_FUN_SUM(t1.c)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([t1.a], [t1.b], [t1.c]), filter(nil), rowset=16
      access([t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.a], [t1.b]), range(MIN,MIN ; MAX,MAX)always true
