## B. pullup 的测试
## pullup 谓词帮助推导上层的谓词
EXPLAIN select t1.c3, V.v3 from t1, 
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t2) V
where t1.c1 = v1 and t1.c1 = 1;
Query Plan
===========================================================
|ID|OPERATOR                   |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |NESTED-LOOP JOIN CARTESIAN |    |1       |3           |
|1 |├─TABLE FULL SCAN          |t1  |1       |3           |
|2 |└─MATERIAL                 |    |1       |3           |
|3 |  └─SUBPLAN SCAN           |V   |1       |3           |
|4 |    └─TABLE FULL SCAN      |t2  |1       |3           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c3], [V.v3]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  1 - output([t1.c3]), filter([t1.c1 = 1]), rowset=16
      access([t1.c1], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([V.v3]), filter(nil), rowset=16
  3 - output([V.v3]), filter(nil), rowset=16
      access([V.v3])
  4 - output([t2.c3]), filter([1 = t2.c1]), rowset=16
      access([t2.c1], [t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select t1.c3, V.v3 from t1, 
