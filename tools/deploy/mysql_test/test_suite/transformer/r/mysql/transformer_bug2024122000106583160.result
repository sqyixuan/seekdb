CREATE TABLE
  IF NOT EXISTS t0 (
    c0 BIGINT (224) COMMENT 'asdf',
    c1 BIGINT (102) COMMENT 'asdf' UNIQUE KEY NOT NULL,
    c2 DATETIME COMMENT 'asdf',
    PRIMARY KEY (c0, c1)
  );
CREATE VIEW v_t0 AS select /*+no_mv_rewrite*/ c0, c1, c2,count(*) as c from t0 group by c0, c1, c2;

EXPLAIN SELECT /*+opt_param('use_hash_rollup', 'disabled') */ 
  SUM(v_t0.c0) AS AF0, * 
FROM v_t0, t0 
GROUP BY v_t0.c1, t0.c1, t0.c0, v_t0.c0, v_t0.c, v_t0.c2 WITH ROLLUP 
HAVING (NOT (((+ ((((-1,'2024-12-20 14:58:49',2) NOT IN ((AF0,'2024-12-20 14:58:49',1), (0,"2024-12-20 14:58:49",v_t0.c1))) )))) != (v_t0.c)));
