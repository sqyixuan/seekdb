drop table if exists t2;
create table t2(c1 int not null);
CREATE or replace VIEW `v1` AS (select /*+ NO_MERGE */`test`.`t2`.`c1` AS `c1` from `test`.`t2`) except (select /*+ NO_MERGE */`t2`.`c1` AS `c1` from `test`.`t2` `t2` where (`t2`.`c1` < 2));
insert into t2 values (1),(2);
result_format: 4
explain_protocol: 2
EXPLAIN SELECT c0, c1, row_number() over () FROM  (SELECT cast(53 NOT IN ( 86, 73, 86) AS decimal) AS c0, c1  FROM  test.v1  AS ref_0 limit 128) AS subq_0;
