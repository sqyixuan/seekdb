drop table if exists t1, t2, t3;
create table t1 (c1 int primary key, c2 int unique not null, c3 int unique, c4 varchar(20), c5 datetime, c6 float);
create table t2 (c1 int primary key, c2 int not null, c3 int not null, unique (c2,c3));
create table t3 (c1 int primary key, c2 int not null, c3 int, unique (c2,c3));
insert into t1 values (1, 10, 5, 'ali', '2022-11-11', 4.56);
insert into t1 values (2, 9, 3, 'baba', '2022-11-10', 5.67);
insert into t1 values (3, 8, null, 'ali', '2022-11-11', 6.78);
insert into t1 values (4, 11, 4, 'baba', '2022-11-10', 7.89);
insert into t2 values (1, 10, 5), (2, 10, 4), (3, 9, 5), (4, 9, 4), (5, 8, 3);
insert into t3 values (1, 10, 5), (2, 10, 4), (3, 9, 5), (4, 9, 4), (5, 8, 3);
result_format: 4
explain_protocol: 2
begin to test bit_and
