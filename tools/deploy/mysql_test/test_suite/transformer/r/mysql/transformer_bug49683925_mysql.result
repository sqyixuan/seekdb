drop table if exists BB;
create table BB(pk int primary key, col_int_key int, col_varchar varchar(20));
result_format: 4
explain_protocol: 2
EXPLAIN SELECT ( SELECT 1 FROM DUAL ) AS field2, col_int_key  FROM BB  GROUP BY field2 HAVING col_int_key NOT IN ( SELECT 1 FROM DUAL );
