drop table if exists t1;
create table t1 (c1 int, c2 int);
result_format: 4
insert into t1 values(1,1);

##basic
select c1,c1,c1+1,c2+c1 from t1 group by 1 with rollup;
+------+------+------+-------+
| c1   | c1   | c1+1 | c2+c1 |
+------+------+------+-------+
|    1 |    1 |    2 |     2 |
| NULL | NULL | NULL |  NULL |
+------+------+------+-------+
alter system flush plan cache global;
select 2,1 from t1 group by 1 with rollup;
+---+---+
| 2 | 1 |
+---+---+
| 2 | 1 |
| NULL | 1 |
+---+---+
select 2,2 from t1 group by 1 with rollup;
+---+---+
| 2 | 2 |
+---+---+
| 2 | 2 |
| NULL | NULL |
+---+---+
select 'abb','abc' from t1 group by 'abc' with rollup;
+-----+-----+
| abb | abc |
+-----+-----+
| abb | abc |
| abb | NULL |
+-----+-----+
select 'abc','abc' from t1 group by 'abc' with rollup;
+-----+-----+
| abc | abc |
+-----+-----+
| abc | abc |
| NULL | NULL |
+-----+-----+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 2,_ from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 'ab_','abc' from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+

alter system flush plan cache global;
select 1+2 from t1 group by 1+1 with rollup;
+-----+
| 1+2 |
+-----+
|   3 |
|   3 |
+-----+
select 1+3 from t1 group by 1+1 with rollup;
+-----+
| 1+3 |
+-----+
|   4 |
|   4 |
+-----+
select 1+1 from t1 group by 1+1 with rollup;
+-----+
| 1+1 |
+-----+
|   2 |
| NULL |
+-----+
select 1+2 from t1 group by 1+2 with rollup;
+-----+
| 1+2 |
+-----+
|   3 |
| NULL |
+-----+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 1+_ from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
|         0 |
|         0 |
+-----------+

alter system flush plan cache global;
select c1+2 from t1 group by c1,c1+1 with rollup;
+------+
| c1+2 |
+------+
|    3 |
|    3 |
| NULL |
+------+
select c1+1 from t1 group by c1,c1+1 with rollup;
+------+
| c1+1 |
+------+
|    2 |
| NULL |
| NULL |
+------+
select c1+3 from t1 group by c1,c1+1 with rollup;
+------+
| c1+3 |
+------+
|    4 |
|    4 |
| NULL |
+------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select c1+_ from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
|         0 |
+-----------+

##with having
alter system flush plan cache global;
select c1,c1+1 from t1 group by c1,c1+1 with rollup having c1+2 is null;
+------+------+
| c1   | c1+1 |
+------+------+
| NULL | NULL |
+------+------+
select c1,c1+1 from t1 group by c1,c1+1 with rollup having c1+1 is null;
+------+------+
| c1   | c1+1 |
+------+------+
|    1 | NULL |
| NULL | NULL |
+------+------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select c1,c1+1 from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+

##with orderby
alter system flush plan cache global;
select c1,c1+1 from t1 group by c1,c1+1 with rollup order by c1+2;
+------+------+
| c1   | c1+1 |
+------+------+
| NULL | NULL |
|    1 |    2 |
|    1 | NULL |
+------+------+
select c1,c1+1 from t1 group by c1,c1+1 with rollup order by c1+1;
+------+------+
| c1   | c1+1 |
+------+------+
|    1 | NULL |
| NULL | NULL |
|    1 |    2 |
+------+------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select c1,c1+1 from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+

##rollup expr is child expr
alter system flush plan cache global;
select 1+2-(1+2)+2 from t1 group by 1+1 with rollup;
+-------------+
| 1+2-(1+2)+2 |
+-------------+
|           2 |
|           2 |
+-------------+
select 1+2-(1+1)+2 from t1 group by 1+1 with rollup;
+-------------+
| 1+2-(1+1)+2 |
+-------------+
|           3 |
|        NULL |
+-------------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 1+2-(1+_)+2 from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+
alter system flush plan cache global;
select 1+(c1+2+1) from t1 group by c1+1 with rollup;
+------------+
| 1+(c1+2+1) |
+------------+
|          5 |
|          5 |
+------------+
select 1+(c1+1+1) from t1 group by c1+1 with rollup;
+------------+
| 1+(c1+1+1) |
+------------+
|          4 |
|       NULL |
+------------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 1+(c1+_+1) from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
+-----------+

##no same structure(hit the same plan)
alter system flush plan cache global;
select c1+c2+1 from t1 group by c1+1 with rollup;
+---------+
| c1+c2+1 |
+---------+
|       3 |
|       3 |
+---------+
select c1+c2+2 from t1 group by c1+1 with rollup;
+---------+
| c1+c2+2 |
+---------+
|       4 |
|       4 |
+---------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select c1+c2+_ from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         1 |
+-----------+

##multi same structure
alter system flush plan cache global;
select 1+c1+2+c2+2, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1 group by 1+c1, 1+c1+1, 1+c1+1+c2+1 with rollup;
+-------------+------+--------+-------------+
| 1+c1+2+c2+2 | 1+c1 | 1+c1+1 | 1+c1+1+c2+1 |
+-------------+------+--------+-------------+
|           7 |    2 |      3 |           5 |
|           7 |    2 |      3 |        NULL |
|           7 |    2 |   NULL |        NULL |
|        NULL | NULL |   NULL |        NULL |
+-------------+------+--------+-------------+
select 1+c1+3+c2+2, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1 group by 1+c1, 1+c1+1, 1+c1+1+c2+1 with rollup;
+-------------+------+--------+-------------+
| 1+c1+3+c2+2 | 1+c1 | 1+c1+1 | 1+c1+1+c2+1 |
+-------------+------+--------+-------------+
|           8 |    2 |      3 |           5 |
|           8 |    2 |      3 |        NULL |
|           8 |    2 |   NULL |        NULL |
|        NULL | NULL |   NULL |        NULL |
+-------------+------+--------+-------------+
select 1+c1+3+c2+3, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1 group by 1+c1, 1+c1+1, 1+c1+1+c2+1 with rollup;
+-------------+------+--------+-------------+
| 1+c1+3+c2+3 | 1+c1 | 1+c1+1 | 1+c1+1+c2+1 |
+-------------+------+--------+-------------+
|           9 |    2 |      3 |           5 |
|           9 |    2 |      3 |        NULL |
|           9 |    2 |   NULL |        NULL |
|        NULL | NULL |   NULL |        NULL |
+-------------+------+--------+-------------+
select 1+c1+1+c2+2, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1 group by 1+c1, 1+c1+1, 1+c1+1+c2+1 with rollup;
+-------------+------+--------+-------------+
| 1+c1+1+c2+2 | 1+c1 | 1+c1+1 | 1+c1+1+c2+1 |
+-------------+------+--------+-------------+
|           6 |    2 |      3 |           5 |
|           6 |    2 |      3 |        NULL |
|        NULL |    2 |   NULL |        NULL |
|        NULL | NULL |   NULL |        NULL |
+-------------+------+--------+-------------+
select 1+c1+1+c2+1, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1 group by 1+c1, 1+c1+1, 1+c1+1+c2+1 with rollup;
+-------------+------+--------+-------------+
| 1+c1+1+c2+1 | 1+c1 | 1+c1+1 | 1+c1+1+c2+1 |
+-------------+------+--------+-------------+
|           5 |    2 |      3 |           5 |
|        NULL |    2 |      3 |        NULL |
|        NULL |    2 |   NULL |        NULL |
|        NULL | NULL |   NULL |        NULL |
+-------------+------+--------+-------------+
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select 1+c1+_+c2+_, 1+c1, 1+c1+1, 1+c1+1+c2+1 from t1%" order by hit_count;
+-----------+
| hit_count |
+-----------+
|         0 |
|         0 |
|         0 |
|         0 |
|         0 |
+-----------+

