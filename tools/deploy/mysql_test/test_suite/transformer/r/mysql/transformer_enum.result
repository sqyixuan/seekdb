      sort_keys([logs.get_amount - logs.used_amount, ASC]), topn(1)
  1 - output([logs.get_amount - logs.used_amount], [logs.id], [logs.shop_id], [logs.active_id], [logs.member_id], [logs.get_amount], [logs.valid_stime],
