      equal_conds([logs.active_id = dc.id]), other_conds([CASE WHEN dc.get_valid_days > 0 THEN unix_timestamp(cast(current_timestamp(), TIMESTAMP(-1, 0))) 
      - unix_timestamp(logs.created_at) < dc.get_valid_days * 86400 ELSE 1 = 1 END])
