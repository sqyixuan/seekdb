drop table if exists t1, t2;
CREATE TABLE t1 (
id int(11) unsigned NOT NULL AUTO_INCREMENT,
shop_id int(11) DEFAULT 0,
active_name varchar(16) DEFAULT '',
user_type_id varchar(255) DEFAULT '0',
realpay_price decimal(10,2) DEFAULT 0.00,
discount_price decimal(10,2) DEFAULT 0.00,
start_time int(10) unsigned DEFAULT NULL,
end_time int(10) unsigned DEFAULT NULL,
dc_type enum('1','2','3') DEFAULT '1',
get_num int(11) unsigned DEFAULT 1,
gap_time int(11) unsigned DEFAULT 0,
daily_limit decimal(10,2) DEFAULT 0.00,
get_valid_days int(11) unsigned DEFAULT 0,
status enum('0','1') DEFAULT '1',
description varchar(255) DEFAULT '',
get_way enum('0','1','2','3') DEFAULT '0',
handout_amount int(11) unsigned DEFAULT 0,
configs text DEFAULT NULL,
area_node_id int(11) unsigned DEFAULT 0,
bfr_path varchar(60) DEFAULT '',
created_at timestamp NULL DEFAULT '0000-00-00 00:00:00',
updated_at timestamp NULL DEFAULT '0000-00-00 00:00:00',
PRIMARY KEY (id),
KEY ind_area_node_id (area_node_id) BLOCK_SIZE 16384 LOCAL,
KEY ind_end_time (end_time) BLOCK_SIZE 16384 LOCAL,
KEY ind_user_type_id (user_type_id) BLOCK_SIZE 16384 LOCAL,
KEY ind_start_time (start_time) BLOCK_SIZE 16384 LOCAL,
KEY ind_bfr_path (bfr_path) BLOCK_SIZE 16384 LOCAL,
KEY ind_shop_id (shop_id) BLOCK_SIZE 16384 LOCAL
);
CREATE TABLE t2 (
id bigint(20) unsigned NOT NULL AUTO_INCREMENT,
shop_id int(11) unsigned DEFAULT 0,
active_id int(11) DEFAULT 0,
member_id int(11) DEFAULT 0,
get_amount decimal(10,2) DEFAULT 0.00,
valid_stime int(10) unsigned DEFAULT NULL,
valid_etime int(10) unsigned DEFAULT NULL,
used_amount decimal(10,2) DEFAULT 0.00,
dc_type enum('1','2','3') DEFAULT '1',
is_absolete enum('0','1') DEFAULT '0',
get_total_amount decimal(10,2) DEFAULT 0.00,
used_total_amount decimal(10,2) DEFAULT 0.00,
created_at timestamp NULL DEFAULT '0000-00-00 00:00:00',
updated_at timestamp NULL DEFAULT '0000-00-00 00:00:00',
PRIMARY KEY (id),
KEY ind_active_id (active_id) BLOCK_SIZE 16384 LOCAL,
KEY ind_is_absolete (is_absolete) BLOCK_SIZE 16384 LOCAL,
KEY ind_get_amount (get_amount) BLOCK_SIZE 16384 LOCAL,
KEY ind_shop_id (shop_id) BLOCK_SIZE 16384 LOCAL,
KEY ind_member_id (member_id) BLOCK_SIZE 16384 LOCAL,
KEY ind_used_amount (used_amount) BLOCK_SIZE 16384 LOCAL
);
result_format: 4
explain_protocol: 2
should trigger OUTER_TO_INNER rewrite
explain outline select /*+opt_param('enable_enum_set_subschema', 'true')*/
  logs.*
from
  t1 as dc
  left join t2 as logs on (logs.active_id = dc.id)
where
  dc.status = '1'
  and dc.user_type_id LIKE '%,0,%'
  and logs.member_id = 11022201
  and logs.shop_id = 2394
  and logs.is_absolete = '0'
  and logs.get_amount - logs.used_amount >= 0.3
  and logs.valid_stime <= 1736298158
  and logs.valid_etime > 1736298158
  and if(
    dc.get_valid_days > 0,
    unix_timestamp(now()) - unix_timestamp(logs.created_at) < dc.get_valid_days * 86400,
    1 = 1
  )
  and if(
    dc.bfr_path != '',
    '72624,%' LIKE CONCAT(dc.bfr_path, '%'),
    1 = 1
  )
order by
  (logs.get_amount - logs.used_amount) asc
limit
  1;
