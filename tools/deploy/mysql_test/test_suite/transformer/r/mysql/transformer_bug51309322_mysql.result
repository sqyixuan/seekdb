drop table if exists t1;
create TABLE t1(c1 int,c2 int ,c3 DATE);
set sql_mode = '';
insert into t1 values (3,0,2);
result_format: 4
explain_protocol: 2
EXPLAIN select * from t1 where c3 in ((select c1 FROM t1) union (select c2 FROM t1 ));
Query Plan
========================================================
|ID|OPERATOR               |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |HASH SEMI JOIN         |     |1       |8           |
|1 |├─TABLE FULL SCAN      |t1   |1       |3           |
|2 |└─SUBPLAN SCAN         |VIEW1|2       |5           |
|3 |  └─HASH UNION DISTINCT|     |2       |5           |
|4 |    ├─TABLE FULL SCAN  |t1   |1       |3           |
|5 |    └─TABLE FULL SCAN  |t1   |1       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      equal_conds([t1.c3 = VIEW1.c1]), other_conds(nil)
  1 - output([t1.c3], [t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c3], [t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([VIEW1.c1]), filter(nil), rowset=16
      access([VIEW1.c1])
  3 - output([cast(UNION([1]), MYSQL_DATE(-1, -1))]), filter(nil), rowset=16
  4 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([t1.c2]), filter(nil), rowset=16
      access([t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where c3 in ((select c1 FROM t1) union (select c2 FROM t1 ));
