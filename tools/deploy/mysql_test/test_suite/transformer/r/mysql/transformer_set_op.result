SELECT CASE
         WHEN col_timestamp_6_index < '2000-01-01' THEN
         'datetime_field is before 2000-01-01.'
         WHEN col_timestamp_6 <=> '2000-01-01' THEN
         'datetime_field is at 2000-01-01.'
         WHEN col_timestamp_6 > '2000-01-01' THEN
         'datetime_field is after 2000-01-01.'
         WHEN col_timestamp_6_index IS NULL THEN 'datetime_field is NULL.'
         ELSE 'datetime_field is not a col_timestamp_6 or NULL'
       end,
       pk
FROM   table5_bigint
WHERE  ( col_bigint BETWEEN NULL AND NULL )
        OR ( col_decimal_20_0_index IN ( -20594 )
             AND ( 5 BETWEEN (SELECT Coalesce((SELECT *
                                               FROM   (SELECT 204) TC1),
                         (SELECT *
                          FROM   (SELECT pk
                                  FROM   table100_bigint
                                  WHERE  NOT
                                   ( ( ( col_decimal_20_0 >
                                         -20594
                                          OR ( Lower(Trim(
                                               Substr(
                                         Substr(Concat(
                                         Substr('g', 1,
                                         20),
                                                Substr(
                                                Substr('u',
                                                1, 20),
                                                3
                                                )), 3,
                                                     122)
                                               , 1, 20)))
                                               NOT LIKE
                                             Lower(
                                               Trim(Substr(
                                               Concat(
                                                    Substr(
                                               'TJDZJ'
                                                    ,
                                                    1,
                                                    20)
                                               , Substr(
                                         'egghexutw',
                                                  1
                                                  ,
                                                  20))
                                         , 1,
                                         20)))
                                             escape 'c' ) )
                                       AND ( col_decimal_20_0_index >=
                                             -20594
                                             AND Round(Round(
                                                 Round(Ceil(11542))))
                                                 IS NOT NULL )
                                       AND
                                       ( (SELECT Coalesce((SELECT *
                                                           FROM
                                                 (SELECT Avg(
                                                 col_decimal_20_0)
                                                  FROM
                                         table10_bigint
                                                  WHERE  Coalesce(
                                                 col_char_20_index,
                                         col_char_20
                                         ,
                                         col_char_20)
                                         <=
                                         Cast(Concat( Substr( 'ue'
                                         , 1, 20)
                                         ,
                                         col_char_20
                                         ) AS
                                         CHAR)
                                                  ORDER  BY pk ASC)
                                                 TC1),
                                                 (SELECT *
                                                  FROM   (SELECT (
                                                 SELECT
                                                         Coalesce(
                                                               (
                                                 SELECT *
                                                 FROM
                                         (SELECT
                                                 col_bigint
                                                         FROM
                                                 table0_hash_pk_parts_1_bigint
                                                          WHERE
                                                 Round(Sign(
                                                 col_decimal_20_0_index)
                                                 )
                                                 !=
                                                 Round(Sign(Round(Sign(
                                                            Round(Sign(
                                                            Round(
                                                                  Ceil(
                                                            Round(Round
                                                            (
                                                 col_decimal_20_0_index
                                                            ))
                                                 )
                                                 )))))
                                                 ))
                                                          ORDER  BY
                                         col_char_5_key,
                                         pk ASC
                                                          LIMIT  1) TC1),
                                                        (SELECT *
                                                         FROM
                         (SELECT Avg(col_bigint)
                          FROM
                                      table2_hash_pk_parts_1_bigint
                                               WHERE
                                      col_char_20 =
                                      col_char_20_index
                                               ORDER  BY pk ASC)
                         TC2), 99))
                         )
                                       TC2), 6663)) <=> col_bigint
                                       )
                                                   AND ( col_bigint IN
                                                         ( -20594, 1922560, 91 )
                                                       )
                                                   AND NOT (
                                       col_bigint_index IN (
                                       -20594, 1922560, 91 )
                                                           )
                                                 )
                                                  OR NOT ( ( Date_sub(Date_add(
                                                             Concat(Cast(2015 +
                                                                    4 +
                                                                    1 AS
                                                                    CHAR(20)
                                                                    ),
                                     '-06-19 01:00:00.000003'
                                     ),
                                     INTERVAL '05:05.000005'
                                     MINUTE_MICROSECOND
                                      ),
                                     INTERVAL '05:05:05' HOUR_SECOND) )
                                     IS NULL
                                     OR (( col_timestamp_6 =
                                     Date_add(Concat(Cast(2015 + 4 +
                                              3 AS
                                              CHAR(
                                              20)
                                              ),
                                            '-06-19 01:00:00.000003')
                                     ,
                                                       INTERVAL
                                     '05:05.000005'
                                     MINUTE_MICROSECOND
                                     )
                                     ))
                                     IS
                                     FALSE
                                     OR ( Length(Trim(Substr(Substr(
                                                      Hex(Substr(Hex(
                                                           Substr(
                                                                  'sue'
                                                           , 1,
                                                           20))
                                                           ,
                                                           1,
                                                           20)),
                                                1
                                                , 20
                                                ),
                                               1, 20)
                                     )) BETWEEN Round(Sign(Round(Round(
                                                          Round(
                                                                Floor(
                                                          col_bigint)
                                                          ))))
                                               )
                                               AND
                                                                 Length
                                               (
                                               Trim(Substr(Substr(
                                                    Cast(( Round(
                                                    Floor( 10 ) )
                                                    )
                                                    AS
                                                    CHAR(100)), 1,
                                                           20)
                                                    , 1
                                                    , 20))) )
                                     OR Trim(Substr(Trim(Date_format(Date_add(
                                                Concat(Cast(2015 + 1 +
                                                       3 AS
                                                       CHAR(20)),
                                     '-06-19 01:00:00.000003'),
                                     INTERVAL '05:05.000005'
                                     MINUTE_MICROSECOND),
                                     Concat('%V%X', '%p'))), 1,
                                     20))
                                     IS
                                     NULL
                                     OR NOT ( Length(Substr('lsueg', 1, 20))
                                              BETWEEN
                                         Round(Ceil(Coalesce(
                                               col_bigint_index,
                                                    col_bigint_index,
                                                    col_bigint))) AND
                                         Length
                                           ('TATAO') ) ) )
                                     ORDER  BY col_timestamp_6_key DESC,
                                     pk DESC
                                     LIMIT  1) TC2), 0)) AND Length(
                                   REPEAT(Cast(7 AS CHAR(20)), 5 + 1)) ) )
        OR ( col_decimal_20_0 IN ( -20594 )
             AND NOT Upper(Trim(Substr(Substr('ULIHV', 1, 20), 1, 20))) LIKE
                     Upper('%a%') escape 'a' )
ORDER  BY 1 ASC,
          pk DESC
LIMIT  8;
