SELECT     subq_1.c0  AS c0,
           subq_0.c0  AS c1,
           subq_2.c13 AS c2,
           ref_3.role AS c3
FROM       (
           (
                  SELECT ref_0.NAME              AS c0
                  FROM   test.t_inc_policy_group AS ref_0
                  WHERE  ((
                                       ref_0.status & ref_0.status)
                         AND    ((
                                              ref_0.OPEN * ref_0.OPEN)
                                AND    (
                                              1)))
                  OR     (
                                ref_0.chkdisabled - ref_0.OPEN) limit 118) AS subq_0
RIGHT JOIN ((
           (
                     SELECT    ref_2.cls               AS c0,
                               ref_1.servercogkeypoint AS c1,
                               ref_2.cls               AS c2,
                               ref_1.servertype        AS c3
                     FROM      (test.t_knowledge_server_cog AS ref_1
                     LEFT JOIN test.stukzz7ya               AS ref_2
                     ON        ((
                                                   ref_1.servercogid + ref_2.cls)
                               AND       (
                                                   ref_1.servercogid > ref_1.servercogid)))
                     WHERE     (
                                      SELECT basicpropertyid
                                      FROM   test.t_sys_basicproperty limit 1 offset 6)
                     AND       17 limit 71) AS subq_1
INNER JOIN test.sys_role_uri                AS ref_3
ON         (
                      EXISTS
                      (
                             SELECT ref_4.trade_status      AS c0,
                                    subq_1.c0               AS c1,
                                    ref_3.role              AS c2,
                                    3                       AS c3,
                                    ref_4.data_packet       AS c4,
                                    ref_3.role              AS c5
                             FROM   test.cool_bill_20180910 AS ref_4
                             WHERE  subq_1.c2 IS NOT NULL limit 21)))
INNER JOIN
           (
                  SELECT ref_5.c1 AS c0,
                         ref_5.c1 AS c1,
                         ref_5.c2 AS c2,
                         (
                                SELECT monitorid
                                FROM   test.t_mon_cpu limit 1 offset 2) AS c3,
                         ref_5.c2                                       AS c4,
                         (
                                SELECT group_concat(trade_time)
                                FROM   test.cool_bill) AS c5,
                         ref_5.c2                      AS c6,
                         ref_5.c1                      AS c7,
                         ref_5.c1                      AS c8,
                         ref_5.c3                      AS c9,
                         ref_5.c1                      AS c10,
                         ref_5.c1                      AS c11,
                         ref_5.c1                      AS c12,
                         (
                                SELECT max(c1)
                                FROM   test.t_hash_rangewkwp9j) AS c13,
                         ref_5.c3                               AS c14,
                         ref_5.c2                               AS c15,
                         ref_5.c1                               AS c16,
                         ref_5.c1                               AS c17,
                         ref_5.c2                               AS c18
                  FROM   test.t1chxee2                          AS ref_5
                  WHERE  ref_5.c3 / ref_5.c3 limit 92) AS subq_2
ON         (
                      ref_3.sys_uri_id = subq_2.c3 ))
ON         (
                      ref_3.sys_uri_id <> subq_1.c0))
WHERE      ref_3.role < ref_3.sys_uri_id limit 93 ;
+------+----+------+------+
| c0   | c1 | c2   | c3   |
+------+----+------+------+
+------+----+------+------+

EXPLAIN SELECT     1
FROM    test.t_inc_policy_group AS subq_0
RIGHT JOIN (test.stukzz7ya subq_1
             INNER JOIN test.sys_role_uri    AS ref_3
             ON  EXISTS (SELECT 1
                         FROM   test.cool_bill_20180910 AS ref_4
                         WHERE  subq_1.cls IS NOT NULL limit 21) )
ON ref_3.sys_uri_id <> subq_1.cls
limit 93 ;
