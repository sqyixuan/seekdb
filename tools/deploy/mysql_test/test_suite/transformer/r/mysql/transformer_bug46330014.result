CREATE TABLE `t_hash_rangewkwp9j` (
`c1` int(11) DEFAULT NULL,
`c2` int(11) DEFAULT NULL,
`c3` int(11) DEFAULT NULL,
`c4` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by hash(c1) subpartition by range(c2)
(partition hp0 (
subpartition hp0sp0 values less than (100),
subpartition hp0sp1 values less than (200),
subpartition hp0sp2 values less than (300)),
partition hp1 (
subpartition hp1sp0 values less than (100),
subpartition hp1sp1 values less than (200),
subpartition hp1sp2 values less than (300)),
partition hp2 (
subpartition hp2sp0 values less than (100),
subpartition hp2sp1 values less than (200),
subpartition hp2sp2 values less than (300)),
partition hp3 (
subpartition hp3sp0 values less than (100),
subpartition hp3sp1 values less than (200),
subpartition hp3sp2 values less than (300)));
create table if not exists `t1chxee2` (
`c1` varchar(1),
`c2` varchar(1),
`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
explain_protocol: 2
result_format: 4
EXPLAIN SELECT     subq_1.c0  AS c0,
           subq_0.c0  AS c1,
           subq_2.c13 AS c2,
           ref_3.role AS c3
FROM       (
           (
                  SELECT ref_0.NAME              AS c0
                  FROM   test.t_inc_policy_group AS ref_0
                  WHERE  ((
                                       ref_0.status & ref_0.status)
                         AND    ((
                                              ref_0.OPEN * ref_0.OPEN)
                                AND    (
                                              1)))
                  OR     (
                                ref_0.chkdisabled - ref_0.OPEN) limit 118) AS subq_0
RIGHT JOIN ((
           (
                     SELECT    ref_2.cls               AS c0,
                               ref_1.servercogkeypoint AS c1,
                               ref_2.cls               AS c2,
                               ref_1.servertype        AS c3
                     FROM      (test.t_knowledge_server_cog AS ref_1
                     LEFT JOIN test.stukzz7ya               AS ref_2
                     ON        ((
                                                   ref_1.servercogid + ref_2.cls)
                               AND       (
                                                   ref_1.servercogid > ref_1.servercogid)))
                     WHERE     (
                                      SELECT basicpropertyid
                                      FROM   test.t_sys_basicproperty limit 1 offset 6)
                     AND       17 limit 71) AS subq_1
INNER JOIN test.sys_role_uri                AS ref_3
ON         (
                      EXISTS
                      (
                             SELECT ref_4.trade_status      AS c0,
                                    subq_1.c0               AS c1,
                                    ref_3.role              AS c2,
                                    3                       AS c3,
                                    ref_4.data_packet       AS c4,
                                    ref_3.role              AS c5
                             FROM   test.cool_bill_20180910 AS ref_4
                             WHERE  subq_1.c2 IS NOT NULL limit 21)))
INNER JOIN
           (
                  SELECT ref_5.c1 AS c0,
                         ref_5.c1 AS c1,
                         ref_5.c2 AS c2,
                         (
                                SELECT monitorid
                                FROM   test.t_mon_cpu limit 1 offset 2) AS c3,
                         ref_5.c2                                       AS c4,
                         (
                                SELECT group_concat(trade_time)
                                FROM   test.cool_bill) AS c5,
                         ref_5.c2                      AS c6,
                         ref_5.c1                      AS c7,
                         ref_5.c1                      AS c8,
                         ref_5.c3                      AS c9,
                         ref_5.c1                      AS c10,
                         ref_5.c1                      AS c11,
                         ref_5.c1                      AS c12,
                         (
                                SELECT max(c1)
                                FROM   test.t_hash_rangewkwp9j) AS c13,
                         ref_5.c3                               AS c14,
                         ref_5.c2                               AS c15,
                         ref_5.c1                               AS c16,
                         ref_5.c1                               AS c17,
                         ref_5.c2                               AS c18
                  FROM   test.t1chxee2                          AS ref_5
                  WHERE  ref_5.c3 / ref_5.c3 limit 92) AS subq_2
ON         (
                      ref_3.sys_uri_id = subq_2.c3 ))
ON         (
                      ref_3.sys_uri_id <> subq_1.c0))
WHERE      ref_3.role < ref_3.sys_uri_id limit 93 ;
