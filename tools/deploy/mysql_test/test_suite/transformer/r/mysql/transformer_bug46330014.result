CREATE TABLE `t_inc_policy_group` (
`id` int(11) NOT NULL AUTO_INCREMENT COMMENT '节点标识,流水号',
`parentID` int(11) DEFAULT NULL COMMENT '父节点标识',
`name` varchar(300) NOT NULL COMMENT '节点名称',
`status` tinyint(4) DEFAULT '1' COMMENT '节点状态:1:正常2:删除',
`isDefault` tinyint(4) DEFAULT '0' COMMENT '是否是默认节点,0:自定义,1:默认',
`isParent` tinyint(4) DEFAULT '0' COMMENT '是否是父类节点,0:否,1:是',
`open` tinyint(4) DEFAULT '1' COMMENT '是否展开节点,0:否,1:是',
`chkDisabled` tinyint(4) DEFAULT '1' COMMENT '设置节点的 checkbox / radio 是否禁用 ',
PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8 COMMENT='告警策略分组表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_knowledge_server_cog` (
`serverCogId` int(11) NOT NULL AUTO_INCREMENT,
`serverCogName` varchar(100) NOT NULL,
`serverType` varchar(20) NOT NULL,
`serverCogDes` text,
`serverCogPreConditions` text,
`resourceId` varchar(100) NOT NULL,
`serverCogDetails` text,
`serverCogKeyPoint` text,
`updateTime` datetime DEFAULT NULL,
PRIMARY KEY (`serverCogId`),
UNIQUE KEY `serverCog` (`serverCogName`,`serverType`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `stukzz7ya` (
`sid` int(11) not null,
`name` varchar(32),
`cls` int(11) not null,
primary key (`cls`, `sid`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (sid)
(
PARTITION `p0`,
PARTITION `p1`,
PARTITION `p2`,
PARTITION `p3`,
PARTITION `p4`,
PARTITION `p5`
);
CREATE TABLE `t_sys_basicproperty` (
`basicPropertyID` int(20) NOT NULL AUTO_INCREMENT COMMENT '基础属性ID',
`basicPropertyType` char(50) DEFAULT NULL COMMENT '基础属性类型',
`basicPropertyName` char(100) DEFAULT NULL COMMENT '基础属性名称',
PRIMARY KEY (`basicPropertyID`)
) ENGINE=InnoDB AUTO_INCREMENT=6 DEFAULT CHARSET=utf8 COMMENT='基础属性表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `sys_role_uri` (
`sys_uri_id` int(11) DEFAULT NULL,
`role` int(11) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `cool_bill_20180910` (
`bill_id` int(11) NOT NULL AUTO_INCREMENT,
`trade_time` varchar(30) DEFAULT NULL ,
`app_id` varchar(20) DEFAULT NULL ,
`mch_id` varchar(30) DEFAULT NULL ,
`sub_mch` varchar(30) DEFAULT NULL ,
`device_id` varchar(50) DEFAULT NULL ,
`wx_order` varchar(50) DEFAULT NULL ,
`order_no` varchar(50) DEFAULT NULL ,
`openid` varchar(50) DEFAULT NULL ,
`trade_type` varchar(50) DEFAULT NULL ,
`trade_status` varchar(50) DEFAULT NULL ,
`bank` varchar(100) DEFAULT NULL ,
`cny` varchar(20) DEFAULT NULL ,
`total_money` varchar(20) DEFAULT NULL ,
`redpacket_money` varchar(20) DEFAULT NULL ,
`aprefund_time` varchar(30) DEFAULT NULL ,
`surefund_time` varchar(30) DEFAULT NULL ,
`wxrefund_no` varchar(50) DEFAULT NULL ,
`mcrefund_no` varchar(50) DEFAULT NULL ,
`refund_money` varchar(20) DEFAULT NULL ,
`redpacket_refund_money` varchar(20) DEFAULT NULL ,
`refund_type` varchar(20) DEFAULT NULL ,
`refund_status` varchar(20) DEFAULT NULL ,
`product_target_name` varchar(100) DEFAULT NULL ,
`data_packet` varchar(255) DEFAULT NULL ,
`fee` varchar(20) DEFAULT NULL ,
`rate` varchar(20) DEFAULT NULL ,
`business_id` varchar(100) DEFAULT NULL,
`door_id` varchar(100) DEFAULT NULL,
`pay_type` varchar(100) DEFAULT NULL ,
`pay_pass` varchar(100) DEFAULT NULL,
`agent_id` varchar(100) DEFAULT NULL ,
`agent_fr_fee` varchar(100) DEFAULT NULL ,
`qd_fr_fee` varchar(100) DEFAULT NULL ,
`td_cost_fee` varchar(100) DEFAULT NULL ,
`from_business_trade_id` varchar(128) DEFAULT NULL,
`bill_time` varchar(30) DEFAULT NULL,
`channel_id` int(10) DEFAULT NULL ,
`activity_type` varchar(30) DEFAULT NULL ,
`pay_log_id` varchar(40) DEFAULT NULL ,
`user_id` varchar(11) DEFAULT NULL ,
PRIMARY KEY (`bill_id`),
UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
KEY `mch_id_idx` (`mch_id`),
KEY `agent_id_idx` (`agent_id`),
KEY `bill_time_idx` (`bill_time`),
KEY `trade_time_idx` (`trade_time`),
KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_mon_cpu` (
`cpuID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'CPU信息ID',
`monitorID` int(11) DEFAULT NULL COMMENT '监控ID',
`cpuNum` varchar(50) CHARACTER SET gbk DEFAULT NULL COMMENT 'cpu编号',
`us` double DEFAULT NULL COMMENT '用户空间占用CPU百分比',
`sy` double DEFAULT NULL COMMENT '内核空间占用CPU百分比',
`ni` double DEFAULT NULL COMMENT '用户进程空间内改变过优先级的进程占用CPU的百分比',
`id` double DEFAULT NULL COMMENT '空闲CPU百分比',
`wa` double DEFAULT NULL COMMENT '等待输入输出的CPU的百分比',
`hi` double DEFAULT NULL COMMENT '硬件CPU中断占用百分比',
`st` double DEFAULT NULL COMMENT '虚拟机占用百分比',
`si` double DEFAULT NULL COMMENT '软中断占用百分比',
PRIMARY KEY (`cpuID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
