SELECT subq_0.c1 AS c0
FROM   (cool_mcc_detail AS ref_0
        INNER JOIN ((SELECT ref_1.create_user_id AS c0,
                           ref_1.create_user_id AS c1
                    FROM   pub_dictionary AS ref_1
                    WHERE  ( ( ref_1.create_user_id >> ref_1.version )
                             AND ( ref_1.version < ref_1.dic_flag ) )
                           AND ( EXISTS (SELECT ref_1.update_user_id AS c0
                                         FROM   t_kms_equip_terminal AS
                                                ref_2
                                         WHERE  (SELECT userid
                                                 FROM   t_kms_lastlogintime
                                                 LIMIT  1 offset 6) / 15) )
                    LIMIT  96) AS subq_0
                    INNER JOIN (((cool_bill_20180903 AS ref_3
                                  INNER JOIN datax_maxid_zy_xy AS ref_4
                                          ON ( ref_3.qd_fr_fee =
                                               ref_4.table_name ))
                                 RIGHT JOIN t_sys_role AS ref_5
                                         ON ( ( ref_4.id < ref_5.roleid )
                                              AND ( ( ref_3.trade_type IS NULL )
                                                     OR ( ( ref_3.channel_id |
                                                            ref_5.status )
                                                           OR ( ref_4.id +
                                            ref_5.issysdefault ) ) ) ))
                                LEFT JOIN (t_hsm_dns_chsm AS ref_6
                                           INNER JOIN ((t_rpt_chartdata AS
                                                       ref_7
                                           INNER JOIN jx_t3eraj78 AS
                                                      ref_8
                                                   ON ( ( ( (
                                           38 = ref_7.resultid )
                                                             OR ( EXISTS
                                           (SELECT ref_8.c2
                                                   AS
                                                   c0,
                                                   ref_8.c1
                                                   AS
                                                   c1,
                                           (SELECT linknum
                                            FROM   t_kms_encryptor
                                            LIMIT  1 offset 3)      AS
                                           c2,
                                           71                       AS
                                           c3,
                                           ref_7.reserveddatavalue1 AS
                                           c4,
                                           ref_9.autoname           AS
                                           c5,
                                           ref_8.c2                 AS
                                           c6,
                                           ref_7.reserveddatavalue1 AS
                                           c7,
                                           ref_9.responseid         AS
                                           c8,
                                           ref_7.resultid           AS
                                           c9,
                                           (SELECT Count(c1)
                                            FROM   t1tscbnp)   AS
                                           c10,
                                           ref_9.inccategoryid      AS
                                           c11,
                                           88                       AS
                                           c12,
                                           ref_8.c2                 AS
                                           c13,
                                           ref_7.datakey            AS
                                           c14,
                                           ref_7.datavalue          AS
                                           c15,
                                           ref_7.reserveddatavalue2 AS
                                           c16,
                                           ref_7.datavalue          AS
                                           c17,
                                           (SELECT business_id
                                            FROM   cool_deal_201811
                                            LIMIT  1 offset 4)      AS
                                           c18,
                                           ref_9.incpolicyid        AS
                                           c19,
                                           ref_9.responseid         AS
                                           c20,
                                           ref_8.c2                 AS
                                           c21,
                                           ref_8.c1                 AS
                                           c22
                                                   FROM
                                               t_inc_incresponse AS
                                               ref_9
                                                             WHERE
                                               ref_9.issendnotification <
                                               ref_8.c2) ) )
                                             AND ( ref_8.c1 &
                                           ref_8.c1 ) )
                                            OR ( ref_8.c1 IS NULL ) ))
                                                       RIGHT JOIN t1az9xc7
                                                                  AS
                                                                  ref_10
                                                               ON
                                                       ( (
                                                       ref_10.c1 IS NULL
                                                                    )
                                                                    AND
                                                         ( ( ref_8.c1 <<
                                                             ref_8.c2 )
                                                           AND ( (
                                           (SELECT Sum(policyid)
                                            FROM   t_sys_passwordpolicy)
                                           AND ref_8.c2 )
                                                    OR ( ref_8.c2 =
                                                      ref_8.c2 ) ) ) ))
                                                   ON ( ( ref_8.c1 IS NOT NULL )
                                                         OR (
                                           ref_6.dnsid IS NULL ) ))
                                       ON ( ( ( 67 <> ref_4.id )
                                              AND ( 1 ) )
                                            AND ( 0 ) ))
                            ON ( subq_0.c1 = ref_3.bill_id ))
                ON ( ref_3.bill_id >= ref_6.chsmid ))
WHERE  subq_0.c1 / ref_6.dnsid
LIMIT  131;
