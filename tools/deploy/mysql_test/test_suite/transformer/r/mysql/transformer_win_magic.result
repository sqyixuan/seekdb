CREATE TABLE t2 (c2 VARCHAR(38), c1 VARCHAR(20), c3 VARCHAR(105) NOT NULL, PRIMARY KEY (c3));
EXPLAIN SELECT 1 FROM t1, t2 B, (SELECT max(C.c1) AS aggr, C.c2 FROM t2 C GROUP BY C.c2) VIEW1 WHERE (B.c1 = VIEW1.aggr) AND (t1.c1 = (SELECT 1 FROM t2 D WHERE (D.c2 = B.c2))) AND (t1.c2 = B.c2) AND (t1.c2 = VIEW1.c2);
