    key idx7(pk, col_varchar_20_key ),
    key idx3(pk, col_varchar_key ),
    key idx1(pk, col_int_key ),
    primary key (pk) ,
    key idx5(pk, col_varchar_10_key )) ;
CREATE TABLE CC (
    col_int_key int,
    col_varchar_10 varchar(10),
    col_int int,
