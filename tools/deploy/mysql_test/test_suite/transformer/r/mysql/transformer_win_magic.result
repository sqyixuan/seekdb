) ;

EXPLAIN SELECT SUM(table1 . `col_varchar_20`) AS field1,
       table1 . `col_int_key` AS field2,
  (SELECT COUNT(DISTINCT SUBQUERY1_t1 . `pk`) AS SUBQUERY1_field1
   FROM (BB AS SUBQUERY1_t1
         INNER JOIN (C AS SUBQUERY1_t2
                     LEFT  JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `col_varchar_key` = SUBQUERY1_t2 . `col_varchar_20_key`)) ON (SUBQUERY1_t3 . `col_varchar_20_key` = SUBQUERY1_t2 . `col_varchar_key`))
   WHERE SUBQUERY1_t3 . `col_varchar_10` > table1 . `col_varchar_10`
     OR SUBQUERY1_t1 . `col_int_key` <> table1 . `col_int` ) AS field3,
       SUM(table1 . `pk`) AS field4
FROM (
        (SELECT SUBQUERY2_t1 . *
         FROM CC AS SUBQUERY2_t1
         WHERE SUBQUERY2_t1 . `col_varchar_20_key` < SUBQUERY2_t1 . `col_varchar_10` ) AS table1
      RIGHT  JOIN ((C AS table2
                    INNER JOIN
                      (SELECT SUBQUERY3_t1 . *
                       FROM (CC AS SUBQUERY3_t1
                             LEFT  JOIN C AS SUBQUERY3_t2 ON (SUBQUERY3_t2 . `col_int` = SUBQUERY3_t1 . `pk`))) AS table3 ON (table3 . `col_int_key` = table2 . `pk`))) ON (table3 . `col_int_key` = table2 . `col_int_key`))
WHERE (table1 . `col_varchar_key` <
         (SELECT MIN(DISTINCT SUBQUERY4_t1 . `col_varchar`) AS SUBQUERY4_field1
          FROM CC AS SUBQUERY4_t1))
  AND table1 . `col_varchar_key` = table1 . `col_varchar_key`
  OR table1 . `col_varchar_key` < table3 . `col_varchar_10_key`
GROUP BY field2,
         field3
HAVING (field1 != 8
        AND field3 <> 'a')
ORDER BY field1,
         field2,
         field3,
         field4;
