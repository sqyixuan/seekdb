=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |SCALAR GROUP BY          |        |1       |2279        |
|1 |└─SUBPLAN SCAN           |VIEW1   |15      |2279        |
|2 |  └─WINDOW FUNCTION      |        |285     |2274        |
|3 |    └─PARTITION SORT     |        |285     |1869        |
|4 |      └─HASH JOIN        |        |285     |1814        |
|5 |        ├─TABLE FULL SCAN|part    |11      |23          |
|6 |        └─TABLE FULL SCAN|lineitem|11957   |779         |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([cast(T_FUN_SUM(VIEW1.lineitem.l_extendedprice), DECIMAL_INT(46, 16)) / 7.0]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_SUM(VIEW1.lineitem.l_extendedprice)])
  1 - output([VIEW1.lineitem.l_extendedprice]), filter([cast(VIEW1.lineitem.l_quantity, DECIMAL(20, 0)) < VIEW1.0.2*AVG(L_QUANTITY)]), rowset=256
      access([VIEW1.0.2*AVG(L_QUANTITY)], [VIEW1.lineitem.l_quantity], [VIEW1.lineitem.l_extendedprice])
  2 - output([cast(0.2, DECIMAL(2, 1)) * cast(cast(T_FUN_SUM(lineitem.l_quantity), DECIMAL_INT(74, 32)) / cast(T_FUN_COUNT(lineitem.l_quantity), DECIMAL_INT(20,
       0)), DECIMAL(24, 4))], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=256
      win_expr(T_FUN_SUM(lineitem.l_quantity)), partition_by([lineitem.l_partkey]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
      win_expr(T_FUN_COUNT(lineitem.l_quantity)), partition_by([lineitem.l_partkey]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  3 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=256
      sort_keys([HASH(lineitem.l_partkey), ASC], [lineitem.l_partkey, ASC])
  4 - output([lineitem.l_quantity], [lineitem.l_partkey], [lineitem.l_extendedprice]), filter(nil), rowset=256
      equal_conds([lineitem.l_partkey = part.p_partkey]), other_conds(nil)
  5 - output([part.p_partkey]), filter([part.p_container = 'MED BOX'], [part.p_brand != 'Brand#23']), rowset=256
      access([part.p_partkey], [part.p_brand], [part.p_container]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([part.p_partkey]), range(MIN ; MAX)always true
  6 - output([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), filter(nil), rowset=256
      access([lineitem.l_partkey], [lineitem.l_quantity], [lineitem.l_extendedprice]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([lineitem.l_orderkey], [lineitem.l_linenumber]), range(MIN,MIN ; MAX,MAX)always true
