EXPLAIN SELECT    table2 . col_varchar_key AS field1 FROM ( CC AS table1 INNER JOIN ( ( CC AS table2 INNER JOIN B AS table3 ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) ) ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) WHERE (   EXISTS ( SELECT   SUBQUERY1_t1 . `col_varchar_20_key` AS SUBQUERY1_field1 FROM C AS SUBQUERY1_t1 WHERE SUBQUERY1_t1 . `pk` != table1 . `col_int` ) ) AND  table1 . `col_varchar` <> SOME ( SELECT   SUBQUERY2_t2 . `col_varchar_20_key` AS SUBQUERY2_field1 FROM ( C AS SUBQUERY2_t1 LEFT OUTER JOIN B AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_10_key`  ) ) WHERE  SUBQUERY2_t2 . `col_int` >= ( SELECT   COUNT(  CHILD_SUBQUERY1_t1 . `pk` ) AS CHILD_SUBQUERY1_field1 FROM B AS CHILD_SUBQUERY1_t1  ) GROUP BY SUBQUERY2_field1 )  GROUP BY field1  ORDER BY 1, field1 ;
