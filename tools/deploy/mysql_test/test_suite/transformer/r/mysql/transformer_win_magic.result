DROP TABLE B, C, CC;

drop table if exists bmsql_oorder;
create table bmsql_oorder (
o_w_id       INTEGER      NOT NULL,
o_d_id       INTEGER      NOT NULL,
o_id         INTEGER      NOT NULL,
o_c_id       INTEGER,
o_carrier_id INTEGER,
o_ol_cnt     DECIMAL(2,0),
o_all_local  DECIMAL(1,0),
o_entry_d    TIMESTAMP,
PRIMARY KEY (o_w_id, o_d_id, o_id)
) compression="lz4_1.0"  partition by hash(o_w_id) partitions 2;
create index oo_hash_partition_1 on bmsql_oorder(o_w_id, o_d_id, o_c_id, o_id) global partition by hash(o_w_id) partitions 3;
create index oo_hash_partition_2 on bmsql_oorder(o_w_id, o_d_id, o_ol_cnt) global partition by hash(o_w_id) partitions 3;

