  4 - output([T.PROPOSALNO], [T.RISKCODE], [T.CURRENCY], [T.PLANFEENOVAT], [T.DELINQUENTFEENOVAT], [T.PLANVAT], [T.DELINQUENTVAT]), filter(nil)
      access([T.PROPOSALNO], [T.RISKCODE], [T.CURRENCY], [T.PLANFEENOVAT], [T.DELINQUENTFEENOVAT], [T.PLANVAT], [T.DELINQUENTVAT]), partitions(p0)
