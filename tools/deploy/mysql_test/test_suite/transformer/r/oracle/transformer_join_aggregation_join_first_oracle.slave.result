set autocommit=1;
drop table t1;
drop table t2;
drop table t3;
drop table tpart;
drop sequence seq;

## enhance join first pullup 
drop table prpCmain;
drop table PrpTmain;
drop table PrpTration;
drop table PrpTplan;

CREATE TABLE prpCmain (PROPOSALNO VARCHAR2(40) NOT NULL, SUMPREMIUMNOVAT NUMBER(20,8), SUMVAT NUMBER(20,8), CONSTRAINT ckt_cmain_endhour PRIMARY KEY (ProposalNo));

CREATE TABLE PrpTmain (PROPOSALNO VARCHAR2(40) NOT NULL, SUMAMOUNT NUMBER(14,2), SUMPREMIUM NUMBER(14,2), SUMPREMIUMNOVAT NUMBER(20,8), SUMVAT NUMBER(20,8), CONSTRAINT PK_TMAIN PRIMARY KEY (ProposalNo));

CREATE TABLE PrpTration (PROPOSALNO VARCHAR2(40) NOT NULL, MODECODE VARCHAR2(20) NOT NULL, RATIONAMOUNT NUMBER(14,2), RATIONPREMIUM NUMBER(14,2), CONSTRAINT pk_tration PRIMARY KEY (ProposalNo,ModeCode));

CREATE TABLE PrpTplan (PROPOSALNO VARCHAR2(40) NOT NULL, CURRENCY VARCHAR2(3) NOT NULL, RISKCODE VARCHAR2(4) DEFAULT ' ' NOT NULL, PLANFEENOVAT NUMBER(20,8), DELINQUENTFEENOVAT NUMBER(20,8), PLANVAT NUMBER(20,8), DELINQUENTVAT NUMBER(20,8), CONSTRAINT pk_prptplan PRIMARY KEY (ProposalNo,RiskCode,Currency));

EXPLAIN UPDATE prpcmain t
SET (t.sumpremiumnovat,
     t.sumvat) =
 (SELECT a.sumpremiumnovat,
         a.sumvat
  FROM prptmain a
  WHERE a.proposalno = t.proposalno)
WHERE t.proposalno = 'a';
Query Plan
=======================================================================
|ID|OPERATOR                               |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                     |    |1       |42          |
|1 |└─EXCHANGE OUT REMOTE                  |    |1       |42          |
|2 |  └─UPDATE                             |    |1       |42          |
|3 |    └─NESTED-LOOP OUTER JOIN CARTESIAN |    |1       |11          |
|4 |      ├─TABLE GET                      |T   |1       |5           |
|5 |      └─TABLE GET                      |A   |1       |5           |
=======================================================================
