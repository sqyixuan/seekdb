CREATE OR REPLACE VIEW v1 AS SELECT * FROM t1 PARTITION(p1) WHERE lnnvl(name>'test7') START WITH id<=102 CONNECT BY PRIOR id=pid;

CREATE OR REPLACE TRIGGER tri1 instead OF INSERT OR DELETE OR UPDATE ON v1
BEGIN
  INSERT INTO t2 VALUES (:NEW.id,:NEW.name,:NEW.grade,:NEW.pid);
  INSERT INTO t2 VALUES (:OLD.id,:OLD.name,:OLD.grade,:OLD.pid);
END |

DELETE FROM t2;
commit;
