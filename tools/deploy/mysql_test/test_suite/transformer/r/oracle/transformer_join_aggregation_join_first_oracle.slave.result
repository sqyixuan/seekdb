      table_columns([{T: ({PRPCMAIN: (T.PROPOSALNO, T.SUMPREMIUMNOVAT, T.SUMVAT)})}]),
      update([T.SUMPREMIUMNOVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,CASE WHEN A.PROPOSALNO IS NOT NULL THEN A.SUMPREMIUMNOVAT ELSE cast(NULL, DECIMAL_INT(20,
       8)) END)], [T.SUMVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,CASE WHEN A.PROPOSALNO IS NOT NULL THEN A.SUMVAT ELSE cast(NULL, DECIMAL_INT(20, 8)) END)])
  3 - output([T.PROPOSALNO], [T.SUMPREMIUMNOVAT], [T.SUMVAT], [A.PROPOSALNO], [A.SUMPREMIUMNOVAT], [A.SUMVAT]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  4 - output([T.PROPOSALNO], [T.SUMPREMIUMNOVAT], [T.SUMVAT]), filter(nil), rowset=16
      access([T.PROPOSALNO], [T.SUMPREMIUMNOVAT], [T.SUMVAT]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T.PROPOSALNO]), range[a ; a], 
      range_cond([T.PROPOSALNO = cast('a', VARCHAR2(1048576 ))])
  5 - output([A.PROPOSALNO], [A.SUMPREMIUMNOVAT], [A.SUMVAT]), filter(nil), rowset=16
      access([A.PROPOSALNO], [A.SUMPREMIUMNOVAT], [A.SUMVAT]), partitions(p0)
      is_index_back=false, is_global_index=false, 
