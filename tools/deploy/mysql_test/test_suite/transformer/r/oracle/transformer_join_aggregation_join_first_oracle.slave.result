UPDATE prptplan t
SET (t.planFeeNoVat,
     t.delinquentFeeNoVat,
     t.planVat,
     t.delinquentVat) =
 (SELECT /*+no_unnest*/ c.sumpremiumnovat,
         c.sumpremiumnovat,
         c.sumvat,
         c.sumvat
  FROM prpcmain c
  WHERE t.proposalno = c.proposalno)
WHERE t.proposalno = 'a';

