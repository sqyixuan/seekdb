      table_columns([{T: ({PRPTPLAN: (T.PROPOSALNO, T.RISKCODE, T.CURRENCY, T.PLANFEENOVAT, T.DELINQUENTFEENOVAT, T.PLANVAT, T.DELINQUENTVAT)})}]),
      update([T.PLANFEENOVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,C.SUMPREMIUMNOVAT)], [T.DELINQUENTFEENOVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,C.SUMPREMIUMNOVAT)],
       [T.PLANVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,C.SUMVAT)], [T.DELINQUENTVAT=column_conv(DECIMAL_INT,PS:(20,8),NULL,C.SUMVAT)])
  3 - output([T.PROPOSALNO], [T.RISKCODE], [T.CURRENCY], [T.PLANFEENOVAT], [T.DELINQUENTFEENOVAT], [T.PLANVAT], [T.DELINQUENTVAT], [C.SUMPREMIUMNOVAT], 
      [C.SUMPREMIUMNOVAT], [C.SUMVAT], [C.SUMVAT]), filter(nil)
