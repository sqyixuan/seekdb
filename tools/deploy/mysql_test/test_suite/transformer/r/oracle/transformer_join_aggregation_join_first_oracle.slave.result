  (SELECT COUNT( tt2.col_number_5_2)
    FROM test3 tt1 INNER JOIN test2 tt2 ON tt2.col_int < tt1.col_int
    WHERE tt1.col_int <= t1.col_int AND tt2.col_number_5_2_not_null < t1.col_int) AS SELECT_SUBQUERY_ALIAS
FROM test1 t1 INNER JOIN (test2 t2 INNER JOIN test3 t3 ON t3.col_number_5_2 != t2.col_int ) ON t3.col_nchar_2_not_null = t2.col_varchar2_2
WHERE ( t2.col_int = 92)
GROUP BY t1.col_int, CONCAT(t1.col_nchar_2_not_null,t3.col_varchar2_2);
