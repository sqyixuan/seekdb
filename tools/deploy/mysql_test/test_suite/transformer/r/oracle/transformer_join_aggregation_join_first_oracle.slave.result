explain select COL_CHAR_20_NOT_NULL,COL_VARCHAR_20
from t4 T1
where T1.COL_INT >= 
    ( select sum(T7.COL_NUMBER_NOT_NULL) 
      from t8 T7 
      where T7.COL_NUMBER <> 
          ( select avg(T8.COL_INT_NOT_NULL) 
            from  t8 T8 JOIN t7 T9 on T8.COL_CHAR_20_NOT_NULL > T9.COL_VARCHAR_20
            where T7.PK < T9.COL_NUMBER_NOT_NULL 
              and T1.COL_CHAR_20_NOT_NULL = T9.COL_CHAR_20 
              and T8.COL_INT <= (   select count(*) from t1 T10 where T1.COL_VARCHAR_20 > T10.COL_CHAR_20 and T10.PK > T10.PK  )  
          )  
    ) ;
