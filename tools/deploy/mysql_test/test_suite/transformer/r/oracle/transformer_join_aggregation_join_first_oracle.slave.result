drop table t1;
drop table t2;
drop table t3;
drop table tpart;
drop sequence seq;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int);
create table t3 (c1 int, c2 int, c3 int, c4 int);
create table tpart (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 4;
create index gidx_c2 on tpart(c2) global partition by hash(c2) partitions 4;
create sequence seq;
set autocommit=0;
explain_protocol: 2
result_format: 4
## test rownum
EXPLAIN select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1) and rownum <= 5;
Query Plan
==========================================================
|ID|OPERATOR                  |NAME|EST.ROWS|EST.TIME(us)|
----------------------------------------------------------
|0 |EXCHANGE IN REMOTE        |    |1       |177         |
|1 |└─EXCHANGE OUT REMOTE     |    |1       |176         |
|2 |  └─LIMIT                 |    |1       |175         |
|3 |    └─HASH GROUP BY       |    |1       |175         |
|4 |      └─NESTED-LOOP JOIN  |    |25      |168         |
|5 |        ├─TABLE FULL SCAN |T2  |10      |3           |
|6 |        └─TABLE RANGE SCAN|T1  |17      |16          |
==========================================================
Outputs & filters:
-------------------------------------
  0 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4]), filter(nil)
  1 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4]), filter(nil)
  2 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4]), filter(nil), rowset=256
      limit(cast(FLOOR(5), BIGINT(-1, 0))), offset(nil)
  3 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4]), filter([cast(2, NUMBER(-1, -85)) * T1.C2 > T_FUN_SUM(T2.C2) / T_FUN_COUNT(T2.C2)]), rowset=256
      group([T1.C1]), agg_func([T_FUN_SUM(T2.C2)], [T_FUN_COUNT(T2.C2)])
  4 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4], [T2.C2]), filter(nil), rowset=256
      conds(nil), nl_params_([T2.C1(:0)]), use_batch=true
  5 - output([T2.C1], [T2.C2]), filter(nil), rowset=256
      access([T2.C1], [T2.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
  6 - output([T1.C1], [T1.C2], [T1.C3], [T1.C4]), filter(nil), rowset=256
      access([GROUP_ID], [T1.C1], [T1.C2], [T1.C3], [T1.C4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.C1]), range(MIN ; MAX), 
      range_cond([:0 > T1.C1])
