drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table c;
drop table cc;
drop table claim_occur_info;
drop table claim_cal;
drop table claimer_info;
drop table claim_opsn_info;
drop table claim_reg;
CREATE TABLE claim_occur_info 
 ( 
     claim_no           VARCHAR2(20) NOT NULL, 
     occur_time         DATE NOT NULL, 
     occur_cnty_no      VARCHAR2(3), 
     occur_place_no     VARCHAR2(6) DEFAULT '#', 
     province           VARCHAR2(80), 
     city               VARCHAR2(80), 
     county             VARCHAR2(80), 
     occur_place        VARCHAR2(64), 
     occur_course       VARCHAR2(255), 
     occur_cls1_code    VARCHAR2(1) NOT NULL, 
     occur_cls2_code    VARCHAR2(4), 
     occur_cls3_code    VARCHAR2(4), 
     occur_cls4_code    VARCHAR2(4), 
     occur_result_time DATE, 
     occur_result_code VARCHAR2(2), 
     occur_result2_time DATE, 
     occur_result2_code VARCHAR2(2), 
     occur_result3_time DATE, 
     occur_result3_code VARCHAR2(2), 
     CONSTRAINT chk_occur_cls1_code_claim_oc CHECK (occur_cls1_code IN ('1', '2', '3', '4')), 
     CONSTRAINT pk_claim_occur_info PRIMARY KEY (claim_no) USING INDEX 
);

CREATE INDEX idx_claim_occur_info_01 
  ON claim_occur_info (occur_time);

CREATE TABLE claim_cal 
  ( 
     claim_cal_id       NUMBER(12, 0) NOT NULL, 
     claim_cntr_id      NUMBER(12, 0) NOT NULL, 
     ipsn_no            NUMBER(10, 0) NOT NULL, 
     sub_pol_code       VARCHAR2(8) NOT NULL, 
     coverage_no        NUMBER(10, 0) NOT NULL, 
     cover_id           VARCHAR2(20) NOT NULL, 
     gift_flag          VARCHAR2(2) DEFAULT 'N' NOT NULL, 
     cpnst_type_code    VARCHAR2(4), 
     cpnst_cal_code     VARCHAR2(4), 
     cover_amnt         NUMBER(12, 2), 
     cal_cpnst_amnt     NUMBER(12, 2), 
     cpnst_pct          NUMBER(5, 2), 
     cal_cpnst_psn_amnt NUMBER(12, 2), 
     cal_cpnst_si_amnt  NUMBER(12, 2), 
     mio_item_code      VARCHAR2(2), 
     cfm_cpnst_amnt     NUMBER(12, 2), 
     remark             VARCHAR2(2000), 
     claim_no           VARCHAR2(20) NOT NULL, 
     CONSTRAINT chk_coverage_no_claim_ca CHECK (coverage_no >= 0), 
     CONSTRAINT pk_claim_cal PRIMARY KEY (claim_cal_id) USING INDEX 
  );

CREATE INDEX idx_claim_cal_01 
  ON claim_cal (claim_no);

CREATE UNIQUE INDEX uni_claim_cal 
  ON claim_cal (claim_cntr_id, ipsn_no, sub_pol_code, coverage_no, cover_id);

CREATE TABLE claimer_info 
  ( 
     claim_no             VARCHAR2(20) NOT NULL, 
     appl_name            VARCHAR2(200), 
     appl_sex             VARCHAR2(1), 
     appl_id_type         VARCHAR2(1), 
     appl_id_no           VARCHAR2(18), 
     appl_rt_opsn         VARCHAR2(1), 
     appl_mobile          VARCHAR2(30), 
     appl_tel             VARCHAR2(30), 
     appl_email           VARCHAR2(64), 
     appl_address         VARCHAR2(680), 
     appl_post_code       VARCHAR2(6), 
     claimer_message_flag VARCHAR2(20), 
     party_id             NUMBER(18, 0), 
     claimer_type         VARCHAR2(1) DEFAULT 'P' NOT NULL, 
     appl_id_valid_date   DATE, 
     appl_birth_date      DATE, 
     cust_level           VARCHAR2(2), 
     CONSTRAINT chk_claimer_type_claimer_ CHECK (claimer_type IN ('P', 'G')), 
     CONSTRAINT pk_claimer_info PRIMARY KEY (claim_no) USING INDEX 
  );

CREATE INDEX idx_claimer_info_01 
  ON claimer_info (appl_name);

CREATE INDEX idx_claimer_info_02 
  ON claimer_info (appl_mobile);

CREATE INDEX idx_claimer_info_03 
  ON claimer_info (appl_id_type, appl_id_no);

CREATE TABLE claim_opsn_info 
  ( 
     claim_no           VARCHAR2(20) NOT NULL, 
     opsn_name          VARCHAR2(200), 
     opsn_sex           VARCHAR2(1), 
     opsn_birth_date    DATE, 
     opsn_id_type       VARCHAR2(1), 
     opsn_id_no         VARCHAR2(18), 
     party_id           NUMBER(18, 0), 
     opsn_id_valid_date DATE, 
     opsn_cust_no       VARCHAR2(25), 
     CONSTRAINT pk_claim_opsn_info PRIMARY KEY (claim_no) USING INDEX 
  );

CREATE INDEX idx_claim_opsn_info_01 
  ON claim_opsn_info (opsn_name, opsn_sex, opsn_birth_date);

CREATE INDEX idx_claim_opsn_info_02 
  ON claim_opsn_info (opsn_id_no, opsn_id_type);

CREATE INDEX idx_claim_opsn_info_03 
  ON claim_opsn_info (party_id);

CREATE TABLE claim_reg 
  ( 
     claim_no           VARCHAR2(20) NOT NULL, 
     accept_channel     VARCHAR2(1) DEFAULT 'S' NOT NULL, 
     cpnst_appl_type    VARCHAR2(1), 
     claim_appl_date    DATE NOT NULL, 
     sys_accept_time    DATE NOT NULL, 
     accept_branch_no   VARCHAR2(6), 
     accept_clerk_no    VARCHAR2(8), 
     accept_dept_no     NUMBER(4, 0), 
     accept_time        DATE, 
     fclk_branch_no     VARCHAR2(6), 
     fclk_no            VARCHAR2(8), 
     pclk_branch_no     VARCHAR2(6), 
     pclk_no            VARCHAR2(8), 
     vclk_branch_no     VARCHAR2(6), 
     vclk_no            VARCHAR2(8), 
     eclk_branch_no     VARCHAR2(6), 
     eclk_no            VARCHAR2(8), 
     arc_branch_no      VARCHAR2(6), 
     claim_close_time   DATE, 
     cpnst_arc_no       VARCHAR2(20), 
     claim_proc_stat    VARCHAR2(1), 
     claim_control_stat VARCHAR2(1) DEFAULT 'N' NOT NULL, 
     claim_stl_stat     VARCHAR2(1) DEFAULT 'N' NOT NULL, 
     is_invsgt          VARCHAR2(1) DEFAULT 'N', 
     is_assignee        VARCHAR2(1) DEFAULT 'N', 
     is_udw_ask         VARCHAR2(1) DEFAULT 'N', 
     assign_acc_type    VARCHAR2(1) DEFAULT 'N', 
     is_scan            VARCHAR2(2) DEFAULT '0', 
     accept_sub_channel VARCHAR2(20), 
     fclk_time          DATE, 
     pclk_time          DATE, 
     last_pay_time      DATE, 
     CONSTRAINT chk_claim_control_sta_claim_re CHECK (claim_control_stat IN ('N' 
     , 'S', 'L', 'B', 'O', 'A', 'P', 'F', 'V', 'E', 'R', 'W', 'D')), 
     CONSTRAINT chk_assign_acc_type_claim_re CHECK (assign_acc_type IS NULL OR ( 
     assign_acc_type IN ('C', 'Q', 'T', 'N'))), 
     CONSTRAINT chk_cpnst_appl_type_claim_re CHECK (cpnst_appl_type IS NULL OR ( 
     cpnst_appl_type IN ('P', 'A', 'G', 'S'))), 
     CONSTRAINT chk_claim_stl_stat_claim_re CHECK (claim_stl_stat IN ('N', 'K', 
     'C', 'W', 'P', 'E')), 
     CONSTRAINT chk_accept_channel_claim_re CHECK (accept_channel IN ('S', 'T', 
     'E', 'N', 'M', 'F', 'Y', 'A', 'G', 'P')), 
     CONSTRAINT chk_claim_proc_stat_claim_re CHECK (claim_proc_stat IS NULL OR ( 
     claim_proc_stat IN ('N', 'S', 'O', 'P', 'V', 'E', 'R', 'W', 'D'))) 
  ) partition BY RANGE (sys_accept_time) (PARTITION p1 VALUES less than (to_date 
(' 2018-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')), 
PARTITION p2 VALUES less than (to_date(' 2019-01-01 00:00:00', 
'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')), PARTITION p3 VALUES less 
than (to_date(' 2020-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 
'NLS_CALENDAR=GREGORIAN')), PARTITION p4 VALUES less than (to_date( 
' 2021-01-01 00:00:00', 'SYYYY-MM-DD HH24:MI:SS', 'NLS_CALENDAR=GREGORIAN')) );

CREATE INDEX idx_claim_reg_01 
  ON claim_reg (claim_close_time, accept_branch_no);

CREATE INDEX idx_claim_reg_02 
  ON claim_reg (accept_time, accept_branch_no);

CREATE INDEX idx_claim_reg_03 
  ON claim_reg (claim_appl_date, accept_branch_no);

CREATE INDEX idx_claim_reg_04 
  ON claim_reg (sys_accept_time);

CREATE UNIQUE INDEX idx_claim_req_05 
  ON claim_reg(claim_no);


EXPLAIN SELECT cr.claim_no, 
       cr.accept_channel, 
       cr.cpnst_appl_type, 
       coi.opsn_name, 
       coi.opsn_sex, 
       To_char(coi.opsn_birth_date, 'yyyy-mm-dd') AS opsn_birth_date, 
       coi.opsn_id_type, 
       coi.opsn_id_no, 
       ci.appl_mobile, 
       cr.claim_proc_stat, 
       cr.claim_control_stat, 
       To_char(cr.accept_time, 'yyyy-mm-dd')      AS accept_time, 
       To_char(cr.claim_close_time, 'yyyy-mm-dd') AS CLAIM_CLOSE_TIME, 
       (SELECT To_char(occur_time, 'YYYY-MM-DD HH24:mi:ss') 
        FROM   claim_occur_info occ 
        WHERE  cr.claim_no = occ.claim_no)        OCCUR_TIME, 
       (SELECT Sum(cc.cfm_cpnst_amnt) 
        FROM   claim_cal cc 
        WHERE  cr.claim_no = cc.claim_no)         CFM_CPNST_AMNT, 
       cc2.cpnst_type_name                        CPNST_TYPE_NAME 
FROM   claimer_info ci, 
       claim_opsn_info coi, 
       claim_reg cr 
       LEFT JOIN (SELECT claim_no, 
                         Decode(Max(SUBSTR(cpnst_type_code, 0, 1)), '1', 
                         '约定给付' 
                                      , 
                                                                    '2', 
                         '比例给付' 
                                      , 
                                                                    '3', 
                         '协议给付' 
                                      , 
                                                                    '4', 
                         '拒绝给付' 
                                      , 
                                                                    '') 
                         CPNST_TYPE_NAME 
                  FROM   claim_cal 
                  WHERE  SUBSTR(cpnst_type_code, 0, 1) IN ( '1', '2', '3', '4' ) 
                  GROUP  BY claim_no) cc2 
              ON cc2.claim_no = cr.claim_no 
WHERE  cr.claim_no = ci.claim_no 
       AND cr.claim_no = coi.claim_no 
       AND cr.claim_no = '123456';
