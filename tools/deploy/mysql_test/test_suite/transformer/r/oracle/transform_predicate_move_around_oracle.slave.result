drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1(c1 int, c2 int, c3 varchar(32));
create table t2(c1 int, c2 int, c3 varchar(32));
create table t3(c1 int, c2 int, c3 varchar(32));
create table t4(c1 int, c2 int, c3 varchar(32));
explain_protocol: 2
result_format: 4
## A. 推导的测试
## stmt 内 join 谓词推导
EXPLAIN select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
Query Plan
===============================================================
|ID|OPERATOR                       |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |EXCHANGE IN REMOTE             |    |1       |5           |
|1 |└─EXCHANGE OUT REMOTE          |    |1       |4           |
|2 |  └─NESTED-LOOP JOIN CARTESIAN |    |1       |3           |
|3 |    ├─TABLE FULL SCAN          |T1  |1       |3           |
|4 |    └─MATERIAL                 |    |1       |3           |
|5 |      └─TABLE FULL SCAN        |T2  |1       |3           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([T1.C3], [T2.C3]), filter(nil)
  1 - output([T1.C3], [T2.C3]), filter(nil)
  2 - output([T1.C3], [T2.C3]), filter(nil), rowset=16
      conds(nil), nl_params_(nil), use_batch=false
  3 - output([T1.C3]), filter([T1.C1 = cast(1, NUMBER(-1, -85))]), rowset=16
      access([T1.C1], [T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
  4 - output([T2.C3]), filter(nil), rowset=16
  5 - output([T2.C3]), filter([cast(1, NUMBER(-1, -85)) = T2.C1]), rowset=16
      access([T2.C1], [T2.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| x    | o    |
+------+------+
