SELECT cr.claim_no, 
       cr.accept_channel, 
       cr.cpnst_appl_type, 
       coi.opsn_name, 
       coi.opsn_sex, 
       To_char(coi.opsn_birth_date, 'yyyy-mm-dd') AS opsn_birth_date, 
       coi.opsn_id_type, 
       coi.opsn_id_no, 
       ci.appl_mobile, 
       cr.claim_proc_stat, 
       cr.claim_control_stat, 
       To_char(cr.accept_time, 'yyyy-mm-dd')      AS accept_time, 
       To_char(cr.claim_close_time, 'yyyy-mm-dd') AS CLAIM_CLOSE_TIME, 
       (SELECT To_char(occur_time, 'YYYY-MM-DD HH24:mi:ss') 
        FROM   claim_occur_info occ 
        WHERE  cr.claim_no = occ.claim_no)        OCCUR_TIME, 
       (SELECT Sum(cc.cfm_cpnst_amnt) 
        FROM   claim_cal cc 
        WHERE  cr.claim_no = cc.claim_no)         CFM_CPNST_AMNT, 
       cc2.cpnst_type_name                        CPNST_TYPE_NAME 
FROM   claimer_info ci, 
       claim_opsn_info coi, 
       claim_reg cr 
       LEFT JOIN (SELECT claim_no, 
                         Decode(Max(SUBSTR(cpnst_type_code, 0, 1)), '1', 
                         '约定给付' 
                                      , 
                                                                    '2', 
                         '比例给付' 
                                      , 
                                                                    '3', 
                         '协议给付' 
                                      , 
                                                                    '4', 
                         '拒绝给付' 
                                      , 
                                                                    '') 
                         CPNST_TYPE_NAME 
                  FROM   claim_cal 
                  WHERE  SUBSTR(cpnst_type_code, 0, 1) IN ( '1', '2', '3', '4' ) 
                  GROUP  BY claim_no) cc2 
              ON cc2.claim_no = cr.claim_no 
WHERE  cr.claim_no = ci.claim_no 
       AND cr.claim_no = coi.claim_no 
       AND cr.claim_no = '123456';
