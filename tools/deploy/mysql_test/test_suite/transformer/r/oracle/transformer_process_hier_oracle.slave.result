 12 - output([S.CLERK_NO], [S.NAME], [S.MOBILE_NO], [S.EMAIL], [S.EMP_STATUS]), filter(nil), rowset=16
      access([S.CLERK_NO], [S.NAME], [S.MOBILE_NO], [S.EMAIL], [S.EMP_STATUS]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([S.CLERK_NO], [S.NAME]), range(MIN,MIN ; 13200093,MIN), (13200093,MAX ; NULL,MIN), 
