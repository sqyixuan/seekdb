       [T.PROCESSING_CENTER], [T.ARC_BRANCH_NO], [T.PRINT_BRANCH_NO], [T.PRINT_BRANCH_NAME]), filter(nil), rowset=16
      access([T.BRANCH_NO], [T.BRANCH_STATUS], [T.JOB_CENTER_FLAG], [T.PRIO_BRANCH_NO], [T.BRANCH_NAME], [T.POST_CODE], [T.TEL], [T.ADDRESS], [T.EMAIL],
       [T.PROCESSING_CENTER], [T.ARC_BRANCH_NO], [T.PRINT_BRANCH_NO], [T.PRINT_BRANCH_NAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T.BRANCH_NO]), range[000000 ; 000000], 
      range_cond([T.BRANCH_NO = cast('000000', VARCHAR2(1048576 ))])
  9 - output([VIEW2.T.BRANCH_NO], [VIEW2.T.BRANCH_STATUS], [VIEW2.T.JOB_CENTER_FLAG], [VIEW2.T.PRIO_BRANCH_NO], [VIEW2.T.BRANCH_NAME], [VIEW2.T.POST_CODE],
       [VIEW2.T.TEL], [VIEW2.T.ADDRESS], [VIEW2.T.EMAIL], [VIEW2.T.PROCESSING_CENTER], [VIEW2.T.ARC_BRANCH_NO], [VIEW2.T.PRINT_BRANCH_NO], [VIEW2.T.PRINT_BRANCH_NAME]), filter(nil), rowset=16
      access([VIEW2.T.BRANCH_NO], [VIEW2.T.BRANCH_STATUS], [VIEW2.T.JOB_CENTER_FLAG], [VIEW2.T.PRIO_BRANCH_NO], [VIEW2.T.BRANCH_NAME], [VIEW2.T.POST_CODE],
       [VIEW2.T.TEL], [VIEW2.T.ADDRESS], [VIEW2.T.EMAIL], [VIEW2.T.PROCESSING_CENTER], [VIEW2.T.ARC_BRANCH_NO], [VIEW2.T.PRINT_BRANCH_NO], [VIEW2.T.PRINT_BRANCH_NAME])
