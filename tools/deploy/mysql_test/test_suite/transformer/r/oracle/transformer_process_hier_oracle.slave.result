SELECT Count(1) 
FROM   (SELECT DISTINCT A.branch_no, 
                        A.clerk_no, 
                        A.name, 
                        B.resource_iD, 
                        B.resource_name, 
                        C.resource_name_path 
        FROM   v_clerk_info A, 
               v_clerk_resource B, 
               v_resource_path C 
        WHERE  A.clerk_no = B.clerk_no 
               AND B.resource_id = C.resource_id 
               AND C.is_leaf = 1 
               AND A.branch_no = '110000'
               AND EXISTS (SELECT 1 
                           FROM   (SELECT brANCH_NO, 
                                          prio_branch_no 
                                   FROM   a_branch T2 
                                   START WITH T2.branch_no = '000000'
                                   CONNECT BY PRIOR 
                                   T2.branch_no = T2.prio_branch_no) 
                                  TT2 
                           WHERE  A.branch_no = TT2.branch_no));
+----------+
| COUNT(1) |
+----------+
|        0 |
+----------+

EXPLAIN select count(1)
from V_CLERK_INFO A, A_CLERK_ROLE B, A_ROLE C
where A.CLERK_NO = B.CLERK_NO
        and B.ROLE_ID = C.ROLE_ID
        and A.BRANCH_NO = '110000'
        and exists (
                select 1
                from (
                        select BRANCH_NO, PRIO_BRANCH_NO
                        from A_BRANCH T2
                        start with T2.BRANCH_NO = '000000'
                        connect by prior T2.BRANCH_NO = T2.PRIO_BRANCH_NO
                ) TT2
                where A.BRANCH_NO = TT2.BRANCH_NO
        );
