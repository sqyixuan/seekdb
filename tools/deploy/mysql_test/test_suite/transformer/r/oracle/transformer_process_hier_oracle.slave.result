CREATE OR REPLACE TYPE names_nt IS TABLE OF VARCHAR2 ( 1000 );
$
CREATE OR REPLACE FUNCTION lotsa_names (  
   base_name_in   IN   VARCHAR2  
 , count_in       IN   INTEGER  
)  
   RETURN names_nt  
IS  
   retval names_nt := names_nt ( );  
BEGIN  
   retval.EXTEND ( count_in );  
  
   FOR indx IN 1 .. count_in  
   LOOP  
      retval ( indx ) := base_name_in || indx;  
   END LOOP;  
  
   RETURN retval;  
END lotsa_names;
$
EXPLAIN SELECT * FROM (SELECT COLUMN_VALUE c1 FROM TABLE ( lotsa_names ( 'A', 10 )) names) V START WITH C1 > 'A1' CONNECT BY NOCYCLE PRIOR C1 = 'A2';
