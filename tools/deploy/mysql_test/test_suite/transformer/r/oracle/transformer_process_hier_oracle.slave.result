       [T.PROCESSING_CENTER], [T.ARC_BRANCH_NO], [T.PRINT_BRANCH_NO], [T.PRINT_BRANCH_NAME]), filter(nil), rowset=16
      access([T.BRANCH_NO], [T.BRANCH_STATUS], [T.JOB_CENTER_FLAG], [T.PRIO_BRANCH_NO], [T.BRANCH_NAME], [T.POST_CODE], [T.TEL], [T.ADDRESS], [T.EMAIL],
       [T.PROCESSING_CENTER], [T.ARC_BRANCH_NO], [T.PRINT_BRANCH_NO], [T.PRINT_BRANCH_NAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T.BRANCH_NO]), range(MIN ; MAX)always true
select *
from (
        select A.*, ROWNUM as RN
        from (
                select *
                from (
                        select T.BRANCH_NO, T.BRANCH_NAME, T.PRIO_BRANCH_NO, T.POST_CODE, T.TEL
                                , T.ADDRESS, T.EMAIL, T.PROCESSING_CENTER, T.ARC_BRANCH_NO, T.PRINT_BRANCH_NO
                                , T.BRANCH_STATUS, T.PRINT_BRANCH_NAME, T.JOB_CENTER_FLAG
                        from A_BRANCH T
                        start with BRANCH_NO = '000000'
                        connect by prior BRANCH_NO = PRIO_BRANCH_NO
                ) T
                where 1 = 1
                        and T.BRANCH_NO = '120000'
                order by BRANCH_NO asc
        ) A
        where ROWNUM <= 5
)
where RN >= 1;
+-----------+-------------+----------------+-----------+-----+---------+-------+-------------------+---------------+-----------------+---------------+-------------------+-----------------+------+
| BRANCH_NO | BRANCH_NAME | PRIO_BRANCH_NO | POST_CODE | TEL | ADDRESS | EMAIL | PROCESSING_CENTER | ARC_BRANCH_NO | PRINT_BRANCH_NO | BRANCH_STATUS | PRINT_BRANCH_NAME | JOB_CENTER_FLAG | RN   |
+-----------+-------------+----------------+-----------+-----+---------+-------+-------------------+---------------+-----------------+---------------+-------------------+-----------------+------+
+-----------+-------------+----------------+-----------+-----+---------+-------+-------------------+---------------+-----------------+---------------+-------------------+-----------------+------+

EXPLAIN select BRANCH_NO, BRANCH_NAME
from (
        select T.BRANCH_NO, T.BRANCH_NAME
        from A_BRANCH T
        start with BRANCH_NO = '000000'
        connect by prior BRANCH_NO = PRIO_BRANCH_NO
)
where BRANCH_NO not in (
        select T.BRANCH_NO
        from A_BRANCH T
        start with BRANCH_NO = '120000'
        connect by prior BRANCH_NO = PRIO_BRANCH_NO
)
order by BRANCH_NO;
