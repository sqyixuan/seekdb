EXPLAIN select A.*
from (
        select A.CLERK_NO, A.BRANCH_NO, A.DEPT_NO, A.ACCEPT_TASK_FLAG, A.NAME
                , A.MOBILE_NO as MOBILE, A.EMAIL, A.EMP_STATUS as CLERK_STATUS, ROWNUM as RN
        from V_CLERK_INFO A
        where A.BRANCH_NO in (
                        select Branch_No
                        from A_BRANCH t
                        start with BRANCH_NO = '000000'
                        connect by prior BRANCH_NO = PRIO_BRANCH_NO
                )
                and clerk_no <> '13200093'
        order by 1 asc
) A
where RN between 1 and 5;
