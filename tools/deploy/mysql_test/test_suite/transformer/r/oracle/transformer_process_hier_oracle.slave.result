select A.CLERK_NO, A.BRANCH_NO, A.DEPT_NO, A.ACCEPT_TASK_FLAG, A.NAME
        , A.MOBILE_NO as MOBILE, A.EMAIL, A.EMP_STATUS as CLERK_STATUS, ROWNUM as RN
from V_CLERK_INFO A
where A.BRANCH_NO in (
                select Branch_No
                from A_BRANCH t
                start with BRANCH_NO = '000000'
                connect by prior BRANCH_NO = PRIO_BRANCH_NO
        )
        and clerk_no <> '13200093';
+----------+-----------+---------+------------------+------+--------+-------+--------------+------+
| CLERK_NO | BRANCH_NO | DEPT_NO | ACCEPT_TASK_FLAG | NAME | MOBILE | EMAIL | CLERK_STATUS | RN   |
+----------+-----------+---------+------------------+------+--------+-------+--------------+------+
+----------+-----------+---------+------------------+------+--------+-------+--------------+------+

EXPLAIN select *
from (
        select A.*, ROWNUM as RN
        from (
                select /*+USE_NL_MATERIALIZATION(q1 TT2)*/distinct A.BRANCH_NO, A.CLERK_NO, A.NAME, B.RESOURCE_ID, B.RESOURCE_NAME
                        , C.RESOURCE_NAME_PATH
                from V_CLERK_INFO A, V_CLERK_RESOURCE B, V_RESOURCE_PATH C
                where A.CLERK_NO = B.CLERK_NO
                        and B.RESOURCE_ID = C.RESOURCE_ID
                        and C.IS_LEAF = 1
                        and A.BRANCH_NO = '110000'
                        and exists (
                                select 1/*+QB_NAME(q1)*/
                                from (
                                        select /*+no_merge*/ BRANCH_NO, PRIO_BRANCH_NO
                                        from A_BRANCH T2
                                        start with T2.BRANCH_NO = '000000'
                                        connect by prior T2.BRANCH_NO = T2.PRIO_BRANCH_NO
                                ) TT2
                                where A.BRANCH_NO = TT2.BRANCH_NO
                        )
                order by A.CLERK_NO asc
        ) A
        where ROWNUM <= 10
)
where RN >= 1 ;
