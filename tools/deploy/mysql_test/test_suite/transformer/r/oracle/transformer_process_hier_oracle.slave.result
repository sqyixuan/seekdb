from (
        select A.CLERK_NO, A.BRANCH_NO, A.DEPT_NO, A.ACCEPT_TASK_FLAG, A.NAME
                , A.MOBILE_NO as MOBILE, A.EMAIL, A.EMP_STATUS as CLERK_STATUS, ROWNUM as RN
        from V_CLERK_INFO A
