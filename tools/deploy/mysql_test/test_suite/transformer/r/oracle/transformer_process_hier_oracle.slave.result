DROP VIEW V_CLERK_INFO;
DROP TABLE A_SYNC_CLERK;
DROP VIEW V_RESOURCE_PATH;
DROP TABLE P_COMMON_MENU;
DROP VIEW V_CLERK_RESOURCE;
DROP TABLE A_CLERK_ROLE;
DROP TABLE A_CLERK;
DROP TABLE A_DEPARTMENT;
DROP TABLE A_BRANCH;
DROP TABLE A_ROLE_RESOURCE;
DROP TABLE A_ROLE;
DROP TABLE A_RESOURCE;

CREATE TABLE "A_RESOURCE"
   (    "RESOURCE_ID" VARCHAR2(50) NOT NULL ,
        "RESOURCE_PARENT_ID" VARCHAR2(50),
        "SYS_CODE" VARCHAR2(8) NOT NULL ,
        "ICON_TYPE" VARCHAR2(20),
        "RESOURCE_NAME" VARCHAR2(100),
        "RESOURCE_MOD_TYPE" VARCHAR2(2) NOT NULL ,
        "RESOURCE_TYPE" VARCHAR2(2) NOT NULL ,
        "RESOURCE_URL" VARCHAR2(512),
        "PERMISSION_SYS" VARCHAR2(30) NOT NULL ,
        "PERMISSION_HTM" VARCHAR2(30),
        "PERMISSION_BTN" VARCHAR2(30),
        "ORDER_ID" NUMBER(10,2),
         CONSTRAINT "CHK_RESOURCE_MOD_TYPE_A_RESOUR" CHECK (RESOURCE_MOD_TYPE IN ('M','T','S')) ,
         CONSTRAINT "CHK_RESOURCE_TYPE_A_RESOUR" CHECK (RESOURCE_TYPE IN ('S','M','H','B')) ,
         CONSTRAINT "PK_A_RESOURCE" PRIMARY KEY ("RESOURCE_ID")
   );

CREATE TABLE "A_ROLE"
   (    "ROLE_ID" VARCHAR2(6) NOT NULL ,
        "ROLE_NAME" VARCHAR2(100) NOT NULL ,
        "ROLE_GROUP" VARCHAR2(2) NOT NULL ,
        "ENABLE_FLAG" VARCHAR2(2) NOT NULL ,
         CONSTRAINT "CHK_ROLE_GROUP_A_ROLE" CHECK (ROLE_GROUP IN ('SM','CD','CL','CS','NC','UW','RP')) ,
         CONSTRAINT "CHK__FLAG_A_ROLE" CHECK (ENABLE_FLAG IN ('Y','N')) ,
         CONSTRAINT "PK_S_ROLE" PRIMARY KEY ("ROLE_ID")
   );

CREATE TABLE "A_ROLE_RESOURCE"
   (    "ROLE_ID" VARCHAR2(6) NOT NULL,
        "PERMISSION_SYS" VARCHAR2(30),
        "PERMISSION_HTM" VARCHAR2(30),
        "PERMISSION_BTN" VARCHAR2(30),
         CONSTRAINT "FK_A_ROLE_RESOURCE_1" FOREIGN KEY ("ROLE_ID")
          REFERENCES "A_ROLE" ("ROLE_ID")
   );

CREATE TABLE "A_BRANCH"
   (    "BRANCH_NO" VARCHAR2(6) NOT NULL,
        "BRANCH_NAME" VARCHAR2(128) NOT NULL,
        "PRIO_BRANCH_NO" VARCHAR2(6),
        "POST_CODE" VARCHAR2(6) NOT NULL,
        "TEL" VARCHAR2(30) NOT NULL,
        "ADDRESS" VARCHAR2(680) NOT NULL,
        "EMAIL" VARCHAR2(64),
        "PROCESSING_CENTER" VARCHAR2(6),
        "ARC_BRANCH_NO" VARCHAR2(6) NOT NULL,
        "PRINT_BRANCH_NO" VARCHAR2(6) NOT NULL,
        "PRINT_BRANCH_NAME" VARCHAR2(64) NOT NULL,
        "BRANCH_STATUS" VARCHAR2(2) NOT NULL,
        "JOB_CENTER_FLAG" VARCHAR2(2) NOT NULL,
         CONSTRAINT "CHK_BRANCH_STATUS_A_BRANCH" CHECK (BRANCH_STATUS IN ('1','0')),
         CONSTRAINT "PK_A_BRANCH" PRIMARY KEY ("BRANCH_NO"),
         CONSTRAINT "CHK_JOB_CENTER_FLAG_A_BRANCH" CHECK (JOB_CENTER_FLAG IN ('Y','N'))
   );

CREATE TABLE "A_DEPARTMENT"
   (    "BRANCH_NO" VARCHAR2(6) NOT NULL,
        "DEPT_NO" NUMBER(4,0) NOT NULL,
        "DEPT_NAME" VARCHAR2(128) NOT NULL,
        "DEPT_CLASS" VARCHAR2(2) NOT NULL,
        "DEPT_STATUS" VARCHAR2(2) NOT NULL,
         CONSTRAINT "CHK_DEPT_CLASS_A_DEPART" CHECK (DEPT_CLASS IN ('SM','CD','CL','CS','NC','UW','RP')),
         CONSTRAINT "CHK_DEPT_STATUS_A_DEPART" CHECK (DEPT_STATUS IN ('1','0')),
         CONSTRAINT "PK_A_DEPARTMENT" PRIMARY KEY ("BRANCH_NO", "DEPT_NO"),
         CONSTRAINT "FK_A_DEPARTMENT_1" FOREIGN KEY ("BRANCH_NO")
          REFERENCES "A_BRANCH" ("BRANCH_NO")
   );

CREATE TABLE "A_CLERK"
   (    "BRANCH_NO" VARCHAR2(6) NOT NULL,
        "DEPT_NO" NUMBER(4,0) NOT NULL,
        "CLERK_NO" VARCHAR2(8) NOT NULL,
        "NAME" VARCHAR2(200),
        "PASSWORD" VARCHAR2(64),
        "PASSWORD_SALT" VARCHAR2(100),
        "TEL" VARCHAR2(30),
        "MOBILE" VARCHAR2(30),
        "EMAIL" VARCHAR2(64),
        "LOCK_FLAG" VARCHAR2(2),
        "ACCEPT_TASK_FLAG" VARCHAR2(2) NOT NULL,
        "CENTER_CODE" VARCHAR2(20),
        "CLERK_STATUS" VARCHAR2(2),
        "LOGIN_FAIL_NUM" NUMBER(2,0),
        "SESSION_ID" VARCHAR2(200),
         CONSTRAINT "CHK_ACCEPT_TASK_FLAG_A_CLERK" CHECK (ACCEPT_TASK_FLAG IN ('Y','N')),
         CONSTRAINT "PK_A_CLERK" PRIMARY KEY ("CLERK_NO"),
         CONSTRAINT "FK_A_CLERK_1" FOREIGN KEY ("BRANCH_NO", "DEPT_NO")
          REFERENCES "A_DEPARTMENT" ("BRANCH_NO", "DEPT_NO")
   );

CREATE TABLE "A_CLERK_ROLE"
   (    "CLERK_NO" VARCHAR2(8) NOT NULL,
        "ROLE_ID" VARCHAR2(6) NOT NULL,
         CONSTRAINT "FK_A_CLERK_ROLE_1" FOREIGN KEY ("CLERK_NO")
          REFERENCES "A_CLERK" ("CLERK_NO"),
         CONSTRAINT "FK_A_CLERK_ROLE_2" FOREIGN KEY ("ROLE_ID")
          REFERENCES "A_ROLE" ("ROLE_ID")
   );

CREATE OR REPLACE VIEW "V_CLERK_RESOURCE" (                                  
"CLERK_NO", "ROLE_ID", "RESOURCE_ID", "RESOURCE_PARENT_ID", "ICON_TYPE", "RESOURCE_NAME", "RESOURCE_MOD_TYPE", "RESOURCE_TYPE", "RESOURCE_URL", "PERMISSION_SYS", "PERMISSION_HTM", "PERMISSION_BTN", "ORDER_ID") AS 
SELECT A.CLERK_NO,
       B.ROLE_ID,
       B.RESOURCE_ID,
       B.RESOURCE_PARENT_ID,
       B.ICON_TYPE,
       B.RESOURCE_NAME,
       B.RESOURCE_MOD_TYPE,
       B.RESOURCE_TYPE,
       B.RESOURCE_URL,
       B.PERMISSION_SYS,
       B.PERMISSION_HTM,
       B.PERMISSION_BTN,
       B.ORDER_ID
  FROM (SELECT B.ROLE_ID,
               C.RESOURCE_ID,
               C.RESOURCE_PARENT_ID,
               C.ICON_TYPE,
               C.RESOURCE_NAME,
               C.RESOURCE_MOD_TYPE,
               C.RESOURCE_TYPE,
               C.RESOURCE_URL,
               C.PERMISSION_SYS,
               C.PERMISSION_HTM,
               C.PERMISSION_BTN,
               C.ORDER_ID
          FROM A_ROLE_RESOURCE B, A_RESOURCE C
          WHERE ((B.PERMISSION_SYS = C.PERMISSION_SYS AND
               B.PERMISSION_HTM IS NULL AND B.PERMISSION_BTN IS NULL) OR
               (B.PERMISSION_SYS = C.PERMISSION_SYS AND
               B.PERMISSION_HTM = C.PERMISSION_HTM AND
               B.PERMISSION_BTN IS NULL) OR
               (B.PERMISSION_SYS = C.PERMISSION_SYS AND
               B.PERMISSION_HTM = C.PERMISSION_HTM AND
               B.PERMISSION_BTN = C.PERMISSION_BTN))) B
  LEFT JOIN A_CLERK_ROLE A
    ON A.ROLE_ID = B.ROLE_ID;

CREATE TABLE "P_COMMON_MENU"
   (    "CLERK_NO" VARCHAR2(8),
        "RESOURCE_ID" VARCHAR2(50) NOT NULL,
        "ORDER_ID" NUMBER(10,2),
         CONSTRAINT "FK_P_COMMON_MENU_1" FOREIGN KEY ("CLERK_NO")
          REFERENCES "A_CLERK" ("CLERK_NO")
   );

CREATE OR REPLACE VIEW "V_RESOURCE_PATH" ("RESOURCE_ID", "RESOURCE_NAME", "RESOURCE_ROOT_NAME", "IS_LEAF", "LEVEL_NO", "RESOURCE_NAME_PATH") AS
  SELECT RESOURCE_ID,
        RESOURCE_NAME,
        CONNECT_BY_ROOT  RESOURCE_NAME AS RESOURCE_ROOT_NAME, 
        CONNECT_BY_ISLEAF AS IS_LEAF, 
        LEVEL AS LEVEL_NO,
        SYS_CONNECT_BY_PATH(RESOURCE_NAME, '-->') AS RESOURCE_NAME_PATH
FROM A_RESOURCE
START WITH RESOURCE_PARENT_ID IS NULL
CONNECT BY PRIOR RESOURCE_ID = RESOURCE_PARENT_ID;

CREATE TABLE "A_SYNC_CLERK"
   (    "CLERK_NO" VARCHAR2(8) NOT NULL,
        "NAME" VARCHAR2(200) NOT NULL,
        "CARDID" VARCHAR2(18),
        "MOBILE_NO" VARCHAR2(30),
        "EMAIL" VARCHAR2(64),
        "SEX" VARCHAR2(2),
        "AD_ORG" VARCHAR2(8),
        "AD_POST" VARCHAR2(8),
        "AUTH_POST" VARCHAR2(50),
        "RANK" VARCHAR2(20),
        "EMP_STATUS" VARCHAR2(2),
        "EMP_MOBILE_NO" VARCHAR2(30),
        "EMP_EMAIL" VARCHAR2(64),
        "EXTENDS_INFO" VARCHAR2(4000),
        "UPDATE_TIME" TIMESTAMP (6),
        "PASSWORD" VARCHAR2(300),
        "APP_INFO" VARCHAR2(4000),
        "LAST_UPDATE_TIMESTAMP" TIMESTAMP (6),
         CONSTRAINT "PK_A_SYNC_CLERK" PRIMARY KEY ("CLERK_NO", "NAME")
   );

CREATE OR REPLACE VIEW "V_CLERK_INFO" ("CLERK_NO", "BRANCH_NO", "DEPT_NO", "ACCEPT_TASK_FLAG", "NAME", "CARDID", "MOBILE_NO", "EMAIL", "EMP_STATUS", "SEX", "RANK","AD_ORG", "AD_POST", "AUTH_POST") AS
  SELECT A.CLERK_NO,
       A.BRANCH_NO,
       A.DEPT_NO,
       A.ACCEPT_TASK_FLAG,
       S.NAME,
       S.CARDID,
       S.MOBILE_NO,
       S.EMAIL,
       S.EMP_STATUS,
       CASE S.SEX
         WHEN '01' THEN
          'M'
         WHEN '02' THEN
          'F'
         WHEN '00' THEN
          'B'
         ELSE
          SEX
       END AS SEX,
       S.RANK,
       S.AD_ORG,
       S.AD_POST,
       S.AUTH_POST
  FROM A_SYNC_CLERK S, A_CLERK A
 WHERE A.CLERK_NO = S.CLERK_NO;

EXPLAIN select LEVEL as ID, C.*
from (
        select A.RESOURCE_ID, A.RESOURCE_PARENT_ID, A.SYS_CODE, A.ICON_TYPE, A.RESOURCE_NAME
                , A.RESOURCE_MOD_TYPE, A.RESOURCE_TYPE, A.RESOURCE_URL, A.PERMISSION_SYS, A.PERMISSION_HTM
                , A.PERMISSION_BTN, P.ORDER_ID, A.ORDER_ID as ORDER_ID_1
                , NVL2(P.CLERK_NO, 1, 0) as COMMONLY
        from (
                select distinct *
                from A_RESOURCE T
                start with RESOURCE_ID in (
                        select T.RESOURCE_ID
                        from V_CLERK_RESOURCE T
                        where T.CLERK_NO = '18100446'
                )
                connect by prior RESOURCE_PARENT_ID = RESOURCE_ID
        ) A
                left join (
                        select *
                        from P_COMMON_MENU
                        where CLERK_NO = '18100446'
                ) P
                on A.RESOURCE_ID = P.RESOURCE_ID
        where A.PERMISSION_BTN is null
) C
start with C.RESOURCE_PARENT_ID is null
connect by prior C.RESOURCE_ID = C.RESOURCE_PARENT_ID
order by ID, C.ORDER_ID_1;
