select *
from (
        select A.*, ROWNUM as RN
        from (
                select /*+USE_NL_MATERIALIZATION(q1 TT2)*/distinct A.BRANCH_NO, A.CLERK_NO, A.NAME, B.RESOURCE_ID, B.RESOURCE_NAME
                        , C.RESOURCE_NAME_PATH
                from V_CLERK_INFO A, V_CLERK_RESOURCE B, V_RESOURCE_PATH C
                where A.CLERK_NO = B.CLERK_NO
                        and B.RESOURCE_ID = C.RESOURCE_ID
                        and C.IS_LEAF = 1
                        and A.BRANCH_NO = '110000'
                        and exists (
                                select 1/*+QB_NAME(q1)*/
                                from (
                                        select /*+no_merge*/ BRANCH_NO, PRIO_BRANCH_NO
                                        from A_BRANCH T2
                                        start with T2.BRANCH_NO = '000000'
                                        connect by prior T2.BRANCH_NO = T2.PRIO_BRANCH_NO
                                ) TT2
                                where A.BRANCH_NO = TT2.BRANCH_NO
                        )
                order by A.CLERK_NO asc
        ) A
        where ROWNUM <= 10
)
where RN >= 1 ;
+-----------+----------+------+-------------+---------------+--------------------+------+
| BRANCH_NO | CLERK_NO | NAME | RESOURCE_ID | RESOURCE_NAME | RESOURCE_NAME_PATH | RN   |
+-----------+----------+------+-------------+---------------+--------------------+------+
+-----------+----------+------+-------------+---------------+--------------------+------+

EXPLAIN SELECT Count(1) 
FROM   (SELECT DISTINCT A.branch_no, 
                        A.clerk_no, 
                        A.name, 
                        B.resource_iD, 
                        B.resource_name, 
                        C.resource_name_path 
        FROM   v_clerk_info A, 
               v_clerk_resource B, 
               v_resource_path C 
        WHERE  A.clerk_no = B.clerk_no 
               AND B.resource_id = C.resource_id 
               AND C.is_leaf = 1 
               AND A.branch_no = '110000'
               AND EXISTS (SELECT 1 
                           FROM   (SELECT brANCH_NO, 
                                          prio_branch_no 
                                   FROM   a_branch T2 
                                   START WITH T2.branch_no = '000000'
                                   CONNECT BY PRIOR 
                                   T2.branch_no = T2.prio_branch_no) 
                                  TT2 
                           WHERE  A.branch_no = TT2.branch_no));
