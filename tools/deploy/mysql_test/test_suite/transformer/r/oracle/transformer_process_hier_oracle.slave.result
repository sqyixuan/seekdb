        , NVL2(B.RESOURCE_ID, 1, 0) as CHECKED
from A_RESOURCE A
        left join (
                select distinct *
                from A_RESOURCE T
                start with RESOURCE_ID in (
                        select T.RESOURCE_ID
                        from V_CLERK_RESOURCE T
                        where T.ROLE_ID = '100'
                )
                connect by prior RESOURCE_PARENT_ID = RESOURCE_ID
        ) B
        on A.RESOURCE_ID = B.RESOURCE_ID
order by A.ORDER_ID;
