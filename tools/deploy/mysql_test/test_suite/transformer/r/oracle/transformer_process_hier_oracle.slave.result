drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table tmp;
drop sequence seq;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
create table t3 (c1 int, c2 int, c3 int);
create table t4 (c1 int, c2 int, c3 int);
create table tmp (c1 int, c2 int, c3 int);
create sequence seq start with 1 increment by 1 nocycle nocache;
create index t1_i1 on t1(c3);
result_format: 4
explain_protocol: 2
set autocommit=0;

EXPLAIN select * from t1 connect by prior c1 = c2 + 3;
Query Plan
========================================================
|ID|OPERATOR               |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |EXCHANGE IN REMOTE     |     |14      |46          |
|1 |└─EXCHANGE OUT REMOTE  |     |14      |35          |
|2 |  └─HASH CONNECT BY    |     |14      |9           |
|3 |    ├─SUBPLAN SCAN     |VIEW1|6       |3           |
|4 |    │ └─TABLE FULL SCAN|T1   |6       |3           |
|5 |    └─SUBPLAN SCAN     |VIEW2|6       |3           |
|6 |      └─TABLE FULL SCAN|T1   |6       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([VIEW2.T1.C1], [VIEW2.T1.C2], [VIEW2.T1.C3]), filter(nil)
  1 - output([VIEW2.T1.C1], [VIEW2.T1.C2], [VIEW2.T1.C3]), filter(nil)
  2 - output([VIEW2.T1.C1], [VIEW2.T1.C2], [VIEW2.T1.C3]), filter(nil)
      equal_conds([VIEW1.T1.C1 = VIEW2.T1.C2 + cast(3, NUMBER(-1, -85))]), other_conds(nil)
  3 - output([VIEW1.T1.__pk_increment], [VIEW1.T1.C1], [VIEW1.T1.C2], [VIEW1.T1.C3]), filter(nil), rowset=16
      access([VIEW1.T1.__pk_increment], [VIEW1.T1.C1], [VIEW1.T1.C2], [VIEW1.T1.C3])
  4 - output([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([VIEW2.T1.__pk_increment], [VIEW2.T1.C1], [VIEW2.T1.C2], [VIEW2.T1.C3]), filter(nil), rowset=16
      access([VIEW2.T1.__pk_increment], [VIEW2.T1.C1], [VIEW2.T1.C2], [VIEW2.T1.C3])
  6 - output([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.C1], [T1.C2], [T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
