##grouping sets
alter system flush plan cache global;
select c1,1,c1+2 from t1 group by grouping sets(c1,1);
+------+---+------+
| C1   | 1 | C1+2 |
+------+---+------+
|    1 | NULL |    3 |
| NULL | 1 | NULL |
+------+---+------+
select c1,1,c1+1 from t1 group by grouping sets(c1,1);
+------+---+------+
| C1   | 1 | C1+1 |
+------+---+------+
|    1 | NULL | NULL |
| NULL | 1 | NULL |
+------+---+------+
select hit_count from GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select c1,1,c1+_ from t1%' order by hit_count;
+-----------+
| HIT_COUNT |
+-----------+
|         0 |
|         0 |
|         0 |
|         0 |
+-----------+

alter system flush plan cache global;
select 2,1,3+3 from t1 group by grouping sets(2,1);
+---+---+-----+
| 2 | 1 | 3+3 |
+---+---+-----+
| 2 | NULL |   6 |
| NULL | 1 |   6 |
+---+---+-----+
select 2,1,4+4 from t1 group by grouping sets(2,1);
+---+---+-----+
| 2 | 1 | 4+4 |
+---+---+-----+
| 2 | NULL |   8 |
| NULL | 1 |   8 |
+---+---+-----+
select 2,1,3+2 from t1 group by grouping sets(2,1);
+---+---+-----+
| 2 | 1 | 3+2 |
+---+---+-----+
| 2 | NULL |   5 |
| NULL | 1 | NULL |
+---+---+-----+
select 2,1,1+3 from t1 group by grouping sets(2,1);
+---+---+-----+
| 2 | 1 | 1+3 |
+---+---+-----+
| 2 | NULL | NULL |
| NULL | 1 |   4 |
+---+---+-----+
select 2,1,1+2 from t1 group by grouping sets(2,1);
+---+---+-----+
| 2 | 1 | 1+2 |
+---+---+-----+
| 2 | NULL | NULL |
| NULL | 1 | NULL |
+---+---+-----+
select hit_count from GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like 'select 2,1,_+_ from t1%' order by hit_count;
