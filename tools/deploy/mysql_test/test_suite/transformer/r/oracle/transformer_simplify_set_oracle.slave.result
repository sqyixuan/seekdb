drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1 (c1 int, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int);
create table t3 (c1 int, c2 int, c3 int, c4 int);
create table t4 (c1 int, c2 int, c3 int, c4 int);
insert into t1 values (1,1,1,1);
insert into t1 values (1,2,2,2);
insert into t2 values (2,2,2,2);
insert into t2 values (2,2,3,3);
insert into t3 values (3,3,3,3);
insert into t3 values (3,3,3,4);
insert into t4 values (4,4,4,4);
explain_protocol: 2
######## UNION #############
#### test const false condition.
# where condition -> should prune
EXPLAIN select c1 from t1 where 1=2 UNION select c1 from t2;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |EXCHANGE IN REMOTE   |    |2       |5           |
|1 |└─EXCHANGE OUT REMOTE|    |2       |4           |
|2 |  └─HASH DISTINCT    |    |2       |3           |
|3 |    └─TABLE FULL SCAN|T2  |2       |2           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([T2.C1]), filter(nil)
  1 - output([T2.C1]), filter(nil)
  2 - output([T2.C1]), filter(nil), rowset=256
      distinct([T2.C1])
  3 - output([T2.C1]), filter(nil), rowset=256
      access([T2.C1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
select c1 from t1 where 1=2 UNION select c1 from t2;
C1
2
