drop table t1;

## push down outer join on condition
## 
drop table t1;
drop table t2;
drop table t3;
drop table pubic_config;
drop table individual_config;
drop table au_partyrelatin;
drop table au_company;
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);

create table pubic_config (
  key varchar2(50) not null,
  type varchar2(20) not null,
  value varchar2(4000) not null,
  is_to_contract_level varchar2(10),
  is_to_bpc_level varchar2(10),
  constraint pk_public_config primary key (key)
);
create table individual_config (
  business_code varchar2(30) not null,
  key varchar2(50) not null,
  value varchar2(4000) not null,
  vc_create_user varchar2(30) not null,
  dt_create_date timestamp(6) not null,
  vc_modify_user varchar2(30),
  dt_modify_date timestamp(6),
  contract_number varchar2(22),
  isinclude char(1),
  constraint uc_key_code_conctract unique (key, business_code, contract_number)
);

create table au_partyrelatin (
  partyid int,
  parent_parent_partyid int,
  partytype_id int,
  company_no int
);

create table au_company (
  id int,
  company_no varchar2(30)
);

