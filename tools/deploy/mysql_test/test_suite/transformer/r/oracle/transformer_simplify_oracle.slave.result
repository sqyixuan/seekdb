drop table t1;
drop table t2;
drop table t3;


************************* replace like condition, begin *********

drop table t1_like;
drop table t2_like;

explain_protocol: 0
create table t1_like(c1 varchar(20), c2 varchar(20), c3 date, c4 CLOB);
create table t2_like(c1 varchar(20), c2 varchar(20));
insert into t1_like(c1,c2,c3,c4) values('abc', 'abc', date'2011-1-1', 'abc');
insert into t1_like(c1,c2,c3) values('ab', 'abcd', date'2011-1-2');
insert into t1_like(c1,c2,c3) values('abcde', 'abcde', date'2012-1-1');
insert into t1_like(c1,c2,c3) values('abd', 'ac', date'2012-2-1');
insert into t1_like(c1,c2,c3) values('ab_', 'acd', date'2012-2-1');
insert into t1_like(c1,c2,c3) values('ab%', 'acd', date'2012-2-1');
insert into t2_like values('abc', 'abc');
insert into t2_like values('ab', 'abc');
alter system flush plan cache global;

explain_protocol: 2
