select pub.key, pub.type, nvl(ind.value, pub.value) as value
from pubic_config pub
  left join individual_config ind
  on pub.key = ind.key
    and 1 = (select case
                      when ind.isinclude = '0'
                      then
                      (
                        select 1 from au_company
                        where id in (
                                      select partyid from au_partyrelatin ap
                                      start with ap.partyid = (select id from au_company where company_no = ind.business_code)
                                      connect by prior ap.partyid = ap.parent_parent_partyid
                                                      and partytype_id = 2312
                                    )
                              and company_no = 11
                      )
                      else
                      (
                        select 1 from dual where ind.business_code = '1'
                      )
                      end
              from dual
            )
;
