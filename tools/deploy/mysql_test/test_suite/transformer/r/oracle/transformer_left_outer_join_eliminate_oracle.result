explain merge into t4 using t5 on (1 = 0)
when matched then update set t4.b = t5.b where (t5.b > 0 or exists (select 1 from t4 left join t5 on 1 = 0))
when not matched then insert (t4.a, t4.b) values (t5.b, t5.a) where t5.a < (select count(1) from t4 left join t5 on 1 = 0);
