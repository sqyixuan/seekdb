SELECT 1 AS CAS_CLIENT_NUM
FROM dual
)
SELECT  /*+no_rewite query_timeout(1000000000) */ a.client_id
, 1 AS remark
, (
SELECT  to_char(wm_concat(cas_client_num))
FROM  CLIENT_CAS_MAPPING
WHERE DELETED = 1
AND a.CLIENT_ID = client_id
AND CAS_CLIENT_NUM IN (
SELECT  cil.CAS_CLIENT_NUM
FROM tmp cil
)
) AS "增量客户号"
	, (
SELECT  to_char(wm_concat(cas_client_num))
FROM  CLIENT_CAS_MAPPING
WHERE DELETED = 1
AND a.CLIENT_ID = client_id
AND CAS_CLIENT_NUM NOT IN (
SELECT  cil.CAS_CLIENT_NUM
FROM tmp cil
)
) AS "非增量客户号"
FROM  CLIENT_ELEMENT a
JOIN  client_certificate b ON a.client_id = b.client_id
AND b.DELETED = 1 
WHERE a.DELETED = 1
AND EXISTS (
SELECT 1
FROM  CLIENT_CAS_MAPPING c
WHERE b.CLIENT_ID = c.CLIENT_ID
AND c.DELETED = 1
AND CAS_CLIENT_NUM IN (
SELECT  cil.CAS_CLIENT_NUM
FROM tmp cil
)
)
AND NOT EXISTS (
SELECT 1
FROM  CLIENT_CAS_MAPPING c
WHERE c.client_id = a.client_id
AND c.client_name = b.client_name
AND c.birth_date = a.birth_date
AND c.sex_code = a.sex_code
AND c.certificate_type = b.certificate_type
AND c.certificate_no = b.certificate_no
AND C.DELETED = 1
AND CAS_CLIENT_NUM IN (
SELECT  cil.CAS_CLIENT_NUM
FROM tmp cil
)
);
