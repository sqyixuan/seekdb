drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t1(c1 int, c2 int, c3 varchar(32));
create table t2(c1 int, c2 int, c3 varchar(32));
create table t3(c1 int, c2 int, c3 varchar(32));
create table t4(c1 int, c2 int, c3 varchar(32));
explain_protocol: 2
result_format: 4
## A. 推导的测试
## stmt 内 join 谓词推导
EXPLAIN select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| x    | o    |
+------+------+
EXPLAIN select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| x    | o    |
+------+------+

EXPLAIN select t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;
select t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
| e    | o    |
| g    | d    |
| h    | c    |
+------+------+
EXPLAIN select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
| e    | o    |
| g    | d    |
| h    | c    |
+------+------+

EXPLAIN select t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;
select t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
+------+------+
EXPLAIN select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
+------+------+

EXPLAIN select t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;
select t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
+------+------+
EXPLAIN select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;
+------+------+
| C3   | C3   |
+------+------+
| u    | c    |
| z    | b    |
+------+------+

