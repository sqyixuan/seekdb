## pullup 引用了语义谓词来推导
EXPLAIN select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
+------+------+
| C3   | V2   |
+------+------+
| u    |    5 |
+------+------+
EXPLAIN select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
