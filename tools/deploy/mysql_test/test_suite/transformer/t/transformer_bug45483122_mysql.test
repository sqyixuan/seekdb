# owner: sean.yyj
# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(c1 int unsigned, c2 int);
create table t2(c1 int unsigned, c2 int);
create index i2 on t2(c2);
insert into t2 values(1,2);

--result_format 4
--explain_protocol 2
set autocommit=0;
insert into t1 select 1,1 from t2 where c1 = -1 and c1 + 1 = 2;
insert into t1 select 2,2 from t2 where c1 = 1 and c1 + 1 = 2;

insert into t1 select 3,3 from t2 where c1 = -1 and c2 = c1 + 1;
insert into t1 select 4,4 from t2 where c1 = 1 and c2 = c1 + 1;

--explain_protocol 0
--echo # expect 2,4
select c1 from t1 order by c1;
rollback;

alter system flush plan cache global;
insert into t1 select 1,1 from t2 where c1 = 1 and c2 = c1 + 1;
insert into t1 select 2,2 from t2 where c1 = -1 and c2 = c1 + 1;
--echo # expect 0,0
select hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t1 select ?,? from t2 where c1 = ? and c2 = c1 + ?' and type = 1;

insert into t1 select 3,3 from t2 where c1 = 1 and c2 = c1 + 1;
insert into t1 select 4,4 from t2 where c1 = -1 and c2 = c1 + 1;
--echo # expect 1,1
select hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t1 select ?,? from t2 where c1 = ? and c2 = c1 + ?' and type = 1;

--echo # expect 1,3
select c1 from t1 order by c1;
rollback;

alter system flush plan cache global;
insert into t1 select 1,1 from t2 where c1 = -1 and c2 = c1 + 1;
insert into t1 select 2,2 from t2 where c1 = 1 and c2 = c1 + 1;
--echo # expect 1
select hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t1 select ?,? from t2 where c1 = ? and c2 = c1 + ?' and type = 1;

insert into t1 select 3,3 from t2 where c1 = -1 and c2 = c1 + 1;
insert into t1 select 4,4 from t2 where c1 = 1 and c2 = c1 + 1;
--echo # expect 3
select hit_count from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t1 select ?,? from t2 where c1 = ? and c2 = c1 + ?' and type = 1;

--echo # expect 2,4
select c1 from t1 order by c1;
rollback;

drop table t1,t2;
