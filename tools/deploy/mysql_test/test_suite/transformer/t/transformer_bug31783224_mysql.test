#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists tt1, tt2;
--enable_warnings

CREATE TABLE `tt1` (
      `seller_code` varchar(9) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `prd_code` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `real_prd_code` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `seller_fee_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
      `last_modify_date` int(11) NOT NULL DEFAULT '0',
      `reserve1` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `reserve2` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `reserve3` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `fee_type` varchar(1) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
      `seller_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
      `manager_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
      `asset_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
      PRIMARY KEY (`seller_code`, `real_prd_code`, `fee_type`)
     ) ;

CREATE TABLE `tt2` (
       `seller_code` varchar(9) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `prd_code` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `real_prd_code` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `seller_fee_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
       `last_modify_date` int(11) NOT NULL DEFAULT '0',
       `reserve1` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `reserve2` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `reserve3` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `fee_type` varchar(1) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       `seller_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
       `manager_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
       `asset_rate` decimal(9,8) NOT NULL DEFAULT '0.00000000',
       `valid_date` int(11) NOT NULL DEFAULT '0',
       `status` varchar(1) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL DEFAULT ' ',
       PRIMARY KEY (`seller_code`, `real_prd_code`, `fee_type`, `valid_date`)
     ) ;

INSERT INTO `tt2` VALUES ('A01', 'HSqq2a', '130105', 0.00035000, 20181030, ' ', ' ', ' ', '3', 0.30000000, 0.40000000, 0.30000000, 20181026, '1');
INSERT INTO `tt2` VALUES ('A01', 'HSqq2a', '130105', 0.00040000, 20181030, ' ', ' ', ' ', '6', 0.25000000, 0.25000000, 0.50000000, 20181026, '1');
INSERT INTO `tt2` VALUES ('A01', 'HSqq2a', '130105', 0.00035000, 20181030, ' ', ' ', ' ', '7', 0.33000000, 0.33000000, 0.34000000, 20181026, '1');
INSERT INTO `tt2` VALUES ('MY1', 'HSqq2b', '130105', 0.00035000, 20181030, ' ', ' ', ' ', '3', 0.30000000, 0.30000000, 0.40000000, 20181026, '1');
INSERT INTO `tt2` VALUES ('MY1', 'HSqq2b', '130105', 0.00010000, 20181030, ' ', ' ', ' ', '6', 0.40000000, 0.40000000, 0.20000000, 20181026, '1');

--result_format 4
--explain_protocol 2

REPLACE INTO  tt1 SELECT
     seller_code,
     prd_code,
     real_prd_code,
     seller_fee_rate,
     20181026,
     reserve1,
     reserve2,
     reserve3,
     fee_type,
     seller_rate,
     manager_rate,
     asset_rate 
FROM tt2 a 
WHERE STATUS <> '1' AND valid_date = (SELECT max( valid_date ) FROM tt2 b WHERE a.real_prd_code = b.real_prd_code AND a.seller_code = b.seller_code AND a.fee_type = b.fee_type AND b.valid_date <= 20181026);

drop table tt1, tt2;