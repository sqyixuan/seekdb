# owner group: SQL1
# tags: optimizer
# owner: yibo.tyf
--disable_abort_on_error
--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t_insert;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
create table t3 (c1 int, c2 int, c3 int);
create table t_insert (c1 int, c2 int, c3 int);

create table t4 (c1 varchar(10) collate  utf8_bin, c2 int);
insert into t4 values ('a', 2);
insert into t4 values ('A', 2);
insert into t4 values ('C', 0);
insert into t4 values ('D', 0);

create table t5 (c1 varchar(10) collate utf8_general_ci, c2 int);
insert into t5 values ('a', 1);
insert into t5 values ('A', 4);

--source mysql_test/include/minor_merge_tenant.inc
--disable_query_log
--let $count = 1
while($count <= 50)
{
  --let $stmt=insert into t1 values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
insert into t2 values (10, 5, 0);
insert into t2 values (10, 5, 0);
insert into t2 values (20,15,10);
insert into t2 values (20,15,10);
insert into t2 values (30,25,20);
insert into t2 values (30,25,20);
insert into t2 values (40,35,30);
insert into t2 values (40,35,30);
insert into t2 values (50,45,40);
insert into t2 values (50,45,40);

insert into t3 values (10, 5, 0);
insert into t3 values (10, 5, 0);
insert into t3 values (20,15,10);
insert into t3 values (20,15,10);
insert into t3 values (30,25,20);
insert into t3 values (30,25,20);
insert into t3 values (40,35,30);
insert into t3 values (40,35,30);

--source mysql_test/include/minor_merge_tenant.inc
--enable_query_log
analyze table t1 compute statistics for all columns size auto;
analyze table t2 compute statistics for all columns size auto;
analyze table t3 compute statistics for all columns size auto;
analyze table t_insert compute statistics for all columns size auto;
analyze table t4 compute statistics for all columns size auto;
analyze table t5 compute statistics for all columns size auto;

set autocommit=0;
--explain_protocol 2
--result_format 4

--echo # different subquery comparision op
select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/avg(c2) from t2 where t2.c1 = t1.c1);

insert into t_insert(c1,c2,c3) select c1,c2,c3 from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
select * from t_insert;
rollback;

insert into t_insert(c1,c2,c3) select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/avg(c2) from t2 where t2.c1 = t1.c1);
select * from t_insert;
rollback;

update t1 set c1 = 100 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
select stddev(c1) from t1;
rollback;

update /*+no_unnest(@qb1)*/ t1 set c1 = 100 where 2 * t1.c2 > (select /*+qb_name(qb1)*/avg(c2) from t2 where t2.c1 = t1.c1);
