#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;

--enable_warnings
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 16;
create table t2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 16;
create index i1 on t1(c1);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, NULL);
insert into t1 values (3, NULL, NULL);
insert into t1 values (4, NULL, NULL);
insert into t1 values (5, 5, 5);
insert into t1 values (5, NULL, NULL);
insert into t1 values (5, 5, NULL);
insert into t1 values (NULL, NULL, NULL);
insert into t2 values (1, 1, 1);
insert into t2 values (2, 2, 2);
insert into t2 values (3, 3, 3);
insert into t2 values (4, 4, 4);
insert into t2 values (5, 5, 5);

--explain_protocol 2
--result_format 4
--enable_sorted_result

select c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5);
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5);

select c1, c2, c3 from t1 where c1 in (select 5 from dual where c2 = 5);
select /*+ no_rewrite */ c1, c2, c3 from t1 where c1 in (select 5 from dual where  c2 = 5);

select c1, c2, c3 from t1 where (c1,c2) in (select 5, 5 from dual);
select /*+ no_rewrite */ c1, c2, c3 from t1 where (c1,c2) in (select 5, 5 from dual);

select c1, c2, c3 from t1 where c1 not in (select 5 from dual where c2 = 5);
select /*+ no_rewrite */ c1, c2, c3 from t1 where c1 not in (select 5 from dual where c2 = 5);

select c1, c2, c3 from t1 where (c1,c2) not in (select 5, 5 from dual);
select /*+ no_rewrite */ c1, c2, c3 from t1 where (c1,c2) not in (select 5, 5 from dual);

select case when exists(select 1 from dual where t1.c1 = 1) then 0 else 1 end from t1;
select /*+ no_rewrite */ case when exists(select 1 from dual where t1.c1 = 1) then 0 else 1 end from t1;

select c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 1 offset 1);
select /*+ no_rewrite */ c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 1 offset 1);

select * from t1 where (c1,c2) != any (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);
select /*+ no_rewrite */ * from t1 where (c1,c2) != any (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);

select * from t1 where (c1,c2) = any (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);
select /*+ no_rewrite */ * from t1 where (c1,c2) = any (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);

select * from t1 where (c1,c2) != all (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);
select /*+ no_rewrite */ * from t1 where (c1,c2) != all (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);

select * from t1 where (c1,c2) = all (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);
select /*+ no_rewrite */ * from t1 where (c1,c2) = all (select /*+no_unnest,no_merge*/ 5, 5 from dual where c3 = 5);

select c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5 or c2 = 2) and c3 is NULL;
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5 or c2 = 2) and c3 is NULL;

select case when exists(select 1 from dual where t1.c1 = 1) then 0 else 1 end from t1 where exists (select /*+no_unnest,no_merge*/ 1 from dual where c1 = 5);
select /*+ no_rewrite */ case when exists(select 1 from dual where t1.c1 = 1) then 0 else 1 end from t1 where exists (select /*+no_unnest,no_merge*/ 1 from dual where c1 = 5);

select t1.c1, t1.c2, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and exists(select 1 from dual where t1.c1 = 5);
select /*+ no_rewrite */ t1.c1, t1.c2, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and exists(select 1 from dual where t1.c1 = 5);

select c1, c2, c3 from t1 where exists(select /*+ no_unnest */ 1 from t2 where c1 = 5);
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select 1 from t2 where c1 = 5);

select c1, c2, c3 from t1 where exists(select 1 as d from dual where c1 = 5 group by d);
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select 1 as d from dual where c1 = 5 group by d);

select exists(select 1 from dual where t1.c1 = 1) as s1 from t1 order by s1 + 1;
select /*+ no_rewrite */ exists(select 1 from dual where t1.c1 = 1) as s1 from t1 order by s1 + 1;

select c1, c2, c3 from t1 where exists(select row_number() over () as d from dual where c1 = 5);
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select row_number() over () as d from dual where c1 = 5);

select c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5) for update;
select /*+ no_rewrite */ c1, c2, c3 from t1 where exists(select 1 from dual where c1 = 5) for update;

select c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 1);
select /*+ no_rewrite */ c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 1);

select c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 0);
select /*+ no_rewrite */ c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5 limit 0);

select c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5  union all select 1 from dual where c1 = 1);
select /*+ no_rewrite */ c1,c2,c3 from t1 where exists(select 1 from dual where c1 = 5  union all select 1 from dual where c1 = 1);

select c1,c2,c3 from t1 where c1 not in (select (select 5 from t2 limit 1) from dual);
select /*+ no_rewrite */ c1,c2,c3 from t1 where c1 not in (select (select 5 from t2 limit 1) from dual);

--explain_protocol 0 

drop table t1;
drop table t2;