--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: 

--disable_query_log
--disable_warnings
DROP TABLE if exists `ob_sql_diag`;
DROP TABLE if exists `ob_topsql_meta`;
--enable_query_log
--enable_warnings

CREATE TABLE `ob_sql_diag` (
 `request_time` timestamp NOT NULL
);

CREATE TABLE `ob_topsql_meta` (
 `obregion_group` varchar(32) DEFAULT NULL
);

select t1.request_time
from
(select request_time, obregion_group
 from
 (select concat(substr(a.request_time,1,16),':00')
  request_time,b.obregion_group,
  count(*) appear_times
  from ob_sql_diag a,ob_topsql_meta b
  where b.obregion_group='obtrans') sub
 ) t1,ob_sql_diag t2;

DROP TABLE if exists `ob_sql_diag`;
DROP TABLE if exists `ob_topsql_meta`;
