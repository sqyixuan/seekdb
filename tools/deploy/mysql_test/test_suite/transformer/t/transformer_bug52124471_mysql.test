--result_format 4
explain (SELECT * FROM table1_key_pk_parts_2_bigint WHERE  @@ob_query_timeout NOT REGEXP @@autocommit IS UNKNOWN   EXCEPT  SELECT  @@max_allowed_packet FROM table1_hash_pk_parts_4_bigint    EXCEPT  SELECT  @a100 AS c1 FROM table2_mediumint_autoinc     LIMIT 8123 , 2  ) ORDER BY @a1 ASC;
( SELECT * FROM table1_key_pk_parts_2_bigint WHERE  @@ob_query_timeout NOT REGEXP @@autocommit IS UNKNOWN   EXCEPT  SELECT  @@max_allowed_packet FROM table1_hash_pk_parts_4_bigint    EXCEPT  SELECT  @a100 AS c1 FROM table2_mediumint_autoinc     LIMIT 8123 , 2  ) ORDER BY @a1 ASC;

