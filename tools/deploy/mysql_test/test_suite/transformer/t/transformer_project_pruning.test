--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
#description: transform模块测试，测试 project pruning

--result_format 4
--explain_protocol 2

##test hierarchical query
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists fm_branch;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

--disable_query_log
--disable_result_log
insert into t1 values(1,1);
insert into t1 values(1,2);
insert into t1 values(3,1);
insert into t2 values(1,0);
insert into t2 values(2,1);
insert into t2 values(3,1);
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

##bug: 
select risk_class
from (
         select (select c1
                 from t1 t
                 where t.c1 = @a) risk_class,
                (select @a := tt.c2
                 from t2 tt
                 where tt.c2 = @a) parent_class
         from (select 1 from t2 limit 4) vir,
              (select @a := '01110') vars
     ) x;

--disable_query_log
--disable_result_log
drop table t1;
drop table t2;

create table FM_BRANCH (`BLORG_NO` varchar(64) NOT NULL, `ORG_NM` varchar(256) NOT NULL, `AFLT_SUPER_NO` varchar(32) DEFAULT NULL, PRIMARY KEY (`BLORG_NO`));
INSERT INTO fm_branch (BLORG_NO,ORG_NM,AFLT_SUPER_NO) VALUES ('1359','乌鲁木齐银行乌鲁木齐汇总','1360');
INSERT INTO fm_branch (BLORG_NO,ORG_NM,AFLT_SUPER_NO) VALUES ('1362','乌鲁木齐银行营业部','1359');
INSERT INTO fm_branch (BLORG_NO,ORG_NM,AFLT_SUPER_NO) VALUES ('9935','乌鲁木齐银行大马哈支行',null);

--enable_result_log
--enable_query_log
select T3.* from (select @codes as blorgNosYYY, (select @codes := GROUP_CONCAT(BLORG_NO) from FM_BRANCH where FIND_IN_SET( AFLT_SUPER_NO, @codes)) as T1 from FM_BRANCH, (select @codes := 1359) T4 where @codes is not null) T2, FM_BRANCH T3 where FIND_IN_SET( T3.BLORG_NO, T2.blorgNosYYY ) order by BLORG_NO;
select /*+ NO_PROJECT_PRUNE(@"SEL$2") */ T3.* from (select @codes as blorgNosYYY, (select /*+no_project_prune*/ @codes := GROUP_CONCAT(BLORG_NO) from FM_BRANCH where FIND_IN_SET( AFLT_SUPER_NO, @codes)) as T1 from FM_BRANCH, (select @codes := 1359) T4 where @codes is not null) T2, FM_BRANCH T3 where FIND_IN_SET( T3.BLORG_NO, T2.blorgNosYYY ) order by BLORG_NO;

drop table fm_branch;