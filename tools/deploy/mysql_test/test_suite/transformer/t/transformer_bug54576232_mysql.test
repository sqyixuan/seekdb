# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

set names gb18030;
create table t1(c1 mediumtext);
CREATE TABLE `t2` (
  `c0` mediumtext DEFAULT NULL COMMENT 'asdf',
  `c1` float unsigned zerofill DEFAULT NULL,
  `c2` float(26,0) DEFAULT NULL COMMENT 'asdf',
  `c3` bigint(180) unsigned zerofill DEFAULT NULL COMMENT 'asdf'
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 32768 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 DUPLICATE_SCOPE = 'CLUSTER'
partition by hash(c3)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`,
partition `p10`,
partition `p11`,
partition `p12`,
partition `p13`,
partition `p14`,
partition `p15`);

--result_format 4
--explain_protocol 1

SELECT 1 FROM t1 WHERE '2' = IF(c1 = '2', c1, NULL);
SELECT ALL * FROM t2 WHERE (+ (("2024-01-17 23:41:38") IN (IF(concat(t2.c1,''), t2.c0, NULL), ('2024-01-17 23:41:38') IS NOT FALSE)));
set names DEFAULT;
SELECT 1 FROM t1 WHERE '2' = IF(c1 = '2', c1, NULL);
drop table t1, t2;