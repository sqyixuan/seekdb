# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: timestamp 函数支持空值拒绝判定

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

CREATE TABLE t1 (
    id INT
);

CREATE TABLE t2 (
    id INT,
    real_time DATETIME
);

CREATE TABLE t3 (
    id INT
);

insert into t1 values(1),(2),(3),(4),(5);
insert into t2 values(1,'2024-09-01 00:00:00.0'), (2,'2024-08-01 00:00:00.0'), (3,NULL), (4,NULL), (5,'2024-10-01 00:00:00.0');
insert into t3 values(1),(2),(3),(4),(5);

--result_format 4
--explain_protocol 2

# t1 left join t2 should be rewritten as an inner join rather than an outer join
select 
  t0.col_0 as id, 
  date(t0.col_1) as col_3
from
(
  select 
    cast(t4.id as char) as col_0, 
    timestamp(t4.real_time) as col_1
  from
    (
      SELECT 
        t1.id as id, 
        t2.real_time as real_time
      FROM t1
        left join t2 on t1.id = t2.id
        left join t3 on t1.id = t3.id
    ) as t4
) as t0
where
  t0.col_1 >= timestamp('2024-09-01 00:00:00.0')  -- # should be treated as a null reject condition
  and t0.col_0 is not NULL
order by id;

select /*+no_rewrite*/
  t0.col_0 as id, 
  date(t0.col_1) as col_3
from
(
  select 
    cast(t4.id as char) as col_0, 
    timestamp(t4.real_time) as col_1
  from
    (
      SELECT 
        t1.id as id, 
        t2.real_time as real_time
      FROM t1
        left join t2 on t1.id = t2.id
        left join t3 on t1.id = t3.id
    ) as t4
) as t0
where
  t0.col_1 >= timestamp('2024-09-01 00:00:00.0')
  and t0.col_0 is not NULL
order by id;

drop table t1, t2, t3;