# bug: left to anti makes the value of generated column be NULL, which is incorrect
--explain_protocol 0
drop table if exists tn, tg1, tg2;
create table tn(c1 int, c2 int, c3 int);
create table tg1(c1 int, c2 int, c3 int);
create table tg2(c1 int, c2 int, c3 int);
alter table tg1 add gen_c int generated always as (c1 + c2) virtual;
alter table tg2 add gen_c int generated always as (c1 + c2) stored;
insert into tn(c1, c2, c3) values(1, 2, 3), (3, 4, 5), (5, 6, 7);
insert into tg1(c1, c2, c3) values(2, 3, 3), (NULL, 4, 5), (5, 6, 7);
insert into tg2(c1, c2, c3) values(2, 3, 3), (NULL, 4, 5), (5, 6, 7);

--explain_protocol 2
select tn.*, tg1.gen_c from tn left join tg1 on tn.c1 = tg1.gen_c where tg1.gen_c is null;
select/*+no_left_to_anti*/ tn.*, tg1.gen_c from tn left join tg1 on tn.c1 = tg1.gen_c where tg1.gen_c is null;
select tn.*, tg2.gen_c from tn left join tg2 on tn.c1 = tg2.gen_c where tg2.gen_c is null;
select/*+no_left_to_anti*/ tn.*, tg2.gen_c from tn left join tg2 on tn.c1 = tg2.gen_c where tg2.gen_c is null;
--explain_protocol 0
drop table if exists t1, t2, t3, t4, t5, t6, tn, tg1, tg2;
set autocommit=1;
