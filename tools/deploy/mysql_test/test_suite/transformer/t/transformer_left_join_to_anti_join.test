select 1 from (t1 join t4) left join t2 on 1 = 1 left join t3 on 1 = 1 where t2.b > 0 and t2.a is null;
select /*+NO_REWRITE*/ 1 from (t1 join t4) left join t2 on 1 = 1 left join t3 on 1 = 1 where t2.b > 0 and t2.a is null;

select * from (t1 left join t2 on t1.a = t2.a) full join t4 on t1.a = t4.a where t2.a is NULL;
select /*+NO_REWRITE*/ * from (t1 left join t2 on t1.a = t2.a) full join t4 on t1.a = t4.a where t2.a is NULL;
