# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t_mon_enc, t_vsm_lock, t1dhvs6y;
--enable_warnings

CREATE TABLE `t_mon_enc` (
  `encID` int(11) NOT NULL AUTO_INCREMENT COMMENT '加密ID',
  `monitorID` int(11) DEFAULT NULL COMMENT '监控ID',
  `name` varchar(500) DEFAULT NULL COMMENT '应用名',
  `lastCount` double DEFAULT NULL COMMENT '上一次加密次数',
  PRIMARY KEY (`encID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `t_vsm_lock` (
  `hsmUUID` varchar(255) NOT NULL DEFAULT '',
  `vsmUUID` varchar(255) NOT NULL DEFAULT '',
  `lockType` int(11) DEFAULT NULL COMMENT '锁类型',
  PRIMARY KEY (`hsmUUID`,`vsmUUID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

create table if not exists `t1dhvs6y` (
	`c1` int(11) not null,
	primary key (`c1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (c1)
(
	PARTITION `p0`,
	PARTITION `p1`
);

--result_format 4
--explain_protocol 2


SELECT
    v1.c12,
    v1.c17,
    (
        SELECT
            SUM(lastCount)
        FROM
            test.t_mon_enc
    ) AS c24,
    v1.c18
FROM test.t_mon_enc, (
            SELECT
                MAX(
                    ref_8.lockType       
                ) over (
                    PARTITION BY ref_8.vsmUUID
                    ORDER BY ref_8.hsmUUID
                ) AS c12,
                ref_8.lockType AS c13,
                ref_8.vsmUUID AS c17,
                ref_8.hsmUUID AS c18
            FROM
                test.t_vsm_lock AS ref_8  
        ) AS v1
WHERE
    v1.c13 - (
        SELECT
            SUM(c1)
        FROM
            test.t1dhvs6y
    )
;


drop table t_mon_enc, t_vsm_lock, t1dhvs6y;