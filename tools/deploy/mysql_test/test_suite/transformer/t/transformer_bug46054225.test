# owner: link.zt
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists cool_deal_201810;
drop table if exists sys_uri_config;
drop table if exists t_sys_basicproperty;
--enable_warnings

# init env

CREATE TABLE `cool_deal_201810` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `body` varchar(255) DEFAULT '' ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
);

CREATE TABLE `sys_uri_config` (
  `sys_uri_id` int(11) DEFAULT NULL,
  `config` text
);

CREATE TABLE `t_sys_basicproperty` (
  `basicPropertyID` int(20) NOT NULL AUTO_INCREMENT COMMENT '基础属性ID',
  `basicPropertyType` char(50) DEFAULT NULL COMMENT '基础属性类型',
  `basicPropertyName` char(100) DEFAULT NULL COMMENT '基础属性名称',
  PRIMARY KEY (`basicPropertyID`)
);


--explain_protocol 2
--result_format 4

# start tests

SELECT
  (SELECT max(total_fee) FROM cool_deal_201810) AS c0
FROM (sys_uri_config AS ref_0
      LEFT JOIN
        (SELECT subq_0.c3 AS c3
         FROM
           (SELECT 38 AS c3
            FROM t_sys_basicproperty AS ref_1) AS subq_0) AS subq_1 ON (subq_1.c3 IS NULL))
WHERE subq_1.c3 IS NULL LIMIT 1;

# clean env
drop table cool_deal_201810;
drop table sys_uri_config;
drop table t_sys_basicproperty;


## another duplicate issue case

--disable_warnings
drop table if exists cool_mcc_qq_cate;
drop table if exists t_mon_eps_user;
drop table if exists t_component_resource_lock;
drop table if exists t_priv5smbex;
drop table if exists zhujian_index;
--enable_warnings

CREATE TABLE `cool_mcc_qq_cate` (
  `mcc_qq_cate_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `cate_name` varchar(255) DEFAULT NULL,
  PRIMARY KEY (`mcc_qq_cate_id`)
);

CREATE TABLE `t_mon_eps_user` (
  `userEpsID` int(20) NOT NULL AUTO_INCREMENT,
  `epsIDs` text COMMENT 'epsIDs',
  `userID` int(20) DEFAULT NULL,
  PRIMARY KEY (`userEpsID`)
);

create TABLE `t_component_resource_lock` (
  `uuid` varchar(10) NOT NULL DEFAULT '' COMMENT '组件资源锁',
  PRIMARY KEY (`uuid`)
);

create table if not exists `t_priv5smbex` (
  `c1` int(11) not null,
  `c2` int(11),
  primary key (`c1`)
);

CREATE TABLE `zhujian_index` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL,
  PRIMARY KEY (`name`)
);

SELECT subq_0.c12 AS c3
FROM
  (SELECT ref_1.c2 AS c9,

     (SELECT max(mcc_qq_cate_id)
      FROM cool_mcc_qq_cate) AS c10,

     (SELECT userEpsID
      FROM t_mon_eps_user LIMIT 1) AS c12,
          ref_1.c1 AS c15
   FROM (t_component_resource_lock AS ref_0
         LEFT JOIN t_priv5smbex AS ref_1 ON 1)) AS subq_0
WHERE subq_0.c9
  AND (((EXISTS
           (SELECT 1
            FROM zhujian_index AS ref_6
            WHERE subq_0.c12))
        OR (subq_0.c15 IS NULL))
       AND (subq_0.c15 OR subq_0.c10)) LIMIT 1;

drop table cool_mcc_qq_cate;
drop table t_mon_eps_user;
drop table t_component_resource_lock;
drop table t_priv5smbex;
drop table zhujian_index;

