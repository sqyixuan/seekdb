#bug:

--disable_warnings
drop table if exists characterset387nhr, t_rpt_templatefield, t_mon_info_hour, t2mfxdtk, bit_pk, t1smcizj, range_columns_test;
--enable_warnings

create table if not exists `characterset387nhr` (
	`id` int(11) not null auto_increment,
	`fuhao` varchar(100),
	`zifu` char(100) not null,
	`sage` tinyint(100) not null,
	`sdept` char(40) not null,
	primary key (`id`)
)
default charset=utf16
default collate=utf16_general_ci
comment='字符集表';

CREATE TABLE `t_rpt_templatefield` (
  `fieldID` int(11) NOT NULL AUTO_INCREMENT COMMENT '字段编号',
  `templateID` int(11) DEFAULT NULL COMMENT '模板编号',
  `fieldCode` varchar(300) DEFAULT NULL COMMENT '字段编码',
  `fieldDisplayName` varchar(300) DEFAULT NULL COMMENT '字段名称',
  `fieldType` int(11) DEFAULT NULL COMMENT '字段类型\n            1:输入\n            2:下拉多选\n            3:下拉单选\n            4“对象选择树',
  `fieldDataType` int(11) DEFAULT NULL COMMENT '当fieldType为输入类型时候，字段数据类型如下：\n            1：文本\n            2：数值\n            3：日期\n            4：IP地址\n            5：端口\n            6:   浮点型',
  `fieldDataSource` text COMMENT '数据来源：\n            1：固定枚举\n             2：从数据库中获取（都需提供ID和显示名称;以事件的严重级别为例,可采用类似"0,微;1,低;2,中;3,高;4,极度"的方式)      ',
  `fieldDataContent` text COMMENT '如fieldDataSource=1则填写枚举值\n            如fieldDataSource=2则需要填写SQL语句',
  `isRequired` tinyint(4) DEFAULT NULL COMMENT '是否必填',
  `tips` varchar(300) DEFAULT '' COMMENT '输入提示',
  PRIMARY KEY (`fieldID`)
) AUTO_INCREMENT=138 DEFAULT CHARSET=utf8 COMMENT='报表模板字段表\r\nWebServer:读';

create table if not exists `test_spm22bwqwi` (
	`a` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

create table if not exists `test_tmp7rwy0g` (
	`pk` int(11) not null,
	`a` int(11),
	primary key (`pk`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_mon_info_hour` (
  `monitorID` int(20) NOT NULL AUTO_INCREMENT COMMENT '监控数据ID',
  `hsmUUID` varchar(50) DEFAULT NULL,
  `vsmUUID` varchar(50) DEFAULT NULL,
  `mode` int(11) DEFAULT NULL COMMENT '机器类型',
  `monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '监控时间',
  `memoryUsage` double DEFAULT NULL COMMENT '内存使用率',
  `cpuUsage` double DEFAULT NULL COMMENT 'CPU使用率',
  `inflowSum` double DEFAULT NULL COMMENT '网络流入总量',
  `outflowSum` double DEFAULT NULL COMMENT '网络流出总量',
  `diskTotal` bigint(20) DEFAULT NULL COMMENT '总存储空间',
  `diskUsed` bigint(20) DEFAULT NULL COMMENT '已使用的空间',
  `ioRsecSize` double(11,0) DEFAULT '0' COMMENT 'io读扇区大小',
  `ioWsecSize` double(11,0) DEFAULT '0' COMMENT 'io写扇区大小',
  `load1` double DEFAULT '0' COMMENT '1分钟的平均系统负载',
  `load5` double DEFAULT '0' COMMENT '5分钟的平均系统负载',
  `load15` double DEFAULT '0' COMMENT '15分钟的平均系统负载',
  `processRunning` int(11) DEFAULT '0' COMMENT '运行进程数',
  `tcpEstablished` int(11) DEFAULT '0' COMMENT '已经打开的tcp连接数',
  `encsCount` double DEFAULT NULL COMMENT '加密次数',
  `decsCount` double DEFAULT NULL COMMENT '解密次数',
  `taskcount` double DEFAULT NULL COMMENT '加解密平均次数',
  PRIMARY KEY (`monitorID`)
) DEFAULT CHARSET=utf8 COMMENT='主机监控表';

create table if not exists `t2mfxdtk` (
	`id` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

create table `bit_pk` (
`c01` int(255),
`c02` numeric,
`c03` decimal(10,5),
`c04` bit(64),
`c05` tinyint(255),
`c06` smallint,
`c07` mediumint,
`c08` bigint,
`c09` float(20),
`c10` double,
`c11` varchar(255),
`c12` char(255),
`c13` tinytext,
`c14` mediumtext,
`c15` tinyblob,
`c16` longtext,
`c17` mediumblob,
`c18` longblob,
`c19` binary(255),
`c20` varbinary(255),
`c21` timestamp,
`c22` date,
`c23` time,
`c24` datetime,
`c25` year,
`c26` blob,
 primary key(`c04`));

create table if not exists `t1smcizj` (
	`c1` varchar(1),
	`c2` varchar(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `range_columns_test` (
  `id` int(11) NOT NULL,
  `departno` bigint(20) NOT NULL,
  PRIMARY KEY (`id`,`departno`)
) DEFAULT CHARSET = utf8mb4 
 partition by range columns(`id`,`departno`)
(partition p0 values less than (100,1000),
partition p1 values less than (100,2000),
partition p2 values less than (200,1000),
partition p4 values less than (200,2000),
partition pmax values less than (MAXVALUE,MAXVALUE));

--explain_protocol 2
--enable_query_log
select ref_0.a as c0, cast(nullif(ref_0.a, ref_0.a) as DECIMAL) as c1, replace( cast( group_concat( cast(cast(null as CHAR) as CHAR)) over (partition by ref_0.a order by ref_0.a,ref_0.a) as CHAR), cast((select group_concat(fuhao) from test.characterset387nhr) as CHAR), cast(cast(nullif(cast(null as CHAR), (select fieldCode from test.t_rpt_templatefield limit 1 offset 2) ) as CHAR) as CHAR)) as c2, ref_0.a as c3, ref_0.a as c4 from test.test_spm22bwqwi as ref_0 where EXISTS ( select ref_2.sage as c0, ref_0.a as c1, ref_2.id as c2, upper( cast(ref_2.fuhao as CHAR)) as c3, ref_0.a as c4, 84 as c5 from ((select ref_0.a as c0 from test.test_tmp7rwy0g as ref_1 where ref_1.a / ref_0.a) as subq_0 right join test.characterset387nhr as ref_2 on (((((ref_2.sage OR ref_2.id) or (EXISTS ( select ref_2.sdept as c0 from test.t_mon_info_hour as ref_3 where (ref_2.sdept is not NULL) and (ref_3.monitorTime is NULL) limit 67))) or (subq_0.c0 OR subq_0.c0)) and (subq_0.c0 >= (select max(id) from test.t2mfxdtk) )) or (50 = subq_0.c0))) where (case when EXISTS ( select (select avg(c02) from test.bit_pk) as c0, ref_2.zifu as c1, ref_4.id as c2, (select c3 from test.t1smcizj limit 1 offset 5) as c3, ref_4.departno as c4 from test.range_columns_test as ref_4 where 1) then ref_2.id else ref_0.a end AND subq_0.c0) or ((ref_2.sage = subq_0.c0) or ((ref_2.sage * 64) and (ref_2.id * ref_2.sage)))) limit 61 ;
--disable_query_log
--explain_protocol 0

drop table characterset387nhr, t_rpt_templatefield, t_mon_info_hour, t2mfxdtk, bit_pk, t1smcizj, range_columns_test;

