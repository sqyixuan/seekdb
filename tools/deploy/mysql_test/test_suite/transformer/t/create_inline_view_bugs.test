--explain_protocol 2
--enable_query_log
SELECT DISTINCT GRANDPARENT1 . col_varchar_20 AS G1 FROM mm AS GRANDPARENT1 LEFT JOIN cc AS GRANDPARENT2 USING ( col_varchar_20 ) WHERE GRANDPARENT1 . `pk` IN ( SELECT DISTINCT PARENT1 . `pk` AS P1 FROM v AS PARENT1 WHERE PARENT1 . `pk` IN ( SELECT  CHILD1 . `col_int` AS C1 FROM jj AS CHILD1   ) AND ( ( PARENT1 . `col_int` < PARENT1 . `col_int_key` ) AND GRANDPARENT1 . col_varchar_20 IS NULL )  ) AND ( GRANDPARENT1 . `pk` <= 6 OR NOT GRANDPARENT1 . `pk` <> 2 ) GROUP BY GRANDPARENT1 . col_varchar_20 HAVING G1 < NULL ORDER BY GRANDPARENT1 . col_varchar_20 LIMIT 3;
--disable_query_log
--explain_protocol 0

drop table cc, jj, mm, v;

