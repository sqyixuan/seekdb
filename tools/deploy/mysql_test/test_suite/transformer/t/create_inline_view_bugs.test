create table t3 (c1 NUMERIC(64,15) ,c2 DECIMAL(64,9) ,c3 VARBINARY(86) ,c4 YEAR(4) ,c5 CHAR(152) ,c6 VARCHAR(86) ,c7 NUMERIC(64,17) ,c8 INT(127) ,c9 DATETIME,c10 TIME,c11 INT(127)  auto_increment,c12 INTEGER(127) ,c13 DECIMAL(64,3) ,c14 BIGINT(127) ,c15 VARBINARY(69) ,c16 INTEGER(127) , primary key(c12,c2,c13,c15))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c12) PARTITIONS 10;
create table t4 (c1 BINARY(100) ,c2 CHAR(152) ,c3 TIME,c4 VARCHAR(86) ,c5 DECIMAL(64,2) ,c6 INT(127) ,c7 INT(127) ,c8 DATE,c9 NUMERIC(64,3) ,c10 BIGINT(127)  auto_increment,c11 TIME,c12 VARCHAR(86) ,c13 INT(127) ,c14 INT(127) ,c15 DECIMAL(64,9) ,c16 BIGINT(127) ,c17 TIME,c18 NUMERIC(64,26) , primary key(c9,c1,c12,c4,c16,c7,c15,c10,c5))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c9,c1,c12,c4,c16) PARTITIONS 10;
create table t5 (c1 INT(127) ,c2 DECIMAL(64,23) ,c3 VARBINARY(53) ,c4 DECIMAL(64,26) ,c5 DATE,c6 INT(127) ,c7 TIMESTAMP(4)  NOT NULL default 0,c8 NUMERIC(64,8) ,c9 INTEGER(127) ,c10 DATETIME,c11 DATE, primary key(c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c9) PARTITIONS 10;
create table t6 (c1 INT(127) ,c2 DECIMAL(64,23) ,c3 VARBINARY(53) ,c4 DECIMAL(64,26) ,c5 DATE,c6 INT(127) ,c7 TIMESTAMP(4)  NOT NULL default 0,c8 NUMERIC(64,8) ,c9 INTEGER(127) ,c10 DATETIME,c11 DATE, primary key(c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c9) PARTITIONS 10;
create table t7 (c1 INT(127) ,c2 DECIMAL(64,23) ,c3 VARBINARY(53) ,c4 DECIMAL(64,26) ,c5 DATE,c6 INT(127) ,c7 TIMESTAMP(4)  NOT NULL default 0,c8 NUMERIC(64,8) ,c9 INTEGER(127) ,c10 DATETIME,c11 DATE, primary key(c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c9) PARTITIONS 10;
create table t8 (c1 BINARY(121) ,c2 TIMESTAMP(2)  NOT NULL default 0,c3 DATETIME,c4 YEAR(4) ,c5 YEAR(4) ,c6 DATE,c7 YEAR(4) ,c8 INTEGER(127) ,c9 INT(127) ,c10 TIME,c11 VARBINARY(67) , primary key(c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;
create table t9 (c1 DATE,c2 VARBINARY(78) ,c3 INTEGER(127) ,c4 DATETIME,c5 DECIMAL(64,1) ,c6 INT(127) ,c7 TIMESTAMP(5)  NOT NULL default 0,c8 VARCHAR(86) ,c9 DECIMAL(64,14) ,c10 BIGINT(127) ,c11 BINARY(123) ,c12 VARBINARY(52) ,c13 DECIMAL(64,28) ,c14 CHAR(152) ,c15 VARCHAR(86) ,c16 DATETIME, primary key(c5,c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;
create table t10 (c1 TIME,c2 BINARY(143) ,c3 TIMESTAMP(1)  NOT NULL default 0,c4 BINARY(140) ,c5 DECIMAL(64,1) ,c6 BIGINT(127) ,c7 BINARY(62) ,c8 NUMERIC(64,20) ,c9 NUMERIC(64,17) ,c10 INT(127)  auto_increment,c11 DATE, primary key(c5,c6,c9,c4,c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c5,c6,c9,c4,c2) PARTITIONS 10;

