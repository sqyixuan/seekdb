--explain_protocol 2
--enable_query_log
SELECT 
/*+
  USE_CONCAT(@"SEL$182FD6B9" )
  PLACE_GROUP_BY(@"SEL$F8C4A4E7" "t8_14"@"SEL$1")      
  SIMPLIFY_EXPR(@"SEL$1")*/
1
FROM
  (SELECT t8.c4,
          t8.c6,
     (SELECT t8.c11
      FROM t8 LIMIT 1) AS c11
   FROM t8) AS t8_14
LEFT OUTER JOIN t23 AS t23_571_1 ON t23_571_1.c18 =1
OR t23_571_1.c8 < 1
WHERE EXISTS
    (SELECT 1
     FROM t21 AS t21_13)
  OR 1 = 1
GROUP BY t8_14.c4,
         t8_14.c11,
         t8_14.c6 HAVING MIN(t8_14.c11) >= 561;
--disable_query_log
--explain_protocol 0

drop table t8, t21, t23;

