
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_info
--disable_metadata
--disable_abort_on_error

--result_format 4
--explain_protocol 2

--disable_warnings
DROP DATABASE IF EXISTS DB_ANY_ALL;
--enable_warnings
CREATE DATABASE DB_ANY_ALL;
USE DB_ANY_ALL;

--let $case_idx= 0

--disable_warnings
drop table if exists t1, t2, is_t1;
--enable_warnings
create table t1(c1 int not null, c2 int, key idx_c1(c2));
create table t2(c1 int not null, c2 int, key idx_c2(c1));
create table is_t1(c1 int);

insert/*trace*/ into t1 values(1,2),(2,3),(3,3), (4,3),(4,4),(6,5),(6,5),(10,20);
insert/*trace*/ into t2 values(1,2),(2,3),(3,3), (4,3),(4,4),(6,5),(6,5),(10,20);

set autocommit = 0;


--echo
--echo
--inc $case_idx
--echo # case $case_idx
--echo ****** val > ANY(SELECT col_item ...)  <==> val > ANY(SELECT MIN(col_item) ...);
--echo
select c1 from t1 where c1 >ANY(select c1 from t2);
select /*+no_rewrite*/c1 from t1 where c1 >ANY(select c1 from t2);
update t1 set c1 = c2 + 1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;
update /*+no_rewrite*/t1 set c1 = c2 + 1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;
delete from t1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;
delete /*+no_rewrite*/from t1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;
insert into is_t1 select c1 from t1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;
insert into is_t1 select /*+NO_REWRITE*/c1 from t1 where c1 >ANY(select c1 from t2);
select/**/ * from t1;
rollback;

