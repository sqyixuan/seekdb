--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql3
#tags: optimizer, cross_validation

--disable_query_log
--disable_warnings
drop view if EXISTS mingye;
DROP TABLE IF EXISTS `t2_resource_material`;
DROP TABLE IF EXISTS `t2_resource`;
DROP TABLE IF EXISTS `t2_slot_requirement`;
--enable_query_log
--enable_warnings

CREATE TABLE `t2_resource_material` (
  `id` int(11) NOT NULL,
  `resource_id` int(11) NOT NULL COMMENT 'id',
  `material_type` varchar(10) NOT NULL COMMENT '(IMAGELINKCONTENTPRODUCTATTRIBUTE)',
  `material_key` varchar(32) NOT NULL COMMENT 'key',
  `material_id` int(11) DEFAULT NULL COMMENT 'id',
  `image_size` varchar(10) DEFAULT NULL,
  `content` text DEFAULT NULL COMMENT '/',
  PRIMARY KEY (`id`),
  KEY `resource_material_mid_idx` (`material_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `resource_material_resource_idx` (`resource_id`) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `t2_resource` (
  `resource_id` int(11) NOT NULL COMMENT 'id',
  `resource_name` varchar(250) NOT NULL,
  `channel` varchar(10) DEFAULT NULL,
  `resource_type` varchar(10) NOT NULL COMMENT '\tMENUADVERT:PRODUCT',
  `advertisement_type` varchar(10) DEFAULT NULL COMMENT '1+,2+,3++,4,5',
  `effective_date` date NOT NULL,
  `expire_date` date NOT NULL,
  `status` varchar(12) NOT NULL COMMENT 'UNCONFIRMEDCONFIRMEDDELETED',
  `enable` tinyint(1) NOT NULL COMMENT ' 01',
  `operator_id` varchar(32) DEFAULT NULL,
  `operator_department` varchar(32) DEFAULT NULL,
  `last_update_time` datetime DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP,
  `tunnel_no` varchar(10) DEFAULT NULL,
  `channel_code` varchar(10) DEFAULT NULL,
  `corporate_bank_no` varchar(32) DEFAULT NULL,
  `resource_origin_id` varchar(50) DEFAULT NULL COMMENT 'id',
  `bsn_code` varchar(32) DEFAULT NULL,
  `app_version` varchar(32) DEFAULT NULL COMMENT '10',
  `pic_type` varchar(32) DEFAULT NULL COMMENT ' imagesplashpopupfloatpictures',
  `expiry_type` varchar(10) DEFAULT NULL COMMENT '01',
  PRIMARY KEY (`resource_id`)
);

CREATE TABLE `t2_slot_requirement` (
  `requirement_id` int(11) NOT NULL COMMENT 'ID',
  `position_id` varchar(50) NOT NULL COMMENT 'id',
  `slot_index` int(11) NOT NULL DEFAULT '0' COMMENT ',10ELSE',
  `material_type` varchar(10) NOT NULL COMMENT '(IMAGELINKCONTENTPRODUCTATTRIBUTE)',
  `material_key` varchar(32) DEFAULT NULL COMMENT 'key',
  `material_key_desc` varchar(50) DEFAULT NULL COMMENT 'key',
  `image_size` varchar(10) DEFAULT NULL COMMENT ',',
  PRIMARY KEY (`requirement_id`),
  KEY `slot_requirement_position_idx` (`position_id`) BLOCK_SIZE 16384 LOCAL
);

create view mingye as 
select tsr.position_id AS position_id,
        trm.resource_id AS resource_id
from test.t2_resource_material trm, test.t2_resource tr, test.t2_slot_requirement tsr 
where trm.material_type = tsr.material_type and tr.resource_id = trm.resource_id;


--result_format 4

select 1
from mingye sat1 
left join (select srm.position_id AS position_id,
                  srm.resource_id AS resource_id 
          from mingye srm
          left join mingye sat 
          on srm.resource_id = sat.resource_id 
          where sat.resource_id is null) usat 
on usat.position_id = sat1.position_id and
   usat.resource_id = sat1.resource_id
where usat.position_id is null and sat1.resource_id = '77';

drop view if EXISTS mingye;
DROP TABLE IF EXISTS `t2_resource_material`;
DROP TABLE IF EXISTS `t2_resource`;
DROP TABLE IF EXISTS `t2_slot_requirement`;
