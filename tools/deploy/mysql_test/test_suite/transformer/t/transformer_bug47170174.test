## bug : 

--disable_warnings
drop table if exists t_empty, t1, t2, t3;
--enable_warnings
create table t_empty(a int not null, b int);
create table t1(a int not null, b int);
create table t2(a int not null, b int);
create table t3(a int not null, b int);

insert into t1 values (1, 1), (2, 2), (3, null);
insert into t2 values (1, 1), (2, null), (4, 4);
insert into t2 values (1, 1), (2, 2), (4, null);

--explain_protocol 2
--result_format 4

select a, max(b) from t_empty having a is null;
select /*+no_rewrite*/ a, max(b) from t_empty having a is null;

select a, b from t1 where b is not null and b > 0;
select /*+no_rewrite*/ a, b from t1 where b is not null and b > 0;

select a, b from t1 where b > 0 group by a having b is not null;
select /*+no_rewrite*/ a, b from t1 where b > 0 group by a having b is not null;

select a, b from t1 group by a having b > 0 and b is not null;
select /*+no_rewrite*/ a, b from t1 group by a having b > 0 and b is not null;

select a, b from t1 group by a having b is not null;
select /*+no_rewrite*/ a, b from t1 group by a having b is not null;

select a, max(b) from t1 group by a with rollup having a is null;
select /*+no_rewrite*/ a, max(b) from t1 group by a with rollup having a is null;

select * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;

select * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;

select * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t3.a is null or t3.a > 0;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) left join t3 on t1.b <=> t3.b where t3.a is null or t3.a > 0;

select * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;

select * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;

select * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t3.a is null or t3.a > 0;
select /*+no_rewrite*/ * from t3 right join (t1 left join t2 on t1.b <=> t2.b) on t1.b <=> t3.b where t3.a is null or t3.a > 0;

select * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t1.a is null or t1.a > 0 or t3.a is null;

select * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t2.a is null or t2.a > 0 or t3.a is null;

select * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t3.a is null or t3.a > 0;
select /*+no_rewrite*/ * from (t1 left join t2 on t1.b <=> t2.b) full join t3 on t1.b <=> t3.b where t3.a is null or t3.a > 0;

drop table t_empty, t1, t2, t3;