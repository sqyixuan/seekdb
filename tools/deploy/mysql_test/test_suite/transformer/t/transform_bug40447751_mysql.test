#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);

--result_format 4
--explain_protocol 2

select * from t1 left join t2 on (select 1 from t3 where t1.c1 = t2.c1) <> 1;

select * from t1 right join t2 on (exists (select t2.c1 from t3)) and ((exists (select 1 from t3)) or (t2.c1 is null));

drop table if exists t1,t2,t3;

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(a int, b int);
create table t2(d int, e int not null);
create table t3(a int, b int) partition by hash(b) partitions 4;
create table t4(d int, e int not null) partition by hash(e) partitions 4;

--disable_query_log
--disable_result_log
insert into t1 values (1,1),(2,2),(3,3),(4,4);
insert into t2 values (1,1),(2,2),(6,6),(5,5);
insert into t3 values (1,1),(2,2),(3,3),(4,4);
insert into t4 values (1,1),(2,2),(6,6),(5,5);
--enable_result_log
--enable_query_log

SELECT /*+ READ_CONSISTENCY (WEAK)  PARALLEL( 8 ) leading(t1 VIEW1) px_join_filter(VIEW1)*/ * FROM (select * from t2 for update) v RIGHT JOIN t1 ON v.e = t1.b WHERE isnull(v.e) ORDER BY 3 LIMIT 3 for update;
SELECT /*+ PARALLEL( 1 )*/ * FROM (select * from t2 for update) v RIGHT JOIN t1 ON v.e = t1.b WHERE isnull(v.e) ORDER BY 3 LIMIT 3 for update;

select /*+parallel(8) leading(t1 VIEW1) px_join_filter(VIEW1) pq_distribute(VIEW1 hash hash)*/ * from (select * from t1 for update) v where exists (select * from t2 where v.b = t2.e for update) order by 1,2;
select /*+parallel(1)*/ * from (select * from t1 for update) v where exists (select * from t2 where v.b = t2.e for update);

SELECT /*+ READ_CONSISTENCY (WEAK)  PARALLEL( 8 ) leading(t3 v) px_join_filter(v)*/ * FROM (select * from t4 for update) v RIGHT JOIN t3 ON v.e = t3.b WHERE isnull(v.e) ORDER BY 3 LIMIT 3 for update;
SELECT /*+ PARALLEL( 1 )*/ * FROM (select * from t4 for update) v RIGHT JOIN t3 ON v.e = t3.b WHERE isnull(v.e) ORDER BY 3 LIMIT 3 for update;

--sorted_result
select /*+parallel(8) leading(t3 t4) px_join_filter(t4) pq_distribute(t4 hash hash)*/ * from (select * from t3 for update) v where exists (select * from t4 where v.b = t4.e for update);
--sorted_result
select /*+parallel(1)*/ * from (select * from t3 for update) v where exists (select * from t4 where v.b = t4.e for update);

--sorted_result
select /*+parallel(8)*/ * from (t3 left join t2 u on e = t3.a) left join t1 on t1.a = t3.b where e is null for update;
--sorted_result
select /*+parallel(1)*/ * from (t3 left join t2 u on e = t3.a) left join t1 on t1.a = t3.b where e is null for update;

drop table t1,t2,t3,t4;
