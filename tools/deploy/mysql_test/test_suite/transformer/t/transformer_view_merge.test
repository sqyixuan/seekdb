## simplified sql
explain
select grandparent1.col_varchar_10
  from gg as grandparent1
  where grandparent1.pk in
    (select parent1.col_int
        from gg as parent1 left join t as parent2 on ( parent1.col_varchar_10 >= parent2.col_varchar_10 )
        where grandparent1.col_int_key in ( select pk as c1 from j as child1 ));

## original sql
explain
select grandparent1.col_varchar_10 as g1
  from gg as grandparent1 left join kk as grandparent2 using ( col_varchar_10 )
  where ( grandparent1.pk , grandparent1.col_int ) in
  (select parent1.col_int as p1 , parent1.col_int_key as p2
      from gg as parent1 left join t as parent2 on ( parent1.col_varchar_10 >= parent2.col_varchar_10 )
      where grandparent1.col_int_key in ( select child1.pk as c1 from j as child1 where ( ( child1.col_int = child1.col_int_key ) or not ( ( ( ( grandparent1.pk > 2 or grandparent1.col_int_key = 5 ) and grandparent1.col_int_key < 0 ) or grandparent1.col_datetime_key <> '2009-11-17' ) or not grandparent1.col_date >= '2005-02-28' ) ) )
      and ( grandparent1.col_varchar_10_key = 'w' ))
  and (((grandparent1.col_varchar_10 is unknown or grandparent1.col_datetime_key between '2007-02-16' and '2003-11-22') and grandparent1.col_varchar_10 is null ) or grandparent1.col_varchar_10 is not null )
  group by grandparent1.col_varchar_10 having g1 >= '2008-12-16' order by grandparent1.col_varchar_10;

--disable_warnings
drop table if exists CC, C, D, B;
--enable_warnings

CREATE TABLE CC ( col_varchar_key varchar (1), col_int_key int, col_varchar_10 varchar(10), pk int, col_varchar_10_key varchar(10), col_varchar_20_key varchar(20), col_varchar varchar (1), col_int int, col_varchar_20 varchar(20), /*Indices*/ key idx3(col_varchar_key ), key idx1(col_int_key ), primary key (pk), key idx5(col_varchar_10_key ), key idx7(col_varchar_20_key ));

CREATE TABLE C ( col_varchar_key varchar (1), pk int, col_varchar_10 varchar(10), col_varchar_20 varchar(20), col_varchar varchar (1), col_int_key int, col_int int, col_varchar_20_key varchar(20), col_varchar_10_key varchar(10), /*Indices*/ key idx3(col_varchar_key ), primary key (pk), key idx1(col_int_key ), key idx7(col_varchar_20_key ), key idx5(col_varchar_10_key ));

CREATE TABLE D ( col_varchar varchar (1), col_varchar_20_key varchar(20), pk int, col_int_key int, col_varchar_20 varchar(20), col_varchar_key varchar (1), col_varchar_10 varchar(10), col_varchar_10_key varchar(10), col_int int, /*Indices*/ key idx7(col_varchar_20_key ), primary key (pk), key idx1(col_int_key ), key idx3(col_varchar_key ), key idx5(col_varchar_10_key ));

CREATE TABLE B ( pk int, col_int int, col_varchar_10 varchar(10), col_varchar_20_key varchar(20), col_varchar_10_key varchar(10), col_varchar_20 varchar(20), col_varchar_key varchar (1), col_int_key int, col_varchar varchar (1), /*Indices*/ primary key (pk), key idx7(col_varchar_20_key ), key idx5(col_varchar_10_key ), key idx3(col_varchar_key ), key idx1(col_int_key ));

explain SELECT 1 
  FROM   c AS table2 RIGHT JOIN (SELECT * FROM   d) AS table3 
ON ( table3.col_varchar_key = table2.col_varchar ) 
  WHERE  ( EXISTS (SELECT 1 
        FROM   b AS SUBQUERY2_t1, b AS SUBQUERY2_t2 
        WHERE  SUBQUERY2_t2.col_int != table2.col_int) ); 

SELECT 1 
  FROM   c AS table2 RIGHT JOIN (SELECT * FROM   d) AS table3 
ON ( table3.col_varchar_key = table2.col_varchar ) 
  WHERE  ( EXISTS (SELECT 1 
        FROM   b AS SUBQUERY2_t1, b AS SUBQUERY2_t2 
        WHERE  SUBQUERY2_t2.col_int != table2.col_int) ); 

