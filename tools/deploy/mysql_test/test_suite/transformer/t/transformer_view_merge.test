#left outer join右表视图展开条件放宽
--disable_warnings
drop table if exists t1, t2, t3, t4;
drop view if exists v1, v2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int not null, c3 int);
create table t3(c1 int primary key, c2 int, c3 int);
create table t4(c1 int, c2 int, c3 int);

create view v1 (c1, c2, c3) as select c1, c2, nvl(c3+1,10) c3 from t1;
create view v2 (c1, c2, c3) as select t2.* from t2,t3 where t2.c1=t3.c1 and t2.c2=1;

--disable_query_log
--disable_result_log
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 values(4,4,4);

