select count(*) from t2;
--enable_query_log 
--enable_result_log

explain select * from (select floor(rand() * 2) + 1 as id, c1 as x1 from t1) v, t2 where v.id = t2.c2;
explain select * from (select /*+no_merge*/ floor(rand() * 2) + 1 as id, c1 as x1 from t1) v, t2 where v.id = t2.c2;

explain select * from (select c1 as x1 from t1 where rand()<t1.c2) v, t2 where v.x1 = t2.c2;
explain select * from (select /*+no_merge*/ c1 as x1 from t1 where rand()<t1.c2) v, t2 where v.x1 = t2.c2;

explain select v.* from t1 left join (select a.* from t2 a, t2 b where a.c1 = b.c1)v on t1.c1 = v.c1;
explain select v.* from t1 left join (select /*+merge*/a.* from t2 a, t2 b where a.c1 = b.c1)v on t1.c1 = v.c1;

explain select v.* from t1 left join (select a.* from t2 a left join t2 b on a.c1 = b.c1)v on t1.c1 = v.c1;

explain select v.* from t1 left join (select a.* from t2 a left join t2 b on 1 = b.c1)v on t1.c1 = v.c1;
explain select v.* from t1 left join (select /*+merge*/a.* from t2 a left join t2 b on 1 = b.c1)v on t1.c1 = v.c1;

explain select v.* from t1 left join (select b.* from t2 a left join t2 b on a.c1 = b.c1)v on t1.c1 = v.c1;
explain select v.* from t1 left join (select /*+merge*/b.* from t2 a left join t2 b on a.c1 = b.c1)v on t1.c1 = v.c1;

explain select v.* from (select a.* from t2 a left join t2 b on a.c1 = b.c1)v right join t1 on t1.c1 = v.c1;

explain select v.* from (select b.* from t2 a right join t2 b on a.c1 = b.c1)v right join t1 on t1.c1 = v.c1;

