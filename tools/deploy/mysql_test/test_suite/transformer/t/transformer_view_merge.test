--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: lijinmao.ljm
# owner group: SQL1
# tags: optimizer
# description: when a subquery is merged with parent, parallel hint should use the one in outer query 
# if specified there; otherwise use parallel hint of its own
# hints such as [no_]use_hash(x, y) with no query block name specified in parent should be ignored.
# tests in this file verify  bug #13234220
# expected behaver should be the same as Oracle
--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--enable_query_log
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc
connection default;
--disable_warnings
drop database if exists view_merge_db;
--enable_warnings
create database view_merge_db;
use view_merge_db;
create table nn1(c1 int, c2 int, c3 varchar(10));
create table nn2(d1 int, d2 int, d3 varchar(10));
sleep 3;

## set @@session.ob_enable_transformation = 0;
--echo ### parallel hints only exist in outer query, plan should be parallel  ###
explain outline  select /*+ parallel(2) */ * from (select * from nn1, nn2 where c1 = d2);
--echo ### no_use_hash hint specified in outer query, should be ignored ###
explain outline  select /*+ no_use_hash(nn1, nn2) */ * from (select * from nn1, nn2 where c1 = d2);

--echo ### hints only exist in inner query, should work  ###
explain outline  select * from (select /*+ no_use_hash(nn1, nn2) */ * from nn1, nn2 where c1 = d2);
--echo ### parallel hint specified in inner query should work ###
explain outline  select * from (select /*+ parallel(2)*/ * from nn1, nn2 where c1 = d2) limit 5;

--echo ### hints exist in inner and outer query, expect parallel(3) and no_use_hash ###
explain outline  select /*+ parallel(3) */ * from (select /*+ parallel(1) no_use_hash(nn1, nn2) */ * from nn1, nn2 where c1 = d2);
--echo ### except no parallel and hash join used
explain outline  select /*+ no_use_hash(nn1, nn2) parallel(1) */ * from (select /*+ parallel(2)*/ * from nn1, nn2 where c1 = d2) limit 8,2;
drop database view_merge_db;

