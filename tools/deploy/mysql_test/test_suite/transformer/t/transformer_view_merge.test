INSERT INTO `cc` VALUES (7,'i','t',1,'z',3,'e','k','s'),(7,'k','a',2,NULL,6,'t','d','z'),(4,NULL,'c',3,'f',9,'g','o','y'),(0,'o','q',4,'d',5,'f','j','r'),(6,'v','j',5,'t',3,'k','r',NULL),(2,'h','t',6,'o',9,'o',NULL,'m'),(4,'i','d',7,'u',6,'z','d','a'),(9,'h',NULL,8,'l',3,'p','y','l'),(5,NULL,'d',9,'i',9,'u','y',NULL),(9,NULL,'j',10,'r',0,'o',NULL,'q'),(6,'w','v',11,'r',7,'s','l',NULL),(1,'l','e',12,NULL,7,'e',NULL,'r'),(9,'b','j',13,'c',0,'a','x','r'),(8,'z',NULL,14,'a',5,'s',NULL,NULL),(5,'b','m',15,'h',6,'i',NULL,'v'),(9,'l','k',16,'o',0,'w','z','l'),(8,'p',NULL,17,'x',4,'l','s',NULL),(6,'p','o',18,'x',9,'s','s','c'),(3,'q',NULL,19,NULL,1,NULL,NULL,NULL),(0,'w','k',20,'q',NULL,NULL,'c','a'),(7,'l','e',21,'u',1,'w',NULL,'o'),(8,'t',NULL,22,'y',2,'k','x','n'),(2,NULL,NULL,23,'g',1,NULL,'s','b'),(NULL,'k',NULL,24,'i',3,'d','a','d'),(6,'j','m',25,NULL,5,'j',NULL,'n'),(8,'p','o',26,'x',0,NULL,'o','z'),(6,'w','c',27,'r',7,'v','h','t'),(8,'s','q',28,NULL,8,'p','p',NULL),(0,'q',NULL,29,'k',3,'t','p','t');
--enable_query_log
--enable_result_log

SELECT table1 . col_int_key AS field1,
       table1 . col_int_key AS field2
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (C AS SUBQUERY1_t1
               LEFT OUTER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
         WHERE SUBQUERY1_t1 . `pk` = 4 ) AS table1
      INNER JOIN
        (SELECT DISTINCT SUBQUERY2_t1 . *
         FROM (C AS SUBQUERY2_t1
               RIGHT  JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `pk` = SUBQUERY2_t1 . `pk`))
         WHERE (EXISTS
                  (SELECT CHILD_SUBQUERY1_t1 . `pk` AS CHILD_SUBQUERY2_field1
                   FROM (CC AS CHILD_SUBQUERY1_t1
                         INNER JOIN C AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `col_int_key` = CHILD_SUBQUERY1_t1 . `col_int`))
                   WHERE CHILD_SUBQUERY1_t2 . `col_varchar` >= SUBQUERY2_t1 . `col_varchar_10_key`
                     AND CHILD_SUBQUERY1_t2 . `col_varchar_20_key` = SUBQUERY2_t2 . `col_varchar_10` )
                AND SUBQUERY2_t1 . `col_varchar_20` >= 'l') ) AS table2 ON (table2 . `col_int_key` = table1 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY3_t1 . `col_varchar_20_key` AS SUBQUERY3_field1
          FROM C AS SUBQUERY3_t1
          WHERE SUBQUERY3_t1 . `col_int_key` <> table1 . `col_int_key`
            AND SUBQUERY3_t1 . `col_varchar_key` <> table2 . `col_varchar_20_key` ))
  AND (table1 . `col_varchar_key` = 'a'
       OR table1 . `col_int_key` = 174)
ORDER BY 1,
         field1,
         field2
LIMIT 1000;

SELECT /*+no_rewrite*/ table1 . col_int_key AS field1,
                       table1 . col_int_key AS field2
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (C AS SUBQUERY1_t1
               LEFT OUTER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
         WHERE SUBQUERY1_t1 . `pk` = 4 ) AS table1
      INNER JOIN
        (SELECT DISTINCT SUBQUERY2_t1 . *
         FROM (C AS SUBQUERY2_t1
               RIGHT  JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `pk` = SUBQUERY2_t1 . `pk`))
         WHERE (EXISTS
                  (SELECT CHILD_SUBQUERY1_t1 . `pk` AS CHILD_SUBQUERY2_field1
                   FROM (CC AS CHILD_SUBQUERY1_t1
                         INNER JOIN C AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `col_int_key` = CHILD_SUBQUERY1_t1 . `col_int`))
                   WHERE CHILD_SUBQUERY1_t2 . `col_varchar` >= SUBQUERY2_t1 . `col_varchar_10_key`
                     AND CHILD_SUBQUERY1_t2 . `col_varchar_20_key` = SUBQUERY2_t2 . `col_varchar_10` )
                AND SUBQUERY2_t1 . `col_varchar_20` >= 'l') ) AS table2 ON (table2 . `col_int_key` = table1 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY3_t1 . `col_varchar_20_key` AS SUBQUERY3_field1
          FROM C AS SUBQUERY3_t1
          WHERE SUBQUERY3_t1 . `col_int_key` <> table1 . `col_int_key`
            AND SUBQUERY3_t1 . `col_varchar_key` <> table2 . `col_varchar_20_key` ))
  AND (table1 . `col_varchar_key` = 'a'
       OR table1 . `col_int_key` = 174)
ORDER BY 1,
         field1,
         field2
LIMIT 1000;

