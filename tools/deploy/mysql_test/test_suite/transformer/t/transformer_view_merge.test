select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
--enable_query_log
--enable_result_log

#on condition有null reject column
select distinct v1.* from (select t2.* from t2,t3 where t2.c1=t3.c1 and t2.c2=1)v2 left join (select c1, c2, nvl(c3+1,10) c3 from t1)v1 on v1.c1=v2.c1 and v1.c3=v2.c3;
select distinct v1.* from (select /*+no_merge*/t2.* from t2,t3 where t2.c1=t3.c1 and t2.c2=1)v2 left join (select /*+no_merge*/c1, c2, nvl(c3+1,10) c3 from t1)v1 on v1.c1=v2.c1 and v1.c3=v2.c3;

select v1.* from (select c1, c2, nvl(c3+1,10) c3 from t1)v1 right join (select t2.* from t2,t3 where t2.c1=t3.c1 and t2.c2=1)v2 on v1.c1=v2.c1 and v1.c3=v2.c3;
select v1.* from (select /*+no_merge*/c1, c2, nvl(c3+1,10) c3 from t1)v1 right join (select /*+no_merge*/t2.* from t2,t3 where t2.c1=t3.c1 and t2.c2=1)v2 on v1.c1=v2.c1 and v1.c3=v2.c3;

#inner stmt找到非空列
select B.c3 from t2 left join (select * from (select c2, nvl(c3,10)c3 from t2) A ) B on t2.c3=B.c3;
select B.c3 from t2 left join (select /*+no_merge*/* from (select /*+no_merge*/c2, nvl(c3,10)c3 from t2) A ) B on t2.c3=B.c3;

#inner stmt找到非空pk
select B.c3 from t2 left join (select * from (select c2, nvl(c3,10)c3 from t3) A ) B on t2.c3=B.c3;
select B.c3 from t2 left join (select /*+no_merge*/* from (select /*+no_merge*/c2, nvl(c3,10)c3 from t3) A ) B on t2.c3=B.c3;

#inner stmt找到隐藏主键
select B.c3 from t2 left join (select * from (select c2, nvl(c3,10)c3 from t4) A ) B on t2.c3=B.c3;
select B.c3 from t2 left join (select /*+no_merge*/* from (select /*+no_merge*/c2, nvl(c3,10)c3 from t4) A ) B on t2.c3=B.c3;

#不能展开
select B.* from t2 left join (select * from (select c1, c2, nvl(c3,10)c3 from t2) A limit 10) B on t2.c3=B.c3;
select B.* from t2 left join (select /*+no_merge*/* from (select /*+no_merge*/c1, c2, nvl(c3,10)c3 from t2) A limit 10) B on t2.c3=B.c3;

--disable_warnings
drop table if exists t1, t2, t3, t4;
drop view if exists v1, v2;
--enable_warnings

