SELECT 1
FROM C LEFT OUTER JOIN (SELECT /*+no_merge*/ BB.* FROM BB) v ON (1), D
WHERE D. `col_varchar_key` != 'faf' OR v . `col_varchar` >= C . `col_varchar`;
SELECT SUM(DISTINCT table2 . `col_int`) AS field1
FROM (CC AS table1
      RIGHT OUTER JOIN ((C AS table2
                         LEFT OUTER JOIN
                           (SELECT DISTINCT SUBQUERY1_t1 . *
                            FROM BB AS SUBQUERY1_t1
                            WHERE (SUBQUERY1_t1 . `col_varchar_20_key` NOT IN
                                     (SELECT CHILD_SUBQUERY1_t2 . `col_varchar_20` AS CHILD_SUBQUERY1_field1
                                      FROM (C AS CHILD_SUBQUERY1_t1
                                            RIGHT OUTER JOIN CC AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `pk` = CHILD_SUBQUERY1_t1 . `col_int_key`))
                                      WHERE CHILD_SUBQUERY1_t2 . `col_varchar_10` <> SUBQUERY1_t1 . `col_varchar` )
                                   AND SUBQUERY1_t1 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_10_key`) ) AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_10`))) ON (table3 . `col_varchar_key` = table2 . `col_varchar`))
WHERE (table1 . `col_varchar_10_key` !=
         (SELECT MAX(SUBQUERY2_t1 . `col_varchar_key`) AS SUBQUERY2_field1
          FROM D AS SUBQUERY2_t1
          WHERE (SUBQUERY2_t1 . `pk` <= 5
                 OR SUBQUERY2_t1 . `col_varchar_10` <= SUBQUERY2_t1 . `col_varchar_20_key`) ))
  AND table1 . `pk` = table1 . `pk`
  OR table3 . `col_varchar` >= table2 . `col_varchar`
HAVING field1 <= 5
ORDER BY 1, field1 ;

SELECT /*+no_rewrite*/SUM(DISTINCT table2 . `col_int`) AS field1
FROM (CC AS table1
      RIGHT OUTER JOIN ((C AS table2
                         LEFT OUTER JOIN
                           (SELECT DISTINCT SUBQUERY1_t1 . *
                            FROM BB AS SUBQUERY1_t1
                            WHERE (SUBQUERY1_t1 . `col_varchar_20_key` NOT IN
                                     (SELECT CHILD_SUBQUERY1_t2 . `col_varchar_20` AS CHILD_SUBQUERY1_field1
                                      FROM (C AS CHILD_SUBQUERY1_t1
                                            RIGHT OUTER JOIN CC AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `pk` = CHILD_SUBQUERY1_t1 . `col_int_key`))
                                      WHERE CHILD_SUBQUERY1_t2 . `col_varchar_10` <> SUBQUERY1_t1 . `col_varchar` )
                                   AND SUBQUERY1_t1 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_10_key`) ) AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_10`))) ON (table3 . `col_varchar_key` = table2 . `col_varchar`))
WHERE (table1 . `col_varchar_10_key` !=
         (SELECT MAX(SUBQUERY2_t1 . `col_varchar_key`) AS SUBQUERY2_field1
          FROM D AS SUBQUERY2_t1
          WHERE (SUBQUERY2_t1 . `pk` <= 5
                 OR SUBQUERY2_t1 . `col_varchar_10` <= SUBQUERY2_t1 . `col_varchar_20_key`) ))
  AND table1 . `pk` = table1 . `pk`
  OR table3 . `col_varchar` >= table2 . `col_varchar`
HAVING field1 <= 5
ORDER BY 1, field1 ;

