SELECT table1 . col_int_key AS field1,
       table1 . col_varchar_key AS field2,
       table1 . col_int_key AS field3
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (CC AS SUBQUERY1_t1
               RIGHT OUTER JOIN (D AS SUBQUERY1_t2
                                 INNER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `col_varchar_10_key` = SUBQUERY1_t2 . `col_varchar_key`)) ON (SUBQUERY1_t3 . `col_varchar_key` = SUBQUERY1_t2 . `col_varchar_20`))) AS table1
      RIGHT  JOIN CC AS table2 ON (table2 . `col_varchar_20` = table1 . `col_varchar_key`))
WHERE (table2 . `col_varchar_key` = ALL
         (SELECT SUBQUERY2_t1 . `col_varchar_key` AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN D AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`))
          WHERE SUBQUERY2_t1 . `col_int_key` > table2 . `col_int_key` ))
  OR table1 . `col_int` <= table2 . `col_int`
ORDER BY field1,
         field2,
         field3
LIMIT 100
OFFSET 1
;
 
SELECT /*+no_rewrite*/ table1 . col_int_key AS field1,
       table1 . col_varchar_key AS field2,
       table1 . col_int_key AS field3
FROM (
        (SELECT SUBQUERY1_t1 . *
         FROM (CC AS SUBQUERY1_t1
               RIGHT OUTER JOIN (D AS SUBQUERY1_t2
                                 INNER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `col_varchar_10_key` = SUBQUERY1_t2 . `col_varchar_key`)) ON (SUBQUERY1_t3 . `col_varchar_key` = SUBQUERY1_t2 . `col_varchar_20`))) AS table1
      RIGHT  JOIN CC AS table2 ON (table2 . `col_varchar_20` = table1 . `col_varchar_key`))
WHERE (table2 . `col_varchar_key` = ALL
         (SELECT SUBQUERY2_t1 . `col_varchar_key` AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN D AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`))
          WHERE SUBQUERY2_t1 . `col_int_key` > table2 . `col_int_key` ))
  OR table1 . `col_int` <= table2 . `col_int`
ORDER BY field1,
         field2,
         field3
LIMIT 100
OFFSET 1
;

