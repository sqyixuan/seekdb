#owner: sean.yyj
#owner group: sql3
# tags: optimizer
##
## Test Name: win_magic_second.test
--disable_warnings
drop table if exists t1, t2, t3, part, lineitem;
create table t1 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t2 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t3 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
CREATE TABLE `part` (
  `p_partkey` bigint(20) NOT NULL,
  `p_name` varchar(55) DEFAULT NULL,
  `p_mfgr` char(25) DEFAULT NULL,
  `p_brand` char(10) DEFAULT NULL,
  `p_type` varchar(25) DEFAULT NULL,
  `p_size` bigint(20) DEFAULT NULL,
  `p_container` char(10) DEFAULT NULL,
  `p_retailprice` decimal(10,2) DEFAULT NULL,
  `p_comment` varchar(23) DEFAULT NULL,
  PRIMARY KEY (`p_partkey`)
);

CREATE TABLE `lineitem` (
  `l_orderkey` bigint(20) NOT NULL,
  `l_partkey` bigint(20) NOT NULL,
  `l_suppkey` bigint(20) NOT NULL,
  `l_linenumber` bigint(20) NOT NULL,
  `l_quantity` bigint(20) NOT NULL,
  `l_extendedprice` decimal(10,2) NOT NULL,
  `l_discount` decimal(10,2) NOT NULL,
  `l_tax` decimal(10,2) NOT NULL,
  `l_returnflag` char(1) DEFAULT NULL,
  `l_linestatus` char(1) DEFAULT NULL,
  `l_shipdate` date NOT NULL,
  `l_commitdate` date DEFAULT NULL,
  `l_receiptdate` date DEFAULT NULL,
  `l_shipinstruct` char(25) DEFAULT NULL,
  `l_shipmode` char(10) DEFAULT NULL,
  `l_comment` varchar(44) DEFAULT NULL,
  PRIMARY KEY (`l_orderkey`, `l_linenumber`, `l_shipdate`, `l_partkey`),
  KEY `i_l_orderkey` (`l_orderkey`) LOCAL  BLOCK_SIZE 16384
);
--enable_warnings
--disable_query_log
insert into t1 values (0,5,7,1);
insert into t1 values (1,9,2,4);
insert into t1 values (2,0,2,1);
insert into t1 values (3,4,6,9);
insert into t1 values (4,7,null,3);
insert into t1 values (5,3,5,null);
insert into t1 values (6,8,null,null);
insert into t1 values (7,7,8,8);

insert into t2 values (0,5,7,1);
insert into t2 values (1,9,2,4);
insert into t2 values (2,0,2,1);
insert into t2 values (3,4,6,9);
insert into t2 values (4,7,null,3);
insert into t2 values (5,3,5,null);
insert into t2 values (6,8,null,null);
insert into t2 values (7,7,8,8);

insert into t3 values(0,2,3,4);
insert into t3 values(9,5,2,7);
insert into t3 values(1,6,8,8);
insert into t3 values(2,4,6,8);
insert into t3 values(5,5,5,5);
insert into t3 values(6,6,6,6);
insert into t3 values(7,7,7,7);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

#basic
select * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;

select * from t1, (select avg(c1+c2), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1+c2), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;

select * from t1, (select avg(c1+c2)+count(c3)+1, c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1+c2)+count(c3)+1, c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;

select * from t1, (select avg(c1), c2 from t1 where t1.c1>1 group by c2) v where t1.c2 = v.c2 and t1.c1>1 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2 from t1 where t1.c1>1 group by c2) v where t1.c2 = v.c2 and t1.c1>1 order by t1.pk;

select * from t1, (select min(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select min(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;

select * from t1, (select max(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select max(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;

select * from (select max(c1), c2 from t1 group by c2) v, t1 where t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from (select max(c1), c2 from t1 group by c2) v, t1 where t1.c2 = v.c2 order by t1.pk;

select * from t1, (select sum(c1) agg, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;

select * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 order by t1.pk;

##no rewrite
select * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;

#rewrite
select * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg > v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg > v.c2 order by t1.pk;

select * from t1, (select sum(c1) agg, min(c3) agg2, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg2 < v.agg order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, min(c3) agg2, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg2 < v.agg order by t1.pk;

#joined table
select * from t1 left join t2 on t1.c1=t2.c1, (select max(t2.c1), t1.c2 from t1 left join t2 on t1.c1=t2.c1 group by t1.c2) v2 where t1.c2=v2.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1=t2.c1, (select max(t2.c1), t1.c2 from t1 left join t2 on t1.c1=t2.c1 group by t1.c2) v2 where t1.c2=v2.c2 order by t1.pk,t2.pk;

##no rewrite
select * from t1 left join t2 on t1.c1=t2.c1, (select /*+no_rewrite*/ max(t1.c1), t2.c2 from t1 left join t2 on t1.c1=t2.c1 group by t2.c2) v2 where t1.c2=v2.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1=t2.c1, (select /*+no_rewrite*/ max(t1.c1), t2.c2 from t1 left join t2 on t1.c1=t2.c1 group by t2.c2) v2 where t1.c2=v2.c2 order by t1.pk,t2.pk;

#numrous tables
select * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk;

select * from t1, t2, (select max(t1.c1) agg, t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 and v.agg > t1.c1 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t1.c1) agg, t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 and v.agg > t1.c1 order by t1.pk,t2.pk;

select * from t1, t2, t3, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk,t3.pk;
select /*+no_rewrite*/ * from t1, t2, t3, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk,t3.pk;

select * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c1) v where v.c2 = t1.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c1) v where v.c2 = t1.c2 order by t1.pk,t2.pk;

select * from t1, t2, (select max(t2.c1), t2.c2 from t2 group by t2.c2) v where v.c2 = t1.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t2.c1), t2.c2 from t2 group by t2.c2) v where v.c2 = t1.c2 order by t1.pk,t2.pk;

#ja to win
select * from t1 where t1.c1 < (select sum(a.c1) from t1 a where a.c1=t1.c1) order by t1.pk;
select /*+no_rewrite*/ * from t1 where t1.c1 < (select sum(a.c1) from t1 a where a.c1=t1.c1) order by t1.pk;

select c1 from t1 a where a.c1 <= (select min(b.c1) from t1 b where a.c2 =b.c2) and pk <10 order by c1;
select /*+no_rewrite*/ c1 from t1 a where a.c1 <= (select min(b.c1) from t1 b where a.c2 =b.c2) and pk <10 order by c1;

#mix column
select * from t1, (select avg(c1), c2+c3 as c from t1 group by c2+c3) v where t1.c2 + t1.c3 = v.c order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2+c3 as c from t1 group by c2+c3) v where t1.c2 + t1.c3 = v.c order by t1.pk;

select * from t1, (select avg(c1), c2+c3 as c from t1 group by c2+c3) v where t1.c3 + t1.c2 = v.c order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2+c3 as c from t1 group by c2+c3) v where t1.c3 + t1.c2 = v.c order by t1.pk;

select * from t1, (select avg(c1), c2+c3 as c, c2 from t1 group by c2+c3,c2) v where t1.c2 + t1.c3 = v.c and t1.c2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2+c3 as c, c2 from t1 group by c2+c3,c2) v where t1.c2 + t1.c3 = v.c and t1.c2 = v.c2 order by t1.pk;

#repeat table
## matched
select * from t1 a, t1 b, (select sum(c.c1), d.c1 from t1 c, t1 d group by d.c1) v where v.c1 = b.c1 order by a.pk,b.pk;
select /*+no_rewrite*/ * from t1 a, t1 b, (select sum(c.c1), d.c1 from t1 c, t1 d group by d.c1) v where v.c1 = b.c1 order by a.pk,b.pk;
## no match
select * from t1 a, t1 b, (select sum(c.c1), d.c1 from t1 c, t1 d group by d.c1) v where v.c1 = a.c1 order by a.pk,b.pk;
select /*+no_rewrite*/  * from t1 a, t1 b, (select sum(c.c1), d.c1 from t1 c, t1 d group by d.c1) v where v.c1 = a.c1 order by a.pk,b.pk;

#random test
select * from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg2 < t1.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c1 = v.c1 and v.agg > t1.c1 and v.agg2 < t1.c2 order by t1.pk;

select * from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg2 > v.c1 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg2 > v.c1 order by t1.pk;

#specail - select column does not in group by
select t1.c1, v.c1 from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg2 > t1.c2 order by t1.pk;
select  /*+no_rewrite*/ t1.c1, v.c1 from t1, (select sum(c1) agg, count(c1) agg2, c1, c2 from t1 group by c2) v where t1.c2 = v.c2 and v.agg2 > t1.c2 order by t1.pk;

#join condition reduction
select * from t1, t2, (select max(t2.c1), t2.c2 from t2 group by t2.c2) v where v.c2 = t1.c1 and t1.c1 = t2.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t2.c1), t2.c2 from t2 group by t2.c2) v where v.c2 = t1.c1 and t1.c1 = t2.c2 order by t1.pk,t2.pk;

select * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = 2 and 2 = v.c2 order by t1.pk;
select /*+no_rewrite*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = 2 and 2 = v.c2 order by t1.pk;

select * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c1 and t2.c1 = t2.c2 order by t1.pk,t2.pk;
select /*+no_rewrite*/ * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c1 and t2.c1 = t2.c2 order by t1.pk,t2.pk;

SELECT sum(l_extendedprice)/7.0 AS avg_yearly FROM lineitem, PART, (SELECT 0.2*avg(l_quantity) AS aggr, l_partkey FROM lineitem GROUP BY l_partkey) v WHERE p_partkey = lineitem.l_partkey AND p_partkey = v.l_partkey AND p_brand !='Brand#23' AND p_container = 'MED BOX' AND l_quantity < v.aggr; 
SELECT /*+no_rewrite*/ sum(l_extendedprice)/7.0 AS avg_yearly FROM lineitem, PART, (SELECT 0.2*avg(l_quantity) AS aggr, l_partkey FROM lineitem GROUP BY l_partkey) v WHERE p_partkey = lineitem.l_partkey AND p_partkey = v.l_partkey AND p_brand !='Brand#23' AND p_container = 'MED BOX' AND l_quantity < v.aggr; 

#test update
update t1, (select avg(c1) as agg, c2 from t1 group by c2) v set t1.c2 = v.agg where t1.c2 = v.c2;
update /*+no_rewrite*/ t1, (select avg(c1) as agg, c2 from t1 group by c2) v set t1.c2 = v.agg where t1.c2 = v.c2;

#test delete
delete a from t1 a, (select avg(c1) as agg, c2 from t1 group by c2) v  where a.c2 = v.c2 and a.c1 = v.agg;
delete /*+no_rewrite*/ a from t1 a, (select avg(c1) as agg, c2 from t1 group by c2) v  where a.c2 = v.c2 and a.c1 = v.agg;

#test normal
select * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v2.s;
select /*+no_rewrite*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v2.s;

select * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s, count(c1) c from t1) v2 order by v1.s,v2.s,v2.c;
select /*+no_rewrite*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s, count(c1) c from t1) v2 order by v1.s,v2.s,v2.c;

select * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1+c2) s, count(c1)+1 c from t1) v2 order by v1.s,v2.s,v2.c;
select /*+no_rewrite*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1+c2) s, count(c1)+1 c from t1) v2 order by v1.s,v2.s,v2.c;

select * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.s,v2.sm,v2.c;
select /*+no_rewrite*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.s,v2.sm,v2.c;

select * from (select sum(c1)+sum(c1+c2) ss ,c2 from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.ss,v1.c2,v2.sm,v2.c;
select /*+no_rewrite*/ * from (select sum(c1)+sum(c1+c2) ss ,c2 from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.ss,v1.c2,v2.sm,v2.c;

select * from (select sum(c1)+sum(c1+c2) ss,sum(c1+c2) s, c2 from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.ss,v1.s,v1.c2,v2.sm,v2.c;
select /*+no_rewrite*/ * from (select sum(c1)+sum(c1+c2) ss,sum(c1+c2) s, c2 from t1 group by c2) v1, (select sum(c1+c2)+max(c1) sm, count(c1)+1 c from t1) v2 order by v1.ss,v1.s,v1.c2,v2.sm,v2.c;

select * from (select count(c1) c from t1 group by c2) v1, (select count(c1) c from t1) v2 order by v1.c,v2.c;
select /*+no_rewrite*/ * from (select count(c1) c from t1 group by c2) v1, (select count(c1) c from t1) v2 order by v1.c,v2.c;

select * from (select sum(c1) s, c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v1.c2, v2.s;
select /*+no_rewrite*/ * from (select sum(c1) s, c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v1.c2, v2.s;

select * from (select sum(c1) s,c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s,v1.c2,v2.s;
select /*+no_rewrite*/ * from (select sum(c1) s,c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s,v1.c2,v2.s;

select * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s,v1.c2,v1.m, v2.s;
select /*+no_rewrite*/ * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s,v1.c2,v1.m, v2.s;

select * from (select sum(c1) m,c2,min(c1) mm from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 order by v1.m,v1.c2,v1.mm,v2.s,v2.m;
select /*+no_rewrite*/ * from (select sum(c1) m,c2,min(c1) mm from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 order by v1.m,v1.c2,v1.mm,v2.s,v2.m;

select * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 where v1.c2 <10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;
select /*+no_rewrite*/ * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 where v1.c2 <10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;

select * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 where v1.c2 >10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;
select /*+no_rewrite*/ * from (select sum(c1) s,c2,min(c1) m from t1 group by c2) v1, (select sum(c1) s,min(c1) m from t1) v2 where v1.c2 >10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;

select * from (select sum(c1) s,c2,min(c1) m from t1 where t1.c1 < 5 group by c2) v1, (select sum(c1) s,min(c1) m from t1 where t1.c1<5) v2 where v1.c2 <10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;
select /*+no_rewrite*/ * from (select sum(c1) s,c2,min(c1) m from t1 where t1.c1 < 5 group by c2) v1, (select sum(c1) s,min(c1) m from t1 where t1.c1<5) v2 where v1.c2 <10 order by v1.s,v1.c2,v1.m,v2.s,v2.m;

select * from (select sum(c1) s,c2,min(c1) m from t1 where t1.c1 < 5 group by c2) v1, (select sum(c1) s,min(c1) m from t1 where t1.c1<5) v2 where v1.c2 <10 and v2.m<v1.c2 order by v1.s,v1.c2,v1.m,v2.s,v2.m;
select /*+no_rewrite*/ * from (select sum(c1) s,c2,min(c1) m from t1 where t1.c1 < 5 group by c2) v1, (select sum(c1) s,min(c1) m from t1 where t1.c1<5) v2 where v1.c2 <10 and v2.m<v1.c2 order by v1.s,v1.c2,v1.m,v2.s,v2.m;

select * from (select avg(c1) a from t1 group by c2) v1, (select avg(c1) a from t1) v2 order by v1.a,v2.a;
select /*+no_rewrite*/ * from (select avg(c1) a from t1 group by c2) v1, (select avg(c1) a from t1) v2 order by v1.a,v2.a;

#test group by intersect
select * from (select sum(c1) s,c2 from t1 group by c1,c2) v1, (select sum(c1) s,c2 from t1 group by c2) v2 where v1.c2=v2.c2 order by v1.s,v1.c2,v2.s,v2.c2;
select /*+no_rewrite*/ * from (select sum(c1) s,c2 from t1 group by c1,c2) v1, (select sum(c1) s,c2 from t1 group by c2) v2 where v1.c2=v2.c2 order by v1.s,v1.c2,v2.s,v2.c2;

#reduction
select * from (select sum(c1) s,c2 from t1 group by c1,c2) v1, (select sum(c1) a,c2 from t1 group by c2) v2 where v1.c2=2 and v2.c2=2 order by v1.s,v1.c2,v2.a,v2.c2;
select /*+no_rewrite*/ * from (select sum(c1) s,c2 from t1 group by c1,c2) v1, (select sum(c1) a,c2 from t1 group by c2) v2 where v1.c2=2 and v2.c2=2 order by v1.s,v1.c2,v2.a,v2.c2;

#both matched
select * from t1,(select sum(c1) s,c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 where t1.c2 = v1.c2 order by v1.s,v1.c2,v2.s,t1.pk;
select /*+no_rewrite*/ * from t1,(select sum(c1) s,c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 where t1.c2 = v1.c2 order by v1.s,v1.c2,v2.s,t1.pk;

#no transform
select * from (select sum(c1) s from t1 group by c2) v, (select sum(c1) s,c2 from t1) v2 order by v.s,v2.s,v2.c2;

select * from (select sum(c1) s, c3 from t1 group by c2) v, (select sum(c1) s from t1) v2 order by v.s,v.c3,v2.s;

select * from (select sum(c1) s,c2 from t1 group by c1,c2) v, (select sum(c1) s,c2 from t1 group by c2) v2 order by v.s,v.c2,v2.s,v2.c2;

#join push down
select * from t1, (select sum(c1) s, c2 from t1 group by c2) v, t3 where t1.c2 = v.c2 and t3.pk = v.c2 and t3.pk >10 order by t1.pk,v.c2,t3.pk,v.s;

