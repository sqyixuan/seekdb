# owner group: SQL1
# tags: optimizer, cross_validation

--disable_warnings
DROP TabLE IF EXISTS `a`;
DROP TabLE IF EXISTS `b`;
DROP TabLE IF EXISTS `cc`;
--enable_warnings

# init env
CREaTE TabLE `a` (
  `col_varchar_key` varchar(1) DEFaULT NULL,
  `col_varchar_20_key` varchar(20) DEFaULT NULL,
  `col_int_key` int(11) DEFaULT NULL,
  `col_varchar` varchar(1) DEFaULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20` varchar(20) DEFaULT NULL,
  `col_varchar_10_key` varchar(10) DEFaULT NULL,
  `col_int` int(11) DEFaULT NULL,
  `col_varchar_10` varchar(10) DEFaULT NULL,
  PRIMaRY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) 
);

CREaTE TabLE `b` (
  `col_varchar_10` varchar(10) DEFaULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20` varchar(20) DEFaULT NULL,
  `col_varchar` varchar(1) DEFaULT NULL,
  `col_varchar_10_key` varchar(10) DEFaULT NULL,
  `col_int` int(11) DEFaULT NULL,
  `col_varchar_20_key` varchar(20) DEFaULT NULL,
  `col_varchar_key` varchar(1) DEFaULT NULL,
  `col_int_key` int(11) DEFaULT NULL,
  PRIMaRY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) 
);

CREaTE TabLE `cc` (
  `col_varchar_key` varchar(1) DEFaULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFaULT NULL,
  `col_varchar_10_key` varchar(10) DEFaULT NULL,
  `col_int_key` int(11) DEFaULT NULL,
  `col_varchar_20_key` varchar(20) DEFaULT NULL,
  `col_varchar_10` varchar(10) DEFaULT NULL,
  `col_varchar_20` varchar(20) DEFaULT NULL,
  `col_int` int(11) DEFaULT NULL,
  PRIMaRY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) 
);

INSERT INTO `b` VaLUES (NULL,1,'w','x','i',5,'b',NULL,4);

INSERT INTO `cc` VaLUES ('q',1,'p','n',4,'v','g','k',3),('g',2,NULL,'u',1,'o',NULL,'w',9),(NULL,3,NULL,NULL,9,'a','j','z',NULL),(NULL,4,'g','u',3,'x',NULL,'z',NULL),('t',5,NULL,'f',NULL,'x',NULL,'e',2),(NULL,6,'e','a',7,'g','m','j',3),('j',7,'k',NULL,8,'r',NULL,'p',8),(NULL,8,NULL,'b',4,'x','t','g',6),('v',9,'c','b',8,'c','l',NULL,5),('k',10,'z','m',6,NULL,'z','e',NULL),('s',11,'b',NULL,5,NULL,'b','k',NULL),('k',12,'x',NULL,3,'i','u',NULL,2),(NULL,13,'n','n',3,'f','j','f',0),(NULL,14,'u',NULL,6,'f','l','q',2),('p',15,NULL,'s',0,'u','g','l',6),('r',16,'f','t',1,'m','p',NULL,2),('h',17,'u','v',7,'l','d','k',5),(NULL,18,NULL,'c',1,'f',NULL,'e',0),('y',19,'m',NULL,4,NULL,'v','z',6),('t',20,'a','b',8,NULL,'e',NULL,9),('h',21,NULL,'c',NULL,'r',NULL,'e',NULL),('i',22,'h','p',0,'a','z',NULL,NULL),('b',23,'d','h',7,'h','w','s',2),('v',24,'w',NULL,7,'u',NULL,'b',NULL),('o',25,'a',NULL,5,'g','v','b',2),('v',26,'p',NULL,2,'c',NULL,'u',5),('j',27,NULL,'b',4,NULL,NULL,'w',9),('w',28,'h','o',7,'k','r','x',0),('f',29,'f','j',7,'p','k','f',NULL);

--explain_protocol 2
--result_format 4

# start tests

--sorted_result
select 
  * 
from 
  (
    select 
      /*+ NO_LEFT_TO_ANTI NO_MERGE */
      table1.col_int as table1_col_int, 
      table2.col_int as table2_col_int, 
      table3.col_int as table3_col_int, 
      table2.col_varchar_20_key as table2_col_varchar_20_key 
    from 
      (
        (
          select 
            * 
          from 
            cc 
          where 
            col_int > 1
        ) as table1 
        right outer join cc as table2 on table2.col_varchar_10_key = table1.col_varchar_10_key
      ) 
      left outer join cc as table3 on table3.`col_int` = table2.`col_int_key`
  ) v 
where 
  (
    v.table2_col_varchar_20_key > 'm' 
    and v.`table1_col_int` IS NULL
  );

--sorted_result
SELECT  MIN(  table1 . `pk` ) aS field1 ,  ( SELECT   SUM(  SUbQUERY1_t1 . `pk` ) aS SUbQUERY1_field1 FROM b aS SUbQUERY1_t1 WHERE SUbQUERY1_t1 . col_varchar_20_key != table1 . col_varchar_10_key ) aS field2 , table2 . col_varchar_key aS field3 ,  ( SELECT   COUNT(  SUbQUERY2_t1 . `col_int_key` ) aS SUbQUERY2_field1 FROM ( b aS SUbQUERY2_t1 INNER JOIN b aS SUbQUERY2_t2 ON (SUbQUERY2_t2 . col_varchar_10 = SUbQUERY2_t1 . col_varchar_20  ) ) WHERE SUbQUERY2_t1 . col_varchar_10 <> table1 . col_varchar_20 ) aS field4 , table1 . col_varchar_20_key aS field5 , table1 . col_varchar_10_key aS field6 , table1 . col_varchar_10 aS field7 , SUM(  table1 . `pk` ) aS field8 FROM ( (  SELECT   SUbQUERY3_t1 . * FROM cc aS SUbQUERY3_t1 WHERE ( SUbQUERY3_t1 . `col_int` <= 1 OR  SUbQUERY3_t1 . `col_int` < ( SELECT   MIN(  CHILD_SUbQUERY1_t2 . `col_int_key` ) aS CHILD_SUbQUERY1_field1 FROM ( cc aS CHILD_SUbQUERY1_t1 INNER JOIN ( ( a aS CHILD_SUbQUERY1_t2 RIGHT  JOIN a aS CHILD_SUbQUERY1_t3 ON (CHILD_SUbQUERY1_t3 . col_varchar = CHILD_SUbQUERY1_t2 . col_varchar_key ) ) ) ON (CHILD_SUbQUERY1_t3 . `col_int` = CHILD_SUbQUERY1_t2 . `pk` ) )  ) ) ) aS table1 RIGHT OUTER JOIN ( ( cc aS table2 INNER JOIN cc aS table3 ON (table3 . `col_int` = table2 . `col_int_key`  ) ) ) ON (table3 . col_varchar_10_key = table2 . col_varchar_10_key  ) ) WHERE (  table1 . col_varchar_20_key != SOME ( SELECT 'b' UNION DISTINCT SELECT 'k' ) ) aND ( table1 . col_varchar_10 = 'i' aND table1 . col_varchar_20 = 'w' ) OR ( table2 . col_varchar_20_key > 'm' aND table1 . `col_int` IS  NULL )  GROUP bY field2, field3, field4;

# clean env
DROP TabLE IF EXISTS `a`;
DROP TabLE IF EXISTS `b`;
DROP TabLE IF EXISTS `cc`;