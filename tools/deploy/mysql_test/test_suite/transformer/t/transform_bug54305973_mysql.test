CREATE TABLE `cool_deal_record_201810` (
  `deal_record_id` int(11) NOT NULL AUTO_INCREMENT,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(50) DEFAULT NULL,
  `pay_type` varchar(10) DEFAULT NULL,
  `pay_pass` varchar(10) NOT NULL DEFAULT '010',
  `money` varchar(100) DEFAULT NULL,
  `regtime` varchar(20) DEFAULT NULL,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `openpl_secret_id` varchar(100) DEFAULT NULL,
  `order_type` int(2) DEFAULT NULL ,
  `status` int(11) DEFAULT '0' ,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `body` varchar(255) DEFAULT NULL ,
  PRIMARY KEY (`deal_record_id`),
  UNIQUE KEY `uiq_out_trade_id` (`out_trade_id`),
  UNIQUE KEY `business_trade_id` (`business_id`,`from_business_trade_id`),
  KEY `origin_trade_no` (`from_business_trade_id`),
  KEY `pay_log_id` (`pay_log_id`)
) ENGINE=InnoDB AUTO_INCREMENT=320914 DEFAULT CHARSET=utf8 ;

create table if not exists `t1d2kshw` (
	`c1` binary(1),
	`c2` binary(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

create table if not exists `gp_refund_info_00` (
	`refund_info_no` varchar(64) not null,
	`tx_id` varchar(128) not null,
	`service_target` varchar(64) not null,
	`refund_id` varchar(128) not null,
	`service_type` varchar(8) not null,
	`refund_service_amount` decimal(20,4),
	`refund_amount` decimal(15,4),
	`refund_account` varchar(20),
	`extra_info` varchar(100),
	`real_amount` decimal(15,4),
	`memo` varchar(100),
	`gmt_create` timestamp(6) not null,
	`gmt_modified` timestamp(6) not null,
	`trans_log_id` decimal(15,0),
	`trans_date` timestamp(6),
	`bill_no` varchar(64),
	primary key (`refund_info_no`),
	unique key (`bill_no`) 
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `idx_txid_service_target_type` on `gp_refund_info_00` (`tx_id` ASC, `service_target` ASC, `service_type` ASC) ;

CREATE TABLE `utf16_test` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL,
  PRIMARY KEY (`name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf16;

CREATE TABLE `cool_device_data` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `device_id` int(11) DEFAULT NULL ,
  `business_id` int(11) DEFAULT NULL ,
  `door_id` int(11) DEFAULT NULL ,
  `bind_flag_no` int(11) DEFAULT NULL ,
  `device_no` varchar(255) DEFAULT NULL ,
  `pay_count` int(11) DEFAULT '0' ,
  `refund_count` int(11) DEFAULT NULL ,
  `date` int(11) DEFAULT NULL ,
  PRIMARY KEY (`id`),
  UNIQUE KEY `bind_no_date` (`bind_flag_no`,`date`)
) ENGINE=InnoDB AUTO_INCREMENT=12448 DEFAULT CHARSET=utf8 ;

CREATE TABLE `cool_bill_20180916` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;


CREATE TABLE `t_kms_role_info` (
  `roleId` int(11) NOT NULL AUTO_INCREMENT,
  `roleName` varchar(255) DEFAULT NULL COMMENT '角色名称',
  `updateTime` datetime DEFAULT NULL COMMENT '更新时间',
  PRIMARY KEY (`roleId`)
) ENGINE=InnoDB AUTO_INCREMENT=16 DEFAULT CHARSET=utf8;

CREATE TABLE `cool_risk_info_record` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `business_id` int(11) DEFAULT NULL ,
  `riskinfo_personal_code` varchar(15) DEFAULT NULL ,
  `riskinfo_merchant_code` varchar(15) DEFAULT NULL ,
  `risktype_person` varchar(5) DEFAULT NULL ,
  `risktype_merchant` varchar(5) DEFAULT NULL ,
  `regtime` int(11) DEFAULT NULL ,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=500 DEFAULT CHARSET=utf8 ;


CREATE TABLE `cool_crontime` (
  `crontime_id` int(11) NOT NULL AUTO_INCREMENT,
  `type` varchar(100) DEFAULT NULL,
  `date` varchar(50) DEFAULT NULL,
  `crondate` varchar(50) DEFAULT NULL,
  `pay_pass` varchar(11) DEFAULT NULL ,
  `status` varchar(10) DEFAULT NULL ,
  `end_time` int(11) DEFAULT NULL ,
  PRIMARY KEY (`crontime_id`)
) ENGINE=InnoDB AUTO_INCREMENT=13516 DEFAULT CHARSET=utf8;


CREATE TABLE `cool_table_roles_fields` (
  `fields_id` int(11) NOT NULL AUTO_INCREMENT,
  `fields` varchar(100) DEFAULT NULL,
  `tableroles_id` int(10) DEFAULT NULL,
  PRIMARY KEY (`fields_id`)
) ENGINE=InnoDB AUTO_INCREMENT=250 DEFAULT CHARSET=utf8;

