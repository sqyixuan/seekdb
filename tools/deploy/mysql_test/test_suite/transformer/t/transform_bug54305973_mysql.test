CREATE TABLE `cool_wean_record` (
  `Id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `business_id` int(11) unsigned DEFAULT NULL,
  `equipment_alignment_num` varchar(255) DEFAULT NULL,
  `wean_time` varchar(255) DEFAULT NULL,
  PRIMARY KEY (`Id`)
) ENGINE=InnoDB AUTO_INCREMENT=9 DEFAULT CHARSET=utf8;

CREATE TABLE `t_sys_cmd` (
  `cmdID` int(20) NOT NULL AUTO_INCREMENT,
  `cmdName` char(200) DEFAULT NULL COMMENT '命令名称',
  `cmdDisplayName` char(50) DEFAULT NULL COMMENT '命令展示名称',
  `cmdCategoryID` int(20) DEFAULT NULL COMMENT '命令分类ID',
  PRIMARY KEY (`cmdID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='命令表';

CREATE TABLE `cool_deal_201810` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `body` varchar(255) DEFAULT '' ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=4007298 DEFAULT CHARSET=utf8;

CREATE TABLE `cool_deal` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `trade_body` varchar(255) DEFAULT NULL ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=4121280 DEFAULT CHARSET=utf8;

--explain_protocol 1
--result_format 4

select   (select business_id from test.cool_deal_record_201810 limit 1 offset 4)  as c0,  subq_0.c3 as c1,  subq_0.c2 as c2,  case when subq_0.c5 & subq_0.c5 then case when subq_0.c5 <> subq_0.c5 then subq_0.c4 else  subq_0.c4 end  else subq_0.c4 end  as c3,  subq_0.c4 as c4,  subq_0.c5 as c5,  case when subq_0.c5 is not NULL then subq_0.c4 else subq_0.c4 end  as c6,  case when  sum( cast((select c3 from test.t1d2kshw limit  1 offset 5)  as DECIMAL)) over (partition by subq_0.c3 order by subq_0.c0,subq_0.c2) >> subq_0.c5 then case when subq_0.c5 - subq_0.c5 then (select refund_amount from test.gp_refund_info_00 limit 1 offset 5)   else cast(null as DECIMAL(10, 2)) end  else (select sex from test.utf16_test limit 1 offset 3)  end  as c7,  subq_0.c3 as c8,  subq_0.c4 as c9 from  (select   ref_3.risktype_merchant as c0,   ref_3.riskinfo_personal_code as c1,  ref_3.riskinfo_personal_code as c2,  ref_0.qd_fr_fee as c3,  ref_1.updateTime as c4,  case when (ref_3.business_id <= ref_3.id)  and (ref_0.bill_id << ref_3.id) then  ref_1.roleId else (select id from test.cool_device_data limit 1 offset 3)  end  as c5 from  ((test.cool_bill_20180916 as ref_0 left join test.t_kms_role_info as ref_1 on ((EXISTS ( select   ref_1.roleId as c0,   ref_2.offer_type as c1,  ref_1.roleName as c2,  ref_1.roleId as c3,  ref_1.roleId as c4,  ref_0.refund_money as c5,  ref_1.roleName as c6 from  test.cool_deal as ref_2 where (ref_2.is_read <= ref_2.is_read)   or (ref_2.deal_id < ref_2.status)))  or (1))) right join test.cool_risk_info_record as ref_3 on (ref_0.bill_id <= (select crontime_id from test.cool_crontime limit 1 offset 2) )) where (EXISTS ( select    ref_3.risktype_person as c0,  ref_0.refund_type as c1,  ref_1.roleName as c2,  ref_1.roleId as c3,  ref_0.business_id as c4 from  test.cool_table_roles_fields as ref_4 where (select avg(bill_id) from test.cool_bill_20180906)   - ref_0.bill_id limit 77))  or (((EXISTS ( select   ref_5.business_id as c0,  ref_0.refund_status as c1,  ref_1.roleId as c2 from  test.cool_wean_record as ref_5 where ref_0.channel_id << ref_3.id))   and (ref_1.updateTime is not NULL))  or (ref_1.roleName is NULL)) limit 104) as subq_0 where EXISTS ( select   subq_0.c4 as c0,  case when subq_0.c2 is NULL then ref_6.body else ref_6.remark_two_value end  as c1,   (select cmdDisplayName from test.t_sys_cmd limit 1 offset 97)  as c2,  ref_6.business_id as c3,  subq_0.c4 as c4,  ref_6.business_id as c5,  subq_0.c2 as c6 from  test.cool_deal_201810 as ref_6 where ref_6.deal_id  OR ref_6.order_regtime) limit 130  for update;

