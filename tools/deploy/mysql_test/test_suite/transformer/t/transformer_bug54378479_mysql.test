--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create index idx_t1 on t1(c1,c2);

explain select * from t1 where (c1,c2) > (1,2) and (c1,c2) < (2,4);
explain select * from t1 where (c1,c2) > (1,2) and (c1,c2) < (2,4) and c1=1;
explain select * from t1 where (c1,c2) > (1,2) and (c1,c2) < (2,4) and c2=1;
explain select t1.c1 from t1, (select 1 as c1 from dual) as v1 where (t1.c1, t1.c2) > (1, v1.c1);
explain select t1.c1 from t1, (select 1 as c1 from dual) as v1 where (t1.c1, t1.c2) > (v1.c1, 1);
explain select t1.c1 from t1, (select 1 as c1 from dual) as v1 where (t1.c1, t1.c2) > (v1.c1, v1.c1+1);
drop table t1;