SELECT  1.95 FROM table1_int  GROUP BY ( SELECT  @@ob_trx_timeout AS 'dqbnnarr' FROM table1_hash_pk_parts_1_bigint WHERE  1.95 ) ASC , @@ob_query_timeout DESC , 1.95 DESC , 0x2F DESC , NULL ASC  UNION  ( ( ( SELECT  1.95 <= 10.2345 != '2015-01-01 00:00:00.000001' OR ( 1.95 ) NOT LIKE NULL && 10 BETWEEN 99999 AND POWER( CONV( 8, 7, 7 ), CONV( 119, 3, 3 ) ) AS c2 FROM DUAL WHERE  @@max_allowed_packet ORDER BY @@autocommit DESC  ) ORDER BY -9223372036854775808 ASC  ) ORDER BY ( 99999 ) LIKE 1.95 DESC  )  LIMIT 99 , 2089943040;

drop table table1_int;