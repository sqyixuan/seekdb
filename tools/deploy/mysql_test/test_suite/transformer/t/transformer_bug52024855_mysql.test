#owner: sean.yyj
#owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int zerofill, c2 int);
insert into t1 values(1,2);

--result_format 4
--explain_protocol 2

select concat(c1, 'a'), concat(c2, 'a') from t1;
select concat(c1, 'a'), concat(c2, 'a') from t1 where c1 = 1 and c2 = 2;
select concat(c1, 'a'), concat(c2, 'a') from t1 where c1 = c2 - 1 and c2 = 2;
select concat(c1, 'a'), concat(c2, 'a') from t1 where c1 = 1 and c2 = c1 + 1;

drop table t1;
