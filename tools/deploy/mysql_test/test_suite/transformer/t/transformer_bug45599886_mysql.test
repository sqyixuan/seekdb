# description: c

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);

select * from t1 where (select count(*) from t2 left join t3 on t1.c1) >100;

select 0 from dual where EXISTS (select 1 from t1 as ref_1 where EXISTS (select 2 from (t2 as ref_2 right join t3 as ref_3 on (EXISTS (select ref_1.c1 as c0 from dual)))));

drop table t1, t2, t3;
