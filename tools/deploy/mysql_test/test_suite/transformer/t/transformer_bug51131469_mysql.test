# owner group: SQL1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists chat_list;
drop table if exists chat_bot_base;
drop table if exists chat_req_records;
--enable_warnings

CREATE TABLE `chat_list` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '非业务主键',
  `uid` bigint(20) DEFAULT NULL,
  `title` varchar(255) DEFAULT NULL COMMENT '聊天列表主题',
  `is_delete` tinyint(2) DEFAULT '0' COMMENT '是否删除,0不删除，1删除',
  `enable` tinyint(2) DEFAULT '1' COMMENT '1可用，0不可用',
  `bot_id` int(11) DEFAULT '0',
  `sticky` tinyint(2) NOT NULL DEFAULT '0' COMMENT '置顶',
  `create_time` datetime DEFAULT NULL COMMENT '创建时间',
  `update_time` datetime DEFAULT NULL COMMENT '修改时间',
  `is_model` tinyint(1) NOT NULL DEFAULT '0' COMMENT '是否是多模态 1是',
  `enabled_plugin_ids` varchar(255) DEFAULT '' COMMENT '当前对话列表启用的插件ids',
  PRIMARY KEY (`id`),
  KEY `uid_index` (`uid`) BLOCK_SIZE 16384 LOCAL,
  KEY `chat_list_create_time_IDX` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_bot_id` (`bot_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_uid_bid_ctime` (`uid`, `bot_id`, `create_time`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 10736905 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `chat_bot_base` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'bot_id',
  `uid` bigint(20) DEFAULT NULL,
  `bot_name` varchar(48) DEFAULT NULL COMMENT 'bot名称',
  `bot_type` tinyint(2) DEFAULT NULL COMMENT 'bot类型，自定义助手，1，生活助手， 2 ，职场助手，3，营销助理， 4，写作达人，5，知识百晓生，6。',
  `avatar` varchar(255) DEFAULT NULL COMMENT 'bot头像url',
  `prompt` varchar(2048) DEFAULT NULL COMMENT 'bot_prompt',
  `bot_desc` varchar(255) DEFAULT NULL COMMENT 'bot描述',
  `is_delete` tinyint(2) DEFAULT '0' COMMENT '是否删除，1删除',
  `create_time` datetime DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP,
  `update_time` datetime DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP,
  `support_context` tinyint(1) NOT NULL DEFAULT '0' COMMENT '是否支持多轮对话 1支持 0 不支持',
  PRIMARY KEY (`id`),
  KEY `idx_create_time` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_create_time1` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_support_context` (`support_context`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_uid` (`uid`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 8201 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '用户创建助手表';


CREATE TABLE `chat_req_records` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `chat_id` bigint(20) NOT NULL,
  `uid` bigint(20) DEFAULT NULL,
  `message` varchar(8000) DEFAULT NULL COMMENT '提问内容',
  `client_type` tinyint(3) DEFAULT '0' COMMENT '用户提问时的客户端类型 0:未知 1:PC 2:H5 主要用于统计',
  `model_id` int(11) DEFAULT NULL COMMENT '多模态关联ID',
  `create_time` datetime NOT NULL COMMENT '创建时间',
  `update_time` datetime DEFAULT NULL,
  `date_stamp` int(11) DEFAULT NULL COMMENT 'cmp_core.BigdataServicesMonitorDaily',
  `new_context` tinyint(1) NOT NULL DEFAULT '1' COMMENT 'bot新的上下文 1是 0否',
  PRIMARY KEY (`id`, `create_time`),
  KEY `idx_chat_id` (`chat_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_create_time` (`create_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_date_stamp` (`date_stamp`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_uid_chatId` (`uid`, `chat_id`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 49617218 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(`create_time`)
(
partition p20230710 values less than ('2023-07-10 00:00:00'),
partition p20230717 values less than ('2023-07-17 00:00:00'),
partition p20230724 values less than ('2023-07-24 00:00:00'),
partition p20230731 values less than ('2023-07-31 00:00:00'),
partition p_max values less than (MAXVALUE));

--result_format 4
--explain_protocol 2

SELECT req_id,uid,chatid,SUBSTR(replace(replace(replace(replace(realquestion,'“',' '),'”',' '),'?',' '),'\"',' ') from 1 for 200) as question,client_type,create_time
        FROM
        (
          SELECT crr.id as req_id,
          crr.uid,crr.chat_id as chatid,
          REPLACE(REPLACE(REPLACE(message,'\t',' '),'\r',''),'\n','') as question,crr.client_type,crr.create_time,
          if(cl.bot_id > 0,cl.bot_id,null) as botid,
          if(cl.bot_id > 0,cbb.prompt,null) as prompt,
          REPLACE(REPLACE(REPLACE(if(cl.bot_id > 0,REPLACE(cbb.prompt,'{{}}',message),message),'\t',' '),'\r',''),'\n','') as realquestion,
          cast(RAND()*50 as signed) as therand
          FROM chat_req_records crr
          left JOIN chat_list cl on crr.chat_id = cl.id
          left join chat_bot_base cbb on cl.bot_id = cbb.id
          WHERE crr.create_time >= '2023-07-23 00:00:00' and crr.create_time < '2023-07-24 00:00:01'
        ) t
        where therand = 3
        limit 300
        ;

drop table if exists chat_list;
drop table if exists chat_bot_base;
drop table if exists chat_req_records;