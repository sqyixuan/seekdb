--disable_query_log
--disable_result_log
--explain_protocol 0
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1(c1 int primary key, c2 int, c3 number, c4 int, c5 int, c6 int as (c2+1) virtual, c7 int as (nvl(c3, 2)) virtual, c8 int as ((nvl(c2, 2) + c3)) virtual, c9 int as (c2 + c2) virtual, c10 int as (c1+c3+c4*c5) virtual);
create index i1 on t1(c2, c3);
create index i2 on t1(c3, c4);
create index i3 on t1(c4, c5);
create index i4 on t1(c6, c2);
create index i5 on t1(c7, c1);
create index i6 on t1(c8, c9);
create index i7 on t1(c9, c4);
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(2,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(3,null,null,null,null);
insert into t1(c1,c2,c3,c4,c5) values(4,1,null,null,null);
insert into t1(c1,c2,c3,c4,c5) values(5,null,1,null,null);
insert into t1(c1,c2,c3,c4,c5) values(6,null,null,1,null);
insert into t1(c1,c2,c3,c4,c5) values(7,null,null,null,1);
analyze table t1;

--enable_query_log
--enable_result_log
--explain_protocol 2
select /*+use_late_materialization*/ * from t1 where c2 > 0 order by c3 limit 10;
select /*+use_late_materialization*/ * from t1 where c3 > 0 order by c4 limit 10;
select /*+use_late_materialization*/ * from t1 where c4 > 0 order by c5 limit 10;
select /*+use_late_materialization*/ * from t1 where c6 > 0 order by c2 limit 10;
select /*+use_late_materialization*/ * from t1 where c7 > 0 order by c1 limit 10;
select /*+use_late_materialization*/ * from t1 where c8 > 0 order by c9 limit 10;
select /*+use_late_materialization*/ * from t1 where c9 > 0 order by c4 limit 10;
select /*+use_late_materialization*/ c6,c7,c8,c9 from t1 where c2 > 0 order by c3 limit 10;

--disable_query_log
--disable_result_log
--explain_protocol 0
drop table t1;

CREATE TABLE t1(c1 int primary key, c2 int, c3 number, c4 int, c5 int, c6 int as (c2+1) stored, c7 int as (nvl(c3, 2)) stored, c8 int as ((nvl(c2, 2) + c3)) stored, c9 int as (c2 + c2) stored, c10 int as (c1+c3+c4*c5) stored);
create index i1 on t1(c2, c3);
create index i2 on t1(c3, c4);
create index i3 on t1(c4, c5);
create index i4 on t1(c6, c2);
create index i5 on t1(c7, c1);
create index i6 on t1(c8, c9);
create index i7 on t1(c9, c4);
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(2,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(3,null,null,null,null);
insert into t1(c1,c2,c3,c4,c5) values(4,1,null,null,null);
insert into t1(c1,c2,c3,c4,c5) values(5,null,1,null,null);
insert into t1(c1,c2,c3,c4,c5) values(6,null,null,1,null);
insert into t1(c1,c2,c3,c4,c5) values(7,null,null,null,1);
analyze table t1;
--enable_query_log
--enable_result_log
--explain_protocol 2

select /*+use_late_materialization*/ * from t1 where c2 > 0 order by c3 limit 10;
select /*+use_late_materialization*/ * from t1 where c3 > 0 order by c4 limit 10;
select /*+use_late_materialization*/ * from t1 where c4 > 0 order by c5 limit 10;
select /*+use_late_materialization*/ * from t1 where c6 > 0 order by c2 limit 10;
select /*+use_late_materialization*/ * from t1 where c7 > 0 order by c1 limit 10;
select /*+use_late_materialization*/ * from t1 where c8 > 0 order by c9 limit 10;
select /*+use_late_materialization*/ * from t1 where c9 > 0 order by c4 limit 10;
select /*+use_late_materialization*/ c6,c7,c8,c9 from t1 where c2 > 0 order by c3 limit 10;

drop table t1;

--disable_query_log
--disable_result_log
create table t1(c1 int primary key, c2 int, g geometry not null srid 0) partition by range(c1) ( partition p0 values less than (4),
                partition p1 values less than (10));
create spatial index idx on t1 (g) local;
insert into t1 (c1, c2, g) values (0, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (1, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (2, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (3, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (4, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (5, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (6, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (7, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (8, 10, st_geomfromtext('point(1 1)'));
insert into t1 (c1, c2, g) values (9, 10, st_geomfromtext('point(2 1)'));
analyze table t1;
--enable_query_log
--enable_result_log

# bad case
select /*+enable_parallel_dml parallel(2) use_late_materialization*/ * from t1 where st_intersects(g, st_geomfromtext('point(2 1)'));

drop table t1;