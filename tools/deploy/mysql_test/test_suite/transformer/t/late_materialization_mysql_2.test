#owner: zhuangyifeng.zyf
#owner group: sql1
# tags: optimizer
--disable_query_log
--disable_result_log
set @@session.explicit_defaults_for_timestamp=off;
# --source mysql_test/include/index_quick_major.inc

--disable_warnings
drop table if exists t1;
create table t1(pk int primary key, c1 int, c2 int, c3 int, c4 text, c5 int as (c2 + c3) virtual);
create index idx1 on t1 (c1, c2);
create index idx2 on t1 ((c1 + 3), c2);
create index idx3 on t1 (c5, c2);
set cte_max_recursion_depth=100000;
insert into t1(pk, c1, c2, c3, c4) select * from (with RECURSIVE cte(a,b,c,d,e) as (select 1,1,1,1,repeat(1, 1024) union all select a+1,b+1,c+1,d+1,repeat(a, 1024) from cte where a < 5000) select * from cte);
insert into t1(pk, c1, c2, c3, c4) select * from (with RECURSIVE cte(a,b,c,d,e) as (select 5001,1,1,1,repeat(1, 1024) union all select a+1,b+1,c-1,d+1,repeat(a, 1024) from cte where a < 10000) select * from cte);
call dbms_stats.gather_table_stats(NULL, 'T1');

--enable_query_log
--enable_result_log
--enable_warnings
--result_format 4
--explain_protocol 2
# without hint
select * from t1 where c1 < 5000 and c1 > 4980 order by c1, c2 limit 10;
select * from t1 where c1 < 5000 and c1 > 4980 order by c1 desc, c2 desc limit 10;
select * from t1 where c1 < 5000 and c1 > 4980 order by c1 asc, c2 desc limit 10;

--echo normal
select /*+use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 < 5000 and c1 > 4980 order by c1, c2 limit 10;
select /*+use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 < 5000 and c1 > 4980 order by c1 desc, c2 desc limit 10;
select /*+use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 < 5000 and c1 > 4980 order by c1 asc, c2 desc limit 10;

--echo functional index and index hint check
select /*+index(t1 idx1), use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 + 3 < 5000 and c1 + 3 > 4980 order by c2 limit 10;
select /*+index(t1 idx2), use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 + 3 < 5000 and c1 + 3 > 4980 order by c2 limit 10;
select /*+no_index(t1 idx1), use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 + 3 < 5000 and c1 + 3 > 4980 order by c2 limit 10;
select /*+no_index(t1 idx2), use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c1 + 3 < 5000 and c1 + 3 > 4980 order by c2 limit 10;

--echo generated column
select /*+index(t1 idx3), use_late_materialization*/pk, c1, c2, c3, c5 from t1 where c5 < 5000 and c5 > 4980 order by c2 limit 10;

select /*+no_index(t1 idx1), use_late_materialization*/pk, c4 from t1 where c1 < 5000 and c1 > 4980 order by c1, c2 limit 10;
select /*+no_index(t1 idx1), use_late_materialization*/pk, c4 from t1 where c1 < 5000 and c1 > 4980 order by c1 desc, c2 desc limit 10;
select /*+no_index(t1 idx1), use_late_materialization*/pk, c4 from t1 where c1 < 5000 and c1 > 4980 order by c1 asc, c2 desc limit 10;

--echo large column, 即使不走索引也晚期物化
select /*+use_late_materialization*/* from t1 where c3 < 5000 and c3 > 4980 order by c1, c2 limit 10;
select /*+use_late_materialization*/* from t1 where c1 < 5000 and c3 > 4980 order by c1, c2 limit 10;
select /*+use_late_materialization*/* from t1 where c1 < 5000 and c1 > 4980 order by c1, c3 limit 10;

--echo normal 走不了晚期物化
select * from t1 where c1 < 5000 and c1 > 4980 order by c1, c2;
select * from t1 where c1 < 5000 and c1 > 4980 limit 10;
select * from t1 where c1 = 5000 and c4 like '4%';

select /*+use_late_materialization*/ * from t1 where c1 < 5000 and c1 > 4980 order by c1, c2;
select /*+use_late_materialization*/ * from t1 where c1 < 5000 and c1 > 4980 limit 10;
select /*+use_late_materialization*/ * from t1 where c1 = 5000 and c4 like '4%';

--disable_query_log
--disable_result_log
--explain_protocol 0
drop table t1;

--disable_warnings
--explain_protocol 0
drop table if exists iw_account_log_00;
CREATE TABLE `iw_account_log_00` (
  `iw_account_log_id` bigint(15) NOT NULL,
  `trans_log_id` bigint(15) NOT NULL,
  `trans_date` char(8) NOT NULL,
  `out_date` char(8) NOT NULL,
  `trans_dt` timestamp(6) NOT NULL,
  `trans_code` char(4) NOT NULL,
  `trans_amount` bigint(15) NOT NULL,
  `balance` bigint(15) NOT NULL,
  `trans_currency` char(3) NOT NULL DEFAULT '156',
  `account_type` bigint(2) NOT NULL,
  `trans_account` varchar(20) NOT NULL,
  `other_account_type` bigint(2) NOT NULL,
  `other_account` varchar(25) DEFAULT NULL,
  `trans_institution` varchar(10) DEFAULT NULL,
  `trans_out_order_no` varchar(128) DEFAULT NULL,
  `bank_name` varchar(100) DEFAULT NULL,
  `trans_memo` varchar(256) DEFAULT NULL,
  `sub_trans_code` varchar(6) DEFAULT NULL,
  `out_biz_no` varchar(128) DEFAULT NULL,
  `model` bigint(2) DEFAULT NULL,
  `suite_id` varchar(64) DEFAULT NULL,
  `is_write_off` char(1) DEFAULT NULL,
  `is_red` char(1) DEFAULT NULL,
  `other_account_log` bigint(15) DEFAULT NULL,
  `delete_flag` char(1) DEFAULT NULL,
  `voucher_id` varchar(32) DEFAULT NULL,
  `orgi_voucher_id` varchar(32) DEFAULT NULL,
  `trans_operator` varchar(8) DEFAULT NULL,
  `inst_channel_api` varchar(32) DEFAULT NULL,
  `gmt_create` timestamp(6) NULL DEFAULT NULL,
  `gmt_modified` timestamp(6) NULL DEFAULT NULL,
  `inst_id` varchar(32) DEFAULT NULL,
  `biz_trans_uniq` varchar(128) DEFAULT NULL,
  `end_to_end_id` varchar(128) DEFAULT NULL,
  `other_display_info` varchar(64) DEFAULT NULL,
  `biz_pd_code` varchar(21) DEFAULT NULL,
  `biz_ev_code` varchar(8) DEFAULT NULL,
  `cnl_pd_code` varchar(21) DEFAULT NULL,
  `cnl_ev_code` varchar(8) DEFAULT NULL,
  `cnl_no` varchar(64) DEFAULT NULL,
  `pd_code` varchar(21) DEFAULT NULL,
  `ev_code` varchar(8) DEFAULT NULL,
  `asset_code` varchar(32) DEFAULT NULL,
  `csu_tx_id` varchar(36) DEFAULT '-1',
  PRIMARY KEY (`iw_account_log_id`, `trans_dt`),
  KEY `iw_account_log_tatd_ind` (`trans_account`, `trans_dt`) ,
  KEY `iw_account_log_toon_ind` (`trans_out_order_no`) 
) DEFAULT CHARSET = utf8mb4;

