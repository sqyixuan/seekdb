--result_format 4
--explain_protocol 1

select * from t1 A where 1 in (select 1 from t1 B where c1 = 1) and c1 = 2;
select * from t1 A where 1 in (select 1 from t1 B where c1 = 1) and c1 = 1;
select * from t1 A where 1 in (select 1 from t1 B) and c1 = 2;
select * from t1 A where c1 in (select c1 from t1 B where c2 = 1) and c1 = 1;
select * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1) and c1 = 2;
select * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and C.c1 = 0);
select * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 0) and c1 = 2;
select * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 0) and c1 = 2;
select * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 1) and c1 = 2;
select * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 1) and c1 = 1;
select * from t1 A where exists (select 1 from t1 B where A.c2 = B.c2 and c1 = 1) and c1 = 1;
select * from t1 A where exists (select 1 from t1 B where A.c1 = B.c1 and c2 >= 1) and c2 < 3;
select /*+no_expand*/ * from t1 A where exists (select 1 from t1 B where (A.c2 = B.c2 or A.c3 = B.c3) and c1 = 1) and c1 = 1;

select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B where c1 = 1) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B where c1 = 1) and c1 = 1;
select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where c1 in (select c1 from t1 B where c2 = 1) and c1 = 1;
select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and C.c1 = 0);
select /*+no_semi_to_inner*/ * from t1 A where 1 in (select 1 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 0) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 0) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 1) and c1 = 2;
select /*+no_semi_to_inner*/ * from t1 A where c3 in (select B.c3 from t1 B, t2 C where B.c2 = C.c2 and B.c1 = 1 and C.c1 = 1) and c1 = 1;
select /*+no_semi_to_inner*/ * from t1 A where exists (select 1 from t1 B where A.c2 = B.c2 and c1 = 1) and c1 = 1;
select /*+no_semi_to_inner*/ * from t1 A where exists (select 1 from t1 B where A.c1 = B.c1 and c2 >= 1) and c2 < 3;
select /*+no_semi_to_inner no_expand*/ * from t1 A where exists (select 1 from t1 B where (A.c2 = B.c2 or A.c3 = B.c3) and c1 = 1) and c1 = 1;

select a.*  from comm_selfbalancerule a 
left join comm_funduse b on a.fundusecode = b.fundusecode    
WHERE  1=1  
and a.fundusecode = '010002' 
and b.fundusename = '交易清算印花税'
and a.fundusecode in (select c.fundusecode from comm_selfbalanceitem c        
left join comm_funduse d on c.fundusecodecheck = d.fundusecode 
where 1=1  
and c.fundusecodecheck = '110000' 
and d.fundusename = '国债交易清算'
)    
order by a.fundusecode;

drop table t1, t2;
drop table comm_selfbalancerule, comm_funduse, comm_selfbalanceitem;