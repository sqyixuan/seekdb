# owner: linyi.cl
# owner group: sql3
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
select concat(COALESCE(null,(select group_concat(c1) from t1 where 1=2),null),null) from dual;
select concat(COALESCE(null,(select 'a' from t1 where 1=2),null),null) from dual;
select concat(COALESCE(null,(select convert('a' using latin1) from t1 where 1=2),null),null) from dual;
select concat(COALESCE(null,(select 1 from t1 where 1=2),null),null) from dual;
select concat(COALESCE(null,(select count(*) from t1 where 1=2),null),null) from dual;
select concat(COALESCE(null,0,null),null) from dual;
drop table t1;