#owner: guohanyun.ghy
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6;
drop sequence if exists s1;
drop sequence if exists s2;
drop sequence if exists s3;
drop sequence if exists s4;
--enable_warnings


CREATE TABLE t1(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t2(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t3(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t4(c1 int primary key, c2 int, c3 varchar(32));
create table t5(
      c1 int,
      c2 int,
      c3 int,
      primary key(c1,c2)
);

create table t6(
      c1 int,
      c2 int,
      c3 int,
      c4 int,
      primary key(c1, c2)
);

create index t1_i1 on t1(c2);
create index t3_i1 on t3(c2);
create index t4_i1 on t4(c2);
create unique index t4_i2 on t4(c2,c3);

create sequence s1 cache 10000 noorder;
create sequence s2 cache 10000 noorder;
create sequence s3 cache 10000 noorder;
create sequence s4 cache 10000 noorder;

--disable_query_log
--disable_result_log
insert into t1 select s1.nextval, s1.nextval, 'test' from table(generator(10000));
insert into t2 select s2.nextval, s2.nextval, 'test' from table(generator(10));
insert into t3 select s3.nextval, s3.nextval, 'test' from table(generator(10000));
insert into t4 select s4.nextval, s4.nextval, 'test' from table(generator(10000));

insert into t5 values(1,1,1);
insert into t5 values(2,2,2);
insert into t5 values(3,3,3);
insert into t5 values(4,4,4);
insert into t5 values(5,5,5);

insert into t6 values(1,1,1,1);
insert into t6 values(2,2,2,2);
insert into t6 values(3,3,3,3);
insert into t6 values(4,4,4,4);
insert into t6 values(5,5,5,5);

--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2);

--echo SEMI JOIN 位于外层，包含重复值不敏感聚合函数，代价改写
select MAX(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select t1.c2, BIT_AND(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;
select t1.c2, BIT_OR(t1.c1), APPROX_COUNT_DISTINCT(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2, t1.c3;
select BIT_AND(t1.c1), MIN(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c3;
select BIT_AND(t1.c1), COUNT(DISTINCT(t1.c1+1)), AVG(DISTINCT(t1.c1+2)) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;

--echo SEMI JOIN 位于外层，包含其他聚合函数，重复值敏感，会添加去重
select SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select t1.c2, BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;
select BIT_AND(t1.c1), BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;
select t1.c2, COUNT(t1.c1), APPROX_COUNT_DISTINCT(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2, t1.c3;
select BIT_AND(t1.c1), COUNT(DISTINCT(t1.c1+1)), AVG(t1.c1+2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;

--echo SEMI JOIN 位于外层，包含 DISTINCT LIMIT
select DISTINCT * from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 0;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1 OFFSET 2;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 1;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 1 OFFSET 2;
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 10;
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 0;
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1;
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 10;
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 10;
select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 1 OFFSET 2;

--echo SEMI JOIN 位于外层，包含聚合函数和 DISTINCT LIMIT
select DISTINCT MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select DISTINCT t1.c2, BIT_AND(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2;
select BIT_AND(t1.c1), BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 0;
select BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 1;
select BIT_AND(t1.c1), BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 1;
select BIT_AND(t1.c1), COUNT(DISTINCT(t1.c1+1)), AVG(DISTINCT(t1.c1+2)) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 2;
select BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1;
select BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1 OFFSET 2;
select DISTINCT t1.c2, BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 5;
select DISTINCT BIT_AND(t1.c1), BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1;

--echo SEMI JOIN 位于不相关 EXISTS
select * FROM t5 where EXISTS(select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where EXISTS(select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 1 OFFSET 2);
select * FROM t5 where EXISTS(select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) HAVING count(t1.c1)>10);
select * FROM t5 where EXISTS(select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) HAVING max(t1.c1)<10);
select * FROM t5 where EXISTS(select DISTINCT MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where EXISTS(select DISTINCT t1.c2, BIT_AND(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2);
select * FROM t5 where EXISTS(select DISTINCT t1.c2, BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2);
select * FROM t5 where EXISTS(select BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1 OFFSET 2);
select * FROM t5 where EXISTS(select DISTINCT t1.c2, BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 0);

--echo SEMI JOIN 位于 EXISTS、IN、ANY/ALL
select * FROM t5 where EXISTS (select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and t5.c1+t1.c2=t5.c2);
select /*+no_rewrite*/ * FROM t5 where EXISTS (select /*+NO_UNNEST*/ MAX(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and t5.c1+t1.c2=t5.c2);
select /*+no_rewrite*/ * FROM t5 where EXISTS (select /*+NO_UNNEST*/ SUM(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and t5.c1+t1.c2=t5.c2);
select * FROM t5 where EXISTS (select /*+NO_UNNEST*/  t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and t5.c1+t1.c2=t5.c2 LIMIT 10);
select * FROM t5 where EXISTS (select /*+NO_UNNEST*/  t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and t5.c1+t1.c2=t5.c2 ORDER BY t1.c1 LIMIT 10 OFFSET 2);
select * FROM t5 where EXISTS (select /*+NO_UNNEST*/ t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2, t1.c1 t1c1 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where t6.c2=v1.t1c1);
select * FROM t5 where EXISTS (select /*+NO_UNNEST*/ t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2, t1.c1 t1c1 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where t6.c2=v1.t1c1 limit 2);
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1);
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 limit 1);
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 limit 2);
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ MIN(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 IN (select /*+NO_UNNEST*/ COUNT(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 < ANY(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 < ANY(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) HAVING sum(t1.c1)>10);
select * FROM t5 where t5.c1 < ANY(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) HAVING max(t1.c1)>10);
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1);
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1 OFFSET 2);
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1 LIMIT 1 OFFSET 2);
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 10);
select * FROM t5 where t5.c1 > ALL(select /*+NO_UNNEST*/ t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1 LIMIT 10 OFFSET 2);

--echo SEMI JOIN 位于 SEMI 右表
select * FROM t5 where t5.c1 IN (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 IN (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) limit 1);
select * FROM t5 where t5.c1 IN (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) order by t1.c1 limit 1 offset 3);
select * FROM t5 where t5.c1 IN (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) limit 10);
select * FROM t5 where t5.c1 IN (select MIN(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 IN (select SUM(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2));
select * FROM t5 where t5.c1 IN (select MIN(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c3 limit 10);
select * FROM t5 where t5.c1 IN (select SUM(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c3 limit 1);
select * FROM t5 where t5.c1 IN (select t6.c1+v1.t1c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1);
select * FROM t5 where t5.c1 IN (select t6.c1+v1.t1c2 from t6, (select SUM(t1.c2) t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1);
select * FROM t5 where t5.c1 IN (select SUM(t6.c1+v1.t1c2) from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1);
select * FROM t5 where t5.c1 IN (select MAX(t6.c1+v1.t1c2) from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 group by t6.c2 limit 10);
select * FROM t5 where t5.c1 IN (select DISTINCT BIT_AND(t1.c1)+BIT_XOR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1);
select * FROM t5 where t5.c1 IN (select (select count(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) from dual);

--echo SEMI JOIN 位于集合查询中
select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) union select 1 from dual;
(select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) limit 1) union select 1 from dual;
(select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) limit 2) union select 1 from dual;
select min(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) union select 1 from dual;
select sum(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) union select 1 from dual;
select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) union select sum(t2.c1) from t2;
select t5.c1 FROM t5 where t5.c1 IN (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) union select sum(t2.c1) from t2;
select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 union select 1 from dual;
(select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 limit 10) union select 1 from dual;
select /*+no_rewrite*/ SUM(DISTINCT t6.c1) from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 union select 1 from dual;
select * from (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) union select t3.c2 from t3 where exists(select 1 from t4 where t3.c1=t4.c2)) v1 order by 1 limit 100;

--echo SEMI JOIN 位于 FROM
select * from t6, (select DISTINCT MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select * from t6, (select DISTINCT t1.c2, BIT_AND(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2) v1;
select * from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 1) v1 where t6.c1 < 100 limit 20;
select * from t6, (select BIT_AND(t1.c1) ba, COUNT(DISTINCT(t1.c1+1)), AVG(DISTINCT(t1.c1+2)) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 2) v1 where v1.ba > t6.c1+1;
select * from t6, (select BIT_AND(t1.c1), BIT_OR(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 ORDER BY t1.c1 LIMIT 1 OFFSET 2) v1 order by t6.c1 limit 1;
select * from t6, (select DISTINCT t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c2 LIMIT 10) v1 where t1c2 < t6.c2;
select * from t6, (select BIT_AND(t1.c1), COUNT(DISTINCT(t1.c1+1)), AVG(t1.c1+2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2) v1;

--echo SEMI JOIN 位于 FROM，外层包含聚合函数
select /*+no_rewrite*/ MIN(t6.c1) from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select DISTINCT MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select /*+no_rewrite*/ t6.c2, BIT_AND(t6.c1), APPROX_COUNT_DISTINCT(v1.t1c2) from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1) v1 where t6.c1 < 100 limit 20;
select /*+no_rewrite*/ t6.c2, BIT_AND(t6.c1), APPROX_COUNT_DISTINCT(v1.t1c2) from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1 limit 2) v1 where t6.c1 < 100 limit 20;
select /*+no_rewrite*/ BIT_AND(t6.c1), COUNT(DISTINCT(t6.c1+1)), AVG(DISTINCT(v1.t1c2+2)), t6.c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 2) v1 where v1.t1c2 > t6.c1+1 group by t6.c2;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select DISTINCT * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 order by t6.c1 limit 1;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select /*+no_rewrite*/ SUM(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 group by t6.c2;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 0) v1;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1) v1 order by t6.c1 limit 1;
select /*+no_rewrite*/ MAX(t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 ) v1;
select /*+no_rewrite*/ MAX(t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 limit 10) v1;
select /*+no_rewrite*/ SUM(t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 ) v1;
select /*+no_rewrite*/ COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 ) v1;
select /*+no_rewrite*/ COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 limit 3) v1;
select /*+no_rewrite*/ COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 limit 3) v1 limit 1;

--echo SEMI JOIN 位于 FROM，外层包含聚合函数 DISTINCT LIMIT 
select /*+no_rewrite*/ DISTINCT * from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select /*+no_rewrite*/ DISTINCT t6.c1 from t6, (select DISTINCT MAX(t1.c1), SUM(t1.c1) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1;
select /*+no_rewrite*/ DISTINCT t6.c2, BIT_AND(t6.c1), APPROX_COUNT_DISTINCT(v1.t1c2) from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1) v1 where t6.c1 < 100 limit 20;
select /*+no_rewrite*/ DISTINCT v1.t1c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) ORDER BY t1.c1 limit 2) v1 where t6.c1 < 100 limit 20;
select /*+no_rewrite*/ DISTINCT t6.c2 from t6, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) group by t1.c2 LIMIT 2) v1 where v1.t1c2 > t6.c1+1 group by t6.c2;
select /*+no_rewrite*/ DISTINCT t6.c1 from t6, (select DISTINCT * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 order by t6.c1 limit 1;
select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2 limit 1;
select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2 limit 1;
select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2 order by t6.c2 limit 1;
select /*+no_rewrite*/ t6.c1 from t6, (select DISTINCT t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2 limit 10;
select /*+no_rewrite*/ t6.c1 from t6, (select t1.c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 where 1 < t6.c2 limit 10;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 limit 1;
select /*+no_rewrite*/ SUM(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1 group by t6.c2 limit 1;
select /*+no_rewrite*/ MAX(t6.c1) from t6, (select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 0) v1 limit 1;
select /*+no_rewrite*/ DISTINCT MAX(t6.c1+v1.t1c1) from t6, (select t1.c1 t1c1 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 1) v1 group by t6.c2 limit 1;
select /*+no_rewrite*/ DISTINCT MAX(t6.c1+v1.t1c1) from t6, (select t1.c1 t1c1 from t1 where exists(select 1 from t2 where t1.c1=t2.c2) LIMIT 2) v1 group by t6.c2 limit 1;
select /*+no_rewrite*/ COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 ) v1 limit 10;
select /*+no_rewrite*/ COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 limit 3) v1 limit 1;
select /*+no_rewrite*/ DISTINCT COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2) v1 limit 10;
select /*+no_rewrite*/ DISTINCT COUNT(DISTINCT t6.c1+v1c1) from t6, (select t5.c1+v2.t1c2 v1c1 from t5, (select t1.c2 t1c2 from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v2 limit 3) v1 limit 1;
select /*+no_rewrite*/ t6.c1, v1.v1c1, v1.v1c2 from t6, (select (select count(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1c1, t3.c2 v1c2 from t3, t4 where t3.c1<t4.c2) v1 limit 20;
select /*+no_rewrite*/ DISTINCT t6.c1, v1.v1c1, v1.v1c2 from t6, (select (select count(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1c1, t3.c2 v1c2 from t3, t4 where t3.c1<t4.c2) v1 limit 20;
select /*+no_rewrite*/ t6.c1, v1.v1c1, v1.v1c2 from t6, (select (select count(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1c1, t3.c2 v1c2 from t3, t4 where t3.c1<t4.c2) v1 limit 1;
select /*+no_rewrite*/ MIN(t6.c1), MIN(v1.v1c1), MIN(v1.v1c2) from t6, (select (select count(t1.c2) from t1 where exists(select 1 from t2 where t1.c1=t2.c2)) v1c1, t3.c2 v1c2 from t3, t4 where t3.c1<t4.c2 limit 10) v1 limit 1;

--echo 外连接消除
select max(t1.c1), bit_and(t1.c2) from t1 left outer join t2 on t1.c1=t2.c2 where t1.c1 < 20;
select distinct v1.*, t3.* from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2) v1 where t3.c1 = v1.c1 and v1.c2 < 10;
select distinct v1.*, t3.* from t3 left join (select t1.* from t1 left outer join t2 on t1.c1=t2.c2) v1 on v1.c1 = t3.c1 where v1.c2 < 10;
select distinct sum(v1.c2), max(t3.c1) from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2) v1 where t3.c1 = v1.c1 and v1.c2 < 10;
select distinct sum(distinct v1.c2), max(t3.c1) from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2) v1 where t3.c1 = v1.c1 and v1.c2 < 10;
select sum(distinct v1.c2), max(t3.c1) from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2) v1 where t3.c1 = v1.c1 and v1.c2 < 10;
select sum(distinct v1.c2), max(t3.c1) from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2 order by t1.c1) v1 where t3.c1 = v1.c1 and v1.c2 < 10;
select sum(distinct v1.c2), max(t3.c1) from t3, (select t1.* from t1 left outer join t2 on t1.c1=t2.c2 order by t1.c1 limit 3) v1 where t3.c1 = v1.c1 and v1.c2 < 10;


drop table t1, t2, t3, t4, t5, t6;
drop sequence s1;
drop sequence s2;
drop sequence s3;
drop sequence s4;