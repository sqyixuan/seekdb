# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: 修复 cte 抽取规则可能会错误地对 update stmt 尝试加 semi to inner hint 的问题

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t7;
--enable_warnings

create table if not exists `t1` (
	`c1` int(11) not null,
	`c2` int(11),
	primary key (`c1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

insert into t1 values (74,53);

CREATE TABLE `t2` (
  `refund_card_id` int(11) NOT NULL AUTO_INCREMENT ,
  `status` varchar(10) DEFAULT '' ,
  `refund_money` decimal(14,2) DEFAULT '0.00' ,
  `out_trade_id` varchar(35) DEFAULT NULL ,
  `mch_no_sft` varchar(15) DEFAULT '' ,
  `terminal_id` varchar(8) DEFAULT '' ,
  `trace_no` varchar(6) DEFAULT '' ,
  `order_id_sft` varchar(12) DEFAULT '' ,
  `regtime` int(11) DEFAULT '0' ,
  `trade_ref` varchar(20) DEFAULT '' ,
  `trade_result` varchar(2) DEFAULT '0' ,
  `orig_trade_ref` varchar(50) DEFAULT '' ,
  PRIMARY KEY (`refund_card_id`)
) AUTO_INCREMENT=34 DEFAULT CHARSET=utf8;

INSERT INTO t2 (refund_card_id, status, refund_money, out_trade_id, mch_no_sft, terminal_id, order_id_sft, regtime,trade_ref, trade_result)  VALUES (4,NULL,0.00, NULL, NULL, 0, NULL,4, NULL, 0);

CREATE TABLE t3 (
  `ID_` varchar(64) COLLATE utf8_bin NOT NULL,
  `REV_` int(11) DEFAULT NULL,
  `CATEGORY_` varchar(255) COLLATE utf8_bin DEFAULT NULL,
  `NAME_` varchar(255) COLLATE utf8_bin DEFAULT NULL,
  `KEY_` varchar(255) COLLATE utf8_bin NOT NULL,
  `VERSION_` int(11) NOT NULL,
  `DEPLOYMENT_ID_` varchar(64) COLLATE utf8_bin DEFAULT NULL,
  `RESOURCE_NAME_` varchar(4000) COLLATE utf8_bin DEFAULT NULL,
  `DGRM_RESOURCE_NAME_` varchar(4000) COLLATE utf8_bin DEFAULT NULL,
  `DESCRIPTION_` varchar(4000) COLLATE utf8_bin DEFAULT NULL,
  `HAS_START_FORM_KEY_` tinyint(4) DEFAULT NULL,
  `HAS_GRAPHICAL_NOTATION_` tinyint(4) DEFAULT NULL,
  `SUSPENSION_STATE_` int(11) DEFAULT NULL,
  `TENANT_ID_` varchar(255) COLLATE utf8_bin DEFAULT '',
  PRIMARY KEY (`ID_`),
  UNIQUE KEY `ACT_UNIQ_PROCDEF` (`KEY_`,`VERSION_`,`TENANT_ID_`)
);

CREATE TABLE `t4` (
  `pay_pass` varchar(20) NOT NULL DEFAULT '010' ,
  `agent_id` int(11) DEFAULT NULL ,
  `agent_title` varchar(100) DEFAULT NULL ,
  `business_id` int(11) DEFAULT NULL ,
  `business_title` varchar(100) DEFAULT NULL ,
  `door_id` int(11) DEFAULT NULL ,
  `door_title` varchar(100) DEFAULT NULL ,
  `all_money` decimal(10,2) DEFAULT NULL ,
  `all_num` int(11) DEFAULT NULL ,
  `clear_money` decimal(10,2) DEFAULT '0.00' ,
  `commission` decimal(10,2) NOT NULL DEFAULT '0.00' ,
  `rate` varchar(11) DEFAULT NULL ,
  `return_num` int(11) DEFAULT NULL ,
  `return_money` decimal(10,2) DEFAULT '0.00' ,
  `meet_money` decimal(10,2) DEFAULT NULL ,
  `meet_num` int(11) DEFAULT NULL ,
  `regtime` int(11) DEFAULT NULL ,
  `statistics_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP ,
  `remark` varchar(255) DEFAULT NULL ,
  `name` varchar(255) DEFAULT NULL ,
  `department_name` varchar(255) DEFAULT NULL ,
  KEY `agent_id` (`agent_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `statistics_time` (`statistics_time`),
  KEY `regtime` (`regtime`)
) DEFAULT CHARSET=utf8;

CREATE TABLE `t5` (
  `id` varchar(36) NOT NULL,
  `create_by` varchar(50) DEFAULT NULL,
  `create_date` datetime DEFAULT NULL,
  `update_by` varchar(50) DEFAULT NULL,
  `update_date` datetime DEFAULT NULL,
  `en_name` varchar(32) DEFAULT NULL,
  `en_ip` varchar(32) DEFAULT NULL,
  `en_port` varchar(10) DEFAULT NULL,
  `en_state` varchar(4) DEFAULT NULL,
  `linknum` int(11) DEFAULT NULL,
  `encodetype` varchar(32) DEFAULT NULL,
  `msgheadlength` varchar(32) DEFAULT NULL,
  `timeout` int(11) DEFAULT NULL,
  `conn_state` int(1) DEFAULT '0',
  PRIMARY KEY (`id`)
) DEFAULT CHARSET=utf8;

create table if not exists `t6` (
	`c1` varchar(1),
	`c2` varchar(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

insert into t6 values (NULL,NULL,82),(NULL,NULL,NULL),(NULL,NULL,57);

CREATE TABLE `t7` (
  `mcc_detail_id` int(11) NOT NULL AUTO_INCREMENT,
  `mcc_name` varchar(255) DEFAULT NULL,
  `mcc_code` varchar(10) DEFAULT NULL,
  `mcc_cate_id` varchar(5) DEFAULT NULL,
  PRIMARY KEY (`mcc_detail_id`)
) AUTO_INCREMENT=269 DEFAULT CHARSET=utf8;

insert into t7 values (32,NULL,NULL,NULL);

update test.t1 set  c1 = (select sum(refund_card_id) from test.t2)  where ((0)  or (((test.t1.c1 = test.t1.c2)  
and ((test.t1.c1 / test.t1.c1)  or (EXISTS ( select   test.t1.c2 as c0,  (select count(REV_) from test.t3)  
as c1 from  test.t4 as ref_0 where test.t1.c2 * ref_0.agent_id))))  and ((((test.t1.c1 | test.t1.c1)  
and (EXISTS ( select   test.t1.c1 as c0 from  test.t5 as ref_1 where (ref_1.conn_state > test.t1.c2)  or (ref_1.timeout AND ref_1.linknum))))  
or (test.t1.c1 <= test.t1.c1))  or (test.t1.c2 / test.t1.c1))))  and (EXISTS ( select   
test.t1.c1 as c0,  ref_2.c3 as c1,  test.t1.c2 as c2 from  test.t6 as ref_2 where test.t1.c1 * (select count(mcc_detail_id) from 
test.t7)  limit 112));

drop table t1, t2, t3, t4, t5, t6, t7;