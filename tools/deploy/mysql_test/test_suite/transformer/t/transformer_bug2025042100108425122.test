# owner: zhuangyifeng.zyf
# onwer group: SQL1
# tags: transformer

--disable_warnings
drop table if exists t0, t1, t2;
drop table if exists a,b,c,d,e,f,a2,b2;
--enable_warnings

CREATE TABLE t0 (c00 INT, PRIMARY KEY (c00));
CREATE TABLE t1 (c10 INT, c11 INT, PRIMARY KEY (c10));
CREATE TABLE t2 (c20 INT, PRIMARY KEY (c20));
INSERT INTO t0 (c00) VALUES (1),(2);
INSERT INTO t1 (c10, c11) VALUES (1, 0),(3,0);
INSERT INTO t2 (c20) VALUES (1),(2),(3);

create table a(c0 int primary key);
create table b(c0 int primary key);
create table c(c0 int primary key);
create table d(c0 int primary key);
create table e(c0 int primary key);
create table f(c0 int primary key);
create table a2(c0 int primary key);
create table b2(c0 int primary key);

insert into a values(1),(2),(3);
insert into b values(1);
insert into c values(2);
insert into a2 values(3);

--result_format 4
--explain_protocol 2

-- echo 可以转 anti join
SELECT * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t1 ON true
  WHERE (t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t1 ON true
  WHERE (t0.c00) IS NULL;

-- echo # 可以转 anti join
SELECT * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true,
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t0 as t0_alias ON true
  WHERE (t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true,
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t0 as t0_alias ON true
  WHERE (t0.c00) IS NULL;

-- echo # 可以转 anti join
SELECT * FROM
  (SELECT 1 AS col0 FROM dual) AS sub0 
  LEFT JOIN t0 ON true
  LEFT JOIN t0 as t0_alias ON true
  WHERE t0.c00 IS NULL;

SELECT /*+no_rewrite*/ * FROM
  (SELECT 1 AS col0 FROM dual) AS sub0 
  LEFT JOIN t0 ON true
  LEFT JOIN t0 as t0_alias ON true
  WHERE t0.c00 IS NULL;

-- echo # 可以转 anti join
SELECT * FROM
  (SELECT 1 AS col0 FROM dual) AS sub0 
  LEFT JOIN t0 ON true
  INNER JOIN t0 as t0_alias ON true
  WHERE t0.c00 IS NULL;

SELECT /*+no_rewrite*/ * FROM
  (SELECT 1 AS col0 FROM dual) AS sub0 
  LEFT JOIN t0 ON true
  INNER JOIN t0 as t0_alias ON true
  WHERE t0.c00 IS NULL;

-- echo # 不能转 anti join, t1.c10 和 t0.c00 会被不同的 LEFT JOIN 补 NULL
SELECT * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t1 ON true
  WHERE (t1.c10 = t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 LEFT JOIN t1 ON true
  WHERE (t1.c10 = t0.c00) IS NULL;

-- echo # 可以转 anti join
SELECT * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 INNER JOIN t1 ON true
  WHERE (t1.c10 = t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM 
  (SELECT 1 AS col0 FROM dual) AS sub0 LEFT JOIN t0 ON true, 
  (SELECT 1 AS col1 FROM dual) AS sub1 INNER JOIN t1 ON true
  WHERE (t1.c10 = t0.c00) IS NULL;

-- echo # 不能转 anti join
SELECT * FROM
  t2
  LEFT JOIN t0 ON t2.c20 = t0.c00
  LEFT JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM
  t2
  LEFT JOIN t0 ON t2.c20 = t0.c00
  LEFT JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

-- echo # 可以转 anti join
SELECT * FROM
  t2
  INNER JOIN t0 ON t2.c20 = t0.c00
  LEFT JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM
  t2
  INNER JOIN t0 ON t2.c20 = t0.c00
  LEFT JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

-- echo # 可以转 anti join
SELECT * FROM
  t2
  LEFT JOIN t0 ON t2.c20 = t0.c00
  INNER JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

SELECT /*+no_rewrite*/ * FROM
  t2
  LEFT JOIN t0 ON t2.c20 = t0.c00
  INNER JOIN t1 ON t2.c20 = t1.c10
  WHERE (t1.c10 = t0.c00) IS NULL;

--echo # 不能转 anti join
select * from (A left join B on true) left join (c left join D on true) on A.c0 = C.c0 where (B.c0 = C.c0) is NULL;
select /*+no_rewrite*/ * from (A left join B on true) left join (c left join D on true) on A.c0 = C.c0 where (B.c0 = C.c0) is NULL;

-- echo # 可以转 anti join
SELECT A2.c0 as a2c0, B2.c0 as b2c0 FROM
  (
    ((A LEFT JOIN B ON true) LEFT JOIN (A2 LEFT JOIN B2 on true) ON true) 
    LEFT JOIN (C LEFT JOIN D ON true) ON true
  )
  LEFT JOIN (E LEFT JOIN F ON true) ON true
WHERE (A2.c0) IS NULL;

SELECT /*+no_rewrite*/ A2.c0 as a2c0, B2.c0 as b2c0 FROM
  (
    ((A LEFT JOIN B ON true) LEFT JOIN (A2 LEFT JOIN B2 on true) ON true) 
    LEFT JOIN (C LEFT JOIN D ON true) ON true
  )
  LEFT JOIN (E LEFT JOIN F ON true) ON true
WHERE (A2.c0) IS NULL;

-- echo # 不能转 anti join
SELECT A2.c0 as a2c0, B2.c0 as b2c0 FROM
  (
    ((A LEFT JOIN B ON true) LEFT JOIN (A2 LEFT JOIN B2 on true) ON true) 
    LEFT JOIN (C LEFT JOIN D ON true) ON true
  )
  LEFT JOIN (E LEFT JOIN F ON true) ON true
WHERE (A2.c0 = B2.c0) IS NULL;

SELECT /*+no_rewrite*/ A2.c0 as a2c0, B2.c0 as b2c0 FROM
  (
    ((A LEFT JOIN B ON true) LEFT JOIN (A2 LEFT JOIN B2 on true) ON true) 
    LEFT JOIN (C LEFT JOIN D ON true) ON true
  )
  LEFT JOIN (E LEFT JOIN F ON true) ON true
WHERE (A2.c0 = B2.c0) IS NULL;

drop table t0, t1, t2;
drop table a,b,c,d,e,f,a2,b2;