--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: guohanyun.ghy
# owner group: sql1
# tags: optimizer,mv_optimizer


--error 0, 1146, 9755
drop materialized view log on t1;
--error 0, 1051
drop table t1;
--error 0, 9757
drop materialized view t1_mv1;
--error 0, 9757
drop materialized view t1_mv2;

create table t1 (c1 int primary key, c2 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
insert into t1 values (3,4);

set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';

create materialized view log on t1 with primary key, rowid, sequence (c2) including new values;
create materialized view t1_mv1 NEVER REFRESH enable query rewrite as select * from t1 where t1.c1>2;
create materialized view t1_mv2 NEVER REFRESH as select * from t1;

--sorted_result
select * from t1 where t1.c1>2;  # can rewrite
--sorted_result
select * from t1 where t1.c1>1;  # can not rewrite

--sorted_result
select * from t1 where t1.c1>1;
select dbms_xplan.display_cursor(0,'basic');

--sorted_result
select * from t1 where t1.c1>2;
select dbms_xplan.display_cursor(0,'basic');

--sorted_result
select * from t1 where t1.c1>3;
select dbms_xplan.display_cursor(0,'basic');


--sorted_result
select * from t1_mv2 where exists (select * from t1 where t1.c1>2);  # can rewrite
--sorted_result
select * from t1_mv2 where exists (select * from t1 where t1.c1>1);  # can not rewrite

--sorted_result
select * from t1_mv2 where exists (select * from t1 where t1.c1>1);
select dbms_xplan.display_cursor(0,'basic');

--sorted_result
select * from t1_mv2 where exists (select * from t1 where t1.c1>2);
select dbms_xplan.display_cursor(0,'basic');

--sorted_result
select * from t1_mv2 where exists (select * from t1 where t1.c1>3);
select dbms_xplan.display_cursor(0,'basic');


let $default_query_rewrite_enabled = query_get_value(select value from oceanbase.DBA_OB_SYS_VARIABLES where name = 'query_rewrite_enabled', value, 1);
let $default_query_rewrite_integrity = query_get_value(select value from oceanbase.DBA_OB_SYS_VARIABLES where name = 'query_rewrite_integrity', value, 1);
eval set query_rewrite_enabled = $default_query_rewrite_enabled;
eval set query_rewrite_integrity = $default_query_rewrite_integrity;

drop materialized view log on t1;
drop table t1;
drop materialized view t1_mv1;
drop materialized view t1_mv2;
