# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t0, t1, t2, t3, t4;
--enable_warnings

CREATE TABLE IF NOT EXISTS t0(c0 SMALLINT(80) ZEROFILL  COMMENT 'asdf'  NULL, c1 DECIMAL(3, 2) ZEROFILL   UNIQUE KEY, PRIMARY KEY(c1));
CREATE TABLE IF NOT EXISTS t1 PARTITION BY RANGE (c0)(partition p0 VALUES LESS THAN(0), partition p1 VALUES LESS THAN(1000000000), partition p2 VALUES LESS THAN(maxvalue)) AS SELECT * FROM t0;
CREATE TABLE IF NOT EXISTS t2(c0 DECIMAL(13, 4)  COMMENT 'asdf'  UNIQUE SKIP_INDEX(SUM, MIN_MAX) , c1 FLOAT(28, 3) ZEROFILL  UNIQUE NOT NULL , c2 SMALLINT ZEROFILL , PRIMARY KEY(c1))  WITH COLUMN GROUP (each column);
CREATE TABLE t3 PARTITION BY KEY (c0, c1) SUBPARTITION BY KEY (c1) subpartitions 11 partitions 11 AS SELECT * FROM t0;
CREATE TABLE t4 PARTITION BY KEY (c0, c2) SUBPARTITION BY KEY (c0, c2) subpartitions 6 partitions 11 AS SELECT * FROM t2;

--explain_protocol 1
--result_format 4

SELECT DISTINCT * FROM t3, t4, t1 WHERE ((NOT ((( (((t4.c0,510.755) NOT IN ((-8.9202,1259545583.27), (-15412174.7235,concat(t4.c1,'')), (t4.c0,34517.839), (-3794.8347,229573.823)))))) NOT IN ((concat(t3.c0,'')) OR (-105), (5.64) > (concat(t1.c1,''))))) ) AND t4.c0 IS NULL;

drop table t0, t1, t2, t3, t4;
