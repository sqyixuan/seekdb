
#owner: sean.yyj
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(20), key i1(c1(10)));
insert into t1 values('123');
insert into t1 values('456');

--explain_protocol 2
--result_format 4

set names gb18030;

select coercibility(ifnull(1, '2'));
select /*+no_rewrite*/ coercibility(ifnull(1, '2'));

select coercibility(ifnull(1, c1)) from t1;
select /*+no_rewrite*/ coercibility(ifnull(1, c1)) from t1;

select substr(ifnull(1, c1), 2) from t1;
select /*+no_rewrite*/ substr(ifnull(123, c1), 2) from t1;

select * from t1 where c1 = ifnull(123, '456');
select /*+no_rewrite*/* from t1 where c1 = ifnull(123, '456');

select * from t1 where c1 = ifnull(123, c1);
select /*+no_rewrite*/* from t1 where c1 = ifnull(123, c1);

drop table t1;