CREATE TABLE `dw_drug_ord_detl` (
`ship_id` varchar(50) NOT NULL COMMENT '配送单号',
`ord_code` varchar(50) DEFAULT NULL COMMENT '订单代码',
`purc_plan_code` varchar(50) DEFAULT NULL COMMENT '采购单号',
`setldoc_id` varchar(50) DEFAULT NULL COMMENT '结算单号',
`drug_code` varchar(50) DEFAULT '' COMMENT '药品编码',
`drug_name` varchar(200) DEFAULT '' COMMENT '药品名称',
`genname` varchar(200) DEFAULT '' COMMENT '通用名称',
`dosform_name` varchar(100) DEFAULT '' COMMENT '剂型名称',
`rute_name` varchar(6) DEFAULT '' COMMENT '给药途径名称',
`spec_name` varchar(100) DEFAULT '' COMMENT '规格名称',
`prodentp_name` varchar(200) DEFAULT '' COMMENT '生产企业名称',
`prxy_entp_name` varchar(200) DEFAULT '' COMMENT '代理企业名称',
`sco_pac_entp_name` varchar(200) DEFAULT '' COMMENT '分包装企业名称',
`pac` varchar(20) DEFAULT '' COMMENT '包装（转换比+最小使用单位/最小包装单位）',
`minunt_name` varchar(10) DEFAULT '' COMMENT '最小使用单位名称',
`minpacunt_name` varchar(10) DEFAULT '' COMMENT '最小包装单位名称',
`min_sel_emp_name` varchar(30) DEFAULT '' COMMENT '最小销售单位名称',
`pacmatl_name` varchar(100) DEFAULT '' COMMENT '包装材质名称',
`prod_type_name` varchar(100) DEFAULT '' COMMENT '产品类型名称',
`prod_souc_name` varchar(100) DEFAULT '' COMMENT '产品来源名称',
`city_name` varchar(50) DEFAULT '' COMMENT '城市名称',
`optins_name` varchar(200) DEFAULT NULL COMMENT '经办机构名称',
`medins_name` varchar(200) DEFAULT NULL COMMENT '医疗机构名称',
`medins_code` varchar(50) DEFAULT NULL COMMENT '医疗机构名称',
`delventp_name` varchar(200) DEFAULT NULL COMMENT '配送企业名称',
`splm_inpt` varchar(3) DEFAULT NULL COMMENT '补录标志 1-补录采购 0-正常采购',
`purcpric` decimal(18,4) DEFAULT '0.0000' COMMENT '采购价',
`ord_sumamt` decimal(18,4) DEFAULT '0.0000' COMMENT '订单总金额',
`send_time` datetime DEFAULT NULL COMMENT '发送时间',
`read_time` datetime DEFAULT NULL COMMENT '已读时间',
`purc_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '采购数量',
`shp_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '发货数量',
`shp_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '发货金额',
`shp_time` datetime DEFAULT NULL COMMENT '发货时间',
`undo_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '撤销数量',
`undo_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '撤销金额',
`shpp_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '收货数量',
`shpp_time` datetime DEFAULT NULL COMMENT '收货时间',
`shpp_pric` decimal(18,4) DEFAULT '0.0000' COMMENT '收货金额',
`retn_time` datetime DEFAULT NULL COMMENT '退货时间',
`appy_retn_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '申请退货数量',
`cnfm_retn_cnt` decimal(18,4) DEFAULT '0.0000' COMMENT '确认退货数量',
`retn_amt` decimal(18,4) DEFAULT '0.0000' COMMENT '退货金额',
`sbmt_setl_appy_time` datetime DEFAULT NULL COMMENT '提交结算申请时间',
`setl_cnt` decimal(18,4) DEFAULT NULL COMMENT '结算数量',
`setl_pric` decimal(18,4) DEFAULT NULL COMMENT '结算价格',
`setl_sumpric` decimal(18,4) DEFAULT NULL COMMENT '结算金额',
`setl_time` datetime DEFAULT NULL COMMENT '结算时间',
`setl_appy_stats` varchar(3) DEFAULT NULL COMMENT '结算申请状态：1 配送企业提交结算申请金额,2 医院财务待审核金额,3 医院财务审核金额,4 医院财务审核不通过金额, 5 医院自付结算金额,6 计算中心待复核金额,7 结算中心复核金额,8 结算中心复核不通过金额',
`paydoc_sumpric` decimal(18,4) DEFAULT NULL COMMENT '支付单总价',
`paydoc_stas` varchar(3) DEFAULT NULL COMMENT '支付单状态：0未生成支付单，1已生成支付单，2已支付',
`paydoc_time` datetime DEFAULT NULL COMMENT '支付时间',
`outsto_flag` varchar(3) DEFAULT NULL COMMENT '缺货标志 1-缺货 0不缺货',
`cncl_type` varchar(3) DEFAULT NULL COMMENT '作废类型 1:医疗机构主动作废 2:配送企业超7日未发送 3:补录单作废',
`setl_way` varchar(3) DEFAULT NULL COMMENT '结算方式 1-医疗机构自付，2-医疗机构委托银行账户代扣，3-医保基金统一代付',
`paydoc_crte_time` datetime DEFAULT NULL COMMENT '支付单生成时间',
`convrat` int(11) DEFAULT '0' COMMENT '转换比(包装)',
`essdrug_flag` varchar(3) DEFAULT '' COMMENT '基药标志',
`hi_nego_drug_flag` varchar(3) DEFAULT '' COMMENT '医保谈判药品标志',
`pubonln_prc` decimal(18,4) DEFAULT '0.0000' COMMENT '挂网价格',
`hi_pay_std` varchar(10) DEFAULT '' COMMENT '医保支付标准',
`high_sel_lmtpric` decimal(18,4) DEFAULT '0.0000' COMMENT '最高销售限价',
`admdvs` varchar(6) DEFAULT '' COMMENT '医保区划代码',
`admdvs_name` varchar(100) DEFAULT '' COMMENT '医保区划名称',
`admorg_code` varchar(50) DEFAULT '' COMMENT '管理单位代码',
`admorg_name` varchar(200) DEFAULT '' COMMENT '管理单位名称',
`item_codg` varchar(50) DEFAULT '' COMMENT '项目编码',
`itemname` varchar(200) DEFAULT '' COMMENT '项目名称',
`ot_upad_stas` varchar(3) DEFAULT NULL COMMENT '超时未付款状态：0否，1超时未付款，2超时已付款',
`all_setl_sumamt` decimal(18,4) DEFAULT NULL COMMENT '全部结算总价',
PRIMARY KEY (`ship_id`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '药品订单统计';

create table s1(c2 int);
create table s2(c2 int, c9 int, c12 int, c13 int, c16 int);

CREATE TABLE t2 (
  c1 decimal(8,0) DEFAULT NULL,
  c2 varchar(14) COLLATE utf8mb4_bin DEFAULT NULL,
  c3 int(18) DEFAULT NULL
); 

CREATE TABLE t4 (
  c1 decimal(24,23) DEFAULT NULL,
  c2 decimal(63,21) DEFAULT NULL,
  c3 binary(101) DEFAULT NULL,
  c4 bigint(88) DEFAULT NULL,
  c5 mediumint(7) DEFAULT NULL,
  c6 int(108) DEFAULT NULL,
  c7 bigint(47) DEFAULT NULL,
  c8 smallint(116) DEFAULT NULL,
  c9 char(50) COLLATE utf8mb4_bin DEFAULT NULL,
  c10 tinyint(96) DEFAULT NULL,
  c11 int(77) DEFAULT NULL,
  c12 tinyint(114) NOT NULL,
  c13 tinyint(38) DEFAULT NULL,
  c14 binary(132) NOT NULL,
  c15 decimal(6,3) DEFAULT NULL,
  c16 binary(34) DEFAULT NULL,
  PRIMARY KEY (c12, c14)
);

CREATE TABLE t7 (
  c1 char(87) COLLATE utf8mb4_bin DEFAULT NULL,
  c2 int(41) NOT NULL,
  c3 char(76) COLLATE utf8mb4_bin DEFAULT NULL,
  c4 decimal(30,20) NOT NULL,
  c5 smallint(7) DEFAULT NULL,
  c6 decimal(60,10) NOT NULL,
  c7 int(51) DEFAULT NULL,
  c8 binary(23) DEFAULT NULL,
  c9 varchar(76) COLLATE utf8mb4_bin DEFAULT NULL,
  c10 int(58) NOT NULL,
  c11 binary(102) NOT NULL,
  c12 char(42) COLLATE utf8mb4_bin NOT NULL,
  c13 binary(122) DEFAULT NULL,
  c14 tinyint(120) NOT NULL,
  c15 binary(22) NOT NULL,
  PRIMARY KEY (c10, c14, c11, c2, c4, c12, c6, c15)
);

CREATE TABLE t15 (
  c1 varbinary(47) DEFAULT NULL,
  c2 varbinary(45) DEFAULT NULL,
  c3 int(14) NOT NULL,
  c4 tinyint(87) NOT NULL,
  c5 bigint(117) DEFAULT NULL,
  c6 varchar(28) COLLATE utf8mb4_bin NOT NULL,
  c7 varchar(17) COLLATE utf8mb4_bin DEFAULT NULL,
  c8 binary(21) DEFAULT NULL,
  c9 int(11) NOT NULL,
  c10 varbinary(22) DEFAULT NULL,
  c11 mediumint(26) DEFAULT NULL,
  PRIMARY KEY (c9, c6, c3, c4)
);

--explain_protocol 2
--result_format 4


SELECT prc.setldoc_id, 
       prc.setl_sumpric 
FROM   (SELECT setldoc_id, 
               admdvs, 
               setl_sumpric 
        FROM   dw_drug_ord_detl 
        GROUP  BY setldoc_id) prc 
       LEFT JOIN dw_drug_ord_detl setl 
              ON prc.setldoc_id = setl.setldoc_id 
WHERE  prc.admdvs = '410000' 
ORDER  BY setl_sumpric DESC 
LIMIT  10;

SELECT prc.setldoc_id, city_name, optins_name AS nhsa, delventp_name, setl_time_ym
        , prc.paydoc_stas, paydoc_time, paydoc_crte_time
        , Round(setl_sumpric, 2) AS setl_sumpric
        , Round(paydoc_sumpric, 2) AS paid_amt
        , Round(setl_sumpric - paydoc_sumpric, 2) AS non_paid_amt
        , Round(paydoc_sumpric / setl_sumpric * 100, 2) AS paid_amt_prop
FROM (
        SELECT setldoc_id, admdvs, admdvs_name AS city_name, admorg_name AS optins_name, delventp_name
                , IF(paydoc_stas = '0'
                        OR paydoc_stas = '1', 1, paydoc_stas) AS paydoc_stas
                , SUM(setl_sumpric) AS setl_sumpric, SUM(CASE
                        WHEN paydoc_stas = 2 THEN setl_sumpric
                        ELSE 0
                END) AS paydoc_sumpric
        FROM dw_drug_ord_detl
        WHERE Length(setldoc_id) > 0
        GROUP BY setldoc_id, admdvs, admdvs_name, optins_name, delventp_name, paydoc_stas
) prc
        LEFT JOIN (
                SELECT DISTINCT setldoc_id, Date_format(setl_time, '%Y%m') AS setl_time_ym
                        , IF(paydoc_stas = '0'
                                OR paydoc_stas = '1', 1, paydoc_stas) AS paydoc_stas
                        , paydoc_time, paydoc_crte_time
                FROM dw_drug_ord_detl
        ) setl
        ON prc.setldoc_id = setl.setldoc_id
                AND prc.paydoc_stas = setl.paydoc_stas
WHERE prc.admdvs = '410000'
ORDER BY setl_sumpric DESC
LIMIT 10;

select 1
from (
	select t4_42.c2,
	(select t4_42.c9 from s2 as t4_42 order by 1 limit 1) as c9,
	t4_42.c16 from s2 as t4_42
) t4_42
left outer join s1 on 1 = 1
where t4_42.c2 < 367 and t4_42.c9 < t4_42.c16 limit 1;



SELECT t7_4.c10 
FROM   t7 AS t7_4 
WHERE  EXISTS (SELECT t4_42.c2 
               FROM   (SELECT t4_42.c2, 
                              (SELECT t4_42.c9 
                               FROM   t4 AS t4_42 
                               ORDER  BY 1 
                               LIMIT  1) AS c9, 
                              t4_42.c13, 
                              t4_42.c16 
                       FROM   t4 AS t4_42) AS t4_42 
                      LEFT OUTER JOIN t2 
                                   ON t4_42.c9 = t2.c2 
                                      AND t4_42.c13 = t2.c2 
               WHERE  t4_42.c2 < 367 
                      AND t4_42.c9 < t4_42.c16) 
        OR t7_4.c10 < 1; 

# 
select * from (select c2 as C, max(t2.c1) as agg from t2 group by c2) L left join t4 R on L.c=R.c2 where L.agg>L.C limit 10;

#enhance
select  * from (select T.c1 from t2 T,t4 TT where T.c1>T.c2) L left join t7 R on L.c1=R.c2 where L.c1>2 limit 10;

select * from (select T.c1 from t2 T) L join t4 TT left join t7 R on L.c1=TT.c1 and TT.c1=R.c1 where L.c1<TT.c2 order by L.c1 limit 10;

select * from (select T.c1 from t2 T) L join t4 TT left join t7 R on L.c1=TT.c1 and TT.c1=R.c1 where L.c1<TT.c2 order by L.c1,TT.c1 limit 10;

select * from (select T.c1 from t2 T) L join t4 TT left join t7 R on L.c1=TT.c1 and TT.c1=R.c1 where L.c1<TT.c2 order by TT.c1 limit 10;

select * from (select T.c1 from t2 T) L join t4 TT left join t7 R on L.c1=TT.c1 and TT.c1=R.c1 where L.c1<TT.c2 order by L.c1,TT.c1 limit 10;

select  * from (select T.c1 from t4 T,t2 TT where T.c1>T.c2) L left join t2 R on L.c1=R.c2 where L.c1>2 limit 10;

select  * from (select T.c1 from t4 T,t2 TT where T.c1>T.c2) L left join t2 R on L.c1=R.c2 where L.c1>2 order by R.c1,R.c2 limit 10;

select  * from (select T.c1 from t4 T left join t2 TT on  T.c1=TT.c1) L left join t2 R on L.c1=R.c2 where L.c1>2 order by R.c1,R.c2 limit 10;

select * from (select T.c1 from t4 T left join t2 TT on  T.c1=TT.c1) L left join (select S.c1 from t7 S left join t2 SS on  S.c1=SS.c1) R on L.c1=R.c1 limit 10;

select * from (select T.c1 from t4 T left join t2 TT on  T.c1=TT.c1) L left join (select S.c1 from t7 S left join t2 SS on  S.c1=SS.c1) R on L.c1=R.c1 where L.c1>1 limit 10;

### limit push down support left join which contains semi info
--explain_protocol 0
drop table if exists t1, t2, t3;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(pk int primary key, c1 int, c2 int, c3 int);

insert into t1 values(1, 1, 1), (1, 2, 3), (3, 2, NULL);
insert into t2 values(1, 1, NULL), (2, 2, 3), (3, 2, NULL);
insert into t3 values(1, 1, 1, NULL), (2, 2, 2, 3), (3, 3, 2, NULL);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;

--explain_protocol 2
# with semi info
select * from t1 left join t2 on t1.c2 > t2.c1 where t1.c1 in (select c2 from t1) limit 10;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c2 > t2.c1 where t1.c1 in (select c2 from t1) limit 10;

select * from t1 left join t2 on t1.c2 > t2.c1 where t1.c1 in (select c2 from t1) and t1.c2 in (select c2 from t2) limit 10;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c2 > t2.c1 where t1.c1 in (select c2 from t1) and t1.c2 in (select c2 from t2) limit 10;

# can not pushdown limit
select * from t1 left join t2 on t1.c1 = t2.c1 where t1.c1 + t2.c1 in (select c2 from t2) limit 10; 
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.c1 where t1.c1 + t2.c1 in (select c2 from t2) limit 10; 

# contains distinct, can not pushdown
select distinct * from t1 left join t2 on t1.c1 = t2.c1 limit 10;
select distinct /*+no_rewrite*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 10;

#no cartesian
#basic
select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 limit 10;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 left join t1 t4 on t3.c1 = t4.c1 limit 10;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 left join t1 t4 on t3.c1 = t4.c1 limit 10;

select * from t1 left join t2 on t1.c1 = t2.c1 inner join t3 on t1.c1 = t3.c1 limit 10;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 inner join t3 on t1.c1 = t3.c1 limit 10;

select * from t1 left join t2 on t1.c1 = t2.c1 full join t3 on t1.c1 = t3.c1 limit 10;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 full join t3 on t1.c1 = t3.c1 limit 10;

select * from t1 left join t2 on t1.c1 = t2.c1 right join t3 on t1.c1 = t3.c1 limit 10;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 right join t3 on t1.c1 = t3.c1 limit 10;

select a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) inner join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 limit 10;
select /*+no_rewrite*/a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) inner join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 limit 10;

select a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 limit 10;
select /*+no_rewrite*/a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 limit 10;

#with order by
select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 order by t3.c1 limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 order by t1.c1 limit 10;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 order by t1.c1 limit 10;

select a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) inner join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 order by a.c1, c.c1 limit 10;
select /*+no_rewrite*/a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) inner join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 order by a.c1, c.c1 limit 10;

select a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 order by a.c1 limit 10;
select /*+no_rewrite*/a.c1, b.c1, c.c1, d.c1 from (t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1 order by a.c1 limit 10;

#with semi info
select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 
where t1.c1 in (select c1 from t2)
order by t1.c1 limit 10;

select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 
where t1.c1 in (select c1 from t2)
order by t1.c1 limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 
where t1.c1 not in (select c1 from t2)
order by t1.c1 limit 10;

select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 
where t1.c1 not in (select c1 from t2)
order by t1.c1 limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1 
where t3.c1 not in (select c1 from t2)
order by t1.c1 limit 10;

#join pk
select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk limit 10;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk limit 1, 1;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk limit 1, 1;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk order by t1.c1 limit 1, 1;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk order by t1.c1 limit 1, 1;

#with cartesian
select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk, t1 t4 limit 10;
select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.pk, t1 t4 limit 10;

select * from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1,
(t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1
where t1.c1 not in (select c1 from t2)
order by t1.c1 limit 10;

select /*+no_rewrite*/* from t1 inner join t2 on t1.c1 = t2.c1 left join t3 on t1.c1 = t3.c1,
(t1 a left join t1 b on a.c1 = b.c1) full join (t1 c left join t1 d on c.c1 = d.c1) on a.c1 = c.c1
where t1.c1 not in (select c1 from t2)
order by t1.c1 limit 10;

# bug: 
drop table t1;
create table t1 (c_bigint int);
insert into t1 values (1), (2);

SELECT AVG(c_bigint)
FROM T1
WHERE coalesce( (select sum(1) from t2),
(select avg(1) from t3)) = 0
OR 1 < 0
