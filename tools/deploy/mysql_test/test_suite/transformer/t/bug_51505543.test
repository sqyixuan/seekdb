--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql3
#tags: optimizer

--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_query_log
--enable_warnings

create table t1(a int, b int, c int);

explain delete FROM t1  where t1.b > any (select count(*) FROM t1  having count(*) < t1.a);
delete FROM t1  where t1.b > any (select count(*) FROM t1  having count(*) < t1.a);

DROP TABLE t1;
