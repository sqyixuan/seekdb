#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
# issue: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int);

insert into t1 values(1,2,3), (1,3,4), (4,5,6), (null,7,8);
insert into t2 values(1);

--explain_protocol 2
set autocommit = 0;
update t1 set c1 = (select 2 from t2), c2 = c1, c3 = (select 3 from t2 tt);
select * from t1;
rollback;
explain update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = c1, c3 = (select 3 from t2 tt);
update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = c1, c3 = (select 3 from t2 tt);
select * from t1;
rollback;

update t1 set c1 = (select 2 from t2), c2 = (select 0 from t2), c3 = (select 3 from t2 tt);
select * from t1;
rollback;
explain update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = (select 0 from t2), c3 = (select 3 from t2 tt);
update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = (select 0 from t2), c3 = (select 3 from t2 tt);
select * from t1;
rollback;

update t1 set c1 = (select 2 from t2), c2 = (select 2 from t2), c3 = (select 2 from t2 tt);
select * from t1;
rollback;
explain update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = (select 2 from t2), c3 = (select 2 from t2 tt);
update/*+no_rewrite*/ t1 set c1 = (select 2 from t2), c2 = (select 2 from t2), c3 = (select 2 from t2 tt);
select * from t1;
rollback;
set autocommit = 1;
--explain_protocol 0
--disable_warnings
DROP TABLE IF EXISTS t1, t2;
--enable_warnings
