# owner: sean.yyj
# owner group: sql1
# tags: optimizer
# desc: pullup const expr in select item of set stmt when do unnest

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings

create table t1(c1 int not null, c2 int);
create table t2(c1 int not null, c2 int);
create table t3(c1 int not null, c2 int);
insert into t1 values(2, 1);
insert into t1 values(3, 1);
insert into t2 values(2, 1);

--result_format 4
--explain_protocol 2

--echo # not in to anti
select * from t1 where c1 not in (select 2 from t2 where c2 = t1.c2 union all select 3 from t2 where c2 = t1.c2);
select * from t1 where c1 not in (select c1 + 0 from t2 where c2 = t1.c2 union all select c1 + 1 from t2 where c2 = t1.c2);

select * from t1 where c1 not in (select 2 from t2 where c2 = t1.c2 union all select 3 from t2 where c2 + 4 = t1.c2 + 4);
select * from t1 where c1 not in (select 0 + c1 from t2 where c2 + 4 = t1.c2 + 4 union all select c1 + 1 from t2 where c2 + 4 = t1.c2 + 4);

select * from t1 where c1 not in (select t1.c2+1 from t2 where c2 = t1.c2 union all select t1.c2+2 from t2 where c2 = t1.c2);

--echo # in to semi
select * from t1 where c1 in (select 2 from t2 where c2 = t1.c2 union all select 3 from t2 where c2 = t1.c2);
select * from t1 where c1 in (select c1 + 0 from t2 where c2 = t1.c2 union all select c1 + 1 from t2 where c2 = t1.c2);

select * from t1 where c1 in (select 2 from t2 where c2 = t1.c2 union all select 3 from t2 where c2 + 4 = t1.c2 + 4);
select * from t1 where c1 in (select 0 + c1 from t2 where c2 + 4 = t1.c2 + 4 union all select c1 + 1 from t2 where c2 + 4 = t1.c2 + 4);

select * from t1 where c1 in (select t1.c2+1 from t2 where c2 = t1.c2 union all select t1.c2+2 from t2 where c2 = t1.c2);

drop table t1,t2,t3;