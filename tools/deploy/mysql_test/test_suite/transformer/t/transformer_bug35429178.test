#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
--error 0, 1051
drop table t_k_dfhko;
--enable_warnings

create table t_k_dfhko (
c_mn INTEGER NOT NULL,
c_d4i TEXT ,
c_lngdt TEXT NOT NULL,
c_c3v INTEGER ,
c_m TEXT NOT NULL,
primary key(c_mn)
);

--result_format 4
--explain_protocol 2

SELECT subq_0.c1 + 1
FROM
 (SELECT
   (SELECT c_mn FROM t_k_dfhko LIMIT 1) AS c1,
   c_c3v AS c3
  FROM t_k_dfhko) AS subq_0
WHERE subq_0.c3 IS NOT NULL
 OR (subq_0.c3 < subq_0.c1
     AND subq_0.c3 = (SELECT subq_0.c3 FROM t_k_dfhko));

--error 0, 1051
drop table t_k_dfhko;
