--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
## 完整case
SELECT coalesce(
      (SELECT COUNT(5842)
       FROM table10_bigint
       WHERE (pk, col_decimal_20_0, pk) NOT IN
           (SELECT col_decimal_20_0, col_bigint, col_decimal_20_0
            FROM table0_bigint
            WHERE (col_bigint, col_bigint) IN
                (SELECT col_bigint, pk
                 FROM table100_bigint
                 WHERE pk IN (-100, 6429, -10, 136, 207)
                 ORDER BY pk ASC , col_timestamp_6 ASC , pk ASC)
            ORDER BY pk ASC , col_decimal_20_0 , pk ASC)
       ORDER BY col_bigint DESC , pk),
      (SELECT SUM(ROUND(ABS(99999)))
       FROM table2_bigint
       WHERE (col_decimal_20_0 = -25866
              OR NOT UPPER(SUBSTR('ez', 1, 20)) NOT LIKE UPPER(SUBSTR('neztewhl', 1, 20)) ESCAPE 'a')
         OR (col_decimal_20_0 != -25866
             OR NOT (UPPER(TRIM(SUBSTR(TRIM(LEADING SUBSTR(SUBSTR('cnezte', 1, 20), 1, 2)
                                            FROM SUBSTR('f', 1, 20)), 1, 20))) NOT LIKE UPPER('_a%') ESCAPE 'a'))
         OR (1=0)
       ORDER BY col_char_20 , pk DESC), -12223);
SELECT coalesce(
      (SELECT /*+no_rewrite*/ COUNT(5842)
       FROM table10_bigint
       WHERE (pk, col_decimal_20_0, pk) NOT IN
           (SELECT col_decimal_20_0, col_bigint, col_decimal_20_0
            FROM table0_bigint
            WHERE (col_bigint, col_bigint) IN
                (SELECT col_bigint, pk
                 FROM table100_bigint
                 WHERE pk IN (-100, 6429, -10, 136, 207)
                 ORDER BY pk ASC , col_timestamp_6 ASC , pk ASC)
            ORDER BY pk ASC , col_decimal_20_0 , pk ASC)
       ORDER BY col_bigint DESC , pk),
      (SELECT SUM(ROUND(ABS(99999)))
       FROM table2_bigint
       WHERE (col_decimal_20_0 = -25866
              OR NOT UPPER(SUBSTR('ez', 1, 20)) NOT LIKE UPPER(SUBSTR('neztewhl', 1, 20)) ESCAPE 'a')
         OR (col_decimal_20_0 != -25866
             OR NOT (UPPER(TRIM(SUBSTR(TRIM(LEADING SUBSTR(SUBSTR('cnezte', 1, 20), 1, 2)
                                            FROM SUBSTR('f', 1, 20)), 1, 20))) NOT LIKE UPPER('_a%') ESCAPE 'a'))
         OR (1=0)
       ORDER BY col_char_20 , pk DESC), -12223);

## 简化case
SELECT COUNT(5842) FROM table10_bigint t0
WHERE (pk, col_decimal_20_0, pk) NOT IN
      (SELECT t1.col_decimal_20_0, t1.col_bigint, t1.col_decimal_20_0
         FROM table0_bigint t1, table100_bigint t2
        WHERE t1.col_bigint = t2.col_bigint and t1.col_bigint = t2.pk and t2.pk IN (-100, 6429));
SELECT /*+no_rewrite*/ COUNT(5842) FROM table10_bigint
WHERE (pk, col_decimal_20_0, pk) NOT IN
      (SELECT t1.col_decimal_20_0, t1.col_bigint, t1.col_decimal_20_0
         FROM table0_bigint t1, table100_bigint t2
        WHERE t1.col_bigint = t2.col_bigint and t1.col_bigint = t2.pk and t2.pk IN (-100, 6429));

drop table table0_bigint, table2_bigint, table10_bigint, table100_bigint;