create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);

--explain_protocol 2
SELECT    table1 . col_varchar_20_key
AS
  field1 , table1 . col_varchar_key
AS
  field2 FROM ( ( 
  SELECT   subquery1_t1 . *
  FROM   ( b AS subquery1_t1 left 
  JOIN   c   AS subquery1_t2
  ON     (
                subquery1_t2 . col_varchar_20_key = subquery1_t1 . col_varchar_20_key  ) )
  WHERE  (
                subquery1_t2 . `pk` <> subquery1_t2 . `pk`
         AND    subquery1_t1 . col_varchar_20_key <> 'l' ) )
AS
  table1 LEFT OUTER JOIN ( 
  SELECT distinct  subquery2_t1 . *
  FROM   b AS subquery2_t1
  WHERE  (
                subquery2_t1 . `col_int` >= 6
         OR     subquery2_t1 . col_varchar_10 <= 'g' ) )
AS
  table2 ON (
    table2 . `pk` = table1 . `pk` 
  )
  ) WHERE (
      EXISTS
    (
               SELECT       subquery3_t1 . col_varchar AS subquery3_field1
               FROM       ( cc AS subquery3_t1
               INNER JOIN c    AS subquery3_t2
               ON         (
                                     subquery3_t2 . `pk` = subquery3_t1 . `col_int`  ) )
               WHERE      subquery3_t2 . `col_int_key` = table2 . `pk`
               OR         subquery3_t2 . col_varchar_key < 'o' )
  )
  AND
  (
    table1 . col_varchar != table1 . col_varchar AND table1 . col_varchar_20_key = 'p'
  )
    GROUP BY field1, field2 HAVING field1 > 188 ORDER BY 1, field1, field2 LIMIT 10 offset 4;

--echo simplifed case
select 1 from t1 A left join t1 B on A.c1 = B.c1 where (exists (select 1 from t2 C where c1 = B.c1 or c1 > 0)) group by 1 having 0;
select 1 from t1 A left join (t1 D left join t1 B on D.c1 = B.c1) on A.c1 = B.c1 where (exists (select 1 from t2 C where c1 = B.c1 or c1 > 0)) group by 1 having 0;
--explain_protocol 0

--disable_warnings
DROP TABLE IF EXISTS t1, t2;
DROP TABLE IF EXISTS `b`;
DROP TABLE IF EXISTS `c`;
DROP TABLE IF EXISTS `cc`;
--enable_warnings
