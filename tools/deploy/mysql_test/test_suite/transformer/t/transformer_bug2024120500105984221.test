# owner: sean.yyj
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

create table t1(c1 int);
create view v1 as select * from t1 a where c1>100;

--result_format 4
--explain_protocol 1
select count(*) from t1 b,v1 where b.c1>100 and b.c1=v1.c1;

drop view v1;
drop table t1;
