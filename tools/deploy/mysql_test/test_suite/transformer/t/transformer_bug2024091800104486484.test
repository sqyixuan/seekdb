# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);

--result_format 4

explain WITH cte AS
  (SELECT subq_1.c0 AS c0
   FROM (
    SELECT 98 AS c0 FROM t2 AS ref_11) AS subq_1)
SELECT 1
FROM
  (SELECT
    9 AS c11
   FROM t1 AS ref_30
        WHERE EXISTS (SELECT 1 FROM cte AS ref_36)
) AS subq_2
WHERE EXISTS (SELECT 1 FROM t2 AS ref_42 WHERE EXISTS (SELECT 1 FROM cte AS ref_50) AND subq_2.c11 = 77);

WITH cte AS
  (SELECT subq_1.c0 AS c0
   FROM (
    SELECT 98 AS c0 FROM t2 AS ref_11) AS subq_1)
SELECT 1
FROM
  (SELECT
    9 AS c11
   FROM t1 AS ref_30
        WHERE EXISTS (SELECT 1 FROM cte AS ref_36)
) AS subq_2
WHERE EXISTS (SELECT 1 FROM t2 AS ref_42 WHERE EXISTS (SELECT 1 FROM cte AS ref_50) AND subq_2.c11 = 77);

drop table t1, t2;