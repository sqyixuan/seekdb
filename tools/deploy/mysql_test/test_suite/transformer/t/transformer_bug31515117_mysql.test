create table test_b ( `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
);

create table test_c ( `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
);

let $single_sql = select /*+ use_nl(a b) leading(a b)*/ a.* from t1 a , test_b b where a.c2=b.c2 and a.c2=1 and 1 = (select c1 from test_c c where a.c2=c.c2 and c3=2) order by c4;
let $sql = $single_sql limit 1;
let $cnt = 1;
while($cnt <= 41)
{
  let $sql = ($sql) union all $single_sql limit $cnt;
  inc $cnt;
}
let $cur_sql= explain basic select * from ($sql);
eval $cur_sql;

let $cnt= 1;
let $sql = $single_sql limit 1;
while($cnt <= 27)
{
  let $sql = ($sql) union all $single_sql limit $cnt;
  inc $cnt;
}
let $cur_sql= explain basic select /*+no_rewrite*/ * from ($sql);
eval $cur_sql;

let $cnt= 1;
let $sql = $single_sql limit 1;
## adjsut from 128 to 112 to avoid 4013: No memory or reach tenant memory limit
while($cnt <= 96)
{
  let $sql = ($sql) union all $single_sql limit $cnt;
  inc $cnt;
}
let $cur_sql= explain basic select /*+no_rewrite*/ * from ($sql);
eval $cur_sql;

drop table t1, test_b, test_c;

--disable_query_log
connection conn_admin;
alter system set_tp tp_no = 551, error_code = 5434, frequency = 1;
connection default;
--enable_query_log
