--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
#description: transform模块测试, 测试多层union改写

## 

--disable_warnings
drop table if exists t1, test_b, test_c;
--enable_warnings

--disable_query_log
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
# the query in this case is too large, disable outline check for this case
alter system set_tp tp_no = 551, error_code = 5434, frequency = 0;
connection default;
--enable_query_log

set ob_query_timeout=6000000000;

