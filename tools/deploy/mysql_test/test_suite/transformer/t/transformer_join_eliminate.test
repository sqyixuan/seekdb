CREATE TABLE t1(c0 VARCHAR(500) , c1 FLOAT(10, 9) ZEROFILL  COMMENT 'asdf' )  PARTITION BY KEY (c1, c0) ;
CREATE TABLE t2 PARTITION BY KEY (c1, c0) AS SELECT * FROM t1;
REPLACE INTO t1(c1) VALUES(1.183888078);
INSERT /*+ */ INTO t2(c0, c1) VALUES ROW('15', 5.582509032);
INSERT /*+ */ INTO t1(c0) VALUES('20');
REPLACE INTO t1(c0, c1) VALUES ROW('25', 7.77606151);

(SELECT  * FROM (SELECT /*+   */ t2.c0 AS C0, concat(t2.c1,'') AS C1, t1.c0 AS C2, concat(t1.c1,'') AS C3, DENSE_RANK() over(partition by t1.c0, t2.c0, t2.c1 order by t1.c0, t2.c1, t1.c1 desc) AS WF0, DENSE_RANK() over( order by t1.c1, t2.c1, t1.c0 desc) AS WF1, RANK() over( order by t2.c0, t2.c1, t1.c1 asc) AS WF2 FROM  t2 RIGHT JOIN t1 ON (concat(t1.c1,'')) IS NOT NULL) L0 WHERE ( ((C0) NOT IN (( (GREATEST(WF0, WF2)))))) );

(SELECT  * FROM (SELECT /*+  no_rewrite  */ t2.c0 AS C0, concat(t2.c1,'') AS C1, t1.c0 AS C2, concat(t1.c1,'') AS C3, DENSE_RANK() over(partition by t1.c0, t2.c0, t2.c1 order by t1.c0, t2.c1, t1.c1 desc) AS WF0, DENSE_RANK() over( order by t1.c1, t2.c1, t1.c0 desc) AS WF1, RANK() over( order by t2.c0, t2.c1, t1.c1 asc) AS WF2 FROM  t2 RIGHT JOIN t1 ON (concat(t1.c1,'')) IS NOT NULL) L0 WHERE ( ((C0) NOT IN (( (GREATEST(WF0, WF2)))))) );

