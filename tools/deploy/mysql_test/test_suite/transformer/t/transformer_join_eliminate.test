## 测试单主键包含group-by, order-by, having
select sum(A.b), min(B.b), max(C.b)
          from t1 as A, t1 As B, t1 as C
          where A.a = B.a and B.a = C.a
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
select /*+NO_REWRITE*/ sum(A.b), min(B.b), max(C.b)
          from t1 as A, t1 As B, t1 as C
          where A.a = B.a and B.a = C.a
          group by B.b
          having min(B.b) > 0
          order by max(C.b);

select sum(A.b), min(B.b), max(C.b)
          from t1 as A, t1 as B, t1 as C
          where A.a = B.a and B.b = C.b
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
