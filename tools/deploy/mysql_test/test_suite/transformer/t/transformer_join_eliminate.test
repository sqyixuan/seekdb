select /*+no_rewrite*/* from tf17 partition(p0) A where exists(select 1 from tf17 B where A.c = B.c and A.d = B.d);
update tf17 partition(p0) A set A.b = A.b + 10 where exists(select 1 from tf17 B where A.c = B.c and A.d = B.d);
