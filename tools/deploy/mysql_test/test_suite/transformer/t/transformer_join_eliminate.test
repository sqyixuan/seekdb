SELECT ((table1 . `col_int`) - (table2 . `col_int_key`)) AS field1,
       table2 . col_varchar_key AS field2
FROM (CC AS table1
      RIGHT OUTER JOIN CC AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10`))
WHERE ((table1 . `pk`,
        table2 . `pk`) NOT IN
         (SELECT DISTINCT SUBQUERY1_t1 . `pk` AS SUBQUERY1_field1,
                          SUBQUERY1_t1 . `pk` AS SUBQUERY1_field2
          FROM C AS SUBQUERY1_t1))
  AND (table1 . `pk` < SOME
         (SELECT 6
          FROM DUAL)
       AND table1 . `col_varchar_10` > 'j')
;
SELECT /*+no_rewrite*/ ((table1 . `col_int`) - (table2 . `col_int_key`)) AS field1,
       table2 . col_varchar_key AS field2
FROM (CC AS table1
      RIGHT OUTER JOIN CC AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10`))
WHERE ((table1 . `pk`,
        table2 . `pk`) NOT IN
         (SELECT DISTINCT SUBQUERY1_t1 . `pk` AS SUBQUERY1_field1,
                          SUBQUERY1_t1 . `pk` AS SUBQUERY1_field2
          FROM C AS SUBQUERY1_t1))
  AND (table1 . `pk` < SOME
         (SELECT 6
          FROM DUAL)
       AND table1 . `col_varchar_10` > 'j')
;

