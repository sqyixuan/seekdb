--explain_protocol 0
drop table if exists t1, t2, t3;

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);
insert into t1 values (1, 2, 3), (3, 4 ,4);
insert into t2 values (2, 3, 4);
insert into t3 values (2, 3, 4);

--explain_protocol 2
SELECT (SELECT MAX(C1)
        FROM   T1 AS TT)
FROM   (SELECT (SELECT MAX(C1)
                FROM   T1 AS TT) AS c1,
               C2,
               C3
        FROM   T1) AS TT2
       RIGHT OUTER JOIN T2
                     ON TT2.C2 = T2.C2
WHERE  NOT EXISTS (SELECT 1
                   FROM   T1
                   WHERE  C1 > 100)
        OR TT2.C1 > 0; 

SELECT /*+no_rewrite*/
       (SELECT MAX(C1)
        FROM   T1 AS TT)
FROM   (SELECT (SELECT MAX(C1)
                FROM   T1 AS TT) AS c1,
               C2,
               C3
        FROM   T1) AS TT2
       RIGHT OUTER JOIN T2
                     ON TT2.C2 = T2.C2
WHERE  NOT EXISTS (SELECT 1
                   FROM   T1
                   WHERE  C1 > 100)
        OR TT2.C1 > 0; 

select * from t2 left join (select (select max(c1) from t2) as c1, c2 from t1) V on t2.c2 = V.c2, (select max(c1) as c1 from t2) VIEW2 where V.c1 is null;
select /*+no_rewrite*/ * from t2 left join (select (select max(c1) from t2) as c1, c2 from t1) V on t2.c2 = V.c2, (select max(c1) as c1 from t2) VIEW2 where V.c1 is null;

select * from t2 left join (t1 left join (t3 inner join (select max(c1) as c1 from t2) VIEW1) on t1.c1 = t3.c1) on t1.c1 = t2.c1, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 = VIEW2.c1;
select /*+no_rewrite*/ * from t2 left join (t1 left join (t3 inner join (select max(c1) as c1 from t2) VIEW1) on t1.c1 = t3.c1) on t1.c1 = t2.c1, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 = VIEW2.c1;

select (select max(c1) as c1 from t2) from t2 left join (t1 left join (t3 inner join (select max(c1) as c1 from t2) VIEW1) on t1.c1 = t3.c1) on t1.c1 = t2.c1, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 is null and VIEW2.c1 > 0;
select /*+no_rewrite*/ (select max(c1) as c1 from t2) from t2 left join (t1 left join (t3 inner join (select max(c1) as c1 from t2) VIEW1) on t1.c1 = t3.c1) on t1.c1 = t2.c1, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 is null and VIEW2.c1 > 0;

select VIEW2.c1 + 1 from t2 left join (select (select max(c1) from t2) as c1, c2 from t1) V on t2.c2 = V.c2, (select max(c1) as c1 from t2) VIEW2 where V.c1 is null;
select /*+no_rewrite*/ VIEW2.c1 + 1 from t2 left join (select (select max(c1) from t2) as c1, c2 from t1) V on t2.c2 = V.c2, (select max(c1) as c1 from t2) VIEW2 where V.c1 is null;

select t2.* from t2 left join (t1 inner join (select max(c1) as c1 from t2) VIEW1) on t2.c2 = t1.c2, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 is null and VIEW2.c1 > 0;
select /*+no_rewrite*/t2.* from t2 left join (t1 inner join (select max(c1) as c1 from t2) VIEW1) on t2.c2 = t1.c2, (select max(c1) as c1 from t2) VIEW2 where VIEW1.c1 is null and VIEW2.c1 > 0;

select t1.* from t1 left join ((select max(c1) as c1 from t2) V1 inner join (select max(c1) as c1 from t2) V2) on t1.c1 > 0;
select /*+no_rewrite*/t1.* from t1 left join ((select max(c1) as c1 from t2) V1 inner join (select max(c1) as c1 from t2) V2) on t1.c1 > 0;
