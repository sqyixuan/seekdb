select * from t1 where a in (select t1.a +P.a +C.a +O.a from t1 right join (tf11 as C left join t12 as O on C.a = O.a inner join t11 as P on P.a = C.a) on t1.a = P.a);
select /*+NO_REWRITE*/ * from t1 where a in (select /*+NO_REWRITE*/ t1.a +P.a +C.a +O.a from t1 right join (tf11 as C left join t12 as O on C.a = O.a inner join t11 as P on P.a = C.a) on t1.a = P.a);

