  (select t15.b a1, t16.a a2, count(t16.c) a3 from t15,t16 where t15.a = t16.b group by a1,a2 having a3 > 0 order by a1) A 
where exists 
  (select 1 from 
        (select t15.b a1, t16.a a2, count(t15.c) a3 from t15,t16 where t15.a = t16.b group by a1,a2 having a3 > 0 order by a2) B 
  where A.a1 = B.a1 and A.a2 = B.a2);

select /*+no_rewrite*/* from 
  (select t15.b a1, t16.a a2, count(t16.c) a3 from t15,t16 where t15.a = t16.b group by a1,a2 having a3 > 0 order by a1) A 
where exists 
  (select 1 from 
        (select t15.b a1, t16.a a2, count(t15.c) a3 from t15,t16 where t15.a = t16.b group by a1,a2 having a3 > 0 order by a2) B 
  where A.a1 = B.a1 and A.a2 = B.a2);

