SELECT outr . col_int_key AS x FROM   b AS outr2 LEFT JOIN b AS outr ON ( outr2 . pk = outr . pk ) WHERE  ( outr . pk, outr . pk ) IN (SELECT innr . col_int AS x, innr . pk      AS y FROM   bb AS innr WHERE  innr . col_int_key = innr . pk OR outr . pk > 8) OR outr . col_datetime BETWEEN '2005-09-10' AND '2001-04-21' ORDER  BY outr . col_datetime, outr . pk;
SELECT /*+no_rewrite*/ outr . col_int_key AS x FROM   b AS outr2 LEFT JOIN b AS outr ON ( outr2 . pk = outr . pk ) WHERE  ( outr . pk, outr . pk ) IN (SELECT innr . col_int AS x, innr . pk      AS y FROM   bb AS innr WHERE  innr . col_int_key = innr . pk OR outr . pk > 8) OR outr . col_datetime BETWEEN '2005-09-10' AND '2001-04-21' ORDER  BY outr . col_datetime, outr . pk;

