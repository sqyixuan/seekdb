## 单主键 + 子查询
select C.a, P.a from tf11 as C, t11 as P where C.a = P.a and exists (select * from t12 where t12.a = P.a);
select /*+NO_REWRITE*/ C.a, P.a from tf11 as C, t11 as P where C.a = P.a and exists (select * from t12 where t12.a = P.a);
update tf11 as C, t11 as P set C.d = C.d + 100 where C.a = P.a and exists (select * from t12 where t12.a = P.a);
