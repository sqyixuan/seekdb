# fix bug 
SELECT table2.`col_varchar_20`
FROM B1 AS table2
WHERE NOT EXISTS (
        (SELECT SUBQUERY1_t1 . `col_int_key` AS SUBQUERY1_field1
         FROM (C1 AS SUBQUERY1_t1 RIGHT OUTER JOIN B1 AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int_key` = SUBQUERY1_t1 . `pk`))
         WHERE SUBQUERY1_t2 . `col_varchar_10_key` != ANY
                               (SELECT CHILD_SUBQUERY1_t1 . `col_varchar_20_key` AS CHILD_SUBQUERY1_field1
                                FROM (CC AS CHILD_SUBQUERY1_t1
                                      RIGHT OUTER JOIN ((CC AS CHILD_SUBQUERY1_t2 INNER JOIN CC AS CHILD_SUBQUERY1_t3))
                                      ON (CHILD_SUBQUERY1_t3 . `col_int_key` = CHILD_SUBQUERY1_t2 . `pk`))
                                WHERE CHILD_SUBQUERY1_t2 . `col_varchar_20` = SUBQUERY1_t2 . `col_varchar`
                                  AND CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar`)))
;

# fix bug 
SELECT table1.`col_varchar_key`
FROM (c2 AS table1 LEFT OUTER JOIN cc2 AS table2 ON (table2 . `pk` = table1 . `col_int_key`))
WHERE (SELECT COUNT(SUBQUERY2_t2 . `col_varchar_20`) AS SUBQUERY2_field1 FROM cc2 AS SUBQUERY2_t2 ) IS NULL
  AND EXISTS (SELECT SUBQUERY3_t1 . `col_int_key` AS SUBQUERY3_field1 FROM c2 AS SUBQUERY3_t1 WHERE SUBQUERY3_t1 . `col_varchar` <= table2 . `col_varchar_key`);

# bug: 
--disable_warnings
DROP TABLE IF EXISTS `cc`, `c`;
--enable_warnings
--disable_result_log
CREATE TABLE `cc` (
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) 
) ;
CREATE TABLE `c` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
