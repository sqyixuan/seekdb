## 主外键连接消除
# 以下测试中 C 表示有主外键约束表的子表, P 表示有主外键约束的表的父表, O 表示与其他表无主外键约束
## 测试单主键的表

select P.a, C.a from t11 as P, tf11 as C where P.a = C.a;
select /*+NO_REWRITE*/ P.a, C.a from t11 as P, tf11 as C where P.a = C.a;
update t11 as P, tf11 as C set C.d = C.d + 1 where P.a = C.a;
select * from t11;
rollback;
update /*+NO_REWRITE*/t11 as P, tf11 as C set C.d = C.d + 1 where P.a = C.a;
select * from t11;
rollback;
delete C from t11 as P, tf11 as C where P.a = C.a;
select * from t11;
rollback;
delete /*+NO_REWRITE*/C from t11 as P, tf11 as C where P.a = C.a;
select * from t11;
rollback;

select P.b, C.b from t11 as P, tf11 as C where P.a = C.a;
