  (select distinct t15.b, t16.c from t15,t16 where t15.a = t16.b limit 10) A 
where exists 
  (select 1 from 
        (select distinct t15.b, t16.c from t15,t16 where t15.a = t16.b) B 
  where A.b = B.b);

select /*+no_rewrite*/* from 
  (select distinct t15.b, t16.c from t15,t16 where t15.a = t16.b limit 10) A 
where exists 
  (select 1 from 
        (select distinct t15.b, t16.c from t15,t16 where t15.a = t16.b) B 
  where A.b = B.b);

