--disable_warnings
drop table if exists t1;
--enable_warnings
--explain_protocol 0

create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 values(1, null, 2), (2, 3, 3), (3, -1, 3);
--explain_protocol 2
