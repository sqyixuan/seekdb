#常规简单表
##semi join的自连接消除
##单表semi join
##无唯一约束消除
select * from tf15 A where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
select /*+no_rewrite*/* from tf15 A where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
update tf15 A set A.d=A.d+10 where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
select * from tf15;
rollback;
update /*+no_rewrite*/ tf15 A set A.d=A.d+10 where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
select * from tf15;
rollback;
delete from tf15 A where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
select * from tf15;
rollback;
delete /*+no_rewrite*/ from tf15 A where exists (select 1 from tf15 B where A.c = B.c and A.d = B.d);
select * from tf15;
rollback;

##过滤谓词+唯一约束
select * from t15 A where exists (select 1 from t15 B where A.b = B.b and A.c = B.c and B.d > 0) and A.d < 4;
select /*+no_rewrite*/ * from t15 A where exists (select 1 from t15 B where A.b = B.b and A.c = B.c and B.d > 0) and A.d < 4;

## 消除后semi condition 存在子查询, 暂不消除
select 1 from t15 A where A.c1 in (select B.c1 from t15 B, t16 C where (select 1 from t17 where c1 = B.c2) < (select 1 from t17 where c1 = C.c2));
select /*+no_rewrite*/ 1 from t15 A where A.c1 in (select B.c1 from t15 B, t16 C where (select 1 from t17 where c1 = B.c2) < (select 1 from t17 where c1 = C.c2));

##过滤谓词+主键
select * from t15 A where exists (select 1 from t15 B where A.a = B.a and (A.c = B.c or B.d > 0)) and A.d < 4;
select /*+no_rewrite*/ * from t15 A where exists (select 1 from t15 B where A.a = B.a and (A.c = B.c or B.d > 0)) and A.d < 4;

##过滤谓词+复杂连接谓词+唯一约束
select * from t15 A where exists (select 1 from t15 B where A.b = B.b and A.c = B.c and (B.d = A.d OR B.a = A.B OR B.a > 4));
select /*+no_rewrite*/ * from t15 A where exists (select 1 from t15 B where A.b = B.b and A.c = B.c and (B.d = A.d OR B.a = A.B OR B.a > 4));

##分区表单表semi join
