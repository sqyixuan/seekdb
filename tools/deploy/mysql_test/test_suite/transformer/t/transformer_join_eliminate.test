select /*+NO_REWRITE*/ P.a, C.a from t11 as P right join tf11 as C on P.a = C.a inner join t12 as O on P.a = O.a;

select P.a, C.a from t11 as P left join tf11 as C on P.a = C.a inner join t12 as O on P.a = O.a;
