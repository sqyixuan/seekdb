--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set foreign_key_checks=1;
--enable_query_log

# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer
# description: test join elimination


--disable_abort_on_error

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t7, t8, C, bb, b;
drop table if exists tf11, tf12, tf112, tf13, tf14, tf134, tf15, tf16, tf17, tf18, t11, t12, t13, t14, t15, t16, t17, t18, ta, tb, tc;
drop table if exists to1, to2, to3, to4, to5, to6, to7, to8, to9, to10;
drop table if exists `b1`, `c1`, `cc`, `c2`, `cc2`;

## 单主键
create table t1(a int primary key, b int, c int, d int);
create table t2(a int primary key, b int, c int, d int);

## 联合主键
create table t3(a int, b int, c int, d int, primary key(a,b));
create table t4(a int, b int, c int, d int, primary key(a,b));

## 带唯一索引的表
create table t5(a int primary key, b int, c int, d int, unique key(b, c));

## 带普通索引的表
create table t6(a int primary key, b int, c int, d int, index idx61 (b, c));

## 多分区表
create table t7(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table t8(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;

CREATE TABLE C (
col_varchar_20_key varchar(20),
col_varchar_20 varchar(20),
col_varchar_10_key varchar(10),
col_int_key int,
col_int int,
col_varchar varchar (1),
pk int,
col_varchar_key varchar (1),
col_varchar_10 varchar(10),
/*Indices*/
key idx7(col_varchar_20_key ),
key idx5(col_varchar_10_key ),
key idx1(col_int_key ),
primary key (pk),
key idx3(col_varchar_key ));

CREATE TABLE `bb` ( `col_date_key` date DEFAULT NULL, `col_int_key` int(11) DEFAULT NULL, `col_datetime_key` datetime DEFAULT NULL, `col_datetime` datetime DEFAULT NULL, `col_varchar_10` varchar(10) DEFAULT NULL, `col_int` int(11) DEFAULT NULL, `col_varchar_20` varchar(20) DEFAULT NULL, `pk` int(11) NOT NULL, `col_varchar_10_key` varchar(10) DEFAULT NULL, `col_date` date DEFAULT NULL, `col_varchar_20_key` varchar(20) DEFAULT NULL, PRIMARY KEY (`pk`), KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384, KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384, KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384, KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384, KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384 ) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE `b` ( `col_varchar_20_key` varchar(20) DEFAULT NULL, `col_date_key` date DEFAULT NULL, `pk` int(11) NOT NULL, `col_datetime_key` datetime DEFAULT NULL, `col_date` date DEFAULT NULL, `col_int` int(11) DEFAULT NULL, `col_varchar_10_key` varchar(10) DEFAULT NULL, `col_varchar_10` varchar(10) DEFAULT NULL, `col_int_key` int(11) DEFAULT NULL, `col_varchar_20` varchar(20) DEFAULT NULL, `col_datetime` datetime DEFAULT NULL, PRIMARY KEY (`pk`), KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384, KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384, KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384, KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384, KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384 ) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE `b1` (
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`)
);
