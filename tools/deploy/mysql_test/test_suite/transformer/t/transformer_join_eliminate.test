select C.a, P.a from tf17 as C right join t17 as P on C.a = P.a inner join t18 as O on C.a = O.a;
select /*+NO_REWRITE*/ C.a, P.a from tf17 as C right join t17 as P on C.a = P.a inner join t18 as O on C.a = O.a;

select C.a, P.a from tf17 as C left join t17 as P on C.a = P.a inner join t18 as O on C.a = O.a;
select /*+NO_REWRITE*/ C.a, P.a from tf17 as C left join t17 as P on C.a = P.a inner join t18 as O on C.a = O.a;

## C1 消除 P1, C2 消除 P2
select C1.a, P1.a, C2.a, P2.a 
    from tf17 as C1, t17 as P1, tf18 as C2, t18 as P2 
    where C1.a = P1.a and P1.a = P2.a and C2.a = P2.a and P2.a > 0;
select /*+NO_REWRITE*/ C1.a, P1.a, C2.a, P2.a 
    from tf17 as C1, t17 as P1, tf18 as C2, t18 as P2 
    where C1.a = P1.a and P1.a = P2.a and C2.a = P2.a and P2.a > 0;

## 多分区表 + 子查询
select C.a, P.a from tf17 as C, t17 as P where C.a = P.a and exists (select * from t18 where t18.a = P.a);
select /*+NO_REWRITE*/ C.a, P.a from tf17 as C, t17 as P where C.a = P.a and exists (select * from t18 where t18.a = P.a);
update tf17 as C, t17 as P set C.d = C.d + 100 where C.a = P.a and exists (select * from t18 where t18.a = P.a);
select * from tf17;
rollback;
update /*+NO_REWRITE*/tf17 as C, t17 as P set C.d = C.d + 100 where C.a = P.a and exists (select * from t18 where t18.a = P.a);
select * from tf17;
rollback;
delete C from tf17 as C, t17 as P where C.a = P.a and exists (select * from t18 where t18.a = P.a);
select * from tf17;
rollback;
delete /*+NO_REWRITE*/C from tf17 as C, t17 as P where C.a = P.a and exists (select * from t18 where t18.a = P.a);
select * from tf17;
rollback;

select C.a, P.a from tf17 as C, t17 as P where C.a = P.a and C.a in (select b from t18 where t18.a = P.a);
select /*+NO_REWRITE*/ C.a, P.a from tf17 as C, t17 as P where C.a = P.a and C.a in (select b from t18 where t18.a = P.a);

select * from t18 where exists (select C.a from tf17 as C, t17 as P where C.a = P.a and P.a = t18.a);
select /*+NO_REWRITE*/ * from t18 where exists (select /*+NO_REWRITE*/ C.a from tf17 as C, t17 as P where C.a = P.a and P.a = t18.a);

select * from t18 where t18.b in (select C.a from tf17 as C, t17 as P where C.a = P.a);
select /*+NO_REWRITE*/ * from t18 where t18.b in (select /*+NO_REWRITE*/ C.a from tf17 as C, t17 as P where C.a = P.a);

select C.a, P.b from tf17 as C, t17 as P where C.a = P.b UNION select C.a, P.a from tf18 as C, t18 as P where C.a = P.a;
select C.a, P.b from tf17 as C, t17 as P where C.a = P.b UNION select /*+NO_REWRITE*/ C.a, P.a from tf18 as C, t18 as P where C.a = P.a;

## 多分区表 + group by + order by + having
select sum(C.b), min(C.c), max(P.a)
    from tf17 as C, t17 as P
    where C.a = P.a
    group by C.b
    having min(C.c) > 0
    order by max(P.a);
select /*+NO_REWRITE*/ sum(C.b), min(C.c), max(P.a)
    from tf17 as C, t17 as P
    where C.a = P.a
    group by C.b
    having min(C.c) > 0
    order by max(P.a);

select sum(C.b), min(C.c), max(P.a)
    from tf17 as C, t17 as P
    where C.a = P.b
    group by C.b
    having min(C.c) > 0
    order by max(P.a);
select /*+NO_REWRITE*/ sum(C.b), min(C.c), max(P.a)
    from tf17 as C, t17 as P
    where C.a = P.b
    group by C.b
    having min(C.c) > 0
    order by max(P.a);

select sum(C.a + C.b + P.a)
    from tf17 as C, t17 as P
    where C.a = P.a
    group by C.c
    having sum(C.a + C.b + P.a) > 10
    order by sum(C.a + C.b + P.a);
select /*+NO_REWRITE*/ sum(C.a + C.b + P.a)
    from tf17 as C, t17 as P
    where C.a = P.a
    group by C.c
    having sum(C.a + C.b + P.a) > 10
    order by sum(C.a + C.b + P.a);

# 存在传递性的消除情景， ta 消除 tb, tb 消除 tc
SELECT ta.c1, tb.c1, tc.c1 FROM tc, tb, ta WHERE tc.c1 = tb.c1 AND tb.c1 = ta.c1;
SELECT /*+NO_REWRITE */ ta.c1, tb.c1, tc.c1 FROM tc, tb, ta WHERE tc.c1 = tb.c1 AND tb.c1 = ta.c1;
update tc, tb, ta set ta.c2 = ta.c2 + 1000 where tc.c1 = tb.c1 AND tb.c1 = ta.c1;
select * from ta;
rollback;
update /*+NO_REWRITE*/tc, tb, ta set ta.c2 = ta.c2 + 1000 where tc.c1 = tb.c1 AND tb.c1 = ta.c1;
select * from ta;
rollback;
delete ta from tc, tb, ta where tc.c1 = tb.c1 AND tb.c1 = ta.c1;
select * from ta;
rollback;
delete /*+NO_REWRITE*/ta from tc, tb, ta where tc.c1 = tb.c1 AND tb.c1 = ta.c1;
select * from ta;
rollback;

SELECT ta.c1, tb.c1, tc.c1 FROM ta, tb, tc WHERE tc.c1 = tb.c1 AND tb.c1 = ta.c1;
SELECT /*+NO_REWRITE */ ta.c1, tb.c1, tc.c1 FROM ta, tb, tc WHERE tc.c1 = tb.c1 AND tb.c1 = ta.c1;

