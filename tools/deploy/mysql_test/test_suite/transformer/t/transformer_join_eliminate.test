select * from t12 where exists (select C.b from tf11 as C, t11 as P where C.a = P.a and P.a = t12.c);
select /*+NO_REWRITE*/ * from t12 where exists (select /*+NO_REWRITE*/ C.b from tf11 as C, t11 as P where C.a = P.a and P.a = t12.c);

select C.a, P.a from tf11 as C, t11 as P where C.a = P.a UNION select C.a, P.a from tf12 as C, t12 as P where C.b = P.a;
select /*+NO_REWRITE*/ C.a, P.a from tf11 as C, t11 as P where C.a = P.a UNION select /*+NO_REWRITE*/ C.a, P.a from tf12 as C, t12 as P where C.b = P.a;

## 单主键 + group by + order by + having
select sum(C.b), min(P1.a), max(P2.a)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.a = P2.a
    group by C.b
    having min(P1.a) > 0
    order by max(P2.a);
select /*+NO_REWRITE*/ sum(C.b), min(P1.a), max(P2.a)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.a = P2.a
    group by C.b
    having min(P1.a) > 0
    order by max(P2.a);


select sum(C.b), min(P1.a), max(P2.a)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.b = P2.b
    group by C.b
    having min(P1.a) > 0
    order by max(P2.a);
select /*+NO_REWRITE*/ sum(C.b), min(P1.a), max(P2.a)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.b = P2.b
    group by C.b
    having min(P1.a) > 0
    order by max(P2.a);


select sum(C.a + P1.a + P2.c)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.a = P2.b
    group by C.b
    having sum(C.a + P1.a + P2.c) > 10
    order by sum(C.a + P1.a + P2.c);
select /*+NO_REWRITE*/ sum(C.a + P1.a + P2.c)
    from tf112 as C, t11 as P1, t12 as P2
    where C.a = P1.a and P1.a = P2.b
    group by C.b
    having sum(C.a + P1.a + P2.c) > 10
    order by sum(C.a + P1.a + P2.c);


