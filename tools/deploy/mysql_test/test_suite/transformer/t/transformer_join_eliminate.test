select D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) left join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;
select /*+no_rewrite*/D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) left join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;

select D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) right join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;
select /*+no_rewrite*/D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) right join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;

select D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) full join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;
select /*+no_rewrite*/D.* from (t11 A inner join t11 B on A.a=B.a and B.b>0) full join (t12 C inner join t12 D on C.a=D.a and C.b<0) on B.a=D.a where B.c>0;

select D.* from t11 A left join ((t12 B inner join t12 C on B.a=C.a and C.d<0) left join t15 D on C.a=D.a) on A.b=D.c;
select /*+no_rewrite*/D.* from t11 A left join ((t12 B inner join t12 C on B.a=C.a and C.d<0) left join t15 D on C.a=D.a) on A.b=D.c;

select D.* from ((t12 B inner join t12 C on B.a=C.a and C.d<0) left join t15 D on C.a=D.a) left join t11 A on A.b=D.c;
select /*+no_rewrite*/D.* from ((t12 B inner join t12 C on B.a=C.a and C.d<0) left join t15 D on C.a=D.a) left join t11 A on A.b=D.c;

