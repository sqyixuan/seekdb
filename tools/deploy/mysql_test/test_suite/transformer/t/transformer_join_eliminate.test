          from t1 as A, t1 as B, t1 as C
          where A.a = B.a and B.b = C.b
          group by B.b
          having min(B.b) > 0
          order by max(C.b);

select sum(A.a + B.b + C.c)
          from t1 as A, t1 as B, t1 as C
          where A.a = B.a and B.b = C.b
          group by B.d
          having sum(A.a + B.b + C.c) > 10;
select /*+NO_REWRITE*/ sum(A.a + B.b + C.c)
          from t1 as A, t1 as B, t1 as C
          where A.a = B.a and B.b = C.b
          group by B.d
          having sum(A.a + B.b + C.c) > 10;

