SELECT table2 . col_int_key AS field1 , CONCAT ( table1 . `col_varchar_10_key` , table2 . `col_varchar` ) AS field2 FROM ( C AS table1 RIGHT JOIN ( SELECT SUBQUERY1_t1 . * FROM C AS SUBQUERY1_t1 WHERE ( SUBQUERY1_t1 . `col_int_key` , SUBQUERY1_t1 . `col_int` ) IN ( SELECT CHILD_SUBQUERY1_t1 . `pk` AS CHILD_SUBQUERY1_field1 , MIN( CHILD_SUBQUERY1_t1 . `pk` ) AS child_subquery1_field2 FROM C AS CHILD_SUBQUERY1_t1 ) ) AS table2 ON (table2 . `pk` = table1 . `pk` ) ) WHERE ( ( SELECT 5 FROM DUAL ) IS NOT NULL ) AND table1 . `col_varchar_key` = 'f' GROUP BY field1, field2 HAVING field1 != 'se';
SELECT /*+NO_REWRITE*/ table2 . col_int_key AS field1 , CONCAT ( table1 . `col_varchar_10_key` , table2 . `col_varchar` ) AS field2 FROM ( C AS table1 RIGHT JOIN ( SELECT SUBQUERY1_t1 . * FROM C AS SUBQUERY1_t1 WHERE ( SUBQUERY1_t1 . `col_int_key` , SUBQUERY1_t1 . `col_int` ) IN ( SELECT CHILD_SUBQUERY1_t1 . `pk` AS CHILD_SUBQUERY1_field1 , MIN( CHILD_SUBQUERY1_t1 . `pk` ) AS child_subquery1_field2 FROM C AS CHILD_SUBQUERY1_t1 ) ) AS table2 ON (table2 . `pk` = table1 . `pk` ) ) WHERE ( ( SELECT 5 FROM DUAL ) IS NOT NULL ) AND table1 . `col_varchar_key` = 'f' GROUP BY field1, field2 HAVING field1 != 'se';

