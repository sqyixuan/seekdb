## 单主键
create table t11(a int primary key, b int, c int, d int);
create table tf11(a int primary key, b int, c int, d int, foreign key (a) references t11 (a));
create table t12(a int primary key, b int, c int, d int);
create table tf12(a int primary key, b int, c int, d int, foreign key (b) references t12 (a));
create table tf112(a int primary key, b int, c int, d int, foreign key (a) references t11 (a), foreign key (a) references t12 (a));

## 联合主键
create table t13(a int, b int, c int, d int, primary key(a,b));
create table tf13(a int, b int, c int, d int, primary key(a,b), foreign key (a,b) references t13 (a,b));
create table t14(a int, b int, c int, d int, primary key(a,b));
create table tf14(a int, b int, c int, d int, primary key(a,b), foreign key (c,d) references t14 (a,b));
create table tf134(a int, b int, c int, d int, primary key(a,b), foreign key (a,b) references t13 (a,b), foreign key (c,d) references t14(a,b));

## 带唯一索引的表
create table t15(a int primary key, b int, c int, d int, unique key(b, c));
create table tf15(a int primary key, b int, c int, d int, foreign key (b,c) references t15 (b, c));
create table t16(a int primary key, b int, c int, d int, unique key(b, c));
create table tf16(a int primary key, b int, c int, d int, foreign key (b,c) references t16 (b, c));

## 主外键约束不能建立在普通索引上

## 多分区表
create table t17(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table tf17(a int, b int, c int, d int, primary key (a), foreign key (a) references t17 (a)) partition by hash(a) partitions 3;
create table t18(a int, b int, c int, d int, primary key (a)) partition by hash(a) partitions 3;
create table tf18(a int, b int, c int, d int, primary key (a), foreign key (a) references t18 (a)) partition by hash(a) partitions 3;


create table tc (c1 int primary key, c2 int);
create table tb (c1 int primary key, c2 int, foreign key (c1) references tc(c1));
create table ta (c1 int primary key, c2 int, foreign key (c1) references tb(c1));

