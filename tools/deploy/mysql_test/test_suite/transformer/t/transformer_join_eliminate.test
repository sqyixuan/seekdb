SELECT /*+NO_REWRITE*/CONCAT (table1 . `col_varchar`,
               table2 . `col_varchar_20`) AS field1
FROM (D AS table1
      RIGHT  JOIN ((CC AS table2
                    LEFT OUTER JOIN CC AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_10_key`))) ON (table3 . `pk` = table2 . `col_int_key`))
WHERE (table1 . `col_varchar_10` IN
         (SELECT /*+NO_REWRITE*/SUBQUERY1_t2 . `col_varchar_10` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                LEFT OUTER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
          WHERE SUBQUERY1_t1 . `col_int_key` < table2 . `col_int`
            AND EXISTS
              (SELECT /*+NO_REWRITE*/CHILD_SUBQUERY1_t1 . `col_varchar_20` AS CHILD_SUBQUERY1_field1
               FROM CC AS CHILD_SUBQUERY1_t1
               WHERE CHILD_SUBQUERY1_t1 . `col_varchar_20` < SUBQUERY1_t2 . `col_varchar` ) ))
  AND table1 . `col_varchar_key` = table3 . `col_varchar_key`
  AND table1 . `pk` IS NULL
GROUP BY field1
ORDER BY 1,
         field1;

SELECT CONCAT (table1 . `col_varchar`,
               table2 . `col_varchar_20`) AS field1
FROM (D AS table1
      RIGHT  JOIN ((CC AS table2
                    LEFT OUTER JOIN CC AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_10_key`))) ON (table3 . `pk` = table2 . `col_int_key`))
WHERE (table1 . `col_varchar_10` IN
         (SELECT SUBQUERY1_t2 . `col_varchar_10` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                LEFT OUTER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
          WHERE SUBQUERY1_t1 . `col_int_key` < table2 . `col_int`
            AND EXISTS
              (SELECT CHILD_SUBQUERY1_t1 . `col_varchar_20` AS CHILD_SUBQUERY1_field1
               FROM CC AS CHILD_SUBQUERY1_t1
               WHERE CHILD_SUBQUERY1_t1 . `col_varchar_20` < SUBQUERY1_t2 . `col_varchar` ) ))
  AND table1 . `col_varchar_key` = table3 . `col_varchar_key`
  AND table1 . `pk` IS NULL
GROUP BY field1
ORDER BY 1,
         field1;

