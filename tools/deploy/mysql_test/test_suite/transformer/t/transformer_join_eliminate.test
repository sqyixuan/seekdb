DELIMITER $$;

CREATE FUNCTION get_random_number()
RETURNS DOUBLE
NOT DETERMINISTIC
BEGIN
    DECLARE l_random DOUBLE;
    SET l_random = RAND();
    RETURN l_random;
END$$
DELIMITER ;$$

explain select distinct t1.*, get_random_number()  from t1 left join t2 on t1.c1 = t2.c1;

