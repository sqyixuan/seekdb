select /*+NO_REWRITE*/ C.a, P.a from tf11 as C, t11 as P where C.a = P.a and C.a in (select c from t12 where t12.a = P.a);

select * from t12 where t12.b in (select C.b from tf11 as C, t11 as P where C.a = P.a);
