set autocommit=0;

## 测试按照不同字段join

select * from t1 as A, t1 as B where A.a = B.a;
select /*+NO_REWRITE*/ * from t1 as A, t1 as B where A.a = B.a;
update t1 as A, t1 as B set A.b=1 where A.a=B.a;
select * from t1;
rollback;
update /*+NO_REWRITE*/t1 as A, t1 as B set A.b=1 where A.a=B.a;
select * from t1;
rollback;

select * from t1 as A, t1 as B where A.b = B.b;
select /*+NO_REWRITE*/ * from t1 as A, t1 as B where A.b = B.b;

select * from t1 as A, t1 as B where A.a = B.b;
select /*+NO_REWRITE*/ * from t1 as A, t1 as B where A.a = B.b;
update t1 as A, t1 as B set A.b = 1 where A.a = B.b;
select * from t1;
rollback;
update /*+NO_REWRITE*/t1 as A, t1 as B set A.b = 1 where A.a = B.b;
select * from t1;
rollback;

select * from t1 as A, t1 as B where A.a = B.a and A.b = B.b;
