### unique key + group-by, order-by, having
select sum(A.b), min(B.b), max(C.b)
          from t5 as A, t5 As B, t5 as C
          where A.a = B.a
            and A.b = C.b
            and B.c = C.c
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
select /*+NO_REWRITE*/ sum(A.b), min(B.b), max(C.b)
          from t5 as A, t5 As B, t5 as C
          where A.a = B.a
            and A.b = C.b
            and B.c = C.c
          group by B.b
          having min(B.b) > 0
          order by max(C.b);

select sum(A.b), min(B.b), max(C.b)
          from t5 as A, t5 as B, t5 as C
          where A.c = B.c and A.b = B.b
            and B.b = C.b
          group by B.b
          having min(B.b) > 0
          order by max(C.b);
select /*+NO_REWRITE*/ sum(A.b), min(B.b), max(C.b)
          from t5 as A, t5 as B, t5 as C
          where A.c = B.c and A.b = B.b
            and B.b = C.b
          group by B.b
          having min(B.b) > 0
          order by max(C.b);


select sum(A.a + B.b + C.c)
          from t5 as A, t5 as B, t5 as C
          where A.c = B.c and A.b = B.b
            and B.a = C.a
          group by B.d
          having sum(A.a + B.b + C.c) > 10;
select /*+NO_REWRITE*/ sum(A.a + B.b + C.c)
          from t5 as A, t5 as B, t5 as C
          where A.c = B.c and A.b = B.b
            and B.a = C.a
          group by B.d
          having sum(A.a + B.b + C.c) > 10;

