## C 消除 P1,P2
select C.a, P1.a, P2.a from tf112 as C, t11 as P1, t12 as P2 where C.a = P1.a and P1.a = P2.a;
select /*+NO_REWRITE*/ C.a, P1.a, P2.a from tf112 as C, t11 as P1, t12 as P2 where C.a = P1.a and P1.a = P2.a;
update tf112 as C, t11 as P1, t12 as P2 set C.d = C.d + 10 where C.a = P1.a and P1.a = P2.a;
select * from tf112;
rollback;
update /*+NO_REWRITE*/tf112 as C, t11 as P1, t12 as P2 set C.d = C.d + 10 where C.a = P1.a and P1.a = P2.a;
select * from tf112;
rollback;
delete C from tf112 as C, t11 as P1, t12 as P2 where C.a = P1.a and P1.a = P2.a;
select * from tf112;
rollback;
delete /*+NO_REWRITE*/C from tf112 as C, t11 as P1, t12 as P2 where C.a = P1.a and P1.a = P2.a;
select * from tf112;
rollback;

