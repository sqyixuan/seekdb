CREATE TABLE `tt1` (
  `c1` binary(69) DEFAULT NULL,
  `c2` char(152) COLLATE utf8mb4_bin NOT NULL,
  `c3` decimal(64,0) NOT NULL,
  `c4` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c5` date DEFAULT NULL,
  `c6` decimal(64,19) DEFAULT NULL,
  `c7` bigint(127) DEFAULT NULL,
  `c8` int(127) NOT NULL,
  `c9` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c10` int(127) NOT NULL,
  `c11` decimal(64,4) NOT NULL,
  PRIMARY KEY (`c8`, `c3`, `c2`, `c11`, `c10`)
) partition by hash(c8)  partitions 20;
CREATE TABLE `tt2` (
  `c1` date DEFAULT NULL,
  `c2` bigint(127) NOT NULL,
  `c3` year(4) DEFAULT NULL,
  `c4` char(152) COLLATE utf8mb4_bin NOT NULL,
  `c5` timestamp(4) NOT NULL DEFAULT '0000-00-00 00:00:00.0000',
  `c6` date DEFAULT NULL,
  `c7` date DEFAULT NULL,
  `c8` int(127) DEFAULT NULL,
  `c9` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c10` bigint(127) DEFAULT NULL,
  `c11` bigint(127) NOT NULL,
  PRIMARY KEY (`c2`, `c11`, `c4`)
) partition by hash(c2+c11) partitions 20;

