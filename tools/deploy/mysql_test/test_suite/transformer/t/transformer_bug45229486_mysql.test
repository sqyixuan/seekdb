## bug: 

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _enable_defensive_check = 2;
sleep 2;
connection default;

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

set session sql_mode='';
create table t1 (a bit(3) primary key) partition by hash (a) partitions 3;
create table t2 (a bit(4) primary key) partition by hash (a) partitions 3;
create table t3 (a bit(3) primary key) partition by hash (a) partitions 3;

insert into t2 values(8);
insert into t3 values(6);

set autocommit=0;

--result_format 4
--explain_protocol 2
insert into t1 select 8;
rollback;

insert into t1 select * from t2;
rollback;

insert into t1 select * from t2 where a = 8;
rollback;

insert into t1 select * from t3;
rollback;

--explain_protocol 0
connection obsys;
alter system set _enable_defensive_check = 1;
connection default;
set autocommit=1;
drop table t1, t2, t3;
