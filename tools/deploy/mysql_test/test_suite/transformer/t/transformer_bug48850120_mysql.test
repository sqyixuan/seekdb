#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

create table t1(c0 varchar(100)collate gb18030_chinese_ci) character set gb18030;
insert into t1 values('中文abc字符');
insert into t1 values('中文ABC字符');
create table t2(c0 varchar(100) collate gb18030_chinese_ci primary key) character set gb18030;
insert into t2 values('中文abc字符');
alter table t1 add constraint 外键 foreign key (c0) references t2(c0);

create table t3(c0 varchar(100), c1 int) character set utf8mb4;
insert into t3 values('中文abc字符', 1);
insert into t3 values('中文ABC字符', 1);
create table t4(c0 varchar(100), c1 int, primary key(c0,c1)) character set utf8mb4;
insert into t4 values('中文abc字符', 1);
alter table t3 add constraint fk2 foreign key (c0, c1) references t4(c0, c1);

--result_format 4
--explain_protocol 2

select p.c0,e.c0 from t2 e inner join t1 p on e.c0 = p.c0;

select p.c0,e.c0 from t2 e left join t1 p on e.c0 = p.c0;

select p.c0,e.c0 from t2 e right join t1 p on e.c0 = p.c0;

select p.c0,e.c0 from t2 e full join t1 p on e.c0 = p.c0;

select c0 from t1 p where exists (select 1 from t2 e where e.c0 = p.c0);

select c0 from t2 p where exists (select 1 from t1 e where e.c0 = p.c0);

select p.c1,e.c1,p.c0,e.c0 from t3 e inner join t4 p on e.c0 = p.c0 and e.c1 = p.c1;

select p.c1,e.c1 from t3 e inner join t4 p on e.c0 = p.c0 and e.c1 = p.c1 and hex(e.c0) = hex(p.c0);

update t1,t2 set t1.c0 = t2.c0 where t1.c0 = t2.c0;

select * from t1;

drop table t1;
drop table t2;
drop table t3;
drop table t4;