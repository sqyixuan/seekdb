SELECT /*+coalesce_aggr*/ MIN(COL_INT_KEY),SUM(CASE WHEN COL_INT_KEY IS NULL THEN 0 ELSE COL_INT_KEY END) AS COLUMN1,AVG(CASE WHEN COL_INT_KEY IS NULL THEN 0 ELSE COL_SMALLINT_KEY END) AS COLUMN2 FROM table30_hash_pk_parts_4_bigint WHERE (COL_MEDIUMINT_KEY = 100000 OR COL_MEDIUMINT <= '') AND COL_INT_KEY = -1000 AND COL_INT_KEY IS NOT NULL GROUP BY COL_INT_KEY ORDER BY 1 ;

SELECT /*+ COALESCE_AGGR*/ COL_INT_KEY +1,
COUNT(CASE WHEN COL_INT_KEY != 
(SELECT COUNT(*) FROM table30_hash_pk_parts_4_bigint B ORDER BY 1 DESC LIMIT 1) THEN ((SELECT COUNT(COL_SMALLINT_KEY) FROM table10_bigint B ORDER BY 1 DESC LIMIT 1)) ELSE COL_INT_KEY END) AS COLUMN1,
SUM(CASE WHEN COL_INT_KEY IS NULL THEN 0 ELSE COL_SMALLINT_KEY END) AS COLUMN2 
FROM table30_hash_pk_parts_4_bigint WHERE 
(COL_INT = 2654646415131313 OR COL_INT_KEY = 40) 
AND COL_INT_KEY = 4 
AND COL_INT_KEY IS NOT NULL 
GROUP BY COL_INT_KEY,COL_SMALLINT_KEY ORDER BY 1;

