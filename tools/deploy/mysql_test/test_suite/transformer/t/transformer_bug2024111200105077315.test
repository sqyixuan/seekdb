# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS join_outer2_t_39_inner, join_outer_new_t_86_inner;
--enable_warnings

CREATE TABLE `join_outer2_t_39_inner` (
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_nokey` varchar(1) DEFAULT NULL,
  KEY `col_datetime_key` (`col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `col_varchar_key` (`col_varchar_key`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = latin1 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `join_outer_new_t_86_inner` (
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_nokey` varchar(1) DEFAULT NULL,
  KEY `col_datetime_key` (`col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `col_varchar_key` (`col_varchar_key`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

--explain_protocol 1
--result_format 4

select *
FROM
  join_outer_new_t_86_inner JOIN_A,
  (
    (
      SELECT
        col_varchar_key
      FROM
        join_outer2_t_39_inner
    )
    UNION
    (
      SELECT
        col_varchar_key
      FROM
        join_outer2_t_39_inner
    )
  ) JOIN_B
WHERE
  JOIN_A.col_varchar_key IN (
    (
      SELECT
        col_varchar_key
      FROM
        join_outer2_t_39_inner
    )
    UNION
    (
      SELECT
        col_varchar_key
      FROM
        join_outer2_t_39_inner
    )
  );

UPDATE
    join_outer_new_t_86_inner JOIN_A
    join (
        (
            select col_varchar_key
            from join_outer2_t_39_inner
        )
        union all
        (
            select col_varchar_key
            from join_outer2_t_39_inner
        )
    ) JOIN_B ON JOIN_A.col_varchar_key != JOIN_B.col_varchar_key
SET 
  JOIN_A.col_varchar_key = JOIN_A.col_varchar_key
WHERE 
  JOIN_A.col_varchar_key not in (
        (
            select col_varchar_key
            from join_outer2_t_39_inner
        )
        union all
        (
            select col_varchar_key
            from join_outer2_t_39_inner
        )
    );

drop table join_outer2_t_39_inner, join_outer_new_t_86_inner;