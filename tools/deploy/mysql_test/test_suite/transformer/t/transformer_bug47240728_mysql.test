#owner: sean.yyj
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 smallint, c4 smallint, c5 varchar(10), c6 varchar(10));
insert into t1(c2,c4,c6) values(2,4,'6');

--explain_protocol 1
--result_format 4

select /*+no_simplify_expr*/ 1 from t1 where ( 1 in (c1, c2) ) and c1 is null;
select /*+no_rewrite*/ 1 from t1 where ( 1 in (c1, c2) ) and c1 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( 1 in (c3, c4) ) and c3 is null;
select /*+no_rewrite*/ 1 from t1 where ( 1 in (c3, c4) ) and c3 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( 1 in (c5, c6) ) and c5 is null;
select /*+no_rewrite*/ 1 from t1 where ( 1 in (c5, c6) ) and c5 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( c1 in (c1, c2, c3, c4, c5, c6) ) and c1 is null;
select /*+no_rewrite*/ 1 from t1 where ( c1 in (c1, c2, c3, c4, c5, c6) ) and c1 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( c2 in (c1, c2, c3, c4, c5, c6) ) and c2 = 2;
select /*+no_rewrite*/ 1 from t1 where ( c2 in (c1, c2, c3, c4, c5, c6) ) and c2 = 2;

select /*+no_simplify_expr*/ 1 from t1 where ( c3 in (c1, c2, c3, c4, c5, c6) ) and c3 is null;
select /*+no_rewrite*/ 1 from t1 where ( c3 in (c1, c2, c3, c4, c5, c6) ) and c3 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( c4 in (c1, c2, c3, c4, c5, c6) ) and c4 = 4;
select /*+no_rewrite*/ 1 from t1 where ( c4 in (c1, c2, c3, c4, c5, c6) ) and c4 = 4;

select /*+no_simplify_expr*/ 1 from t1 where ( c5 in (c1, c2, c3, c4, c5, c6) ) and c5 is null;
select /*+no_rewrite*/ 1 from t1 where ( c5 in (c1, c2, c3, c4, c5, c6) ) and c5 is null;

select /*+no_simplify_expr*/ 1 from t1 where ( (1,2) in ((c1,c3), (c2,c4)) ) and c1 is null;
select /*+no_rewrite*/ 1 from t1 where ( (1,2) in ((c1,c3), (c2,c4)) ) and c1 is null;

drop table t1;
