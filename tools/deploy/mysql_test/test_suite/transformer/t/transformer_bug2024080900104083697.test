# owner: zhuangyifeng.zyf
# onwer group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings

CREATE TABLE t1(c1 INT, c2 INT);
CREATE TABLE t2(c1 INT, c2 INT);
CREATE TABLE t3(c1 INT, c2 INT);

--explain_protocol 1
--result_format 4
--echo # join
--echo # can merge view
SELECT * FROM t1, lateral (SELECT t2.c1 + t1.c1 FROM t2 LEFT JOIN t3 ON t2.c2 = t3.c2);
--echo # can merge view
SELECT * FROM t1, lateral (SELECT t2.c1 + t1.c1 FROM t2 LEFT JOIN t3 ON t2.c2 = t3.c2 WHERE t2.c2 = t1.c1);
--echo # can merge view
SELECT * FROM t1, lateral (SELECT t2.c1 + t1.c1 FROM t2 LEFT JOIN t3 ON t2.c2 = t3.c2 WHERE t2.c2 = t1.c1);
--echo # can not merge view
SELECT * FROM t1, lateral (SELECT t2.c1 + t1.c1 FROM t2 LEFT JOIN t3 ON t2.c2 = t3.c2 + t1.c2);
--echo # semi join, can not merge view
SELECT t1.* FROM t1 LEFT JOIN LATERAL (SELECT t2.* FROM t2 WHERE t2.c1 IN (SELECT t3.c1 FROM t3 WHERE t3.c1 = t1.c1 + t2.c1)) v ON t1.c2 = v.c2;

DROP TABLE IF EXISTS t1, t2, t3;