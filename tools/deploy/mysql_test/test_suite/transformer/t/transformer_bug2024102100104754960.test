# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# desc: =any(empty set) should be overall rewritten as false

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

--result_format 4
--explain_protocol 2

CREATE TABLE t1 (c1 int);

SELECT
  count(
    (select c1 from t1 limit 1) in (select 1 where 0<>0)
  ) over (partition by c1)
FROM t1 WHERE 0<>0 ORDER BY 1;

SELECT /*+no_rewrite*/
  count(
    (select c1 from t1 limit 1) in (select 1 where 0<>0)
  ) over (partition by c1)
FROM t1 WHERE 0<>0 ORDER BY 1;

# the simplest case, should output (0)
SELECT ((SELECT 1) IN (SELECT 1 WHERE false));
SELECT /*+no_rewrite*/ ((SELECT 1) IN (SELECT 1 WHERE false));

SELECT 1 WHERE ((SELECT 1) IN (SELECT 1 WHERE false));
SELECT /*+no_rewrite*/ 1 WHERE ((SELECT 1) IN (SELECT 1 WHERE false));

DROP TABLE t1;