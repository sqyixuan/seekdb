select count(distinct c1), bit_and(c2), c3 from t1 group by c3;
select count(distinct c1), bit_or(c2), c3 from t1 group by c3;
select count(distinct c1), bit_xor(c2), c3 from t1 group by c3;
select count(distinct c1), sum_opnsize(c2), c3 from t1 group by c3;
select count(distinct c1), avg(c2), c3 from t1 group by c3;
select count(distinct c1), std(c2), c3 from t1 group by c3;

select count(distinct c1, c2), min(c2), c3 from t1 group by c3;
select count(distinct c1+c2, c1+c2), min(c2), c3 from t1 group by c3;
select count(distinct c1, c2+1), min(c2), c3 from t1 group by c3;
select count(distinct c1, c2), count(distinct c2, c1, c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;
select count(distinct c2, c1, c2), count(distinct c1, c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;
select count(distinct c2, c1+c2, c1+c2), count(distinct c1+c2, c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;
select count(distinct c1+c2, c2), count(distinct c2, c1+c2, c1+c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;
select GROUP_CONCAT(distinct c1, c2), GROUP_CONCAT(distinct c2, c1, c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;
select GROUP_CONCAT(distinct c1+c2, c2), GROUP_CONCAT(distinct c2, c1+c2, c2), APPROX_COUNT_DISTINCT(c2, c1), c3 from t1 group by c3;

select count(distinct c1), sum(c2) from t1;
select count(distinct c1), sum(distinct c1), sum(c1) from t1;
select count(distinct c1), sum(c2), c3 from t1 group by c3;
select count(distinct c1), sum(c2) from t1 group by c3;
select count(distinct c1), sum(distinct c1), sum(c1), c3 from t1 group by c3;
select count(distinct c1), sum(distinct c1), sum(c2), c3 from t1 group by c3;
select count(distinct c1), sum(distinct c2), sum(c2), c3 from t1 group by c3;
select count(distinct c1), c2+c3 from t1 group by c2+c3;
select count(distinct c1), c2+c3 from t1 group by c2, c3;
select count(distinct c1+c2), sum(distinct c1+c2), sum(c2), c3 from t1 group by c3;
select count(distinct c1+c2), sum(distinct c2+c1), sum(c2), c3 from t1 group by c3;
select count(distinct c1+1), sum(distinct c1+1), sum(c2), c3 from t1 group by c3;
select count(distinct c1+1), sum(distinct c1+2), sum(c2), c3 from t1 group by c3;

select count(distinct c1), sum(c2), c3 from t1 where c1 > 1;
select count(distinct c1), sum(c2), c3, 1, 2 + 3 from t1 where c1 > 1;
select count(distinct c1), sum(c2), c3 from t1 where c1 > 1 having sum(c2) > 2 order by c3 limit 5;
select count(distinct c1), sum(c2), c3 from t1 where c1 > 1 group by c3;
select count(distinct c1), sum(c2), sum(c2), c3 from t1 where c1 > 1 group by c3;
select count(distinct c1), sum(c2), c3 from t1 where c1 > 1 group by c3 having sum(c2) > 2;
select count(distinct c1), sum(c2), c3 from t1 where c1 > 1 group by c3 having sum(c2) > 2 order by c3 limit 5;
select count(distinct c1), sum(c2), c3 from t1 where c1 > 1 group by c2+c3 having c3 > 2 order by c3 limit 5;
select count(distinct c1), sum(c2), c2+c3 s1 from t1 where c1 > 1 group by c2+c3 having s1 > 2 order by c3 limit 5;
select count(distinct c1), sum(c2), c2+c3 s1 from t1 where c1 > 1 group by c2, c3 having s1 > 2 order by c3 limit 5;
select count(distinct c1) from t1 where c1 > 1 group by c3 order by c2 limit 5;
select count(distinct c1), count(c2), c3, max(c3) over (partition by count(c2)) from t1 group by c3;
select count(distinct c1), count(c2), c3, max(count(c3)) over (partition by count(c2)) from t1 group by c3;
select count(distinct c1), count(c2), c3, max(count(distinct c1)) over (partition by count(c2)) from t1 group by c3;
select count(distinct c1), count(c2), c3, max(count(distinct c2)) over (partition by count(c2)) from t1 group by c3;
select count(distinct c1), count(c2), c3, max(count(distinct c1)) over (partition by count(c2)) from t1 where c1 > 1 group by c3 having sum(c2) > 2 order by c3 limit 5;
select count(distinct c1), max(c3) over (partition by count(c2)) from t1 group by c3;
select count(distinct c1), max(count(c2)) over (partition by c3) from t1 group by c3;
select count(distinct c1), max(c3) over (partition by count(distinct c2)) from t1 group by c3;
select count(distinct c1), max(count(distinct c2)) over (partition by c3) from t1 group by c3;
select count(distinct c1), max(sum(c1)) over (partition by c2+c3) from t1 group by c2+c3;

select /*+NO_SIMPLIFY_GROUP_BY*/ sum(distinct 1), sum(c2) from t1;
select /*+NO_SIMPLIFY_GROUP_BY*/ sum(distinct 1), sum(c2) from t1 group by c3;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ SUM(DISTINCT 1);
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ SUM(DISTINCT 1) FROM dual;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ SUM(DISTINCT (TRUNCATE((.1), NULL)));

create table t3(c1 int);
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ SUM(DISTINCT 3) from t3;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ SUM(DISTINCT 3) from t3 group by 1.0;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ COUNT(DISTINCT 3) from t3;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ COUNT(DISTINCT 3) from t3 group by 1.0;
