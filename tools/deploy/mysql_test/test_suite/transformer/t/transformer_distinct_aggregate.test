SELECT /*+NO_SIMPLIFY_GROUP_BY*/ COUNT(DISTINCT 3) from t3;
SELECT /*+NO_SIMPLIFY_GROUP_BY*/ COUNT(DISTINCT 3) from t3 group by 1.0;

--sorted_result
select /*+parallel(3)*/ count(distinct c1), sum(c2), c3 from t1 where c1 > 1 group by c3;

select count(distinct a1) from (select count(distinct c1) a1, sum(c2) a2, c3 a3 from t1 group by c3) v1 group by a2;
select count(distinct a1), sum(distinct a1), sum(a3) from (select count(distinct c1) a1, sum(c2) a2, c3 a3 from t1 group by c3) v1 group by a2;
select avg(b2), sum(distinct b3), b1 from (select count(distinct a1) b1, sum(distinct a1) b2, sum(a3) b3 from (select count(distinct c1) a1, sum(c2) a2, c3 a3 from t1 group by c3) v1 group by a2) v2 group by b1;
select avg(b2), sum(distinct b3), b1 from (select count(distinct a1) b1, sum(distinct a1) b2, sum(a3) b3 from (select count(distinct c1) a1, sum(c2) a2, c3 a3 from t1 where c1 > 5 group by c3 having a2 > 3) v1 where a1 >= 5 group by a2 having b2 < 80) v2 where b2 > 3 group by b1;
select avg(b2), sum(distinct b1) from (select count(distinct a1) b1, sum(distinct a1) b2 from (select count(distinct c1) a1, sum(c2) a2 from t1 where c1 > 5 having sum(c2) > 3) v1 where a1 >= 5 group by a2 having sum(distinct a1) < 80) v2 where b2 > 3;

with RECURSIVE temp AS
(
SELECT count(distinct c1) a1, sum(c2) a2 FROM t1 WHERE c1 > 1 group by c3
UNION ALL
SELECT c.c1, r.a1 FROM t1 c, temp r WHERE c.c1=r.a1 + 10
) SELECT * FROM temp;

select count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3 from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 group by t1.c3+t2.c3 having sum(t2.c2) > 10;
select count(distinct t1.c1), sum(t2.c2), t2.c1, t1.c2 from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 group by t1.c3+t2.c3 having sum(t2.c2) > 10;
select count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3 from t1 left join t2 on t1.c1 = t2.c2 - 2 where t1.c3 > 9 group by t1.c3+t2.c3 having sum(t2.c2) > 10;
select count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3 from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 and exists (select 1 from t2 st2 where t1.c1 = st2.c2 and st2.c2 > 5) group by t1.c3+t2.c3 having sum(t2.c2) > 60832;
select /*+NO_TRANSFORM_DISTINCT_AGG(@"SEL$1") TRANSFORM_DISTINCT_AGG(@"SEL$6FCAE2AA")*/ count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3 from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 and exists (select 1 from t2 st2 where t1.c1 = st2.c2 and st2.c2 > 5) group by t1.c3+t2.c3 having sum(t2.c2) > 60832;
select count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3, (select st1.c3 from t1 st1 where st1.c3 = t1.c3 order by st1.c3 limit 1) from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 group by t1.c3, t2.c3 having (select t1.c3 from t1 st1 where st1.c3 = t1.c3 - 1 order by st1.c3 limit 1) > 5;
select count(distinct t1.c1), sum(t2.c2), t1.c3+t2.c3, (select st1.c3 from t1 st1 where st1.c3 > 5 order by st1.c3 limit 1) from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 group by t1.c3, t2.c3 having (select t1.c3 from t1 st1 where st1.c3 = 5 order by st1.c3 limit 1) >= 5;
select count(distinct t1.c1), sum(v1.c2), t1.c3+v1.c3 from t1 right join t2 on t1.c1 = t2.c2 - 5,  (select st2.c1 c1, st2.c2 c2, st2.c3 c3 from t2 st2 where st2.c2 > 5) v1 where t1.c1 = v1.c2 - 2 and t2.c3 > 9 group by t1.c3+v1.c3 having sum(v1.c2) > 60832;
select count(distinct t1.c1, t2.c2), count(distinct t2.c2, t1.c1), sum(t2.c2), t1.c3+t2.c3 from t1, t2 where t1.c1 = t2.c2 - 2 and t2.c3 > 9 group by t1.c3+t2.c3 having sum(t2.c2) > 10;

select /*+TRANSFORM_DISTINCT_AGG*/ count(distinct c1), sum(c1), c2 from t1 group by c2;
select /*+TRANSFORM_DISTINCT_AGG OPTIMIZER_FEATURES_ENABLE('4.3.4.0')*/ count(distinct c1), sum(c1), c2 from t1 group by c2;
select /*+NO_TRANSFORM_DISTINCT_AGG*/ count(distinct c1), sum(c1), c2 from t1 group by c2;
select /*+TRANSFORM_DISTINCT_AGG(@"SEL$2") NO_TRANSFORM_DISTINCT_AGG(@"SEL$1") */ avg(b2), sum(distinct b3), b1 from (select count(distinct a1) b1, sum(distinct a1) b2, sum(a3) b3 from (select count(distinct c1) a1, sum(c2) a2, c3 a3 from t1 group by c3) v1 group by a2) v2 group by b1;

CREATE TABLE `dmp_market_media_play_rank_dbmusic_xiaomi_mm_pm_test_2` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键ID',
  `deviceid` varchar(100) COLLATE utf8mb4_bin NOT NULL,
  `dev_uuid` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `userid` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `play_cnt` bigint(20) DEFAULT NULL,
  `aid` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `aid_name` text COLLATE utf8mb4_bin DEFAULT NULL,
  `cid` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `album` text COLLATE utf8mb4_bin DEFAULT NULL,
  `songer` text COLLATE utf8mb4_bin DEFAULT NULL,
  `channel` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `play_duration` bigint(20) DEFAULT NULL,
  `is_music_vip` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `is_ktv_vip` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `is_svip` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
  `ym` bigint(20) NOT NULL,
  PRIMARY KEY (`id`, `ym`, `deviceid`)
) AUTO_INCREMENT = 127334506 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(ym) subpartition by key(`deviceid`) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`,
subpartition `p3`,
subpartition `p4`,
subpartition `p5`,
subpartition `p6`,
subpartition `p7`,
subpartition `p8`,
subpartition `p9`,
subpartition `p10`,
subpartition `p11`,
subpartition `p12`,
subpartition `p13`,
subpartition `p14`,
subpartition `p15`,
subpartition `p16`,
subpartition `p17`,
subpartition `p18`,
subpartition `p19`,
subpartition `p20`,
subpartition `p21`,
subpartition `p22`,
subpartition `p23`,
subpartition `p24`,
subpartition `p25`,
subpartition `p26`,
subpartition `p27`,
subpartition `p28`,
subpartition `p29`,
subpartition `p30`,
subpartition `p31`)
(partition `p202410` values less than (202411)) WITH COLUMN GROUP(each column);

select 
  aid,
  aid_name,
  case
  when cid = '1' then '音乐'
  when cid = '3' then 'MV'
end
  as cid,
  count(distinct deviceid, dev_uuid) as play_cnt
from
  dmp_market_media_play_rank_dbmusic_xiaomi_mm_pm_test_2
where
  ym = 202410
group by
  aid,
  aid_name,
  cid;

