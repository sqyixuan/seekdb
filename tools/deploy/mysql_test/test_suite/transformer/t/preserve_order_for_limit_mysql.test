--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1

--disable_query_log
--disable_warnings
DROP TABLE if exists t1,t2,t3,t4, t5, t6;
--enable_query_log
--enable_warnings

create table t1(c1 int, c2 int);

create table t2(c1 int primary key, c2 int);

create table t3(c1 int, c2 int, c3 longtext);

create table t4(c1 int, c2 int);

create table t5(c1 int, c2 int, c3 blob);  

create table t6(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2));

insert into t1 values(2,2);
insert into t1 values(1,1);

insert into t2 values(2,2);
insert into t2 values(1,1);

insert into t3 values(2,2,'xx');
insert into t3 values(1,1,'yy');

insert into t4 values(2,2);
insert into t4 values(1,1);

insert into t5 values(2,2,'xx');
insert into t5 values(1,1,'yy');

insert into t6 values(1, 2, 3, 4);
insert into t6 values(2, 3, 4, 5);

alter system set _preserve_order_for_pagination = 1;

--explain_protocol 2

--sleep 1

begin;
delete from t1 limit 10; 
rollback;

select * from t1 limit 10;

select /*+opt_param('preserve_order_for_pagination' 'false')*/ * from t1 limit 10;

select c2 from (select * from t1 limit 10) limit 5;

select * from t1 order by c1 limit 10;

select /*+use_hash_aggregation no_rewrite*/ c1 from t3 group by c1 order by c1 limit 10;

select * from t3 limit 10;

select * from t1 where c1 in (select c1 from t4 limit 10);

select * from t5 limit 10;

select * from (select * from t5 order by c2 desc) limit 10;

select * from t5 order by c2 desc limit 10;

select * from t1, t2 where t1.c1 != t2.c1 limit 10;

select * from t1, (select * from t2)t2 where t1.c1 != t2.c1 limit 10;

select * from t1, (select * from t2)t2 where t1.c1 != t2.c1 order by t1.c2 desc limit 10;
--sorted_result
select * from (select * from t5) limit 10;

select * from (select * from (select * from t5 order by c2 desc)) limit 10;

select * from ( (select * from t5) union all (select * from t5))  limit 10;

select * from ( select * from (select * from t5 order by c2 desc) union all (select * from t5))  limit 10;

select * from ( select * from (select * from t5 order by c2 desc ) union all select * from (select * from t5 order by c1 desc))  limit 10;

select * from t6 limit 10;

select * from t6 order by c1 limit 10;

select * from t6 order by c2 limit 10;

alter system set _preserve_order_for_pagination = 0;

--sleep 1

begin;
delete from t1 limit 10; 
rollback;

select * from t1 limit 10;

select /*+opt_param('preserve_order_for_pagination' 'true')*/ * from t1 limit 10;

select c2 from (select * from t1 limit 10) limit 5;

select * from t1 order by c1 limit 10;

select /*+use_hash_aggregation no_rewrite*/ c1 from t3 group by c1 order by c1 limit 10;

select * from t3 limit 10;

select * from t1 where c1 in (select c1 from t4 limit 10);

select * from t5 limit 10;

DROP TABLE if exists t1,t2,t3,t4,t5;