
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists `cool_agent_edit_business`;
drop table if exists `testgm4cji`;
drop table if exists `cool_deal_20180822_1`;
drop table if exists `cool_bill_20180926`;
drop table if exists `t1cjbsaz`;
drop table if exists `cool_async_notify`;
drop table if exists `t_sys_cmd`;
--enable_warnings

CREATE TABLE `cool_agent_edit_business` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `business_id` int(11) DEFAULT NULL ,
  `agent_id` int(11) DEFAULT NULL ,
  `admin_ids` varchar(255) DEFAULT NULL ,
  `regtime` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP ,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=10 DEFAULT CHARSET=utf8 ;

create table if not exists `testgm4cji` (
	`c1` int(11) not null,
	`c2` int(11),
	`c3` int(11),
	`c4` char(3),
	primary key (`c1`),
	unique key (`c2`) GLOBAL
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `cool_deal_20180822_1` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=3584557 DEFAULT CHARSET=utf8;

CREATE TABLE `cool_bill_20180926` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

create table if not exists `t1cjbsaz` (
	`c1` varchar(10) not null comment 'c1 comment',
	`c2` int(11),
	`c3` int(11) comment '',
	`c4` int(11),
	`c5` int(11),
	`c6` int(11),
	`c7` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
comment='';
create index `i1` on `t1cjbsaz` (`c1` ASC) ;
create index `i2` on `t1cjbsaz` (`c2` ASC) ;

CREATE TABLE `cool_async_notify` (
  `out_trade_no` varchar(35) NOT NULL ,
  `notify_time` int(11) NOT NULL ,
  `content` text NOT NULL ,
  `times` int(11) DEFAULT '0' ,
  `status` int(11) DEFAULT '0' ,
  PRIMARY KEY (`out_trade_no`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 ;

CREATE TABLE `t_sys_cmd` (
  `cmdID` int(20) NOT NULL AUTO_INCREMENT,
  `cmdName` char(200) DEFAULT NULL COMMENT '命令名称',
  `cmdDisplayName` char(50) DEFAULT NULL COMMENT '命令展示名称',
  `cmdCategoryID` int(20) DEFAULT NULL COMMENT '命令分类ID',
  PRIMARY KEY (`cmdID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='命令表';

--explain_protocol 2
--result_format 4

select 
  1 
from 
  (
    test.cool_agent_edit_business as ref_0 
    left join test.testgm4cji as subq_0 on (
      (
        EXISTS (
          select 
            ref_0.id as c2 
          from 
            test.t1cjbsaz as ref_2 
          where 
              (
                (
                  EXISTS (
                    select 
                      1 
                    from 
                      test.cool_async_notify as ref_3 
                    where 
                      0
                  )
                ) 
                and (subq_0.c1 << 100)
              )
        )
      ) 
      or (
        EXISTS (
          select 
            1 
          from 
            test.t_sys_cmd as ref_4 
          where 
            (subq_0.c1 > ref_4.cmdID)
        )
      )
    )
  ) 
where 
  subq_0.c1 < ref_0.id;

select ref_0.id as c0, cast(coalesce(ref_0.regtime, ref_0.regtime) as DATETIME) as c1, subq_0.c1 as c2 from (test.cool_agent_edit_business as ref_0 left join (select ref_1.c4 as c0, ref_1.c1 as c1 from test.testgm4cji as ref_1 where (select deal_id from test.cool_deal_20180822_1 limit 1 offset 2) - ref_1.c1 limit 79) as subq_0 on (((ref_0.id > ref_0.business_id) or ((EXISTS ( select ref_2.c3 as c0, ref_0.admin_ids as c1, ref_0.id as c2, ref_2.c4 as c3, ref_0.admin_ids as c4, (select max(bill_id) from test.cool_bill_20180926) as c5, subq_0.c1 as c6 from test.t1cjbsaz as ref_2 where (0) or ((ref_2.c5 is NULL) and ((EXISTS ( select ref_2.c4 as c0 from test.cool_async_notify as ref_3 where 0 limit 43)) and (subq_0.c1 << 100))) limit 61)) or (ref_0.id << ref_0.business_id))) or (EXISTS ( select ref_4.cmdID as c0, ref_4.cmdName as c1, ref_0.agent_id as c2, ref_4.cmdDisplayName as c3, ref_0.agent_id as c4, ref_0.agent_id as c5, subq_0.c1 as c6, ref_4.cmdID as c7 from test.t_sys_cmd as ref_4 where (0) or (subq_0.c1 > ref_4.cmdID) limit 99)))) where subq_0.c1 < ref_0.id limit 81 ;

drop table if exists `cool_agent_edit_business`;
drop table if exists `testgm4cji`;
drop table if exists `cool_deal_20180822_1`;
drop table if exists `cool_bill_20180926`;
drop table if exists `t1cjbsaz`;
drop table if exists `cool_async_notify`;
drop table if exists `t_sys_cmd`;