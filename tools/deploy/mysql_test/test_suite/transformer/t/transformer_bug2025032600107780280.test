# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: left to anti 错误触发问题修复

--disable_warnings
drop table if exists t0, t1;
--enable_warnings

CREATE TABLE t0 (c2 INT, PRIMARY KEY (c2));
CREATE TABLE t1 (c0 INT, c1 INT, PRIMARY KEY (c0));
INSERT INTO t0 (c2) VALUES (1);
INSERT INTO t1 (c0, c1) VALUES (1, 0);

--result_format 4
--explain_protocol 2

--echo # 结果应该有一行
SELECT * FROM t0
    RIGHT JOIN (
        SELECT 1 AS col0 FROM t1
    ) AS sub0 ON true, t1
    RIGHT JOIN (
        SELECT t1.c1 = t1.c1 AS col0
        FROM t1
    ) AS sub1 ON ((sub1.col0) = (false));

--echo # 结果应该有一行
SELECT (t1.c0 = t0.c2) IS NULL FROM t0
    RIGHT JOIN (
        SELECT 1 AS col0 FROM t1
    ) AS sub0 ON true,
    t1 RIGHT JOIN (
        SELECT t1.c1 = t1.c1 AS col0 FROM t1
    ) AS sub1 ON ((sub1.col0) = (false));

--echo # 结果应该有一行, 并且不应该触发 left to anti
SELECT * FROM t0
    RIGHT JOIN (
        SELECT 1 AS col0 FROM t1
    ) AS sub0 ON true, t1
    RIGHT JOIN (
        SELECT t1.c1 = t1.c1 AS col0 FROM t1
    ) AS sub1 ON ((sub1.col0) = (false))
    WHERE (t1.c0 = t0.c2) IS NULL;

drop table t0, t1;