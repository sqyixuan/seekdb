# owner: sean.yyj
# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 varchar(10) collate utf8mb4_general_ci, c2 int);
create table t2(c1 varchar(10) collate utf8mb4_general_ci, c2 int);
insert into t1 values('a', 1);
insert into t2 values('a ', 1);

--result_format 4
--explain_protocol 1

--echo # predicate pullup
--echo ------------------------------------------------------------
select * from t1 where c1 = 'a' intersect select * from t2;
select * from t1 where concat(c1,'a') = 'aa' intersect select * from t2;

select * from t1 where c1 = 'a' except select * from t2;
select * from t1 where concat(c1,'a') = 'aa' except select * from t2;

select * from t1 where c2 = 1 intersect select * from t2;
select * from t1 where c2 + 1 = 2 intersect select * from t2;

select * from t1 where c2 = 1 except select * from t2;
select * from t1 where c2 + 1 = 2 except select * from t2;

--echo # predicate pushdown
--echo ------------------------------------------------------------
select * from (select * from t1 intersect select * from t2) v where c1 = 'a';
select /*+no_rewrite*/ * from (select * from t1 intersect select * from t2) v where c1 = 'a';

select * from (select * from t1 intersect select * from t2) v where concat(c1,'a') = 'aa';
select /*+no_rewrite*/ * from (select * from t1 intersect select * from t2) v where concat(c1,'a') = 'aa';

select * from (select * from t1 except select * from t2) v where c1 = 'a';
select /*+no_rewrite*/ * from (select * from t1 except select * from t2) v where c1 = 'a';

select * from (select * from t1 except select * from t2) v where concat(c1,'a') = 'aa';
select /*+no_rewrite*/ * from (select * from t1 except select * from t2) v where concat(c1,'a') = 'aa';

--echo # todo: support pushdown into union
select * from (select * from t1 union select * from t2) v where c1 = 'a';
select /*+no_rewrite*/ * from (select * from t1 union select * from t2) v where c1 = 'a';

select * from (select * from t1 union select * from t2) v where concat(c1,'a') = 'aa';
select /*+no_rewrite*/ * from (select * from t1 union select * from t2) v where concat(c1,'a') = 'aa';


drop table t1,t2;