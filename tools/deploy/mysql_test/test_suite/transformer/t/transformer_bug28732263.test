## simple cases
EXPLAIN
SELECT /*+use_concat*/ 'x'
FROM CC AS table1
WHERE (1 NOT IN
    (SELECT 1
     FROM CC
     WHERE (col_varchar_20 > ANY (SELECT 9 UNION SELECT 2))))
OR col_varchar_key = 's';

SELECT /*+use_concat*/ 'x'
FROM CC AS table1
WHERE (1 NOT IN
    (SELECT 1
     FROM CC
     WHERE (col_varchar_20 > ANY (SELECT 9 UNION SELECT 2))))
OR col_varchar_key = 's';

EXPLAIN
SELECT 'x'
FROM CC AS table1
WHERE (1 NOT IN
    (SELECT 1
     FROM CC
     WHERE (col_varchar_20 > ANY (SELECT 9 UNION SELECT 2))))
OR col_varchar_key = 's';

SELECT 'x'
FROM CC AS table1
WHERE (1 NOT IN
    (SELECT 1
     FROM CC
     WHERE (col_varchar_20 > ANY (SELECT 9 UNION SELECT 2))))
OR col_varchar_key = 's';

## origin cases
SELECT    table2 . col_varchar_key AS field1 FROM ( CC AS table1 LEFT  JOIN CC AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_key`  ) ) WHERE (  ( 'x', 'm' ) NOT IN ( SELECT COUNT(  SUBQUERY1_t1 . `col_varchar_10_key` ) AS SUBQUERY1_field1 , MIN(  SUBQUERY1_t1 . `col_varchar_key` ) AS SUBQUERY1_field2 FROM ( CC AS SUBQUERY1_t1 INNER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_key`  AND SUBQUERY1_t1 . `col_varchar_20` > ANY ( SELECT 9 UNION  SELECT 2 ) ) ) WHERE SUBQUERY1_t1 . `pk` > SUBQUERY1_t2 . `pk`  ) ) OR ( table1 . `col_varchar_key`  IN ('s', 'g') OR table1 . `col_int_key`  BETWEEN 90 AND ( 90 + 47 ) ) AND ( table1 . `col_varchar_10` = table1 . `col_varchar_20_key` AND  table1 . `col_int_key` NOT IN ( SELECT   SUBQUERY2_t1 . `col_int` AS SUBQUERY2_field1 FROM ( CC AS SUBQUERY2_t1 INNER JOIN BB AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`  ) ) WHERE ( SUBQUERY2_t2 . `col_varchar_10_key` <> 'g' AND SUBQUERY2_t2 . `pk` >= 6 ) GROUP BY SUBQUERY2_field1  ) )   ORDER BY 1, field1 LIMIT 100;

SELECT    count(table2 . col_varchar_key) AS field1 FROM ( CC AS table1 LEFT  JOIN CC AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_key`  ) ) WHERE (  ( 'x', 'm' ) NOT IN ( SELECT COUNT(  SUBQUERY1_t1 . `col_varchar_10_key` ) AS SUBQUERY1_field1 , MIN(  SUBQUERY1_t1 . `col_varchar_key` ) AS SUBQUERY1_field2 FROM ( CC AS SUBQUERY1_t1 INNER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_key`  AND SUBQUERY1_t1 . `col_varchar_20` > ANY ( SELECT 9 UNION  SELECT 2 ) ) ) WHERE SUBQUERY1_t1 . `pk` > SUBQUERY1_t2 . `pk`  ) ) OR ( table1 . `col_varchar_key`  IN ('s', 'g') OR table1 . `col_int_key`  BETWEEN 90 AND ( 90 + 47 ) ) AND ( table1 . `col_varchar_10` = table1 . `col_varchar_20_key` AND  table1 . `col_int_key` NOT IN ( SELECT   SUBQUERY2_t1 . `col_int` AS SUBQUERY2_field1 FROM ( CC AS SUBQUERY2_t1 INNER JOIN BB AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`  ) ) WHERE ( SUBQUERY2_t2 . `col_varchar_10_key` <> 'g' AND SUBQUERY2_t2 . `pk` >= 6 ) GROUP BY SUBQUERY2_field1  ) )   ORDER BY 1, field1 LIMIT 100;

DROP TABLE `c`;
DROP TABLE `cc`;
DROP TABLE `bb`;
