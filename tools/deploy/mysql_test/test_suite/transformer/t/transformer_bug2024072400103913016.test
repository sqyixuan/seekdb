--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

--explain_protocol 2
--result_format 4

select
    case when (
        select count(*)
        from t2 
        where  t2.c1 = subq.c1
    ) > 0
    then 1 end
from (
    select sum(c1) over (
        partition by c2
    )  as c1 from t1
) as subq;

drop table t1, t2;

