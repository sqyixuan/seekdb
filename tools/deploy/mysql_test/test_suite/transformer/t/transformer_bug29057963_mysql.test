--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

## 完整case
SELECT DISTINCT OUTR . `col_int` AS X
FROM B AS OUTR
WHERE (OUTR . `col_int`,
       OUTR . `col_int`) IN
    (SELECT INNR . `pk` AS X,
            INNR . `pk` AS Y
     FROM BB AS INNR
     WHERE INNR . `pk` = 1
     ORDER BY INNR . `col_int_key`)
  OR (OUTR . `pk` >= 1
      OR OUTR . `col_datetime` IS NULL)
HAVING X = '2003-06-01 12:06:35'
ORDER BY 1 DESC,
         OUTR . `col_datetime` ,
         OUTR . `pk` DESC
;

## 简化case
SELECT DISTINCT OUTR . `col_int` AS X
FROM B AS OUTR
WHERE OUTR . `col_int` IN
    (SELECT `pk`
     FROM BB
     WHERE `pk` = 1)
  OR OUTR . `pk` >= 1
HAVING X = '2003-06-01 12:06:35'
ORDER BY OUTR . `col_datetime`
;

select c1 
from (
  select c1, c2, c3 from t1 
  union all 
  select c1, c2, c3 from t2
  order by c2)
;

select c1 
from (
  select c1, c2, c3 from t1 
  union all 
  select c2, c1, c3 from t2
  order by c2)
;

DROP TABLE B, BB, t1, t2;