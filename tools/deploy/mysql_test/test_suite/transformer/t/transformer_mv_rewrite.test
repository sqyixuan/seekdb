# partition hint test
create table t7 (c1 int, c2 int) 
partition by range (c1) 
(partition p1 values less than (3),
partition p2 values less than (5),
partition p3 values less than (7));

create materialized view log on t7 with primary key, rowid, sequence (c1, c2) including new values;

insert into t7 values (1,2);
insert into t7 values (2,3);
insert into t7 values (3,4);
insert into t7 values (4,5);
insert into t7 values (5,6);

create materialized view t7_mv1 refresh complete enable query rewrite as select * from t7 where c1 > 2;
create materialized view t7_p1_mv refresh complete enable query rewrite as select * from t7 partition(p1);
--error 0, 9783
create materialized view t7_p2_rt_mav refresh fast on demand enable on query computation enable query rewrite as select count(*) cnt, c1 c1 from t7 partition(p2) group by c1;

set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';

select * from t7;
select * from t7 partition(p1);
select * from t7 partition(p2);
select * from t7 where c1 > 2;
select * from t7 partition(p2) where c1 > 2;

set query_rewrite_integrity = 'ENFORCED';

select count(*) cnt, c1 c1 from t7 partition(p2) group by c1;

insert into t7 values (1,2);
insert into t7 values (2,3);
insert into t7 values (3,4);
insert into t7 values (4,5);
insert into t7 values (5,6);

select count(*) cnt, c1 c1 from t7 partition(p2) group by c1;

# privilege test
connection default;
--error 0,1396
drop user test1;
CREATE USER 'test1' IDENTIFIED BY 'test1';
GRANT ALL PRIVILEGES ON test.t1 TO 'test1'@'%' IDENTIFIED BY 'test1';
connect (conn_test1,$OBMYSQL_MS0,test1,test1,test,$OBMYSQL_PORT);
connection default;
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
--echo should be rewrited by t1_mv2
select * from t1;

connection conn_test1;
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
--echo should NOT be rewrited by t1_mv2
select * from t1;
--echo should NOT be rewrited by t1_mv2
select * from t1 where t1.c1 > 1;

connection default;
GRANT SELECT ON test.t1_mv2 TO test1;

connection conn_test1;
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
--echo should be rewrited by t1_mv2
select * from t1;
--echo should be rewrited by t1_mv2
select * from t1 where t1.c1 > 1;

connection default;
REVOKE SELECT ON test.t1_mv2 FROM test1;

connection conn_test1;
set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
--echo should NOT be rewrited by t1_mv2
select * from t1;
--echo should NOT be rewrited by t1_mv2
select * from t1 where t1.c1 > 1;

connection default;
drop user test1;


