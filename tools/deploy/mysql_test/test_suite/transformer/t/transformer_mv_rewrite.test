drop view t1_view;

create table t1 (c1 int primary key, c2 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
insert into t1 values (3,4);

create table t2 (c1 int primary key, c2 int);
insert into t2 values (1,2);
insert into t2 values (2,4);
insert into t2 values (3,6);

create table t3 (c1 int primary key, c2 int, c3 int, c4 int);
insert into t3 values (1,2,3,4);
insert into t3 values (2,4,6,8);
insert into t3 values (3,2,2,6);
insert into t3 values (4,4,4,7);

CREATE VIEW t1_view AS SELECT * FROM t1;

create materialized view log on t1 with primary key, rowid, sequence (c2) including new values;
create materialized view log on t2 with primary key, rowid, sequence (c2) including new values;
create materialized view log on t3 with primary key, rowid, sequence (c2,c3,c4) including new values;

create materialized view t1_mv1 as select * from t1;
select rewrite_enabled, on_query_computation from oceanbase.dba_mviews where mview_name = 'T1_MV1';
create materialized view t1_mv2 refresh complete enable query rewrite as select * from t1;
select rewrite_enabled, on_query_computation from oceanbase.dba_mviews where mview_name = 'T1_MV2';
create materialized view t1_rt_mav refresh fast on demand enable on query computation enable query rewrite as select count(*) cnt, c1 c1 from t1 group by c1;
select rewrite_enabled, on_query_computation from oceanbase.dba_mviews where mview_name = 'T1_RT_MAV';

connection conn_sys;
select rewrite_enabled, on_query_computation from oceanbase.cdb_mviews where mview_name = 'T1_MV1';
select rewrite_enabled, on_query_computation from oceanbase.cdb_mviews where mview_name = 'T1_MV2';
select rewrite_enabled, on_query_computation from oceanbase.cdb_mviews where mview_name = 'T1_RT_MAV';

connection default;
create materialized view t2_mv1 refresh complete enable query rewrite as select * from t2 where t2.c1 > 1 order by t2.c2;
create materialized view t2_mv2 refresh complete enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > 1);
create materialized view t2_mv3 refresh complete enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > t2.c1);
create materialized view t2_mv4 refresh complete enable query rewrite as select * from t2 where t2.c1 >= 2;

create materialized view t1_t2_mv1 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;
create materialized view t1_t2_mv2 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 1;

create materialized view t1_t2_rt_mjv refresh complete enable on query computation enable query rewrite as select t1.c1 t1c1, t2.c1 t2c1, t2.c2 t2c2 from t1, t2 where t1.c1 = t2.c2;

create materialized view t3_mv1 refresh complete enable query rewrite as select c1 c1, c2+c3 c2p3, c3+1 c31, 5*c4 c4t5 from t3;
create materialized view t3_mav_1 refresh complete enable query rewrite as select c1, c2, c3, sum(c4) sc4, count(c4) cc4 from t3 group by c1, c2, c3;
create materialized view t3_rt_mav_1 refresh fast on demand enable on query computation enable query rewrite as select count(1) cntc1, count(c3), c1 c1, count(*) from t3 group by c1;
create materialized view t3_rt_mav_2 refresh fast on demand enable on query computation enable query rewrite as select count(c3) cntc1, sum(c3), c1 c1, c2, count(*) from t3 group by c1, c2;


--result_format 4
--explain_protocol 1
--enable_sorted_result

set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';

# query with same or more condition
select * from t1;
select * from t1 where t1.c1 > 1 and c2 < 4;
select c1 + c2 from t1;
select c1 + c2 from t1 where t1.c1 > 1 and c2 < 4;
select c1 + c2 from t1 where t1.c1 > 1 and c2 < 4 order by c1;
select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2;
select t1.c2, t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1;
select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 in (1,3,5);
select c1 ac1, c1+5*c4 ac2, (c2+c3)-c1 ac3 from t3 where c3+1 > 1;
select * from t2 where t2.c1 > 1;
select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 1;
select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 0; # not support now
select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 = 2; # not support now
select t1.c1 t1c1, t1.c2 t1c2, t2.c2 t2c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c2 > 1; # not support now

# const param constraints test
select * from t2 where t2.c1 >= 2;
select * from t2 where t2.c1 >= 1;
select * from t2 where t2.c1 >= 3;

# query with subquery
create materialized view t2_mv5 refresh complete enable query rewrite as select t2.*, (select t3.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2;
create materialized view t2_mv6 refresh complete enable query rewrite as select t2.*, (select t2.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2;
create materialized view t2_mv7 refresh complete enable query rewrite as select t2.*, (select t3.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2 where exists(select 1 from t3 where t3.c1 > 1);
create materialized view t2_mv8 refresh complete enable query rewrite as select t2.*, vt3.c1 vc1 from t2, (select t3.c1 from t3 where t3.c1 > 1) vt3;

select * from t2 where t2.c1 > 1 and exists(select 1 from t3 where t3.c1 > 1);
select * from t2 where exists(select 1 from t3 where t3.c1 > t2.c1); # not support now
select t2.*, (select t3.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2;
select /*+mv_rewrite(t2_mv6)*/ t2.*, (select t2.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2;
select /*+mv_rewrite(t2_mv7)*/ t2.*, (select t3.c1 from t3 where t3.c1 > 1 order by 1 limit 1) from t2 where exists(select 1 from t3 where t3.c1 > 1);
select /*+mv_rewrite(t2_mv8)*/ t2.*, vt3.c1 vc1 from t2, (select /*+no_mv_rewrite*/ t3.c1 from t3 where t3.c1 > 1) vt3;
select /*+mv_rewrite(t2_mv8)*/ t2.*, vt3.c1 vc1 from t2, (select /*+no_mv_rewrite*/ t3.c1 from t3 where t3.c1 > 2) vt3;
select /*+mv_rewrite(t2_mv8)*/ t2.*, vt3.c1 vc1 from t2, (select /*+no_mv_rewrite*/ t3.c1 from t3 where t3.c2 > 1) vt3;
drop materialized view t2_mv5;
drop materialized view t2_mv6;
drop materialized view t2_mv7;
drop materialized view t2_mv8;

# query with view
select * from t1_view;
select t1_view.* from t1_view, t2 where t2.c1 = t1_view.c1;

# query in subquery
select * from t2 where exists(select t1.c1 from t1 where t1.c1 > 1);
select * from t2 where exists(select t1.c1 from t1 where t1.c1 > t2.c1); 
select /*+mv_rewrite(t2_mv1)*/ * from t2 where t2.c1 in (select /*+no_mv_rewrite*/ t1.c1 from t1 where t1.c1 > 1); # not support now
select /*+mv_rewrite(t2_mv1)*/ * from t2 where t2.c1 > 1 and exists(select /*+no_mv_rewrite*/ t1.c1 from t1 where t1.c1 > t2.c1); # not support now

# query with union
select t1.c1 from t1 where t1.c1 > 1 union all select t1.c1 from t1 where t1.c1 > 2;
select count(t1.c2) from t1 where t1.c1 > 1 group by t1.c1 union all (select t1.c1 from t1 where t1.c1 > 2 order by t1.c2 * t1.c2);

# query with aggregation
select count(c1 + c2) from t1;
select sum(t1.c1) from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2;
select sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2 having sum(t1.c1) < 3;
select sum(t1.c2), t1.c1 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t1.c1 having count(t2.c2) < 3;
select count(t1.c1), t1.c2 from t1 join t2 on t1.c1 = t2.c2 where t1.c1 > 1 group by t1.c2;

# query can not be rewrite
select t1.c1 from t1 for update;
commit;
select sum(t1.c1) from t1, t2 where t1.c1 = t2.c2 group by t2.c2 with rollup;

# drop mv test
drop materialized view t1_mv2;
drop materialized view t2_mv2;

select * from t1;
select * from t1 where t1.c1 > 1 and c2 < 4;
select * from t2 where t2.c1 > 1 and exists(select 1 from t3 where t3.c1 > 1);

create materialized view t1_mv2 refresh complete enable query rewrite as select * from t1;
create materialized view t2_mv2 refresh complete enable query rewrite as select * from t2 where exists(select 1 from t3 where t3.c1 > 1);

select * from t1;
select * from t1 where t1.c1 > 1 and c2 < 4;
select * from t2 where t2.c1 > 1 and exists(select 1 from t3 where t3.c1 > 1);

# query real time mview test
set query_rewrite_integrity = 'ENFORCED';

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select t1.c1, t1.c2 from t1, t2 where t1.c1 = t2.c2; # can not rewrite, t1.c2 not in real time mv
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 and t2.c2 in (select c3 from t3) group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), count(1) over (partition by sum(t1.c1)) from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 and t2.c2 in (select c3 from t3) group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2 limit 5;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select c1, count(1), count(c3) from t3 where c1 > 2 group by c1 order by c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select c1, avg(c3) from t3 where c1 > 2 group by c1 order by c1;

insert into t1 values (4,6);
insert into t1 values (5,5);
insert into t1 values (6,6);
insert into t2 values (4,3);
insert into t2 values (5,6);
insert into t2 values (6,7);
insert into t3 values (5,2,2,6);
insert into t3 values (6,4,4,7);

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 and t2.c2 in (select c3 from t3) group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select distinct sum(t1.c1), count(1) over (partition by sum(t1.c1)) from t1, t2 where t1.c1 = t2.c2 and t1.c1 > 1 and t2.c2 in (select c3 from t3) group by t2.c2 having max(t2.c1) > 2 order by 1-t2.c2 limit 5;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select c1, count(1), count(c3) from t3 where c1 > 2 group by c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select c1, avg(c3) from t3 where c1 > 2 group by c1;

set query_rewrite_enabled = 'TRUE';
set query_rewrite_integrity = 'STALE_TOLERATED';

call dbms_mview.refresh('T1_MV2', 'c');
call dbms_mview.refresh('T1_RT_MAV', 'c');
call dbms_mview.refresh('t2_mv1', 'c');
call dbms_mview.refresh('t2_mv2', 'c');
call dbms_mview.refresh('t2_mv3', 'c');
call dbms_mview.refresh('t2_mv4', 'c');
call dbms_mview.refresh('t1_t2_mv1', 'c');
call dbms_mview.refresh('t1_t2_mv2', 'c');
call dbms_mview.refresh('t1_t2_rt_mjv', 'c');
call dbms_mview.refresh('t3_mv1', 'c');
call dbms_mview.refresh('t3_mav_1', 'c');
call dbms_mview.refresh('t3_rt_mav_1', 'c');
call dbms_mview.refresh('t3_rt_mav_2', 'c');

# rule/cost check test
create index idx_t1_mv2 on t1_mv2(c1,c2);
create index idx_t1_t2_rt_mjv on t1_t2_rt_mjv(t1c1);

select * from t1 where t1.c1 > 1 and c2 < 4;
select c1 + c2 from t1 where t1.c1 > 1 and c2 < 4 order by c1;
select * from t2 where exists(select t1.c1 from t1 where t1.c1 > t2.c1); 
select t1.c1, t2.c2 from t1, t2 where t1.c1 = t2.c2 and t1.c1 in (1,3,5);
select t1.c1, t2.c2, sum(t1.c2) from t1, t2 where t1.c1 = t2.c2 group by t1.c1, t2.c2 having sum(t1.c2) > 2;


# query hint test
select * from t1 where t1.c1 > 1;
select /*+ mv_rewrite */ * from t1 where t1.c1 > 1;
select /*+ mv_rewrite(t1_mv1) */ * from t1 where t1.c1 > 1;
select /*+ mv_rewrite(t1_mv1, t1_mv2) */ * from t1 where t1.c1 > 1;

select c1 from t1;
select /*+ no_mv_rewrite */ c1 from t1;

# optimizer features control test
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.1.0') */ * from t1 where t1.c1 > 1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.0.0') */ * from t1 where t1.c1 > 1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.2.4.0') */ * from t1 where t1.c1 > 1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.2.0') mv_rewrite(t1_mv2) */ * from t1, t3 where t1.c1 > 1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.3.0') mv_rewrite(t1_mv2) */ * from t1, t3 where t1.c1 > 1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.2.0') mv_rewrite(t3_mav_1) */ c1, count(c4) cc4 from t3 group by c1, c2, c3;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.3.0') mv_rewrite(t3_mav_1) */ c1, count(c4) cc4 from t3 group by c1, c2, c3;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.2.0') mv_rewrite(t3_mav_1) */ c1, avg(c4) from t3 group by c1;
select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.3.0') mv_rewrite(t3_mav_1) */ c1, avg(c4) from t3 group by c1;

# collection scene test
set query_rewrite_enabled = 'TRUE';
set query_rewrite_integrity = 'ENFORCED';

--error 0, 1146
drop materialized view log on collect_info;
--error 0, 1051
drop table collect_info;
--error 0, 1146
drop materialized view log on collect_item;
--error 0, 1051
drop table collect_item;
--error 0, 9757
drop materialized view collect_mv;

create table collect_info(
  user_id int,
  item_id int,
  user_name varchar(1000),
  primary key(user_id, item_id)
  ) partition by hash(user_id) partitions 1024;

create table collect_item(
  item_id int,
  item_type int,
  price int,
  pic_url varchar(1000),
  primary key(item_id)
  ) partition by hash(item_id) partitions 16;

create materialized view log on collect_info with primary key, rowid, sequence (user_name) including new values;
create materialized view log on collect_item with primary key, rowid, sequence (item_type, price, pic_url) including new values;
create materialized view collect_mv refresh complete enable on query computation enable query rewrite as select collect_info.user_id uid, collect_info.item_id uiid, collect_item.item_id iid, collect_item.item_type itype, collect_item.price price, collect_item.pic_url pic from collect_info, collect_item where collect_info.item_id = collect_item.item_id;
create index idx_collect_mv on collect_mv(uid);

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select collect_info.user_id uid, collect_item.* from collect_info, collect_item where collect_info.item_id = collect_item.item_id and user_id = 10010;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select collect_info.user_id uid, collect_item.item_type, count(1) from collect_info, collect_item where collect_info.item_id = collect_item.item_id and user_id = 10010 group by collect_item.item_type;

