set query_rewrite_enabled = 'FORCE';
set query_rewrite_integrity = 'STALE_TOLERATED';
create materialized view t1_mav_2 refresh complete enable query rewrite as select count(c2) cnt, avg(c2) avg,  c1 c1 from t1 group by c1;
create materialized view t1_mav_3 refresh complete enable query rewrite as select sum(c1) sc1, sum(c2) sc2, count(c1) cc1 from t1;
create materialized view t1_mav_4 refresh complete enable query rewrite as select sum(c1+c2) sc1, sum(c2) sc2, count(c1+c2) cc1 from t1;
create materialized view t1_mav_5 refresh complete enable query rewrite as select sum(c2) sc2, sum(distinct c2) sdc2, count(c2) cc2, count(distinct c2) cdc2, MAX(c2) mc2, MAX(distinct c2) maxdc2, MIN(distinct c2) mindc2, BIT_AND(c2) bc2, c1 from t1 group by c1;
create materialized view t1_t2_mv3 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c1 t2c1, t2.c2 t2c2 from t1 left join t2 on t1.c1 = t2.c2;
create materialized view t1_t2_mv4 refresh complete enable query rewrite as select t1.c1 t1c1, t1.c2 t1c2, t2.c1 t2c1, t2.c2 t2c2 from t1 full outer join t2 on t1.c1 = t2.c2 where t1.c1 > 1;
create materialized view multi_t1_mv1 refresh complete enable query rewrite as select a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, a3.c2 a3c2 from t1 a1, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
create materialized view multi_t1_t2_mv1 refresh complete enable query rewrite as select a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1;
create materialized view multi_t1_t2_mv2 refresh complete enable query rewrite as select a2.c1 a2c1, a2.c2 a2c2, b1.c1 b1c1, b1.c2 b1c2, b2.c2 b2c2, a4.c1 a4c1 from t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a2.c1 = b1.c2;
create materialized view t1_t2_rt_mav_1 refresh fast on demand enable on query computation enable query rewrite as
select a.c1 as group_col, count(*) cnt, sum(b.c1), count(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1;
create materialized view t1_t2_rt_mav_2 refresh fast on demand enable on query computation enable query rewrite as
select a.c1 as group_col1, b.c2 as group_col2, c.c1 as group_col3, count(*) cnt, sum(b.c1), count(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1, b.c2, c.c1;

# multi table test
select /*+mv_rewrite(multi_t1_mv1)*/ a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, a3.c2 a3c2 from t1 a1, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a2.c2 from t1 a1, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1 a2c1, a2.c2 a2c2, a1.c2 a1c2, a3.c2 a3c2 from t1 a1 left join t1 a3 on a1.c1 = a3.c2, t1 a2 where a2.c1 = a1.c1;
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1;
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t2 b1 inner join t1 a4 on a4.c1 = b1.c2, t1 a2 left join t2 b2 on a2.c1 = b2.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1;
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c1 a1c1, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t2 b1, t1 a4, t1 a2 left join t2 b2 on a2.c1 = b2.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1 and a1.c1 = b1.c2 and a4.c1 = a1.c1;  # reach base table map try limit
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c1 a1c1, b1.c1 b1c1, b2.c2 b2c2 from t1 a1, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t2 b1, t1 a4 where a1.c1 = a2.c1 and a1.c2 = a4.c1 and a1.c1 = b1.c2 and a4.c1 = a1.c1;  # reach base table map try limit
select /*+mv_rewrite(multi_t1_t2_mv2)*/ a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a2.c1 = b1.c2;
select /*+mv_rewrite(multi_t1_t2_mv2)*/ a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a4 inner join t2 b1 on a4.c1 = b1.c2, t1 a2 left join t2 b2 on a2.c1 = b2.c2 where a2.c1 = b1.c2;
select /*+mv_rewrite(multi_t1_t2_mv2)*/ a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a4, t2 b1, t2 b2 right join t1 a2 on a2.c1 = b2.c2 where a2.c1 = b1.c2 and a4.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_t2_mv2)*/ a2.c2 a2c2 from t1 a4 inner join t2 b1 on a4.c1 = b1.c1, t1 a2 left join t2 b2 on a2.c1 = b2.c2 where a2.c1 = b1.c2 and b1.c1 = a2.c1;

# delta table test
select /*+mv_rewrite(t2_mv4)*/ t1.c1, t2.c1, t2.c2 from t1, t2 where t2.c1 >= 2 and t1.c1 = t2.c1 order by t2.c2;
select /*+mv_rewrite(t2_mv4)*/ t1.c1, t2.c1, t2.c2 from t2 left join t1 on t1.c1 = t2.c1 where t2.c1 >= 2 order by t2.c2;
select /*+mv_rewrite(t2_mv4)*/ t1.c1, t2.c1, t2.c2 from t1 right join t2 on t1.c1 = t2.c1 where t2.c1 >= 2 order by t2.c2;
select /*+mv_rewrite(t1_t2_mv1)*/ t1.c1, a1.c1, t2.c2 from t1, t2, t1 a1 where a1.c1 = t2.c2 and t1.c2 = a1.c1;
select /*+mv_rewrite(t1_t2_mv1)*/ t1.c1, a1.c1, t2.c2 from t1, t2, t1 a1 where t1.c2 = t2.c2 and t1.c2 = a1.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a4.c1 from t1 a1 left join t1 a4 on a1.c1 = a4.c2, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a4.c1 from t1 a1 left join t2 a4 on a1.c1 = a4.c2, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a4.c1 from t2 a1 left join t1 a4 on a1.c1 = a4.c2, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a3.c1, a4.c1 from t1 a1 left join t1 a4 on a1.c1 = a4.c2, t1 a2 right join t1 a3 on a3.c1 = a2.c2 where a1.c1 = a3.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a4.c1 from t1 a1, t1 a2 left join t1 a3 on a2.c1 = a3.c2, t1 a4 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_mv1)*/ a2.c1, a4.c1 from t1 a1 inner join t1 a4 on a1.c2 = a4.c2, t1 a2 left join t1 a3 on a2.c1 = a3.c2 where a1.c1 = a2.c1;
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c1 a1c1, a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1 inner join t2 b3 on a1.c1 = b3.c2, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a1.c1 = a2.c1 and a1.c2 = a4.c1;
select /*+mv_rewrite(multi_t1_t2_mv1)*/ a1.c2 a1c2, a2.c2 a2c2, b1.c1 b1c1, b2.c2 b2c2 from t1 a1 inner join t2 b3 on a1.c1 = b3.c2, t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a4.c1 = a2.c1 and a1.c1 = a4.c2;               # reach base table map try limit
select /*+mv_rewrite(multi_t1_t2_mv2)*/ a2.c1 a2c1, a2.c2 a2c2, b2.c1 b2c1, b2.c2 b2c2, a22.c2 a22c2, b22.c2 b22c2 from t1 a2 left join t2 b2 on a2.c1 = b2.c2, t1 a22 left join t2 b22 on a22.c1 = b22.c2, t1 a4 inner join t2 b1 on a4.c1 = b1.c2 where a22.c1 = b1.c2; # reach base table map try limit

# join compatibility test
select /*+mv_rewrite(t1_t2_mv3, t1_t2_mv4)*/ t1.c1, t2.c2 from t1 inner join t2 on t1.c1 = t2.c2;
select /*+mv_rewrite(t1_t2_mv4)*/ t1.c1, t2.c2 from t1 left join t2 on t1.c1 = t2.c2 where t1.c1>1;
select /*+mv_rewrite(t1_t2_mv4)*/ t1.c1, t2.c2 from t1 inner join t2 on t1.c1 = t2.c2 where t1.c1>1;
select /*+mv_rewrite(t1_t2_mv3, t1_t2_mv4)*/ t1.c1, t2.c2 from t1 right join t2 on t1.c1 = t2.c2 where t1.c1>1;
select /*+mv_rewrite(t1_t2_mv3, t1_t2_mv4)*/ a1.c1, t1.c1, t2.c2 from t1 a1, t1, t2 where t1.c1 = t2.c2 and a1.c1>1;

# aggregate roll up test
select /*+mv_rewrite(t3_mav_1)*/ sum(c4), count(c4) from t3 group by c1, c2;
select /*+mv_rewrite(t3_mav_1)*/ sum(c4), count(c4) from t3 group by c1;
select /*+mv_rewrite(t3_mav_1)*/ c1, sum(c4), count(c4) from t3 where c2 = 2 and c3 = 3 group by c1;
select /*+mv_rewrite(t3_mav_1)*/ c1, sum(c4), count(c4) from t3 where c2 = 2 and c4 = 4 group by c1; # should not be rewrite
select /*+mv_rewrite(t3_mav_1)*/ c1, sum(c4), count(c4) from t3 where c2 + c3 > 5 group by c1;
select /*+mv_rewrite(t3_mav_1)*/ c1, c2, c3, sum(c4) sc4, count(c4) cc4 from t3 group by c1, c2, c3 with rollup;
select /*+mv_rewrite(t3_mav_1)*/ sum(c4), count(c4) from t3 group by c1, c2 with rollup;
select /*+mv_rewrite(t3_mav_1)*/ grouping(c1), grouping(c2), sum(c4), count(c4) from t3 group by c1, c2 with rollup;
select /*+mv_rewrite(t3_mav_1)*/ c1, sum(c4), count(c4) from t3 where c2 = 2 and c3 = 3 group by c1 with rollup;
set query_rewrite_integrity = 'ENFORCED';
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_1)*/ a.c1 as group_col, count(*) cnt, sum(b.c1), count(b.c1) from t1 b, t2 c, t1 a where c.c2 = b.c1 and a.c1 = b.c2 group by a.c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_1)*/ count(*) from t1 b, t2 c, t1 a where c.c2 = b.c1 and a.c1 = b.c2;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_2)*/ a.c1 as group_col1, b.c2 as group_col2, c.c1 as group_col3, count(*) cnt, sum(b.c1), count(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1, b.c2, c.c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_2)*/ a.c1, count(*), avg(b.c1) from t1 a, t1 b inner join t2 c on c.c2 = b.c1  where a.c1 = b.c2 group by a.c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_2)*/ a.c1, c.c1, rank() over(partition by count(*))  from t1 b inner join t1 a on a.c1 = b.c2, t2 c where c.c2 = b.c1 group by c.c1, a.c1;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
select /*+mv_rewrite(t1_t2_rt_mav_2)*/ a.c1, c.c1, rank() over(partition by count(*))  from t1 b inner join t1 a on a.c1 = b.c2, t2 c where c.c2 = b.c1 group by c.c1, a.c1 with rollup;
set query_rewrite_integrity = 'STALE_TOLERATED';

# aggregate function calculate test
select /*+mv_rewrite(t1_mav_2)*/ sum(c2) from t1 group by c1;
select /*+mv_rewrite(t1_mav_3)*/ avg(c1) from t1;
select /*+mv_rewrite(t1_mav_4)*/ avg(c1+c2) from t1;
select /*+mv_rewrite(t1_mav_3)*/ sum(c1+c2) from t1;
select /*+mv_rewrite(t1_mav_3)*/ sum(c1+c2-c1), sum(c1-(c2-c1)+c2) from t1;
select /*+mv_rewrite(t1_mav_3)*/ sum(c1*c2) from t1; # should not be rewrite
select /*+mv_rewrite(t1_mav_3)*/ sum(c1*(c1+c2)) from t1; # should not be rewrite
select /*+mv_rewrite(t1_mav_5)*/ avg(c2), MAX(c2), MAX(DISTINCT c2), BIT_AND(c2) from t1 group by c1;
select /*+mv_rewrite(t1_mav_5)*/ avg(c2), MAX(c2), MAX(DISTINCT c2), BIT_AND(c2) from t1;
select /*+mv_rewrite(t1_mav_5)*/ avg(DISTINCT c2) from t1; # should not be rewrite
select /*+mv_rewrite(t1_mav_5)*/ min(DISTINCT c2) from t1;



create table t4 (c1 int primary key, c2 int);
insert into t4 values (1,2);
insert into t4 values (2,3);
insert into t4 values (3,4);
insert into t4 values (4,5);
insert into t4 values (5,6);
insert into t4 values (6,7);
insert into t4 values (8,9);
insert into t4 values (9,9);

create table t5 (c1 int not null, c2 int, c3 int);
insert into t5 values (1,2,1);
insert into t5 values (2,4,1);
insert into t5 values (4,3,1);
insert into t5 values (5,5,1);
insert into t5 values (6,6,1);
insert into t5 values (7,6,1);
insert into t5 values (8,6,1);
insert into t5 values (8,9,1);

create table t6 (c1 int, c2 int, c3 int, c4 int);
insert into t6 values (1,2,3,4);
insert into t6 values (2,4,6,8);
insert into t6 values (3,6,9,18);
insert into t6 values (4,8,18,28);
insert into t6 values (5,10,36,38);
insert into t6 values (6,12,64,48);

create materialized view log on t4 with primary key, rowid, sequence (c2) including new values;
create materialized view log on t5 with primary key, rowid, sequence (c1,c2,c3) including new values;
create materialized view log on t6 with primary key, rowid, sequence (c1,c2,c3,c4) including new values;

create materialized view t4_t5_mv1 refresh complete enable query rewrite as
select t4.c1 t4c1, t5.c1 t5c1, t5.c2 t5c2, count(1), count(t5.c3) from t4 left join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c1, t5.c2;

# test join condition
select t1.c1, t6.c1 from t1 inner join t6 on t1.c1 = t6.c1 and t1.c1 > 1 and t6.c1 > 1 where t6.c2 > t1.c2 and t1.c2 > 3 and t6.c3 > 3;
select t1.c1, t6.c1 from t1 left join t6 on t1.c1 = t6.c1 and t1.c1 > 1 and t6.c1 > 1 where t1.c2 > 3;
select t1.c1, t6.c1 from t1 right join t6 on t1.c1 = t6.c1 and t1.c1 > 1 and t6.c1 > 1 where t6.c3 > 3;
select t1.c1, t6.c1 from t1 full join t6 on t1.c1 = t6.c1 and t1.c1 > 1 and t6.c1 > 1 where t6.c3 > 3 or t6.c3 is NULL;
select * from t1 where t1.c1 =  t1.c1;
select * from t1 where t1.c1 in (c1);
select t6.* from t6 left join t1 on true WHERE false;
select t6.* from t6 left join t1 on false WHERE true;
select t6.* from t6 full join t1 on true WHERE false;
select t6.* from t6 full join t1 on false WHERE true;

# test aggregate roll up with compensation predicates
select t4.c1, t5.c1, count(1) from t4 left join t5 on t4.c2 = t5.c2 where t5.c2 > 1 group by t4.c1, t5.c1;
select count(1), count(1) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c2;
select count(t5.c3), count(t5.c3) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c2;
select t4.c1, t5.c2, count(1) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c2;
select t4.c1, t5.c2, count(1) from t5 inner join t4 on t4.c2 = t4.c1 where t4.c1 = t5.c2 group by t4.c1, t5.c2;
select t4.c1, count(1), count(t5.c3) from t4 inner join t5 on t4.c2 = t5.c2 where t5.c2 > 1 group by t4.c1 order by t4.c1;
select t4.c1, count(1), count(t5.c3) from t4 left join t5 on t4.c2 = t5.c2 where t4.c1 > 3 group by t4.c1 order by t4.c1;
select t4.c1, t5.c1, t5.c2, count(1) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c1, t5.c2;

# test query with window function
select sum(count(1)) over(partition by t4.c1), sum(count(1)) over(partition by t4.c1) from t4 left join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c1, t5.c2;
select t4.c1 t4c1, t5.c1 t5c1, t5.c2 t5c2, sum(count(1)) over(partition by t4.c1), MAX(count(t5.c3)) over(partition by t5.c2) from t4 left join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c1, t5.c2;
select t4.c1, t5.c2, count(count(t5.c3)) over(partition by count(1)), count(1) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c2;
select distinct t4.c1, t5.c2, count(count(t5.c3)) over(partition by count(1)), count(count(t5.c3)) over(partition by count(1)), count(t5.c3), count(1) from t4 inner join t5 on t4.c2 = t5.c2 group by t4.c1, t5.c2 having count(1) < 2 order by t4.c1 + t5.c2 desc limit 3 offset 2;


drop materialized view t4_t5_mv1;



