CREATE MATERIALIZED VIEW BUG_MV14_SGP parallel 3 refresh complete enable QUERY rewrite AS select OUTR .*, sum(OUTR.col_int_key) as sck, sum(OUTR.col_int) as sc, count(OUTR.col_int_key) as ck, count(OUTR.col_int) as ci, avg(OUTR.col_int) as ac, avg(OUTR.col_int_key) as ak, count(*) as c from BUG_C OUTR;
SELECT AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR;
SELECT AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR WHERE 1=0;
CREATE MATERIALIZED VIEW BUG_MV14_NGP parallel 3 refresh complete enable QUERY rewrite AS select OUTR .*, sum(OUTR.col_int_key) as sck, sum(OUTR.col_int) as sc, count(OUTR.col_int_key) as ck, count(OUTR.col_int) as ci, avg(OUTR.col_int) as ac, avg(OUTR.col_int_key) as ak, count(*) as c from BUG_C OUTR  group by pk, col_int_key, col_int, col_date_key ;
SELECT /*+MV_REWRITE(bug_mv14_ngp)*/ AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR;
SELECT AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR WHERE 1=0;
SELECT /*+NO_MV_REWRITE*/ AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR;
SELECT /*+NO_MV_REWRITE*/ AVG( OUTR . col_int ) AS X FROM  BUG_C OUTR WHERE 1=0;

DROP MATERIALIZED VIEW BUG_MV14_SGP;
DROP MATERIALIZED VIEW BUG_MV14_NGP;
DROP TABLE BUG_C;



