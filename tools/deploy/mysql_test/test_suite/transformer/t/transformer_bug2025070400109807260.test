# owner: lijinmao.ljm
# owner group: SQL1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (c1 int, c2 int, key i1 (c1));
create table t2 (c1 int, c2 int, key i2 (c1));

insert into t1 select uniform(1,100, random(1)), uniform(1,100, random(2)) from table(generator(10000));
insert into t2 select uniform(1,100, random(1)), uniform(1,100, random(2)) from table(generator(10000));

select count(*) from t1;
select count(*) from t2;

--result_format 4

--replace_regex /[0-9]+/xx/g
select * from oceanbase.GV$OB_PARAMETERS where name like '_force_subquery_unnest';

--explain_protocol 2
--echo >>> JA in select scope <<<
select c2, (select max(c2) from t2 where c1 = t1.c1) as max from t1 order by max,c2 limit 10;

--echo >>> single set as JA <<<
select c2 from t1 where 100 > (select c2 from t2 where c1 = t1.c1 limit 1) order by c2 limit 10;

--echo >>> single set in update set <<<
explain update t1 set c2 = (select c2 from t2 where t1.c1 = t2.c1 limit 1);

--explain_protocol 0
alter system set `_force_subquery_unnest` = true;
alter system flush plan cache;
--replace_regex /[0-9]+/xx/g
select * from oceanbase.GV$OB_PARAMETERS where name like '_force_subquery_unnest';

--explain_protocol 2
--echo >>> JA in select scope <<<
select c2, (select max(c2) from t2 where c1 = t1.c1) as max from t1 order by max,c2 limit 10;

--echo >>> single set as JA <<<
select c2 from t1 where 100 > (select c2 from t2 where c1 = t1.c1 limit 1) order by c2 limit 10;
explain outline select c2 from t1 where 100 > (select c2 from t2 where c1 = t1.c1 limit 1) order by c2 limit 10;

--echo >>> single set in update set <<<
explain outline update t1 set c2 = (select c2 from t2 where t1.c1 = t2.c1 limit 1);

alter system set `_force_subquery_unnest` = false;
drop table t1, t2;