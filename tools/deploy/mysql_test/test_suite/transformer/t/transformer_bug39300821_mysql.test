##

--result_format 4
--explain_protocol 2

## bug: 

--disable_warnings
drop table if exists t0;
--enable_warnings

CREATE TABLE t0(c0 FLOAT ZEROFILL  UNIQUE PRIMARY KEY NOT NULL)
PARTITION BY KEY (c0) partitions 3;

--disable_query_log
--disable_result_log
INSERT INTO t0(c0) VALUES(2.8583529045855247E18);
select count(*) from t0;
--enable_query_log
--enable_result_log

SELECT /*+ NO_REWRITE  */ ALL concat(t0.c0,'') FROM t0 WHERE ((+ (NULL))) || (concat(t0.c0,''));

drop table t0;

## 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);
insert into t1 values (1),(2),(3);
select /*+no_simplify_expr*/ * from t1 where null < (select count(*) from t1);
select /*+no_rewrite*/ * from t1 where null < (select count(*) from t1);

drop table t1;