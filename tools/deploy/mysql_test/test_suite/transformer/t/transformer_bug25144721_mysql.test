--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
## 完整case
SELECT
  (SELECT DISTINCT MAX(SUBQUERY1_t2 . `col_int_key`) AS SUBQUERY1_field1
   FROM (CC AS SUBQUERY1_t1
         LEFT OUTER JOIN D AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_key`))
   WHERE (SUBQUERY1_t1 . `col_int` != 226
          AND SUBQUERY1_t1 . `col_varchar_20` <= SUBQUERY1_t2 . `col_varchar_10_key`) ) AS field1,
       COUNT(table1 . `col_varchar_20_key`) AS field2,

  (SELECT 2
   FROM DUAL) AS field3,
       table2 . `col_varchar` AS field4
FROM (C AS table1
      LEFT OUTER JOIN
        (SELECT SUBQUERY3_t1 . *
         FROM CC AS SUBQUERY3_t1
         WHERE (SUBQUERY3_t1 . `pk` <> SUBQUERY3_t1 . `pk`
                AND SUBQUERY3_t1 . `pk` != SUBQUERY3_t1 . `pk`) ) AS table2 ON (table2 . `pk` = table1 . `col_int_key`))
WHERE (table1 . `pk` <=
         (SELECT MIN(SUBQUERY4_t1 . `pk`) AS SUBQUERY4_field1
          FROM BB AS SUBQUERY4_t1))
  OR (table1 . `pk` = 199
      OR table1 . `col_varchar_key` = table1 . `col_varchar_key`)
GROUP BY field1,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4;

SELECT /*+no_rewrite*/
  (SELECT DISTINCT MAX(SUBQUERY1_t2 . `col_int_key`) AS SUBQUERY1_field1
   FROM (CC AS SUBQUERY1_t1
         LEFT OUTER JOIN D AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_key`))
   WHERE (SUBQUERY1_t1 . `col_int` != 226
          AND SUBQUERY1_t1 . `col_varchar_20` <= SUBQUERY1_t2 . `col_varchar_10_key`) ) AS field1,
       COUNT(table1 . `col_varchar_20_key`) AS field2,

  (SELECT 2
   FROM DUAL) AS field3,
       table2 . `col_varchar` AS field4
FROM (C AS table1
      LEFT OUTER JOIN
        (SELECT SUBQUERY3_t1 . *
         FROM CC AS SUBQUERY3_t1
         WHERE (SUBQUERY3_t1 . `pk` <> SUBQUERY3_t1 . `pk`
                AND SUBQUERY3_t1 . `pk` != SUBQUERY3_t1 . `pk`) ) AS table2 ON (table2 . `pk` = table1 . `col_int_key`))
WHERE (table1 . `pk` <=
         (SELECT MIN(SUBQUERY4_t1 . `pk`) AS SUBQUERY4_field1
          FROM BB AS SUBQUERY4_t1))
  OR (table1 . `pk` = 199
      OR table1 . `col_varchar_key` = table1 . `col_varchar_key`)
GROUP BY field1,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4;

## 简化case
SELECT /*+PLACE_GROUP_BY*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk), t3
WHERE t1.c2 = t3.c1
GROUP BY field4;
SELECT /*+NO_PLACE_GROUP_BY*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk), t3
WHERE t1.c2 = t3.c1
GROUP BY field4;


DROP TABLE `c`, `d`, `cc`, `bb`, t1, t2, t3;