#owner: sean.yyj
#owner group: sql1
# tags: optimizer
#info: 测试对ora decode的改写 

######### try replace ora_decode with const result and take case of cast type #########
--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
--enable_warnings
create table t1 (c1 int, c2 int, c3 varchar(10));
select c1, c2 from t1 where c1 > ora_decode(1, 0, 0, 1/0, c1, c2);
insert into t1 values(1,10,'aa'),(2,20,'bb'),(3,30,'cc'),(4,40,'dd');
select c1, c2 from t1 where c1 > ora_decode(1, 0, 0, 1/0, c1, c2);

create table t2 (c1 int, c2 timestamp(0), c3 date);
insert into t2 values(1, timestamp'2010-10-20 11:11:11', date'2017-01-20');

--result_format 4
--explain_protocol 2
--enable_metadata

# com is static const expr
--echo com = con1
select /*+no_rewrite*/ora_decode(2, 2, 2, 'NO') from t1;
select ora_decode(2, 2, 2, 'NO') from t1;

select /*+no_rewrite*/ora_decode(2, 2, c1, c2) from t1;
select ora_decode(2, 2, c1, c2) from t1;

select /*+no_rewrite*/ora_decode('aaa', 'aaa', c1, c2) from t1;
select ora_decode('aaa', 'aaa', c1, c2) from t1;

select /*+no_rewrite*/ora_decode('aaa', 'AAA', c1, c2) from t1;
select ora_decode('aaa', 'AAA', c1, c2) from t1;

select /*+no_rewrite*/ora_decode(null, null, c1, c2) from t1;
select ora_decode(null, null, c1, c2) from t1;

--echo com = con2, result 1 and result 2 is different type column

select /*+no_rewrite*/ora_decode(2, 1, c2, 2, c3) from t2;
select ora_decode(2, 1, c2, 2, c3) from t2;

--echo com = nothing, return default or null
select ora_decode(c1, 2, 2, 3) from t2;
select ora_decode(1, 0, c2, c1, c3) from t2;

select /*+no_rewrite*/ora_decode(1, 0, c3) from t2;
select ora_decode(1, 0, c3) from t2;

select /*+no_rewrite*/ora_decode(1, 0, c2, c3) from t2;
select ora_decode(1, 0, c2, c3) from t2;

drop table t1;
drop table t2;

--echo test using query range
create table t1 (c1 int, c2 int, c3 int);
create index i1 on t1(c1);
insert into t1 values(1,10,100),(2,20,200),(3,30,300),(4,40,400),(5,50,500),(6,60,600);

select /*+no_rewrite*/* from t1 where c1 > ora_decode(3, 0, c1, 3, 3, -1);
select * from t1 where c1 > ora_decode(3, 0, c1, 3, 3, -1);

select /*+no_rewrite*/* from t1 where ora_decode(3, 0, 0, 3, c1, -1) > 3;
select * from t1 where ora_decode(3, 0, 0, 3, c1, -1) > 3;

--explain_protocol 0
--disable_metadata
alter system flush plan cache global;
select * from t1 where c1 > ora_decode(3, 0, c1, 1, c2, 3, c3, -1);
select * from t1 where c1 > ora_decode(2, 0, 0, 1, 1, 2, 2, 3);
select * from t1 where c1 > ora_decode(3, 0, c1, 1, c2, 2, c3, -1);
select * from t1 where c1 > ora_decode(3, 0, 0, 1, c2, 3, c3, -1);
select * from t1 where c1 > ora_decode(3, 0, c1, 5, c2, 3, c3);
select * from t1 where c1 > ora_decode(3, 0, c1, 3, c2, 3, c3, -1);
select statement,query_sql,param_infos,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where query_sql like '%ora_decode%';

select * from t1 where c1 > ora_decode(3, 0, c1, 5, c2, 3, c3, -1);
select * from t1 where c1 > ora_decode(3, 2, 2, 1, c2, 3, c3, -1);
select * from t1 where c1 > ora_decode(2, '2', '2', 1, 1, 2, 2, 3);
select * from t1 where c1 > ora_decode(3, 1, c1, 2, c2, 0, c3, -1);
select statement,query_sql,param_infos,hit_count from oceanbase.gv$ob_plan_cache_plan_stat where query_sql like '%ora_decode%';

drop table t1;
