# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create TABLE t1(c1 int,c2 int ,c3 DATE);
set sql_mode = '';
insert into t1 values (3,0,2);

--result_format 4
--explain_protocol 2

select * from t1 where c3 in ((select c1 FROM t1) union (select c2 FROM t1 ));
delete FROM t1 where c3 in ((select c1 FROM t1) union (select c2 FROM t1 ));

drop table t1;

# issue: 

--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists d0,d1,d2;
--enable_warnings

create table d0(a int);
create table d1(b int);
create table d2(c int);
insert into d0 values (4),(5);
insert into d1 values (4),(6);
insert into d2 values (4),(5);

--enable_query_log
--explain_protocol 2

select * from d0 where a = 4 and (a in (select b from d1 where b < 7 limit 2)) and (a in (select c from d2));

drop table d0,d1,d2;

# issue : 

--explain_protocol 0
--disable_query_log
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(a int);
create table t2(x int, y int not null);

--enable_query_log
--explain_protocol 2
select 1 from (select /*+no_merge*/ a from t1 where a = 1) ref0 left join t2 on a = x where y is null;
select 1 from (select /*+no_merge*/ a from t1 where a > 1) ref0 left join (select * from t2 where x < 8 limit 2) ref1 on a = x where y is null;

drop table t1,t2;