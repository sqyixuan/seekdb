--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(a int, b int, c int);
insert into t1 values (1,1,1);

--explain_protocol 2
--result_format 4

explain with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;
with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;

explain with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte left join t2 on (1=1) where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;
with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte left join t2 on (1=1) where (c2 = 4 or c1 = 1) and c1 < 10) 
select * from cte;

explain with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte left join t2 on (c2 = b or c1 = a) where c1 < 10) 
select * from cte;
with recursive cte(c1, c2) as (select c1, c2  from t1 union all select /*+use_concat*/ c1+1, c2+1 from cte left join t2 on (c2 = b or c1 = a) where c1 < 10) 
select * from cte;

drop table t1,t2;