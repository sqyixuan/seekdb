# owner: lijinmao.ljm
# onwer group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (`qzkh_id` int, `mphone` varchar(600));
create index i1 on t1(mphone);
insert into t1 select uniform(1,10000, random(1)) as c1, concat('test', uniform(1,10000, random(1))) as c2 from table(generator(10000));
select count(*) from t1;
create table t2 (`id` int, `remark_name` varchar(300));

--explain_protocol 2
--result_format 4

--echo 隐式 cast 出现在连接条件中，能做下推
select * from t1, t2 where mphone = RIGHT(FROM_BASE64(remark_name), 11);

--echo 不做子查询提升，能抽隐式 cast range
select * from t2 where exists (select /*+no_unnest*/ 1 from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));
--echo exists/any/all 的提升不看索引匹配，提升后做视图合并能走基表条件下推
select * from t2 where exists (select 1 from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));
--echo exists/any/all 的提升不看索引匹配，提升后不做视图合并能走非基表条件下推
select * from t2 where exists (select /*+no_merge*/ 1 from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));

--echo 聚合子查询提升后，支持带 cast 的非基表条件下推
select * from t2 where id = (select max(qzkh_id) from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11));
--echo 写在 select 里，子查询能走索引，默认不做聚合子查询提升
select (select max(qzkh_id) from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11)) as c1 from t2;
--echo 写在 select 里，子查询能走索引，强制 unnest 后能做非基表条件下推
select (select /*+unnest*/ max(qzkh_id) from t1 where mphone = RIGHT(FROM_BASE64(remark_name), 11)) as c1 from t2;

drop table t1, t2;