# Enhance Predicate Move Around
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--explain_protocol 0
create table t1 (c1 int, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int, c3 int);
insert into t2 values (1,1),(2,2),(null,null);
insert into t3 values (1,1,0),(1,2,2),(2,2,1),(2,2,0);
--explain_protocol 2

# For nulltype
alter system flush plan cache global;
insert into t1 select null,1 from dual;
insert into t1 select 1,2 from dual;
insert into t1 select null+1,1 from dual;
insert into t1 select 1+2,2 from dual;
insert into t1 select null as c1,1 as c2 from dual;
insert into t1 select 1 as c1,2 as c2 from dual;
insert into t1 select null+1 as c1,1 as c2 from dual;
insert into t1 select 1+1 as c1,2 as c2 from dual;
insert into t1 select c1,1 from (select null as c1 from t1 union select null as c1 from t2);
insert into t1 select c1,1 from (select 1 as c1 from t1 union select 1 as c1 from t2);

--explain_protocol 0
select * from t1;
select statement,query_sql,hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "insert into t1%" order by first_load_time;
--explain_protocol 2

insert into t1 select c1,c2 from t2 where t2.c1 is null;
insert into t1 select c1,c2 from t2 where t2.c1 = null;
insert into t1 select c1,c2 from t2 where t2.c1 = t2.c2 and t2.c2 is null;
--explain_protocol 0
select * from t1;
--explain_protocol 2

select * from t1 where c1 is null;
select * from t1 where c1 is null and c1 <=> c2;
select * from t1, (select * from t2 where c1 is null) v where t1.c1 <=> v.c1;

alter system flush plan cache global;
select * from t1, (select 2 as c1 from dual)v where t1.c1 <=> v.c1;
select * from t1, (select null as c1 from dual)v where t1.c1 <=> v.c1;
select * from t1, (select 1 as c1 from dual)v where t1.c1 <=> v.c1;
select * from t1, (select null as c1 from dual)v where t1.c1 > v.c1;
select * from t1, (select 1 as c1 from dual)v where t1.c1 > v.c1;
--explain_protocol 0
select statement,query_sql,hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like "select * from t1%" order by first_load_time;
--explain_protocol 2
alter system flush plan cache global;

insert into t1 select c1,1 from (select 1 as c1 from t1 union select 1 as c1 from t2);
insert into t1 select c1,1 from (select null as c1 from t1 union select null as c1 from t2);

#For rollup
select c1,c2,count(*) from t3 group by c1, c2 with rollup having c1 = 1;
select /*+no_rewrite*/ c1,c2,count(*) from t3 group by c1, c2 with rollup having c1 = 1;
select c1,c2 from t3 group by c1,c2 with rollup having c1 >0 or (c2>0 and c1<1);
select /*+no_rewrite*/ c1,c2 from t3 group by c1,c2 with rollup having c1 >0 or (c2>0 and c1<1);

drop table if exists t1, t2, t3;

#Fix:Predicate Move around does not converge
create table t1(c1 int, c2 int, c3 int, c4 int);
explain outline select * from (select * from t1 a where c1 is null) intersect (select * from t1 a where c2 is null);
explain outline select * from (select * from t1 a where c1 = 1) intersect (select * from t1 a where c2 = 1) ;
drop table t1;

