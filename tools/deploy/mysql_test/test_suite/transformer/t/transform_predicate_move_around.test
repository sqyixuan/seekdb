#嵌套set stmt下推
--disable_warnings
select * from (
    (select c1,c3 from t1 except (select c2, sum(c3) from t2 group by c2))
        union all
    (select c1,rank()over(partition by c2 order by c1) from t3 intersect (select distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/ * from (
    (select /*+no_rewrite*/c1,c3 from t1 except (select /*+no_rewrite*/c2, sum(c3) from t2 group by c2))
        union all
    (select /*+no_rewrite*/c1,rank()over(partition by c2 order by c1) from t3 intersect (select /*+no_rewrite*/distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

select * from (
    (select c1,c3 from t1 except (select c1,rank()over(partition by c1 order by c2) from t2))
        union all
    (select c1,rank()over(partition by c1 order by c2) from t3 intersect (select distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/* from (
    (select /*+no_rewrite*/c1,c3 from t1 except (select /*+no_rewrite*/c1,rank()over(partition by c1 order by c2) from t2))
        union all
    (select /*+no_rewrite*/c1,rank()over(partition by c1 order by c2) from t3 intersect (select /*+no_rewrite*/distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

#set stmt中嵌套的子查询带有set stmt
select * from (
    (select c1,c3 from t1 except (select * from (
           select c2 ,sum(c3) from t2 group by c2  union (select c1, avg(c2) from t4 group by c1)) s))
        union all
    (select c1,rank()over(partition by c1 order by c2) from t3 intersect (select distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/* from (
    (select /*+no_rewrite*/c1,c3 from t1 except (select /*+no_rewrite*/* from (
           select /*+no_rewrite*/c2 ,sum(c3) from t2 group by c2  union (select /*+no_rewrite*/c1, avg(c2) from t4 group by c1)) s))
        union all
    (select /*+no_rewrite*/c1,rank()over(partition by c1 order by c2) from t3 intersect (select /*+no_rewrite*/distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;
--enable_warnings

#set stmt谓词上拉后再下推到其他侧
#上拉左侧，下推到右侧
select * from (select c1 from t1 where c1 < 5 except select c2 from t2) t where t.c1 > 0;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/c1 from t1 where c1 < 5 except select /*+no_rewrite*/c2 from t2) t where t.c1 > 0;

#上拉右侧，下推到左侧
select * from (select c1 from t1 intersect select c2 from t2 where c2 > 0) t where t.c1 < 5;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/c1 from t1 intersect select /*+no_rewrite*/c2 from t2 where c2 > 0) t where t.c1 < 5;

#左侧无法下推谓词，但是可以上拉谓词推到右侧
select * from ((select c1 from t1 where c1 > 0 limit 10) except select c2 from t2) t where t.c1 < 5;
select /*+no_rewrite*/* from ((select /*+no_rewrite*/c1 from t1 where c1 > 0 limit 10) except select /*+no_rewrite*/c2 from t2) t where t.c1 < 5;

#右侧无法压到where，但是谓词上拉推到左侧
select * from (select c1 from t1 intersect select sum(c2) as c2 from t2 group by c1 having c2 > 0) t where t.c1 < 5;
select /*+no_rewrite*/* from (select /*+no_rewrite*/c1 from t1 intersect select /*+no_rewrite*/sum(c2) as c2 from t2 group by c1 having c2 > 0) t where t.c1 < 5;

#两侧无法下推，但是可以上拉谓词，没有任何效果
select * from ((select c1 from t1 where c1 > 0 limit 2) union all (select c2 from t2 where c2 > 0 limit 2)) t where t.c1 < 5;
select /*+no_rewrite*/* from ((select /*+no_rewrite*/c1 from t1 where c1 > 0 limit 2) union all (select /*+no_rewrite*/c2 from t2 where c2 > 0 limit 2)) t where t.c1 < 5;

#嵌套set stmt，同时存在上拉和下推谓词
--disable_warnings
#谓词上拉中途失败，不能下推到同侧子查询
