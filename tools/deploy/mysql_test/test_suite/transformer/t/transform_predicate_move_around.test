SELECT * FROM ((select c1 , sum(c2) from t2 group by c1)v INNER JOIN t1 ON 1 = 1) LEFT JOIN t4 ON v.c1 = t4.c1 WHERE  v.c1 = 1;
SELECT /*+no_rewrite*/* FROM ((select /*+no_rewrite*/c1 , sum(c2) from t2 group by c1)v INNER JOIN t1 ON 1 = 1) LEFT JOIN t4 ON v.c1 = t4.c1 WHERE  v.c1 = 1;

SELECT * FROM (t1 INNER JOIN (t2 LEFT JOIN t3 ON t2.c1 = t3.c1) ON 1 = 1) LEFT JOIN t4 ON t2.c1 = t4.c1 WHERE  t2.c1 = 1;
