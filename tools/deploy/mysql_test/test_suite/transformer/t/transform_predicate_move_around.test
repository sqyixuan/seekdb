        intersect
    (select c1,rank()over(partition by c1 order by c2) from t3 intersect (select distinct c2, c3 from t4 where c3 > 0 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/* from (
    (select /*+no_rewrite*/c1,c3 from t1 where c1 < 5 except (select /*+no_rewrite*/c1,rank()over(partition by c1 order by c2) from t2))
        intersect
    (select /*+no_rewrite*/c1,rank()over(partition by c1 order by c2) from t3 intersect (select /*+no_rewrite*/distinct c2, c3 from t4 where c3 > 0 order by c2))
) where c1 > 0 and c3 < 5;

#set stmt中嵌套的子查询带有set stmt
select * from (
    (select c1,c3 from t1 except (select * from (
           select c2 ,sum(c3) from t2 where c2 < 5 group by c2 intersect (select c1, avg(c2) from t4 group by c1)) s))
        union all
    (select c1,rank()over(partition by c1 order by c2) from t3 intersect (select distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/* from (
