# owner: link.zt
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
create table t1(c1 int, c2 int, c3 varchar(32));
create table t2(c1 int, c2 int, c3 varchar(32));
create table t3(c1 int, c2 int, c3 varchar(32));
create table t4(c1 int, c2 int, c3 varchar(32));

--disable_query_log
insert into t1 values (1, 1, 'x');
insert into t1 values (2, 5, 'u');
insert into t1 values (3, 2, 'z');
insert into t1 values (4, 6, 'e');
insert into t1 values (5, 4, 'g');
insert into t1 values (6, 7, 'h');

insert into t2 values (1, 1, 'o');
insert into t2 values (2, 5, 'c');
insert into t2 values (3, 5, 'b');
insert into t2 values (4, 6, 'o');
insert into t2 values (5, 7, 'd');
insert into t2 values (6, 8, 'c');

insert into t3 values (1, 2, '3');
insert into t3 values (2, 5, '4');
insert into t3 values (3, 6, '1');
insert into t3 values (4, 5, '1');
insert into t3 values (5, 5, '5');
insert into t3 values (6, 5, 'c');

insert into t4 values (1, 1, 'o');
insert into t4 values (2, 5, 'c');
insert into t4 values (3, 5, 'b');
insert into t4 values (4, 6, 'o');
insert into t4 values (5, 7, 'd');
insert into t4 values (6, 8, 'c');
--disable_result_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

## A. 推导的测试

## stmt 内 join 谓词推导
select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1;

select t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 > 1 and t1.c1 = t2.c1;

select t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 in (2,3) and t1.c1 = t2.c1;

select t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 between 2 and 3 and t1.c1 = t2.c1;

## stmt 内 outer join 谓词推导
select t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 where t1.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 where t1.c1 = 1;

select t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t2.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t2.c1 = 1;

select t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t1.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t1.c1 = 1;

select t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);

select t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t1.c1 in (1, 2);
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 left join t2 on t1.c1 = t2.c1 and t1.c1 in (1, 2);


select t1.c3, t2.c3 from t1 right join t2 on t1.c1 = t2.c1 where t1.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 right join t2 on t1.c1 = t2.c1 where t1.c1 = 1;

select t1.c3, t2.c3 from t1 right join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 right join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);


select t1.c3, t2.c3 from t1 full join t2 on t1.c1 = t2.c1 and t1.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 full join t2 on t1.c1 = t2.c1 and t1.c1 = 1;

select t1.c3, t2.c3 from t1 full join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);
select /*+no_rewrite*/ t1.c3, t2.c3 from t1 full join t2 on t1.c1 = t2.c1 and t2.c1 in (1, 2);


## stmt 内 outer join 谓词推导以及push down 测试

select t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) left join t3 on t1.c1 = t3.c1 where t1.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) left join t3 on t1.c1 = t3.c1 where t1.c1 = 1;


select t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) left join t3 on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) left join t3 on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;

select t1.c3, t2.c3, t3.c3 from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;


select t1.c3, t2.c3, t3.c3 from t1 right join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from t1 right join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;

select t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) right join t3 on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) right join t3 on t1.c1 = 1 and t2.c1 = 1 and t3.c1 = 1;


select t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) full join (t3 left join t4 on t3.c1 = t4.c1) on t1.c1 = t3.c1 and t3.c1 = 1;
select /*+no_rewrite*/ t1.c3, t2.c3, t3.c3 from (t1 left join t2 on t1.c1 = t2.c1) full join (t3 left join t4 on t3.c1 = t4.c1) on t1.c1 = t3.c1 and t3.c1 = 1;

select  t1.c3, t2.c3, t3.c3, t4.c3 from (t1 left join t2 on t1.c1 = t2.c1) full join (t3 left join t4 on t4.c1 = t3.c1) on t1.c1 = t4.c1 where  t4.c1 = 1;
select  /*+no_rewrite*/ t1.c3, t2.c3, t3.c3, t4.c3 from (t1 left join t2 on t1.c1 = t2.c1) full join (t3 left join t4 on t4.c1 = t3.c1) on t1.c1 = t4.c1 where  t4.c1 = 1;


## stmt 内 semi/anti join 谓词推导（多层级联 semi/anti join）

select c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2 and t1.c1 = 1);
select /*+no_rewrite*/ c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2 and t1.c1 = 1);

select c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2 and t2.c1 = 1);
select /*+no_rewrite*/ c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2 and t2.c1 = 1);

select c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2) and t1.c1 = 1;
select /*+no_rewrite*/ c1 from t1 where exists (select 1 from t2 where t1.c1 = t2.c2) and t1.c1 = 1;

select c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2 and t1.c1 = 1);
select /*+no_rewrite*/ c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2 and t1.c1 = 1);

select c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2 and t2.c2 = 1);
select /*+no_rewrite*/ c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2 and t2.c2 = 1);

select c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2) and t1.c1 = 1;
select /*+no_rewrite*/ c1 from t1 where not exists (select 1 from t2 where t1.c1 = t2.c2) and t1.c1 = 1;


select c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					exists (select 1 from t4 where t4.c1 = t3.c1)));

select /*+no_rewrite*/ c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					exists (select 1 from t4 where t4.c1 = t3.c1)));


## 这种是有提升空间的
select c1 from t1 where 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and 
			exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));

select /*+no_rewrite*/ c1 from t1 where 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and 
			exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));


select c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			not exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));

select /*+no_rewrite*/ c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			not exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));


select c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			not exists (select 1 from t3 where t3.c1 = t1.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));

select /*+no_rewrite*/ c1 from t1 where 
	exists (select 1 from t2 where t2.c1 = t1.c1 and 
			not exists (select 1 from t3 where t3.c1 = t1.c1 and t3.c1 = 1 and 
					not exists (select 1 from t4 where t4.c1 = t3.c1)));


### 这个 corner case 非常的危险。 exists 提升产生的是一个 semi。但它处于一个 anti join 之下
### 所以，这个 semi info 对应的 condition 不能和主查询的谓词一起推导新谓词
### 要避免： t3.c1 = v.c1, t1.c1 = v.c1 => t1.c1 = t3.c1, 结合 t3.c1 = 0 推出 t1.c1 = 0
select c1 from t1 where t1.c1 = 1 and 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and
				exists (select 1 from t3 where t3.c1 = 1 and t3.c1 = 0 and t3.c2 = t2.c2));
select /*+no_rewrite*/ c1 from t1 where t1.c1 = 1 and 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and
				exists (select 1 from t3 where t3.c1 = 1 and t3.c1 = 0 and t3.c2 = t2.c2));


select v.c1 from t1 v where v.c1 > (
select c1 from t1 where t1.c1 = v.c2 and 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and
				exists (select 1 from t3 where t3.c1 = v.c2 and t3.c1 = 0 and t3.c2 = t2.c2)) limit 1
);

select /*+no_rewrite*/ v.c1 from t1 v where v.c1 > (
select c1 from t1 where t1.c1 = v.c2 and 
	not exists (select 1 from t2 where t2.c1 = t1.c1 and
				exists (select 1 from t3 where t3.c1 = v.c2 and t3.c1 = 0 and t3.c2 = t2.c2)) limit 1
);



## stmt 内单层聚合函数谓词推导

select c1 from t1 group by c1 having max(c2) > 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having max(c2) > 10;

select c1 from t1 group by c1 having max(c2) >= 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having max(c2) >= 10;

select c1 from t1 group by c1 having max(c2) = 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having max(c2) = 10;

select c1 from t1 group by c1 having max(c2) < 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having max(c2) < 10;

select min(c2) from t1 group by c1 having max(c2) > 10;
select /*+no_rewrite*/ min(c2) from t1 group by c1 having max(c2) > 10;

select max(c2) from t1 having max(c2) > 10;
select /*+no_rewrite*/ max(c2) from t1 having max(c2) > 10;


select c1 from t1 group by c1 having min(c2) > 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having min(c2) > 10;

select c1 from t1 group by c1 having min(c2) = 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having min(c2) = 10;

select c1 from t1 group by c1 having min(c2) < 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having min(c2) < 10;

select c1 from t1 group by c1 having min(c2) <= 10;
select /*+no_rewrite*/ c1 from t1 group by c1 having min(c2) <= 10;

select min(c2) from t1 having min(c2) < 10;
select /*+no_rewrite*/ min(c2) from t1 having min(c2) < 10;

## B. pullup 的测试

## pullup 谓词帮助推导上层的谓词

select t1.c3, V.v3 from t1, 
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t2) V
where t1.c1 = v1 and t1.c1 = 1;

select /*+no_rewrite*/ t1.c3, V.v3 from t1, 
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t2) V
where t1.c1 = v1 and t1.c1 = 1;


select t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t3 where c1 = 1) V
where t1.c3 = V.v1;

select /*+no_rewrite*/ t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t3 where c1 = 1) V
where t1.c3 = V.v1;


select t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t3 where c1 in (1, 2)) V
where t1.c1 = V.v1 ;

select /*+no_rewrite*/ t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c2 as v2, c3 as v3 from t3 where c1 in (1, 2)) V
where t1.c1 = V.v1 ;


select t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c1 as v2, c3 as v3 from t3 where c1 in (1, 2)) V
where t1.c1 = V.v1 and t1.c1 = V.v2;

select /*+no_rewrite*/ t1.c3, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, c1 as v2, c3 as v3 from t3 where c1 in (1, 2)) V
where t1.c1 = V.v1 and t1.c1 = V.v2;


## pullup 引用了语义谓词来推导

select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;


select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;


select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;

select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, avg(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, avg(c2) as v2 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;

select t1.c3, V.v2, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2, count(*) as v3 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2, V.v3 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2, count(*) as v3 from t3 where c2 < 2 group by c1) V
where t1.c2 = V.v2 and t1.c1 = V.v1;



## be careful about the null problem
select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 10) V
where t1.c2 > V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, max(c2) as v2 from t3 where c2 > 10) V
where t1.c2 > V.v2 and t1.c1 = V.v1;


select t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2 from t3 where c2 < 0) V
where t1.c2 > V.v2 and t1.c1 = V.v1;
select /*+no_rewrite*/ t1.c3, V.v2 from t1,
(select /*+no_merge*/ c1 as v1, min(c2) as v2 from t3 where c2 < 0) V
where t1.c2 > V.v2 and t1.c1 = V.v1;


## pullup 视图在 outer join 中

select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1;
select /*+no_rewrite*/ V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1;

select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V right join t2 on V.c1 = t2.c1;
select /*+no_rewrite*/ V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V right join t2 on V.c1 = t2.c1;


select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V full join t2 on V.c1 = t2.c1;
select /*+no_rewrite*/ V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V full join t2 on V.c1 = t2.c1;


## pullup 对 set stmt 的遍历

(select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1)
union 
(select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1);

(select /*+no_rewrite*/ t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1)
union 
(select /*+no_rewrite*/ V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1); 

select c1 from t1 where (t1.c1, t1.c1) in  (
(select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1)
union 
(select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1));

select /*+no_rewrite*/ c1 from t1 where (t1.c1, t1.c1) in  (
(select t1.c3, t2.c3 from t1, t2 where t1.c1 = 1 and t1.c1 = t2.c1)
union 
(select V.c3, t2.C3 from (select * /*+no_merge*/ from t1 where t1.c1 = 1) V left join t2 on V.c1 = t2.c1));

## pullup 视图是 anti/semi join 的右表

select * from t1 where t1.c1 >any (select c1 from t2 where c1 > 2 order by c2 limit 1);
select /*+no_rewrite*/ * from t1 where t1.c1 >any (select c1 from t2 where c1 > 2 order by c2 limit 1);

select * from t1 where t1.c1 >all (select c1 from t2 where c1 < 2 order by c2 limit 1) and t1.c1 is not null;
select /*+no_rewrite*/ * from t1 where t1.c1 >all (select c1 from t2 where c1 < 2 order by c2 limit 1) and t1.c1 is not null;

## C. pushdown 的测试

## 基本 push down 测试, limit, sequence, distinct, order by, rownum 边界测试

select t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2) V where t1.c1 = V.c1 and t1.c1 > 1;
select /*+no_rewrite*/ t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2) V where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2 limit 1) V where t1.c1 = V.c1 and t1.c1 > 1;
select /*+no_rewrite*/ t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2 limit 1) V where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2 order by c1) V where t1.c1 = V.c1 and t1.c1 > 1;
select /*+no_rewrite*/ t1.c3, V.c3 from t1, (select /*+no_merge*/ * from t2 order by c1) V where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.c3 from t1, (select /*+no_merge*/ distinct * from t2) V where t1.c1 = V.c1 and t1.c1 > 1;
select /*+no_rewrite*/ t1.c3, V.c3 from t1, (select /*+no_merge*/ distinct * from t2) V where t1.c1 = V.c1 and t1.c1 > 1;

