## pullup + push down 谓词一起推导新的谓词

select t1.c3, V.c3 from t1,
(select /*+no_merge*/ * from t2 where (c1, c2) in (select c1, c1 from t3)) V
where t1.c1 = V.c2 and t1.c1 = 1;

select /*+no_rewrite*/ t1.c3, V.c3 from t1,
(select /*+no_merge*/ * from t2 where (c1, c2) in (select c1, c1 from t3)) V
where t1.c1 = V.c2 and t1.c1 = 1;


select t1.c3, V.c3 from t1,
(select /*+no_merge*/ * from t2 where (c1, c2) in (select c1, c1 from t3)) V
where t1.c1 = V.c2 and t1.c1 between 1 and 5;

select /*+no_rewrite*/ t1.c3, V.c3 from t1,
(select /*+no_merge*/ * from t2 where (c1, c2) in (select c1, c1 from t3)) V
where t1.c1 = V.c2 and t1.c1 between 1 and 5;

## push down through window functions

select t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c1) as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c1) as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over () as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over () as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c2) as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.wf from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c2) as wf from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select t1.c3, V.wf1, V.wf2 from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c1) as wf1, sum(c1) over (partition by c2) as wf2 from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.wf1, V.wf2 from t1, 
(select /*+no_merge*/ c1, sum(c1) over (partition by c1) as wf1, sum(c1) over (partition by c2) as wf2 from t2) V 
where t1.c1 = V.c1 and t1.c1 > 1;

## push down into having, and push down through group by 

select t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, max(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, max(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 > 1;

select t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, min(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 > 1;

select /*+no_rewrite*/ t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, min(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 > 1;

select t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, min(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select /*+no_rewrite*/ t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, min(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select t1.c3, V.aggr, V.cnt from t1,
(select /*+no_merge*/ c2, min(c1) as aggr, count(*) as cnt from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select /*+no_rewrite*/ t1.c3, V.aggr, V.cnt from t1,
(select /*+no_merge*/ c2, min(c1) as aggr, count(*) as cnt from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, max(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select /*+no_rewrite*/ t1.c3, V.aggr from t1,
(select /*+no_merge*/ c2, max(c1) as aggr from t2 group by c2) V
where t1.c1 = v.aggr and t1.c1 < 4;

select t1.c3, V.c1, V.c3, V.aggr from t1,
(select /*+no_merge*/ c1, c3, count(*) as aggr from t2 group by c1) V
where t1.c2 > V.aggr and t1.c3 = V.c3 and t1.c1 = V.c1 and t1.c1 > 1 and t1.c2 < 5 and t1.c3 <> 'z';

select /*+no_rewrite*/ t1.c3, V.c1, V.c3, V.aggr from t1,
(select /*+no_merge*/ c1, c3, count(*) as aggr from t2 group by c1) V
where t1.c2 > V.aggr and t1.c3 = V.c3 and t1.c1 = V.c1 and t1.c1 > 1 and t1.c2 < 5 and t1.c3 <> 'z';

select t1.c3, V.c2, V.aggr from t1,
(select /*+no_merge*/ c2, max(c2) as aggr from t2 where c2 > 1) V
where t1.c2 = V.aggr;

select /*+no_rewrite*/ t1.c3, V.c2, V.aggr from t1,
(select /*+no_merge*/ c2, max(c2) as aggr from t2 where c2 > 1) V
where t1.c2 = V.aggr;

## max(t2.c2) > t2.c2 这个谓词用的时候要非常的小心
## 下面这种推导是不对的: max(t2.c2) > t2.c2 = t3.c2 > 1, then add max(t2.c2) > 1 into the having clause
## max(t2.c2) > t2.c2 这个谓词对本层是不可见的，它仅对上层 stmt 可见
## 如果对本层可见，一方面是可能推导出冗余的谓词，另一方面，scalar aggregate 引入的谓词会改变查询的语义。

select c2, max(c2) as aggr from t2 where c2 in (select c2 from t3 where c2 > 1);
select /*+no_rewrite*/ c2, max(c2) as aggr from t2 where c2 in (select c2 from t3 where c2 > 1);

select c2, max(c2) as aggr from t2 where c2 in (select c2 from t3 where c2 > 1) group by c1;
select /*+no_rewrite*/ c2, max(c2) as aggr from t2 where c2 in (select c2 from t3 where c2 > 1) group by c1;

## push down into joined table views

select t1.c3, V.aggr from t1 left join (select c2, max(c1) as aggr from t2 group by c2) V on t1.c1 = v.aggr where t1.c1 > 1;
select /*+no_rewrite*/ t1.c3, V.aggr from t1 left join (select c2, max(c1) as aggr from t2 group by c2) V on t1.c1 = v.aggr where t1.c1 > 1;

select t1.c3, V.aggr from t1 right join (select c2, max(c1) as aggr from t2 group by c2) V on t1.c1 = v.aggr where V.aggr > 1;
select /*+no_rewrite*/ t1.c3, V.aggr from t1 right join (select c2, max(c1) as aggr from t2 group by c2) V on t1.c1 = v.aggr where V.aggr > 1;

