SELECT  GRANDPARENT1 . col_varchar_20_key AS G1 FROM z AS GRANDPARENT1 LEFT JOIN s AS GRANDPARENT2 ON ( GRANDPARENT2 . `col_int` <= GRANDPARENT1 . `col_int_key` ) WHERE ( GRANDPARENT1 . `col_int_key` , GRANDPARENT1 . `pk` ) IN ( SELECT DISTINCT PARENT1 . `pk` AS P1 , PARENT1 . `col_int_key` AS P2 FROM bb AS PARENT1 LEFT JOIN d AS PARENT2 USING ( col_varchar_20_key ) WHERE ( PARENT1 . `pk` , PARENT1 . `pk` ) IN ( SELECT  CHILD1 . `col_int` AS C1 , CHILD1 . `pk` AS C2 FROM w AS CHILD1 WHERE ( ( CHILD1 . `col_int` <> CHILD1 . `pk` ) AND GRANDPARENT1 . `col_int_key` <= 9 )  ) AND ( ( PARENT1 . `pk` >= GRANDPARENT1 . `col_int` ) AND ( GRANDPARENT1 . col_varchar_20_key IS NOT NULL ) ) ORDER BY PARENT1 . col_varchar_20_key ) AND GRANDPARENT1 . `pk` >= 8 HAVING G1 <> '2001-10-16 12:02:08' ORDER BY GRANDPARENT1 . col_varchar_20_key LIMIT 8;

SELECT 1 FROM z AS GRANDPARENT1  WHERE ( GRANDPARENT1 . `col_int_key` , GRANDPARENT1 . `pk` ) IN
    ( SELECT PARENT1 . `pk` AS P1 , PARENT1 . `col_int_key` AS P2 FROM bb AS PARENT1 , d
            WHERE exists (SELECT  1  FROM w AS CHILD1 WHERE PARENT1 . `pk` =  CHILD1 . `col_int`  and  GRANDPARENT1 . `col_int_key` <= 9 and  CHILD1 . `col_int` = CHILD1 . `pk`)
                AND PARENT1 . `pk` >= GRANDPARENT1 . `col_int` );

