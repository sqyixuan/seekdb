#简单set stmt下推
select * from (select c1 from t1 union select c2 from t2) t where t.c1 < 5;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/c1 from t1 union select /*+no_rewrite*/c2 from t2) t where t.c1 < 5;

select * from (select c1 from t1 except select c2 from t2) t where t.c1 < 5;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/c1 from t1 except select /*+no_rewrite*/c2 from t2) t where t.c1 < 5;

select * from (select c1 from t1 intersect select c2 from t2) t where t.c1 < 5;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/c1 from t1 intersect select /*+no_rewrite*/c2 from t2) t where t.c1 < 5;

