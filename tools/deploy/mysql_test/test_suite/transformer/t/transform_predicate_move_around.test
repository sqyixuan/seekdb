        union all
    (select c1,rank()over(partition by c2 order by c1) from t3 intersect (select distinct c2, c3 from t4 where c3 > 0 order by c2))
) where c1 > 0 and c3 < 5;

select /*+no_rewrite*/ * from (
    (select /*+no_rewrite*/c1,c3 from t1 where c1 < 5 except (select /*+no_rewrite*/c2, sum(c3) from t2 group by c2))
        union all
    (select /*+no_rewrite*/c1,rank()over(partition by c2 order by c1) from t3 intersect (select /*+no_rewrite*/distinct c2, c3 from t4 order by c2))
) where c1 > 0 and c3 < 5;

#谓词成功上拉到顶层试图，并且成功下推到其他子查询
