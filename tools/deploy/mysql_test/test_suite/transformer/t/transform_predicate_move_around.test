explain SELECT * FROM (SELECT * FROM (SELECT (SELECT MAX(t1.a1) from t1) AS a1, (SELECT MAX(t1.a2) from t1) AS a2 from t1) AS v1 WHERE v1.a1 = 'a') AS v2 LEFT OUTER JOIN t1 AS v3 ON false WHERE concat(v2.a1, v2.a2) LIKE '%Ab%';

