--disable_warnings
drop table if exists obright;
--enable_warnings

CREATE TABLE `obright` (
  `grp_id` bigint(20) NOT NULL,
  `row_id` bigint(20) NOT NULL,
  `row_hex` varchar(2048) COLLATE utf8mb4_bin NOT NULL,
  `trx_grp` bigint(20) DEFAULT NULL,
  `v1` varchar(65536) COLLATE utf8mb4_bin DEFAULT NULL,
  `v1_check` bigint(20) DEFAULT NULL,
  `v2` varchar(65536) COLLATE utf8mb4_bin DEFAULT NULL,
  `v2_check` bigint(20) DEFAULT NULL,
  `r1` int(11) DEFAULT NULL,
  `r2` int(11) DEFAULT NULL,
  `glike` varchar(4096) COLLATE utf8mb4_bin DEFAULT NULL,
  `c1` bigint(20) DEFAULT NULL,
  `c2` bigint(20) DEFAULT NULL,
  `c3` bigint(20) DEFAULT NULL,
  `c4` bigint(20) DEFAULT NULL,
  `c5` bigint(20) DEFAULT NULL,
  `c6` tinyint(4) DEFAULT NULL,
  `c7` bigint(20) DEFAULT NULL,
  `c8` bigint(20) DEFAULT NULL,
  `c9` bigint(20) DEFAULT NULL,
  `c10` bigint(20) DEFAULT NULL,
  `v3` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL,
  `ts` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  `t1` timestamp(6) NULL DEFAULT NULL,
  `t2` datetime(6) DEFAULT NULL,
  `dec1` decimal(16,4) DEFAULT NULL,
  `dec2` decimal(16,4) DEFAULT NULL,
  `dec3` decimal(16,6) DEFAULT NULL,
  `b1` tinyint(1) DEFAULT NULL,
  `d1` bigint(20) DEFAULT '0',
  `ac1` bigint(20) NOT NULL AUTO_INCREMENT,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gen_v1` varchar(10) COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`v1`,1,10)) VIRTUAL,
  `gen_v2` varchar(10) COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`v1`,1,10)) STORED,
  `a1` ARRAY(VARCHAR(65536)) DEFAULT NULL,
  `a2` ARRAY(BIGINT) DEFAULT NULL,
  `a3` ARRAY(SMALLINT) DEFAULT NULL,
  `a4` ARRAY(INT) DEFAULT NULL,
  `a5` ARRAY(TINYINT) DEFAULT NULL,
  `a6` ARRAY(FLOAT) DEFAULT NULL,
  `a7` ARRAY(DOUBLE) DEFAULT NULL,
  `a8` ARRAY(ARRAY(INT)) DEFAULT NULL,
  PRIMARY KEY (`grp_id`, `row_id`, `row_hex`),
  UNIQUE KEY `obright1_uniq` (`t1`, `grp_id`, `row_id`, `row_hex`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `obright2_uniq` (`trx_grp`, `r1`, `row_hex`, `row_id`, `grp_id`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `obright3_uniq` (`row_hex`, `grp_id`, `row_id`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `obright4_uniq` (`dec1`, `ts`, `gmt_create`, `gmt_modified`, `row_id`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `obright5_uniq` (`trx_grp`, `row_hex`, `grp_id`) STORING (`v1`, `v1_check`, `r1`, `r2`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `obright6_uniq` (`row_id`, `gen_v1`, `gen_v2`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright1` (`row_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright2` (`trx_grp`, `row_id`, `ac1`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright3` (`glike`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright4` (`t1`, `ts`, `dec1`, `dec2`) STORING (`v1`, `v1_check`, `r1`, `r2`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright5` (`v1_check`, `v2_check`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright6` (`row_hex`, `v1_check`) STORING (`r1`, `glike`, `t1`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright7` (`grp_id`, `row_id`, `row_hex`, `trx_grp`, `v1_check`, `r1`, `r2`) STORING (`v1`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright8` (`ac1`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright9` (`grp_id`, `row_id`, `row_hex`) BLOCK_SIZE 16384 LOCAL,
  KEY `obright10` (`gen_v1`, `gen_v2`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION HEAP AUTO_INCREMENT = 6657 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(each column);

delete /*+         BEGIN_OUTLINE_DATA       USE_HASH_DISTINCT(@"SET$63189727")        INDEX(@"SEL$4CBAAF6F_1" "obstress_db"."obright"@"SEL$4CBAAF6F_1" "obright2")               INDEX(@"SEL$4CBAAF6F_2" "obstress_db"."obright"@"SEL$4CBAAF6F_2" "obright2")        INDEX(@"SEL$4CBAAF6F_3" "obstress_db"."obright"@"SEL$4CBAAF6F_3" "obright5_uniq")       USE_CONCAT(@"DEL$1" 'obright.trx_grp IN (?, ? + ?, ? + ?)')           PARALLEL( AUTO )             OPTIMIZER_FEATURES_ENABLE('4.3.5.2')            END_OUTLINE_DATA  */ from obright where trx_grp in (25,25+1,25+2) order by row_id limit 6;

drop table obright;