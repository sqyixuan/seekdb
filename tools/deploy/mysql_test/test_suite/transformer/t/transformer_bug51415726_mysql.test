select distinct cast(ifnull(cast(nullif(67, subq_0.sc0) as DECIMAL), count(1) over (order by subq_0.sc7)) as DECIMAL) as sc0, (select count(c1) from test.t1) as sc6 from (select 59 as sc0, 88 as sc1, (select stddev(c2) from test.t1) as sc7 from test.t1 as ref_0 where EXISTS (select 1 from test.t1 as ref_1) limit 110) as subq_0 where subq_0.sc1 >= (select sum(c2) from test.t1);

