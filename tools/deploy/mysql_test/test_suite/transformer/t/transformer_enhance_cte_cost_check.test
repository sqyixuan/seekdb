# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create index i1 on t1(c1);
create index i2 on t2(c1);
create index i3 on t2(c2);    
insert into t1 select uniform(1,30000,random(1)), uniform(1,30000,random(1)) from table(generator(30000));
insert into t2 select uniform(1,30000,random(1)), uniform(1,30000,random(1)) from table(generator(30000));
insert into t3 values(1,1);
call dbms_stats.gather_table_stats(null,'t1'); 
call dbms_stats.gather_table_stats(null,'t2');
call dbms_stats.gather_table_stats(null,'t3');
create or replace view v as select t1.c1, t2.c2, t1.c2 as c1_2 from t1,t2 where t1.c2 = t2.c1;
create or replace view v1 as select t1.c1, t2.c2, t1.c2 as c1_2 from t1,t2 where t1.c1 = t2.c1;

--result_format 4
--explain_protocol 2

select (select distinct c2 from v where c1 = t2.c1), (select distinct c2 from v where c1 = t2.c2) from t2 where c1 = 1;
select * from v where c1 = 1 union all select * from v where c2 = 2;
select * from v where v.c1 in (select c2 from v where c1 = 1);
select * from v, (select c2 from v where c1_2 = 1) v1 where v.c1 = v1.c2;
select * from v as v1, v as v2 where v1.c1_2 = v2.c1_2 and v1.c1 in (select c1 from t3 where c2 = 1);
select * from v as v1, v as v2 where v1.c1_2 = v2.c1_2 and exists (select c1 from t3 where c2 = 1 and v1.c1 = t3.c1);
select * from t3 left join (select c2, count(*) as cnt1 from v where v.c1_2 > 5000 group by c2 union select c2, count(*) as cnt1 from v where v.c1_2 <= 5000 group by c2) v3 on t3.c1 = v3.c2;
select * from t3 where t3.c1 > any (select * from (select max(c1) as m1 from v union all select min(c1) as m1 from v) v1 where v1.m1 = t3.c2);
select * from t3 where t3.c1 > any (select max(c1) as m1 from v union all select min(c1) as m1 from v);
select * from t2, (select (select sum(c2) from t3) as a1, case when (select sum(c1) from t2) > 1 then (select sum(c1) from t2) else 2 end as a2 from t1) v where t2.c1 < v.a1;
select * from v where c1 = 1 or c2 = 2 union all select * from v where c1 = 2;
select count(*) from v1, t3 where v1.c1 = t3.c1 or v1.c2 = t3.c2 union all select count(*) from v1 where v1.c1 > 20000;

explain with cte as (select t1.c1, t2.c2, t1.c2 as c1_2 from t1,t2 where t1.c2 = t2.c1) select * from cte where c1 = 1 union all select * from cte where c2 = 2;
with cte as (select t1.c1, t2.c2, t1.c2 as c1_2 from t1,t2 where t1.c2 = t2.c1) select * from cte where c1 = 1 union all select * from cte where c2 = 2;

explain with cte as (select t3.* from t3, t2 where t3.c1=t2.c1 or t3.c2=t2.c2) select count(*) from cte A where A.c1 in (select c2 from cte B);
with cte as (select t3.* from t3, t2 where t3.c1=t2.c1 or t3.c2=t2.c2) select count(*) from cte A where A.c1 in (select c2 from cte B);

#drop table t1, t2, t3;