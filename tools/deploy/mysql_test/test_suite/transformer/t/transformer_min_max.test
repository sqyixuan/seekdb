--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
#description: transform模块测试，对比transform以后的结果与非transform的结果,验证transform正确性

--disable_warnings
DROP DATABASE IF EXISTS AGG_SUBQUERY;
--enable_warnings
CREATE DATABASE AGG_SUBQUERY;
USE AGG_SUBQUERY;

# test rewrite for count
# 对于COUNT，我们仅在FROM里面只有一张基表的时候才改写
#               value,  count,     id
create table T1(a1 int, a2 int, a3 int);
#               value,  t1_id,     id
create table T2(b1 int, b2 int, b3 int);

insert into T1 values(233333, 3, 0);
insert into T1 values(244444, 1, 1);
insert into T1 values(255555, 0, 2);
insert into T1 values(255555, 2, 3);

insert into T2 values(24, 0, 0);
insert into T2 values(24, 0, 0);

insert into T2 values(25, 1, 0);
insert into T2 values(25, 1, 0);

insert into T2 values(26, 3, 0);
insert into T2 values(26, 3, 0);

select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3);
explain select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3);

explain select /*+no_rewrite*/ a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3);
select/*+no_rewrite*/ a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3);

select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3);
explain select a1 from T1 LEFT OUTER JOIN (select count(b1) as cnt, b2 from T2 group by b2) AS TEMP on TEMP.b2 = T1.a3  where a2 = IFNULL(cnt, 0);

# test rewrite for sum
#               value,  sum,       id
create table T3(a1 int, a2 int, a3 int);
#               value,  t1_id,     id
create table T4(b1 int, b2 int, b3 int);

insert into T3 values(233333, 37, 0);
insert into T3 values(244444, 158, 1);
insert into T3 values(255555, 0, 2);
insert into T3 values(255555, 56, 3);

insert into T4 values(24, 0, 0);
insert into T4 values(12, 0, 0);

insert into T4 values(25, 1, 0);
insert into T4 values(133, 1, 0);

insert into T4 values(26, 3, 0);
insert into T4 values(26, 3, 0);
sleep 3;

select a1 from T3 where a2 = (select sum(b1) from T4 where T4.b2 = T3.a3);
explain select a1 from T3 where a2 = (select sum(b1) from T4 where T4.b2 = T3.a3);

explain select /*+no_rewrite*/ a1 from T3 where a2 = (select sum(b1) from T4 where T3.a2 = T4.b3);
select /*+no_rewrite*/ a1 from T3 where a2 = (select sum(b1) from T4 where T3.a2 = T4.b3);

select a1 from T3 where a2 = (select sum(b1) from T4 where T4.b2 = T3.a3);
explain select a1 from T3, (select sum(b1) as sum_b1, b2 from T4 group by b2) AS TEMP where TEMP.b2 = T3.a3 and a2 = sum_b1;

# test for multi-condition
explain select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3 AND T2.b3 = T1.a3);
explain select a1 from T3 where a2 = (select sum(b1) from T4 where T4.b2 = T3.a3 AND T4.b3 = T3.a3);

# 多个表的情况
explain select T1.a1 from T1, T3 where T1.a2 = (select sum(b1) from T2 where T1.a3 = T2.b1 and T2.b1 = T3.a3);

# test for multi-subquery
explain select a1 from T1 where a2 = (select sum(b1) from T2 where T2.b2 = T1.a3) AND (select sum(a1) from T3 where T3.a2 = a3);

# 对于count，我们现在要求FROM里面只有一项，所以这种情况SUM会发生改写，而COUNT不会发生改写
explain select a1 from T1 where a2 = (select sum(b1) from T2 where T2.b2 = T1.a3) AND (select count(a1) from T3 where T3.a2 = a3);

explain select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3) AND (select sum(a1) from T3 where T3.a2 = a3);
explain select a1 from T1 where a2 = (select count(b1) from T2 where T2.b2 = T1.a3) AND (select count(a1) from T3 where T3.a2 = a3);

# 子查询中的WHERE子句非连接条件中包含了没有在SELECT中的列
# 改写的时候需要将这一列加入到SELECT ITEM中
SELECT a1 FROM T1 WHERE a2 = (SELECT COUNT(b1) FROM T2 WHERE T2.b2 = T1.a3 AND T2.b3 = 5);

#bug 16651881, [rqg]复杂子查询resolve报-4016 
#
CREATE TABLE table0_bigint(
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`col_char_20` char(20) DEFAULT NULL,
`col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
`pk` bigint(20) NOT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
PRIMARY KEY (`pk`)
);

#Q1 最原始语句
SELECT CAST(CONCAT(CAST(CONCAT(col_char_20, SUBSTR('v', 1, 20)) AS CHAR(100)), col_char_20) AS CHAR(100))
FROM table0_bigint
WHERE CAST(CONCAT(col_char_20, SUBSTR((
SELECT GROUP_CONCAT(99 ORDER BY (
SELECT coalesce((
SELECT SUM(2335)
FROM table0_bigint
WHERE EXISTS (
SELECT *
FROM table0_bigint table1
INNER JOIN table0_bigint table2 USING (pk)
WHERE table1.col_bigint > ROUND(CEIL(-100))
ORDER BY table1.pk DESC, table1.col_decimal_20_0 ASC, table1.pk
LIMIT 6
)
ORDER BY pk DESC, col_timestamp_6, col_char_20 DESC, pk DESC
), (
SELECT SUM(ROUND(FLOOR(-99999)))
FROM table0_bigint
WHERE SUBSTR('vunm', 1, 20) <> CAST(CONCAT(col_char_20, SUBSTR('g', 1, 20)) AS CHAR(100))
ORDER BY col_decimal_20_0, col_timestamp_6 DESC, col_char_20 ASC, pk
), -100)
) ASC, pk ASC SEPARATOR '')
FROM table0_bigint
WHERE ROUND(ABS(col_decimal_20_0)) > col_decimal_20_0
ORDER BY pk DESC, col_bigint ASC, pk ASC, pk ASC
LIMIT 5, 3
), 1, 20)) AS CHAR(100)) <=> COALESCE(col_char_20, col_char_20, col_char_20)
FOR UPDATE;

#Q2 简化重现的例子
create table tt(c int);
SELECT GROUP_CONCAT(99 ORDER BY (
    SELECT 44
    FROM dual
    WHERE EXISTS (
    SELECT 1
    FROM tt x join tt y using(c)
    )
) ASC )
FROM dual;

#不报错
SELECT GROUP_CONCAT(99 ORDER BY (
    SELECT 44
    FROM dual
    WHERE EXISTS (
    SELECT 1
    FROM tt x , tt y where x.c = y.c
    )
) ASC )
FROM dual;

#报错
SELECT sum(
    (SELECT 44
    FROM dual
    WHERE EXISTS (
    SELECT 1
    FROM tt x join tt y using(c)
    ))
)
FROM dual;

#报错
SELECT sum(
    (SELECT 1
    FROM tt x join tt y using(c))
)
FROM dual;

SELECT sum(
    (SELECT 1
    FROM tt x left join tt y on x.c = y.c)
)
FROM dual;

#不报错
SELECT sum(
    (SELECT 1
    FROM tt x, tt y where x.c = y.c)
)
FROM dual;

