
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer

--result_format 4
--explain_protocol 2
--enable_sorted_result

--disable_warnings
DROP DATABASE IF EXISTS SUBQUERY_PULLUP;
--enable_warnings
CREATE DATABASE SUBQUERY_PULLUP;
USE SUBQUERY_PULLUP;

--let $case_idx= 0
CREATE TABLE t1(c1 int primary key, c2 int);
CREATE TABLE t2(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE t3(c1 int primary key, c2 int, c3 varchar(32));
CREATE TABLE pullup1(pk int primary key, c1 int, uniq_c2 int, c3 int, unique key(uniq_c2));
CREATE TABLE pullup2(pk int primary key, c1 int, uniq_c2 int, c3 int, unique key(uniq_c2));
CREATE TABLE pullup3(pk int primary key, c1 int, uniq_c2 int, c3 int, unique key(uniq_c2));
CREATE TABLE is_c1(c1 int);
CREATE TABLE is_t1(c1 int, c2 int);
CREATE TABLE is_t2(c1 int, c2 int, c3 varchar(32));
CREATE TABLE is_t3(c1 int, c2 int, c3 varchar(32));
CREATE TABLE is_pullup1(pk int, c1 int, uniq_c2 int, c3 int);
CREATE TABLE is_pullup2(pk int, c1 int, uniq_c2 int, c3 int);
CREATE TABLE is_pullup3(pk int, c1 int, uniq_c2 int, c3 int);
CREATE TABLE uniq_varchar(pk varchar(32) primary key);

--disable_query_log
--let $count= 1
while($count < 100)
{
      --let $stmt=insert/*trace*/INTO t1 VALUES($count, $count + 1)
      eval $stmt;
      inc $count;
      --let $stmt=insert/*trace*/INTO t2 VALUES($count, $count + 1, "test")
      eval $stmt;
      inc $count;
      --let $stmt=insert/*trace*/INTO t3 VALUES($count, $count + 1, "test")
      eval $stmt;
      inc $count;
      --let $stmt=insert/*trace*/INTO pullup1 VALUES($count, $count + 1, $count, 3)
      eval $stmt;
      inc $count;
      --let $stmt=insert/*trace*/INTO pullup2 VALUES($count, $count + 1, $count, 3)
      eval $stmt;
      inc $count;
      --let $stmt=insert/*trace*/INTO pullup3 VALUES($count, $count + 1, $count, 3)
      eval $stmt;
      inc $count;
}
insert into uniq_varchar values("0"), ("00"), ("000"), ("0000"), ("00000"), ("000000");
--enable_query_log

--echo
--inc $case_idx
--echo # case $case_idx
select /*+ no_rewrite() */* from t1 where t1.c1 > 10 and t1.c1 in (select c2 from t2);
select * from t1 where t1.c1 > 10 and t1.c1 in (select c2 from t2);
start transaction;
update t1 set c1 = c2 + 1  where t1.c1 > 10 and t1.c1 in (select c2 from t2);
delete from t1 where t1.c1 > 10 and t1.c1 in (select c2 from t2);
insert into is_t1 select * from t1 where t1.c1 > 10 and t1.c1 in (select c2 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx
select  /*+ no_rewrite() */* from t1 where t1.c1 In (select c1 from t2);
select * from t1 where t1.c1 In (select c1 from t2);
start transaction;
update t1 set c1 = c2 + 1 where t1.c1 In (select c1 from t2);
delete from t1 where t1.c1 In (select c1 from t2);
insert into is_t1 select * from t1 where t1.c1 In (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated EXISTS Subquery
select /*+ no_rewrite() */ * from t1 where Exists (select c1 from t2);
select * from t1 where Exists (select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where Exists (select c1 from t2);
delete from t1 where Exists (select c1 from t2);
insert into is_t1 select * from t1 where Exists (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ANY Subquery
select /*+ no_rewrite() */ * from t1 where c1 In (select c1 from t2);
select * from t1 where c1 In (select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where  c1 In (select c1 from t2);
delete from t1 where c1 In (select c1 from t2);
insert into is_t1 select * from t1 where c1 In (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ANY Subquery
select /*+ no_rewrite() */ * from t1 where c1 =ANY (select c1 from t2);
select * from t1 where c1 =ANY (select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where  c1 =ANY (select c1 from t2);
delete from t1 where c1 =ANY (select c1 from t2);
insert into is_t1 select * from t1 where c1 =ANY (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ANY Subquery
select /*+ no_rewrite() */ * from t1 where c1 >ANY (select c1 from t2);
select * from t1 where c1 >ANY (select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where  c1 >ANY (select c1 from t2);
delete from t1 where c1 >ANY (select c1 from t2);
insert into is_t1 select * from t1 where c1 >ANY (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ALL Subquery, can be pulled up
select /*+ no_rewrite() */ * from t1 where c1 <ALL (select c1 from t2);
select * from t1 where c1 <ALL (select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where  c1 <ALL (select c1 from t2);
delete from t1 where c1 <ALL (select c1 from t2);
insert into is_t1 select * from t1 where c1 <ALL (select c1 from t2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: [PULLUP AS VIEW LEFT SEMI]non-correlated ALL Subquery, contains LIMIT
select /*+ no_rewrite() */ * from t1 where c1 <ALL (select c1 from t2 limit 1);
select * from t1 where c1 <ALL (select c1 from t2 limit 1);
start transaction;
update t1 set c1 = c2+1 where  c1 <ALL (select c1 from t2 limit 1);
delete from t1 where c1 <ALL (select c1 from t2 limit 1);
insert into is_t1 select * from t1 where c1 <ALL (select c1 from t2 limit 1);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ANY Subquery, can be pulled up
select /*+ no_rewrite() */ * from t1 where 1 < ANY(select c1 from t2);
select * from t1 where 1 < ANY(select c1 from t2);
start transaction;
update t1 set c1 = c2+1 where  1 < ANY(select c1 from t2);
delete from t1 where 1 < ANY(select c1 from t2);
insert into is_t1 select * from t1 where 1 < ANY(select c1 from t2);
rollback;


--echo
--inc $case_idx
--echo # case $case_idx: non-correlated ANY Subquery, contains LIMIT, cannot be pulled up
select /*+ no_rewrite() */ * from t1 where 1 < ANY(select c1 from t2 limit 1);
select * from t1 where 1 < ANY(select c1 from t2 limit 1);
start transaction;
update t1 set c1 = c2+1 where  1 < ANY(select c1 from t2 limit 1);
delete from t1 where 1 < ANY(select c1 from t2 limit 1);
insert into is_t1 select * from t1 where 1 < ANY(select c1 from t2 limit 1);
rollback;



--echo
--inc $case_idx
--echo # case $case_idx: multi-level non-correlated subquery
explain select/*+ no_rewrite() */ * from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
select/*+ no_rewrite() */ * from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
select * from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
start transaction;
update t1 set c1 = c2+1 where  Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
delete from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
insert into is_t1 select * from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));
rollback;


--echo
--echo # correlated subquery
--inc $case_idx
--echo # case $case_idx: correlated EXISTS subquery: can be pulled up
select /*+ no_rewrite() */ * from t1 where Exists (select c1 from t2 where t1.c2=t2.c2);
select * from t1 where Exists (select c1 from t2 where t1.c2=t2.c2);
start transaction;
update t1 set c1 = c2+1 where  Exists (select c1 from t2 where t1.c2=t2.c2);
delete from t1 where Exists (select c1 from t2 where t1.c2=t2.c2);
insert into is_t1 select * from t1 where Exists (select c1 from t2 where t1.c2=t2.c2);
rollback;


--echo
--inc $case_idx
--echo # case $case_idx: correlated ALL subquery: can be pulled up
select /*+ no_rewrite() */ * from t1 where c1 <ALL (select c1 from t2 where t1.c2=t2.c2);
select * from t1 where c1 <ALL (select c1 from t2 where t1.c2=t2.c2);
start transaction;
update t1 set c1 = c2+1 where  c1 <ALL (select c1 from t2 where t1.c2=t2.c2);
delete from t1 where c1 <ALL (select c1 from t2 where t1.c2=t2.c2);
insert into is_t1 select * from t1 where c1 <ALL (select c1 from t2 where t1.c2=t2.c2);
rollback;


--echo
--inc $case_idx
--echo # case $case_idx: correlated !=ANY subquery, contains LIMIT: cannot be pulled up
select /*+ no_rewrite() */ * from t1 where c1 !=ANY (select c1 from t2 where t1.c2=t2.c2 limit 1);
select * from t1 where c1 !=ANY (select c1 from t2 where t1.c2=t2.c2 limit 1);
start transaction;
update t1 set c1 = c2+1 where  c1 !=ANY (select c1 from t2 where t1.c2=t2.c2 limit 1);
delete from t1 where c1 !=ANY (select c1 from t2 where t1.c2=t2.c2 limit 1);
insert into is_t1 select * from t1 where c1 !=ANY (select c1 from t2 where t1.c2=t2.c2 limit 1);
rollback;

--inc $case_idx
--echo # case $case_idx
select /*+ no_rewrite() */ * from t1 where exists (select c1 from t2 where t1.c1 = t2.c1);
select * from t1 where exists (select c1 from t2 where t1.c1 = t2.c1);
start transaction;
update t1 set c1 = c2+1 where  exists (select c1 from t2 where t1.c1 = t2.c1);
delete from t1 where exists (select c1 from t2 where t1.c1 = t2.c1);
