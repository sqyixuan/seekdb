set autocommit=0;

DELETE FROM pp WHERE PK IN (SELECT PK FROM (SELECT DISTINCT COUNT(DISTINCT OUTR . `col_date` ) AS X FROM B AS OUTR WHERE ( OUTR . `col_int` , OUTR . `col_int_key` ) IN ( SELECT  INNR . `col_int` AS X , INNR . `col_int_key` AS Y FROM BB AS INNR WHERE INNR . `col_int` > 0 OR NOT OUTR . `col_date` IS NULL  ) AND OUTR . `col_datetime` BETWEEN '2007-08-28' AND '2007-11-10'  ORDER BY OUTR . `col_int` , OUTR . `pk`)TC1);
rollback;
DELETE /*+no_rewrite*/ FROM pp WHERE PK IN (SELECT PK FROM (SELECT DISTINCT COUNT(DISTINCT OUTR . `col_date` ) AS X FROM B AS OUTR WHERE ( OUTR . `col_int` , OUTR . `col_int_key` ) IN ( SELECT  INNR . `col_int` AS X , INNR . `col_int_key` AS Y FROM BB AS INNR WHERE INNR . `col_int` > 0 OR NOT OUTR . `col_date` IS NULL  ) AND OUTR . `col_datetime` BETWEEN '2007-08-28' AND '2007-11-10'  ORDER BY OUTR . `col_int` , OUTR . `pk`)TC1);
rollback;

select pk from pp WHERE PK IN (SELECT PK FROM (SELECT COUNT( 1 ) AS X FROM B AS OUTR WHERE false));
select /*+no_rewrite*/ pk from pp WHERE PK IN (SELECT PK FROM (SELECT COUNT( 1 ) AS X FROM B AS OUTR WHERE false));

select pk from pp WHERE PK IN (SELECT PK FROM (SELECT DISTINCT COUNT(DISTINCT 1 ) AS X  from dual WHERE false));
select /*+no_rewrite*/ pk from pp WHERE PK IN (SELECT PK FROM (SELECT DISTINCT COUNT(DISTINCT 1 ) AS X  from dual WHERE false));

DELETE FROM x WHERE PK IN (SELECT PK FROM (SELECT DISTINCT OUTR . col_varchar_20_key AS X FROM C AS OUTR WHERE OUTR . `col_int` IN ( SELECT  INNR . `col_int_key` AS Y FROM BB AS INNR WHERE INNR . `pk` <= INNR . `col_int_key` OR INNR . `col_int` > INNR . `col_int` ORDER BY INNR . `pk` ) AND OUTR . col_varchar_20_key IS NOT NULL AND NOT OUTR . col_varchar_20_key IS NULL  ORDER BY OUTR . `col_datetime_key` , OUTR . `pk`)TC1);
rollback;
DELETE /*+no_rewrite*/ FROM x WHERE PK IN (SELECT PK FROM (SELECT DISTINCT OUTR . col_varchar_20_key AS X FROM C AS OUTR WHERE OUTR . `col_int` IN ( SELECT  INNR . `col_int_key` AS Y FROM BB AS INNR WHERE INNR . `pk` <= INNR . `col_int_key` OR INNR . `col_int` > INNR . `col_int` ORDER BY INNR . `pk` ) AND OUTR . col_varchar_20_key IS NOT NULL AND NOT OUTR . col_varchar_20_key IS NULL  ORDER BY OUTR . `col_datetime_key` , OUTR . `pk`)TC1);

set autocommit=1;
DROP TABLE IF EXISTS `pp`, `bb`, `b`, `c`, `x`;


