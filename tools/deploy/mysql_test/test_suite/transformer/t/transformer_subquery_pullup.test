select /*+no_rewrite*/ * from t_abc where 1 in (select 1 from t_xyz where a = x);
select * from t_abc where 1 in (select 1 from t_xyz where b = y);
select /*+no_rewrite*/ * from t_abc where 1 in (select 1 from t_xyz where b = y);

##right hand const
select * from t_abc where a in (select 1 from t_xyz);
select /*+no_rewrite*/ * from t_abc where a in (select 1 from t_xyz);
select * from t_abc where a in (select 1 from t_xyz where a = x);
select /*+no_rewrite*/ * from t_abc where a in (select 1 from t_xyz where a = x);
select * from t_abc where a in (select 1 from t_xyz where a = y);
select /*+no_rewrite*/ * from t_abc where a in (select 1 from t_xyz where a = y);
select * from t_abc where a in (select 1 from t_xyz where a = z);
select /*+no_rewrite*/ * from t_abc where a in (select 1 from t_xyz where a = z);

## not unique
select * from t_abc where a in (select b from t_xyz);
select /*+no_rewrite*/ * from t_abc where a in (select b from t_xyz);

## generated table
select * from t_abc where a in (select * from (select b from t_xyz where b = 100));
select /*+no_rewrite*/ * from t_abc where a in (select * from (select b from t_xyz where b = 100));
select * from t_abc where a in (select tmp from (select x + 1 as tmp from t_xyz) as v);
select /*+no_rewrite*/ * from t_abc where a in (select tmp from (select x + 1 as tmp from t_xyz) as v);
select * from t_abc where a in (select distinct y from (select y from t_xyz));
select /*+no_rewrite*/ * from t_abc where a in (select distinct y from (select y from t_xyz));

## join table 
select * from t_abc where a in (select b + c2 from t_xyz join t_ccc on b = c2);
select /*+no_rewrite*/ * from t_abc where a in (select b + c2 from t_xyz join t_ccc on b = c2);

