insert/*trace*/into TA3 values(1, 16, 23);
insert/*trace*/into TA3 values(2, 555, 27);
insert/*trace*/into TA3 values(999, 999, 999);

insert/*trace*/into TA4 values(3, 3, 0);
insert/*trace*/into TA4 values(1, 1, 1);
insert/*trace*/into TA4 values(0, 0, 2);
insert/*trace*/into TA4 values(2, 2, 3);
insert/*trace*/into TA4 values(6, 6, 3);
insert/*trace*/into TA4 values(1, 16, 23);
insert/*trace*/into TA4 values(2, 555, 27);
insert/*trace*/into TA4 values(999, 999, 999);

insert/*trace*/into TA5 values(24, 0, 0);
insert/*trace*/into TA5 values(24, 0, 0);
insert/*trace*/into TA5 values(25, 1, 0);
insert/*trace*/into TA5 values(25, 1, 0);
insert/*trace*/into TA5 values(26, 3, 0);
insert/*trace*/into TA5 values(26, 3, 0);
insert/*trace*/into TA5 values(999, 999, 999);

insert/*trace*/into TA6 values(-33, -44);
insert/*trace*/into TA6 values(-44, -33);
insert/*trace*/into TA6 values(-77, -88);
insert/*trace*/into TA6 values(-88, -77);
insert/*trace*/into TA6 values(-5, 6);
insert/*trace*/into TA6 values(6, -5);
insert/*trace*/into TA6 values(-11, -9);
insert/*trace*/into TA6 values(-9, -11);
sleep 3;
--enable_query_log


--echo
--inc $case_idx
--echo # case $case_idx
--echo # [TO LEFT SEMI]
SELECT /*+ no_rewrite() */ a1 FROM TA1 where a2 IN (SELECT b2 FROM TA2);
SELECT a1 FROM TA1 where a2 IN (SELECT b2 FROM TA2);
start transaction;
UPDATE TA1 SET  a1 = a2 + 1 where a2 IN (SELECT b2 FROM TA2);
delete FROM TA1 where a2 IN (SELECT b2 FROM TA2);
insert into is_c1 SELECT a1 FROM TA1 where a2 IN (SELECT b2 FROM TA2);
rollback;

--echo
--inc $case_idx
--echo # case $case_idx
