SELECT a1 FROM TA1 where a2 IN (SELECT * FROM (SELECT c1 FROM (SELECT /*+ index(TA6 primary) */ c1 FROM TA6 order by c2 LIMIT 1) order by c1 LIMIT 3) order by c1 LIMIT 2);
start transaction;
UPDATE TA1 SET  a1 = a2 + 1 where a2 IN (SELECT * FROM (SELECT c1 FROM (SELECT /*+ index(TA6 primary) */ c1 FROM TA6 order by c2 LIMIT 1) order by c1 LIMIT 3) order by c1 LIMIT 2);
delete FROM TA1 where a2 IN (SELECT * FROM (SELECT c1 FROM (SELECT /*+ index(TA6 primary) */ c1 FROM TA6 order by c2 LIMIT 1) order by c1 LIMIT 3) order by c1 LIMIT 2);
insert into is_c1 SELECT a1 FROM TA1 where a2 IN (SELECT * FROM (SELECT c1 FROM (SELECT /*+ index(TA6 primary) */ c1 FROM TA6 order by c2 LIMIT 1) order by c1 LIMIT 3) order by c1 LIMIT 2);
rollback;


