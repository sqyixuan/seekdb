--explain_protocol 0
set autocommit=1;
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);
insert into t1 values(1, 1), (3, 2), (2, 3), (NULL, NULL);
insert into t2 values(1, 1), (3, 3);
insert into t3 values(NULL, NULL);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;

--explain_protocol 2
# exists in select item
select exists(select 1 from t1) as e, c1, c2 from t2;
select /*+no_rewrite*/ exists(select 1 from t1) as e, c1, c2 from t2;

select not exists(select 1 from t1) as e, c1, c2 from t2;
select /*+no_rewrite*/ not exists(select 1 from t1) as e, c1, c2 from t2;

select (case when exists (select 1 from t1,t2 where t1.c1 = t2.c1) then 0 else c1 + 1 end) e, c1, c2 from t1;
select /*+no_rewrite*/ (case when exists (select 1 from t1,t2 where t1.c1 = t2.c1) then 0 else c1 + 1 end) e, c1, c2 from t1;

# exists in group by item
select max(c1) from t1 group by exists (select 1 from t2);
select /*+no_rewrite*/ max(c1) from t1 group by exists (select 1 from t2);

select max(c1) from t1 group by case when exists(select 1 from t2 where t1.c1 = t2.c1) then c1 else c2 end;
select /*+no_rewrite*/ max(c1) from t1 group by case when exists(select 1 from t2 where t1.c1 = t2.c1) then c1 else c2 end;

# exists in order by item
select * from t1 order by exists(select 1 from t1);
select /*+no_rewrite*/ * from t1 order by exists(select 1 from t1);

select * from t1 order by case when exists(select 1 from t2) then c1 else c2 end;
select /*+no_rewrite*/ * from t1 order by case when exists(select 1 from t2) then c1 else c2 end;

# exists in having item
select * from t1 having case when exists(select 1 from t1) then c1 = min(c2) else c1 > 0 end;
select /*+no_rewrite*/ * from t1 having case when exists(select 1 from t1) then c1 = min(c2) else c1 > 0 end;

