select * from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3) order by 1;
select /*+no_rewrite*/ * from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3) order by 1;

select * from t1 where (case when c1 is null then 1 else c2 end) in (select c1 from t2) or (case when c1 is null then 1 else c2 end) in (select c1 from t3) order by 1;
select /*+no_rewrite*/ * from t1 where (case when c1 is null then 1 else c2 end) in (select c1 from t2) or (case when c1 is null then 1 else c2 end) in (select c1 from t3) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1=t1.c1) or exists (select c1 from t3 where t3.c1=t1.c1) order by 1;
select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1=t1.c1) or exists (select c1 from t3 where t3.c1=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1+1=t1.c1) or exists (select c1 from t3 where t3.c1+2=t1.c1) order by 1;
select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1+1=t1.c1) or exists (select c1 from t3 where t3.c1+2=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1!=t1.c1) or exists (select c1 from t3 where t3.c1!=t1.c1) order by 1;
select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1!=t1.c1) or exists (select c1 from t3 where t3.c1!=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1>=t1.c1) or exists (select c1 from t3 where t3.c1>=t1.c1) order by 1;
select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1>=t1.c1) or exists (select c1 from t3 where t3.c1>=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1+t1.c1 = 4) or exists (select c1 from t3 where t3.c1+t1.c1 = 4) order by 1;
select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1+t1.c1 = 4) or exists (select c1 from t3 where t3.c1+t1.c1 = 4) order by 1;

select * from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3)  or c1 in (select c1 from t3)  or c1 in (select c1 from t3) order by 1;
select /*+no_rewrite*/ * from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3)  or c1 in (select c1 from t3)  or c1 in (select c1 from t3) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2
                       union all select c1 from t3 A where A.c3 = t1.c2 and A.c1=t1.c1
                       union all select c1 from t3 B where B.c2 = t1.c2 and B.c3=t1.c1) order by 1;

select /*+no_rewrite*/ * from t1 where  exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2
                       union all select c1 from t3 A where A.c3 = t1.c2 and A.c1=t1.c1
                       union all select c1 from t3 B where B.c2 = t1.c2 and B.c3=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2
                       except select c1 from t3 A where A.c3 = t1.c2 and A.c1=t1.c1
                       union all select c1 from t3 B where B.c2 = t1.c2 and B.c3=t1.c1) order by 1;

