select 1 from t1 where c1 not in (select c1 from t2 where c2 != (select avg((select min(1) from t3)) from t1));
select /*+no_rewrite*/1 from t1 where c1 not in (select /*+no_rewrite*/c1 from t2 where c2 != (select avg((select min(1) from t3)) from t1));

drop table t1,t2,t3,table5_hash_pk_parts_1_bigint,table2_hash_pk_parts_1_bigint,table1_key_pk_parts_1_bigint,table10_key_pk_parts_1_bigint,table0_hash_pk_parts_1_bigint;

