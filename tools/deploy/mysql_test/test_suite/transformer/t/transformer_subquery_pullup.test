select /*+no_rewrite*/ * from tmp where tmp.pk not in (select distinct t2.c2 + 2 from t t1 left join t t2 on t1.c1 = 0);

## bug: 
drop table if exists t1, t2 ,t3;
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
create table t3 (c1 int primary key, c2 int, c3 int);
select * from t1 where t1.c1 in (select t2.c1 from t2 where t1.c2 = (select min(c1) from t3) and (t2.c2 = 1 or t2.c3 = 1));
select /*+no_rewrite*/ * from t1 where t1.c1 in (select t2.c1 from t2 where t1.c2 = (select min(c1) from t3) and (t2.c2 = 1 or t2.c3 = 1));

## bug: 
