delete FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 GROUP BY pullup2.c1);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 GROUP BY pullup2.c1);
rollback;


--echo
--inc $case_idx
--echo #case $case_idx: [NO REWRITE] has set-op
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 UNION ALL SELECT pk FROM pullup3);
SELECT c1 FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 UNION ALL SELECT pk FROM pullup3);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE c1 IN (SELECT pk FROM pullup2 UNION ALL SELECT pk FROM pullup3);
delete FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 UNION ALL SELECT pk FROM pullup3);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT pk FROM pullup2 UNION ALL SELECT pk FROM pullup3);
rollback;


--echo
--inc $case_idx
--echo #case $case_idx: [NO REWRITE] left operator of this IN is a constant
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE 1 IN (SELECT c1 FROM pullup2);
SELECT c1 FROM pullup1 WHERE 1 IN (SELECT c1 FROM pullup2);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE 1 IN (SELECT c1 FROM pullup2);
delete FROM pullup1 WHERE 1 IN (SELECT c1 FROM pullup2);
insert into is_c1 SELECT c1 FROM pullup1 WHERE 1 IN (SELECT c1 FROM pullup2);
rollback;


--echo
--inc $case_idx
--echo #case $case_idx: [TO SEMI] select item of sub-query is a constant
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE c1 IN (SELECT 1 FROM pullup2);
SELECT c1 FROM pullup1 WHERE c1 IN (SELECT 1 FROM pullup2);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE c1 IN (SELECT 1 FROM pullup2);
delete FROM pullup1 WHERE c1 IN (SELECT 1 FROM pullup2);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT 1 FROM pullup2);
rollback;


--echo
--inc $case_idx
--echo #case $case_idx: [TO SEMI] select item of sub-query is not a regular column
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE c1 IN (SELECT floor(pk) FROM pullup2);
SELECT c1 FROM pullup1 WHERE c1 IN (SELECT floor(pk) FROM pullup2);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE c1 IN (SELECT floor(pk) FROM pullup2);
delete FROM pullup1 WHERE c1 IN (SELECT floor(pk) FROM pullup2);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT floor(pk) FROM pullup2);
rollback;


--echo
--echo # case pull up sub-query to inner join: cannot be pulled up:
--inc $case_idx
--echo # case $case_idx: [TO SEMI] not unique key
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE c1 IN (SELECT c1 FROM pullup2);
SELECT c1 FROM pullup1 WHERE c1 IN (SELECT c1 FROM pullup2);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE c1 IN (SELECT c1 FROM pullup2);
delete FROM pullup1 WHERE c1 IN (SELECT c1 FROM pullup2);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT c1 FROM pullup2);
rollback;


--echo
--inc $case_idx
--echo # case $case_idx: [TO SEMI] more than one FromItem
SELECT /*+ no_rewrite() */ c1 FROM pullup1 WHERE c1 IN (SELECT pullup2.pk FROM pullup2, pullup3);
SELECT c1 FROM pullup1 WHERE c1 IN (SELECT pullup2.pk FROM pullup2, pullup3);
start transaction;
UPDATE pullup1 SET c1 = c1 + 1 WHERE c1 IN (SELECT pullup2.pk FROM pullup2, pullup3);
delete FROM pullup1 WHERE c1 IN (SELECT pullup2.pk FROM pullup2, pullup3);
insert into is_c1 SELECT c1 FROM pullup1 WHERE c1 IN (SELECT pullup2.pk FROM pullup2, pullup3);
rollback;


--echo
--echo #--------------------------------------------------------------------
--echo #| description: 测试将和外查询无关联的IN(subquery),
--echo #|              NOT IN(subquery)提升为SEMI JOIN或INNER JOIN的场景
--echo #|              这里测试的是将subquery整个提升的改写方式
--echo #--------------------------------------------------------------------
create table TA1(a1 int, a2 int, a3 int);
create table TA2(b1 int, b2 int, b3 int);
# TA3 is the same as TA1 except that a2 is primary key
create table TA3(a1 int, a2 int key, a3 int);
# TA4 is the same as TA1 except that a2 is not null
create table TA4(a1 int, a2 int NOT NULL, a3 int);
# TA5 is the same as TA2 except that b2 is not null
create table TA5(b1 int, b2 int NOT NULL, b3 int);

create table TA6(c1 int, c2 int, primary key(c1), index idx_c2(c2));

--disable_query_log
insert/*trace*/into TA1 values(3, 3, 0);
insert/*trace*/into TA1 values(1, 1, 1);
insert/*trace*/into TA1 values(0, 0, 2);
insert/*trace*/into TA1 values(2, 2, 3);
insert/*trace*/into TA1 values(6, 6, 3);
insert/*trace*/into TA1 values(1, 16, 23);
insert/*trace*/into TA1 values(2, 555, 27);
insert/*trace*/into TA1 values(999, NULL, 999);

