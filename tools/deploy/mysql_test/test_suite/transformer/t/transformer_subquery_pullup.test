SELECT 1 FROM   cc AS table1
WHERE  ( table1 . `col_varchar` IN
        (SELECT SUBQUERY1_t1 . `col_varchar_10_key` FROM   c AS SUBQUERY1_t1 WHERE  SUBQUERY1_t1 . `col_varchar_10` < table1 . `col_varchar`
        AND EXISTS (SELECT DISTINCT `col_int_key`  FROM   c WHERE  `pk` = SUBQUERY1_t1 . `pk` )) );

SELECT 1 FROM   cc AS table1
WHERE  ( table1 . `col_varchar` IN
        (SELECT /*+no_unnest*/ SUBQUERY1_t1 . `col_varchar_10_key` FROM   c AS SUBQUERY1_t1 WHERE  SUBQUERY1_t1 . `col_varchar_10` < table1 . `col_varchar`
        AND EXISTS (SELECT /*+no_unnest*/ DISTINCT `col_int_key`  FROM   c WHERE  `pk` = SUBQUERY1_t1 . `pk` )) );

