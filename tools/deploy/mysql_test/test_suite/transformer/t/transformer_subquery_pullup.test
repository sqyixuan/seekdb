select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2) or exists (select c1 from t3 where t3.c3 = t1.c2 and t3.c1=t1.c1) order by 1;

select * from t1 where exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2) 
                       or exists (select c1 from t3 A where A.c3 = t1.c2 and A.c1=t1.c1)
                       or exists (select c1 from t3 B where B.c2 = t1.c2 and B.c3=t1.c1) order by 1;

select /*+no_rewrite*/ * from t1 where exists (select c1 from t2 where t2.c1=t1.c1 and t2.c2 = t1.c2) 
                       or exists (select c1 from t3 A where A.c3 = t1.c2 and A.c1=t1.c1)
                       or exists (select c1 from t3 B where B.c2 = t1.c2 and B.c3=t1.c1) order by 1;

