select count(*) from nn;
select count(*) from gg;
select count(*) from i;
select count(*) from mm;
select count(*) from dd;
--enable_query_log
--enable_result_log

# the case runs too slow, much slower than MySQL, need revisit
EXPLAIN SELECT DISTINCT GRANDPARENT1 . col_varchar_20 AS G1
FROM nn AS GRANDPARENT1
LEFT JOIN gg AS GRANDPARENT2 ON (GRANDPARENT2 . `pk` >= GRANDPARENT1 . `col_int_key`)
WHERE (GRANDPARENT1 . `col_varchar_10_key`,
       GRANDPARENT1 . `col_varchar_20_key`) IN
    (SELECT PARENT1 . `col_varchar_20` AS P1,
            PARENT1 . `col_varchar_10` AS P2
     FROM gg AS PARENT1
     LEFT JOIN mm AS PARENT2 ON (PARENT1 . `col_varchar_10` <> PARENT2 . `col_varchar_10_key`)
     WHERE (PARENT1 . `col_varchar_10`,
            PARENT1 . `col_varchar_10_key`) IN
         (SELECT DISTINCT CHILD1 . `col_varchar_10` AS C1,
                          CHILD1 . `col_varchar_20_key` AS C2
          FROM i AS CHILD1
          LEFT JOIN dd AS CHILD2 USING (col_varchar_20)
          WHERE ((CHILD1 . `col_int` > GRANDPARENT1 . `col_int`)
                 OR NOT ((CHILD1 . `col_varchar_10` > CHILD1 . `col_varchar_20_key`)
                         OR ((CHILD1 . `col_int_key` = GRANDPARENT1 . `col_int_key`)
                             OR ((CHILD1 . `col_datetime` <= GRANDPARENT1 . `col_datetime_key`)
                                 AND ((CHILD1 . `col_datetime_key` = '2004-04-27')
                                      OR NOT (PARENT1 . `col_varchar_20` > 'c')))))) )
       AND (GRANDPARENT1 . `col_date` >= '2000-11-06') )
  AND (GRANDPARENT1 . col_varchar_20 IS NOT NULL
       OR GRANDPARENT1 . col_varchar_20 IS UNKNOWN)
GROUP BY GRANDPARENT1 . col_varchar_20
ORDER BY GRANDPARENT1 . col_varchar_20
LIMIT 4
;

DROP TABLE `nn`, `i`, `gg`, `mm`, `dd`;

# bug: 
--disable_warnings
drop table if exists b, c, d, cc;
--enable_warnings
--disable_result_log
CREATE TABLE `b` (
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) 
) ;
CREATE TABLE `c` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) 
) ;
CREATE TABLE `d` (
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) 
) ;
CREATE TABLE `cc` (
  `col_int` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
