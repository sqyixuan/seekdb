--disable_warnings
drop table if exists ftsp_kh_khxx, ftsp_kh_pg;
--enable_warnings

CREATE TABLE `ftsp_kh_khxx` (
  `id_` varchar(32) NOT NULL COMMENT '无业务意义主键',
  PRIMARY KEY (`id_`)
);

CREATE TABLE `ftsp_kh_pg` (
  `id_` varchar(32) NOT NULL COMMENT '无业务意义主键ID',
  `kh_khxx_id_` varchar(32) DEFAULT NULL COMMENT '客户ID',
  `infra_user_id_` varchar(32) DEFAULT NULL COMMENT '用户id，记录派工到的个人。',
  c1 int, 
  c2 int,
  PRIMARY KEY (`id_`),
  UNIQUE KEY `idx_ftsp_kh_pg_1` (`kh_khxx_id_`, `infra_user_id_`, c1) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_ftsp_kh_pg_3` (`infra_user_id_`, `kh_khxx_id_`, c2) BLOCK_SIZE 16384 GLOBAL
) ;

insert into ftsp_kh_khxx values ('1');
insert into ftsp_kh_khxx values ('2');
insert into ftsp_kh_khxx values ('3');
insert into ftsp_kh_pg values ('1','1','h0000000000000486478080385785856',1,1);
insert into ftsp_kh_pg values ('2','2','h0000000000000486478080385785856',1,1);
insert into ftsp_kh_pg values ('5','5','h0000000000000486478080385785856',1,1);

explain basic SELECT 
    1
FROM
    ftsp_kh_khxx kh
WHERE kh.id_ IN (SELECT DISTINCT
            pg_.kh_khxx_id_
        FROM
            ftsp_kh_pg pg_
        WHERE pg_.kh_khxx_id_ = kh.id_
                AND pg_.infra_user_id_ = 'h0000000000000486478080385785856');

SELECT 
    1
FROM
    ftsp_kh_khxx kh
WHERE kh.id_ IN (SELECT DISTINCT
            pg_.kh_khxx_id_
        FROM
            ftsp_kh_pg pg_
        WHERE pg_.kh_khxx_id_ = kh.id_
                AND pg_.infra_user_id_ = 'h0000000000000486478080385785856');

drop table ftsp_kh_khxx, ftsp_kh_pg;