create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int);
create table t3 (c1 int, c2 int);
create table t4(pk int primary key, c1 int ,c2 int);

SELECT (SELECT c1 FROM t2 WHERE t2.c1 = t1.c1) AS s FROM t1;

SELECT (SELECT /*+unnest*/c1 FROM t2 WHERE t2.c1 = t1.c1) AS s FROM t1;

SELECT (SELECT count(*) FROM t2 WHERE t2.c1 = t1.c1) AS s FROM t1;

SELECT (SELECT /*+unnest*/count(*) FROM t2 WHERE t2.c1 = t1.c1) AS s FROM t1;

SELECT (SELECT c1 FROM t3 WHERE t3.c1 = t1.c1) AS s FROM t1;

select (select /*+unnest*/3 from t4 B, (select c1, sum(c2) as ss from t4 group by c1) C where A.pk = B.pk and B.c1 = C.c1) as ss from t4 A;
select (select /*+unnest*/ t2.c1 from t2 where t2.c1 = t1.c1 and exists (select 1 from t3 where t3.c2 = t2.c2)) as new_c2 from t1;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

