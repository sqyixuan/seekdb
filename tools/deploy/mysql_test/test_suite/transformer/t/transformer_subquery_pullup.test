--disable_result_log
select/**/ count(*) from B;
select/**/ count(*) from C;
select/**/ count(*) from BB;
--enable_result_log
--enable_query_log

SELECT DISTINCT table1 . col_varchar_10_key AS field1,
                table2 . col_varchar_20_key AS field2,
                table2 . col_varchar_20_key AS field3,
                table1 . col_varchar_20_key AS field4,
                table1 . col_int_key AS field5
FROM (B AS table1
      INNER JOIN BB AS table2 ON (table2 . `col_varchar` = table1 . `col_varchar_key`))
WHERE (table2 . `col_int` < ALL
         (SELECT SUBQUERY1_t1 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                RIGHT OUTER JOIN (C AS SUBQUERY1_t2
                                  INNER JOIN C AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`
                                                                   AND SUBQUERY1_t2 . `col_varchar_20` IN
                                                                     (SELECT CHILD_SUBQUERY1_t1 . `col_varchar_20_key` AS CHILD_SUBQUERY1_field1
                                                                      FROM B AS CHILD_SUBQUERY1_t1
                                                                      GROUP BY child_subquery1_field1))) ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`))
          WHERE SUBQUERY1_t3 . `col_varchar_10` = table2 . `col_varchar_10_key` ))
;

--ERROR 0,1235
SELECT /*+no_rewrite*/ DISTINCT table1 . col_varchar_10_key AS field1,
                table2 . col_varchar_20_key AS field2,
                table2 . col_varchar_20_key AS field3,
                table1 . col_varchar_20_key AS field4,
                table1 . col_int_key AS field5
FROM (B AS table1
      INNER JOIN BB AS table2 ON (table2 . `col_varchar` = table1 . `col_varchar_key`))
WHERE (table2 . `col_int` < ALL
         (SELECT SUBQUERY1_t1 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                RIGHT OUTER JOIN (C AS SUBQUERY1_t2
                                  INNER JOIN C AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`
                                                                   AND SUBQUERY1_t2 . `col_varchar_20` IN
                                                                     (SELECT CHILD_SUBQUERY1_t1 . `col_varchar_20_key` AS CHILD_SUBQUERY1_field1
                                                                      FROM B AS CHILD_SUBQUERY1_t1
                                                                      GROUP BY child_subquery1_field1))) ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`))
          WHERE SUBQUERY1_t3 . `col_varchar_10` = table2 . `col_varchar_10_key` ))
;

