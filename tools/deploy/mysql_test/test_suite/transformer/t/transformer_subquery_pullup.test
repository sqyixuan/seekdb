SELECT table1 . `col_varchar_key` AS field1,
       table1 . col_varchar_key AS field2,
       table1 . col_varchar_key AS field3
FROM (C AS table1
      INNER JOIN ((D AS table2
                   INNER JOIN A AS table3 ON (table3 . `col_int_key` = table2 . `col_int`))) ON (table3 . `col_int_key` = table2 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY1_t1 . `col_int_key` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                RIGHT  JOIN (C AS SUBQUERY1_t2
                             LEFT OUTER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`)) ON (SUBQUERY1_t3 . `col_varchar_20_key` = SUBQUERY1_t2 . `col_varchar_key`))
          WHERE SUBQUERY1_t2 . `pk` = table1 . `pk`
            AND SUBQUERY1_t2 . `col_varchar_20` < table3 . `col_varchar_key` ))
  AND table1 . `pk` = 140
  OR (table1 . `col_varchar` IS NULL
      AND table2 . `col_varchar_10` = table2 . `col_varchar_10`)
ORDER BY field1,
         field2,
         field3;
 
SELECT /*+no_rewrite*/table1 . `col_varchar_key` AS field1,
       table1 . col_varchar_key AS field2,
       table1 . col_varchar_key AS field3
FROM (C AS table1
      INNER JOIN ((D AS table2
                   INNER JOIN A AS table3 ON (table3 . `col_int_key` = table2 . `col_int`))) ON (table3 . `col_int_key` = table2 . `pk`))
WHERE (EXISTS
         (SELECT SUBQUERY1_t1 . `col_int_key` AS SUBQUERY1_field1
          FROM (CC AS SUBQUERY1_t1
                RIGHT  JOIN (C AS SUBQUERY1_t2
                             LEFT OUTER JOIN CC AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `pk`)) ON (SUBQUERY1_t3 . `col_varchar_20_key` = SUBQUERY1_t2 . `col_varchar_key`))
          WHERE SUBQUERY1_t2 . `pk` = table1 . `pk`
            AND SUBQUERY1_t2 . `col_varchar_20` < table3 . `col_varchar_key` ))
  AND table1 . `pk` = 140
  OR (table1 . `col_varchar` IS NULL
      AND table2 . `col_varchar_10` = table2 . `col_varchar_10`)
ORDER BY field1,
         field2,
         field3;

##简化case:
SELECT 1 FROM C AS t1 WHERE EXISTS (SELECT 1 FROM ((C AS s2 LEFT  JOIN CC AS s3 ON (s3.pk = t1.pk)) LEFT JOIN CC as s1 ON (s3 . `pk` = 1)) WHERE s2 . `pk` = t1 . `pk`);
SELECT /*+no_rewrite*/1 FROM C AS t1 WHERE EXISTS (SELECT 1 FROM ((C AS s2 LEFT  JOIN CC AS s3 ON (s3.pk = t1.pk)) LEFT JOIN CC as s1 ON (s3 . `pk` = 1)) WHERE s2 . `pk` = t1 . `pk`);

SELECT 1 FROM C AS t1 WHERE t1.pk in (SELECT s2.pk  FROM ((C AS s2 LEFT  JOIN CC AS s3 ON (s3.pk = t1.pk)) LEFT JOIN CC as s1 ON (s3 . `pk` = 1)));
SELECT /*+no_rewrite*/1 FROM C AS t1 WHERE t1.pk in (SELECT s2.pk  FROM ((C AS s2 LEFT  JOIN CC AS s3 ON (s3.pk = t1.pk)) LEFT JOIN CC as s1 ON (s3 . `pk` = 1)));

SELECT 1 FROM C AS t1 WHERE t1.pk in (SELECT s2.pk  FROM ((C AS s2 INNER  JOIN CC AS s3 ON (s3.pk = t1.pk)) INNER JOIN CC as s1 ON (s3 . `pk` = 1)));
SELECT /*+no_rewrite*/1 FROM C AS t1 WHERE t1.pk in (SELECT s2.pk  FROM ((C AS s2 INNER  JOIN CC AS s3 ON (s3.pk = t1.pk)) INNER JOIN CC as s1 ON (s3 . `pk` = 1)));

