## 原始SQl
SELECT table2 . col_int_key AS field1,
       table1 . col_varchar_20_key AS field2,
       table1 . col_varchar_20_key AS field3,
       table1 . col_varchar_20_key AS field4
FROM (CC AS table1
      RIGHT  JOIN ((CC AS table2
                    INNER JOIN D AS table3 ON (table3 . `col_varchar_10_key` = table2 . `col_varchar_key`))) ON (table3 . `col_varchar_key` = table2 . `col_varchar_10_key`))
WHERE (NOT EXISTS
         (SELECT SUBQUERY1_t2 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                RIGHT OUTER JOIN (C AS SUBQUERY1_t2
                                  INNER JOIN B AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`
                                                                   AND (4,
                                                                        6) IN
                                                                     (SELECT CHILD_SUBQUERY1_t2 . `col_int_key` AS CHILD_SUBQUERY1_field1,
                                                                             CHILD_SUBQUERY1_t1 . `col_int_key` AS child_subquery1_field2
                                                                      FROM (CC AS CHILD_SUBQUERY1_t1
                                                                            LEFT  JOIN ((CC AS CHILD_SUBQUERY1_t2
                                                                                         RIGHT  JOIN CC AS CHILD_SUBQUERY1_t3 ON (CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar_10`))) ON (CHILD_SUBQUERY1_t3 . `col_varchar` = CHILD_SUBQUERY1_t2 . `col_varchar_key`))
                                                                      GROUP BY child_subquery1_field1,
                                                                               child_subquery1_field2))) ON (SUBQUERY1_t3 . `col_int_key` = SUBQUERY1_t2 . `pk`))
          WHERE SUBQUERY1_t2 . `col_varchar` <> table3 . `col_varchar_20`
            OR SUBQUERY1_t2 . `col_varchar_20_key` <> 's' ))
  AND table1 . `col_varchar_10` IS NULL
GROUP BY field1,
         field2,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4;

SELECT /*+no_rewrite*/ table2 . col_int_key AS field1,
       table1 . col_varchar_20_key AS field2,
       table1 . col_varchar_20_key AS field3,
       table1 . col_varchar_20_key AS field4
FROM (CC AS table1
      RIGHT  JOIN ((CC AS table2
                    INNER JOIN D AS table3 ON (table3 . `col_varchar_10_key` = table2 . `col_varchar_key`))) ON (table3 . `col_varchar_key` = table2 . `col_varchar_10_key`))
WHERE (NOT EXISTS
         (SELECT SUBQUERY1_t2 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                RIGHT OUTER JOIN (C AS SUBQUERY1_t2
                                  INNER JOIN B AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`
                                                                   AND (4,
                                                                        6) IN
                                                                     (SELECT CHILD_SUBQUERY1_t2 . `col_int_key` AS CHILD_SUBQUERY1_field1,
                                                                             CHILD_SUBQUERY1_t1 . `col_int_key` AS child_subquery1_field2
                                                                      FROM (CC AS CHILD_SUBQUERY1_t1
                                                                            LEFT  JOIN ((CC AS CHILD_SUBQUERY1_t2
                                                                                         RIGHT  JOIN CC AS CHILD_SUBQUERY1_t3 ON (CHILD_SUBQUERY1_t3 . `col_varchar_key` = CHILD_SUBQUERY1_t2 . `col_varchar_10`))) ON (CHILD_SUBQUERY1_t3 . `col_varchar` = CHILD_SUBQUERY1_t2 . `col_varchar_key`))
                                                                      GROUP BY child_subquery1_field1,
                                                                               child_subquery1_field2))) ON (SUBQUERY1_t3 . `col_int_key` = SUBQUERY1_t2 . `pk`))
          WHERE SUBQUERY1_t2 . `col_varchar` <> table3 . `col_varchar_20`
            OR SUBQUERY1_t2 . `col_varchar_20_key` <> 's' ))
  AND table1 . `col_varchar_10` IS NULL
GROUP BY field1,
         field2,
         field3,
         field4
ORDER BY 1,
         field1,
         field2,
         field3,
         field4;
## 简化SQL
SELECT table3 . col_int_key AS field1
FROM D AS table3
WHERE (NOT EXISTS
         (SELECT SUBQUERY1_t2 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                    RIGHT OUTER JOIN (C AS SUBQUERY1_t2 INNER JOIN B AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key` AND false)
                ) ON (SUBQUERY1_t3 . `col_int_key` = SUBQUERY1_t2 . `pk`))
          WHERE SUBQUERY1_t2 . `col_varchar` <> table3 . `col_varchar_20`));
SELECT /*+no_rewrite*/ table3 . col_int_key AS field1
FROM D AS table3
WHERE (NOT EXISTS
         (SELECT SUBQUERY1_t2 . `col_int` AS SUBQUERY1_field1
          FROM (B AS SUBQUERY1_t1
                RIGHT OUTER JOIN (C AS SUBQUERY1_t2
                                  INNER JOIN B AS SUBQUERY1_t3 ON (SUBQUERY1_t3 . `pk` = SUBQUERY1_t2 . `col_int_key`
                                                                   AND false)) ON (SUBQUERY1_t3 . `col_int_key` = SUBQUERY1_t2 . `pk`))
          WHERE SUBQUERY1_t2 . `col_varchar` <> table3 . `col_varchar_20`));


