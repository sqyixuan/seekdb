# bug: 
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (id int primary key, c_sensitive varchar(10) collate utf8_bin, c2 int);
create table t2 (id int primary key, c_insensitive varchar(10) collate utf8_general_ci, c2 int);
--disable_query_log
insert/**/ into t1 values (1, 'a', 0);
insert/**/ into t1 values (2, 'A', 0);
insert/**/ into t2 values (1, 'a', 1);
insert/**/ into t2 values (2, 'A', 4);
--enable_query_log

## sensitive vs in-sensitive
select * from t1 where c_sensitive in (select c_insensitive from t2);
select /*+no_rewrite*/ * from t1 where c_sensitive in (select c_insensitive from t2);

select * from t2 where c_insensitive in (select c_sensitive from t1 where id = 1);
select /*+no_rewrite*/ * from t2 where c_insensitive in (select c_sensitive from t1 where id = 1);

## varchar vs int
select * from t1 where c2 in (select c_insensitive from t2);
select /*+no_rewrite*/ * from t1 where c2 in (select c_insensitive from t2);

select * from t2 where c_insensitive in (select c2 from t1 where id = 1);
select /*+no_rewrite*/ * from t2 where c_insensitive in (select c2 from t1 where id = 1);

## not null test
--disable_warnings
drop table if exists t, tmp;
--enable_warnings
create table t (c1 int, c2 int, primary key(c1, c2));
create table tmp(pk int primary key, a int);
--disable_query_log
insert/**/ into t values (1, 1), (2,2), (3,3);
--enable_query_log

## scalar aggregation output
select * from t where (c1, c2) not in (select pk, max(pk) from tmp);
select /*+no_rewrite*/ * from t where (c1, c2) not in (select pk, max(pk) from tmp);

## do not take semi conditons as null-reject ones
select * from t where c1 not in (select a from tmp S where not exists (select 1 from tmp P where P.a > S.a));
select /*+no_rewrite*/ * from t where c1 not in (select a from tmp S where not exists (select 1 from tmp P where P.a > S.a));

## do not pullup subquery in semi join condition
--disable_warnings
DROP TABLE IF EXISTS C, CC;
--enable_warnings
CREATE TABLE C (
    col_int_key int,
    col_varchar_10 varchar(10),
    col_varchar_20_key varchar(20),
    pk int,
    col_int int,
    col_varchar_key varchar (1),
    col_varchar_10_key varchar(10),
    col_varchar varchar (1),
    col_varchar_20 varchar(20),
    /*Indices*/
    key idx1(pk, col_int_key ),
    key idx7(pk, col_varchar_20_key ),
    primary key (pk) ,
    key idx3(pk, col_varchar_key ),
    key idx5(pk, col_varchar_10_key ));

CREATE TABLE CC (
    col_varchar_key varchar (1),
    col_varchar_20 varchar(20),
    col_varchar varchar (1),
    col_int int,
    col_varchar_10_key varchar(10),
    col_varchar_20_key varchar(20),
    col_int_key int,
    pk int,
    col_varchar_10 varchar(10),
    /*Indices*/
    key idx3(pk, col_varchar_key ),
    key idx5(pk, col_varchar_10_key ),
    key idx7(pk, col_varchar_20_key ),
    key idx1(pk, col_int_key ),
    primary key (pk) );

