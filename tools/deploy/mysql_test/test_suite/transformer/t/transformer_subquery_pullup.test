SELECT a1 FROM TA1 where a2 IN (SELECT b2 FROM TA2 LIMIT 6);
start transaction;
UPDATE TA1 SET  a1 = a2 + 1 where a2 IN (SELECT b2 FROM TA2 LIMIT 6);
delete FROM TA1 where a2 IN (SELECT b2 FROM TA2 LIMIT 6);
