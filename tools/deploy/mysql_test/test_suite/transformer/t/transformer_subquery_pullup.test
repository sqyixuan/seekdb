SELECT table1.col_varchar_key AS field1 , table1.col_varchar_key AS field2 FROM ((SELECT SUBQUERY1_t1 . * FROM (BB AS SUBQUERY1_t1 LEFT JOIN 
  C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int` = SUBQUERY1_t1 . `col_int_key`  )) WHERE SUBQUERY1_t2 . `col_int_key` = 7 ) AS table1 RIGHT
  OUTER JOIN B AS table2 ON (table2 . `pk` = table1 . `pk` )) WHERE (( 'g', 'y' )  IN (SELECT MAX(  SUBQUERY2_t1 . `col_varchar` ) AS 
  SUBQUERY2_field1 , COUNT(  SUBQUERY2_t1 . `col_varchar_10_key` ) AS SUBQUERY2_field2 FROM C AS SUBQUERY2_t1 WHERE  SUBQUERY2_t1 . `pk` > ANY 
  ( SELECT   CHILD_SUBQUERY1_t1 . `col_int_key` AS CHILD_SUBQUERY2_field1 FROM (C AS CHILD_SUBQUERY1_t1 INNER JOIN C AS CHILD_SUBQUERY1_t2 ON 
  (CHILD_SUBQUERY1_t2 . `col_int_key` = CHILD_SUBQUERY1_t1 . `col_int` )) WHERE CHILD_SUBQUERY1_t2 . `pk` >= SUBQUERY2_t1 . `col_int_key`))) 
  OR ( table1 . `pk`  BETWEEN 87 AND ( 87 + 191 ) OR table1 . `pk` > 87 AND table1 . `pk` < (87 + 61))   ORDER BY 1, field1, field2 ;

##强化子查询改写
--disable_warnings
drop table if exists t1, t2 ,t3;
--enable_warnings

create table t1(a int, b int, c int);
create table t2(a int, b int, c int);
create table t3(a int, b int, c int);

--disable_query_log
--disable_result_log
insert/**/ into t1 values(1,1,1);
insert/**/ into t1 values(2,2,2);
insert/**/ into t1 values(3,3,3);
insert/**/ into t1 values(4,4,4);
insert/**/ into t2 values(1,1,1);
insert/**/ into t2 values(2,2,2);
insert/**/ into t2 values(3,3,3);
insert/**/ into t2 values(4,4,4);
insert/**/ into t3 values(1,1,1);
insert/**/ into t3 values(2,2,2);
insert/**/ into t3 values(3,3,3);
insert/**/ into t3 values(4,4,4);
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_query_log
--enable_result_log

##test uncorrelated subquery contains limit 1 ==> do inner join
select * from t1 where a in (select 1 from t2 limit 1);
select /*+no_rewrite*/ * from t1 where a in (select 1 from t2 limit 1);

select * from t1 where a in (select c from t2 limit 1);
select /*+no_rewrite*/ * from t1 where a in (select c from t2 limit 1);

##test uncorrelated subquery select item is uncorrelated for current level ==> add limt 1 and do inner join
select * from t1 where a in (select 1 from t2);
select /*+no_rewrite*/ * from t1 where a in (select 1 from t2);

##test not in uncorrelated subquery contains limit 1 ==> do inner join
select * from t1 where a >any (select 1 from t2 limit 1);
select /*+no_rewrite*/ * from t1 where a >any (select 1 from t2 limit 1);

select * from t1 where a <any (select a from t2 limit 1);
select /*+no_rewrite*/ * from t1 where a <any (select a from t2 limit 1);

##test not in uncorrelated subquery add limit 1 ==> do inner join
select * from t1 where a >any (select 1 from t2);
select /*+no_rewrite*/ * from t1 where a >any (select 1 from t2);

