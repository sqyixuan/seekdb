drop table if exists obfloat, obsavepoint1, obcachetable2;
--enable_warnings
CREATE TABLE `obfloat` (
  `a` double(20,0) DEFAULT NULL,
  `b` double DEFAULT NULL,
  `c` decimal(22,8) DEFAULT NULL,
  `d` double DEFAULT NULL,
  `e` double DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`pk`)
) ;
CREATE TABLE `obsavepoint1` (
  `pk1` bigint(20) DEFAULT NULL,
  `pk2` bigint(20) DEFAULT NULL,
  `pk3` bigint(20) DEFAULT '0',
  `c1` bigint(20) DEFAULT '0',
  `c2` varchar(1024) DEFAULT '0',
  `c3` varchar(1024) DEFAULT 'obsavepoint',
  `gmt_create` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  KEY `gmt_modified` (`gmt_modified`) BLOCK_SIZE 16384 LOCAL
) ;
 CREATE TABLE `obcachetable2` (
  `pk` int(11) NOT NULL,
  `v1` varchar(1024) DEFAULT NULL,
  `v1_check` bigint(20) DEFAULT NULL,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`pk`),
  KEY `gmt_modified` (`gmt_modified`) BLOCK_SIZE 16384 LOCAL
);
select 1 from obfloat as ref_1  where EXISTS ( select 1 from  obsavepoint1 as ref_2 
where EXISTS ( select ref_1.a as c2,   sum(1) over (partition by ref_2.pk3) as c3 from  obcachetable2 as ref_3 )) ;

