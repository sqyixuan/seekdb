select /*+no_rewrite*/ * from t1 where c1 in (select t1.c1 from t2) or c1 in (select t1.c1 from t3) order by 1;

select * from t1 where c1 in (select count(*) from t2 where t2.c1 = t1.c2 group by c1) or c1 in (select sum(c2) from t3 where t3.c1 = t1.c1 group by c1) order by 1;
select /*+no_rewrite*/ * from t1 where c1 in (select count(*) from t2 where t2.c1 = t1.c2 group by c1) or c1 in (select sum(c2) from t3 where t3.c1 = t1.c1 group by c1) order by 1;

