SELECT DISTINCT MIN(DISTINCT OUTR . `col_date_key` ) AS X FROM B AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_int` > OUTR . `col_int` ) WHERE ( OUTR . `col_int` , OUTR . `pk` ) IN ( SELECT DISTINCT INNR . `col_int_key` AS X , INNR . `col_int_key` AS Y FROM CC AS INNR WHERE OUTR . `col_date` = '2008-03-05'  ) AND ( OUTR . `pk` IS NULL OR NOT OUTR . `pk` = 3 )  ORDER BY 1 DESC, OUTR . `col_datetime_key`  , OUTR . `pk` ASC ;

SELECT 1 FROM B AS OUTR2 LEFT JOIN C AS OUTR ON (1) WHERE OUTR . `pk` IN ( SELECT INNR . `col_int_key` AS Y FROM CC AS INNR) AND ( OUTR . `pk` IS NULL OR NOT OUTR . `pk` = 3 );

