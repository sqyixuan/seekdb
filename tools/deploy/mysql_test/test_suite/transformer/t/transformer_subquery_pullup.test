select * from t1 where exists (select c1 from t2 where t2.c1=t1.c1) or exists (select c1 from t3 where t3.c1 = t1.c1 and t1.c2=t3.c2) order by 1;

select * from t1 where c1 in (select t1.c1 from t2) or c1 in (select t1.c1+1 from t3) order by 1;

