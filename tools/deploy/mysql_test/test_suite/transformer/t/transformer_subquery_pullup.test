SELECT a1 FROM TA1 where a2 IN (SELECT MAX(c2) FROM (SELECT /*+ index(TA6 idx_c2) */ c2 FROM TA6 order by c1));
start transaction;
UPDATE TA1 SET  a1 = a2 + 1 where a2 IN (SELECT MAX(c2) FROM (SELECT /*+ index(TA6 idx_c2) */ c2 FROM TA6 order by c1));
delete FROM TA1 where a2 IN (SELECT MAX(c2) FROM (SELECT /*+ index(TA6 idx_c2) */ c2 FROM TA6 order by c1));
insert into is_c1 SELECT a1 FROM TA1 where a2 IN (SELECT MAX(c2) FROM (SELECT /*+ index(TA6 idx_c2) */ c2 FROM TA6 order by c1));
rollback;


