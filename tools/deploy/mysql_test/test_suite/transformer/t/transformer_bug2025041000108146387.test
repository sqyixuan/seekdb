--result_format 4
--explain_protocol 1

SELECT /*+PARALLEL(1) */ DISTINCT COUNT(DISTINCT OUTR . pk ) AS X, 1 AS Y FROM J AS OUTR LEFT JOIN (SELECT * FROM D WHERE col_date <= '2002-11-15' ORDER BY col_date_key) OUTR2 ON ( OUTR2 . col_date >= OUTR . col_date ) WHERE OUTR . col_text = 'english' or ( exists (select col_varchar_10 from B INNR where OUTR . col_int = INNR . col_int and '2007-11-18' BETWEEN OUTR . col_date_key AND OUTR . col_date_key or '2007-12-06' < INNR . col_date) AND NOT exists (select col_int_key from K INNR where OUTR . col_int = INNR . col_int) );

drop table j,k,d,b;