--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists j,k,d,b;
--enable_warnings

CREATE TABLE `j` (
  `pk` int(11) DEFAULT NULL,
  `col_text` text DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_text_key` text DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  KEY `idx5` (`col_text_key`(255)) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `pkJ` (`pk`) BLOCK_SIZE 16384 LOCAL,
  FULLTEXT KEY `fidxJ` (`col_text`) WITH PARSER space PARSER_PROPERTIES=(min_token_size=3,max_token_size=84) BLOCK_SIZE 16384,
  KEY `JG0` (`col_int`, `col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `JG1` (`col_date`, `col_int`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(pk)
(partition `p0`,
partition `p1`,
