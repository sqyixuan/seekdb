# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings

--result_format 4

create table t1 as select 1 > 0;
create table t2 as select not 1 > 0;
create table t3 as select not 0.25;

desc t1;
desc t2;
desc t3;

drop table t1, t2, t3;