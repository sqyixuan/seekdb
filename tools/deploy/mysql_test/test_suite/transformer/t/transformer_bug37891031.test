--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
--error 0, 1051
drop table t0;
--error 0, 1051
drop table t1;
--enable_warnings

CREATE TABLE t0(c0 BIGINT(197)  UNIQUE, c1 VARCHAR(500)  COMMENT 'asdf' )  TABLE_MODE = 'QUEUING' ;
CREATE TABLE t1 LIKE t0;

INSERT INTO t0(c0) VALUES(246627220);
INSERT INTO t1(c0, c1) VALUES(1475961172, 'CN'), (-302257083, "'-R7B3}o4"), (-578118677, "U");

--result_format 4
--explain_protocol 2

select count(*) from (SELECT /*+ ORDERED  */ SUM(t0.c0) s, t0.c0 a, t0.c1 b, t1.c0 c, t1.c1 d FROM t0, t1 GROUP BY t0.c0, t0.c1, t1.c0, t1.c1 HAVING MAX(((t0.c1) && (t0.c1)) OR (t0.c1)) is NULL);

SELECT /*+ ORDERED  */ SUM(t0.c0) s, t0.c0 a, t0.c1 b, t1.c0 c, t1.c1 d FROM t0, t1 GROUP BY t0.c0, t0.c1, t1.c0, t1.c1 HAVING MAX(((t0.c1) && (t0.c1)) OR (t0.c1)) is NULL;


