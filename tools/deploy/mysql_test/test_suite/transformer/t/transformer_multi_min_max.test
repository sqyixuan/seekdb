# owner: linyi.cl
# owner group: sql3
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,pt1,pt2,pt3;
drop sequence if exists s1;
--enable_warnings

create table t1(c1 int, c2 int);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1,c2);
create table t2(c1 int, c2 int);
create table t3(c1 double);
create index t3i1 on t3(c1);
create table pt1(c1 int, c2 int, c3 varchar(32)) partition by hash (c1) partitions 3;
create index pt1i1 on pt1(c1, c2);
create table pt2(c1 int, c2 int, c3 varchar(32)) partition by hash (c1) partitions 3;
create index pt2i1 on pt2(c2);
create table pt3(c1 int primary key, c2 int, c3 varchar(32)) partition by hash (c1) partitions 3;
create index pt3i1 on pt3(c1, c2);
create table t4(c1 int, c2 int, c3 int generated always as (c1+c2));
create index t4i3 on t4(c3);
create table t5(c1 int, c2 int);
create index t5i1 on t5(c1);
create index t5i2 on t5(c2);
create index t5i3 on t5(c1,c2);
create table t6(c1 varchar(32), c2 varchar(32));
create index t6i1 on t6(c1);
create index t6i2 on t6(c2);
create index t6i3 on t6(c1,c2);

set ob_query_timeout = 10000000000;

insert /*+append enable_parallel_dml parallel(8) */ into t1
select if(random(7) % 10 = 0, null, UNIFORM(1, 10000, random(7))),
       if(random(7) % 10 = 0, null, ZIPF(1, 1000, random(7))) from table(generator(100000));

insert /*+append enable_parallel_dml parallel(8) */ into t2
select if(random(7) % 10 = 0, null, UNIFORM(1, 100, random(7))),
       if(random(7) % 10 = 0, null, ZIPF(1, 10, random(7))) from table(generator(100));

insert /*+append enable_parallel_dml parallel(8) */ into t3
select NORMAL(5, 2, random(7)) from table(generator(50));

insert /*+enable_parallel_dml parallel(8) */ into t4(c1,c2)
select UNIFORM(1, 10, random(7)), UNIFORM(1, 10, random(7)) from table(generator(50));

insert /*+append enable_parallel_dml parallel(8) */ into pt1
select ZIPF(1, 1000, random(7)), UNIFORM(1, 10000, random(7)), RANDSTR(7, random(7)) from table(generator(100000));

insert /*+append enable_parallel_dml parallel(8) */ into pt2
select ZIPF(1, 1000, random(7)), UNIFORM(1, 10000, random(7)), RANDSTR(7, random(7)) from table(generator(100000));

create sequence s1 cache 100000 noorder;
insert /*+append enable_parallel_dml parallel(8) */ into pt3
select s1.nextval, UNIFORM(1, 10000, random(7)), RANDSTR(7, random(7)) from table(generator(100000));

insert /*+append enable_parallel_dml parallel(8) */ into t6
select RANDSTR(7, random(7)), RANDSTR(7, random(7)) from table(generator(1000));

--result_format 4
--explain_protocol 2


### 单min/max

select max(c1) from t1;
select /*+no_fast_minmax*/ max(c1) from t1;
select min(c2) from t1;
select /*+no_fast_minmax*/ min(c2) from t1;
select min(c1)*2+1 from t1;
select /*+no_fast_minmax*/ min(c1)*2+1 from t1;
select 1,min(c1) from t1;
select /*+no_fast_minmax*/ 1,min(c1) from t1;

select 1 from t1 having min(c1) > 1;
select /*+no_fast_minmax*/ 1 from t1 having min(c1) > 1;
select 1 from t1 order by min(c1);
select /*+no_fast_minmax*/ 1 from t1 order by min(c1);

select min(c1) from t1 where c1 < 1;
select /*+no_fast_minmax*/ min(c1) from t1 where c1 < 1;
select min(c1) from t1 where c1 + 1 < 1;
select /*+no_fast_minmax*/ min(c1) from t1 where c1 + 1 < 1;
select min(c1) from t1 where c1 < 1 or c1 > 2;
select /*+no_fast_minmax*/ min(c1) from t1 where c1 < 1 or c1 > 2;
select min(c1) from t1 where c1 in (1,2);
select /*+no_fast_minmax*/ min(c1) from t1 where c1 in (1,2);

select min(c2) from t1 where c1 = 1;
select /*+no_fast_minmax*/ min(c2) from t1 where c1 = 1;
select min(c2) from t1 where c2 > 1 and c1 = 1;
select /*+no_fast_minmax*/ min(c2) from t1 where c2 > 1 and c1 = 1;
select min(c1) from t1 where c2 > 1 and c1 = 1;
select /*+no_fast_minmax*/ min(c1) from t1 where c2 > 1 and c1 = 1;

select min(c1) from t1 where c2 = 1 and c1 > 1;
select /*+no_fast_minmax*/ min(c1) from t1 where c2 = 1 and c1 > 1;


