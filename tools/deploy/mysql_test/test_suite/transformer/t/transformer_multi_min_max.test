### like
select min(c1) from t6 where c1 like 'a';
select /*+no_fast_minmax*/ min(c1) from t6 where c1 like 'a';
select min(c1) from t6 where c1 like 'a%';
select /*+no_fast_minmax*/ min(c1) from t6 where c1 like 'a%';
select min(c1) from t6 where c1 like 'a_';
select /*+no_fast_minmax*/ min(c1) from t6 where c1 like 'a_';
select min(c1),max(c1) from t6 where c1 like 'a';
select /*+no_fast_minmax*/ min(c1),max(c1) from t6 where c1 like 'a';
select min(c1),max(c1) from t6 where c1 like 'a%';
select /*+no_fast_minmax*/ min(c1),max(c1) from t6 where c1 like 'a%';
select min(c1),max(c1) from t6 where c1 like 'a_';
select /*+no_fast_minmax*/ min(c1),max(c1) from t6 where c1 like 'a_';
select max(c1),max(c2) from t6 where c1 = 'a' and c2 like 'b%';
select /*+no_fast_minmax*/ max(c1),max(c2) from t6 where c1 = 'a' and c2 like 'b%';


### lossless cast
select min(c1) from t1 where c1=1.0;
select /*+no_fast_minmax*/ min(c1) from t1 where c1=1.0;
select min(c1),max(c1) from t1 where c1=1.0;
select /*+no_fast_minmax*/ min(c1),max(c1) from t1 where c1=1.0;
select max(c1),max(c2) from t1 where c1=1.0;
select /*+no_fast_minmax*/ max(c1),max(c2) from t1 where c1=1.0;


### 非确定性udf
drop function if exists func;
delimiter /;
create function func() returns int
begin
  return 1;
end;
/
delimiter ;/

select min(c1) from t1 where c1 = func();
select /*+no_fast_minmax*/ min(c1) from t1 where c1 = func();
select min(c1),max(c1) from t1 where c1 = func();
select /*+no_fast_minmax*/ min(c1),max(c1) from t1 where c1 = func();

drop table t1,t2,t3,t4,t5,t6,pt1,pt2,pt3;
drop sequence s1;

# 
# 不应该对含semi join的sql进行多minmax改写
create table t1(c1 int, c2 int);
create index i1 on t1(c1);
create table t2(c3 int);
select min(c1),max(c1) from t1 where c1 = any (select c3 from t2);
select min(c1) from t1 where c1 = any (select c3 from t2);
drop table t1,t2;