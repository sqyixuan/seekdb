#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int unique, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int, unique key (c2,c3));

insert into t1 values (1,1,1),(2,2,1),(3,3,2),(4,4,2),(5,null,3),(6,null,null), (7,null,null);
insert into t2 values (1,1,2),(2,2,2),(3,3,4),(4,4,4),(5,null,6),(6,null,null), (7,null,null);
--disable_query_log
--disable_result_log
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

select max(distinct c1) from t1;
select /*+no_rewrite*/ max(distinct c1) from t1;
select min(distinct c1) from t1;
select /*+no_rewrite*/ min(distinct c1) from t1;
select sum(distinct c1) from t1;
select /*+no_rewrite*/ sum(distinct c1) from t1;
select avg(distinct c1) from t1;
select /*+no_rewrite*/ avg(distinct c1) from t1;
select count(distinct c1) from t1;
select /*+no_rewrite*/ count(distinct c1) from t1;
select group_concat(distinct c1,c3) from t1;
select /*+no_rewrite*/ group_concat(distinct c1,c3) from t1;

select max(distinct c2) from t1;
select /*+no_rewrite*/ max(distinct c2) from t1;
select min(distinct c2) from t1;
select /*+no_rewrite*/ min(distinct c2) from t1;
select sum(distinct c2) from t1;
select /*+no_rewrite*/ sum(distinct c2) from t1;
select avg(distinct c2) from t1;
select /*+no_rewrite*/ avg(distinct c2) from t1;
select count(distinct c2) from t1;
select /*+no_rewrite*/ count(distinct c2) from t1;
select group_concat(distinct c2,c3) from t1;
select /*+no_rewrite*/ group_concat(distinct c2,c3) from t1;

select max(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1;
select /*+no_rewrite*/ max(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1;
select min(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1;
select /*+no_rewrite*/ min(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1;
select sum(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1;
select /*+no_rewrite*/ sum(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1;
select avg(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1;
select /*+no_rewrite*/ avg(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1;
select count(distinct v.c3) from (select distinct c3 from t1) v;
select /*+no_rewrite*/ count(distinct v.c3) from (select distinct c3 from t1) v;
select group_concat(distinct t1.c1,t1.c3) from t1 left join t2 on t1.c3 = t2.c1;
select /*+no_rewrite*/ group_concat(distinct t1.c1,t1.c3) from t1 left join t2 on t1.c3 = t2.c1;

select max(distinct c1) from t1 group by c1 with rollup;
select /*+no_rewrite*/ max(distinct c1) from t1 group by c1 with rollup;
select min(distinct c1) from t1 group by c1 with rollup;
select /*+no_rewrite*/ min(distinct c1) from t1 group by c1 with rollup;
select sum(distinct c1) from t1 group by c1,c2 with rollup;
select /*+no_rewrite*/ sum(distinct c1) from t1 group by c1,c2 with rollup;
select avg(distinct c1) from t1 group by c1,c2 with rollup;
select /*+no_rewrite*/ avg(distinct c1) from t1 group by c1,c2 with rollup;
select count(distinct c1) from t1 group by c1,c2,c3 with rollup;
select /*+no_rewrite*/ count(distinct c1) from t1 group by c1,c2,c3 with rollup;
select group_concat(distinct c1,c3) from t1 group by c1,c2,c3 with rollup;
select /*+no_rewrite*/ group_concat(distinct c1,c3) from t1 group by c1,c2,c3 with rollup;

select max(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1 group by t1.c1 with rollup;
select /*+no_rewrite*/ max(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1 group by t1.c1 with rollup;
select min(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1 group by t1.c1 with rollup;
select /*+no_rewrite*/ min(distinct t1.c1) from t1, t2 where t1.c3 = t2.c1 group by t1.c1 with rollup;
select sum(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2 with rollup;
select /*+no_rewrite*/ sum(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2 with rollup;
select avg(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2 with rollup;
select /*+no_rewrite*/ avg(distinct t1.c1) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2 with rollup;
select count(distinct v.c3) from (select distinct c3 from t1) v group by v.c3 with rollup;
select /*+no_rewrite*/ count(distinct v.c3) from (select distinct c3 from t1) v group by v.c3 with rollup;
select group_concat(distinct t1.c1,t1.c3) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2,t1.c3 with rollup;
select /*+no_rewrite*/ group_concat(distinct t1.c1,t1.c3) from t1 left join t2 on t1.c3 = t2.c1 group by t1.c1,t1.c2,t1.c3 with rollup;

select count(distinct c1,c3) from t1;
select /*+no_rewrite*/ count(distinct c1,c3) from t1;
select count(distinct c2,c3) from t1;
select /*+no_rewrite*/ count(distinct c2,c3) from t1;
select count(distinct c2,c3) from t2;
select /*+no_rewrite*/ count(distinct c2,c3) from t2;

select max(distinct c1) over() from t1;
select /*+no_rewrite*/ max(distinct c1) over() from t1;
select min(distinct c1) over() from t1;
select /*+no_rewrite*/ min(distinct c1) over() from t1;
select c3, sum(distinct c1) over(partition by c3) from t1;
select /*+no_rewrite*/ c3, sum(distinct c1) over(partition by c3) from t1;
select c3, avg(distinct c1) over(partition by c3) from t1;
select /*+no_rewrite*/ c3, avg(distinct c1) over(partition by c3) from t1;
select c1, count(distinct c1) over(partition by c3) from t1;
select /*+no_rewrite*/ c1, count(distinct c1) over(partition by c3) from t1;

select max(distinct c2) over() from t1;
select /*+no_rewrite*/ max(distinct c2) over() from t1;
select min(distinct c2) over() from t1;
select /*+no_rewrite*/ min(distinct c2) over() from t1;
select c3, sum(distinct c2) over(partition by c3) from t1;
select /*+no_rewrite*/ c3, sum(distinct c2) over(partition by c3) from t1;
select c3, avg(distinct c2) over(partition by c3) from t1;
select /*+no_rewrite*/ c3, avg(distinct c2) over(partition by c3) from t1;
select c1, count(distinct c2) over(partition by c3) from t1;
select /*+no_rewrite*/ c1, count(distinct c2) over(partition by c3) from t1;

select max(distinct t1.c1) over() from t1, t2 where t1.c3 = t2.c1;
select /*+no_rewrite*/ max(distinct t1.c1) over() from t1, t2 where t1.c3 = t2.c1;
select min(distinct t1.c1) over() from t1, t2 where t1.c3 = t2.c1;
select /*+no_rewrite*/ min(distinct t1.c1) over() from t1, t2 where t1.c3 = t2.c1;
select t1.c3, sum(distinct t1.c1) over(partition by t1.c3) from t1 left join t2 on t1.c3 = t2.c1;
select /*+no_rewrite*/ t1.c3, sum(distinct t1.c1) over(partition by t1.c3) from t1 left join t2 on t1.c3 = t2.c1;
select t1.c3, avg(distinct t1.c1) over(partition by t1.c3) from t1 left join t2 on t1.c3 = t2.c1;
select /*+no_rewrite*/ t1.c3, avg(distinct t1.c1) over(partition by t1.c3) from t1 left join t2 on t1.c3 = t2.c1;
select count(distinct v.c3) over(partition by c3) from (select distinct c3 from t1) v;
select /*+no_rewrite*/ count(distinct v.c3) over(partition by c3) from (select distinct c3 from t1) v;

select max(distinct c1) over() from t1 group by c1;
select /*+no_rewrite*/ max(distinct c1) over() from t1 group by c1;
select min(distinct c1) over() from t1 group by c1 with rollup;
select /*+no_rewrite*/ min(distinct c1) over() from t1 group by c1 with rollup;
select c2, sum(distinct c1) over(partition by c2) from t1 group by c1,c2;
select /*+no_rewrite*/ c2, sum(distinct c1) over(partition by c2) from t1 group by c1,c2;
select c2, avg(distinct c1) over(partition by c2) from t1 group by c1,c2 with rollup;
select /*+no_rewrite*/ c2, avg(distinct c1) over(partition by c2) from t1 group by c1,c2 with rollup;
select c3, count(distinct c1) over(partition by c2) from t1 group by c1,c2,c3;
select /*+no_rewrite*/ c3, count(distinct c1) over(partition by c2) from t1 group by c1,c2,c3;

select c1, c3, count(distinct c1,c3) over() from t1;
select /*+no_rewrite*/ c1, c3, count(distinct c1,c3) over() from t1;
select c2, c3, count(distinct c2,c3) over(partition by c3) from t1;
select /*+no_rewrite*/ c2, c3, count(distinct c2,c3) over(partition by c3) from t1;
select c2, c3, count(distinct c2,c3) over(partition by c3) from t2;
select /*+no_rewrite*/ c2, c3, count(distinct c2,c3) over(partition by c3) from t2;

drop table t1,t2;
