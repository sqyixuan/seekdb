--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(a int, b int);
create table t2(a int, b int);
create table t3(a int, b int, c int);
insert into t1 values (1,1),(2,1),(3,1),(NULL, NULL);
insert into t2 values (1,2),(3,1);
insert into t3 values (1,2,3),(3,1,2),(2,3,1),(1,NULL,5);

--result_format 4
--explain_protocol 2

select * from t1 where a in (select a from t2) and a in (select b from t2);
select * from t1 where a in (select a from t2) and a in (select b from t2 where b < 3);
select * from t1 where a >= all(select a from t2) and a >= all(select b from t2);
select * from t1 where exists (select a from t2) and exists (select b from t2);

# issue : 
