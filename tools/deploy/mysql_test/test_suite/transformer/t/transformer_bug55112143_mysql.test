--result_format 4

select 
   (
    select 1
    from (select  subq_1.c1 as c0 from dual) as subq_2 
    where subq_1.c0 = subq_1.c2
  ) 
from 
  (
    select 
    max(cast(ref_3.obschema_c_9_i as DECIMAL)) as c0, 
      ref_3.obschema_c_23_EaObMQ as c1, 
      ref_1.obschema_c_6_Z as c2 
    from test.obschema_t_pc4xbxfo as ref_1, test.obschema_t_6alr2wn as ref_3
  ) as subq_1 
where 
    subq_1.c0 is NULL
    and subq_1.c1 is NULL;

