# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(a int, b int, c int);
create table t2(d int, e int, f int);

--result_format 4

--echo # 所有 join 条件中都包含 generated table 的聚合列, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
;

--echo # 有一个 join 条件只包含 generated table 的非聚合列, 可以做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c = v.d
;

--echo #  t1.c > v.d 只包含 generated table 的非聚合列, 但它不是 join (等值) 条件, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c > v.d
;

--echo # v.d > 0 只包含 generated table 的非聚合列, 但它不是 join (等值) 条件, 不做 groupby pullup
explain select t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and v.d > 0
;

--echo # 优化器版本号低于 4.3.5.2 时, 上述场景都会做 groupby pullup
explain select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.5.1') */ t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
;

explain select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.5.1') */ t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c = v.d
;

explain select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.5.1') */ t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and t1.c > v.d
;

explain select /*+ OPTIMIZER_FEATURES_ENABLE('4.3.5.1') */ t1.a, v.total_f
from 
  t1,
  (
    select /*+merge*/ 
      d, max(e) as max_e, sum(f) as total_f
    from t2
    group by d
  ) v
where
    t1.a = v.max_e + v.d
    and t1.b = v.total_f
    and v.d > 0
;

drop table t1, t2;