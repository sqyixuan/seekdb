--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql3
#tag: optimizer

--disable_query_log
--disable_warnings
DROP TABLE if exists `t1`;
DROP TABLE if exists `t2`;
--enable_query_log
--enable_warnings

--result_format 4

create table t2(c1 int, c2 varchar(10), c3 varchar(10), c4 varchar(10) generated always as (substring(c2, 1, 2)),
                    constraint check_t2 check (c4 = substring(c3, 1, NULL))) partition by list columns(c4)
                   (partition p0 values in ('01'),
                    partition p1 values in ('02'),
                    partition p2 values in ('03'),
                    partition p3 values in ('04'),
                    partition p4 values in ('05'));

insert into t2(c1,c2,c3) values(0,'010','011'),(1,'020','022'),(2,'030','033'),(3,'040','044'),(4,'050','055');

select * from t2;

select * from t2 where c3 = '011';
select/*+no_rewrite*/ * from t2 where c3 = '011';


drop table t2;

create table t2(c1 int, c2 varchar(10), c3 varchar(10), c4 varchar(10) generated always as (substring(c2, 1, 2)),
                    constraint check_t2 check (c4 = substring(c3, 1, 10/c1))) partition by list columns(c4)
                   (partition p0 values in ('01'),
                    partition p1 values in ('02'),
                    partition p2 values in ('03'),
                    partition p3 values in ('04'),
                    partition p4 values in ('05'));

insert into t2(c1,c2,c3) values(0,'010','011');
insert into t2(c1,c2,c3) values(5,'020','022');
insert into t2(c1,c2,c3) values(5,'030','033'), (5,'040', '044'), (5, '050', '055'), (5, '033', '033');


select * from t2;

select * from t2 where c3 = '022' and c1=5;
select /*+no_rewrite*/ * from t2 where c3 = '022' and c1=5;

select * from t2 where c3 = '011' and c1=0;
select/*+no_rewrite*/ * from t2 where c3 = '011' and c1=0;

select * from t2 where c3 in ('011', '022', '033', '055') and c1=5;
select /*+no_rewrite*/ * from t2 where c3 in ('011', '022', '033', '055') and c1=5;
explain select * from t2 where c3 in ('011', '022', '033', '055') and c1=5;

select * from t2 where c3 in ('011', '022', '033', '044', '055', '016','027','038','049','055') and c1=5;
select /*+no_rewrite*/ * from t2 where c3 in ('011', '022', '033', '044', '055', '016','027','038','049','055') and c1=5;
explain select * from t2 where c3 in ('011', '022', '033', '044', '055', '016','027','038','049','055','011', '022') and c1=5;

drop table t2;

create table t2(c1 int, c3 varchar(10), c4 varchar(10) not null,
                    constraint check_t2 check (c4 = substring(c3, 1, 2))) partition by list columns(c4)
                   (partition p0 values in ('01'),
                    partition p1 values in ('02'),
                    partition p2 values in ('03'),
                    partition p3 values in ('04'),
                    partition p4 values in ('05'));

insert into t2(c1,c3,c4) values(0,'010','01');
insert into t2(c1,c3,c4) values(0,'020','02');
insert into t2(c1,c3,c4) values(0, NULL,'03');
select * from t2;

select * from t2 where c3='010';
select /*+no_rewrite*/ * from t2 where c3='010';
explain outline select * from t2 where c3='010';

create table t1 (c1 int, constraint check_t1 check (c1=2));
insert into t1 values(NULL);

set ob_enable_plan_cache = 0;

select * from t1 where c1=2;
select /*+no_rewrite*/ * from t1 where c1=2;

drop table t1;
drop table t2;

