# owner: lijinmao.ljm
# onwer group: SQL1
# tags: optimizer, cross_validation

--disable_warnings
DROP TABLE IF EXISTS t2, t3, t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, primary key(c1, c2), unique(c2,c3));
create table t2(c1 int not null, c2 int not null, c3 int, foreign key(c1, c2) references t1(c1, c2));
create table t3(c1 int not null, c2 int not null, c3 int, foreign key(c2, c3) references t1(c2, c3));
insert into t1 values(0,1,null);
insert into t1 values(1,1,1);
insert into t1 values(1,2,2);
insert into t1 values(2,2,null);
insert into t1 values(1,3,null);
insert into t2 values(1,1,10);
insert into t2 values(1,2,11);
insert into t2 values(1,3,null);
insert into t3 values(1,1,1);
insert into t3 values(1,1,null);
insert into t3 values(1,2,2);
insert into t3 values(1,2,null);
insert into t3 values(1,3,null);

--explain_protocol 1
--result_format 4

--echo 预期可以消除连接
select t2.* from t1, t2 where t1.c2 = t2.c2 and t1.c1 = t2.c1;
select /*+no_rewrite*/ t2.* from t1, t2 where t1.c2 = t2.c2 and t1.c1 = t2.c1;
select t3.* from t3 left join t1 on (t1.c2 = t3.c2 and t1.c3 = t3.c3);
select /*+no_rewrite*/ t3.* from t3 left join t1 on (t1.c2 = t3.c2 and t1.c3 = t3.c3);
--echo 预期不可以消除连接
select /*+no_simplify_expr*/ t2.* from t1, t2 where t1.c1 = t2.c1 and t1.c1 = t2.c1;
select t2.* from t1, t2 where t1.c2 = t2.c1 and t1.c1 = t2.c2;
select t2.* from t1, t2 where t1.c2 = t2.c1;
select t2.* from t1, t2 where t1.c1 = t2.c1;
select t2.* from t1, t2 where t1.c2 = t2.c2 and t1.c1 = t2.c1 and t1.c3 = t2.c3;
select t3.* from t1, t3 where t1.c2 = t3.c2 and t1.c3 = t3.c3;
select t3.* from t1, t3 where t1.c2 = t3.c2;
select t3.* from t1, t3 where t1.c3 = t3.c3;

--echo 预期可以 outer to inner
select t2.* from t2 left join t1 on (t1.c2 = t2.c2);
select /*+no_rewrite*/ t2.* from t2 left join t1 on (t1.c2 = t2.c2);
select t2.* from t2 left join t1 on (t1.c1 = t2.c1);
select /*+no_rewrite*/ t2.* from t2 left join t1 on (t1.c1 = t2.c1);
select t2.* from t2 left join t1 on (t1.c2 = t2.c2 and t1.c1 = t2.c1);
select /*+no_rewrite*/ t2.* from t2 left join t1 on (t1.c2 = t2.c2 and t1.c1 = t2.c1);
select t3.* from t3 left join t1 on (t1.c2 = t3.c2);
select /*+no_rewrite*/ t3.* from t3 left join t1 on (t1.c2 = t3.c2);
--echo 预期不可以 outer to inner
select t2.* from t2 left join t1 on (t1.c1 = t2.c2);
select t2.* from t2 left join t1 on (t1.c1 = t2.c1 and t1.c3 = t2.c3);
select t3.* from t3 left join t1 on (t1.c3 = t3.c3);

drop table t2, t3, t1;