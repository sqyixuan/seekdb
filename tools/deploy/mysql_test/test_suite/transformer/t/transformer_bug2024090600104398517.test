# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);
insert into t1 values(1),(2),(null);

--result_format 4
--explain_protocol 2

select (select sum_opnsize(1) from t1 where 1=0) from t1;
select /*+no_rewrite*/ (select sum_opnsize(1) from t1 where 1=0) from t1;

select
(
  select 
    CONCAT_WS('-',
              approx_count_distinct('1'),
              sum_opnsize('1') + sum_opnsize('1'),
              sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1'),
              count('1') - count('1') - count('1') + count('1'),
              avg('1') + avg('1'),
              sum('1') - sum('1') - sum('1') + sum('1'),
              min('1') - min('1') - min('1') + min('1'),
              max('1') + max('1')
    )
  from t1 where '1' not like '1%'
),
(
  select 
    CONCAT_WS('-',
              approx_count_distinct('1'),
              approx_count_distinct('1') - approx_count_distinct('1') - approx_count_distinct('1') + approx_count_distinct('1'),
              sum_opnsize('1') + sum_opnsize('1'),
              count('1') - count('1') - count('1') + count('1'),
              avg('1') + avg('1'),
              sum('1'),
              sum('1') - sum('1') - sum('1') + sum('1'),
              min('1') - min('1') - min('1') + min('1'),
              max('1') + max('1'),
              max('1') + max('1')
    )
  from t1 where '1'%10 not in (0,1,2)
)
from t1;

select /*+no_rewrite*/ 
(
  select 
    CONCAT_WS('-',
              approx_count_distinct('1'),
              sum_opnsize('1') + sum_opnsize('1'),
              sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1') + sum_opnsize('1'),
              count('1') - count('1') - count('1') + count('1'),
              avg('1') + avg('1'),
              sum('1') - sum('1') - sum('1') + sum('1'),
              min('1') - min('1') - min('1') + min('1'),
              max('1') + max('1')
    )
  from t1 where '1' not like '1%'
),
(
  select 
    CONCAT_WS('-',
              approx_count_distinct('1'),
              approx_count_distinct('1') - approx_count_distinct('1') - approx_count_distinct('1') + approx_count_distinct('1'),
              sum_opnsize('1') + sum_opnsize('1'),
              count('1') - count('1') - count('1') + count('1'),
              avg('1') + avg('1'),
              sum('1'),
              sum('1') - sum('1') - sum('1') + sum('1'),
              min('1') - min('1') - min('1') + min('1'),
              max('1') + max('1'),
              max('1') + max('1')
    )
  from t1 where '1'%10 not in (0,1,2)
)
from t1;

drop table t1;
