
#owner: sean.yyj
#owner group: sql1
# tags: optimizer
# link: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(c1 int,c2 bigint,c3 FLOAT);
insert into test1 values(0,0,0);
insert into test1 values(1,1,1);
insert into test1 values(0,0,1);
insert into test1 values(0,1,1);
insert into test1 values(1,0,0);
insert into test1 values(1,1,0);
select * from test1 order by c1 asc;

#basic
##non-paramlized groupby expr
alter system flush plan cache global;
select * from test1 group by '1' having '1' = '2';
select * from test1 group by '1' having '2' = '2';
select * from test1 group by '1' with rollup having '1' = '2';
select * from test1 group by '1' with rollup having '2' = '2';
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like "select * from test1%" order by statement,hit_count;

alter system flush plan cache global;
select * from test1 group by 1+1 having 1+1 = 2;
select * from test1 group by 1+1 having 2+1 = 2;
select * from test1 group by 1+1 having 1+2 = 2;
select * from test1 group by 1+1 with rollup having 1+1 = 2;
select * from test1 group by 1+1 with rollup having 2+1 = 2;
select * from test1 group by 1+1 with rollup having 1+2 = 2;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select * from test1 %' order by statement,hit_count;

##groupby expr is replaced by select expr
alter system flush plan cache global;
select 1 from test1 group by 1 having 1 = 2;
select 1 from test1 group by 1 having 2 = 2;

select 1 from test1 group by 1 with rollup having 1 = 2;
select 1 from test1 group by 1 with rollup having 2 = 2;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select 1 from%' order by statement,hit_count;

select c1 from test1 group by 1 having 1 = 2;
select c1 from test1 group by 1 having 2 = 2;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select c1 from test1 %'order by statement,hit_count;
##with function
alter system flush plan cache global;
select * from test1 group by hex(1) having hex(1) = 1;
select * from test1 group by hex(1) having hex(2) = 1;
select * from test1 group by hex(1) with rollup having hex(1) = 1;
select * from test1 group by hex(1) with rollup having hex(2) = 1;

select hex(1),c1 from test1 group by 1 having hex(1) = 1;
select hex(1),c1 from test1 group by 1 having hex(2) = 1;

select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select * from test1 %' order by statement,hit_count;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select hex(1),c1 from test1 %' order by statement,hit_count;

alter system flush plan cache global;
select * from test1 group by is_uuid('6ccd780c-baba-1026-9564-5b8c656024db') HAVING is_uuid('6ccd780c-baba-1026-9564-5b8c656024db')=
is_uuid('u海军第三部分我不懂给');
select * from test1 group by is_uuid('6ccd780c-baba-1026-9564-5b8c656024db') HAVING is_uuid('u海军第三部分我不懂给')=
is_uuid('u海军第三部分我不懂给');

select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where QUERY_SQL like 'select * from test1 %' order by statement,hit_count;

drop table if exists test1;