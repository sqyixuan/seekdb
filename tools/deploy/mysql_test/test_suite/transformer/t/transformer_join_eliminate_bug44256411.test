--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: jim.wjh
# owner group: SQL3
# tags: optimizer
# description: test join elimination bug


--disable_abort_on_error

--disable_warnings
drop table if exists t4, t8;
--enable_warnings

create table t4 (c1 YEAR(4) ,c2 DECIMAL(64,15) ,c3 DATETIME,c4 CHAR(152) ,c5 DATE,c6 TIMESTAMP(2)  NOT NULL default 0,c7 YEAR(4) ,c8 VARCHAR(86) ,c9 VARBINARY(86) ,c10 VARBINARY(84) ,c11 VARBINARY(59) ,c12 VARCHAR(86) ,c13 NUMERIC(64,3) ,c14 TIMESTAMP(5)  NOT NULL default 0,c15 BINARY(98) ,c16 BIGINT(127)  auto_increment,c17 TIMESTAMP(1)  NOT NULL default 0,c18 INT(127) , primary key(c10))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;

create table t8 (c1 DECIMAL(64,18) ,c2 BINARY(136) ,c3 DECIMAL(64,5) ,c4 BIGINT(127) ,c5 INTEGER(127)  auto_increment,c6 VARCHAR(86) ,c7 VARCHAR(86) ,c8 INTEGER(127) ,c9 YEAR(4) ,c10 BIGINT(127) ,c11 NUMERIC(64,29) ,c12 DATETIME, primary key(c4,c5))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c4) PARTITIONS 20;


INSERT INTO t4 VALUES (1975,1.000000000000000,'1980-4-2 1:56:56','pXVUdIdaAGdLCl0001',date'1973-10-22',timestamp'1989-3-12 8:19:36',1961,'IaRZcCvQaRYnMxUMTOkDkXLihYuixGWcGdNYUqKcXleoOSoCWCiOjQVnQbMwjnbGCNUrbTmJJIOwgdPQj0001','pPlvaNCDeyoaBbEiaoaK0001','JxBUzMOqAskAmlCyVIdOBafdnvuqHLvDjlohlQFliEhWidNipzfsqqdePVUjODNqiokFFsvL0001','zDtTFVymeRCekgSwYMAvJJJuxXBLAtLxqUWxEgzsEesuyPdrrlqpq0001','xLYDXviskL0001',1.000,timestamp'2010-3-27 13:7:29','grtxTLkQNmsMwGxwuNiAUiZIhXDrDsTvLNBPDEUsKynYedDDqwBmTDChCngCjrnBFZlOtSqeejzfIN0001',1,timestamp'2034-10-4 6:53:15',1);

INSERT INTO t8 VALUES (1.000000000000000000,'xcMMsh01',1.00000,1,1,'jUDCEINZFQguxiaRgG01','hhRNkmiuzdhbamAVIU01',1,1968,1,1.00000000000000000000000000000,'1982-9-15 2:19:56');

SELECT /*+ no_rewrite */
concat(t8.c6, t8.c9)
FROM t4 LEFT OUTER JOIN t8
ON 1=0

SELECT /*+ no_rewrite */
concat(t8.c6, t8.c9)
FROM t4 LEFT OUTER JOIN t8
ON 1=0

SELECT /*+ no_rewrite ELIMINATE_JOIN */
concat(t8.c6, t8.c9)
FROM t4 LEFT OUTER JOIN t8
ON 1=0

drop table t4, t8;
