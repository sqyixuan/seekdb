# owner: sean.yyj
# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
insert into t1 values(2,3,3), (2,4,4), (2,2,2), (2,5,5), (1,3,3), (1,4,4), (1,2,2), (1,1,1);
create table t2(c1 int);
insert into t2 values(1), (2), (3);
set @part = null;
set @rn = 100;
set @a = 0;

--explain_protocol 1
--result_format 4

--echo # test expr pullup
select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2);
select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where rn <= 3;
select c1, c2, c3, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where c1 = 1 and rn <= 3;

--echo # test const propagate
select * from t2 where (@a := c1) and (c1 = 1);
select @a;

--echo # both transform can happend when the query block does not contain assignment
select /*+no_pred_deduce*/ * from (select /*+no_merge*/ c1, c2, c3, case when c2 = 1 then c1 + 3 else c3 + 4 end as expr_to_pullup, rn from (select c1, c2, c3, case when @part = c1 then @rn := @rn + 1 else @rn := 1 end as rn, @part := c1 from t1 order by c1, c2) where c1 = 1 and rn <= 3) where c3 > 0;

drop table t1, t2;