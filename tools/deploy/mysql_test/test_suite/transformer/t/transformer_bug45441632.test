# owner: yibo.tyf
# onwer group: SQL1
# tags: transformer

--disable_warnings
DROP TABLE IF EXISTS timepk, no_pk, cool_agent_edit_business, t_dsb_dashboard;
--enable_warnings
--result_format 4
create table timepk(id int, classtime time, primary key(classtime));
CREATE TABLE `no_pk` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL
);
CREATE TABLE `cool_agent_edit_business` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `business_id` int(11) DEFAULT NULL ,
  `agent_id` int(11) DEFAULT NULL ,
  `admin_ids` varchar(255) DEFAULT NULL ,
  `regtime` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP ,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=10 DEFAULT CHARSET=utf8 ;
create TABLE `t_dsb_dashboard` (
  `dashboardID` int(11) NOT NULL AUTO_INCREMENT COMMENT '仪表板标识，流水号',
  `layoutID` int(11) NOT NULL COMMENT '布局流水号',
  `dashboardName` varchar(300) NOT NULL COMMENT '仪表板名称',
  `isSysDefault` tinyint(1) DEFAULT '0' COMMENT '是否系统内置 0:用户自定义1:系统内置',
  `status` int(11) DEFAULT '1' COMMENT '状态:1正常2删除',
  PRIMARY KEY (`dashboardID`)
) ENGINE=InnoDB AUTO_INCREMENT=10 DEFAULT CHARSET=utf8 COMMENT='仪表板表\r\nWebServer:读/写';

--explain_protocol 2
## right side of anti join is inner join
SELECT 1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (timepk AS ref_0
                   INNER JOIN no_pk AS ref_1
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;
SELECT /*+no_left_to_anti*/1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (timepk AS ref_0
                   INNER JOIN no_pk AS ref_1
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;

## right side of anti join is left join
SELECT 1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (no_pk AS ref_1
                   LEFT JOIN timepk AS ref_0
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;
SELECT /*+no_left_to_anti*/1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (no_pk AS ref_1
                   LEFT JOIN timepk AS ref_0
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;

## right side of anti join is right join
SELECT 1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (timepk AS ref_0
                   RIGHT JOIN no_pk AS ref_1
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;
SELECT /*+no_left_to_anti*/1
FROM   (cool_agent_edit_business AS ref_3
        LEFT JOIN (timepk AS ref_0
                   RIGHT JOIN no_pk AS ref_1
                           ON true )
               ON true)
       LEFT JOIN t_dsb_dashboard AS ref_5
              ON true
WHERE  ref_1.address IS NULL;
--explain_protocol 0

--disable_warnings
DROP TABLE IF EXISTS timepk, no_pk, cool_agent_edit_business, t_dsb_dashboard;
--enable_warnings
