#owner group: sql1
# tags: optimizer,cross_validation
# issue: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS isszmx,ishbzh;
--enable_warnings
CREATE TABLE `isszmx` (
  `ZQZH` char(20) NOT NULL DEFAULT '',
  `YMTH` char(20) NOT NULL DEFAULT '',
  `TGDY` char(6) NOT NULL DEFAULT '',
  `YXSZ` decimal(18,3) NOT NULL DEFAULT '0.000',
  `ZZHZ` char(20) NOT NULL DEFAULT '',
  `HZSZ` decimal(18,3) NOT NULL DEFAULT '0.000',
  `KSGS` decimal(12,0) NOT NULL DEFAULT '0',
  `CLRQ` date NOT NULL DEFAULT '0001-01-01',
  PRIMARY KEY (`ZQZH`)
);
CREATE TABLE `ishbzh` (
  `ZQZH` char(20) NOT NULL DEFAULT '',
  `MAIN` char(20) NOT NULL DEFAULT '',
  `ZHBZ` char(1) NOT NULL DEFAULT '',
  `GDLB` char(1) NOT NULL DEFAULT '',
  `CLRQ` date NOT NULL DEFAULT '0001-01-01',
  `CLSJ` time NOT NULL DEFAULT '00:00:00',
  `GLSL` decimal(5,0) NOT NULL DEFAULT '0',
  `BYZD` char(20) NOT NULL DEFAULT '',
  PRIMARY KEY (`ZQZH`)
);

--explain_protocol 2
UPDATE isszmx a,
  (SELECT b.zqzh,
          c.main AS main
   FROM isszmx b
   LEFT JOIN ishbzh c ON b.zqzh = c.zqzh
   WHERE b.clrq = curdate()
     AND b.zqzh >= '0075344534'
     AND b.zqzh <= '0080947705') d
SET a.zzhz = d.main
WHERE a.clrq = curdate()
  AND a.zqzh >= '0075344534'
  AND a.zqzh <= '0080947705'
  AND a.zqzh = d.zqzh;

DROP TABLE isszmx,ishbzh;