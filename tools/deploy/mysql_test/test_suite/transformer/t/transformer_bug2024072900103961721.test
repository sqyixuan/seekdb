# owner group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE IF EXISTS T0, T1, T2, T3, T4, T5, TBL, TBL2;
--enable_warnings

CREATE TABLE IF NOT EXISTS t0(c0 FLOAT(15, 8) , c1 FLOAT , c2 DOUBLE(36, 17)  COMMENT 'asdf'  , c3 TINYINT ZEROFILL , PRIMARY KEY(c2))  PARTITION BY KEY (c2) partitions 11;
CREATE TABLE t1 
  PARTITION BY RANGE (c3) 
  SUBPARTITION BY HASH(c3) subpartitions 7(partition p0 VALUES LESS THAN(0), partition p1 VALUES LESS THAN(1000000000), partition p2 VALUES LESS THAN(maxvalue))
  AS SELECT * FROM t0;
CREATE TABLE IF NOT EXISTS t2 LIKE t0;
CREATE TABLE IF NOT EXISTS t3 PARTITION BY HASH(c3) SUBPARTITION BY KEY (c1, c3) subpartitions 1 partitions 17 AS SELECT * FROM t0;
CREATE TABLE IF NOT EXISTS t4 LIKE t0;

--result_format 4
--explain_protocol 1
WITH jennifer_0 AS (
  select 
  if(1, ref_0.c2, case when EXISTS (select 1 from t3 as ref_4) then 1 else ref_0.c0 end) as c4,
  if(EXISTS(select 1 from t1 as ref_7 where 48 in ( 20,  46,  17,  61,  47)),
     case when EXISTS (select 1 from t3 as ref_8 where 33 not in (28, 33) limit 95) then ref_0.c3 else 34 end, 
     ref_0.c3) as c5 
  from t4 as ref_0
)
SELECT * FROM jennifer_0;

CREATE TABLE t5 as WITH jennifer_0 AS (
  select 
  if(1, ref_0.c2, case when EXISTS (select 1 from t3 as ref_4) then 1 else ref_0.c0 end) as c4,
  if(EXISTS(select 1 from t1 as ref_7 where 48 in ( 20,  46,  17,  61,  47)),
     case when EXISTS (select 1 from t3 as ref_8 where 33 not in (28, 33) limit 95) then ref_0.c3 else 34 end, 
     ref_0.c3) as c5 
  from t4 as ref_0
)
SELECT * FROM jennifer_0;

-- echo # basic problem
create table tbl(c1 tinyint zerofill);
select 
  case when 0 then 
    case when 0 then tbl.c1 else 1 end 
    else tbl.c1 
  end as c0 
from tbl;
create table tbl2 as select case when 0 then case when 0 then tbl.c1 else 1 end else tbl.c1 end as c0 from tbl;

DROP TABLE IF EXISTS T0, T1, T2, T3, T4, T5, TBL, TBL2;