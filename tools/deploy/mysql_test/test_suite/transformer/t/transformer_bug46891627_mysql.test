SELECT pk , col_bigint FROM table0_bigint WHERE NOT ( ROUND( ROUND( ROUND( CEIL( col_decimal_20_0 ) ) ) ) BETWEEN ROUND( SIGN( col_decimal_20_0 ) ) AND ROUND( FLOOR( 99999 ) ) ) OR ( ( col_bigint > 26358 AND  col_char_20 IN (TRIM( SUBSTR( HEX( TRIM( SUBSTR( SUBSTR( 'wcdy' , 1, 20) , 1 , 20 ) ) ) , 1 , 20 ) ) , TRIM( SUBSTR( TRIM(  'a' FROM SUBSTR( 'e' , 1, 20) ) , 1 , 20 ) ) , TRIM( SUBSTR( COALESCE( SUBSTR( 'l' , 1, 20) , SUBSTR( 'flwcd' , 1, 20) , SUBSTR( 'jf' , 1, 20) ) , 1 , 20 ) )) ) AND ( col_bigint = 26358 AND  ( col_timestamp_6 <= COALESCE( '2015-06-15 10:00:00.000001' , CONCAT( CAST( 2015 + 4 + 3 AS CHAR(20) ) , '-06-15 01:00:00.000003') , CONCAT( CAST( 2015 + 3 + 3 AS CHAR(20) ) , '-06-15 01:00:00.000003') ) ) ) ) OR ( ( col_bigint > 26358 AND NOT LOWER( TRIM( SUBSTR( TRIM( BOTH SUBSTR( SUBSTR( 'ajflwcdyfi' , 1, 20) , 1 , 2 ) FROM TRIM( SUBSTR( CONCAT(SUBSTR( 'RFXSM' , 1, 20) , CONCAT( HEX( SUBSTR( 'jajflw' , 1, 20) ) , SUBSTR( CONCAT(SUBSTR( 'djaj' , 1, 20) , SUBSTR( UPPER( SUBSTR( 'm' , 1, 20) ) , 8 ) ) , 5 ) ) ) , 1 , 20 ) ) ) , 1 , 20 ) ) ) LIKE LOWER( TRIM( SUBSTR( SUBSTR( SUBSTR( SUBSTR( REPEAT( TRIM( SUBSTR( SUBSTR( SUBSTR( TRIM( SUBSTR( LOWER( CONCAT('head' , CONCAT(SUBSTR( 'adja' , 1, 20) , SUBSTR( 'i' , 1, 20) ) ) ) FROM 5 + 1 ) ) , 5 ) FROM 9 + 1 ) , 1 , 20 ) ) , 9 + 1 ) FROM 1 + 1 ) , 2 ) , 6 ) , 1 , 20 ) ) ) ESCAPE 'c' ) AND ( col_bigint <= 26358 OR col_bigint >= 26358 ) ) ORDER BY 1  , pk ASC LIMIT 5;
