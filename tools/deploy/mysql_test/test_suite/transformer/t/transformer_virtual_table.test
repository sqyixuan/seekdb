# owner: link.zt
# owner group: SQL 1
# tags: optimizer

## disable cost-based rewrite for virtual table

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

--explain_protocol 2
--result_format 4

select table_id from __all_virtual_table where tenant_id = 1 or tenant_id = 2 order by table_id limit 2;
select /*+use_concat*/ table_id from __all_virtual_table where tenant_id = 1 or tenant_id = 2 order by table_id limit 2;

select c.table_id, c.table_name, aggr from (select tenant_id, table_id, table_name from __all_virtual_table where tenant_id = 1 order by table_id limit 10) c, (select table_id, count(*) as aggr from __all_virtual_column group by table_id) V where c.table_id = V.table_id and table_name = '__all_ls_meta_table';
select c.table_id, c.table_name, aggr from (select tenant_id, table_id, table_name from __all_virtual_table where tenant_id = 1 order by table_id limit 10) c, (select /*+merge*/ table_id, count(*) as aggr from __all_virtual_column group by table_id) V where c.table_id = V.table_id and table_name = '__all_ls_meta_table';

select c.table_id, c.table_name, count(*) from __all_virtual_table c, __all_virtual_column d where c.tenant_id = d.tenant_id and c.table_id = d.table_id and table_name = '__all_ls_meta_table' and c.tenant_id = 1 group by c.tenant_id, c.table_id, c.table_name;
select /*+place_group_by*/ c.table_id, c.table_name, count(*) from __all_virtual_table c, __all_virtual_column d where c.tenant_id = d.tenant_id and c.table_id = d.table_id and table_name = '__all_ls_meta_table' and c.tenant_id = 1 group by c.tenant_id, c.table_id, c.table_name;

select table_id from __all_virtual_table t1 where table_id <= (select min(table_id) from __all_virtual_table t2 where t1.tenant_id = t2.tenant_id) and tenant_id <= 500;
select table_id from __all_virtual_table t1 where table_id <= (select /*+unnest*/ min(table_id) from __all_virtual_table t2 where t1.tenant_id = t2.tenant_id) and tenant_id <= 500;



