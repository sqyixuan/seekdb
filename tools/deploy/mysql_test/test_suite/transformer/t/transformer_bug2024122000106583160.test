# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: rollup + having 场景谓词推导 bug

--disable_warnings
DROP TABLE IF EXISTS t0;
DROP VIEW IF EXISTS v_t0;
--enable_warnings

--result_format 4
--explain_protocol 2

# a = c1 不应该被改写为 a = 1
select count(*) as a, c1 from (select 1 as c1) group by c1 with rollup having a = c1;
select /*+no_rewrite*/ count(*) as a, c1 from (select /*+no_rewrite*/ 1 as c1) group by c1 with rollup having a = c1;

select count(*) as b, a, c1, c2 from (
  select 1 as c2, count(*) as a, c1 from (
    select 1 as c1
  ) group by c1 with rollup having a = c1
) group by c2 having b = c2;

select /*+no_rewrite*/ count(*) as b, a, c1, c2 from (
  select /*+no_rewrite*/  1 as c2, count(*) as a, c1 from (
    select /*+no_rewrite*/  1 as c1
  ) group by c1 with rollup having a = c1
) group by c2 having b = c2;

CREATE TABLE
  IF NOT EXISTS t0 (
    c0 BIGINT (224) COMMENT 'asdf',
    c1 BIGINT (102) COMMENT 'asdf' UNIQUE KEY NOT NULL,
    c2 DATETIME COMMENT 'asdf',
    PRIMARY KEY (c0, c1)
  );
CREATE VIEW v_t0 AS select /*+no_mv_rewrite*/ c0, c1, c2,count(*) as c from t0 group by c0, c1, c2;

--disable_query_log
--disable_result_log
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS */ INTO t0(c0, c1) VALUES(-3322894, 5925094);
INSERT /*+GATHER_OPTIMIZER_STATISTICS */ INTO t0(c2, c0, c1) VALUES ROW('2024-12-20 14:28:43', -9888553, -6113354),  ROW("2024-12-20 14:28:43", 1113812, -14131016);
--enable_query_log
--enable_result_log

# v_t0.c 不应该被改写为常数 1
SELECT /*+opt_param('use_hash_rollup', 'disabled') */ 
  SUM(v_t0.c0) AS AF0, * 
FROM v_t0, t0 
GROUP BY v_t0.c1, t0.c1, t0.c0, v_t0.c0, v_t0.c, v_t0.c2 WITH ROLLUP 
HAVING (NOT (((+ ((((-1,'2024-12-20 14:58:49',2) NOT IN ((AF0,'2024-12-20 14:58:49',1), (0,"2024-12-20 14:58:49",v_t0.c1))) )))) != (v_t0.c)));

SELECT /*+opt_param('use_hash_rollup', 'disabled') no_rewrite */ 
  SUM(v_t0.c0) AS AF0, * 
FROM v_t0, t0 
GROUP BY v_t0.c1, t0.c1, t0.c0, v_t0.c0, v_t0.c, v_t0.c2 WITH ROLLUP 
HAVING (NOT (((+ ((((-1,'2024-12-20 14:58:49',2) NOT IN ((AF0,'2024-12-20 14:58:49',1), (0,"2024-12-20 14:58:49",v_t0.c1))) )))) != (v_t0.c)));

DROP VIEW v_t0;
DROP TABLE t0;