#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int);
create table t3 (c1 int primary key, c2 int, c3 int, unique key(c2));

insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 3, 3);
insert into t2 values (1, 1, 1);
insert into t2 values (2, 2, 2);
insert into t3 values (1, 1, 1);

--result_format 4
--explain_protocol 2

select t1.*,v.* from t1, lateral (select t2.c3,t2.c2 from t2 where t2.c1 = t1.c1 and t1.c2 = 1) v;

select t1.*,v.* from t1, lateral (select t2.c2 + t1.c2, t2.c2 from t2 where t2.c1 = t1.c1) v;

select t1.*,v.* from t1, lateral (select /*+  no_merge */ * from (select /*+ no_merge */ * from t2 where t2.c1 = t1.c1)) v;

select t1.*,v.* from t1, lateral (select t2.c2 from t2 where t2.c1 = t1.c1) v;

select /*+ leading(v t1) */ t1.*,v.* from t1, lateral (select /*+ no_merge */ count(t2.c1), t2.c2 from t2 group by c2 having t2.c2 = t1.c1 ) v;

select * from t1, lateral (select c2, sum(c1) from t2 where t2.c2 = t1.c1 group by c2) v;

select * from t1, lateral(select /*+ no_merge */ c2,c1 from t2 where t1.c1 = t2.c2) v left join t3 on v.c1 = t3.c1;

--error 4240
select * from t1, t3 left join lateral(select c2,c1 from t2 where t1.c1 = t2.c2) v on v.c1 = t3.c1;

select * from t1, t3 left join lateral(select c2,c1 from t2 where t3.c1 = t2.c2) v on 1=1;

select * from t3 left join lateral(select /*+ no_merge */ c2,c1 from t2 where t3.c1 = t2.c2) v on 1=1;

select * from t1 left join lateral (select c2, sum(c1) from t2 where t2.c2 = t1.c1 group by c2) v on 1=1;

select * from t1 left join lateral (select /*+ no_merge*/ c1, c2 from t2 where t2.c2 = t1.c2) v on 1=1;

select * from t1, lateral (select c1 from t2 where t2.c1 = t1.c2 union all select c1 from t3 where t3.c1 = t1.c2);

select * from t1 where exists(select c1 from t2 where t2.c1 = t1.c2 union all select c1 from t3 where t3.c1 = t1.c2);

select * from t1, lateral (select  sum(c1) from t2 where t1.c2 = t2.c2);

select * from t1, t2, lateral (select sum(c1) from t3 where t1.c2 = t3.c2 and t2.c3 = t3.c3);

--error 4240
select * from t1, t2 left join lateral (select sum(c1) from t3 where t1.c2 = t3.c2 and t2.c3 = t3.c3) v on 1=1;

select * from t1, t2 left join lateral (select sum(c1) from t3 where t2.c3 = t3.c3) v on 1=1;

select * from t1, lateral (select  sum(c1) from t2 where t1.c2 = t2.c2 and t1.c3 = t2.c3);

--error 4240
select * from t1, lateral (select  sum(c1) as a from t2 where t1.c2 = t2.c2 and t1.c3 = t2.c3) v left join t3 on v.a = t3.c1;

--error 4240
select * from t1, lateral (select  sum(c1) as a from t2 where t1.c2 = t2.c2 having a = 1) v left join t3 on v.a = t3.c1;

select /*+  */ t1.*, v.* from t1, lateral (select /*+ no_merge no_decorrelate */ * from t2 where t2.c2 = t1.c1 ) v where v.c1 = 1;

select  t1.*, v.* from t1, lateral (select /*+ no_merge no_decorrelate */  * from t2 where t2.c2 = t1.c1  and t2.c3 = 1 ) v where v.c3 = t1.c1;

select  t1.*, v.* from t1, lateral (select /*+ no_merge no_decorrelate use_concat */  * from t3 where t3.c3 = t1.c1  and (t3.c1 = 1 or t3.c2 =2 ) ) v where v.c3 = t1.c1;

select /*+ use_concat */  t3.*, v.* from t3, lateral (select /*+ no_merge no_decorrelate */  * from t2 where t2.c2 = t3.c1  and t2.c3 = 1 ) v where t3.c1 = 1 or t3.c2 = 2 ;

select t1.c1,v1.c2,v2.c3 from t1 left join lateral(select c2 from t2 where t2.c1 = t1.c1) v1 on 1=1
left join lateral (select c3 from t3 where t3.c1 = t1.c1) v2 on 1=1;

drop table if exists t1,t2,t3;
