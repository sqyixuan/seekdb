#owner: link.zt
#owner group: sql1
# tags: optimizer
##
## Test Name: win_magic.test
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 509, error_code = 4016, frequency = 1;
connection default;
--enable_query_log

--source mysql_test/include/sql_import_opt_wisconsin.inc
--source mysql_test/include/sql_import_opt_tpch.inc
--result_format 4
--explain_protocol 2

set ob_query_timeout = 60000000;
--echo
--echo **************  测试非分布式场景
use opt_tpch;
--source tpch_q17.inc

--echo **************  子查询from item不是基表情况
use test;
## bug: 
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
insert/*insert trace*/ into t1 values(1,2),(3,3),(4,5);
insert/*insert trace*/ into t2 values(1,2),(3,3),(4,5);
select * from t2 where c1 < (select sum(c1) from t1 right join t2 using (c1));
select * from t2 where c1 < (select sum(c1) from (select * from t1 order by c1 limit 10) as t);

--disable_warnings
drop table t1,t2;
--enable_warnings

USE OPT_WISCONSIN;
--disable_warnings
drop table if exists tmp;
--enable_warnings
create table tmp (c1 int);

set autocommit = 0;
## 外层的表和内层的表是相同的
--sorted_result
select avg(a1.thousand) from t2_100 a1 where a1.hundred >= (select avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);
--sorted_result
select /*+no_unnest(@qb1)*/ avg(a1.thousand) from t2_100 a1 where a1.hundred >= (select /*+qb_name(qb1)*/avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);

update t2_100 a1 set a1.thousand = a1.unique1 where a1.hundred >= (select avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);
select/*no explain*/sum(thousand), stddev(thousand) from t2_100;
rollback;
update t2_100 a1 set a1.thousand = (select avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);
select/*no explain*/sum(thousand), stddev(thousand) from t2_100;
rollback;
delete from t2_100 a1 where a1.hundred >= (select avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);
select/*no explain*/count(*), stddev(thousand) from t2_100;
rollback;
insert into tmp select avg(a1.thousand) from t2_100 a1 where a1.hundred >= (select avg(a2.hundred) from t2_100 a2 where a1.unique1 = a2.unique1);
select/*no explain*/* from tmp;
rollback;

