SELECT 1 FROM t1, t2 B, (SELECT max(C.c1) AS aggr, C.c2 FROM t2 C GROUP BY C.c2) VIEW1 WHERE (B.c1 = VIEW1.aggr) AND (t1.c1 = (SELECT 1 FROM t2 D WHERE (D.c2 = B.c2))) AND (t1.c2 = B.c2) AND (t1.c2 = VIEW1.c2);

#maintain semi info
--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
alter system set_tp tp_no = 556, error_code = 1735821087, frequency = 1;
sleep 2;
--enable_query_log

drop table if exists t1;
create table t1(c1 int, c2 int, c3 int);
explain outline
SELECT
    /*+opt_param('inlist_rewrite_threshold', 1)*/
    (
        SELECT
            MAX(t1_0.c1)
        FROM
            t1 AS t1_0
    ) AS c1
FROM
    (
        SELECT
            t1_0.c1,
            (
                SELECT
                    MIN(t1_0.c2)
                FROM
                    t1 AS t1_0
            ) AS c2,
            t1_0.c3
        FROM
            t1 AS t1_0
    ) AS t1_0
WHERE
    t1_0.c1 = 1
    OR t1_0.c3 in (2);

