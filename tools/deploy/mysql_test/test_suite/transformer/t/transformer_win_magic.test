SELECT table1 . col_varchar_key AS field1,
       table1 . col_int_key AS field2
FROM (B AS table1
      LEFT  JOIN ((
                     (SELECT SUBQUERY1_t2 . *
                      FROM (D AS SUBQUERY1_t1
                            INNER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `pk`))) AS table2
                   LEFT  JOIN
                     (SELECT SUBQUERY2_t1 . *
                      FROM (C AS SUBQUERY2_t1
                            LEFT  JOIN (B AS SUBQUERY2_t2
                                        INNER JOIN C AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_varchar_10` = SUBQUERY2_t2 . `col_varchar_key`
                                                                         AND SUBQUERY2_t3 . `pk` <=
                                                                           (SELECT MAX(CHILD_SUBQUERY1_t1 . `col_int_key`) AS CHILD_SUBQUERY1_field1
                                                                            FROM B AS CHILD_SUBQUERY1_t1))) ON (SUBQUERY2_t3 . `col_int` = SUBQUERY2_t2 . `col_int_key`))) AS table3 ON (table3 . `col_int` = table2 . `pk`))) ON (table3 . `col_int_key` = table2 . `col_int_key`))
WHERE (table3 . `col_varchar_20` IN
         (SELECT 'f'
          UNION SELECT 'h'))
  AND table1 . `col_varchar_key` = table2 . `col_varchar_key`
HAVING field2 < 126
ORDER BY field1,
         field2;
SELECT /*+no_rewrite*/ table1 . col_varchar_key AS field1,
       table1 . col_int_key AS field2
FROM (B AS table1
      LEFT  JOIN ((
                     (SELECT SUBQUERY1_t2 . *
                      FROM (D AS SUBQUERY1_t1
                            INNER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `pk`))) AS table2
                   LEFT  JOIN
                     (SELECT SUBQUERY2_t1 . *
                      FROM (C AS SUBQUERY2_t1
                            LEFT  JOIN (B AS SUBQUERY2_t2
                                        INNER JOIN C AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_varchar_10` = SUBQUERY2_t2 . `col_varchar_key`
                                                                         AND SUBQUERY2_t3 . `pk` <=
                                                                           (SELECT MAX(CHILD_SUBQUERY1_t1 . `col_int_key`) AS CHILD_SUBQUERY1_field1
                                                                            FROM B AS CHILD_SUBQUERY1_t1))) ON (SUBQUERY2_t3 . `col_int` = SUBQUERY2_t2 . `col_int_key`))) AS table3 ON (table3 . `col_int` = table2 . `pk`))) ON (table3 . `col_int_key` = table2 . `col_int_key`))
WHERE (table3 . `col_varchar_20` IN
         (SELECT 'f'
          UNION SELECT 'h'))
  AND table1 . `col_varchar_key` = table2 . `col_varchar_key`
HAVING field2 < 126
ORDER BY field1,
         field2;

