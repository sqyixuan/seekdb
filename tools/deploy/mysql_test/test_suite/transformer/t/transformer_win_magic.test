## rqg cases
--disable_warnings
DROP TABLE IF EXISTS B, C, CC;
--enable_warnings
CREATE TABLE B (
    col_int int,
    pk int,
    col_varchar_10_key varchar(10),
    col_varchar_20_key varchar(20),
    col_int_key int,
    col_varchar_10 varchar(10),
    col_varchar_key varchar (1),
    col_varchar varchar (1),
    col_varchar_20 varchar(20),
    /*Indices*/
    primary key (pk) ,
    key idx5(pk, col_varchar_10_key ),
    key idx7(pk, col_varchar_20_key ),
    key idx1(pk, col_int_key ),
    key idx3(pk, col_varchar_key )) ;
CREATE TABLE C (
    col_int int,
    col_varchar varchar (1),
    col_varchar_20_key varchar(20),
    col_varchar_20 varchar(20),
    col_varchar_key varchar (1),
    col_varchar_10 varchar(10),
    col_int_key int,
    pk int,
    col_varchar_10_key varchar(10),
    /*Indices*/
    key idx7(pk, col_varchar_20_key ),
    key idx3(pk, col_varchar_key ),
    key idx1(pk, col_int_key ),
    primary key (pk) ,
    key idx5(pk, col_varchar_10_key )) ;
CREATE TABLE CC (
    col_int_key int,
    col_varchar_10 varchar(10),
    col_int int,
    pk int,
    col_varchar_key varchar (1),
    col_varchar_10_key varchar(10),
    col_varchar_20_key varchar(20),
    col_varchar_20 varchar(20),
    col_varchar varchar (1),
    /*Indices*/
    key idx1(pk, col_int_key ),
    primary key (pk) ,
    key idx3(pk, col_varchar_key ),
    key idx5(pk, col_varchar_10_key ),
    key idx7(pk, col_varchar_20_key )) ;
--disable_query_log
INSERT INTO B VALUES  (4, 1, 'b', 'h', 9, 'n', 'i', 'i', 'x') ;
INSERT INTO C VALUES  (7, 'n', 'n', NULL, 'h', 'r', NULL, 1, 'b') ,  (NULL, NULL, 'a', NULL, 'g', 't', 7, 2, NULL) ;
INSERT INTO CC VALUES  (5, 'f', 7, 1, 't', 'v', 'r', 'k', 't') ,  (NULL, 's', NULL, 2, 'y', 't', NULL, NULL, 'q') ,  (5, 'i', 7, 3, 't', 'm', 'l', 'i', NULL) ,  (NULL, 'p', NULL, 4, 'l', NULL, NULL, NULL, 'r') ,  (NULL, 'i', 6, 5, 'b', NULL, NULL, 'j', 'y') ,  (1, 'p', 3, 6, NULL, 'h', 'o', 'i', NULL) ,  (6, 'n', 7, 7, 'u', 'y', 'l', 'f', 'q') ,  (5, 'x', 3, 8, 'g', 'r', 'y', 'l', 'f') ,  (7, NULL, 4, 9, NULL, 'o', 'r', NULL, 'j') ,  (1, NULL, 6, 10, 'v', NULL, 'j', 'u', 'w') ,  (3, 'f', NULL, 11, 'q', 'h', NULL, 'p', 't') ,  (NULL, 'q', 3, 12, 'f', 'x', 'l', 't', 'b') ,  (5, 's', 8, 13, 'n', NULL, 'u', NULL, NULL) ,  (7, 'n', 5, 14, 'y', 'i', 'j', 'u', 'q') ,  (8, 'b', NULL, 15, NULL, 'l', 'j', 'd', 'c') ,  (8, NULL, 1, 16, 'n', 'b', 'c', 'l', 'y') ,  (9, 's', NULL, 17, 'c', 'k', 'u', 'e', 'u') ,  (9, 'd', 5, 18, 'x', 'v', 'c', 'd', 'l') ,  (NULL, 'f', 7, 19, 'e', 'i', 'i', NULL, 'v') ,  (7, 'd', 5, 20, 'u', 'm', 'z', 'z', 'y') ,  (0, 'a', NULL, 21, NULL, 'r', NULL, 'n', NULL) ,  (6, 'q', 0, 22, NULL, 'd', 'k', 'o', 'd') ,  (8, 'w', 4, 23, 'k', 'c', 'k', 's', 'j') ,  (4, 'v', NULL, 24, 'l', 'f', 'g', 'n', 'i') ,  (8, 'b', 7, 25, NULL, 'w', 'h', 'f', 'v') ,  (2, 'l', 4, 26, 'j', 'h', 's', 'c', 'e') ,  (8, 'x', 7, 27, NULL, 't', 'b', 'h', 'a') ,  (3, 'l', 4, 28, 'i', 'f', 'o', 'o', 'a') ,  (NULL, 'h', NULL, 29, 'k', NULL, NULL, NULL, 'n') ;
--enable_query_log

SELECT    table2 . col_varchar_key AS field1 FROM ( CC AS table1 INNER JOIN ( ( CC AS table2 INNER JOIN B AS table3 ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) ) ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) WHERE (   EXISTS ( SELECT   SUBQUERY1_t1 . `col_varchar_20_key` AS SUBQUERY1_field1 FROM C AS SUBQUERY1_t1 WHERE SUBQUERY1_t1 . `pk` != table1 . `col_int` ) ) AND  table1 . `col_varchar` <> SOME ( SELECT   SUBQUERY2_t2 . `col_varchar_20_key` AS SUBQUERY2_field1 FROM ( C AS SUBQUERY2_t1 LEFT OUTER JOIN B AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_10_key`  ) ) WHERE  SUBQUERY2_t2 . `col_int` >= ( SELECT   COUNT(  CHILD_SUBQUERY1_t1 . `pk` ) AS CHILD_SUBQUERY1_field1 FROM B AS CHILD_SUBQUERY1_t1  ) GROUP BY SUBQUERY2_field1 )  GROUP BY field1  ORDER BY 1, field1 ;
SELECT /*+no_rewrite*/ table2 . col_varchar_key AS field1 FROM ( CC AS table1 INNER JOIN ( ( CC AS table2 INNER JOIN B AS table3 ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) ) ON (table3 . `col_int_key` = table2 . `col_int_key`  ) ) WHERE (   EXISTS ( SELECT   SUBQUERY1_t1 . `col_varchar_20_key` AS SUBQUERY1_field1 FROM C AS SUBQUERY1_t1 WHERE SUBQUERY1_t1 . `pk` != table1 . `col_int` ) ) AND  table1 . `col_varchar` <> SOME ( SELECT   SUBQUERY2_t2 . `col_varchar_20_key` AS SUBQUERY2_field1 FROM ( C AS SUBQUERY2_t1 LEFT OUTER JOIN B AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_10_key`  ) ) WHERE  SUBQUERY2_t2 . `col_int` >= ( SELECT   COUNT(  CHILD_SUBQUERY1_t1 . `pk` ) AS CHILD_SUBQUERY1_field1 FROM B AS CHILD_SUBQUERY1_t1  ) GROUP BY SUBQUERY2_field1 )  GROUP BY field1  ORDER BY 1, field1 ;

SELECT 1 FROM cc AS table1, b as table3 WHERE table1 . `col_varchar` <> some (SELECT SUBQUERY2_t2 . `col_varchar_20_key` FROM b AS SUBQUERY2_t2 WHERE SUBQUERY2_t2 . `col_int` >= (SELECT Count(`pk`) FROM b)) ;
SELECT /*+no_rewrite*/ 1 FROM cc AS table1, b as table3 WHERE table1 . `col_varchar` <> some (SELECT SUBQUERY2_t2 . `col_varchar_20_key` FROM b AS SUBQUERY2_t2 WHERE SUBQUERY2_t2 . `col_int` >= (SELECT Count(`pk`) FROM b)) ;
DROP TABLE B, C, CC;

