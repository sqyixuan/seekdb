--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS `t1k4wc1g`;
DROP TABLE IF EXISTS `t2iyebas`;
DROP TABLE IF EXISTS `datax_down_reconciliation_xy_zy`;
DROP TABLE IF EXISTS `cool_mcc_zfb_cate`;
DROP TABLE IF EXISTS `cool_fenrun_agent`;
DROP TABLE IF EXISTS `cool_admin_menu`;
DROP TABLE IF EXISTS `shuju_default`;
DROP TABLE IF EXISTS `cool_deal_201811`;
DROP VIEW IF EXISTS `menu_parent`;
--enable_warnings
create table if not exists `t1k4wc1g` (
	`c1` varbinary(1),
	`c2` varbinary(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

create table if not exists `t2iyebas` (
	`c1` int(11) not null,
	`c2` int(11),
	`c3` int(11),
	`c4` int(11),
	primary key (`c1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `datax_down_reconciliation_xy_zy` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
  `table_name` varchar(128) NOT NULL COMMENT '表名',
  `cd_batch` varchar(32) DEFAULT NULL COMMENT '批次号',
  `cd_count` int(11) NOT NULL COMMENT '数据量',
  `cd_time` timestamp NOT NULL DEFAULT current_timestamp() ON UPDATE current_timestamp() COMMENT '同步时间',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=20200907111722 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='下行数据对账表(祥云TO正元)';

CREATE TABLE `cool_mcc_zfb_cate` (
  `mcc_zfb_cate_id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `cate_name` varchar(100) DEFAULT NULL ,
  `cate_superior_id` int(10) DEFAULT NULL ,
  `mcc_code` varchar(10) DEFAULT NULL ,
  `mcc` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`mcc_zfb_cate_id`),
  KEY `cate_superior_id` (`cate_superior_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=410 DEFAULT CHARSET=utf8;

CREATE TABLE `cool_fenrun_agent` (
  `Id` int(11) NOT NULL AUTO_INCREMENT,
  `agent_id` varchar(50) DEFAULT NULL ,
  `total_money` varchar(255) DEFAULT NULL ,
  `agent_fr_money` varchar(255) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL ,
  `regtime` int(11) DEFAULT NULL ,
  `created_at` int(11) DEFAULT NULL ,
  PRIMARY KEY (`Id`),
  KEY `index_a` (`agent_id`),
  KEY `index_p` (`pay_pass`),
  KEY `index_r` (`regtime`)
) ENGINE=InnoDB AUTO_INCREMENT=1794 DEFAULT CHARSET=utf8 ;

CREATE TABLE `cool_admin_menu` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `name` varchar(100) DEFAULT NULL ,
  `sort` int(3) DEFAULT NULL ,
  `parent_id` int(5) DEFAULT NULL ,
  `roles` varchar(255) DEFAULT NULL ,
  `icon` varchar(255) DEFAULT NULL ,
  `url` varchar(255) DEFAULT NULL ,
  `regtime` int(11) DEFAULT NULL ,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=116 DEFAULT CHARSET=utf8 ;

CREATE
  ALGORITHM = UNDEFINED
  VIEW `menu_parent`
  AS
SELECT
  `name`, `id`
FROM
  `cool_admin_menu`
WHERE
  (`parent_id` = 0)
ORDER BY
  `sort`;

create table `shuju_default` (
`c01` int(255) NOT NULL DEFAULT '01',
`c02` numeric NOT NULL DEFAULT '02',
`c03` decimal(10,5) NOT NULL DEFAULT '03',
`c04` bit(64) NOT NULL DEFAULT '04',
`c05` tinyint(255) NOT NULL DEFAULT '05',
`c06` smallint NOT NULL DEFAULT '06',
`c07` mediumint NOT NULL DEFAULT '07',
`c08` bigint NOT NULL DEFAULT '08',
`c09` float(20) NOT NULL DEFAULT '09',
`c10` double NOT NULL DEFAULT '10',
`c11` varchar(255) NOT NULL DEFAULT '杭州',
`c12` char(255) NOT NULL DEFAULT '雷峰塔',
`c13` tinytext NOT NULL,
`c14` mediumtext NOT NULL,
`c15` tinyblob NOT NULL,
`c16` longtext NOT NULL,
`c17` mediumblob NOT NULL,
`c18` longblob NOT NULL,
`c19` binary(255) NOT NULL DEFAULT '19',
`c20` varbinary(255) NOT NULL DEFAULT '20',
`c21` timestamp,
`c22` date NOT NULL DEFAULT '2018-09-22',
`c23` time NOT NULL DEFAULT '21:41:23',
`c24` datetime NOT NULL DEFAULT '2020-05-14 21:41:24',
`c25` year NOT NULL DEFAULT '1996',
`c26` blob NOT NULL,
 primary key(`c01`));
