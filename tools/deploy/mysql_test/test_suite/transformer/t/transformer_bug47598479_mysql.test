CREATE TABLE `cool_deal_201811` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `trade_body` varchar(255) DEFAULT NULL ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=4009771 DEFAULT CHARSET=utf8;

--disable_query_log
--explain_protocol 2
--result_format 4
--enable_query_log

select 
  EXISTS (
    select 
      ref_1.c09 as c0 
    from 
      (
        select  
          1
        from 
          test.datax_down_reconciliation_xy_zy as ref_2 
        where 
          ref_1.c06 > 0
        limit 
          1
      ) as subq_1 
    where 
      (
        select 
          mcc_zfb_cate_id 
        from 
          test.cool_mcc_zfb_cate 
      ) 
  ) as c1
from 
  (
    test.menu_parent as ref_0 left join test.shuju_default as ref_1 on (0)
  );

select cast(coalesce(ref_1.c23, ref_1.c24) as DATETIME) as c0, case when ref_1.c01 <> case when ref_1.c05 | ref_1.c05 then ref_1.c08 else (select avg(c3) from test.t1k4wc1g) end then case when 1 then ref_1.c07 else ref_1.c07 end else (select c1 from test.t2iyebas limit 1 offset 57) end as c1, rtrim( cast(ref_1.c14 as CHAR)) as c2, case when EXISTS ( select ref_1.c09 as c0 from (select subq_0.c1 as c0, ref_2.cd_batch as c1, subq_0.c0 as c2, subq_0.c1 as c3, ref_1.c08 as c4, ref_1.c12 as c5, subq_0.c0 as c6 from test.datax_down_reconciliation_xy_zy as ref_2 where ref_2.cd_count - ref_1.c06 limit 116) as subq_1 where ((subq_1.c6 AND ref_1.c08) or ((select mcc_zfb_cate_id from test.cool_mcc_zfb_cate limit 1 offset 74) OR ref_1.c06)) and (ref_1.c17 is NULL) limit 42) then ref_1.c15 else ref_1.c19 end as c3 from ((select ref_0.id as c0, (select total_money from test.cool_fenrun_agent limit 1 offset 6) as c1 from test.menu_parent as ref_0 where ((ref_0.id / ref_0.id) or ((ref_0.id <= ref_0.id) and (ref_0.name is not NULL))) or (((ref_0.id > ref_0.id) and (ref_0.id << ref_0.id)) or (ref_0.id <= ref_0.id)) limit 140) as subq_0 left join test.shuju_default as ref_1 on (0)) where (subq_0.c0 | ref_1.c07) and (case when case when subq_0.c0 is not NULL then ref_1.c06 else ref_1.c05 end = ref_1.c06 then ref_1.c01 else (select avg(deal_id) from test.cool_deal_201811) end & ref_1.c01) limit 149 ;

