# owner: sean.yyj
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);
insert into t1 values(1);

--result_format 4
--explain_protocol 1
select 1 from t1 left join t2 on t1.c1 = t2.c1 where 1=0 or (t2.c1 is null and exists(select 1 from t3));

drop table t1,t2,t3;
