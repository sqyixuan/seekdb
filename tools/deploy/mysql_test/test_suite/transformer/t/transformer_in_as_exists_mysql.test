#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists s1;
drop table if exists s2;
drop table if exists s3;
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table s1 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table s2 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table s3 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
insert into s1 values (1,1,1),(2,2,2),(3,3,3);
insert into s2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
insert into s3 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10);
insert into t1 values(1,2,1);
insert into t2 values(1,1,1);
--explain_protocol 2
--result_format 4

select case when c2 in (select c1 from S2) then 0 else 1 end from S1;
select * from s1 where case when c2 in (select c1 from S2) then 0 else 1 end = 0;
select * from s1 where c1 in (select c1 from s2);
select sum(c2) from s1 where c1 < 100 group by c3 having sum(c2) in (select c1 from s2);
select case when (select c1 + 1 from S1 where c1 = 1) + 1 in (select c1 from S2) then 0 else 1 end from S1;

select case when c2 in (select c2 from S2) then 0 else 1 end from S1;
select case when c2 in (select c1 + 1 from S2) then 0 else 1 end from S1;

select case when c2 in (select c1 from S2 where S2.c1 < 100 limit 1) then 0 else 1 end from S1;

select case when c2 in (select sum(c1) from S2 group by c2) then 0 else 1 end from S1;
select case when c1 in (select sum(c2) from S2 where S2.c1 < 100 group by c1 with rollup) then 0 else 1 end from S1;

select case when c1 in (select sum(c2) over (partition by c1 order by c3) from s2 where c1 < 100) then 0 else 1 end from s1;

select case when c2 in (select c1 from s2 where c1 < 100 union all select c1 from s2 where c1 > 200) then 0 else 1 end from S1;
select case when c2 in (select c1 from s2 where c1 < 100 except select c1 from s1 where c1 < 50) then 0 else 1 end from s1;
select case when c2 in (select c1 from s2 where c1 < 100 intersect select c1 from s2 where c1 < 50) then 0 else 1 end from s1;

select case when c2 in (select r.c1 from s2 l left join s2 r on l.c2 = r.c2 + 1 where l.c1 < 100) then 0 else 1 end from s1;
select r.c2 from s2 l left join s2 r on l.c2 in (select c1 from s2) where l.c1 < 100;

select case when (c2,c1) in (select c1,c2 + 100 from S2 where S2.c1 < 100) then 0 else 1 end from S1;

select case when c2 not in (select c1 from s2) then 0 else 1 end from s1;
select case when c2 > any (select c1 from s2) then 0 else 1 end from s1;
select case when c2 < any (select c1 from s2) then 0 else 1 end from s1;
select case when c2 >= any (select c1 from s2) then 0 else 1 end from s1;
select case when c2 <= any (select c1 from s2) then 0 else 1 end from s1;
select case when c2 > all (select c1 from s2) then 0 else 1 end from s1;
select case when c2 < all (select c1 from s2) then 0 else 1 end from s1;
select case when c2 >= all (select c1 from s2) then 0 else 1 end from s1;
select case when c2 <= all (select c1 from s2) then 0 else 1 end from s1;

select case when c2 in (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from S1;
select * from s1 where case when c2 in (select c2 from S2 where c1 > S1.c1) then 0 else 1 end = 0;
select * from s1 where c1 in (select c2 from S2 where c1 > S1.c1);
select case when (select c1 + 1 from S1 where c1 = 1) + 1 in (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from S1;

select case when c2 in (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from S1;
select case when c2 in (select c2 + 100 + (select 1 from dual) from S2 where c1 > S1.c1) then 0 else 1 end from S1;

select case when c2 in (select c2 from S2 where c1 > S1.c1 limit 1) then 0 else 1 end from S1;

select case when c2 in (select sum(c1) from S2 where c1 > S1.c1 group by c2) then 0 else 1 end from S1;
select case when c1 in (select sum(c2) from S2 where S2.c1 < 100 and c1 > S1.c1 group by c1 with rollup) then 0 else 1 end from S1;

select case when c1 in (select sum(c2) over (partition by c1 order by c3) from s2 where c1 < 100 and c1 > S1.c1) then 0 else 1 end from s1;

select case when c2 in (select c2 from S2 where c1 > S1.c1 union all select c2 from S2 where c1  < S1.c1 + 100) then 0 else 1 end from S1;
select case when c2 in (select c2 from S2 where c1 > S1.c1 except select c1 from s1 where c1 < 50) then 0 else 1 end from s1;
select case when c2 in (select c2 from S2 where c1 > S1.c1 intersect select c1 from s2 where c1 < 50) then 0 else 1 end from s1;

select case when c2 in (select r.c2 from s2 l left join s2 r on l.c2 = r.c2 + 1 where l.c1 < 100 and l.c1 > S1.c1) then 0 else 1 end from s1;
select r.c2 from s2 l left join s2 r on l.c2 in (select c2 from s2 where c1 > l.c1) where l.c1 < 100;

select case when (c2,c1) in (select c3,c2 + 100 from S2 where S2.c1 < 100 and S2.c1 > S1.c1) then 0 else 1 end from S1;

select case when c2 not in (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 > any (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 < any (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 >= any (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 <= any (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 > all (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 < all (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 >= all (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;
select case when c2 <= all (select c2 from S2 where c1 > S1.c1) then 0 else 1 end from s1;

select null in (select c1 from s1 where c1 = 1), c2 from s2;
select /*+ no_rewrite */ null in (select c1 from s1 where c1 = 1), c2 from s2;
select c1,c2 from s1 where c1 in (select c1 from s2) is false;
select /*+ no_rewrite */ c1,c2 from s1 where c1 in (select c1 from s2) is false;
select case when not c1 in (select c1 from s2) and c2 in (select c1 from s1) then c1 else c1 + 100 end from s1;
select /*+ no_rewrite */ case when not c1 in (select c1 from s2) and c2 in (select c1 from s1) then c1 else c1 + 100 end from s1;
select s1.c1,s2.c2 from s1 left join s2 on (s1.c1 not in (select c1 from s2));
select /*+ no_rewrite */ s1.c1,s2.c2 from s1 left join s2 on (s1.c1 not in (select c1 from s2));
select s1.c1,s2.c2 from s1 left join s2 on (s1.c2 not in (select c1 from s2));
select /*+ no_rewrite */ s1.c1,s2.c2 from s1 left join s2 on (s1.c2 not in (select c1 from s2));
select s1.c1,s2.c2 from s1 left join s2 on (s2.c1 not in (select c1 from s2));
select /*+ no_rewrite */ s1.c1,s2.c2 from s1 left join s2 on (s2.c1 not in (select c1 from s2));
select s1.c1,s2.c2,s3.c3 from s1 left join (s2 left join s3 on (s3.c1 not in (select c1 from s1))) on (s1.c1 not in (select c1 from s2));
select /*+ no_rewrite */ s1.c1,s2.c2,s3.c3 from s1 left join (s2 left join s3 on (s3.c1 not in (select c1 from s1))) on (s1.c1 not in (select c1 from s2));
select s1.c1,s2.c2,s3.c3 from (s1 left join s2 on s1.c1 = s2.c2) left join s3 on (s2.c1 not in (select c1 from s1));
select /*+ no_rewrite */ s1.c1,s2.c2,s3.c3 from (s1 left join s2 on s1.c1 = s2.c2) left join s3 on (s2.c1 not in (select c1 from s1));

select * from t1 where (c1,c2) in (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);
select /*+ no_rewrite */ * from t1 where (c1,c2) in (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select * from t1 where (c1,c2) not in (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);
select /*+ no_rewrite */ * from t1 where (c1,c2) not in (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);


select * from t1 where (c1,c2) != any (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select /*+ no_rewrite */ * from t1 where (c1,c2) != any (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select * from t1 where (c1,c2) = any (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select /*+ no_rewrite */ * from t1 where (c1,c2) = any (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select * from t1 where (c1,c2) != all (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select /*+ no_rewrite */* from t1 where (c1,c2) != all (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select * from t1 where (c1,c2) = all (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

select /*+ no_rewrite */ * from t1 where (c1,c2) = all (select /*+no_unnest,no_merge*/ c1, c2 from t2 where t2.c3 = t1.c3);

--explain_protocol 0 

drop table s1;
drop table s2;
drop table s3;