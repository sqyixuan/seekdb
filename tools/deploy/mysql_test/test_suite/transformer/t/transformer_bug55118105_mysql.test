# tags: optimizer, cross_validation
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int);
insert into t1 values(1,1);

--explain_protocol 1
--result_format 4

--echo # eliminate left join 
select 1 from (t1 left join (select 1 from dual where 0 = 1) `VIEW1` on 1 = 1), (select 2 from dual where 0 = 1) `VIEW2` where t1.c1 = t1.c2;
select 1 from (t1 left join (select 1 from dual where 0 = 1) `VIEW1` on 1 = 1), (select 2 from dual) `VIEW2` where t1.c1 = t1.c2;
select 1 from (t1 left join (select 1 from dual) `VIEW1` on 1 = 1), (select 2 from dual where 0 = 1) `VIEW2` where t1.c1 = t1.c2;
select 1 from (t1 left join (select 1 from dual) `VIEW1` on 1 = 1), (select 2 from dual) `VIEW2` where t1.c1 = t1.c2;

--echo # eliminate inner join 
select 1 from (select /*+no_merge*/ 2 from dual) a, (select /*+no_merge*/ 3 from dual) b;
select /*+no_simplify_expr*/ 1 from (select /*+no_merge*/ 2 from dual) a, (select /*+no_merge*/ 3 from dual) b where 1 = 1;
select /*+no_simplify_expr*/ 1 from (select /*+no_merge*/ 2 from dual where 4=5) a, (select /*+no_merge*/ 3 from dual where 6=7) b where 1 = 1;
select /*+no_simplify_expr*/ 1 from (select /*+no_merge*/ 2 from dual where 4=5) a, (select /*+no_merge*/ 3 from dual) b where 1 = 1;
select /*+no_simplify_expr*/ 1 from (select /*+no_merge*/ 2 from dual) a, (select /*+no_merge*/ 3 from dual) b where 1 = 1;

--echo # eliminate temp table
explain with cte as (select /*+materialize*/ 2 from dual where 0 = 1) select 1 from (t1 left join cte a on 1 = 1), cte b where t1.c1 = t1.c2;
with cte as (select /*+materialize*/ 2 from dual where 0 = 1) select 1 from (t1 left join cte a on 1 = 1), cte b where t1.c1 = t1.c2;
explain with cte as (select /*+materialize*/ 2 from dual) select 1 from (t1 left join cte a on 1 = 1), cte b where t1.c1 = t1.c2;
with cte as (select /*+materialize*/ 2 from dual) select 1 from (t1 left join cte a on 1 = 1), cte b where t1.c1 = t1.c2;

--echo # target table contains nested inline view, not supported by now
select 1 from (t1 left join (select 1 from (select /*+no_merge*/ 2 from dual)) `VIEW1` on 1 = 1), (select 3 from (select /*+no_merge*/ 4 from dual)) `VIEW2` where t1.c1 = t1.c2;
select 1 from (t1 left join (select 1 from (select /*+no_merge*/ 2 from dual where 0 = 1)) `VIEW1` on 1 = 1), (select 3 from (select /*+no_merge*/ 4 from dual where 0 = 1)) `VIEW2` where t1.c1 = t1.c2;

--echo # target table contains more than one table, not supported by now
select 1 from (t1 left join (select /*+no_merge*/ 1 from (select /*+no_merge*/ 2 from dual) a, (select /*+no_merge*/ 3 from dual) b) `VIEW1` on 1 = 1), (select /*+no_merge*/ 4 from (select /*+no_merge*/ 5 from dual) c, (select /*+no_merge*/ 6 from dual) d) `VIEW2` where t1.c1 = t1.c2;
select 1 from (t1 left join (select /*+no_merge*/ 1 from (select /*+no_merge*/ 2 from dual where 0 = 1) a, (select /*+no_merge*/ 3 from dual) b) `VIEW1` on 1 = 1), (select /*+no_merge*/ 4 from (select /*+no_merge*/ 5 from dual where 0 = 1) c, (select /*+no_merge*/ 6 from dual) d) `VIEW2` where t1.c1 = t1.c2;

drop table t1;
