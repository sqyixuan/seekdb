                                     ),
                                     INTERVAL '05:05.000005'
                                     MINUTE_MICROSECOND
                                      ),
                                     INTERVAL '05:05:05' HOUR_SECOND) )
                                     IS NULL
                                     OR (( col_timestamp_6 =
                                     Date_add(Concat(Cast(2015 + 4 +
                                              3 AS
                                              CHAR(
                                              20)
                                              ),
                                            '-06-19 01:00:00.000003')
                                     ,
                                                       INTERVAL
                                     '05:05.000005'
                                     MINUTE_MICROSECOND
                                     )
                                     ))
                                     IS
