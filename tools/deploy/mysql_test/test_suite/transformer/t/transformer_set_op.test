(select c1, c2 from t1 limit 5) union all select c1, c2 from t2 order by c1 limit 2 offset 1;
--sorted_result
(select /*+ NO_REWRITE */c1, c2 from t1 limit 5) union all select /*+ NO_REWRITE */c1, c2 from t2 order by c1 limit 2 offset 1;

explain select c1 from t1 minus select c2 from t2 order by c1 limit 2;
