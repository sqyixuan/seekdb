                                         <=
                                         Cast(Concat( Substr( 'ue'
                                         , 1, 20)
                                         ,
                                         col_char_20
                                         ) AS
                                         CHAR)
                                                  ORDER  BY pk ASC)
                                                 TC1),
                                                 (SELECT *
                                                  FROM   (SELECT (
                                                 SELECT
                                                         Coalesce(
                                                               (
                                                 SELECT *
                                                 FROM
                                         (SELECT
                                                 col_bigint
                                                         FROM
                                                 table0_hash_pk_parts_1_bigint
                                                          WHERE
                                                 Round(Sign(
                                                 col_decimal_20_0_index)
                                                 )
                                                 !=
                                                 Round(Sign(Round(Sign(
                                                            Round(Sign(
                                                            Round(
                                                                  Ceil(
                                                            Round(Round
                                                            (
                                                 col_decimal_20_0_index
                                                            ))
                                                 )
                                                 )))))
                                                 ))
                                                          ORDER  BY
                                         col_char_5_key,
                                         pk ASC
                                                          LIMIT  1) TC1),
                                                        (SELECT *
                                                         FROM
                         (SELECT Avg(col_bigint)
                          FROM
                                      table2_hash_pk_parts_1_bigint
                                               WHERE
                                      col_char_20 =
                                      col_char_20_index
                                               ORDER  BY pk ASC)
                         TC2), 99))
                         )
                                       TC2), 6663)) <=> col_bigint
                                       )
                                                   AND ( col_bigint IN
                                                         ( -20594, 1922560, 91 )
                                                       )
                                                   AND NOT (
                                       col_bigint_index IN (
                                       -20594, 1922560, 91 )
                                                           )
                                                 )
                                                  OR NOT ( ( Date_sub(Date_add(
                                                             Concat(Cast(2015 +
                                                                    4 +
