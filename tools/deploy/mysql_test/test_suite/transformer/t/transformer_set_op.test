##test support insert/update/delete stmt

--disable_warnings
drop table if exists t3;
--enable_warnings

create table t3 (c1 int, c2 int);

--disable_query_log
--disable_result_log
insert into t3 values (1, 1);
insert into t3 values (2, 5);
select count(*) from t3;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

set autocommit = 0;

##basic result
select /**/ * from t3;

insert into t3 select * from t1 union select c1,c2 from t2;
select/**/* from t3;
rollback;
insert into t3 select /*+ NO_REWRITE */* from t1 union select c1,c2 from t2;
select/**/* from t3;
rollback;
update t3 set t3.c1 = (select c1 from t1 union select c2 from t2 limit 1);
select/**/* from t3;
rollback;
update t3 set t3.c1 = (select /*+ NO_REWRITE */c1 from t1 union select c2 from t2 limit 1);
select/**/* from t3;
rollback;
delete t3 from t3, (select c1 from t1 union select c2 from t2)v where t3.c1 = v.c1;
select/**/* from t3;
rollback;
delete t3 from t3, (select /*+ NO_REWRITE */c1 from t1 union select c2 from t2)v where t3.c1 = v.c1;
select/**/* from t3;
rollback;

insert into t3(c1) select c1 from t1 union select c2 from t2 limit 2;
