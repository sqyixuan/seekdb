##测试case
--sorted_result
SELECT CASE
         WHEN col_timestamp_6_index < '2000-01-01' THEN
         'datetime_field is before 2000-01-01.'
         WHEN col_timestamp_6 <=> '2000-01-01' THEN
         'datetime_field is at 2000-01-01.'
         WHEN col_timestamp_6 > '2000-01-01' THEN
         'datetime_field is after 2000-01-01.'
         WHEN col_timestamp_6_index IS NULL THEN 'datetime_field is NULL.'
         ELSE 'datetime_field is not a col_timestamp_6 or NULL'
       end,
       pk
FROM   table5_bigint
WHERE  ( col_bigint BETWEEN NULL AND NULL )
        OR ( col_decimal_20_0_index IN ( -20594 )
             AND ( 5 BETWEEN (SELECT Coalesce((SELECT *
                                               FROM   (SELECT 204) TC1),
                         (SELECT *
                          FROM   (SELECT pk
                                  FROM   table100_bigint
                                  WHERE  NOT
                                   ( ( ( col_decimal_20_0 >
