LIMIT  8; 

## 简化case
--sorted_result
SELECT pk 
FROM table5_bigint 
WHERE 
  (SELECT /*+use_concat*/ pk 
   FROM table100_bigint 
   WHERE col_bigint IN (1, 2) 
   ORDER BY col_timestamp_6_key DESC LIMIT 1);

--sorted_result
select t1.c1 from t1 where ((select t2.c1 from t2 union select t3.c1 from t3) order by t1.c1 limit 1);

drop table t1, t2, t3;
drop table `table5_bigint`, `table100_bigint`, `table10_bigint`, `table0_hash_pk_parts_1_bigint`, `table2_hash_pk_parts_1_bigint`;


## non-deterministic func case
create table nt1(c1 int, c2 int);
insert into nt1 values (1, 1);
select * from nt1 union select * from nt1 order by rand() limit 1;
select * from nt1 union select * from nt1 order by rand() + 1 limit 1;
select * from (select c2 from nt1 union select c2 from nt1) v order by v.c2;
select * from (select c2 from nt1 union select c2 from nt1) v order by rand();
select * from (select c2 from nt1 union select c2 from nt1) v order by v.c2 limit 1;
select * from (select c2 from nt1 union select c2 from nt1) v order by rand() limit 1;

#bug fix:
SELECT c1
              FROM   (SELECT /*+no_merge use_concat*/c1 + 1 cc,
                             c1
                      FROM   nt1
                      WHERE  c1 = 1 or c1 = 2 or c1 = 3
                      ORDER  BY 1 DESC
                      LIMIT  3 offset 5)TC1; 

drop table nt1;


drop database transformer;
