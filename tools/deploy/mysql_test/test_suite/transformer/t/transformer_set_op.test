explain (select c1, c2 from t1 order by c2) union all select c1, c2 from t2 order by c1 limit 2;
explain (select /*+ NO_REWRITE */c1, c2 from t1 order by c2) union all select /*+ NO_REWRITE */c1, c2 from t2 order by c1 limit 2;
