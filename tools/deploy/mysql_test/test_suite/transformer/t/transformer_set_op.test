##bug:
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

--disable_query_log
--disable_result_log
insert into t1 values(3,3);
insert into t1 values(2,2);
insert into t1 values(1,1);
insert into t2 values(3,3);
insert into t2 values(2,2);
insert into t2 values(1,1);
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log

select * from t1 union select * from t1 order by c2, (select min(c2) from t2) limit 2;
select /*+parallel(2)*/* from t1 union select * from t1 order by c2, (select min(c2) from t2) limit 2;

select * from t1 union select * from t1 order by c1, (select min(c2) from t2) limit 2;
select /*+parallel(2)*/* from t1 union select * from t1 order by c1, (select min(c2) from t2) limit 2;

select * from (select * from t1 union select * from t1)v order by (select min(c2) from t2 where v.c1 = t2.c1) limit 2;
select /*+parallel(2)*/* from (select * from t1 union select * from t1)v order by (select min(c2) from t2 where v.c1 = t2.c1) limit 2;

select (select min(c2)+33223) as cc from t1 where t1.c1 = 1 or t1.c2 = 1 order by 1 limit 232;
select /*+use_concat,parallel(2)*/ (select min(c2)+33223) as cc from t1 where t1.c1 = 1 or t1.c2 = 1 order by 1 limit 232;

drop table t1,t2;


## test get limit、order by from parent
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--disable_query_log
--disable_result_log
create table t1 (c1 int, c2 int, primary key(c1, c2));
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);

insert into t1 values (1, 1);
insert into t1 values (2, 5);
insert into t1 values (3, 2);
insert into t1 values (4, 6);
insert into t1 values (5, 4);
insert into t1 values (6, 7);

insert into t2 values (1, 2);
insert into t2 values (1, 2);
insert into t2 values (2, 3);

insert into t3 values (2, 3);
insert into t3 values (2, 3);
insert into t3 values (3, 4);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_query_log
--enable_result_log

select /*+ NO_REWRITE */* from (select * from t2 union all select * from t3) order by c2 limit 5;
select * from (select * from t2 union all select * from t3) order by c2 limit 5;

select /*+ NO_REWRITE */* from (select * from t2 union select * from t3) order by c2 limit 5;
select * from (select * from t2 union select * from t3) order by c2 limit 5;

select /*+ NO_REWRITE */* from (select * from t2 union select * from t3) limit 5;
select * from (select * from t2 union select * from t3) limit 5;

select /*+ NO_REWRITE */ * from (select * from t2 union select * from t3) where c1 = 1 order by c2 limit 5;
select * from (select * from t2 union select * from t3) where c1 = 1 order by c2 limit 5;

## do not transform
select distinct c1 from (select * from t2 union all select * from t3) order by c2 limit 5;
select min(c1) from (select * from t2 union select * from t3) order by c2 limit 5;
select (select c1 from t2 where c1 < 0 union select c1 from t3 where c1 = 2) from t1 order by c2 limit 5;
select * from t1, (select * from t2 union select * from t3) v order by t1.c1 limit 5;
select * from t1 where t1.c1 >any (select t2.c1 from t2 union select t3.c1 from t3) order by t1.c1 limit 5;

