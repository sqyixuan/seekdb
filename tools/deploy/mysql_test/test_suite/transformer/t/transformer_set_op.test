--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
#description: transform模块测试，对比transform以后的结果与非transform的结果,验证transform正确性

## 
--disable_warnings
--disable_query_log
drop database if exists transformer;
create database transformer;
use transformer;

create table t1(c1 int primary key, c2 int);
insert into t1 values (1, 1);
insert into t1 values (2, 5);
insert into t1 values (3, 2);
insert into t1 values (4, 6);
insert into t1 values (5, 4);
insert into t1 values (6, 7);

create table t2(c1 int primary key, c2 int, c3 varchar(32));
insert into t2 values (1, 1, 'o');
insert into t2 values (2, 5, 'c');
insert into t2 values (3, 5, 'b');
insert into t2 values (4, 6, 'o');
insert into t2 values (5, 7, 'd');
insert into t2 values (6, 8, 'c');

create view v(c1) as select c1 from t1;

sleep 3;

--enable_warnings
--enable_query_log
# schema END

# distinct 下压(有才limit 下压)
explain select c1 from t1 union select c2 from t2;
explain select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2;
--sorted_result
select c1 from t1 union select c2 from t2;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2;

# 下压
explain select c1 from t1 union select c2 from t2 limit 2;
explain select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2 limit 2;
--sorted_result
select c1 from t1 union select c2 from t2 limit 2;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2 limit 2;

explain select c1 from t1 union select c2 from t2 limit 2 offset 1;
explain select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;
--sorted_result
select c1 from t1 union select c2 from t2 limit 2 offset 1;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 union select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;

explain select c1 from t1 minus select c2 from t2 limit 2;
explain select /*+ NO_REWRITE */c1 from t1 minus select /*+ NO_REWRITE */c2 from t2 limit 2;
--sorted_result
select c1 from t1 minus select c2 from t2 limit 2;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 minus select /*+ NO_REWRITE */c2 from t2 limit 2;

explain select c1 from t1 minus select c2 from t2 limit 2 offset 1;
explain select /*+ NO_REWRITE */c1 from t1 minus select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;
--sorted_result
select c1 from t1 minus select c2 from t2 limit 2 offset 1;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 minus select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;

explain (select c1 from t1 limit 2) union select c2 from t2;
explain (select /*+ NO_REWRITE */c1 from t1 limit 2) union select /*+ NO_REWRITE */c2 from t2;
--sorted_result
(select c1 from t1 limit 2) union select c2 from t2;
--sorted_result
(select /*+ NO_REWRITE */c1 from t1 limit 2) union select /*+ NO_REWRITE */c2 from t2;

# limit 下压(只有union all下压)
explain select c1 from t1 union all select c2 from t2 limit 2;
explain select /*+ NO_REWRITE */c1 from t1 union all select /*+ NO_REWRITE */c2 from t2 limit 2;
--sorted_result
select c1 from t1 union all select c2 from t2 limit 2;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 union all select /*+ NO_REWRITE */c2 from t2 limit 2;

explain select c1 from t1 union all select c2 from t2 limit 2 offset 1;
explain select /*+ NO_REWRITE */c1 from t1 union all select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;
