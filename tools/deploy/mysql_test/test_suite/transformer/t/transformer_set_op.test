--sorted_result
select /*+ NO_REWRITE */c1 from t1 intersect select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;

# order by 下压
explain select c1 from t1 union all select c2 from t2 order by c1;
explain select /*+ NO_REWRITE */c1 from t1 union all select /*+ NO_REWRITE */c2 from t2 order by c1;
