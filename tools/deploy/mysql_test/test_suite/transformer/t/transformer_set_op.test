select c1 from t1 union all select c2 from t2 limit 2 offset 1;
--sorted_result
select /*+ NO_REWRITE */c1 from t1 union all select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;

explain (select c1 from t1 limit 5) union all select c2 from t2 limit 2;
explain (select /*+ NO_REWRITE */c1 from t1 limit 5) union all select /*+ NO_REWRITE */c2 from t2 limit 2;
--sorted_result
(select c1 from t1 limit 5) union all select c2 from t2 limit 2;
--sorted_result
(select /*+ NO_REWRITE */c1 from t1 limit 5) union all select /*+ NO_REWRITE */c2 from t2 limit 2;

explain (select c1 from t1 limit 5) union all select c2 from t2 limit 2 offset 1;
explain (select /*+ NO_REWRITE */c1 from t1 limit 5) union all select /*+ NO_REWRITE */c2 from t2 limit 2 offset 1;
