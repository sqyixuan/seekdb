
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql3
# tags: optimizer
#description: rownum limit改写测试,验证transform以及plan cache正确性
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
insert into t1 values (0,5,7,1);
insert into t1 values (1,9,2,4);
insert into t1 values (2,0,2,1);
insert into t1 values (3,4,6,9);
insert into t1 values (4,7,null,3);
insert into t1 values (5,3,5,null);
insert into t1 values (6,8,null,null);
insert into t1 values (7,7,8,8);

create table t2 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
insert into t2 values (0,5,7,1);
insert into t2 values (1,9,2,4);
insert into t2 values (2,0,2,1);
insert into t2 values (3,4,6,9);
insert into t2 values (4,7,null,3);
insert into t2 values (5,3,5,null);
insert into t2 values (6,8,null,null);
insert into t2 values (7,7,8,8);


--result_format 4
--explain_protocol 2
set autocommit = 0;

#### merge_limit 
## to limit 0
select * from (select * from t1 limit 10 offset 2) limit 3 offset 11;

select * from (select * from t1 limit 10 offset 2) limit 3 offset 10;

select * from (select * from t1 limit 4 offset 2) limit 3 offset 6;

select * from (select * from t1 limit 4 offset 2) limit 3 offset 6;
#should have 1 rows, hint count = 4
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ? offset ?';


# to upper limit
select * from (select * from t1 limit 10 offset 3) limit 5 offset 3;

select * from (select * from t1 limit 10 offset 3) limit 5 offset 6;
#should have 2 rows
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ? offset ?';

## to view limit - upper offset
select * from (select * from t1 limit 12 offset 3) limit 5 offset 9;

#should have 3 rows
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ? offset ?';



#upper limit
select * from (select * from t1 limit 10 offset 3) limit 5;

select * from (select * from t1 limit 10 offset 3) limit 8;

##1 rows, hit count = 1
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ?';


select * from (select * from t1 limit 10) limit 5 offset 3;

select * from (select * from t1 limit 10) limit 5 offset 9;

select * from (select * from t1 limit 10) limit 5 offset 11;

##2 rows, hit count = 0, 1
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ?';



#view limit
select * from (select * from t1 limit 10 offset 3) limit 13;

select * from (select * from t1 limit 10 offset 3) limit 18;

select * from (select * from t1 limit 10 offset 3) limit 20;
##2 rows, hit count = 2 
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?) limit ?';


#view limit
select * from (select * from t1 limit 10 offset 3);

select * from (select * from t1 limit 10 offset 11);

select * from (select * from t1 limit 0 offset 11);
## 1 rows 2 hint count
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ? offset ?)';

#view limit
select * from (select * from t1 limit 10);

select * from (select * from t1 limit 3);

select * from (select * from t1 limit 0);

# 1 rows, 2 hit count
select hit_count, query_sql from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where statement like 'select * from (select * from t1 limit ?)';

--disable_warnings
drop table t1;
drop table t2;
--enable_warnings

