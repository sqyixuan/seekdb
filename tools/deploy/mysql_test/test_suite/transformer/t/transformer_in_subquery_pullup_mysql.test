# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists s1;
drop table if exists s2;
drop table if exists s3;
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table s1 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table s2 (c1 int primary key, c2 int, c3 int) partition by hash(c1);
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
insert into s2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,null,null);
insert into s1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,null,null);
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(null,null,null);
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(null,null,null);

--explain_protocol 2
--result_format 4

select exists (select c2 from t2 where t2.c1 = t1.c1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1) from t1;
select exists (select c2 from t2 where t2.c1 = 1) from dual;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = 1) from dual;
select exists (select c2 from t2) from t1;
select exists (select /*+no_unnest*/ c2 from t2) from t1;
select exists (select c2 from t2 where t2.c1 > t1.c1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 > t1.c1) from t1;
select exists (select c2 from t2 where t2.c1 = t1.c1 limit 1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1 limit 1) from t1;
select exists (select c2 from t2 where t2.c1 = t1.c1 order by c2 limit 1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1 order by c2 limit 1) from t1;
select exists (select c2 from t2 where t2.c1 = t1.c1 order by c1 limit 1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1 order by c1 limit 1) from t1;
select exists (select c2 from t2 where t2.c1 = t1.c1 limit 0) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1 limit 0) from t1;
select exists (select c2 from t2 where t2.c1 = t1.c1 limit 1 offset 1) from t1;
select exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1 limit 1 offset 1) from t1;
select exists (select distinct c2 from t2 where t2.c1 = t1.c1) from t1;
select exists (select /*+no_unnest*/ distinct c2 from t2 where t2.c1 = t1.c1) from t1;
select case when exists (select c2 from t2 where t2.c1 = t1.c1) then 1 else 0 end from t1;
select case when exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1) then 1 else 0 end from t1;
select not exists (select c2 from t2 where t2.c1 = t1.c1) from t1;
select not exists (select /*+no_unnest*/ c2 from t2 where t2.c1 = t1.c1) from t1;

select c1 in (select c1 from t2) from t1;
select c1 in (select /*+no_unnest*/ c1 from t2) from t1;
select case when c1 in (select c1 from t2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2) then 1 else 0 end from t1;
select case when c1 in (select distinct c1 from t2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ distinct c1 from t2) then 1 else 0 end from t1;
select case when c1 in (select distinct c1 from t2 where t2.c2 = 0) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ distinct c1 from t2 where t2.c2 = 0) then 1 else 0 end from t1;
select case when c1 in (select distinct c1 from t2 where t1.c2 = 0) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ distinct c1 from t2 where t1.c2 = 0) then 1 else 0 end from t1;
select case when c1 in (select distinct c1 from t2 where t1.c2 = t2.c2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ distinct c1 from t2 where t1.c2 = t2.c2) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2 where t1.c2 = t2.c2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2 where t1.c2 = t2.c2) then 1 else 0 end from t1;
select case when c1 in (select distinct c1 from t2 where t1.c2 > t2.c2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ distinct c1 from t2 where t1.c2 > t2.c2) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2 limit 1) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2 limit 1) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2 having count(*) > 0) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2 having count(*) > 0) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2 group by c1) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2 group by c1) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2 group by c2) then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2 group by c2) then 1 else 0 end from t1;
select case when c1 not in (select c1 from t2) then 1 else 0 end from t1;
select case when c1 not in (select /*+no_unnest*/ c1 from t2) then 1 else 0 end from t1;
select case when c1 in (select c1 from t2) or c1 = 0 then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2) or c1 = 0 then 1 else 0 end from t1;
select case when c1 in (select c1 from t2) and c1 = 0 then 1 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2) and c1 = 0 then 1 else 0 end from t1;
select c1 in (select c1 from t2) and c1 = 0 from t1;
select c1 in (select /*+no_unnest*/ c1 from t2) and c1 = 0 from t1;
select case when c1 in (select c1 from t2) then 1 when c2 in (select c2 from t2) then 2 else 0 end from t1;
select case when c1 in (select /*+no_unnest*/ c1 from t2) then 1 when c2 in (select /*+no_unnest*/ c2 from t2) then 2 else 0 end from t1;

select case when c1 in (select c1 from s2) then 1 else 0 end from s1;
select /*+parallel(auto)*/ case when c1 in (select c1 from s2) then 1 else 0 end from s1;
select case when c1 in (select /*+no_unnest*/ c1 from s2) then 1 else 0 end from s1;

set OPTIMIZER_FEATURES_ENABLE = '4.2.1.0';
select case when c1 in (select c1 from s2) then 1 else 0 end from s1;
select case when c1 in (select /*+no_unnest*/ c1 from s2) then 1 else 0 end from s1;

set OPTIMIZER_FEATURES_ENABLE = default;
drop table s1,s2,t1,t2; 