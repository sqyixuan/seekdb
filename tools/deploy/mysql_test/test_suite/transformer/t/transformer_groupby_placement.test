USE OPT_WISCONSIN;

select count(*) from g_4k;
select count(*) from h_4k;
select count(*) from t1_1;
select count(*) from t1_100;
select count(*) from t2_1;
select count(*) from t2_100;
select count(*) from t_4k;
select count(*) from t_5k;
select count(*) from t_10k;
select count(*) from t_part;
select count(*) from z_4k;

## inner join tables
select min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
select /*+no_place_group_by*/ min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;

select sum(l.thousand), count(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), count(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;

select count(*) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ count(*) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten;

## outer join tables
select min(l.thousand), max(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ min(l.thousand), max(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), count(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), count(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;

select count(*) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ count(*) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten;

select min(l.thousand), max(l.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ min(l.thousand), max(l.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), count(l.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), count(l.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;

select count(*) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_rewrite*/ count(*) from t1_100 l right join t2_100 r on l.ten = r.ten group by l.ten;

select min(l.thousand), max(l.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ min(l.thousand), max(l.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), count(l.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), count(l.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l full join t2_100 r on l.ten = r.ten;

select count(*) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ count(*) from t1_100 l full join t2_100 r on l.ten = r.ten group by l.ten;

## two-sided group by
select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten, r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten, r.ten;

select count(*) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten, r.ten;
select /*+no_place_group_by*/ count(*) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten, r.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten, r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten, r.ten;

select count(*) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten, r.ten;
select /*+no_place_group_by*/ count(*) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten, r.ten;

## push down filter
select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred > 10 and r.hundred > 10 group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred > 10 and r.hundred > 10 group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred > 10 and r.hundred > 10;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred > 10 and r.hundred > 10;

select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred + r.hundred > 10 group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred + r.hundred > 10 group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten and r.hundred > 10 where l.hundred > 10 group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten and r.hundred > 10 where l.hundred > 10 group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten and l.hundred > 10 and r.hundred > 10 group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten and l.hundred > 10 and r.hundred > 10 group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten where lnnvl(r.hundred <= 10) and lnnvl(l.hundred > 10) group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten where lnnvl(r.hundred <= 10) and lnnvl(l.hundred > 10) group by l.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten where lnnvl(r.hundred <= 10) and lnnvl(l.hundred > 10);
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten where lnnvl(r.hundred <= 10) and lnnvl(l.hundred > 10);

## many tables join with unique property, paper example
select sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r3.ten;
select /*+no_place_group_by*/ sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r3.ten;

select sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10;
select /*+no_place_group_by*/ sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10;

select sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r3.ten;
select /*+no_place_group_by*/ sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r3.ten;

select sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r2.unique1, r3.unique1;
select /*+no_place_group_by*/ sum(r1.thousand) from t_4k r1, t1_100 r2, t2_100 r3 where r1.hundred = r2.unique1 and r2.unique2 = r3.unique1 and r3.hundred > 10 group by r2.unique1, r3.unique1;

select sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;
select /*+no_place_group_by*/ sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;

select sum(l.thousand) from t_4k l left join t_5k r on l.unique2 = r.ten group by l.hundred, l.ten;
select /*+no_place_group_by*/ sum(l.thousand) from t_4k l left join t_5k r on l.unique2 = r.ten group by l.hundred, l.ten;

select max(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;
select /*+no_place_group_by*/ max(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;

select sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten;
select /*+no_place_group_by*/ sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten;

## max(1), count(1)
select max(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100 group by r.ten;
select count(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100 group by r.ten;
select sum(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100 group by r.ten;

select max(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100;
select count(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100;
select sum(2) from t_4k l, t_5k r where l.hundred = r.hundred and l.thousand < 100;

## complex group, aggregation exprs
select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r, t2_100 s where l.ten = r.ten and s.hundred = l.hundred group by l.ten + r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r, t2_100 s where l.ten = r.ten and s.hundred = l.hundred group by l.ten + r.ten;

select sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten + r.ten;
select /*+no_place_group_by*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten + r.ten;

select sum(l.thousand + r.thousand) from t1_100 l, t2_100 r, t2_100 s where l.ten = r.ten and s.hundred = l.hundred group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand + r.thousand) from t1_100 l, t2_100 r, t2_100 s where l.ten = r.ten and s.hundred = l.hundred group by l.ten;

select sum(l.thousand + r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand + r.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten;

## invalid for group by push down
select sum(l.thousand) from t1_100 l group by l.ten;
select /*+no_place_group_by*/ sum(l.thousand) from t1_100 l group by l.ten;

select min(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and exists (select 1 from t1_1 where t1_1.hundred = l.hundred) group by l.ten;
select min(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and exists (select /*+no_unnest*/1 from t1_1 where t1_1.hundred = l.hundred) group by l.ten;

select min(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred >any (select unique1 from t1_1 where t1_1.hundred = l.hundred order by ten limit 3) group by l.ten;
select /*+no_unnest(@qb1)*/ min(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten and l.hundred >any (select /*+qb_name(qb1)*/unique1 from t1_1 where t1_1.hundred = l.hundred order by ten limit 3) group by l.ten;

## some corner cases
## can not do eager aggregation on t1, t2;
select max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0;
select /*+no_place_group_by*/ max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0;

## can not do eager agggregation on t2;
select max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0 group by t1.ten;
select /*+no_place_group_by*/ max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0 group by t1.ten;

select max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0 and t1.unique1 < t2.unique1 group by t1.ten;
select /*+no_place_group_by*/ max(t1.hundred), max(t2.hundred) from t1_100 t1, t2_100 t2 where t2.ten < 0 and t1.unique1 < t2.unique1 group by t1.ten;

select /*+opt_param('optimizer_group_by_placement', 'false')*/ min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
alter system set _optimizer_group_by_placement=0;
sleep 1;
select /*+opt_param('optimizer_group_by_placement', 'true')*/ min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
alter system set _optimizer_group_by_placement=1;
sleep 1;

--disable_warnings
drop table if exists tmp;
--enable_warnings
create table tmp (c1 int, c2 int);
set autocommit = 0;
## pull up tests
select t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
select /*+no_merge(@qb1)*/ t1.unique1, v.* from t1_100 t1, (select /*+qb_name(qb1)*/t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;

update t1_100 t1, (select t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
update t1_100 t1, (select /*+no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand > v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select /*+no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand > v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
insert into tmp select t1.unique1, v.aggr from t1_100 t1, (select t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ * from tmp;
rollback;

select t1.unique1, v.* from t1_100 t1, (select t2.hundred, sum(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
select /*+no_merge(@qb1)*/ t1.unique1, v.* from t1_100 t1, (select /*+qb_name(qb1)*/t2.hundred, sum(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;

update t1_100 t1, (select t2.hundred, sum(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
update t1_100 t1, (select /*+no_merge*/ t2.hundred, sum(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select t2.hundred, sum(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand < v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select /*+no_merge*/ t2.hundred, sum(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand < v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
insert into tmp select t1.unique1, v.aggr from t1_100 t1, (select t2.hundred, sum(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
select/**/ * from tmp;
rollback;

select t1.unique1, v.* from t1_100 t1, (select t2.hundred, count(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
select /*+no_merge(@qb1)*/ t1.unique1, v.* from t1_100 t1, (select /*+qb_name(qb1)*/t2.hundred, count(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;

update t1_100 t1, (select t2.hundred, count(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
update t1_100 t1, (select /*+no_merge*/ t2.hundred, count(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v set t1.thousand = v.aggr where t1.unique1 < 4 and t1.hundred = v.hundred;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select t2.hundred, count(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand < v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
delete t1 from t1_100 t1, (select /*+no_merge*/ t2.hundred, count(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred and t1.thousand < v.aggr;
select/**/ t1.unique1, t1.thousand from t1_100 t1 where t1.unique1 < 4;
rollback;
insert into tmp select t1.unique1, v.aggr from t1_100 t1, (select t2.hundred, count(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
select/**/ * from tmp;
rollback;

