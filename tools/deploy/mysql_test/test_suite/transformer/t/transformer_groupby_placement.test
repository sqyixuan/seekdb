select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred group by t1.ten having sum(v.aggr) > 100;
select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred group by t1.ten having sum(v.aggr) > 100;

select sum(t1.unique1), sum(v.hundred), v.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred group by v.aggr;
select sum(t1.unique1), sum(v.hundred), v.aggr from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred group by v.aggr;

select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred;
select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred;

select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 3 group by t1.hundred, t1.ten with rollup;
select sum(t1.unique1), sum(v.hundred), sum(v.aggr) from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 3 group by t1.hundred, t1.ten with rollup;

## test window function

select sum(v.hundred) over (partition by t1.ten), v.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 2;
select sum(v.hundred) over (partition by t1.ten), v.aggr from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 2;

select sum(v.aggr) over (partition by t1.ten), v.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 2;
select sum(v.aggr) over (partition by t1.ten), v.aggr from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.ten < 2;

## test distinct

select distinct t1.thousand, v.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.hundred < 20;
select distinct t1.thousand, v.aggr from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred and t1.hundred < 20;

## test order by, limit

select t1.thousand, v.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred order by v.aggr limit 10;
select t1.thousand, v.aggr from t1_100 t1, (select /*+ no_merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) v where t1.hundred = v.hundred order by v.aggr limit 10;

## test for update
set autocommit = 0;
select /*+use_nl(t1), leading(view1), index(t1 T2_100_TEN)*/ t1.thousand from t2_100 t1 where (t1.ten, t1.hundred) in (select /*+merge*/ t2.ten, max(t2.hundred) as aggr from t_4k t2 group by t2.ten) for update;
select /*+use_nl(t1), leading(view1), index(t1 T2_100_TEN)*/ t1.thousand from t2_100 t1 where (t1.ten, t1.hundred) in (select /*+ no_merge*/ t2.ten, max(t2.hundred) as aggr from t_4k t2 group by t2.ten) for update;
rollback;
set autocommit = 1;

## test where subquery
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred and V.aggr > (select 1 except select 2);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred and V.aggr >all (select t1.thousand except select 2);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred and V.aggr >all (select V.hundred except select 2);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred and V.hundred <any (select V.aggr except select 2);

## test group by subquery
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred group by t1.ten;
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred group by (select max(t2_100.hundred) from t2_100 where t1.ten = t2_100.ten except select 1);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred group by (select COUNT(*) from t2_100 where V.hundred = t2_100.ten);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred group by (select COUNT(*) from t2_100 where V.aggr > t2_100.thousand);

## test select subquery
select (select max(t2_100.hundred) from t2_100 where t1.ten = t2_100.ten except select 1) as filed1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred;
select (select COUNT(*) from t2_100 where V.hundred = t2_100.ten) as filed1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred;
select (select /*+no_unnest*/ COUNT(*) from t2_100 where V.aggr > t2_100.thousand) as filed1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred;

## test order by subquery
select (select max(t2_100.hundred) from t2_100 where t1.ten = t2_100.ten except select 1) as filed1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by filed1;
select (select COUNT(*) from t2_100 where V.hundred = t2_100.ten) as field1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by field1;
select (select /*+no_unnest*/ COUNT(*) from t2_100 where V.aggr > t2_100.thousand) as field1, t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by field1;

select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by (select max(t2_100.hundred) from t2_100 where t1.ten = t2_100.ten except select 1);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by (select COUNT(*) from t2_100 where V.hundred = t2_100.ten);
select t1.unique1, V.hundred, V.aggr from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand) as aggr from t_4k t2 group by t2.hundred) V where t1.hundred = v.hundred order by (select COUNT(*) from t2_100 where V.aggr > t2_100.thousand);

