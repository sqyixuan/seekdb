# collation problem
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1 (id int primary key, c_sensitive varchar(10) collate utf8_bin, c2 int, index idx_str1(c_sensitive));
create table t2 (id int primary key, c_insensitive varchar(10) collate utf8_general_ci, c2 int, index idx_str2(c_insensitive));

select count(*) from t1, t2 where c_sensitive = c_insensitive group by t1.c2;
select /*+no_place_group_by*/ count(*) from t1, t2 where c_sensitive = c_insensitive group by t1.c2;

select * from t1, (select c_insensitive, count(*) from t2 group by c_insensitive) v where t1.c_sensitive = v.c_insensitive and t1.c_sensitive = 'A' and v.c_insensitive in ('a', 'A');
select * from t1, (select /*+no_merge*/c_insensitive, count(*) from t2 group by c_insensitive) v where t1.c_sensitive = v.c_insensitive and t1.c_sensitive = 'A' and v.c_insensitive in ('a', 'A');


