SELECT /*+no_expand*/ Min(table1.`col_varchar`), table1 . col_varchar_10_key AS field3
FROM   ( c AS table1 RIGHT JOIN cc AS table2 ON ( table2 . `col_varchar_key` = table1 . `col_varchar` ) )
WHERE  (SELECT Sum(`pk`) FROM bb) IS NOT NULL OR table1 . `col_varchar_key` = 'o'
GROUP  BY field3 ;

SELECT /*+no_rewrite*/ Min(table1.`col_varchar`), table1 . col_varchar_10_key AS field3
FROM   ( c AS table1 RIGHT JOIN cc AS table2 ON ( table2 . `col_varchar_key` = table1 . `col_varchar` ) )
WHERE  (SELECT Sum(`pk`) FROM bb) IS NOT NULL OR table1 . `col_varchar_key` = 'o'
GROUP  BY field3 ;

