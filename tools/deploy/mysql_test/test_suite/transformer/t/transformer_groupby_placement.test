select count(*) from t1_100 t1, (select t2.ten, max(t2.hundred)  from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten;
select count(*) from t1_100 t1, (select /*+no_merge*/t2.ten, max(t2.hundred)  from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten;

select count(*) from t1_100 t1, (select t2.ten, max(t2.hundred)  from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten group by t1.ten;
select /*+no_place_group_by*/count(*) from t1_100 t1, (select /*+no_merge*/t2.ten, max(t2.hundred)  from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten group by t1.ten;

select sum(v.aggr) from t1_100 t1, (select t2.ten, max(t2.hundred) as aggr from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten;
select sum(v.aggr) from t1_100 t1, (select /*+no_merge*/t2.ten, max(t2.hundred) as aggr from t2_100 t2 group by t2.ten) v where t1.ten < 10 and t1.ten = v.ten;

select * from (select t1.ten, count(*)  from t1_100 t1 group by t1.ten) s, (select t2.ten, count(*)  from t2_100 t2 group by t2.ten) v where s.ten < 10 and s.ten = v.ten;
select /*+no_merge(@qb1) no_merge(@qb2)*/ * from (select /*+qb_name(qb1)*/t1.ten, count(*)  from t1_100 t1 group by t1.ten) s, (select /*+qb_name(qb2)*/t2.ten, count(*)  from t2_100 t2 group by t2.ten) v where s.ten < 10 and s.ten = v.ten;

