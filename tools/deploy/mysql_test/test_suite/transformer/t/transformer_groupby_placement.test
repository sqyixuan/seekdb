## invalid rewrite cases
select t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand) as aggr from t_4k t2) v where t1.unique1 < 4 and t1.hundred = v.hundred and aggr > 901 order by t1.unique1;
