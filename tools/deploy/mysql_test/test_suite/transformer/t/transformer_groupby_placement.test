explain select /*+place_group_by*/ min(c1), c2, sum(min(c1)) over (partition by c2) as wf from t1, t2 group by c2, c3;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

## pushdown into union
## 
--disable_warnings
drop table if exists t1,t2,t3;
drop view if exists v, v_distinct;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

insert into t1 values(1, 1);
insert into t1 values(2, NULL);
insert into t1 values(1, 2);
insert into t1 values(NULL, 2);
insert into t1 values(2, 3);
insert into t1 values(3, NULL);
insert into t1 values(4, 3);
insert into t1 values(3, 4);

insert into t2 values(1, 1);
insert into t2 values(2, 1);
insert into t2 values(NULL, 1);
insert into t2 values(1, 2);
insert into t2 values(3, 2);
insert into t2 values(2, 3);
insert into t2 values(3, NULL);
insert into t2 values(4, 3);
insert into t2 values(NULL, 4);

create view v as
(
    select * from t1
    union all
    select * from t2
);

create view v_distinct as
(
    select * from t1
    union
    select * from t2
);

select /*+no_place_group_by*/ sum(c1), count(c1), c2 from v group by c2;
select sum(c1), min(c2) from v;
explain outline select sum(c1), min(c2) from v;
select sum(c1), count(c1), c2 from v group by c2;
select min(c1), max(c1), c2 from v group by c2;
select /*+place_group_by*/ sum(c1), count(c1), c2 from v group by c2;
select /*+place_group_by*/ min(c1), max(c1), c2 from v group by c2;
select /*+place_group_by*/ min(c1), max(c1), sum(c1), count(c1), c2 from v group by c2;
select /*+place_group_by*/ avg(c1), min(c1), max(c1), sum(c1), count(c1), c2 from v group by c2;
select /*+place_group_by*/ avg(c1), min(c1), max(c1), sum(c1), count(c1), count(*), c2 from v group by c2;
select /*+place_group_by*/ sum(c1), count(c1), c2 from v_distinct group by c2;
select /*+place_group_by*/ min(c1), max(c1), c2 from v_distinct group by c2;
select /*+place_group_by*/ sum(c1), count(c1), min(c1), max(c1), c2 from v_distinct group by c2;
select /*+place_group_by*/ sum(distinct c1), c2 from v group by c2;
select /*+place_group_by*/ sum(c1) from (select * from t1 union all select * from t2 order by c2 limit 3) as v_order_limit;
select /*+place_group_by*/ sum(c1), count(*), min(c2), max(c1), avg(c2) from v;
select /*+place_group_by*/ sum(c1), c1, c2 from v group by c2;
select /*+place_group_by*/ sum(c1 + c2), count(c1 / c2) from v;
select /*+place_group_by*/ sum(c1), c2 from ( select c1 * c2 as c1, c1 + c2 as c2 from t1 union all select * from t2) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select c1, 1 as c2 from t1 union all select * from t2) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select c1 * c2 as c1, c1 + c2 as c2 from t1 union all select c1 + c2, c1 * c2 from t2) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( (select * from t1) union all (select * from t2 order by t2.c1 limit 2)) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( (select sum(c1) as c1, c2 from t1 group by c2) union all (select * from t2 order by t2.c1 limit 2)) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select * from t1 union all (select * from t2 union select * from t1)) v2 group by c2;
select /*+place_group_by*/ count(c1), c2 from ( select * from t1 union all select distinct * from t2) v2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select * from t1 union all select * from t2) v2 where c2=1 or c2=2 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select * from t1 union all select c1, (select /*+no_rewrite*/ sum(t3.c2) from t1 t3 where t3.c1=t2.c1) as c2 from t2) v3 group by c2;
select /*+place_group_by*/ sum(c1), c2 from ( select * from t1 union all select (select /*+no_rewrite*/ sum(t3.c2) from t1 t3 where t3.c1=t2.c1) as c1, c2 from t2) v3 group by c2;

