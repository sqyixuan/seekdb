##

--result_format 4
--explain_protocol 2

## bug: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(pk int primary key, c1 int, c2 int);
create table t2(c1 int, c2 int);

select sum(case when not exists(select * from t1 where t1_o.pk = c2) then 1 else 0 end) a,
       sum(case when 1 = (select count(*) from t1 where t1_o.pk = c2) then 1 else 0 end) b
from t1 t1_o, t2 group by t2.c2;

select sum(case when not exists(select * from t1 tiin1 where t1o.pk = tiin1.c2) then 1 else 0 end) a
from t1 t1o, t2, (select c2, count(*) c from t1 t1in2 group by t1in2.c2) v;

select sum(case when exists(select * from t1 tiin1 where t1o.pk = tiin1.c2) then 1 else 0 end) a
from t1 t1o, t2, (select c2, count(*) c from t1 t1in2 group by t1in2.c2) v;

select sum(case when 1 < any (select c1 from t1 tiin1 where t1o.pk = tiin1.c2) then 1 else 0 end) a
from t1 t1o, t2, (select c2, count(*) c from t1 t1in2 group by t1in2.c2) v;

select sum(case when 1 < all (select c1 from t1 tiin1 where t1o.pk = tiin1.c2) then 1 else 0 end) a
from t1 t1o, t2, (select c2, count(*) c from t1 t1in2 group by t1in2.c2) v;

select sum(case when 1 < (select c1 from t1 tiin1 where t1o.pk = tiin1.c2) then 1 else 0 end) a
from t1 t1o, t2, (select c2, count(*) c from t1 t1in2 group by t1in2.c2) v;

drop table t1;
drop table t2;