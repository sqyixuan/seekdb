# owner: sean.yyj
# owner group: SQL1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists BB;
--enable_warnings

create table BB(pk int primary key, col_int_key int, col_varchar varchar(20));

--result_format 4
--explain_protocol 2

SELECT ( SELECT 1 FROM DUAL ) AS field2, col_int_key  FROM BB  GROUP BY field2 HAVING col_int_key NOT IN ( SELECT 1 FROM DUAL );
SELECT /*+no_rewrite*/ ( SELECT 1 FROM DUAL ) AS field2, col_int_key  FROM BB  GROUP BY field2 HAVING col_int_key NOT IN ( SELECT 1 FROM DUAL );

SELECT ( SELECT 1 FROM DUAL ) AS field2, col_int_key  FROM BB  GROUP BY field2 HAVING exists ( SELECT 1 FROM DUAL );
SELECT /*+no_rewrite*/ ( SELECT 1 FROM DUAL ) AS field2, col_int_key  FROM BB  GROUP BY field2 HAVING exists ( SELECT 1 FROM DUAL );
