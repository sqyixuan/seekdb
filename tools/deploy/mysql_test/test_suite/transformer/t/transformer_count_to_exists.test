--disable_warnings
--explain_protocol 0
drop table if exists t1, t2, t3;

create table t1(c1 int, c2 int);
create table t2(c1 int primary key, c2 int);
create table t3(c1 int, c2 int) partition by hash(c1) partitions 4;

insert into t1 values(1, 2), (NULL, NULL), (3, 3);
insert into t2 values(1, 1), (2, 3), (3, 4);
insert into t3 values(1, 2), (2, 5), (2, 3);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--explain_protocol 2
--result_format 4

# count to exists
select * from t1 where (select count(*) from t2) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2) > 0;

select * from t1 where (select count(c1 + c2 + 1) from t2 where c1 > 1) > 0;
select /*+no_rewrite*/* from t1 where (select count(c1 + c2 + 1) from t2 where c1 > 1) > 0;

# not allowed to do transform
select * from t1 where (select count(*) from t2 having avg(c1) > 1) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 having avg(c1) > 1) > 0;

# not allowed to do transform
select * from t1 where (select count(*) from t2 having count(*) > 10) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 having count(*) > 10) > 0;

# not allowed to do transform
select * from t1 where (select count(c1) from t2 group by c1 limit 1) > 0;
select /*+no_rewrite*/* from t1 where (select count(c1) from t2 group by c1 limit 1) > 0;

# not allowed to do transform
select (select count(*) from t1) s1, c1 from t2 having s1 > 0;
select /*+no_rewrite*/(select count(*) from t1) s1, c1 from t2 having s1 > 0;

select count(*) from t2 where (select count(*) from t3) > 0;
select /*+no_rewrite*/count(*) from t2 where (select count(*) from t3) > 0;

# TODO: support cast
# select * from t1 where (select count(*) from t2) > 0.0;

select * from t1 where 0 < (select count(*) from t2);
select /*+no_rewrite*/* from t1 where 0 < (select count(*) from t2);

select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0;

select * from t1 where (select count(*) from t2 where t1.c1 > t2.c1) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 > t2.c1) > 0;

select * from t1 where (select count(*) from t2) > 0 and t1.c1 > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2) > 0 and t1.c1 > 0;

select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and t1.c1 > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and t1.c1 > 0;

select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;

select * from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t3.c1 = t1.c1 and t3.c1 = t2.c1) > 0;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t3.c1 = t1.c1 and t3.c1 = t2.c1) > 0;

# count to not exists
select * from t1 where (select count(*) from t2) < 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2) < 0;

select * from t1 where (select count(*) from t2) <= 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2) <= 0;

select * from t1 where 0 >= (select count(*) from t2);
select /*+no_rewrite*/* from t1 where 0 >= (select count(*) from t2);

select * from t1 where (select count(*) from t2) = 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2) = 0;

select * from t1 where (select count(c1) from t2) = 0;
select /*+no_rewrite*/* from t1 where (select count(c1) from t2) = 0;

select * from t1 where (select count(c1 + c2 + 1) from t2 where c1 > 1) = 0;
select /*+no_rewrite*/* from t1 where (select count(c1 + c2 + 1) from t2 where c1 > 1) = 0;

select * from t1 where 0 = (select count(*) from t2);
select /*+no_rewrite*/* from t1 where 0 = (select count(*) from t2);

select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0;

select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0 and (select count(*) from t3 where t1.c1 = t3.c1) > 0;
select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0 and (select count(*) from t3 where t1.c1 = t3.c1) > 0;

select * from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t1.c1 = t3.c1 and t2.c1 = t3.c1) = 0;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t1.c1 = t3.c1 and t2.c1 = t3.c1) = 0;

select * from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t1.c1 = t3.c1 or t2.c1 = t3.c1) = 0;
select /*+no_rewrite*/* from t1 left join t2 on t1.c1 = t2.c1 where (select count(*) from t3 where t1.c1 = t3.c1 or t2.c1 = t3.c1) = 0;

select * from t1, t2 where t1.c1 = t2.c1 and (select count(*) from t3 where t3.c1 = t2.c1 and t3.c1 = t1.c1) = 0;
select /*+no_rewrite*/* from t1, t2 where t1.c1 = t2.c1 and (select count(*) from t3 where t3.c1 = t2.c1 and t3.c1 = t1.c1) = 0;

# subquery count to exists
select * from t1 where (select count(*) from t2 where (select count(*) from t3) = 0) > 0;
select /*+no_rewrite*/* from t1 where (select /*+no_rewrite*/count(*) from t2 where (select count(*) from t3) = 0) > 0;

select * from t1 where (select count(*) from t2 where (select count(*) from t3) != 0) > 0;
select /*+no_rewrite*/* from t1 where (select /*+no_rewrite*/count(*) from t2 where (select count(*) from t3) != 0) > 0;

# update
