# for update
select * from t1 where (select count(*) from t1) > 0 for update;
select /*+no_rewrite*/* from t1 where (select count(*) from t1) > 0 for update;

# cte
with cte as (select * from t1 order by c1) select * from cte where (select count(*) from t2 where cte.c1 = t2.c1) > 0;
with cte as (select * from t1 order by c1) select /*+no_rewrite*/* from cte where (select count(*) from t2 where cte.c1 = t2.c1) > 0;

