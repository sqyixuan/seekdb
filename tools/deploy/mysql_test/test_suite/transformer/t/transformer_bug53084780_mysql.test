# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists km_imissive_receive_main, km_imissive_rmain_areader, sys_org_element;
--enable_warnings

CREATE TABLE `km_imissive_receive_main` (
  `fd_id` varchar(36) NOT NULL,
  `doc_status` varchar(2) DEFAULT NULL,
  `doc_create_id` varchar(36) DEFAULT NULL,
  PRIMARY KEY (`fd_id`)
);

CREATE TABLE `km_imissive_rmain_areader` (
  `fd_main_id` varchar(36) DEFAULT NULL,
  KEY `index_fd_main_id` (`fd_main_id`)
);

CREATE TABLE `sys_org_element` (
  `fd_id` varchar(36) NOT NULL,
  PRIMARY KEY (`fd_id`)
);

--explain_protocol 1
--result_format 4

SELECT
    1
FROM
    km_imissive_receive_main kmimissive0_
WHERE
    kmimissive0_.fd_id IN (
        SELECT
            kmimissive1_.fd_id
        FROM
            km_imissive_receive_main kmimissive1_
            INNER JOIN km_imissive_rmain_areader authallrea2_ ON kmimissive1_.fd_id = authallrea2_.fd_main_id
            INNER JOIN sys_org_element sysorgpers4_ ON kmimissive1_.doc_create_id = sysorgpers4_.fd_id
        WHERE
            (
                kmimissive1_.doc_status <> '10'
                OR sysorgpers4_.fd_id = '123'
            )
            AND sysorgpers4_.fd_id = '123'
    );

drop table km_imissive_receive_main, km_imissive_rmain_areader, sys_org_element;
