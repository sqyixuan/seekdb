#owner: lijinmao.ljm
#owner group: sql1
#tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS cool_bill_20180829, int_decimal_pk, t_chsm_system_log, t_hsm_dns, t_log_exception_detail; 
--enable_warnings

create table if not exists `cool_bill_20180829` (
        `bill_id` int(11) not null auto_increment,
        `trade_time` varchar(30),
        `app_id` varchar(20),
        `mch_id` varchar(30),
        `sub_mch` varchar(30),
        `device_id` varchar(50),
        `wx_order` varchar(50),
        `order_no` varchar(50),
        `openid` varchar(50),
        `trade_type` varchar(50),
        `trade_status` varchar(50),
        `bank` varchar(100),
        `cny` varchar(20),
        `total_money` varchar(20),
        `redpacket_money` varchar(20),
        `aprefund_time` varchar(30),
        `surefund_time` varchar(30),
        `wxrefund_no` varchar(50),
        `mcrefund_no` varchar(50),
        `refund_money` varchar(20),
        `redpacket_refund_money` varchar(20),
        `refund_type` varchar(20),
        `refund_status` varchar(20),
        `product_target_name` varchar(100),
        `data_packet` varchar(255),
        `fee` varchar(20),
        `rate` varchar(20),
        `business_id` varchar(100),
        `door_id` varchar(100),
        `pay_type` varchar(100),
        `pay_pass` varchar(100),
        `agent_id` varchar(100),
        `agent_fr_fee` varchar(100),
        `qd_fr_fee` varchar(100),
        `td_cost_fee` varchar(100),
        `from_business_trade_id` varchar(128),
        `bill_time` varchar(30),
        `channel_id` int(10),
        `activity_type` varchar(30),
        `pay_log_id` varchar(40),
        primary key (`bill_id`),
        CONSTRAINT `uiq_order_type_refund` unique key (`order_no`, `trade_type`, `wxrefund_no`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `agent_id_idx` on `cool_bill_20180829` (`agent_id` ASC);
create index `bill_time_idx` on `cool_bill_20180829` (`bill_time` ASC);
create index `business_id_idx` on `cool_bill_20180829` (`business_id` ASC);
create index `mch_id_idx` on `cool_bill_20180829` (`mch_id` ASC);
create index `trade_time_idx` on `cool_bill_20180829` (`trade_time` ASC);
create table if not exists `int_decimal_pk` (
        `c01` int(255) not null,
        `c02` decimal(10,0),
        `c03` decimal(10,5) not null,
        `c04` bit(64),
        `c05` tinyint(255),
        `c06` smallint(6),
        `c07` mediumint(9),
        `c08` bigint(20),
        `c09` float,
        `c10` double,
        `c11` varchar(255),
        `c12` char(255),
        `c13` tinytext,
        `c14` mediumtext,
        `c15` tinyblob,
        `c16` longtext,
        `c17` mediumblob,
        `c18` longblob,
        `c19` binary(255),
        `c20` varbinary(255),
        `c21` timestamp,
        `c22` date,
        `c23` time,
        `c24` datetime,
        `c25` year(4),
        `c26` blob,
        primary key (`c01`, `c03`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create table if not exists `t_chsm_system_log` (
        `id` int(10) unsigned zerofill not null auto_increment,
        `type` varchar(10),
        `version` varchar(50),
        `logGenTime` timestamp,
        `logGenmillisecond` varchar(20),
        `uuid` varchar(50) default '',
        `deviceIp` varchar(20),
        `pName` varchar(200),
        `pId` varchar(50),
        `level` varchar(20),
        `message` varchar(1000),
        `digest` varchar(50),
        `generateCount` int(20) comment 'RSM ID',
        `vsmIdF` int(20),
        `chsmIdF` int(20),
        `hsmClusterIdF` int(20),
        `staticticsCount` int(20) not null default '0',
        `createdOn` timestamp not null default '0000-00-00 00:00:00' on update current_timestamp,
        primary key (`id`),
        CONSTRAINT `digest` unique key (`digest`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `chsmIdF` on `t_chsm_system_log` (`chsmIdF` ASC);
create index `hsmClusterIdF` on `t_chsm_system_log` (`hsmClusterIdF` ASC);
create index `vsmIdF` on `t_chsm_system_log` (`vsmIdF` ASC);
create table if not exists `t_hsm_dns` (
        `dnsID` int(20) not null auto_increment comment '宿主机DNS ID',
        `dnsName` char(100) comment 'DNS名称',
        primary key (`dnsID`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
comment='宿主机DNS';
create table if not exists `t_log_exception_detail` (
        `detail_ID` int(11) not null auto_increment,
        `exceptDetail` text comment '异常详情',
        primary key (`detail_ID`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

update test.t_chsm_system_log set type = (select dnsName from test.t_hsm_dns limit 1 offset 2) , logGenmillisecond = (select group_concat(exceptDetail) from test.t_log_exception_detail) , uuid = test.t_chsm_system_log.logGenmillisecond, message = test.t_chsm_system_log.version, digest = test.t_chsm_system_log.uuid, generateCount = test.t_chsm_system_log.staticticsCount, vsmIdF = test.t_chsm_system_log.id, chsmIdF = instr( cast((select trade_time from test.cool_bill_20180829 limit 1 offset 6) as CHAR), cast(test.t_chsm_system_log.type as CHAR)), staticticsCount = test.t_chsm_system_log.hsmClusterIdF, createdOn = test.t_chsm_system_log.logGenTime where (test.t_chsm_system_log.pName is NULL) or ((EXISTS ( select rtrim( cast(test.t_chsm_system_log.digest as CHAR)) as c0 from test.t_hsm_dns as ref_0 where test.t_chsm_system_log.hsmClusterIdF & test.t_chsm_system_log.id)) and (EXISTS ( select test.t_chsm_system_log.logGenmillisecond as c0 from test.int_decimal_pk as ref_1 where ((((ref_1.c07 + test.t_chsm_system_log.generateCount) and (91 is NULL)) and (ref_1.c01 AND test.t_chsm_system_log.id)) and (((test.t_chsm_system_log.generateCount + ref_1.c08) and (test.t_chsm_system_log.level is NULL)) or (ref_1.c12 is not NULL))) and (test.t_chsm_system_log.logGenTime is NULL))));