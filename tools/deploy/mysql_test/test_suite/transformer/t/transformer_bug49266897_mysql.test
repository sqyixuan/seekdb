--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int);
create index i1 on t1(a);
create index i2 on t1(b);
insert into t1 values (1,1);
insert into t1 values (1,2);
insert into t1 values (2,1);
insert into t1 values (3,3);
insert into t1 values (4,4);
insert into t1 values (5,1);

--result_format 4
--explain_protocol 2

select /*+use_concat*/ * from t1 where a=1 or b=1;
select /*+use_concat*/ * from t1 where a=1 or b=1 for update;
explain with tmp as (select /*+use_concat*/ * from t1 where a=1 or b=1) select * from tmp;
with tmp as (select /*+use_concat*/ * from t1 where a=1 or b=1) select * from tmp;
explain with tmp as (select /*+use_concat*/ * from t1 where a=1 or b=1 for update) select * from tmp;
with tmp as (select /*+use_concat*/ * from t1 where a=1 or b=1 for update) select * from tmp;

