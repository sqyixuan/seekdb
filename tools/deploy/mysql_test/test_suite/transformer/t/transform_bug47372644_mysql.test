#owner: dingjincheng.djc 
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists `pindexesdg0n`;
drop table if exists `wechat_info`;
drop table if exists `t2koj1cl`;
drop table if exists `t_mon_load`;
drop table if exists `t1flic85`;
--enable_warnings
create table if not exists `pindexesdg0n` (
	`c1` int(11),
	`c2` int(11),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (c1)
(
	PARTITION `p0`,
	PARTITION `p1`,
	PARTITION `p2`,
	PARTITION `p3`
);
create index `iemgaod` on `pindexesdg0n` (`c2` ASC) ;

CREATE TABLE `wechat_info` (
  `wechat_info_id` int(11) NOT NULL AUTO_INCREMENT ,
  `wechat_access_token` varchar(32) NOT NULL ,
  `wechat_expire_time` varchar(16) NOT NULL ,
  `wechat_app_id` varchar(32) NOT NULL ,
  PRIMARY KEY (`wechat_info_id`),
  UNIQUE KEY `wechat_app_id` (`wechat_app_id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8mb4;


create table if not exists `t2koj1cl` (
	`a` int(11),
	`b` int(11),
	`c` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_mon_load` (
  `loadID` int(11) NOT NULL AUTO_INCREMENT COMMENT '负载ID',
  `monitorID` int(11) DEFAULT NULL COMMENT '监控ID',
  `load1` double(20,0) DEFAULT NULL COMMENT '1分钟的平均系统负载',
  `load5` double(20,0) DEFAULT NULL COMMENT '5分钟的平均系统负载',
  `load15` double(20,0) DEFAULT NULL COMMENT '15分钟的平均系统负载',
  PRIMARY KEY (`loadID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

create table if not exists `t1flic85` (
	`pk` int(11) not null,
	`v1` varchar(10),
	`v2` varchar(10),
	primary key (`pk`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `idx_t1isjw4o` on `t1flic85` (`v2` ASC) GLOBAL;

--explain_protocol 1
--result_format 4

select 
  EXISTS (
    select 
      subq_0.c as c0
    from 
      test.pindexesdg0n as ref_3 
    where 
      (
        EXISTS (
          select 
            subq_0.c as c1 
          from 
            test.wechat_info as ref_4 
          where 
            ref_3.c1 > ref_3.c1
        )
      ) 
      or (ref_3.c1 < ref_3.c1)
  ) as c0 
from 
  test.t2koj1cl as subq_0;

select case when EXISTS ( select subq_0.c0 as c0, subq_0.c0 as c1, subq_0.c0 as c2, ref_3.c3 as c3 from test.pindexesdg0n as ref_3 where (EXISTS ( select ref_3.c3 as c0, subq_0.c0 as c1, ref_3.c3 as c2 from test.wechat_info as ref_4 where ref_3.c1 > ref_3.c1)) or (ref_3.c1 < ref_3.c1)) then subq_0.c0 else case when subq_0.c0 <= subq_0.c0 then subq_0.c0 else subq_0.c0 end end as c0, subq_0.c0 as c1, case when subq_0.c0 / case when subq_0.c0 * subq_0.c0 then subq_0.c0 else 59 end then subq_0.c0 else subq_0.c0 end as c2, subq_0.c0 as c3, subq_0.c0 as c4, subq_0.c0 as c5, subq_0.c0 as c6 from (select ref_0.c as c0 from ((test.t2koj1cl as ref_0 left join test.t_mon_load as ref_1 on ((((ref_1.loadID > ref_1.monitorID) or (0)) and (ref_1.monitorID / ref_1.loadID)) and (1))) left join test.t1flic85 as ref_2 on (0)) where ref_0.a AND ref_1.loadID limit 63) as subq_0 where 1 ;

drop table if exists `pindexesdg0n`;
drop table if exists `wechat_info`;
drop table if exists `t2koj1cl`;
drop table if exists `t_mon_load`;
drop table if exists `t1flic85`;

