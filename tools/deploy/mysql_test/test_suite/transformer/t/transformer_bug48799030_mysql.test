--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int);

--result_format 4
--explain_protocol 2

select * from (select * from (select sum(a) as c0 from t1)) a left join (select sum((select a from t1)) as c1 from t1) b on c0 = c1 where c1 = 1; 
select * from (select * from (select sum((select a*2 from t1)) as c0 from t1)) a left join (select sum((select a from t1)) as c1 from t1) b on c0 = c1 where c1 = 1; 

drop table t1;