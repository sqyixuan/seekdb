select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_query_log
--enable_result_log

select * from T1 where exists (select 1 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where exists (select /*+no_rewrite*/1 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where exists (select 1 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1 limit 2));
select /*+no_rewrite*/* from T1 where exists (select /*+no_rewrite*/1 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1 limit 2));

select * from T1 where exists (select 1 from T2 where T2.c2 in (select T3.c2 from T3 where T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where exists (select /*+no_rewrite*/t2.c2 from T2 where T2.c2 in (select T3.c2 from T3 where T1.c1 = T3.c1));

select * from T1 where exists (select 1 from T2 where T2.c2 in (select T3.c2 from T3 where T1.c1 = T3.c1) limit 2);
select /*+no_rewrite*/* from T1 where exists (select /*+no_rewrite*/t2.c2 from T2 where T2.c2 in (select T3.c2 from T3 where T1.c1 = T3.c1) limit 2);

select * from T1 where t1.c1 in (select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where t1.c1 in (select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where t1.c1 in (select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) group by t2.c2);
select /*+no_rewrite*/* from T1 where t1.c1 in (select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) group by t2.c2);

select * from T1 where t1.c1 not in (select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where t1.c1 not in (select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where t1.c1 not in (select sum(t2.c2) from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where t1.c1 not in(select /*+no_rewrite*/sum(t2.c2) from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where t1.c1 >= any(select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where t1.c1 >=any(select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where t1.c1 >= some(select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) limit 2);
select /*+no_rewrite*/* from T1 where t1.c1 >= some(select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) limit 2);

select * from T1 where t1.c1 >= all (select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));
select /*+no_rewrite*/* from T1 where t1.c1 >= all (select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1));

select * from T1 where t1.c1 != all (select t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) group by c2);
select /*+no_rewrite*/* from T1 where t1.c1 != all (select /*+no_rewrite*/t2.c2 from T2 where exists (select 1 from T3 where t2.c2 = t3.c2 and T1.c1 = T3.c1) group by c2);

select * from t1, t3 where exists(select 1 from t2 where t1.c1 = t2.c1 and t3.c2 = t2.c2);
select /*+no_semi_to_inner*/* from t1, t3 where exists(select 1 from t2 where t1.c1 = t2.c1 and t3.c2 = t2.c2);

select * from t1, t3 where exists(select 1 from t2 where t1.c1 + t3.c2 = t2.c2);

select * from t1 where exists(select 1 from t2 where t1.c1 = t2.c2 and t1.c2 = t2.c2);

