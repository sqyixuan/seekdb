#单个semi（可转不可转）、多个semi（部分可转）、混合anti

#semi condition（有无右表filter、简单等值、简单非等值、复杂等值、复杂非等值、混合等值非等值、混合简单非简单、左右表混合谓词）

#唯一约束、group by、limit 1

#是否需要加distinct、单向cast

#overlap左右表的index

--echo 单个semi info
--echo 没有右表filter、简单等值
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1);

select * from t1 where exists(select 1 from t2 where t1.c1+t2.c1 = 1);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1+t2.c1 = 1);

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c2);

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c3);

select * from t1 where exists(select 1 from t2 where t1.c3=t2.c1);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c3=t2.c1);

select * from t1 where c3 in (select c3 from t2 limit 1);
select /*+no_rewrite*/* from t1 where c3 in (select c3 from t2 limit 1);

select * from t1 where c3 in (select c3 from t2);
select /*+no_rewrite*/* from t1 where c3 in (select c3 from t2);

--echo 有右表filter、复杂谓词，需要保证等值谓词的唯一性
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and c1 > 0 and t1.c2 >= t2.c2);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and c1 > 0 and t1.c2 >= t2.c2);

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2 and c1 > 0 and t1.c3 >= t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c2 and c1 > 0 and t1.c3 >= t2.c3);

select * from t1 where c1 in (select c2 from t2 where c1 > 0 limit 1);
select /*+no_rewrite*/* from t1 where c1 in (select c2 from t2 where c1 > 0 limit 1);

--echo 复杂等值谓词
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2+t2.c1);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c2+t2.c1);

select * from t1 where exists(select 1 from t2 where t1.c1 + t1.c3 = t2.c2 + t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1  + t1.c3 = t2.c2 + t2.c3);

select * from t1 where exists(select 1 from t2 where t1.c1 + t1.c3 = case when c1 > 0 then 1 else 1 end);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1 + t1.c3 = case when c1 > 0 then 1 else 1 end);

--echo 混合anti
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1) and not exists (select 1 from t2 where t1.c2 < t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1) and not exists (select 1 from t2 where t1.c2 < t2.c3);

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and not exists (select 1 from t2 where t1.c2 < t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c2) and not exists (select 1 from t2 where t1.c2 < t2.c3);

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c3) and not exists (select 1 from t2 where t1.c2 < t2.c3);
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c3) and not exists (select 1 from t2 where t1.c2 < t2.c3);

--echo 多个semi join
select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c3=t3.c3));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c3=t3.c3));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c3 and exists(select 1 from t3 where t2.c1=t3.c1));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c3 and exists(select 1 from t3 where t2.c1=t3.c1));

select * from t1 where exists(select 1 from t2 where t1.c1<=t2.c3 and exists(select 1 from t3 where t2.c1=t3.c1));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1<=t2.c3 and exists(select 1 from t3 where t2.c1=t3.c1));

select * from t1 where exists(select 1 from t2 where t1.c1<=t2.c3 and exists(select 1 from t3 where t1.c1=t3.c1));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1<=t2.c3 and exists(select 1 from t3 where t1.c1=t3.c1));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c3 and exists(select 1 from t4 where t3.c1 = t4.c3)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c3 and exists(select 1 from t4 where t3.c1 = t4.c3)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1<=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1<=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 <= t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1) and not exists(select 1 from t4 where t3.c1 > t4.c1)));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and exists(select 1 from t3 where t2.c1=t3.c1 and exists(select 1 from t4 where t3.c1 = t4.c1) and not exists(select 1 from t4 where t3.c1 > t4.c1)));

select * from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and c2 <= (select count(*) from t3));
select /*+no_rewrite*/* from t1 where exists(select 1 from t2 where t1.c1=t2.c1 and c2 <= (select count(*) from t3));

SELECT * 
FROM   t5 d 
WHERE  EXISTS(SELECT a.level_no 
              FROM   t6 a, 
                     t6 b, 
                     t5 c 
              WHERE  a.task_id = 105 
                     AND a.task_flow_id = b.task_flow_id 
                     AND a.level_no <= b.level_no 
                     AND b.task_id = c.task_id 
                     AND b.task_seq = c.task_seq 
                     AND c.task_id = d.task_id 
                     AND c.task_seq = d.task_seq) 
LIMIT  1; 

set autocommit=1;
--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6;
--enable_warnings

--disable_warnings
drop table if exists PSI_FLOW_STOCKBILL_ENTITY, PSI_FLOW_APPLY, PSI_FLOW_STOCKOUT;
--enable_warnings

CREATE TABLE PSI_FLOW_STOCKBILL_ENTITY
(
REGION NUMBER(5,0) NOT NULL ,
RES_TYPE_ID VARCHAR(32) NOT NULL ,
INV_ID VARCHAR(32) NOT NULL ,
OUT_BILL_ID VARCHAR(32) NOT NULL ,
OUT_BATCH_ID VARCHAR(32) NOT NULL ,
IN_BILL_ID VARCHAR(32),
IN_BATCH_ID VARCHAR(32),
CREATE_DATE DATE,
STATUS VARCHAR(32),
STATUS_DATE DATE,
REASON VARCHAR(256),
CHECK_FLAG VARCHAR(32),
FILE_NAME VARCHAR(256),
UNIFIED_FILE_NAME VARCHAR(64),
COLOR VARCHAR(32),
BOX_SEQNO NUMBER(8,0),
STOCK_NUM NUMBER(10,0) DEFAULT 1,
END_INV_ID VARCHAR(32),
ERROR_CODE VARCHAR(32)
);

CREATE INDEX IDX_STOCKENTITY_OUTBATCHID ON PSI_FLOW_STOCKBILL_ENTITY(REGION, OUT_BILL_ID);

CREATE TABLE PSI_FLOW_APPLY
(
REGION NUMBER(5,0) NOT NULL ,
FLOW_ID VARCHAR(32) NOT NULL ,
FLOW_STATUS VARCHAR(32),
RES_KIND_ID VARCHAR(32) NOT NULL ,
ORG_LEVEL VARCHAR(32),
ORG_ID VARCHAR(32) NOT NULL ,
APPLY_CYCLE NUMBER(8,0),
CYCLE_TYPE VARCHAR(32),
APPLY_TYPE VARCHAR(32),
APPLY_CLASS VARCHAR(32),
CHANNEL_TYPE VARCHAR(32) NOT NULL ,
PROJECT_ID VARCHAR(64),
IF_BASE VARCHAR(32),
PARENT_FLOW_ID VARCHAR(32),
LINK_MAN VARCHAR(64),
CONTACT_PHONE VARCHAR(32),
RECEIVE_DATE DATE,
RECEIVE_LAST_DATE DATE,
CREATE_DATE DATE,
CREATE_OPER VARCHAR(32),
CREATE_ORG_ID VARCHAR(32),
DES_ORG_ID VARCHAR(32),
MEMO VARCHAR(512),
LOCK_STATUS VARCHAR(32) NOT NULL ,
STATUS_DATE DATE NOT NULL ,
DES_REGION NUMBER(5,0),
DES_STORE_ID VARCHAR(32),
SRC_STORE_ID VARCHAR(32),
SRC_ORG_ID VARCHAR(32),
SUM_PRICE VARCHAR(32),
PAY_TYPE VARCHAR(32),
PAY_OID VARCHAR(64),
SUM_APPLY_NUM NUMBER(9,0),
PAY_PRICE VARCHAR(32),
ADDRESS VARCHAR(256),
ORDER_PRIV_ID VARCHAR(32),
ORDER_PRIV_DESC VARCHAR(128),
ORDER_PRIV_DISC NUMBER(10,0),
PAY_STATUS VARCHAR(32),
UNLOCKED_EXPDATE DATE,
OTHER_COUPONS NUMBER(10,0),
ALREADY_PAY_PRICE NUMBER(12,0),
PAYPLAT_TYPE VARCHAR(32),
COUNTY_ID VARCHAR(32) DEFAULT NULL,
SUPPLIER_ID VARCHAR(32),
SETTLE_MODE VARCHAR(32),
CLOSE_FLAG VARCHAR(32),
ADD_STATUS VARCHAR(32) DEFAULT NULL,
COMMENT_TIMES NUMBER(2,0) DEFAULT 0,
OUT_ORDER_ID VARCHAR(32)
);

CREATE INDEX IDX_FLOWAPPLY_CREATEDATE ON PSI_FLOW_APPLY(CREATE_DATE);

CREATE TABLE PSI_FLOW_STOCKOUT
(
REGION NUMBER(5,0) NOT NULL ,
STOCK_BILL_ID VARCHAR(32) NOT NULL ,
RES_KIND_ID VARCHAR(32) NOT NULL ,
RELA_ID VARCHAR(512),
RELA_ID_TYPE VARCHAR(32),
STOCK_BILL_TYPE VARCHAR(32) NOT NULL ,
DETAIL_FLAG VARCHAR(32),
STATUS VARCHAR(32) NOT NULL ,
STATUS_DATE DATE NOT NULL ,
SRC_ORG_ID VARCHAR(32) NOT NULL ,
DES_ORG_ID VARCHAR(32),
SUPPLIER_ID VARCHAR(32),
CREATE_DATE DATE,
END_DATE DATE,
OPER_ID VARCHAR(32),
MEMO VARCHAR(256),
LOCK_STATUS VARCHAR(32),
LINK_MAN VARCHAR(64),
LINK_PHONE VARCHAR(32),
LINK_SEC_MAN VARCHAR(32),
LINK_SEC_PHONE VARCHAR(32),
RECEIVE_ADDR VARCHAR(256),
LDSTORE_TYPE VARCHAR(32),
SETTLE_MODE VARCHAR(32),
PROJECT_ID VARCHAR(32),
CHANNEL_TYPE VARCHAR(32),
TRANSPORT_ID VARCHAR(32),
PURPOSE VARCHAR(32),
TRANSPORT_NAME VARCHAR(64),
DES_REGION NUMBER(5,0),
FILE_NAME VARCHAR(256),
UNIFIED_FILE_NAME VARCHAR(64),
LOGISTICS_SUPPLIER VARCHAR(32),
LOGISTICS_TYPE VARCHAR(32),
EMERGENCY_LEVEL NUMBER(8,0),
CREATE_ORG_ID VARCHAR(32),
SRC_OPER VARCHAR(32),
SRC_DELIVERY_TIME DATE,
DELIVERY_OPER VARCHAR(32),
DELIVERY_OPER_PHONE VARCHAR(20),
DELIVERY_VEHICLE_INFO VARCHAR(32),
LOGISTICS_CONFIRM_TIME DATE,
LOGISTICS_CONFIRM_MEM VARCHAR(255),
SRC_STORE_ID VARCHAR(32),
DES_STORE_ID VARCHAR(32),
BUSI_ID VARCHAR(32),
RELA_APPLY_TYPE VARCHAR(32),
RECV_METHOD VARCHAR(32),
OUT_STOCK_ID VARCHAR(32),
IF_EXTEND_RECVDATE VARCHAR(32)
);

CREATE INDEX IDX_PSIFLOWSTOCKOUT_RELAID ON PSI_FLOW_STOCKOUT(RELA_ID);

SELECT t.flow_id     flow_id, 
       t.region      region, 
       t.supplier_id supplier_id, 
       e.res_type_id res_type_id, 
       e.inv_id      inv_id, 
       e.status      inv_status, 
       t.flow_status flow_status 
FROM   psi_flow_stockbill_entity e, 
       psi_flow_apply t 
WHERE  e.region = 999 
       AND e.out_bill_id IN (SELECT f.stock_bill_id 
                             FROM   psi_flow_stockout f 
                             WHERE  f.rela_id = t.flow_id 
                                    AND f.region = 999) 
       AND t.create_date >= ('2020-11-01 00:00:00') 
       AND t.create_date <= ('2020-11-17 23:59:59') 
       AND t.src_org_id = 'SD.LU.01.01' 
       AND t.apply_type IN ( 'CATA_MOBAPPLY_AGENTSELL', 'MOBTEL_APPLY_CTRM', 
                             'CATA_MOBALLPY_AGENTPRESELL', 
                                                 'CATA_MOBALLPY_SELFSELL', 
                             'CATA_MOBAPPLY_PUBLIC_SELL_FAN', 
                                 'CATA_MOBAPPLYFORRETURN_RTTERM', 
                                                 'CATA_MOBAPPLY_PUBLIC_SELL_A2S' 
                             , 
                                                 'CATA_MOBAPPLY_PUBLIC_SELL', 
                             'CATA_MOBAPPLY_PUBLIC_SELL_NEW', 
                                 'CATA_MOBAPPLY_PUBLIC_SELL_SEC', 
                                                 'CATA_MOBAPPLY_GROUP_SELL_A2S', 
                                 'CATA_MOBAPPLY_GROUP_SELL' 
                                                 , 
                             'CATA_MOBAPPLY_SELFSELL_A2S', 
                             'CATA_MOBAPPLY_ECHANNEL_SELL' );

--disable_warnings
drop table if exists PSI_FLOW_STOCKBILL_ENTITY, PSI_FLOW_APPLY, PSI_FLOW_STOCKOUT;
--enable_warnings


##test semi join to inner join in nested subquery

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);

