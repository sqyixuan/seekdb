--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#tags: optimizer

##
## Test Name: group_by_eliminate
##
## Scope: Test eliminate group by when group exprs is unique and eliminate duplicated group exprs 
##
## Date: 2019-09-09
##


--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

## create tables
create table t1(c1 int primary key, c2 int);
create table t2(c1 int unique key not null,
                c2 int,
                c3 varchar(10));
CREATE TABLE t3 (c1 int, c2 decimal(4,2));

--disable_query_log
## generate data
insert into t1 values(1, 1);
insert into t1 values(2, 1);
insert into t1 values(3, NULL);
insert into t1 values(4, 3);
insert into t1 values(5, NULL);

insert into t2 values(0, 1, 'alibaba');
insert into t2 values(1, 2, 'mayijinfu');
insert into t2 values(2, 3, '123');
insert into t2 values(3, 4, NULL);
insert into t2 values(4, 5, '12312-123');
insert into t2 values(5, 2, '2019/08/07');
insert into t2 values(6, 3, NULL);
insert into t3 values (1, 90), (2, 9), (1, 80);
--result_format 4
--explain_protocol 2
--enable_query_log
##basic test
select max(c2) from t1 group by c1;
select max(distinct c2) from t1 group by c1;
select max(1) from t1 group by c1,c2;

select min(c2) from t1 group by c1;
select min(1) from t1 group by c1,c2;

select sum(c2) from t1 group by c1;
select sum(distinct c2) from t1 group by c1;
select sum(1) from t1 group by c1,c2;

select avg(c2) from t1 group by c1;
select avg(distinct c2) from t1 group by c1;
select avg(1) from t1 group by c1,c2;
 
select count(*) from t1 group by c1;
select count(distinct c2) from t1 group by c1;
select count(c2) from t1 group by c1;
select count(1) from t1 group by c1,c2;

select group_concat(c2) from t1 group by c1;
select group_concat(distinct c2) from t1 group by c1;
select group_concat(1) from t1 group by c1,c2;
select group_concat(distinct c2 order by c2 desc) from t2 group by c1;

##test different types
select max('abcdef') from t2 group by c1;
select max('123.123') from t2 group by c1;
select max(c3) from t2 group by c1;
select max(c2) from t2 group by c1,c2;

select min('abcdef') from t2 group by c1;
select min('123.123') from t2 group by c1;
select min(c3) from t2 group by c1;
select min(c2) from t2 group by c1,c2;

--disable_warnings
select sum('abcdef') from t2 group by c1;
select sum('123.123') from t2 group by c1;
select sum(c3) from t2 group by c1;
select sum(c2) from t2 group by c1,c2;

select avg('abcdef') from t2 group by c1;
select avg('123.123') from t2 group by c1;
select avg(c3) from t2 group by c1;
select avg(c2) from t2 group by c1,c2;
--enable_warnings

select count('abcdef') from t2 group by c1;
select count('123.123') from t2 group by c1;
select count(c3) from t2 group by c1;
select count(c2) from t2 group by c1,c2;

select group_concat('abcdef') from t2 group by c1;
select group_concat('123.123') from t2 group by c1;
select group_concat(c3) from t2 group by c1;
select group_concat(c2) from t2 group by c1,c2;

##test different math computation in aggr
--disable_warnings
select max(1 + c2) from t2 group by c1;
select max(c2 - 'abc') from t2 group by c1;
select max(c1 * c2) from t2 group by c1,c2;

select min(1 * c2) from t2 group by c1;
select min(c2 + 'abc') from t2 group by c1;
select min(c1 / c2) from t2 group by c1,c2;

select sum(1 - c2) from t2 group by c1;
select sum(c2 * 'abc') from t2 group by c1;
select sum(c1 + c2) from t2 group by c1,c2;

select avg(1 * c2) from t2 group by c1;
select avg(c2 - 'abc') from t2 group by c1;
select avg(c1 + c2) from t2 group by c1,c2;

select count(1 + c2) from t2 group by c1;
select count(c2 * 'abc') from t2 group by c1;
select count(c1 - c2) from t2 group by c1,c2;

select group_concat(1 + c2) from t2 group by c1;
select group_concat(c2 * 'abc') from t2 group by c1;
select group_concat(c1 - c2) from t2 group by c1,c2;
--enable_warnings


##test different aggr math computation
select 1 + max(c2) from t1 group by c1;
select 2 - min(c2) from t1 group by c1;
select 3 + sum(c2) from t1 group by c1;
select 4 - avg(c2) from t1 group by c1;
select 5 + count(c2) from t1 group by c1,c2;


select max(c1) + min(c2) from t1 group by c1;
select sum(c1) + avg(c2) from t1 group by c1;
select max(c1) + sum(c2) from t1 group by c1;
select max(c1) + count(c2) from t1 group by c1;
select sum(c1) + count(c2) from t1 group by c1,c2;

select 1 - (max(c1) + min(c2)) from t1 group by c1;
select 2 * (sum(c1) + avg(c2)) from t1 group by c1;
select 3 + max(c1) + sum(c2) from t1 group by c1;
select 4 / (max(c1) + count(c2)) from t1 group by c1;
select 5 - (sum(c1) + count(c2)) from t1 group by c1,c2;

##test can not eliminate group by
select max(c1) from t1 group by c2;
select min(c1) from t1 group by c2;
select sum(c1) from t1 group by c2;
select avg(c1) from t2 group by c2,c3;
select count(c1) from t2 group by c2,c3;

select max(c1) from t1 group by c1,c2 with rollup;
select min(c1) from t1 group by c1,c2 with rollup;
select sum(c1) from t1 group by c1,c2 with rollup;
select avg(c1) from t1 group by c1,c2 with rollup;
select count(c1) from t1 group by c1,c2 with rollup;

##test eliminate duplicated group exprs in group by  vs  can not eliminate duplicated group exprs in group by
select c2 from t1 group by c2,c2,c2;
select c2 from t1 group by c2,c2,c2 with rollup; 

select c2,c3 from t2 group by c3,c2,c2;
select c2,c3 from t2 group by c3,c2,c2 with rollup;

select c2,c3 from t2 group by c3,c3,c2;
select c2,c3 from t2 group by c3,c3,c2 with rollup; 

select c2,c3 from t2 group by c2,c3,c2,c3;
select c2,c3 from t2 group by c2,c3,c2,c3 with rollup; 

select c2,c3 from t2 group by c2,c3,c3,c2;
select c2,c3 from t2 group by c2,c3,c3,c2 with rollup; 

##test group by ... having ...
select c1 from t1 group by c1 having c1 > 2;
select sum(c1) from t1 group by c1 having c1 > 2;
select max(c1) from t1 group by c1 having max(c1) > 2;
select count(c1)from t1 group by c1 having c1 > 2;
select min(c1) from t1 group by c1 having c1 > 2;
select avg(c1) from t1 group by c1 having avg(c1) > 2;
select group_concat(c1) from t1 group by c1 having c1 > 2;
select max(c1), min(c1), sum(c2), count(c2), avg(c1), group_concat(c1) from t1 group by c1 having sum(c1) > 2;

##test in subquery
select * from t2 where c1 in (select max(c1) from t1 group by c1 having c1 > 2);
select * from t2 where exists (select sum(c1), count(c2) from t1 group by c1 having sum(c1) > 2);
select * from (select sum(c1) from t2 group by c1), t1;
select * from (select max(c2) from t2 group by c1), t1;
select * from (select count(c1) from t2 group by c1), t1;

##test group by ... having ... order by ...
select c1 from t1 group by c1 having c1 > 2 order by c1;
select sum(c1) from t1 group by c1 having sum(c1) > 2 order by sum(c1);
select max(c1) from t1 group by c1 having c1 > 2 order by max(c1) desc;
select count(c1) from t1 group by c1 having count(c1) > 2 order by count(c1) asc;
select min(c1) from t1 group by c1 having c1 > 2 order by min(c1);
select avg(c1) from t1 group by c1 having avg(c1) > 2 order by avg(c1);
select group_concat(c1) from t1 group by c1 having c1 > 2 order by group_concat(c1);

## bug: 
select sum(aggr) from (select c1, sum(c2) as aggr from t3 group by c1) group by c1;
select avg(aggr) from (select c1, sum(c2) as aggr from t3 group by c1) group by c1;

## bug: the expr sum(c2) is directly referred by the insert stmt
## after the select expr is rewritten, the insert stmt gets an invalid pointer
## link: 
insert into t3 select c1, sum(c2) as aggr from t1 group by c1;

drop table t1, t2, t3;
