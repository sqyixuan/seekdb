# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# desc: do not merge view for rollup stmt

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

CREATE TABLE t1(c1 int);
INSERT INTO t1 VALUES(100),(200),(300);

--result_format 4
--explain_protocol 2

SELECT s1, s2 FROM (SELECT c1 AS s1, c1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;
SELECT /*+no_rewrite*/ s1, s2 FROM (SELECT c1 AS s1, c1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;

SELECT s1, s2 FROM (SELECT c1 AS s1, c1-1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;
SELECT /*+no_rewrite*/ s1, s2 FROM (SELECT c1 AS s1, c1-1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;

SELECT s1, s2 FROM (SELECT c1 AS s1, c1+c1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;
SELECT /*+no_rewrite*/ s1, s2 FROM (SELECT c1 AS s1, c1+c1 AS s2 FROM t1) GROUP BY s1 WITH ROLLUP;

DROP TABLE t1;