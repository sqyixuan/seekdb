# owner: linyi.cl
# owner group: sql3
# tags: optimizer
# 

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1, c2);
create table t2(c3 int);

--disable_query_log
--let $count = 0
while($count < 10)
{
  --let $stmt=insert into t1(c1, c2, c3) values (1, $count, $count)
  eval $stmt;
  inc $count;
}

--let $count = 0
while($count < 10)
{
  --let $stmt=insert into t1(c1, c2, c3) values ($count, 1, $count)
  eval $stmt;
  inc $count;
}

--let $count = 0
while($count < 10)
{
  --let $stmt=insert into t1(c1, c2, c3) values ($count, $count, 1)
  eval $stmt;
  inc $count;
}

--let $count = 0
while($count < 9960)
{
  --let $stmt=insert into t1(c1, c2, c3) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log

call dbms_stats.gather_table_stats('test', 't1');

--echo #之前因为or param count > 10不改写,现在因为or expr classify count <= 10会改写
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4;
explain select * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4;

--echo #之前因为or param count > 10不改写,现在因为or expr classify count <= 10且不是valid topk所以会改写
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4 order by c2 limit 1;
explain select * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4 order by c2 limit 1;

--echo #会改写,不是valid topk,做or expr classify
explain select /*+use_concat*/ * from t1 where (c3 = 1 and c1 = 1) or (c3 = 1 and c1 = 2)
or (c3 = 1 and c1 = 3) or (c3 = 2 and c2 = 1) or (c3 = 2 and c2 = 2) or (c3 = 2 and c2 = 3)
order by c2 limit 1;
explain select * from t1 where (c3 = 1 and c1 = 1) or (c3 = 1 and c1 = 2)
or (c3 = 1 and c1 = 3) or (c3 = 2 and c2 = 1) or (c3 = 2 and c2 = 2) or (c3 = 2 and c2 = 3)
order by c2 limit 1;

create index i4 on t1(c3, c2);

--echo #会改写,且是valid topk,不做or expr classify
explain select /*+use_concat*/ * from t1 where (c3 = 1 and c1 = 1) or (c3 = 1 and c1 = 2)
or (c3 = 1 and c1 = 3) or (c3 = 2 and c2 = 1) or (c3 = 2 and c2 = 2) or (c3 = 2 and c2 = 3)
order by c2 limit 1;
explain select * from t1 where (c3 = 1 and c1 = 1) or (c3 = 1 and c1 = 2)
or (c3 = 1 and c1 = 3) or (c3 = 2 and c2 = 1) or (c3 = 2 and c2 = 2) or (c3 = 2 and c2 = 3)
order by c2 limit 1;

--echo #会改写,不是valid topk,做or expr classify
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4 order by c2 limit 1;
explain select * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = 3 or c2 = 4 order by c2 limit 1;

--echo #inner join
explain select /*+use_concat*/ * from t1, t2 where t1.c1 = 1 or t1.c1 = 2 or t1.c1 = 3 or t1.c1 = 4
or t1.c1 = 5 or t1.c1 = 6 or t1.c1 = 7 or t1.c1 = 8 or t1.c2 = 1 or t1.c2 = 2 or t1.c2 = t2.c3;
explain select * from t1, t2 where t1.c1 = 1 or t1.c1 = 2 or t1.c1 = 3 or t1.c1 = 4
or t1.c1 = 5 or t1.c1 = 6 or t1.c1 = 7 or t1.c1 = 8 or t1.c2 = 1 or t1.c2 = 2 or t1.c2 = t2.c3;

--echo #semi join
explain select /*+use_concat*/ * from t2 where exists (select c1 from t1 where c1 = 1 or c1 = 2
or c1 = 3 or c1 = 4 or c1 = 5 or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = t2.c3);
explain select * from t2 where exists (select c1 from t1 where c1 = 1 or c1 = 2
or c1 = 3 or c1 = 4 or c1 = 5 or c1 = 6 or c1 = 7 or c1 = 8 or c2 = 1 or c2 = 2 or c2 = t2.c3);

explain select /*+use_concat*/ * from t2 where exists (select c1 from t1 where c1 = 1 or c1 = 2
or c1 = 3 or c2 = 1 or c2 = 2 or c2 = t2.c3);
explain select * from t2 where exists (select c1 from t1 where c1 = 1 or c1 = 2
or c1 = 3 or c2 = 1 or c2 = 2 or c2 = t2.c3);

drop table t1,t2;

--echo #using same columns和之前保持一致
create table t1(c1 int, c2 int, c3 int);
create index i1 on t1(c1);

explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 order by c2 limit 1;
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 order by c1 limit 1;
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3;
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c1 = 9 or c1 = 10 or c1 = 11 order by c2 limit 1;
explain select /*+use_concat*/ * from t1 where c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5
or c1 = 6 or c1 = 7 or c1 = 8 or c1 = 9 or c1 = 10 or c1 = 11 order by c1 limit 1;

drop table t1;