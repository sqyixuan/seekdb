#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS `cool_mcc_detail`;
DROP TABLE IF EXISTS `pub_dictionary`;
DROP TABLE IF EXISTS `t_kms_equip_terminal`;
DROP TABLE IF EXISTS `t_kms_lastlogintime`;
DROP TABLE IF EXISTS `cool_bill_20180903`;
DROP TABLE IF EXISTS `datax_maxid_zy_xy`;
DROP TABLE IF EXISTS `t_sys_role`;
DROP TABLE IF EXISTS `t_hsm_dns_chsm`;
DROP TABLE IF EXISTS `t_rpt_chartdata`;
DROP TABLE IF EXISTS `jx_t3eraj78`;
DROP TABLE IF EXISTS `t_kms_encryptor`;
DROP TABLE IF EXISTS `t1tscbnp`;
DROP TABLE IF EXISTS `cool_deal_201811`;
DROP TABLE IF EXISTS `t_inc_incresponse`;
DROP TABLE IF EXISTS `t1az9xc7`;
DROP TABLE IF EXISTS `t_sys_passwordpolicy`;
DROP TABLE IF EXISTS `table100_bigint`;
DROP TABLE IF EXISTS `table10_bigint`;
DROP TABLE IF EXISTS `table1_bigint`;
--enable_warnings

CREATE TABLE `cool_mcc_detail` (
  `mcc_detail_id` int(11) NOT NULL AUTO_INCREMENT,
  `mcc_name` varchar(255) DEFAULT NULL,
  `mcc_code` varchar(10) DEFAULT NULL,
  `mcc_cate_id` varchar(5) DEFAULT NULL,
  PRIMARY KEY (`mcc_detail_id`)
) ENGINE=InnoDB AUTO_INCREMENT=269 DEFAULT CHARSET=utf8;

create TABLE `pub_dictionary` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `version` int(10) unsigned DEFAULT 1 COMMENT '版本号',
  `create_time` datetime NOT NULL COMMENT '创建时间',
  `dic_key` varchar(32) DEFAULT NULL COMMENT '键',
  `dic_value` varchar(64) DEFAULT NULL COMMENT '值',
  `dic_type` varchar(32) DEFAULT NULL COMMENT '字典类型',
  `description` varchar(255) DEFAULT NULL COMMENT '字段描述',
  `dic_flag` bigint(20) DEFAULT NULL COMMENT '字典标识 0 不区分系统 1 政务系统 ',
  `update_time` datetime NOT NULL COMMENT '更新时间',
  `update_user_id` bigint(20) DEFAULT NULL COMMENT '修改人',
  `create_user_id` bigint(20) DEFAULT NULL COMMENT '创建人',
  PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=610 DEFAULT CHARSET=utf8 COMMENT='数据字典表';

CREATE TABLE `t_kms_equip_terminal` (
  `id` varchar(36) NOT NULL DEFAULT '' COMMENT '设备id',
  `type` varchar(255) DEFAULT NULL COMMENT '设备类型',
  `applicationDefinedName` varchar(255) DEFAULT NULL COMMENT '应用程序定义名称',
  `sn` varchar(255) DEFAULT NULL COMMENT '密码设备序列号',
  `description` varchar(255) DEFAULT NULL COMMENT '描述',
  `encpublickey` varchar(255) DEFAULT NULL COMMENT '公钥',
  `signpublickey` varchar(255) DEFAULT NULL COMMENT '签名值',
  `create_time` varchar(32) DEFAULT NULL COMMENT '创建时间',
  `group_id` varchar(36) DEFAULT NULL COMMENT '分组id',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `t_kms_lastlogintime` (
  `userId` int(11) NOT NULL,
  `lastLoginTime` varchar(32) DEFAULT NULL,
  PRIMARY KEY (`userId`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `cool_bill_20180903` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_status` varchar(11) DEFAULT NULL ,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `datax_maxid_zy_xy` (
  `id` bigint(20) DEFAULT NULL COMMENT 'ID',
  `table_name` varchar(128) COLLATE utf8_bin NOT NULL COMMENT '表名',
  `cd_batch` varchar(32) COLLATE utf8_bin NOT NULL COMMENT '批次号'
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin COMMENT='最大ID临时表(正元TO祥云)';

CREATE TABLE `t_sys_role` (
  `roleID` int(11) NOT NULL AUTO_INCREMENT COMMENT '角色标识',
  `roleName` varchar(300) NOT NULL COMMENT '角色名称',
  `description` text COMMENT '描述',
  `isSysDefault` tinyint(1) DEFAULT '0' COMMENT '是否系统内置\n            0 : 不内置\n            1 : 内置',
  `status` int(11) DEFAULT '1' COMMENT '状态\n            1 : 正常\n            2 : 删除',
  PRIMARY KEY (`roleID`)
) ENGINE=InnoDB AUTO_INCREMENT=19 DEFAULT CHARSET=utf8 COMMENT='角色表\r\nWebServer读/写 ';

CREATE TABLE `t_hsm_dns_chsm` (
  `dnsID` int(20) NOT NULL AUTO_INCREMENT COMMENT '宿主机DNS ID',
  `chsmID` int(20) DEFAULT NULL COMMENT '宿主机ID',
  PRIMARY KEY (`dnsID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='宿主机DNS关系表';

CREATE TABLE `t_rpt_chartdata` (
  `dataID` int(11) NOT NULL AUTO_INCREMENT COMMENT '数据编号',
  `resultID` int(11) DEFAULT NULL COMMENT '结果编号',
  `dataKey` varchar(300) DEFAULT NULL COMMENT '图表数据key',
  `dataValue` varchar(300) DEFAULT NULL COMMENT '图表数据值',
  `reservedDataValue1` varchar(300) DEFAULT NULL COMMENT '保留数据值1',
  `reservedDataValue2` varchar(300) DEFAULT NULL COMMENT '保留数据值2',
  PRIMARY KEY (`dataID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='报表执行图表数据';

create table if not exists `jx_t3eraj78` (
	`c1` int(11) not null comment 'primary_key',
	`c2` int(11),
	primary key (`c1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_kms_encryptor` (
  `id` varchar(36) NOT NULL COMMENT '主键',
  `create_by` varchar(50) DEFAULT NULL COMMENT '创建人登录名称',
  `create_date` datetime DEFAULT NULL COMMENT '创建日期',
  `update_by` varchar(50) DEFAULT NULL COMMENT '更新人登录名称',
  `update_date` datetime DEFAULT NULL COMMENT '更新日期',
  `en_name` varchar(32) DEFAULT NULL COMMENT '加密机名',
  `en_ip` varchar(32) DEFAULT NULL COMMENT '加密机IP',
  `en_port` varchar(10) DEFAULT NULL COMMENT '加密机端口',
  `en_state` varchar(4) DEFAULT NULL COMMENT '状态on已启用off已停用',
  `linknum` int(11) DEFAULT NULL COMMENT '连接数',
  `encodetype` varchar(32) DEFAULT NULL COMMENT '编码类型',
  `msgheadlength` varchar(32) DEFAULT NULL COMMENT '消息头长度',
  `timeout` int(11) DEFAULT NULL COMMENT '超时时间',
  `conn_state` int(1) DEFAULT '0' COMMENT '连接状态0正常1错误',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

create table if not exists `t1tscbnp` (
	`c1` int(11),
	`c2` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (c1)
(
	PARTITION `p0`,
	PARTITION `p1`,
	PARTITION `p2`,
	PARTITION `p3`
);

CREATE TABLE `cool_deal_201811` (
  `deal_id` int(11) NOT NULL AUTO_INCREMENT ,
  `agent_id` varchar(11) DEFAULT NULL,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(40) DEFAULT NULL,
  `status` int(1) NOT NULL DEFAULT '0' ,
  `transation_id` varchar(32) DEFAULT NULL ,
  `total_fee` decimal(10,2) DEFAULT NULL ,
  `bonus_fee` decimal(10,2) DEFAULT '0.00' ,
  `cash_fee` decimal(10,2) NOT NULL ,
  `pay_type` varchar(20) DEFAULT NULL ,
  `pay_pass` varchar(20) NOT NULL DEFAULT '010',
  `admin_id` varchar(11) DEFAULT NULL,
  `regtime` varchar(11) DEFAULT NULL,
  `remark_one_value` varchar(255) DEFAULT NULL ,
  `remark_two_value` varchar(255) DEFAULT NULL ,
  `remark_three_value` varchar(255) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `is_read` int(1) NOT NULL DEFAULT '0',
  `app_id` varchar(200) DEFAULT NULL,
  `open_id` varchar(255) DEFAULT '0' ,
  `order_type` int(11) DEFAULT NULL,
  `order_regtime` int(11) DEFAULT NULL,
  `discount_amt` decimal(10,2) DEFAULT NULL,
  `offer_type` varchar(20) DEFAULT NULL,
  `device_id` int(11) DEFAULT NULL ,
  `attach` varchar(255) DEFAULT NULL ,
  `bank_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  `trade_body` varchar(255) DEFAULT NULL ,
  PRIMARY KEY (`deal_id`),
  UNIQUE KEY `out_trade_id` (`out_trade_id`),
  KEY `business_id` (`business_id`),
  KEY `door_id` (`door_id`),
  KEY `regtime_bdoor_idx` (`regtime`,`business_id`,`door_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `origin_trade_no` (`from_business_trade_id`)
) ENGINE=InnoDB AUTO_INCREMENT=4009771 DEFAULT CHARSET=utf8;

CREATE TABLE `t_inc_incresponse` (
  `responseID` int(11) NOT NULL AUTO_INCREMENT,
  `incPolicyID` int(11) NOT NULL COMMENT '告警策略标识',
  `autoName` int(11) DEFAULT NULL COMMENT '告警名称是否自动生成\n            1自动\n            2自定义',
  `incName` varchar(300) NOT NULL COMMENT '告警名称\n            当autoName=2时填写自定义告警名称',
  `severity` int(11) NOT NULL DEFAULT '2' COMMENT '告警的严重级别\n            1:一般\n            2警告\n            3严重\n            4极度严重',
  `incCategoryID` int(11) NOT NULL COMMENT '告警分类',
  `isAppendInc` tinyint(1) NOT NULL DEFAULT '0' COMMENT '是否追加告警\n            0.否\n            1.是',
  `isSendNotification` tinyint(1) DEFAULT '0' COMMENT '是否发送到通知缺省是不发送。',
  PRIMARY KEY (`responseID`)
) ENGINE=InnoDB AUTO_INCREMENT=70 DEFAULT CHARSET=utf8 COMMENT='产生告警响应方式\r\nDataAnalyser读/写';

create table if not exists `t1az9xc7` (
	`c1` char(1),
	`c2` char(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_sys_passwordpolicy` (
  `policyID` int(11) NOT NULL AUTO_INCREMENT COMMENT '口令策略标识流水号',
  `policyName` varchar(300) NOT NULL COMMENT '策略名',
  `creatorID` int(11) DEFAULT NULL COMMENT '创建人',
  `updateTime` datetime DEFAULT NULL COMMENT '更新时间记录策略从创建开始每次更新的时间',
  `maxLength` int(11) NOT NULL COMMENT '最大长度',
  `minLength` int(11) NOT NULL COMMENT '最小长度',
  `containMinFigure` int(11) DEFAULT NULL COMMENT '最小包含数字',
  `containMinCharacter` int(11) DEFAULT NULL COMMENT '最小包含字母',
  `pwdUpdateInterval` int(11) DEFAULT NULL COMMENT '密码更新间隔间隔单位为天。',
  `advanceDaysInform` int(11) DEFAULT NULL COMMENT '日期在过期多少天前通知用户',
  `isExpired` tinyint(1) DEFAULT NULL COMMENT '是否过期\n            0 不过期 \n            1 过期',
  `description` text COMMENT '描述',
  `isSysDefault` tinyint(1) DEFAULT '0' COMMENT '标识1 内置 0 用户创建缺省为0',
  `remindType` int(11) DEFAULT NULL COMMENT '过期提醒方式1 邮件 2短信 3邮件和短信',
  `containMinSpecialChar` int(11) DEFAULT NULL COMMENT '包含最小特殊字符数',
  `isSimilarPasswordChecked` tinyint(1) DEFAULT NULL COMMENT '是否做相似口令检查0 否 1是',
  `isContinuousPasswordChecked` tinyint(1) DEFAULT NULL COMMENT '是否做连续字检测0 否 1是',
  `continuousPasswordCount` int(11) DEFAULT NULL COMMENT '检查连续字检测次数',
  `isSamePasswordChecked` tinyint(1) DEFAULT NULL COMMENT '是否用同一口令设置0 否 1是',
  `isCheckHisPassword` tinyint(1) DEFAULT NULL COMMENT '是否检测历史代码0 不检查 1检查',
  `checkHisPasswordCount` int(11) DEFAULT NULL COMMENT '检查历史代码次数',
  `isUsing` int(11) DEFAULT NULL COMMENT '是否被使用 0:否 1:是',
  `isSamePassword` int(11) DEFAULT NULL COMMENT '密码能否与上次相同 0否    1是',
  PRIMARY KEY (`policyID`)
) ENGINE=InnoDB AUTO_INCREMENT=69 DEFAULT CHARSET=utf8 COMMENT='口令策略\r\nWebServer读/写 ';

CREATE TABLE `table100_bigint` (
  `col_char_20` char(20) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  PRIMARY KEY (`pk`)
) ;

CREATE TABLE `table10_bigint` (
  `col_char_20` char(20) DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  PRIMARY KEY (`pk`)
) ;

CREATE TABLE `table1_bigint` (
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_char_20` char(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  PRIMARY KEY (`pk`)
) ;

