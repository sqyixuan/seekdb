INSERT INTO `table10_bigint` VALUES ('szdayibbcpwsoued','2004-03-18 11:37:43.031820',112,1,NULL),('k','2005-12-16 08:44:53.059988',0,2,8),('','2003-08-09 23:02:42.057875',NULL,3,NULL),('f','2008-01-02 03:39:15.038599',0,4,-117),('ok','2002-01-23 15:10:28.020781',1270015094918479872,5,29675),('','2004-03-19 07:57:35.050313',NULL,6,0),('w','2000-08-12 04:17:11.037594',NULL,7,NULL),('but','2004-05-11 23:34:20.020427',-24,8,1618),('','2008-02-27 21:10:10.009877',NULL,9,0),('pszdayibbcpws','2009-04-15 17:21:50.036210',57,10,NULL);
INSERT INTO `table1_bigint` VALUES (-45,37,'2009-12-23 11:47:14.004493','zda',1);
select count(*) from table100_bigint;
select count(*) from table10_bigint;
select count(*) from table1_bigint;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

## bug: 
##      

SELECT subq_0.c1 AS c0
FROM   (cool_mcc_detail AS ref_0
        INNER JOIN ((SELECT ref_1.create_user_id AS c0,
                           ref_1.create_user_id AS c1
                    FROM   pub_dictionary AS ref_1
                    WHERE  ( ( ref_1.create_user_id >> ref_1.version )
                             AND ( ref_1.version < ref_1.dic_flag ) )
                           AND ( EXISTS (SELECT ref_1.update_user_id AS c0
                                         FROM   t_kms_equip_terminal AS
                                                ref_2
                                         WHERE  (SELECT userid
                                                 FROM   t_kms_lastlogintime
                                                 LIMIT  1 offset 6) / 15) )
                    LIMIT  96) AS subq_0
                    INNER JOIN (((cool_bill_20180903 AS ref_3
                                  INNER JOIN datax_maxid_zy_xy AS ref_4
                                          ON ( ref_3.qd_fr_fee =
                                               ref_4.table_name ))
                                 RIGHT JOIN t_sys_role AS ref_5
                                         ON ( ( ref_4.id < ref_5.roleid )
                                              AND ( ( ref_3.trade_type IS NULL )
                                                     OR ( ( ref_3.channel_id |
                                                            ref_5.status )
                                                           OR ( ref_4.id +
                                            ref_5.issysdefault ) ) ) ))
                                LEFT JOIN (t_hsm_dns_chsm AS ref_6
                                           INNER JOIN ((t_rpt_chartdata AS
                                                       ref_7
                                           INNER JOIN jx_t3eraj78 AS
                                                      ref_8
                                                   ON ( ( ( (
                                           38 = ref_7.resultid )
                                                             OR ( EXISTS
                                           (SELECT ref_8.c2
                                                   AS
                                                   c0,
                                                   ref_8.c1
                                                   AS
                                                   c1,
                                           (SELECT linknum
                                            FROM   t_kms_encryptor
                                            LIMIT  1 offset 3)      AS
                                           c2,
                                           71                       AS
                                           c3,
                                           ref_7.reserveddatavalue1 AS
                                           c4,
                                           ref_9.autoname           AS
                                           c5,
                                           ref_8.c2                 AS
                                           c6,
                                           ref_7.reserveddatavalue1 AS
                                           c7,
                                           ref_9.responseid         AS
                                           c8,
                                           ref_7.resultid           AS
                                           c9,
                                           (SELECT Count(c1)
                                            FROM   t1tscbnp)   AS
                                           c10,
                                           ref_9.inccategoryid      AS
                                           c11,
                                           88                       AS
                                           c12,
                                           ref_8.c2                 AS
                                           c13,
                                           ref_7.datakey            AS
                                           c14,
                                           ref_7.datavalue          AS
                                           c15,
                                           ref_7.reserveddatavalue2 AS
                                           c16,
                                           ref_7.datavalue          AS
                                           c17,
                                           (SELECT business_id
                                            FROM   cool_deal_201811
                                            LIMIT  1 offset 4)      AS
                                           c18,
                                           ref_9.incpolicyid        AS
                                           c19,
                                           ref_9.responseid         AS
                                           c20,
                                           ref_8.c2                 AS
                                           c21,
                                           ref_8.c1                 AS
                                           c22
                                                   FROM
                                               t_inc_incresponse AS
                                               ref_9
                                                             WHERE
                                               ref_9.issendnotification <
                                               ref_8.c2) ) )
                                             AND ( ref_8.c1 &
                                           ref_8.c1 ) )
                                            OR ( ref_8.c1 IS NULL ) ))
                                                       RIGHT JOIN t1az9xc7
                                                                  AS
                                                                  ref_10
                                                               ON
                                                       ( (
                                                       ref_10.c1 IS NULL
                                                                    )
                                                                    AND
                                                         ( ( ref_8.c1 <<
                                                             ref_8.c2 )
                                                           AND ( (
                                           (SELECT Sum(policyid)
                                            FROM   t_sys_passwordpolicy)
                                           AND ref_8.c2 )
                                                    OR ( ref_8.c2 =
                                                      ref_8.c2 ) ) ) ))
                                                   ON ( ( ref_8.c1 IS NOT NULL )
                                                         OR (
                                           ref_6.dnsid IS NULL ) ))
                                       ON ( ( ( 67 <> ref_4.id )
                                              AND ( 1 ) )
                                            AND ( 0 ) ))
                            ON ( subq_0.c1 = ref_3.bill_id ))
                ON ( ref_3.bill_id >= ref_6.chsmid ))
WHERE  subq_0.c1 / ref_6.dnsid
LIMIT  131; 

SELECT  1
FROM    t_sys_role AS ref_5,
        (t_hsm_dns_chsm AS ref_6
        INNER JOIN ((select (SELECT Sum(policyid) FROM t_sys_passwordpolicy) s, c2, c1 from jx_t3eraj78) AS ref_8
                    RIGHT JOIN t1az9xc7 AS ref_10
                    ON   ref_8.s OR ref_8.c2 = ref_8.c2)
        ON ( ref_8.c1 IS NOT NULL OR ref_6.dnsid IS NULL))
LIMIT  1;

SELECT coalesce( ( SELECT col_decimal_20_0 FROM table1_bigint WHERE  (  TRIM( SUBSTR( CONCAT(SUBSTR( 'kqbgsw' , 1, 20) , SUBSTR( HEX( SUBSTR( 'ikqbg' , 1, 20) ) , 1, 20) ) , 1 , 20 ) ) <=> col_char_20 AND NOT LOWER( SUBSTR( 'zi' , 1, 20) ) NOT LIKE LOWER( 'a_' ) ESCAPE 'c' OR ( col_bigint in ( 8330 ) OR  1=0 ) OR ( col_bigint in ( 8330 ) AND  col_timestamp_6 <= DATE_SUB( DATE_SUB( DATE_SUB( '2015-06-15 10:00:00.000001' , INTERVAL '01 05' DAY_HOUR ) , INTERVAL '01 05:05:05' DAY_SECOND ) , INTERVAL '01 05:05:05' DAY_SECOND ) ) AND (col_bigint, col_decimal_20_0, pk) IN ( SELECT col_decimal_20_0, pk, col_decimal_20_0 FROM table100_bigint WHERE  (  col_char_20 > TRIM( SUBSTR( LOWER( SUBSTR( 'izikqbgsw' , 1, 20) ) , 1 , 20 ) ) AND ( col_decimal_20_0 in ( 8330 ) OR  ( col_timestamp_6 <> CONCAT( CAST( 2015 + 3 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) ) OR ( col_decimal_20_0 in ( 8330 ) AND (  LOWER( TRIM( SUBSTR( CONCAT(SUBSTR( 'ZBBCT' , 1, 20) , SUBSTR( HEX( SUBSTR( HEX( SUBSTR( 'RGRLB' , 1, 20) ) , 1, 20) ) , 1, 20) ) , 1 , 20 ) ) ) LIKE LOWER( TRIM( SUBSTR( SUBSTR( REPEAT( TRIM( SUBSTR( REPEAT( TRIM( SUBSTR( HEX( TRIM( SUBSTR( COALESCE( SUBSTR( 'GRXSX' , 1, 20) , SUBSTR( 'v' , 1, 20) , SUBSTR( 't' , 1, 20) ) , 1 , 20 ) ) ) , 1 , 20 ) ) , 0 + 1 ) , 1 , 20 ) ) , 1 + 1 ) , 3 , -11237 ) , 1 , 20 ) ) ) ESCAPE 'a' ) IS NOT FALSE ) OR (col_bigint, col_decimal_20_0, col_bigint) NOT IN ( SELECT col_decimal_20_0, col_bigint, col_decimal_20_0 FROM table10_bigint WHERE -99999 > ROUND( FLOOR( col_bigint ) ) ORDER BY col_bigint  , pk DESC ) ) ORDER BY col_bigint  , col_char_20  , pk DESC ) ) ORDER BY col_char_20 DESC , pk  LIMIT 1 ), ( SELECT 10 ), 10 );


