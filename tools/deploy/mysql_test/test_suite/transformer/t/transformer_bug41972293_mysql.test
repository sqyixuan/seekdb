#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
# link: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 enum('col1', 'col2'), c2 int);
create table t2(c1 char, c2 int, c3 varchar(10));
insert into t1 values('col1', 2);
insert into t1 values('col2', 3);
insert into t2 values('1', 2, 'col1');
insert into t2 values('2', 2, 'col2');
--explain_protocol 2
--result_format 4
SELECT /*+use_concat*/ Sum(1)            AS c1,
                       Nullif(T1.C1, 33) AS c2
FROM   T1
WHERE  ( T1.C2 = 1
          OR EXISTS (SELECT 1
                     FROM   DUAL
                     LIMIT  1) ); 

SELECT /*+no_expand*/ Sum(1)            AS c1,
                       Nullif(T1.C1, 33) AS c2
FROM   T1
WHERE  ( T1.C2 = 1
          OR EXISTS (SELECT 1
                     FROM   DUAL
                     LIMIT  1) );
select * from t2 where t2.c2 in (select c1 from t1);
# bug: 
select * from t2 where t2.c1 in (select c1 from t1);
select * from t2 where t2.c3 in (select c1 from t1);
--explain_protocol 0
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
