##
## Test Name: transformer_shared_expr_bug.test
--result_format 4
--explain_protocol 2

## win_magic bug: 
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);

--disable_query_log
--disable_result_log
insert into t1 values(1), (1), (2), (2), (3), (3);
insert into T2 values(1), (1), (2), (2), (3), (3);
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

select c1, c2 from (select t1.c1 c1, date_format(from_unixtime(t1.c1), '%Y-%m-%d') c2 from t1)
where (c2='2021-06-30' and c1 = (select max(t1.c1) from t1 where date_format(from_unixtime(t1.c1), '%Y-%m-%d')='2021-06-30')) limit 1;

select c1, c2 from (select t1.c1 c1, c1+1 c2 from t1)
where (c2 = 3 and c1 = (select max(t1.c1) from t1 where c1+1 = 3));

select /*+no_rewrite*/ c1, c2 from (select t1.c1 c1, c1+1 c2 from t1)
where (c2 = 3 and c1 = (select max(t1.c1) from t1 where c1+1 = 3));

#
SELECT /*+use_concat*/ DISTINCT ( 598 + t10_5.c12 )
FROM   (SELECT t1.c1,
               (SELECT Max(T2.c1)
                FROM   T2) AS c11,
               (SELECT Max(T2.c1)
                FROM   T2) AS c12
        FROM   t1) t10_5
WHERE  t10_5.c1 <= 150
        OR t10_5.c12 > t10_5.c11;

# bug: 
--disable_warnings
drop table if exists cool_bill_20181003;
drop table if exists sbjxoaai;
drop table if exists varbinary_pk;
drop table if exists t_rpt_response;
--enable_warnings
CREATE TABLE `cool_bill_20181003` (
    `bill_id` int(11) NOT NULL AUTO_INCREMENT,
    PRIMARY KEY (`bill_id`)
    );

create table if not exists `sbjxoaai` (
    `d` year(4),
    `h` double
    );

CREATE TABLE `varbinary_pk` (
    `c01` int(255) DEFAULT NULL,
    `c02` decimal(10,0) DEFAULT NULL,
    `c20` varbinary(255) NOT NULL,
    PRIMARY KEY (`c20`)
    ) ;

CREATE TABLE `t_rpt_response` (
    `responseID` int(11) NOT NULL AUTO_INCREMENT,
    `taskSchedulerID` int(11) DEFAULT NULL ,
    `receiveUser` varchar(300) DEFAULT NULL ,
    `otherEmail` text DEFAULT NULL ,
    `reportType` int(11) DEFAULT NULL ,
    PRIMARY KEY (`responseID`)
    ) ;

SELECT subq_1.c2 AS c10
FROM
(SELECT subq_0.c0 AS c2,
 subq_0.c0 AS c5,
 ref_1.h AS c7
 FROM (
   (SELECT 56 AS c0
    FROM test.cool_bill_20181003 AS ref_0) AS subq_0
   RIGHT JOIN test.sbjxoaai AS ref_1 ON ref_1.d IS NULL) LIMIT 1) AS subq_1
WHERE subq_1.c7 <= subq_1.c5;

SELECT subq_0.c8 AS c1
FROM
(SELECT ref_0.taskSchedulerID AS c1,
 ref_0.responseID AS c3,
 avg(
   (SELECT max(c02)
    FROM varbinary_pk)) over () AS c8
 FROM t_rpt_response AS ref_0 LIMIT 2) AS subq_0
WHERE subq_0.c3 < 1;

drop table t1;
drop table cool_bill_20181003;
drop table sbjxoaai;
drop table varbinary_pk;
drop table t_rpt_response;

# bug: 
# bug: 

--disable_warnings
drop table if exists t1ksttub;
drop table if exists cool_crontime;
drop table if exists t_mon_application_day;
drop table if exists t_component_resource_lock;
drop table if exists weiyi_index;
drop table if exists t_vsm_cluster;
drop table if exists t_kms_app;
drop table if exists cool_bill_20180920;
--enable_warnings

create table `t1ksttub` (
    `c1` varbinary(1),
    `c2` varbinary(1),
    `c3` int(11)
);

CREATE TABLE `cool_crontime` (
    `crontime_id` int(11) NOT NULL AUTO_INCREMENT,
    `type` varchar(100) DEFAULT NULL,
    `date` varchar(50) DEFAULT NULL,
    `crondate` varchar(50) DEFAULT NULL,
    `pay_pass` varchar(11) DEFAULT NULL ,
    `status` varchar(10) DEFAULT NULL ,
    `end_time` int(11) DEFAULT NULL ,
    PRIMARY KEY (`crontime_id`)
    );

CREATE TABLE `t_mon_application_day` (
    `applicationID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'applicationID',
    `monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '监控时间',
    `applicationName` varchar(20) DEFAULT NULL COMMENT '应用名称',
    `encsCount` double DEFAULT NULL COMMENT '加密次数',
    `decsCount` double DEFAULT NULL COMMENT '解密次数',
    `count` double DEFAULT NULL COMMENT '加解密总次数',
    `hsmUUID` varchar(50) DEFAULT NULL,
    `vsmUUID` varchar(50) DEFAULT NULL,
    PRIMARY KEY (`applicationID`)
    );

create TABLE `t_component_resource_lock` (
    `uuid` varchar(10) NOT NULL DEFAULT '' COMMENT '组件资源锁',
    PRIMARY KEY (`uuid`)
    );

CREATE TABLE `weiyi_index` (
    `name` varchar(20) NOT NULL,
    `age` int(10) NOT NULL,
    `address` varchar(20) NOT NULL,
    `sex` float NOT NULL,
    `class` int(10) NOT NULL,
    PRIMARY KEY (`name`)
    );

CREATE TABLE `t_vsm_cluster` (
    `clusterID` int(20) NOT NULL AUTO_INCREMENT COMMENT '集群ID',
    `clusterName` char(100) NOT NULL DEFAULT '' COMMENT '集群名称',
    `standardVsmUUID` char(100) DEFAULT NULL COMMENT '基准虚拟机UUID',
    `mode` int(11) DEFAULT '0' COMMENT '设备类型',
    `syncMethod` int(11) DEFAULT NULL COMMENT '同步方式(0-自动，1-手动)',
    `syncPolicy` int(11) DEFAULT NULL COMMENT '同步策略(0-立即同步，1-时间间隔同步)',
    `syncTimeInterval` int(11) DEFAULT NULL COMMENT '同步时间间隔(单位:分钟)',
    `retryTimeInterval` int(11) DEFAULT NULL COMMENT '重试时间间隔(单位:分钟)',
    `maxRetryNum` int(11) DEFAULT NULL COMMENT '最大重试次数',
    `vsmMin` int(13) DEFAULT '0' COMMENT 'VSM最小容量',
    `vsmMax` int(11) DEFAULT '0' COMMENT 'VSM最大容量',
    PRIMARY KEY (`clusterID`)
    );

CREATE TABLE `t_kms_app` (
    `id` varchar(128) NOT NULL COMMENT '主键',
    `create_by` varchar(50) DEFAULT NULL COMMENT '创建人登录名称',
    `create_date` varchar(32) DEFAULT NULL COMMENT '创建日期',
    `update_by` varchar(50) DEFAULT NULL COMMENT '更新人登录名称',
    `update_date` varchar(32) DEFAULT NULL COMMENT '更新日期',
    `app_name` varchar(50) NOT NULL COMMENT '应用名',
    `validat_type` varchar(32) NOT NULL COMMENT '验证方式0不验证，1验证IP，2验证token3验证IP和token',
    `app_state` varchar(5) DEFAULT NULL COMMENT '状态on启用off停用',
    `app_desc` varchar(512) DEFAULT NULL COMMENT '应用详情描述',
    `searchStr` varchar(512) DEFAULT NULL COMMENT '搜索条件拼接',
    `sign_pubkey` varchar(512) DEFAULT NULL,
    `en_pubkey` varchar(512) DEFAULT NULL,
    `key_alg` varchar(16) DEFAULT NULL,
    PRIMARY KEY (`id`)
    );


CREATE TABLE `cool_bill_20180920` (
    `bill_id` int(11) NOT NULL AUTO_INCREMENT,
    `trade_time` varchar(30) DEFAULT NULL ,
    `app_id` varchar(20) DEFAULT NULL ,
    `mch_id` varchar(30) DEFAULT NULL ,
    `sub_mch` varchar(30) DEFAULT NULL ,
    `device_id` varchar(50) DEFAULT NULL ,
    `wx_order` varchar(50) DEFAULT NULL ,
    `order_no` varchar(50) DEFAULT NULL ,
    `openid` varchar(50) DEFAULT NULL ,
    `trade_type` varchar(50) DEFAULT NULL ,
    `trade_status` varchar(50) DEFAULT NULL ,
    `bank` varchar(100) DEFAULT NULL ,
    `cny` varchar(20) DEFAULT NULL ,
    `total_money` varchar(20) DEFAULT NULL ,
    `redpacket_money` varchar(20) DEFAULT NULL ,
    `aprefund_time` varchar(30) DEFAULT NULL ,
    `surefund_time` varchar(30) DEFAULT NULL ,
    `wxrefund_no` varchar(50) DEFAULT NULL ,
    `mcrefund_no` varchar(50) DEFAULT NULL ,
    `refund_money` varchar(20) DEFAULT NULL ,
    `redpacket_refund_money` varchar(20) DEFAULT NULL ,
    `refund_type` varchar(20) DEFAULT NULL ,
    `refund_status` varchar(20) DEFAULT NULL ,
    `product_target_name` varchar(100) DEFAULT NULL ,
    `data_packet` varchar(255) DEFAULT NULL ,
    `fee` varchar(20) DEFAULT NULL ,
    `rate` varchar(20) DEFAULT NULL ,
    `business_id` varchar(100) DEFAULT NULL,
    `door_id` varchar(100) DEFAULT NULL,
    `pay_type` varchar(100) DEFAULT NULL ,
    `pay_pass` varchar(100) DEFAULT NULL,
    `agent_id` varchar(100) DEFAULT NULL ,
    `agent_fr_fee` varchar(100) DEFAULT NULL ,
    `qd_fr_fee` varchar(100) DEFAULT NULL ,
    `td_cost_fee` varchar(100) DEFAULT NULL ,
    `from_business_trade_id` varchar(128) DEFAULT NULL,
    `bill_time` varchar(30) DEFAULT NULL,
    `channel_id` int(10) DEFAULT NULL ,
    `activity_type` varchar(30) DEFAULT NULL ,
    `pay_log_id` varchar(40) DEFAULT NULL ,
    `user_id` varchar(11) DEFAULT NULL ,
    PRIMARY KEY (`bill_id`),
    UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
    KEY `mch_id_idx` (`mch_id`),
    KEY `agent_id_idx` (`agent_id`),
    KEY `bill_time_idx` (`bill_time`),
    KEY `trade_time_idx` (`trade_time`),
    KEY `business_id_idx` (`business_id`)
);

SELECT /*+use_concat*/ subq_1.c0 AS c0
FROM
(SELECT ref_1.encsCount AS c0
 FROM (
   (SELECT
    (SELECT c3
     FROM t1ksttub LIMIT 1) AS c5
    FROM cool_crontime AS ref_0) AS subq_0
   INNER JOIN test.t_mon_application_day AS ref_1 ON (1 >= subq_0.c5)) LIMIT 183) AS subq_1
WHERE EXISTS
(SELECT 1
 FROM
 (SELECT subq_1.c0 AS c0
  FROM t_component_resource_lock AS ref_3) AS subq_2
 WHERE (EXISTS
   (SELECT subq_2.c0 AS c0
    FROM weiyi_index AS ref_4)));


SELECT 1
FROM
(SELECT
 (SELECT syncPolicy
  FROM t_vsm_cluster LIMIT 1) AS c0
 FROM t_kms_app AS ref_0) AS subq_0
  WHERE subq_0.c0
AND ((subq_0.c0 IS NULL)
    OR EXISTS
    (SELECT 1
     FROM cool_bill_20180920 AS ref_2
     WHERE subq_0.c0 >= ref_2.bill_id));

drop table t1ksttub;
drop table cool_crontime;
drop table t_mon_application_day;
drop table t_component_resource_lock;
drop table weiyi_index;
drop table t_vsm_cluster;
drop table t_kms_app;
drop table cool_bill_20180920;
