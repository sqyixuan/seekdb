# owner: sean.yyj
# owner group: sql1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(c1 int unique, c2 int, c3 int);
create table t2(c1 int unique not null, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int, unique key(c1, c2));
create table t4(c1 int not null, c2 int, c3 int, unique key(c1, c2));

--explain_protocol 1
--result_format 4

select sum(distinct c1) from t1 group by c2;
select sum(distinct c2) from t1 group by c1;
select sum(distinct c2) from t1 group by c1, c3;
select sum(distinct c2) from t1 where c1 > 0 group by c1;
select sum(distinct c2) from t1 where c1 > 0 group by c1, c3;
select sum(distinct c1) from t2 group by c2;
select sum(distinct c2) from t2 group by c1;
select sum(distinct c2) from t3 group by c1;
select sum(distinct c2) from t3 group by c1, c3;
select sum(distinct c2) from t3 where c1 > 0 group by c1;
select sum(distinct c2) from t3 where c1 > 0 group by c1, c3;
select sum(distinct c1) from t4 group by c2;
select sum(distinct c2) from t4 group by c1;
select sum(distinct c2) from t4 group by c1, c3;

drop table t1,t2,t3,t4;
