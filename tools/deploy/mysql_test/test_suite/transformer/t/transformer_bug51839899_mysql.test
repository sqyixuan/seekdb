--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 text collate utf8mb4_bin, c2 text collate utf8mb4_bin);
create table t2(c1 char(100) collate utf8mb4_bin, c2 char(100) collate utf8mb4_bin);
create table t3(c1 varchar(100) collate utf8mb4_bin, c2 varchar(100) collate utf8mb4_bin);

insert into t1 values('a','a');
insert into t2 values('a','a');
insert into t3 values('a','a');

--result_format 4
--explain_protocol 2

select 1 from t1 where c1 = 'a' and c1 = c2;
select 1 from t2 where c1 = 'a' and c1 = c2;
select 1 from t3 where c1 = 'a' and c1 = c2;

drop table t1,t2,t3;
