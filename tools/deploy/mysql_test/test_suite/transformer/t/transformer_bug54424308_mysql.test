--explain_protocol 2
(select count(*) from t1 for update) union all select count(*) from t1;
select count(*) from t1 union all (select count(*) from t1 for update);
select * from t1 where a in (select b from t1 where a = 1 for update) and a in (select b from t1 where 1 = 1);
select * from t1 where a in (select b from t1 where a = 1) and a in (select b from t1 where 1 = 1 for update);

