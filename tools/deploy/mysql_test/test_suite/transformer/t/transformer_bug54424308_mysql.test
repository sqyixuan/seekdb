--disable_query_log
--error 0,1396
drop user link1;
create user link1 identified by "link";
grant all on *.* to link1;
--disable_warnings
drop database if exists link1;
--enable_warnings
create database if not exists link1;

--error 0, 5836
drop database link my_link1;
eval create database link my_link1 connect to link1 database link1 identified by "link" host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int);
insert into t1 values (1,1),(2,2),(3,3),(4,4);

create table link1.t1(a int, b int);
insert into link1.t1 values (1,1),(2,2),(3,3),(4,4);

--enable_query_log
--result_format 4

set @r = 0;

# random function
explain with cte as (select rand() from t1) select * from cte minus select * from cte;
with cte as (select rand() from t1) select * from cte minus select * from cte;
explain with cte as (select /*+inline*/ rand() from t1) select * from cte minus select * from cte;
with cte as (select /*+inline*/ rand() from t1) select * from cte minus select * from cte;

# user variable
explain with cte(c1) as (select @r from t1) select * from cte union all select * from cte;
with cte(c1) as (select @r from t1) select * from cte union all select * from cte;
explain with cte(c1) as (select @r from dual union all select @r := a from t1) select * from cte union all select * from cte;
with cte(c1) as (select @r from dual union all select @r := a from t1) select * from cte union all select * from cte;

# state function
delimiter |;
--disable_warnings
drop function if exists f1|
--enable_warnings

create function f1()
    returns int(11)
not deterministic
begin
  return 1;
end|                        
delimiter ;|

explain with cte(c1) as (select sleep(1) from dual) select * from cte;
explain with cte(c1) as (select f1() from dual) select * from cte union all select * from cte;
drop function f1;

# correlated CTE
--error 1235
select (with cte as (select rand() as r from dual having r > -0.2 * t1.a) select v1.r = v2.r from cte v1, cte v2) from t1;

# dblink
explain with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1 where c1=a;
with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1 where c1=a;
explain with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1@my_link1 where c1=a;
with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1@my_link1 where c1=a;
explain with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1 where c1=a minus select * from cte, t1 where c1=a;
with cte(c1, c2) as (select a, rand() from t1@my_link1) select * from cte, t1 where c1=a minus select * from cte, t1 where c1=a;
explain with cte(c1, c2) as (select a, rand() from t1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1@my_link1 where c1=a;
with cte(c1, c2) as (select a, rand() from t1) select * from cte, t1@my_link1 where c1=a minus select * from cte, t1@my_link1 where c1=a;
explain with cte(c1, c2) as (select a, rand() from t1) select * from cte, t1 where c1=a minus select * from cte, t1@my_link1 where c1=a;
with cte(c1, c2) as (select a, rand() from t1) select * from cte, t1 where c1=a minus select * from cte, t1@my_link1 where c1=a;

