  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_char_20_index`) ,
  KEY `idx7` (`pk`, `col_timestamp_6_index`) ,
  KEY `idx3` (`pk`, `col_decimal_20_0_index`) ,
