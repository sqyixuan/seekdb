SELECT
(SELECT MAX(SUBQUERY1_t1 . `col_varchar_20`) AS SUBQUERY1_field1
 FROM (C AS SUBQUERY1_t1
   LEFT OUTER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int` = SUBQUERY1_t1 . `pk`))) AS field1
FROM (C AS table1
    LEFT OUTER JOIN ((CC AS table2
        RIGHT OUTER JOIN CC AS table3 ON (table3 . `pk` = table2 . `pk`))) ON (table3 . `pk` = table2 . `col_int_key`))
  WHERE
  (table1 . `col_varchar_key` < SOME
   (SELECT SUBQUERY2_t1 . `col_varchar` AS SUBQUERY2_field1
    FROM A AS SUBQUERY2_t1
   ))
OR (table1 . `col_varchar_20_key` IS NULL)
  GROUP BY field1
  HAVING (field1 <= 4
      AND field1 <= 'w')
  ORDER BY 1,
  field1
  LIMIT 100;

SELECT /*+no_rewrite*/
  (SELECT /*+no_rewrite*/ MAX(SUBQUERY1_t1 . `col_varchar_20`) AS SUBQUERY1_field1
   FROM (C AS SUBQUERY1_t1
     LEFT OUTER JOIN C AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int` = SUBQUERY1_t1 . `pk`))) AS field1
  FROM (C AS table1
      LEFT OUTER JOIN ((CC AS table2
          RIGHT OUTER JOIN CC AS table3 ON (table3 . `pk` = table2 . `pk`))) ON (table3 . `pk` = table2 . `col_int_key`))
  WHERE
  (table1 . `col_varchar_key` < SOME
   (SELECT /*+no_rewrite*/ SUBQUERY2_t1 . `col_varchar` AS SUBQUERY2_field1
    FROM A AS SUBQUERY2_t1
   ))
OR (table1 . `col_varchar_20_key` IS NULL)
  GROUP BY field1
  HAVING (field1 <= 4
      AND field1 <= 'w')
  ORDER BY 1,
  field1
  LIMIT 100;

