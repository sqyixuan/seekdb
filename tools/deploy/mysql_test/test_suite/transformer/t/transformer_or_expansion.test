rollback;

select * from t2 where t2.e > any (select e from t1 where t2.a = 1 or t2.b = 1);
select /*+NO_REWRITE*/ * from t2 where t2.e > any (select e from t1 where t2.a = 1 or t2.b = 1);
insert into is_t1 select a,b,c from t2 where t2.e > any (select e from t1 where t2.a = 1 or t2.b = 1);
