select /*+no_rewrite*/* from t1 where t1.c1 in (select c1 from t3) or t1.c1 in (select c1 from t4) group by (select min(c1) from t3) having c1 in (select c2 from t2 where t1.c1 = t2.c1);

##test update/delete stmt can't rewrite
delete /*+use_concat*/is_t1,is_t2 from is_t1,is_t2 where is_t1.c1=1 or is_t2.c1=1;
select/**/ * from is_t1 limit 10;
select/**/ * from is_t2 limit 10;
rollback;
delete /*+no_expand*/is_t1,is_t2 from is_t1,is_t2 where is_t1.c1=1 or is_t2.c1=1;
select/**/ * from is_t1 limit 10;
select/**/ * from is_t2 limit 10;
rollback;
update /*+use_concat*/is_t1, is_t2 set is_t1.c1=100,is_t2.c1=100 where is_t1.c1=1 or is_t2.c1=1;
select/**/ * from is_t1 limit 10;
select/**/ * from is_t2 limit 10;
rollback;
update /*+no_expand*/is_t1, is_t2 set is_t1.c1=100,is_t2.c1=100 where is_t1.c1=1 or is_t2.c1=1;
select/**/ * from is_t1 limit 10;
select/**/ * from is_t2 limit 10;
rollback;

drop table t1, t2, t3, t4, is_t1, is_t2, tpart_1;
set autocommit = 1;

