select/**/ count(*) from is_t1;
rollback;
insert into is_t1 select /*+NO_REWRITE*/a,b,c from t1 where (t1.a = 1 or t1.b = 1) and t1.e > any (select e from t2 where t1.a = 1 or t2.a = 1);
select/**/ count(*) from is_t1;
rollback;
update /*+use_concat*/t1 set t1.a = 100 where (t1.a = 1 or t1.b = 1) and t1.e > any (select e from t2 where t1.a = 1 or t2.a = 1);
select/**/ * from t1 limit 10;
rollback;
update /*+no_expand*/t1 set t1.a = 100 where (t1.a = 1 or t1.b = 1) and t1.e > any (select e from t2 where t1.a = 1 or t2.a = 1);
select/**/ * from t1 limit 10;
rollback;
delete /*+use_concat*/from t1 where (t1.a = 1 or t1.b = 1) and t1.e > any (select e from t2 where t1.a = 1 or t2.a = 1);
