    )
;

SELECT table1 . `col_varchar` AS field2,
       table2 . col_int_key AS field3,
       table2 . col_varchar_key AS field4,
       table2 . col_varchar_key AS field5
       FROM (
           (SELECT SUBQUERY1_t1 . * FROM C AS SUBQUERY1_t1) AS table1
           RIGHT OUTER JOIN
           (SELECT SUBQUERY2_t2 . * FROM (C SUBQUERY2_t2) ) AS table2 ON (table2 . `col_int` = table1 . `pk`))
  WHERE (EXISTS (SELECT SUBQUERY3_t1 . `col_varchar_20` AS SUBQUERY3_field1 FROM C AS SUBQUERY3_t1 WHERE SUBQUERY3_t1 . `col_int_key` < table1 . `col_int_key`))
  AND (table1 . `col_int_key` >= table1 . `col_int_key` OR table1 . `col_varchar_10` IS NULL) ;

SELECT /*+NO_REWRITE*/ table1 . `col_varchar` AS field2,
       table2 . col_int_key AS field3,
       table2 . col_varchar_key AS field4,
       table2 . col_varchar_key AS field5
       FROM (
           (SELECT SUBQUERY1_t1 . * FROM C AS SUBQUERY1_t1) AS table1
           RIGHT OUTER JOIN
           (SELECT SUBQUERY2_t2 . * FROM (C SUBQUERY2_t2) ) AS table2 ON (table2 . `col_int` = table1 . `pk`))
  WHERE (EXISTS (SELECT SUBQUERY3_t1 . `col_varchar_20` AS SUBQUERY3_field1 FROM C AS SUBQUERY3_t1 WHERE SUBQUERY3_t1 . `col_int_key` < table1 . `col_int_key`))
  AND (table1 . `col_int_key` >= table1 . `col_int_key` OR table1 . `col_varchar_10` IS NULL) ;

