call dbms_stats.gather_table_stats('TEST', 'TPART', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'IS_T1', method_opt=>'for all columns size 64', estimate_percent=>100);
--result_format 4
--explain_protocol 2
set autocommit = 0;

##basic result
select/**/ count(*) from is_t1;

## test or-expansion to use different index to speed up the query
select * from t1 where t1.a = 1 or t1.b = 1;
select /*+NO_REWRITE*/ * from t1 where t1.a = 1 or t1.b = 1;
