create table t1 (c1 int, c2 int, c3 int, primary key(c1));
create table t2 (c1 int, c2 int, c3 int, primary key(c1, c2));
create table t3 (c1 int, c2 int, c3 int, primary key(c1, c2, c3));
create table t4 (c1 int, c2 int, c3 int);
create table is_t1(c1 int, c2 int, c3 int);
create table is_t2(c1 int, c2 int, c3 int);
create table tpart_1 (c1 int, c2 int, c3 int, c4 int, primary key (c1)) partition by hash(c1) partitions 4;
create index gkey on tpart_1(c2,c3,c4) global;

