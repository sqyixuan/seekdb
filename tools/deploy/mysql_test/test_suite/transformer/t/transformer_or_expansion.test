select /*+no_expand*/c2 from t1 where c2 in (select c2 from t2) or c2 in (select c2 from t3) or c2 in (select c2 from t4) group by c2;
insert into is_t1(c2) select /*+use_concat*/c2 from t1 where c2 in (select c2 from t2) or c2 in (select c2 from t3) or c2 in (select c2 from t4) group by c2;
select/**/ count(*) from is_t1;
rollback;
insert into is_t1(c2) select /*+no_expand*/c2 from t1 where c2 in (select c2 from t2) or c2 in (select c2 from t3) or c2 in (select c2 from t4) group by c2;
select/**/ count(*) from is_t1;
rollback;
update /*+use_concat*/t1 set t1.c2 = 100 where c2 in (select c2 from t2) or c2 in (select c2 from t3) or c2 in (select c2 from t4);
