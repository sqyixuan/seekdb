SELECT DISTINCT table2 . `col_int` AS field1,
                table1 . col_varchar_key AS field2
FROM (BB AS table1
      LEFT  JOIN C AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_20`))
WHERE (NOT EXISTS
         (SELECT DISTINCT SUBQUERY1_t1 . `col_varchar_20_key` AS SUBQUERY1_field1
          FROM (C AS SUBQUERY1_t1
                INNER JOIN B AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int`))
          WHERE SUBQUERY1_t1 . `pk` <> table1 . `col_int`
            AND SUBQUERY1_t1 . `col_int_key` > SUBQUERY1_t1 . `pk` ))
  AND (table1 . `col_int_key` > 77
       AND table1 . `col_int_key` < (77 + 123)
       OR table1 . `col_int_key` BETWEEN 77 AND (77 + 167))
  OR (table1 . `col_int_key` > table2 . `col_int`
      OR EXISTS (
                   (SELECT SUBQUERY2_t1 . `col_int` AS SUBQUERY2_field1
                    FROM C AS SUBQUERY2_t1
                    WHERE SUBQUERY2_t1 . `col_int_key` <> SUBQUERY2_t1 . `pk`
                    GROUP BY SUBQUERY2_field1)))
HAVING field2 <> 8
ORDER BY field1,
         field2;

