delete /*+no_expand*/from t1 where t1.a = 1 or (t1.b = 2 and c in (select a from t2 union select b from t3));
select/**/ * from t1 limit 10;
rollback;

## test semi-anti join
## pullup as semi-anti join, no or-expansion
select * from t2 where not exists (select * from t1 where t1.a = 1 or t2.b = 1);
select /*+NO_REWRITE*/ * from t2 where not exists (select * from t1 where t1.a = 1 or t2.b = 1);
