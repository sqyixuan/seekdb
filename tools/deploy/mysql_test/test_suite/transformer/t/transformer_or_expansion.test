SELECT CAST( CONCAT(TRIM( SUBSTR( ( SELECT coalesce( ( SELECT SUM( pk ) FROM table10_bigint WHERE col_char_20 <= ( TRIM( SUBSTR( SUBSTR( SUBSTR( CONCAT( SUBSTR( 'ywhc' , 1, 20) , SUBSTR( 'WGXFV' , 1, 20) ) , 5 ) , 5 ) , 1 , 20 ) ) ) ORDER BY col_timestamp_6 DESC , pk  ), ( SELECT 0 ), -10 ) ) , 1 , 20 ) ) , col_char_20 ) AS CHAR(100) ),pk
FROM table100_bigint
WHERE ( col_decimal_20_0 != -16869 AND  FALSE ) OR ( col_decimal_20_0 <= -16869 AND  ( col_bigint BETWEEN NULL AND NULL ) ) OR col_timestamp_6 IS NOT NULL
ORDER BY 1 , pk ASC ;

SELECT /*+no_rewrite*/ CAST( CONCAT(TRIM( SUBSTR( ( SELECT coalesce( ( SELECT SUM( pk ) FROM table10_bigint WHERE col_char_20 <= ( TRIM( SUBSTR( SUBSTR( SUBSTR( CONCAT( SUBSTR( 'ywhc' , 1, 20) , SUBSTR( 'WGXFV' , 1, 20) ) , 5 ) , 5 ) , 1 , 20 ) ) ) ORDER BY col_timestamp_6 DESC , pk  ), ( SELECT 0 ), -10 ) ) , 1 , 20 ) ) , col_char_20 ) AS CHAR(100) ),pk
FROM table100_bigint
WHERE ( col_decimal_20_0 != -16869 AND  FALSE ) OR ( col_decimal_20_0 <= -16869 AND  ( col_bigint BETWEEN NULL AND NULL ) ) OR col_timestamp_6 IS NOT NULL
ORDER BY 1 , pk ASC ;

--disable_warnings
drop table if exists a, c, cc;
--enable_warnings
CREATE TABLE `A` (
    `col_int_key` int(11) DEFAULT NULL,
    `col_varchar_20` varchar(20) DEFAULT NULL,
    `col_varchar_20_key` varchar(20) DEFAULT NULL,
    `pk` int(11) NOT NULL,
    `col_varchar_10_key` varchar(10) DEFAULT NULL,
    `col_varchar` varchar(1) DEFAULT NULL,
    `col_int` int(11) DEFAULT NULL,
    `col_varchar_key` varchar(1) DEFAULT NULL,
    `col_varchar_10` varchar(10) DEFAULT NULL,
    PRIMARY KEY (`pk`),
    KEY `idx1` (`pk`, `col_int_key`) ,
    KEY `idx7` (`pk`, `col_varchar_20_key`) ,
    KEY `idx5` (`pk`, `col_varchar_10_key`) ,
    KEY `idx3` (`pk`, `col_varchar_key`));
CREATE TABLE `C` (
    `pk` int(11) NOT NULL,
    `col_int_key` int(11) DEFAULT NULL,
    `col_varchar_20` varchar(20) DEFAULT NULL,
    `col_varchar_key` varchar(1) DEFAULT NULL,
    `col_varchar` varchar(1) DEFAULT NULL,
    `col_varchar_10_key` varchar(10) DEFAULT NULL,
    `col_varchar_10` varchar(10) DEFAULT NULL,
    `col_int` int(11) DEFAULT NULL,
    `col_varchar_20_key` varchar(20) DEFAULT NULL,
    PRIMARY KEY (`pk`),
    KEY `idx1` (`pk`, `col_int_key`) ,
    KEY `idx3` (`pk`, `col_varchar_key`) ,
    KEY `idx5` (`pk`, `col_varchar_10_key`) ,
    KEY `idx7` (`pk`, `col_varchar_20_key`)
    );
