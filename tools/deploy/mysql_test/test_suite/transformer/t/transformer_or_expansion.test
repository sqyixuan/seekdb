SELECT SUM(table1 . `col_int`) AS field1,
  (SELECT SUM(SUBQUERY1_t1 . `col_int_key`) AS SUBQUERY1_field1
   FROM CC AS SUBQUERY1_t1) AS field2,
       SUM(table1 . `pk`) AS field3,
       table1 . col_varchar_20_key AS field4
FROM (CC AS table1
      RIGHT OUTER JOIN D AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10_key`))
WHERE (
         (SELECT MIN(SUBQUERY2_t2 . `col_int_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                LEFT OUTER JOIN C AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`))) IS NULL)
  OR (table1 . `pk` = table1 . `pk`
      AND EXISTS (
                    (SELECT 6
                     FROM DUAL)))
GROUP BY field2,
         field4
HAVING field2 != 6
ORDER BY field1,
         field2,
         field3,
         field4;

SELECT /*+no_rewrite*/ SUM(table1 . `col_int`) AS field1,
  (SELECT SUM(SUBQUERY1_t1 . `col_int_key`) AS SUBQUERY1_field1
   FROM CC AS SUBQUERY1_t1) AS field2,
       SUM(table1 . `pk`) AS field3,
       table1 . col_varchar_20_key AS field4
FROM (CC AS table1
      RIGHT OUTER JOIN D AS table2 ON (table2 . `col_varchar_key` = table1 . `col_varchar_10_key`))
WHERE (
         (SELECT MIN(SUBQUERY2_t2 . `col_int_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                LEFT OUTER JOIN C AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar` = SUBQUERY2_t1 . `col_varchar_key`))) IS NULL)
  OR (table1 . `pk` = table1 . `pk`
      AND EXISTS (
                    (SELECT 6
                     FROM DUAL)))
GROUP BY field2,
         field4
HAVING field2 != 6
ORDER BY field1,
         field2,
         field3,
         field4;

