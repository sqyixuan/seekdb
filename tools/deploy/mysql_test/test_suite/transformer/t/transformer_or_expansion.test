SELECT table2 . col_varchar_10_key AS field1,
       table1 . `pk` AS field2
FROM (CC AS table1
      INNER JOIN CC AS table2 ON (table2 . `col_varchar_20` = table1 . `col_varchar_key`))
WHERE (EXISTS
         (SELECT SUBQUERY1_t1 . `col_varchar_key` AS SUBQUERY1_field1
          FROM (A AS SUBQUERY1_t1
                INNER JOIN B AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_10_key`))
          WHERE SUBQUERY1_t2 . `col_int_key` = table2 . `pk`
            AND SUBQUERY1_t2 . `col_int_key` = SUBQUERY1_t1 . `pk` ))
  AND table1 . `col_int_key` = table2 . `pk`
  OR (table1 . `col_int_key` IS NULL
      AND EXISTS
        (SELECT SUBQUERY2_t1 . `col_varchar_10` AS SUBQUERY2_field1
         FROM (C AS SUBQUERY2_t1
               RIGHT  JOIN (BB AS SUBQUERY2_t2
                            LEFT OUTER JOIN B AS SUBQUERY2_t3 ON (SUBQUERY2_t3 . `col_varchar_key` = SUBQUERY2_t2 . `col_varchar_10`)) ON (SUBQUERY2_t3 . `pk` = SUBQUERY2_t2 . `col_int_key`))
         WHERE SUBQUERY2_t1 . `col_varchar_10_key` >= table1 . `col_varchar_10_key` ))
ORDER BY field1,
         field2
LIMIT 10
OFFSET 4;

