set autocommit = 0;
##test basic, select item unique and table has unique key
select /*+use_concat*/* from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select /*+no_expand*/* from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
insert into is_t1 select /*+use_concat*/* from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ count(*) from is_t1;
rollback;
insert into is_t1 select /*+no_expand*/* from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ count(*) from is_t1;
rollback;
update /*+use_concat*/t1 set t1.c2 = 100 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ * from t1 limit 10;
rollback;
update /*+no_expand*/t1 set t1.c2 = 100 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ * from t1 limit 10;
rollback;
delete /*+use_concat*/from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ * from t1 limit 10;
rollback;
delete /*+no_expand*/from t1 where c1 in (select c1 from t2) or c1 in (select c1 from t3);
select/**/ * from t1 limit 10;
rollback;

##test basic, select item not unique and table has unique key
