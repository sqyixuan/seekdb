SELECT    table1 . col_int_key AS field1 , table1 . col_varchar_10_key AS field2 , table1 . col_int_key AS field3 , table1 . `col_varchar_10_key` AS field4 , table2 . col_varchar_key AS field5 , table1 . col_varchar_20_key AS field6 , table1 . col_varchar_20_key AS field7 , table1 . col_varchar_20_key AS field8 FROM ( (  SELECT   SUBQUERY1_t1 . * FROM CC AS SUBQUERY1_t1  ) AS table1 INNER JOIN ( ( A AS table2 RIGHT  JOIN (  SELECT   SUBQUERY2_t1 . * FROM C AS SUBQUERY2_t1 WHERE (   EXISTS ( SELECT   CHILD_SUBQUERY1_t2 . `col_varchar_key` AS CHILD_SUBQUERY2_field1 FROM ( C AS CHILD_SUBQUERY1_t1 RIGHT OUTER JOIN C AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `pk` = CHILD_SUBQUERY1_t1 . `pk` ) ) WHERE CHILD_SUBQUERY1_t1 . `col_int` = SUBQUERY2_t1 . `col_int` ) AND SUBQUERY2_t1 . `col_varchar_20_key` >= SUBQUERY2_t1 . `col_varchar_10` ) ) AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_key`  ) ) ) ON (table3 . `col_varchar` = table2 . `col_varchar_key`  OR table3 . `col_int_key`  IN ( SELECT 2 UNION  SELECT 161 ) ) ) WHERE (   EXISTS ( SELECT   SUBQUERY4_t1 . `col_varchar_20` AS SUBQUERY4_field1 FROM ( C AS SUBQUERY4_t1 INNER JOIN ( CC AS SUBQUERY4_t2 INNER JOIN CC AS SUBQUERY4_t3 ON (SUBQUERY4_t3 . `pk` = SUBQUERY4_t2 . `col_int_key`  ) ) ON (SUBQUERY4_t3 . `col_varchar_10_key` = SUBQUERY4_t2 . `col_varchar_key`  ) ) WHERE SUBQUERY4_t2 . `col_varchar_20` != table2 . `col_varchar_key` AND SUBQUERY4_t1 . `col_int_key` > table1 . `pk` ) ) AND ( table1 . `pk` > 187 OR table1 . `pk`  IN (203) ) ;

SELECT   col_bigint, col_bigint_key, col_bigint_unique_index, col_char_20, col_char_20_key, col_char_20_unique_index, col_char_21, col_char_21_key, col_char_21_unique_index, col_char_22, col_char_22_key, col_char_22_unique_index, col_char_23, col_char_23_key, col_char_23_unique_index, col_char_24, col_char_24_key, col_char_24_unique_index, col_char_25, col_char_25_key, col_char_25_unique_index, col_char_26, col_char_26_key, col_char_26_unique_index, col_char_27, col_char_27_key, col_char_27_unique_index, col_char_28, col_char_28_key, col_char_28_unique_index, col_char_29, col_char_29_key, col_char_29_unique_index, col_char_30, col_char_30_key, col_char_30_unique_index, col_char_31, col_char_31_key, col_char_31_unique_index, col_char_32, col_char_32_key, col_char_32_unique_index, col_char_33, col_char_33_key, col_char_33_unique_index, col_char_34, col_char_34_key, col_char_34_unique_index, col_char_35, col_char_35_key, col_char_35_unique_index, col_char_36, col_char_36_key, col_char_36_unique_index, col_char_37, col_char_37_key, col_char_37_unique_index, pk FROM     table10_bigint WHERE    col_char_23_unique_index NOT LIKE 'a%' OR       col_char_24_key LIKE Substr( '%' , 3 , 7 ) ESCAPE 'z' HAVING   col_char_25_key LIKE '%' ESCAPE 'b' OR       col_char_26_unique_index LIKE hex( '_' ) ESCAPE 'h' ORDER BY col_char_22_unique_index ASC , pk limit 5 , 1;

SELECT 1
FROM   (   cc AS table1
    INNER JOIN ( ( a AS table2 RIGHT JOIN (SELECT col_varchar_key, col_varchar, col_int_key FROM c) AS table3
        ON ( table3 . `col_varchar_key` = table2 . `col_varchar_key` ) ) ) ON ( table3 . `col_varchar` = table2 . `col_varchar_key` OR table3 . `col_int_key` =2 ) )
  WHERE  ( EXISTS (SELECT 1 FROM  c WHERE  `col_int_key` > table1 . `pk`) );

## test memory usage
SELECT col_bigint,col_bigint_key,col_char_20,col_char_20_key,col_char_21,col_char_21_key,col_char_22,col_char_22_key,col_char_23,col_char_23_key,col_char_24,col_char_24_key,col_char_25,col_char_25_key,col_char_26,col_char_26_key,col_char_27,col_char_27_key,col_char_28,col_char_28_key,col_char_29,col_char_29_key,col_char_30,col_char_30_key,col_char_31,col_char_31_key,col_char_32,col_char_32_key,col_char_33,col_char_33_key,col_char_34,col_char_34_key,col_char_35,col_char_35_key,col_char_36,col_char_36_key,col_char_37,col_char_37_key,col_char_38,col_char_38_key,col_char_39,col_char_39_key,col_char_40,col_char_40_key,col_char_41,col_char_41_key,col_char_42,col_char_42_key,col_char_43,col_char_43_key,col_char_44,col_char_44_key,col_char_45,col_char_45_key,col_char_46,col_char_46_key,col_char_47,col_char_47_key,col_char_48,col_char_48_key,col_timestamp_6,col_timestamp_6_key,pk FROM table10_bigint WHERE col_char_27_key LIKE SUBSTR( TRIM( '%' FROM TRIM( SUBSTR( CONCAT(SUBSTR( 'ej' , 1, 20) , SUBSTR( 'b' , 1, 20) ) , 1 , 20 ) ) ) , 1 , 8 ) ESCAPE 's' OR col_char_20_key LIKE TRIM( TRIM( BOTH CONCAT( 'u' , '%') FROM TRIM( SUBSTR( SUBSTR( SUBSTR( 's' , 1, 20) , 5 ) , 1 , 20 ) ) ) FROM TRIM( SUBSTR( DATE_FORMAT( DATE_SUB( CONCAT( CAST( 2015 + 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') , INTERVAL '01 05' DAY_HOUR ) , '%U' ) , 1 , 20 ) ) ) OR col_char_30_key NOT LIKE TRIM( TRAILING SUBSTR( 'ts' , 1, 20) FROM TRIM( SUBSTR( DATE_FORMAT( DATE_SUB( CONCAT( CAST( 2015 + 1 + 2 AS CHAR(20) ) , '-06-15 01:00:00.000003') , INTERVAL 4 MICROSECOND ) , CONCAT( '%b' , '%W' ) ) , 1 , 20 ) ) ) AND col_char_34_key LIKE '%' ESCAPE 'j' OR col_char_42_key LIKE CONCAT( TRIM( BOTH HEX( '_' ) FROM SUBSTR( 'dtsbejrf' , 1, 20) ) , REPEAT( CONCAT( SUBSTR( 'adts' , 3 , 7 ) , CONCAT( SUBSTR( 'a%' , 4 , 8 ) , REPEAT( CONCAT( CONCAT( TRIM( TRAILING '>' FROM SUBSTR( 'hadts' , 1, 20) ) , REPEAT( '%' , 1 ) ) , REPEAT( CONCAT('p' , '%') , 3 ) ) , 5 ) ) ) , 1 ) ) OR col_char_37_key NOT LIKE CONCAT( 't' , '%') AND col_char_25_key LIKE SUBSTR( TRIM( '%a%' FROM SUBSTR( 'shadt' , 1, 20) ) , 3 , 8 ) OR col_char_39_key NOT LIKE 'a%' HAVING col_char_45_key NOT LIKE 'u' ESCAPE 'q' OR col_char_26_key NOT LIKE SUBSTR( SUBSTR( TRIM( BOTH CONCAT( 'd' , '%') FROM SUBSTR( 'zush' , 1, 20) ) , 5 , 5 ) , 1 , 5 ) OR col_char_39_key LIKE '%' ESCAPE 'm' AND col_char_32_key NOT LIKE SUBSTR( 'j' , 5 , 7 ) ESCAPE 'e' AND col_char_22_key NOT LIKE HEX( HEX( '!' ) ) ESCAPE 'w' OR col_char_20_key NOT LIKE CONCAT( SUBSTR( 'z' , 1, 20) , '_a_a_' ) OR col_char_24_key LIKE TRIM( TRAILING REPEAT( TRIM( 'a%' FROM TRIM( SUBSTR( TRIM( 'a' FROM SUBSTR( 'qz' , 1, 20) ) , 1 , 20 ) ) ) , 4 ) FROM SUBSTR( 'qqzjzus' , 1, 20) ) ESCAPE 'k' OR col_char_27_key NOT LIKE REPEAT( TRIM( TRAILING CONCAT( TRIM( BOTH CONCAT('s' , '%') FROM SUBSTR( 'nqq' , 1, 20) ) , HEX( HEX( CONCAT('p' , '%') ) ) ) FROM TRIM( SUBSTR( TRIM( LEADING SUBSTR( 'cn' , 1, 20) FROM SUBSTR( 'r' , 1, 20) ) , 1 , 20 ) ) ) , 2 ) ORDER BY 1 ASC , pk LIMIT 5;

