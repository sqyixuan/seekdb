set autocommit = 1;

## online case,  merchant 业务 SQL 积累
--disable_warnings
drop table if exists cm_merchant_card, cm_order_link_card, cm_order_link, cm_merchant_relation;
--enable_warnings
CREATE TABLE `cm_merchant_card` (
  `id` bigint(20) NOT NULL COMMENT '编号',
  `merchant_id` bigint(20) NOT NULL COMMENT '商户ID',
  `card_no` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '账户的cardNo，即userid',
  `partner_id` varchar(30) COLLATE utf8mb4_bin NOT NULL COMMENT 'partnerid',
  `gmt_create` datetime(6) NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime(6) NOT NULL COMMENT '修改时间',
  `del_flag` bigint(20) NOT NULL DEFAULT '0' COMMENT '是否逻辑删除，0：否；值为对应的ID：是(逻辑删除时填入该条记录对应的id',
   PRIMARY KEY (`id`),
   UNIQUE KEY `uk_cm_merchant_card_no` (`card_no`, `del_flag`) BLOCK_SIZE 16384,
   UNIQUE KEY `uk_cm_merchant_partner_id` (`partner_id`, `del_flag`) BLOCK_SIZE 16384,
   KEY `idx_cm_card_mid` (`merchant_id`) BLOCK_SIZE 16384,
   KEY `IDX_CM_MERCHANT_CARD_GMT` (`gmt_modified`) BLOCK_SIZE 16384
);

CREATE TABLE `cm_order_link_card` (
  `id` bigint(20) NOT NULL COMMENT '主键ID',
  `link_id` bigint(20) NOT NULL COMMENT '订购关系ID',
  `card_no` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '卡号',
  `partner_id` varchar(30) COLLATE utf8mb4_bin NOT NULL COMMENT '合作伙伴ID',
  `credit_account` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '指定收款帐号',
  `debit_account` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '指定扣款帐号',
  `gmt_create` datetime(6) NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime(6) NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_cm_order_link_card` (`card_no`, `link_id`) BLOCK_SIZE 16384,
  UNIQUE KEY `uk_cm_order_link_partner` (`link_id`, `partner_id`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_card_ca_da` (`credit_account`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_card_dc` (`debit_account`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_card_pid` (`partner_id`) BLOCK_SIZE 16384
);

CREATE TABLE `cm_order_link` (
  `id` bigint(20) NOT NULL COMMENT '订购关系ID',
  `order_num` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '所属订单号',
  `sales_plan_code` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT '销售方案CODE',
  `link_type` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '订购关系类型（DEFAULT普通，REWARD返佣上家类型，SLAVE_REWARD返佣下家）',
  `onlined` char(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '0' COMMENT '是否上线：0：未上线1：上线',
  `gmt_online` datetime(6) DEFAULT NULL COMMENT '上线时间',
  `valid_type` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '生效类型（PRE_TIME预约生效，FIXED_TIME截止日期审核生效，AUDIT固定期限审核生效）',
  `gmt_valid` datetime(6) DEFAULT NULL COMMENT '实际生效时间',
  `gmt_invalid` datetime(6) DEFAULT NULL COMMENT '实际结束时间',
  `gmt_valid_due` datetime(6) DEFAULT NULL COMMENT '预计生效时间',
  `gmt_invalid_due` datetime(6) DEFAULT NULL COMMENT '预计结束时间',
  `sign_type` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT '签约类型（NS新签，CS改签，RS续签）',
  `origin_link_id` bigint(20) DEFAULT NULL COMMENT '原订购关系ID(针对改签、续签的订购关系来填)',
  `reward_link_id` bigint(20) DEFAULT NULL COMMENT '需要返佣的订购关系说明：如果是下家订购关系，则填入需要向上家返佣的订购关系',
  `ext_memo` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '扩展字段，专门用于订购中心冗余部分业务字段',
  `biz_pool_id` bigint(20) DEFAULT NULL COMMENT '所属商户业务池',
  `biz_manager_id` bigint(20) DEFAULT NULL COMMENT '所属业绩经理',
  `gmt_create` datetime(6) NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime(6) NOT NULL COMMENT '修改时间',
  `gmt_valid_protocl` datetime(6) DEFAULT NULL COMMENT '协议生效时间',
  `gmt_invalid_protocl` datetime(6) DEFAULT NULL COMMENT '协议结束时间',
  `sales_plan_name` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT '销售方案CODE名称',
  `canceled` bigint(20) NOT NULL COMMENT '是否取消，冗余订单取消状态。0：未取消；1：取消；',
  `use_scene` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'B2B：企业对企业；B2C：企业对个人；SETTLE：资金清算',
  `merchant_id` bigint(20) NOT NULL COMMENT '订单所属的商户ID',
  `payment_due` bigint(20) DEFAULT NULL COMMENT '应付款项',
  `payment_actual` bigint(20) DEFAULT NULL COMMENT '实付款项',
  `refund_status` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '退款状态，目前存在：CSRS_REFUND--改续签需要退款给源订购关系、CSRS_UN_REFUND--改续签订购关系不需要退款给源订购关系',
  `refund_memo` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '退款备注',
  `state` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '订购关系状态（0，未生效，1，已生效，2，已失效）',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_cm_order_link` (`order_num`, `sales_plan_code`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_gmtc_bmid` (`biz_manager_id`, `gmt_create`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_gmt_create` (`gmt_create`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_gmt_invalid` (`gmt_invalid`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_gvalid_due` (`gmt_valid_due`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_merchant_id` (`merchant_id`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_origin_lid` (`origin_link_id`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_rewardlink` (`reward_link_id`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_spc_c_gigcid` (`sales_plan_code`, `canceled`, `gmt_invalid`, `gmt_create`, `id`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_state` (`state`) BLOCK_SIZE 16384,
  KEY `idx_cm_order_link_sg` (`sign_type`, `gmt_invalid`, `gmt_valid`, `gmt_create`) BLOCK_SIZE 16384
);

CREATE TABLE `cm_merchant_relation` (
  `id` bigint(20) NOT NULL COMMENT '主键ID',
  `primary_id` bigint(20) NOT NULL COMMENT '主商户ID：引入关系中的上家、父子关系中的集团公司、伙伴关系中的伙伴圈ID',
  `slave_id` bigint(20) NOT NULL COMMENT '从商户ID：引入关系中的下家、父子关系中的子公司、伙伴关系中的商户',
  `type` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT '关系类型:I 引入关系、S父子关系、P伙伴关系、C合作关系',
  `gmt_create` datetime(6) NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime(6) NOT NULL COMMENT '修改时间',
  `del_flag` bigint(20) NOT NULL COMMENT '逻辑删除标记位。若有效，值为0；若关系废除，值为该条关系的ID。',
  `relation_ext_info` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关系扩展信息',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_cm_merchant_relation` (`slave_id`, `type`, `del_flag`, `primary_id`) BLOCK_SIZE 16384,
  KEY `idx_cm_relation_pid` (`primary_id`) BLOCK_SIZE 16384,
  KEY `IDX_CM_MERCHANT_RELATION_ALL` (`del_flag`, `primary_id`, `type`, `slave_id`, `id`, `relation_ext_info`, `gmt_create`, `gmt_modified`) BLOCK_SIZE 16384
);

select c.ID from CM_ORDER_LINK_CARD  c,CM_ORDER_LINK l
  where (c.CREDIT_ACCOUNT = '2088332063833223' or c.DEBIT_ACCOUNT = '2088332063833223') and c.LINK_ID = l.ID and ((l.gmt_valid < '2023-01-02 00:00' and gmt_invalid > '2023-01-01 00:00') or (l.gmt_valid is null and l.gmt_invalid is null)) and l.CANCELED = 0;

select count(c.ID)
  from CM_ORDER_LINK_CARD  c,CM_ORDER_LINK  l
  where (c.CREDIT_ACCOUNT = '2088332063833223' or c.DEBIT_ACCOUNT = '2088332063833223') and c.LINK_ID = l.ID and ((l.gmt_valid < '2023-01-02 00:00' and gmt_invalid > '2023-01-01 00:00') or (l.gmt_valid is null and l.gmt_invalid is null)) and l.CANCELED = 0;

select t.ID, t.MERCHANT_ID, t.CARD_NO, t.PARTNER_ID, t.GMT_CREATE, t.GMT_MODIFIED
  from CM_MERCHANT_CARD t
  where (t.CARD_NO = '2088502902587835' or t.PARTNER_ID = '2088502902587835') and t.DEL_FLAG = 0;

select * from CM_MERCHANT_RELATION
  where DEL_FLAG = 0 and ((PRIMARY_ID = 221188772 and type = 'I') or (PRIMARY_ID = 221188772 and type = 'S') or (PRIMARY_ID = 221188772  and  type  =  'C')  or (SLAVE_ID  =  221188772  and  type  =  'I')  or (SLAVE_ID  =  221188772  and  type  =  'S')  or (SLAVE_ID  =  221188772  and  type  =  'C')  or (type = 'P' and SLAVE_ID  !=221188772  and PRIMARY_ID  in  (select  q.PRIMARY_ID from  CM_MERCHANT_RELATION  q where  q.SLAVE_ID  =  221188772 and  q.TYPE  =  'P' and  q.DEL_FLAG  =  0) ));

select count(*) from CM_MERCHANT_RELATION
  where DEL_FLAG = 0 and ((PRIMARY_ID = 221188772 and type = 'I') or (PRIMARY_ID = 221188772 and type = 'S') or (PRIMARY_ID = 221188772  and  type  =  'C')  or (SLAVE_ID  =  221188772  and  type  =  'I')  or (SLAVE_ID  =  221188772  and  type  =  'S')  or (SLAVE_ID  =  221188772  and  type  =  'C')  or (type = 'P' and SLAVE_ID  !=221188772  and PRIMARY_ID  in  (select  q.PRIMARY_ID from  CM_MERCHANT_RELATION  q where  q.SLAVE_ID  =  221188772 and  q.TYPE  =  'P' and  q.DEL_FLAG  =  0) ));

select * from  CM_MERCHANT_RELATION where (PRIMARY_ID= 2 or SLAVE_ID= 1) and TYPE= 'P' and DEL_FLAG = 0;

select count(*) from CM_MERCHANT_RELATION where (PRIMARY_ID=2 or SLAVE_ID=1) and TYPE= 'P' and DEL_FLAG = 0;

# 
--disable_warnings
drop table if exists t1, t2, BB, B, C, CC, table1_bigint;
--enable_warnings
create table t1(pk int primary key, c1 int, c2 int, index idx_c1_c2_pk(c1, c2, pk));
create table t2(pk int primary key, c1 int, c2 int);

select c2 from t1 where t1.c2 = any (select pk from t2 where t2.c1 = t1.c1) or t1.pk = 0;
select c2 from t1 where t1.pk = 0 or t1.c2 = (select min(subq.pk) from (select pk from t2 where t2.c1 = t1.c1 order by pk limit 1) subq);

CREATE TABLE BB (
  col_varchar_10_key varchar(10) DEFAULT NULL,
  col_int int(11) DEFAULT NULL,
  pk int(11) NOT NULL,
  col_int_key int(11) DEFAULT NULL,
  col_varchar_key varchar(1) DEFAULT NULL,
  col_varchar_20_key varchar(20) DEFAULT NULL,
  col_varchar_20 varchar(20) DEFAULT NULL,
  col_varchar_10 varchar(10) DEFAULT NULL,
  col_varchar varchar(1) DEFAULT NULL,
  PRIMARY KEY (pk),
  KEY idx5 (col_varchar_10_key) BLOCK_SIZE 16384,
  KEY idx1 (col_int_key) BLOCK_SIZE 16384,
  KEY idx3 (col_varchar_key) BLOCK_SIZE 16384,
  KEY idx7 (col_varchar_20_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE C (
  col_varchar_20_key varchar(20) DEFAULT NULL,
  col_varchar varchar(1) DEFAULT NULL,
  col_int int(11) DEFAULT NULL,
  pk int(11) NOT NULL,
  col_int_key int(11) DEFAULT NULL,
  col_varchar_20 varchar(20) DEFAULT NULL,
  col_varchar_10_key varchar(10) DEFAULT NULL,
  col_varchar_10 varchar(10) DEFAULT NULL,
  col_varchar_key varchar(1) DEFAULT NULL,
  PRIMARY KEY (pk),
  KEY idx7 (col_varchar_20_key) BLOCK_SIZE 16384,
  KEY idx1 (col_int_key) BLOCK_SIZE 16384,
  KEY idx5 (col_varchar_10_key) BLOCK_SIZE 16384,
  KEY idx3 (col_varchar_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE CC ( col_date_key date DEFAULT NULL,
 col_varchar_20 varchar(20) DEFAULT NULL,
 pk int(11) NOT NULL,
 col_varchar_10_key varchar(10) DEFAULT NULL,
 col_datetime datetime DEFAULT NULL,
 col_varchar_10 varchar(10) DEFAULT NULL,
 col_varchar_20_key varchar(20) DEFAULT NULL,
 col_int int(11) DEFAULT NULL,
 col_int_key int(11) DEFAULT NULL,
 col_datetime_key datetime DEFAULT NULL,
 col_date date DEFAULT NULL,
 PRIMARY KEY (pk),
 KEY idx7 (col_date_key) BLOCK_SIZE 16384,
 KEY idx3 (col_varchar_10_key) BLOCK_SIZE 16384,
 KEY idx5 (col_varchar_20_key) BLOCK_SIZE 16384,
 KEY idx1 (col_int_key) BLOCK_SIZE 16384,
 KEY idx9 (col_datetime_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE B ( col_int_key int(11) DEFAULT NULL,
 col_varchar_20_key varchar(20) DEFAULT NULL,
 col_date_key date DEFAULT NULL,
 col_datetime_key datetime DEFAULT NULL,
 col_varchar_10 varchar(10) DEFAULT NULL,
 col_date date DEFAULT NULL,
 col_varchar_20 varchar(20) DEFAULT NULL,
 pk int(11) NOT NULL,
 col_datetime datetime DEFAULT NULL,
 col_varchar_10_key varchar(10) DEFAULT NULL,
 col_int int(11) DEFAULT NULL,
 PRIMARY KEY (pk),
 KEY idx1 (col_int_key) BLOCK_SIZE 16384,
 KEY idx5 (col_varchar_20_key) BLOCK_SIZE 16384,
 KEY idx7 (col_date_key) BLOCK_SIZE 16384,
 KEY idx9 (col_datetime_key) BLOCK_SIZE 16384,
 KEY idx3 (col_varchar_10_key) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

SELECT MAX(table2.col_varchar) AS field1, COUNT(table1.col_int) AS field2
FROM BB table1
 INNER JOIN C table2 ON table2.col_varchar_key = table1.col_varchar
WHERE table2.col_int_key >= SOME (
  SELECT SUBQUERY1_t1.pk AS SUBQUERY1_field1
  FROM BB SUBQUERY1_t1
  WHERE SUBQUERY1_t1.col_varchar_key != table1.col_varchar_10
   OR SUBQUERY1_t1.col_int < table2.col_int_key
 )
 OR (table1.pk > 86
  AND table1.pk < 86 + 23
  OR table1.pk > 86
  AND table1.pk < 86 + 82)
ORDER BY field2 DESC, field1, field2;

EXPLAIN SELECT DISTINCT OUTR.pk AS X
FROM   c AS OUTR2 LEFT JOIN b AS OUTR ON ( OUTR2.col_varchar_10 <> OUTR.col_varchar_10 )
  WHERE  ( OUTR.col_int_key, OUTR.col_int ) IN (SELECT INNR.pk AS X,
      INNR.col_int AS Y
      FROM   cc AS INNR2
      LEFT JOIN cc AS INNR
      ON ( INNR2.col_date <= INNR.col_date )
      WHERE
      INNR.col_varchar_20 >= INNR.col_varchar_10
      OR INNR.col_int_key = INNR.col_int)
  AND OUTR.col_varchar_20_key > 'm'
  OR OUTR.col_datetime < '2009-04-17'
  ORDER  BY OUTR.col_date,
  OUTR.pk;

