select/**/ * from t2 limit 10;
rollback;

select * from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select /*+NO_REWRITE*/ * from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
insert into is_t1 select a,b,c from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ count(*) from is_t1;
rollback;
insert into is_t1 select /*+NO_REWRITE*/a,b,c from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ count(*) from is_t1;
rollback;
update /*+use_concat*/t2 set t2.a = 100 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ * from t2 limit 10;
rollback;
update /*+no_expand*/t2 set t2.a = 100 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ * from t2 limit 10;
rollback;
delete /*+use_concat*/from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ * from t2 limit 10;
rollback;
delete /*+no_expand*/from t2 where t2.e > any (select e from t1 where t1.a = 1 or t2.b = 1);
select/**/ * from t2 limit 10;
rollback;

## never pull up as semi-anti join
select * from t2 where not exists (select * from t1 where t2.a = 1 or t2.b = 1);
select /*+NO_REWRITE*/ * from t2 where not exists (select * from t1 where t2.a = 1 or t2.b = 1);
