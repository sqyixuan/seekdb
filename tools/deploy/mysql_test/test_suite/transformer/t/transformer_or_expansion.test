SELECT /*+no_expand*/ CC.col_varchar_key FROM CC, B where EXISTS (SELECT 1 FROM BB) OR CC.`col_varchar_key` IN (SELECT /*+use_concat*/ CC.`col_varchar_10_key` FROM CC WHERE EXISTS (SELECT 1 FROM BB) OR EXISTS (SELECT 1 FROM B));
SELECT CC.col_varchar_key FROM CC, B where EXISTS (SELECT 1 FROM BB) OR CC.`col_varchar_key` IN (SELECT CC.`col_varchar_10_key` FROM CC WHERE EXISTS (SELECT 1 FROM BB) OR EXISTS (SELECT 1 FROM B));
SELECT /*+no_rewrite*/CC.col_varchar_key FROM CC, B where EXISTS (SELECT 1 FROM BB) OR CC.`col_varchar_key` IN (SELECT CC.`col_varchar_10_key` FROM CC WHERE EXISTS (SELECT 1 FROM BB) OR EXISTS (SELECT 1 FROM B));

