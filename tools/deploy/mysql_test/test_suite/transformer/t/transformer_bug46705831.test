# owner: sean.yyj
# tags: optimizer
# owner group: sql1

#bugfix:
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
--explain_protocol 1
#subquery in agg
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select EXISTS (select c1 from t1) as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select c1 > ANY (select c1 from t1) as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select c1 > ALL(select c1 from t1) as c0 from t2) as subq_0 ;

#subquery in groupby
select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0 except select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0;
select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0 except select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0;
select group_concat(2),subq_0.c0 from (select c1 > ANY (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0 except select group_concat(2),subq_0.c0 from (select c1 > ANY (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0;
select group_concat(2),subq_0.c0 from (select c1 > ALL (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0 except select group_concat(2),subq_0.c0 from (select c1 > ALL (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0;

#subquery in having
select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select c1 > ANY(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select c1 > ANY(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select c1 > ALL(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select c1 > ANY(select c1 from t1) as c0 from t2) as subq_0 having subq_0.c0 > 0;

#subquery in where
select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select EXISTS(select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select c1 > ANY(select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select c1 > ANY (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0;
select group_concat(2),subq_0.c0 from (select c1 > ALL(select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0 except select group_concat(2),subq_0.c0 from (select c1 > ALL (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0;

#subquery not shared
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),1 from (select (select c1 from t1) as c0 from t2) as subq_0 ;
select group_concat(2),1 from (select (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0 except select group_concat(2),1 from (select (select c1 from t1) as c0 from t2) as subq_0 group by subq_0.c0;
select group_concat(2),1 from (select (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0 except select group_concat(2),1 from (select (select c1 from t1) as c0 from t2) as subq_0 where subq_0.c0 > 0;

#subquery is child expr of a shared expr
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select if(EXISTS(select c1 from t1),1,1) as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select EXISTS(select c1 from t1)+1 as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select (c1 > ANY(select c1 from t1))+1 as c0 from t2) as subq_0 ;
select group_concat(1),1 from t2 except select group_concat(subq_0.c0),subq_0.c0 from (select (c1 > ALL(select c1 from t1))+1 as c0 from t2) as subq_0 ;
--explain_protocol 0
drop table t1;
drop table t2;
