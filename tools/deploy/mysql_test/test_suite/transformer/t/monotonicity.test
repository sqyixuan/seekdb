create table t8(c1 int, c2 varchar(20));
create table t9(c1 int, c2 datetime unique);
insert into t8 values(0, '2024-03-07 14:12:12'),(-1, '2024-03-07 14:12:12');
insert into t9 values(-1, '2024-03-07 14:12:12');
select/*+no_rewrite*/ count(*) from t8 where c1 > (select c1 from t9 where t8.c2 = t9.c2);
select count(*) from t8 where c1 > (select c1 from t9 where t8.c2 = t9.c2);

