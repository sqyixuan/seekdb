# owner : sanquan.qz
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t0,t1,t11,t2,t3,t4,t5,t6,t7,t8,t9;
--enable_warnings

--result_format 4
--explain_protocol 2
create table t0(c1 int, c2 int);
create table t1(c1 int, c2 int unique);

# 2147483647 + 10 在溢出的情况 -2147483639 这里验证不等于
insert into t0 values(-1,10),(0,10),(1,10),(null,10),(0,20),(0,30),(0,null),(1,-2147483639);
insert into t1 values(-1,0),(0,10),(1,11),(0,20),(0,2147483647);
# 结果为2 t0中的0,10和1,10符合条件
select/*+no_rewrite*/ count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = t1.c2 + 10);
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = t1.c2 + 10);

# SCALAR GROUP BY 条件无效 结果为0
select count(*) from t0 where c1 > (select c1 from t1 where null = t1.c2 + 10);
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = t1.c2 + null);

# 不能做子查询提升没有单调性
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = abs(t1.c2) + 10);
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = t1.c2 * 2 + 10);
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = t1.c2 / 2 + 10);

# 单调递减
select/*+no_rewrite*/ count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = 20 - t1.c2);
select count(*) from t0 where c1 > (select c1 from t1 where t0.c2 = 20 - t1.c2);

create table t11(c1 int, c2 int not null unique);
insert into t11 values(-1,0),(0,10),(1,11),(0,20),(0,2147483647);
select count(*) from t0 where c1 > (select c1 from t11 where t0.c2 = 20 - t11.c2);
select /*+no_rewrite*/ count(*) from t0 where c1 > (select c1 from t11 where t0.c2 = 20 - t11.c2);

# 目前尚未讨论清楚是否需要把lossless cast的单调性不放开
create table t6(c1 decimal, c2 decimal(32,20));
create table t7(c1 decimal, c2 decimal(32,20) unique);
--disable_warnings
insert into t6 values(5.2, 10.1),(null, 10.1),(5.2, null),(6, 10.0000000000000000001);
insert into t7 values(4.2, 0.1), (3.2, 0.0000000000000000001);
--enable_warnings
select/*+no_rewrite*/ count(*) from t6 where c1 > (select c1 from t7 where t6.c2 = t7.c2 + 10);
select count(*) from t6 where c1 > (select c1 from t7 where t6.c2 = t7.c2 + 10);
select/*+no_rewrite*/ count(*) from t6 where c1 > (select c1 from t7 where t6.c2 = t7.c2 + floor(t7.c2));
select count(*) from t6 where c1 > (select c1 from t7 where t6.c2 = t7.c2 + floor(t7.c2));

create table t2(c1 int, c2 varchar(256) COLLATE utf8mb4_bin);
create table t3(c1 int, c2 varchar(256) COLLATE utf8mb4_bin unique);
insert into t2 values(2,'Q'),(0,'q'),(-1,'q'),(1,'q'),(null,'Q'),(1,null),(1,'aaa');
insert into t3 values(-1,'q'),(-1,'aaaaa');
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, 3));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, 3));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 2, 3));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 2, 3));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, null));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, null));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, null, 1));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, null, 1));
drop table t2,t3;

# 下面的用例暂时没用,能识别出const。但是由于子查询提升是is_strict是true不能提升。
create table t2(c1 int, c2 varchar(256) COLLATE utf8mb4_unicode_ci);
create table t3(c1 int, c2 varchar(256) COLLATE utf8mb4_unicode_ci unique);
insert into t2 values(2,'Q'),(0,'q'),(-1,'q'),(1,'q'),(null,'Q'),(1,null),(1,'aaa');
insert into t3 values(-1,'q'),(-1,'aaaaa');
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = UPPER(t3.c2));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = UPPER(t3.c2));
# 下面用例得不到提升因为不是严格单调的
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, 3));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, 3));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 2, 3));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 2, 3));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, null));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, 1, null));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, null, 1));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = SUBSTR(t3.c2, null, 1));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = LEFT(t3.c2, 2));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = LEFT(t3.c2, 2));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = LEFT(t3.c2, -1));
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = LEFT(t3.c2, -1));
drop table t2,t3;

create table t2(c1 int, c2 varchar(256) COLLATE GB18030_CHINESE_CI);
create table t3(c1 int, c2 varchar(256) COLLATE GB18030_CHINESE_CI unique);
insert into t2 values(2,'Q'),(0,'q'),(-1,'q'),(1,'q'),(null,'Q'),(1,null),(1,'aaa');
insert into t3 values(-1,'q'),(-1,'aaaaa');
select/*+no_rewrite*/ count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = UPPER(t3.c2));
select count(*) from t2 where c1 > (select c1 from t3 where t2.c2 = UPPER(t3.c2));
drop table t2,t3;


