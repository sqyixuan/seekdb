# owner: tuliwei.tlw
# onwer group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE IF EXISTS dw_sdp_kpi_sale_prod_month_product_rep, dw_sdp_kpi_sale_prod_month_product_all;
--enable_warnings

CREATE TABLE `dw_sdp_kpi_sale_prod_month_product_rep` (
  `calendar_start_day_of_month` datetime DEFAULT NULL,
  `mtd_month` datetime DEFAULT NULL,
  `sell_barcode` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sell_barcode 也称 ean_code',
  `category_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'category_en',
  `brand_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'brand_en',
  `segment_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'product_form_en',
  `size_new` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sap_size_total 把G替换为ML',
  `east_variant` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'east_variant',
  `sku_type` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sku_type',
  `full_variant_cn` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '系列中文全称',
  `dp_variant_name` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Variant Name',
  `calendar_month_abbrevation_name` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `store_nskey` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `product_name_cn` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品中文名',
  `giv` decimal(38,8) DEFAULT NULL,
  `giv_ya` decimal(38,8) DEFAULT NULL,
  `p3rolling_giv` decimal(38,8) DEFAULT NULL,
  `top_sku_type` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `perfect_store_campaign` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(each column);

CREATE TABLE `dw_sdp_kpi_sale_prod_month_product_all` (
  `calendar_start_day_of_month` datetime DEFAULT NULL,
  `mtd_month` datetime DEFAULT NULL,
  `sell_barcode` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sell_barcode 也称 ean_code',
  `category_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'category_en',
  `brand_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'brand_en',
  `segment_en` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'product_form_en',
  `size_new` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sap_size_total 把G替换为ML',
  `east_variant` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'east_variant',
  `sku_type` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'sku_type',
  `full_variant_cn` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '系列中文全称',
  `dp_variant_name` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Variant Name',
  `calendar_month_abbrevation_name` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `store_nskey` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `product_name_cn` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '产品中文名',
  `giv` decimal(38,8) DEFAULT NULL,
  `giv_ya` decimal(38,8) DEFAULT NULL,
  `p3rolling_giv` decimal(38,8) DEFAULT NULL,
  `top_sku_type` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL,
  `perfect_store_campaign` varchar(512) COLLATE utf8mb4_bin DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(each column);

--explain_protocol 1
--result_format 4

update 
  dw_sdp_kpi_sale_prod_month_product_rep M
set 
  sell_barcode = (
    select 
      '1' 
    from 
      dw_sdp_kpi_sale_prod_month_product_all A
  ), 
  full_variant_cn = (
    select 
      '2' 
    from 
      dw_sdp_kpi_sale_prod_month_product_rep B
  ), 
  calendar_month_abbrevation_name = M.sell_barcode, 
  product_name_cn = case when EXISTS (
    select 
      1 
    from 
      dw_sdp_kpi_sale_prod_month_product_rep as ref_3
  ) then (
    select 
	  /*+ unnest */
      max(sell_barcode) 
    from 
      dw_sdp_kpi_sale_prod_month_product_rep C
  ) else M.calendar_month_abbrevation_name end, 
  p3rolling_giv = (
    select 
      1 
    from 
      dw_sdp_kpi_sale_prod_month_product_all D
  );

DROP TABLE IF EXISTS dw_sdp_kpi_sale_prod_month_product_rep, dw_sdp_kpi_sale_prod_month_product_all;