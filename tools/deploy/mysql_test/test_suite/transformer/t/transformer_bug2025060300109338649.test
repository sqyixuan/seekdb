# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: or expansion 走前缀索引

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_CBQT_IGNORE_COST", error_code = 1, frequency = 1;
connection default;

--disable_warnings
drop table if exists tt, tt2;
--enable_warnings

create table tt (c1 int, c2 int, c3 int, c4 int, c5 int, c6 varchar(100), key i1(c1), key i2(c2), key i3(c3), key i4(c4), key i5(c5), key i6(c6(50)));
insert into tt select uniform(1,10000,random(1)), uniform(1,10000,random(1)), uniform(1,10000,random(1)), uniform(1,10000,random(1)), uniform(1,10000,random(1)), uniform(1,10000,random(1)) from table(generator(10000));
-- echo # 预期可以走 or expansion, c6 会走前缀索引
explain outline select * from tt where c1 = 1 or c2 = 1 or c3 = 1 or c4 = 1 or c5 = 1 or c6 = 'bbbb';

create table tt2(a int, b varchar(30), key ia(a), key ib(b(5)));
-- echo # 预期可以走 or expansion, b 列会走前缀索引
explain outline select * from tt2 where a = 1 or b = 'aaa';

connection obsys;
alter system set_tp tp_name = "EN_CBQT_IGNORE_COST", error_code = 0, frequency = 0;
connection default;

drop table tt, tt2;