# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1; 
--enable_warnings

create table t1 (c1 int(255) zerofill, c2 longtext);
INSERT INTO t1 VALUES (1,'ss');

select sum(c1), c1+1 from t1;

select degrees(sum(c1)) from t1;

select concat(c1, c2) from t1;

drop table t1;