# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 varchar(100), fulltext index ftx(c2));
insert into t1 values (1, "hello world"), (2, "hello world"), (3, "hello world");

--explain_protocol 2
--result_format 4

select /*+use_concat*/ (select max(c1) from t1) from t1 where exists (select c1 from t1) or exists (select c2 from t1);
select /*+no_rewrite*/ (select max(c1) from t1) from t1 where exists (select c1 from t1) or exists (select c2 from t1);

drop table t1;