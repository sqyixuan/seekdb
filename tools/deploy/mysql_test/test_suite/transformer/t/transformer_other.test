#case 1 exists without correlated exprs
--sorted_result
select * from t1 where Exists (select c1 from t2);

#case 2 ANY without correlated exprs
--sorted_result
select * from t1 where c1 In (select c1 from t2);

--sorted_result
select * from t1 where c1 =ANY (select c1 from t2);

--sorted_result
select * from t1 where c1 >ANY (select c1 from t2);

#case 3 ALL without correlated exprs
#can be pulled up
--sorted_result
select * from t1 where c1 <ALL (select c1 from t2);
#can not be pulled up
--sorted_result
select * from t1 where c1 <ALL (select c1 from t2 limit 1);

##case 4 subquery-expr without correlated vars
##can be pulled up
--sorted_result
select * from t1 where 1 < ANY(select c1 from t2);
##can not be pulled up
--sorted_result
select * from t1 where 1 < ANY(select c1 from t2 limit 1);

##case 5 multi-level subquery without correlated expr
--sorted_result
select * from t1 where Exists (select c1 from t2 where c2 >ALL (select c1 from t3));

##case subquery with left_hand = row
--sorted_result
select * from t1 where (t1.c1, t1.c2) in (select c1,c2 from t2);
explain  select * from t1 where (t1.c1, t1.c2) in (select c1,c2 from t2);

--sorted_result
select * from t1 where (t1.c1, t1.c2) not in (select c1,c2 from t2);
explain  select * from t1 where (t1.c1, t1.c2) not in (select c1,c2 from t2);

--sorted_result
select * from t1 where (t1.c1, t1.c2) = ANY(select c1,c2 from t2 where c3 > 'a');
explain  select * from t1 where (t1.c1, t1.c2) = ANY(select c1,c2 from t2 where c3 > 'a');

--sorted_result
select * from t1 where (t1.c1, t1.c2) != ANY(select c1,c2 from t2 where c3 > 'b');
explain  select * from t1 where (t1.c1, t1.c2) != ANY(select c1,c2 from t2 where c3 > 'b');

--sorted_result
select * from t1 where (t1.c1, t1.c2) = ALL(select c1,c2 from t2 where c3 < 'f');
explain  select * from t1 where (t1.c1, t1.c2) = ALL(select c1,c2 from t2 where c3 < 'f');

--sorted_result
select * from t1 where (t1.c1, t1.c2) != ALL(select c1,c2 from t2 where c3 < 'd');
explain  select * from t1 where (t1.c1, t1.c2) != ALL(select c1,c2 from t2 where c3 < 'd');

--sorted_result
select * from t1 where (t1.c1, t1.c2) != ANY(select c1,c2 from t2 where t1.c2 = t2.c2);
explain  select * from t1 where (t1.c1, t1.c2) != ANY(select c1,c2 from t2 where t1.c2 = t2.c2);

--sorted_result
select * from t1 where (t1.c1, t1.c2) = ALL(select c1,c2 from t2 where t1.c1 > t2.c1);
explain  select * from t1 where (t1.c1, t1.c2) = ALL(select c1,c2 from t2 where t1.c1 > t2.c1);

--sorted_result
select * from t3 where (t3.c1, t3.c2, t3.c3) in (select c1,c2,c3 from t2 where t3.c3 <> t2.c3);
explain  select * from t3 where (t3.c1, t3.c2, t3.c3) in (select c1,c2,c3 from t2 where t3.c3 <> t2.c3);

