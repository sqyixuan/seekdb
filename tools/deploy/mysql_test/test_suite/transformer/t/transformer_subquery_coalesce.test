## multiple exists and not exists
select l.numeric from t1_100 l where
exists (select 1 from t2_100 r1 where l.ten > r1.ten and r1.hundred < 10) and
exists (select 1 from t2_100 r1 where l.ten > r1.ten and r1.hundred < 10 and r1.hundred > 5) and
not exists (select 1 from t2_100 r2 where l.ten > r2.ten and l.hundred = r2.hundred and r2.hundred < 10) and
not exists (select 1 from t2_100 r2 where l.ten > r2.ten and l.hundred = r2.hundred and r2.hundred < 10 and r2.hundred > 5) order by l.numeric limit 5;

