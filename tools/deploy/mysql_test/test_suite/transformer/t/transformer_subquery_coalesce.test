--source mysql_test/include/sql_import_opt_wisconsin.inc
--result_format 4
--explain_protocol 2

USE OPT_WISCONSIN;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 double, c2 decimal(10,0), c3 double);

--disable_query_log
--disable_result_log
insert/**/ into t1 values(1.0,1.0,1.0);
insert/**/ into t1 values(2.0,2.0,2.0);
insert/**/ into t1 values(3.0,3.0,3.0);
select count(*) from t1;
--enable_query_log
--enable_result_log

set autocommit=0;
##basic result
select/**/ count(*) from t1;
select/**/ stddev(ten) from t1_100;
select/**/ stddev(ten) from t1_100;

## exists and not exists
select l.numeric from t1_100 l where exists (select 1 from t2_100 r1 where l.ten = r1.ten) and not exists (select 1 from t2_100 r2 where l.ten = r2.ten and l.hundred = r2.hundred) order by l.numeric limit 5;
