# owner: maolai.cy
# owner group: SQL1
# tags: optimizer


--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 decimal(20,0), c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int);

--explain_protocol 1
--result_format 4

create table tmp as select /*+NO_PLACE_GROUP_BY*/sum(t1.c1) as a, sum(t1.c2) as b from t1, t2 where t1.c4 = t2.c2 group by t1.c3;

create table tmp2 as select sum(t1.c1) as a, sum(t1.c2) as b from t1, t2 group by t1.c3;

desc tmp2;

desc tmp;

drop table t1;
drop table t2;
drop table tmp;
drop table tmp2;