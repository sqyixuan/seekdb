SELECT col_varchar_20_key FROM C WHERE 
(SELECT MAX(SUBQUERY1_t1 . `pk`) AS SUBQUERY1_field1 
FROM (B AS SUBQUERY1_t1 RIGHT OUTER JOIN (C AS SUBQUERY1_t2 INNER JOIN C AS SUBQUERY1_t3
    ON (SUBQUERY1_t3 . `col_varchar_20_key` in 
    (SELECT CHILD_SUBQUERY1_t2 . `col_varchar_key` AS CHILD_SUBQUERY1_field1 
            FROM C AS CHILD_SUBQUERY1_t2 WHERE (CHILD_SUBQUERY1_t2 . `col_varchar_10` > 'r')))) 
                  ON (SUBQUERY1_t3 . `pk` = 1))) IS NULL;

