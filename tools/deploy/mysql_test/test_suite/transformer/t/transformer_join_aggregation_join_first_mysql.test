SELECT * FROM TC WHERE C1 > (SELECT COUNT(1 + NULL) FROM TD WHERE C2 > D2);
SELECT /*+no_rewrite*/ * FROM TC WHERE C1 > (SELECT COUNT(1 + NULL) FROM TD WHERE C2 > D2);

SELECT * FROM TC WHERE C1 > (SELECT COUNT(case when 1 then null else 1 end) FROM TD WHERE C2 > D2);
SELECT /*+no_rewrite*/ * FROM TC WHERE C1 > (SELECT COUNT(case when 1 then null else 1 end) FROM TD WHERE C2 > D2);

SELECT * FROM TC WHERE (SELECT MIN(D1) FROM TD WHERE C2 > D2) AND (SELECT MAX(D1) FROM TD WHERE C2 > D2);
SELECT /*+no_rewrite*/ * FROM TC WHERE (SELECT MIN(D1) FROM TD WHERE C2 > D2) AND (SELECT MAX(D1) FROM TD WHERE C2 > D2);

