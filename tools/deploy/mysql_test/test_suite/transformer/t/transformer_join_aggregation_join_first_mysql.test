SELECT  table1 . col_varchar_10_key AS field1,
       table1 . `col_int` AS field2
FROM (C AS table1
      RIGHT  JOIN ((
                      (SELECT SUBQUERY1_t2 . *
                       FROM (C AS SUBQUERY1_t1
                             INNER JOIN D AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int`))) AS table2
                    INNER JOIN C AS table3 ON (table3 . `pk` = table2 . `col_int_key`))) ON (table3 . `col_varchar` = table2 . `col_varchar_key`))
WHERE (
         (SELECT SUM(SUBQUERY2_t1 . `col_int_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_int` = SUBQUERY2_t1 . `pk`
                                                  OR SUBQUERY2_t1 . `col_int_key` IN
                                                    (SELECT 9
                                                     UNION SELECT 2)))) IS NULL)
  AND table1 . `col_varchar_key` != 'x'
GROUP BY field1,
         field2
ORDER BY field1,
         field2
LIMIT 10
OFFSET 6;
 
SELECT /*+no_rewrite*/ table1 . col_varchar_10_key AS field1,
       table1 . `col_int` AS field2
FROM (C AS table1
      RIGHT  JOIN ((
                      (SELECT SUBQUERY1_t2 . *
                       FROM (C AS SUBQUERY1_t1
                             INNER JOIN D AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int`))) AS table2
                    INNER JOIN C AS table3 ON (table3 . `pk` = table2 . `col_int_key`))) ON (table3 . `col_varchar` = table2 . `col_varchar_key`))
WHERE (
         (SELECT SUM(SUBQUERY2_t1 . `col_int_key`) AS SUBQUERY2_field1
          FROM (CC AS SUBQUERY2_t1
                INNER JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_int` = SUBQUERY2_t1 . `pk`
                                                  OR SUBQUERY2_t1 . `col_int_key` IN
                                                    (SELECT 9
                                                     UNION SELECT 2)))) IS NULL)
  AND table1 . `col_varchar_key` != 'x'
GROUP BY field1,
         field2
ORDER BY field1,
         field2
LIMIT 10
OFFSET 6;

