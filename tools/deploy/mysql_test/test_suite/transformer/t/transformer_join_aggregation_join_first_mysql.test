--disable_warnings
drop table if exists table1_bigint, table1_key_pk_parts_4_bigint;
--enable_warnings
CREATE TABLE `table1_bigint` (
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_bigint_index` bigint(20) DEFAULT NULL,
  `col_char_20_index` char(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_timestamp_6_index` timestamp(6) NULL DEFAULT NULL,
  `col_char_20` char(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_bigint_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`pk`, `col_char_20_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`pk`, `col_timestamp_6_index`) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `table1_key_pk_parts_4_bigint` (
  `col_bigint_signed` bigint(20) DEFAULT NULL,
  `col_decimal_20_0_unsigned` decimal(20,0) unsigned DEFAULT NULL,
  `col_bigint_unsigned` bigint(20) unsigned DEFAULT NULL,
  `col_decimal_20_0_signed` decimal(20,0) DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_char_20` char(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  PRIMARY KEY (`pk`)
);
UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ table1_bigint SET pk = ROUND( ROUND( 0 ) ) , col_bigint = ROUND( ROUND( col_bigint ) ) / ( SELECT coalesce( (SELECT * FROM ( SELECT pk FROM table1_key_pk_parts_4_bigint WHERE CAST( CONCAT( col_char_20 , SUBSTR( 'e' , 1, 20) ) AS CHAR) = col_char_20_index ORDER BY pk DESC LIMIT 1 ) TC1), (SELECT * FROM ( SELECT LENGTH( REPEAT( CAST( 3 AS CHAR(20) ) , 4 + 1 ) ) ) TC2), -99999 ) ) WHERE DATE_ADD( col_timestamp_6_index , INTERVAL '5.000005' SECOND_MICROSECOND ) <> col_timestamp_6_index ORDER BY col_bigint_index ASC , col_char_20_index  , pk DESC LIMIT 6;
#简化sql
UPDATE table1_bigint SET col_bigint = (SELECT a.pk FROM table1_key_pk_parts_4_bigint a WHERE a.col_char_20 = col_char_20_index LIMIT 1) ORDER BY pk;
drop table table1_bigint, table1_key_pk_parts_4_bigint;