SELECT   ( SELECT   SUM(  SUBQUERY1_t1 . `col_int_key` ) AS SUBQUERY1_field1 FROM ( C AS SUBQUERY1_t1 INNER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`  ) ) WHERE SUBQUERY1_t2 . `pk` < table1 . `col_int` ) AS field1 , table1 . `col_int` AS field2 ,  ( SELECT   COUNT(  SUBQUERY2_t1 . `pk` ) AS SUBQUERY2_field1 FROM C AS SUBQUERY2_t1 WHERE SUBQUERY2_t1 . `pk` < table1 . `col_int_key` ) AS field3 FROM ( BB AS table1 RIGHT  JOIN CC AS table2 ON (table2 . `col_int_key` = table1 . `col_int_key`  ) ) WHERE (  table1 . `col_int` <> SOME ( SELECT 1 UNION  SELECT 7 ) ) AND table1 . `col_varchar_key` = 'j'  GROUP BY field1, field2, field3  ORDER BY field1, field2, field3;

SELECT /*+no_rewrite*/    ( SELECT   SUM(  SUBQUERY1_t1 . `col_int_key` ) AS SUBQUERY1_field1 FROM ( C AS SUBQUERY1_t1 INNER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`  ) ) WHERE SUBQUERY1_t2 . `pk` < table1 . `col_int` ) AS field1 , table1 . `col_int` AS field2 ,  ( SELECT   COUNT(  SUBQUERY2_t1 . `pk` ) AS SUBQUERY2_field1 FROM C AS SUBQUERY2_t1 WHERE SUBQUERY2_t1 . `pk` < table1 . `col_int_key` ) AS field3 FROM ( BB AS table1 RIGHT  JOIN CC AS table2 ON (table2 . `col_int_key` = table1 . `col_int_key`  ) ) WHERE (  table1 . `col_int` <> SOME ( SELECT 1 UNION  SELECT 7 ) ) AND table1 . `col_varchar_key` = 'j'  GROUP BY field1, field2, field3  ORDER BY field1, field2, field3;

