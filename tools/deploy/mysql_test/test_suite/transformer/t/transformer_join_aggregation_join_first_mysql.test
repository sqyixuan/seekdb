insert into t2 values (30,25,20, 6);
insert into t2 values (40,35,30, 7);
insert into t2 values (40,35,30, 8);
insert into t2 values (50,45,40, null);
insert into t2 values (50,45,40, null);

insert into t3 values (10, 5, 0, 1);
insert into t3 values (10, 5, 0, 2);
insert into t3 values (20,15,10, 3);
insert into t3 values (20,15,10, null);
insert into t3 values (30,25,20, 5);
insert into t3 values (30,25,20, 6);
insert into t3 values (40,35,30, 7);
insert into t3 values (40,35,30, null);

insert into t4 values (10, 5, 0, 1);
insert into t4 values (20,15,10, 3);
insert into t4 values (30,25,20, 5);
insert into t4 values (40,35,30, 7);

insert into t5 values (1,1,null);
insert into t5 values (2,2,null);
insert into t5 values (3,3,1);

insert into t6 values (1,1,null);
insert into t6 values (2,2,null);
insert into t6 values (3,3,1);

insert into t7 values (1,1,null);
insert into t7 values (2,2,null);
insert into t7 values (3,3,null);

--enable_query_log
--source mysql_test/include/minor_merge_tenant.inc
analyze table t1 compute statistics for all columns size auto;
analyze table t2 compute statistics for all columns size auto;
analyze table t3 compute statistics for all columns size auto;
analyze table t4 compute statistics for all columns size auto;
analyze table t5 compute statistics for all columns size auto;
analyze table t6 compute statistics for all columns size auto;
analyze table t7 compute statistics for all columns size auto;
analyze table t_insert compute statistics for all columns size auto;
analyze table lineitem compute statistics for all columns size auto;

set autocommit=0;
--explain_protocol 2
--result_format 4

--echo # spj with different subquery comparision op
select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/ avg(c2) from t2 where t2.c1 > t1.c1);

insert into t_insert(c1,c2,c3,c4) select * from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
select * from t_insert;
rollback;

insert into t_insert(c1,c2,c3,c4) select /*+no_unnest(@qb1)*/ * from t1 where 2 * t1.c2 > (select /*+qb_name(qb1)*/ avg(c2) from t2 where t2.c1 > t1.c1);
select * from t_insert;
rollback;

update t1 set c4 = 100 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
select stddev(c4) from t1;
rollback;

update /*+no_unnest(@qb1)*/ t1 set c4 = 100 where 2 * t1.c2 > (select /*+qb_name(qb1)*/ avg(c2) from t2 where t2.c1 > t1.c1);
