--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
#description: test transform with nested subquery

--explain_protocol 2
--result_format 4

## bug: 
--disable_warnings
drop table if exists t1, t2, t3, obschema_t_nl3dunxw, obschema_t_t9, obschema_t_de;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);

--disable_query_log
--disable_result_log
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 2, 3);
insert into t1 values (4, 6, 4);
insert into t1 values (5, 4, 3);
insert into t1 values (6, 4, 2);
insert into t2 values (1, 1, 1);
insert into t2 values (2, 2, 2);
insert into t2 values (3, 2, 3);
insert into t2 values (4, 6, 4);
insert into t2 values (5, 4, 3);
insert into t2 values (6, 4, 2);
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

## nested subquery in order by
select c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 order by (select a from t2 tt2 limit 1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 order by (select a from t2 tt2 limit 1));
select c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 order by (select c2 from t2 tt2 where a = c1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 order by (select /*+no_rewrite*/ c2 from t2 tt2 where a = c1));
select c1 from (select c1, (select c1 from t2 tt1 where c2 = t1.c1 limit 1) a from t1 order by (select a from t2 tt2 limit 1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 where c2 = t1.c1 limit 1) a from t1 order by (select a from t2 tt2 limit 1));

select c1, (select c2 from t2 tt1 limit 1) a from t1 order by (select c2 from t2 tt2 where c1 = a);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 limit 1) a from t1 order by (select /*+no_rewrite*/ c2 from t2 tt2 where c1 = a);
select c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 order by (select c2 from t2 tt2 where c1 = a);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 order by (select /*+no_rewrite*/ c2 from t2 tt2 where c1 = a);
select c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 order by (select a from t2 tt2 limit 1);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 order by (select a from t2 tt2 limit 1);

## nested subquery in group by
select c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 group by (select a from t2 tt2 limit 1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 group by (select a from t2 tt2 limit 1));
select c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 group by (select c2 from t2 tt2 where a = c1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 limit 1) a from t1 group by (select /*+no_rewrite*/ c2 from t2 tt2 where a = c1));
select c1 from (select c1, (select c1 from t2 tt1 where c2 = t1.c1 limit 1) a from t1 group by (select a from t2 tt2 limit 1));
select /*+no_rewrite*/ c1 from (select c1, (select c1 from t2 tt1 where c2 = t1.c1 limit 1) a from t1 group by (select a from t2 tt2 limit 1));

select c1, (select c2 from t2 tt1 limit 1) a from t1 group by (select c2 from t2 tt2 where c1 = a);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 limit 1) a from t1 group by (select /*+no_rewrite*/ c2 from t2 tt2 where c1 = a);
select c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 group by (select c2 from t2 tt2 where c1 = a);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 group by (select /*+no_rewrite*/ c2 from t2 tt2 where c1 = a);
select c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 group by (select a from t2 tt2 limit 1);
select /*+no_rewrite*/ c1, (select c2 from t2 tt1 where c1 = t1.c1) a from t1 group by (select a from t2 tt2 limit 1);

--disable_query_log
--disable_result_log
drop table t1;
drop table t2;

create table t1 (c1 int);
create table t3 (c1 DATETIME,c2 YEAR(4) ,c3 TIME,c4 TIMESTAMP(2)  NOT NULL default 0,c5 INT(127) ,c6 YEAR(4) ,c7 DATE,c8 VARCHAR(86) ,c9 NUMERIC(64,7) ,c10 YEAR(4) ,c11 TIMESTAMP(3)  NOT NULL default 0,c12 DATE,c13 TIME,c14 NUMERIC(64,28) ,c15 BIGINT generated always as (c5 + c5))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c15) PARTITIONS 10;
CREATE TABLE `obschema_t_nl3dunxw` (`obschema_c_0_MC3` int(255), PRIMARY KEY (`obschema_c_0_MC3`));
CREATE TABLE `obschema_t_t9` (`obschema_c_22_2` float NOT NULL, KEY `obschema_i_0_rpZ5i` (`obschema_c_22_2`));
CREATE TABLE `obschema_t_de` (`obschema_c_13_qns` varchar(150));

--enable_query_log
--enable_result_log

explain WITH cte AS (SELECT 1 AS c1, 1 IN (SELECT 1 FROM t1) AS c2 FROM (SELECT 1 FROM t1) AS subq_1) SELECT 1 FROM cte AS ref_1 WHERE EXISTS (SELECT 1 FROM cte AS ref_2 WHERE ref_1.c1 != ref_2.c2);
UPDATE /*+multi_table_complicated_multi_index_table_recall_case.yaml ENABLE_PARALLEL_DML PARALLEL(7) */ t3 SET c11=c11, c12=c12, c1=(SELECT MAX(t3.c1) FROM t3) WHERE c11 in (select /*+multi_table_complicated_multi_index_table_recall_case.yaml no_use_px */ c11 from (select /*+multi_table_complicated_multi_index_table_recall_case.yaml  LEFT_TO_ANTI(B, A) NO_USE_NL_MATERIALIZATION(A) leading(B,A) use_hash(B,A)*/ (select max(A.c11) from t3 A limit 1) c11, A.c12 c12_alias, A.c1 c1_alias_1 from t3 A left join t3 B on A.c11=B.c11 where B.c11 is null) where c11 in (timestamp'2002-5-1 22:24:1') or c12_alias not in (date'2060-10-16') order by 1 desc);
select   subq_1.c0 + ( select max(obschema_c_0_MC3) from obschema_t_nl3dunxw) from   (     select       subq_0.c0 as c0,       max(null) over (partition by subq_0.c0) as c3     from       (         select           ref_0.obschema_c_13_qns as c0         from obschema_t_de as ref_0       ) as subq_0   ) as subq_1 where   EXISTS (     select       subq_1.c3 as c0     from obschema_t_t9 as ref_2   ) > (     select       max(obschema_c_0_MC3)     from obschema_t_nl3dunxw);

drop table t1;
drop table t3;
drop table obschema_t_nl3dunxw;
drop table obschema_t_t9;
drop table obschema_t_de;