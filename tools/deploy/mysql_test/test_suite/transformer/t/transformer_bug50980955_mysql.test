# issue: 
 
 
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
 
CREATE TABLE T1 (c1 int, c2 int, c3 int);
CREATE TABLE T2 (c1 int, c2 int, c3 int);
CREATE TABLE T3 (c1 int, c2 int, c3 int);
 
--result_format 4
--explain_protocol 2
 
EXPLAIN OUTLINE SELECT T3.c1, V.c2
FROM T2, (
    select T1.c1, T1.c2
    from T1, T2
    where T1.c1 = T2.c1
  UNION ALL
    select T1.c1, T1.c2
    from T1, T3
    where T1.c1 = T3.c1
) V, T3
WHERE V.c1 = T2.C1 AND T2.c1 = 0;
 
drop table t1, t2, t3;
 
 
connect (obsys,$OBMYSQL_MS0,admin@sys,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
 
connection obsys;
 
