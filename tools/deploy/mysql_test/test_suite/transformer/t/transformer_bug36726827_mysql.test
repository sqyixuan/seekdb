##

--result_format 4
--explain_protocol 2

## bug: 

--disable_warnings
drop table if exists t0, t1;
--enable_warnings

CREATE TABLE t0(c0 int) ;
CREATE TABLE t1(c1 int, c2 int);

--disable_query_log
--disable_result_log
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
select count(*) from t1;
--enable_query_log
--enable_result_log

SELECT t0.c0 FROM t0 WHERE !GREATEST(null, 0 ) IN (0.0, 1) ORDER BY TRUE LIMIT 0, 1;

select * from t1 where c1 in (1, 2.0);
select * from t1 where c1 not in (1, 2.0);
select * from t1 where (c1, c2) in ((1, 1), (2, 2.0));
select * from t1 where (c1, c2) not in ((1, 1), (2, 2.0));

drop table t0;
drop table t1;