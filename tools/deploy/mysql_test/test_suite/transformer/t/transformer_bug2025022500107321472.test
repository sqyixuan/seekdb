# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: aggr 子查询提升暂时不能改写 select item 全是常量的子查询

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(c1 FLOAT NULL);

--explain_protocol 2
--result_format 4

--echo # 不应该做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when 1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
--echo # 不应该做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when c1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;

--echo # 可以做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
--echo # 可以做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when c1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when c1 in (select c1 FROM t1) then 1 else 0 end FROM t1;

--disable_query_log
insert into t1 values(1);
--enable_query_log

--echo # 不应该做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when 1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
--echo # 不应该做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when c1 in (select 1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;

--echo # 可以做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when 1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
--echo # 可以做子查询提升
select /*+NO_SIMPLIFY_SUBQUERY*/ case when c1 in (select c1 FROM t1) then 1 else 0 end FROM t1;
select /*+NO_REWRITE*/ case when c1 in (select c1 FROM t1) then 1 else 0 end FROM t1;


drop table t1;