# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1 (a1 int, b1 int);
create table t2 (a2 int, b2 int);
create table t3 (a3 int, b3 int);
insert into t1 select uniform(1,5,random(1)), uniform(1,10,random(1)) from table(generator(20));
insert into t1 values (NULL, NULL), (NULL, NULL);
insert into t2 select uniform(1,5,random(2)), uniform(1,10,random(2)) from table(generator(20));
insert into t2 values (NULL, NULL), (NULL, NULL);
insert into t3 select uniform(1,5,random(3)), uniform(1,10,random(3)) from table(generator(20));

--result_format 4
--explain_protocol 1

select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);
select a1 from t1 where a1 >= (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a1 >= 4);

select a1 from t1 group by a1, b1 having a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);
select a1 from t1 group by a1, b1 having a1 >= (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a1 >= 4);

select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4 group by b2);
select a1 from t1 where a1 >= (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a1 >= 4 group by b2);

select a1 from t1 where a1 >= (select count(*) from t2 where b1 = b2 and a1 >= 4 group by b2);
select a1 from t1 where a1 >= (select /*+no_unnest*/ count(*) from t2 where b1 = b2 and a1 >= 4 group by b2);

select count(*) from t1 where a1 >= (select count(a2) from t2 where b1 = b2 and a1 >= 4);
select count(*) from t1 where a1 >= (select /*+no_unnest*/ count(a2) from t2 where b1 = b2 and a1 >= 4);

select (select max(a2) from t2 where b1 = b2 and a1 >= 4 group by b2) as cnt from t1;
select (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a1 >= 4 group by b2) as cnt from t1;

select (select count(a2) from t2 where b1 = b2 and a1 >= 4 group by b2) as cnt from t1;
select (select /*+no_unnest*/ count(a2) from t2 where b1 = b2 and a1 >= 4 group by b2) as cnt from t1;

select (select count(a2) from t2 where b1 = b2 and a1 >= 4) as cnt from t1;
select (select /*+no_unnest*/ count(a2) from t2 where b1 = b2 and a1 >= 4) as cnt from t1;

select (select max(a2) from t2 where b1 = b2 and a1 >= 4) as cnt from t1;
select (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a1 >= 4) as cnt from t1;

select (select max(a1) from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a3 >= 4)) as d from t3 limit 10;
select (select max(a1) from t1 where a1 >= (select /*+no_unnest*/ max(a2) from t2 where b1 = b2 and a3 >= 4)) as d from t3 limit 10;

set OPTIMIZER_FEATURES_ENABLE = '4.3.1.0';
explain select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);
set OPTIMIZER_FEATURES_ENABLE = '4.2.3.0';
explain select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);
set OPTIMIZER_FEATURES_ENABLE = '4.2.1.7';
explain select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);
set OPTIMIZER_FEATURES_ENABLE = '4.2.4.0';
explain select a1 from t1 where a1 >= (select max(a2) from t2 where b1 = b2 and a1 >= 4);

drop table t1, t2, t3;