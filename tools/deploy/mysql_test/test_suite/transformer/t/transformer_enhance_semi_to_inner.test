#inner group by with tables not used in semi condition
create table t1(pk int primary key, c1 int, c2 varchar(30));
create table t2(pk int primary key, c1 int, c2 varchar(30));
create table t3(pk int primary key, c1 int, c2 varchar(30));
create table t4(pk int primary key, c1 int, c2 varchar(30));
insert into t1 values(1,1,'aaaaaaaaaaaaaaa');
insert into t1 values(2,2,'bbbbbbbbbbbbbbb');
insert into t2 values(4,4,'aaaaaaaaaaaaaaa');
insert into t2 values(5,5,'aaaadaaaaaaaaaa');
insert into t3 values(4,4,'aaaaaaaaaaaaaaa');
insert into t3 values(5,5,'aaaadaaaaaaaaaa');
insert into t3 values(6,6,'affadaaaaaaaaaa');
insert into t4 values(0,0,'affadaaaaaaaaaa');
explain select /*+semi_to_inner(t3 t1 view1)*/t1.pk,t2.pk,t3.pk from t1,t2,t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);
##reject transform because the cost is increased
explain select t1.pk,t2.pk,t3.pk from t1,t2,t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);
select /*+semi_to_inner(t3 t1 view1)*/t1.pk,t2.pk,t3.pk from t1,t2,t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);
select /*+no_rewrite*/t1.pk,t2.pk,t3.pk from t1,t2,t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);
select /*+semi_to_inner(t3 t1 view1)*/t1.c1 from t1 left join t2 on (1=1), t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);
select /*+no_rewrite*/t1.c1 from t1 left join t2 on (1=1), t3 where t1.c1 > some(select t4.c1 from t4 where t4.c1 < t3.c1);

drop table t1,t2,t3,t4;

#BugFix46978247:
--disable_warnings
drop table if exists B,BB,C;
--enable_warnings

create table B(c1 int, pk int primary key);
create table BB(c1 int, pk int primary key);
create table C(c1 int, pk int primary key);
explain SELECT /*+ USE_CONCAT(@"SEL$C3026C6E" ) */ 1 FROM C LEFT JOIN B ON (C.c1 < B.c1) WHERE B .pk IN (SELECT BB.c1 FROM C LEFT JOIN BB ON (C.c1 > BB.pk) WHERE BB.c1 > BB.pk OR B.pk = 5 ORDER BY BB.pk) ;
SELECT /*+ USE_CONCAT(@"SEL$C3026C6E" ) */ 1 FROM C LEFT JOIN B ON (C.c1 < B.c1) WHERE B .pk IN (SELECT BB.c1 FROM C LEFT JOIN BB ON (C.c1 > BB.pk) WHERE BB.c1 > BB.pk OR B.pk = 5 ORDER BY BB.pk) ;
explain SELECT /*+ USE_CONCAT(@"SEL$C3026C6E" ) */ 1 FROM C LEFT JOIN B ON (C.c1 < B.c1) WHERE B .pk IN (SELECT BB.c1 FROM C LEFT JOIN BB ON (C.c1 > BB.pk) WHERE BB.c1 > BB.pk OR B.pk < 5 ORDER BY BB.pk) ;
SELECT /*+ USE_CONCAT(@"SEL$C3026C6E" ) */ 1 FROM C LEFT JOIN B ON (C.c1 < B.c1) WHERE B .pk IN (SELECT BB.c1 FROM C LEFT JOIN BB ON (C.c1 > BB.pk) WHERE BB.c1 > BB.pk OR B.pk < 5 ORDER BY BB.pk) ;

drop table B,BB,C;
