--echo #Part4: View table test
drop view if exists v1,v2,v3,v4;
insert into t1 select * from t2 where c1 < 20;
create view v1(c1,c2,c3) as (select t1.c1+t2.c1, t1.c1+t1.c2, t1.c1+1 from t1 left join t2 on t1.c1=t2.c1);
create view v2(c1,c2) as (select t2.c1, t3.c1+1 from t2 left join t3 on t2.c1 < t3.c1);
create view v3(c1,c2) as select t2.c2,t5.c2 from t2,t5;
create view v4(c1,c2) as select t1.c1, t3.c1 from t1,t3 where t1.c1=t3.c1;
create view v5(c1,c2) as select t1.c1, t3.c1 from t1,t3 where t1.c1=t3.c1 group by t1.c1,t3.c1;
select count(*) from v1;
select count(*) from v2;
select count(*) from v3;
select count(*) from v4;
