# owner: sean.yyj
# owner group: SQL1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set foreign_key_checks=1;
--enable_query_log
result_format 4;

# schema
--disable_warnings
--disable_query_log
drop database if exists transformer;
create database transformer;
use transformer;

drop table if exists t1, t2, t3, t4, t5;

create table t1 (c1 int, c2 int, c3 int);
insert into t1 values (2, 10, 2);
create index t1_i1 on t1(c1);

create table t2 (c1 int primary key, c2 int, c3 int);
insert into t2 values (1, 3, 2);
insert into t2 values (3, 3, 3);
insert into t2 values (2, 1, 2);
insert into t2 values (4, 3, 2);
insert into t2 values (0, 0, 3);
insert into t2 values (5, 3, 2);
insert into t2 values (6, 0, 2);
insert into t2 values (7, 2, 2);

--let $count = 8
while($count < 500)
{
  --let $stmt=insert into t2(c1, c2, c3) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}

create table t3 (c1 int, c2 int, c3 int);
insert into t3 values (1, 3, 2);
create index t3_i2 on t3(c2);

create table t4 (c1 varchar(20), c2 int, c3 int);
insert into t4 values ('1.', 3, 2);
insert into t4 values ('1.0', 1, 1);
create index t4_i2 on t4(c2);

create table t5(c1 int, c2 int) as select * from t2 where c1 < 100;

--enable_warnings
--enable_query_log
# schema END

--echo #Part1: Single Semi Info Test

--echo ==> reject rewrite: no matched index on right, cross-stmt condition
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 > T2.C2);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 > T2.C2);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 > T2.C2);

EXPLAIN SELECT * from t3 where C1 >= (SELECT COUNT(*) FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T3.C1 - T1.C1));
SELECT * from t3 where C1 >= (SELECT COUNT(*) FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T3.C1 - T1.C1));
SELECT /*+no_semi_to_inner*/ * from t3 where C1 >= (SELECT COUNT(*) FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T3.C1 - T1.C1));


--echo ==> right expr unique
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2);

EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2 && T1.C2 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2 && T1.C2 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C1 = T2.C2 && T1.C2 > T2.C1);

--echo ==> right output one row
EXPLAIN select * from t1 where c1 in (select c2 from t2 where c2 > 0 limit 1);
select * from t1 where c1 in (select c2 from t2 where c2 > 0 limit 1);
select /*+no_semi_to_inner*/* from t1 where c1 in (select c2 from t2 where c2 > 0 limit 1);

--echo ==> outer stmt not sensitive to duplicate outputs
EXPLAIN SELECT * from t3 where EXISTS (SELECT t1.c1 FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T1.C2));
SELECT * from t3 where EXISTS (SELECT t1.c1 FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T1.C2));
SELECT /*+no_semi_to_inner*/ * from t3 where EXISTS (SELECT t1.c1 FROM T1 WHERE EXISTS (SELECT C1 FROM T2 WHERE T2.C2 = T1.C2));

--echo ==> distinct view
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);

EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 = T2.C1 && T1.C2 > 2);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 = T2.C1 && T1.C2 > 2);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 = T2.C1 && T1.C2 > 2);

#with left filter
EXPLAIN SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 = T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 = T2.C1);
SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 = T2.C1);

#with right filter
EXPLAIN SELECT * FROM T1 WHERE (C1,1) = ANY(SELECT C1,1 FROM T3);
SELECT /*+no_semi_to_inner*/ * FROM T1 WHERE (C1,1) = ANY(SELECT C1,1 FROM T3);
SELECT * FROM T1 WHERE (C1,1) = ANY(SELECT C1,1 FROM T3);

--echo ==> aggr view
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1);

EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 > T2.C1);

#with filters
EXPLAIN SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 < T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 < T2.C1);
SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C2 < T2.C1);

EXPLAIN SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 < T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 < T2.C1);
SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T3 WHERE T3.C1 = T2.C2 AND T3.C2 < T2.C1);

# test type cast
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T4 WHERE T4.C1 = T2.C2 AND T4.C2 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T4 WHERE T4.C1 = T2.C2 AND T4.C2 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T4 WHERE T4.C1 = T2.C2 AND T4.C2 > T2.C1);

EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C2 > T2.C1 AND T2.C2 = T3.C2 AND T2.C3 = T3.C3);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C2 > T2.C1 AND T2.C2 = T3.C2 AND T2.C3 = T3.C3);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C2 > T2.C1 AND T2.C2 = T3.C2 AND T2.C3 = T3.C3);

--echo ==> inner group by
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE (T3.C1 = T2.C2 OR T3.C1 = 1) AND T3.C2 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE (T3.C1 = T2.C2 OR T3.C1 = 1) AND T3.C2 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE (T3.C1 = T2.C2 OR T3.C1 = 1) AND T3.C2 > T2.C1);

EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);

EXPLAIN SELECT C2 FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;
SELECT C2 FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;
SELECT /*+no_semi_to_inner*/ C2 FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;

EXPLAIN SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT /*+no_semi_to_inner*/ count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);

#with filters
EXPLAIN SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);
SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1);

EXPLAIN SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;
SELECT * FROM T2 WHERE (C1,1) = ANY(SELECT 1,C2 FROM T1 WHERE T1.C2 > T2.C1 AND T1.C1 > T2.C1) GROUP BY T2.C2;

--echo #Part2: Multi Semi Info Test
EXPLAIN SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT /*+no_semi_to_inner*/ * FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);

EXPLAIN SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);
SELECT /*+no_semi_to_inner*/ count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2) AND EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C1);

EXPLAIN SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T2.C1 > T3.C1) AND EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2);
SELECT count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T2.C1 > T3.C1) AND EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2);
SELECT /*+no_semi_to_inner*/ count(*) FROM T2 WHERE EXISTS (SELECT C1 FROM T3 WHERE T2.C1 > T3.C1) AND EXISTS (SELECT C1 FROM T1 WHERE T2.C1 < T1.C1 AND T1.C2 > T2.C2);

EXPLAIN select * from T2 where exists(select 1 from T1 where T1.C1 = T2.C1 and exists(select 1 from T3 where T1.C1 > T3.C2 AND T1.C1 > T3.C1));
select * from T2 where exists(select 1 from T1 where T1.C1 = T2.C1 and exists(select 1 from T3 where T1.C1 > T3.C2 AND T1.C1 > T3.C1));
select /*+no_semi_to_inner*/ * from T2 where exists(select 1 from T1 where T1.C1 = T2.C1 and exists(select 1 from T3 where T1.C1 > T3.C2 AND T1.C1 > T3.C1));

--echo ==> multi join(not match index)
--echo ==> #inner group by with multi join
##normal
EXPLAIN SELECT /*+no_semi_to_inner*/ count(*) FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1);
SELECT /*+no_semi_to_inner*/ count(*) FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1);
EXPLAIN SELECT count(*) FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1);
SELECT count(*) FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1);
##with spj
EXPLAIN SELECT T2.c2 FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1) GROUP BY T2.C2 HAVING T2.C2 < 20;
SELECT T2.C2 FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1) GROUP BY T2.C2 HAVING T2.C2 < 20;
EXPLAIN SELECT /*+no_semi_to_inner*/T2.c2 FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1) GROUP BY T2.C2 HAVING T2.C2 < 20;
SELECT /*+no_semi_to_inner*/T2.C2 FROM T2, T5 WHERE EXISTS (SELECT 1 FROM T3 WHERE T2.C2 > T3.C1 AND T5.C1 > T3.C1) GROUP BY T2.C2 HAVING T2.C2 < 20;

