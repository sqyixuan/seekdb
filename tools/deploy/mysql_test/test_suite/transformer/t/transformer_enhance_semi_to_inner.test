EXPLAIN SELECT count(*) FROM T2,T5 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C2 AND T5.C1 > T3.C1);
SELECT count(*) FROM T2,T5 WHERE EXISTS (SELECT C1 FROM T3 WHERE T3.C1 = T2.C2 AND T5.C1 > T3.C1);
