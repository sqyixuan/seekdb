--echo #Part5: Update/Delete Test
--disable_warnings
drop table if exists t6,t7;
--enable_warnings
create table t6(c1 int, c2 int) partition by hash(c1) partitions 4;
create index t6_i1 on t6(c1);
create table t7(c1 int, c2 int) partition by range(c1) (
                partition p0 values less than(0),
                partition p1 values less than(100),
                partition p2 values less than(200),
                partition p3 values less than(300),
                partition p4 values less than maxvalue);
insert into t6 select c1,c2 from t5;
insert into t7 select c1,c2 from t2;
--echo ==> inner group by
#basic test
EXPLAIN DELETE T1 FROM T1 LEFT JOIN T2 ON T1.C1 = T2.C1 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
DELETE T1 FROM T1 LEFT JOIN T2 ON T1.C1 = T2.C1 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
EXPLAIN DELETE /*+no_semi_to_inner*/T1 FROM T1 LEFT JOIN T2 ON T1.C1 = T2.C1 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
DELETE /*+no_semi_to_inner*/T1 FROM T1 LEFT JOIN T2 ON T1.C1 = T2.C1 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);

EXPLAIN UPDATE T2 SET T2.C2 = 1000 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
UPDATE T2 SET T2.C2 = 1000 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
EXPLAIN UPDATE /*+no_semi_to_inner*/T2 SET T2.C2 = 1000 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);
UPDATE /*+no_semi_to_inner*/T2 SET T2.C2 = 1000 WHERE T2.C1 IN (SELECT T3.C2 FROM T3 WHERE T3.C1 < T2.C1 AND T3.C3 < T2.C1);

#partition table
EXPLAIN DELETE T1 FROM T1 LEFT JOIN T6 ON T1.C1 = T6.C1 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
DELETE T1 FROM T1 LEFT JOIN T6 ON T1.C1 = T6.C1 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
EXPLAIN DELETE /*+no_semi_to_inner*/T1 FROM T1 LEFT JOIN T6 ON T1.C1 = T6.C1 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
DELETE /*+no_semi_to_inner*/T1 FROM T1 LEFT JOIN T6 ON T1.C1 = T6.C1 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);

EXPLAIN UPDATE T6 SET T6.C2 = 1000 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
UPDATE T6 SET T6.C2 = 1000 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
EXPLAIN UPDATE /*+no_semi_to_inner*/T6 SET T6.C2 = 1000 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);
UPDATE /*+no_semi_to_inner*/T6 SET T6.C2 = 1000 WHERE T6.C1 IN (SELECT T7.C2 FROM T7 WHERE T7.C1 < T6.C1 AND T7.C2 < T6.C1);

