#owner: sean.yyj
#owner group: sql1
#tags: optimizer

--disable_query_log
--disable_warnings
set @@session.explicit_defaults_for_timestamp=off;
drop table if exists prh_exrt_inf_hist;

CREATE TABLE `prh_exrt_inf_hist` (
  `bank_id` varchar(3) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '法人银行号',
  `org_id` varchar(6) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '机构编号',
  `ex_rate_type` varchar(3) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '汇率类型',
  `ccy` varchar(3) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '币种',
  `effect_date` date NOT NULL COMMENT '生效日期',
  `last_upd_time` datetime NOT NULL COMMENT '最后修改时间',
  `quote_type` varchar(1) COLLATE utf8mb4_bin NOT NULL DEFAULT 'D' COMMENT '牌价类型',
  `buy_exrt` decimal(31,8) NOT NULL DEFAULT '0.00000000' COMMENT '买入汇率',
  `sell_exrt` decimal(31,8) NOT NULL DEFAULT '0.00000000' COMMENT '卖出汇率',
  `mediate_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '中间汇率',
  `buy_ex_rate_spread` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '买入汇率差价',
  `sell_ex_rate_spread` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '卖出汇率差价',
  `note_buy_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '现钞买入汇率',
  `note_sell_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '现钞卖出汇率',
  `note_buy_ex_rate_spread` decimal(15,8) NOT NULL DEFAULT '0.00000000' COMMENT '现钞买入汇率差价',
  `note_sell_ex_rate_spread` decimal(15,8) NOT NULL DEFAULT '0.00000000' COMMENT '现钞卖出汇率差价',
  `fx_to_usd_buy_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '外币兑美元买入汇率',
  `fx_to_usd_sell_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '外币兑美元卖出汇率',
  `fx_to_usd_ex_rate_quote_type` varchar(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '外币兑美元汇率报价方式',
  `buy_exrt_transfer` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '总行移存买入价',
  `sell_exrt_transfer` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '总行移存卖出价',
  `central_bank_refer_quote_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '中央银行参考报价汇率',
  `unwind_ex_rate` decimal(22,8) NOT NULL DEFAULT '0.00000000' COMMENT '平盘汇率',
  `appr_stat` varchar(1) COLLATE utf8mb4_bin NOT NULL DEFAULT '1' COMMENT '审批状态',
  `rcd_sts` varchar(1) COLLATE utf8mb4_bin NOT NULL COMMENT '记录状态',
  `modify_date` date NOT NULL COMMENT '维护日期',
  `modify_org_id` varchar(6) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '维护机构',
  `modify_tlr_id` varchar(30) COLLATE utf8mb4_bin NOT NULL DEFAULT '' COMMENT '维护柜员',
  `create_date_time` datetime(3) NOT NULL COMMENT '记录创建时间戳',
  `update_date_time` datetime(3) NOT NULL COMMENT '记录修改时间戳',
  UNIQUE KEY `idx_prh_exrt_inf_hist_uni_1` (`bank_id`, `org_id`, `ex_rate_type`, `ccy`, `effect_date`, `last_upd_time`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '汇率参数历史表';

alter system flush plan cache global;

--enable_query_log
--enable_warnings
SELECT /*+query_timeout(600000000)*/  `bank_id`,`org_id`,`ex_rate_type`,`ccy`,`effect_date`,`last_upd_time`,`appr_stat`,`buy_ex_rate_spread`,`buy_exrt`,`buy_exrt_transfer`,`central_bank_refer_quote_ex_rate`,`create_date_time`,`fx_to_usd_buy_ex_rate`,`fx_to_usd_ex_rate_quote_type`,`fx_to_usd_sell_ex_rate`,`mediate_ex_rate`,`modify_date`,`modify_org_id`,`modify_tlr_id`,`note_buy_ex_rate`,`note_buy_ex_rate_spread`,`note_sell_ex_rate`,`note_sell_ex_rate_spread`,`quote_type`,`rcd_sts`,`sell_ex_rate_spread`,`sell_exrt`,`sell_exrt_transfer`,`unwind_ex_rate`,`update_date_time` FROM `prh_exrt_inf_hist`  WHERE  ( (`bank_id` = '001' AND `org_id` = '756013' AND `ex_rate_type` = 'CTR' AND `ccy` = 'AUD' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 12:03:14') OR (`bank_id` = '001' AND `org_id` = '756035' AND `ex_rate_type` = 'CTR' AND `ccy` = 'MOP' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 15:38:14') OR (`bank_id` = '001' AND `org_id` = '756026' AND `ex_rate_type` = 'CTR' AND `ccy` = 'MOP' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 12:40:14') OR (`bank_id` = '001' AND `org_id` = '755031' AND `ex_rate_type` = 'CTR' AND `ccy` = 'MOP' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 14:03:14') OR (`bank_id` = '001' AND `org_id` = '756051' AND `ex_rate_type` = 'CTR' AND `ccy` = 'USD' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 13:35:14') OR (`bank_id` = '001' AND `org_id` = '755033' AND `ex_rate_type` = 'CTR' AND `ccy` = 'JPY' AND `effect_date` = '2023-02-13' AND `last_upd_time` = '2023-02-13 14:10:11') OR (`bank_id` = '001' AND `org_id` = '752888' AND `ex_rate_type` = 'CTR' AND `ccy` = 'JPY' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 12:55:14') OR (`bank_id` = '001' AND `org_id` = '756014' AND `ex_rate_type` = 'CTR' AND `ccy` = 'AUD' AND `effect_date` = '2023-02-14' AND `last_upd_time` = '2023-02-14 12:03:14') OR (`bank_id` = '001' AND `org_id` = '75