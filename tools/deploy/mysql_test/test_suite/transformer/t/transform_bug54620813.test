# 验证计划命中
--sorted_result
select HIT_COUNT, SQL_ID, TYPE from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like '%prh_exrt_inf_hist%';

drop table prh_exrt_inf_hist;
