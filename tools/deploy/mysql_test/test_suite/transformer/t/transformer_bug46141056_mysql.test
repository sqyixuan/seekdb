#owner: sean.yyj
#owner group: sql1
# tags: optimizer
# link: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(pk int primary key, c1 int);
create table t2(c1 int);

--explain_protocol 2
--result_format 4

select * from t1 as t1_a left join t1 as t1_b on t1_a.c1 = t1_b.c1 where not exists (select 1 from t2 where t2.c1 = t1_a.pk) and t1_b.pk is NULL;

select * from t1 as t1_a left join t1 as t1_b on t1_a.c1 = t1_b.c1 where not exists (select 1 from t2 where t2.c1 = t1_b.pk) and t1_b.pk is NULL;

drop table t1, t2;
