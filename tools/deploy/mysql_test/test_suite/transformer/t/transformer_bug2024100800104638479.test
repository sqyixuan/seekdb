# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3, t4;
--enable_warnings
CREATE TABLE t1(c1 int primary key);
CREATE TABLE t2(c1 int);
CREATE TABLE t3(c1 int);
CREATE TABLE t4(c1 int primary key, c2 int);

DROP SEQUENCE IF EXISTS seq;
CREATE SEQUENCE seq CACHE 4000 ORDER;
INSERT INTO T2 SELECT seq.nextval FROM TABLE(GENERATOR(1000));
INSERT INTO T3 SELECT seq.nextval FROM TABLE(GENERATOR(1000));
INSERT INTO T4 SELECT seq.nextval, seq.nextval FROM TABLE(GENERATOR(1000));
DROP SEQUENCE seq;
CREATE SEQUENCE seq CACHE 100 INCREMENT BY 100;
INSERT INTO T1 SELECT seq.nextval FROM TABLE(GENERATOR(100));

--result_format 4
--explain_protocol 2

# 这个查询的实际结果只有 10 条
# UNION 中存在相关子查询，外层的 IN 子查询应该要改成 EXISTS 子查询
SELECT /*+no_unnest(@SET$1) query_timeout(10000000)*/
  t1.c1
FROM
  t1
WHERE t1.c1 IN (
  SELECT t2.c1 FROM t2
  UNION
  SELECT t3.c1 FROM t3
  WHERE t3.c1 IN (
    SELECT c2 FROM t4 WHERE t4.c1 = t1.c1
  )
);

SELECT /*+no_rewrite query_timeout(10000000)*/
  t1.c1
FROM
  t1
WHERE t1.c1 IN (
  SELECT t2.c1 FROM t2
  UNION
  SELECT t3.c1 FROM t3
  WHERE t3.c1 IN (
    SELECT c2 FROM t4 WHERE t4.c1 = t1.c1
  )
);

DROP TABLE t1, t2, t3, t4;
DROP SEQUENCE seq;