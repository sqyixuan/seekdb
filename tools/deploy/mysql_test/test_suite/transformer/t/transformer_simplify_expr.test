--explain_protocol 2

--echo begin to test push_not
SELECT c1,c2,c3,not (c1 =1 and c2!=1) FROM t1 where not (c1 =1 and c2!=1) GROUP BY not (c1 =1 and c2!=1) HAVING not (c1 =1 and c2!=1);
SELECT c1,c2,c3,not (c1 > 1 or c2>=1) FROM t1 where not (c1 > 1 or c2>=1) GROUP BY not (c1 > 1 or c2>=1) HAVING not (c1 > 1 or c2>=1);
SELECT c1,c2,c3,not (c1 < 1 or c2<=1) FROM t1 where not (c1 < 1 or c2<=1) GROUP BY not (c1 < 1 or c2<=1) HAVING not (c1 < 1 or c2<=1);
SELECT c1,c2,c3,not (c1 is null and c2 is not null) FROM t1 where not (c1 is null and c2 is not null) GROUP BY not (c1 is null and c2 is not null) HAVING not (c1 is null and c2 is not null);
SELECT c1,c2,c3,not (c1 between 1 and 2 or c2 not between 1 and 2) FROM t1 where not (c1 between 1 and 2 or c2 not between 1 and 2) GROUP BY not (c1 between 1 and 2 or c2 not between 1 and 2) HAVING not (c1 between 1 and 2 or c2 not between 1 and 2);
SELECT c1,c2,c3,not (c1 in (1,2,3) and c2 not in (1,2,3)) FROM t1 where not (c1 in (1,2,3) and c2 not in (1,2,3)) GROUP BY not (c1 in (1,2,3) and c2 not in (1,2,3)) HAVING not (c1 in (1,2,3) and c2 not in (1,2,3));
SELECT c1,c2,c3,not (c1>1 or not (c2 >1 and not c3 in (1,2,3))) FROM t1 where not (c1>1 or not (c2 >1 and not c3 in (1,2,3))) GROUP BY not (c1>1 or not (c2 >1 and not c3 in (1,2,3))) HAVING not (c1>1 or not (c2 >1 and not c3 in (1,2,3)));
SELECT c1,c2,c3,not (not (not c1 > 1)) FROM t1 where not (not (not c1 > 1)) GROUP BY not (not (not c1 > 1)) HAVING not (not (not c1 > 1));
SELECT c1, c2, c3, not (not (c1 > 1)) FROM t1 WHERE not (not (c1 > 1)) GROUP BY not (not (c1 > 1)) HAVING not (not (c1 > 1));
SELECT c1, c2, c3, not (not (not c1<=>1)) FROM t1 WHERE not (not (not c1<=>1)) GROUP BY not (not (not c1<=>1)) HAVING not (not (not c1<=>1));
SELECT c1, c2, c3, not (c1>1 and (not c2>2)) FROM t1 WHERE not (c1>1 and (not c2>2)) GROUP BY not (c1>1 and (not c2>2)) HAVING not (c1>1 and (not c2>2));
SELECT c1, c2, c3, not (c1>1 and (not c2>2) and not not (c2>2 and not c1>1 and not not c1>1)) FROM t1 WHERE not (c1>1 and (not c2>2) and not not (c2>2 and not c1>1 and not not c1>1)) GROUP BY not (c1>1 and (not c2>2) and not not (c2>2 and not c1>1 and not not c1>1)) HAVING not (c1>1 and (not c2>2) and not not (c2>2 and not c1>1 and not not c1>1));
SELECT c1, c2, c3, not (select c1 FROM t1 limit 1) FROM t1 WHERE not (select c1 FROM t1 limit 1) GROUP BY not (select c1 FROM t1 limit 1) HAVING not (select c1 FROM t1 limit 1);

--echo begin to test cluster_and_or_xor
SELECT c1, c2, c3, c1>1 and (c2>1 and c3>1) FROM t1 WHERE c1>1 and (c2>1 and c3>1) GROUP BY c1>1 and (c2>1 and c3>1) HAVING c1>1 and (c2>1 and c3>1);
SELECT c1, c2, c3, c1 and (c1>1 and c1<3) FROM t1 WHERE c1 and (c1>1 and c1<3) GROUP BY c1 and (c1>1 and c1<3) HAVING c1 and (c1>1 and c1<3);
SELECT c1, c2, c3, c1>1 or (c2>1 or c3>1) FROM t1 WHERE c1>1 or (c2>1 or c3>1) GROUP BY c1>1 or (c2>1 or c3>1) HAVING c1>1 or (c2>1 or c3>1);
SELECT c1, c2, c3, c1>1 xor (c2>1 xor c3>1) FROM t1 WHERE c1>1 xor (c2>1 xor c3>1) GROUP BY c1>1 xor (c2>1 xor c3>1) HAVING c1>1 xor (c2>1 xor c3>1);
SELECT c1, c2, c3, c1>1 or c2>3 or (c3>4 xor (c2>1 xor c3>1 and c1>1 and c2>3)) FROM t1 WHERE c1>1 or c2>3 or (c3>4 xor (c2>1 xor c3>1 and c1>1 and c2>3)) GROUP BY c1>1 or c2>3 or (c3>4 xor (c2>1 xor c3>1 and c1>1 and c2>3)) HAVING c1>1 or c2>3 or (c3>4 xor (c2>1 xor c3>1 and c1>1 and c2>3));

--echo begin to test remove_dupicate_expr

SELECT c1, c2, c3, c1>1 and (c1>1 and c1>1) FROM t1 WHERE c1>1 and (c1>1 and c1>1) GROUP BY c1>1 and (c1>1 and c1>1) HAVING c1>1 and (c1>1 and c1>1);
SELECT c1, c2, c3, not (c1>1 and c1>1) FROM t1 WHERE not (c1>1 and c1>1) GROUP BY not (c1>1 and c1>1) HAVING not (c1>1 and c1>1);
SELECT c1, c2, c3, c1 <= 1 and  (c1<=1 and c2>2) FROM t1 WHERE c1 <= 1 and  (c1<=1 and c2>2) GROUP BY c1 <= 1 and  (c1<=1 and c2>2) HAVING c1 <= 1 and  (c1<=1 and c2>2);
SELECT c1, c2, c3, c1>1 or (c1>1 or c1>1) FROM t1 WHERE c1>1 or (c1>1 or c1>1) GROUP BY c1>1 or (c1>1 or c1>1) HAVING c1>1 or (c1>1 or c1>1);
SELECT c1, c2, c3, c1>1 and (c1>1 or c1>1) FROM t1 WHERE c1>1 and (c1>1 or c1>1) GROUP BY c1>1 and (c1>1 or c1>1) HAVING c1>1 and (c1>1 or c1>1);
SELECT c1, c2, c3, c1>1 or (c1>1 and c1>1) FROM t1 WHERE c1>1 or (c1>1 and c1>1) GROUP BY c1>1 or (c1>1 and c1>1) HAVING c1>1 or (c1>1 and c1>1);
--echo begin to test pull similar expr

SELECT c1, c2, c3, c1 or (c1 and c2) FROM t1 WHERE  c1 or (c1 and c2) GROUP BY  c1 or (c1 and c2) HAVING  c1 or (c1 and c2);
SELECT c1, c2, c3, (c1 and c2) or c1 FROM t1 WHERE  (c1 and c2) or c1 GROUP BY  (c1 and c2) or c1 HAVING  (c1 and c2) or c1;
SELECT c1, c2, c3, c2 and (c1 or c2) FROM t1 WHERE  c2 and (c1 or c2) GROUP BY  c2 and (c1 or c2) HAVING  c2 and (c1 or c2);
SELECT c1, c2, c3, (c1 or c2) and c1 FROM t1 WHERE  (c1 or c2) and c1 GROUP BY  (c1 or c2) and c1 HAVING  (c1 or c2) and c1;
SELECT c1, c2, c3, (c1 and c2) or (c1 and c2 and c3) FROM t1 WHERE  (c1 and c2) or (c1 and c2 and c3) GROUP BY  (c1 and c2) or (c1 and c2 and c3) HAVING  (c1 and c2) or (c1 and c2 and c3);
SELECT c1, c2, c3, (c1 or c2 ) and (c1 or c2 or c3<0) FROM t1 WHERE  (c1 or c2 ) and (c1 or c2 or c3<0) GROUP BY  (c1 or c2 ) and (c1 or c2 or c3<0) HAVING  (c1 or c2 ) and (c1 or c2 or c3<0);
SELECT c1, c2, c3, (c1>1 and c2>2 and c3<10) or (c1>1 and c2>2 and c3>10) FROM t1 WHERE  (c1>1 and c2>2 and c3<10) or (c1>1 and c2>2 and c3>10) GROUP BY  (c1>1 and c2>2 and c3<10) or (c1>1 and c2>2 and c3>10) HAVING  (c1>1 and c2>2 and c3<10) or (c1>1 and c2>2 and c3>10);
SELECT c1, c2, c3, ((c1>1 or c2>2) and c3<10) or ((c1>1 or c2>2) and c3>10) FROM t1 WHERE  ((c1>1 or c2>2) and c3<10) or ((c1>1 or c2>2) and c3>10) GROUP BY  ((c1>1 or c2>2) and c3<10) or ((c1>1 or c2>2) and c3>10) HAVING  ((c1>1 or c2>2) and c3<10) or ((c1>1 or c2>2) and c3>10);
SELECT c1, c2, c3, (c1 and (c3 or c1>2)) or (c1 and (c2 or c1>1)) FROM t1 WHERE  (c1 and (c3 or c1>2)) or (c1 and (c2 or c1>1)) GROUP BY  (c1 and (c3 or c1>2)) or (c1 and (c2 or c1>1)) HAVING  (c1 and (c3 or c1>2)) or (c1 and (c2 or c1>1));
SELECT c1, c2, c3, (c1 or c2 or c3>1) and (c1 or c2 or c3<0) FROM t1 WHERE  (c1 or c2 or c3>1) and (c1 or c2 or c3<0) GROUP BY  (c1 or c2 or c3>1) and (c1 or c2 or c3<0) HAVING  (c1 or c2 or c3>1) and (c1 or c2 or c3<0);
SELECT c1, c2, c3, ((c1 and c2) or c3>1) and ((c1 and c2) or c3<0) FROM t1 WHERE  ((c1 and c2) or c3>1) and ((c1 and c2) or c3<0) GROUP BY  ((c1 and c2) or c3>1) and ((c1 and c2) or c3<0) HAVING  ((c1 and c2) or c3>1) and ((c1 and c2) or c3<0);
SELECT c1, c2, c3, (c1 and (c3 and c1>2)) or (c1 and (c2 or c1>1)) FROM t1 WHERE  (c1 and (c3 and c1>2)) or (c1 and (c2 or c1>1)) GROUP BY  (c1 and (c3 and c1>2)) or (c1 and (c2 or c1>1)) HAVING  (c1 and (c3 and c1>2)) or (c1 and (c2 or c1>1));
SELECT c1, c2, c3, (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3) FROM t1 WHERE  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3) GROUP BY  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3) HAVING  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3);
SELECT c1, c2, c3, (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3 and c1>1) FROM t1 WHERE  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3 and c1>1) GROUP BY  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3 and c1>1) HAVING  (c1>1 and c2>2 or c1>1 and c3>3) and (c2>2 or c3>3 and c1>1);
SELECT c1, c2, c3, (c1>1 or c2>2 and c1>1 or c3>3) or (c2>2 and c3>3 or c1>1) FROM t1 WHERE  (c1>1 or c2>2 and c1>1 or c3>3) or (c2>2 and c3>3 or c1>1) GROUP BY  (c1>1 or c2>2 and c1>1 or c3>3) or (c2>2 and c3>3 or c1>1) HAVING  (c1>1 or c2>2 and c1>1 or c3>3) or (c2>2 and c3>3 or c1>1);
SELECT c1, c2, c3, (c1 and c2) and (c1 and c2 or c3) FROM t1 WHERE  (c1 and c2) and (c1 and c2 or c3) GROUP BY  (c1 and c2) and (c1 and c2 or c3) HAVING  (c1 and c2) and (c1 and c2 or c3);
SELECT c1, c2, c3, (c1 or c2) or ((c1 or c2) and c3) FROM t1 WHERE  (c1 or c2) or ((c1 or c2) and c3) GROUP BY  (c1 or c2) or ((c1 or c2) and c3) HAVING  (c1 or c2) or ((c1 or c2) and c3);
SELECT c1, c2, c3, c1 and c2 or (c2 and (c2 or c1)) FROM t1 WHERE  c1 and c2 or (c2 and (c2 or c1)) GROUP BY  c1 and c2 or (c2 and (c2 or c1)) HAVING  c1 and c2 or (c2 and (c2 or c1));
SELECT c1, c2, c3, c2 or (c1 and c2 and (c2 or c1)) FROM t1 WHERE  c2 or (c1 and c2 and (c2 or c1)) GROUP BY  c2 or (c1 and c2 and (c2 or c1)) HAVING  c2 or (c1 and c2 and (c2 or c1));
SELECT c1, c2, c3, ((c1>1 and c2>1) or (c3>1 and c1>1)) or ((c2>1 and c3>1) or c3>1) FROM t1 WHERE  ((c1>1 and c2>1) or (c3>1 and c1>1)) or ((c2>1 and c3>1) or c3>1) GROUP BY  ((c1>1 and c2>1) or (c3>1 and c1>1)) or ((c2>1 and c3>1) or c3>1) HAVING  ((c1>1 and c2>1) or (c3>1 and c1>1)) or ((c2>1 and c3>1) or c3>1);
SELECT c1, c2, c3, (c1 and c2) or (c3 and c1) or (c2 or c3) or c3 FROM t1 WHERE  (c1 and c2) or (c3 and c1) or (c2 or c3) or c3 GROUP BY  (c1 and c2) or (c3 and c1) or (c2 or c3) or c3 HAVING  (c1 and c2) or (c3 and c1) or (c2 or c3) or c3;
SELECT c1, c2, c3, c3 and (c1 or c2) and ((c3 or c1) and (c2 or c3)) FROM t1 WHERE  c3 and (c1 or c2) and ((c3 or c1) and (c2 or c3)) GROUP BY  c3 and (c1 or c2) and ((c3 or c1) and (c2 or c3)) HAVING  c3 and (c1 or c2) and ((c3 or c1) and (c2 or c3));
SELECT c1, c2, c3, c3 or (c1 and c2) or ((c3 or c1) and (c2 or c3)) FROM t1 WHERE  c3 or (c1 and c2) or ((c3 or c1) and (c2 or c3)) GROUP BY  c3 or (c1 and c2) or ((c3 or c1) and (c2 or c3)) HAVING  c3 or (c1 and c2) or ((c3 or c1) and (c2 or c3));
SELECT c1, c2, c3, c1 > 1 and c2 > 2 or c3 > 1 or c1 > 1 and c3 > 10 FROM t1 WHERE  c1 > 1 and c2 > 2 or c3 > 1 or c1 > 1 and c3 > 10 GROUP BY  c1 > 1 and c2 > 2 or c3 > 1 or c1 > 1 and c3 > 10 HAVING  c1 > 1 and c2 > 2 or c3 > 1 or c1 > 1 and c3 > 10;

--echo test join&having&semi
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,not (t1.c1 = t2.c1 or t2.c2>=1) FROM t1 LEFT JOIN t2 ON not (t1.c1 = t2.c1 or t2.c2>=1) GROUP BY not (t1.c1 = t2.c1 or t2.c2>=1) HAVING not (t1.c1 = t2.c1 or t2.c2>=1);
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,t1.c1>1 or (t1.c2>1 or t2.c3>1) FROM t1 LEFT JOIN t2 ON t1.c1>1 or (t1.c2>1 or t2.c3>1) GROUP BY t1.c1>1 or (t1.c2>1 or t2.c3>1) HAVING t1.c1>1 or (t1.c2>1 or t2.c3>1);
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,t1.c1>1 and(t1.c1>1 or t1.c1>1) FROM t1 LEFT JOIN t2 ON t1.c1>1 and(t1.c1>1 or t1.c1>1) GROUP BY t1.c1>1 and(t1.c1>1 or t1.c1>1) HAVING t1.c1>1 and(t1.c1>1 or t1.c1>1);
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,(t1.c1 > 1 and t2.c2>=1) or (t1.c1 > 1 and t2.c2<=10) FROM t1 LEFT JOIN t2 ON (t1.c1 > 1 and t2.c2>=1) or (t1.c1 > 1 and t2.c2<=10) GROUP BY (t1.c1 > 1 and t2.c2>=1) or (t1.c1 > 1 and t2.c2<=10) HAVING (t1.c1 > 1 and t2.c2>=1) or (t1.c1 > 1 and t2.c2<=10);
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,t1.c1>1 and (t2.c2>1 and t2.c3>1) FROM t1 LEFT JOIN t2 ON t1.c1>1 and (t2.c2>1 and t2.c3>1) GROUP BY t1.c1>1 and (t2.c2>1 and t2.c3>1) HAVING t1.c1>1 and (t2.c2>1 and t2.c3>1);
SELECT t1.c1, t1.c2, t1.c3, t2.c1,t2.c2,t2.c3,not (t1.c1>1 and t3.c1 > 1) or (t1.c1>1 and t2.c1>1) and (t3.c1=1 or t3.c1=2) FROM t1,t2,t3 where not (t1.c1>1 and t3.c1 > 1) or (t1.c1>1 and t2.c1>1) and (t3.c1=1 or t3.c1=2) GROUP BY not (t1.c1>1 and t3.c1 > 1) or (t1.c1>1 and t2.c1>1) and (t3.c1=1 or t3.c1=2);
SELECT * FROM t1 WHERE exists (SELECT * FROM t2 WHERE (t1.c1 > 1 and t2.c2>=1) OR (t1.c1 > 1 AND t2.c2<=10) group by (t1.c1 > 1 and t2.c2>=1) OR (t1.c1 > 1 AND t2.c2<=10)) AND NOT (t1.c1=1 OR t1.c1=2);



--echo check bool predicate(and, or, not, if ,case when, max)

SELECT * FROM test;
SELECT * FROM test WHERE (c1 and c1) = c1;
SELECT * FROM test WHERE (c1 or c1) = c1;
SELECT * FROM test WHERE (not not c1) = c1;
SELECT * FROM test GROUP BY c1 having max((c1 && c1) or c1) = c1;
SELECT * FROM test WHERE (case when c1 or c1 then 1 else 0 end) =c1;
SELECT * FROM test WHERE if(c1>c1,c1 and c1 ,c1 or c1)=c1;
