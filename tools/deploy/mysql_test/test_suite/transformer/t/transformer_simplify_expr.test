--error 0,942,1051
drop table t0;
--error 0,942,1051
drop table t1;

CREATE TABLE t0(c0 SMALLINT(2) ZEROFILL , c1 DECIMAL ZEROFILL , c2 BIGINT(190) , c3 FLOAT(27, 15)) PARTITION BY KEY (c3, c0) SUBPARTITION BY KEY (c2, c1, c3) subpartitions 18 partitions 13;
CREATE TABLE t1 LIKE t0;
CREATE INDEX i520 ON t0(c2, c0, c1, c3);
SELECT 1 FROM t1, t0  WHERE (NOT (3 IN (3,t1.c2))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT (3 IN (3,t1.c2))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT NOT(3 IN (3,t1.c2))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT (3 IN (3,t1.c2) < 2 IN (3,t1.c2))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT (3 IN (3,t1.c2) < (NOT(2 IN (3,t1.c2))))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT (1 != t1.c3 or (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT (1 != t1.c3 or (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT NOT (1 != t1.c3 or (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT (1 != t1.c3 AND (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT (1 != t1.c3 AND (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT NOT NOT (1 != t1.c3 AND (1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT ((1,2) IN ((3,-4), (512,t1.c2)))) NOT IN (t0.c1, 1);
SELECT 1 FROM t1, t0  WHERE (NOT (1 != t1.c3 or 3 IN (3,t1.c2))) NOT IN (t0.c1, 1);
