--echo test align_date4cmp_expr
select * from t_date where NOT c1 != '2006-03-25'; #T_OP_EQ = 110
select * from t_date where NOT '2006-03-25' != c1; #T_OP_EQ = 110
select * from t_date where NOT c1 <=> '2006-03-25'; #T_OP_NSEQ = 111
select * from t_date where NOT '2006-03-25' <=> c1; #T_OP_NSEQ = 111
select * from t_date where NOT c1 > '2006-03-25'; #T_OP_LE = 112
select * from t_date where NOT '2006-03-25' < c1; #T_OP_LE = 112
select * from t_date where NOT c1 >= '2006-03-25';#T_OP_LT = 113
select * from t_date where NOT '2006-03-25' <= c1;#T_OP_LT = 113
select * from t_date where NOT c1 < '2006-03-25'; #T_OP_GE = 114
select * from t_date where NOT '2006-03-25' > c1; #T_OP_GE = 114
select * from t_date where NOT c1 <= '2006-03-25';#T_OP_GT = 115
select * from t_date where NOT '2006-03-25' >= c1;#T_OP_GT = 115
select * from t_date where NOT c1 = '2006-03-25';  #T_OP_NE = 116
select * from t_date where NOT '2006-03-25' = c1;  #T_OP_NE = 116

select * from t_date where NOT (c1, c1) != ('0', '2006-03-25'); #T_OP_EQ = 110
select * from t_date where NOT ('0', '2006-03-25') != (c1, c1); #T_OP_EQ = 110
select * from t_date where NOT (c1, c1) <=> ('0', '2006-03-25'); #T_OP_NSEQ = 111
select * from t_date where NOT ('0', '2006-03-25') <=> (c1, c1); #T_OP_NSEQ = 111
select * from t_date where NOT (c1, c1) > ('0', '2006-03-25'); #T_OP_LE = 112
select * from t_date where NOT ('0', '2006-03-25') < (c1, c1); #T_OP_LE = 112
select * from t_date where NOT (c1, c1) >= ('0', '2006-03-25');#T_OP_LT = 113
select * from t_date where NOT ('0', '2006-03-25') <= (c1, c1);#T_OP_LT = 113
select * from t_date where NOT (c1, c1) < ('0', '2006-03-25'); #T_OP_GE = 114
select * from t_date where NOT ('0', '2006-03-25') > (c1, c1); #T_OP_GE = 114
select * from t_date where NOT (c1, c1) <= ('0', '2006-03-25');#T_OP_GT = 115
select * from t_date where NOT ('0', '2006-03-25') >= (c1, c1);#T_OP_GT = 115
select * from t_date where NOT (c1, c1) = ('0', '2006-03-25');  #T_OP_NE = 116
select * from t_date where NOT ('0', '2006-03-25') = (c1, c1);  #T_OP_NE = 116

select * from t_date where NOT c1 != (not c1!='2006-03-25');
select * from t_date where NOT (c1, c1) != ( NOT (c1, c1) != ('0', '0'), NOT (c1, c1) != ('0', '2006-03-25')); #T_OP_EQ = 110
select * from t_date where NOT (c1, c1) >= ( NOT (c1, c1) != ('0', '0'), NOT (c1, c1) < ('0', '2006-03-25')); #T_OP_EQ = 110

drop table t_date;

drop table t1;
drop table t2;
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
select * from t1 where t1.c1 < ALL (select c1 from t2 where c1 > 0 order by 1) and t1.c1 < ANY (select c1 from t2 where c1 > 0 order by 1);
select * from t1 where t1.c1 < ANY (select c1 from t2 where c1 > 0 order by 1) and t1.c1 < ANY (select c1 from t2 where c1 > 0);
select * from t1 where t1.c1 < ALL (select c1 from t2 where c1 > 0 order by 1) and t1.c1 < ALL (select c1 from t2 where c1 > 0);
drop table t1;
drop table t2;


--disable_warnings
--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table t2;
--error 0,942,1051
drop table t3;
--error 0,942,1051
drop table t0;
--enable_warnings
create table t0(c0 int,c1 int);
create table t1(c0 int,c1 int);
create table t2(c0 int,c1 int);
create table t3(c0 int,c1 int);
SELECT /*+ TOPK (50 50)  */ ALL concat(t1.c0,'') FROM  t1 LEFT  OUTER JOIN t3 ON CAST((! (((NOT (concat(t1.c0,'')))) IS TRUE)) AS SIGNED),  t0 LEFT  OUTER JOIN t2 ON concat(t2.c0,'') WHERE t0.c1;

SELECT * FROM t1 WHERE 
      exists (SELECT /*+no_simplify_expr*/* FROM t2 WHERE t1.c1= CAST((! (((NOT (concat(t2.c0,'')))) IS false)) AS SIGNED)) 
      and
      exists (SELECT /*+no_simplify_expr*/ * FROM t3 WHERE t1.c1= CAST((! ((( (concat(t3.c0,'')))) IS false)) AS SIGNED));




