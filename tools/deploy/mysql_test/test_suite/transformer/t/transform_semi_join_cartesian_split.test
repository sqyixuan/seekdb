# owner: guohanyun.ghy
# owner group: SQL1
# tags: optimizer


--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings

create table t1(a int, b int);
create table t2(a int, b int);
create table t3(a int, b int);
create table t4(a int, b int);
create table t5(a int, b int);

--disable_query_log
--let $count = 1
while($count <= 20)
{
  --let $stmt=insert into t1 values ($count, $count + 1)
  eval $stmt;
  --let $stmt=insert into t2 values ($count + 3, $count)
  eval $stmt;
  --let $stmt=insert into t3 values ($count * 2, $count)
  eval $stmt;
  --let $stmt=insert into t4 values ($count, $count * 3)
  eval $stmt;
  --let $stmt=insert into t5 values ($count + 3, $count * 2)
  eval $stmt;
  inc $count;
}
--enable_query_log

--explain_protocol 1

# can't split
SELECT * FROM T1 WHERE NOT EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.B = T1.B AND T2.A = T1.A AND (T3.A = T1.B OR T4.A = T1.A));
SELECT * FROM T1 WHERE T1.A NOT IN (SELECT 1 FROM T2, T3 WHERE T2.A = T1.A AND T3.A = T1.B);
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.B FROM T2, T3 WHERE T2.A > 2 AND T3.A < 3 ORDER BY 1 LIMIT 1);
SELECT * FROM T1 WHERE T1.A IN (SELECT COUNT(T2.B) FROM T2, T3 WHERE T2.A > 2 AND T3.A < 3 GROUP BY T2.B);
SELECT * FROM T1 WHERE T1.A IN (SELECT 1 FROM T2, T3 WHERE T2.A = 5 AND T3.A < 3 HAVING SUM(T3.B) > 10);

# can't split, contain subquery
SELECT * FROM T1 WHERE EXISTS (SELECT V1.V1B FROM T2, T3, (SELECT T4.B V1B FROM T4 WHERE T4.A < T4.B) V1 WHERE T2.A + 4 = T3.A AND V1.V1B = T1.A);

# can't split, in same WHERE condition
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.A FROM T2, T3 WHERE T2.A = T3.A + 3 AND T3.B < 2);
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE T2.A + T3.A > 3 AND T4.B > T3.B);
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE T2.A + T3.A > T4.B);
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE T2.A + T3.A > 3 AND (T3.A > T2.B OR T4.A < 20));

# can't split, in same semi info
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND NOT EXISTS (SELECT 1 FROM T4 WHERE T4.B < T2.A+T3.B));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND T3.B in (SELECT T2.A FROM T4 WHERE T4.A <> T2.B));

# can't split, in same semi condition
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.A+T3.B FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A > 2);
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A+T3.B = T1.A + 3 AND T3.A > 2);
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.B FROM T2, T3 WHERE T2.A+T3.B = T1.A + 3 AND T3.A > 2);
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE T2.A + T3.A > 3 AND (T3.A = T1.B OR T4.A = T1.A));

# can't split, mix
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A + T3.B FROM T2, T3, T4 WHERE T2.A + T3.A > 3 AND T4.B > 3);
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND T3.B in (SELECT T2.A FROM T4 WHERE T4.A <> T2.B));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.B = T1.B - 1 AND T2.A - 3 = T1.A AND (T3.A = T1.B OR T4.A = T1.A) AND T3.B in (SELECT T2.A FROM T5 WHERE T5.A <> T2.B));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.A + 4 = T3.A AND (T4.A = T1.A OR T2.A-T3.B > 0));
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE NOT EXISTS (SELECT 1 FROM T5 WHERE T5.B < T2.A+T3.B) AND (T3.A = T1.B OR T4.A = T1.A));

# can split
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.B = T1.B - 1 AND T2.A - 3 = T1.A AND (T3.A = T1.B OR T4.A = T1.A));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.A + 4 = T3.A AND T4.A = T1.A);
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A = T3.A - 6 AND T2.B > 3 AND T3.B = T1.B + 7);
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 WHERE T2.A - 3 = T1.A AND T3.A = T1.B AND T2.B = T3.B);
SELECT * FROM T1 WHERE EXISTS (SELECT T2.A + T3.B FROM T2, T3 WHERE T2.A - 3 = T1.A AND T3.A = T1.B AND T2.B = T3.B);
SELECT * FROM T1 WHERE EXISTS (SELECT T2.A + T3.B - T4.A FROM T2, T3, T4 WHERE T2.A + 4 = T3.A AND T4.A = T1.A);
SELECT * FROM T1 WHERE EXISTS (SELECT T2.A + T3.B FROM T2, T3, T4, T5 WHERE T2.A + 4 = T4.A AND (T3.A = T1.B OR T5.A = T1.A));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3 T31, T4, T5 WHERE T31.B in (SELECT T2.A FROM T3 T33 WHERE T4.A <> T2.B AND T33.A - T2.B < 20));
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 T41, T5 WHERE EXISTS (SELECT T2.A FROM T4 T44 WHERE T44.A <> T2.B AND T3.A > T44.B));
SELECT * FROM T1 WHERE T1.A IN (SELECT 1 FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A = T1.B);
SELECT * FROM T1 WHERE T1.B IN (SELECT T2.A FROM T2, T3, T4 WHERE T2.B = T1.B AND T2.A = T1.A AND (T3.A = T1.B OR T4.A = T1.A));
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.B FROM T2, T3 WHERE T2.A = T1.A + 3 AND T3.A > 2);
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.B FROM T2, T3 T31 WHERE T2.A >= T1.A - 3 AND T31.A IN (SELECT T32.B * 2 FROM T3 T32 WHERE T32.A + 2 <= T2.B * 2 AND EXISTS (SELECT 1 FROM T4, T5 WHERE T4.A=T1.A AND T5.B >= T2.B + 5 AND T32.B + 3 <> T32.A)));
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.A FROM T2, T3, T4, T5 WHERE T3.A = T1.B OR T4.A = T1.A);
SELECT * FROM T1 WHERE T1.A IN (SELECT T5.A FROM T2, T3, T4, T5 WHERE T3.B in (SELECT T2.A FROM T4 WHERE T4.A <> T2.B));
SELECT * FROM T1 T10 WHERE T10.A IN (SELECT 1 FROM T2, T3, T4, T5 WHERE T2.A+T3.B = T10.A + 3 AND T3.A > 2 AND (T4.B in (SELECT T11.A FROM T1 T11 WHERE T11.B > 0) OR T5.A > 2));
SELECT * FROM T1 WHERE T1.A IN (SELECT T2.A - T3.B FROM T2, T3, T4, T5 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND T3.B in (SELECT T2.A FROM T4 WHERE T4.A <> T2.B) AND T4.A + T5.B <> 20);
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A - T5.B + 10 FROM T2, T3, T4, T5 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND T3.B in (SELECT T2.A FROM T4 WHERE T4.A <> T2.B));
SELECT * FROM T1 WHERE T1.A IN (SELECT T4.A FROM T2, T3, T4 WHERE EXISTS (SELECT T2.A FROM T5 WHERE T5.A <> T2.B AND T3.A > T5.B) AND T4.B < 100);
SELECT * FROM T2 WHERE (A, B) IN (SELECT T1.A + 3, T1.B - 1 FROM T1 JOIN T3 ON T3.A = T3.B * 2 WHERE T2.A IN (SELECT B FROM T4) AND T1.B < T2.A ORDER BY T1.B);
SELECT * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.A = T1.A + 3 AND T3.A > 2 AND NOT EXISTS (SELECT 1 FROM T3, T4));

# feature enable test
SELECT /*+ optimizer_features_enable('4.2.2.0') */ * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.A + 4 = T3.A AND T4.A = T1.A);
SELECT /*+ optimizer_features_enable('4.2.3.0') */ * FROM T1 WHERE EXISTS (SELECT 1 FROM T2, T3, T4 WHERE T2.A + 4 = T3.A AND T4.A = T1.A);

# 计划回退，子查询中 t1 拆分出来后无法被 ObTransformJoinElimination 消去
EXPLAIN BASIC SELECT COUNT(1) FROM t1 WHERE A IN (SELECT t2.A FROM t1,t2 WHERE t2.A IS NOT NULL);

SELECT  1
FROM T1
WHERE T1 . `a` IN ( 
      SELECT T2 .`a`
      FROM T2
      WHERE T1 . `a` IN ( 
            SELECT  T3 . `a` AS C1 
            FROM T3
            WHERE ( T2.`a` = 1 )));

select * from t1 
where (t1.a = 1 or t1.b = 1) 
    and t1.a in 
    (select t2.b + 1 from t2 where t2.a > t1.a order by t2.b + 1);

SELECT * FROM T1 WHERE T1.a in (SELECT SUM(T2.b) FROM T2 WHERE T2.a >= 1);

select * from t1, t2  where t1.a > any(select t3.b from t2, t3 where t2.a > any(select t4.a from t4, t5));

SELECT
  1
FROM
  t3
WHERE
  t3.b IN (
    SELECT
      2
    FROM
      t2
    WHERE
      t3.a IN (
        SELECT
          t1.a
        FROM
          t1
          LEFT JOIN T2 ON true
      )
  );

drop table t1, t2, t3, t4, t5;

--disable_warnings
drop table if exists a, c, cc;
--enable_warnings

CREATE TABLE `a` ( `col_int` int(11) DEFAULT NULL, `col_varchar_20` varchar(20) DEFAULT NULL, `col_int_key` int(11) DEFAULT NULL, `col_varchar` varchar(1) DEFAULT NULL, `pk` int(11) NOT NULL, `col_varchar_key` varchar(1) DEFAULT NULL, `col_varchar_10` varchar(10) DEFAULT NULL, `col_varchar_10_key` varchar(10) DEFAULT NULL, `col_varchar_20_key` varchar(20) DEFAULT NULL, PRIMARY KEY (`pk`), KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384, KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384, KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384, KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384);
CREATE TABLE `c` ( `col_varchar_10_key` varchar(10) DEFAULT NULL, `col_varchar_20` varchar(20) DEFAULT NULL, `pk` int(11) NOT NULL, `col_varchar` varchar(1) DEFAULT NULL, `col_varchar_20_key` varchar(20) DEFAULT NULL, `col_varchar_10` varchar(10) DEFAULT NULL, `col_varchar_key` varchar(1) DEFAULT NULL, `col_int` int(11) DEFAULT NULL, `col_int_key` int(11) DEFAULT NULL, PRIMARY KEY (`pk`), KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384, KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384, KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384, KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384);
CREATE TABLE `cc` ( `col_int` int(11) DEFAULT NULL, `col_varchar_10` varchar(10) DEFAULT NULL, `col_varchar` varchar(1) DEFAULT NULL, `col_varchar_20_key` varchar(20) DEFAULT NULL, `col_varchar_key` varchar(1) DEFAULT NULL, `col_varchar_20` varchar(20) DEFAULT NULL, `col_int_key` int(11) DEFAULT NULL, `col_varchar_10_key` varchar(10) DEFAULT NULL, `pk` int(11) NOT NULL, PRIMARY KEY (`pk`), KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384, KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384, KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384, KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384);

EXPLAIN SELECT   table1 . col_int_key AS field1 , table1 . col_varchar_10_key AS field2 , table1 . col_int_key AS field3 , table1 . `col_varchar_10_key` AS field4 , table2 . col_varchar_key AS field5 , table1 . col_varchar_20_key AS field6 , table1 . col_varchar_20_key AS field7 , table1 . col_varchar_20_key AS field8 FROM ( (  SELECT   SUBQUERY1_t1 . * FROM CC AS SUBQUERY1_t1  ) AS table1 INNER JOIN ( ( A AS table2 RIGHT  JOIN (  SELECT   SUBQUERY2_t1 . * FROM C AS SUBQUERY2_t1 WHERE (   EXISTS ( SELECT   CHILD_SUBQUERY1_t2 . `col_varchar_key` AS CHILD_SUBQUERY2_field1 FROM ( C AS CHILD_SUBQUERY1_t1 RIGHT OUTER JOIN C AS CHILD_SUBQUERY1_t2 ON (CHILD_SUBQUERY1_t2 . `pk` = CHILD_SUBQUERY1_t1 . `pk` ) ) WHERE CHILD_SUBQUERY1_t1 . `col_int` = SUBQUERY2_t1 . `col_int` ) AND SUBQUERY2_t1 . `col_varchar_20_key` >= SUBQUERY2_t1 . `col_varchar_10` ) ) AS table3 ON (table3 . `col_varchar_key` = table2 . `col_varchar_key`  ) ) ) ON (table3 . `col_varchar` = table2 . `col_varchar_key`  OR table3 . `col_int_key`  IN ( SELECT 2 UNION  SELECT 161 ) ) ) WHERE (   EXISTS ( SELECT   SUBQUERY4_t1 . `col_varchar_20` AS SUBQUERY4_field1 FROM ( C AS SUBQUERY4_t1 INNER JOIN ( CC AS SUBQUERY4_t2 INNER JOIN CC AS SUBQUERY4_t3 ON (SUBQUERY4_t3 . `pk` = SUBQUERY4_t2 . `col_int_key`  ) ) ON (SUBQUERY4_t3 . `col_varchar_10_key` = SUBQUERY4_t2 . `col_varchar_key`  ) )) );

drop table a, c, cc;