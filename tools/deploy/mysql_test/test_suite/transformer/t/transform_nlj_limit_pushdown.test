## =================
drop table if exists t1, t2, t3, t4;

--explain_protocol 0
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create table t4(c1 int, c2 int);

insert into t1 values(1, 1);
insert into t2 values(1, 1);
insert into t3 values(1, 1);
insert into t4 values(1, 1);
--explain_protocol 2
select 1 from t1 left join t2 on 1 = 1 inner join (t3 left join t4 on (exists (select t3.c1 from dual))) on t2.c1 = t3.c1 limit 1;
select /*+no_rewrite*/1 from t1 left join t2 on 1 = 1 inner join (t3 left join t4 on (exists (select t3.c1 from dual))) on t2.c1 = t3.c1 limit 1;
--explain_protocol 0
drop table if exists t1, t2, t3, t4;
## =================

## =================
--explain_protocol 0
drop table if exists t1, t2, t3;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);
create table t3(c1 int primary key, c2 int);

insert into t1 values(1, 1), (2, 2);
insert into t2 values(1, 1), (2, 2);
insert into t3 values(1, 1), (2, 2);

--explain_protocol 2
select v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0 limit 1;
select /*+no_rewrite*/v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0 limit 1;

select v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on exists (select c1 from t3 where v.c1 = t3.c1) limit 1;
select /*+no_rewrite*/v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on exists (select c1 from t3 where v.c1 = t3.c1) limit 1;

select v.c1, (select sum(1) from dual) as c2 from  t1 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0 limit 1;
select /*+no_rewrite*/v.c1, (select sum(1) from dual) as c2 from  t1 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0 limit 1;

select v.c1, (select sum(1) from dual) as c2 from  t1 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where v.c1 = t3.c1 limit 1;
select /*+no_rewrite*/v.c1, (select sum(1) from dual) as c2 from  t1 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where v.c1 = t3.c1 limit 1;

select v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where t2.c1 = t3.c1 limit 1;
select /*+no_rewrite*/v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where t2.c1 = t3.c1 limit 1;

select v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where v.c1 = t3.c1 limit 1;
select /*+no_rewrite*/v.c1 from t1, t2 left join (select c1 + 1 as c1 from t2) v on v.c1 > 0, t3 where v.c1 = t3.c1 limit 1;

select v.c1,(select c1 from t1 where v.c1 > 0 limit 1) as c2 from t1, t2 left join (select c1 + 1 as c1 from t2) v on (select c1 from t1 where v.c1 > 0 limit 1) limit 1;
select /*+no_rewrite*/v.c1,(select c1 from t1 where v.c1 > 0 limit 1) as c2 from t1, t2 left join (select c1 + 1 as c1 from t2) v on (select c1 from t1 where v.c1 > 0 limit 1) limit 1;
--explain_protocol 0
drop table if exists t1, t2, t3;
