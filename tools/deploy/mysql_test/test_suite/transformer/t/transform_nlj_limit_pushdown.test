## 
--disable_warnings
DROP TABLE IF EXISTS `a`;
CREATE TABLE `a` (
  `pk` int(11) NOT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`));

DROP TABLE IF EXISTS `c`;
CREATE TABLE `c` (
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`)
);

INSERT INTO `c` VALUES ('c','f','u','d','l',0,2,1,'w'),('b',NULL,NULL,'g','l',0,NULL,2,'w');

DROP TABLE IF EXISTS `cc`;
CREATE TABLE `cc` (
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`));

--explain_protocol 2
SELECT 1
FROM   (select * from a limit 10),
       c AS sq1
       LEFT OUTER JOIN cc AS sq2
                    ON sq1 . col_varchar_key < (SELECT Count(1) AS c1
                                                FROM   DUAL)
WHERE  sq1 . col_varchar_key = '1'
LIMIT  10;
SELECT /*+no_rewrite*/1
FROM   (select * from a limit 10),
       c AS sq1
       LEFT OUTER JOIN cc AS sq2
                    ON sq1 . col_varchar_key < (SELECT Count(1) AS c1
                                                FROM   DUAL)
WHERE  sq1 . col_varchar_key = '1'
LIMIT  10;

SELECT 1
FROM   a AS table1, (SELECT t1 . *
                    FROM   ( c AS t1
                             LEFT  JOIN ( cc AS t2
                                               LEFT OUTER JOIN cc AS
                                               t3
                                                            ON (
                                               t3 . `pk` =
                                               t2 . `pk` )
                                             )
                                          ON ( t3 . col_varchar_key =
                                               t2 . col_varchar
                                               AND t1 . col_varchar_key
                                                   <
                                                   (SELECT
                                                   Count(1)
                                                   AS
                                                   cnt
                                                   FROM
                                                   dual) ) )) AS
                                        table2
WHERE  ( table2 . col_varchar_key IN (SELECT 'h'
                                      UNION
                                      SELECT 'j') )
limit 1; 
SELECT /*+no_rewrite*/1
FROM   a AS table1, (SELECT t1 . *
                    FROM   ( c AS t1
                             LEFT  JOIN ( cc AS t2
                                               LEFT OUTER JOIN cc AS
                                               t3
                                                            ON (
                                               t3 . `pk` =
                                               t2 . `pk` )
                                             )
                                          ON ( t3 . col_varchar_key =
                                               t2 . col_varchar
                                               AND t1 . col_varchar_key
                                                   <
                                                   (SELECT
                                                   Count(1)
                                                   AS
                                                   cnt
                                                   FROM
                                                   dual) ) )) AS
                                        table2
WHERE  ( table2 . col_varchar_key IN (SELECT 'h'
                                      UNION
                                      SELECT 'j') )
limit 1; 
--explain_protocol 0
DROP TABLE IF EXISTS a, c, cc;

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
--error 0, 1051
drop table t3;
--error 0, 1051
drop table t4;
--error 0, 1051
drop table t5;
