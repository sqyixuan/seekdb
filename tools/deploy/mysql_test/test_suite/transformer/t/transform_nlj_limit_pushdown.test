# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
--error 0, 1051
drop table t3;
--error 0, 1051
drop table t4;
--error 0, 1051
drop table t5;

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);
create table t4(c1 int, c2 int, c3 int);
create table t5(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx_c1 on t4(c1);

insert into t1 values(1, 1, 1), (1, 2, 3), (3, 2, NULL);
insert into t2 values(1, 1, NULL), (2, 2, 3), (3, 2, NULL);
insert into t3 values(1, NULL, 2), (1, 3, 3), (3, 1, 1);
insert into t4 values(1, 2, 2), (2, 3, 3), (NULL, NULL, NULL);
insert into t5 values(1, 3, 3), (2, 3, 3), (3, NULL, NULL);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
select count(*) from t5;

--explain_protocol 2
--result_format 4

# basic table
select t1.* from t1, t2 limit 5;
select /*+no_rewrite*/ t1.* from t1, t2 limit 5;

select t1.* from t1, t2 where t1.c1 > 0 and t2.c1 > 0 limit 5;
select /*+no_rewrite*/ t1.* from t1, t2 where t1.c1 > 0 and t2.c1 > 0 limit 5;

# not nlj
select t1.* from t1, t2 where t1.c1 = t2.c1 limit 5;
select /*+no_rewrite*/ t1.* from t1, t2 where t1.c1 = t2.c1 limit 5;

select t1.* from t1, t2 where t1.c1 > 0 order by t1.c1, t1.c2, t1.c3 limit 5;
select /*+no_rewrite*/ t1.* from t1, t2 where t1.c1 > 0 order by t1.c1, t1.c2, t1.c3 limit 5;

# can't push down limit
select t1.* from t1, t2 where t1.c1 > 0 order by t1.c1 + t2.c1 limit 5;
select /*+no_rewrite*/ t1.* from t1, t2 where t1.c1 > 0 order by t1.c1 + t2.c1 limit 5;

select * from t1, t2, t3 where t1.c1 > 0 order by t1.c1 + t3.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 > 0 order by t1.c1 + t3.c1 limit 10;

select * from t1, t2 where t1.c1 > 0 and t2.c1 > 0 order by t1.c1, t2.c2 limit 5;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 > 0 and t2.c1 > 0 order by t1.c1, t2.c2 limit 5;

select t1.* from t1 inner join t2 where t1.c1 > 0 and t2.c1 > 0 order by t1.c1, t1.c2, t1.c3 limit 5;
select /*+no_rewrite*/ t1.* from t1 inner join t2 where t1.c1 > 0 and t2.c1 > 0 order by t1.c1, t1.c2, t1.c3 limit 5;

# with left join
select t1.* from (t1 left join t2 on t1.c1 = t2.c1), t3 where t3.c1 > 0 limit 5;
select /*+no_rewrite*/ t1.* from (t1 left join t2 on t1.c1 = t2.c1), t3 where t3.c1 > 0 limit 5;

select * from t1, (t2 left join t3 on t2.c1 > t3.c1) where t1.c1 > 0 limit 10;
select /*+no_rewrite*/ * from t1, (t2 left join t3 on t2.c1 > t3.c1) where t1.c1 > 0 limit 10;

select t1.* from t1 left join t2 on t1.c1 > 0 where t2.c1 > 0 limit 10;
select /*+no_rewrite*/ t1.* from t1 left join t2 on t1.c1 > 0 where t2.c1 > 0 limit 10;

# generated view
select * from (select c1 from t1 group by c1) V, t2 where V.c1 > 0 limit 5;
select /*+no_rewrite*/ * from (select /*+no_rewrite*/ c1 from t1 group by c1) V, t2 where V.c1 > 0 limit 5;

select * from (select c1 from t1 where c1 < (select max(c1) from t3)) V, t2 where V.c1 > 0 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 where c1 < (select max(c1) from t3)) V, t2 where V.c1 > 0 limit 5;

select * from (select c1 from t1 group by c1) V left join t2 on V.c1 = t2.c1, t3 where V.c1 > 0 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 group by c1) V left join t2 on V.c1 = t2.c1, t3 where V.c1 > 0 limit 5;

select * from (select c1 from t1 group by c1) V, t2, t3 where V.c1 = t3.c1 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 group by c1) V, t2, t3 where V.c1 = t3.c1 limit 5;

select * from (select c1 from t1 group by c1) V1, (select c2 from t2 group by c2) V2 where V1.c1 > 0 order by V1.c1 limit 10;
select /*+no_rewrite*/ * from (select c1 from t1 group by c1) V1, (select c2 from t2 group by c2) V2 where V1.c1 > 0 order by V1.c1 limit 10;

# V already contains limit, only t2 needs to do limit pushdown
select * from (select c1 from t1 group by c1 limit 10) V, t2 where V.c1 > 0 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 group by c1 limit 10) V, t2 where V.c1 > 0 limit 5;

# both V1, V2 already contains limit, no need to do limit pushdown
select * from (select c1 from t1 limit 10) V1, (select * from t2 limit 10) V2 where V1.c1 > 0 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 limit 10) V1, (select * from t2 limit 10) V2 where V1.c1 > 0 limit 5;

select * from (select c1 from t1 limit 10) V1, (select * from t2 limit 10) V2, t3 where V1.c1 = V2.c1 order by V1.c1, t3.c1 limit 5;
select /*+no_rewrite*/ * from (select c1 from t1 limit 10) V1, (select * from t2 limit 10) V2, t3 where V1.c1 = V2.c1 order by V1.c1, t3.c1 limit 5;

# contains distinct, can not pushdown
select distinct * from t1, t2 where t1.c1 > 1 order by t1.c1, t2.c1 limit 10;
select /*+no_rewrite*/ distinct * from t1, t2 where t1.c1 > 1 order by t1.c1, t2.c1 limit 10;

# V2 is a scalor group by, only t1 needs to do limit pushdown
select * from t1, (select count(*) as cnt2 from t2) V2 where V2.cnt2 > 0 order by V2.cnt2 limit 10;
select /*+no_rewrite*/ * from t1, (select count(*) as cnt2 from t2) V2 where V2.cnt2 > 0 order by V2.cnt2 limit 10;

select * from (select count(*) as cnt1 from t1) V1, (select count(*) as cnt2 from t2) V2 limit 10;
select /*+no_rewrite*/ * from (select count(*) as cnt1 from t1) V1, (select count(*) as cnt2 from t2) V2 limit 10;

select L.* from (select c1 as C, max(t1.c1) as agg from t1 group by c1) L, t2 where L.agg = L.C limit 5;
select /*+no_rewrite*/ L.* from (select /*+no_rewrite*/ c1 as C, max(t1.c1) as agg from t1 group by c1) L, t2 where L.agg = L.C limit 5;

select L.* from (select c1 as C, max(t1.c1) as agg from t1 group by c1) L, t2 where L.agg = L.C order by L.C limit 5;
select /*+no_rewrite*/ L.* from (select /*+no_rewrite*/ c1 as C, max(t1.c1) as agg from t1 group by c1) L, t2 where L.agg = L.C order by L.C limit 5;

# [t1 inner join t2 left join t3]
select * from t2 inner join t1 on t2.c1 > 0 left join t3 on t2.c1 = t3.c1 order by t2.c1 limit 5;
select /*+no_rewrite*/ * from t2 inner join t1 on t2.c1 > 0 left join t3 on t2.c1 = t3.c1 order by t2.c1 limit 5;

# mixed
select * from t2 inner join t1 left join t3 on t2.c1 = t1.c1 and t1.c1 = t3.c1 where t2.c1 < t1.c2 order by t1.c1, t2.c1 limit 5;
select /*+no_rewrite*/ * from t2 inner join t1 left join t3 on t2.c1 = t1.c1 and t1.c1 = t3.c1 where t2.c1 < t1.c2 order by t1.c1, t2.c1 limit 5;

# t2, [t1 left join t3]
select * from t2 inner join t1 left join t3 on t2.c1 > 0 and t1.c1 > 0 where t3.c1 = t1.c2 order by t2.c1 limit 5;
select /*+no_rewrite*/ * from t2 inner join t1 left join t3 on t2.c1 > 0 and t1.c1 > 0 where t3.c1 = t1.c2 order by t2.c1 limit 5;

# [t1 left join t2], t3
select * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > 0 order by t2.c1 limit 5;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > 0 order by t2.c1 limit 5;

# t1 left join t2 inner join t3 left join t4
select * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > 0 left join t4 on t4.c1 > 0 order by t2.c1 limit 5;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > 0 left join t4 on t4.c1 > 0 order by t2.c1 limit 5;

select * from t1, t2, t3 where t1.c1 > 0 and t2.c1 > 0 and t2.c1 > t3.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 > 0 and t2.c1 > 0 and t2.c1 > t3.c1 limit 10;

select * from t1, t2, t3 where t1.c1 = 1 and t1.c1 = t3.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 = 1 and t1.c1 = t3.c1 limit 10;

select * from t1, t2, t3, t4 where t1.c1 > 0 and t3.c1 > t4.c1 and t2.c1 > 0 and t1.c1 > t2.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3, t4 where t1.c1 > 0 and t3.c1 > t4.c1 and t2.c1 > 0 and t1.c1 > t2.c1 limit 10;

select * from t1, t2, t3, t4 order by t1.c1, t2.c1, t3.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3, t4 order by t1.c1, t2.c1, t3.c1 limit 10;

# t2, [t1, t3, t4]
select * from t1, t2, t3, t4 where t1.c1 < t3.c1 + t4.c1 and t2.c1 > 0 order by t1.c1, t2.c1, t3.c1 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3, t4 where t1.c1 < t3.c1 + t4.c1 and t2.c1 > 0 order by t1.c1, t2.c1, t3.c1 limit 10;

select * from t1, t2 inner join t3 on t2.c1 > 0 where t1.c1 > 0 limit 10;
select /*+no_rewrite*/ * from t1, t2 inner join t3 on t2.c1 > 0 where t1.c1 > 0 limit 10;

# t1, [t2, t3]
select * from t1, t2 inner join t3 on t2.c1 > t3.c1 where t1.c1 > 0 limit 10;
select /*+no_rewrite*/ * from t1, t2 inner join t3 on t2.c1 > t3.c1 where t1.c1 > 0 limit 10;

select * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > t1.c1 order by t2.c1 limit 5;
select /*+no_rewrite*/ * from t1 left join t2 on t1.c1 > 0 inner join t3 on t3.c1 > t1.c1 order by t2.c1 limit 5;

# with partition info
--sorted_result
select * from t1, t2, t3, t4, t5 where t1.c1 > 0 and t5.c1 > 0 order by t1.c1, t1.c2, t2.c1, t3.c1, t4.c1, t5.c1 limit 5;
--sorted_result
select /*+no_rewrite*/ * from t1, t2, t3, t4, t5 where t1.c1 > 0 and t5.c1 > 0 order by t1.c1, t1.c2, t2.c1, t3.c1, t4.c1, t5.c1 limit 5;

select * from t1, t2, t3, t4, t5 where t1.c1 > t3.c1 and t2.c1 > t5.c1 and t4.c1 > 0 order by t1.c1, t1.c2, t2.c1, t3.c1, t4.c1, t5.c1 limit 5;
select /*+no_rewrite*/ * from t1, t2, t3, t4, t5 where t1.c1 > t3.c1 and t2.c1 > t5.c1 and t4.c1 > 0 order by t1.c1, t1.c2, t2.c1, t3.c1, t4.c1, t5.c1 limit 5;

### with semi info, can pushdown limit
select * from t1, t2 where t1.c1 in (select c1 from t2) limit 10;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 in (select c1 from t2) limit 10;

select * from t1, t2 where t1.c1 in (select t2.c1 from t2 left join t3 on t2.c1 = t3.c1) limit 10;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 in (select t2.c1 from t2 left join t3 on t2.c1 = t3.c1) limit 10;

select * from t1, t2, t3 where t1.c1 > 1 and t2.c1 + t3.c1 in (select c1 + 2 from t1) order by t1.c1, t2.c2, t3.c2 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 > 1 and t2.c1 + t3.c1 in (select c1 + 2 from t1) order by t1.c1, t2.c2, t3.c2 limit 10;

select * from t1, t2, t3 where t1.c1 in (select min(c1) from t3 group by c1) and t2.c1 + t3.c1 in (select c1 + 2 from t1) order by t1.c1, t2.c2, t3.c2 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 in (select min(c1) from t3 group by c1) and t2.c1 + t3.c1 in (select c1 + 2 from t1) order by t1.c1, t2.c2, t3.c2 limit 10;

select * from t1, t2, t3 where t1.c1 > 1 and t2.c1 in (select c1 from t3 where t1.c1 > t3.c1) order by t1.c1, t2.c2, t3.c2 limit 10;
select /*+no_rewrite*/ * from t1, t2, t3 where t1.c1 > 1 and t2.c1 in (select c1 from t3 where t1.c1 > t3.c1) order by t1.c1, t2.c2, t3.c2 limit 10;

select * from t1, t2 where t1.c1 not in (select c1 from t2) limit 10;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 not in (select c1 from t2) limit 10;

select * from t1, t2 where exists (select c1 from t2) limit 10;
select /*+no_rewrite*/ * from t1, t2 where exists (select c1 from t2) limit 10;

select * from t1, t2 where not exists (select c1 from t2) limit 10;
select /*+no_rewrite*/ * from t1, t2 where not exists (select c1 from t2) limit 10;

select * from t1, (select c1, c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t1) limit 10;
select /*+no_rewrite*/ * from t1, (select c1, c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t1) limit 10;

select * from t1, (select min(c1) as c1, min(c2) as c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t1) limit 10;
select /*+no_rewrite*/ * from t1, (select min(c1) as c1, min(c2) as c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t1) limit 10;

select * from t1, (select c1, c2 from t2 group by c1, c2) V1 where t1.c1 in (select c1 from t2) limit 10;
select /*+no_rewrite*/ * from t1, (select c1, c2 from t2 group by c1, c2) V1 where t1.c1 in (select c1 from t2) limit 10;

### with semi info, but can not pushdown limit
select * from t1, t2 where t1.c1 + t2.c1 in (select c2 from t1) limit 10;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 + t2.c1 in (select c2 from t1) limit 10;

select * from t1, t2 where t1.c1 in (select c2 from t2 where t1.c2 > t2.c2) limit 10;
select /*+no_rewrite*/ * from t1, t2 where t1.c1 in (select c2 from t2 where t1.c2 > t2.c2) limit 10;

select * from t1, (select c1, c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t2 where t2.c1 > t1.c1) limit 10;
select /*+no_rewrite*/ * from t1, (select c1, c2 from t2 group by c1, c2) V1 where V1.c1 in (select c1 from t2 where t2.c1 > t1.c1) limit 10;

## =================
SELECT  t1.c1 as t1_c1,
        t1.c2 as t1_c2,
        t2.c1 as t2_c1,
        t2.c2 as t2_c2,
        t3.c2 as t3_c2
FROM    t1, t2, t3
WHERE   t1.c1 = 1
AND     t1.c1 = t3.c1
AND     t2.c2 = t1.c2
ORDER BY t1.c2 limit 5;

SELECT /*+no_rewrite*/  
        t1.c1 as t1_c1,
        t1.c2 as t1_c2,
        t2.c1 as t2_c1,
        t2.c2 as t2_c2,
        t3.c2 as t3_c2
FROM    t1, t2, t3
WHERE   t1.c1 = 1
AND     t1.c1 = t3.c1
AND     t2.c2 = t1.c2
ORDER BY t1.c2 limit 5;
