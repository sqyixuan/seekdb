--disable_warnings
drop table if exists t1, table1_key_pk_parts_2_bigint, t2;
--enable_warnings

CREATE TABLE table1_key_pk_parts_2_bigint (
col_bigint bigint,
col_datetime datetime,
col_date_key date,
col_char_20 char(20),
col_mediumint_key mediumint,
col_bigint_key bigint,
col_char_30 char(30),
col_varchar_10 varchar(10),
col_smallint smallint,
col_int_key int,
col_integer_key integer,
col_char_20_key char(20),
col_decimal_30_5 decimal(30,5),
col_timestamp_key timestamp NULL DEFAULT NULL,
col_decimal_20_0 decimal(20,0),
col_varchar_10_key varchar(10),
col_tinyint tinyint,
col_datetime_key datetime,
col_decimal_30_5_key decimal(30,5),
col_char_30_key char(30),
col_tinyint_key tinyint,
col_integer integer,
col_int int,
pk bigint,
col_smallint_key smallint,
col_mediumint mediumint,
col_date date,
col_decimal_20_0_key decimal(20,0),
col_timestamp timestamp NULL DEFAULT NULL,
/*Indices*/
key idx23(pk, col_date_key ),
key idx5(pk, col_mediumint_key ),
key idx11(pk, col_bigint_key ),
key idx7(pk, col_int_key ),
key idx9(pk, col_integer_key ),
key idx17(pk, col_char_20_key ),
key idx27(pk, col_timestamp_key ),
key idx21(pk, col_varchar_10_key ),
key idx25(pk, col_datetime_key ),
key idx15(pk, col_decimal_30_5_key ),
key idx19(pk, col_char_30_key ),
key idx1(pk, col_tinyint_key ),
primary key (pk) ,
key idx3(pk, col_smallint_key ),
key idx13(pk, col_decimal_20_0_key ))    PARTITION BY key(pk) partitions 2 ; 
INSERT INTO table1_key_pk_parts_2_bigint VALUES  (950259521375174656, '2008-07-02', '2000-07-11 12:22:49.032334', NULL, NULL, 6, 'a', 'xyrg', NULL, NULL, 8, 'bxyrgtfcvv', NULL, '2000-01-06 02:48:40', 8, '', 21, '2004-05-13 16:07:13.013885', 0, 'sbxyr', NULL, 7, -339410944, 1, NULL, NULL, '2004-03-28 14:50:29', 0, '2001-12-28 14:10:16') ;

create table t1(c1 int,c2 int ,c3 int);
insert into t1 values (1,1,1);
insert into t1 values (1,1,2);
insert into t1 values (2,1,2);

create table t2(c11 int,c22 int ,c33 int);
insert into t2 values (1,1,1);
insert into t2 values (1,1,2);
insert into t2 values (2,1,2);
insert into t2 values (3,1,2);

--explain_protocol 1
--result_format 4

SELECT /*+no_rewrite*/ COL_INT_KEY,COL_VARCHAR_10_KEY,MIN(CASE WHEN COL_INT_KEY IS NULL THEN 0 ELSE COL_BIGINT END) AS COLUMN2 
FROM table1_key_pk_parts_2_bigint 
WHERE COL_INT_KEY IS NULL AND COL_VARCHAR_10_KEY ='' AND  EXISTS((SELECT  COUNT(*) FROM t1 B WHERE REGEXP_LIKE(COL_VARCHAR_10_KEY, '^[a-zA-Z]+'))) GROUP BY COL_INT_KEY,COL_VARCHAR_10_KEY ORDER BY 1;
SELECT  COL_INT_KEY,COL_VARCHAR_10_KEY,MIN(CASE WHEN COL_INT_KEY IS NULL THEN 0 ELSE COL_BIGINT END) AS COLUMN2 
FROM table1_key_pk_parts_2_bigint 
WHERE COL_INT_KEY IS NULL AND COL_VARCHAR_10_KEY ='' AND  EXISTS((SELECT  COUNT(*) FROM t1 B WHERE REGEXP_LIKE(COL_VARCHAR_10_KEY, '^[a-zA-Z]+'))) GROUP BY COL_INT_KEY,COL_VARCHAR_10_KEY ORDER BY 1;

SELECT /*+no_rewrite*/ COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE EXISTS((SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = 'a'));
SELECT COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE EXISTS((SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = 'a'));

SELECT /*+no_rewrite*/ COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE EXISTS((SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = B.c1));
SELECT COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE EXISTS((SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = B.c1));

SELECT /*+no_rewrite*/ C11 ,
SUM(CASE WHEN C11 IS NULL THEN 0 ELSE C11 END) AS COLUMN1 
FROM T2 WHERE 
EXISTS(SELECT COUNT(*) FROM t1 WHERE C11 <2)
GROUP BY C11,C22,C33;
SELECT C11 ,
SUM(CASE WHEN C11 IS NULL THEN 0 ELSE C11 END) AS COLUMN1 
FROM T2 WHERE 
EXISTS(SELECT COUNT(*) FROM t1 WHERE C11 <2)
GROUP BY C11,C22,C33;

SELECT /*+no_rewrite*/ COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE col_bigint > any (SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = 'a');
SELECT COL_INT_KEY,COL_VARCHAR_10_KEY  FROM table1_key_pk_parts_2_bigint  WHERE col_bigint > any (SELECT COUNT(*) FROM t1 B WHERE COL_VARCHAR_10_KEY = 'a');

drop table t1, table1_key_pk_parts_2_bigint, t2;