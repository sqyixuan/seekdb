# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: place_group_by hint 测试

--disable_warnings
drop table if exists orders, users, products;
--enable_warnings

create table users(user_id int, city varchar(20), age int);
create table products(product_id int, category varchar(20), price int);
create table orders(order_id int, user_id int, product_id int, quantity int, amount int);

INSERT INTO users VALUES (1, 'New York', 30);
INSERT INTO users VALUES (2, 'Los Angeles', 25);
INSERT INTO users VALUES (3, 'Chicago', 40);

INSERT INTO products VALUES (1, 'Electronics', 500);
INSERT INTO products VALUES (2, 'Books', 20);
INSERT INTO products VALUES (3, 'Clothing', 100);

INSERT INTO orders VALUES (1, 1, 1, 2, 1000);
INSERT INTO orders VALUES (2, 2, 2, 5, 100);
INSERT INTO orders VALUES (4, 1, 2, 3, 60); 
INSERT INTO orders VALUES (5, 2, 1, 1, 500);

alter system flush plan cache;

--result_format 4
--explain_protocol 2
--enable_sorted_result

--echo # 禁用 groupby 下压
SELECT /*+no_rewrite*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压, 不指定表. 会分别下压到 o,p,u 表
SELECT /*+PLACE_GROUP_BY*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 o 表
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 u 表
SELECT /*+PLACE_GROUP_BY("u"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 p 表
SELECT /*+PLACE_GROUP_BY("p"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 o, u 表
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1" "u"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 o, p 表
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1" "p"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 p, u 表
SELECT /*+PLACE_GROUP_BY("p"@"SEL$1" "u"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # 强制 groupby 下压到 o, u, p 表
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1" "u"@"SEL$1" "p"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category;

--echo # hint 不指定表, group by 应该会下压到 o, p, u 表构成的视图中
SELECT /*+PLACE_GROUP_BY*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 指定下压到 o 表, 但是存在一个聚合函数的参数引用了 o,p 表, 无法单独下压 groupby 到 o 表
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 指定下压到 p 表, 但是存在一个聚合函数的参数引用了 o,p 表, 无法单独下压 groupby 到 p 表
SELECT /*+PLACE_GROUP_BY(("p"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 指定下压到 u 表, 因为所有包含聚合函数的表达式都没有引用 u, 可以单独下压到 u 表
SELECT /*+PLACE_GROUP_BY(("u"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # hint 指定下压到 o,p 组成的视图中, 但是因为 left join 包含了 u 表, 故 u 表也必须包含在下压视图中. hint 无效
SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "p"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # hint 指定表, group by 应该会下压到 o, p, u 表构成的视图中
SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "u"@"SEL$1" "p"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 测试 outline 回放, groupby 应该能下压到 o,p,u 构成的视图中
explain outline
SELECT 
/*+   
  BEGIN_OUTLINE_DATA
  USE_HASH_AGGREGATION(@"SEL$A33DF116")
  LEADING(@"SEL$A33DF116" ("VIEW1"@"SEL$C6D21C0F" "p2"@"SEL$1"))
  USE_NL(@"SEL$A33DF116" "p2"@"SEL$1") 
  USE_NL_MATERIALIZATION(@"SEL$A33DF116" "p2"@"SEL$1")
  USE_HASH_AGGREGATION(@"SEL$39FFD6E5")
  LEADING(@"SEL$39FFD6E5" ("u"@"SEL$1" ("o"@"SEL$1" "p"@"SEL$1"))) 
  USE_HASH(@"SEL$39FFD6E5" ("p"@"SEL$1" "o"@"SEL$1")) 
  FULL(@"SEL$39FFD6E5" "u"@"SEL$1")
  USE_HASH(@"SEL$39FFD6E5" "p"@"SEL$1")
  FULL(@"SEL$39FFD6E5" "o"@"SEL$1")
  FULL(@"SEL$39FFD6E5" "p"@"SEL$1")
  FULL(@"SEL$A33DF116" "p2"@"SEL$1")   
  OUTER_TO_INNER(@"SEL$1")
  PLACE_GROUP_BY(@"SEL$C6D21C0F" ("o"@"SEL$1" "u"@"SEL$1" "p"@"SEL$1")) 
  PRED_DEDUCE(@"SEL$A33DF115") 
  OPTIMIZER_FEATURES_ENABLE('') 
  END_OUTLINE_DATA  
   */
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # hint 指定表, 这样的 hint 写法是预期下压到 o,p,u 单表, 但这个下压非法, hint 无效
SELECT /*+PLACE_GROUP_BY("o"@"SEL$1" "u"@"SEL$1" "p"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
LEFT JOIN users u ON o.user_id = u.user_id
LEFT JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 测试 inner join 场景
--echo # hint 不指定表, group by 会下压到 (o, p) 视图和 u 上
SELECT /*+PLACE_GROUP_BY*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 指定 hint, group by 会下压到 (o, p) 视图和 u 上
SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "p"@"SEL$1") "u"@"SEL$1")*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 测试 outline 回放, group by 会下压到 (o, p) 和 u 上
explain outline 
SELECT
/*+   
  BEGIN_OUTLINE_DATA
  USE_HASH_AGGREGATION(@"SEL$A33DF117")
  LEADING(@"SEL$A33DF117" (("VIEW2"@"SEL$C6D21C0F" "VIEW1"@"SEL$C6D21C0F") "p2"@"SEL$1"))
  USE_NL(@"SEL$A33DF117" "p2"@"SEL$1") 
  USE_NL_MATERIALIZATION(@"SEL$A33DF117" "p2"@"SEL$1")
  USE_HASH(@"SEL$A33DF117" "VIEW1"@"SEL$C6D21C0F")
  USE_HASH_AGGREGATION(@"SEL$A33DF116")
  FULL(@"SEL$A33DF116" "u"@"SEL$1")
  USE_HASH_AGGREGATION(@"SEL$E153C7C4")
  LEADING(@"SEL$E153C7C4" ("p"@"SEL$1" "o"@"SEL$1"))  
  USE_HASH(@"SEL$E153C7C4" "o"@"SEL$1")
  FULL(@"SEL$E153C7C4" "p"@"SEL$1")
  FULL(@"SEL$E153C7C4" "o"@"SEL$1")
  FULL(@"SEL$A33DF117" "p2"@"SEL$1")   
  OUTER_TO_INNER(@"SEL$1")   
  PLACE_GROUP_BY(@"SEL$C6D21C0F" ("o"@"SEL$1" "p"@"SEL$1") "u"@"SEL$1")   
