  OPTIMIZER_FEATURES_ENABLE('') 
  END_OUTLINE_DATA 
   */
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # 指定 hint, group by 会下压到 (o, p, u) 构成的视图上
SELECT /*+PLACE_GROUP_BY(("o"@"SEL$1" "p"@"SEL$1" "u"@"SEL$1"))*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

--echo # outline 回放, group by 会下压到 (o, p, u) 构成的视图上
SELECT
/*+
  BEGIN_OUTLINE_DATA
  USE_HASH_AGGREGATION(@"SEL$B91BE001")
  LEADING(@"SEL$B91BE001" ("p2"@"SEL$1" "VIEW1"@"SEL$29D7F082"))
  USE_NL(@"SEL$B91BE001" "VIEW1"@"SEL$29D7F082")
  USE_NL_MATERIALIZATION(@"SEL$B91BE001" "VIEW1"@"SEL$29D7F082")
  FULL(@"SEL$B91BE001" "p2"@"SEL$1")
  USE_HASH_AGGREGATION(@"SEL$B91BE000")
  LEADING(@"SEL$B91BE000" ("u"@"SEL$1" ("o"@"SEL$1" "p"@"SEL$1")))
  USE_HASH(@"SEL$B91BE000" ("p"@"SEL$1" "o"@"SEL$1"))
  FULL(@"SEL$B91BE000" "u"@"SEL$1")
  USE_HASH(@"SEL$B91BE000" "p"@"SEL$1")
  FULL(@"SEL$B91BE000" "o"@"SEL$1")
  FULL(@"SEL$B91BE000" "p"@"SEL$1")
  PRED_DEDUCE(@"SEL$1")
  OUTER_TO_INNER(@"SEL$0208448F")
  PLACE_GROUP_BY(@"SEL$29D7F082" ("o"@"SEL$1" "u"@"SEL$1" "p"@"SEL$1"))
  OPTIMIZER_FEATURES_ENABLE('')
  END_OUTLINE_DATA
*/
  u.city,
  p.category,
  SUM(o.amount) AS total_sales
FROM orders o
INNER JOIN users u ON o.user_id = u.user_id
INNER JOIN products p ON o.product_id = p.product_id
INNER JOIN products p2 ON o.product_id = p.product_id
GROUP BY u.city, p.category
having min(o.amount + p.price) > 1;

drop table orders, users, products;