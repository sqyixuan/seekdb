#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
# link: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2;
create table t1(c1 int);
create table t2(c1 blob, c2 int, c3 varchar(10), c4 year);
--enable_warnings
--explain_protocol 2
--result_format 4

## test always false elimination
select * from t1 left join t2 on 1 = 0;
## test another issue assocated with always false elimination: 
select concat(t2.c3, t2.c4) from t1 left join t2 on 1 = 0;

## test left to anti
select * from t1 left join t2 on t1.c1 = t2.c2 where t2.c2 is null;

--explain_protocol 0
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
