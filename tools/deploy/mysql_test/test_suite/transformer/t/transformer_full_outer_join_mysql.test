--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer

## Scope: test full outer join in mysql mode.
## Date: 2020-03-23

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
--enable_warnings

create table t1(a int, b int, c int);
create table t2(a int, b int, c int);
create table t3(a int, b int, c int);
create table t4(a int, b int, c int);
create table t5(a int, b int, c int);
create table t6(a int, b int, c int);

insert into t1 values(1, 2, 3);
insert into t1 values(3, 2, 3);
insert into t1 values(5, 2, 3);
insert into t1 values(7, 2, 3);
insert into t1 values(null, 2, 3);
insert into t2 values(2, 3, 4);
insert into t2 values(4, 2, 3);
insert into t2 values(6, 2, 3);
insert into t2 values(8, 2, 3);
insert into t2 values(null, 2, 3);
insert into t3 values(1, 2, null);
insert into t3 values(2, 4, 3);
insert into t3 values(3, null, 3);
insert into t3 values(null, 4, 4);
insert into t3 values(5, null, 5);
insert into t4 values(2, 2, 2);
insert into t4 values(3, 3, 3);
insert into t4 values(4, 4, 4);
insert into t4 values(null, 5, 5);
insert into t4 values(5, null, null);
insert into t5 values(1, 1, 2);
insert into t5 values(3, 3, 3);
insert into t5 values(5, 5, 4);
insert into t5 values(null, 5, 5);
insert into t5 values(7, null, null);
insert into t6 values(2, 2, 2);
insert into t6 values(4, 4, 3);
insert into t6 values(6, 6, 4);
insert into t6 values(null, 5, 5);
insert into t6 values(8, null, null);

--result_format 4
--explain_protocol 2

--sorted_result
select * from t1 full join t3 on t1.a > t3.a group by (select t2.a * t1.a from t2 order by t2.a limit 1);

set autocommit = 0;
delete from t1 where not exists (select t2.a from t2 full join t3 on t2.a<t3.a where t1.a=t2.a);
select * from t1;
rollback;
delete /*+no_rewrite*/from t1 where not exists (select /*+no_rewrite*/t2.a from t2 full join t3 on t2.a<t3.a where t1.a=t2.a);
select * from t1;
rollback;

update t1 set t1.a=1 where not exists (select t2.a from t2 full join t3 on t2.a<t3.a where t1.a=t2.a);
select * from t1;
rollback;
update /*+no_rewrite*/t1 set t1.a=1 where not exists (select /*+no_rewrite*/t2.a from t2 full join t3 on t2.a<t3.a where t1.a=t2.a);
select * from t1;
rollback;

delete from t1 where t1.b in (select t2.a from t2 full join t3 on t2.a<t3.a);
select * from t1;
rollback;
delete /*+no_rewrite*/from t1 where t1.b in (select /*+no_rewrite*/t2.a from t2 full join t3 on t2.a<t3.a);
select * from t1;
rollback;

update t1 set t1.a=1 where t1.b in (select t2.a from t2 full join t3 on t2.a<t3.a);
select * from t1;
rollback;
update /*+no_rewrite*/t1 set t1.a=1 where t1.b in (select /*+no_rewrite*/t2.a from t2 full join t3 on t2.a<t3.a);
select * from t1;
rollback;

delete t1 from t1 full join t2 on t1.a < t2.a;
select * from t1;
rollback;
delete /*+no_rewrite*/t1 from t1 full join t2 on t1.a < t2.a;
select * from t1;
rollback;

delete t1 from (t1 full join t2 on t1.a<t2.a) full join (t4 full join t5 on t4.a<t5.a) on t1.a>t4.a;
select * from t1;
rollback;
delete /*+no_rewrite*/t1 from (t1 full join t2 on t1.a<t2.a) full join (t4 full join t5 on t4.a<t5.a) on t1.a>t4.a;
select * from t1;
rollback;

delete t1 from (t1 full join t2 on t1.a<t2.a full join t3 on t1.a<t3.a) full join (t4 full join t5 on t4.a<t5.a full join t6 on t5.a>t6.a) on t1.a<t4.a;
select * from t1;
rollback;
delete /*+no_rewrite*/t1 from (t1 full join t2 on t1.a<t2.a full join t3 on t1.a<t3.a) full join (t4 full join t5 on t4.a<t5.a full join t6 on t5.a>t6.a) on t1.a<t4.a;
select * from t1;
rollback;

set autocommit = 1;

#bug:
select * from t1 full join t2 on t2.a = 2;
select /*+no_rewrite*/* from t1 full join t2 on t2.a = 2;

select * from t1 full join t2 on t1.a = 3;
select /*+no_rewrite*/* from t1 full join t2 on t1.a = 3;


select * from t1 left join t2 on t1.a = t2.a full join t3 on t1.b = t2.b;
select /*+no_rewrite*/* from t1 left join t2 on t1.a = t2.a full join t3 on t1.b = t2.b;

SELECT   t3.a, t3.b 
FROM t1 FULL  JOIN (t2 FULL OUTER JOIN t3 ON t3.a = t2.a) ON t1.b+t2.b = t3.b 
ORDER BY 1, 2;

--error 1235
select * from t1 full join t2 on exists(select 1 from dual);

select * from t1 full join t2 on (t1.a, t1.b) = (t2.a, t2.b);
select /*+no_rewrite*/* from t1 full join t2 on (t1.a, t1.b) = (t2.a, t2.b);

drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t6;

