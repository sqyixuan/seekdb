call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T2', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.set_table_prefs('TEST', 'T3', 'ESTIMATE_BLOCK', 'false');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'for all columns size 64', estimate_percent=>100);

## test Classify OR Predicate 
select * from t1 where t1.a = 1 or t1.b = 1 or t1.c = 1 or t1.d = 1 or t1.a = 2 or t1.b = 2 or t1.c = 2 or t1.d = 2;
select /*+NO_REWRITE*/ * from t1 where t1.a = 1 or t1.b = 1 or t1.c = 1 or t1.d = 1 or t1.a = 2 or t1.b = 2 or t1.c = 2 or t1.d = 2;

select * from t1 where t1.a = 1 or t1.b = 1 or t1.c = 1 or t1.d = 1 or t1.e = 1 or t1.a = 2 or t1.b = 2 or t1.c = 2 or t1.d = 2 or t1.e = 2;
select /*+NO_REWRITE*/ * from t1 where t1.a = 1 or t1.b = 1 or t1.c = 1 or t1.d = 1 or t1.e = 1 or t1.a = 2 or t1.b = 2 or t1.c = 2 or t1.d = 2 or t1.e = 2;

select * from t1 where (t1.a >= 1 and t1.a <=2) or t1.b = 1 or t1.a = 3 or t1.b = 2;
select /*+NO_REWRITE*/ * from t1 where (t1.a >= 1 and t1.a <=2) or t1.b = 1 or t1.a = 3 or t1.b = 2;

select * from t1 where (t1.a = 2 or t1.b = 1 or t1.a = 3) and (t1.c = 1 or t1.d = 1 or t1.d = 3);
select /*+use_concat*/* from t1 where (t1.a = 2 or t1.b = 1 or t1.a = 3) and (t1.c = 1 or t1.d = 1 or t1.d = 3);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1 or t1.a = 3) and (t1.c = 1 or t1.d = 1 or t1.d = 3);

select /*+no_outer_to_inner use_concat*/ count(*) from t2 left join t1 on t1.a = t2.a or t1.a = 2 or t2.b = 2 or t1.a=3;
select /*+NO_REWRITE*/ count(*) from t2 left join t1 on t1.a = t2.a or t1.a = 2 or t2.b = 2 or t1.a=3;

select /*+no_outer_to_inner use_concat*/ count(*) from t2 right join t1 on t1.a = t2.a or t1.a = 2 or t2.b = 2 or t1.a=3;
select /*+NO_REWRITE*/ count(*) from t2 right join t1 on t1.a = t2.a or t1.a = 2 or t2.b = 2 or t1.a=3;

## test expand only part of tables
select * from t1,t2 where (t1.a = 3 or t1.b = 3 or t1.a = 2) and t1.c = t2.c;
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = 3 or t1.b = 3 or t1.a = 2) and t1.c = t2.c;

select * from t1,t2,t3 where (t1.a = 3 or t1.b = 3) and t1.c = t2.c and t2.a = t3.a;
select /*+NO_REWRITE*/ * from t1,t2,t3 where (t1.a = 3 or t1.b = 3) and t1.c = t2.c and t2.a = t3.a;

select * from t1 left join t2 on t1.c = t2.c,t3 where (t1.a = 3 or t1.b = 3) and t1.a = t3.a;
select /*+NO_REWRITE*/ * from t1 left join t2 on t1.c = t2.c,t3 where (t1.a = 3 or t1.b = 3) and t1.a = t3.a;

select /*+no_outer_to_inner*/ * from t1 right join t2 on t1.c = t2.c,t3 where (t1.a = 3 or t1.b = 3) and t2.a = t3.a;
select /*+NO_REWRITE*/ * from t1 right join t2 on t1.c = t2.c,t3 where (t1.a = 3 or t1.b = 3) and t2.a = t3.a;

## test delay subquery computation
select * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);

select * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2);

select * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2);

select * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2 where t1.a=t2.a);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and 0 = t1.c - (select /*+no_unnest*/ min(c) from t2 where t1.a=t2.a);

select * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and exists (select 1 from t3 where t3.a = t1.a);
select /*+NO_REWRITE*/ * from t1 where (t1.a = 2 or t1.b = 1) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a) and exists (select 1 from t3 where t3.a = t1.a);

select /*+use_concat*/ * from t1,t2 where (t1.a = 2 or t2.b = 1) and 0 = t1.b - (select /*+no_unnest*/ b from t2 limit 1) and exists (select 1 from t3 where t3.a = t1.a);
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = 2 or t2.b = 1) and 0 = t1.b - (select /*+no_unnest*/ b from t2 limit 1) and exists (select 1 from t3 where t3.a = t1.a);

select /*+use_concat*/ * from t1,t2 where (t1.a = 2 or t2.b = 1) and 0 = t1.b - (select /*+no_unnest*/ b from t2 limit 1) and not exists (select 1 from t3 where t3.a = t1.a);
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = 2 or t2.b = 1) and 0 = t1.b - (select /*+no_unnest*/ b from t2 limit 1) and not exists (select 1 from t3 where t3.a = t1.a);

select * from t1,t2 where (t1.a = 2 or t1.b = 1) and t1.c=t2.c and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = 2 or t1.b = 1) and t1.c=t2.c and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);

select * from t1,t2 where (t1.a = t2.a or t1.b = t2.b) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);
select /*+use_concat*/ * from t1,t2 where (t1.a = t2.a or t1.b = t2.b) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = t2.a or t1.b = t2.b) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t2.a > 3);

select * from t1,t2 where (t1.a = t2.a or t1.b = t2.b) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a);
select /*+NO_REWRITE*/ * from t1,t2 where (t1.a = t2.a or t1.b = t2.b) and 0 = t1.b - (select /*+no_unnest*/ min(b) from t2 where t1.a=t2.a);

select * from t1,t2,t3 where (t1.a = 3 or t1.b = 3) and t2.a = t1.a and t2.a = t3.a and t1.b in (select b from t2 where t1.a=t2.a limit 2);
select /*+NO_REWRITE*/ * from t1,t2,t3 where (t1.a = 3 or t1.b = 3) and t2.a = t1.a and t2.a = t3.a and t1.b in (select b from t2 where t1.a=t2.a limit 2);

select /*+use_concat*/ * from t1,t2 left join t3 on t2.c=t3.c where (t1.a=3 or t2.a=3) and t1.b=t2.b and t1.c in (select a from t3 v where t1.b=v.b order by c limit 3);
select /*+no_rewrite*/ * from t1,t2 left join t3 on t2.c=t3.c where (t1.a=3 or t2.a=3) and t1.b=t2.b and t1.c in (select a from t3 v where t1.b=v.b order by c limit 3);

select /*+use_concat*/ * from t1,t2 where (t1.a=1 or t2.a=1) and t1.b=t2.b and exists (select 1 from t3 where t1.c=t3.c) and t1.c in (select a from t3 v where t1.b=v.b order by c limit 3);
select /*+no_rewrite*/ * from t1,t2 where (t1.a=1 or t2.a=1) and t1.b=t2.b and exists (select 1 from t3 where t1.c=t3.c) and t1.c in (select a from t3 v where t1.b=v.b order by c limit 3);

## shared subqueries
select /*+use_concat*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v where (c1 > 2 or c2 = 3) and c1 < 5;
select /*+no_rewrite*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v where (c1 > 2 or c2 = 3) and c1 < 5;

select /*+use_concat*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v join t2 on c2=t2.a where (c1 > 1 or c2 = 3) and c1 < 5;
select /*+no_rewrite*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v join t2 on c2=t2.a where (c1 > 1 or c2 = 3) and c1 < 5;

select /*+use_concat*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v where (c1 > 1 or c2 = 3) and c1 < 5 and exists (select 1 from t3 where t3.a = v.c1);
select /*+no_rewrite*/ * from (select (select a from t1 order by b limit 2,1) as c1, b as c2 from t1) v where (c1 > 1 or c2 = 3) and c1 < 5 and exists (select 1 from t3 where t3.a = v.c1);

select /*+use_concat*/ * from (select (select a from t1 order by b limit 2,1) as c1, (select b from t1 order by a limit 2,1) as c2, c as c3 from t1) v where (c1 > 1 or c3 = 3) and c1+c2 < 5 and c2 < 2;
select /*+no_rewrite*/ * from (select (select a from t1 order by b limit 2,1) as c1, (select b from t1 order by a limit 2,1) as c2, c as c3 from t1) v where (c1 > 1 or c3 = 3) and c1+c2 < 5 and c2 < 2;

drop table t1,t2,t3;

