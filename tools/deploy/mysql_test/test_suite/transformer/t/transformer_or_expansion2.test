--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhanyue.zzy
#owner group: sql1
# tags: optimizer
#test or-expansion cost-based transformation

--result_format 4
--explain_protocol 2

## or expansion log plan check for topK & multi index

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, index idx_c1_c2(c1, c2));
create table t2(c1 int, c2 int, c3 int, index idx_c1(c1), index idx_c2(c2));

## top K
select * from t1 where c1 in (1,2) order by c2 limit 10;
select * from t1, t2 where t1.c1 in (1,2,3) and t1.c3 = t2.c1 order by t1.c2 limit 10;

## multi index
select * from t2 where c1 = 4 or c2 = 5;
select /*+index(t2 idx_c1)*/ * from t2 where c1 = 4 or c2 = 5;
select /*+ use_concat index(t2 idx_c1)*/ * from t2 where c1 = 4 or c2 = 5;

select * from t2 where (c1 = 4 or c2 = 5) and c3 = 1;
select /*+index(t2 idx_c1)*/ * from t2 where (c1 = 4 or c2 = 5) and c3 = 1;
select /*+ use_concat index(t2 idx_c1)*/ * from t2 where (c1 = 4 or c2 = 5) and c3 = 1;

drop table t1, t2;

