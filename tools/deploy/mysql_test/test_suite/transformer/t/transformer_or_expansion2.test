drop table if exists `t_kms_server_api`;
--enable_warnings

CREATE TABLE `cool_door_delete` (
  `door_delete_id` int(11) NOT NULL AUTO_INCREMENT,
  `door_id` varchar(11) DEFAULT NULL ,
  `mch_code` varchar(32) DEFAULT NULL ,
  `door_name` varchar(255) DEFAULT NULL ,
  `status` varchar(1) DEFAULT NULL ,
  `address` varchar(255) DEFAULT NULL ,
  `contact_tel` varchar(20) DEFAULT NULL ,
  `change_time` varchar(20) DEFAULT NULL ,
  PRIMARY KEY (`door_delete_id`)
) ENGINE=InnoDB AUTO_INCREMENT=218 DEFAULT CHARSET=utf8 ;

create table `shuju_notnull` (
`c01` int(255) NOT NULL,
`c02` numeric NOT NULL,
`c03` decimal(10,5) NOT NULL,
`c04` bit(64) NOT NULL,
`c05` tinyint(255) NOT NULL,
`c06` smallint NOT NULL,
`c07` mediumint NOT NULL,
`c08` bigint NOT NULL,
`c09` float(20) NOT NULL,
`c10` double NOT NULL,
`c11` varchar(255) NOT NULL,
`c12` char(255) NOT NULL,
`c13` tinytext NOT NULL,
`c14` mediumtext NOT NULL,
`c15` tinyblob NOT NULL,
`c16` longtext NOT NULL,
`c17` mediumblob NOT NULL,
`c18` longblob NOT NULL,
`c19` binary(255) NOT NULL,
`c20` varbinary(255) NOT NULL,
`c21` timestamp NOT NULL,
`c22` date NOT NULL,
`c23` time NOT NULL,
`c24` datetime NOT NULL,
`c25` year NOT NULL,
`c26` blob NOT NULL,
 primary key(`c01`));

CREATE TABLE `cool_business_delete_record` (
  `record_id` int(11) NOT NULL AUTO_INCREMENT ,
  `admin_id` int(11) DEFAULT NULL ,
  `regtime` int(11) DEFAULT NULL ,
  `created_at` int(11) DEFAULT NULL ,
  `business_id` int(11) DEFAULT NULL ,
  `agent_id` int(11) DEFAULT NULL ,
  `all_title` varchar(255) DEFAULT NULL ,
  `title` varchar(255) DEFAULT NULL ,
  `business_info` text ,
  PRIMARY KEY (`record_id`)
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8 ;

create table if not exists `t1nroc8e` (
	`id` int(11) not null,
	`n1` int(11),
	`n2` int(11),
	`s` varchar(20),
	`vs` varchar(20),
	`t` varchar(256),
	primary key (`id`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_sys_cmd` (
  `cmdID` int(20) NOT NULL AUTO_INCREMENT,
  `cmdName` char(200) DEFAULT NULL COMMENT '命令名称',
  `cmdDisplayName` char(50) DEFAULT NULL COMMENT '命令展示名称',
  `cmdCategoryID` int(20) DEFAULT NULL COMMENT '命令分类ID',
  PRIMARY KEY (`cmdID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='命令表';

CREATE TABLE `t_kms_encrypt_key` (
  `cek_id` varchar(64) NOT NULL,
  `cek_name` varchar(50) DEFAULT NULL,
  `cek_desc` varchar(512) DEFAULT NULL,
  `cek_value` varchar(255) DEFAULT NULL,
  `cek_check` varchar(255) DEFAULT NULL,
  `skey_id` varchar(64) DEFAULT NULL,
  `skey_name_version` varchar(255) DEFAULT NULL,
  `skey_version` varchar(255) DEFAULT NULL,
  `instance_id` varchar(64) DEFAULT NULL,
  `create_by` varchar(50) DEFAULT NULL COMMENT '创建人登录名称',
  `create_date` varchar(32) DEFAULT NULL COMMENT '创建日期',
  `update_by` varchar(50) DEFAULT NULL COMMENT '更新人登录名称',
  `update_date` varchar(32) DEFAULT NULL COMMENT '更新日期',
  PRIMARY KEY (`cek_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `t_operation_relation_init` (
  `gID` int(11) NOT NULL AUTO_INCREMENT COMMENT '流水号',
  `columnType` int(11) NOT NULL COMMENT '数据类型：\n            0：字符\n            1：数值\n            2：日期\n            3：IP地址',
  `operateionRelation` varchar(300) NOT NULL COMMENT '字符型：\n等于（eq）、不等于(ne)、大于(gt)、小于(lt)、大于等于(ge)、小于等于(le)、匹配(match)、不匹配(not_match)>、正则匹配\n(reg_match)、正则不匹配(reg_not_match)\n 数值型： 等于、不等于、大于、小于、大于等于、小于等于、区间内（between）、不在区间内（not between）\n        日期>型：\n 等于、不等于、大于、小于、大于等于、小于等于、区间内（between）、不在区间内（not between）IP地址型：\n等于、不等于、大于、小于、大于等于、小于等于、匹配、不匹配
、正则匹配、正则不匹配、区间内（between）、不在区间内（not between）对象：属于（in）、不属于（not in）',
  `operateionRelationCNName` varchar(300) DEFAULT NULL,
  PRIMARY KEY (`gID`)
) ENGINE=InnoDB AUTO_INCREMENT=53 DEFAULT CHARSET=utf8 COMMENT='运算关系初始化数据';

CREATE TABLE `cool_crontime` (
  `crontime_id` int(11) NOT NULL AUTO_INCREMENT,
  `type` varchar(100) DEFAULT NULL,
  `date` varchar(50) DEFAULT NULL,
  `crondate` varchar(50) DEFAULT NULL,
  `pay_pass` varchar(11) DEFAULT NULL ,
  `status` varchar(10) DEFAULT NULL ,
  `end_time` int(11) DEFAULT NULL ,
  PRIMARY KEY (`crontime_id`)
) ENGINE=InnoDB AUTO_INCREMENT=13516 DEFAULT CHARSET=utf8;

CREATE TABLE `cool_bill_20180919` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `cool_mch_order_map` (
  `out_trade_id` varchar(50) NOT NULL ,
  `mch_code` varchar(30) NOT NULL ,
  `from_business_trade_id` varchar(128) NOT NULL DEFAULT '' ,
  PRIMARY KEY (`out_trade_id`),
  UNIQUE KEY `uiq_mch_code_trade_id` (`mch_code`,`from_business_trade_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 ;

create table if not exists `t1u4htee` (
	`c1` varbinary(1),
	`c2` varbinary(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;


CREATE TABLE `t_kms_server_api` (
  `apiId` int(11) NOT NULL AUTO_INCREMENT,
  `name` varchar(32) DEFAULT NULL,
  `url` varchar(64) DEFAULT NULL,
  `describe` varchar(512) DEFAULT NULL,
  `request` varchar(4096) DEFAULT NULL,
  `response` varchar(4096) DEFAULT NULL,
  `type` varchar(4) DEFAULT NULL,
  `category` varchar(32) DEFAULT NULL,
  `id` int(11) NOT NULL DEFAULT '0',
  PRIMARY KEY (`apiId`)
) ENGINE=InnoDB AUTO_INCREMENT=50 DEFAULT CHARSET=utf8;

SELECT     ref_6.c3 AS c0,
           99       AS c1
FROM       (((test.cool_door_delete AS ref_0
RIGHT JOIN
           (
                  SELECT ref_1.c16          AS c0,
                         ref_1.c18          AS c1
                  FROM   test.shuju_notnull AS ref_1
                  WHERE  30 = ref_1.c01 limit 140) AS subq_0
ON         ((
                                 subq_0.c0 IS NOT NULL)
           OR         ((
                                            EXISTS
                                            (
                                                   SELECT ref_0.change_time AS c0,
                                                          ref_0.status      AS c1,
                                                          subq_0.c0         AS c2,
                                                          ref_2.cmdname     AS c3,
                                                          subq_0.c1         AS c4,
                                                          subq_0.c1         AS c5,
                                                          (
                                                                 SELECT title
                                                                 FROM   test.cool_business_delete_record limit 1 offset 3) AS c6,
                                                          ref_0.contact_tel                                                AS c7,
                                                          subq_0.c1                                                        AS c8,
                                                          ref_2.cmdcategoryid                                              AS c9,
                                                          ref_0.contact_tel                                                AS c10,
                                                          100                                                              AS c11,
                                                          subq_0.c0                                                        AS c12,
                                                          subq_0.c1                                                        AS c13
                                                   FROM   test.t_sys_cmd                                                   AS ref_2
                                                   WHERE  ref_2.cmdcategoryid <=
                                                          (
                                                                 SELECT id
                                                                 FROM   test.t1nroc8e limit 1 offset 100) limit 95))
                      OR         (
                                            0))))
LEFT JOIN  ((
           (
                  SELECT ref_3.update_date       AS c0,
                         ref_3.cek_value         AS c1,
                         ref_3.cek_name          AS c2,
                         ref_3.cek_name          AS c3,
                         ref_3.cek_check         AS c4,
                         ref_3.cek_check         AS c5,
                         ref_3.skey_id           AS c6,
                         ref_3.cek_desc          AS c7,
                         ref_3.cek_name          AS c8,
                         ref_3.create_date       AS c9,
                         ref_3.cek_name          AS c10,
                         ref_3.update_date       AS c11,
                         ref_3.skey_name_version AS c12,
                         ref_3.skey_name_version AS c13,
                         ref_3.create_date       AS c14,
                         ref_3.skey_version      AS c15,
                         ref_3.create_date       AS c16,
                         ref_3.update_date       AS c17,
                         ref_3.instance_id       AS c18,
                         ref_3.update_by         AS c19,
                         ref_3.skey_id           AS c20,
                         ref_3.skey_version      AS c21
                  FROM   test.t_kms_encrypt_key  AS ref_3
                  WHERE  59
                  OR
                         (
                                SELECT gid
                                FROM   test.t_operation_relation_init limit 1 offset 4) limit 103) AS subq_1
INNER JOIN test.cool_crontime                                                                      AS ref_4
ON         ((
                                 ref_4.crontime_id - ref_4.crontime_id)
           OR         ((
                                        SELECT bill_id
                                        FROM   test.cool_bill_20180919 limit 1 offset 6) | ref_4.end_time)))
INNER JOIN test.cool_mch_order_map AS ref_5
ON         (((
                                            ref_4.crontime_id & ref_4.crontime_id)
                      AND        (
                                            ref_4.end_time * ref_4.crontime_id))
           AND        (
                                 ref_4.crontime_id / ref_4.end_time)))
ON         ((
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)
           AND        (
                                 ref_0.door_delete_id
                      AND        ref_4.crontime_id)))
LEFT JOIN  (test.t1u4htee     AS ref_6
INNER JOIN test.shuju_notnull AS ref_7
ON         (
                      ref_6.c3 > ref_7.c05))
ON         (
                      EXISTS
                      (
                             SELECT ref_5.from_business_trade_id AS c0,
                                    subq_0.c0                    AS c1,
                                    ref_0.mch_code               AS c2,
                                    ref_8.type                   AS c3
                             FROM   test.t_kms_server_api        AS ref_8
                             WHERE  ref_0.door_delete_id | ref_7.c06)))
WHERE      ref_7.c01 - ref_6.c3 limit 10;

SELECT /*+use_concat*/ 1
FROM   test.cool_door_delete AS ref_0
       RIGHT JOIN (SELECT ref_1.c16 AS c0
                   FROM   test.shuju_notnull AS ref_1
                   WHERE  ref_1.c01 = 30
                   LIMIT  10) AS subq_0
               ON subq_0.c0 IS NOT NULL
                   OR ref_0.door_delete_id < 10; 

SELECT /*+use_concat*/ 1
FROM   test.cool_door_delete AS ref_0
       RIGHT JOIN (SELECT /*+no_rewrite*/ ref_1.c16 AS c0
                   FROM   test.shuju_notnull AS ref_1
                   WHERE  ref_1.c01 = 30
                   group by c02
                   LIMIT  10) AS subq_0
               ON subq_0.c0 IS NOT NULL
                   OR ref_0.door_delete_id < 10; 

SELECT /*+use_concat*/ 1
FROM   test.cool_door_delete AS ref_0
       RIGHT JOIN (SELECT /*+no_rewrite*/ ref_1.c16 AS c0
                   FROM   test.shuju_notnull AS ref_1
                   WHERE  ref_1.c01 = 30
                   having sum(c02) > 1
                   LIMIT  10) AS subq_0
               ON subq_0.c0 IS NOT NULL
                   OR ref_0.door_delete_id < 10;  

