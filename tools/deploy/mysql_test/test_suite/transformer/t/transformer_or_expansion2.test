--enable_warnings
--disable_query_log
--disable_result_log
CREATE TABLE `users` (
  `id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `nickname` varchar(128) COLLATE utf8mb4_unicode_ci DEFAULT '' COMMENT '昵称',
  `headimgurl` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT '头像',
  `sex` tinyint(1) DEFAULT NULL COMMENT '性别',
  `unionid` varchar(48) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT 'unionid',
  `openid` varchar(48) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT 'openid',
  `inviter_user_id` int(11) NOT NULL DEFAULT '-1' COMMENT '邀请人，-1 初始化，0 没有邀请人 ，其他用户ID',
  `from` varchar(128) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '' COMMENT '来源',
  `from_version` varchar(128) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '' COMMENT '来源版本',
  `language` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '',
  `country` varchar(30) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '',
  `city` varchar(20) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '',
  `province` varchar(30) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '',
  `mobile` varchar(14) COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '',
  `puid` char(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '统一平台puid',
  `wxid` varchar(36) COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '用户微信id',
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  `updated_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  `subscribe_time` int(11) NOT NULL DEFAULT '0' COMMENT '关注时间',
  `area_code` varchar(10) COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '区号/正阳/2021-07-08',
  PRIMARY KEY (`id`),
  UNIQUE KEY `unionid` (`unionid`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `openid` (`openid`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_wxid` (`wxid`) BLOCK_SIZE 16384 LOCAL,
  KEY `mobile` (`mobile`) BLOCK_SIZE 16384 LOCAL,
  KEY `nickname` (`nickname`) BLOCK_SIZE 16384 LOCAL,
  KEY `puid` (`puid`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_nickname_mobile` (`nickname`, `mobile`) STORING (`headimgurl`, `unionid`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 20847841 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_unicode_ci ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

insert into users(unionid, openid, wxid, mobile, nickname, area_code) select * from (with RECURSIVE cte(a,b,c,d,e,f) as (select 2,2,2,2,2,2 union all select a+1,b+1,c+1,d+1,e+1,f+1 from cte where a < 1000) select * from cte);
--enable_query_log
--enable_result_log

select u.id user_id, u.unionid union_id, u.nickname nick_name, u.headimgurl avatar, u.mobile phone  from users u  where u.nickname like '18525381669%' or u.mobile like '18525381669%'  order by u.id limit 30 offset 0;

drop table users;
