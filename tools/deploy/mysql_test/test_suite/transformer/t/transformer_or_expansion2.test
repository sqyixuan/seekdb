create table t1(c1 int, c2 int);

CREATE TABLE t8 (
  c1 int(30) DEFAULT NULL,
  c2 bigint(85) DEFAULT NULL,
  c3 int(117) NOT NULL,
  PRIMARY KEY (c3)
) partition by hash(c3)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9,
partition p10,
partition p11,
partition p12,
partition p13,
partition p14,
partition p15,
partition p16,
partition p17,
partition p18,
partition p19);

CREATE TABLE t28 (
  c1 binary(126) NOT NULL,
  c2 char(15) COLLATE utf8mb4_bin NOT NULL,
  c3 decimal(1,0) DEFAULT NULL,
  c4 mediumint(21) DEFAULT NULL,
  c5 decimal(18,5) DEFAULT NULL,
  c6 int(26) DEFAULT NULL,
  c7 varbinary(32) DEFAULT NULL,
  c8 smallint(42) DEFAULT NULL,
  c9 mediumint(32) DEFAULT NULL,
  c10 decimal(49,15) DEFAULT NULL,
  c11 decimal(12,12) DEFAULT NULL,
  c12 char(56) COLLATE utf8mb4_bin DEFAULT NULL,
  c13 varchar(51) COLLATE utf8mb4_bin NOT NULL,
  c14 decimal(30,6) NOT NULL,
  c15 decimal(53,18) DEFAULT NULL,
  c16 mediumint(14) NOT NULL,
  c17 int(21) DEFAULT NULL,
  c18 varbinary(70) DEFAULT NULL,
  PRIMARY KEY (c2, c16, c13, c1, c14)
);

CREATE TABLE t30 (
  c1 char(50) COLLATE utf8mb4_bin NOT NULL,
  c2 int(81) DEFAULT NULL,
  c3 decimal(35,7) DEFAULT NULL,
  c4 decimal(53,3) NOT NULL,
  c5 int(36) NOT NULL,
  c6 int(56) NOT NULL,
  c7 bigint(108) DEFAULT NULL,
  c8 decimal(54,27) NOT NULL,
  c9 decimal(10,6) NOT NULL,
  c10 tinyint(23) NOT NULL,
  c11 varchar(26) COLLATE utf8mb4_bin NOT NULL,
  c12 int(54) NOT NULL,
  c13 varchar(21) COLLATE utf8mb4_bin NOT NULL,
  c14 char(92) COLLATE utf8mb4_bin DEFAULT NULL,
  c15 decimal(27,4) NOT NULL,
  c16 char(1) COLLATE utf8mb4_bin DEFAULT NULL,
  PRIMARY KEY (c4, c12, c13, c9, c10, c6, c11, c15, c1, c8, c5)
) partition by hash(c12+c10+c6+c5)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9,
partition p10,
partition p11,
partition p12,
partition p13,
partition p14,
partition p15,
partition p16,
partition p17,
partition p18,
partition p19);

--disable_query_log
--disable_result_log
insert into t1 values(1,1);
select count(*) from t1;
--enable_query_log
--enable_result_log

SELECT t8_1552.c2 FROM t8 AS t8_1552 RIGHT OUTER JOIN t30 AS t30_6617 ON
t8_1552.c1 = t30_6617.c6 OR t8_1552.c1 = t30_6617.c15 OR t8_1552.c1 < 90
WHERE
EXISTS (SELECT t28_379.c5, t28_379.c5, t28_379.c4, t28_379.c15, t28_379.c3, t28_379.c12, t28_379.c13, t28_379.c13, t28_379.c12, t28_379.c13, t28_379.c2, t28_379.c17, t28_379.c8, t28_379.c12 FROM t28 AS t28_379 WHERE t28_379.c5 >= t28_379.c14 OR t28_379.c6 = t28_379.c15 AND t28_379.c9 > t28_379.c5)
OR t8_1552.c1 <= 166
OR t8_1552.c1 = 661 AND t8_1552.c2 >= t8_1552.c1
ORDER BY 1;

select /*+use_concat*/ * from t1 A left join t1 B
on A.c1 = B.c2 or A.c1 < 5
where lnnvl(B.c1 <= 5);

select /*+no_expand*/ * from t1 A left join t1 B
on A.c1 = B.c2 or A.c1 < 5
where lnnvl(B.c1 <= 5);

drop table t1, t8, t28, t30;

--disable_warnings
drop table if exists t5, t29, t11;
--enable_warnings

create table t5 (c1 NUMERIC(43,28) ,c2 DECIMAL(45,25) ,c3 MEDIUMINT(15) ,c4 CHAR(151),c5 CHAR(24),c7 CHAR(24) , primary key(c4), unique index u_hnFEPoJR(c1,c3), index i_bkMRdSD(c2), index i_BqZAjb(c3,c4));
create table t29 (c1 SMALLINT(35) ,c2 MEDIUMINT(33) ,c3 CHAR(24) ,c4 INTEGER(67) , primary key(c4), unique index u_iWHEy(c4), index i_lbjsuEd(c4,c2,c1));
create table t11 (c1 BINARY(34) ,c2 VARCHAR(1) ,c3 INTEGER(127) ,c4 VARBINARY(61) ,c5 INTEGER(3) ,c6 MEDIUMINT(40) ,c7 DECIMAL(9,0) ,c8 CHAR(125) ,c9 SMALLINT(31) ,c10 SMALLINT(13) ,c11 INT(107) ,c12 MEDIUMINT(38) ,c13 SMALLINT(67) ,c14 BINARY(44) ,c15 NUMERIC(26,22), c17 NUMERIC(26,22) , primary key(c5,c14,c4,c1,c7,c15,c13,c9,c6,c2));

SELECT /*+use_concat*/ 1
FROM t5 AS t5_678 RIGHT OUTER JOIN t29 AS t29_17035
                     ON t5_678.c3 = t29_17035.c4 OR t5_678.c7 = t29_17035.c3
WHERE t5_678.c5 <= (SELECT t5_678.c5 FROM   t5 AS t5_678)
      AND NOT EXISTS (SELECT 
                          Min(t11_925.c12)
                   FROM   (SELECT t11_925.c5,
                                  (SELECT t11_925.c12
                                   FROM   t11 AS t11_925
                                   ORDER  BY 1
                                   LIMIT  1) AS c12,
                                  t11_925.c17
                           FROM   t11 AS t11_925) AS t11_925
                   GROUP  BY t11_925.c5
                   HAVING Sum(t11_925.c17) > 365);

 --disable_warnings
drop table if exists t5, t29, t11;
--enable_warnings
                  
