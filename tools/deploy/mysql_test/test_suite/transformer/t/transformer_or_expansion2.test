# bug: 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int, c3 int);

create index idx_c1 on t1 (c1);
create index idx_c2 on t1 (c2);

insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);

SELECT /*+use_concat*/ 1
FROM t1
GROUP BY c1, c2
HAVING
(1 NOT IN (SELECT c2 FROM t1 tt WHERE tt.c1 = t1.c1 LIMIT 1)
 AND c1 = 1 AND c2 = 1 AND count(*) > -1)
OR c2 = 2;

SELECT /*+no_rewrite*/ 1
FROM t1
GROUP BY c1, c2
HAVING
(1 NOT IN (SELECT c2 FROM t1 tt WHERE tt.c1 = t1.c1 LIMIT 1)
 AND c1 = 1 AND c2 = 1 AND count(*) > -1)
OR c2 = 2;

drop table t1;
drop table table0_bigint;

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(a int, b int, c int, d int, e int, index idx_a(a), index idx_b(b), index idx_c(c), index idx_d(d));
create table t2(a int, b int, c int, d int, e int, index idx_b(b));
create table t3(a int, b int, c int, d int, e int);

