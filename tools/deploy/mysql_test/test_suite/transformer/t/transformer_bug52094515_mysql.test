#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer
# issue : 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, a int, b int);
create index i1 on t1(a);
create index i2 on t1(b);
insert into t1 select n,n,n from (select row_number() over () as n from table(generator(10000)));

--result_format 4
--explain_protocol 2

select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte where pk = 1 union all select * from cte where pk = 2);
select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte where a = 1 union all select * from cte where a = 2);
select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte where a = 1 union all select * from cte where b = 2);
select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte union all select * from cte);
select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte union all select * from cte where pk = 1);
select * from (with cte as (select /*+materialize*/ * from t1 where a=1 or b=2) select * from cte where pk = 1 union all select * from cte where lnnvl(pk = 1 or (1,1) = (2,2)));
select * from (with cte as (select /*+materialize*/ * from (select /*+no_merge*/ * from t1 where a=1 or b=2) v) select * from cte where pk = 1 union all select * from cte where pk = 2);
select * from (with cte as (select /*+materialize*/ * from (select /*+no_merge*/ * from t1 where a=1 or b=2) v) select * from cte where pk = 1 union all select * from cte);
select * from (with cte as (select /*+materialize*/ * from (select /*+no_merge no_simplify_group_by*/ pk, count(*) as cnt from t1 where a=1 or b=2 group by pk) v) select * from cte where pk = 1 and cnt > 0 union all select * from cte where pk = 2 and cnt < 10);
select * from (with cte as (select /*+materialize*/ * from t1 limit 1) select * from cte where pk = 2 union all select * from cte where pk = 3);

drop table t1;