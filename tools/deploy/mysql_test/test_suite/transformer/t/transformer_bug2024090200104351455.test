# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer, cross_validation
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);

INSERT INTO t1 VALUES(1, 1),(2, 2),(3, 3);
INSERT INTO t2 VALUES(4, 4),(5, 5),(1, 1);
INSERT INTO t3 VALUES(6, 6),(2, 2);

--result_format 4
--explain_protocol 1

-- echo # no 'limit' in plan, should output (1, 1) and (2, 2)
select
/*+
    query_timeout(10000000000000)
    BEGIN_OUTLINE_DATA
    COALESCE_SQ(@"SEL$1" ("SEL$2", "SEL$3"))
    SIMPLIFY_SUBQUERY(@"SEL$699F1F46")
    UNNEST(@"SET$44BC08D9")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/
* from t1 where exists (select 1 from t2 where t2.c1 = t1.c1) or exists (select 1 from t3 where t3.c1 = t1.c1);

--explain_protocol 0
drop table if exists t1, t2, t3;