#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer,cross_validation
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
--error 0, 942
drop table if exists t1, t2, t3, t4;
--enable_warnings

create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
create table t3 (c1 int, c2 int);
create table t4 (c1 int, c2 int);
--result_format 4
--explain_protocol 2

--echo issue: 
select 1 from  (t1 left join t2 on true) left join t3 on false where exists(select 1 from t4 where t4.c1 or t3.c1);
select/*+no_eliminate_join*/ 1 from  (t1 left join t2 on true) left join t3 on false where exists(select 1 from t4 where t4.c1 or t3.c1);

--echo issue: 
--explain_protocol 0
--disable_warnings
--error 0, 942
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int generated always as (c1 + 1));
--explain_protocol 2

select 1 from t1, t1 tt where t1.c1 = tt.c1 and tt.c2 > 0;
select /*+no_eliminate_join*/ 1 from t1, t1 tt where t1.c1 = tt.c1 and tt.c2 > 0;

select tt.* from t1, t1 tt where t1.c1 = tt.c1;
select /*+no_eliminate_join*/ tt.* from t1, t1 tt where t1.c1 = tt.c1;
--explain_protocol 0

--disable_warnings
--error 0, 942
drop table if exists t1, t2, t3, t4;
--enable_warnings

--echo issue: 
--explain_protocol 0
--disable_warnings
--error 0, 942
drop table if exists t1,t2,d0;
--enable_warnings

CREATE TABLE `t2` (
  `c0` decimal(9,0) DEFAULT NULL,
  `c1` tinytext DEFAULT NULL COMMENT 'asdf',
  `c2` mediumint(8) unsigned zerofill DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `d0` (
  `c0` decimal(27,0) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by key(c0)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`);
--explain_protocol 2
WITH RECURSIVE `TEMP1` as (select max(c0) q0 from `d0`)
SELECT  min( (SELECT q0 FROM temp1 view1)) OVER () AS c6,
      (SELECT max(c1) FROM t1) AS c7,
     subq_0.c2 AS c9
    FROM 
        (SELECT  ref_0.c2 AS c1,
                 (SELECT max(c0)  FROM t2 ) AS c2
         FROM t1 AS ref_0) AS subq_0
    WHERE EXISTS
        (SELECT  1
                FROM t1 AS ref_16, `TEMP1` `VIEW2`
                    WHERE EXISTS (SELECT 15 AS c0 FROM t2 AS ref_17)
                         and subq_0.c1 >= `VIEW2`.q0  limit 1);
drop table t1,t2,d0;