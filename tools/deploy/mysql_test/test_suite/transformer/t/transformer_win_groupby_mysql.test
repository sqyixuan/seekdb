#owner: sean.yyj
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t1_part;
--enable_warnings
create table t1(a int, b int, c int, primary key(a,b));
create table t1_part(a int, b int, c int, primary key(a,b)) partition by hash(b) partitions 4;
--disable_query_log
insert into t1 values (1,1,1),(1,2,1),(1,3,2),(1,4,5),(1,5,6),(2,1,7),(2,2,3),(2,3,4),(2,4,5),(2,5,7);
insert into t1_part values (1,1,1),(1,2,1),(1,3,2),(1,4,5),(1,5,6),(2,1,7),(2,2,3),(2,3,4),(2,4,5),(2,5,7);

--disable_result_log
select count(*) from t1;
select count(*) from t1_part;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

