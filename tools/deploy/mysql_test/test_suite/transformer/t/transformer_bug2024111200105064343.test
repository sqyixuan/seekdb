# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer,cross_validation

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set_tp tp_no = 556, error_code = 23088, frequency = 1;

connection default;

--disable_warnings
DROP TABLE IF EXISTS t0, t1, t2;
--enable_warnings

CREATE TABLE t0(c0 FLOAT(5, 1) ZEROFILL  NULL, c1 FLOAT(6, 4)  , c2 VARCHAR(500) , PRIMARY KEY(c1))  BLOCK_SIZE =  32768  PARTITION BY KEY (c1) SUBPARTITION BY KEY (c1) subpartitions 1 partitions 7;
CREATE TABLE t1(c0 LONGTEXT , c1 DATETIME , c2 VARCHAR(500) ) USE_BLOOM_FILTER =  true  PARTITION BY KEY (c1) partitions 10;
CREATE TABLE t2 PARTITION BY KEY (c1, c2) partitions 12 AS SELECT * FROM t1;
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS parallel(8) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t1(c0, c1, c2) VALUES('/\\mm/J6q!h%*vW#]''dEk#M,-t,VC', "2024-11-12 11:40:54", 'VYZUb%|DF?J{-*zzwH]88\\J%dn'), ("rTrNojAD7U?qEwT(|+Z WBhJ", "2024-11-12 11:40:54", 'ms{%.N%MU1B^<X#HEp]');
REPLACE INTO t2(c0, c2) VALUES("-926950495", 'T1*pxw1');
INSERT /*+parallel(1) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t0(c1) VALUES ROW(19.7404);
REPLACE INTO t1(c2, c0) VALUES ROW("/", '-1447970766');
INSERT /*+*/ INTO t2(c2, c1) VALUES('-1447970766', '2024-11-12 11:40:54');
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS */ INTO t1(c1) VALUES ROW('2024-11-12 11:40:54');
REPLACE INTO t2(c0) select c0 from t1 ORDER BY RAND() limit 3;

--result_format 4
--explain_protocol 1

SELECT Sum(1) AS AF, t1.*
FROM   t1,t2
GROUP  BY t1.c0,t2.c1,t2.c2
HAVING ((af != 0 AND (t1.c0 IS NOT NULL OR t1.c0 = 'aaa')) OR (t1.c0 != 'bbb'));

SELECT /*+no_rewrite*/ Sum(1) AS AF, t1.*
FROM   t1,t2
GROUP  BY t1.c0,t2.c1,t2.c2
HAVING ((af != 0 AND (t1.c0 IS NOT NULL OR t1.c0 = 'aaa')) OR (t1.c0 != 'bbb'));

drop table t0,t1,t2;
connection syscon;
alter system set_tp tp_no = 556, error_code = 23088, frequency = 0;