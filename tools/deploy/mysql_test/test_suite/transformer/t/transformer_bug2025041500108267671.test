# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: place_group_by hint 指定下推表导致 join 谓词丢失 bug

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (pk int primary key, c1 int, c2 int);
create table t2 (pk int primary key, c1 int, c2 int);
insert into t1 values (1,1,1);
insert into t2 values (1,1,1);

--result_format 4
--explain_protocol 2

--echo # t2.pk != t2.pk 这个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk) 
group by field4;

SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk) 
group by field4;

--echo # t2.pk != 1 这个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != 1) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != 1) 
group by field4;

--echo # t2.pk = 1 这个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk = 1) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk = 1) 
group by field4;

--echo # t1.c1 = 1 这个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t1.c1 = 1) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t1.c1 = 1) 
group by field4;

--echo # t1.c1 != 1 这个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t1.c1 != 1) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t1.c1 != 1) 
group by field4;

--echo # t2.pk = 1 和 t1.c1 = 1 这两个条件不应该被丢弃
SELECT /*+PLACE_GROUP_BY(t1)*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk AND t1.c1 = 1) 
group by field4;

SELECT /*+no_rewrite*/ COUNT(t1.`c1`) AS field2, t2.`c1` AS field4 
FROM (t1 LEFT OUTER JOIN t2 ON t1.c2 = t2.pk AND t2.pk != t2.pk AND t1.c1 = 1) 
group by field4;

drop table t1;
drop table t2;