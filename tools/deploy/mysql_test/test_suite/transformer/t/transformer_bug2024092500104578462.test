                  (
                    cast(ref_238.c7 as char) <> cast(ref_237.c1 as char)
                  ) as unsigned
                )
              )
            )
          limit
            1
        )
      )
    )
  )
where
  (
    NOT NOT(
      cast(
        (
          cast(ref_238.c5 as double) != cast(ref_238.c10 as signed)
        ) as unsigned
      )
    )
  );

