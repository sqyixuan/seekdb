                            cast(ref_210.c_p_hd as signed) <= cast(
                              (1 = 1)
                              or (
                                (
                                  NOT NOT(
                                    cast(
                                      (
                                        cast(ref_210.c_p_hd as signed) || cast(-1041834766355044601 as signed)
                                      ) as unsigned
                                    )
                                  )
