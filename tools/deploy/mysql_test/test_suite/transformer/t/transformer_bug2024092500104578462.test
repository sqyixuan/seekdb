  LIMIT
    92
)
select
  ref_237.c1 as c0
from
  (
    cte_3 as ref_237
    left outer join (
      cte_38 as ref_238
      left outer join cte_8 as ref_239 on 1 = 0
    ) on (
      (
        ref_239.c0 <> (
          select
            (
              NOT NOT(
                cast(
