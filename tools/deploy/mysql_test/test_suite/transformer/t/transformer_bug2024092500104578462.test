create table t1(c1 int);

--result_format 4
--explain_protocol 1

explain basic with cte as (select c1, sum((select c1 from t1)) as c2 from t0) select c1 from cte union all select c1 from cte;
explain basic with cte as (select c1, sum((select c1 from t1)) as c2 from t0 group by c1) select c1 from cte union all select c1 from cte;
explain basic with cte as (select c1, sum((select c1 from t1 where c1 < t0.c1)) as c2 from t0 group by c1) select c1 from cte union all select c1 from cte;
explain basic with cte as (select c1, sum((select c1 from t1)) as c2, count(*) as c3 from t0 group by c1) select c1, c3 from cte union all select c1, c3 from cte;

with cte as (select c1, sum((select c1 from t1)) as c2 from t0) select c1 from cte union all select c1 from cte;
with cte as (select c1, sum((select c1 from t1)) as c2 from t0 group by c1) select c1 from cte union all select c1 from cte;
with cte as (select c1, sum((select c1 from t1 where c1 < t0.c1)) as c2 from t0 group by c1) select c1 from cte union all select c1 from cte;
with cte as (select c1, sum((select c1 from t1)) as c2, count(*) as c3 from t0 group by c1) select c1, c3 from cte union all select c1, c3 from cte;

explain basic WITH cte_3 AS (
  SELECT
    count(
      cast(
        (
          select
            c7
          from
            v_zhm
          order by
            c7
          limit
            1 offset 4
        ) as char
      )
    ) as c0,
    count(cast(ref_22.c_zbfsvzu7rl as signed)) as c1,
    count(
      cast(
        case
        when (
          NOT NOT(
            cast(
              (
                cast(ref_22.c_m as signed) != cast(ref_22.c_ewlq as unsigned)
              ) as unsigned
            )
          )
        ) then cast(ref_22.c_bupx6kx as char)
        else cast(cast(null as char) as char)
        end
          as char
      )
    ) as c2,
    ref_22.c_c40vnnle as c3,
    count(
      cast(
        cast(
          (
            cast(ref_22.c_q6 as unsigned) % cast(
              (
                (
                  NOT NOT(
                    cast(
                      (
                        cast(ref_22.c_jmnf888 as signed) >= cast(-8257985502052348461 as signed)
                      ) as unsigned
                    )
                  )
                )
              )
              or (
                (
                  NOT NOT(
                    cast((ref_22.c_unp != ref_22.c_hngj36) as unsigned)
                  )
                )
              ) as unsigned
            )
          ) as char
        ) as char
      )
    ) as c4,
    count(
      cast(
        cast(
          (
            cast(ref_22.c_zbfsvzu7rl as unsigned) << cast(
              case
              when 1 = 1 then cast(ref_22.c_q6 as signed)
              else cast(ref_22.c_sl_y as signed)
              end
                as signed
            )
          ) as char
        ) as char
      )
    ) as c5,
    count(
      cast(
        cast((-296120777 - -8919397557609958522) as signed) as signed
      )
    ) as c6
  FROM
    t_gu6hkjur as ref_22
  WHERE
    (
      hex(cast(cast(null as char) as char)) like 'v_dej'
    )
  GROUP BY
    ref_22.c_c40vnnle
  HAVING
    1 = 1
  LIMIT
    97
), cte_8 AS (
  SELECT
    subq_5.c6 as c0,
    count(
      cast(
        (
          select
            c3
          from
            v_zhm
          order by
            c3
          limit
            1 offset 62
        ) as double
      )
    ) as c1,
    count(cast(subq_5.c2 as signed)) as c2
  FROM
    (
      select
        ref_52.c_q6 as c0,
        ref_52.c_m as c1,
        -742916021 as c2,
        ref_52.c_unp as c3,
        ref_52.c_unp as c4,
        -1057483205 as c5,
        ref_52.c_p_hd as c6
      from
        t_gu6hkjur as ref_52
      where
        (
          (
            (
              NOT NOT(
                cast(
                  (
                    cast(ref_52.c_hngj36 as double) < cast(ref_52.c_jmnf888 as signed)
                  ) as unsigned
                )
              )
            )
          )
          and (
            (
              NOT NOT(
                cast(
                  (
                    cast(ref_52.c_hngj36 as double) < cast(558875919 as signed)
                  ) as unsigned
                )
              )
            )
          )
        )
        and (
          (
            NOT NOT(
              cast(
                (
                  cast(ref_52.c_unp as decimal) < cast(ref_52.c_hngj36 as double)
                ) as unsigned
              )
            )
          )
        )
      limit
        61
    ) as subq_5
  WHERE
    (
      NOT NOT(
        cast(
          (
            cast(subq_5.c1 as signed) < cast(98.53 as double)
          ) as unsigned
        )
      )
    )
  GROUP BY
    subq_5.c6
  HAVING
    (
      cast(
        (cast('lit8136c' as char) < cast(c2 as char)) as unsigned
      ) in (
        (
          cast(
            (cast(30905 as signed) * cast(-21480 as signed)) as char
          ) not like 'qvzpkf_'
        ),
        (
          case
          when (
            3 in (
              -730877324,
              cast(c1 as signed),
              1878965238
            )
          ) then case
          when 0 <> 0 then -580633012
          else -4
          end
            else cast(c0 as signed)
          end
            is NULL
        )
      )
    )
),
cte_38 AS (
  SELECT
    var_pop(
      cast(
        case
        when (
          NOT NOT(
            cast(
              (
                cast(ref_209.c_y_zuhmuz1n as char) != cast(ref_209.c_af3qk as char)
