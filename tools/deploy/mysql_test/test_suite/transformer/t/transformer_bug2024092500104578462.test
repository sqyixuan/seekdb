create table t_e9mix7pge as 
select  
    subq_0.c0 as c0, 
    
      first_value(
        cast(case when (subq_0.c0 in (
            select  
                  ref_1.c_v12 as c0
                from 
                  t_fvr6 as ref_1
                where 0<>0
              union all
              (
              select  
                  ref_2.c__h22jnn88z as c0
                from 
                  t_fvr6 as ref_2
                where 1=1
              ))) then cast(subq_0.c0 as char) else cast(subq_0.c0 as char) end
           as char)) over (partition by subq_0.c0 order by subq_0.c0) as c1, 
    case when (subq_0.c0 like 'r23z32_zk') then subq_0.c0 else cast((cast(cast(nullif(
          cast((select count(c_bty7) from t_fvr6)
             as double), 
          cast((cast((select avg(c_bbcn7_i9) from t_fvr6)
               as unsigned) / cast((select c_bbcn7_i9 from t_fvr6 order by c_bbcn7_i9 limit 1 offset 1)
               as signed)) as double)
          ) as signed) as signed) | cast((case when (NOT NOT(cast((cast(subq_0.c0 as char) >= cast(subq_0.c0 as char)) as unsigned))) then (select c_os0j from t_fvr6 order by c_os0j limit 1 offset 4)
               else (select c_os0j from t_fvr6 order by c_os0j limit 1 offset 6)
               end
             between case when 0<>0 then (select c_os0j from t_fvr6 order by c_os0j limit 1 offset 1)
               else (select c_os0j from t_fvr6 order by c_os0j limit 1 offset 3)
               end
             and truncate(
            cast(-707382848 as signed), 
            cast((select c_os0j from t_fvr6 order by c_os0j limit 1 offset 3)
               as signed))) as unsigned)) as char) end
       as c2, 
    cast((cast(-603645051 as signed) << cast((select c_bbcn7_i9 from t_fvr6 order by c_bbcn7_i9 limit 1 offset 5)
         as signed)) as signed) as c3, 
    cos(
      cast(9223372036854775806.5 as double)) as c4, 
    subq_0.c0 as c5, 
    cast(cast(null as signed) as signed) as c6, 
    case when (NOT NOT(cast((77.85 = (select c_os0j from t_fvr6 order by c_os0j limit 1 offset 4)
            ) as unsigned))) then cast((cast(-1256397100929285165 as signed) << cast(55.44 as double)) as signed) else case when (subq_0.c0 not like 'q%arl1_l') then 9127328887777838319 else 100 end
         end
       as c7
  from 
    (select distinct 
          ref_0.c_s21plux_ as c0
        from 
          t_fvr6 as ref_0
        where (NOT NOT(cast((25218 <=> ref_0.c_h1zxg9iu9) as unsigned)))) as subq_0
  where (NOT NOT(cast((cast(abs(
        cast(abs(
          cast(abs(
            cast(cast(null as decimal) as decimal)) as decimal)) as decimal)) as decimal) > cast((select c_bbcn7_i9 from t_fvr6 order by c_bbcn7_i9 limit 1 offset 5)
         as signed)) as unsigned)));

