create view v_zhm as 
select distinct 
    ref_0.c5 as c0, 
    ref_0.c3 as c1, 
    ref_0.c0 as c2, 
    ref_0.c4 as c3, 
    cast((cast(ref_0.c4 as double) / cast(ref_0.c3 as signed)) as double) as c4, 
    ref_0.c7 as c5, 
    ref_0.c3 as c6, 
    ref_0.c2 as c7, 
    cast((cast(ref_0.c4 as double) + cast((select c_w from t_zw72a order by c_w limit 1 offset 4)
         as double)) as double) as c8, 
    case when (ref_0.c6 is NULL) then ref_0.c6 else ref_0.c6 end
       as c9
  from 
    t_e9mix7pge as ref_0
  where ((case when (NOT NOT(cast((cast(ref_0.c6 as decimal) XOR cast(ref_0.c4 as double)) as unsigned))) then substring(
          cast(left(
            cast(ref_0.c1 as char), 
            cast(ref_0.c6 as signed)) as char), 
          cast(ref_0.c7 as signed)) else ref_0.c5 end
         not like 'i%2ql%_742')) 
    and (((((ref_0.c0 in (
            ref_0.c5, ref_0.c0))) 
          or ((NOT NOT(cast((cast(ref_0.c4 as double) < cast((NOT NOT(cast((cast(ref_0.c2 as char) = cast(ref_0.c5 as char)) as unsigned))) as unsigned)) as unsigned))))) 
        or ((0<>0) 
          and ((ref_0.c3 in (
            select distinct 
                8380746707185676006 as c0
              from 
                t_fvr6 as ref_1
              where (ref_1.c_s21plux_ like 'wjwa_d')))))) 
      or (((select c_v12 from t_fvr6 order by c_v12 limit 1 offset 6)
           not like 'd4y_ej_lt')));

