# owner group: SQL1
# tags: optimizer
# issue : 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);

--result_format 4
--explain_protocol 2
select * from 
(select t1.c1, (exists(select 1 from t2 where (t1.c1 = t2.c1))) as c2 from t1) v 
where v.c2 is true;

select * from (select 1 a, exists(select 1 from t2 where t1.c1=t2.c1) b from t1 
union all select c1,c2 from t1) v 
where b is true;

drop table t1, t2;
