CREATE TABLE IF NOT EXISTS t0(c0 int ZEROFILL   COMMENT 'asdf' , c1 int , c2 DOUBLE , c3 int ZEROFILL  COMMENT 'asdf'  NULL)  ;
CREATE TABLE IF NOT EXISTS t1(c0 int , c1 int ZEROFILL  NULL COMMENT 'asdf' , c2 int ZEROFILL  )  ;
CREATE VIEW v_t1 AS select t1.c0 AS C0, t1.c1 AS C1, t1.c2 AS C2, t0.c0 AS C3, t0.c1 AS C4, t0.c2 AS C5, t0.c3 AS C6 from t1, t0;
CREATE VIEW v_t0 AS select t0.c0 AS C0, t0.c1 AS C1, t0.c2 AS C2, t0.c3 AS C3, t1.c0 AS C4, t1.c1 AS C5, t1.c2 AS C6 from t0, t1;
insert into t0 values(1,1,1,1);
insert into t1 values(2,2,2);
