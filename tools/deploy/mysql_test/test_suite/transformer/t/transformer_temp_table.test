select /*+materialize(@"SEL$FC8A34D9")*/(select sum(C1) from v_t0 order by 1) as c13,   (select sum(C1) from v_t1 order by 1) as c20 from dual;
select /*+no_rewrite*/ (select sum(C1) from v_t0 order by 1) as c13,   (select sum(C1) from v_t1 order by 1)  as c20 from dual;

