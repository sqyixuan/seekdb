# owner: sean.yyj
# owner group: SQL1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set foreign_key_checks=1;
--enable_query_log

# schema
--disable_warnings
--disable_query_log
drop database if exists transformer;
create database transformer;
use transformer;
drop table if exists t1, t2;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
insert into t1 values (1, 2, 3);
insert into t1 values (2, 4, 5);
insert into t1 values (3, 0, 1);
insert into t1 values (3, null, null);

create table t2 (c1 int, c2 int, c3 int);
insert into t2 values (2, 1, 2);
insert into t2 values (4, 2, 3);
insert into t2 values (0, 0, 1);

sleep 3;
--enable_warnings
--enable_query_log
# schema END


# base case test : subquery projection expression with single aggregation function
##'select max(1)' is optimized in simplify_groupby
explain select (select max(1) from t2 where t1.c2 > t2.c2) as v from t1;
select (select max(1) from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select max(1) from t2 where t1.c2 > t2.c2) as v from t1;

explain select (select max(c1) from t2 where t1.c2 < t2.c2) as v from t1;
select (select max(c1) from t2 where t1.c2 < t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select max(c1) from t2 where t1.c2 < t2.c2) as v from t1;

explain select (select count(1) from t2 where t1.c2 > t2.c2) as v from t1;
select (select count(1) from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select count(1) from t2 where t1.c2 > t2.c2) as v from t1;

explain select (select count(*) from t2 where t1.c2 < t2.c2) as v from t1;
select (select count(*) from t2 where t1.c2 < t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select count(*) from t2 where t1.c2 < t2.c2) as v from t1;

explain select (select count(c1) from t2 where t1.c2 > t2.c2) as v from t1;
select (select count(c1) from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select count(c1) from t2 where t1.c2 > t2.c2) as v from t1;

explain select * from t1 where c1 > (select max(1) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 > (select max(1) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select max(1) from t2 where t1.c2 > t2.c2);

explain select * from t1 where c1 > (select max(c1) from t2 where t1.c2 < t2.c2);
select * from t1 where c1 > (select max(c1) from t2 where t1.c2 < t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select max(c1) from t2 where t1.c2 < t2.c2);

explain select * from t1 where c1 < (select count(1) from t2 where t1.c2 < t2.c2);
select * from t1 where c1 < (select count(1) from t2 where t1.c2 < t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select count(1) from t2 where t1.c2 < t2.c2);

explain select * from t1 where c1 < (select count(c1) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 < (select count(c1) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select count(c1) from t2 where t1.c2 > t2.c2);

explain select * from t1 where c1 < (select count(*) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 < (select count(*) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select count(*) from t2 where t1.c2 > t2.c2);


# compound case test : compound projection expression with aggregation function
explain select (select count(1)+max(c1) from t2 where t1.c2 < t2.c2) as v from t1;
select (select count(1)+max(c1) from t2 where t1.c2 < t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select count(1)+max(c1) from t2 where t1.c2 < t2.c2) as v from t1;

explain select (select max(1)+max(c1)-1 from t2 where t1.c2 > t2.c2) as v from t1;
select (select max(1)+max(c1)-1 from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select max(1)+max(c1)-1 from t2 where t1.c2 > t2.c2) as v from t1;

explain select (select count(nvl(c1,1)) from t2 where t1.c2 < t2.c2) as v from t1;
select (select count(nvl(c1,1)) from t2 where t1.c2 < t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select count(nvl(c1,1)) from t2 where t1.c2 < t2.c2) as v from t1;

explain select (select max(nvl(c1,1)) from t2 where t1.c2 > t2.c2) as v from t1;
select (select max(nvl(c1,1)) from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select max(nvl(c1,1)) from t2 where t1.c2 > t2.c2) as v from t1;

explain select (select nvl(count(c1),1) from t2 where t1.c2 < t2.c2) as v from t1;
select (select nvl(count(c1),1) from t2 where t1.c2 < t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select nvl(count(c1),1) from t2 where t1.c2 < t2.c2) as v from t1;

explain select (select nvl(max(c1-1)+1,1) from t2 where t1.c2 > t2.c2) as v from t1;
select (select nvl(max(c1-1)+1,1) from t2 where t1.c2 > t2.c2) as v from t1;
select /*+ NO_REWRITE */ (select nvl(max(c1-1)+1,1) from t2 where t1.c2 > t2.c2) as v from t1;

explain select (select nvl(max(1)+max(c1),0) from t2 where t1.c2 < t2.c2) as v from t1; 
select (select nvl(max(1)+max(c1),0) from t2 where t1.c2 < t2.c2) as v from t1; 
select /*+ NO_REWRITE */ (select nvl(max(1)+max(c1),0) from t2 where t1.c2 < t2.c2) as v from t1; 

explain select * from t1 where c1 > (select count(1)+max(c1) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 > (select count(1)+max(c1) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select count(1)+max(c1) from t2 where t1.c2 > t2.c2);

explain select * from t1 where c1 < (select max(1)+max(c1)-1 from t2 where t1.c2 < t2.c2);
select * from t1 where c1 < (select max(1)+max(c1)-1 from t2 where t1.c2 < t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select max(1)+max(c1)-1 from t2 where t1.c2 < t2.c2);

explain select * from t1 where c1 > (select count(nvl(c1,1)) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 > (select count(nvl(c1,1)) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select count(nvl(c1,1)) from t2 where t1.c2 > t2.c2);

explain select * from t1 where c1 < (select max(nvl(c1,1)) from t2 where t1.c2 < t2.c2);
select * from t1 where c1 < (select max(nvl(c1,1)) from t2 where t1.c2 < t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select max(nvl(c1,1)) from t2 where t1.c2 < t2.c2);

explain select * from t1 where c1 > (select nvl(count(c1),1) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 > (select nvl(count(c1),1) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select nvl(count(c1),1) from t2 where t1.c2 > t2.c2);

explain select * from t1 where c1 < (select nvl(max(c1-1)+1,1) from t2 where t1.c2 < t2.c2);
select * from t1 where c1 < (select nvl(max(c1-1)+1,1) from t2 where t1.c2 < t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 < (select nvl(max(c1-1)+1,1) from t2 where t1.c2 < t2.c2);

explain select * from t1 where c1 > (select nvl(max(1)+max(c1),0) from t2 where t1.c2 > t2.c2);
select * from t1 where c1 > (select nvl(max(1)+max(c1),0) from t2 where t1.c2 > t2.c2);
select /*+ NO_REWRITE */ * from t1 where c1 > (select nvl(max(1)+max(c1),0) from t2 where t1.c2 > t2.c2);


# base vector comparison
explain select /*+NO_REWRITE*/ * from t1 where (c1+c2, c2) > (select max(c1), min(c2) from t2 where t1.c1 > t2.c1);
explain select * from t1 where (c1+c2, c2) > (select max(c1), min(c2) from t2 where t1.c1 > t2.c1);
select * from t1 where (c1+c2, c2) > (select max(c1), min(c2) from t2 where t1.c1 > t2.c1);
select /*+NO_REWRITE*/ * from t1 where (c1+c2, c2) > (select max(c1), min(c2) from t2 where t1.c1 > t2.c1);


# compound condition
explain select * from t1 where not (c1, c2) > (select max(c1), min(c2) from t2 where t1.c3 > t2.c3);
select * from t1 where not (c1, c2) > (select max(c1), min(c2) from t2 where t1.c3 > t2.c3);
select /*+NO_REWRITE*/ * from t1 where not (c1, c2) > (select max(c1), min(c2) from t2 where t1.c3 > t2.c3);


# compound projection
explain select * from t1 where (c1, c2) < (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1);
select * from t1 where (c1, c2) < (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1);
select /*+NO_REWRITE*/ * from t1 where (c1, c2) < (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1);


# non_null_propagation projection 
explain select * from t1 where (c1, c2) > (select max(c1)+1, nvl(max(1),5) from t2 where t1.c1 > t2.c1);
select * from t1 where (c1, c2) > (select max(c1)+1, nvl(max(1),5) from t2 where t1.c1 > t2.c1);
select /*+NO_REWRITE*/ * from t1 where (c1, c2) > (select max(c1)+1, nvl(max(1),5) from t2 where t1.c1 > t2.c1);


# non_null_reject condition
explain select * from t1 where (c1, nvl(c2,-1)) > (select max(c1), min(c2) from t2 where t1.c3 >= t2.c1);
select * from t1 where (c1, nvl(c2,-1)) > (select max(c1), min(c2) from t2 where t1.c3 >= t2.c1);
select /*+NO_REWRITE*/ * from t1 where (c1, nvl(c2,-1)) > (select max(c1), min(c2) from t2 where t1.c3 >= t2.c1);


# equal correlation condition
explain select * from t1 where (c1, c2) > (select max(c1), max(c2) from t2 where t1.c1 = t2.c1);
select * from t1 where (c1, c2) > (select max(c1), max(c2) from t2 where t1.c1 = t2.c1);
select /*+NO_REWRITE*/ * from t1 where (c1, c2) > (select max(c1), max(c2) from t2 where t1.c1 = t2.c1);


# query-query vector comparison
explain select * from t1 where not (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 = t2.c2);
select * from t1 where not (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 = t2.c2);
select /*+NO_REWRITE*/ * from t1 where not (select max(c1)-avg(c2)+2, max(0) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 = t2.c2);

explain select * from t1 where not (select nvl(max(c1),1), max(c2) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 > t2.c2);
select * from t1 where not (select nvl(max(c1),1), max(c2) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 > t2.c2);
select /*+NO_REWRITE*/ * from t1 where not (select nvl(max(c1),1), max(c2) from t2 where t1.c1 > t2.c1) > (select max(c1), max(c2) from t2 where t1.c2 > t2.c2);


# test the rewrite impact on the general ja cases (Does it affect other rewriting logic?) 
EXPLAIN select * from t1 where (select min(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;
select * from t1 where (select min(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;
select * from t1 where (select /*+no_unnest*/ min(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;

EXPLAIN select * from t1 where (select count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;
select * from t1 where (select count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;
select * from t1 where (select /*+no_unnest*/ count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1) > 0;

EXPLAIN select * from t1 where nvl((select count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1), 1) > 0;
select * from t1 where nvl((select count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1), 1) > 0;
select * from t1 where nvl((select /*+no_unnest*/ count(c2) from t2 where t2.c1 = t1.c1 group by t2.c1), 1) > 0;

EXPLAIN select t1.* from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
select t1.* from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 = t1.c1);
select t1.* from t1 where 2 * t1.c2 > (select /*+no_unnest*/ avg(c2) from t2 where t2.c1 = t1.c1);

EXPLAIN select t1.* from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
select t1.* from t1 where 2 * t1.c2 > (select avg(c2) from t2 where t2.c1 > t1.c1);
select t1.* from t1 where 2 * t1.c2 > (select /*+no_unnest*/ avg(c2) from t2 where t2.c1 > t1.c1);

drop table if exists t1, t2;
drop database transformer;