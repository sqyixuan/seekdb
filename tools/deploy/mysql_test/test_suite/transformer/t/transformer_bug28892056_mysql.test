#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP DATABASE IF EXISTS database2;
--enable_warnings

CREATE DATABASE database2;
USE database2;
CREATE TABLE t0(c0 FLOAT ZEROFILL  COMMENT 'asdf' , c1 DECIMAL ZEROFILL  UNIQUE, c2 DOUBLE  UNIQUE NULL , c3 DOUBLE ZEROFILL  ) ;
CREATE TABLE t1 LIKE t0;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
INSERT  INTO t0(c1) VALUES(-0.0);
DELETE FROM t0;
CREATE INDEX i220 USING BTREE ON t0(c3, c1, c2, c0) INVISIBLE;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
DROP INDEX c1 ON t0;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
CREATE UNIQUE INDEX i850 ON t1(c2);
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
DELETE FROM t0 WHERE t0.c1;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2' order by table_name;
DELETE FROM t1;
CREATE INDEX i4487 ON t1(c3, c2, c0, c1) INVISIBLE;

--result_format 4
--explain_protocol 2

SELECT /*+ NO_MERGE (t1, t0) */ ALL t1.c0 AS ref0 FROM t1, t0 WHERE ( EXISTS (SELECT 1)) IN (NULL, CAST(NULL AS SIGNED)) 
UNION ALL 
SELECT /*+ NO_MERGE (t1, t0) */ ALL t1.c0 AS ref0 FROM t1, t0 WHERE (NOT (( EXISTS (SELECT 1)) IN (NULL, CAST(NULL AS SIGNED)))) 
UNION ALL
SELECT /*+ NO_MERGE (t1, t0) */ ALL t1.c0 AS ref0 FROM t1, t0 WHERE (( EXISTS (SELECT 1)) IN (NULL, CAST(NULL AS SIGNED))) IS UNKNOWN;


DROP DATABASE database2;
