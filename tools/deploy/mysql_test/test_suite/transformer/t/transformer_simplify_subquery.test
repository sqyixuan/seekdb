--error 0, 942, 1051
drop table t3;
create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);
insert into t1 values(1);
insert into t2 values(1);
insert into t3 values(2);
explain select * from t1 where exists (select c1 from t2 union select c1 from t3 limit 1 offset 1);
select * from t1 where exists (select c1 from t2 union select c1 from t3 limit 1 offset 1);
explain select /*+no_simplify_subquery*/ * from t1 where exists (select c1 from t2 union select c1 from t3 limit 1 offset 1);
select /*+no_simplify_subquery*/ * from t1 where exists (select c1 from t2 union select c1 from t3 limit 1 offset 1);
