#owner: zhuangyifeng.zyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;

--enable_warnings
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);
create table t4(c1 int, c2 int, c3 int);
insert into t1 values (1,2,3),(2,2,3);
insert into t2 values (2,3,2);

--explain_protocol 2

--echo
--echo *********************no table item and not set query************************
select * from t1 where exists (select 1+floor(2));
select * from t1 where not exists (select 1+floor(2));
select * from t1 where exists (select 1+floor(2) from dual where c1=1);
select * from t1 where not exists (select 1+floor(2) from dual where c1=1);
select * from t1 where exists (select 1+floor(2) from dual having c1>1);
select * from t1 where not exists (select 1+floor(2) from dual having c1>1);

--echo
--echo **************scalar group by with have and not set query*******************
select * from t1 where exists (select max(c1)+sum(c1) from t1 having max(c1) > 0);
select * from t1 where exists (select max(c1)+sum(c1) from t1 group by c1 WITH ROLLUP);

--echo
--echo *********************eliminate set query in exists************************
select * from t1 where exists (select 1+floor(2) union select max(c2)+sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c1)+sum(c1) from t1  union select max(c2)+sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c1)+sum(c1) from t1 union select max(c2)+sum(c2) from t2 intersect select max(c3)+sum(c3) from t3 group by c3);
select * from t1 where exists (select max(c3)+sum(c3) from t3 group by c3 intersect select max(c1)+sum(c1) from t1 union select max(c2)+sum(c2) from t2 );

--echo
--echo *********************simplify select item of set query in exists************************
select * from t1 where exists (select 1+floor(2) where c1=1 union select max(c2)+sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c2),sum(c2) from t2 group by c1 union (select distinct c1,c2 from t3 limit 3,1));
select * from t1 where exists (select max(c1) from t1 group by c1 having min(c1) union select sum(c2)+max(c1) from t2 group by c1 having max(c1));
select * from t1 where exists (select max(c1)+sum(c1) from t1 having max(c1)>1 intersect select max(c2)+sum(c2) from t2 having max(c2)>0 union select min(c2)+sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c1)+sum(c1) from t1 having max(c1)>1 union select max(c2)+sum(c2) from t2 having max(c2)>0 intersect select min(c2)+sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c1),sum(c1) from t1 having max(c1)>1 union select min(c2),sum(c2) from t2 having max(c2)>0);
select * from t1 where exists (select max(c1),sum(c1) from t1 intersect select max(c2),sum(c2) from t2 union select c1,min(c1) from t2 group by c1);
select * from t1 where exists (select max(c1),sum(c1) from t1 having max(c1)>1 intersect select max(c2),sum(c2) from t2 having max(c2)>0 union select min(c2),sum(c2) from t2 having max(c2)>0);
--echo
--echo *********************simplify group by of set query in exists************************
select * from t1 where exists (select * from t1 group by c1 union select * from t2 group by c2);
select * from t1 where exists (select * from t1 group by c1 intersect select * from t2 group by c2);
select * from t1 where exists (select * from t1 group by c1 except select * from t2 group by c2);
select * from t1 where exists (select * from t1 group by c1 union select * from t2 group by c2 intersect select * from t3 group by c3);
select * from t1 where exists (select * from t1 group by c1 intersect select * from t2 group by c2 union select * from t3 group by c3);

--explain_protocol 0

--error 0, 942
drop table t1;
--error 0, 942
drop table t2;
--error 0, 942
drop table t3;
--error 0, 942
drop table t4;


