#owner: sean.yyj
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11;
--enable_warnings
let old_version='4.3.4.0';
let new_version='4.3.5.0';

create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t3(c1 int primary key, c2 int, c3 int);
create table t4(c1 int primary key, c2 int, c3 int);
create table t5(c1 int primary key, c2 int, c3 int);
create table t6(c1 int primary key, c2 int, c3 int);
create table t7(c1 int primary key, c2 int, c3 int);
create table t8(c1 int primary key, c2 int, c3 int);
create table t9(c1 int primary key, c2 int, c3 int);
create table t10(c1 int primary key, c2 int, c3 int);
create table t11(c1 int primary key, c2 int, c3 int);

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
--echo # ignore cost comparision when do cost based transformation to verify whether plan validation works
alter system set_tp tp_no = 560, error_code = 1, frequency = 1;

connection default;

--result_format 4
--explain_protocol 2

select t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select sum(t1.c1) from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10 where t1.c1 = t2.c1 and t1.c1 = t3.c1 and t1.c1 = t4.c1 and t1.c1 = t5.c1 and t1.c1 = t6.c1 and t1.c1 = t7.c1 and t1.c1 = t8.c1 and t1.c1 = t9.c1 and t1.c1 = t10.c1
union all
select sum(t1.c2) from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10 where t1.c1 = t2.c1 and t1.c1 = t3.c1 and t1.c1 = t4.c1 and t1.c1 = t5.c1 and t1.c1 = t6.c1 and t1.c1 = t7.c1 and t1.c1 = t8.c1 and t1.c1 = t9.c1 and t1.c1 = t10.c1;

--echo # disable cbqt when table num exceeds 10
select t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+use_concat*/ t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select sum(t1.c1) from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c1 = t2.c1 and t1.c1 = t3.c1 and t1.c1 = t4.c1 and t1.c1 = t5.c1 and t1.c1 = t6.c1 and t1.c1 = t7.c1 and t1.c1 = t8.c1 and t1.c1 = t9.c1 and t1.c1 = t10.c1 and t1.c1 = t11.c1
union all
select sum(t1.c2) from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c1 = t2.c1 and t1.c1 = t3.c1 and t1.c1 = t4.c1 and t1.c1 = t5.c1 and t1.c1 = t6.c1 and t1.c1 = t7.c1 and t1.c1 = t8.c1 and t1.c1 = t9.c1 and t1.c1 = t10.c1 and t1.c1 = t11.c1;

--echo # test sys_var and opt_param
select /*+opt_param('optimizer_cost_based_transformation', 2)*/ t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
set _optimizer_cost_based_transformation = 2;
select t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+opt_param('optimizer_cost_based_transformation', 1)*/ t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
set _optimizer_cost_based_transformation = 0;
select t1.* from t1,t2 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+opt_param('optimizer_cost_based_transformation', 1)*/ t1.* from t1,t2 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+opt_param('optimizer_cost_based_transformation', 2)*/ t1.* from t1,t2 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
set _optimizer_cost_based_transformation = 1;

--echo # test optimizer version
eval set optimizer_features_enable = $old_version;
select t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+opt_param('optimizer_cost_based_transformation', 0)*/ t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
eval set optimizer_features_enable = $new_version;

--echo # cbqt will be enabled after some table has been eliminated
select t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10 left join t11 on t10.c1 = t11.c1 where t1.c2 = t2.c2 or t1.c3 = t2.c3;
select /*+no_eliminate_join*/ t1.* from t1,t2,t3,t4,t5,t6,t7,t8,t9,t10 left join t11 on t10.c1 = t11.c1 where t1.c2 = t2.c2 or t1.c3 = t2.c3;

connection conn_admin;
alter system set_tp tp_no = 560, error_code = 0, frequency = 0;

connection default;
drop table t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11;
