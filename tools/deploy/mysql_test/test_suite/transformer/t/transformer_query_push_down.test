--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lijinmao.ljm
#owner group: sql1
#tags: pl, optimizer
#description: transform模块测试，对比transform以后的结果与非transform的结果,验证transform正确性

--disable_warnings
drop table if exists t1, t2, t3, t4;
drop table if exists t_sq;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t3 (c1 int, c2 int, c3 int);
create table t4 (c1 int, c2 int, c3 int);

--disable_query_log
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 2, 3);
insert into t1 values (4, 6, 4);
insert into t1 values (5, 4, 3);
insert into t1 values (6, 4, 2);
insert into t2 values (1, 1, 1);
insert into t2 values (2, 2, 2);
insert into t2 values (3, 2, 3);
insert into t2 values (4, 6, 4);
insert into t2 values (5, 4, 3);
insert into t2 values (6, 4, 2);
insert into t3 values(2, 2, 2);
insert into t3 values(3, 3, 3);
insert into t3 values(4, 4, 4);
insert into t3 values(5, 5, 5);
insert into t4 values(1, 1, 1);
insert into t4 values(2, 2, 2);
insert into t4 values(3, 3, 3);
insert into t4 values(7, 7, 7);
insert into t4 values(8, 8, 8);
--disable_result_log
call dbms_stats.gather_table_stats(NULL, 't1');
call dbms_stats.gather_table_stats(NULL, 't2');
call dbms_stats.gather_table_stats(NULL, 't3');
call dbms_stats.gather_table_stats(NULL, 't4');
select/**/ count(*) from t1;
select count(*) from t2;
select/**/ count(*) from t3;
select count(*) from t4;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
set autocommit=0;

--echo select stmt no operator and view stmt is not spj

