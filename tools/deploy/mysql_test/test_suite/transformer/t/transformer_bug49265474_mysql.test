--disable_warnings
drop table if exists collect_company_base_info;
--enable_warnings

CREATE TABLE `collect_company_base_info` 
(
  id bigint(11) primary key,
  social_credit_code varchar(32) collate utf8mb4_bin,
  tax_no varchar(32) collate utf8mb4_bin,
  key idx_ssc(social_credit_code),
  key idx_tax(tax_no)
);

delimiter //;
create procedure insert_values()
begin
declare number int;
set number = 1;
while number <= 10000
do
insert into collect_company_base_info values (number, number, number);
set number = number + 1;
end
while;
end //
delimiter ;//

call insert_values();

--result_format 4
--explain_protocol 2

select 
1
from
  collect_company_base_info
where(
    tax_no in (
      '911301045909779885',
      '911301045632034429',
      '91130123MA07N6YM14',
      '91130181MA0F8YDMX0',
      '91130981MA0D820N6R',
      '91130302MA0E39844G',
      '91130100792673181N',
      '91130982MA07QF9388',
      '92131026MA0839F27J',
      '91130181MA0DCG3L9W'
    )
    or social_credit_code in (
      '911301045909779885',
      '911301045632034429',
      '91130123MA07N6YM14',
      '91130181MA0F8YDMX0',
      '91130981MA0D820N6R',
      '91130302MA0E39844G',
      '91130100792673181N',
      '91130982MA07QF9388',
      '92131026MA0839F27J',
      '91130181MA0DCG3L9W'
    )
  );

drop table collect_company_base_info;