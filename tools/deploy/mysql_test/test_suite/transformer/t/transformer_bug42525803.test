#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
--error 0, 1051
drop table partsupp;
--error 0, 1051
drop table part;
--enable_warnings

CREATE TABLE partsupp (
    ps_partkey bigint NOT NULL,
    ps_suppkey bigint NOT NULL,
    ps_availqty bigint DEFAULT NULL,
    ps_supplycost bigint DEFAULT NULL,
    ps_comment varchar(199) DEFAULT NULL,
    PRIMARY KEY (ps_partkey, ps_suppkey))
    partition by key(ps_partkey) partitions 96;

CREATE TABLE part (
  p_partkey bigint NOT NULL,
  p_name varchar(55) DEFAULT NULL,
  p_mfgr char(25) DEFAULT NULL,
  p_brand char(10) DEFAULT NULL,
  p_type varchar(25) DEFAULT NULL,
  p_size bigint DEFAULT NULL,
  p_container char(10) DEFAULT NULL,
  p_retailprice bigint DEFAULT NULL,
  p_comment varchar(23) DEFAULT NULL,
  PRIMARY KEY (p_partkey))
  partition by key(p_partkey) partitions 96;

--result_format 4
--explain_protocol 2

#--error 1235
INSERT INTO partsupp VALUES
(
59,1,
CASE WHEN
    CASE WHEN 
    (
      (exists
          (
           select 82 AS sc0,
                  68 AS sc1
           FROM   part AS ref_0
           limit 120
          )
      )
    ) 
    THEN 99
    ELSE 6
    END
    IN (cast(73 AS decimal),32)
THEN 99
ELSE 63
END,
82,'');

select * from partsupp;

--error 0, 1051
drop table partsupp;
--error 0, 1051
drop table part;


--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);

SELECT if(not EXISTS (SELECT 1 FROM t1 AS ref_7) , subq_0.sc1 , 10) as a
FROM (SELECT CASE WHEN EXISTS (SELECT 1 FROM t2 AS ref_1 where ref_1.c1 ) THEN 24 ELSE 6 END AS sc1 FROM t3 AS ref_0) AS subq_0
WHERE subq_0.sc1 != (22);

drop table t1,t2,t3;
