# owner: lijinmao.ljm
# onwer group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE IF EXISTS t4, t5;
--enable_warnings

create table t4(c1 int , c2 int , c3 int, primary key(c1,c2));
insert into t4 values (1, 2, 3);
insert into t4 values (1, 5, 4);
insert into t4 values (2, 6, 1);
insert into t4 values (2, 5, 1);
insert into t4 values (3, 5, 5);
insert into t4 values (3, 7, 1);

create table t5(c1 int , c2 int , c3 int primary key);
insert into t5 values (3, 2, 1);
insert into t5 values (4, 5, 2);
insert into t5 values (1, 1, 3);
insert into t5 values (1, 5, 4);
insert into t5 values (5, 5, 5);
insert into t5 values (1, 7, 6);

--explain_protocol 1
--result_format 4

select /*+no_simplify_subquery*/ * from t4 where exists(select /*+no_simplify_group_by*/ min(999+1) from t5 where t5.c1 = 1 and t5.c2 = 1 group by t5.c2);
select * from t4 where exists(select min(999+1) from t5 where t5.c1 = 1 and t5.c2 = 1 group by t5.c2);

select /*+no_simplify_subquery*/ * from t4 where not exists(select /*+no_simplify_group_by*/ min(999+1) from t5 where t5.c1 = 1 and t5.c2 = 1 group by t5.c2);
select * from t4 where not exists(select min(999+1) from t5 where t5.c1 = 1 and t5.c2 = 1 group by t5.c2);

drop table t4, t5;