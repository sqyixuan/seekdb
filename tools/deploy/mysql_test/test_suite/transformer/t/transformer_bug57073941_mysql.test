# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set ob_query_timeout=100000000;
--enable_sorted_result

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (c1 varchar(48));
create table t2 (c1 varchar(48), c2 int);
create index idx1 on t2(c1(12));
create index idx2 on t2((concat('BM_',c1)));
create index idx3 on t2(c2, c1(12));
insert into t2 values ('abcde', 1), ('BM_abcd', 2), ('abcd', 3), (null, null), ('', null);
insert into t2 select randstr(3,random(1)), uniform(1, 10000, random(1)) from table(generator(10000));
insert into t1 values ('abcd'), (null), (''), ('BM_abcd'), ('ab%cd');
insert into t1 select randstr(4,random(2)) from table(generator(10));
call dbms_stats.gather_table_stats(null,'t1');
call dbms_stats.gather_table_stats(null,'t2');

--explain_protocol 2
--result_format 4


select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;
select /*+index(t2 idx1)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;

select t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1;
select /*+index(t2 idx2)*/ t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1;

select t2.c1, t1.c1 from t1, t2 where t2.c1 like t1.c1;
select /*+no_index(t2 idx1)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 like t1.c1;

select v.c1, t1.c1 from t1, (select distinct c1 from t2) v where v.c1 like t1.c1;

select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 and t2.c2 = 1;
select /*+use_nl(t1,t2)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 and t2.c2 = 1;

select t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) like t1.c1;
select /*+no_index(t2 idx2)*/ t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) like t1.c1;

select * from t2 where c1 like 'abcde%' or c1 = 'abcd';
select /*+no_index(t2 idx1)*/ * from t2 where c1 like 'abcde%' or c1 = 'abcd';

select * from t2 where concat('BM_',c1) = 'BM_abcde' or concat('BM_',c1) = 'BM_abcd';
select /*+no_index(t2 idx2)*/ * from t2 where concat('BM_',c1) = 'BM_abcde' or concat('BM_',c1) = 'BM_abcd';

select * from t2 where (c2 = 1 and c1 like 'abcde%') or (c2 = 2 and c1 = 'abcd');
select /*+index(t2 idx3)*/ * from t2 where (c2 = 1 and c1 like 'abcde%') or (c2 = 2 and c1 = 'abcd');

select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 or t2.c1 like t1.c1;
select /*+no_index(t2 idx1)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 or t2.c1 like t1.c1;

select t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1 or concat('BM_',t2.c1) like t1.c1;
select /*+no_index(t2 idx2)*/ t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1 or concat('BM_',t2.c1) like t1.c1;

set optimizer_features_enable = '4.2.1.0';
show variables like 'optimizer_features_enable';
select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;
select /*+index(t2 idx1)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1;

select t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1;
select /*+index(t2 idx2)*/ t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) = t1.c1;

select t2.c1, t1.c1 from t1, t2 where t2.c1 like t1.c1;
select /*+no_index(t2 idx1)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 like t1.c1;

select v.c1, t1.c1 from t1, (select distinct c1 from t2) v where v.c1 like t1.c1;

select t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 and t2.c2 = 1;
select /*+use_nl(t1,t2)*/ t2.c1, t1.c1 from t1, t2 where t2.c1 = t1.c1 and t2.c2 = 1;

select t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) like t1.c1;
select /*+no_index(t2 idx2)*/ t2.c1, t1.c1 from t1, t2 where concat('BM_',t2.c1) like t1.c1;

select * from t2 where c1 like 'abcde%' or c1 = 'abcd';
select /*+no_index(t2 idx1)*/ * from t2 where c1 like 'abcde%' or c1 = 'abcd';

set optimizer_features_enable = default;
drop table t1, t2;