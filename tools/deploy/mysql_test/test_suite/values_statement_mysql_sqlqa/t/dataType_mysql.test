drop table hal;

CREATE TABLE hal (
  id INT NOT NULL PRIMARY KEY,
  date_col DATE NOT NULL,
  time_col TIME NOT NULL,
  year_col YEAR(4) NOT NULL,
  datetime_col DATETIME NOT NULL,
  timestamp_col TIMESTAMP NOT NULL
);

INSERT INTO hal (
    id, date_col, time_col, year_col, datetime_col, timestamp_col)
VALUES(
    1, '2021-04-15', '14:30:00', 2021, '2021-04-15 14:30:00', '2023-07-06 12:00:00');

select * from hal;

