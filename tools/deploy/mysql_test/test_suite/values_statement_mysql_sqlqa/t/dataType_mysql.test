--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user hal@'%';
create user hal identified by 'hal';
grant all on *.* to hal WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hal,hal,test,$OBMYSQL_PORT);

--enable_warnings
