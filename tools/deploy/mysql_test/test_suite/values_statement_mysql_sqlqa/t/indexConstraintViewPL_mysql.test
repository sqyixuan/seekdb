-- error 0,1064
CREATE PROCEDURE hal_procedure()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 4
DO
    values row((select * from ((values row(2)))as c1));
    SET i = i + 1;
END WHILE;
COMMIT;
END;
/
delimiter ;/
-- error 0,1305
call hal_procedure;



-- error 0,1305
