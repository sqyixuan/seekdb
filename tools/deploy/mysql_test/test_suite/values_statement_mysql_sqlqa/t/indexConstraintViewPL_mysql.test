-- echo # 索引 values-6
-- echo # 普通索引
--error 0,1051
drop table hal;

create table hal(
    id int(10),
    num1 int(10),
    num2 int(10)
);

insert into hal(id,num1,num2) values(1,100,2020),(2,11,2300),(3,1111,2800);

select * from hal;

-- error 0,1091
drop index hal_index on hal;

create index hal_index on hal(id);

select * from hal where id >0;
values row((select id from hal where id = 1));
select * from (
    values row((select id from hal where id = 2))
)as c1;



-- echo # 普唯一索引
