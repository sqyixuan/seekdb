    SET i = i + 1;
END WHILE;
COMMIT;
END;
/
delimiter ;/
call hal_procedure;



-- echo # loop
-- error 0,1305
-- echo todo bugid:81079
-- error 0,1305
drop procedure hal_procedure;
delimiter /;
-- error 0,1064
CREATE PROCEDURE hal_procedure()
BEGIN
    DECLARE i INT DEFAULT 1;
    lp:loop
        values row(1,2,3);
        SET i = i + 1;
        if i>3 then
        leave lp;
    end if;
    end loop;
COMMIT;
END;
/
delimiter ;/
-- error 0,1305
call hal_procedure;


