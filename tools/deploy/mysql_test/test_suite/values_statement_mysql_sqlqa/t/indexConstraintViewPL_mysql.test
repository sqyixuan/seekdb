-- echo # 范围check约束
--error 0,1051
drop table hal;

create table hal(
    id int(10) not null,
    num1 int(10),
    num2 int(10),
    CONSTRAINT num2_check CHECK (num2 >= 0 AND num2 <= 10000)
);

insert into hal(id,num1,num2) values row(1,100,2020),row(2,11,2300),row(3,1111,2800);

-- error 0,3819
insert into hal(id,num1,num2) values row(4,11111,-100);
-- error 0,3819
insert into hal(id,num1,num2) values row(5,11111,111110);

select * from hal where id > 0;

values row((select num2 from hal where num2 = 2020));
select * from (
    values row((select num2 from hal where num2 = 2020))
)as c1;



-- echo # 外键约束
--error 0,1051
drop table hal;
--error 0,1051
drop table hal1;
create table hal1(
    c_id int PRIMARY KEY,
    username char(20)
);
insert into hal1 values row(1,'hal'),row(2,'haer'),row(3,'coco');
select * from hal1;

CREATE TABLE hal(
        v_id int,
        num1 int,
        num2 int,
        CONSTRAINT fk_orders_customer_id FOREIGN KEY (v_id)
        REFERENCES hal1 (c_id)
);

insert into hal(v_id,num1,num2) values row(1,100,2020),row(2,11,2300),row(3,1111,2800);
select * from hal;

-- error 0,1054
insert into hal(id,num1,num2) values row(4,11111,-100);
-- error 0,1054
insert into hal1(id,num1,num2) values row(4,'11111');

values row((select v_id from hal where v_id = 1));
select * from (
    values row((select v_id from hal where v_id = 2))
)as c1;

values row((select c_id from hal1 where c_id = 1));
select * from (
    values row((select c_id from hal1 where c_id = 2))
)as c1;



