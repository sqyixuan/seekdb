-- echo # 触发器values-9-3
-- echo # insert
-- error 0,1305
drop table hal;
create table hal(
    id int,
    num1 int,
    num2 int
);
insert into hal values(1,111,2222);
select * from hal;

-- error 0,1305
drop table hal1;
create table hal1(
    id int,
    num1 int,
    num2 int
);
insert into hal1 values(1,111,2222);
select * from hal1;

DROP TRIGGER IF EXISTS hal_trigger;
delimiter /;
CREATE TRIGGER hal_trigger
AFTER insert ON hal1
FOR EACH ROW
BEGIN
    insert into hal values row(2,666,888);
END;
/
delimiter ;/
insert into hal1 values(2,666,888);
select * from hal;
select * from hal1;



-- echo # update
-- error 0,1051
drop table hal;
create table hal(
    id int,
    num1 int,
    num2 int
);
insert into hal values(1,111,2222);
select * from hal;

-- error 0,1051
drop table hal1;
create table hal1(
    id int,
    num1 int,
    num2 int
);
insert into hal1 values(1,111,2222);
select * from hal1;

DROP TRIGGER IF EXISTS hal_trigger;
delimiter /;
CREATE TRIGGER hal_trigger
AFTER UPDATE ON hal1
FOR EACH ROW
BEGIN
    UPDATE hal SET num1 = (values row(10086)) where id = 1;
END;
/
delimiter ;/
update hal1 set num1 = 10086 where id = 1;
select * from hal;
select * from hal1;



