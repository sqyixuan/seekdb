-- echo # while
-- echo todo bugid:81079
-- error 0,1305
drop procedure hal_procedure;
delimiter /;
-- error 0,1064
CREATE PROCEDURE hal_procedure()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 4
DO
    values row(1,2,3);
    SET i = i + 1;
END WHILE;
COMMIT;
END;
/
delimiter ;/
-- error 0,1305
call hal_procedure;


-- echo todo bugid:81079
