#owner:zhanyue.zzy
#owner group:sql2
#tags:DML\DDL
#description:参数验证
#author:wb-zcp01469308
--echo #Environmental cleaning
--disable_warnings
--error 0,1396
drop user hal@'%';
create user hal identified by 'hal';
grant all on *.* to hal WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hal,hal,test,$OBMYSQL_PORT);


-- echo # 测试用例：参数验证 values-2------------------------------------------------------
-- echo # 单个参数、多个参数前面已测试
-- echo # 参数为空
-- error 0,3942
values row( );

-- echo # 多个参数为空
-- error 0,1064
values row( , );

-- echo # 参数为null
values row(null);

-- echo # 参数为null
values row(null,null);

values row(null,null),row(null,null);

-- echo # 参数为负
values row(-100);

values row(-100,-100);

values row(-100,-100),row(-100,-100);

-- echo # 特殊字符
values row('-！@#¥%……&*');

values row('-！@#¥%……&*','-！@#¥%……&*');

values row('-！@#¥%……&*','-！@#¥%……&*'),row('-！@#¥%……&*','-！@#¥%……&*');

