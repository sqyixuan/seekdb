drop table hal;

create table hal(
    id int(10),
    num int(10)
);

insert into hal(id,num) values(1,100);

select * from hal;

select * from hal where (
    num > (values row(1))
);

select * from hal where (
    num < (values row(1))
);

select * from hal where (
    num <= (values row(1))
);

select * from hal where (
    num >= (values row(1))
);

select * from hal where (
    num = (values row(100))
);

select * from hal where (
    num >= (values row(100))
);

select * from hal where (
    num >= (values row(10))
);




drop table hal;

create table hal(
    id int(10),
    num int(10)
);

insert into hal(id,num) values(1,100);
insert into hal(id,num) values(2,1000);
insert into hal(id,num) values(3,10000);

select * from hal;

select * from hal where (
    num > (values row(1))
);

select * from hal where (
    num < (values row(1))
);

select * from hal where (
    num <= (values row(1))
);

select * from hal where (
    num >= (values row(1))
);

select * from hal where (
    num = (values row(100))
);

select * from hal where (
    num >= (values row(100))
);

select * from hal where (
    num >= (values row(10))
) order by num desc ;

select * from hal where (
    num >= (values row(10))
) limit 1 ;

select * from hal where (
    num >= (values row(10))
) order by num desc limit 1 ;



