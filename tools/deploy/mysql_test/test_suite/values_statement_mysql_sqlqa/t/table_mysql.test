   if (column_0 = (values row(1110)),'yes','NAN hal...')as column_if
from ((values row(1110,222,333)))as c1;

select column_0 ,
   if (column_0 = (values row(111)),'yes','NAN hal...')as column_if
from ((values row(1110,222,333)))as c1;

-- echo # ifnull
select *,
    IFNULL(column_1, 'value default null...')as if_null
from ((values row(1,'char1','varchar')))as c1;

select *,
    IFNULL((values row(column_1)), (values row('value default null...')))as if_null
from ((values row(1,'char1','varchar')))as c1;

select *,
    IFNULL((values row(column_1)), (values row('value default null...')))as if_null
from ((values row(2,'','varchar')))as c1;

-- echo # nullif
select *,
    NULLIF(column_1, column_2)as null_if
from ((values row(1,'char1','varchar')))as c1;

select *,
    NULLIF((values row(column_1)), (values row(column_2)))as null_if
from ((values row(1,'char1','varchar')))as c1;

select *,
    NULLIF((values row(column_1)), (values row(column_2)))as null_if
from ((values row(2,'varchar','varchar')))as c1;

