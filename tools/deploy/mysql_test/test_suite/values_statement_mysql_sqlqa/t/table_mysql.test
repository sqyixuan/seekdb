-- echo # 自查询
--error 0,1051
drop table hal;

create table hal as (
    select * from (
        values
        row(11,12),
        row(21,22),
        row(31,32),
        row(41,42),
        row(51,52),
        row(61,62)
    ) as dd
);

select * from hal;

select * from hal where column_0 in (
    select * from(
        values
        row(11),
        row(61)
    ) as dd
);



-- echo # 外连接
select c1.column_0,c1.column_1 from (
    values
    row(11,12),
    row(21,22)
) as c1
inner join(
    select c2.column_0,c2.column_1 from (
        values
        row(11,12),
        row(21,22),
        row(31,32)
    ) as c2
)as c22 on c1.column_0 = c22.column_0;


select c1.column_0,c1.column_1 from (
    values
    row(11,12),
    row(21,22)
) as c1
left join(
    select c2.column_0,c2.column_1 from (
        values
        row(11,12),
        row(21,22),
        row(31,32)
    ) as c2
)as c22 on c1.column_0 = c22.column_0;


select c1.column_0,c1.column_1 from (
    values
    row(11,12),
    row(21,22)
) as c1
right join(
    select c2.column_0,c2.column_1 from (
        values
        row(11,12),
        row(21,22),
        row(31,32)
    ) as c2
)as c22 on c22.column_0 = c1.column_0;



-- echo # union
values
    row(11,12),
    row(21,22),
    row(31,32)
    union
    values
    row(111,120);


select c1.column_0,c1.column_1 from (
    values
    row(11,12),
    row(21,22),
    row(31,32)
    union
    values
    row(111,120)
) as c1;



