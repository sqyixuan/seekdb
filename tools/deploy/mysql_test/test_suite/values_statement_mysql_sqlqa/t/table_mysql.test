-- echo # update values-3-4
-- error 0,1051
drop table hal;
create table hal(
    id int(10),
    c_char char(100),
    c_int int(10),
    c_date date,
    c_blob blob
);

insert into hal(id,c_char,c_int,c_date,c_blob)
values
row(1,'c_char',10086,'2022-10-10','c_blob');
select * from hal;

update hal set c_char = (values row('c_char1')) where id = 1;
select * from hal;

update hal set
    c_int = (values row(10001)),
    c_date = (values row('2024-10-10')),
    c_blob = (values row('c_blob1'))
where id = 1;
select * from hal;


update hal set c_char = (select * from (values row('c_char2'))as c1) where id = 1;
select * from hal;

update hal set
    c_int = (select * from (values row(88888-8))as c1),
    c_date = (select * from (values row('2026-10-10'))as c2),
    c_blob = (select * from (values row('c_blob2'))as c3)
where id = 1;
select * from hal;

-- echo # where字句
update hal set
    c_int = (select * from (values row(88888-8))as c1)
where id <> 0;
select * from hal;

update hal set
    c_int = (select * from (values row(88888-8))as c1)
where id = 0 and c_char = '';
select * from hal;

update hal set
    c_int = (select * from (values row(88))as c1)
where c_char like '' or c_char like 'c_char';
select * from hal;

