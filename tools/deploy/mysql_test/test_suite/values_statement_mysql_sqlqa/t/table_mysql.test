where column_0 > any
(select * from ((values row(1)))as c1);
select * from ((values row(10,2,3)))as c1
where column_0 > all
(select * from ((values row(1)))as c1);
select * from ((values row(10,2,3)))as c1 where column_0 in(10,20,30);



