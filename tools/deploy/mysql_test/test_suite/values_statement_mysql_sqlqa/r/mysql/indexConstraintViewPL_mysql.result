grant all on *.* to hal WITH GRANT OPTION;
# 索引 values-6
# 普通索引
drop table hal;
create table hal(
id int(10),
num1 int(10),
num2 int(10)
);
insert into hal(id,num1,num2) values(1,100,2020),(2,11,2300),(3,1111,2800);
select * from hal;
id	num1	num2
1	100	2020
2	11	2300
3	1111	2800
drop index hal_index on hal;
create index hal_index on hal(id);
select * from hal where id >0;
id	num1	num2
1	100	2020
2	11	2300
3	1111	2800
values row((select id from hal where id = 1));
column_0
1
select * from (
values row((select id from hal where id = 2))
)as c1;
column_0
