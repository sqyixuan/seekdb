todo bugid:81079
drop procedure hal_procedure;
CREATE PROCEDURE hal_procedure()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 4
DO
values row(1,2,3);
SET i = i + 1;
END WHILE;
COMMIT;
END;
/
call hal_procedure;
