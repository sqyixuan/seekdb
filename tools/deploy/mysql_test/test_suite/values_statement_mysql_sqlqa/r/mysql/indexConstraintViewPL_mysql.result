drop procedure hal_procedure;
CREATE PROCEDURE hal_procedure()
BEGIN
DECLARE i INT DEFAULT 1;
lp:loop
values row(1,2,3);
SET i = i + 1;
if i>3 then
leave lp;
end if;
end loop;
COMMIT;
END;
/
call hal_procedure;
