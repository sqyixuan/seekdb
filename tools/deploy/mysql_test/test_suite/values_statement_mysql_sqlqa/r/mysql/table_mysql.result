# insert values-3-2
# 插入到不同的数据类型value
# 字符数据类型
# 数值数据类型
# 日期时间类型
# 大对象类型
# 运算符
drop table hal;
create table hal(
id int(10),
c_char char(100),
c_int int(10),
c_date date,
c_blob blob
);
insert into hal(id,c_char,c_int,c_date,c_blob)
values
row(1,'c_char',10086,'2022-10-10','c_blob');
select * from hal;
id	c_char	c_int	c_date	c_blob
1	c_char	10086	2022-10-10	c_blob
