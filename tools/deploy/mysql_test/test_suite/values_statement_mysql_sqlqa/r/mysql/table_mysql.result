#Environmental cleaning
drop user hal@'%';
create user hal identified by 'hal';
grant all on *.* to hal WITH GRANT OPTION;
# 表 values-3
# select values-3-1
# create as values
drop table hal;
create table hal as (select * from (values row(11,22)) as d);
select * from hal;
