# where字句
values row(1,2,3) where column_0 > 1;
values row(1,2,3),row(10,20,30) where column_0 > 1;
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 >1;
column_0	column_1	column_2
10	20	30
values row(1,2,3) where column_0 = 1;
values row(1,2,3),row(10,20,30) where column_0 = 1;
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 =1;
column_0	column_1	column_2
1	2	3
values row(1,2,3) where column_0 < 1;
values row(1,2,3),row(10,20,30) where column_0 < 1;
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 < 100;
column_0	column_1	column_2
1	2	3
10	20	30
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 <= 100;
column_0	column_1	column_2
1	2	3
10	20	30
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 >= 0;
column_0	column_1	column_2
1	2	3
10	20	30
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 <> 100;
column_0	column_1	column_2
1	2	3
10	20	30
select * from ((values row(1,2,3),row(10,20,30)))as c1 where (column_0 >= 10 and column_1 >= 20) or column_2 > 20 ;
column_0	column_1	column_2
10	20	30
select * from ((values row(1,2,3),row(10,20,30)))as c1 where column_0 between 10 and 20;
column_0	column_1	column_2
10	20	30
select * from ((values row('aaa','abc','保时捷'),row('bbb','bfg','保时捷')))as c1 where column_0 like '%a%';
column_0	column_1	column_2
aaa	abc	保时捷
select * from ((values row('aaa','abc','保时捷'),row('bbb','bfg','保时捷')))as c1 where column_0 not like '%a%';
column_0	column_1	column_2
bbb	bfg	保时捷
select * from ((values row('aaa','abc','保时捷')))as c1 where exists (select * from dual);
column_0	column_1	column_2
aaa	abc	保时捷
select * from ((values row(10,2,3)))as c1
where column_0 > any
(select * from ((values row(1)))as c1);
