# 字符型数据类型
# char
drop table hal;
CREATE TABLE hal (
id INT NOT NULL PRIMARY KEY,
char_col CHAR(5) NOT NULL,
varchar_col VARCHAR(255) NOT NULL,
tinytext_col TINYTEXT NOT NULL,
text_col TEXT NOT NULL,
mediumtext_col MEDIUMTEXT NOT NULL,
longtext_col LONGTEXT NOT NULL,
blob_col BLOB NOT NULL,
tinyblob_col TINYBLOB NOT NULL,
mediumblob_col MEDIUMBLOB NOT NULL,
longblob_col LONGBLOB NOT NULL
);
INSERT INTO hal (
id, char_col, varchar_col, tinytext_col, text_col, mediumtext_col,
longtext_col, blob_col, tinyblob_col, mediumblob_col, longblob_col
) VALUES
(
1, 'hello', 'world', 'tinytext', 'text', 'mediumtext',
'longtext_col', 'blob_col', 'tinyblob_col', '010203mediumblob_col', '010203040506longblob_col'
);
