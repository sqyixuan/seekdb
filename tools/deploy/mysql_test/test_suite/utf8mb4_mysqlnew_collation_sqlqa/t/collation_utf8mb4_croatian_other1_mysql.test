drop table t1;
create table t1(c0 varchar(100),c1 varchar(100),full varchar(100) collate utf8mb4_unicode_520_ci generated always as(concat(c0,c1)) ) character set utf8mb4;
insert into t1(c0,c1) values('$','$');
insert into t1(c0,c1) values('￥','￥');
insert into t1(c0,c1) values('123','123');
insert into t1(c0,c1) values('null','null');
insert into t1(c0,c1) values('Null','Null');
insert into t1(c0,c1) values('123.1','123.1');
insert into t1(c0,c1) values('abc ABC','abc ABC');
insert into t1(c0,c1) values('abc&ABC','abc&ABC');
insert into t1(c0,c1) values('2010-11-11','2010-11-11');
insert into t1(c0,c1) values('中文字符123','中文字符123');
insert into t1(c0,c1) values('中文abc字符','中文abc字符');
insert into t1(c0,c1) values('中文ABC字符','中文ABC字符');
insert into t1(c0,c1) values('abc中文字符123','abc中文字符123');
insert into t1(c0,c1) values('ABC中文字符123','ABC中文字符123');
