explain (SELECT t8_49.c13 AS c1 FROM (SELECT (SELECT t8.c1 FROM t8 ORDER BY 1 LIMIT 1) AS c1, t8.c2, t8.c3, t8.c4, (SELECT MAX(t8.c5) FROM t8) AS c5, (SELECT t8.c6 FROM t8 ORDER BY 1 DESC LIMIT 1) AS c6, t8.c7, t8.c8, t8.c9, t8.c10, (SELECT t8.c11 FROM t8 ORDER BY 1 LIMIT 1) AS c11, (SELECT MIN(t8.c12) FROM t8) AS c12, t8.c13, t8.c14, t8.c15 FROM t8) AS t8_49, t24 AS t24_143_1 WHERE EXISTS (SELECT t35_47.c2 FROM t35 AS t35_47 WHERE concat(t35_47.c8, t35_47.c11) LIKE '%Ab%' OR t35_47.c2 = 'AyTJeAmtTWcIR' AND t35_47.c11 >= (SELECT t35_47.c1 FROM t35 AS t35_47 ORDER BY 1 ASC LIMIT 1)) GROUP BY t8_49.c13 HAVING MAX(t8_49.c6) <> 173 ORDER BY 1 LIMIT 6778) UNION (SELECT t5_32.c2 FROM (SELECT t5.c1, t5.c2, t5.c3, t5.c4, t5.c5, t5.c6, t5.c7, t5.c8, t5.c9, t5.c10, t5.c11, t5.c12, t5.c13, t5.c14, t5.c15 FROM t5) AS t5_32 WHERE t5_32.c9 > 750 GROUP BY t5_32.c2 HAVING AVG(t5_32.c7) >= 600 ORDER BY 1) ORDER BY 1 LIMIT 1087;
(SELECT t8_49.c13 AS c1 FROM (SELECT (SELECT t8.c1 FROM t8 ORDER BY 1 LIMIT 1) AS c1, t8.c2, t8.c3, t8.c4, (SELECT MAX(t8.c5) FROM t8) AS c5, (SELECT t8.c6 FROM t8 ORDER BY 1 DESC LIMIT 1) AS c6, t8.c7, t8.c8, t8.c9, t8.c10, (SELECT t8.c11 FROM t8 ORDER BY 1 LIMIT 1) AS c11, (SELECT MIN(t8.c12) FROM t8) AS c12, t8.c13, t8.c14, t8.c15 FROM t8) AS t8_49, t24 AS t24_143_1 WHERE EXISTS (SELECT t35_47.c2 FROM t35 AS t35_47 WHERE concat(t35_47.c8, t35_47.c11) LIKE '%Ab%' OR t35_47.c2 = 'AyTJeAmtTWcIR' AND t35_47.c11 >= (SELECT t35_47.c1 FROM t35 AS t35_47 ORDER BY 1 ASC LIMIT 1)) GROUP BY t8_49.c13 HAVING MAX(t8_49.c6) <> 173 ORDER BY 1 LIMIT 6778) UNION (SELECT t5_32.c2 FROM (SELECT t5.c1, t5.c2, t5.c3, t5.c4, t5.c5, t5.c6, t5.c7, t5.c8, t5.c9, t5.c10, t5.c11, t5.c12, t5.c13, t5.c14, t5.c15 FROM t5) AS t5_32 WHERE t5_32.c9 > 750 GROUP BY t5_32.c2 HAVING AVG(t5_32.c7) >= 600 ORDER BY 1) ORDER BY 1 LIMIT 1087;

drop table t8;
drop table t5;
drop table t24;
drop table t35;
