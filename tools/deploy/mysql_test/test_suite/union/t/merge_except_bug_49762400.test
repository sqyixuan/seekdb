#owner: peihan.dph
#owner group: SQL2
# tags:


--disable_warnings
drop table if exists t5,t6, t15, t20;
--enable_warnings


--disable_query_log
create table t5 (c1 INT(127) ,c2 DATE,c3 INT(127) ,c4 BIGINT(127) ,c5 VARCHAR(86) ,c6 TIMESTAMP(2)  NOT NULL default 0,c7 VARBINARY(67) ,c8 BIGINT(127) ,c9 BIGINT(127) ,c10 TIME,c11 DATE,c12 YEAR(4) ,c13 TIME, primary key(c3,c9,c8,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;
create table t6 (c1 YEAR(4) ,c2 VARCHAR(86) ,c3 BINARY(100) ,c4 DATETIME,c5 DECIMAL(64,7) ,c6 VARBINARY(57) ,c7 BINARY(122) ,c8 TIME,c9 INT(127) ,c10 DATE, primary key(c2,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;
create table t15 (c1 CHAR(152) ,c2 TIMESTAMP(3)  NOT NULL default 0,c3 TIME,c4 DATE,c5 VARBINARY(56) ,c6 DATE,c7 VARBINARY(50) ,c8 DECIMAL(64,9) ,c9 TIME,c10 VARBINARY(56) ,c11 DATE,c12 INT(127)  auto_increment,c13 VARCHAR(86) ,c14 DATE,c15 DATETIME,c16 INT(127) ,c17 DATE,c18 BIGINT(127) ,c19 YEAR(4) , primary key(c7,c13))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c7) PARTITIONS 10;
create table t20 (c1 TIME,c2 VARBINARY(60) ,c3 TIME,c4 TIMESTAMP(5)  NOT NULL default 0,c5 BINARY(122) ,c6 NUMERIC(64,6) ,c7 CHAR(152) ,c8 NUMERIC(64,10) ,c9 VARBINARY(73) ,c10 DATETIME,c11 CHAR(152) ,c12 TIMESTAMP(1)  NOT NULL default 0,c13 BINARY(105) ,c14 BIGINT(127) ,c15 NUMERIC(64,25) , primary key(c15,c9,c14,c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;

