purge recyclebin;
#Environmental cleaning
DROP USER lrp01;
CREATE USER 'lrp01' IDENTIFIED BY 'lrp123';
GRANT all ON *.* TO lrp01 WITH GRANT OPTION;
DROP DATABASE oblrp;
CREATE DATABASE oblrp;
use oblrp;
drop table tt1;
create table tt1(id int,a varchar(20),d date);
insert into tt1 values(1,'test01','2021-12-10');
insert into tt1 values(2,'test02','2021-12-11');
insert into tt1 values(3,'test03','2021-12-11');
drop table t2;
create table tt2(id int,a varchar(20),d date);
insert into tt2 values(1,'test01','2020-10-10');
alter_routine_2 存储过程alter routine
