name	security_type	sql_data_access	definer	is_deterministic	param_list
p_test	DEFINER	CONTAINS_SQL	'lrp01'@'%'	NO	
call p_test();
id	a	d
1	test01	2021-12-10
2	test02	2021-12-11
3	test03	2021-12-11
4	test04	2021-12-12
