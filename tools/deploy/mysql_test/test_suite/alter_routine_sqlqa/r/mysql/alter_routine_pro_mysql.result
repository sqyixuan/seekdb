drop PROCEDURE p_test;
CREATE  PROCEDURE p_test() 
begin
insert into tt1 values(4,'test04','2021-12-12');
select * from tt1;
END;
//
alter procedure p_test CONTAINS SQL;
SHOW CREATE PROCEDURE p_test ;
Procedure	sql_mode	Create Procedure	character_set_client	collation_connection	Database Collation
p_test	STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER	CREATE DEFINER = `lrp01`@`%` PROCEDURE `p_test`()
begin
insert into tt1 values(4,'test04','2021-12-12');
select * from tt1;
END	utf8mb4	utf8mb4_general_ci	utf8mb4_general_ci
