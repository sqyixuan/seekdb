#insert/replace/ ON DUPLICATE KEY UPDATE
drop table if exists tt3;
create table tt3(id int primary key,b int unsigned ,a varchar(50),r roaringbitmap);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(rb_contains(rb_from_string('1'),1),rb_contains(rb_from_string('1'),rb_from_string('1,2')),rb_contains(rb_from_string('1'),1),rb_from_string('1'));
--error 1235
insert into tt3 values(rb_contains(rb_from_string('1'),0),rb_contains(rb_from_string('1'),rb_from_string('1,2')),rb_contains(rb_from_string('1'),1),rb_contains(rb_from_string('1'),1));

replace into tt3 values(rb_contains(rb_from_string('1'),1),rb_contains(rb_from_string('1,2,3'),rb_from_string('1,2')),rb_contains(rb_from_string('1'),rb_from_string('1,2')),rb_from_string('1,3,4,5')),
(rb_contains(rb_from_string('1'),0),rb_contains(rb_from_string('0,1'),rb_from_string('1,2')),rb_contains(rb_from_string('1'),0),rb_from_string('1'));

