#order by
select *,rb_contains(r,r) from tt3 order by rb_contains(r,r);
select *,rb_contains(r,r1),rb_contains(r1,1) from tt3 order by rb_contains(r,1) desc,rb_contains(r1,r1) asc;
select * from tt3 order by rb_contains(r,r);
select * from tt3,tt1 order by rb_contains(tt3.r,tt1.r);
select * from tt3,tt1 order by rb_contains(tt3.r,tt1.id);

#group by
select *,rb_contains(r,r),rb_contains(r1,1) from tt3 group by id,a0;
select *,rb_contains(r,1),rb_contains(r1,r) from tt3  group by id,a0 order by rb_contains(r,r),rb_contains(r,1);

select /*+use_hash_aggregation*/ *,rb_contains(r,1),rb_contains(r1,r) from tt3  group by id,a0 order by rb_contains(r,r),rb_contains(r,1);


select *,rb_contains(r,r1),rb_contains(r1,1) from tt3 group by id,a0 having(rb_contains(r,r))<10;
select rb_contains(r,r),rb_contains(r1,2),r from tt3 group by id,a0 having rb_contains(r,3)<10;
select rb_contains(r,1),rb_contains(r1,r1),r1 ,r from tt3 group by id,a0 having rb_contains(r,r1) <10;
select rb_contains(r,r),rb_contains(r1,1),r from tt3 group by id,a0 having rb_contains(r,3) =10;

select r from tt3 group by id,a0 having(rb_contains(r,r))<10;
select id,rb_contains(r,1),rb_contains(r1,r1),r from tt3 group by a0 having rb_contains(r,id) <10;
--disable_result_log
select t1.r,t2.r from tt3 t1,tt3 t2 group by t2.id,t1.a0 having(rb_contains(t1.r,t2.r))=rb_contains(t1.r,t2.r);
select t1.r,t2.r,rb_contains(t2.r1,1) from tt3 t1,tt3 t2 group by t2.id,t1.a0 having(rb_contains(t1.r,t2.r))=rb_contains(t1.r,t2.r);
--enable_result_log
#distinct
select  distinct rb_contains(r,r),rb_contains(r1,2) from tt3;
select  distinct rb_contains(r,r) from vtt3;
--sorted_result
select  /*+NO_USE_HASH_DISTINCT*/ distinct rb_contains(r,r),rb_contains(r1,2) from tt3;
--sorted_result
select /*+USE_HASH_AGGREGATION*/  distinct rb_contains(r,r) from vtt3;
--sorted_result
select  distinct rb_contains(t1.r,t2.r),rb_contains(t2.r1,2) from tt3 t1 inner join tt3 t2 on rb_contains(t2.r,1)=rb_contains(t1.r,t2.r);
#limit
--sorted_result
select *, rb_contains(r,r),rb_contains(r1,1) from tt3 limit 2;
--sorted_result
select *, rb_contains(r,r),rb_contains(r1,1) from tt2 order by id limit 3 OFFSET 2;
#where
select  * from tt3 where rb_contains(r,r)=rb_contains(r1,r1);
select  * from tt3 where rb_contains(r,1)='test';
select  * from tt3 where rb_contains(r,r)!=1;
select  * from tt3 where rb_contains(r,r)<>1;
select  * from tt3 where rb_contains(r,r)<=>1;
select  * from tt3 where rb_contains(r,1)>=rb_contains(r,1);
select  * from tt3 where rb_contains(r,1) is true;
select  * from tt3 where rb_contains(r,r) is not true;
select  * from tt3 where rb_contains(r,1) is false;
select  * from tt3 where rb_contains(r,r) is not false;
select  * from tt3 where rb_contains(r,1) BETWEEN rb_contains(r,1) AND  rb_contains(r1,r1);
select  * from tt3 where rb_contains(r,1) not BETWEEN rb_contains(r,1) AND  rb_contains(r1,r1);
select  * from tt3 where  rb_contains(r,1) like rb_contains(r1,r1);
select  r,r1 from tt3 where  rb_contains(r,1) like rb_contains(r1,r1);
select  r,r1 from tt3 where  rb_contains(r,r) not like rb_contains(r1,1);
select  * from tt3 where rb_contains(r,r) in(rb_contains(r,r),rb_contains(r1,1));
select  * from tt3 where rb_contains(r,1) not in (rb_contains(r,r),rb_contains(r1,1));
--sorted_result
select  * from tt3 t1,tt3 t2 where rb_contains(t1.r,1) in (rb_contains(t1.r,t2.r),rb_contains(t2.r1,1));
--sorted_result
select  * from tt3 t1,tt3 t2 where rb_contains(t1.r,1) in (rb_contains(t1.r,t2.r));

select  * from tt3 where rb_contains(r,r) is null;
select  * from tt3 where rb_contains(r,id) is not null;
select  * from tt3 where rb_contains(r,id) is  null;

select  * from tt3 where  rb_contains(r,r) >some(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) =some(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) >=some(select rb_contains(r,1) from tt3);
select  * from tt3 where  rb_contains(r,r) >any(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) =any(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) <>any(select rb_contains(r,1) from tt3);
select  * from tt3 where  rb_contains(r,r) >all(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) =all(select rb_contains(r,r1) from tt3);
select  * from tt3 where  rb_contains(r,id) <>all(select rb_contains(r,1) from tt3);


#for update
select * ,rb_contains(r,r) from tt3  for update;
select * ,rb_contains(r,id) from tt2  for update;
#with as
WITH Alice_Students AS (
    select rb_contains(r,id) a,rb_contains(r1,r1) from tt3
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
    select rb_contains(rb_from_string('1,2,3,5'),1) a,rb_contains(rb_from_string('1,2,3,5'),rb_from_string('1,2,3'))
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
    select rb_contains(rb_from_string('1,2,3,5'),r) a,rb_contains(rb_from_string('1,2,3,5'),rb_from_string('1,2,3')) from tt3
)
SELECT * FROM Alice_Students;
--disable_result_log
WITH Alice_Students AS (
    select rb_contains(t1.r,t2.id) a,rb_contains(t2.r1,t1.r) b from tt3 t1,tt3 t2
)
SELECT * FROM Alice_Students;
--enable_result_log

#case when 
SELECT CASE rb_contains(r,r) WHEN rb_contains(r,1) THEN rb_contains(r,r1) WHEN rb_contains(r1,id) THEN rb_contains(r1,id) END  from tt2 order by id;
SELECT CASE rb_contains(r1,id) WHEN rb_contains(r,r) THEN rb_contains(r,id) WHEN rb_contains(r1,r) THEN rb_contains(r1,6) END  from tt2 order by id;

SELECT CASE WHEN rb_contains(r1,r1) >rb_contains(r,1) THEN rb_contains(r1,id) else  rb_contains(r,r) end from tt2 order by id;
SELECT CASE WHEN rb_contains(r1,r) =rb_contains(r,r1) THEN 105 else  rb_contains(r1,r1) end from tt2 order by id;
SELECT CASE WHEN rb_contains(r1,1) !=rb_contains(r,1) THEN 105 else  rb_contains(r,1) end from vtt2 order by id;


