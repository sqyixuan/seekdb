select  rb_contains(tt2.r,tt1.r1) from tt1 left  JOIN	 tt2 on rb_contains(tt2.r,tt1.r1)=rb_contains(tt1.r,tt2.r1) MINUS select  rb_contains(tt2.r,tt1.id) from tt1 FULL  JOIN	tt2 on tt1.id=tt2.id;
