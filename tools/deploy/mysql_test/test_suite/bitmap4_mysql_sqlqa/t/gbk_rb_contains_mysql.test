select rb_contains(r,r) a from tt1 UNION select rb_contains(r1,r1) a from tt2;
select rb_contains(r,id) a from tt1 UNION ALL select rb_contains(r,id) a from tt2;
select rb_contains(r,r) a from tt1 INTERSECT select rb_contains(r,id) a from tt2;
select rb_contains(r,r1) a from tt1 MINUS  select rb_contains(r,r) a from tt2;
select rb_contains(r,id) a from tt1 UNION select rb_contains(r,r1) a from tt2 UNION select rb_contains(r,r1) a from tt3;
select rb_contains(r1,r) a from tt1 UNION ALL select rb_contains(r,id) a from tt2 UNION ALL select rb_contains(r1,r1) a from tt3;
select rb_contains(r1,1) a from tt1 INTERSECT select rb_contains(r1,r) a from tt2 INTERSECT select rb_contains(r,r) a from tt3;
select rb_contains(r,id) a from tt1 MINUS  select rb_contains(r1,1) a from tt2 INTERSECT select rb_contains(r,r) a from tt3;

select * from tt1 INNER JOIN tt2 on rb_contains(tt1.r,tt2.r1)=rb_contains(tt2.r,tt1.id);
select * from tt1 right JOIN tt2 on rb_contains(tt1.r,tt2.r1)=rb_contains(tt2.r,tt1.id);
select * from tt1 left JOIN tt2 on rb_contains(tt1.r,tt2.r1)=rb_contains(tt2.r,tt1.id);
select * from tt1 full JOIN tt2 on rb_contains(tt1.r,tt2.r1)=rb_contains(tt2.r,tt1.id);

select *, rb_contains(tt2.r,tt1.r) from tt1 LEFT  JOIN tt2 on tt1.id=tt2.id order by tt2.id;
select *, rb_contains(tt2.r,tt1.r1) from tt1 RIGHT  JOIN tt2 on tt1.id=tt2.id order by tt2.id;
select *, rb_contains(tt2.r,tt1.id) from tt1 FULL  JOIN	 tt2 on tt1.id=tt2.id order by tt2.id;
