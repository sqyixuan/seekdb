drop database if exists db_sync_src;
drop database if exists db_sync_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
# 启用 debug sync
alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
============================================
1. 创建源库（单表，便于卡在 BUILD_DATA 的单一任务）
============================================
create database db_sync_src;
use db_sync_src;
create table t1 (id int primary key, name varchar(50));
insert into t1 values (1, 'a'), (2, 'b'), (3, 'c');
============================================
2. 设置 debug sync：Fork 卡在 BUILD_DATA（数据构建前）
============================================
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for signal_fork_db execute 10000';
# 执行 fork database（提交后立即返回，后台任务会卡在 BUILD_DATA）
fork database db_sync_src to db_sync_fork;
# 等待任务进入 BUILD_DATA 阶段（数据尚未构建）
============================================
3. 数据构建完成前的行为校验：目标库已建、表已建、数据未就绪
============================================
# 目标库应已存在
show databases like 'db_sync_fork';
Database (db_sync_fork)
db_sync_fork
# 进入目标库，表应已存在
use db_sync_fork;
show tables;
Tables_in_db_sync_fork
t1
# 数据构建完成前（卡在 BUILD_DATA 时）的可见性校验
select count(*) as cnt_before_build from t1;
cnt_before_build
3
============================================
4. 释放卡点并等待 Fork Database 完成
============================================
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal signal_fork_db';
============================================
5. 数据构建完成后的校验
============================================
use db_sync_fork;
select count(*) as cnt_after_build from t1;
cnt_after_build
3
select * from t1 order by id;
id	name
1	a
2	b
3	c
============================================
6. 清理
============================================
set ob_global_debug_sync = 'reset';
use oceanbase;
drop database if exists db_sync_src;
drop database if exists db_sync_fork;
