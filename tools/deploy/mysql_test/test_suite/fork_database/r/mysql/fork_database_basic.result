drop database if exists db_src;
drop database if exists db_fork;
drop database if exists db_empty;
drop database if exists db_empty_fork;
drop database if exists db_multi;
drop database if exists db_multi_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 基本Fork Database功能测试
============================================
# 创建源数据库和表
create database db_src;
use db_src;
# 创建多个表并插入数据
create table t1 (
id int primary key,
name varchar(50),
age int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300)
);
create table t2 (
id int primary key,
value int,
status varchar(20)
);
create table t3 (
id int primary key,
data text
) partition by hash(id) partitions 2;
# 向各表插入数据
insert into t1 values (1, 'Alice', 25);
insert into t1 values (101, 'Bob', 30);
insert into t1 values (201, 'Charlie', 35);
insert into t2 values (1, 100, 'active');
insert into t2 values (2, 200, 'inactive');
insert into t2 values (3, 300, 'pending');
insert into t3 values (1, 'Data1');
insert into t3 values (2, 'Data2');
insert into t3 values (3, 'Data3');
# 执行Fork Database
fork database db_src to db_fork;
# 等待Fork Database完成
# 验证目标数据库已创建
show databases like 'db_fork';
Database (db_fork)
db_fork
# 切换到目标数据库，验证表结构
use db_fork;
show tables;
Tables_in_db_fork
t1
t2
t3
# 验证各表结构
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `age` int(11) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p2` values less than (300))
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `id` int(11) NOT NULL,
  `value` int(11) DEFAULT NULL,
  `status` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `id` int(11) NOT NULL,
  `data` text DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(id)
(partition `p0`,
partition `p1`)
# 验证各表数据
select count(*) as t1_cnt from t1;
t1_cnt
3
select * from t1 order by id;
id	name	age
1	Alice	25
101	Bob	30
201	Charlie	35
select count(*) as t2_cnt from t2;
t2_cnt
3
select * from t2 order by id;
id	value	status
1	100	active
2	200	inactive
3	300	pending
select count(*) as t3_cnt from t3;
t3_cnt
3
select * from t3 order by id;
id	data
1	Data1
2	Data2
3	Data3
# 验证源数据库数据未受影响
use db_src;
select count(*) as t1_cnt from t1;
t1_cnt
3
select count(*) as t2_cnt from t2;
t2_cnt
3
select count(*) as t3_cnt from t3;
t3_cnt
3
============================================
2. 数据隔离测试 - INSERT/UPDATE/DELETE
============================================
# 在Fork库中插入新数据
use db_fork;
insert into t1 values (50, 'Fork_New', 40);
# 验证Fork库有新数据
select count(*) as t1_cnt from t1;
t1_cnt
4
select * from t1 where id = 50;
id	name	age
50	Fork_New	40
# 验证源库数据未受影响
use db_src;
select count(*) as t1_cnt from t1;
t1_cnt
3
select * from t1 where id = 50;
id	name	age
# 修改Fork库中的数据
use db_fork;
update t1 set name = 'Fork_Updated', age = 100 where id = 1;
# 验证Fork库数据已修改
select * from t1 where id = 1;
id	name	age
1	Fork_Updated	100
# 验证源库数据未受影响
use db_src;
select * from t1 where id = 1;
id	name	age
1	Alice	25
# 从Fork库中删除数据
use db_fork;
delete from t1 where id = 201;
# 验证Fork库数据已删除
select * from t1 where id = 201;
id	name	age
# 验证源库数据未受影响
use db_src;
select * from t1 where id = 201;
id	name	age
201	Charlie	35
============================================
3. 空数据库Fork测试
============================================
create database db_empty;
use db_empty;
# Fork空数据库
fork database db_empty to db_empty_fork;
# 验证Fork空数据库成功
show databases like 'db_empty_fork';
Database (db_empty_fork)
db_empty_fork
# 验证Fork数据库为空
use db_empty_fork;
show tables;
Tables_in_db_empty_fork
============================================
4. Fork数据库含自增列表测试
============================================
create database db_multi;
use db_multi;
create table t_auto (
id int auto_increment primary key,
name varchar(50),
value int
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t_auto(name, value) values ('Auto1', 100);
insert into t_auto(name, value) values ('Auto2', 200);
# Fork数据库
fork database db_multi to db_multi_fork;
# 验证自增列独立工作
use db_multi_fork;
insert into t_auto(name, value) values ('Fork_Auto', 999);
select * from t_auto order by id;
id	name	value
1	Auto1	100
2	Auto2	200
3	Fork_Auto	999
use db_multi;
insert into t_auto(name, value) values ('Source_Auto', 888);
select * from t_auto order by id;
id	name	value
1	Auto1	100
2	Auto2	200
3	Source_Auto	888
============================================
5. 清理
============================================
drop database if exists db_src;
drop database if exists db_fork;
drop database if exists db_empty;
drop database if exists db_empty_fork;
drop database if exists db_multi;
drop database if exists db_multi_fork;
