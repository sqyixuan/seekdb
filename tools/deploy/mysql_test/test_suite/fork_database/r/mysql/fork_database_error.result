drop database if exists db_error_src;
drop database if exists db_error_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 错误场景 - 源数据库不存在
============================================
fork database non_existent_db to some_target_db;
ERROR 42000: Unknown database 'non_existent_db'
============================================
2. 错误场景 - 目标数据库已存在
============================================
create database db_error_src;
create database db_error_fork;
fork database db_error_src to db_error_fork;
ERROR HY000: Can't create database 'db_error_fork'; database exists
============================================
3. 错误场景 - 源库在回收站中
============================================
drop database if exists db_recycle_test;
drop database if exists db_recycle_fork;
create database db_recycle_test;
use db_recycle_test;
create table t1 (id int primary key);
# 将数据库放入回收站
drop database db_recycle_test;
# 尝试Fork回收站中的数据库应该失败
fork database db_recycle_test to db_recycle_fork;
ERROR 42000: Unknown database 'db_recycle_test'
============================================
4. 错误场景 - Fork到同名数据库
============================================
fork database db_error_src to db_error_src;
ERROR HY000: Can't create database 'db_error_src'; database exists
============================================
5. 错误场景 - 从系统库/内部库 Fork 不支持
============================================
fork database oceanbase to db_from_sys;
ERROR 0A000: fork database from system or internal database not supported
fork database mysql to db_from_mysql;
ERROR 0A000: fork database from system or internal database not supported
============================================
6. 错误场景 - 含全局索引的分区表不支持Fork
============================================
drop database if exists db_gidx_src;
drop database if exists db_gidx_fork;
create database db_gidx_src;
use db_gidx_src;
# 创建带全局索引的分区表
create table t_global (
a int,
b varchar(150),
c int,
d int,
primary key(a, b)
) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300)
);
# 创建全局索引
create index idx_c_global on t_global(c) global partition by hash(c) partitions 2;
create unique index idx_d_global on t_global(d) global;
# 插入数据
insert into t_global values (1, 'Row1', 100, 1000);
insert into t_global values (101, 'Row2', 200, 2000);
insert into t_global values (201, 'Row3', 300, 3000);
# Fork数据库应该失败（含全局索引的分区表不支持）
fork database db_gidx_src to db_gidx_fork;
ERROR 0A000: fork table on partitioned table with global index is not supported
============================================
7. 错误场景 - 含 Routine（存储过程/函数）的数据库不支持 Fork
============================================
drop database if exists db_routine_src;
drop database if exists db_routine_fork;
create database db_routine_src;
use db_routine_src;
create table t1 (id int primary key);
create procedure p_dummy() begin end;
# Fork 含存储过程的数据库应失败
fork database db_routine_src to db_routine_fork;
ERROR 0A000: fork database containing routines (procedures/functions) not supported
============================================
8. 错误场景 - 含 Trigger 的数据库不支持 Fork
============================================
drop database if exists db_trigger_src;
drop database if exists db_trigger_fork;
create database db_trigger_src;
use db_trigger_src;
create table t1 (id int primary key, c1 int);
create trigger tri_bi before insert on t1 for each row set new.c1 = coalesce(new.c1, 0) + 1;
# Fork 含触发器的数据库应失败
fork database db_trigger_src to db_trigger_fork;
ERROR 0A000: fork database containing triggers not supported
============================================
9. 错误场景 - 含 Sequence 的数据库不支持 Fork
============================================
drop database if exists db_seq_src;
drop database if exists db_seq_fork;
create database db_seq_src;
use db_seq_src;
create table t1 (id int primary key);
create sequence seq1;
# Fork 含 Sequence 的数据库应失败
fork database db_seq_src to db_seq_fork;
ERROR 0A000: fork database containing sequences not supported
============================================
10. 清理
============================================
use oceanbase;
drop database if exists db_error_src;
drop database if exists db_error_fork;
drop database if exists db_gidx_src;
drop database if exists db_gidx_fork;
Warnings:
Note	1008	Can't drop database 'db_gidx_fork'; database doesn't exist
drop database if exists db_routine_src;
drop database if exists db_routine_fork;
Warnings:
Note	1008	Can't drop database 'db_routine_fork'; database doesn't exist
drop database if exists db_trigger_src;
drop database if exists db_trigger_fork;
Warnings:
Note	1008	Can't drop database 'db_trigger_fork'; database doesn't exist
drop database if exists db_seq_src;
drop database if exists db_seq_fork;
Warnings:
Note	1008	Can't drop database 'db_seq_fork'; database doesn't exist
