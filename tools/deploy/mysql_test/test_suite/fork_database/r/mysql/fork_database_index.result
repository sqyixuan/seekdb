drop database if exists db_idx_src;
drop database if exists db_idx_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. Fork含多种索引类型的数据库
============================================
create database db_idx_src;
use db_idx_src;
# 创建带普通索引的表
create table t_normal_idx (
id int primary key,
name varchar(50),
age int,
index idx_name(name),
index idx_age(age)
);
# 创建带唯一索引的表
create table t_unique_idx (
id int primary key,
username varchar(100) unique,
phone varchar(20),
unique key uk_phone(phone)
);
# 创建带复合索引的表
create table t_composite_idx (
id int primary key,
a int,
b int,
c int,
index idx_ab(a, b),
index idx_abc(a, b, c)
);
# 创建带前缀索引的表
create table t_prefix_idx (
id int primary key,
content varchar(500),
index idx_content(content(20))
);
# 插入数据
insert into t_normal_idx values (1, 'Alice', 25), (2, 'Bob', 30), (3, 'Charlie', 35);
insert into t_unique_idx values (1, 'user_a', '111'), (2, 'user_b', '222');
insert into t_composite_idx values (1, 10, 20, 30), (2, 11, 21, 31), (3, 10, 21, 32);
insert into t_prefix_idx values (1, repeat('Hello ', 50)), (2, repeat('World ', 50));
# Fork数据库
fork database db_idx_src to db_idx_fork;
============================================
2. 验证Fork库中索引工作正常
============================================
use db_idx_fork;
# 验证普通索引
select * from t_normal_idx where name = 'Alice';
id	name	age
1	Alice	25
select * from t_normal_idx where age = 30;
id	name	age
2	Bob	30
# 验证唯一索引
select * from t_unique_idx where username = 'user_a';
id	username	phone
1	user_a	111
select * from t_unique_idx where phone = '111';
id	username	phone
1	user_a	111
# 验证复合索引
select * from t_composite_idx where a = 10;
id	a	b	c
1	10	20	30
3	10	21	32
select * from t_composite_idx where a = 10 and b = 20;
id	a	b	c
1	10	20	30
select * from t_composite_idx where a = 10 and b = 21 and c = 32;
id	a	b	c
3	10	21	32
# 验证前缀索引
select id, left(content, 20) as preview from t_prefix_idx where content like 'Hello%';
id	preview
1	Hello Hello Hello He
============================================
3. 验证唯一索引约束在Fork库中生效
============================================
insert into t_unique_idx values (3, 'user_a', '333');
ERROR 23000: Duplicate entry 'user_a' for key 'username'
insert into t_unique_idx values (4, 'user_c', '111');
ERROR 23000: Duplicate entry '111' for key 'uk_phone'
# 合法插入
insert into t_unique_idx values (5, 'user_c', '333');
select * from t_unique_idx order by id;
id	username	phone
1	user_a	111
2	user_b	222
5	user_c	333
============================================
4. 验证索引独立性
============================================
# 在源库中添加新索引
use db_idx_src;
create index idx_name_age on t_normal_idx(name, age);
show create table t_normal_idx;
Table	Create Table
t_normal_idx	CREATE TABLE `t_normal_idx` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `age` int(11) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_name` (`name`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_age` (`age`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_name_age` (`name`, `age`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
# 验证Fork库无此索引
use db_idx_fork;
show create table t_normal_idx;
Table	Create Table
t_normal_idx	CREATE TABLE `t_normal_idx` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `age` int(11) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_name` (`name`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_age` (`age`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
============================================
5. 清理
============================================
drop database if exists db_idx_src;
drop database if exists db_idx_fork;
