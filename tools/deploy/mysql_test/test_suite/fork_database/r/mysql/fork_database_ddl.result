drop database if exists db_ddl_src;
drop database if exists db_ddl_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. Fork数据库
============================================
create database db_ddl_src;
use db_ddl_src;
create table t1 (
id int primary key,
name varchar(50),
value int
);
create table t2 (
id int primary key,
data varchar(100)
);
insert into t1 values (1, 'Test1', 100), (2, 'Test2', 200);
insert into t2 values (1, 'Data1'), (2, 'Data2');
# Fork数据库
fork database db_ddl_src to db_ddl_fork;
============================================
2. 在源库中执行DDL - ADD COLUMN
============================================
use db_ddl_src;
alter table t1 add column phone varchar(20);
desc t1;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(50)	YES		NULL	
value	int(11)	YES		NULL	
phone	varchar(20)	YES		NULL	
# 验证Fork库表结构未受影响
use db_ddl_fork;
desc t1;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(50)	YES		NULL	
value	int(11)	YES		NULL	
============================================
3. 在Fork库中执行DDL - ADD COLUMN（不同列）
============================================
use db_ddl_fork;
alter table t1 add column address varchar(200);
desc t1;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(50)	YES		NULL	
value	int(11)	YES		NULL	
address	varchar(200)	YES		NULL	
# 验证源库表结构未受影响
use db_ddl_src;
desc t1;
Field	Type	Null	Key	Default	Extra
id	int(11)	NO	PRI	NULL	
name	varchar(50)	YES		NULL	
value	int(11)	YES		NULL	
phone	varchar(20)	YES		NULL	
============================================
4. 在源库中执行DDL - CREATE INDEX
============================================
use db_ddl_src;
create index idx_value on t1(value);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `phone` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_value` (`value`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
# 验证Fork库无此索引
use db_ddl_fork;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `address` varchar(200) DEFAULT NULL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
============================================
5. 在Fork库中执行DDL - CREATE INDEX（不同索引）
============================================
use db_ddl_fork;
create index idx_name on t1(name);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `address` varchar(200) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_name` (`name`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
# 验证源库无此索引
use db_ddl_src;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `name` varchar(50) DEFAULT NULL,
  `value` int(11) DEFAULT NULL,
  `phone` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_value` (`value`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
============================================
6. 在源库中执行DDL - CREATE TABLE
============================================
use db_ddl_src;
create table t3 (id int primary key, info varchar(100));
insert into t3 values (1, 'OnlyInSrc');
show tables;
Tables_in_db_ddl_src
t1
t2
t3
# 验证Fork库无此表
use db_ddl_fork;
show tables;
Tables_in_db_ddl_fork
t1
t2
============================================
7. 在Fork库中执行DDL - CREATE TABLE
============================================
use db_ddl_fork;
create table t4 (id int primary key, info varchar(100));
insert into t4 values (1, 'OnlyInFork');
show tables;
Tables_in_db_ddl_fork
t1
t2
t4
# 验证源库无此表
use db_ddl_src;
show tables;
Tables_in_db_ddl_src
t1
t2
t3
============================================
8. 在源库中执行DDL - DROP TABLE
============================================
use db_ddl_src;
drop table t2;
show tables;
Tables_in_db_ddl_src
t1
t3
# 验证Fork库仍有此表
use db_ddl_fork;
show tables;
Tables_in_db_ddl_fork
t1
t2
t4
select * from t2;
id	data
1	Data1
2	Data2
============================================
9. 删除Fork库不影响源库
============================================
drop database db_ddl_fork;
# 验证源库仍可用
use db_ddl_src;
select * from t1;
id	name	value	phone
1	Test1	100	NULL
2	Test2	200	NULL
show tables;
Tables_in_db_ddl_src
t1
t3
============================================
10. 清理
============================================
drop database if exists db_ddl_src;
drop database if exists db_ddl_fork;
Warnings:
Note	1008	Can't drop database 'db_ddl_fork'; database doesn't exist
