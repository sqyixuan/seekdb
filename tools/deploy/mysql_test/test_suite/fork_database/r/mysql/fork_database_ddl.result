drop database if exists db_dsync_src;
drop database if exists db_dsync_fork;
drop database if exists db_dsync_src2;
drop database if exists db_dsync_fork2;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
# 启用 debug sync，DDL 超时设短以便验证阻塞后超时
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '3s';
set ob_global_debug_sync = 'reset';
============================================
1. Fork Database 进行中 DROP 源表：应被阻塞，_ob_ddl_timeout 后超时
============================================
create database db_dsync_src;
use db_dsync_src;
create table t1 (
id int primary key,
name varchar(50)
) partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
insert into t1 values (1, 'A');
insert into t1 values (101, 'B');
# 设置 debug sync：fork 卡在 BUILD_DATA 阶段
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for fork_db_drop_table_signal execute 10000';
# 执行 Fork Database（后台表 fork 任务会在 BUILD_DATA 处卡住）
fork database db_dsync_src to db_dsync_fork;
# 等待至少一个 fork table 任务进入 BUILD_DATA
# Fork 进行中对源表 DROP TABLE：预期被阻塞后超时
drop table t1;
ERROR HY000: Timeout
# 放开 debug sync，让 Fork Database 完成
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal fork_db_drop_table_signal';
# 验证：源库表可正常使用（之前 drop 已超时未生效）
use db_dsync_src;
select count(*) as cnt from t1;
cnt
2
============================================
2. Fork Database 进行中 DROP 源库：应被阻塞，_ob_ddl_timeout 后超时
============================================
create database db_dsync_src2;
use db_dsync_src2;
create table t1 (
id int primary key,
name varchar(50)
);
insert into t1 values (1, 'X');
# 设置 debug sync：fork 卡在 BUILD_DATA 阶段
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for fork_db_drop_db_signal execute 10000';
fork database db_dsync_src2 to db_dsync_fork2;
# 等待至少一个 fork table 任务进入 BUILD_DATA
use oceanbase;
# Fork 进行中对源库 DROP DATABASE：预期被阻塞后超时
drop database db_dsync_src2;
ERROR HY000: Timeout
# 放开 debug sync，让 Fork Database 完成
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal fork_db_drop_db_signal';
# 验证：源库仍存在（之前 drop database 已超时未生效）
show databases like 'db_dsync_src2';
Database (db_dsync_src2)
db_dsync_src2
============================================
3. 清理
============================================
alter system set _ob_ddl_timeout = '1000s';
set ob_global_debug_sync = 'reset';
use oceanbase;
drop database if exists db_dsync_src;
drop database if exists db_dsync_fork;
drop database if exists db_dsync_src2;
drop database if exists db_dsync_fork2;
