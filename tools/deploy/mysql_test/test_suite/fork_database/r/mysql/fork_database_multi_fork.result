drop database if exists db_mf_src;
drop database if exists db_mf_a;
drop database if exists db_mf_b;
drop database if exists db_mf_c;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. 多次Fork同一源库到不同目标库
============================================
create database db_mf_src;
use db_mf_src;
create table t1 (id int primary key, data varchar(50));
insert into t1 values (1, 'Original');
# 第一次Fork
fork database db_mf_src to db_mf_a;
# 修改源库数据后第二次Fork
insert into db_mf_src.t1 values (2, 'Added_Before_B');
fork database db_mf_src to db_mf_b;
# 再次修改源库数据后第三次Fork
insert into db_mf_src.t1 values (3, 'Added_Before_C');
fork database db_mf_src to db_mf_c;
============================================
2. 验证各Fork库数据反映Fork时刻的快照
============================================
# 各库记录数
select 'db_mf_a' as db, count(*) as cnt from db_mf_a.t1;
db	cnt
db_mf_a	1
select 'db_mf_b' as db, count(*) as cnt from db_mf_b.t1;
db	cnt
db_mf_b	2
select 'db_mf_c' as db, count(*) as cnt from db_mf_c.t1;
db	cnt
db_mf_c	3
select 'db_mf_src' as db, count(*) as cnt from db_mf_src.t1;
db	cnt
db_mf_src	3
# 各库数据详情
select * from db_mf_a.t1 order by id;
id	data
1	Original
select * from db_mf_b.t1 order by id;
id	data
1	Original
2	Added_Before_B
select * from db_mf_c.t1 order by id;
id	data
1	Original
2	Added_Before_B
3	Added_Before_C
select * from db_mf_src.t1 order by id;
id	data
1	Original
2	Added_Before_B
3	Added_Before_C
============================================
3. 验证各Fork库独立修改
============================================
insert into db_mf_a.t1 values (10, 'Only_In_A');
insert into db_mf_b.t1 values (20, 'Only_In_B');
insert into db_mf_c.t1 values (30, 'Only_In_C');
insert into db_mf_src.t1 values (40, 'Only_In_Src');
# 验证各库数据独立
select * from db_mf_a.t1 order by id;
id	data
1	Original
10	Only_In_A
select * from db_mf_b.t1 order by id;
id	data
1	Original
2	Added_Before_B
20	Only_In_B
select * from db_mf_c.t1 order by id;
id	data
1	Original
2	Added_Before_B
3	Added_Before_C
30	Only_In_C
select * from db_mf_src.t1 order by id;
id	data
1	Original
2	Added_Before_B
3	Added_Before_C
40	Only_In_Src
============================================
4. 验证修改某个Fork库不影响其他库
============================================
# 在A库中更新数据
update db_mf_a.t1 set data = 'Updated_In_A' where id = 1;
# 验证其他库未受影响
select * from db_mf_a.t1 where id = 1;
id	data
1	Updated_In_A
select * from db_mf_b.t1 where id = 1;
id	data
1	Original
select * from db_mf_c.t1 where id = 1;
id	data
1	Original
select * from db_mf_src.t1 where id = 1;
id	data
1	Original
============================================
5. 清理
============================================
drop database if exists db_mf_src;
drop database if exists db_mf_a;
drop database if exists db_mf_b;
drop database if exists db_mf_c;
