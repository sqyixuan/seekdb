drop database if exists db_cons_src;
drop database if exists db_cons_fork;
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
============================================
1. Fork含各种约束的数据库
============================================
create database db_cons_src;
use db_cons_src;
# 创建带NOT NULL约束的表
create table t_notnull (
id int primary key,
name varchar(50) not null,
username varchar(100) not null
);
# 创建带UNIQUE约束的表
create table t_unique (
id int primary key,
username varchar(100) unique,
phone varchar(20),
unique key uk_phone(phone)
);
# 创建带CHECK约束的表
create table t_check (
id int primary key,
age int check(age >= 0 and age <= 150),
score int check(score >= 0 and score <= 100)
);
# 创建带DEFAULT约束的表
create table t_default (
id int primary key,
name varchar(50),
status int default 0,
created_at timestamp default current_timestamp
);
# 插入数据
insert into t_notnull values (1, 'Alice', 'user_alice');
insert into t_unique values (1, 'user_a', '111');
insert into t_check values (1, 25, 85);
insert into t_default(id, name) values (1, 'Test');
# Fork数据库
fork database db_cons_src to db_cons_fork;
============================================
2. 验证约束在Fork库中生效
============================================
use db_cons_fork;
# 验证数据已复制
select * from t_notnull;
id	name	username
1	Alice	user_alice
select * from t_unique;
id	username	phone
1	user_a	111
select * from t_check;
id	age	score
1	25	85
select id, name, status from t_default;
id	name	status
1	Test	0
# 验证NOT NULL约束（name字段没有默认值）
insert into t_notnull(id, username) values (2, 'test_user');
ERROR HY000: Field 'name' doesn't have a default value
# 验证UNIQUE约束
insert into t_unique values (2, 'user_a', '222');
ERROR 23000: Duplicate entry 'user_a' for key 'username'
# 验证CHECK约束
insert into t_check values (2, -1, 50);
ERROR HY000: check constraint violated
insert into t_check values (3, 25, 150);
ERROR HY000: check constraint violated
# 验证DEFAULT值
insert into t_default(id, name) values (2, 'Default_Test');
select id, name, status from t_default where id = 2;
id	name	status
2	Default_Test	0
============================================
3. 验证约束独立性
============================================
# 在Fork库中插入合法数据
insert into db_cons_fork.t_unique values (10, 'fork_user', '999');
# 在源库中插入相同username（应该成功，因为是不同的库）
insert into db_cons_src.t_unique values (10, 'fork_user', '888');
# 验证两库数据
select * from db_cons_fork.t_unique order by id;
id	username	phone
1	user_a	111
10	fork_user	999
select * from db_cons_src.t_unique order by id;
id	username	phone
1	user_a	111
10	fork_user	888
============================================
4. 清理
============================================
drop database if exists db_cons_src;
drop database if exists db_cons_fork;
