##owner: fankun.fan
##owner group: 底层引擎部-轻量版
##description: Fork Database LOB大字段测试
##tags: fork_database lob text blob
##author: fankun.fan

--disable_warnings
drop database if exists db_lob_src;
drop database if exists db_lob_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. Fork含TEXT字段的数据库
--echo ============================================

create database db_lob_src;
use db_lob_src;

--echo # 创建含TEXT字段的表
create table t_text (
    id int primary key,
    name varchar(50),
    content text,
    description longtext
);

--echo # 创建含BLOB字段的表
create table t_blob (
    id int primary key,
    name varchar(50),
    data blob,
    large_data longblob
);

--echo # 插入数据
insert into t_text values (1, 'Text1', repeat('A', 1000), repeat('B', 5000));
insert into t_text values (2, 'Text2', repeat('C', 2000), repeat('D', 10000));

insert into t_blob values (1, 'Blob1', repeat('X', 1000), repeat('Y', 5000));
insert into t_blob values (2, 'Blob2', repeat('Z', 2000), repeat('W', 10000));

--echo # Fork数据库
fork database db_lob_src to db_lob_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 2. 验证Fork库中LOB数据
--echo ============================================

use db_lob_fork;

--echo # 验证TEXT数据长度
select id, name, length(content) as content_len, length(description) as desc_len from t_text order by id;

--echo # 验证BLOB数据长度
select id, name, length(data) as data_len, length(large_data) as large_len from t_blob order by id;

--echo # 验证TEXT数据内容正确
select id, left(content, 10) as content_preview, left(description, 10) as desc_preview from t_text order by id;

--echo ============================================
--echo 3. 验证LOB数据隔离
--echo ============================================

--echo # 修改Fork库中的LOB数据
update db_lob_fork.t_text set content = repeat('FORK', 500) where id = 1;

--echo # 验证Fork库数据已修改
select id, left(content, 10) as fork_content, length(content) as len from db_lob_fork.t_text where id = 1;

--echo # 验证源库数据未受影响
select id, left(content, 10) as src_content, length(content) as len from db_lob_src.t_text where id = 1;

--echo # 在Fork库中插入新的大LOB数据
insert into db_lob_fork.t_text values (3, 'Fork_New', repeat('NEW', 3000), repeat('LONG', 20000));
select id, name, length(content), length(description) from db_lob_fork.t_text where id = 3;

--echo # 验证源库无此数据
select count(*) as cnt from db_lob_src.t_text where id = 3;

--echo ============================================
--echo 4. 清理
--echo ============================================

drop database if exists db_lob_src;
drop database if exists db_lob_fork;
