##owner: [CONTRIBUTOR]
##owner group: [INTERNAL_PROJECT]
##description: Fork Database多表一致性快照测试
##tags: fork_database snapshot consistency
##author: [CONTRIBUTOR]

--disable_warnings
drop database if exists db_snap_src;
drop database if exists db_snap_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. 创建多表关联的业务场景
--echo ============================================

create database db_snap_src;
use db_snap_src;

--echo # 创建客户表
create table customers (
    customer_id int primary key,
    name varchar(100),
    email varchar(100)
);

--echo # 创建订单表
create table orders (
    order_id int primary key,
    customer_id int,
    total_amount decimal(10,2),
    order_date date
) partition by range(order_id) (
    partition p0 values less than (1000),
    partition p1 values less than (2000)
);

--echo # 创建订单明细表
create table order_items (
    item_id int primary key,
    order_id int,
    product_name varchar(100),
    quantity int,
    price decimal(10,2)
);

--echo # 创建库存表
create table inventory (
    product_id int primary key,
    product_name varchar(100),
    stock int
);

--echo # 插入一致性数据
insert into customers values (1, 'Customer_A', 'a@test.com');
insert into customers values (2, 'Customer_B', 'b@test.com');

insert into orders values (1, 1, 150.00, '2025-01-01');
insert into orders values (2, 1, 200.00, '2025-01-02');
insert into orders values (3, 2, 150.00, '2025-01-03');

insert into order_items values (1, 1, 'Product_A', 2, 50.00);
insert into order_items values (2, 1, 'Product_B', 1, 50.00);
insert into order_items values (3, 2, 'Product_C', 4, 50.00);
insert into order_items values (4, 3, 'Product_A', 3, 50.00);

insert into inventory values (1, 'Product_A', 100);
insert into inventory values (2, 'Product_B', 50);
insert into inventory values (3, 'Product_C', 200);

--echo # Fork数据库
fork database db_snap_src to db_snap_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 2. 验证Fork后多表关联查询一致性
--echo ============================================

--echo # 源库 - 客户订单关联查询
use db_snap_src;
select c.name, o.order_id, o.total_amount
from customers c join orders o on c.customer_id = o.customer_id
order by c.name, o.order_id;

--echo # Fork库 - 客户订单关联查询（应与源库完全一致）
use db_snap_fork;
select c.name, o.order_id, o.total_amount
from customers c join orders o on c.customer_id = o.customer_id
order by c.name, o.order_id;

--echo ============================================
--echo 3. 验证订单明细金额一致性
--echo ============================================

--echo # 源库 - 订单金额校验
use db_snap_src;
select o.order_id, o.total_amount, sum(oi.quantity * oi.price) as calculated_total
from orders o join order_items oi on o.order_id = oi.order_id
group by o.order_id, o.total_amount
order by o.order_id;

--echo # Fork库 - 订单金额校验（应与源库完全一致）
use db_snap_fork;
select o.order_id, o.total_amount, sum(oi.quantity * oi.price) as calculated_total
from orders o join order_items oi on o.order_id = oi.order_id
group by o.order_id, o.total_amount
order by o.order_id;

--echo ============================================
--echo 4. 验证库存数据一致性
--echo ============================================

--echo # 源库 - 库存查询
use db_snap_src;
select * from inventory order by product_id;

--echo # Fork库 - 库存查询
use db_snap_fork;
select * from inventory order by product_id;

--echo ============================================
--echo 5. 验证Fork后独立业务操作
--echo ============================================

--echo # 在Fork库中进行业务操作（模拟下单扣减库存）
use db_snap_fork;
insert into orders values (100, 1, 100.00, '2025-02-01');
insert into order_items values (100, 100, 'Product_A', 5, 20.00);
update inventory set stock = stock - 5 where product_name = 'Product_A';

--echo # 验证Fork库业务数据变化
select * from orders where order_id = 100;
select * from order_items where order_id = 100;
select * from inventory where product_name = 'Product_A';

--echo # 验证源库数据未受影响
use db_snap_src;
select count(*) from orders where order_id = 100;
select * from inventory where product_name = 'Product_A';

--echo ============================================
--echo 6. 清理
--echo ============================================

drop database if exists db_snap_src;
drop database if exists db_snap_fork;
