##owner: fankun.fan
##owner group: 底层引擎部-轻量版
##description: Fork Database约束测试
##tags: fork_database constraint
##author: fankun.fan

--disable_warnings
drop database if exists db_cons_src;
drop database if exists db_cons_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. Fork含各种约束的数据库
--echo ============================================

create database db_cons_src;
use db_cons_src;

--echo # 创建带NOT NULL约束的表
create table t_notnull (
    id int primary key,
    name varchar(50) not null,
    email varchar(100) not null
);

--echo # 创建带UNIQUE约束的表
create table t_unique (
    id int primary key,
    email varchar(100) unique,
    phone varchar(20),
    unique key uk_phone(phone)
);

--echo # 创建带CHECK约束的表
create table t_check (
    id int primary key,
    age int check(age >= 0 and age <= 150),
    score int check(score >= 0 and score <= 100)
);

--echo # 创建带DEFAULT约束的表
create table t_default (
    id int primary key,
    name varchar(50),
    status int default 0,
    created_at timestamp default current_timestamp
);

--echo # 插入数据
insert into t_notnull values (1, 'Alice', 'alice@test.com');
insert into t_unique values (1, 'a@test.com', '111');
insert into t_check values (1, 25, 85);
insert into t_default(id, name) values (1, 'Test');

--echo # Fork数据库
fork database db_cons_src to db_cons_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 2. 验证约束在Fork库中生效
--echo ============================================

use db_cons_fork;

--echo # 验证数据已复制
select * from t_notnull;
select * from t_unique;
select * from t_check;
select id, name, status from t_default;

--echo # 验证NOT NULL约束（name字段没有默认值）
--error 1364
insert into t_notnull(id, email) values (2, 'test@test.com');

--echo # 验证UNIQUE约束
--error 1062
insert into t_unique values (2, 'a@test.com', '222');

--echo # 验证CHECK约束
--error 3819
insert into t_check values (2, -1, 50);

--error 3819
insert into t_check values (3, 25, 150);

--echo # 验证DEFAULT值
insert into t_default(id, name) values (2, 'Default_Test');
select id, name, status from t_default where id = 2;

--echo ============================================
--echo 3. 验证约束独立性
--echo ============================================

--echo # 在Fork库中插入合法数据
insert into db_cons_fork.t_unique values (10, 'fork@test.com', '999');

--echo # 在源库中插入相同email（应该成功，因为是不同的库）
insert into db_cons_src.t_unique values (10, 'fork@test.com', '888');

--echo # 验证两库数据
select * from db_cons_fork.t_unique order by id;
select * from db_cons_src.t_unique order by id;

--echo ============================================
--echo 4. 清理
--echo ============================================

drop database if exists db_cons_src;
drop database if exists db_cons_fork;
