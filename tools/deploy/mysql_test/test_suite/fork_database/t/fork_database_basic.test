##owner: fankun.fan
##owner group: 底层引擎部-轻量版
##description: Fork Database基础功能测试
##tags: fork_database basic
##author: fankun.fan

--disable_warnings
drop database if exists db_src;
drop database if exists db_fork;
drop database if exists db_empty;
drop database if exists db_empty_fork;
drop database if exists db_multi;
drop database if exists db_multi_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. 基本Fork Database功能测试
--echo ============================================

--echo # 创建源数据库和表
create database db_src;
use db_src;

--echo # 创建多个表并插入数据
create table t1 (
    id int primary key,
    name varchar(50),
    age int
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200),
    partition p2 values less than (300)
);

create table t2 (
    id int primary key,
    value int,
    status varchar(20)
);

create table t3 (
    id int primary key,
    data text
) partition by hash(id) partitions 2;

--echo # 向各表插入数据
insert into t1 values (1, 'Alice', 25);
insert into t1 values (101, 'Bob', 30);
insert into t1 values (201, 'Charlie', 35);

insert into t2 values (1, 100, 'active');
insert into t2 values (2, 200, 'inactive');
insert into t2 values (3, 300, 'pending');

insert into t3 values (1, 'Data1');
insert into t3 values (2, 'Data2');
insert into t3 values (3, 'Data3');

--echo # 执行Fork Database
fork database db_src to db_fork;

--echo # 等待Fork Database完成
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo # 验证目标数据库已创建
show databases like 'db_fork';

--echo # 切换到目标数据库，验证表结构
use db_fork;
show tables;

--echo # 验证各表结构
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t2;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3;

--echo # 验证各表数据
select count(*) as t1_cnt from t1;
select * from t1 order by id;

select count(*) as t2_cnt from t2;
select * from t2 order by id;

select count(*) as t3_cnt from t3;
select * from t3 order by id;

--echo # 验证源数据库数据未受影响
use db_src;
select count(*) as t1_cnt from t1;
select count(*) as t2_cnt from t2;
select count(*) as t3_cnt from t3;

--echo ============================================
--echo 2. 数据隔离测试 - INSERT/UPDATE/DELETE
--echo ============================================

--echo # 在Fork库中插入新数据
use db_fork;
insert into t1 values (50, 'Fork_New', 40);

--echo # 验证Fork库有新数据
select count(*) as t1_cnt from t1;
select * from t1 where id = 50;

--echo # 验证源库数据未受影响
use db_src;
select count(*) as t1_cnt from t1;
select * from t1 where id = 50;

--echo # 修改Fork库中的数据
use db_fork;
update t1 set name = 'Fork_Updated', age = 100 where id = 1;

--echo # 验证Fork库数据已修改
select * from t1 where id = 1;

--echo # 验证源库数据未受影响
use db_src;
select * from t1 where id = 1;

--echo # 从Fork库中删除数据
use db_fork;
delete from t1 where id = 201;

--echo # 验证Fork库数据已删除
select * from t1 where id = 201;

--echo # 验证源库数据未受影响
use db_src;
select * from t1 where id = 201;

--echo ============================================
--echo 3. 空数据库Fork测试
--echo ============================================

create database db_empty;
use db_empty;

--echo # Fork空数据库
fork database db_empty to db_empty_fork;

--echo # 验证Fork空数据库成功
show databases like 'db_empty_fork';

--echo # 验证Fork数据库为空
use db_empty_fork;
show tables;

--echo ============================================
--echo 4. Fork数据库含自增列表测试
--echo ============================================

create database db_multi;
use db_multi;

create table t_auto (
    id int auto_increment primary key,
    name varchar(50),
    value int
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);

insert into t_auto(name, value) values ('Auto1', 100);
insert into t_auto(name, value) values ('Auto2', 200);

--echo # Fork数据库
fork database db_multi to db_multi_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo # 验证自增列独立工作
use db_multi_fork;
insert into t_auto(name, value) values ('Fork_Auto', 999);
select * from t_auto order by id;

use db_multi;
insert into t_auto(name, value) values ('Source_Auto', 888);
select * from t_auto order by id;

--echo ============================================
--echo 5. 清理
--echo ============================================

drop database if exists db_src;
drop database if exists db_fork;
drop database if exists db_empty;
drop database if exists db_empty_fork;
drop database if exists db_multi;
drop database if exists db_multi_fork;
