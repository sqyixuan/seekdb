##owner: [CONTRIBUTOR]
##owner group: [INTERNAL_PROJECT]
##description: Fork Database后DDL独立性测试
##tags: fork_database ddl independence
##author: [CONTRIBUTOR]

--disable_warnings
drop database if exists db_ddl_src;
drop database if exists db_ddl_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. Fork数据库
--echo ============================================

create database db_ddl_src;
use db_ddl_src;

create table t1 (
    id int primary key,
    name varchar(50),
    value int
);

create table t2 (
    id int primary key,
    data varchar(100)
);

insert into t1 values (1, 'Test1', 100), (2, 'Test2', 200);
insert into t2 values (1, 'Data1'), (2, 'Data2');

--echo # Fork数据库
fork database db_ddl_src to db_ddl_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 2. 在源库中执行DDL - ADD COLUMN
--echo ============================================

use db_ddl_src;
alter table t1 add column phone varchar(20);
desc t1;

--echo # 验证Fork库表结构未受影响
use db_ddl_fork;
desc t1;

--echo ============================================
--echo 3. 在Fork库中执行DDL - ADD COLUMN（不同列）
--echo ============================================

use db_ddl_fork;
alter table t1 add column address varchar(200);
desc t1;

--echo # 验证源库表结构未受影响
use db_ddl_src;
desc t1;

--echo ============================================
--echo 4. 在源库中执行DDL - CREATE INDEX
--echo ============================================

use db_ddl_src;
create index idx_value on t1(value);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--echo # 验证Fork库无此索引
use db_ddl_fork;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--echo ============================================
--echo 5. 在Fork库中执行DDL - CREATE INDEX（不同索引）
--echo ============================================

use db_ddl_fork;
create index idx_name on t1(name);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--echo # 验证源库无此索引
use db_ddl_src;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--echo ============================================
--echo 6. 在源库中执行DDL - CREATE TABLE
--echo ============================================

use db_ddl_src;
create table t3 (id int primary key, info varchar(100));
insert into t3 values (1, 'OnlyInSrc');
show tables;

--echo # 验证Fork库无此表
use db_ddl_fork;
show tables;

--echo ============================================
--echo 7. 在Fork库中执行DDL - CREATE TABLE
--echo ============================================

use db_ddl_fork;
create table t4 (id int primary key, info varchar(100));
insert into t4 values (1, 'OnlyInFork');
show tables;

--echo # 验证源库无此表
use db_ddl_src;
show tables;

--echo ============================================
--echo 8. 在源库中执行DDL - DROP TABLE
--echo ============================================

use db_ddl_src;
drop table t2;
show tables;

--echo # 验证Fork库仍有此表
use db_ddl_fork;
show tables;
select * from t2;

--echo ============================================
--echo 9. 删除Fork库不影响源库
--echo ============================================

drop database db_ddl_fork;

--echo # 验证源库仍可用
use db_ddl_src;
select * from t1;
show tables;

--echo ============================================
--echo 10. 清理
--echo ============================================

drop database if exists db_ddl_src;
drop database if exists db_ddl_fork;
