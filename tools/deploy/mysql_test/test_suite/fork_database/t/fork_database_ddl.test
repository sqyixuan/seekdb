##owner: [CONTRIBUTOR]
##owner group: 底层引擎部-轻量版
##description: Fork Database 过程中 DDL 行为测试（debug sync 卡在数据构建阶段时 drop 原表/原库应被阻塞并超时）
##tags: fork_database ddl debug_sync timeout
##author: [CONTRIBUTOR]

--disable_warnings
drop database if exists db_dsync_src;
drop database if exists db_dsync_fork;
drop database if exists db_dsync_src2;
drop database if exists db_dsync_fork2;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo # 启用 debug sync，DDL 超时设短以便验证阻塞后超时
connection obsys;
alter system set debug_sync_timeout = '60s';
alter system set _ob_ddl_timeout = '3s';
sleep 2;
set ob_global_debug_sync = 'reset';
connection default;

--echo ============================================
--echo 1. Fork Database 进行中 DROP 源表：应被阻塞，_ob_ddl_timeout 后超时
--echo ============================================

create database db_dsync_src;
use db_dsync_src;
create table t1 (
    id int primary key,
    name varchar(50)
) partition by range(id) (
    partition p0 values less than (100),
    partition p1 values less than (200)
);
insert into t1 values (1, 'A');
insert into t1 values (101, 'B');

--echo # 设置 debug sync：fork 卡在 BUILD_DATA 阶段
connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for fork_db_drop_table_signal execute 10000';
sleep 1;
connection default;

--echo # 执行 Fork Database（后台表 fork 任务会在 BUILD_DATA 处卡住）
fork database db_dsync_src to db_dsync_fork;

--echo # 等待至少一个 fork table 任务进入 BUILD_DATA
sleep 3;

--echo # Fork 进行中对源表 DROP TABLE：预期被阻塞后超时
--error 4012
drop table t1;

--echo # 放开 debug sync，让 Fork Database 完成
connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal fork_db_drop_table_signal';
connection default;

--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo # 验证：源库表可正常使用（之前 drop 已超时未生效）
use db_dsync_src;
select count(*) as cnt from t1;

--echo ============================================
--echo 2. Fork Database 进行中 DROP 源库：应被阻塞，_ob_ddl_timeout 后超时
--echo ============================================

create database db_dsync_src2;
use db_dsync_src2;
create table t1 (
    id int primary key,
    name varchar(50)
);
insert into t1 values (1, 'X');

--echo # 设置 debug sync：fork 卡在 BUILD_DATA 阶段
connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for fork_db_drop_db_signal execute 10000';
sleep 1;
connection default;

fork database db_dsync_src2 to db_dsync_fork2;

--echo # 等待至少一个 fork table 任务进入 BUILD_DATA
sleep 3;

use oceanbase;
--echo # Fork 进行中对源库 DROP DATABASE：预期被阻塞后超时
--error 4012
drop database db_dsync_src2;

--echo # 放开 debug sync，让 Fork Database 完成
connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal fork_db_drop_db_signal';
connection default;

--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo # 验证：源库仍存在（之前 drop database 已超时未生效）
show databases like 'db_dsync_src2';

--echo ============================================
--echo 3. 清理
--echo ============================================

connection obsys;
alter system set _ob_ddl_timeout = '1000s';
set ob_global_debug_sync = 'reset';
connection default;

use oceanbase;
drop database if exists db_dsync_src;
drop database if exists db_dsync_fork;
drop database if exists db_dsync_src2;
drop database if exists db_dsync_fork2;
