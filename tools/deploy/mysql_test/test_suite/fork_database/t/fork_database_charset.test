##owner: fanxingkun.fxk
##owner group: 底层引擎部-轻量版
##description: Fork Database数据库属性继承测试
##tags: fork_database charset collation
##author: fanxingkun.fxk

--disable_warnings
drop database if exists db_cs_src;
drop database if exists db_cs_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo ============================================
--echo 1. Fork指定字符集的数据库
--echo ============================================

--echo # 创建指定字符集的数据库
create database db_cs_src default charset utf8mb4 collate utf8mb4_unicode_ci;

--echo # 验证源库字符集
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create database db_cs_src;

use db_cs_src;

--echo # 创建表
create table t_charset (
    id int primary key,
    name varchar(50),
    data text
);

--echo # 插入多语言数据
insert into t_charset values (1, '中文测试', '这是一段中文内容');
insert into t_charset values (2, '日本語テスト', 'これは日本語の内容です');
insert into t_charset values (3, 'English Test', 'This is English content');
insert into t_charset values (4, '한국어 테스트', '이것은 한국어 내용입니다');

--echo # Fork数据库
fork database db_cs_src to db_cs_fork;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 2. 验证Fork库字符集继承
--echo ============================================

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create database db_cs_fork;

--echo ============================================
--echo 3. 验证多语言数据正确
--echo ============================================

use db_cs_fork;
select * from t_charset order by id;

--echo # 验证特定语言查询
select * from t_charset where name like '%中文%';
select * from t_charset where name like '%日本語%';
select * from t_charset where name like '%한국어%';

--echo ============================================
--echo 4. 验证Fork库中可正常插入多语言数据
--echo ============================================

insert into db_cs_fork.t_charset values (5, 'Ελληνικά', 'Greek content');
insert into db_cs_fork.t_charset values (6, 'العربية', 'Arabic content');

select * from db_cs_fork.t_charset where id >= 5;

--echo # 验证源库无此数据
select count(*) from db_cs_src.t_charset where id >= 5;

--echo ============================================
--echo 5. 数据库名含特殊字符（café / cafe_plain）
--echo ============================================

--disable_warnings
drop database if exists `café`;
drop database if exists `cafe_plain`;
drop database if exists db_special_fork1;
drop database if exists db_special_fork2;
--enable_warnings

--echo # 创建名称为 café（含重音）的数据库并 Fork
create database `café` default charset utf8mb4 collate utf8mb4_unicode_ci;
use `café`;
create table t1 (id int primary key, name varchar(50));
insert into t1 values (1, 'café');

fork database `café` to db_special_fork1;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

use db_special_fork1;
select * from t1;

--echo # 创建名称为 cafe_plain（纯英文，与 café 区分）的数据库并 Fork
create database `cafe_plain` default charset utf8mb4 collate utf8mb4_unicode_ci;
use `cafe_plain`;
create table t1 (id int primary key, name varchar(50));
insert into t1 values (1, 'cafe');

fork database `cafe_plain` to db_special_fork2;
--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

use db_special_fork2;
select * from t1;

--echo # 验证 café 与 cafe_plain 为两个不同库，互不影响
select count(*) from `café`.t1;
select count(*) from `cafe_plain`.t1;

--echo ============================================
--echo 6. 清理
--echo ============================================

drop database if exists db_cs_src;
drop database if exists db_cs_fork;
drop database if exists `café`;
drop database if exists `cafe_plain`;
drop database if exists db_special_fork1;
drop database if exists db_special_fork2;
