##owner: fankun.fan
##owner group: 底层引擎部-轻量版
##description: Fork Database Debug Sync 测试 - 数据构建完成前的行为
##tags: fork_database debug_sync
##author: fankun.fan

--disable_warnings
drop database if exists db_sync_src;
drop database if exists db_sync_fork;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection default;

SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;

--echo # 启用 debug sync
connection obsys;
alter system set debug_sync_timeout = '60s';
sleep 3;
set ob_global_debug_sync = 'reset';
connection default;

--echo ============================================
--echo 1. 创建源库（单表，便于卡在 BUILD_DATA 的单一任务）
--echo ============================================

create database db_sync_src;
use db_sync_src;
create table t1 (id int primary key, name varchar(50));
insert into t1 values (1, 'a'), (2, 'b'), (3, 'c');

--echo ============================================
--echo 2. 设置 debug sync：Fork 卡在 BUILD_DATA（数据构建前）
--echo ============================================

connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA wait_for signal_fork_db execute 10000';
sleep 1;
connection default;

--echo # 执行 fork database（提交后立即返回，后台任务会卡在 BUILD_DATA）
fork database db_sync_src to db_sync_fork;

--echo # 等待任务进入 BUILD_DATA 阶段（数据尚未构建）
let $wait_timeout= 30;
let $wait_status= BUILD_DATA;
--source mysql_test/test_suite/fork_table/include/wait_fork_table.inc

--echo ============================================
--echo 3. 数据构建完成前的行为校验：目标库已建、表已建、数据未就绪
--echo ============================================

--echo # 目标库应已存在
show databases like 'db_sync_fork';

--echo # 进入目标库，表应已存在
use db_sync_fork;
show tables;

--echo # 数据构建完成前（卡在 BUILD_DATA 时）的可见性校验
select count(*) as cnt_before_build from t1;

--echo ============================================
--echo 4. 释放卡点并等待 Fork Database 完成
--echo ============================================

connection obsys;
set ob_global_debug_sync = 'FORK_TABLE_BUILD_DATA clear';
set ob_global_debug_sync = 'now signal signal_fork_db';
connection default;

--source mysql_test/test_suite/fork_database/include/wait_fork_database.inc

--echo ============================================
--echo 5. 数据构建完成后的校验
--echo ============================================

use db_sync_fork;
select count(*) as cnt_after_build from t1;
select * from t1 order by id;

--echo ============================================
--echo 6. 清理
--echo ============================================

connection obsys;
set ob_global_debug_sync = 'reset';
connection default;

use oceanbase;
drop database if exists db_sync_src;
drop database if exists db_sync_fork;
