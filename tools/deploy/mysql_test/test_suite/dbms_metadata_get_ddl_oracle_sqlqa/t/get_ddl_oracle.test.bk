purge recyclebin;
let $char_charset = 'utf8';
--source mysql_test/test_suite/dbms_metadata_get_ddl_oracle_sqlqa/t/include/charset/create_tenant_by_charset.inc
--source mysql_test/test_suite/dbms_metadata_get_ddl_oracle_sqlqa/t/include/charset/conn_tenant.inc
