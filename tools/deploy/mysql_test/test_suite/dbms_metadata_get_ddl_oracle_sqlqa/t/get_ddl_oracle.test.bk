ALTER SESSION SET NLS_DATE_FORMAT='YYYY-MM-DD HH24:MI:SS';
ALTER SESSION SET NLS_TIMESTAMP_FORMAT='YYYY-MM-DD HH24:MI:SS.FF';
ALTER SESSION SET NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
#解决超时问题：
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
#设置数字长度：
#set numwidth 64;
#set line 200;
#set pagesize 0;
#set long 99999;
#set feedback off;
#set echo off;
#ALTER SESSION SET CURRENT_SCHEMA = LAIRP123;
--echo dbms_metadata.get.ddl-1 和dbms_metadata.get.ddl-2
--error 0,942
drop table t1;
create table t1(a int constraint sid1_pk primary key ,b varchar(20) constraint nn_b not null,c int ,d date DEFAULT '2021-10-10',constraint c_ch check(c=1 or c=1));
alter table t1 add constraint b_uq unique(b);
--error 0,942
drop table t2;
create table t2(id int, fk_a int,CONSTRAINT fk_PerOrders FOREIGN KEY (fk_a) REFERENCES t1(a));
--error 0,1418
drop INDEX index_t1;
CREATE INDEX index_t1 ON t2 (id);
--error 0,942
drop view v_t1;
create view v_t1 as select * from t1;
--error 0,942
drop view v_t2;
create view v_t2 as select * from t1;
--error 0,2289
drop sequence s1;
create sequence s1;
--error 0,2289
drop sequence s2;
create sequence s2;
--error 0,600
drop PROCEDURE MY_PROC;
--error 0,600
drop FUNCTION MY_FUNC;
--error 0,600
drop PACKAGE MY_PACK;
--error 0,600
drop PACKAGE test_package;
--error 0,4080
drop trigger tr;

--error 0,600
drop PROCEDURE MY_PROC1;
--error 0,600
drop FUNCTION MY_FUNC1;
--error 0,600
drop PACKAGE MY_PACK1;
--error 0,4080
drop trigger tr1;
DELIMITER //;
CREATE OR REPLACE PROCEDURE MY_PROC IS BEGIN NULL; END;
//
CREATE OR REPLACE FUNCTION MY_FUNC RETURN INT IS BEGIN RETURN NULL; END;
//
CREATE OR REPLACE PACKAGE MY_PACK IS PROCEDURE MY_PACK_PROC; END MY_PACK;
//
CREATE OR REPLACE PACKAGE BODY MY_PACK IS
  PROCEDURE MY_PACK_PROC IS BEGIN null; END;  
END MY_PACK;  
//

CREATE OR REPLACE PROCEDURE MY_PROC1 IS BEGIN NULL; END;
//
CREATE OR REPLACE FUNCTION MY_FUNC1 RETURN INT IS BEGIN RETURN NULL; END;
//
CREATE OR REPLACE PACKAGE MY_PACK1 IS PROCEDURE MY_PACK_PROC1; END MY_PACK1;
//
CREATE OR REPLACE PACKAGE BODY MY_PACK1 IS
  PROCEDURE MY_PACK_PROC1 IS BEGIN null; END;  
END MY_PACK1;  
//

create or replace trigger tr
before
delete or update
on t1
for each row
begin
insert into t1 values(1,'xiaolai',1,'2011-08-08');
end;
//

create or replace trigger tr1
before
delete or update
on t1
for each row
begin
insert into t1 values(2,'xiaolai01',2,'2011-08-09');
end;
//


create or replace package body test_package
is
function t_add(a number,b number)return number 
is
begin
return (a+b);
end;

function t_adds(a number,b number,c number)return number 
is
begin
return (a+b+c);
end;

procedure shuchu(a varchar2)
is
begin
dbms_output.put_line(name||','||a);
end;   
end test_package;
//

--error 0,600
drop type ty1;
//
create or replace type ty1 force as object(id int,a char,b nchar(20),c nvarchar2(20),d varchar2(20),e varchar(30), f number, g float,h BINARY_DOUBLE,k blob,j clob, l date,z timestamp, p timestamp with time zone);
//

CREATE TYPE typ2 AS OBJECT (
     a1 NUMBER, 
     MEMBER FUNCTION get_square RETURN NUMBER
   );
   //
   
CREATE OR REPLACE TYPE BODY typ2 IS
     MEMBER FUNCTION get_square RETURN NUMBER IS
     BEGIN

        RETURN a1;
    END; 
  END;
//
CREATE TYPE typ3 AS OBJECT (
     a1 NUMBER, 
     MEMBER FUNCTION get_square1 RETURN NUMBER
   );
   //

DELIMITER ;//

