#owner: dachuan.sdc
#owner group: sql2
#description: EXPORT_SET_DML
#tags: EXPORT_SET在dml场景的应用
#author: wb-zc01084078


--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;


drop TABLE if EXISTS A;
CREATE TABLE A(A_0 INT,A_1 INT,A_2 VARCHAR(20),A_3 FLOAT,A_4 DATE);
INSERT INTO A VALUES(1,1,'A',1.23,'1999-09-09'),(2,-1,'nb',3.21,'1111-11-11'),(3,0,'#',6666.6666,'11-11-11'),(4,NULL,NULL,NULL,NULL);

##数值类型dml##

INSERT INTO A(A_0,A_1) VALUES (5,EXPORT_SET(1,1,1,1,5));
SELECT A_1 FROM A ;
UPDATE A SET A_1=EXPORT_SET(4,6,5,2,5) WHERE A_0=5;
SELECT A_1 FROM A ;
DELETE FROM A WHERE A_1=EXPORT_SET(4,6,5,2,5);
SELECT A_1 FROM A;

INSERT INTO A(A_0,A_1) VALUES (5,(SELECT EXPORT_SET(1,1,1,1,5) FROM DUAL));
SELECT A_1 FROM A ;
UPDATE A SET A_1=(SELECT EXPORT_SET(4,6,5,2,5) FROM DUAL) WHERE A_0=(SELECT EXPORT_SET(1,5,5,5,1) FROM DUAL);
SELECT A_1 FROM A ;
DELETE FROM A WHERE A_1=(SELECT EXPORT_SET(4,6,5,2,5) FROM DUAL);
SELECT A_1 FROM A ;

##字符类型dml##
INSERT INTO A(A_0,A_2) VALUES (5,EXPORT_SET(6,'a','b',1,5));
SELECT A_2 FROM A ;
UPDATE A SET A_2=EXPORT_SET(7,'abc','xyz',' ',5) WHERE A_0=5;
SELECT A_2 FROM A ;
DELETE FROM A WHERE A_2=EXPORT_SET(7,'abc','xyz',' ',5);
SELECT A_2 FROM A;

INSERT INTO A(A_0,A_2) VALUES (5,(SELECT EXPORT_SET(6,'a','b',1,5) FROM DUAL));
SELECT A_2 FROM A ;
UPDATE A SET A_2=(SELECT EXPORT_SET(7,'abc','xyz',' ',5) FROM DUAL) WHERE A_0=(SELECT EXPORT_SET(1,5,5,5,1) FROM DUAL);
SELECT A_2 FROM A ;
DELETE FROM A WHERE A_2=(SELECT EXPORT_SET(7,'abc','xyz',' ',5) FROM DUAL);
SELECT A_2 FROM A ;

##日期类型dml##
INSERT INTO A(A_0,A_4) VALUES (5,EXPORT_SET(6,1,12,'-',3));
SELECT A_4 FROM A ;
UPDATE A SET A_4=EXPORT_SET(2.2,12,12,'-',3) WHERE A_0=5;
SELECT A_4 FROM A ;
DELETE FROM A WHERE A_4=EXPORT_SET(2.2,12,12,'-',3);
SELECT A_4 FROM A;

INSERT INTO A(A_0,A_4) VALUES (5,(SELECT EXPORT_SET(6,1,12,'-',3) FROM DUAL));
SELECT A_4 FROM A ;
UPDATE A SET A_4=(SELECT EXPORT_SET(2.2,12,12,'-',3) FROM DUAL) WHERE A_0=(SELECT EXPORT_SET(1,5,5,5,1) FROM DUAL);
SELECT A_4 FROM A ;
DELETE FROM A WHERE A_4=(SELECT EXPORT_SET(2.2,12,12,'-',3) FROM DUAL);
SELECT A_4 FROM A ;

drop TABLE if EXISTS A;

connection default;
--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
