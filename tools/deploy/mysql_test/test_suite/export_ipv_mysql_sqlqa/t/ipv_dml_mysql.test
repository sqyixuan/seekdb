--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

drop TABLE if EXISTS A;
CREATE TABLE A(A_0 INT,A_1 BIGINT,A_2 VARCHAR(39),A_3 VARBINARY(32));
INSERT INTO A VALUES(1,0,'222.222.222.222','0A000509'),(2,1,'::','0000'),(3,4294967040,'::192.168.111.222','FFFF'),(4,-1,'::FFFF:196.126.99.88','-FF'),
(5,167773449,'FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF','FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'),(6,NULL,NULL,NULL);
SELECT * FROM A ;

##INET_ATON##
INSERT INTO A(A_0,A_1) VALUES (7,INET_ATON('255.255.255.255')); 
SELECT A_1 FROM A WHERE A_0=7;
UPDATE A SET A_1=INET_ATON('000.000.000.250') WHERE A_0=7;
SELECT A_1 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_1=INET_ATON('000.000.000.250');
SELECT * FROM A;

INSERT INTO A(A_0,A_1) VALUES (7,(SELECT INET_ATON('255.255.255.255') FROM DUAL));
SELECT A_1 FROM A WHERE A_0=7;
UPDATE A SET A_1=(SELECT INET_ATON('000.000.000.250') FROM DUAL) WHERE A_0=7;
SELECT A_1 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_1=(SELECT INET_ATON('000.000.000.250') FROM DUAL);
SELECT * FROM A ;

##INET6_ATON##
INSERT INTO A(A_0,A_3) VALUES (7,HEX(INET6_ATON('fdfe::5a55:caff:fefa:9089'))); 
SELECT A_3 FROM A WHERE A_0=7;
UPDATE A SET A_3=HEX(INET6_ATON('::1111')) WHERE A_0=7;
SELECT A_3 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_3=HEX(INET6_ATON('::1111'));
SELECT * FROM A;

INSERT INTO A(A_0,A_3) VALUES (7,(SELECT HEX(INET6_ATON('fdfe::5a55:caff:fefa:9089')) FROM DUAL));
SELECT A_3 FROM A WHERE A_0=7;
UPDATE A SET A_3=(SELECT HEX(INET6_ATON('::1111')) FROM DUAL) WHERE A_0=7;
SELECT A_3 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_3=(SELECT HEX(INET6_ATON('::1111')) FROM DUAL);
SELECT * FROM A ;

##INET_NTOA##
INSERT INTO A(A_0,A_2) VALUES (7,INET_NTOA(4294967040)); 
SELECT A_2 FROM A WHERE A_0=7;
UPDATE A SET A_2=INET_NTOA('4294967040') WHERE A_0=7;
SELECT A_2 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_2=INET_NTOA('4294967040');
SELECT * FROM A;

INSERT INTO A(A_0,A_2) VALUES (7,(SELECT INET_NTOA(4294967040) FROM DUAL));
SELECT A_2 FROM A WHERE A_0=7;
UPDATE A SET A_2=(SELECT INET_NTOA('4294967040') FROM DUAL) WHERE A_0=7;
SELECT A_2 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_2=(SELECT INET_NTOA('4294967040') FROM DUAL);
SELECT * FROM A ;

##INET6_NTOA##
INSERT INTO A(A_0,A_2) VALUES (7,INET6_NTOA(UNHEX('FDFE0000000000005A55CAFFFEFA9089'))); 
SELECT A_2 FROM A WHERE A_0=7;
UPDATE A SET A_2=INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) WHERE A_0=7;
SELECT A_2 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_2=INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'));
SELECT * FROM A;

INSERT INTO A(A_0,A_2) VALUES (7,(SELECT INET6_NTOA(UNHEX('FDFE0000000000005A55CAFFFEFA9089')) FROM DUAL));
SELECT A_2 FROM A WHERE A_0=7;
UPDATE A SET A_2=(SELECT INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) FROM DUAL) WHERE A_0=7;
SELECT A_2 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_2=(SELECT INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) FROM DUAL);
SELECT * FROM A ;

##IS_IPV4##
