UPDATE A SET A_1=(SELECT IS_IPV4('196') FROM DUAL) WHERE A_0=7;
SELECT A_1 FROM A WHERE A_0=7;
DELETE FROM A WHERE A_1=(SELECT IS_IPV4('196') FROM DUAL);
SELECT * FROM A ;

