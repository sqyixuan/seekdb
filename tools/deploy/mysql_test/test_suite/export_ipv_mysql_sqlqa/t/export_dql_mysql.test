SELECT EXPORT_SET(14,A_0,A_0,A_4,5) FROM A WHERE EXPORT_SET(76,A_0,A_0,',',1)=EXPORT_SET(189,1,2,',',1) ORDER BY EXPORT_SET(-1,NULL,'n',6,1.23);
SELECT EXPORT_SET(71,A_4,A_4,A_4,5) FROM A WHERE EXPORT_SET(37,A_4,A_4,',',1)=EXPORT_SET(190,'1999-09-09','1111-11-11',',',1) ORDER BY EXPORT_SET(255,A_0,A_1,A_0,5);
