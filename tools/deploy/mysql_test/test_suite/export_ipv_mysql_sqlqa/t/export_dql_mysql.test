##HAVING##
SELECT A_0 FROM A GROUP BY A_0 HAVING A_0 = EXPORT_SET(1,A_0,A_0,A_0,1);
SELECT A_1 FROM A GROUP BY A_1 HAVING A_1 = EXPORT_SET(1,1,0,'',1);
SELECT A_3 FROM A GROUP BY A_3 HAVING A_3 = EXPORT_SET(1,1.23,3.21,'',1);

