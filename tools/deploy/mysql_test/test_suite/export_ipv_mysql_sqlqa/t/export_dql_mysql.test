##where##
SELECT * FROM A WHERE A_0 = EXPORT_SET(1,A_0,A_0,A_0,1) ;
SELECT * FROM A WHERE A_0 = EXPORT_SET(1,1,1,1,1) ;
SELECT * FROM A WHERE EXPORT_SET(1,A_0,A_0,',',1) =  EXPORT_SET(1,2,3,4,1);
SELECT EXPORT_SET(221,A_1,A_1,A_2,5) FROM A WHERE EXPORT_SET(38,A_1,A_1,'ab',1)=EXPORT_SET(241,NULL,1,'@',1);
SELECT EXPORT_SET(107,A_4,A_1,A_3,5) FROM A WHERE EXPORT_SET(223,A_1,A_1,'ab',1)=EXPORT_SET(92,-1,-1,6,1);
SELECT EXPORT_SET(223,A_1,A_1,A_1,5) FROM A WHERE EXPORT_SET(111,A_4,A_4,' ',1)=EXPORT_SET(225,'1999-09-09','1999-09-09','+',1);
SELECT EXPORT_SET(97,A_4,A_0,A_3,5) FROM A WHERE EXPORT_SET(238,A_1,A_1,',',1)=EXPORT_SET(146,0,1,',',1);
SELECT EXPORT_SET(144,A_1,A_1,A_2,5) FROM A WHERE EXPORT_SET(106,A_4,A_4,'ab',1)=EXPORT_SET(238,'1111-11-11','1999-09-09',' ',1);
SELECT EXPORT_SET(243,A_1,A_2,A_4,5) FROM A WHERE EXPORT_SET(21,A_4,A_4,' ',1)=EXPORT_SET(71,NULL,NULL,',',1);
SELECT EXPORT_SET(139,A_3,A_2,A_2,5) FROM A WHERE EXPORT_SET(104,A_4,A_4,'@',1)=EXPORT_SET(22,'1999-09-09','1999-09-09','ab',1);
SELECT EXPORT_SET(222,A_0,A_1,A_0,5) FROM A WHERE EXPORT_SET(164,A_4,A_4,6,1)=EXPORT_SET(176,'1111-11-11','1999-09-09',6,1);

##GROUP BY##
SELECT EXPORT_SET(1,A_0,A_0,1,1) FROM A GROUP BY EXPORT_SET(1,A_0,A_0,1,1);
SELECT EXPORT_SET(1,A_3,A_0,1,1) FROM A GROUP BY EXPORT_SET(1,A_3,A_0,1,1);

