##case when##
SELECT CASE A_0 WHEN EXPORT_SET(1,1,1,1,1) THEN EXPORT_SET(1,0,1,1,1) ELSE EXPORT_SET(1,2,1,1,1)  END VAL FROM A;
SELECT CASE A_0 WHEN EXPORT_SET(1,2,3,1,1) THEN EXPORT_SET(1,3,1,1,1) ELSE EXPORT_SET(1,3,2,1,1)  END VAL FROM A;
SELECT CASE A_2 WHEN EXPORT_SET(1,'A',' ',1,1) THEN EXPORT_SET(1,'NB',1,1,1) ELSE EXPORT_SET(1,'666',2,1,1)  END VAL FROM A;

