#owner: dachuan.sdc
#owner group: sql2
#description: export_ddl_mysql
#tags: 表达式ddl应用场景
#author: wb-zc01084078

--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

##create##
##table##
drop TABLE if EXISTS A;
CREATE TABLE A(A_1 INT, A_2 varchar(20) GENERATED ALWAYS AS (EXPORT_SET(5,'y','N',',',2)));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(A_1 INT, A_2 varchar(20) GENERATED ALWAYS AS (EXPORT_SET(-0,'y','y',NULL)));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;

drop TABLE if EXISTS A;
CREATE TABLE A(A_1 INT, A_2 char(20) GENERATED ALWAYS AS (EXPORT_SET(64,1,-1,' ',1)));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;

drop TABLE if EXISTS A;
CREATE TABLE A(A_1 INT, A_2 char(255) GENERATED ALWAYS AS (EXPORT_SET(1000,' ','yes')));
INSERT INTO A(A_1) VALUES (1);
INSERT INTO A(A_1) VALUES (2);
SELECT * FROM A;



##view##				
drop TABLE if EXISTS A;
CREATE TABLE A(A_1 INT,A_2 VARCHAR(20),A_3 FLOAT);
INSERT INTO A VALUES(1,'A',1.23),(-1,'nb',3.21),(0,'#',6666.6666),(NULL,NULL,NULL);
SELECT * FROM A;

CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(64,1,-1,' ',1) val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(-9223372036854775808,' ','y',NULL,1.23) VAL FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(1.23,NULL,'n',6,-9223372036854775808) VAL FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(64,1,-1,' ',1) val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_1,A_2,A_3,NULL,10) val FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_1,A_1,A_3,A_3,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_3,A_1,A_1,A_1,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_3,A_3,A_2,A_1,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_1,A_3,A_3,A_3,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_3,A_2,A_1,'',10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_1,A_1,A_2,A_3,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_1,A_1,A_3,A_2,10) VAL FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT EXPORT_SET(A_3,A_2,A_2,A_1,10) VAL FROM A;
SELECT * FROM A_VIEW;

DROP VIEW A_VIEW;

##ALTER##
ALTER TABLE A ADD A_4 varchar(20) GENERATED ALWAYS AS(EXPORT_SET(64,1,-1,' ',5));
SELECT A_4 FROM A;
ALTER TABLE A DROP A_4;

ALTER TABLE A ADD A_5 varchar(20) GENERATED ALWAYS AS(EXPORT_SET(6,'S','S',' ',5));
SELECT A_5 FROM A;
ALTER TABLE A DROP A_5;

ALTER TABLE A ADD A_6 varchar(20) GENERATED ALWAYS AS(EXPORT_SET(-0,'y','y',NULL));
SELECT A_6 FROM A;
ALTER TABLE A DROP A_6;

SELECT * FROM A;
drop TABLE if EXISTS A;

connection default;
--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
