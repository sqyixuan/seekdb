##where##
SELECT * FROM A WHERE a_1=INET_ATON(INET_NTOA(A_1));
SELECT * FROM A WHERE a_2=INET_NTOA(INET_ATON(A_2));
SELECT * FROM A WHERE a_3=HEX(INET6_ATON(INET6_NTOA(UNHEX(A_3))));
SELECT * FROM A WHERE a_2=INET6_NTOA(UNHEX(HEX(INET6_ATON(A_2))));
SELECT * FROM A WHERE a_1=IS_IPV4((SELECT A_2 FROM A WHERE A_0=2));
SELECT * FROM A WHERE a_1=IS_IPV4((SELECT A_2 FROM A WHERE A_0=1));
SELECT * FROM A WHERE a_1=IS_IPV6('::');
SELECT * FROM A WHERE a_1=IS_IPV4_COMPAT(INET6_ATON('::10.10.10.111'));
SELECT * FROM A WHERE a_1=IS_IPV4_MAPPED(INET6_ATON((SELECT A_2 FROM A WHERE A_0=4)));
SELECT * FROM A WHERE INET_NTOA(a_1)=INET_NTOA(A_1);
SELECT * FROM A WHERE INET_ATON(a_2)=INET_ATON(A_2);
SELECT * FROM A WHERE a_2 = INET_ATON('255.255.255.0');
SELECT * FROM A WHERE a_2 = INET_ATON('10.0.5.9');
SELECT * FROM A WHERE a_1 != IS_IPV6('::');
SELECT * FROM A WHERE a_2 <= IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222'));
SELECT * FROM A WHERE a_2 <= IS_IPV4('255.255.255.0');
SELECT * FROM A WHERE a_3 < INET6_ATON(NULL);
SELECT * FROM A WHERE a_2 < IS_IPV4('255.255.255.0');
SELECT * FROM A WHERE a_3 != INET_NTOA(3739147998);
SELECT * FROM A WHERE a_3 > INET_NTOA(NULL);
SELECT * FROM A WHERE a_1 != INET_NTOA(3739147998);
SELECT * FROM A WHERE a_3 <= HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A WHERE a_2 != INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'));
SELECT * FROM A WHERE a_3 >= INET_NTOA(3739147998);
SELECT * FROM A WHERE a_3 >= INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE'));
SELECT * FROM A WHERE a_1 < INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE'));
SELECT * FROM A WHERE a_1 = IS_IPV4_COMPAT(NULL);
SELECT * FROM A WHERE a_2 <= INET_NTOA(NULL);
SELECT * FROM A WHERE a_3 >= INET6_NTOA(UNHEX('00000000000000000000000000000000'));
SELECT * FROM A WHERE a_1 < INET_ATON('0.0.0.0');
SELECT * FROM A WHERE a_1 != INET_NTOA(NULL);

##GROUP BY##
SELECT IS_IPV4_MAPPED(a_1) FROM A GROUP BY INET_ATON(a_3);
SELECT INET_ATON(a_2) FROM A GROUP BY IS_IPV4(a_1);
#SELECT INET6_ATON(a_2) FROM A GROUP BY IS_IPV4_MAPPED(a_2);
SELECT INET6_NTOA(a_1) FROM A GROUP BY INET6_ATON(a_3);
SELECT INET_ATON(a_3) FROM A GROUP BY IS_IPV6(a_3);
SELECT INET6_NTOA(a_3) FROM A GROUP BY IS_IPV4_COMPAT(a_1);
SELECT INET6_NTOA(a_2) FROM A GROUP BY IS_IPV4_COMPAT(a_3);
SELECT IS_IPV4_MAPPED(a_2) FROM A GROUP BY IS_IPV6(a_1);
#SELECT INET6_ATON(a_2) FROM A GROUP BY INET6_ATON(a_3);
SELECT INET_ATON(a_2) FROM A GROUP BY IS_IPV6(a_3);
SELECT INET6_NTOA(a_2) FROM A GROUP BY IS_IPV6(a_1);
SELECT INET6_NTOA(a_2) FROM A GROUP BY IS_IPV4_COMPAT(a_2);
SELECT IS_IPV4(a_1) FROM A GROUP BY INET_ATON(a_1);
SELECT INET6_ATON(a_1) FROM A GROUP BY IS_IPV4_COMPAT(a_3);
SELECT IS_IPV4_MAPPED(a_3) FROM A GROUP BY INET_ATON(a_1);
SELECT INET6_NTOA(a_3) FROM A GROUP BY INET6_NTOA(a_2);
SELECT INET6_NTOA(a_3) FROM A GROUP BY IS_IPV4_COMPAT(a_3);
SELECT IS_IPV4(a_2) FROM A GROUP BY INET6_ATON(a_3);
SELECT INET6_ATON(a_3) FROM A GROUP BY IS_IPV4_MAPPED(a_3);
SELECT INET6_NTOA(a_3) FROM A GROUP BY IS_IPV6(a_3);

##HAVING##
SELECT * FROM A GROUP BY A_1 HAVING A_1 >= HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF'));
SELECT * FROM A GROUP BY A_3 HAVING A_3 < INET6_ATON(NULL);
SELECT * FROM A GROUP BY A_2 HAVING A_2 < INET_ATON('255.255.255.0');
SELECT * FROM A GROUP BY A_1 HAVING A_1 != INET_ATON('0.0.0.0');
SELECT * FROM A GROUP BY A_2 HAVING A_2 <= INET_ATON(NULL);
SELECT * FROM A GROUP BY A_1 HAVING A_1 >= HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF'));
SELECT * FROM A GROUP BY A_3 HAVING A_3 != INET6_ATON(NULL);
SELECT * FROM A GROUP BY A_3 HAVING A_3 < INET_ATON('0.0.0.0');
SELECT * FROM A GROUP BY A_3 HAVING A_3 > INET_ATON('0.0.0.0');
SELECT * FROM A GROUP BY A_3 HAVING A_3 != HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_3 HAVING A_3 < HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_2 HAVING A_2 != INET_ATON('10.0.5.9');
SELECT * FROM A GROUP BY A_2 HAVING A_2 < HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_3 HAVING A_3 = INET_ATON(NULL);
SELECT * FROM A GROUP BY A_2 HAVING A_2 != HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_1 HAVING A_1 < INET_ATON(NULL);
SELECT * FROM A GROUP BY A_1 HAVING A_1 < HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_2 HAVING A_2 != HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF'));
SELECT * FROM A GROUP BY A_3 HAVING A_3 >= INET_ATON(NULL);
SELECT * FROM A GROUP BY A_1 HAVING INET6_NTOA(A_1) = HEX(INET6_ATON('10.0.5.9'));
SELECT * FROM A GROUP BY A_1 HAVING IS_IPV4_COMPAT(A_1) != INET_ATON('10.0.5.9');
SELECT * FROM A GROUP BY A_1 HAVING IS_IPV4_MAPPED(A_1) >= HEX(INET6_ATON('10.0.5.9'));

##orderby##
SELECT * FROM A ORDER BY IS_IPV4_MAPPED(a_1);
SELECT * FROM A ORDER BY IS_IPV4_MAPPED(a_2);
SELECT * FROM A ORDER BY INET_ATON(a_1);
SELECT * FROM A ORDER BY INET_NTOA(a_2);
SELECT * FROM A ORDER BY INET_NTOA(a_3);
