SELECT * FROM A ORDER BY INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE'));
SELECT * FROM A ORDER BY INET6_NTOA(a_3);
SELECT * FROM A ORDER BY HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF'));
SELECT * FROM A ORDER BY IS_IPV4_COMPAT(NULL);
SELECT * FROM A ORDER BY IS_IPV6(a_3);
SELECT * FROM A ORDER BY INET6_NTOA(NULL);
SELECT * FROM A ORDER BY INET6_NTOA(UNHEX('00000000000000000000000000000000'));
SELECT * FROM A ORDER BY IS_IPV6(a_2);
SELECT * FROM A ORDER BY INET_NTOA(a_1);
SELECT * FROM A ORDER BY INET6_NTOA(a_3);

##CASE WHEN##
SELECT CASE a_2 WHEN INET6_NTOA(NULL) THEN INET_ATON('255.255.255.0') ELSE INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) END VAL FROM A;
SELECT CASE a_1 WHEN INET_ATON('10.0.5.9') THEN IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222')) ELSE INET_ATON('255.255.255.0') END VAL FROM A;
SELECT CASE a_1 WHEN IS_IPV6(NULL) THEN INET6_NTOA(NULL) ELSE HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF')) END VAL FROM A;
SELECT CASE a_2 WHEN INET6_NTOA(UNHEX('00000000000000000000000000000000')) THEN INET_ATON('10.0.5.9') ELSE INET_NTOA(NULL) END VAL FROM A;
SELECT CASE a_1 WHEN IS_IPV4_MAPPED(NULL) THEN INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) ELSE INET6_ATON(NULL) END VAL FROM A;
SELECT CASE a_2 WHEN IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222')) THEN IS_IPV4('255.255.255.0') ELSE INET6_NTOA(UNHEX('00000000000000000000000000000000')) END VAL FROM A;
SELECT CASE a_1 WHEN INET_NTOA(3739147998) THEN IS_IPV4('255.255.255.0') ELSE IS_IPV4(NULL) END VAL FROM A;
SELECT CASE a_3 WHEN INET_NTOA(3739147998) THEN IS_IPV4_COMPAT(NULL) ELSE IS_IPV6('::') END VAL FROM A;
SELECT CASE a_3 WHEN INET_NTOA(3739147998) THEN INET6_ATON(NULL) ELSE INET_ATON('0.0.0.0') END VAL FROM A;
SELECT CASE a_3 WHEN INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE')) THEN IS_IPV4_COMPAT(NULL) ELSE INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) END VAL FROM A;
SELECT CASE a_3 WHEN INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE')) THEN INET_NTOA(3739147998) ELSE INET6_NTOA(NULL) END VAL FROM A;
SELECT CASE a_2 WHEN INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE')) THEN HEX(INET6_ATON('10.0.5.9')) ELSE IS_IPV4_MAPPED(INET6_ATON('::FFFF:196.126.99.88')) END VAL FROM A;
SELECT CASE a_2 WHEN INET_ATON(NULL) THEN HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF')) ELSE INET_ATON(NULL) END VAL FROM A;
SELECT CASE a_3 WHEN INET_ATON('255.255.255.0') THEN IS_IPV4('255.255.255.0') ELSE IS_IPV4_MAPPED(NULL) END VAL FROM A;
SELECT CASE a_1 WHEN INET_ATON('0.0.0.0') THEN HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF')) ELSE INET6_NTOA(UNHEX('00000000000000000000000000000000')) END VAL FROM A;
SELECT CASE a_1 WHEN IS_IPV4(NULL) THEN INET_ATON('0.0.0.0') ELSE INET_ATON('10.0.5.9') END VAL FROM A;
SELECT CASE a_1 WHEN INET_NTOA(NULL) THEN HEX(INET6_ATON('10.0.5.9')) ELSE IS_IPV4_MAPPED(NULL) END VAL FROM A;
SELECT CASE a_3 WHEN IS_IPV4('255.255.255.0') THEN INET_ATON('10.0.5.9') ELSE IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222')) END VAL FROM A;
SELECT CASE a_2 WHEN INET_NTOA(NULL) THEN IS_IPV4_MAPPED(INET6_ATON('::FFFF:196.126.99.88')) ELSE INET6_ATON(NULL) END VAL FROM A;
SELECT CASE a_1 WHEN INET_NTOA(NULL) THEN INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) ELSE IS_IPV4_MAPPED(NULL) END VAL FROM A;
SELECT CASE a_3 WHEN IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222')) THEN HEX(INET6_ATON('10.0.5.9')) ELSE INET6_NTOA(UNHEX('00000000000000000000000000000000')) END VAL FROM A;
SELECT CASE a_2 WHEN INET_NTOA(NULL) THEN IS_IPV4(NULL) ELSE INET_ATON(NULL) END VAL FROM A;
SELECT CASE a_1 WHEN INET_ATON('255.255.255.0') THEN IS_IPV4('255.255.255.0') ELSE INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) END VAL FROM A;
SELECT CASE a_1 WHEN INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) THEN INET_ATON('255.255.255.0') ELSE INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) END VAL FROM A;
SELECT CASE a_3 WHEN INET_ATON(NULL) THEN HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF')) ELSE HEX(INET6_ATON('10.0.5.9')) END VAL FROM A;

##distinct##
SELECT DISTINCT IS_IPV4_MAPPED(a_1) FROM A ORDER BY 1;
SELECT DISTINCT INET_ATON(a_3) FROM A ORDER BY 1;
SELECT DISTINCT INET_NTOA(a_3) FROM A ORDER BY 1;
SELECT DISTINCT INET6_ATON(a_3) FROM A ORDER BY 1;
SELECT DISTINCT IS_IPV4_COMPAT(a_1) FROM A ORDER BY 1;
SELECT DISTINCT IS_IPV6(a_3) FROM A ORDER BY 1;
SELECT DISTINCT INET6_NTOA(a_1) FROM A ORDER BY 1;
SELECT DISTINCT IS_IPV4(a_3) FROM A ORDER BY 1;

##多表##
DROP TABLE IF EXISTS B;
CREATE TABLE B (B_0 INT,B_1 VARCHAR(40));
INSERT INTO B(B_0) VALUES (1),(2),(3),(4);
SELECT * FROM B;

SELECT INET_ATON(A_0) FROM A,B WHERE A_0=B_0;
SELECT IS_IPV4_MAPPED(a_1),INET_ATON(b_1) FROM A LEFT JOIN B ON A_0=B_0;
SELECT INET6_ATON(a_3),INET_ATON(b_1) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV4_MAPPED(a_2),IS_IPV4(b_1) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV4_MAPPED(a_2),INET6_ATON(b_1) FROM A LEFT JOIN B ON A_0=B_0;
SELECT IS_IPV6(a_3),INET6_NTOA(b_0) FROM A INNER JOIN B ON A_0=B_0;
SELECT INET_ATON(a_1),IS_IPV6(b_0) FROM A,B WHERE A_0=B_0;
SELECT IS_IPV4_MAPPED(a_2),IS_IPV6(b_0) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV6(a_3),INET6_NTOA(b_0) FROM A,B WHERE A_0=B_0;
SELECT IS_IPV6(a_3),INET6_NTOA(b_0) FROM A LEFT JOIN B ON A_0=B_0;
SELECT IS_IPV4_MAPPED(a_3),IS_IPV6(b_0) FROM A,B WHERE A_0=B_0;
SELECT IS_IPV4(a_3),IS_IPV4(b_0) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV6(a_3),INET_ATON(b_1) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV4_MAPPED(a_3),INET_ATON(b_1) FROM A INNER JOIN B ON A_0=B_0;
SELECT INET_ATON(a_3),INET6_ATON(b_0) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV4_COMPAT(a_3),INET_ATON(b_1) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV4(a_1),IS_IPV4_COMPAT(b_1) FROM A,B WHERE A_0=B_0;
SELECT INET6_ATON(a_3),INET6_NTOA(b_1) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV4_COMPAT(a_3),IS_IPV4(b_0) FROM A LEFT JOIN B ON A_0=B_0;
SELECT IS_IPV6(a_3),INET_ATON(b_1) FROM A,B WHERE A_0=B_0;
SELECT INET_ATON(a_2),IS_IPV6(b_1) FROM A,B WHERE A_0=B_0;
SELECT INET_ATON(a_3),INET6_NTOA(b_0) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV4_COMPAT(a_1),INET6_NTOA(b_0) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT IS_IPV6(a_3),IS_IPV4(b_1) FROM A LEFT JOIN B ON A_0=B_0;
SELECT IS_IPV4_COMPAT(a_2),IS_IPV4_COMPAT(b_0) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT INET_ATON(a_3),INET6_NTOA(b_0) FROM A RIGHT JOIN B ON A_0=B_0;
SELECT INET6_ATON(a_3),IS_IPV6(b_1) FROM A LEFT JOIN B ON A_0=B_0;
SELECT INET6_NTOA(a_3),IS_IPV4_MAPPED(b_0) FROM A,B WHERE A_0=B_0;
SELECT INET_ATON(a_1),INET6_NTOA(b_0) FROM A,B WHERE A_0=B_0;
SELECT IS_IPV4_MAPPED(a_1),IS_IPV6(b_1) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV4(a_3),INET_ATON(b_1) FROM A INNER JOIN B ON A_0=B_0;
SELECT IS_IPV4_MAPPED(b_1),INET_ATON(b_1) FROM A LEFT JOIN B ON A_0=B_0 AND a_2 = INET_ATON('10.0.5.9') ORDER BY 1;
SELECT IS_IPV4_COMPAT(b_0),INET6_ATON(b_1) FROM A,B WHERE A_0=B_0 AND a_3 <= IS_IPV4_COMPAT(INET6_ATON('::192.168.111.222')) ORDER BY 1;
SELECT INET6_ATON(a_3),IS_IPV4_COMPAT(b_0) FROM A RIGHT JOIN B ON A_0=B_0 AND b_1 < INET6_ATON(NULL) ORDER BY 1;
SELECT INET6_NTOA(a_1),IS_IPV4_COMPAT(b_1) FROM A INNER JOIN B ON A_0=B_0 AND b_1 != INET_NTOA(3739147998) ORDER BY 1;
SELECT IS_IPV6(a_3),IS_IPV4_MAPPED(b_1) FROM A INNER JOIN B ON A_0=B_0 AND a_3 != INET_NTOA(3739147998) ORDER BY 1;
SELECT INET6_ATON(b_1),IS_IPV4_COMPAT(b_0) FROM A,B WHERE A_0=B_0 AND a_2 != INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF')) ORDER BY 1;
SELECT INET6_NTOA(b_1),IS_IPV6(b_0) FROM A,B WHERE A_0=B_0 AND a_2 >= INET6_NTOA(UNHEX('000000000000000000000000C0A86FDE')) ORDER BY 1;
SELECT IS_IPV4(b_0),IS_IPV4(b_0) FROM A INNER JOIN B ON A_0=B_0 AND a_3 = IS_IPV4_COMPAT(NULL) ORDER BY 1;
SELECT IS_IPV4_COMPAT(b_0),IS_IPV4_MAPPED(b_0) FROM A LEFT JOIN B ON A_0=B_0 AND a_2 >= INET6_NTOA(UNHEX('00000000000000000000000000000000')) ORDER BY 1;
SELECT INET6_NTOA(b_1),INET6_NTOA(b_1) FROM A,B WHERE A_0=B_0 AND a_2 != INET_NTOA(NULL) ORDER BY 1;
SELECT INET_ATON(a_1),IS_IPV4(b_1) FROM A,B WHERE A_0=B_0 AND a_1 != IS_IPV4_MAPPED(NULL) ORDER BY 1;
