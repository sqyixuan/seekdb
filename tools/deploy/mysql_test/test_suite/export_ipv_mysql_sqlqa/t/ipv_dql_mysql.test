drop TABLE if EXISTS A;
CREATE TABLE A(a_0 INT,a_1 BIGINT,a_2 VARCHAR(39),a_3 VARBINARY(32));
INSERT INTO A VALUES(1,0,'222.222.222.222','0A000509'),(2,1,'::','0000'),(3,4294967040,'::192.168.111.222','FFFF'),(4,-1,'::FFFF:196.126.99.88','-FF'),
(5,167773449,'FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF','FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'),(6,NULL,NULL,NULL);
