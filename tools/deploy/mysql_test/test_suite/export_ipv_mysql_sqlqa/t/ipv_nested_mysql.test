##嵌套其他函数##
##inet_aton,inet6_aton##
SELECT INET_ATON(UPPER(NULL));
SELECT INET_ATON(INET_ATON(TRIM(' ::FFFF:255.12.002.00 ')));
SELECT INET_ATON(MAX('yes'));
SELECT INET_ATON(INET_NTOA(4294967040));
