--disable_warnings
--error 0,1396
drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

##create##
##table##
drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(20) GENERATED ALWAYS AS (INET_ATON('255.255.255.255')),
A_3 INT GENERATED ALWAYS AS (INET_ATON('000.000.000.250')),
A_4 varchar(20) GENERATED ALWAYS AS (INET_ATON(NULL)),
A_5 varchar(20) GENERATED ALWAYS AS (INET_ATON('000.000.000.000')));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(50) GENERATED ALWAYS AS (HEX(INET6_ATON('fdfe::5a55:caff:fefa:9089'))),
A_3 INT GENERATED ALWAYS AS (HEX(INET6_ATON('::1111'))),
A_4 varchar(20) GENERATED ALWAYS AS (HEX(INET6_ATON(NULL))),
A_5 varchar(32) GENERATED ALWAYS AS (HEX(INET6_ATON('::'))));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (INET_NTOA(4294967040)),
A_3 VARCHAR(32) GENERATED ALWAYS AS (INET_NTOA('4294967040')),
A_4 varchar(20) GENERATED ALWAYS AS (INET_NTOA(NULL)),
A_5 varchar(20) GENERATED ALWAYS AS (INET_NTOA(0)));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (INET6_NTOA(UNHEX('FDFE0000000000005A55CAFFFEFA9089'))),
A_3 VARCHAR(39) GENERATED ALWAYS AS (INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'))),
A_4 varchar(20) GENERATED ALWAYS AS (INET6_NTOA(NULL)),
A_5 varchar(5) GENERATED ALWAYS AS (INET6_NTOA(UNHEX('00000000000000000000000000000000'))));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (IS_IPV4('196.126.99.88')),
A_3 INT GENERATED ALWAYS AS (IS_IPV4('196.126.99.88')),
A_4 INT GENERATED ALWAYS AS (IS_IPV4(NULL)),
A_5 CHAR GENERATED ALWAYS AS (IS_IPV4('196')));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (IS_IPV6('::196.126.99.88')),
A_3 INT GENERATED ALWAYS AS (IS_IPV6('::')),
A_4 INT GENERATED ALWAYS AS (IS_IPV6(NULL)),
A_5 CHAR GENERATED ALWAYS AS (IS_IPV6('196')));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (IS_IPV4_MAPPED(INET6_ATON('::196.126.99.88'))),
A_3 INT GENERATED ALWAYS AS (IS_IPV4_MAPPED(INET6_ATON('::'))),
A_4 INT GENERATED ALWAYS AS (IS_IPV4_MAPPED(NULL)),
A_5 CHAR GENERATED ALWAYS AS (IS_IPV4_MAPPED(INET6_ATON('::FFFF:196.126.99.88'))));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;

drop TABLE if EXISTS A;
CREATE TABLE A(
A_1 INT, 
A_2 varchar(32) GENERATED ALWAYS AS (IS_IPV4_COMPAT(INET6_ATON('::196.126.99.88'))),
A_3 INT GENERATED ALWAYS AS (IS_IPV4_COMPAT(INET6_ATON('::'))),
A_4 INT GENERATED ALWAYS AS (IS_IPV4_COMPAT(NULL)),
A_5 CHAR GENERATED ALWAYS AS (IS_IPV4_COMPAT(INET6_ATON('::FFFF:196.126.99.88'))));
INSERT INTO A(A_1) VALUES (1);
SELECT * FROM A;
CREATE OR REPLACE VIEW A_VIEW AS SELECT * FROM A;
SELECT * FROM A_VIEW;


##view##				
drop TABLE if EXISTS A;
CREATE TABLE A(A_0 INT,A_1 INT,A_2 VARCHAR(32),A_3 FLOAT);
INSERT INTO A VALUES(1,0,'222.222.222.222',1.23),(2,1,'::',3.21),(3,42949,'::192.168.111.222',6666.6666),(4,-1,'::FFFF:196.126.99.88',-1.23),
(5,255,'FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF',NULL);
SELECT * FROM A;

CREATE OR REPLACE VIEW A_VIEW AS SELECT INET_ATON('255.255.255.255') val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT HEX(INET6_ATON('fdfe::5a55:caff:fefa:9089')) VAL FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT INET_NTOA(4294967040) VAL FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT INET6_NTOA(UNHEX('FDFE0000000000005A55CAFFFEFA9089')) val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT IS_IPV4('196.126.99.88') val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT IS_IPV6('::') val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT IS_IPV4_COMPAT(INET6_ATON('::196.126.99.88')) val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT IS_IPV4_MAPPED(INET6_ATON('::FFFF:196.126.99.88')) val FROM DUAL;
SELECT * FROM A_VIEW;

CREATE OR REPLACE VIEW A_VIEW AS SELECT INET_ATON(A_2) val FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT HEX(INET6_ATON(A_2)) val FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT INET_NTOA(A_1) val FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT INET6_NTOA(UNHEX(A_2)) val FROM A;
SELECT * FROM A_VIEW;
CREATE OR REPLACE VIEW A_VIEW AS SELECT IS_IPV4(A_2),IS_IPV6(A_2),IS_IPV4_COMPAT(INET6_ATON(A_2)),IS_IPV4_MAPPED(INET6_ATON(A_2)) val FROM A;
SELECT * FROM A_VIEW;

DROP VIEW A_VIEW;

