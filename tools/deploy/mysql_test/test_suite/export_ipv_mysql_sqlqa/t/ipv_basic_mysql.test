##inet_ntoa##
SELECT INET_NTOA(4294967040);
SELECT INET_NTOA(4294967041);
SELECT INET_NTOA(1.2);
SELECT INET_NTOA(1);
SELECT INET_NTOA('YEA');
SELECT INET_NTOA('4294967040');
SELECT INET_NTOA(0);
SELECT INET_NTOA(-2.1);
SELECT INET_NTOA(-1);
SELECT INET_NTOA(-4294967040);
SELECT INET_NTOA(NULL);

##inet6_aton##
SELECT INET6_ATON(NULL) IS NULL;
SELECT INET6_ATON(123) IS NULL;
SELECT INET6_ATON(123.45) IS NULL ;
SELECT INET6_ATON(str_to_date('2014,2,28 09', '%Y,%m,%d %h')) IS NULL ;
SELECT INET6_ATON('1.2.3') IS NULL ;
SELECT INET6_ATON('1.2.3.') IS NULL ;
SELECT INET6_ATON('1..3.4') IS NULL ;
SELECT INET6_ATON('-1.2.3.4') IS NULL ;
SELECT INET6_ATON('1.2.3.256') IS NULL ;
SELECT INET6_ATON('1.2.3.4.5') IS NULL ;
SELECT INET6_ATON('0001.2.3.4') IS NULL ;
SELECT INET6_ATON('0x1.2.3.4') IS NULL ;
SELECT INET6_ATON('a.2.3.4') IS NULL ;

SELECT INET6_ATON('0000:0000:0000:0000')  ;
#SELECT INET6_ATON('fdfe::5a55:caff:fefa:9089');
SELECT HEX(INET6_ATON('fdfe::5a55:caff:fefa:9089'));
SELECT HEX(INET6_ATON('0000:0000:0000:0000:0000:0000:0000:0000'))  ;
SELECT HEX(INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF'))  ;
SELECT HEX(INET6_ATON('0000:0000:0000:0000'))  ;
SELECT INET6_ATON('FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF:FFFF') is NULL  ;
SELECT HEX(INET6_ATON('1.2.3.4'));
SELECT HEX(INET6_ATON(':'));
SELECT HEX(INET6_ATON('::'));
SELECT HEX(INET6_ATON('1:2:3:4a::123'));
SELECT HEX(INET6_ATON(':::'));
--error 1064
SELECT HEX(INET6_ATON(fdfe::5a55:caff:fefa:9089));
SELECT HEX(INET6_ATON(-'fdfe::5a55:caff:fefa:9089'));
SELECT HEX(INET6_ATON('0000::0000:0000:0000:0000::0001'))  ;
SELECT HEX(INET6_ATON('::ffff:192.168.1.2'));
SELECT HEX(INET6_ATON('ffff:ffff:ffff:ffff::255.255.255.255'));
SELECT HEX(INET6_ATON('ffff:ffff:ffff:ffff::255.255.255.'));
SELECT HEX(INET6_ATON('1234:1234:1234:1234:1234::255.255'));
SELECT HEX(INET6_ATON(TRIM(' ::123.123.002.12 ')));
SELECT HEX(INET6_ATON(TRIM(' ab:1:ab:ab:1234:a:a:1234 ')));
SELECT HEX(INET6_ATON(TRIM(' ::1.00.12.002 ')));
SELECT HEX(INET6_ATON(TRIM(' ::0.000.00.123 ')));
SELECT HEX(INET6_ATON(TRIM(' 1234:ab:0000:a:1:1234:00:1 ')));
SELECT HEX(INET6_ATON(TRIM(' ffff:abc:12:000:abc:000:ffff:1 ')));
SELECT HEX(INET6_ATON(TRIM(' a:a:0:abcd:12:1:abc:abcd ')));
SELECT HEX(INET6_ATON(TRIM(' ::000.255.0.123 ')));
SELECT HEX(INET6_ATON(TRIM(' 0000:ab:12:000:000:1:123:ab ')));
SELECT HEX(INET6_ATON(TRIM(' abcd:123:1:1234:ab:12:ab:abcd ')));
SELECT HEX(INET6_ATON(TRIM(' abc:ab:00:0:0:abcd:12:a ')));
SELECT HEX(INET6_ATON(TRIM(' ::002.1.12.12 ')));
SELECT HEX(INET6_ATON(TRIM(' a:abcd:0:ffff:0:0000:a:0000 ')));
SELECT HEX(INET6_ATON(TRIM(' ffff:1234:abc:abcd:0:abc:a:000 ')));
SELECT HEX(INET6_ATON(TRIM(' ::12.256.000.000 ')));
SELECT HEX(INET6_ATON(TRIM(' 1:ab:12:ffff:a:1234:abc:ab ')));
SELECT HEX(INET6_ATON(TRIM(' ::000.002.255.1 ')));
SELECT HEX(INET6_ATON(TRIM(' 00:000:000:a:123:00:a:abc ')));
SELECT HEX(INET6_ATON(TRIM(' ::002.00.000.1 ')));
SELECT HEX(INET6_ATON(TRIM(' ::123.256.256.123 ')));
SELECT HEX(INET6_ATON(TRIM(' ::0.000.002.000 ')));
SELECT HEX(INET6_ATON(TRIM(' ::000.002.12.000 ')));
SELECT HEX(INET6_ATON(TRIM(' abcd:000:00:1:1234:abcd:abcd:000 ')));
SELECT HEX(INET6_ATON(TRIM(' 1:abc:a:00:ffff:123:ffff:12 ')));
SELECT HEX(INET6_ATON(TRIM(' 1:123:000:0:abc:00:ffff:abc ')));
SELECT HEX(INET6_ATON(TRIM(' ::1.000.1.255 ')));
SELECT HEX(INET6_ATON(TRIM(' ::12.000.000.000 ')));
SELECT HEX(INET6_ATON(TRIM(' 12:abcd:abc:ab:1234:0000:abc:0000 ')));
SELECT HEX(INET6_ATON(TRIM(' ::123.12.0.002 ')));
SELECT HEX(INET6_ATON(TRIM(' 1:12:000:123:1:0000:abc:000 ')));

##inet6_ntoa##
SELECT INET6_NTOA(NULL);
SELECT INET6_NTOA(INET6_ATON('fdfe::5a55:caff:fefa:9089'));
SELECT INET6_NTOA(INET6_ATON('10.0.5.9'));
SELECT INET6_NTOA(UNHEX('FDFE0000000000005A55CAFFFEFA9089'));
SELECT INET6_NTOA(UNHEX('0A000509'));
SELECT INET6_NTOA(UNHEX('00000000000000000000000000000000'));
SELECT INET6_NTOA(UNHEX('00000000000000000000000000000001'));
SELECT INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF'));
SELECT INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF0'));
SELECT INET6_NTOA(UNHEX('FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE'));
SELECT INET6_NTOA(UNHEX('1234'));
SELECT INET6_NTOA(UNHEX('C0A801'));
SELECT INET6_NTOA(UNHEX('C0A80102'));
SELECT INET6_NTOA(UNHEX('C0A8010203'));
SELECT INET6_NTOA(UNHEX('0102030405060708090A0B0C0D0E0F'));
SELECT INET6_NTOA(UNHEX('0102030405060708090A0B0C0D0E0F10'));
SELECT INET6_NTOA(UNHEX('0102030405060708090A0B0C0D0E0F1011'));
SELECT INET6_NTOA(12321312412);
--error 1054
SELECT INET6_NTOA(0A000509);
SELECT INET6_NTOA('123');
SELECT INET6_NTOA('0A000509');
SELECT INET6_NTOA(123.123);
SELECT INET6_NTOA(-123.456);
SELECT INET6_NTOA(str_to_date('2014,2,28 09', '%Y,%m,%d %h'));
SELECT INET6_NTOA(1234),INET6_NTOA('1234'), INET6_NTOA(BINARY('1234'));
SELECT INET6_NTOA('0123456789abcdef'), INET6_NTOA(BINARY('0123456789abcdef'));
SELECT INET6_NTOA(BINARY('1111111111111111111111111111111111111111111111111111111111111111'));

##is_ipv4,is_ipv6##
SELECT IS_IPV4(null);
SELECT IS_IPV4(' ');
SELECT IS_IPV4('');
SELECT IS_IPV4('196.196');
SELECT IS_IPV4('196');
SELECT IS_IPV4('0'),IS_IPV4('1'),IS_IPV4('-1'),IS_IPV4('1.23'),IS_IPV4('-1.23'),IS_IPV4(0),IS_IPV4(-1),IS_IPV4(1.23);
SELECT IS_IPV4('196.126.99.88');
SELECT IS_IPV4('10.0.0.3');
SELECT IS_IPV4('99.0.0.3');
select IS_IPV4("255.255.255.255.255"),IS_IPV4("255.255.1.255"),IS_IPV4("0.1.255");
select IS_IPV4("0.255.255.255.255");
select IS_IPV4("255.255.255.0000");
SELECT IS_IPV4('255.255.255.255');
SELECT IS_IPV4('255.255.255.255.255');
SELECT IS_IPV4('2555555.2555555.25555555.25555555');
SELECT IS_IPV4('196.196..196');
SELECT IS_IPV4('.196.196.196');
SELECT IS_IPV4('196.196.196.');
SELECT IS_IPV4('196...196');
SELECT IS_IPV4(TRIM(' 002.12 '));
SELECT IS_IPV4(TRIM(' 002 '));
SELECT IS_IPV6(TRIM(' 1.000.000 '));
SELECT IS_IPV6(TRIM(' 002.000.0.000.00 '));
SELECT IS_IPV4(TRIM(' 12.000 '));
SELECT IS_IPV6(TRIM(' 256.1.000.255 '));
SELECT IS_IPV6(TRIM(' 256.00.255.12 '));
SELECT IS_IPV6(TRIM(' 256.002.000.000.1 '));
SELECT IS_IPV6(TRIM(' 000:ffff:a:12:0000:ab:12:000 '));
SELECT IS_IPV6(TRIM(' 000.0.12.255.000 '));
SELECT IS_IPV6(TRIM(' 12.000.123.0 '));
SELECT IS_IPV6(TRIM(' 002.0.123.12 '));
SELECT IS_IPV6(TRIM(' 12.002.0.000 '));
SELECT IS_IPV6(TRIM(' 0.1.0.00 '));
SELECT IS_IPV6(TRIM(' 255.000.1.256.000 '));
SELECT IS_IPV6(TRIM(' 000.000.123.002 '));
SELECT IS_IPV6(TRIM(' 002.1.255 '));
SELECT IS_IPV6(TRIM(' 002.255.1 '));
SELECT IS_IPV6(TRIM(' 256.255 '));
SELECT IS_IPV4(TRIM(' 000.1.002.00 '));
SELECT IS_IPV4(TRIM(' 123 '));
SELECT IS_IPV4(TRIM(' 1.0.000.002 '));
SELECT IS_IPV6(TRIM(' ::002.12.000.002 '));
SELECT IS_IPV6(TRIM(' 255.000.12.000 '));
SELECT IS_IPV4(TRIM(' 1.256.12.0.256 '));
SELECT IS_IPV4(TRIM(' 1.00 '));
SELECT IS_IPV6(TRIM(' 12.12.255.12 '));
SELECT IS_IPV6(TRIM(' 12.12 '));
SELECT IS_IPV4(TRIM(' 0.0 '));
SELECT IS_IPV4(TRIM(' ::1.256.12.255 '));

##is_ipv4_mapped,is_ipv4_compat##
SELECT IS_IPV4_COMPAT(' ');
SELECT IS_IPV4_MAPPED(' ');
SELECT IS_IPV4_COMPAT('123');
SELECT IS_IPV4_MAPPED('123');
SELECT IS_IPV4_COMPAT(123);
SELECT IS_IPV4_MAPPED(123);
SELECT IS_IPV4_COMPAT(NULL);
SELECT IS_IPV4_MAPPED(NULL);
SELECT IS_IPV4_COMPAT(0);
SELECT IS_IPV4_MAPPED(0);
SELECT IS_IPV4_COMPAT('123.123.123.123');
SELECT IS_IPV4_MAPPED('123.123.123.123');
SELECT IS_IPV4_COMPAT('::FFFF:123.123.123.123');
SELECT IS_IPV4_MAPPED('::FFFF:123.123.123.123');
SELECT IS_IPV4_COMPAT('::123.123.123.123');
SELECT IS_IPV4_MAPPED('::123.123.123.123');

SELECT IS_IPV4_COMPAT(INET6_ATON('::10.0.5.9'));
SELECT IS_IPV4_COMPAT('::10.0.5.9');
SELECT IS_IPV4_COMPAT(INET6_ATON('::ffff:10.0.5.9'));
SELECT IS_IPV4_COMPAT(INET6_ATON('::198.51.100.1')),IS_IPV4_COMPAT(INET6_ATON('::c0a8:0001')),IS_IPV4_COMPAT(INET6_ATON('::c0a8:1'));
SELECT IS_IPV4_COMPAT('C6336401');
SELECT IS_IPV4_COMPAT(INET6_ATON('198.51.100.1'));
SELECT IS_IPV4_MAPPED(INET6_ATON('::10.0.5.9'));
SELECT IS_IPV4_MAPPED(INET6_ATON('::ffff:10.0.5.9'));
SELECT IS_IPV4_MAPPED(INET6_ATON('::ffff:198.51.100.1')),IS_IPV4_MAPPED(INET6_ATON('::ffff:c0a8:0001')),IS_IPV4_MAPPED(INET6_ATON('::ffff:c0a8:1'));
SELECT IS_IPV4_MAPPED('::10.0.5.9');
SELECT IS_IPV4_MAPPED('::ffff:10.0.5.9');

SELECT IS_IPV4_COMPAT(INET6_ATON('0:1234:1234:1234:1234:1234:255.255.255.255'));
SELECT IS_IPV4_MAPPED(INET6_ATON('0:1234:1234:1234:1234:1234:255.255.255.255'));
SELECT IS_IPV4_COMPAT(INET6_ATON('1234:1234:1234::1234:255.255.255.255'));
SELECT IS_IPV4_MAPPED(INET6_ATON('1234:1234:1234::1234:255.255.255.255'));

connection default;
