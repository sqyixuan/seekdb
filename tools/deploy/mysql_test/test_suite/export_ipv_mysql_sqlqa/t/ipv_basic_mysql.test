drop user 'zc_subquery_mysql'@'%';
--enable_warnings
create user 'zc_subquery_mysql'@'%' IDENTIFIED BY 'zc_subquery_mysql';
grant all on *.* to 'zc_subquery_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,zc_subquery_mysql,zc_subquery_mysql,test,$OBMYSQL_PORT);
connection conn;

##inet_aton##
SELECT INET_ATON(null);
SELECT INET_ATON(' ');
SELECT INET_ATON('');
SELECT INET_ATON('196.196');
SELECT INET_ATON('196');
SELECT INET_ATON('0'),INET_ATON('1'),INET_ATON('-1'),INET_ATON('1.23'),INET_ATON('-1.23'),INET_ATON(0),INET_ATON(-1),INET_ATON(1.23);
SELECT INET_ATON('196.126.99.88');
SELECT INET_ATON('10.0.0.3');
SELECT INET_ATON('99.0.0.3');
select inet_aton("255.255.255.255.255"),inet_aton("255.255.1.255"),inet_aton("0.1.255");
select inet_aton("0.255.255.255.255");
select inet_aton("255.255.255.0000");
SELECT INET_ATON('255.255.255.255');
SELECT INET_ATON('255.255.255.255.255');
SELECT INET_ATON('2555555.2555555.25555555.25555555');
SELECT INET_ATON('196.196..196');
SELECT INET_ATON('.196.196.196');
SELECT INET_ATON('196.196.196.');
SELECT INET_ATON('196...196');
SELECT INET_ATON('123.123.002.12');
