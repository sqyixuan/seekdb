SELECT INET_ATON('000.1.256.000');
SELECT INET_ATON('0.123.00.000');
SELECT INET_ATON('0.000.12.1');
SELECT INET_ATON('000.0.12.255');
SELECT INET_ATON('1.256.00.12');
SELECT INET_ATON('0.000.255.256');
SELECT INET_ATON('0.123.12.000');
SELECT INET_ATON('12.12.002.0');
SELECT INET_ATON('000.12.002.0');
SELECT INET_ATON('00.123.002.1');
SELECT INET_ATON('000.1.256.000');
SELECT INET_ATON('1.2.3.4%');
