# ------------------------------------------------------------------
# -- End of 5.1 tests
# ------------------------------------------------------------------
#
# Test for bug#11763757 "56510: ERROR 42000: FUNCTION DOES NOT EXIST
# IF NOT-PRIV USER RECONNECTS ".
#
# The real problem was that server was unable handle properly stored
# functions in databases which names contained dot.
#
DROP DATABASE IF EXISTS `my.db`;
create database `my.db`;
use `my.db`;
CREATE FUNCTION f1(a int) RETURNS INT RETURN a;
# Create new connection.
USE `my.db`;
SELECT f1(1);
SELECT `my.db`.f1(2);
# Switching to default connection.
DROP DATABASE `my.db`;
USE test;
#
# Bug#11763507 - 56224: FUNCTION NAME IS CASE-SENSITIVE
#
SET @@SQL_MODE = '';
DROP EVENT IF EXISTS teste_bug11763507$
CREATE EVENT teste_bug11763507 ON SCHEDULE AT CURRENT_TIMESTAMP + INTERVAL 1 HOUR 
DO SELECT 1 $
SHOW EVENTS LIKE 'teste_bug11763507';
SHOW EVENTS LIKE 'TESTE_bug11763507';
SHOW CREATE EVENT teste_bug11763507;
SHOW CREATE EVENT TESTE_bug11763507;
DROP EVENT teste_bug11763507;
#END OF BUG#11763507 test.

# WL#4179: Stored programs: validation of stored program statements
#
# Test handle of metadata changes with events.

drop table if exists t1, t2, t3;
CREATE TABLE t1 (a INT, b INT);
CREATE TABLE t2 (a INT, b INT);
CREATE TABLE t3 (a INT);
INSERT INTO t1 VALUES (1, 2);
SET GLOBAL EVENT_SCHEDULER = ON;
SELECT GET_LOCK('e1_lock', 60);
CREATE EVENT e1 ON SCHEDULE EVERY 1 SECOND STARTS NOW() DO
BEGIN
DECLARE EXIT HANDLER FOR 1136 BEGIN
INSERT INTO t3 VALUES (1);
END; -- ER_WRONG_VALUE_COUNT_ON_ROW
SELECT GET_LOCK('e1_lock', 60);
SELECT RELEASE_LOCK('e1_lock');
INSERT INTO t2 SELECT * FROM t1;
END|
SELECT RELEASE_LOCK('e1_lock');
Timeout in wait_condition.inc for SELECT COUNT(*) >= 3 FROM t2
SELECT GET_LOCK('e1_lock', 60);
ALTER TABLE t1 ADD COLUMN (c INT);
SELECT RELEASE_LOCK('e1_lock');
# Wait for new rows in t3. That means, the even has been executed,
# and INSERT INTO t2 failed because now t1 has 3 columns.
Timeout in wait_condition.inc for SELECT COUNT(*) > 0 FROM t3
DROP EVENT e1;
DROP TABLE t1, t2, t3;
SET GLOBAL EVENT_SCHEDULER = OFF;
#
# WL#2284: Increase the length of a user name
#
CREATE DATABASE if not exists test1;
drop table if exists test1.t1;
CREATE TABLE test1.t1 (
int_field INTEGER UNSIGNED NOT NULL,
char_field CHAR(10),
INDEX(`int_field`)
);
drop user if exists user_name_len_16, user_name_len_22_01234, user_name_len_32_012345678901234;
CREATE USER user_name_len_16;
CREATE USER user_name_len_22_01234;
CREATE USER user_name_len_32_012345678901234;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM user_name_len_16;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM user_name_len_22_01234;
# Check that user_name_len16 has no SELECT permission ON t1
SELECT * FROM test1.t1;
# Check that user_name_len_22_01234 has no SELECT permission ON t1
SELECT * FROM test1.t1;
GRANT SELECT ON test1.t1 TO user_name_len_22_01234;
# Check that user_name_len_22_01234 has *now* SELECT permission ON t1
SELECT * FROM test1.t1;
DROP PROCEDURE IF EXISTS test1.p1_len22;
CREATE DEFINER=user_name_len_22_01234 PROCEDURE test1.p1_len22()
SELECT * FROM test1.t1;
GRANT EXECUTE ON PROCEDURE test1.p1_len22 TO user_name_len_22_01234;
GRANT EXECUTE ON PROCEDURE test1.p1_len22 TO user_name_len_16;
# Now user_name_len_16 should be able to SELECT FROM t1 by calling
# p1_len22 procedure
CALL test1.p1_len22();
CREATE DEFINER=user_name_len_33_0123456789012345 PROCEDURE test1.p1_len33()
SELECT * FROM test1.t1;
# REVOKE the SELECT permission from user_name_len_22_01234
REVOKE SELECT ON test1.t1 FROM user_name_len_22_01234;
# and GRANT it to user_name_len_32_012345678901234
GRANT SELECT ON test1.t1 TO user_name_len_32_012345678901234;
DROP FUNCTION IF EXISTS test1.f1_len32;
CREATE DEFINER = user_name_len_32_012345678901234 FUNCTION test1.f1_len32() RETURNS INT
RETURN (SELECT COUNT(*) FROM test1.t1);
GRANT EXECUTE ON FUNCTION test1.f1_len32 TO user_name_len_32_012345678901234;
GRANT EXECUTE ON FUNCTION test1.f1_len32 TO user_name_len_22_01234;
GRANT SELECT ON test1.t1 TO user_name_len_22_01234;
# Now user_name_len_22_01234 should be able to SELECT COUNT(*) FROM t1
# by calling f1_len32 function
SELECT test1.f1_len32();
# Recreate test1.p1_len22, this time with Security Context set to INVOKER
DROP PROCEDURE test1.p1_len22;
# Make sure user_name_len_22_01234 has SELECT privileges on test.t1
SELECT * FROM test1.t1;
CREATE DEFINER=user_name_len_22_01234 PROCEDURE test1.p1_len22()
SQL SECURITY INVOKER
SELECT * FROM test1.t1;
GRANT EXECUTE ON PROCEDURE test1.p1_len22 TO user_name_len_22_01234;
GRANT EXECUTE ON PROCEDURE test1.p1_len22 TO user_name_len_16;
# Now user_name_len_16 should *NOT* be able to SELECT COUNT(*) FROM t1
# by calling f1_len22 function as this function is using the INVOKER
# security context
CALL test1.p1_len22();
CREATE DEFINER=user_name_len_33_0123456789012345 FUNCTION test1.f1_len33() RETURNS INT
RETURN (SELECT COUNT(*) FROM test1.t1);
DROP DATABASE test1;
DROP USER user_name_len_16;
DROP USER user_name_len_22_01234;
DROP USER user_name_len_32_012345678901234;
