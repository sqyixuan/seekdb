drop database if exists `FoO`;
CREATE DATABASE FoO COLLATE ascii_bin;
USE FoO;
CREATE TABLE t1(a INT);
# t1 should inherit ascii_bin
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = ascii COLLATE = ascii_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
DROP TABLE t1;
USE Foo;
CREATE TABLE t1(a INT);
# t1 should inherit utf8_unicode_ci
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = ascii COLLATE = ascii_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
DROP TABLE t1;
DROP DATABASE FoO;
