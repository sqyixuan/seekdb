#
# WL#4284: Transactional DDL locking
#
# FLUSH PRIVILEGES should not implicitly unlock locked tables.
#
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (c1 INT);
LOCK TABLES t1 READ;
FLUSH PRIVILEGES;
Warnings:
Warning	1235	After executing the GRANT and REVOKE statements, the permissions will be automatically applied and take effect. There is no need to execute the FLUSH PRIVILEGES command. FLUSH PRIVILEGES not supported
UNLOCK TABLES;
FLUSH PRIVILEGES;
Warnings:
Warning	1235	After executing the GRANT and REVOKE statements, the permissions will be automatically applied and take effect. There is no need to execute the FLUSH PRIVILEGES command. FLUSH PRIVILEGES not supported
DROP TABLE t1;
#
# Bug#54812: assert in Diagnostics_area::set_ok_status during EXPLAIN
#
CREATE USER nopriv_user;
connection: default
DROP TABLE IF EXISTS t1,t2,t3;
DROP FUNCTION IF EXISTS f;
CREATE TABLE t1 (key1 INT PRIMARY KEY);
CREATE TABLE t2 (key2 INT);
INSERT INTO t1 VALUES (1),(2);
CREATE FUNCTION f() RETURNS INT RETURN 1;
GRANT FILE ON *.* TO 'nopriv_user';
GRANT CREATE ON *.* TO 'nopriv_user';
FLUSH PRIVILEGES;
Warnings:
Warning	1235	After executing the GRANT and REVOKE statements, the permissions will be automatically applied and take effect. There is no need to execute the FLUSH PRIVILEGES command. FLUSH PRIVILEGES not supported
connection: con1
SELECT MAX(key1) FROM t1 WHERE f() < 1 INTO OUTFILE '<outfile>';
ERROR 42000: SELECT command denied to user 'nopriv_user'@'%' for table 't1'
INSERT INTO t2 SELECT MAX(key1) FROM t1 WHERE f() < 1;
ERROR 42000: INSERT command denied to user 'nopriv_user'@'%' for table 't2'
SELECT MAX(key1) INTO @dummy FROM t1 WHERE f() < 1;
ERROR 42000: SELECT command denied to user 'nopriv_user'@'%' for table 't1'
CREATE TABLE t3 (i INT) AS SELECT MAX(key1) FROM t1 WHERE f() < 1;
ERROR 42000: INSERT command denied to user 'nopriv_user'@'%' for table 't3'
connection: default
DROP TABLE t1,t2;
DROP FUNCTION f;
DROP USER nopriv_user;
