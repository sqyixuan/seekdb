DROP TABLE t2;
#
# This ALTER should change old fields to new fields
# Expecting new WEIGHT_STRING the rounding.
#
ALTER TABLE t1 MODIFY f_time TIME, MODIFY f_timestamp TIMESTAMP, MODIFY f_datetime DATETIME;
