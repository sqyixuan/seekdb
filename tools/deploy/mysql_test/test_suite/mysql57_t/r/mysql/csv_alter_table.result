# ===== csv_alter_table.1 =====
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a int NOT NULL) ENGINE = CSV;
Warnings:
Warning	1286	Unknown storage engine 'CSV'
ALTER TABLE t1 ADD COLUMN b CHAR(5) NOT NULL;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	int(11)	NO		NULL	
b	char(5)	NO		NULL	
ALTER TABLE t1 DROP COLUMN b;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	int(11)	NO		NULL	
ALTER TABLE t1 MODIFY a BIGINT NOT NULL;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	bigint(20)	NO		NULL	
ALTER TABLE t1 CHANGE a a INT NOT NULL;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	int(11)	NO		NULL	
DROP TABLE t1;
# ===== csv_alter_table.2 =====
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a int NOT NULL) ENGINE = CSV;
Warnings:
Warning	1286	Unknown storage engine 'CSV'
ALTER TABLE t1 ADD COLUMN b CHAR(5);
DESC t1;
Field	Type	Null	Key	Default	Extra
a	int(11)	NO		NULL	
b	char(5)	YES		NULL	
ALTER TABLE t1 MODIFY a BIGINT;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	bigint(20)	YES		NULL	
b	char(5)	YES		NULL	
ALTER TABLE t1 CHANGE a a INT;
DESC t1;
Field	Type	Null	Key	Default	Extra
a	int(11)	YES		NULL	
b	char(5)	YES		NULL	
DROP TABLE t1;
