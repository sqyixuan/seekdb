#owner group:技术部-SQL-优化器
#description:mysqlcase迁移
#tags:hint

--echo # WL#8017 Infrastructure for Optimizer Hints

--echo # MAX_EXECUTION_TIME hint testing
####--source include/have_statement_timeout.inc

--echo # QUERY_TIMEOUT hint testing

CREATE TABLE t1 (a INT, b VARCHAR(300));
INSERT INTO t1 VALUES (1, 'string');
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;
INSERT INTO t1 SELECT * FROM t1;

-- disable_query_log
-- disable_result_log
####ob这里报错（已支持语法）
--error 0,1064
analyze table t1;
-- enable_result_log
-- enable_query_log

####--error ER_QUERY_TIMEOUT
--error 4012
SELECT /*+ QUERY_TIMEOUT(1) */ * FROM t1 a, t1 b;

####EXPLAIN SELECT /*+ MAX_EXECUTION_TIME(10) MAX_EXECUTION_TIME(100) */ * FROM t1;

DROP TABLE t1;


--echo
--echo # test the QUERY_TIMEOUT hint for SELECT statements:
--echo

CREATE TABLE t1 (i INT, j INT);
CREATE INDEX i1 ON t1(i);
CREATE INDEX i2 ON t1(j);

INSERT INTO t1 VALUES (1, 1), (2, 2);

SELECT /*+ QUERY_TIMEOUT(4294967296) */ 1 FROM t1;

####--error ER_QUERY_TIMEOUT
--error 4012
SELECT /*+ QUERY_TIMEOUT(1) */ *, SLEEP(1000) FROM t1;
####--error ER_QUERY_TIMEOUT
--error 4012
SELECT  /*+ QUERY_TIMEOUT(1) */ *, SLEEP(1000) FROM t1 UNION SELECT 1, 2, 3;
####--error ER_QUERY_TIMEOUT
--error 4012
(SELECT /*+ QUERY_TIMEOUT(1) */ *, SLEEP(1000) FROM t1) UNION (SELECT 1, 2, 3);
####--error ER_QUERY_TIMEOUT
--error 4012
((SELECT  /*+ QUERY_TIMEOUT(1) */ *, SLEEP(1000) FROM t1));

--echo
--echo # only SELECT statements supports the MAX_EXECUTION_TIME hint (warning):
--echo
####ob的QUERY_TIMEOUT会作用所有以下语句
####为保证结果一致，禁掉结果
--disable_result_log
CREATE TABLE t2 (i INT);
--error 4012
INSERT /*+ QUERY_TIMEOUT(1) */ INTO t2 SELECT 1;
--error 4012
REPLACE /*+ QUERY_TIMEOUT(1) */ INTO t2 SELECT 1;
--error 4012
UPDATE /*+ QUERY_TIMEOUT(1) */ t2 SET i = 1;
--error 4012
DELETE /*+ QUERY_TIMEOUT(1) */ FROM t2 WHERE i = 1;
--enable_result_log

DROP TABLE t1, t2;

--error 4012
SELECT 1 FROM (SELECT /*+ QUERY_TIMEOUT(10) */ 1) a;

DELIMITER |;
CREATE FUNCTION f1() RETURNS INT BEGIN SELECT /*+ QUERY_TIMEOUT(10) */ 1
INTO @a; RETURN 1; END|
DELIMITER ;|
DROP FUNCTION f1;
