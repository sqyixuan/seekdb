disconnect default;
####connect(default, localhost, root,,);
connect(default,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

--error 1064
ROLLBACK RELEASE;
disconnect default;
####connect(default, localhost, root,,);
connect(default,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

####--error ER_PARSE_ERROR
--error 1064
ROLLBACK CHAIN RELEASE;

####--error ER_PARSE_ERROR
--error 1064
ROLLBACK NO CHAIN RELEASE;
disconnect default;
####connect(default, localhost, root,,);
connect(default,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

####--error ER_PARSE_ERROR
--error 1064
ROLLBACK AND NO RELEASE;

####--error ER_PARSE_ERROR
--error 1064
ROLLBACK AND RELEASE;

--error 1064
ROLLBACK NO RELEASE;

####--error ER_PARSE_ERROR
--error 1064
ROLLBACK CHAIN NO RELEASE;

####--error ER_PARSE_ERROR
