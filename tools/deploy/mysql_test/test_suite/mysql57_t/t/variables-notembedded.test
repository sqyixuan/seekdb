--echo #
--echo # Bug #11766769 : 59959: SMALL VALUES OF --MAX-ALLOWED-PACKET 
--echo #   ARE NOT BEING HONORED
--echo #

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1 (a MEDIUMTEXT);

SET GLOBAL max_allowed_packet=2048;
SET GLOBAL net_buffer_length=4096;
####CONNECT (con1,localhost,root,,test);
connect(con1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
SHOW SESSION VARIABLES LIKE 'max_allowed_packet';
SHOW SESSION VARIABLES LIKE 'net_buffer_length';
--disable_query_log
--error ER_NET_PACKET_TOO_LARGE,2013
INSERT INTO t1 VALUES ('');
--enable_query_log

CONNECTION default;
DISCONNECT con1;
SELECT LENGTH(a) FROM t1;

SET GLOBAL max_allowed_packet=default;
SET GLOBAL net_buffer_length=default;
DROP TABLE t1;

--echo End of 5.1 tests
