result_format: 4


alter system set _use_odps_jni_connector = false;

drop table if exists t1,t3;
CREATE EXTERNAL TABLE t1(
c1 array(TINYINT),
c2 array(SMALLINT),
c3 array(INT),
c4 array(BIGINT),
c5 array(FLOAT),
c6 array(DOUBLE),
c7 array(VARCHAR(10)),
c8 array(VARCHAR(100))
)
PROPERTIES = (
TYPE = 'ODPS'
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
PROJECT_NAME = "mysqltest_regression_sqlqa"
TABLE_NAME = 'yt_array1',
API_MODE = 'TUNNEL_API',
QUOTA_NAME = '',
COMPRESSION_CODE = ''
);

CREATE EXTERNAL TABLE t3(
c1 array(array(TINYINT)),
c2 array(array(SMALLINT)),
c3 array(array(INT)),
c4 array(array(BIGINT)),
c5 array(array(FLOAT)),
c6 array(array(DOUBLE)),
c7 array(array(VARCHAR(10))),
c8 array(array(VARCHAR(100)))
)
PROPERTIES = (
TYPE = 'ODPS'
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
PROJECT_NAME = "mysqltest_regression_sqlqa"
TABLE_NAME = 'yt_array2',
API_MODE = 'TUNNEL_API',
QUOTA_NAME = '',
COMPRESSION_CODE = ''
);

