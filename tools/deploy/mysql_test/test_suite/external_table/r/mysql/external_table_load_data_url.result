## 2. csv
create table csv_ex_t1(
    c1            varchar(100),
    c2            varchar(100),
    c3            varchar(100),
    c4            varchar(100)
);

load data  /*+ direct(true,0) parallel(2)*/
from files(
    location = "mysqltest_data_for_external_table/external_table_mock_log", 
    FORMAT (
        type = 'csv',
        field_delimiter = ',',
        SKIP_BLANK_LINES = TRUE
    ))
into table csv_ex_t1
;

select * from csv_ex_t1 order by c1, c3;
+----------------------------+--------------------------------+--------+----------------------------------------+
| c1                         | c2                             | c3     | c4                                     |
+----------------------------+--------------------------------+--------+----------------------------------------+
