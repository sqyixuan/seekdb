## 3. parquet
create table parquet_ex_t1(
c1 decimal(6,3),
c2 decimal,
c3 date,
c4 timestamp
);

load data  /*+ direct(true,0) parallel(2)*/
from (select decimal32, decimal64, date, timestamp from 
    files(location = 'mysqltest_data_for_external_table/parquet_ex_t1',
    FORMAT ( type = 'PARQUET')))
into table parquet_ex_t1 (c1, c2, c3, c4);

select * from parquet_ex_t1 order by c4 desc, c3 desc limit 10;
+--------+-----------+------------+---------------------+
| c1     | c2        | c3         | c4                  |
+--------+-----------+------------+---------------------+
| 90.499 | 904990000 | 2115-09-04 | 2024-06-18 12:12:45 |
| 80.499 | 804990000 | 2105-09-06 | 2024-06-18 12:12:45 |
| 70.499 | 704990000 | 2095-09-08 | 2024-06-18 12:12:45 |
| 60.499 | 604990000 | 2085-09-10 | 2024-06-18 12:12:45 |
| 50.499 | 504990000 | 2075-09-13 | 2024-06-18 12:12:45 |
| 40.499 | 404990000 | 2065-09-15 | 2024-06-18 12:12:45 |
| 30.499 | 304990000 | 2055-09-18 | 2024-06-18 12:12:45 |
| 20.499 | 204990000 | 2045-09-20 | 2024-06-18 12:12:45 |
| 10.499 | 104990000 | 2035-09-23 | 2024-06-18 12:12:45 |
|  0.499 |   4990000 | 2025-09-25 | 2024-06-18 12:12:45 |
+--------+-----------+------------+---------------------+

drop table parquet_ex_t1;
