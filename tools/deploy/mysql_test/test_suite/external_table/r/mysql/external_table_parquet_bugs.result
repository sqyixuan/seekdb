CREATE EXTERNAL TABLE `dim_goods_id_info_full_h_external` (
`goods_id` BIGINT(40) COMMENT'商品id',
`goods_no` BIGINT(40) COMMENT'商品货号',
`goods_name` VARCHAR(16383) COMMENT'商品名字',
`goods_img` VARCHAR(16383) COMMENT'商品图片',
`goods_kh` VARCHAR(511) COMMENT'款号',
`goods_type` BIGINT(40) COMMENT'商品类型{1:特价,}',
`goods_type_desc` VARCHAR(511) COMMENT'是否特价',
`goods_desc` VARCHAR(16383) COMMENT'商品详情',
`goods_middle` VARCHAR(2047),
`goods_model_id` BIGINT(40) COMMENT'商品使用的商品模型id',
`goods_number` BIGINT(40),
`goods_status` BIGINT(40),
`goods_status_desc` VARCHAR(511) COMMENT'是否断货',
`goods_tag` VARCHAR(511),
`goods_thumb` VARCHAR(2047),
`goods_weight` DOUBLE,
`goods_lib_weight` DOUBLE COMMENT'商品库表中的商品重量',
`goods_dept` VARCHAR(511) COMMENT'商品部门',
`style_id` BIGINT(40) COMMENT'样式id',
`grade_id` BIGINT(40) COMMENT'档次{1:高档, 2:中高档, 3:中档, 4:中低档, 5:低档}',
`grade_desc` VARCHAR(511) COMMENT'商品档次',
`special_status` BIGINT(40) COMMENT'专场状态：1未开始，2正在拼，3已结束',
`special_status_desc` VARCHAR(511) COMMENT'专场状态',
`is_alone` BIGINT(40) COMMENT'是否可用一手币购买{0:否,1:是}',
`is_hot` BIGINT(40),
`is_sale` BIGINT(40) COMMENT'专场结束时在售商品',
`is_on_sale` BIGINT(40) COMMENT'是否上架',
`is_on_sale_desc` VARCHAR(511) COMMENT'是否上架{是;否}',
`is_replenish` BIGINT(40) COMMENT'上架来源{0:普通商品,1:补货,2:组货上架,}',
`is_show_stock` BIGINT(40) COMMENT'是否显示库存',
`is_stockout` BIGINT(40) COMMENT'是否售罄',
`sort_order` BIGINT(40),
`max_sales` BIGINT(40) COMMENT'最大销量',
`picker_group` BIGINT(40) COMMENT'买手组编码',
`picker_group_code` VARCHAR(511) COMMENT'买手买助代号',
`provider_id` BIGINT(40),
`provider_name` VARCHAR(1023),
`video_status` BIGINT(40) COMMENT'是否是小视频商品',
`video_url` VARCHAR(2047) COMMENT'视频地址',
`vip_discount` BIGINT(40) COMMENT'vip会员专享折扣',
`season` BIGINT(40) COMMENT'季节{1:春, 2:夏, 3:秋, 4:冬}',
`season_desc` VARCHAR(511) COMMENT'商品季节',
`special_id` BIGINT(40) COMMENT'专场id',
`special_period` BIGINT(40) COMMENT'专场期数',
`cat_id` BIGINT(40) COMMENT'品类id',
`cat_name` VARCHAR(511) COMMENT'品类名称',
`second_cat_id` BIGINT(40) COMMENT'二级品类id',
`second_cat_name` VARCHAR(511) COMMENT'二级品类',
`primary_cat_id` BIGINT(40) COMMENT'一级品类id',
`primary_cat_name` VARCHAR(511) COMMENT'一级品类',
`brand_id` BIGINT(40) COMMENT'品牌id',
`brand_tag` VARCHAR(511) COMMENT'品牌标签',
`supply_id` BIGINT(40) COMMENT'供应商id',
`supply_name` VARCHAR(1023) COMMENT'供应商名称',
`is_platform` VARCHAR(511) COMMENT'是否平台化商家',
`market_id` BIGINT(40) COMMENT'市场id',
`market_name` VARCHAR(511) COMMENT'市场名称',
`primary_market_id` BIGINT(40) COMMENT'一级市场id',
`primary_market_name` VARCHAR(511) COMMENT'一级市场',
`big_market` VARCHAR(511) COMMENT'大市场',
`pg_id` BIGINT(40) COMMENT'买手组id',
`pg_code` VARCHAR(511) COMMENT'买手组代号',
`pg_name` VARCHAR(511) COMMENT'买手组名称',
`pgm_code` VARCHAR(511) COMMENT'买手代号',
`pgm_name` VARCHAR(511) COMMENT'买手姓名',
`pgid` BIGINT(40) COMMENT'采购组id',
`market_price` DOUBLE COMMENT'活动拿货价',
`shop_price` DOUBLE COMMENT'商品价格',
`act_market_price` DOUBLE COMMENT'实际拿货价',
`act_shoppe_price` DOUBLE COMMENT'活动专柜价',
`act_prefer_price` DOUBLE COMMENT'活动预设价',
`act_shop_price` DOUBLE COMMENT'活动销售价',
`level_shop_price` VARCHAR(511) COMMENT'价格区间',
`level_shop_price_2` VARCHAR(511) COMMENT'价格区间2',
`special_start_rank` BIGINT(40) COMMENT'上架顺序',
`special_start_time` VARCHAR(511) COMMENT'专场开始时间',
`special_end_time` VARCHAR(511) COMMENT'专场结束时间',
`is_video` BIGINT(40) COMMENT'是否小视频{1:是,0:否}',
`admin_name` VARCHAR(511) COMMENT'上架人',
`putaway_type` VARCHAR(511) COMMENT'上架方式:人工上架,用户主动补货,阿尔法上架',
`putaway_channel` VARCHAR(511) COMMENT'上架渠道:现货上架,用户补货,正常上架（判断优先级:现货上架>用户补货>正常上架）',
`shoppe_discount` DOUBLE COMMENT'折扣',
`shoppe_price` DOUBLE COMMENT'专柜价【高于销售价】',
`shoppe_price_before_discount` DOUBLE COMMENT'折前价',
`alone_discount` DOUBLE COMMENT'一手币折扣',
`alone_price` DOUBLE COMMENT'一手币价格',
`original_price` DOUBLE COMMENT'销售原始价',
`origin` BIGINT(40) COMMENT'商品发货地',
`origin_desc` VARCHAR(511) COMMENT'商品发货地',
`is_bargain` BIGINT(40) COMMENT'是否特价{1:是,0:否}',
`is_bargain_desc` VARCHAR(511) COMMENT'是否特价{是;否}',
`is_new` BIGINT(40) COMMENT'是否新款{1:是,0:否}',
`is_new_desc` VARCHAR(511) COMMENT'是否新款{是;否}',
`is_supply_first_up` BIGINT(40) COMMENT'是否供应商首次自主上款{1:是,0:否}',
`is_supply_up` BIGINT(40) COMMENT'是否供应商自主上款{1:是,0:否}',
`is_in_stock` BIGINT(40) COMMENT'是否现货{1:是,0:否}',
`is_in_stock_desc` VARCHAR(511) COMMENT'是否现货{是,否}',
`is_in_stock_detail` VARCHAR(511) COMMENT'是否现货{现货上架,预售上架}',
`is_today_first_live` BIGINT(40) COMMENT'是否当天首次直播{1:是,0:否}',
`is_live` BIGINT(40) COMMENT'是否直播商品（商品款直播过，以后的商品id都记为直播商品）{1:是,0:否}',
`is_today_live` BIGINT(40) COMMENT'是否当天直播款{1:是,0:否}',
`is_live_room` BIGINT(40) COMMENT'是否直播间开始时对应的商品id{1:是,0:否}',
`is_valid` BIGINT(40) COMMENT'是否有效{1:是,0:否}',
`activity_goods` VARCHAR(511) COMMENT'是否活动商品{是;否}',
`sales_num` BIGINT(40) COMMENT'刷单销量',
`real_sales_num` BIGINT(40) COMMENT'实际销量',
`group_num` BIGINT(40) COMMENT'成团数量',
`dscnt_shoppe_price` DOUBLE COMMENT'专柜价',
`dscnt_price_spot` DOUBLE COMMENT'现货折扣',
`dscnt_price_seckill` DOUBLE COMMENT'秒杀折扣',
`is_tail_dscn_goods` VARCHAR(511) COMMENT'是否尾货折销商品{是;否}',
`origin_name` VARCHAR(511) COMMENT'商品发货地中文名称',
`grade` BIGINT(40) COMMENT'商品档次{1:高档,2:中高档,3:中档,4:中低档,5:低档,}',
`grade_name` VARCHAR(511) COMMENT'商品档次中文:低档,中低档,中档,中高档,高档',
`special_date` VARCHAR(511) COMMENT'专场日期',
`extra_price` DOUBLE COMMENT'加价',
`old_price` DOUBLE COMMENT'原价',
`supplier_id` BIGINT(40) COMMENT'旧档口ID',
`special_type` BIGINT(40) COMMENT'专场类型{1:今日专场,2:店主补货,11:7日爆款,12:工厂直供,13:新人专享,21:app活动,23:直播,}',
`special_style_type` BIGINT(40) COMMENT'专场风格',
`special_style_type_desc` VARCHAR(511) COMMENT'专场风格详情',
`special_name` VARCHAR(1023) COMMENT'专场名称',
`replenish_type` VARCHAR(511) COMMENT'上架渠道',
`add_time` VARCHAR(511) COMMENT'商品添加时间',
`update_time` VARCHAR(511) COMMENT'更新时间',
`special_show` BIGINT(40) COMMENT'是否展示 {0:不展示,1:展示}',
`goods_no_admin_name` VARCHAR(511) COMMENT'商品库表的添加人姓名',
`purchaser_id` VARCHAR(511) COMMENT'采购组ID',
`purchaser_name` VARCHAR(511) COMMENT'采购组',
`purchaser_member_id` VARCHAR(511) COMMENT'采购员ID',
`purchaser_member_name` VARCHAR(511) COMMENT'采购员',
`dg_id` VARCHAR(511) COMMENT'次品组ID',
`dg_name` VARCHAR(511) COMMENT'次品组',
`dgm_id` VARCHAR(511) COMMENT'市场专场/次品专员ID',
`dgm_name` VARCHAR(511) COMMENT'市场专场/次品专员',
`follower_id` VARCHAR(511) COMMENT'商运ID',
`follower_name` VARCHAR(511) COMMENT'商运',
`vendor_supply_id` BIGINT(40) COMMENT'渠道商ID',
`department` VARCHAR(511) COMMENT'部分',
`sub_department` VARCHAR(511) COMMENT'细分部门',
`comprhs_rank_level_mt` VARCHAR(511) COMMENT'商品力商家排名层级',
`last_month_sales_tier` VARCHAR(511) COMMENT'上月商家累计业绩排名层级',
`current_month_sales_tier` VARCHAR(511) COMMENT'当月商家累计业绩排名层级',
`salenum_type` VARCHAR(511) COMMENT'爆涨平滞',
`real_stock_num` BIGINT(40) COMMENT'该货号当天实际库存',
`is_wide_stock` BIGINT(40) COMMENT'是否广义现货, 1是0否',
`drawing_img` VARCHAR(1023) COMMENT'版型图片',
`drawing_name` VARCHAR(511) COMMENT'版型名称',
`goods_rank_level` VARCHAR(511) COMMENT'商品排名等级',
`sale_age` BIGINT(40) COMMENT'售龄'
)LOCATION ='#OSS_HOST#:#OSS_ACCESS_ID#@#OSS_ACCESS_KEY#/antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/issue2024110400104944070'
