Table	Create Table
lineitem	CREATE EXTERNAL TABLE `lineitem` (
  `l_orderkey` int(11) GENERATED ALWAYS AS (metadata$filecol1),
  `l_partkey` int(11) GENERATED ALWAYS AS (metadata$filecol2),
  `l_suppkey` int(11) GENERATED ALWAYS AS (metadata$filecol3),
  `l_linenumber` int(11) GENERATED ALWAYS AS (metadata$filecol4),
  `l_quantity` decimal(15,2) GENERATED ALWAYS AS (metadata$filecol5),
  `l_extendedprice` decimal(15,2) GENERATED ALWAYS AS (metadata$filecol6),
  `l_discount` decimal(15,2) GENERATED ALWAYS AS (metadata$filecol7),
  `l_tax` decimal(15,2) GENERATED ALWAYS AS (metadata$filecol8),
  `l_returnflag` char(1) GENERATED ALWAYS AS (metadata$filecol9),
  `l_linestatus` char(1) GENERATED ALWAYS AS (metadata$filecol10),
  `l_shipdate` date GENERATED ALWAYS AS (metadata$filecol11),
  `l_commitdate` date GENERATED ALWAYS AS (metadata$filecol12),
  `l_receiptdate` date GENERATED ALWAYS AS (metadata$filecol13),
  `l_shipinstruct` char(25) GENERATED ALWAYS AS (metadata$filecol14),
  `l_shipmode` char(10) GENERATED ALWAYS AS (metadata$filecol15),
  `l_comment` varchar(44) GENERATED ALWAYS AS (metadata$filecol16),
  `l_dummy` varchar(44) GENERATED ALWAYS AS (metadata$filecol17)
) 
