result_format: 4
drop table if exists t_string_part, t_string_part1;
create  external table t_string_part (
c1 int,
pdate string AS (metadata$partition_list_col1)
)
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="t_string_part"
)
partition by (pdate);

create  external table t_string_part1 (
c1 int,
pyear string AS (metadata$partition_list_col1),
pmonth string AS (metadata$partition_list_col2)
)
PROPERTIES =(
type = "odps"
#ODPS_ACCESSID#
#ODPS_ACCESSKEY#
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "http://service.cn-hangzhou.maxcompute.aliyun.com/api"
TABLE_NAME ="t_string_part1"
)
partition by (pyear, pmonth);

