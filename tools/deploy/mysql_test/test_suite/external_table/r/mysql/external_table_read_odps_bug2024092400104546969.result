result_format: 4
## test show create table and partition table
drop table if exists ailing_t1p;
CREATE EXTERNAL TABLE ailing_t1p (
  c1 int,
  c2 varchar(10) AS (metadata$partition_list_col1),
  c3 int AS (metadata$partition_list_col2)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID='#ODPS_ACCESSID#'
ACCESSKEY='#ODPS_ACCESSKEY#'
ENDPOINT='#ODPS_ENDPOINT#'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'ailing_t1p'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
)
charset utf8mb4 collate utf8mb4_bin
partition by (c2, c3);
select * from ailing_t1p;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
+------+------+------+
show create table ailing_t1p;
Table	Create Table
ailing_t1p	CREATE EXTERNAL TABLE `ailing_t1p` (
  `c1` int(11) GENERATED ALWAYS AS (external$tablecol1),
  `c2` varchar(10) COLLATE utf8mb4_bin GENERATED ALWAYS AS (metadata$partition_list_col1),
  `c3` int(11) GENERATED ALWAYS AS (metadata$partition_list_col2)
) 
AUTO_REFRESH = OFF
PROPERTIES (
  TYPE = 'ODPS',
  ACCESSTYPE = '',
  ACCESSID = '********',
  ACCESSKEY = '********',
  ENDPOINT = 'http://service.cn-hangzhou.maxcompute.aliyun.com/api',
  TUNNEL_ENDPOINT = '',
  PROJECT_NAME = 'mysqltest_regression_sqlqa',
  SCHEMA_NAME = '',
  TABLE_NAME = 'ailing_t1p',
  QUOTA_NAME = '',
  COMPRESSION_CODE = '',
  COLLECT_STATISTICS_ON_CREATE = FALSE,
  REGION = '',
  API_MODE = 'tunnel_api'
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin
 partition by (c2, c3)
drop table if exists ailing_t1p;
