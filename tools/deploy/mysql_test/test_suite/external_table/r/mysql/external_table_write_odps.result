  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2])
  2 - output([t1_.c1], [t1_.c2]), filter(nil), rowset=16
      access([t1_.c1], [t1_.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1_.__pk_increment]), range(MIN ; MAX)always true
explain insert /*+parallel(5)*/ into t1 select * from t1_;
