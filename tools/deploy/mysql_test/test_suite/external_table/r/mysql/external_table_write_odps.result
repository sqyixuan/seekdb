CREATE EXTERNAL TABLE test_part (
 c1             int AS (external$tablecol1),
 c2             int AS (external$tablecol2),
 c3          varchar(20) AS (metadata$partition_list_col1)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID='#ODPS_ACCESSID#'
ACCESSKEY='#ODPS_ACCESSKEY#'
ENDPOINT='#ODPS_ENDPOINT#'
TUNNEL_ENDPOINT='#TUNNEL_ENDPOINT#'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_part'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
)
partition by (c3)
;

create table test_part_(c1 int, c2 int);

insert overwrite test_part partition (c3='abc') select * from test_part_;
insert overwrite test_part partition (c3='def') select * from test_part_;
insert /*+parallel(3)*/ overwrite test_part partition (c3='p3') select * from test_part_;
insert /*+parallel(3)*/ overwrite test_part partition (c3='p4') select * from test_part_;

insert into test_part_ values(1,2),(2,3),(3,4);

insert into test_part partition (c3='abc') select * from test_part_;
insert into test_part partition (c3 = 'def') select * from test_part_;
insert /*+parallel(3)*/ into test_part partition (c3 ='p3') select * from test_part_;
insert /*+parallel(3)*/ into test_part partition (c3= 'p4') select * from test_part_;

alter external table test_part refresh;
set ob_query_timeout=1000000000;
select * from test_part;
