drop table test_part;

CREATE EXTERNAL TABLE test_part (
    c1 int AS (external$tablecol1),
    c2 varchar(500) AS (external$tablecol2),
    c3 varchar(500) AS (external$tablecol3),
    c4 varchar(500) AS (external$tablecol4),
    c5 varchar(500) AS (external$tablecol5),
    c6 varchar(10) AS (metadata$partition_list_col1),
    c7 int AS (metadata$partition_list_col2)
)
PROPERTIES = (
REGION = 'shanghai'
TYPE = 'ODPS'
ACCESSID='#ODPS_ACCESSID#'
ACCESSKEY='#ODPS_ACCESSKEY#'
ENDPOINT='#ODPS_ENDPOINT#'
TUNNEL_ENDPOINT='#TUNNEL_ENDPOINT#'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_performance3'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
)
partition by (c6,c7)
;

insert overwrite test_part partition (c6='20201010',c7=12345678) select 1,'a','b','c','d' from dual;
alter external table test_part refresh;
select * from test_part;
+------+------+------+------+------+----------+----------+
| c1   | c2   | c3   | c4   | c5   | c6       | c7       |
+------+------+------+------+------+----------+----------+
|    1 | a    | b    | c    | d    | 20201010 | 12345678 |
+------+------+------+------+------+----------+----------+



create external table t1_csv (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
insert into t1_csv select 1,2,3 from dual;
ERROR 0A000: insert into external table which is not in odps not supported

create external table t1_parquet (
    c1 bigint as (cast(get_path(external$filerow, 'int') as signed)),
    c2 varchar(1000) as (cast(get_path(external$filerow, 'string') as char)),
    c3 decimal(6,3) as (cast(get_path(external$filerow, 'decimal32') as decimal(6,3))),
    c4 decimal as (cast(get_path(external$filerow, 'decimal64') as decimal)),
    c6 date as (cast(get_path(external$filerow, 'date') as date))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table/parquet_ex_t1';
insert into t1_parquet select null,null,null,null,null from dual;
ERROR 0A000: insert into external table which is not in odps not supported

drop table t1, t1_, t2, t2_, t3, t3_, test_date, test_date_, test_part, test_part_, t1_csv, t1_parquet;


set ob_query_timeout=10000000;

