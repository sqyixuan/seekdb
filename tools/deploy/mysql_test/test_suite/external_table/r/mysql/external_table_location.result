/***************************privilege test********************************/
create user user_1 identified by 'ttt';
grant create,select,drop on *.* to user_1;
grant use catalog on *.* to user_1;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location = @local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
ERROR HY000: Location access denied

select * from FILES(LOCATION = @oss_t, FORMAT(TYPE = 'PARQUET') pattern='decimal38_0.parquet');
ERROR HY000: Location access denied

create location priv_t url = 'file://test';
ERROR 42501: Access denied; you need (at least one of) the CREATE LOCATION privilege(s) for this operation

grant read on location local_t to user_1;
grant read on location oss_t to user_1;
grant create location on *.* to user_1;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location = @local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

select * from ex_t1;
