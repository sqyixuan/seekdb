create location priv_t url = 'file://test';

revoke read on location local_t from user_1;
revoke read on location oss_t from user_1;
revoke create location on *.* from user_1;

select * from ex_t1;
ERROR HY000: Location access denied

select * from FILES(LOCATION = @oss_t, FORMAT(TYPE = 'PARQUET') pattern='decimal38_0.parquet');
ERROR HY000: Location access denied

drop location priv_t;
ERROR 42501: Access denied; you need (at least one of) the CREATE LOCATION privilege(s) for this operation

drop table ex_t1;


drop user user_1@'%';
drop location local_t;
drop location local_t1;
drop location oss_t;
drop location priv_t;

desc oceanbase.__all_virtual_tenant_location;
+----------------------+---------------+------+-----+---------+-------+
| Field                | Type          | Null | Key | Default | Extra |
+----------------------+---------------+------+-----+---------+-------+
| tenant_id            | bigint(20)    | NO   | PRI | NULL    |       |
| location_id          | bigint(20)    | NO   | PRI | NULL    |       |
| gmt_create           | timestamp(6)  | NO   |     | NULL    |       |
| gmt_modified         | timestamp(6)  | NO   |     | NULL    |       |
| location_name        | varchar(128)  | NO   |     |         |       |
| location_url         | varchar(4000) | NO   |     |         |       |
| location_access_info | varchar(8000) | NO   |     |         |       |
+----------------------+---------------+------+-----+---------+-------+
