deallocate prepare stmt1;
prepare stmt1 from 'delete from ex_t1 where c1 > ?';
ERROR 0A000: DML operation on External Table not supported
prepare stmt1 from 'insert into ex_t1 values(10,10,?)';
ERROR 0A000: insert into external table with values, replace, ignore, returning, update not supported
prepare stmt1 from 'update ex_t1 set c1 = ? where c1 > ?';
