prepare stmt1 from 'alter table ex_t1 rename new_ext1';
ERROR 0A000: alter table type not supported
prepare stmt1 from 'rename table ex_t1 to new_ex_t1';
execute stmt1;
deallocate prepare stmt1;
rename table new_ex_t1 to ex_t1;
prepare stmt1 from 'create index idx1 on ex_t1 (c1)';
ERROR 0A000: operation on external table not supported
prepare stmt1 from 'show create table ex_t1';
execute stmt1;
Table	Create Table
ex_t1	CREATE EXTERNAL TABLE `ex_t1` (
  `c1` int(11) GENERATED ALWAYS AS (metadata$filecol1),
  `c2` int(11) GENERATED ALWAYS AS (metadata$filecol2),
  `c3` int(11) GENERATED ALWAYS AS (metadata$filecol3)
) 
LOCATION='file://mysqltest_data_for_external_table/external_table_lineitem'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'CSV',
  LINE_DELIMITER = NVL(NULL, 'b'),
  FIELD_DELIMITER = UPPER('a'),
  ENCODING = 'utf8mb4',
  NULL_IF = (NVL(NULL, 'NULL'),UPPER('c'))
) DEFAULT CHARSET = utf8mb4
deallocate prepare stmt1;
prepare stmt1 from 'truncate table ex_t1';
