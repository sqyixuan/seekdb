show create table ex_t1;
Table	Create Table
ex_t1	CREATE EXTERNAL TABLE `ex_t1` (
  `c1` int(11) GENERATED ALWAYS AS (metadata$filecol1),
  `c2` int(11) GENERATED ALWAYS AS (metadata$filecol2),
  `c3` int(11) GENERATED ALWAYS AS (metadata$filecol3)
) 
LOCATION='file://mysqltest_data_for_external_table/external_table_lineitem'
PATTERN='temp[0-3].dat'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'CSV',
  LINE_DELIMITER = NVL(NULL, 'b'),
  FIELD_DELIMITER = UPPER('a'),
  ENCODING = 'utf8mb4',
  NULL_IF = (NVL(NULL, 'NULL'),UPPER('c'))
) DEFAULT CHARSET = utf8mb4
