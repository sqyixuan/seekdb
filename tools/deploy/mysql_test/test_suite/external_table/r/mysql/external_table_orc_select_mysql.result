select col_int,col_date,col_double,col_date from 
files (
location = 'mysqltest_data_for_external_table/orc',
format (type = 'ORC '),
pattern = 'all.orc'
  )where col_int IN
(SELECT col_int FROM 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC') pattern = 'all.orc')
WHERE col_varchar NOT IN ('1000') OR (col_double IN (NULL) AND col_date IS NOT NULL) OR col_string LIKE '%中文%')
;
