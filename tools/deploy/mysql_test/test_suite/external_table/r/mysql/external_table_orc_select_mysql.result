col_int INT,                   
col_bigint BIGINT ,         
col_float FLOAT,          
col_double DOUBLE,         
col_decimal DECIMAL(10,2), 
col_string STRING,         
col_varchar VARCHAR(50),   
col_char CHAR(10),      
col_boolean BOOLEAN,      
col_date DATE,             
col_timestamp TIMESTAMP
);
