result_format: 4
CREATE EXTERNAL TABLE `ex_compression_auto` (
  `time` datetime GENERATED ALWAYS AS (metadata$filecol1),
  `errstate` varchar(30) GENERATED ALWAYS AS (metadata$filecol2),
  `errcode` int(11) GENERATED ALWAYS AS (metadata$filecol3),
  `errcontent` varchar(100) GENERATED ALWAYS AS (metadata$filecol4)
)
LOCATION='file://mysqltest_data_for_external_table/compression_auto'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'CSV',
  FIELD_DELIMITER = ',',
  ENCODING = 'utf8mb4',
  SKIP_BLANK_LINES = TRUE,
  compression=auto
) DEFAULT CHARSET = utf8mb4;

alter external table ex_compression_auto refresh;

select * from ex_compression_auto order by errstate;
