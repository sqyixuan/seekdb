result_format: 4
drop table if exists t1;

CREATE EXTERNAL TABLE t1 (
c1 int,
tt int as (metadata$partition_list_col1)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID='#ODPS_ACCESSID#'
ACCESSKEY='#ODPS_ACCESSKEY#'
ENDPOINT='#ODPS_ENDPOINT#'
TUNNEL_ENDPOINT='#TUNNEL_ENDPOINT#'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 't_auto_add_part'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
)
partition by(tt);

insert overwrite t1 partition(tt = 1) select 1 from dual;
insert overwrite t1 partition(tt = 1) select 2 from dual;
insert overwrite t1 partition(tt = 2) select 3 from dual;

alter external table t1 refresh;
select * from t1;
+------+------+
| c1   | tt   |
+------+------+
|    2 |    1 |
|    3 |    2 |
+------+------+

drop table t1;
