result_format: 4
create external table lineitem
(
  l_orderkey     int,
  l_partkey      int,
  l_suppkey      int,
  l_linenumber   int,
  l_quantity     decimal(15,2),
  l_extendedprice  decimal(15,2),
  l_discount     decimal(15,2),
  l_tax          decimal(15,2),
  l_returnflag   char(1),
  l_linestatus   char(1),
  l_shipdate     date,
  l_commitdate   date,
  l_receiptdate  date,
  l_shipinstruct char(25),
  l_shipmode     char(10),
  l_comment      varchar(44)
) location 'mysqltest_data_for_external_table/lineitem_parquet' 
format (
type = 'parquet'
);

result_format: 1
select * from oceanbase.dba_ob_external_table_files where table_name = 'lineitem' order by FILE_SIZE;
