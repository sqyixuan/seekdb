drop table ex_t1;

create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

show create table ex_t1;
Table	Create Table
ex_t1	CREATE EXTERNAL TABLE `ex_t1` (
  `time` datetime GENERATED ALWAYS AS (metadata$filecol1),
  `errstate` varchar(30) GENERATED ALWAYS AS (metadata$filecol2),
  `errcode` int(11) GENERATED ALWAYS AS (metadata$filecol3),
  `errcontent` varchar(100) GENERATED ALWAYS AS (metadata$filecol4),
  `date_key` datetime GENERATED ALWAYS AS (substr(substr(metadata$fileurl,(instr(metadata$fileurl,'%') + 1)),1,10))
) 
LOCATION='file://mysqltest_data_for_external_table/external_table_mock_log'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'CSV',
  FIELD_DELIMITER = ',',
  ENCODING = 'utf8mb4',
  SKIP_BLANK_LINES = TRUE
) DEFAULT CHARSET = utf8mb4
 partition by (date_key)
