      access([EX_T1.C1], [EX_T1.C2], [EX_T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([EX_T1.__file_id], [EX_T1.__line_number]), range(MIN,MIN ; MAX,MAX)always true
