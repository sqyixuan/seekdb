--source mysql_test/include/external_table/delete_data_for_external_table.inc
--result_format 4
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--error 0,1051
drop table tt18;

--error 1235
CREATE EXTERNAL TABLE `tt18` (   `C1` varchar(10) GENERATED ALWAYS AS (GET_PATH(EXTERNAL$FILEROW,'string_col_null')),   `C2` varchar(10) GENERATED ALWAYS AS (GET_PATH(EXTERNAL$FILEROW,'string_col_not_null')) , part_col varchar(20) GENERATED ALWAYS AS (metadata$PARTITION_LIST_COL1))PARTITION_TYPE = USER_SPECIFIED LOCATION='file:///data/1/external_table'  PATTERN='%' AUTO_REFRESH = IMMEDIATE FORMAT (   TYPE = 'PARQUET' ) partition by(part_col);

CREATE EXTERNAL TABLE `tt18` (   `C1` varchar(10) GENERATED ALWAYS AS (GET_PATH(EXTERNAL$FILEROW,'string_col_null')),   `C2` varchar(10) GENERATED ALWAYS AS (GET_PATH(EXTERNAL$FILEROW,'string_col_not_null')) , part_col varchar(20) GENERATED ALWAYS AS (metadata$PARTITION_LIST_COL1))PARTITION_TYPE = USER_SPECIFIED LOCATION='file:///data/1/external_table'  PATTERN='%' AUTO_REFRESH = OFF FORMAT (   TYPE = 'PARQUET' ) partition by(part_col);

--error 1235
alter external table tt18 auto_refresh immediate;

--error 1235
alter external table tt18 auto_refresh interval;

alter external table tt18 auto_refresh OFF;


call dbms_external_table.auto_refresh_external_table(-1);
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
)
AUTO_REFRESH = OFF;

--source mysql_test/include/external_table/copy_data_for_external_table.inc
select * from ex_t1;

call dbms_external_table.auto_refresh_external_table(1);
select sleep(3);
select * from ex_t1;
alter external table ex_t1 refresh;
select * from ex_t1;


--source mysql_test/include/external_table/delete_data_for_external_table.inc
drop table ex_t1;
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
)
AUTO_REFRESH = IMMEDIATE;

select * from ex_t1;
--source mysql_test/include/external_table/copy_data_for_external_table.inc
select * from ex_t1;

--source mysql_test/include/external_table/delete_data_for_external_table.inc
drop table ex_t1;
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
)
AUTO_REFRESH = INTERVAL;

select * from ex_t1;
--source mysql_test/include/external_table/copy_data_for_external_table.inc
call dbms_external_table.auto_refresh_external_table(3);
select job_name, repeat_interval from oceanbase.__all_tenant_scheduler_job where job_name='auto_refresh_external_table_job' and job > 0;

select sleep(1);
select * from ex_t1;
select sleep(1);
select * from ex_t1;
select sleep(9);
select sleep(9);
select * from ex_t1;

select job_name, repeat_interval, state from oceanbase.__all_tenant_scheduler_job where job_name='auto_refresh_external_table_job' and job > 0;
--source mysql_test/include/external_table/delete_data_for_external_table.inc
select * from ex_t1;

call dbms_external_table.auto_refresh_external_table(10);
select job_name, repeat_interval from oceanbase.__all_tenant_scheduler_job where job_name='auto_refresh_external_table_job' and job > 0;

call dbms_external_table.auto_refresh_external_table(-1);
select job_name, repeat_interval from oceanbase.__all_tenant_scheduler_job where job_name='auto_refresh_external_table_job' and job > 0;

alter external table ex_t1 auto_refresh interval;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
alter external table ex_t1 auto_refresh immediate;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;

drop table ex_t1;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
AUTO_REFRESH = IMMEDIATE
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

show create table ex_t1;

