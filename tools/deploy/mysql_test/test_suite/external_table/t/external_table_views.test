# owner: jim.wjh
# owner group: SQL3
# tags: external_table, inner_table
# description: test external table privilege

--source mysql_test/include/external_table/copy_data_for_external_table.inc
--enable_sorted_result
--disable_query_log
--disable_warnings

--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table tmp;
--error 0,1396
drop user user_1@'%';

create table tmp(c1 int);

create external table t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

create external table t2 (
    c1 int,
    c2 int,
    c3 int,
    partkey int as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 5, 1))
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
)
partition by (partkey);

--enable_query_log
--enable_warnings

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T1';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T2';

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.DBA_OB_EXTERNAL_TABLE_FILES where table_name='T1';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.DBA_OB_EXTERNAL_TABLE_FILES where table_name='T2';

select table_name, table_type from information_schema.tables where table_name = 't1';
select table_name, table_type from information_schema.tables where table_name = 't2';


create user user_1 identified by 'ttt';
grant select on test.tmp to user_1;
grant select on oceanbase.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T1';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T2';

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.DBA_OB_EXTERNAL_TABLE_FILES where table_name='T1';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.DBA_OB_EXTERNAL_TABLE_FILES where table_name='T2';

disconnect user_1;
connection default;
grant select on test.t1 to user_1;
grant select on test.t2 to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T1';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.ALL_OB_EXTERNAL_TABLE_FILES where table_name='T2';

disconnect user_1;
connection default;
drop table t1;
drop table t2;
drop user user_1@'%';
drop table tmp;
--source mysql_test/include/external_table/delete_data_for_external_table.inc
