# owner: jim.wjh
# owner group: sql3
# tags: external_table
# description: test external table cross ps

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

--enable_query_log

prepare stmt1 from 'select * from ex_t1 where c1 > ?';
set @a = 5;
--sorted_result
execute stmt1 using @a;
deallocate prepare stmt1;
--error 1235
prepare stmt1 from 'delete from ex_t1 where c1 > ?';
--error 1235
prepare stmt1 from 'insert into ex_t1 values(10,10,?)';
--error 3105
prepare stmt1 from 'update ex_t1 set c1 = ? where c1 > ?';
--error 1235
prepare stmt1 from 'alter table ex_t1 rename new_ext1';

prepare stmt1 from 'rename table ex_t1 to new_ex_t1';
execute stmt1;
deallocate prepare stmt1;
rename table new_ex_t1 to ex_t1;

--error 1235
prepare stmt1 from 'create index idx1 on ex_t1 (c1)';
prepare stmt1 from 'show create table ex_t1';
--source mysql_test/include/show_create_table_old_version_replica2.inc
execute stmt1;
deallocate prepare stmt1;

--error 1235
prepare stmt1 from 'truncate table ex_t1';
# execute stmt1;
# deallocate prepare stmt1;

prepare stmt1 from 'drop table ex_t1';
execute stmt1;
deallocate prepare stmt1;

prepare stmt1 from 'create external table ex_t2 (c1 int) location=\'mysqltest_data_for_external_table/external_table_lineitem\' format (type = \'csv\')';
execute stmt1;
deallocate prepare stmt1;

prepare stmt1 from 'drop table ex_t2';
execute stmt1;
deallocate prepare stmt1;

--source mysql_test/include/external_table/delete_data_for_external_table.inc
