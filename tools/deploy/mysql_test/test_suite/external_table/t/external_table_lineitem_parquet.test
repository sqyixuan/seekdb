# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: parquet data for lineitem example

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table lineitem;
--error 0,1051
drop table lineitem_part;
--error 0,1051
--enable_query_log

--result_format 4

create external table lineitem
(
  l_orderkey     int,
  l_partkey      int,
  l_suppkey      int,
  l_linenumber   int,
  l_quantity     decimal(15,2),
  l_extendedprice  decimal(15,2),
  l_discount     decimal(15,2),
  l_tax          decimal(15,2),
  l_returnflag   char(1),
  l_linestatus   char(1),
  l_shipdate     date,
  l_commitdate   date,
  l_receiptdate  date,
  l_shipinstruct char(25),
  l_shipmode     char(10),
  l_comment      varchar(44)
) location 'mysqltest_data_for_external_table/lineitem_parquet' 
format (
type = 'parquet'
);

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.dba_ob_external_table_files where table_name = 'lineitem' order by FILE_SIZE;
--result_format 4

select * from lineitem order by l_orderkey;

select count(*) from lineitem;

create external table lineitem_part
(
  l_orderkey     int,
  l_partkey      int,
  l_suppkey      int,
  l_linenumber   int,
  l_quantity     decimal(15,2),
  l_extendedprice  decimal(15,2),
  l_discount     decimal(15,2),
  l_tax          decimal(15,2),
  l_returnflag   char(1),
  l_linestatus   char(1),
  l_shipdate     date,
  l_commitdate   date,
  l_receiptdate  date,
  l_shipinstruct char(25),
  l_shipmode     char(10),
  l_comment      varchar(44),
  l_shipyear     varchar(4) as (substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1, 4))
) location 'mysqltest_data_for_external_table/lineitem_part_parquet' 
format (
type = 'parquet'
)
partition by(l_shipyear);

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.dba_ob_external_table_files where table_name = 'lineitem_part' order by PARTITION_NAME;
--result_format 4

select * from lineitem_part order by l_orderkey;

select count(*), l_shipyear from lineitem_part group by l_shipyear;

drop table lineitem;
drop table lineitem_part;