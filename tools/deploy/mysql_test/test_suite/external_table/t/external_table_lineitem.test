# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test create external table. and external table schema's format info.

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--error 0,1051
drop table ex_t5;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

create external table ex_t2 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv'
);

create external table ex_t3 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = X'0A',
    field_delimiter = X'09',
    field_optionally_enclosed_by = '',
    escape = '\\',
    skip_blank_lines = false,
    trim_space = false,
    encoding = 'gbk',
    skip_header = 0,
    empty_field_as_null = false
);

create external table ex_t4 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(1+1, 'b'),
    field_delimiter = 'A',
    field_optionally_enclosed_by = NVL(NULL, ''),
    escape = '\\',
    null_if = (NVL(NULL, 'NULL'),UPPER('c'),'x'),
    skip_blank_lines = true,
    trim_space = false,
    encoding = 'gbk',
    skip_header = 0,
    empty_field_as_null = true
);

create external table ex_t5 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    FIELD_OPTIONALLY_ENCLOSED_BY = '"'
)
PATTERN = 'test03.csv';

--result_format 4
--enable_query_log

--sorted_result
select * from ex_t1;

select external_file_format from oceanbase.__all_virtual_table where table_name='ex_t1';
select external_file_format from oceanbase.__all_virtual_table where table_name='ex_t2';
select external_file_format from oceanbase.__all_virtual_table where table_name='ex_t3';
select external_file_format from oceanbase.__all_virtual_table where table_name='ex_t4';
select external_file_format from oceanbase.__all_virtual_table where table_name='ex_t5';

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t5;

select * from ex_t5;

--disable_query_log
--source mysql_test/include/external_table/delete_data_for_external_table.inc
drop table ex_t1;
drop table ex_t2;
drop table ex_t3;
drop table ex_t4;
drop table ex_t5;
