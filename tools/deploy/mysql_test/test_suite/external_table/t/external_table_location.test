--echo /***************************basic test********************************/
create or replace location local_t URL = 'file://mysqltest_data_for_external_table/external_table_lineitem';
create or replace location local_t1 URL = 'file://mysqltest_data_for_external_table';
--disable_query_log
eval create or replace location oss_t URL ='oss://antsys-antsys-oceanbase-rd-sql/jim.wjh/mysqltest_regression_data/issue2024121100106434847' CREDENTIAL = (ACCESSID = '$OSS_ACCESS_ID', ACCESSKEY = '$OSS_ACCESS_KEY', HOST = '$OSS_HOST');
--enable_query_log

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location=@local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

select * from ex_t1;
select * from FILES(LOCATION = @oss_t, FORMAT(TYPE = 'PARQUET') pattern='decimal38_0.parquet');
select * from FILES(LOCATION = @local_t1'/external_table_lineitem', FORMAT(
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
));

# 验证alter location
