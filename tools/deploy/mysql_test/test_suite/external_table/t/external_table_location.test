--source mysql_test/include/external_table/copy_data_for_external_table.inc

--result_format 4

--error 0,1051
drop table ex_t1;
--error 0, 11092
drop location local_t;
--error 0, 11092
drop location local_t1;
--error 0, 11092
drop location priv_t;
--error 0, 11092
drop location cafe;
--error 0, 11092
drop location verify_ddl_l;

--echo /***************************basic test********************************/
create or replace location local_t URL = 'file://mysqltest_data_for_external_table/external_table_lineitem';
create or replace location local_t1 URL = 'file://mysqltest_data_for_external_table';
--disable_query_log
--enable_query_log

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location=@local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

select * from ex_t1;
select * from FILES(LOCATION = @local_t1'/external_table_lineitem', FORMAT(
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
));

# 验证alter location
alter location local_t set url = 'file://mysqltest_data_for_external_table/external_table_lineitem_2';
select * from FILES(LOCATION = @local_t, FORMAT(
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
));
alter external table ex_t1 refresh;
select * from ex_t1;
alter location local_t set url = 'file://mysqltest_data_for_external_table/external_table_lineitem';
select * from FILES(LOCATION = @local_t, FORMAT(
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
));
alter external table ex_t1 refresh;
select * from ex_t1;

# 验证show
show grants;

show locations;

--echo /***************************privilege test********************************/

create user user_1 identified by 'ttt';
grant create,select,drop on *.* to user_1;
grant use catalog on *.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1@sys,ttt,test,$OBMYSQL_PORT);
connection user_1;

--error 11090
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location = @local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

--error 1227
create location priv_t url = 'file://test';

disconnect user_1;
connection default;
grant read on location local_t to user_1;
grant create location on *.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1@sys,ttt,test,$OBMYSQL_PORT);

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location = @local_t
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

select * from ex_t1;

create location priv_t url = 'file://test';

disconnect user_1;
connection default;
revoke read on location local_t from user_1;
revoke create location on *.* from user_1;
connect (user_1,$OBMYSQL_MS0,user_1@sys,ttt,test,$OBMYSQL_PORT);

--error 11090
select * from ex_t1;

--error 1227
drop location priv_t;

drop table ex_t1;

disconnect user_1;
connection default;

drop user user_1@'%';
drop location local_t;
drop location local_t1;
drop location priv_t;

desc oceanbase.__all_virtual_tenant_location;
desc oceanbase.__all_virtual_tenant_location_history;
desc oceanbase.__all_virtual_objauth_mysql;
desc oceanbase.__all_virtual_objauth_mysql_history;

