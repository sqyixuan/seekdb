# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test create external table. and external table schema's format info.

--source mysql_test/include/external_table/copy_data_for_external_table.inc


--result_format 4
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--error 0,1051
drop table ex_t5;

create external table ex_t1 (
    c1 varchar(10),
    c2 varchar(10),
    c3 varchar(10),
    ip varchar(100) as (substr(metadata$fileurl, 1, instr(metadata$fileurl, ':') - 1)),
    port varchar(100) as (substr(metadata$fileurl, instr(metadata$fileurl, ':') + 1, instr(metadata$fileurl, '%') - instr(metadata$fileurl, ':') - 1))
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

select c1, c2, c3, length(ip) >= length('0.0.0.0'), length(port) > 0 from ex_t1;
--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select a.metadata$fileurl, b.metadata$fileurl from ex_t1 a, ex_t1 b;
--source mysql_test/include/external_table/replace_ip_port.inc
select metadata$fileurl from ex_t1;
--result_format 4



--disable_query_log
--source mysql_test/include/external_table/delete_data_for_external_table.inc
drop table ex_t1;
