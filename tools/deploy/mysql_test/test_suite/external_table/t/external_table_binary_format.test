# owner: chendingchao.cdc
# owner group: SQL3
# tags: external_table
# description: test binary format for csv in external table.

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_binary_format;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists binary_format_test,binary_format_aes_test,ex_binary_format_hex_test,ex_binary_format_base64_test,ex_aes_binary_format_base64_test;
--enable_warnings

create table binary_format_test(c1 binary(10), c2 varbinary(15), c3 bit(6));
INSERT INTO binary_format_test VALUES ('cdc', 'chenchao.cdc', b'101010'), ('smith123', 'smith1234', b'101111'), ('danny', 'danny1234', b'000000');
select c1,c2,hex(c3) from binary_format_test;

create table binary_format_aes_test(c1 varbinary(128), c2 varbinary(128));
insert into binary_format_aes_test values (aes_encrypt('smith','123'), aes_encrypt('cruise','123')), (aes_encrypt('hello', '123'), aes_encrypt('world', '123'));
select aes_decrypt(c1, '123'), aes_decrypt(c2, '123') from binary_format_aes_test;

eval SELECT * FROM binary_format_test
into outfile '$DATA_FOLDER_NAME/csv_binary_format_hex.csv'
format = (
    TYPE = 'csv',
    binary_format = hex
) single=true;

eval SELECT * FROM binary_format_test
into outfile '$DATA_FOLDER_NAME/csv_binary_format_base64.csv'
format = (
    TYPE = 'csv',
    binary_format = base64
) single=true;

eval SELECT * FROM binary_format_aes_test
into outfile '$DATA_FOLDER_NAME/csv_aes_binary_format_base64.csv'
format = (
    TYPE = 'csv',
    binary_format = base64
) single=true;

eval create external table ex_binary_format_hex_test(
c1 binary(10), c2 varbinary(15), c3 bit(6)
)  format (type = 'csv', binary_format = 'hex') location '$DATA_FOLDER_NAME/' pattern='csv_binary_format_hex.csv';

eval create external table ex_binary_format_base64_test(
c1 binary(10), c2 varbinary(15), c3 bit(6)
)  format (type = 'csv', binary_format = 'base64') location '$DATA_FOLDER_NAME/' pattern='csv_binary_format_base64.csv';

eval create external table ex_aes_binary_format_base64_test(
c1 varbinary(128), c2 varbinary(128)
)  format (type = 'csv', binary_format = 'base64') location '$DATA_FOLDER_NAME/' pattern='csv_aes_binary_format_base64.csv';

--source mysql_test/include/select_into_outfile/list_dir.inc

show create table ex_binary_format_hex_test;
show create table ex_binary_format_base64_test;

select c1,c2,hex(c3) from ex_binary_format_hex_test;
select c1,c2,hex(c3) from ex_binary_format_base64_test;
select aes_decrypt(c1, '123'), aes_decrypt(c2, '123') from ex_aes_binary_format_base64_test;

drop table binary_format_test;
drop table binary_format_aes_test;
drop table ex_binary_format_hex_test;
drop table ex_binary_format_base64_test;
drop table ex_aes_binary_format_base64_test;

--source mysql_test/include/select_into_outfile/delete_dir.inc
