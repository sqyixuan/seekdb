#create table orc_table(c1 boolean, c2 tinyint, c3 smallint, c4 int, c5 bigint, c6 float, c7 double, c8 decimal(10, 3), c9 decimal(20,1), c10 string, c11 varchar(10), c12 char(10), c13 binary, c14 timestamp, c15 date) stored as orc;
#create table orc_table3(c1 boolean, c2 tinyint, c3 smallint, c4 int, c5 bigint, c6 float, c7 double, c8 decimal(10, 3), c9 decimal(20,1), c10 string, c11 varchar(100), c12 char(100), c13 binary, c14 timestamp, c15 date) stored as orc tblproperties ("orc.compress"="NONE", "orc.stripe.size"="10010");

create external table ex_t1(
c1 bool as (get_path(external$filerow, 'c1')),
c2 int as (get_path(external$filerow, 'c2')),
c3 int as (get_path(external$filerow, 'c3')),
c4 int as (get_path(external$filerow, 'c4')),
c5 bigint as (get_path(external$filerow, 'c5')),
c6 float as (get_path(external$filerow, 'c6')),
c7 double as (get_path(external$filerow, 'c7')),
c8 decimal(10,3) as (get_path(external$filerow, 'c8')),
c9 decimal(20,1) as (get_path(external$filerow, 'c9')),
c10 varchar(100) as (get_path(external$filerow, 'c10')),
c11 varchar(100) as (get_path(external$filerow, 'c11')),
c12 char(100) as (get_path(external$filerow, 'c12')),
c13 varchar(100) as (get_path(external$filerow, 'c13')),
c14 timestamp as (get_path(external$filerow, 'c14')),
c15 date as (get_path(external$filerow, 'c15')),
c16 datetime as (get_path(external$filerow, 'c14')),
c17 timestamp(3) as (get_path(external$filerow, 'c14'))
) format (type = 'ORC') location 'mysqltest_data_for_external_table/orc'
pattern = 't1.orc';

select * from ex_t1;

alter external table ex_t1 refresh;

drop table ex_t1;


create external table ex_t1(
c1 bool as (get_path(external$filerow, 'c1')),
c2 int as (get_path(external$filerow, 'c2')),
c3 int as (get_path(external$filerow, 'c3')),
c4 int as (get_path(external$filerow, 'c4')),
c5 bigint as (get_path(external$filerow, 'c5')),
c6 float as (get_path(external$filerow, 'c6')),
c7 double as (get_path(external$filerow, 'c7')),
c8 decimal(10,3) as (get_path(external$filerow, 'c8')),
c9 decimal(20,1) as (get_path(external$filerow, 'c9')),
c10 varchar(100) as (get_path(external$filerow, 'c10')),
c11 varchar(100) as (get_path(external$filerow, 'c11')),
c12 char(100) as (get_path(external$filerow, 'c12')),
c13 varchar(100) as (get_path(external$filerow, 'c13')),
c14 timestamp as (get_path(external$filerow, 'c14')),
c15 date as (get_path(external$filerow, 'c15')),
c16 datetime as (get_path(external$filerow, 'c14')),
c17 timestamp(3) as (get_path(external$filerow, 'c14')),
part_key varchar(10) as (substr(metadata$fileurl,0, 1))
) format (type = 'ORC') location 'mysqltest_data_for_external_table/orc' pattern = 't1.orc'
AUTO_REFRESH = IMMEDIATE
partition by (part_key);

select * from ex_t1;

drop table ex_t1;

