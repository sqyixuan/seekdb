# owner: yibo.tyf
# owner group: SQL1
# tags: external_table

--result_format 4
--source mysql_test/include/odps_config_for_cloud.inc

--disable_result_log
let $ODPS_CMD_DROPTAB = odpscmd -e "use mysqltest_regression_sqlqa;DROP TABLE IF EXISTS t_string_part; create table t_string_part (c1 int) PARTITIONED BY (pdate STRING);
insert into t_string_part partition(pdate) (c1,pdate) values(1, '20250101'),(2, '20250101'),(3, '20250101'),(4, '20250102'),(5, '20250102'),(6, '20250102'),(7, '20250103'),(8, '20250103'),(9, '20250103')";
exec $ODPS_CMD_DROPTAB;
let $ODPS_CMD_DROPTAB = odpscmd -e "use mysqltest_regression_sqlqa;DROP TABLE IF EXISTS t_string_part1; create table t_string_part1 (c1 int) PARTITIONED BY (pyear STRING, pmonth STRING);
insert into t_string_part1 partition(pyear,pmonth) (c1,pyear,pmonth) values(1, '25', '01'),(2, '25', '01'),(3, '25', '01'),(4, '25', '02'),(5, '25', '02'),(6, '25', '02'),(7, '25', '03'),(8, '25', '03'),(9, '25', '03')";
exec $ODPS_CMD_DROPTAB;
--enable_result_log

--disable_warnings
drop table if exists t_string_part, t_string_part1;
--enable_warnings

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create  external table t_string_part (
c1 int,
pdate string AS (metadata\$partition_list_col1)
)
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "$ODPS_ENDPOINT"
TABLE_NAME ="t_string_part"
)
partition by (pdate);

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create  external table t_string_part1 (
c1 int,
pyear string AS (metadata\$partition_list_col1),
pmonth string AS (metadata\$partition_list_col2)
)
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "$ODPS_ENDPOINT"
TABLE_NAME ="t_string_part1"
)
partition by (pyear, pmonth);

select * from t_string_part;
select * from t_string_part where pdate = '20250101';
select * from t_string_part where pdate = '20250102';
select * from t_string_part where pdate = '20250103';
select * from t_string_part where pdate = '20250104';

select * from t_string_part1;
select * from t_string_part1 where pyear = '25';
select * from t_string_part1 where pyear = '25' and pmonth = '01';
select * from t_string_part1 where pyear = '25' and pmonth = '02';
select * from t_string_part1 where pyear = '25' and pmonth = '03';
select * from t_string_part1 where pyear = '25' and pmonth = '04';

drop table t_string_part;
drop table t_string_part1;
