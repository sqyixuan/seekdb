# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test external table ddls
--enable_sorted_result
--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
#--error 0, 4354, 3510
#drop tablespace externaltablesapce;
--enable_query_log

#create tablespace externaltablesapce;

--result_format 4

# automatic partition for external table
create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

alter external table ex_t1 refresh;

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select file_url from oceanbase.__all_external_table_file;
--result_format 4

select date_key from ex_t1;
select * from ex_t1;
--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select *, metadata$fileurl from ex_t1;
--source mysql_test/include/external_table/replace_ip_port.inc
select metadata$fileurl from ex_t1;
--result_format 4

explain select * from ex_t1 where date_key = '2023-06-01';
select * from ex_t1 where date_key = '2023-06-01';

explain select * from ex_t1 where date_key > '2023-06-02';
select * from ex_t1 where date_key > '2023-06-02';

explain select * from ex_t1 where substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1) = '2023-06-01/server_log1.csv';
select * from ex_t1 where substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1) = '2023-06-01/server_log1.csv';

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;

drop table ex_t1;
create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key date as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10)),
year int as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 4)),
month int as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 6, 2)),
day int as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 9, 2))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (year, month, day)
;

select * from ex_t1;

explain select * from ex_t1 where year=2023 and month=7 and day=1;
select * from ex_t1 where year=2023 and month=7 and day=1;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
drop table ex_t1;

# user specified partition for external table
create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (metadata$partition_list_col1)
)
location='mysqltest_data_for_external_table/external_table_mock_log'
PARTITION_TYPE = USER_SPECIFIED
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

--error 1235
alter external table ex_t1 refresh;

alter external table ex_t1 add partition (date_key = '2023-06-01' ) location '2023-06-01';
explain select * from ex_t1 where date_key='2023-06-01';
select * from ex_t1;

alter external table ex_t1 drop partition location '2023-06-01';
select * from ex_t1;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
drop table ex_t1;

create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (metadata$partition_list_col1),
id_key int as (metadata$partition_list_col2)
)
location='mysqltest_data_for_external_table/external_table_mock_log'
PARTITION_TYPE = USER_SPECIFIED
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key, id_key)
;

select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

alter external table ex_t1 add partition (date_key = '2023-06-01', id_key = 1 ) location '2023-06-01';
select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';
alter external table ex_t1 add partition (date_key = '2023-06-01', id_key = 2 ) location '2023-06-01';
select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';
explain select * from ex_t1 where date_key= '2023-06-01' and id_key = 1;
explain select * from ex_t1 where date_key= '2023-06-01';
explain select * from ex_t1 where date_key= '2023-06-02';
select * from ex_t1 where date_key= '2023-06-01' and id_key = 1;
select * from ex_t1 where date_key= '2023-06-01' and id_key = 2;
select * from ex_t1 where date_key= '2023-06-01';
select * from ex_t1 where date_key= '2023-06-02';

alter external table ex_t1 add partition (date_key = '2023-06-01', id_key = 0 ) location '2023-06-01';
select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

--disable_query_log
let $idx = 3;
while ($idx <= 1024)
{
  eval alter external table ex_t1 add partition (date_key = '2023-06-01', id_key = $idx ) location '2023-06-01';
  inc $idx;
}
--enable_query_log

select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

alter external table ex_t1 add partition (date_key = '2023-06-01', id_key = 1035 ) location '2023-06-01';

select part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

