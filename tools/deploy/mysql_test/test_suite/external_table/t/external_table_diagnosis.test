# owner: zhengjin.zz
# owner group: SQL3
# tags: external_table, url, csv, diagnosis
# description: test diagnosis for loading data from url external table.

--result_format 4
--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table csv_ex_t1;
--error 0,1051
drop table csv_ex_t2;
--error 0,1051
drop table csv_ex_t3;
--error 0,1051
drop table csv_ex_t4;
--error 0,1051
drop table csv_ex_t5;

## 1. type cast

create table csv_ex_t1(
    c1            int,
    c2            int,
    c3            int
);

load data
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors reject limit unlimited;

select * from csv_ex_t1 order by c1;

load data /*+ direct(true, 0) parallel(2) enable_parallel_dml */
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors reject limit unlimited;

select * from csv_ex_t1 order by c1;

## 2. reject limit
--error 11088
load data
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors;

show warnings;

select * from csv_ex_t1 order by c1;

--error 11088
load data 
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors reject limit 1;

show warnings;

select * from csv_ex_t1 order by c1;

load data
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors reject limit 2;

select * from csv_ex_t1 order by c1;

## 3. column conv check

create table csv_ex_t2(
    c1            varchar(5),
    c2            varchar(5),
    c3            varchar(5)
);

load data 
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'column_conv.csv')
into table csv_ex_t2
log errors reject limit unlimited;

select * from csv_ex_t2 order by c1;

## 4. long csv to test the rightness of line number

create table csv_ex_t3(
    c1            varchar(5),
    c2            varchar(5),
    c3            varchar(5)
);

load data 
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'long_data.csv')
into table csv_ex_t3
log errors reject limit unlimited;

select count(*) from csv_ex_t3 order by c1;

## 5. missing column

create table csv_ex_t4(
    c1            int,
    c2            int,
    c3            int
);

load data 
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'missing_col.csv')
into table csv_ex_t4
log errors reject limit unlimited;

select * from csv_ex_t4 order by c1;

## 6. string to float

create table csv_ex_t5(
    user_id int unsigned,
    age float unsigned
);

load data 
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ',',
        parse_header = true
    ),
    pattern = 'unsigned_negative.csv')
into table csv_ex_t5
log errors reject limit unlimited;

select * from csv_ex_t5 order by user_id;

## 7. only load one column 
load data 
from (select age from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ',',
        parse_header = true
    ),
    pattern = 'unsigned_negative.csv'))
into table csv_ex_t5(age)
log errors reject limit unlimited;

select * from csv_ex_t5 order by age;

## 8. non-vectorized

set _enable_rich_vector_format = false;

load data
from files(
    location = 'mysqltest_data_for_external_table/diagnosis', 
    FORMAT (
        type = 'csv',
        field_delimiter = ','
    ),
    pattern = 'type_cast.csv')
into table csv_ex_t1
log errors reject limit unlimited;

select * from csv_ex_t1 order by c1;