# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test parquet format for external table.

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--enable_query_log



create external table ex_t1(
c1 bigint as (cast(get_path(external$filerow, 'int') as signed)),
c2 varchar(1000) as (cast(get_path(external$filerow, 'string') as char)),
c3 decimal(6,3) as (cast(get_path(external$filerow, 'decimal32') as decimal(6,3))),
c4 decimal as (cast(get_path(external$filerow, 'decimal64') as decimal)),
c6 date as (cast(get_path(external$filerow, 'date') as date))
) format (type = 'PARQUET') location 'mysqltest_data_for_external_table/parquet_ex_t1';

select * from ex_t1;

--enable_sorted_result

create external table ex_t2(
c1 bigint as (cast(get_path(external$filerow, 'int') as signed)),
c2 varchar(1000) as (cast(get_path(external$filerow, 'string') as char)),
c3 decimal(6,3) as (cast(get_path(external$filerow, 'decimal32') as decimal(6,3))),
c4 decimal as (cast(get_path(external$filerow, 'decimal64') as decimal)),
c6 date as (cast(get_path(external$filerow, 'date') as date)),
partkey varchar(100) as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 2))
)  format (type = 'PARQUET') location 'mysqltest_data_for_external_table/parquet_ex_t2' partition by (partkey);

select count(1) cnt, partkey from ex_t2 group by partkey;

--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.dba_ob_external_table_files where table_name = 'ex_t2';
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.all_ob_external_table_files where table_name = 'ex_t2';

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--source mysql_test/include/external_table/replace_ip_port.inc
select * from oceanbase.cdb_ob_external_table_files where table_name = 'ex_t2';


connection default;

--source mysql_test/include/external_table/replace_ip_port.inc
select metadata$fileurl, count(1) cnt from ex_t1 group by metadata$fileurl;

drop table ex_t1;
drop table ex_t2;


create external table ex_t3(
first_col bigint)
location = 'mysqltest_data_for_external_table/parquet_ex_t1'
format( type = 'parquet', column_index_type = 'POSITION');

select max(first_col) from ex_t3;
drop table ex_t3;

create external table ex_t3(
first_col bigint)
location = 'mysqltest_data_for_external_table/parquet_ex_t1'
format( type = 'parquet', column_index_type = 'NAME');

--error 11046
select max(first_col) from ex_t3;
drop table ex_t3;

--error 1235
create external table ex_t3(
first_col bigint)
location = 'mysqltest_data_for_external_table/parquet_ex_t1'
format( type = 'parquet', column_index_type = 'ID');

create external table ex_t3(
second_col varchar(1000) as (external$filepos2))
location = 'mysqltest_data_for_external_table/parquet_ex_t1'
format( type = 'parquet', column_index_type = 'POSITION');

select max(second_col) from ex_t3;
drop table ex_t3;

create external table ex_t3(
second_col varchar(1000) as (external$filepos200))
location = 'mysqltest_data_for_external_table/parquet_ex_t1'
format( type = 'parquet', column_index_type = 'POSITION');

--error 5311
select * from ex_t3;
drop table ex_t3;