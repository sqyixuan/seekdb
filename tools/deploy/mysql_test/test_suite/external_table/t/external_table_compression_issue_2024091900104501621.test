# owner: wangyunlai.wyl
# owner group: open
# tags: external_table
# description: test external table with gzip compressed files
--enable_sorted_result
--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
#--error 0, 4354, 3510
#drop tablespace externaltablesapce;
--enable_query_log

#create tablespace externaltablesapce;

--result_format 4

create external table ex_t1 (
id CHAR (10),
name CHAR (10),
mon CHAR (10),
age CHAR (10),
tel_number varCHAR (50)
)
location='file://mysqltest_data_for_external_table/compression_issue2024091900104501621/'
format (
  type = 'csv'
  LINE_DELIMITER = '\n'
  compression = GZIP
)
PATTERN = 'test.csv.gz'
;

select * from ex_t1 order by id;
