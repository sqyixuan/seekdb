--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
--disable_warnings
drop tablegroup IF EXISTS t00;
--enable_warnings
create tablegroup t00;
--error 1235
alter tablegroup t00 add ex_t1;
--error 1235
alter table ex_t1 add c111 int;

--error 1235
alter table ex_t1 tablegroup = 't00';

drop table ex_t1;

--error 1235
create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
tablegroup = 't00'
;


#drop tablespace externaltablesapce;
drop tablegroup t00;

create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime
)
location='mysqltest_data_for_external_table/external_table_mock_log'
PARTITION_TYPE = USER_SPECIFIED
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
desc ex_t1;

drop table ex_t1;

create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime
)
location='mysqltest_data_for_external_table/external_table_mock_log'
PARTITION_TYPE = USER_SPECIFIED
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (errcontent, time, errcode)
;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
desc ex_t1;

let $create_stmt = query_get_value(show create table ex_t1, 'Create Table', 1);
drop table ex_t1;

eval $create_stmt;
show create table ex_t1;
drop table ex_t1;

