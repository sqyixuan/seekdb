# description: test external table ddls

--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
#--error 0, 4354, 3510
#drop tablespace externaltablesapce;
#--error 0,5151
#drop tablegroup t00;
--enable_query_log

#create tablespace externaltablesapce;

--result_format 4
create external table ex_t1 (
errstate varchar(30),
errcode int,
errcontent varchar(100)
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
;

--error 1235
alter table ex_t1 partition by list(errcode) (partition p1 values in (1,2,3));

select /*+ leading(b a) */ part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

drop table ex_t1;

# automatic partition for external table
create external table ex_t1 (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
select /*+ leading(b a) */ part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

alter external table ex_t1 refresh;

--error 1235
alter table ex_t1 add partition (partition pp1 values in(1,2,3));
--error 1235
alter table ex_t1 drop partition pp1;
--error 1235
alter table ex_t1 add partition (partition pp2 values in(1));

--error 1235
insert into ex_t1(time) values('2022'); 

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select file_url from oceanbase.__all_external_table_file;
--result_format 4

--source mysql_test/include/external_table/delete_data_for_external_table.inc
alter external table ex_t1 refresh;
--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select metadata$fileurl from ex_t1;
--result_format 4
select /*+ leading(b a) */ part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select a.time, a.metadata$fileurl from ex_t1 a, ex_t1 b where a.errcode <> 0 and b.metadata$fileurl <> '' and exists(select metadata$fileurl from ex_t1 where metadata$fileurl <> '');
--result_format 4

--source mysql_test/include/external_table/copy_data_for_external_table.inc
alter external table ex_t1 refresh;

--result_format 1
--source mysql_test/include/external_table/replace_ip_port.inc
select metadata$fileurl from ex_t1;
--result_format 4
select /*+ leading(b a) */ part_name, part_idx from oceanbase.__all_part a, oceanbase.__all_table b where a.table_id = b.table_id and b.table_name='ex_t1';



let $x=2023;
let $dir_list= ;
let $cp_file= echo "";
while ($x <= 2545)
{
  let $dir_list = $dir_list $OBSERVER_DIR/$DATA_FOLDER_NAME/external_table_mock_log/$x-07-02;
  let $cp_file = $cp_file && cp $OBSERVER_DIR/$DATA_FOLDER_NAME/external_table_mock_log/2023-07-01/server_log1.csv $OBSERVER_DIR/$DATA_FOLDER_NAME/external_table_mock_log/$x-07-02;
  inc $x;
}
let $MK_DIR = ssh $HOST_IP 'mkdir -p $dir_list';
exec  $MK_DIR;
exec ssh $HOST_IP '$cp_file';

