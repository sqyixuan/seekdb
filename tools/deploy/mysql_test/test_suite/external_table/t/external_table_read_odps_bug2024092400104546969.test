# owner: sanquan.qz
# owner group: SQL3
# tags: external_table, odps
# description: test read external odps table

--source mysql_test/include/odps_config_for_cloud.inc
--result_format 4

## test show create table and partition table
--disable_warnings
drop table if exists ailing_t1p;
--enable_warnings
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE ailing_t1p (
  c1 int,
  c2 varchar(10) AS (metadata\$partition_list_col1),
  c3 int AS (metadata\$partition_list_col2)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'ailing_t1p'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
)
charset utf8mb4 collate utf8mb4_bin
partition by (c2, c3);
select * from ailing_t1p;
show create table ailing_t1p;
--disable_warnings
drop table if exists ailing_t1p;
--enable_warnings
#clean env
