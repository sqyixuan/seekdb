# owner: yibo.tyf
# owner group: SQL1
# tags: external_table

--result_format 4
--source mysql_test/include/odps_config_for_cloud.inc

--disable_result_log
let $ODPS_CMD_INITTABLE = odpscmd -e "set odps.sql.type.system.odps2=true;
drop table IF  EXISTS yt_array1;
create table yt_array1 (c1 array<tinyint>, c2 array<smallint>,c3 array<int>, c4 array<bigint>, c5 array<float>, c6 array<double>, c7 array<varchar(10)>,c8 array<string>);
drop table IF  EXISTS yt_array2;
create table yt_array2 (c1 array<array<tinyint>>, c2 array<array<smallint>>,c3 array<array<int>>,c4 array<array<bigint>>,c5 array<array<float>>,c6 array<array<double>>,c7 array<array<varchar(10)>>,c8 array<array<string>>);
insert into yt_array1 values 
  (cast(array(1,2,3) as array<tinyint>), cast(array(10,20,30) as array<smallint>), array(100,200,300), array(1000,2000,3000), cast(array(1.1, 2.2, 3.3) as array<float>), array(11.11, 22.22, 33.33), array('aaa', 'bbb', 'ccc'), array('aaaaaa', 'bbbbbb', 'cccccc')),
  (cast(array(1,2,3) as array<tinyint>), cast(array(10,20,30) as array<smallint>), array(100,200,300), array(1000,2000,3000), cast(array(1.1, 2.2, 3.3) as array<float>), array(11.11, 22.22, 33.33), array('aaa', 'bbb', 'ccc'), array('aaaaaa', 'bbbbbb', 'cccccc')),
  (NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL),
  (cast(array(4,5,null) as array<tinyint>), cast(array(40,50,NULL) as array<smallint>), array(400,500,NULL), array(4000,5000,NULL), cast(array(4.4, NULL, 5.5) as array<float>), array(44.4, NULL, 55.55), array(NULL, 'ddd', 'eee'), array(NULL, 'dddddd', 'eeeeee')),
  (cast(array(6) as array<tinyint>), cast(array(60) as array<smallint>), array(600), array(6000), cast(array(7.7) as array<float>), array(77.77), array('fff'), array('fffffff')),
  (cast(array(7,7,7,7,7) as array<tinyint>), cast(array(70,70,70,70,70) as array<smallint>), array(700,700,700,700,700), array(7000,7000,7000,7000,7000), cast(array(7.7,7.7) as array<float>), array(77.77,77.77), array('ggg'), array('ggggggg'));
insert into yt_array2 values 
  (cast(array(array(1,2,3),array(1,2,3)) as array<array<tinyint>>), cast(array(array(10,20,30),array(10,20,30)) as array<array<smallint>>), array(array(100,200,300),array(100,200,300)), array(array(1000,2000,3000),array(1000,2000,3000)), cast(array(array(1.1, 2.2, 3.3),array(1.1, 2.2, 3.3)) as array<array<float>>), array(array(11.11, 22.22, 33.33),array(11.11, 22.22, 33.33)), array(array('aaa', 'bbb', 'ccc'),array('aaa', 'bbb', 'ccc')), array(array('aaaaaa', 'bbbbbb', 'cccccc'),array('aaaaaa', 'bbbbbb', 'cccccc'))),
  (cast(array(array(1,2,3),array(1,2,3)) as array<array<tinyint>>), cast(array(array(10,20,30),array(10,20,30)) as array<array<smallint>>), array(array(100,200,300),array(100,200,300)), array(array(1000,2000,3000),array(1000,2000,3000)), cast(array(array(1.1, 2.2, 3.3),array(1.1, 2.2, 3.3)) as array<array<float>>), array(array(11.11, 22.22, 33.33),array(11.11, 22.22, 33.33)), array(array('aaa', 'bbb', 'ccc'),array('aaa', 'bbb', 'ccc')), array(array('aaaaaa', 'bbbbbb', 'cccccc'),array('aaaaaa', 'bbbbbb', 'cccccc'))),
  (NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL),
  (cast(array(array(4,5,NULL),NULL) as array<array<tinyint>>), cast(array(array(40,50,NULL),NULL) as array<array<smallint>>), array(array(400,500,NULL),NULL), array(array(4000,5000,NULL),NULL), cast(array(array(4.4,NULL,5.5),NULL) as array<array<float>>), array(array(44.44,NULL,55.55),NULL), array(array(NULL,'ddd', 'eee'),NULL), array(array(NULL,'dddddd', 'eeeeee'),NULL)),
  (cast(array(array(6)) as array<array<tinyint>>), cast(array(array(60)) as array<array<smallint>>), array(array(600)), array(array(6000)), cast(array(array(6.6)) as array<array<float>>), array(array(66.66)), array(array('fff')), array(array('ffffff'))),
  (cast(array(array(7,7,7),array(7,7)) as array<array<tinyint>>), cast(array(array(70,70,70),array(70,70)) as array<array<smallint>>), array(array(700,700,700),array(700,700,700)), array(array(7000,7000,7000),array(7000,7000)), cast(array(array(7.7,7.7),array(7.7),array(7.7,7.7)) as array<array<float>>), array(array(77.77,77.77),array(77.77),array(77.77,77.77)), array(array('ggg', 'ggg'),array('ggg', 'ggg', 'ggg')), array(array('gggggg', 'gggggg'),array('gggggg', 'gggggg', 'gggggg')));
";
exec $ODPS_CMD_INITTABLE;
--enable_result_log

--disable_warnings
drop table if exists t1,t3;
--enable_warnings

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval CREATE EXTERNAL TABLE t1(
c1 array(TINYINT),
c2 array(SMALLINT),
c3 array(INT),
c4 array(BIGINT),
c5 array(FLOAT),
c6 array(DOUBLE),
c7 array(VARCHAR(10)),
c8 array(VARCHAR(100))
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
ENDPOINT = "$ODPS_ENDPOINT"
PROJECT_NAME = "mysqltest_regression_sqlqa"
TABLE_NAME = 'yt_array1',
API_MODE = 'TUNNEL_API',
QUOTA_NAME = '',
COMPRESSION_CODE = ''
);

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
