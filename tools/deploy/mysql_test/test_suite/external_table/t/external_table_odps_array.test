## test read/write with jni
connection sys_conn;
alter system set _use_odps_jni_connector = true;
alter system set _ob_java_odps_data_transfer_mode = 'arrowTable';
connection mysql_conn;
--sorted_result
select /* arrowTable */ * from t1;
--sorted_result
select /* arrowTable */ * from t3;

connection sys_conn;
alter system set _use_odps_jni_connector = true;
alter system set _ob_java_odps_data_transfer_mode = 'offHeapTable';
connection mysql_conn;
--sorted_result
select /* offHeapTable */ * from t1;
--sorted_result
select /* offHeapTable */ * from t3;


insert into t1 select [8,9], [80,90], [800,900], [8000,9000], [8.8,9.9], [88.88,99.99],["hhh","iii"], ["hhhhhh","iiiiii"] from table(generator(10));
insert into t3 select [[8,9],[9,8]], [[80,90],[90,80]], [[800,900],[900,800]], [[8000,9000],[9000,8000]], [[8.8,9.9],[9.9,8.8]], [[88.88,99.99],[99.99,88.88]],[["hhh","iii"],["iii","hhh"]], [["hhhhhh","iiiiii"],["iiiiii","hhhhhh"]] from table(generator(10));
--sorted_result
select /* offHeapTable */ * from t1;
--sorted_result
select /* offHeapTable */ * from t3;


## test read/write with cpp api
connection sys_conn;
alter system set _use_odps_jni_connector = false;
connection mysql_conn;
--sorted_result
select /* cpp */ * from t1;
--sorted_result
select /* cpp */ * from t3;
#insert into t1 select [8,9], [80,90], [800,900], [8000,9000], [8.8,9.9], [88.88,99.99],["hhh","iii"], ["hhhhhh","iiiiii"] from table(generator(10));
#insert into t3 select [[8,9],[9,8]], [[80,90],[90,80]], [[800,900],[900,800]], [[8000,9000],[9000,8000]], [[8.8,9.9],[9.9,8.8]], [[88.88,99.99],[99.99,88.88]],[["hhh","iii"],["iii","hhh"]], [["hhhhhh","iiiiii"],["iiiiii","hhhhhh"]] from table(generator(10));
insert into t1 select [8,9], [80,90], [800,900], [8000,9000], [8.8,9.9], [88.88,99.99],["hhh","iii"], NULL from table(generator(10));
insert into t3 select [[8,9],[9,8]], [[80,90],[90,80]], [[800,900],[900,800]], [[8000,9000],[9000,8000]], [[8.8,9.9],[9.9,8.8]], [[88.88,99.99],[99.99,88.88]],[["hhh","iii"],["iii","hhh"]], NULL from table(generator(10));
--sorted_result
select /* cpp */ * from t1;
--sorted_result
select /* cpp */ * from t3;

drop table t1,t3;