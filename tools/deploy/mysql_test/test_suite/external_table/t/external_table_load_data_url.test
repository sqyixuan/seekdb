# owner: zhengjin.zz
# owner group: SQL3
# tags: external_table, url, orc, csv, parquet, odps
# description: test load data from select url external table.

--source mysql_test/include/odps_config_for_cloud.inc
--result_format 4
--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

## 1. orc

create table orc_ex_t1(
c1 bool,
c2 int,
c3 int,
c4 int,
c5 bigint,
c6 float,
c7 double,
c8 decimal(10,3),
c9 decimal(20,1),
c10 varchar(100),
c11 varchar(100),
c12 char(100),
c13 varchar(100),
c14 timestamp,
c15 date
);

load data  /*+ direct(true,0) parallel(2)*/
from files(location = "mysqltest_data_for_external_table/orc", format( type = 'ORC'), pattern = 't1.orc')
into table orc_ex_t1;

select * from orc_ex_t1 order by c9 limit 10;

drop table orc_ex_t1;

## 2. csv

create table csv_ex_t1(
    c1            varchar(100),
    c2            varchar(100),
    c3            varchar(100),
    c4            varchar(100)
);

load data  /*+ direct(true,0) parallel(2)*/
from files(
    location = "mysqltest_data_for_external_table/external_table_mock_log", 
    FORMAT (
        type = 'csv',
        field_delimiter = ',',
        SKIP_BLANK_LINES = TRUE
    ))
into table csv_ex_t1
;

select * from csv_ex_t1 order by c1, c3;

drop table csv_ex_t1;

## 3. parquet

create table parquet_ex_t1(
c1 decimal(6,3),
c2 decimal,
c3 date,
c4 timestamp
);

load data  /*+ direct(true,0) parallel(2)*/
from (select decimal32, decimal64, date, timestamp from 
    files(location = 'mysqltest_data_for_external_table/parquet_ex_t1',
    FORMAT ( type = 'PARQUET')))
into table parquet_ex_t1 (c1, c2, c3, c4);

select * from parquet_ex_t1 order by c4 desc, c3 desc limit 10;

drop table parquet_ex_t1;

## 4. odps

CREATE TABLE odps_ex_t1 (
 c1             int,
 c2             int,
 c3          varchar(20)
);

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval load data  /*+ direct(true,0) parallel(2)*/
from source (
    TYPE = 'ODPS'
    ACCESSID = '$ODPS_ACCESSID'
    ACCESSKEY = '$ODPS_ACCESSKEY'
    ENDPOINT= '$ODPS_ENDPOINT'
    PROJECT_NAME = 'mysqltest_regression_sqlqa'
    SCHEMA_NAME = ''
    TABLE_NAME = 'zhengjin_test_part'
    QUOTA_NAME = ''
    COMPRESSION_CODE = ''
)
into table odps_ex_t1
;

select * from odps_ex_t1 where c3 = 'part1';

drop table odps_ex_t1;
