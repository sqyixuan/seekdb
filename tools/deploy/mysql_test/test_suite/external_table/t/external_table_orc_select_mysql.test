###函数嵌套
select lower(col_string),UPPER(col_string),substr(col_varchar,1,3),length(UPPER(col_char)),replace(col_string,col_varchar,'TYPE')
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = 'all.orc');

select col_int+999.000 ,cast(col_char as char(10)),round(col_float,1),col_float||col_double,cast(col_decimal as decimal(5,2)) ,cast(col_date as date)
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = 'all.orc');


select case when col_char > '1003' then 'Y' else 'N' end from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select case when col_bigint > 1003 then 'Y' else 'N' end from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select case when col_double > 0.0000023232 then 'Y' else 'N' end from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select case when col_varchar > '1003' then nvl(col_char,'kong')  else 'N' end from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select col_int MON,CASE WHEN col_decimal >= 4000 THEN 'H' WHEN col_bigint >= 3000 THEN 'N' ELSE 'L' END AS T from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select DISTINCT col_decimal, col_int,col_char,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select UNIQUE col_bigint,col_boolean,col_timestamp from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select ALL col_char, col_string,col_date,col_double from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select col_char || '-' || col_decimal && col_double || col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

select col_char,col_boolean,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) GROUP BY col_date ORDER BY col_int;


select col_char,col_boolean,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) GROUP BY col_date ORDER BY col_int LIMIT 1,5;


##UNION 
select col_char,col_boolean,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) UNION
select col_string,col_date,col_date from files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) limit 1,2;

##UNION DISTINCT
select col_date,col_int,col_timestamp from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) UNION DISTINCT
select col_varchar,col_double,col_date from files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) limit 1,2;

## 创建表union
--error 0,1051
drop table orc_ex_t1;
create table orc_ex_t1(
col_int INT,                   
col_bigint BIGINT ,         
col_float FLOAT,          
col_double DOUBLE,         
col_decimal DECIMAL(10,2), 
col_string STRING,         
col_varchar VARCHAR(50),   
col_char CHAR(10),      
col_boolean BOOLEAN,      
col_date DATE,             
col_timestamp TIMESTAMP
);
load data  /*+ direct(true,0) parallel(2)*/
from files(location = "mysqltest_data_for_external_table/orc", format( type = 'ORC'),pattern = 'only_date_int_double_float_string.orc')
into table orc_ex_t1;

select * from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) UNION
select * from orc_ex_t1 order by col_char limit 10;



##MINUS 
select col_decimal,col_varchar,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) MINUS
select col_decimal,col_varchar,col_date from files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

##INTERSECT 
select col_date,col_double,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) INTERSECT
select col_date,col_double,col_date from files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  ) ;

##子查询
select col_int,col_date,col_double,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  )where col_int IN
(SELECT col_int FROM 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC') pattern = 'all.orc')
WHERE col_varchar NOT IN ('1000') OR (col_double IN (NULL) AND col_date IS NOT NULL) OR col_string LIKE '%中文%')
;

####view select
DROP TABLE IF EXISTS ex_t1;
--error 1146
create table ex_t1  as
select col_decimal,col_timestamp,col_double,col_date from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  );

--error 0,1051
drop view ex_t1;
create view ex_t1 as select  * from 'mysqltest_data_for_external_table/orc/'
(format (type = 'ORC')
PATTERN = 'all.orc');
--error 1356
select * from ex_t1;

##JOIN
-- error 0,1051
drop table orc_ex_t1;
create table orc_ex_t1(
col_int1 INT,                   
col_bigint1 BIGINT ,         
col_float1 FLOAT,          
col_double1 DOUBLE,         
col_decimal1 DECIMAL(10,2), 
col_string1 STRING,         
col_varchar1 VARCHAR(50),   
col_char1 CHAR(10),      
col_boolean1 BOOLEAN,      
col_date1 DATE,             
col_timestamp1 TIMESTAMP
);
load data  /*+ direct(true,0) parallel(2)*/
from files(location = "mysqltest_data_for_external_table/orc", format( type = 'ORC'),pattern = 'all.orc')
into table orc_ex_t1;

SELECT /*+ USE_PX PARALLEL(4)*/ * FROM
 'mysqltest_data_for_external_table/orc/'
 (format (type = 'ORC')
PATTERN = 'all.orc')
JOIN orc_ex_t1 B ON col_int = B.col_int1 WHERE col_double IS NULL OR B.col_double1 IS NOT NULL GROUP BY col_char HAVING col_float > 100 ORDER BY col_date;


