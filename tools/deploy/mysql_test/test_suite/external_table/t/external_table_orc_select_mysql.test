--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 5
connection default;

##正常场景查询
select * from 
files ( 
location = 'mysqltest_data_for_external_table/orc', 
format (type = 'ORC', 
line_delimiter = NVL(NULL, ' ') ), 
pattern = 't1.orc' ) where c15 < c14 order by c1 limit 10;

select * from 
files ( 
location = 'mysqltest_data_for_external_table/orc', 
format (type = 'ORC', 
line_delimiter = NVL(NULL, ' ') ), 
pattern = 'invalid_date.orc' );

select col_varchar from 
files ( 
location = 'mysqltest_data_for_external_table/orc', 
format (type = 'ORC', 
line_delimiter = NVL(NULL, ' ') ), 
pattern = 'char_type_test.orc' );

select `col_double`,col_varchar
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = '00000_0');

select concat(col_double,col_int),col_varchar
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = '00000_0');


select * from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC',
  line_delimiter = NVL(NULL, ' ')
  FIELD_DELIMITER = '$'
     ENCODING = 'utf8mb4',
   null_if = (NVL(NULL, 'NULL'),UPPER('c')),
   SKIP_BLANK_LINES = FALSE ,
   TRIM_SPACE = true ,
   EMPTY_FIELD_AS_NULL =TRUE

  ),
  pattern = '000000_0'
  );

select col_date,col_date,col_date from 
files (
 location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC',
  line_delimiter = NVL(NULL, ' ')
  FIELD_DELIMITER = '$'
     ENCODING = 'latin1',
   null_if = (NVL(NULL, 'NULL'),UPPER('c')),
   SKIP_BLANK_LINES = FALSE ,
   TRIM_SPACE = false ,
   EMPTY_FIELD_AS_NULL =TRUE
  ),
  pattern = '中文sdcd123123123c.orc'
  ) order by col_bigint limit 0;

select count(*),sum(col_int),max(col_string),min(col_boolean),avg(col_double) from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC'),
  pattern = 'all.orc'
  );

select * from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  )  where col_float = '' or col_string = '中文吃的送常见的场地吃大餐长度差点迟到没得' order by col_int limit 14;


select col_int,col_string,col_boolean,col_timestamp from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'all.orc'
  )  where col_double >= 0.0000323232121212000;

select col_double
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = 'only_date_int._double_float.orc'
) where col_date != '';

--error 1235
select col_boolean from 
files (
  location = 'mysqltest_data_for_external_table/orc',
  format (type = 'ORC '),
  pattern = 'only_date_int_double_float_string.orc'
  ) where col_int !=1 FOR UPDATE;

select col_date,col_bigint,col_double,col_varchar,col_string
from 'mysqltest_data_for_external_table/orc'
( format (type = 'ORC')
  pattern = 'only_number.orc');

