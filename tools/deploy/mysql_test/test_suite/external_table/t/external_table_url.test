# description: test select url external table.


--result_format 4
--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

## 0. basic test

--error 1064
select * from 'mock_path/';

--error 1017
select * from 'wrong_path/' (format (type = 'csv'));

## 1. orc

select * from 'mysqltest_data_for_external_table/orc' (format (type = 'ORC') pattern = 't1.orc');

select * from files(location = 'mysqltest_data_for_external_table/orc', format (type = 'ORC'), pattern = 't1.orc');

--error 11065
select * from files(location = 'mysqltest_data_for_external_table/parquet_ex_t1', format (type = 'ORC'));

SET time_zone = '+00:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/orc', format (type = 'ORC'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/orc', format (type = 'ORC'));

SET time_zone = '+08:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/orc', format (type = 'ORC'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/orc', format (type = 'ORC'));

## 2. csv

select * from 'mysqltest_data_for_external_table/external_table_mock_log'
(format (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
));

select * from files(
    location = 'mysqltest_data_for_external_table/external_table_mock_log'
    FORMAT (
        type = 'csv',
        field_delimiter = ',',
        SKIP_BLANK_LINES = TRUE
    )
);

select * from 'mysqltest_data_for_external_table/parse_header/'
(format( type = 'CSV' field_delimiter = ',' parse_header  = true)); 

--error 11081
select * from 'mysqltest_data_for_external_table/parse_header/' 
(format( type = 'CSV' field_delimiter = ',' parse_header  = true skip_header = 2)); 

# ignore_last_empty_column
select * from 'mysqltest_data_for_external_table/ignore_last_empty_column' 
(format( type = 'CSV' field_delimiter = '|')); 

select * from 'mysqltest_data_for_external_table/ignore_last_empty_column' 
(format( type = 'CSV' field_delimiter = '|' ignore_last_empty_column = false)); 

connect(sys_conn,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connect(mysql_conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_conn;
let $ver = query_get_value(show PARAMETERS like '%min_observer_version%', value, 1);
alter system set min_observer_version = '4.3.5.1';

connection mysql_conn;

--disable_query_log
--error 0,1051
drop table lineitem_old;
--error 0,1051
drop table lineitem_new;
--enable_query_log

CREATE external TABLE lineitem_old (
  l_orderkey     int,
  l_partkey      int,
  l_suppkey      int,
  l_linenumber   int,
  l_quantity     decimal(15,2),
  l_extendedprice  decimal(15,2),
  l_discount     decimal(15,2),
  l_tax          decimal(15,2),
  l_returnflag   char(1),
  l_linestatus   char(1),
  l_shipdate     date,
  l_commitdate   date,
  l_receiptdate  date,
  l_shipinstruct char(25),
  l_shipmode     char(10),
  l_comment      varchar(44),
  l_dummy varchar(44)
)
location  'mysqltest_data_for_external_table/ignore_last_empty_column'
format( type = 'CSV' field_delimiter = '|');

select l_dummy from lineitem_old;

connection sys_conn;
--disable_query_log
eval alter system set min_observer_version = "$ver";
--enable_query_log
connection mysql_conn;

# for old table, ignore_last_empty_column should be false after upgrade
select l_dummy from lineitem_old;

drop table lineitem_old;

select * from 'mysqltest_data_for_external_table/url_one_line' 
(format( type = 'CSV' field_delimiter = ','));

select * from 'mysqltest_data_for_external_table/issue2025020500107141519/'
(format (
    type = 'csv'
    field_delimiter = ' '
    FIELD_OPTIONALLY_ENCLOSED_BY='"'
    LINE_DELIMITER = '\n'
    NULL_IF = ('a')
));

## 3. parquet

select string, decimal32, decimal64, date, timestamp
from 'mysqltest_data_for_external_table/parquet_ex_t1'
(format (type = 'PARQUET')) limit 10;

select distinct (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 2)) from 
files(location = 'mysqltest_data_for_external_table/parquet_ex_t2', format (type = 'PARQUET'));

select * from 
files(location = 'mysqltest_data_for_external_table/external_table_parquet_hive_data', 
format (type = 'PARQUET'),
PATTERN = 'int_values'); 

SET time_zone = '+00:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/parquet', format (type = 'parquet'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/parquet', format (type = 'parquet'));

SET time_zone = '+08:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/parquet', format (type = 'parquet'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/parquet', format (type = 'parquet'));
