## 3. parquet

select string, decimal32, decimal64, date, timestamp
from 'mysqltest_data_for_external_table/parquet_ex_t1'
(format (type = 'PARQUET')) limit 10;

select distinct (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 2)) from 
files(location = 'mysqltest_data_for_external_table/parquet_ex_t2', format (type = 'PARQUET'));

select * from 
files(location = 'mysqltest_data_for_external_table/external_table_parquet_hive_data', 
format (type = 'PARQUET'),
PATTERN = 'int_values'); 

SET time_zone = '+00:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/parquet', format (type = 'parquet'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/parquet', format (type = 'parquet'));

SET time_zone = '+08:00';
select * from files(location = 'mysqltest_data_for_external_table/timestamp/micros/parquet', format (type = 'parquet'));
select * from files(location = 'mysqltest_data_for_external_table/timestamp/nanos/parquet', format (type = 'parquet'));
## 4. odps

## 分区裁剪
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval select * from 
source (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT= '$ODPS_ENDPOINT'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'zhengjin_test_part'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
) where c3 = 'part1';

# CREATE TABLE IF NOT EXISTS zhengjin_test_types(c1 TINYINT, c2 SMALLINT, c3 INT, c4 BIGINT, c5 FLOAT, c6 DOUBLE, c7 DECIMAL(38,18), c8 BINARY, c9 STRING, c10 TIMESTAMP, c11 CHAR(10), c12 VARCHAR(20), c13 JSON, c14 TIMESTAMP_NTZ) STORED AS ALIORC;

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
# not support reading c13(json)
eval select c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12 from
source (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT= '$ODPS_ENDPOINT'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'zhengjin_test_types'
QUOTA_NAME = ''
COMPRESSION_CODE = '')
where c1 is not NULL order by c8 limit 1;

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval select * from
source (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT= '$ODPS_ENDPOINT'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'zhengjin_test_date'
QUOTA_NAME = ''
COMPRESSION_CODE = '')
order by c1;
