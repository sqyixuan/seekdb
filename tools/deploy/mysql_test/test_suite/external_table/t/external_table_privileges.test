--echo /***************************table privilege level********************************/
--echo CREATE

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

--echo SELECT/INSERT/DELETE/UPDATE/INDEX/ALTER/CREATE VIEW

connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

--error 1142
select * from ex_t1;
--error 1235
insert into ex_t1 values(5, 6,7);
--error 1235
delete from ex_t1 where c1 = 1;
--error 3105
update ex_t1 set c1 = 1 where c1 = 2;
--error 1235
CREATE unique INDEX idx ON ex_t1 (c1);
--error 1235
alter table ex_t1 ADD i INT;
--error 1142
create view v1 as (select c1 from ex_t1);
--error 1142
show create table ex_t1;

disconnect user_1;
connection default;
grant create, select, insert, delete, update, index, alter on test.ex_t1 to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

select * from ex_t1;
--error 1235
insert into ex_t1 values(5, 6,7);
--error 1235
delete from ex_t1 where c1 = 1;
--error 3105
update ex_t1 set c1 = 1 where c1 = 2;
--error 1235
create unique index idx on ex_t1 (c1);
--error 1235
alter table ex_t1 ADD i INT;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;

update t1, ex_t1 set t1.c1 = 0 where t1.c1 = ex_t1.c1;

# for update

--error 1235
select * from ex_t1 for update;
--error 1235
select * from t1, ex_t1 where t1.c1 = ex_t1.c1 for update;
--error 1235
select t1.* from t1, ex_t1 where t1.c1 = ex_t1.c1 for update;
--error 1235
select ex_t1.* from t1, ex_t1 where t1.c1 = ex_t1.c1 for update;

--error 1235
select * from t1, (select c1 from ex_t1 for update) a where t1.c1 = a.c1;
select * from ex_t1, (select c1 from t1 for update) a where ex_t1.c1 = a.c1;
--echo DROP

--error 1142
drop table ex_t1;

disconnect user_1;
connection default;
grant drop on test.ex_t1 to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

drop table ex_t1;
--error 1146
select * from ex_t1;

disconnect user_1;
connection default;
show tables;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv'
);

create view v1 as (select * from ex_t1);
--error 1235
delete from v1;
--error 3105
update v1 set c1 = 1 where c1 = 2;
--error 3105
insert into v1 values(1,1,1);

drop view v1;
drop table ex_t1;
drop table t1;
drop user user_1@'%';
