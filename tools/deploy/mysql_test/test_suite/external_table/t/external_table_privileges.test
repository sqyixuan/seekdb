# owner: jim.wjh
# owner group: SQL3
# tags: external_table,ddl
# description: test external table privilege

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--disable_warnings

--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop view v1;
--error 0,1396
drop user user_1@'%';

create table t1 (c1 int);
create user user_1 identified by 'ttt';
grant select on test.t1 to user_1;

--enable_query_log
--enable_warnings

show grants for user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

--echo /***************************user privilege level********************************/
--echo CREATE

--error 1142
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

disconnect user_1;
connection default;
grant create on *.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

--echo SELECT/INSERT/DELETE/UPDATE/INDEX/ALTER/CREATE VIEW

--error 1142
select * from ex_t1;
--error 1235
insert into ex_t1 values(5, 6,7);
--error 1235
delete from ex_t1 where c1 = 1;
--error 3105
update ex_t1 set c1 = 1 where c1 = 2;
--error 1235
CREATE unique INDEX idx ON ex_t1 (c1);
--error 1235
create external table ex_t2 (
    c1 int,
    c2 int,
    c3 int,
    index(c1)
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv'
);
--error 1235
alter table ex_t1 ADD i INT;
--error 1142
create view v1 as (select c1 from ex_t1);

disconnect user_1;
connection default;
revoke create on *.* from user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

--error 1142
show create table ex_t1;

disconnect user_1;
connection default;
grant create, select, insert, delete, update, index, alter, create view on *.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

select * from ex_t1;
--error 1235
insert into ex_t1 values(5, 6,7);
--error 1235
delete from ex_t1 where c1 = 1;
--error 3105
update ex_t1 set c1 = 1 where c1 = 2;
--error 1235
create unique index idx on ex_t1 (c1);
--error 1235
create external table ex_t2 (
    c1 int,
    c2 int,
    c3 int,
    index(c1)
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv'
);
--error 1235
alter table ex_t1 ADD i INT;

create view v1 as (select c1 as a1 from ex_t1);
select * from v1;
--error 3105
insert into v1 values(3);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;

--echo DROP

--error 1142
drop table ex_t1;

disconnect user_1;
connection default;
grant drop on *.* to user_1;
connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);

drop table ex_t1;
--error 1146
select * from ex_t1;

disconnect user_1;
connection default;

show tables;
drop view v1;

REVOKE ALL PRIVILEGES, GRANT OPTION FROM user_1;
grant select on test.t1 to user_1;
show grants for user_1;

--echo /***************************database privilege level********************************/
--echo CREATE

connect (user_1,$OBMYSQL_MS0,user_1,ttt,test,$OBMYSQL_PORT);
