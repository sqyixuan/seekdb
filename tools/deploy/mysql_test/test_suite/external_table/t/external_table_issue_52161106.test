# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description:
--disable_abort_on_error
--disable_warnings
drop table if exists t0,t1,t2;
--enable_warnings

--result_format 4
CREATE EXTERNAL TABLE t0(c0 VARCHAR(500) GENERATED ALWAYS AS (LTRIM(METADATA$FILECOL1)), c1 FLOAT ZEROFILL GENERATED ALWAYS AS (METADATA$FILECOL2), c2 DATETIME GENERATED ALWAYS AS (METADATA$FILECOL3)) LOCATION='oss://1:1@1/1' FORMAT(TYPE = 'CSV', FIELD_DELIMITER = ',', FIELD_OPTIONALLY_ENCLOSED_BY = '\'', ENCODING = 'UTF8MB4', SKIP_BLANK_LINES = TRUE, EMPTY_FIELD_AS_NULL = TRUE);
CREATE EXTERNAL TABLE t1(c0 VARCHAR(500) GENERATED ALWAYS AS (METADATA$FILECOL1), c1 FLOAT GENERATED ALWAYS AS (METADATA$FILECOL2)) LOCATION='oss://1:1@1/1' FORMAT(TYPE = 'CSV', FIELD_DELIMITER = '$', FIELD_OPTIONALLY_ENCLOSED_BY = '\'', ENCODING = 'UTF8MB4', TRIM_SPACE = TRUE, SKIP_BLANK_LINES = TRUE, EMPTY_FIELD_AS_NULL = TRUE);
CREATE EXTERNAL TABLE t2(c0 DOUBLE ZEROFILL GENERATED ALWAYS AS (METADATA$FILECOL1), c1 DATETIME GENERATED ALWAYS AS (METADATA$FILECOL2), c2 DOUBLE GENERATED ALWAYS AS (METADATA$FILECOL3), c3 INT GENERATED ALWAYS AS (METADATA$FILECOL4)) LOCATION='oss://1:1@1/1' FORMAT(TYPE = 'CSV', FIELD_DELIMITER = '$', FIELD_OPTIONALLY_ENCLOSED_BY = '\'', ENCODING = 'UTF8MB4', TRIM_SPACE = TRUE, SKIP_BLANK_LINES = TRUE, EMPTY_FIELD_AS_NULL = TRUE);

SELECT /*+ leading(t0 t2 t22) parallel(t22, 3) parallel(t0, 1) parallel(t2, 1) NO_USE_MERGE  */ count(*)
   FROM t0,
        t2,
        t2 t22
   WHERE ((((+ (concat(t2.c0,'')))) IS NOT FALSE)
          AND (t2.c3));

drop table t0,t1,t2;

