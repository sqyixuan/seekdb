# owner: lidaojing.ldj
# owner group: SQL3
# tags: external_table
# description: test orc load data for external table.

--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 5
connection default;

# 正常查询

--error 0,1051
drop table orc_ex_t1;
create table orc_ex_t1(
col_int INT,                   
col_bigint BIGINT ,         
col_float FLOAT,          
col_double DOUBLE,         
col_decimal DECIMAL(10,2), 
col_string STRING,         
col_varchar VARCHAR(50),   
col_char CHAR(10),      
col_boolean BOOLEAN,      
col_date DATE,             
col_timestamp TIMESTAMP
);
load data  /*+ direct(true,0) parallel(2)*/
from files(location = "mysqltest_data_for_external_table/orc", format( type = 'ORC'),pattern = 'all.orc')
into table orc_ex_t1;

select * from orc_ex_t1 ;
select * from orc_ex_t1  where col_double > -121312321321312;
select * from orc_ex_t1  where col_varchar = 'NULL' or col_date = '2023-09-31';

--error 0,1051
drop table orc_test;
create table orc_test(col_int int,col_bigint BIGINT,col_float float,col_double DOUBLE,col_decimal DECIMAL(10,2));
load data from (select col_int,col_bigint,col_float,col_double,col_decimal from files(
location = 'mysqltest_data_for_external_table/orc/'
format (type = 'orc')
PATTERN = 'all.orc')) into table orc_test;
select col_int,col_float from orc_test order by col_double limit 1,3 ;

