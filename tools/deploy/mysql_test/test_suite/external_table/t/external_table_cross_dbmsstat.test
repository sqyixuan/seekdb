# 4. GATHER_DATABASE_STATS_JOB_PROC
drop table ex_t1;
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC(1000000000);
--sorted_result
select s1.object_type,s1.sstable_row_cnt,s1.sstable_avg_row_len,s1.macro_blk_cnt,s1.micro_blk_cnt,s1.memtable_row_cnt,s1.memtable_avg_row_len,s1.row_cnt,s1.avg_row_len,s1.global_stats,s1.user_stats,s1.stattype_locked,s1.stale_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6,s1.index_type from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.object_type,s1.distinct_cnt,s1.null_cnt,s1.max_value,s1.b_max_value,s1.min_value,s1.b_min_value,s1.avg_len,s1.distinct_cnt_synopsis,s1.distinct_cnt_synopsis_size,s1.sample_size,s1.density ,s1.bucket_cnt,s1.histogram_type,s1.global_stats,s1.user_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6 from OCEANBASE.__ALL_COLUMN_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.endpoint_num,s1.object_type,s1.endpoint_normalized_value,s1.endpoint_value,s1.b_endpoint_value,s1.endpoint_repeat_cnt from OCEANBASE.__ALL_HISTOGRAM_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;

# 5. set_table_stats,set_column_stats,delete_table_stats,delete_column_stats
drop table ex_t1;
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
call dbms_stats.set_table_stats('TEST', 'EX_T1', numrows=>10000);
call dbms_stats.set_column_stats('TEST', 'EX_T1', 'C1', distcnt=>10, nullcnt=>10);
--sorted_result
select s1.object_type,s1.sstable_row_cnt,s1.sstable_avg_row_len,s1.macro_blk_cnt,s1.micro_blk_cnt,s1.memtable_row_cnt,s1.memtable_avg_row_len,s1.row_cnt,s1.avg_row_len,s1.global_stats,s1.user_stats,s1.stattype_locked,s1.stale_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6,s1.index_type from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.object_type,s1.distinct_cnt,s1.null_cnt,s1.max_value,s1.b_max_value,s1.min_value,s1.b_min_value,s1.avg_len,s1.distinct_cnt_synopsis,s1.distinct_cnt_synopsis_size,s1.sample_size,s1.density ,s1.bucket_cnt,s1.histogram_type,s1.global_stats,s1.user_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6 from OCEANBASE.__ALL_COLUMN_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.endpoint_num,s1.object_type,s1.endpoint_normalized_value,s1.endpoint_value,s1.b_endpoint_value,s1.endpoint_repeat_cnt from OCEANBASE.__ALL_HISTOGRAM_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;
call dbms_stats.delete_table_stats('TEST', 'EX_T1');
call dbms_stats.delete_column_stats('TEST', 'EX_T1', 'C1');
--sorted_result
select s1.object_type,s1.sstable_row_cnt,s1.sstable_avg_row_len,s1.macro_blk_cnt,s1.micro_blk_cnt,s1.memtable_row_cnt,s1.memtable_avg_row_len,s1.row_cnt,s1.avg_row_len,s1.global_stats,s1.user_stats,s1.stattype_locked,s1.stale_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6,s1.index_type from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.object_type,s1.distinct_cnt,s1.null_cnt,s1.max_value,s1.b_max_value,s1.min_value,s1.b_min_value,s1.avg_len,s1.distinct_cnt_synopsis,s1.distinct_cnt_synopsis_size,s1.sample_size,s1.density ,s1.bucket_cnt,s1.histogram_type,s1.global_stats,s1.user_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6 from OCEANBASE.__ALL_COLUMN_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.endpoint_num,s1.object_type,s1.endpoint_normalized_value,s1.endpoint_value,s1.b_endpoint_value,s1.endpoint_repeat_cnt from OCEANBASE.__ALL_HISTOGRAM_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;

# 6. set_table_stats,set_column_stats,delete_table_stats,delete_column_stats
call dbms_stats.set_table_prefs('TEST', 'EX_T1', 'degree', '128');
call dbms_stats.delete_table_prefs('TEST', 'EX_T1','degree');

--source mysql_test/include/external_table/delete_data_for_external_table.inc
drop table ex_t1;
