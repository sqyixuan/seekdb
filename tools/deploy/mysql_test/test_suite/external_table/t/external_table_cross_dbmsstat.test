# owner: jim.wjh
# owner group: sql3
# tags: external_table,pl,opt_stats
# description: test external table cross dbms_stat

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--source mysql_test/include/external_table/copy_data_for_external_table.inc

--error 0,1051
drop table ex_t1;

drop database  test;
create database test;
use test;
--enable_query_log
--result_format 4
# 1. gather_table_stats
create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;
--sorted_result
select * from ex_t1;
call dbms_stats.gather_table_stats('TEST','EX_T1',method_opt=>'for all columns size 5',granularity=>'all');
--sorted_result
select OWNER,TABLE_NAME,PARTITION_NAME,PARTITION_POSITION,SUBPARTITION_NAME,SUBPARTITION_POSITION,OBJECT_TYPE,NUM_ROWS,BLOCKS,EMPTY_BLOCKS,AVG_SPACE,CHAIN_CNT,AVG_ROW_LEN,AVG_SPACE_FREELIST_BLOCKS,NUM_FREELIST_BLOCKS,AVG_CACHED_BLOCKS,AVG_CACHE_HIT_RATIO,IM_IMCU_COUNT,IM_BLOCK_COUNT,IM_STAT_UPDATE_TIME,SCAN_RATE,SAMPLE_SIZE,GLOBAL_STATS,USER_STATS,STATTYPE_LOCKED,STALE_STATS,SCOPE from OCEANBASE.DBA_TAB_STATISTICS where owner='TEST';
--sorted_result
select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,NUM_BUCKETS,SAMPLE_SIZE,GLOBAL_STATS,USER_STATS,NOTES,AVG_COL_LEN,HISTOGRAM,SCOPE from OCEANBASE.DBA_TAB_COL_STATISTICS where table_name='ex_t1';
--sorted_result
select /*+query_timeout(30000000)*/ OWNER,TABLE_NAME,COLUMN_NAME,ENDPOINT_NUMBER,ENDPOINT_VALUE,ENDPOINT_ACTUAL_VALUE,ENDPOINT_ACTUAL_VALUE_RAW,ENDPOINT_REPEAT_COUNT,SCOPE from OCEANBASE.DBA_TAB_HISTOGRAMS where table_name='ex_t1';
--sorted_result
select s1.object_type,s1.sstable_row_cnt,s1.sstable_avg_row_len,s1.macro_blk_cnt,s1.micro_blk_cnt,s1.memtable_row_cnt,s1.memtable_avg_row_len,s1.row_cnt,s1.avg_row_len,s1.global_stats,s1.user_stats,s1.stattype_locked,s1.stale_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6,s1.index_type from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.object_type,s1.distinct_cnt,s1.null_cnt,s1.max_value,s1.b_max_value,s1.min_value,s1.b_min_value,s1.avg_len,s1.distinct_cnt_synopsis,s1.distinct_cnt_synopsis_size,s1.sample_size,s1.density ,s1.bucket_cnt,s1.histogram_type,s1.global_stats,s1.user_stats,s1.spare1,s1.spare2,s1.spare3,s1.spare4,s1.spare5,s1.spare6 from OCEANBASE.__ALL_COLUMN_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
--sorted_result
select s1.column_id,s1.endpoint_num,s1.object_type,s1.endpoint_normalized_value,s1.endpoint_value,s1.b_endpoint_value,s1.endpoint_repeat_cnt from OCEANBASE.__ALL_HISTOGRAM_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
# no records
--sorted_result
select * from OCEANBASE.DBA_PART_HISTOGRAMS where table_name='ex_t1';
--sorted_result
select * from OCEANBASE.DBA_SUBPART_HISTOGRAMS where table_name='ex_t1';
--sorted_result
select * from OCEANBASE.DBA_IND_STATISTICS where table_name='ex_t1';
--sorted_result
select * from OCEANBASE.DBA_PART_COL_STATISTICS where table_name='ex_t1';
--sorted_result
select * from OCEANBASE.DBA_SUBPART_COL_STATISTICS where table_name='ex_t1';
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;

# 2. lock_table_stats,unlock_table_stats
select s1.stattype_locked from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
call dbms_stats.lock_table_stats('TEST', 'EX_T1');
select s1.stattype_locked from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
call dbms_stats.unlock_table_stats('TEST', 'EX_T1');
select s1.stattype_locked from OCEANBASE.__ALL_TABLE_STAT s1,(select tenant_id,table_id from oceanbase.__all_table where table_name='ex_t1') s2 where s1.tenant_id=s2.tenant_id and s1.table_id=s2.table_id;
explain select c1, sum(c2) from ex_t1 where c1 > 5 group by c1, c2;

