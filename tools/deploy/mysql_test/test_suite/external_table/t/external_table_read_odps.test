# owner: sanquan.qz
# owner group: SQL3
# tags: external_table, odps
# description: test read external odps table

--source mysql_test/include/odps_config_for_cloud.inc
--result_format 4

--disable_query_log
connect(sys_conn, $OBMYSQL_MS0, root@sys,,oceanbase, $OBMYSQL_PORT);
connect(mysql_conn,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

connection sys_conn;
let $ver_org = query_get_value(show PARAMETERS like '%min_observer_version%', value, 1);
alter system set min_observer_version = '4.3.5.3';
connection mysql_conn;
--enable_query_log

## test show create table and partition table
--disable_warnings
drop table if exists ailing_t1, ailing_t1p, mlpt_10_col, mlpt_10_big, inc_data;
drop procedure if exists TEST_INC_DATA;
--enable_warnings
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE ailing_t1 (c1 int)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression_sqlqa'
SCHEMA_NAME = ''
TABLE_NAME = 'ailing_t1'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
);
select * from ailing_t1;
show create table ailing_t1;

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE ailing_t1p (
  c1 int,
  c2 varchar(10) AS (metadata\$partition_list_col1),
  c3 int AS (metadata\$partition_list_col2)
)
