# owner: linyi.cl
# owner group: SQL3
# tags: external_table
# issue: ctas分区外表, insert into from select分区外表 报错4016
# 2024072000103865288
# 2024072000103865355
# 2024072000103865311
# 2024080700104064414

--result_format 4
--enable_sorted_result
--disable_warnings
drop table if exists t1, test_part;
drop view if exists v1, v2;
--enable_warnings
set @@ob_query_timeout=1000000*60*60*10;

--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

create external table test_part (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

create table t1 as select * from test_part;

explain select * from test_part;
explain insert into t1 select * from test_part;
insert into t1 select * from test_part;

explain select /*+parallel(2)*/ * from test_part;
explain insert /*+parallel(2)*/ into t1 select * from test_part;
insert /*+parallel(2)*/ into t1 select * from test_part;

select count(*) from test_part;
select count(*) from t1;

explain insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert overwrite t1 select * from test_part;

create view v1 as select * from test_part;
explain select count(*) from v1,test_part;
select count(*) from v1,test_part;

drop table t1, test_part;
drop view v1;
