--source mysql_test/include/odps_config_for_cloud.inc
--result_format 4
--enable_sorted_result
--disable_warnings
drop table if exists t1, test_part;
drop view if exists v1, v2;
--enable_warnings
set @@ob_query_timeout=1000000*60*60*10;

# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_part(c1 INT, c2 INT) PARTITIONED BY (c3 VARCHAR(20)) STORED AS ALIORC;
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE test_part (
 c1             int AS (external\$tablecol1),
 c2             int AS (external\$tablecol2),
 c3          varchar(20) AS (metadata\$partition_list_col1)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_part'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
)
partition by (c3)
;

insert overwrite test_part partition (c3='abc') select 1,1 from dual;
insert overwrite test_part partition (c3='def') select 2,2 from dual;
insert overwrite test_part partition (c3='p3') select 3,3 from dual;
insert overwrite test_part partition (c3='p4') select 4,4 from dual;
alter external table test_part refresh;

select * from test_part;

create table t1 as select * from test_part;
select * from t1;

explain select * from test_part;
explain insert into t1 select * from test_part;
insert into t1 select * from test_part;

explain select /*+parallel(2)*/ * from test_part;
explain insert /*+parallel(2)*/ into t1 select * from test_part;
insert /*+parallel(2)*/ into t1 select * from test_part;
select * from t1;

explain insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert overwrite t1 select * from test_part;
select * from t1;

create view v1 as select * from test_part;
create view v2 as select * from test_part;
explain select count(*) from v1,v2,test_part;
select count(*) from v1,v2,test_part;

drop table t1, test_part;
drop view v1, v2;


--source mysql_test/include/external_table/delete_data_for_external_table.inc
--source mysql_test/include/external_table/copy_data_for_external_table.inc

create external table test_part (
time datetime,
errstate varchar(30),
errcode int,
errcontent varchar(100),
date_key datetime as (substr(substr(metadata$fileurl, instr(metadata$fileurl, '%') + 1), 1, 10))
)
location='mysqltest_data_for_external_table/external_table_mock_log'
FORMAT (
    type = 'csv',
    field_delimiter = ',',
    SKIP_BLANK_LINES = TRUE
)
partition by (date_key)
;

create table t1 as select * from test_part;

explain select * from test_part;
explain insert into t1 select * from test_part;
insert into t1 select * from test_part;

explain select /*+parallel(2)*/ * from test_part;
explain insert /*+parallel(2)*/ into t1 select * from test_part;
insert /*+parallel(2)*/ into t1 select * from test_part;

select count(*) from test_part;
select count(*) from t1;

explain insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert /*+parallel(2)*/ overwrite t1 select * from test_part;
insert overwrite t1 select * from test_part;

create view v1 as select * from test_part;
explain select count(*) from v1,test_part;
select count(*) from v1,test_part;

drop table t1, test_part;
drop view v1;
