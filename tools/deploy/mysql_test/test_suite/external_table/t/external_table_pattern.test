# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test create external table

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;

create external table ex_t1 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
pattern='temp[0-3].dat'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

create external table ex_t2 (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);

--result_format 4
--enable_query_log

select * from ex_t1;
select * from ex_t2;

select external_file_pattern from oceanbase.__all_virtual_table where table_name='ex_t1';
select external_file_pattern from oceanbase.__all_virtual_table where table_name='ex_t2';

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ex_t2;

# select file_url from oceanbase.__all_external_table_file;

--disable_query_log
drop table ex_t1;
drop table ex_t2;
--source mysql_test/include/external_table/delete_data_for_external_table.inc
