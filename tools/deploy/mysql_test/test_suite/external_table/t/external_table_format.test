--disable_query_log
--error 0,1051
drop table t1;
--enable_query_log

--error 1083
create external table t1(c1 int) format (type='CSV' LINE_DELIMITER = '\\');
--error 1083
create external table t1(c1 int) format (type='CSV' FIELD_DELIMITER = '\\');
--error 1083
create external table t1(c1 int) format (type='CSV' LINE_DELIMITER = 'a'  FIELD_OPTIONALLY_ENCLOSED_BY = 'a');
--error 1083
create external table t1(c1 int) format (type='CSV' FIELD_DELIMITER = 'a' FIELD_OPTIONALLY_ENCLOSED_BY = 'a');
--error 1235
create external table t1(c1 int) format (type='CSV' ESCAPE = 'a' FIELD_OPTIONALLY_ENCLOSED_BY = 'a');


