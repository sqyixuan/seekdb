create table test_date_ (c1 date, c2 datetime(3));
insert into test_date_ values('2020-10-10','2020-1-1 1:00:10'),('2024-2-1','2023-10-1 8:00:00');
insert overwrite test_date select * from test_date_;

select * from test_date_;
select * from test_date;

set time_zone = "+8:00";
--error 1441
insert into test_date(c1) select '0000-00-00' from dual;
insert into test_date(c1) select '0001-01-01' from dual;
