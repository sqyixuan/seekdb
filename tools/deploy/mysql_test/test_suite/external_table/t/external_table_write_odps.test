# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_part(c1 INT, c2 INT) PARTITIONED BY (c3 VARCHAR(20)) STORED AS ALIORC;
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE test_part (
 c1             int AS (external\$tablecol1),
 c2             int AS (external\$tablecol2),
 c3          varchar(20) AS (metadata\$partition_list_col1)
)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_part'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
)
partition by (c3)
;

create table test_part_(c1 int, c2 int);

# need create partition first
# alter table linyi_test_part add partition (c3='abc');
# alter table linyi_test_part add partition (c3='def');
# alter table linyi_test_part add partition (c3='p3');
# alter table linyi_test_part add partition (c3='p4');
insert overwrite test_part partition (c3='abc') select * from test_part_;
insert overwrite test_part partition (c3='def') select * from test_part_;
insert /*+parallel(3)*/ overwrite test_part partition (c3='p3') select * from test_part_;
insert /*+parallel(3)*/ overwrite test_part partition (c3='p4') select * from test_part_;

insert into test_part_ values(1,2),(2,3),(3,4);

insert into test_part partition (c3='abc') select * from test_part_;
insert into test_part partition (c3 = 'def') select * from test_part_;
insert /*+parallel(3)*/ into test_part partition (c3 ='p3') select * from test_part_;
insert /*+parallel(3)*/ into test_part partition (c3= 'p4') select * from test_part_;

alter external table test_part refresh;
set ob_query_timeout=1000000000;
select * from test_part;

drop table test_part;

# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_performance3(c1 INT, c2 VARCHAR(500), c3 VARCHAR(500),
# c4 VARCHAR(500), c5 VARCHAR(500)) partitioned by (c6 varchar(10), c7 int);

--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE test_part (
    c1 int AS (external\$tablecol1),
    c2 varchar(500) AS (external\$tablecol2),
    c3 varchar(500) AS (external\$tablecol3),
    c4 varchar(500) AS (external\$tablecol4),
    c5 varchar(500) AS (external\$tablecol5),
    c6 varchar(10) AS (metadata\$partition_list_col1),
    c7 int AS (metadata\$partition_list_col2)
)
PROPERTIES = (
REGION = 'shanghai'
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_performance3'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
)
partition by (c6,c7)
;

insert overwrite test_part partition (c6='20201010',c7=12345678) select 1,'a','b','c','d' from dual;
alter external table test_part refresh;
select * from test_part;

--source mysql_test/include/external_table/copy_data_for_external_table.inc
create external table t1_csv (
    c1 int,
    c2 int,
    c3 int
)
location='mysqltest_data_for_external_table/external_table_lineitem'
format (
    type = 'csv',
    line_delimiter = NVL(NULL, 'b'),
    field_delimiter = UPPER('a'),
    field_optionally_enclosed_by = NVL(NULL, ''),
    null_if = (NVL(NULL, 'NULL'),UPPER('c'))
);
--error 1235
insert into t1_csv select 1,2,3 from dual;

create external table t1_parquet (
    c1 bigint as (cast(get_path(external$filerow, 'int') as signed)),
    c2 varchar(1000) as (cast(get_path(external$filerow, 'string') as char)),
    c3 decimal(6,3) as (cast(get_path(external$filerow, 'decimal32') as decimal(6,3))),
    c4 decimal as (cast(get_path(external$filerow, 'decimal64') as decimal)),
    c6 date as (cast(get_path(external$filerow, 'date') as date))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table/parquet_ex_t1';
--error 1235
insert into t1_parquet select null,null,null,null,null from dual;

drop table t1, t1_, t2, t2_, t3, t3_, test_date, test_date_, test_part, test_part_, t1_csv, t1_parquet;
--source mysql_test/include/external_table/delete_data_for_external_table.inc
set ob_query_timeout=10000000;

