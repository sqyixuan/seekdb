# owner: linyi.cl
# owner group: SQL3
# tags: external_table, select_into
# description: test insert into external table in odps

--source mysql_test/include/odps_config_for_cloud.inc
--result_format 4
--disable_warnings
drop table if exists t1, t1_, t2, t2_, t3, t3_, test_date, test_date_, test_part, test_part_, t1_csv, t1_parquet;
--enable_warnings
 
# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_int(c1 INT, c2 INT) STORED AS ALIORC;
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE t1 (c1 int, c2 int)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_int'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
);

create table t1_(c1 int, c2 int);
insert into t1_ values(1,1),(2,2),(3,3);
insert overwrite t1 select 1, 2 from dual;
select * from t1;

explain insert into t1 select * from t1_;
explain insert /*+parallel(5)*/ into t1 select * from t1_;

insert into t1 select * from t1_;
select * from t1;
insert /*+parallel(5)*/ into t1 select * from t1_;
--sorted_result
select * from t1;

delete from t1_;
select count(*) from t1;
insert into t1 select * from t1_;
select count(*) from t1;
insert overwrite t1 select * from t1_;
select count(*) from t1;

insert /*+append enable_parallel_dml parallel(8) */ into t1_
select UNIFORM(1, 1000, random(7)), UNIFORM(1, 1000, random(7)) from table(generator(10000));
insert /*+parallel(5)*/ into t1 select * from t1_;
select count(*) from t1;

# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_select_into0(c1 TINYINT, c2 SMALLINT, c3 INT, c4 BIGINT, c5 FLOAT, c6 DOUBLE, c7 DECIMAL(38,18), c8 BINARY, c9 STRING, c10 TIMESTAMP, c11 CHAR(10), c12 VARCHAR(20), c13 JSON, c14 TIMESTAMP_NTZ) STORED AS ALIORC;
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE t2
(c1 tinyint, c2 smallint, c3 int, c4 bigint, c5 float, c6 double, c7 decimal(38,18), c8 blob,
c9 text, c10 timestamp(6), c11 char(10), c12 varchar(20), c13 json, c14 datetime)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_select_into0'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
);

create table t2_
(c1 tinyint, c2 smallint, c3 int, c4 bigint, c5 float, c6 double, c7 decimal(38,18), c8 blob,
c9 text, c10 timestamp(6), c11 char(10), c12 varchar(20), c13 json, c14 datetime);

insert into t2_ values(null,null,null,null,null,null,null,null,null,null,null,null,null,null);
insert into t2_ values(1,2,3,4,5.5,6.666,7.7777, "blobc80101", "text c9", "2010-10-10 10:10:10",
"c11", "c1212", '{"id":129}', "2014-12-14 8:00:00");
insert into t2_ values(1,2,3,4,5.5,6.666,7.7777, "blobc81111", "text c9", "2010-10-10 10:10:10",
"c11", "c1212", '{"name":"ak"}', "2014-12-14 1:00:00");
insert into t2_ values(1,2,3,4,5.5,6.666,7.7777, "blobc81234", "text c9", "2010-10-10 10:10:10",
"c11", "c1212", null, "2014-12-14");

insert overwrite t2 select * from t2_;
insert /*+parallel(4)*/ overwrite t2 select * from t2_;

#set time_zone = "+0:00";
#select * from t2_;
#select * from t2;

set time_zone = "+8:00";
select * from t2_;
#select * from t2;

insert into t2 select * from t2_;
insert /*+parallel(4)*/ into t2 select * from t2_;
#select * from t2;

--error 1441
insert into t2(c10) select '0000-00-00 00:00:00' from dual;
--error 1441
insert into t2(c14) select '0000-00-00 00:00:00' from dual;
--error 1441
insert into t2(c10) select '0001-01-01 00:00:00' from dual;
insert into t2(c10) select '0001-01-01 08:00:00' from dual;
insert into t2(c14) select '0001-01-01 00:00:00' from dual;

# CREATE TABLE IF NOT EXISTS mysqltest_regression.linyi_test_select_into1(c1 BOOLEAN, c2 DECIMAL(20,10), c3 STRING, c4 STRING, c5 BINARY, c6 BINARY) STORED AS ALIORC;
--source mysql_test/include/select_into_outfile/replace_odps_info.inc
eval CREATE EXTERNAL TABLE t3
(c1 tinyint, c2 decimal(20,10), c3 varchar(500), c4 longtext, c5 varbinary(500), c6 longblob)
PROPERTIES = (
TYPE = 'ODPS'
ACCESSID = '$ODPS_ACCESSID'
ACCESSKEY = '$ODPS_ACCESSKEY'
ENDPOINT = '$ODPS_ENDPOINT'
TUNNEL_ENDPOINT = 'http://dt.cn-hangzhou.maxcompute.aliyun.com'
PROJECT_NAME = 'mysqltest_regression'
SCHEMA_NAME = ''
TABLE_NAME = 'linyi_test_select_into1'
QUOTA_NAME = ''
COMPRESSION_CODE = ''
COLLECT_STATISTICS_ON_CREATE = FALSE
);

create table t3_(c1 tinyint, c2 decimal(20,10), c3 varchar(500), c4 longtext, c5 varbinary(500), c6 longblob);
insert overwrite t3 select * from t3_;

insert into t3_ values(null,null,null,null,null,null);
insert into t3_ values(0, 1, '', '', '', '');
insert into t3_ values(1, 12.345, 'asdfghjk', 'qwertyuiop', 'asdfghjk', 'qwertyuiop');
insert into t3_ values(1, 12.345678, 'AA', 'NOT', 'NULL', 'PPP');
insert into t3 select * from t3_;
insert into t3(c1,c2) select c1,c2 from t3_;
--sorted_result
select * from t3;

