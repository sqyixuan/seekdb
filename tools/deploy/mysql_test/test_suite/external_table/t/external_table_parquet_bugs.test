# owner: jim.wjh
# owner group: SQL3
# tags: external_table
# description: test parquet format for external table.

--source mysql_test/include/external_table/copy_data_for_external_table.inc

--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--error 0,1051
drop table ex_t3;
--error 0,1051
drop table ex_t4;
--enable_query_log

--echo issue 57611419
CREATE EXTERNAL TABLE `ex_t1` (
  `c1` int(11) GENERATED ALWAYS AS (get_path(external$filerow,'c1')),
  `c2` int(11) GENERATED ALWAYS AS (get_path(external$filerow,'c2')),
  `c3` varchar(50) GENERATED ALWAYS AS (get_path(external$filerow,'c3')),
  `c4` date GENERATED ALWAYS AS (get_path(external$filerow,'c4'))
)
LOCATION='mysqltest_data_for_external_table/issue57611419/ex_t1'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'PARQUET'
) DEFAULT CHARSET = utf8mb4;


CREATE EXTERNAL TABLE `ex_t3` (
  `c1` int(11) GENERATED ALWAYS AS (get_path(external$filerow,'c1')),
  `c2` int(11) GENERATED ALWAYS AS (get_path(external$filerow,'c2'))
)
LOCATION='mysqltest_data_for_external_table/issue57611419/ex_t3'
AUTO_REFRESH = OFF
FORMAT (
  TYPE = 'PARQUET'
) DEFAULT CHARSET = utf8mb4;

SELECT/*+no_rewrite*/ *
FROM (ex_t3 AS ref_0
      LEFT JOIN
        (SELECT 1 AS c5,
                1 AS c10
         FROM ex_t1 AS ref_1) AS subq_0 ON (1));

SELECT *
FROM (ex_t3 AS ref_0
      LEFT JOIN
        (SELECT 1 AS c5,
                1 AS c10
         FROM ex_t1 AS ref_1) AS subq_0 ON (1));

drop table ex_t1;
drop table ex_t3;

--echo issue 2024100800104637876
create external table ex_t1(
c1 NUMBER(5,2) as (get_path(external$filerow, 'c1'))
)
location 'mysqltest_data_for_external_table/issue2024100800104637876/ex_t1'
format (type = 'PARQUET');

select * from ex_t1;
drop table ex_t1;

--echo issue 2024100900104642883
create external table ex_t1(
`id` int(11) GENERATED ALWAYS AS (get_path(external$filerow,'id')),
  `money` double GENERATED ALWAYS AS (get_path(external$filerow,'money')),
  `money1` float GENERATED ALWAYS AS (get_path(external$filerow,'money1')),
  `name` varchar(200) GENERATED ALWAYS AS (get_path(external$filerow,'name'))
)
location 'mysqltest_data_for_external_table/issue2024100900104642883/ex_t1'
format (type = 'PARQUET');

select * from ex_t1;
drop table ex_t1;

#issue2024111200105076234

--disable_query_log
--error 0,1051
drop table t1;
--enable_query_log

create external table t1(c1 int, c2 int)
location 'mysqltest_data_for_external_table/issue2024111200105076234' format(type='parquet');

select * from t1;

drop table t1;

#issue2024120400105968789

--disable_query_log
--error 0,1051
drop table t1;
