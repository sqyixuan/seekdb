# owner: yibo.tyf
# owner group: SQL1
# tags: external_table

--result_format 4
--source mysql_test/include/odps_config_for_cloud.inc

--disable_result_log
let $ODPS_CMD_INITTABLE = odpscmd -e "drop table IF  EXISTS t_2025031700107576513;create table t_2025031700107576513 (c1 TIMESTAMP,c2 BIGINT,c3 BIGINT,c4 DATE) PARTITIONED BY (c5 STRING,c6 STRING,c7 STRING);
ALTER TABLE t_2025031700107576513 ADD if NOT EXISTS PARTITION (c5='2024',c6='2024',c7='2024');";
exec $ODPS_CMD_INITTABLE;
--enable_result_log

--disable_warnings
drop table if exists t_2025031700107576513;
--enable_warnings

--source mysql_test/test_suite/extable3_odps_datatype_sqlqa/include/replace_odps_info.inc
eval create  external table t_2025031700107576513 (
c1 TIMESTAMP(6),c2 BIGINT,c3 BIGINT,c4 DATE,
c5 VARCHAR(86)  AS (metadata\$partition_list_col1),
c6 VARCHAR(86)  AS (metadata\$partition_list_col2),
c7 VARCHAR(86)  AS (metadata\$partition_list_col3)
)
AUTO_REFRESH = IMMEDIATE
PROPERTIES =(
type = "odps"
ACCESSID = "$ODPS_ACCESSID"
ACCESSKEY = "$ODPS_ACCESSKEY"
PROJECT_NAME = "mysqltest_regression_sqlqa"
ENDPOINT = "$ODPS_ENDPOINT"
TABLE_NAME ="t_2025031700107576513"
)
partition by (c5,c6,c7);

select * from t_2025031700107576513 limit 1;

drop table t_2025031700107576513;