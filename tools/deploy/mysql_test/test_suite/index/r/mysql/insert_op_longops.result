result_format: 4



drop table if exists lineitem;
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(l_orderkey) partitions 10;

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
create /*+parallel(2)*/index idx1 on lineitem(l_quantity, l_suppkey,l_extendedprice);
select sum(OTHERSTAT_1_VALUE), sum(OTHERSTAT_2_VALUE) from (select OTHERSTAT_1_VALUE,OTHERSTAT_2_VALUE from oceanbase.__all_virtual_sql_plan_monitor where PLAN_OPERATION = 'PHY_PX_MULTI_PART_SSTABLE_INSERT' order by LAST_REFRESH_TIME desc limit 2);
+------------------------+------------------------+
| sum(OTHERSTAT_1_VALUE) | sum(OTHERSTAT_2_VALUE) |
+------------------------+------------------------+
|                      0 |                 100000 |
+------------------------+------------------------+


create /*+parallel(4)*/index idx2 on lineitem(l_partkey, l_suppkey,l_orderkey) with column group(all columns, each column);
select sum(OTHERSTAT_1_VALUE), sum(OTHERSTAT_2_VALUE) from (select OTHERSTAT_1_VALUE, OTHERSTAT_2_VALUE from oceanbase.__all_virtual_sql_plan_monitor where PLAN_OPERATION = 'PHY_PX_MULTI_PART_SSTABLE_INSERT' order by LAST_REFRESH_TIME desc limit 4);
+------------------------+------------------------+
| sum(OTHERSTAT_1_VALUE) | sum(OTHERSTAT_2_VALUE) |
+------------------------+------------------------+
|                 500000 |                 100000 |
+------------------------+------------------------+

alter table lineitem add column group(all columns, each column);
select OTHERSTAT_1_VALUE, OTHERSTAT_2_VALUE from oceanbase.__all_virtual_sql_plan_monitor where PLAN_OPERATION = 'PHY_PX_MULTI_PART_SSTABLE_INSERT' order by LAST_REFRESH_TIME desc limit 3;
+-------------------+-------------------+
| OTHERSTAT_1_VALUE | OTHERSTAT_2_VALUE |
+-------------------+-------------------+
|            500000 |            100000 |
|                 0 |            100000 |
|           1700000 |            100000 |
+-------------------+-------------------+
