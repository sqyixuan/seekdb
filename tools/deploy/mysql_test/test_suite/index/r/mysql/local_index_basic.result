| a    | b    | c    | d    |
+------+------+------+------+
|    1 |    1 |    2 |    0 |
+------+------+------+------+
drop table gen_t;

create table t1(a int primary key, b int, c int generated always as (a+1), d int);
insert into t1(a,b,d) values(1,1,1);
update t1 set a=1, d=0 where a=1;
select * from t1;
