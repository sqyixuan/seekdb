drop table if exists t0, t1, t2, gen_t;
create table t1(a int primary key, b int, c int, index i1(b));
insert into t1 values(1, 1, 1);
select /*+index(t1 i1)*/ a, b from t1 where b=1;
+---+------+
| a | b    |
+---+------+
| 1 |    1 |
+---+------+
select /*+index(t1 i1)*/ a, b, c from t1 where b=1;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 1 |    1 |    1 |
+---+------+------+
select /*+index(t1 i1)*/ a, b, c from t1 where b=1 and a=0;
+---+------+------+
| a | b    | c    |
+---+------+------+
+---+------+------+
select /*+index(t1 i1)*/ a, b, c from t1 where b=1 and c=1;
