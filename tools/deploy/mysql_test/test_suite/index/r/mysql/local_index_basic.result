| a | b    | c    |
+---+------+------+
| 1 |    1 |    1 |
+---+------+------+
select /*+index(t1 i1)*/ a, b, c from t1 where b=1 and c=0;
+---+------+------+
| a | b    | c    |
+---+------+------+
+---+------+------+
drop table t1;

create table t1(a int, b int, c int, d int, e int, primary key(a,b,c,d), key k1(b) local, key k2(c,b) local, key k3(c,d,b) local) partition by hash(b) partitions 2;
