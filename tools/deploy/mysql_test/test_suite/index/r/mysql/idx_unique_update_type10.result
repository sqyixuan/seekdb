drop table if exists test;
create table test(pk1 int primary key, c1 int, c2 int);
create unique index i1 on test(c1,c2);
update test set c1=0 where pk1=0;
select * from test;
pk1	c1	c2
insert into test values(1,1,1),(0,2,2);
update test set c1=0 where pk1=0;
update test set c1=3 where pk1=1;
select * from test order by pk1;
pk1	c1	c2
0	0	2
1	3	1
insert into test values(3,3,3),(4,4,4);
update test set c1=5 where pk1=0 limit 1;
update test set c1=6 where pk1=1 limit 1;
select * from test order by pk1;
pk1	c1	c2
0	5	2
1	6	1
3	3	3
4	4	4
update test set c1=5 where pk1=0 order by c2 limit 1;
update test set c1=6 where pk1=1  order by c1 desc limit 1;
select * from test order by pk1;
pk1	c1	c2
0	5	2
1	6	1
3	3	3
4	4	4
update test set c1=5 where pk1=-1 order by c2 limit 1;
update test set c1=6 where pk1=-3  order by c1 desc limit 1;
select * from test order by pk1;
pk1	c1	c2
0	5	2
1	6	1
3	3	3
4	4	4
delete from  test  where pk1=-1 order by c2 limit 1;
delete from test where pk1=-3  order by c1 desc limit 1;
select * from test order by pk1;
pk1	c1	c2
0	5	2
1	6	1
3	3	3
4	4	4
