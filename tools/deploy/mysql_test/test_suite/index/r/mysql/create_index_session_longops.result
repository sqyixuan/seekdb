drop table if exists t1;
create table t1(c1 int, c2 int auto_increment);
insert into t1 values(1,1),(2,2),(3,3),(4,4);
create index i1 on t1(c1);
alter system set debug_sync_timeout = '10000s';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'CREATE_INDEX_WAIT_TRANS_END wait_for signal1 execute 10000';
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for signal2 execute 10000';
set ob_global_debug_sync = 'CREATE_INDEX_TAKE_EFFECT wait_for signal3 execute 10000';
alter table t1 drop column c2;
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS WHERE MESSAGE LIKE '%PENDING_TX_ID%';
OPNAME
create index
set ob_global_debug_sync = 'CREATE_INDEX_WAIT_TRANS_END clear';
set ob_global_debug_sync = 'now signal signal1';
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
OPNAME
create index
table redefinition
set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD clear';
set ob_global_debug_sync = 'now signal signal2';
SELECT OPNAME FROM oceanbase.GV$SESSION_LONGOPS ORDER BY OPNAME;
OPNAME
create index
table redefinition
set ob_global_debug_sync = 'CREATE_INDEX_TAKE_EFFECT clear';
set ob_global_debug_sync = 'now signal signal3';
drop table t1;
