--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: fanfangzhou.ffz
# owner group: RS
# description: test create index would not confilict to built in index

connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
alter system set ob_vector_memory_limit_percentage = 10;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

alter system set _parallel_ddl_control = "create_index:on";
--source built_in_index_not_visible.inc

alter system set _parallel_ddl_control = "create_index:off";
--source built_in_index_not_visible.inc
