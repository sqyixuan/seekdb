--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy 
# owner group: SQL1
# description: 本case是为了测试唯一索引.(验证完整性约束；验证drop 索引后去掉完整性约束)

--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
--source mysql_test/include/check_all_idx_ok_unq.inc
--replace_column 3 idx_name 
show index from t1; 
select * from t1; 
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(3,5);
--error 1062 
insert into t1 values(3,6),(1,1),(1,2),(2,3),(2,4);
--error 1062 
insert into t1 values(4,5);
delete from t1; 
--disable_query_log
--let $loop=1000
while  ($loop)
{
  eval insert into t1 values($loop,$loop);
  dec $loop;
}
--enable_query_log
select count(*) from t1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from t1;
####case: drop unique index,after insert same data 
drop index idx1 on t1;
sleep 10;
--disable_query_log
--let $loop=1000
while  ($loop)
{
  eval insert into t1 values($loop,$loop+1001);
  dec $loop;
}
--enable_query_log

select count(*) from t1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from t1;
delete from t1;
create unique index idx1 on t1(a);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--disable_query_log
--let $loop=1000
while  ($loop)
{
    eval insert into t1 values($loop,$loop);
      dec $loop;
}
--enable_query_log
select count(*) from t1; 
--error 1062 
insert into t1 values(1,1);
drop table t1;
