#owner: linyi.cl
#owner group: sql3
#description: mysql5.7cmpt descending index parsed but ignored
#tags: ddl
#


--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings

##create table
create table t1(c1 int, c2 int, index t1i1 (c1 asc), index t1i2 (c2 desc), 
                index t1i3 using hash (c2 desc, c1 desc), index t1i4 using btree (c2 asc, c1 desc));
create table t2(c1 int, c2 int, unique key t2i1 (c1 asc, c2 desc));
create table t3(c1 int, c2 int, constraint unique key t3i1 (c1 asc, c2 desc));
--error 1221
create table t4(c1 geometry not null, spatial index t4i1 (c1 desc));
--error 1221
create table t4(c1 geometry not null, spatial index t4i1 (c1 asc));
create table t4(c1 geometry not null, c2 geometry not null, c3 geometry not null, spatial index t4i1 (c1));

##alter table
alter table t1 add index t1i5 (c1 asc, c2 desc), add index t5i6 using hash (c1 desc);
alter table t2 add unique key t2i2 using hash (c1 desc, c2 asc);
alter table t3 add constraint unique key t3i2 (c1 desc, c2 desc);
--error 1221
alter table t4 add spatial index t4i2 (c2 desc);
--error 1221
alter table t4 add spatial index t4i2 (c2 asc);
alter table t4 add spatial index t4i2 (c2);

##create index
create index t1i7 using hash on t1 (c2 desc);
--error 1221
create spatial index t4i3 on t4(c3 desc);
--error 1221
create spatial index t4i3 on t4(c3 asc);
create spatial index t4i3 on t4(c3);
create unique index t2i3 on t2(c1 desc, c2 desc);
create unique index t2i4 using hash on t2(c1 desc, c2 desc);

drop table t1, t2, t3, t4;