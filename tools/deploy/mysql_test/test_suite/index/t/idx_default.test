--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: qiaolinjun.qlj
# owner group: SQL1
# description: test MySQL default index mode is local

--result_format 4
##--explain_protocol 2

--disable_warnings
drop table if exists t1;
--enable_warnings
## 1 create index after table creation
## 1.1 create default index, should be local
create table t1(c1 int primary key, c2 int, c3 int);
create index idx on t1(c2);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.2 create default unique index, should be local
create unique index idx on t1(c2);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.3 create global index
create index idx on t1(c2) global;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.4 create global unique index
create unique index idx on t1(c2) global;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.5 create partitioned index, should be global
create index idx on t1(c2) partition by hash(c2) partitions 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.6 create global partitioned index
create index idx on t1(c2) global partition by hash(c2) partitions 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 1.7 create local partitioned index, should fail
--error 1235
create index idx on t1(c2) local partition by hash(c2) partitions 2;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;

## 1.8 cleanup
--disable_warnings
drop table if exists t1;
--enable_warnings

## 2 create table with index
## 2.1 create default index, should be local
create table t1(c1 int primary key, c2 int, c3 int, index idx(c2));
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;
drop table t1;

## 2.2 create default unique index, should be local
create table t1(c1 int primary key, c2 int, c3 int, unique index idx(c2));
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;
drop table t1;

## 2.3 create global index
create table t1(c1 int primary key, c2 int, c3 int, index idx(c2) global);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;
drop table t1;

## 2.4 create global unique index
create table t1(c1 int primary key, c2 int, c3 int, unique index idx(c2) global);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;
drop table t1;

## 2.5 cleanup
--disable_warnings
drop table if exists t1;
--enable_warnings

## 3 alter table to add index
## 3.1 create default index, should be local
create table t1(c1 int primary key, c2 int, c3 int);
alter table t1 add index idx(c2);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 3.2 create default unique index, should be local
alter table t1 add unique index idx(c2);
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 3.3 create global index
alter table t1 add index idx(c2) global;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 3.4 create global unique index
alter table t1 add unique index idx(c2) global;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop index idx on t1;

## 3.5 cleanup
--disable_warnings
drop table if exists t1;
--enable_warnings
