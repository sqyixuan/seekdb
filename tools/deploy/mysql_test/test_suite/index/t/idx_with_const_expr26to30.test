--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group: SQL4
#description: Test index with constant expr
#tags: cost

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, c1 int,c2 int);
create index ia on t1(c1);

--source mysql_test/include/check_all_idx_ok.inc
insert into t1 values(1,9,1),(2,8,2),(3,7,3),(4,6,6),(5,5,5);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t1 where c1 between 0 and 10;
select * from t1 where c1 between length('') and length('0123456789');
#检查表达式与索引列的顺序
select * from t1 where length('') <= c1 and length('0123456789') >= c1;
select * from t1 where length('') <= c1 and c1<=10;
select * from t1 where c1>=0 and length('0123456789') >= c1;
select * from t1 where c1 >= length('') and c1 <= length('0123456789');


select * from t1 where c1>= '0' and c1<= '10';
select * from t1 where c1>= substr('a0a000',2,1) and c1<= substr('10a0000',1,2);

select * from t1 where c1>= cast(substr('a0a000',2,1)  as signed int) and c1<= cast(substr('10a0000',1,2) as signed int);


select /*+ index(t1 primary) */* from t1 where c1>= '0' and c1<= '10';
select /*+ index(t1 ia) */* from t1 where c1>= '0' and c1<= '10';
select /*+ index(t1 primary) */* from t1 where c1>= substr('a0a000',2,1) and c1<= substr('10a0000',1,2);
select /*+ index(t1 ia) */* from t1 where c1>= substr('a0a000',2,1) and c1<= substr('10a0000',1,2);

update t1 set c1=2 where c1=length('01234567');
select * from t1 ;
update t1 set c1=2 where c1=length('01');
select * from t1 where c1 between 1 and 10 ;
update t1 set c1=2 where c1=length('01');
select * from t1 where c1 between 5-4 and 5*2;
select c1   from t1 where c1=length('01');
select * from t1 where c1 between 5-4 and 5*2;

update t1 set c1=8 where c1=length('01');
update t1 set c1=3 where c1=length('0123456');
select * from t1;








