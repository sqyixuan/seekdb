# link: 

--disable_warnings
drop database if exists analyze_test;
drop database if exists analyze_test2;
--enable_warnings

create database analyze_test;
use analyze_test;
create table t1(c1 int, c2 int, c3 int, index i1(c1,c2)) partition by hash(c1) partitions 2;
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create table t4(c1 int, c2 int);
insert into t1 values(1,2,3), (4,5,6), (7,8,9);
insert into t2 values(1,1),(2,2);
insert into t3 values(3,3),(0,0);
insert into t4 values(3,3),(0,0);

create database analyze_test2;
create table analyze_test2.t2(c1 int, c2 int);
insert into analyze_test2.t2 values(1,1),(2,2),(3,3);

#analyze single table
analyze table t1;
select OWNER,TABLE_NAME,PARTITION_NAME,PARTITION_POSITION,NUM_ROWS,AVG_ROW_LEN
       from OCEANBASE.DBA_TAB_STATISTICS
       where owner = 'analyze_test' and table_name = 't1' order by 1, 2, 3, 4, 5, 6;
select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,
       NUM_BUCKETS,SAMPLE_SIZE,AVG_COL_LEN,HISTOGRAM from OCEANBASE.DBA_TAB_COL_STATISTICS
       where owner = 'analyze_test' and table_name = 't1';
select OWNER,TABLE_NAME,PARTITION_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,SAMPLE_SIZE,HISTOGRAM
       from OCEANBASE.DBA_PART_COL_STATISTICS
       where owner = 'analyze_test' and table_name = 't1' order by 1, 2, 3, 4, 5, 6, 7, 8, 9;
select * from OCEANBASE.DBA_IND_STATISTICS where owner = 'analyze_test' and table_name = 't1';

#analyze multi table
analyze table t2,t3;
select OWNER,TABLE_NAME,PARTITION_NAME,PARTITION_POSITION,NUM_ROWS,AVG_ROW_LEN
       from OCEANBASE.DBA_TAB_STATISTICS
       where owner = 'analyze_test' and table_name in ('t2','t3') order by 1, 2, 3, 4, 5, 6;
select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,
       NUM_BUCKETS,SAMPLE_SIZE,AVG_COL_LEN,HISTOGRAM
       from OCEANBASE.DBA_TAB_COL_STATISTICS
       where owner = 'analyze_test' and table_name in ('t2','t3') order by 1, 2, 3, 4, 5, 6;
analyze table t4,analyze_test2.t2;
select OWNER,TABLE_NAME,PARTITION_NAME,PARTITION_POSITION,NUM_ROWS,AVG_ROW_LEN
       from OCEANBASE.DBA_TAB_STATISTICS
       where owner = 'analyze_test' and table_name ='t4' order by 1, 2, 3, 4, 5, 6;
select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,
       NUM_BUCKETS,SAMPLE_SIZE,AVG_COL_LEN,HISTOGRAM
       from OCEANBASE.DBA_TAB_COL_STATISTICS
       where owner = 'analyze_test' and table_name ='t4' order by 1, 2, 3, 4, 5, 6;
select OWNER,TABLE_NAME,PARTITION_NAME,PARTITION_POSITION,NUM_ROWS,AVG_ROW_LEN
       from OCEANBASE.DBA_TAB_STATISTICS
       where owner = 'analyze_test2' and table_name ='t2' order by 1, 2, 3, 4, 5, 6;
select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,
       NUM_BUCKETS,SAMPLE_SIZE,AVG_COL_LEN,HISTOGRAM
       from OCEANBASE.DBA_TAB_COL_STATISTICS
       where owner = 'analyze_test2' and table_name ='t2' order by 1, 2, 3, 4, 5, 6;

#mysql returns a result set
--error 1066
analyze table t1,t1;
--error 1146
analyze table t1,t11;

#update histogram
ANALYZE TABLE t1 update histogram on c3;

select OWNER,TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,
       NUM_BUCKETS,SAMPLE_SIZE,AVG_COL_LEN,HISTOGRAM
       from OCEANBASE.DBA_TAB_COL_STATISTICS
       where owner = 'analyze_test' and table_name = 't1' order by 1, 2, 3, 4, 5, 6;
select * from OCEANBASE.DBA_TAB_HISTOGRAMS where owner = 'analyze_test' and table_name = 't1';

drop database analyze_test;
drop database analyze_test2;