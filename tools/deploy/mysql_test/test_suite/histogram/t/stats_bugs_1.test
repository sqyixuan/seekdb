#dup params should raise error 1330 in mysql mode.
--error 1330
call dbms_stats.export_index_stats('YYL', 'IDX_1', tabname=>'I_GENERAL_TAB_UNIFORM', stattab=>'t_stat', statown=>'YYL',statown=>'YYL');

# bug code.alibaba-inc.com/oceanbase/oceanbase/codereview/8815537
--error 0,1051
DROP TABLE T1;
create table t1(c1 int);
call dbms_stats.gather_table_stats('TEST', 'T1');
--error 5935
call dbms_stats.restore_table_stats('TEST', 'T1', STR_TO_DATE('2000-09-26 19:02:12', '%Y-%m-%d %H:%i:%s'));
--error 5935
call dbms_stats.restore_table_stats('TEST', 'T1', STR_TO_DATE('2200-09-26 19:02:12', '%Y-%m-%d %H:%i:%s'));
drop table t1;
