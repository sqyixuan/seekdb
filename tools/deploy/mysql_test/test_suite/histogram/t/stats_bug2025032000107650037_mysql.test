# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int);
create table t2(c1 varchar(4000));
create table t3 (c1 text);

set @n := 1;
insert into t1 select @n := @n + 1  from table(generator(50000));
insert into t2 values (repeat('1', 4000)),(repeat('2', 4000)),(repeat('3', 4000)),(repeat('4', 4000)),(repeat('5', 4000)),(repeat('6', 4000)),(repeat('7', 4000)),(repeat('8', 4000)),(repeat('1', 4000));
insert into t3 values (repeat('1', 4000)),(repeat('2', 4000)),(repeat('3', 4000)),(repeat('4', 14000)),(repeat('5', 14000)),(repeat('6', 14000)),(repeat('7', 14000)),(repeat('8', 14000)),(repeat('1', 14000));

select /*+ OPT_PARAM('enable_rich_vector_format', 'true') */ md5(hybrid_hist(c1, 128)) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'false') */ md5(hybrid_hist(c1, 128)) from t1;

select /*+ OPT_PARAM('enable_rich_vector_format', 'true') */ md5(hybrid_hist(c1, 128)) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'false') */ md5(hybrid_hist(c1, 128)) from t2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'true') */ md5(hybrid_hist(c1, 128)) from t3;
select /*+ OPT_PARAM('enable_rich_vector_format', 'false') */ md5(hybrid_hist(c1, 128)) from t3;

drop table t1;
drop table t2;
drop table t3;