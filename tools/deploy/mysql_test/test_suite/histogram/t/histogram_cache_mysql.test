--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer, opt_stats
# 检测直方图统计信息更新、删除后计划会重新生成
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection default;


--result_format 3
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b int, c int, d int);
--disable_query_log
--let $count = 0
while($count < 1000)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, $count%10, $count%20, $count%40)
  eval $stmt;
  inc $count;
}
--enable_query_log

analyze table t1 drop histogram on a, b, c, d;
--sleep 2

--echo #before generating histogram
connection my_obsys;
select object_type from oceanbase.__all_table_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1;
select column_id, object_type, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3, 4;
connection default;
set global ob_plan_cache_percentage = 90;
--sleep 5

select a, b from t1 where a < 1;
--echo #after first execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after second execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after third execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

analyze table t1 update histogram on a, b, c, d with 30 buckets;
--sleep 2

--echo #after generating histogram, before dropping histogram
connection my_obsys;
select object_type from oceanbase.__all_table_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1;
select column_id, object_type, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3, 4;
connection default;


select a, b from t1 where a < 1;
--echo #after first execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after second execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after third execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;



analyze table t1 update histogram on a, b, c, d with 30 buckets;
--sleep 2

--echo #after updating histogram, before dropping histogram
connection my_obsys;
select object_type from oceanbase.__all_table_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1;
select column_id, object_type, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3, 4;
connection default;

select a, b from t1 where a < 1;
--echo #after first execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after second execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after third execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

analyze table t1 drop histogram on a, b;
--sleep 2




select a, b from t1 where a < 1;
--echo #after dropping histogram first execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

select a, b from t1 where a < 1;
--echo #after dropping histogram second execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;

--disable_warnings
drop table if exists t1;
--enable_warnings
disconnect my_obsys;
