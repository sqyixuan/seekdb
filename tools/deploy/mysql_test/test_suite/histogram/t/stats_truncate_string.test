--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor: test the column string is too long, we need truncate string to gather histogram縲［ax_value縲［in_value

##Mysql mode need consider: VARCHAR縲ゝINYTEXT縲ゝINYBLOB縲〃ARBINARY

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 char(256),
                c2 varchar(1000) CHARSET GBK,
                c3 binary(256),
                c4 varbinary(1000),
                c5 TINYBLOB,
                c6 TINYTEXT CHARSET GBK);

