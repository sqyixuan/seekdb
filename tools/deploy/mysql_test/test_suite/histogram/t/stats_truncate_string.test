insert into t1 select * from t1;
insert into t1 select * from t1 limit 20;

--result_format 4
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 100');
--sorted_result
select TABLE_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name = 'T1' and OWNER = 'TEST';
--sorted_result
SELECT table_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, avg_col_len, histogram FROM oceanbase.DBA_TAB_COL_STATISTICS WHERE table_name='T1' and OWNER = 'TEST';

