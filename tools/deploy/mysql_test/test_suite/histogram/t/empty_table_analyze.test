--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yizhou.wyf
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor:

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;

--disable_warnings
drop table if exists test_global, test_part, test_subpart;
--enable_warnings

create table test_global (c1 int, c2 int, c3 int);

create table test_part (c1 int primary key, c2 int, c3 int) 
partition by range(c1) 
   (PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (50),
    PARTITION p3 VALUES LESS THAN (150),
   PARTITION p4 VALUES LESS THAN (300),
  PARTITION p5 VALUES LESS THAN (500));
 
create table test_subpart (
  a int, b int ,c int, d int
) 
partition by range(a) 
 subpartition by key(b,c) subpartitions 3 
   (PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (50),
    PARTITION p3 VALUES LESS THAN (150),
   PARTITION p4 VALUES LESS THAN (300),
  PARTITION p5 VALUES LESS THAN (500));
 

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS 
where table_name in ('test_global','test_subpart','test_part') and OWNER = 'TEST';

call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS 
where table_name in ('test_global','test_subpart','test_part') and OWNER = 'TEST';



#test insert count stats
