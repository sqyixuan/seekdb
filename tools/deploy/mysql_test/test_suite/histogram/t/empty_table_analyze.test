insert into test_part select c1,c2,c3 from test_global;

insert into test_subpart select c1,c2,c3,c1+c3 from test_global;

##the dml statistics are recorded in memtable and reported periodically to dba_tab_modifications, we must use minor freeze to report the residual statistics
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS 
where table_name in ('test_global','test_subpart','test_part') and OWNER = 'TEST';



call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS 
where table_name in ('test_global','test_subpart','test_part') and OWNER = 'TEST';


--disable_warnings
drop table if exists test_global, test_part, test_subpart;
--enable_warnings



connection conn_admin;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
