start transaction;
insert /*+GATHER_OPTIMIZER_STATISTICS*/into t1 select 1000+c1,c2,c3 from t2;
insert /*+ENABLE_PARALLEL_DML parallel(2)*/into t_part select 10000+c1,c2,c3 from t2;
insert /*+APPEND*/into t_subpart select 100000+c1,c2,c3 from t2;

select count(*) from t1;
select count(*) from t_part;
