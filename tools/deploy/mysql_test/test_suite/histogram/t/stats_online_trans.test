--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor: test online stat gather in trans

--disable_warnings
drop table if exists t1, t2, t_part, t_subpart;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);

create table t2 (c1 int, c2 int, c3 int);

create table t_part (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;

create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
  subpartition p0,
  subpartition p1,
  subpartition p2
)
partitions 3;
create index idx1_subpart on t_subpart(c2) local;

--result_format 4

##test insert count stats
insert into t2 values(1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8), (9,9,9), (10,10,10);
insert into t2 values(11,1,1), (12,2,2), (13,3,3), (14,4,4), (15,5,5), (16,6,6), (17,7,7), (18,8,8), (19,9,9), (20,10,10);
insert into t2 values(21,1,1), (22,2,2), (23,3,3), (24,4,4), (25,5,5), (26,6,6), (27,7,7), (28,8,8), (29,9,9), (30,10,10);
insert into t2 values(31,1,1), (32,2,2), (33,3,3), (34,4,4), (35,5,5), (36,6,6), (37,7,7), (38,8,8), (39,9,9), (40,10,10);
insert into t2 values(41,1,1), (42,2,2), (43,3,3), (44,4,4), (45,5,5), (46,6,6), (47,7,7), (48,8,8), (49,9,9), (50,10,10);
insert into t2 values(51,1,1), (52,2,2), (53,3,3), (54,4,4), (55,5,5), (56,6,6), (57,7,7), (58,8,8), (59,9,9), (60,10,10);
insert into t2 values(61,1,1), (62,2,2), (63,3,3), (64,4,4), (65,5,5), (66,6,6), (67,7,7), (68,8,8), (69,9,9), (70,10,10);
insert into t2 values(71,1,1), (72,2,2), (73,3,3), (74,4,4), (75,5,5), (76,6,6), (77,7,7), (78,8,8), (79,9,9), (80,10,10);
insert into t2 values(81,1,1), (82,2,2), (83,3,3), (84,4,4), (85,5,5), (86,6,6), (87,7,7), (88,8,8), (89,9,9), (90,10,10);
insert into t2 values(91,1,1), (92,2,2), (93,3,3), (94,4,4), (95,5,5), (96,6,6), (97,7,7), (98,8,8), (99,9,9), (100,10,10);

start transaction;
insert /*+GATHER_OPTIMIZER_STATISTICS*/into t1 select * from t2;
insert /*+GATHER_OPTIMIZER_STATISTICS*/into t1 select c1+100, c2+100,c3+100 from t2;
insert /*+ENABLE_PARALLEL_DML parallel(2)*/into t_part select * from t2;
insert /*+ENABLE_PARALLEL_DML parallel(2)*/into t_part select c1+1000, c2+100,c3+1000 from t2;
insert /*+APPEND*/into t_subpart select * from t2;
insert /*+APPEND*/into t_subpart select c1+10000, c2+10000,c3+10000 from t2;

select count(*) from t1;
select count(*) from t_part;
select count(*) from t_subpart;

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST' and PARTITION_NAME is null;
--sorted_result
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.DBA_TAB_COL_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST';

rollback;
select count(*) from t1;
select count(*) from t_part;
select count(*) from t_subpart;

--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST' and PARTITION_NAME is null;
--sorted_result
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.DBA_TAB_COL_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST';


