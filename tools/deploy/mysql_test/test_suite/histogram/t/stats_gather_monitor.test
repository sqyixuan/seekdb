insert into t_part select c1%100,c2,c3 from t_part;
insert into t_part select c1+201,c2,c3 from t_part;
insert into t_part select c1+402,c2,c3 from t_part;

insert into t_subpart select * from t_part;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;

--result_format 4

call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T1',method_opt=>'for all columns size 10');
--sorted_result
select OWNER, TABLE_NAME, STATUS, PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T1' and owner = 'TEST' and TASK_ID is not null;
--disable_query_log
let $id = query_get_value("select TASK_ID as X from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T1' and owner = 'TEST' and TASK_ID is not null;", X, 1);
eval select count(*) from OCEANBASE.DBA_OB_TASK_OPT_STAT_GATHER_HISTORY where TASK_ID = '$id';
--enable_query_log

call dbms_stats.gather_table_stats('TEST', 'T_PART');
call dbms_stats.gather_table_stats('TEST', 'T_PART',degree=>2);
--sorted_result
select OWNER, TABLE_NAME, STATUS, PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T_PART' and owner = 'TEST' and TASK_ID is not null;
--disable_query_log
let $id = query_get_value("select TASK_ID as X from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T_PART' and owner = 'TEST' and TASK_ID is not null;", X, 1);
eval select count(*) from OCEANBASE.DBA_OB_TASK_OPT_STAT_GATHER_HISTORY where TASK_ID = '$id';
--enable_query_log

call dbms_stats.gather_table_stats('TEST', 'T_SUBPART');
call dbms_stats.gather_table_stats('TEST', 'T_SUBPART',granularity=>'GLOBAL AND PARTITION');
--sorted_result
select OWNER, TABLE_NAME, STATUS, PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T_SUBPART' and owner = 'TEST' and TASK_ID is not null;
--disable_query_log
let $id = query_get_value("select TASK_ID as X from oceanbase.dba_ob_table_opt_stat_gather_history where table_name='T_SUBPART' and owner = 'TEST' and TASK_ID is not null;", X, 1);
eval select count(*) from OCEANBASE.DBA_OB_TASK_OPT_STAT_GATHER_HISTORY where TASK_ID = '$id';
--enable_query_log

drop table t1;
drop table t_part;
drop table t_subpart;