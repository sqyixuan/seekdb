--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor: test stat gather monitor

##relation table and view
DESC OCEANBASE.__ALL_VIRTUAL_TASK_OPT_STAT_GATHER_HISTORY;
DESC OCEANBASE.__ALL_VIRTUAL_TABLE_OPT_STAT_GATHER_HISTORY;
DESC OCEANBASE.DBA_OB_TASK_OPT_STAT_GATHER_HISTORY;
DESC OCEANBASE.DBA_OB_TABLE_OPT_STAT_GATHER_HISTORY;
DESC OCEANBASE.GV$OB_OPT_STAT_GATHER_MONITOR;
DESC OCEANBASE.V$OB_OPT_STAT_GATHER_MONITOR;

--disable_warnings
drop table if exists t1, t_part, t_subpart;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);

create table t_part (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;

create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
  subpartition p0,
  subpartition p1,
  subpartition p2
)
partitions 3;
create index idx1_subpart on t_subpart(c2) local;

insert into t1 values(1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8), (9,9,9), (10,10,10);
