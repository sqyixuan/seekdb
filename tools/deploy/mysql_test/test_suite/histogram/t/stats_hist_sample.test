--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jiangxiu.wt
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor: test estimate percent and block_sample

--result_format 3
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;

create table t1 (c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;

insert into t1 select mod(random(), 100000), mod(random(), 10000), mod(random(), 1000) from table(generator(100000));
insert into t2 select mod(random(), 100000), mod(random(), 10000), mod(random(), 1000) from table(generator(100000));

select dbms_stats.get_prefs('HIST_EST_PERCENT') from dual;

##test estimate percent
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 1, method_opt=>'for all columns size 1');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
select COLUMN_NAME,SAMPLE_SIZE,HISTOGRAM from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1';

call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 0.000001, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1' and HISTOGRAM is not null and SAMPLE_SIZE > 5000;

call dbms_stats.gather_table_stats('TEST', 'T1', estimate_percent => 10, hist_est_percent => 50, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1' and HISTOGRAM is not null and SAMPLE_SIZE > 45000;

call dbms_stats.set_global_prefs('HIST_EST_PERCENT', '1');
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 1');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T2' order by START_TIME limit 1;
select COLUMN_NAME,SAMPLE_SIZE,HISTOGRAM from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T2';
call dbms_stats.set_global_prefs('HIST_EST_PERCENT', NULL);

call dbms_stats.set_global_prefs('HIST_EST_PERCENT', '0.000001');
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T2' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T2' and HISTOGRAM is not null and SAMPLE_SIZE > 5000;
call dbms_stats.set_global_prefs('HIST_EST_PERCENT', NULL);

call dbms_stats.set_table_prefs('TEST', 'T2', 'HIST_EST_PERCENT', '50');
call dbms_stats.set_table_prefs('TEST', 'T2', 'estimate_percent', '10');
call dbms_stats.gather_table_stats('TEST', 'T2', estimate_percent => 10, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T2' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T2' and HISTOGRAM is not null and SAMPLE_SIZE > 45000;
call dbms_stats.delete_table_prefs('TEST', 'T2', 'HIST_EST_PERCENT');
call dbms_stats.delete_table_prefs('TEST', 'T2', 'estimate_percent');

##test hist est percent and hist block sample;
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 1, hist_block_sample => true, method_opt=>'for all columns size 1');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
select COLUMN_NAME,SAMPLE_SIZE,HISTOGRAM from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1';

call dbms_stats.gather_table_stats('TEST', 'T1', estimate_percent => 10, hist_est_percent => 50, hist_block_sample => true, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1' and HISTOGRAM is not null and SAMPLE_SIZE > 20000;

call dbms_stats.set_global_prefs('HIST_EST_PERCENT', '1');
call dbms_stats.set_global_prefs('hist_block_sample', 'true');
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 1');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T2' order by START_TIME limit 1;
select COLUMN_NAME,SAMPLE_SIZE,HISTOGRAM from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T2';
call dbms_stats.set_global_prefs('HIST_EST_PERCENT', null);
call dbms_stats.set_global_prefs('hist_block_sample', null);

call dbms_stats.set_table_prefs('TEST', 'T2', 'HIST_EST_PERCENT', '50');
call dbms_stats.set_table_prefs('TEST', 'T2', 'estimate_percent', '10');
call dbms_stats.set_table_prefs('TEST', 'T2', 'hist_block_sample', 'true');
call dbms_stats.gather_table_stats('TEST', 'T2', estimate_percent => 10, hist_est_percent => 50, hist_block_sample => true, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T2' order by START_TIME limit 1;
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T2' and HISTOGRAM is not null and SAMPLE_SIZE > 45000;
call dbms_stats.delete_table_prefs('TEST', 'T2', 'HIST_EST_PERCENT');
call dbms_stats.delete_table_prefs('TEST', 'T2', 'estimate_percent');
call dbms_stats.delete_table_prefs('TEST', 'T2', 'hist_block_sample');

call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size skewonly', hist_est_percent => 0);
--error 5935
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 1000);
#--error 5935
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 0.00000001);
--error 5935
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => -1.11);
--error 5114
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 'a');

drop table t1;
drop table t2;
