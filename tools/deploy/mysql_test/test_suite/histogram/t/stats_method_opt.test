--enable_query_log
--enable_warnings

call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns size 1');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 size 1');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for all columns');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns for columns c1');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c2');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c2 for all columns for columns c3');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 size 1 for columns c2 size 2 for all columns for columns c3');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c2 for all columns for columns c3 for all columns size 10');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 c2 c3 c4 size 4 for columns c5 for all columns for columns c6 for all columns size 10');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c2 for all columns for columns for all columns size 10');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 c2 size 10 for columns c3 for all columns for columns for all columns size 10');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns  size 1 c1 size 2  c2 size 4 c3' );

--error 1166
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c100');
--error 1060
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 c1 c1');
--error 1060
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c1');
--error 1060
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for columns c1 for columns c2 for all columns for columns c2');

--echo ## test size auto and col_usage
--result_format 4
select count(*) from t2 where c1 = 1;
select count(*) from t2 where c2 < 10;
select count(*) from t2 where c3 is null;

call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
--sleep 1
select COLUMN_ID, EQUALITY_PREDS, EQUIJOIN_PREDS, NONEQUIJION_PREDS, RANGE_PREDS, LIKE_PREDS, NULL_PREDS, FLAGS
from oceanbase.__all_column_usage cu, oceanbase.__all_table obj where obj.table_name = 'T2' and obj.table_id = cu.TABLE_ID;

call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size auto');
select COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, GLOBAL_STATS, USER_STATS, NOTES, AVG_COL_LEN, HISTOGRAM
from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T2' and owner = 'TEST';
call dbms_stats.delete_table_stats('TEST', 'T2');

call dbms_stats.gather_table_stats('TEST', 'T2');
select COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, GLOBAL_STATS, USER_STATS, NOTES, AVG_COL_LEN, HISTOGRAM
from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T2' and owner = 'TEST';

--echo ## test size repeat
create table t3 (c1 int, c2 int, c3 int);
insert into t3 select c1,c2,c3 from t2;
insert into t3 select c1,c2,c3 from t2;
insert into t3 select c1,c2,c3 from t2;
insert into t3 select c1,c2,c3 from t2;
insert into t3 select c1,c2,c3 from t2;
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'FOR ALL COLUMNS SIZE 200');
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T3' and owner = 'TEST';

insert into t3 select c1+100, c2+150, c3 from t3;
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'FOR ALL COLUMNS SIZE REPEAT');
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T3' and owner = 'TEST';

create table t4 (c1 int, c2 int, c3 int)
partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);
insert into t4 select c1,c2,c3 from t2 where c1 < 200;
insert into t4 select c1,c2,c3 from t2 where c1 < 200;
insert into t4 select c1,c2,c3 from t2 where c1 < 200;
insert into t4 select c1,c2,c3 from t2 where c1 < 200;
insert into t4 select c1,c2,c3 from t2 where c1 < 200;
call dbms_stats.gather_table_stats('TEST', 'T4', method_opt=>'FOR ALL COLUMNS SIZE 200', granularity => 'PARTITION');
call dbms_stats.gather_table_stats('TEST', 'T4', method_opt=>'FOR ALL COLUMNS SIZE 50', granularity => 'GLOBAL');
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T4' and owner = 'TEST';
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_part_col_statistics where TABLE_NAME = 'T4' and owner = 'TEST' order by column_name, partition_name;

insert into t4 select mod(c1,100)+100, c2+150, c3 from t4;
call dbms_stats.gather_table_stats('TEST', 'T4', method_opt=>'FOR ALL COLUMNS SIZE REPEAT');
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_tab_col_statistics where TABLE_NAME = 'T4' and owner = 'TEST';
select COLUMN_NAME, NUM_BUCKETS, HISTOGRAM from oceanbase.dba_part_col_statistics where TABLE_NAME = 'T4' and owner = 'TEST' order by column_name, partition_name;

drop table t1,t2,t3,t4;