--enable_result_log

--result_format 4

##1.show system table and system view struct

desc oceanbase.dba_tab_stats_history;

##2.test history retention query and alter
select dbms_stats.get_stats_history_retention() from dual;

call dbms_stats.alter_stats_history_retention(15);
select dbms_stats.get_stats_history_retention() from dual;

call dbms_stats.alter_stats_history_retention(-1);
select dbms_stats.get_stats_history_retention() from dual;

call dbms_stats.alter_stats_history_retention(0);
select dbms_stats.get_stats_history_retention() from dual;

call dbms_stats.alter_stats_history_retention(NULL);
select dbms_stats.get_stats_history_retention() from dual;

--error 5935
call dbms_stats.alter_stats_history_retention(-2);
--error 5935
call dbms_stats.alter_stats_history_retention(365001);

##3.test gather stats and history stats
##basic table
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T1' and STATS_UPDATE_TIME IS NOT NULL;
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 9', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 8', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 7', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 6', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 5', granularity=>'ALL');
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T1' and STATS_UPDATE_TIME IS NOT NULL;
--sorted_result
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.dba_TAB_COL_STATISTICS where table_name ='T1' and OWNER = 'TEST' order by 1, 2, 3;
--sorted_result
select TABLE_NAME, COLUMN_NAME, ENDPOINT_NUMBER, ENDPOINT_VALUE, ENDPOINT_ACTUAL_VALUE, ENDPOINT_ACTUAL_VALUE_RAW, ENDPOINT_REPEAT_COUNT from oceanbase.dba_TAB_HISTOGRAMS where table_name ='T1' and OWNER = 'TEST' order by 1, 2;

--disable_result_log
select dbms_stats.get_stats_history_availability() from dual;
--enable_result_log

let $point1 = query_get_value("select concat('\'',substr(STATS_UPDATE_TIME, 1, 26),'\'') as X from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T1' order by STATS_UPDATE_TIME limit 1", X, 1);
--disable_query_log
eval call dbms_stats.restore_table_stats('TEST', 'T1', cast($point1 as datetime(6)));
--enable_query_log
--sorted_result
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.dba_TAB_COL_STATISTICS where table_name ='T1' and OWNER = 'TEST' order by 1, 2, 3;
--sorted_result
select TABLE_NAME, COLUMN_NAME, ENDPOINT_NUMBER, ENDPOINT_VALUE, ENDPOINT_ACTUAL_VALUE, ENDPOINT_ACTUAL_VALUE_RAW, ENDPOINT_REPEAT_COUNT from oceanbase.dba_TAB_HISTOGRAMS where table_name ='T1' and OWNER = 'TEST' order by 1, 2;

