--sorted_result
select OWNER, TABLE_NAME, STATUS, PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where table_name in ('T1', 'T_PART', 'T_SUBPART') and owner = 'TEST' and TASK_ID is not null order by start_time limit 3;

call dbms_stats.alter_stats_history_retention(0);
select count(*) from oceanbase.DBA_OB_TASK_OPT_STAT_GATHER_HISTORY;
select count(*) from oceanbase.DBA_OB_TABLE_OPT_STAT_GATHER_HISTORY where TASK_ID IS NOT NULL;

drop table t1;
drop table t_part;
drop table t_subpart;

--error 0, 4298
drop sequence s1;
create sequence s1 cache 42000 noorder;

create table t_part (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;

let $tab_id = query_get_value("select table_id as X from oceanbase.__all_table where table_name='T_PART';", X, 1);

--disable_warnings
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
--enable_warnings
--sorted_result
select TABLE_NAME,PARTITION_NAME,NUM_ROWS from oceanbase.dba_tab_statistics where table_name='T_PART' and OWNER = 'TEST';

insert into t_part select s1.nextval, s1.nextval, s1.nextval from table(generator(40000));
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
