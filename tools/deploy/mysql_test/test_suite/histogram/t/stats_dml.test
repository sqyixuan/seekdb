SELECT table_name, subpartition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size, avg_col_len, histogram FROM OCEANBASE.DBA_SUBPART_COL_STATISTICS WHERE table_name = 'T_SUBPART' and owner='TEST';

##more than stale percent(default value:10)
update t1 set c1 = 10000 where c1 >=89;
update t_part partition(p0) set c3 = 10000 where c1 < 100;
update t_subpart partition(p0sp1) set c3 = 10000 where c1 <= 1200;
update t_subpart partition(p1sp0) set c3 = 10000 where c1 <= 640;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
