call dbms_stats.set_table_prefs('TEST', 'T_PART', 'GRANULARITY', 'GLOBAL');
--disable_warnings
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
--enable_warnings
--sorted_result
select TABLE_NAME,PARTITION_NAME,NUM_ROWS from oceanbase.dba_tab_statistics where table_name='T_PART' and OWNER = 'TEST';
--sorted_result
--replace_regex /table_id = [0-9]+/table_id = $T_PART_TABLE_ID/
eval select LAST_INSERTS, LAST_UPDATES, LAST_DELETES, INSERTS, UPDATES, DELETES from oceanbase.__all_monitor_modified where table_id = $tab_id;
