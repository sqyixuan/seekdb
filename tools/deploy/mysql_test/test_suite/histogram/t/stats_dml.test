connection conn_stat_test_sys_mysql;
use test;

--result_format 4
--disable_warnings
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
--enable_warnings
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from OCEANBASE.DBA_TAB_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST';
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from OCEANBASE.DBA_TAB_COL_STATISTICS where table_name in ('T1','T_PART','T_SUBPART') and OWNER = 'TEST';
select TABLE_NAME, partition_name, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from OCEANBASE.DBA_PART_COL_STATISTICS where table_name in ('T_PART','T_SUBPART') and OWNER = 'TEST';
SELECT table_name, subpartition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size, avg_col_len, histogram FROM OCEANBASE.DBA_SUBPART_COL_STATISTICS WHERE table_name = 'T_SUBPART' and owner='TEST';

##not arrive stale percent(default value:10)
delete from t1 where c1 >=95;
delete from t_part partition(p0) where c1 <= 36;
delete from t_part partition(p1) where c1 <= 37;
delete from t_subpart partition(p0sp1) where c1 <= 1029;
delete from t_subpart partition(p1sp0) where c1 <= 28;
delete from t_subpart partition(p1sp1) where c1 <= 1027;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
connection conn_stat_test_sys_mysql;
use test;

call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
