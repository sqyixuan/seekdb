# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

create table t1(
    pk int primary key,
    c1 varchar(32768) SKIP_INDEX(MIN_MAX),
    c2 char(256) SKIP_INDEX(MIN_MAX),
    c3 tinytext SKIP_INDEX(MIN_MAX),
    c4 mediumtext SKIP_INDEX(MIN_MAX),
    c5 int);

create table t2(
    pk int primary key,
    c1 varchar(32768),
    c2 char(256),
    c3 tinytext,
    c4 mediumtext,
    c5 int) with column group (all columns, each column);

create table t3(
    pk int primary key,
    c1 varchar(32768) SKIP_INDEX(MIN_MAX),
    c2 char(256) SKIP_INDEX(MIN_MAX),
    c3 tinytext SKIP_INDEX(MIN_MAX),
    c4 mediumtext SKIP_INDEX(MIN_MAX),
    c5 int) partition by hash(pk) partitions 4;

create table t4(
    pk int primary key,
    c1 varchar(32768),
    c2 char(256),
    c3 tinytext,
    c4 mediumtext,
    c5 int) partition by hash(pk) partitions 4 with column group (all columns, each column);

set @loop = 0;
insert into t1 select 
      @loop := @loop + 1,
      concat(repeat('t', 39), @loop),
      concat(repeat('t', 39), @loop * 3),
      concat(repeat('t', 39), @loop * 10),
      concat(repeat('t', 39), @loop),
      @loop from table(generator(10000));
insert into t2 select * from t1;
insert into t3 select * from t1;
insert into t4 select * from t1;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--explain_protocol 2
--result_format 4
select /*+ DBMS_STATS parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t1;
select /*+ DBMS_STATS parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t2;
select /*+ DBMS_STATS parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t3;
select /*+ DBMS_STATS parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t4;
select /*+ DBMS_STATS parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t1;
select /*+ DBMS_STATS parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t2;
select /*+ DBMS_STATS parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t3;
select /*+ DBMS_STATS parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t4;

select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t1;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t2;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t3;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(1) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t4;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t1;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t2;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t3;
select /*+ DBMS_STATS OPT_PARAM('enable_rich_vector_format', 'false') parallel(2) */ min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(c4), max(c4), min(pk), max(pk) from t4;

drop table t1;
drop table t2;
drop table t3;
drop table t4;