call dbms_stats.set_global_prefs('ASYNC_STALE_MAX_TABLE_SIZE', null);
select dbms_stats.get_param('ASYNC_STALE_MAX_TABLE_SIZE') from dual;
--error 5935
call dbms_stats.set_global_prefs('ASYNC_STALE_MAX_TABLE_SIZE', '9999');

--disable_warnings
drop table if exists t1, t_part, t_subpart;
--enable_warnings

--error 0,4298
drop sequence s1;

--result_format 4

create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);

call dbms_stats.gather_table_stats('TEST', 'T1');
create sequence s1 cache 600 noorder;
insert into t1 select s1.nextval,s1.nextval,s1.nextval from table(generator(600));
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
drop sequence s1;
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
select table_name,partition_name,subpartition_name,num_rows,stale_stats from oceanbase.DBA_TAB_STATISTICS where table_name = 'T1' and owner='TEST';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t1;

call dbms_stats.async_gather_stats_job_proc();
--sorted_result
select table_name,partition_name,subpartition_name,num_rows,stale_stats from oceanbase.DBA_TAB_STATISTICS where table_name = 'T1' and owner='TEST';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t1;

create sequence s1 cache 10000 noorder;
insert into t1 select s1.nextval,s1.nextval,s1.nextval from table(generator(10000));
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
drop sequence s1;

call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
select table_name,partition_name,subpartition_name,num_rows,stale_stats from oceanbase.DBA_TAB_STATISTICS where table_name = 'T1' and owner='TEST';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t1;

call dbms_stats.async_gather_stats_job_proc();
--sorted_result
select table_name,partition_name,subpartition_name,num_rows,stale_stats from oceanbase.DBA_TAB_STATISTICS where table_name = 'T1' and owner='TEST';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t1;

create table t_part (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create sequence s1 cache 600 noorder;
insert into t_part select s1.nextval,s1.nextval,s1.nextval from table(generator(600));
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
drop sequence s1;
call dbms_stats.gather_table_stats('TEST', 'T_PART');
call dbms_stats.set_global_prefs('ASYNC_GATHER_STALE_RATIO', '3');
insert into t_part partition(p0) select 4,4,4 from table(generator(500));
insert into t_part partition(p3) select 3,3,3 from table(generator(500));
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
--sorted_result
select table_name,partition_name,subpartition_name,num_rows,stale_stats from oceanbase.DBA_TAB_STATISTICS where table_name = 'T_PART' and owner='TEST';
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t_part;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select count(*) from t_part partition(p0);
