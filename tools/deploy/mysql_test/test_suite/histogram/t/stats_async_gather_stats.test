--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jiangxiu.wt
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor:async gather stats

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;

##set the relation prefs
select dbms_stats.get_param('ASYNC_GATHER_FULL_TABLE_SIZE') from dual;
call dbms_stats.set_global_prefs('ASYNC_GATHER_FULL_TABLE_SIZE', '100000');
select dbms_stats.get_param('ASYNC_GATHER_FULL_TABLE_SIZE') from dual;
call dbms_stats.set_global_prefs('ASYNC_GATHER_FULL_TABLE_SIZE', null);
select dbms_stats.get_param('ASYNC_GATHER_FULL_TABLE_SIZE') from dual;
--error 5935
call dbms_stats.set_global_prefs('ASYNC_GATHER_FULL_TABLE_SIZE', '10');

select dbms_stats.get_param('ASYNC_GATHER_SAMPLE_SIZE') from dual;
