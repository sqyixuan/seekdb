select dbms_stats.get_param('ASYNC_GATHER_STALE_RATIO') from dual;
call dbms_stats.set_global_prefs('ASYNC_GATHER_STALE_RATIO', null);
select dbms_stats.get_param('ASYNC_GATHER_STALE_RATIO') from dual;

select dbms_stats.get_param('ASYNC_STALE_MAX_TABLE_SIZE') from dual;
call dbms_stats.set_global_prefs('ASYNC_STALE_MAX_TABLE_SIZE', '0');
select dbms_stats.get_param('ASYNC_STALE_MAX_TABLE_SIZE') from dual;
call dbms_stats.set_global_prefs('ASYNC_STALE_MAX_TABLE_SIZE', '10001');
