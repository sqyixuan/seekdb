call dbms_stats.set_global_prefs('ASYNC_GATHER_SAMPLE_SIZE', null);
select dbms_stats.get_param('ASYNC_GATHER_SAMPLE_SIZE') from dual;
--error 5935
call dbms_stats.set_global_prefs('ASYNC_GATHER_SAMPLE_SIZE', '10');

select dbms_stats.get_param('ASYNC_GATHER_STALE_RATIO') from dual;
