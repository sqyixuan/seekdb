##7.restore_schema_stats
let $point1 = query_get_value("select concat('\'',substr(STATS_UPDATE_TIME, 1, 26),'\'') as X from oceanbase.dba_tab_stats_history where owner = 'TEST_STAT_SCHEMA' and table_name = 'T1' order by STATS_UPDATE_TIME desc limit 1", X, 1);
--disable_query_log
eval call dbms_stats.restore_schema_stats('TEST_STAT_SCHEMA', cast($point1 as datetime(6)));
--enable_query_log
select TABLE_NAME, PARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from oceanbase.dba_TAB_STATISTICS where table_name in ('T1', 'T_PART', 'T_SUBPART') and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3;
select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.dba_TAB_COL_STATISTICS where table_name in ('T1', 'T_PART', 'T_SUBPART') and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3;
select TABLE_NAME, COLUMN_NAME, ENDPOINT_NUMBER, ENDPOINT_VALUE, ENDPOINT_ACTUAL_VALUE, ENDPOINT_ACTUAL_VALUE_RAW, ENDPOINT_REPEAT_COUNT from oceanbase.dba_TAB_HISTOGRAMS where table_name in ('T1', 'T_PART', 'T_SUBPART') and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2;
select TABLE_NAME, PARTITION_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.dba_PART_COL_STATISTICS where table_name in ('T_PART', 'T_SUBPART') and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3, 4;
select TABLE_NAME, PARTITION_NAME, COLUMN_NAME, ENDPOINT_NUMBER, ENDPOINT_VALUE, ENDPOINT_ACTUAL_VALUE, ENDPOINT_ACTUAL_VALUE_RAW, ENDPOINT_REPEAT_COUNT from oceanbase.dba_PART_HISTOGRAMS where table_name in ('T_PART', 'T_SUBPART') and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3;
select TABLE_NAME, SUBPARTITION_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from oceanbase.dba_SUBPART_COL_STATISTICS where table_name ='T_SUBPART' and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3, 4;
select TABLE_NAME, SUBPARTITION_NAME, COLUMN_NAME, ENDPOINT_NUMBER, ENDPOINT_VALUE, ENDPOINT_ACTUAL_VALUE, ENDPOINT_ACTUAL_VALUE_RAW, ENDPOINT_REPEAT_COUNT from oceanbase.dba_SUBPART_HISTOGRAMS where table_name ='T_SUBPART' and OWNER = 'TEST_STAT_SCHEMA' order by 1, 2, 3, 4;

##8.lock schema stats
call dbms_stats.lock_schema_stats('TEST_STAT_SCHEMA');
--sorted_result
select TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,NUM_ROWS,AVG_ROW_LEN,STATTYPE_LOCKED from oceanbase.dba_tab_statistics where owner = 'TEST_STAT_SCHEMA' and TABLE_NAME in ('T_PART', 'T_SUBPART', 'T1');

--error 5935
call dbms_stats.gather_table_stats('TEST_STAT_SCHEMA', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');
--error 5935
call dbms_stats.delete_column_stats('TEST_STAT_SCHEMA', 'T_PART', 'C1');
--error 5935
call dbms_stats.set_table_stats('TEST_STAT_SCHEMA', 'T_SUBPART', numrows=>10);
--error 5935
call dbms_stats.import_table_stats('TEST_STAT_SCHEMA', 'T1', NULL, 'TEST_STAT', statown=>'TEST_STAT_SCHEMA');
--error 5935
call dbms_stats.import_table_stats('TEST_STAT_SCHEMA', 'T_PART', NULL, 'TEST_STAT', statown=>'TEST_STAT_SCHEMA');
--error 5935
call dbms_stats.import_table_stats('TEST_STAT_SCHEMA', 'T_SUBPART', NULL, 'TEST_STAT', statown=>'TEST_STAT_SCHEMA');

##9.lock schema stats
call dbms_stats.unlock_schema_stats('TEST_STAT_SCHEMA');
--sorted_result
select TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,NUM_ROWS,AVG_ROW_LEN,STATTYPE_LOCKED from oceanbase.dba_tab_statistics where owner = 'TEST_STAT_SCHEMA' and TABLE_NAME in ('T_PART', 'T_SUBPART', 'T1');

##10.clean env
call dbms_stats.drop_stat_table('TEST_STAT_SCHEMA', 'TEST_STAT');
drop table t1;
drop table t_part;
drop table t_subpart;
drop view v1;
drop view v_part;
drop view v_subpart;

use test;
drop database test_stat_schema;
