--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: sql1
# tags: optimizer, opt_stats
# description: 测试所有已经支持的analyze table syntax，在未major freeze的时候，不再报错，暂时什么都不做

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings


create table t1(a int primary key, b int, c int, d int);
create table t2(a int primary key, b int, c int, d int) partition by hash(a) partitions 4;

--disable_query_log
--disable_result_log
insert into t1 values(1, 1, 1, 1);
insert into t1 values(2, 2, 2, 2);
insert into t1 values(3, 3, 3, 3);
insert into t1 values(4, 4, 4, 4);
insert into t2 values(1, 1, 1, 1);
insert into t2 values(2, 2, 2, 2);
insert into t2 values(3, 3, 3, 3);
insert into t2 values(4, 4, 4, 4);
select/**/ count(*) from t1;
select/**/ count(*) from t2;
--enable_query_log
--enable_result_log

--result_format 3


analyze table t1 compute statistics;

analyze table t1 estimate statistics;

analyze table t1 compute statistics for all columns;

analyze table t1 compute statistics for all columns size 5;

analyze table t1 compute statistics for all indexed columns;

analyze table t1 compute statistics for all indexed columns size 5;

analyze table t1 compute statistics for columns b, c size 5, d;

analyze table t1 compute statistics for columns size 5 b, c size 5, d;

analyze table t1 compute statistics for all columns;

analyze table t1 compute statistics for all columns size 5;

analyze table t1 compute statistics for all indexed columns;

analyze table t1 compute statistics for all indexed columns size 5;

analyze table t1 compute statistics for columns b, c size 5, d;

analyze table t1 compute statistics for columns size 5 b, c size 5, d;

analyze table t1 estimate statistics for all columns sample 3 rows;

analyze table t1 estimate statistics for all columns size 5 sample 3 percentage;

analyze table t1 estimate statistics for all indexed columns sample 3 rows;

analyze table t1 estimate statistics for all indexed columns size 5 sample 3 rows;

analyze table t1 estimate statistics for columns b, c size 5, d sample 3 percentage;

analyze table t1 estimate statistics for columns size 5 b, c size 5, d sample 3 rows;

analyze table t2 partition(p0) compute statistics;

analyze table t2 partition(p0) estimate statistics;

analyze table t2 partition(p0) compute statistics for all columns;

analyze table t2 partition(p0) compute statistics for all columns size 5;

analyze table t2 partition(p0) compute statistics for all indexed columns;

analyze table t2 partition(p0) compute statistics for all indexed columns size 5;

analyze table t2 partition(p0) compute statistics for columns b, c size 5, d;

analyze table t2 partition(p0) compute statistics for columns size 5 b, c size 5, d;

analyze table t2 partition(p0) compute statistics for all columns;

analyze table t2 partition(p0) compute statistics for all columns size 5;

analyze table t2 partition(p0) compute statistics for all indexed columns;

analyze table t2 partition(p0) compute statistics for all indexed columns size 5;

analyze table t2 partition(p0) compute statistics for columns b, c size 5, d;

analyze table t2 partition(p0) compute statistics for columns size 5 b, c size 5, d;

analyze table t2 partition(p0) estimate statistics for all columns sample 3 rows;

analyze table t2 partition(p0) estimate statistics for all columns size 5 sample 3 percentage;

analyze table t2 partition(p0) estimate statistics for all indexed columns sample 3 rows;

analyze table t2 partition(p0) estimate statistics for all indexed columns size 5 sample 3 rows;

analyze table t2 partition(p0) estimate statistics for columns b, c size 5, d sample 3 percentage;

analyze table t2 partition(p0) estimate statistics for columns size 5 b, c size 5, d sample 3 percentage;


--error 1235
analyze table t1 compute statistics for table;
--error 1235
analyze table t1 compute statistics for table;
--error 1235
analyze table t1 estimate statistics for table sample 3 percentage;
--error 1235
analyze table t2 partition(p0) compute statistics for table;
--error 1235
analyze table t2 partition(p0) compute statistics for table;
--error 1235
analyze table t2 partition(p0) estimate statistics for table sample 3 percentage;

