# owner: yizhou.wyf
# owner group: sql1
# tags: optimizer, opt_stats
# description: 测试硬解析同一条SQL，如果缺失统计信息，不会对同一个分区统计信息拉多次

--disable_warnings
drop table if exists gw_ads_schedule_rt;
--enable_warnings


CREATE TABLE `gw_ads_schedule_rt` (
  `scd_id` bigint(20) NOT NULL COMMENT '排期ID',
  `show_date` int(11) NOT NULL COMMENT '放映日期',
  `stat_date` int(11) NOT NULL COMMENT '统计日期',
  `stat_month` bigint(20) NOT NULL COMMENT '统计月份',
  `cinema_id` bigint(20) NOT NULL COMMENT '影院ID',
  `show_id` bigint(20) NOT NULL COMMENT '影片ID',
  `hall_id` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '影厅ID,C端hall_id,16位字符串',
  `show_time` time NOT NULL COMMENT '放映时间',
  `hall_seat_cnt` int(11) NOT NULL COMMENT '影厅座位数',
  `province_id` int(11) NOT NULL COMMENT '省份id',
  `city_id` int(11) NOT NULL COMMENT '城市id',
  `city_level` int(11) NOT NULL COMMENT '城市级别',
  `company_code` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '影投编码,company_code为空时用-1000替代',
  `company_code_insight` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '影投编码列表,为空时用-1000替代,用于运维使用',
  `bd_company_code` int(11) NOT NULL COMMENT '商务影管,BD口径，为空时用-1000替代',
  `merchant_code` int(11) NOT NULL COMMENT '院线编码',
  `sold_seat_cnt` int(11) NOT NULL COMMENT '已售人次',
  `avg_ticket_price` int(11) NOT NULL COMMENT '平均票价',
  `fcst_service_fee` int(11) NOT NULL COMMENT '平均服务费',
  `scd_is_valid` int(11) NOT NULL COMMENT '是否有效',
  `scd_status` int(11) NOT NULL COMMENT '排期状态',
  `gmt_create` varchar(256) COLLATE utf8mb4_bin NOT NULL COMMENT '创建时间',
  `scd_valid_reason` int(11) DEFAULT NULL COMMENT '原因',
  `hall_type` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '厅类型',
  PRIMARY KEY (`stat_month`, `show_date`, `stat_date`, `scd_id`)
) ORGANIZATION INDEX  
partition by hash(stat_month) partitions 6 subpartition by key(`show_date`,`stat_date`,`scd_id`) subpartitions 8 WITH COLUMN GROUP(each column);

--disable_query_log
--disable_result_log
explain extended_noaddr select   /*+ QUERY_TIMEOUT(60000000),  READ_CLUSTER(SLAVE), READ_CONSISTENCY(WEAK) */ show_date,   substr(`show_date`, 1, 4),   count(*) FROM   `gw_ads_schedule_rt` where   `show_date` >= 20250504 group by   `show_date`;
--enable_result_log
--enable_query_log
set @id = (select last_trace_id());


select count(*) <=3 from oceanbase.gv$ob_sql_audit  where trace_id = @id and query_sql  like '%all_table_stat%';
