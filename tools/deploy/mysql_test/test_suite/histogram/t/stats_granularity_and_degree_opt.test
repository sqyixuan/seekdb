##test degree
call dbms_stats.gather_table_stats('TEST', 'T1', degree => 3);
select TABLE_NAME, PARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.dba_TAB_STATISTICS where table_name = 'T1' and OWNER = 'TEST' order by 1, 2, 3;
