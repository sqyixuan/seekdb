# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

--disable_warnings
drop table if exists t1;
drop table if exists TEST_STAT_1;
--enable_warnings

create table t1 (
  c1 int primary key,
  c2 int
);

set @num = 0;

insert into t1 select @num := @num + 1, case when @num < 500 then @num else null end from table(generator(100000));

call dbms_stats.gather_table_stats('TEST', 'T1', degree=>2, method_opt=>'FOR ALL COLUMNS SIZE 256');

let $trace_id = query_get_value(select last_trace_id() as VALUE from dual,VALUE, 1);

--disable_query_log
eval select query_sql from oceanbase.gv\$ob_sql_audit where trace_id = '$trace_id' and query_sql like '%DBMS_STATS%' order by 1;
--enable_query_log

call dbms_stats.create_stat_table('TEST', 'TEST_STAT_1');
call dbms_stats.export_schema_stats('TEST',stattab=>'TEST_STAT_1',statid=>'1');
call dbms_stats.import_schema_stats('TEST',stattab=>'TEST_STAT_1',statid=>'1');

drop table t1;
drop table TEST_STAT_1;