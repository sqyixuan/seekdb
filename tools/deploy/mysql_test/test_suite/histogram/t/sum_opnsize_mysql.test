# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

--disable_warnings
drop table if exists table_all;
drop table if exists table_all2;
--enable_warnings
create table table_all(
  part int,
  c1 int,
  c2 int(11),
  c3 VARCHAR(255),
  c4 char(250),
  c5 timestamp,
  c6 datetime,
  c7 text,
  c8 longtext,
  c9 array(int)
)
PARTITION BY hash(c1) subpartition by range columns(c6) 
subpartition template(
  subpartition p0 values less than ('2001-01-01 00:00:00'),
	subpartition p1 values less than ('2003-01-01 00:00:00'),
	subpartition p2 values less than ('2005-01-01 00:00:00'),
	subpartition p3 values less than (maxvalue)) partitions 10;

create table table_all2(
  part int,
  c1 int,
  c2 int(11),
  c3 VARCHAR(255),
  c4 char(250),
  c5 timestamp,
  c6 datetime,
  c7 text,
  c8 longtext,
  c9 array(int)
);

set @rownum=0;
INSERT /*+APPEND PARALLEL(20) ENABLE_PARALLEL_DML NO_GATHER_OPTIMIZER_STATISTICS*/ INTO table_all 
SELECT @rownum % 10, @rownum:=@rownum+5,
@rownum:=@rownum+3,
@rownum,
(substr(@rownum,10,20)),
'2014-01-09 00:02:01',
DATE_ADD('2000-01-01', INTERVAL FLOOR(@rownum * 7300) DAY),
REPEAT('T', 5120),
REPEAT('A', 80000),
[1, 2, 3]
FROM 
table(generator(1000));

--explain_protocol 2
--result_format 4
select 
/*+ opt_param('pushdown_storage_level', 2) */
sum_opnsize(part),
sum_opnsize(c1),
sum_opnsize(c2),
sum_opnsize(c3),
sum_opnsize(c4),
sum_opnsize(c5),
sum_opnsize(c6),
sum_opnsize(c7),
sum_opnsize(c8),
sum_opnsize(c9)
from table_all;

--sorted_result
select 
/*+ opt_param('pushdown_storage_level', 2) */
part,
sum_opnsize(c1),
sum_opnsize(c2),
sum_opnsize(c3),
sum_opnsize(c4),
sum_opnsize(c5),
sum_opnsize(c6),
sum_opnsize(c7),
sum_opnsize(c8),
sum_opnsize(c9)
from table_all group by part with rollup;

select 
/*+ opt_param('pushdown_storage_level', 2) */
sum_opnsize(part),
sum_opnsize(c1),
sum_opnsize(c2),
sum_opnsize(c3),
sum_opnsize(c4),
sum_opnsize(c5),
sum_opnsize(c6),
sum_opnsize(c7),
sum_opnsize(c8),
sum_opnsize(c9)
from table_all2;

--sorted_result
select 
/*+ opt_param('pushdown_storage_level', 2) */
part,
sum_opnsize(c1),
sum_opnsize(c2),
sum_opnsize(c3),
sum_opnsize(c4),
sum_opnsize(c5),
sum_opnsize(c6),
sum_opnsize(c7),
sum_opnsize(c8),
sum_opnsize(c9)
from table_all2 group by part with rollup;

drop table if exists table_all;
drop table if exists table_all2;