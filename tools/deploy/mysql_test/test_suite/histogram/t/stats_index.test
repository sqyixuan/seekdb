call dbms_stats.delete_index_stats('TEST', 'idx3_part', tabname=>'T_PART', cascade_parts=>false);
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and INDEX_NAME='IDX3_PART';
