                         `num` bigint(18) DEFAULT NULL,
                         `lin` linestring NOT NULL /*!80003 SRID 4326 */,
                         PRIMARY KEY (`id`), SPATIAL KEY `lin_index` (`lin`) BLOCK_SIZE 16384 LOCAL );

