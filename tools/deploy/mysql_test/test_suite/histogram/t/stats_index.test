##################test gather index stats#########################
##   ownname            VARCHAR2,
##   indname            VARCHAR2,
##   partname           VARCHAR2 DEFAULT NULL,
##   estimate_percent   NUMBER DEFAULT AUTO_SAMPLE_SIZE,
##   stattab            VARCHAR2 DEFAULT NULL,
##   statid             VARCHAR2 DEFAULT NULL,
##   statown            VARCHAR2 DEFAULT NULL,
##   degree             NUMBER DEFAULT NULL,
##   granularity        VARCHAR2 DEFAULT DEFAULT_GRANULARITY,
##   no_invalidate      BOOLEAN DEFAULT FALSE,
##   force              BOOLEAN DEFAULT FALSE
###################################################################

call dbms_stats.gather_index_stats('TEST', 'idx', tabname=>'T1');
call dbms_stats.gather_index_stats('TEST', 'idx1_t1', tabname=>'T1');
call dbms_stats.gather_index_stats('TEST', 'idx2_t1', tabname=>'T1', degree=>2);
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and TABLE_NAME='T1';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and TABLE_NAME='T1' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);

call dbms_stats.gather_index_stats('TEST', 'idx', tabname=>'T_PART');
call dbms_stats.gather_index_stats('TEST', 'idx1_part', tabname=>'T_PART');
call dbms_stats.gather_index_stats('TEST', 'idx2_part', tabname=>'T_PART', degree=>2);
call dbms_stats.gather_index_stats('TEST', 'idx3_part', 'P0', tabname=>'T_PART', granularity=>'PARTITION');
call dbms_stats.gather_index_stats('TEST', 'idx3_part', 'P2', tabname=>'T_PART', granularity=>'GLOBAL');
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and TABLE_NAME='T_PART';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and TABLE_NAME='T_PART' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);

call dbms_stats.gather_index_stats('TEST', 'idx3_part', tabname=>'T_PART');
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and TABLE_NAME='T_PART';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and TABLE_NAME='T_PART' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);

