##   stattype         VARCHAR2 DEFAULT 'ALL',
##   force            BOOLEAN  DEFAULT FALSE
###################################################################

call dbms_stats.delete_index_stats('TEST', 'idx', tabname=>'T1');
call dbms_stats.delete_index_stats('TEST', 'idx1_t1', tabname=>'T1');
call dbms_stats.delete_index_stats('TEST', 'idx2_t1', tabname=>'T1');
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and TABLE_NAME='T1';

