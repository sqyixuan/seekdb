call dbms_stats.delete_index_stats('TEST', 'idx3_part', tabname=>'T_PART');

call dbms_stats.delete_index_stats('TEST', 'idx1_subpart', tabname=>'T_SUBPART');
call dbms_stats.delete_index_stats('TEST', 'idx2_subpart', tabname=>'T_SUBPART');
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and TABLE_NAME='T_SUBPART';

##################set index stats#########################
##      ownname            VARCHAR2,
##      indname            VARCHAR2,
##      partname           VARCHAR2  DEFAULT NULL,
##      stattab            VARCHAR2  DEFAULT NULL,
##      statid             VARCHAR2  DEFAULT NULL,
##      numrows            NUMBER    DEFAULT NULL,
##      numlblks           NUMBER    DEFAULT NULL,
##      numdist            NUMBER    DEFAULT NULL,
##      avglblk            NUMBER    DEFAULT NULL,
##      avgdblk            NUMBER    DEFAULT NULL,
##      clstfct            NUMBER    DEFAULT NULL,
##      indlevel           NUMBER    DEFAULT NULL,
##      flags              NUMBER    DEFAULT NULL,
##      statown            VARCHAR2  DEFAULT NULL,
##      no_invalidate      BOOLEAN   DEFAULT FALSE,
##      guessq             NUMBER    DEFAULT NULL,
##      cachedblk          NUMBER    DEFAULT NULL,
##      cachehit           NUMBER    DEFAULT NULL,
##      force              BOOLEAN   DEFAULT FALSE,
##      avgrlen            NUMBER    DEFAULT NULL,
##      nummacroblks       NUMBER    DEFAULT NULL,
##      nummicroblks       NUMBER    DEFAULT NULL
############################################################

call dbms_stats.set_index_stats('TEST', 'idx1_t1', tabname=>'T1', numrows=>100, avgrlen=>20, nummacroblks=>10, nummicroblks=>10);
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and INDEX_NAME='IDX1_T1';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and INDEX_NAME='IDX1_T1' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);
call dbms_stats.delete_index_stats('TEST', 'idx1_t1', tabname=>'T1');

call dbms_stats.set_index_stats('TEST', 'idx2_part', tabname=>'T_PART', numrows=>1000, avgrlen=>20, nummacroblks=>20, nummicroblks=>20);
call dbms_stats.set_index_stats('TEST', 'idx2_part', 'P0', tabname=>'T_PART', numrows=>500, avgrlen=>20, nummacroblks=>10, nummicroblks=>10);
call dbms_stats.set_index_stats('TEST', 'idx2_part', 'P1', tabname=>'T_PART', numrows=>500, avgrlen=>20, nummacroblks=>10, nummicroblks=>10);
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and INDEX_NAME='IDX2_PART';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and INDEX_NAME='IDX2_PART' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);
call dbms_stats.delete_index_stats('TEST', 'idx2_part', tabname=>'T_PART');

##################test export index stats###################
##      ownname           VARCHAR2,
##      indname           VARCHAR2,
##      partname          VARCHAR2 DEFAULT NULL,
##      stattab           VARCHAR2,
##      statid            VARCHAR2 DEFAULT NULL,
##      statown           VARCHAR2 DEFAULT NULL
############################################################

--disable_warnings
drop table if exists t_stat;
--enable_warnings

call dbms_stats.create_stat_table('TEST', 'T_STAT');
call dbms_stats.gather_index_stats('TEST', 'idx1_t1', tabname=>'T1');
call dbms_stats.gather_index_stats('TEST', 'idx2_part', tabname=>'T_PART');
call dbms_stats.gather_index_stats('TEST', 'idx2_subpart', tabname=>'T_SUBPART');

call dbms_stats.export_index_stats('TEST', 'idx1_t1', tabname=>'T1', stattab=>'t_stat', statown=>'TEST');
--sorted_result
select statid, type, version, flags, c1, c2, c3, c4, c5, n1, n3 from T_STAT where C1 = 'IDX1_T1' and ob_spec1 > 0 and ob_spec2 > 0 order by c5, c4, c1, c2, c3;

call dbms_stats.export_index_stats('TEST', 'idx2_part', tabname=>'T_PART', stattab=>'t_stat', statown=>'TEST');
--sorted_result
select statid, type, version, flags, c1, c2, c3, c4, c5, n1, n3 from T_STAT where C1 = 'IDX2_PART' and ob_spec1 > 0 and ob_spec2 > 0 order by c5, c4, c1, c2, c3;

call dbms_stats.export_index_stats('TEST', 'idx2_subpart', tabname=>'T_SUBPART', partname=>'P0', stattab=>'t_stat', statown=>'TEST');
call dbms_stats.export_index_stats('TEST', 'idx2_subpart', tabname=>'T_SUBPART', partname=>'P1', stattab=>'t_stat', statown=>'TEST');
--sorted_result
select statid, type, version, flags, c1, c2, c3, c4, c5, n1, n3 from T_STAT where C1 = 'IDX2_SUBPART' and ob_spec1 > 0 and ob_spec2 > 0 order by c5, c4, c1, c2, c3;

##################test import index stats####################
##      ownname          VARCHAR2,
##      indname          VARCHAR2,
##      partname         VARCHAR2 DEFAULT NULL,
##      stattab          VARCHAR2,
##      statid           VARCHAR2 DEFAULT NULL,
##      statown          VARCHAR2 DEFAULT NULL,
##      no_invalidate    BOOLEAN DEFAULT FALSE,
##      force            BOOLEAN DEFAULT FALSE
##############################################################

call dbms_stats.delete_index_stats('TEST', 'idx1_t1', tabname=>'T1');
call dbms_stats.delete_index_stats('TEST', 'idx2_part', tabname=>'T_PART');
call dbms_stats.delete_index_stats('TEST', 'idx2_subpart', tabname=>'T_SUBPART');

call dbms_stats.import_index_stats('TEST', 'idx1_t1', stattab=>'t_stat', statown=>'TEST', tabname=>'T1');
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS from oceanbase.dba_ind_statistics where owner='TEST' and INDEX_NAME='IDX1_T1';
--sorted_result
select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and INDEX_NAME='IDX1_T1' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);

