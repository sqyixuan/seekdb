select OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN from index_stats_view where owner='TEST' and INDEX_NAME='IDX3_PART' and ((MACRO_BLK_CNT > 0 and MICRO_BLK_CNT > 0) or MACRO_BLK_CNT is null);

call dbms_stats.delete_index_stats('TEST', 'idx3_part', partname=>'P0', tabname=>'T_PART');
call dbms_stats.delete_index_stats('TEST', 'idx3_part', partname=>'P2', tabname=>'T_PART');
