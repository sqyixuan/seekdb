--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats
# descriptor: test index stats relation feature

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--enable_query_log

--disable_warnings
drop table if exists t1, t2, t_part, t_subpart;
drop view if exists index_stats_view;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, key idx(c2));
create index idx1_t1 on t1(c3);
create index idx2_t1 on t1(c3);

create table t_part (c1 int primary key, c2 int, c3 int, key idx(c2)) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;
create index idx2_part on t_part(c3) global partition by hash(c3) partitions 2;
create index idx3_part on t_part(c2, c3) global partition by hash(c2) partitions 3;

create table t_subpart (c1 int, c2 int, c3 int, key idx(c2)) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
  subpartition p0,
  subpartition p1,
  subpartition p2
)
partitions 3;
create index idx1_subpart on t_subpart(c2) global;
create index idx2_subpart on t_subpart(c3) global partition by hash(c3) partitions 4;

##由于oracle兼容的视图没有平均行长、宏块、微块字段，这里提前创建一个视图用于查询
create view index_stats_view as SELECT
    CAST(DB.DATABASE_NAME AS CHAR(128)) AS OWNER,
    CAST(V.INDEX_NAME AS     CHAR(128)) AS INDEX_NAME,
    CAST(DB.DATABASE_NAME AS     CHAR(128)) AS TABLE_OWNER,
    CAST(T.TABLE_NAME       AS  CHAR(128)) AS TABLE_NAME,
    CAST(V.PARTITION_NAME   AS  CHAR(128)) AS PARTITION_NAME,
    CAST(V.SUBPARTITION_NAME  AS    CHAR(128)) AS SUBPARTITION_NAME,
    CAST(V.OBJECT_TYPE AS CHAR(12)) AS OBJECT_TYPE,
    CAST(STAT.ROW_CNT AS    DECIMAL) AS NUM_ROWS,
    CAST(STAT.AVG_ROW_LEN AS    DECIMAL) AS AVG_ROW_LEN,
    CAST(STAT.macro_blk_cnt AS    DECIMAL) AS MACRO_BLK_CNT,
    CAST(STAT.micro_blk_cnt AS    DECIMAL) AS MICRO_BLK_CNT
    FROM
    (SELECT DATABASE_ID,
            TABLE_ID,
            DATA_TABLE_ID,
            CASE WHEN PART_LEVEL = 0 THEN -2 ELSE -1 END AS PARTITION_ID,
            SUBSTR(TABLE_NAME, 7 + INSTR(SUBSTR(TABLE_NAME, 7), '_')) AS INDEX_NAME,
            NULL AS PARTITION_NAME,
            NULL AS SUBPARTITION_NAME,
            NULL AS PARTITION_POSITION,
            NULL AS SUBPARTITION_POSITION,
            'INDEX' AS OBJECT_TYPE
        FROM
            oceanbase.__all_table T
        WHERE T.TABLE_TYPE = 5
    UNION ALL
        SELECT T.DATABASE_ID,
                T.TABLE_ID,
                T.DATA_TABLE_ID,
                P.PART_ID,
                SUBSTR(T.TABLE_NAME, 7 + INSTR(SUBSTR(T.TABLE_NAME, 7), '_')) AS INDEX_NAME,
                P.PART_NAME,
                NULL,
                P.PART_ID + 1,
                NULL,
                'PARTITION'
        FROM
            oceanbase.__all_table T
          JOIN
            oceanbase.__all_part P
            ON T.TABLE_ID = P.TABLE_ID
        WHERE T.TABLE_TYPE = 5
    UNION ALL
        SELECT T.DATABASE_ID,
               T.TABLE_ID,
               T.DATA_TABLE_ID,
               SP.SUB_PART_ID AS PARTITION_ID,
               SUBSTR(T.TABLE_NAME, 7 + INSTR(SUBSTR(T.TABLE_NAME, 7), '_')) AS INDEX_NAME,
               P.PART_NAME,
               SP.SUB_PART_NAME,
               P.PART_ID + 1,
               SP.SUB_PART_ID + 1,
              'SUBPARTITION'
        FROM
            oceanbase.__all_table T
        JOIN
            oceanbase.__all_part P
            ON T.TABLE_ID = P.TABLE_ID
        JOIN
            oceanbase.__all_sub_part SP
            ON T.TABLE_ID = SP.TABLE_ID
            AND P.PART_ID = SP.PART_ID
        WHERE T.TABLE_TYPE = 5
    ) V
    JOIN oceanbase.__all_table T
         ON T.TABLE_ID = V.DATA_TABLE_ID
         AND T.DATABASE_ID = V.DATABASE_ID
    JOIN
        oceanbase.__all_database DB
        ON DB.DATABASE_ID = V.DATABASE_ID
        AND DB.DATABASE_NAME !=  '__recyclebin'
    LEFT JOIN
        oceanbase.__all_table_stat STAT
        ON V.TABLE_ID = STAT.TABLE_ID
        AND (V.PARTITION_ID = STAT.PARTITION_ID OR V.PARTITION_ID = -2)
        AND STAT.INDEX_TYPE = 1;

