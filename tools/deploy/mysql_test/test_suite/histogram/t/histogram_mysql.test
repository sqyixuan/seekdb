--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer, opt_stats
#test mysql histogram construction
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--result_format 3
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b int, c int, d int);
--disable_query_log
--let $count = 0
while($count < 1000)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, $count%10, $count%20, $count%40)
  eval $stmt;
  inc $count;
}

--enable_query_log

connection default;

analyze table t1 drop histogram on a, b, c, d;
connection my_obsys;
alter system change tenant sys;
select object_type, row_cnt from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1');
select column_id, object_type, distinct_cnt, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1, 2;
connection default;

analyze table t1 update histogram on a, b, c, d with 30 buckets;
connection my_obsys;
select object_type, row_cnt from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1');
select column_id, object_type, distinct_cnt, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1, 2;
connection default;

analyze table t1 drop histogram on a, b;
connection my_obsys;
select object_type, row_cnt from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1');
select column_id, object_type, distinct_cnt, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1, 2;
connection default;

analyze table t1 update histogram on a, b with 30 buckets;
connection my_obsys;
select object_type, row_cnt from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1');
select column_id, object_type, distinct_cnt, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't1') order by 1, 2;
connection default;
#drop table t1;
disconnect my_obsys;
