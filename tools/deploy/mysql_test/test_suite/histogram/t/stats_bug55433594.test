--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

##bug:

##check lock tables bug
set range_index_dive_limit = -1;
set partition_index_dive_limit = -1;

--error 0,1051
drop table t1;
--error 0,1051
drop table t_part;
--error 0, 4298
drop sequence s1;

create table t1(c1 int, c2 int, c3 int);
create table t_part(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create sequence s1 cache 1000 noorder;
insert into t_part select mod(s1.nextval, 10),mod(s1.nextval, 10), mod(s1.nextval, 10) from table(generator(1000));

call dbms_stats.gather_table_stats('test', 't_part', granularity=>'GLOBAL');
call dbms_stats.lock_table_stats('test', 't1');
call dbms_stats.lock_table_stats('test', 't_part');
--sorted_result
select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,STATTYPE_LOCKED from oceanbase.dba_tab_statistics where table_name in ('T1', 'T_PART') and LAST_ANALYZED is not null;

explain extended_noaddr select * from t1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select * from t_part where c2 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select * from t_part partition(p2) where c2 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
explain extended_noaddr select * from t_part partition(p0,p1) where c2 = 1;

drop table t1;
drop table t_part;
drop sequence s1;

##check set column min/max value

--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t_part;
--error 0, 4298
drop sequence s1;


create table t1(c1 int, c2 int, c3 int);
create sequence s1 cache 10 noorder;
insert into t1 select s1.nextval, s1.nextval, s1.nextval from table(generator(10));

call dbms_stats.gather_table_stats('test', 't1');
drop sequence s1;
create sequence s1 cache 100 noorder;
insert into t1 select 100 + s1.nextval, 100 + s1.nextval, 100 + s1.nextval from table(generator(100));
select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN from oceanbase.dba_tab_statistics where owner='TEST' and table_name = 'T1' and LAST_ANALYZED is not null;
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T1' and LAST_ANALYZED is not null;

explain select count(*) from t1 where c1 = 1;
select count(*) from t1 where c1 = 1;

explain select count(*) from t1 where c1 > 100;
select count(*) from t1 where c1 > 100;

call dbms_stats.set_table_stats('test', 't1', numrows=>110, avgrlen=>20);
call dbms_stats.set_column_stats('test', 't1', 'c1', distcnt=>110, minval=>'1', maxval=>'200');
call dbms_stats.set_column_stats('test', 't1', 'c2', distcnt=>110, minval=>'1', maxval=>'200');
call dbms_stats.set_column_stats('test', 't1', 'c3', distcnt=>110, minval=>'1', maxval=>'200');

select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN from oceanbase.dba_tab_statistics where owner='TEST' and table_name = 'T1' and LAST_ANALYZED is not null;
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T1' and LAST_ANALYZED is not null;

explain select count(*) from t1 where c1 = 1;
select count(*) from t1 where c1 = 1;

explain select count(*) from t1 where c1 > 100;
select count(*) from t1 where c1 > 100;

drop table t1;
drop sequence s1;

create table t_part(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create sequence s1 cache 1000 noorder;

call dbms_stats.gather_table_stats('test', 't_part');
insert into t_part select mod(s1.nextval, 10),mod(s1.nextval, 10), mod(s1.nextval, 10) from table(generator(1000));

--sorted_result
select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN from oceanbase.dba_tab_statistics where owner='TEST' and table_name = 'T_PART' and LAST_ANALYZED is not null;
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T_PART' and LAST_ANALYZED is not null;
--sorted_result
select table_name, partition_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_part_col_statistics where owner='TEST' and table_name = 'T_PART' and partition_name = 'P0' and LAST_ANALYZED is not null;

explain select count(*) from t_part;
select count(*) from t_part;

explain select count(*) from t_part where c2 = 1;
select count(*) from t_part where c2 = 1;

explain select count(*) from t_part where c2 > 5;
select count(*) from t_part where c2 > 5;

explain select count(*) from t_part partition(p0) where c2 = 2;
select count(*) from t_part partition(p0) where c2 = 2;

explain select count(*) from t_part partition(p0) where c2 > 3;
select count(*) from t_part partition(p0) where c2 > 3;


call dbms_stats.set_table_stats('test', 't_part', numrows=>1000, avgrlen=>20);
call dbms_stats.set_table_stats('test', 't_part', 'p0', numrows=>200, avgrlen=>20);
call dbms_stats.set_column_stats('test', 't_part', 'c1', distcnt=>10, minval=>'1', maxval=>'10');
call dbms_stats.set_column_stats('test', 't_part', 'c2', distcnt=>10, minval=>'1', maxval=>'10');
call dbms_stats.set_column_stats('test', 't_part', 'c3', distcnt=>10, minval=>'1', maxval=>'10');
call dbms_stats.set_column_stats('test', 't_part', 'c1', 'p0', distcnt=>2, minval=>'2', maxval=>'7');
call dbms_stats.set_column_stats('test', 't_part', 'c2', 'p0', distcnt=>2, minval=>'2', maxval=>'7');
call dbms_stats.set_column_stats('test', 't_part', 'c3', 'p0', distcnt=>2, minval=>'2', maxval=>'7');

--sorted_result
select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN from oceanbase.dba_tab_statistics where owner='TEST' and table_name = 'T_PART' and LAST_ANALYZED is not null;
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T_PART' and LAST_ANALYZED is not null;
--sorted_result
select table_name, partition_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_part_col_statistics where owner='TEST' and table_name = 'T_PART' and partition_name = 'P0' and LAST_ANALYZED is not null;

explain select count(*) from t_part;
select count(*) from t_part;

explain select count(*) from t_part where c2 = 1;
select count(*) from t_part where c2 = 1;

explain select count(*) from t_part where c2 > 5;
select count(*) from t_part where c2 > 5;

explain select count(*) from t_part partition(p0) where c2 = 2;
select count(*) from t_part partition(p0) where c2 = 2;

explain select count(*) from t_part partition(p0) where c2 > 3;
select count(*) from t_part partition(p0) where c2 > 3;

drop table t_part;
drop sequence s1;

create table t2(c1 int, c2 varchar(20), c3 date, c4 timestamp(6));
call dbms_stats.set_table_stats('test', 't2', numrows=>1000000000, avgrlen=>20000);
call dbms_stats.set_column_stats('test', 't2', 'c1', distcnt=>9, minval=>'1', maxval=>'9');
call dbms_stats.set_column_stats('test', 't2', 'c2', distcnt=>99, minval=>'aaa', maxval=>'eeee');
call dbms_stats.set_column_stats('test', 't2', 'c3', distcnt=>999, minval=>'2022-01-01', maxval=>'2024-03-15');
call dbms_stats.set_column_stats('test', 't2', 'c4', distcnt=>99999, minval=>'2022-01-01 12:00:00', maxval=>'2024-01-01 12:00:00');

select TABLE_NAME,PARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN from oceanbase.dba_tab_statistics where owner='TEST' and table_name = 'T2' and LAST_ANALYZED is not null;
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T2' and LAST_ANALYZED is not null;

drop table t2;

##check set block sample

select dbms_stats.get_param('BLOCK_SAMPLE') from dual;

--error 0,1051
drop table t1;
--error 0, 4298
drop sequence s1;

create table t1(c1 int, c2 int, c3 int);
create sequence s1 cache 40000 noorder;
insert into t1 select s1.nextval, s1.nextval, s1.nextval from table(generator(40000));
select dbms_stats.get_prefs('BLOCK_SAMPLE', 'TEST', 'T1') from dual;
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'T1') from dual;
call dbms_stats.gather_table_stats('TEST', 'T1');
--sorted_result
select table_name, column_name, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE,SAMPLE_SIZE  from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T1';
select table_name, PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name = 'T1' order by START_TIME desc limit 1;

call dbms_stats.set_table_prefs('TEST', 'T1', 'BLOCK_SAMPLE', 'TRUE');
call dbms_stats.set_table_prefs('TEST', 'T1', 'ESTIMATE_PERCENT', '50');
select dbms_stats.get_prefs('BLOCK_SAMPLE', 'TEST', 'T1') from dual;
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'T1') from dual;

call dbms_stats.gather_table_stats('TEST', 'T1');
select count(*) from oceanbase.dba_tab_col_statistics where owner='TEST' and table_name = 'T1' and SAMPLE_SIZE > 10000;
select PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name = 'T1' order by START_TIME desc limit 1;

drop table t1;
drop sequence s1;
