# owner: dingjincheng.djc
#tags: pl, optimizer, opt_stats
# owner group: SQL1

--disable_warnings
drop table if exists ct2;
--enable_warnings

CREATE TABLE `ct2` (   `c1` int(11) NOT NULL,   `c2` int(11) NOT NULL,   `c3` varchar(100) DEFAULT NULL,   `c4` int(11) DEFAULT NULL,   `c5` int(11) DEFAULT NULL,   `c6` int(11) DEFAULT NULL,   PRIMARY KEY (`c1`, `c2`),   KEY `ct2_idx` (`c4`, `c3`) BLOCK_SIZE 16384 LOCAL WITH COLUMN GROUP(each column) ) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0  partition by hash(c2) (partition `p0`, partition `p1`, partition `p2`) WITH COLUMN GROUP(all columns, each column);

set @n = 0;
insert into ct2 select @n := @n + 1, @n * 3, concat('ADDSDSDDFSDG', @n), @n, @n, @n from table(generator(40000));
insert into ct2 select @n := @n + 1, @n * 3 + 1, concat('ADDSDSDDFSDG', @n), @n, @n, @n from table(generator(40000));
insert into ct2 select @n := @n + 1, @n * 3 + 2, concat('ADDSDSDDFSDG', @n), @n, @n, @n from table(generator(4));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--result_format 4

call dbms_stats.gather_table_stats('TEST', 'CT2');

drop table ct2;
