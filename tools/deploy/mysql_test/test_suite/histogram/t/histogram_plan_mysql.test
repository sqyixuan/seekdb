--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: sql
# tags: optimizer, opt_stats
# description: 测试有直方图的情况下计划估行的正确性
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--result_format 3
--disable_warnings
DROP DATABASE IF EXISTS HISTOGRAM_PLAN;
--enable_warnings
CREATE DATABASE HISTOGRAM_PLAN;
USE HISTOGRAM_PLAN;

--echo # 场景1
--echo # 表T1的数据分布如下：10行c2 = 1，20行c2 = 2，
--echo # 40行c2 = 3，80行c2 = 4，160行c2 = 5，320行c2 = 6，
--echo # 640行c2 = 7，1280行c2 = 8，一共2550行

create table T1 (c1 int key, c2 int, c3 int);

--disable_query_log
--let $count= 0
--let $i= 1
--let row_cnt= 10
while($i < 9)
{
  --let $idx= 0
  --let $stmt= INSERT INTO T1 VALUES($count, $i, 233333)
  inc $count;
  inc $idx;
  while($idx < $row_cnt)
  {
    --let $value= ,($count, $i, 233333)
    --let $stmt= $stmt$value
    inc $count;
    inc $idx;
  }
  eval $stmt;
  --let $row_cnt= query_get_value(SELECT $row_cnt * 2 as rc, rc, 1)
  inc $i;
}
--enable_query_log
connection default;

--echo Frequency Histogram
analyze table t1 update histogram on c2 with 20 buckets;
select endpoint_num, endpoint_value from oceanbase.__all_histogram_stat where table_id = (
    select table_id from oceanbase.__all_table where table_name = 't1' and database_id =(
        select database_id from oceanbase.__all_database where database_name = 'HISTOGRAM_PLAN'));

explain select * from t1 where c2 = -10;
explain select * from t1 where c2 = 0;
explain select * from t1 where c2 = 1;
explain select * from t1 where c2 = 2;
explain select * from t1 where c2 = 3;
explain select * from t1 where c2 = 4;
explain select * from t1 where c2 = 5;
explain select * from t1 where c2 = 6;
explain select * from t1 where c2 = 7;
explain select * from t1 where c2 = 8;
explain select * from t1 where c2 = 9;
explain select * from t1 where c2 = 10;
explain select * from t1 where c2 >= 4 and c2 <= 6;


--echo Height-balance Histogram
analyze table t1 update histogram on c2 with 7 buckets;
select endpoint_num, endpoint_value from oceanbase.__all_histogram_stat where table_id = (
    select table_id from oceanbase.__all_table where table_name = 't1' and database_id =(
        select database_id from oceanbase.__all_database where database_name = 'HISTOGRAM_PLAN'));

explain select * from t1 where c2 = -10;
explain select * from t1 where c2 = 0;
explain select * from t1 where c2 = 1;
explain select * from t1 where c2 = 2;
explain select * from t1 where c2 = 3;
explain select * from t1 where c2 = 4;
explain select * from t1 where c2 = 5;
explain select * from t1 where c2 = 6;
explain select * from t1 where c2 = 7;
explain select * from t1 where c2 = 8;
explain select * from t1 where c2 = 9;
explain select * from t1 where c2 = 10;
explain select * from t1 where c2 >= 4 and c2 <= 6;

USE HISTOGRAM_PLAN;
##DROP DATABASE IF EXISTS HISTOGRAM_PLAN;
disconnect my_obsys;
