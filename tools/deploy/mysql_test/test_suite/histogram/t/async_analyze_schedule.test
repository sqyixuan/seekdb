select t.table_name,s.stale_stats,	s.spare1,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  in ('t', 't1','tsubpart', 'tsubpart1') and t.database_id in (select database_id from oceanbase.__all_database where database_name ='test_async_scheduler' );

call dbms_stats.async_gather_stats_job_proc();
## 't', 't1'不收集，tsubpart收集成功应该有数据
-- sorted_result
select t.table_name,s.stale_stats,	s.spare1,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  in ('t', 't1','tsubpart', 'tsubpart1') and t.database_id in (select database_id from oceanbase.__all_database where database_name ='test_async_scheduler' );


--disable_query_log
--disable_warnings
drop table if exists aa;
drop table if exists bb;
drop table if exists cc;
create table aa(a1 int primary key auto_increment, a2 int, a3 int);
create table bb(b1 int primary key auto_increment, b2 int, b3 int);
create table cc(c1 int primary key auto_increment, c2 int, c3 int) with column group (all columns, each column);
delete from aa;
insert into aa(a2, a3) values (10, 15), (10, 14), (10, 12), (11, 13), (12, 12), (12, 10);
delete from bb;
insert into bb(b2, b3) values  (10, 14), (11, 14), (11, 13), (12, 11), (12, 10);
--enable_warnings
--enable_query_log
call DBMS_STATS.ASYNC_GATHER_STATS_JOB_PROC();

--sorted_result
select TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,STALE_STATS,NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where TABLE_NAME in ('aa', 'bb', 'cc', 't', 't1','tsubpart', 'tsubpart1') and OWNER ='test_async_scheduler';
--sorted_result
select t.table_name,s.stale_stats,	s.spare1,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  in ('aa', 'bb', 'cc', 't', 't1','tsubpart', 'tsubpart1') and t.database_id in (select database_id from oceanbase.__all_database where database_name ='test_async_scheduler' );

## test timeout


--disable_query_log
--disable_warnings
drop table if exists aa;
drop table if exists bb;
drop table if exists cc;
--enable_warnings
--enable_query_log

create table aa(a1 int primary key auto_increment, a2 int, a3 int);
create table bb(b1 int primary key auto_increment, b2 int, b3 int);
create table cc(c1 int primary key auto_increment, c2 int, c3 int) with column group (all columns, each column);
delete from aa;
insert into aa(a2, a3) values (10, 15), (10, 14), (10, 12), (11, 13), (12, 12), (12, 10);
delete from bb;
insert into bb(b2, b3) values  (10, 14), (11, 14), (11, 13), (12, 11), (12, 10);


--disable_warnings
set ob_query_timeout= 10;

call dbms_stats.async_gather_stats_job_proc();
call dbms_stats.async_gather_stats_job_proc();
call dbms_stats.async_gather_stats_job_proc();
call dbms_stats.async_gather_stats_job_proc();
call dbms_stats.async_gather_stats_job_proc();
--enable_warnings


SET ob_query_timeout = DEFAULT;

--sorted_result
select TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,STALE_STATS,NUM_ROWS from oceanbase.DBA_TAB_STATISTICS where TABLE_NAME in ('aa', 'bb', 'cc', 't', 't1','tsubpart', 'tsubpart1') and OWNER ='test_async_scheduler';
--sorted_result
select t.table_name,s.stale_stats,	s.spare1,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  in ('aa', 'bb', 'cc', 't', 't1','tsubpart', 'tsubpart1') and t.database_id in (select database_id from oceanbase.__all_database where database_name ='test_async_scheduler' );

drop database test_async_scheduler;