## make analyze errror
connection obsys;
alter system set_tp tp_name = ERRSIM_FAILED_ANALYZE_TABLE_STATS, error_code = 4013, frequency = 0;
--enable_warnings


connection default;
use test_async_scheduler;
## stale_stats 应该没1
-- sorted_result
select t.table_name, s.stale_stats,	s.spare1,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  in ('t', 't1','tsubpart', 'tsubpart1') and t.database_id in (select database_id from oceanbase.__all_database where database_name ='test_async_scheduler' );

call dbms_stats.async_gather_stats_job_proc();
## 't', 't1'不收集，tsubpart收集成功应该有数据
