## make analyze errror
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = ERRSIM_FAILED_ANALYZE_TABLE_STATS, error_code = 4013, frequency = 1;
connection default;
--enable_warnings

create table t(c1 int, c2 int);
create table t1(c1 int, c2 int, c3 int, index i1(c1,c2)) partition by hash(c1) partitions 2;
create table tsubpart1 (c1 int, c2 int) partition by hash(c1)
subpartition by hash(c2)
  subpartition template (subpartition p0, subpartition p1)
  partitions 2;

