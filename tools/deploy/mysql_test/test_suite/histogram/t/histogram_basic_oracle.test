--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:dingjincheng.djc
#owner group: sql1
#tags: optimizer, opt_stats
#test basic histogram construction
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
let $tenant_id = query_get_value(select effective_tenant_id() TENANT_ID from dual, TENANT_ID, 1);

--result_format 3
--disable_warnings
--error 0, 942
drop table  t0;
--error 0, 942
drop table  t1;
--error 0, 942
drop table  t2;
--error 0, 942
drop table  t3;
--error 0, 942
drop table  t4;
--enable_warnings
create table t0(a int primary key, b int, c int, d int);
create table t1(a int primary key, b int, c int, d int);
create table t2(a int primary key, b int, c int, d int) partition by hash(a) partitions 2;
create table t3(a int, b int, c int, d int, primary key(a,b)) partition by hash(a) subpartition by range (b) 
subpartition template (
subpartition pa values less than (4),  
subpartition pb values less than (10)) partitions 2;
create table t4 (c1 varchar2(20));

--disable_query_log
insert into t0 select level-1, level-1, level-1, level-1 from dual connect by level <= 10;
insert into t1 select level-1, mod(level-1, 10), mod(level-1, 20), mod(level-1, 40) from dual connect by level <= 1000;
insert into t2 select level-1, mod(level-1, 10), mod(level-1, 20), mod(level-1, 40) from dual connect by level <= 1000;
insert into t3 select level-1, mod(level-1, 10), mod(level-1, 20), mod(level-1, 40) from dual connect by level <= 1000;
insert into t4 values ('100'),('200');
--enable_query_log

connection my_obsys;
eval alter system change tenant tenant_id = $tenant_id;
delete from oceanbase.__all_table_stat;
delete from oceanbase.__all_column_stat;
delete from oceanbase.__all_histogram_stat;
alter system change tenant tenant_id = 1;
connection default;

--sleep 10

## test basic analyze clause
analyze table t0 compute statistics for all columns;

connection my_obsys;
alter system change tenant oracle;
select object_type, row_cnt from oceanbase.__all_table_stat order by 1, 2;
select column_id, object_type, min_value, max_value, distinct_cnt, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat order by 1, 2,3,4;
select column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat order by 1, 2,3,4;
delete from oceanbase.__all_table_stat;
delete from oceanbase.__all_column_stat;
delete from oceanbase.__all_histogram_stat;
connection default;

