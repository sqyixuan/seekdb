select  object_type, row_cnt, avg_row_len from oceanbase.__all_table_stat order by table_id, 1, 2;
delete from oceanbase.__all_table_stat;
delete from oceanbase.__all_column_stat;
delete from oceanbase.__all_histogram_stat;
connection default;

drop table  t0;
drop table  t1;
drop table  t2;
drop table  t3;
drop table  t4;
disconnect my_obsys;
