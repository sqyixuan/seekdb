## 全部过期
insert into t select * from t;
insert into tpart select * from t;
insert into tsubpart select * from t;

call dbms_stats.gather_database_stats_job_proc();

## 应该为空
--sorted_result
select * from oceanbase.__all_virtual_table_opt_stat_gather_history where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and ret_code <> 0;
--sorted_result
select t.table_name, ret_code from  oceanbase.__all_virtual_table_opt_stat_gather_history s inner join oceanbase.__all_table t
on s.table_id = t.table_id
where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and t.table_name  in ('t','tpart','tsubpart','tpart1','tsubpart1');

create table tsubpart1 (c1 int, c2 int) partition by hash(c1)
	subpartition by range(c2)
	subpartition template(
		subpartition p1 values less than (3),
		subpartition p2 values less than (6),
		subpartition p3 values less than (9),
		subpartition p4 values less than (100)
	)
 partitions 10;
create table tpart1(c1 int, c2 int) partition by range(c1)   (partition p0 values less than(0), partition p1 values less than(100), partition p2 values less than(1000));
## 全部过期
insert into tpart1 select * from t;
insert into tsubpart1 select * from t;

call dbms_stats.gather_database_stats_job_proc();
## 应该为空
--sorted_result
select * from oceanbase.__all_virtual_table_opt_stat_gather_history where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and ret_code <> 0;
--sorted_result
select t.table_name, ret_code from  oceanbase.__all_virtual_table_opt_stat_gather_history s inner join oceanbase.__all_table t
on s.table_id = t.table_id
where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and t.table_name  in ('t','tpart','tsubpart','tpart1','tsubpart1');
--sorted_result
select table_name, count(1) -1 <= 7 from oceanbase.DBA_TAB_STATISTICS where table_name in ('tpart1','tsubpart1') and owner='TEST' group by table_name, LAST_ANALYZED;


insert into tpart1 select c2-c1, c1-c2 from t;
insert into tsubpart1  select * from t where c2<5;


## 部分过期
call dbms_stats.gather_database_stats_job_proc();
--sorted_result
select * from oceanbase.__all_virtual_table_opt_stat_gather_history where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and ret_code <> 0;
--sorted_result
select t.table_name, ret_code from  oceanbase.__all_virtual_table_opt_stat_gather_history s inner join oceanbase.__all_table t
on s.table_id = t.table_id
where start_time > date_sub(current_timestamp(), INTERVAL 5 MINUTE) and t.table_name  in ('t','tpart','tsubpart','tpart1','tsubpart1');

--disable_warnings
drop table if exists t_subpart;
--enable_warnings

create table t_subpart (c1 int, c2 int) 
partition by range(c1)
subpartition BY hash(c2) subpartitions 64
(partition part_1 values less than (1),
partition part_2 values less than (2),
partition part_3 values less than (3),
partition part_4 values less than (4),
partition part_5 values less than (5),
partition part_6 values less than (6),
partition part_7 values less than (7),
partition part_8 values less than (maxvalue))
;
set ob_query_timeout = 1000000000;
set @num = 0;
insert into t_subpart select (@num := @num + 1) % 8, @num from table(generator(100000));

--sorted_result
select count(1) from t_subpart where c1 is not null;
--sorted_result
select count(1), c1 from t_subpart group by c1;

call dbms_stats.gather_database_stats_job_proc();
--sorted_result
select (num_rows - 100000)/100000 <=0.1 from oceanbase.DBA_TAB_STATISTICS where owner= 'TEST' and table_name = 'T_SUBPART' and OBJECT_TYPE = 'TABLE';
--sorted_result
select count(1) from oceanbase.DBA_TAB_HISTOGRAMS where owner = 'TEST' and table_name = 'T_SUBPART' and column_name = 'c1'; 
drop table if exists t_subpart;

call dbms_stats.reset_global_pref_defaults();

--disable_warnings
drop table if exists tsubpart, t, tpart, tpart1, tsubpart1;
--enable_warnings
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
