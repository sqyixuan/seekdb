# owner: dingjincheng.djc
#tags: optimizer, opt_stats
# owner group: SQL1

--disable_warnings
drop table if exists t1;
drop table if exists t_subpart;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, key i1(c2)) partition by key(c1) partitions 4 WITH COLUMN GROUP(each column);
create table t_subpart(c1 int, c2 int, c3 int, key i1(c2))
 partition by range(c1) subpartition by key(c2) subpartition template (
subpartition `p0`,
subpartition `p1`,
subpartition `p2`,
subpartition `p3`,
subpartition `p4`,
subpartition `p5`,
subpartition `p6`,
subpartition `p7`)
(partition `M20240111` values less than (2500),
partition `M20240112` values less than (5000),
partition `M20240113` values less than (7500),
partition `M20240114` values less than (1000000000)
) WITH COLUMN GROUP(each column);

set @n = 0;
insert into t1 select @n := @n + 1, @n, @n from table(generator(10000));
insert into t_subpart select * from t1;

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;

connection default;

call dbms_stats.gather_table_stats('TEST', 'T1', granularity=>'GLOBAL', estimate_percent=>50);
call dbms_stats.gather_table_stats('TEST', 't_subpart', granularity=>'GLOBAL', estimate_percent=>50);

connection syscon;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;

connection default;

--result_format 4
select count(1) from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 'T1') and partition_id = -1;
select count(1) from oceanbase.__all_table_stat where table_id in (select table_id from oceanbase.__all_table where table_name = 't_subpart') and partition_id = -1;

drop table t1;
drop table t_subpart;