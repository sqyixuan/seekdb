# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, opt_stats

--disable_warnings
drop table if exists t_subpart;
--enable_warnings

create table t_subpart (c1 int, c2 int) 
partition by range(c1)
subpartition BY hash(c2) subpartitions 64
(partition part_1 values less than (1),
partition part_2 values less than (2),
partition part_3 values less than (3),
partition part_4 values less than (4),
partition part_5 values less than (5),
partition part_6 values less than (6),
partition part_7 values less than (7),
partition part_8 values less than (maxvalue))
;

set ob_query_timeout = 1000000000;
set @num = 0;
insert into t_subpart select (@num := @num + 1) % 8, @num from table(generator(100000));

select count(1) from t_subpart where c1 is not null;
select count(1), c1 from t_subpart group by c1;

call dbms_stats.gather_database_stats_job_proc();

select num_rows from oceanbase.DBA_TAB_STATISTICS where owner= 'TEST' and table_name = 'T_SUBPART' and OBJECT_TYPE = 'TABLE';
select count(1) from oceanbase.DBA_TAB_HISTOGRAMS where owner = 'TEST' and table_name = 'T_SUBPART' and column_name = 'c1'; 
drop table if exists t_subpart;