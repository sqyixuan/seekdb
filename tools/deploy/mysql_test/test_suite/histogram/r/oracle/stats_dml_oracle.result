##test ins/upd/del count stats
merge INTO t1 master USING t2 slave ON (master.c1=slave.c1) WHEN matched THEN UPDATE SET master.c2=slave.c2 delete where master.c1 > 900 when not matched then insert (c1,c2,c3) values (slave.c1,slave.c2,slave.c3);
merge INTO t_part master USING t2 slave ON (master.c1=slave.c2) WHEN matched THEN UPDATE SET master.c3=slave.c3 delete where master.c1 > 3750 when not matched then insert (c1,c2,c3) values (slave.c1,slave.c2,slave.c3);
merge INTO t_subpart master USING t2 slave ON (master.c1=slave.c3) WHEN matched THEN UPDATE SET master.c3=slave.c3 delete where master.c1 > 30750 when not matched then insert (c1,c2,c3) values (slave.c1,slave.c2,slave.c3);
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from dba_tab_modifications where TABLE_OWNER='TEST' and table_name in ('T1','T_PART','T_SUBPART');
