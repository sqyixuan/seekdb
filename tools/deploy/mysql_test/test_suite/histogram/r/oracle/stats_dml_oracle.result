drop table t1;
drop table t2;
drop table t_part;
drop table t_subpart;

##test gather table stats consider the stats whether is expired.
##build new tenant.


## 功能: 获取指定租户的ip&port
## 用法:
## 模板:




call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_ALL_TABLE');
call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_COLUMN_TABLE');

drop table t1;
drop table t_part;
drop table t_subpart;
drop view index_stats_view;
create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);

create table t_part (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2);

create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by range(c2)
subpartition template
(
  subpartition p0 values less than (3000),
  subpartition p1 values less than (6000),
  subpartition p2 values less than (MAXVALUE)
)
partitions 3;
create index idx1_subpart on t_subpart(c2) local;

insert into t1 select level,level,level from dual connect by level<=100;
insert into t_part select level,level,level from dual connect by level<=1000;
insert into t_subpart select level,level,level from dual connect by level<=10000;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
