##more than stale percent(default value:10)
update t1 set c1 = 10000 where c1 >=89;
update t_part partition(p0) set c3 = 10000 where c1 >=800;
update t_subpart subpartition(p0sp0) set c3 = 10000 where c1 >=2428;
delete from t_subpart subpartition(p1sp0) where c1 >=2363;
delete from t_subpart subpartition(p1sp1) where c1 >=5411;
delete from t_subpart subpartition(p2sp0) where c1 <=183;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
##expected regather table stat and the stat is changed.
