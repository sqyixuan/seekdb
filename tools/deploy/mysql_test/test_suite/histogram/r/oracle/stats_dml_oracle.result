merge INTO t1 master USING t2 slave ON (master.c1=slave.c1) WHEN matched THEN UPDATE SET master.c2=slave.c2 delete where master.c1 < 900 when not matched then insert (c1,c2,c3) values (slave.c1,slave.c2,slave.c3);
merge INTO t_part master USING t2 slave ON (master.c1=slave.c2) WHEN matched THEN UPDATE SET master.c3=slave.c3 delete where master.c1 < 3750 when not matched then insert (c1,c2,c3) values (slave.c1+100000,slave.c2+100000,slave.c3+100000);
merge INTO t_subpart master USING t2 slave ON (master.c1=slave.c3) WHEN matched THEN UPDATE SET master.c3=slave.c3 delete where master.c1 < 30750 when not matched then insert (c1,c2,c3) values (slave.c1,slave.c2,slave.c3);
