delete from t_part partition(p0) where c1 >=963;
delete from t_part partition(p1) where c1 >=970;
delete from t_subpart subpartition(p0sp0) where c1 >=2800;
delete from t_subpart subpartition(p1sp0) where c1 >=2813;
delete from t_subpart subpartition(p1sp1) where c1 >=5806;
