alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
select OWNER,JOB_NAME,ENABLED,REPEAT_INTERVAL,MAX_RUN_DURATION from dba_scheduler_jobs where JOB_NAME in ('FRIDAY_WINDOW','MONDAY_WINDOW','OPT_STATS_HISTORY_MANAGER','SATURDAY_WINDOW','SUNDAY_WINDOW','THURSDAY_WINDOW','TUESDAY_WINDOW','WEDNESDAY_WINDOW');
OWNER	JOB_NAME	ENABLED	REPEAT_INTERVAL	MAX_RUN_DURATION
SYS	FRIDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	MONDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	OPT_STATS_HISTORY_MANAGER	1	FREQ=DAYLY; INTERVAL=1	+000 12:00:00
SYS	SATURDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	SUNDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	THURSDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	TUESDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
SYS	WEDNESDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00
desc all_scheduler_windows;
FIELD	TYPE	NULL	KEY	DEFAULT	EXTRA
OWNER	VARCHAR2(128)	NO	NULL	NULL	NULL
WINDOW_NAME	VARCHAR2(128)	NO	NULL	NULL	NULL
RESOURCE_PLAN	VARCHAR2(128)	NO	NULL	NULL	NULL
SCHEDULE_OWNER	VARCHAR2(4000)	NO	NULL	NULL	NULL
SCHEDULE_NAME	VARCHAR2(4000)	NO	NULL	NULL	NULL
SCHEDULE_TYPE	VARCHAR2(8)	NO	NULL	NULL	NULL
START_DATE	TIMESTAMP(6) WITH TIME ZONE	YES	NULL	NULL	NULL
REPEAT_INTERVAL	VARCHAR2(4000)	YES	NULL	NULL	NULL
END_DATE	TIMESTAMP(6) WITH TIME ZONE	YES	NULL	NULL	NULL
DURATION	INTERVAL DAY (3) TO SECOND (0)	NO	NULL	NULL	NULL
WINDOW_PRIORITY	VARCHAR2(4)	NO	NULL	NULL	NULL
NEXT_RUN_DATE	TIMESTAMP(6) WITH TIME ZONE	NO	NULL	NULL	NULL
LAST_START_DATE	TIMESTAMP(6) WITH TIME ZONE	YES	NULL	NULL	NULL
ENABLED	VARCHAR2(5)	YES	NULL	NULL	NULL
ACTIVE	VARCHAR2(5)	NO	NULL	NULL	NULL
MANUAL_OPEN_TIME	TIMESTAMP(6) WITH TIME ZONE	NO	NULL	NULL	NULL
MANUAL_DURATION	INTERVAL DAY (3) TO SECOND (0)	NO	NULL	NULL	NULL
COMMENTS	VARCHAR2(4000)	YES	NULL	NULL	NULL
select OWNER,WINDOW_NAME,ENABLED,REPEAT_INTERVAL,DURATION,COMMENTS from all_scheduler_windows;
OWNER	WINDOW_NAME	ENABLED	REPEAT_INTERVAL	DURATION	COMMENTS
SYS	FRIDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	MONDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	SATURDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	SUNDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	THURSDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	TUESDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
SYS	WEDNESDAY_WINDOW	1	FREQ=WEEKLY; INTERVAL=1	+000 04:00:00	used to auto gather table stats
