result_format: 3
drop table if exists t1;
create table t1(a int primary key, b int, c int, d int);
analyze table t1 drop histogram on a, b, c, d;
#before generating histogram
alter system change tenant sys;
select tenant_id, object_type from oceanbase.__all_table_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2;
+-----------+-------------+
| tenant_id | object_type |
+-----------+-------------+
+-----------+-------------+
select tenant_id, column_id, object_type, sample_size, density, bucket_cnt, histogram_type from oceanbase.__all_column_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3;
+-----------+-----------+-------------+-------------+---------+------------+----------------+
| tenant_id | column_id | object_type | sample_size | density | bucket_cnt | histogram_type |
+-----------+-----------+-------------+-------------+---------+------------+----------------+
+-----------+-----------+-------------+-------------+---------+------------+----------------+
select tenant_id, column_id, endpoint_num, object_type, endpoint_value, b_endpoint_value, endpoint_repeat_cnt from oceanbase.__all_histogram_stat where table_id in (select table_id from __all_table where table_name = 't1') order by 1, 2, 3, 4;
+-----------+-----------+--------------+-------------+----------------+------------------+---------------------+
| tenant_id | column_id | endpoint_num | object_type | endpoint_value | b_endpoint_value | endpoint_repeat_cnt |
+-----------+-----------+--------------+-------------+----------------+------------------+---------------------+
+-----------+-----------+--------------+-------------+----------------+------------------+---------------------+
alter system change tenant sys;
set global ob_plan_cache_percentage = 90;
select a, b from t1 where a < 1;
+---+------+
| a | b    |
+---+------+
| 0 |    0 |
+---+------+
#after first execution
select statement, query_sql, hit_count, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = "5E2AA4215E5BBDA14FBD6C95BADB38E1" order by 1,2,3,4;
+---------------------------------+---------------------------------+-----------+------------+
| statement                       | query_sql                       | hit_count | executions |
+---------------------------------+---------------------------------+-----------+------------+
| select a, b from t1 where a < ? | select a, b from t1 where a < 1 |         0 |          1 |
+---------------------------------+---------------------------------+-----------+------------+
select a, b from t1 where a < 1;
