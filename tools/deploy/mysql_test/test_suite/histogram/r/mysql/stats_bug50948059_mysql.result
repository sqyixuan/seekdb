| t3         | p1             | p1sp3             | SUBPARTITION |        0 |           0 |
| t3         | p2             | NULL              | PARTITION    |        0 |           0 |
| t3         | p2             | p2sp0             | SUBPARTITION |        0 |           0 |
| t3         | p2             | p2sp1             | SUBPARTITION |        0 |           0 |
| t3         | p2             | p2sp2             | SUBPARTITION |        0 |           0 |
| t3         | p2             | p2sp3             | SUBPARTITION |        0 |           0 |
| t4         | NULL           | NULL              | TABLE        |        6 |          40 |
| t4         | p0             | NULL              | PARTITION    |        0 |           0 |
| t4         | p1             | NULL              | PARTITION    |        3 |          40 |
| t4         | p2             | NULL              | PARTITION    |        0 |           0 |
| t4         | p3             | NULL              | PARTITION    |        3 |          40 |
