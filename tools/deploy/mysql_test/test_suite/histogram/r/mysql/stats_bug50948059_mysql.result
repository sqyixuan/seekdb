call dbms_stats.set_table_prefs('TEST', 'T4', 'STALE_PERCENT', '50');
insert into t4 values(13,14),(15,16);
alter system minor freeze;
t4 will not be regathered
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
