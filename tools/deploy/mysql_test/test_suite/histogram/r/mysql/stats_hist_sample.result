| SUCCESS | GRANULARITY:AUTO;METHOD_OPT:for all columns size 1;DEGREE:1;ESTIMATE_PERCENT:100.000000;BLOCK_SAMPLE:0;STALE_PERCENT:-1.000000;HIST_EST_PERCENT:1.000000 |
+---------+----------------------------------------------------------------------------------------------------------------------------------------------------------+
select count(*) from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1' and HISTOGRAM is not null and SAMPLE_SIZE > 5000;
