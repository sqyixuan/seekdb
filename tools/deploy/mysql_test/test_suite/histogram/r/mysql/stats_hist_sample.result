result_format: 3
drop table t1;
drop table t2;
create table t1 (c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
insert into t1 select mod(random(), 100000), mod(random(), 10000), mod(random(), 1000) from table(generator(100000));
insert into t2 select mod(random(), 100000), mod(random(), 10000), mod(random(), 1000) from table(generator(100000));
select dbms_stats.get_prefs('HIST_EST_PERCENT') from dual;
+------------------------------------------+
| dbms_stats.get_prefs('HIST_EST_PERCENT') |
+------------------------------------------+
| DBMS_STATS.AUTO_SAMPLE_SIZE              |
+------------------------------------------+
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 1, method_opt=>'for all columns size 1');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
+---------+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| STATUS  | PROPERTIES                                                                                                                                               |
+---------+----------------------------------------------------------------------------------------------------------------------------------------------------------+
| SUCCESS | GRANULARITY:AUTO;METHOD_OPT:for all columns size 1;DEGREE:1;ESTIMATE_PERCENT:100.000000;BLOCK_SAMPLE:0;STALE_PERCENT:-1.000000;HIST_EST_PERCENT:1.000000 |
+---------+----------------------------------------------------------------------------------------------------------------------------------------------------------+
select COLUMN_NAME,SAMPLE_SIZE,HISTOGRAM from oceanbase.dba_Tab_col_statistics where owner='TEST' and table_name='T1';
+-------------+-------------+-----------+
| COLUMN_NAME | SAMPLE_SIZE | HISTOGRAM |
+-------------+-------------+-----------+
| c1          |      100000 | NULL      |
| c2          |      100000 | NULL      |
| c3          |      100000 | NULL      |
+-------------+-------------+-----------+
call dbms_stats.gather_table_stats('TEST', 'T1', hist_est_percent => 0.000001, method_opt=>'for all columns size 254');
select STATUS,PROPERTIES from oceanbase.dba_ob_table_opt_stat_gather_history where owner='TEST' and table_name='T1' order by START_TIME limit 1;
