##6.test export/import stats and history stats
##data ready
call dbms_stats.create_stat_table('TEST', 'T_SUBPART_STAT');
call dbms_stats.gather_table_stats('TEST', 'T_SUBPART', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T_SUBPART' and STATS_UPDATE_TIME IS NOT NULL;
+----------+
| count(*) |
+----------+
|       13 |
+----------+
call dbms_stats.export_table_stats('TEST', 'T_SUBPART', NULL, 'T_SUBPART_STAT', statown=>'TEST');
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T_SUBPART' and STATS_UPDATE_TIME IS NOT NULL;
+----------+
| count(*) |
+----------+
|       13 |
+----------+
call dbms_stats.delete_table_stats('TEST', 'T_SUBPART');

select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T_SUBPART' and STATS_UPDATE_TIME IS NOT NULL;
+----------+
| count(*) |
+----------+
|       26 |
+----------+
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P0', 'T_SUBPART_STAT', statown=>'TEST');
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P1', 'T_SUBPART_STAT', statown=>'TEST');
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P2SP0', 'T_SUBPART_STAT', statown=>'TEST');
call dbms_stats.import_column_stats('TEST', 'T_SUBPART', 'C1', 'P2SP1', 'T_SUBPART_STAT', statown=>'TEST');
call dbms_stats.import_column_stats('TEST', 'T_SUBPART', 'C2', 'P2SP1', 'T_SUBPART_STAT', statown=>'TEST');
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P2SP2', 'T_SUBPART_STAT', statown=>'TEST');
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T_SUBPART' and STATS_UPDATE_TIME IS NOT NULL;
