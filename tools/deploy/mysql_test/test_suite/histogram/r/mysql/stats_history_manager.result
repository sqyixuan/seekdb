##1.show system table and system view struct
desc oceanbase.dba_tab_stats_history;
+-------------------+--------------+------+-----+---------+-------+
| Field             | Type         | Null | Key | Default | Extra |
+-------------------+--------------+------+-----+---------+-------+
| OWNER             | varchar(128) | NO   |     |         |       |
| TABLE_NAME        | varchar(128) | NO   |     |         |       |
| PARTITION_NAME    | varchar(128) | NO   |     |         |       |
| SUBPARTITION_NAME | varchar(128) | NO   |     |         |       |
| STATS_UPDATE_TIME | datetime(6)  | NO   |     | NULL    |       |
+-------------------+--------------+------+-----+---------+-------+

##2.test history retention query and alter
select dbms_stats.get_stats_history_retention() from dual;
+------------------------------------------+
| dbms_stats.get_stats_history_retention() |
+------------------------------------------+
|                                       31 |
+------------------------------------------+

call dbms_stats.alter_stats_history_retention(15);
select dbms_stats.get_stats_history_retention() from dual;
+------------------------------------------+
| dbms_stats.get_stats_history_retention() |
+------------------------------------------+
|                                       15 |
+------------------------------------------+

call dbms_stats.alter_stats_history_retention(-1);
select dbms_stats.get_stats_history_retention() from dual;
+------------------------------------------+
| dbms_stats.get_stats_history_retention() |
+------------------------------------------+
|                                       -1 |
+------------------------------------------+

call dbms_stats.alter_stats_history_retention(0);
select dbms_stats.get_stats_history_retention() from dual;
+------------------------------------------+
| dbms_stats.get_stats_history_retention() |
+------------------------------------------+
|                                        0 |
+------------------------------------------+

call dbms_stats.alter_stats_history_retention(NULL);
select dbms_stats.get_stats_history_retention() from dual;
+------------------------------------------+
| dbms_stats.get_stats_history_retention() |
+------------------------------------------+
|                                       31 |
+------------------------------------------+

call dbms_stats.alter_stats_history_retention(-2);
ERROR HY000: Invalid or inconsistent input values
call dbms_stats.alter_stats_history_retention(365001);
ERROR HY000: Invalid or inconsistent input values

##3.test gather stats and history stats
##basic table
select count(*) from oceanbase.dba_tab_stats_history where owner = 'TEST' and table_name = 'T1' and STATS_UPDATE_TIME IS NOT NULL;
