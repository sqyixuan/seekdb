drop table t1;
drop table t_part;
drop table t_subpart;

##test gather table stats consider the stats whether is expired.
##build new tenant.
##build tenant


use test;

call dbms_stats.gather_table_stats('OCEANBASE','__ALL_VIRTUAL_CORE_ALL_TABLE');
call dbms_stats.gather_table_stats('OCEANBASE','__ALL_VIRTUAL_CORE_COLUMN_TABLE');

drop table if exists t1, t_part, t_subpart;
create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);

create table t_part (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;

create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by range(c2)
subpartition template
(
  subpartition p0 values less than (1000),
  subpartition p1 values less than (10000),
  subpartition p2 values less than (100000),
  subpartition p3 values less than (MAXVALUE)
)
partitions 3;
create index idx1_subpart on t_subpart(c2) local;

