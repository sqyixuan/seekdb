replace into t1 select * from t1;
replace into t_part select c1+2000,c2+2000,c3+2000 from t_part order by c1 desc limit 1000;
replace into t_subpart select * from t_subpart;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
