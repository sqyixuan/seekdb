##not arrive stale percent(default value:10)
delete from t1 where c1 >=95;
delete from t_part partition(p0) where c1 <= 36;
delete from t_part partition(p1) where c1 <= 37;
delete from t_subpart partition(p0sp1) where c1 <= 1029;
delete from t_subpart partition(p1sp0) where c1 <= 28;
delete from t_subpart partition(p1sp1) where c1 <= 1027;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
use test;

call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
##expected no regather table stat and the stat isn't change.
