drop table t1;
drop table t_part;
drop table t_subpart;

drop sequence s1;
create sequence s1 cache 42000 noorder;

create table t_part (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;


call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC();
select TABLE_NAME,PARTITION_NAME,NUM_ROWS from oceanbase.dba_tab_statistics where table_name='T_PART' and OWNER = 'TEST';
