##more than stale percent(default value:10)
update t1 set c1 = 10000 where c1 >=89;
update t_part partition(p0) set c3 = 10000 where c1 < 100;
update t_subpart partition(p0sp1) set c3 = 10000 where c1 <= 1200;
update t_subpart partition(p1sp0) set c3 = 10000 where c1 <= 640;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
use test;

