drop table if exists t1, t_part, t_subpart;
create table t1 (c1 int, c2 int, c3 int);
create index idx1_t1 on t1(c2);
create table t_part (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;
create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
subpartition p0,
subpartition p1,
subpartition p2
)
partitions 3;
create index idx1_subpart on t_subpart(c2) local;
result_format: 4
##desc oceanbase.v$dml_stats, oceanbase.dba_tab_modifications;
desc oceanbase.v$dml_stats;
+----------+-------------+------+-----+---------+-------+
| Field    | Type        | Null | Key | Default | Extra |
+----------+-------------+------+-----+---------+-------+
| CON_ID   | bigint(0)   | NO   |     |         |       |
| CURROWS  | bigint(0)   | NO   |     |         |       |
| DEL      | bigint(20)  | NO   |     |         |       |
| DROPSEG  | bigint(0)   | NO   |     |         |       |
| FLAGS    | bigint(0)   | NO   |     |         |       |
| INS      | bigint(20)  | NO   |     |         |       |
| INST_ID  | bigint(20)  | NO   |     |         |       |
| LASTUSED | bigint(0)   | NO   |     |         |       |
| OBJN     | bigint(20)  | NO   |     |         |       |
| PAROBJN  | bigint(20)  | NO   |     |         |       |
| SVR_IP   | varchar(46) | NO   |     |         |       |
| SVR_PORT | bigint(20)  | NO   |     |         |       |
| UPD      | bigint(20)  | NO   |     |         |       |
+----------+-------------+------+-----+---------+-------+

desc oceanbase.dba_tab_modifications;
+-------------------+--------------+------+-----+---------+-------+
| Field             | Type         | Null | Key | Default | Extra |
+-------------------+--------------+------+-----+---------+-------+
| DELETES           | bigint(20)   | NO   |     |         |       |
| DROP_SEGMENTS     | bigint(0)    | NO   |     |         |       |
| INSERTS           | bigint(20)   | NO   |     |         |       |
| PARTITION_NAME    | varchar(128) | NO   |     |         |       |
| SUBPARTITION_NAME | varchar(128) | NO   |     |         |       |
| TABLE_NAME        | varchar(128) | NO   |     |         |       |
| TABLE_OWNER       | varchar(128) | NO   |     |         |       |
| TIMESTAMP         | date         | NO   |     |         |       |
| TRUNCATED         | varchar(3)   | NO   |     |         |       |
| UPDATES           | bigint(20)   | NO   |     |         |       |
+-------------------+--------------+------+-----+---------+-------+

