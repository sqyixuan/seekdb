result_format: 4
##build new tenant.
##build tenant


use test;

drop table if exists t1, t_part, t_subpart;
create table t1 (c1 int, c2 int, c3 varchar(100));
create index idx1_t1 on t1(c2);

create table t_part (c1 int primary key, c2 int, c3 varchar(100)) partition by hash(c1) partitions 4;
create index idx1_part on t_part(c2) global;

create table t_subpart (c1 int, c2 int, c3 varchar(100)) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
  subpartition p0,
  subpartition p1,
  subpartition p2
)
partitions 4;
create index idx1_subpart on t_subpart(c2) local;

set ob_query_timeout = 100000000000;
set @num = 0;
insert /*+ parallel(2) enable_parallel_dml */ into t1 select @num := @num + 1, @num % 100, concat('ABCDJDLSJKJDFLSDJJLSDFJPW', @num) from table(generator(500000));
insert /*+ parallel(2) enable_parallel_dml */ into t_part select * from t1;
insert /*+ parallel(2) enable_parallel_dml */ into t_subpart select * from t1;

call dbms_stats.gather_table_stats(NULL, 'T1', method_opt=>'FOR ALL COLUMNS SIZE 256');
call dbms_stats.gather_table_stats(NULL, 't_part', method_opt=>'FOR ALL COLUMNS SIZE 256');
call dbms_stats.gather_table_stats(NULL, 't_subpart', method_opt=>'FOR ALL COLUMNS SIZE 256');

drop table if exists t1, t_part, t_subpart;

##drop tenant
