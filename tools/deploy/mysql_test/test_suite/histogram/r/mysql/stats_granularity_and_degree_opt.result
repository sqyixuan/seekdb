drop table if exists t1, t2, t3, t_part, t_subpart;
create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int);
create table t2(a int primary key, b int, c int, d int) partition by hash(a) partitions 2;
create table t3(a int, b int, c int, d int) partition by hash(a) partitions 2;
create table t_part (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int) partition by hash(c1) partitions 4;
create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
subpartition p0,
subpartition p1,
subpartition p2
)
partitions 3;
