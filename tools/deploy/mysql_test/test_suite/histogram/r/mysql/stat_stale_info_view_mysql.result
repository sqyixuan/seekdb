drop database if exists STALE_INFO;
create database stale_info;
use stale_info;
result_format: 4
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table t3 (c1 int, c2 int, c3 int) partition by hash(c1) subpartition by hash(c2) subpartitions 3 partitions 2;
create table tmp (c1 int, c2 int, c3 int);

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
use stale_info;

call dbms_stats.gather_table_stats('STALE_INFO', 'T1');
call dbms_stats.gather_table_stats('STALE_INFO', 'T2');
call dbms_stats.gather_table_stats('STALE_INFO', 'T3');
call dbms_stats.set_table_prefs('STALE_INFO', 'T1', 'STALE_PERCENT', '20');

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
use stale_info;

select table_name, partition_name, subpartition_name, last_analyzed_rows, inserts, stale_percent, is_stale
from oceanbase.dba_ob_table_stat_stale_info where database_name = 'STALE_INFO' order by 1,2,3;
+------------+----------------+-------------------+--------------------+---------+---------------+----------+
| table_name | partition_name | subpartition_name | last_analyzed_rows | inserts | stale_percent | is_stale |
+------------+----------------+-------------------+--------------------+---------+---------------+----------+
| t1         | NULL           | NULL              |               1000 |     150 |            20 | NO       |
| t2         | NULL           | NULL              |               1000 |     150 |            10 | YES      |
| t2         | p0             | NULL              |                500 |      75 |            10 | YES      |
| t2         | p1             | NULL              |                500 |      75 |            10 | YES      |
| t3         | NULL           | NULL              |               1000 |     150 |            10 | YES      |
| t3         | p0             | NULL              |                500 |      75 |            10 | YES      |
| t3         | p0             | p0sp0             |                166 |      25 |            10 | YES      |
| t3         | p0             | p0sp1             |                167 |      25 |            10 | YES      |
| t3         | p0             | p0sp2             |                167 |      25 |            10 | YES      |
| t3         | p1             | NULL              |                500 |      75 |            10 | YES      |
| t3         | p1             | p1sp0             |                167 |      25 |            10 | YES      |
| t3         | p1             | p1sp1             |                167 |      25 |            10 | YES      |
| t3         | p1             | p1sp2             |                166 |      25 |            10 | YES      |
| tmp        | NULL           | NULL              |               NULL |     150 |            10 | YES      |
+------------+----------------+-------------------+--------------------+---------+---------------+----------+

drop database STALE_INFO;
