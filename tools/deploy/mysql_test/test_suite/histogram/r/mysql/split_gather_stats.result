drop table if exists dsemp_split_gather;
use test;
alter system set_tp tp_name = ERRSIM_RANDOM_GATHER_STATS_OPTION, error_code = 4016, frequency = 1;
set ob_query_timeout=10000000;
CREATE TABLE dsemp_split_gather (
id int(11) DEFAULT NULL,
name varchar(20) DEFAULT NULL,
leaderid int(11) DEFAULT NULL
)
partition by hash(id)
(partition p0,
partition p1,
partition p2) WITH COLUMN GROUP(all columns, each column);
insert into dsemp_split_gather select random()%10010,"123",3 from table(generator(10010));
alter system major freeze;
call dbms_stats.gather_table_stats('test', 'dsemp_split_gather',method_opt=>'FOR ALL HIDDEN COLUMNS SIZE REPEAT');
select t.table_name, s.stale_stats,	s.spare2  from oceanbase.__all_table_stat s inner join  oceanbase.__all_table t on s.table_id = t.table_id 
where t.table_name  = 'dsemp_split_gather';
table_name	stale_stats	spare2
dsemp_split_gather	0	0
dsemp_split_gather	0	0
dsemp_split_gather	0	0
dsemp_split_gather	0	0
select owner, table_name, partition_name, subpartition_name, NUM_ROWS >0, LAST_ANALYZED>0 from oceanbase.dba_tab_statistics where owner = 'TEST' and table_name = 'dsemp_split_gather' order by 1,2,3,4;
owner	table_name	partition_name	subpartition_name	NUM_ROWS >0	LAST_ANALYZED>0
test	dsemp_split_gather	NULL	NULL	1	1
test	dsemp_split_gather	p0	NULL	1	1
test	dsemp_split_gather	p1	NULL	1	1
test	dsemp_split_gather	p2	NULL	1	1
alter system set_tp tp_name = ERRSIM_RANDOM_GATHER_STATS_OPTION, error_code = 0, frequency = 0;
set ob_query_timeout=default;
drop table dsemp_split_gather;
