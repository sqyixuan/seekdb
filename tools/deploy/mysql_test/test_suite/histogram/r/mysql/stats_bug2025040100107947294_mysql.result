drop table if exists t1;
create table t1 (
c1 int primary key,
c2 int
);
result_format: 4
call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', 0);
set @num = 0;
insert into t1 select @num := @num + 1, case when @num < 500 then @num else null end from table(generator(10));
call dbms_stats.gather_table_stats('TEST', 'T1');
select c1,c2 from t1 where c1 = 1;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
+----+------+

insert into t1 select @num := @num + 1, case when @num < 500 then @num else null end from table(generator(100000));
alter system minor freeze;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
select table_name, NUM_ROWS, stale_stats from oceanbase.DBA_TAB_STATISTICS where owner = 'TEST' and table_name = 'T1';
+------------+----------+-------------+
| table_name | NUM_ROWS | stale_stats |
+------------+----------+-------------+
| t1         |       10 | YES         |
+------------+----------+-------------+

select c1,c2 from t1 where c1 = 1;
+----+------+
| c1 | c2   |
+----+------+
|  1 |    1 |
+----+------+
+-------------+-----------------------------------+
| is_hit_plan | query_sql                         |
+-------------+-----------------------------------+
|           1 | select c1,c2 from t1 where c1 = 1 |
+-------------+-----------------------------------+
call dbms_stats.async_gather_stats_job_proc();
select table_name, NUM_ROWS, stale_stats from oceanbase.DBA_TAB_STATISTICS where owner = 'TEST' and table_name = 'T1';
+------------+----------+-------------+
| table_name | NUM_ROWS | stale_stats |
+------------+----------+-------------+
| t1         |   100010 | NO          |
+------------+----------+-------------+
call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', 5000000);

drop table t1;
