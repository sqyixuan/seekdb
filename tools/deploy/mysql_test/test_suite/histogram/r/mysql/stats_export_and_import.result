delete from T1_STAT;
delete from T_PART_STAT;
delete from T_SUBPART_STAT;

##import table stats
##data ready
call dbms_stats.export_table_stats('TEST', 'T1', NULL, 'T1_STAT', statown=>'TEST');
call dbms_stats.export_table_stats('TEST', 'T_PART', NULL, 'T_PART_STAT', statown=>'TEST');
call dbms_stats.export_table_stats('TEST', 'T_SUBPART', NULL, 'T_SUBPART_STAT', statown=>'TEST');

call dbms_stats.delete_table_stats('TEST', 'T1');
call dbms_stats.delete_table_stats('TEST', 'T_PART');
call dbms_stats.delete_table_stats('TEST', 'T_SUBPART');

##1.just import table stats
call dbms_stats.import_table_stats('TEST', 'T1', NULL, 'T1_STAT', statown=>'TEST', cascade=>false);
call dbms_stats.import_table_stats('TEST', 'T_PART', NULL, 'T_PART_STAT', statown=>'TEST', cascade=>false);
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P2', 'T_SUBPART_STAT', statown=>'TEST', cascade=>false);
call dbms_stats.import_table_stats('TEST', 'T_SUBPART', 'P0SP1', 'T_SUBPART_STAT', statown=>'TEST', cascade=>false);

