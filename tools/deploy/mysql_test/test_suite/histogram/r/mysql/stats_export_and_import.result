################################
## test create/drop stat table
################################
call dbms_stats.create_stat_table('TEST', 'TEST_STAT');
desc test.test_stat;
+----------+---------------+------+-----+---------+-------+
| Field    | Type          | Null | Key | Default | Extra |
+----------+---------------+------+-----+---------+-------+
| STATID   | varchar(128)  | YES  |     | NULL    |       |
| TYPE     | char(1)       | YES  |     | NULL    |       |
| VERSION  | decimal(10,0) | YES  |     | NULL    |       |
| FLAGS    | decimal(10,0) | YES  |     | NULL    |       |
| C1       | varchar(128)  | YES  |     | NULL    |       |
| C2       | varchar(128)  | YES  |     | NULL    |       |
| C3       | varchar(128)  | YES  |     | NULL    |       |
| C4       | varchar(128)  | YES  |     | NULL    |       |
| C5       | varchar(128)  | YES  |     | NULL    |       |
| C6       | varchar(128)  | YES  |     | NULL    |       |
| N1       | decimal(10,0) | YES  |     | NULL    |       |
| N2       | double        | YES  |     | NULL    |       |
| N3       | decimal(10,0) | YES  |     | NULL    |       |
| N4       | decimal(10,0) | YES  |     | NULL    |       |
| N5       | decimal(10,0) | YES  |     | NULL    |       |
| N6       | decimal(10,0) | YES  |     | NULL    |       |
| N7       | decimal(10,0) | YES  |     | NULL    |       |
| N8       | decimal(10,0) | YES  |     | NULL    |       |
| N9       | decimal(10,0) | YES  |     | NULL    |       |
| N10      | decimal(10,0) | YES  |     | NULL    |       |
| N11      | decimal(10,0) | YES  |     | NULL    |       |
| N12      | decimal(10,0) | YES  |     | NULL    |       |
| N13      | decimal(10,0) | YES  |     | NULL    |       |
| D1       | timestamp(6)  | YES  |     | NULL    |       |
| T1       | timestamp     | YES  |     | NULL    |       |
| R1       | text          | YES  |     | NULL    |       |
| R2       | text          | YES  |     | NULL    |       |
| R3       | text          | YES  |     | NULL    |       |
| CH1      | varchar(1000) | YES  |     | NULL    |       |
| CL1      | blob          | YES  |     | NULL    |       |
| BL1      | blob          | YES  |     | NULL    |       |
| OB_SPEC1 | decimal(10,0) | YES  |     | NULL    |       |
| OB_SPEC2 | decimal(10,0) | YES  |     | NULL    |       |
| OB_SPEC3 | varchar(4096) | YES  |     | NULL    |       |
+----------+---------------+------+-----+---------+-------+

call dbms_stats.drop_stat_table('TEST', 'TEST_STAT');

call dbms_stats.create_stat_table('TEST', 'TEST_STAT', 'tgroup');

call dbms_stats.drop_stat_table('TEST', 'TEST_STAT');

##invalid test
call dbms_stats.create_stat_table('TEST', 'TEST_STAT', 'TGROUP1');
ERROR 42P01: tablegroup not exist
call dbms_stats.drop_stat_table('TEST','T1');
ERROR HY000: Unable to drop table: does not appear to be a statistics table

################################
## test export/import stat
################################
##data ready
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T_PART', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');
call dbms_stats.gather_table_stats('TEST', 'T_SUBPART', method_opt=>'FOR ALL COLUMNS SIZE 10', granularity=>'ALL');

##create stat table
call dbms_stats.create_stat_table('TEST', 'T1_STAT');
call dbms_stats.create_stat_table('TEST', 'T_PART_STAT');
call dbms_stats.create_stat_table('TEST', 'T_SUBPART_STAT', 'tgroup');

##export table stats
call dbms_stats.export_table_stats('TEST', 'T1', NULL, 'T1_STAT', statown=>'TEST', cascade=>false);

call dbms_stats.export_table_stats('TEST', 'T_PART', NULL, 'T_PART_STAT', statown=>'TEST', cascade=>false);

call dbms_stats.export_table_stats('TEST', 'T_SUBPART', 'P0', 'T_SUBPART_STAT', statown=>'TEST', cascade=>false);

call dbms_stats.export_table_stats('TEST', 'T_SUBPART', 'P1SP1', 'T_SUBPART_STAT', statown=>'TEST', cascade=>false);

select statid, type, version, flags, c1, c2, c3, c5, n1, n3, ob_spec1, ob_spec2 from T1_STAT order by c5, c1, c2, c3, c4;
