create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by range(c2)
subpartition template
(
  subpartition p0 VALUES LESS THAN (30),
  subpartition p1 VALUES LESS THAN (60),
  subpartition p2 VALUES LESS THAN (MAXVALUE)
)
partitions 3;
create sequence s1 cache 600 noorder;
insert into t_subpart select s1.nextval, s1.nextval, s1.nextval from table(generator(600));
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
drop sequence s1;
call dbms_stats.gather_table_stats('TEST', 'T_SUBPART');
