insert into t2 values(1,repeat('a',200),'1'),(2,repeat('a',200),'2'),(3,repeat('a',200),'3'),(4,'d','4'),(5,'e','5'),(6,'f','6'),(7,'g','7'),(8,'h','8'),(9,'i','9'),(10,'j','10');
insert /*+GATHER_OPTIMIZER_STATISTICS*/ into t1 select * from t2;
call dbms_stats.gather_table_stats('test', 't1', 'P0', granularity=>'APPROX_GLOBAL AND PARTITION');
call dbms_stats.gather_table_stats('test', 't1', method_opt=>'for all columns size 16');
explain select * from t1 where c2 > 'f';
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |189         |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |188         |
|2 |  └─PX PARTITION ITERATOR|        |1       |184         |
|3 |    └─TABLE FULL SCAN    |t1      |1       |184         |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter([t1.c2 > 'f']), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
