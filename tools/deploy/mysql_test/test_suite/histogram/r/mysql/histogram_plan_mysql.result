result_format: 3
DROP DATABASE IF EXISTS HISTOGRAM_PLAN;
CREATE DATABASE HISTOGRAM_PLAN;
USE HISTOGRAM_PLAN;
# 场景1
# 表T1的数据分布如下：10行c2 = 1，20行c2 = 2，
# 40行c2 = 3，80行c2 = 4，160行c2 = 5，320行c2 = 6，
# 640行c2 = 7，1280行c2 = 8，一共2550行
create table T1 (c1 int key, c2 int, c3 int);
Frequency Histogram
analyze table t1 update histogram on c2 with 20 buckets;
select endpoint_num, endpoint_value from oceanbase.__all_histogram_stat where table_id = (
    select table_id from oceanbase.__all_table where table_name = 't1' and database_id =(
        select database_id from oceanbase.__all_database where database_name = 'HISTOGRAM_PLAN'));
+--------------+----------------+
| endpoint_num | endpoint_value |
+--------------+----------------+
|           10 | 1              |
|           30 | 2              |
|           70 | 3              |
|          150 | 4              |
|          310 | 5              |
|          630 | 6              |
|         1270 | 7              |
|         2550 | 8              |
+--------------+----------------+
explain select * from t1 where c2 = -10;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |105         |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter([t1.c2 = -10]), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1]), range(MIN ; MAX)always true
explain select * from t1 where c2 = 0;
