result_format: 4
drop table t1;
drop table t2;
create table t1(c1 int, c2 int, c3 int);
create index idx_t1 on t1(c1);

set autocommit=0;

##test analyze table
insert into t1 select mod(random(), 100), mod(random(), 100), mod(random(), 100) from table(generator(100));
analyze table t1;
rollback;
select count(*) from t1;
+----------+
| count(*) |
+----------+
|      100 |
+----------+
select NUM_ROWS from oceanbase.dba_tab_statistics where table_name='T1' and owner='TEST';
+----------+
| NUM_ROWS |
+----------+
|      100 |
+----------+

##test delete table stats
delete from t1;
call dbms_stats.delete_table_stats('test','t1');
rollback;
select count(*) from t1;
+----------+
| count(*) |
+----------+
|        0 |
+----------+

