DROP TABLE IF EXISTS `table_15`;
drop sequence s1;
CREATE TABLE `table_15` (   `id` int(11) NOT NULL,   `col_2` varchar(16) DEFAULT NULL,   `col_3` varchar(600) NOT NULL,   `col_4` float DEFAULT NULL,   `col_5` varchar(199) DEFAULT NULL,   `col_6` bigint(20) DEFAULT NULL,   `col_7` longtext DEFAULT NULL,   `col_8` longblob DEFAULT NULL,   PRIMARY KEY (`id`, `col_3`) );
create sequence s1 cache 1000000 noorder;
insert /*+ append parallel(20) enable_parallel_dml query_timeout(30000000)*/ into table_15 select s1.nextval, randstr(10, random()), randstr(1+zipf(200, 500, random()), random()), normal(0, 50, random()), randstr(1+zipf(1, 20, random()), random()), if(random(4) % 10 = 0, null, random(4)), repeat('r', 3323), repeat('l', 38904) from table(generator(10));
