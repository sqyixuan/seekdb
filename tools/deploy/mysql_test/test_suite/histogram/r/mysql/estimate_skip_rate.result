drop table if exists test;
drop table if exists test_hash;
drop table if exists test_hash_hash;
drop procedure if exists InsertTestData;
drop table if exists cost1;
drop table if exists cost2;
drop table if exists cost3;
drop table if exists cost1_range;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
alter system flush kvcache;
set _enable_storage_cardinality_estimation = OFF;
set optimizer_dynamic_sampling = 0;
result_format: 4
set ob_query_timeout = 1000000000;

create table test(
  c1 bigint DEFAULT NULL,
  c2 float DEFAULT NULL,
  c3 double DEFAULT NULL,
  c4 date DEFAULT NULL,
  c5 time DEFAULT NULL,
  c6 year DEFAULT NULL,
  c7 timestamp DEFAULT NULL,
  c8 char(20) DEFAULT NULL,
  c9 varchar(20) DEFAULT NULL,
  c10 text DEFAULT NULL
) with column group (each column);

call dbms_stats.SET_TABLE_PREFS('TEST','test', 'SKIP_RATE_SAMPLE_COUNT', '100000');
SELECT dbms_stats.get_prefs('SKIP_RATE_SAMPLE_COUNT', 'TEST', 'test') FROM dual;
+----------------------------------------------------------------+
| dbms_stats.get_prefs('SKIP_RATE_SAMPLE_COUNT', 'TEST', 'test') |
+----------------------------------------------------------------+
| 100000                                                          |
+----------------------------------------------------------------+


create procedure InsertTestData()
begin
  declare i int default 0;
  declare base_time time default '00:00:00';
  declare base_date date default '2024-01-01';
  declare base_ts timestamp default '2024-01-01 00:00:00';
  
  while i < 10000 do
    insert into test (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10)
    values (
      i + 1,
      round(rand(i) * 1000, 2),
      round(rand(i) * 1000000, 2),
      base_date + interval floor(rand(i) * 365) day,
      sec_to_time(time_to_sec(base_time) + floor(rand(i) * 86400)),
      year(base_date) + floor(rand(i) * 10),
      base_ts + interval floor(rand(i) * 31536000) second,
      char(
        65 + floor(rand(i) * 26),
        65 + floor(rand(i) * 26),
        65 + floor(rand(i) * 26)
      ),
      concat('test', lpad(i, 4, '0')),
      concat('Fixed text content ', i) 
    );
    set i = i + 1;
  end while;
end$$


call InsertTestData();

create table test_hash(c1 int, c2 int) partition by hash(c1) partitions 3 with column group (each column);
insert into test_hash select random(3)%100,random(100)%100 from table(generator(30000));

create table test_hash_hash(c1 int, c2 int) partition by hash(c1)  subpartition by hash(c2) subpartitions 2 partitions 3 with column group (all columns, each column);
insert into test_hash_hash select random(3)%100,random(100)%100 from table(generator(300000));

create table cost1(c1 int, c2 float) with column group (all columns, each column);
create index k1 on cost1(c1);
set cte_max_recursion_depth =  1000000;
insert into cost1(c1, c2)
with recursive nums(n) as (
  select 1
  union all
  select n + 1 from nums where n < 1000000
)
select n, n from nums;

create table cost1_range (
    c1 int,
    c2 float
)
partition by range (c1) (
    partition p0 values less than (100001),
    partition p1 values less than (500001),
    partition p2 values less than maxvalue
) with column group (all columns, each column);
create index k1 on cost1_range(c1);
set cte_max_recursion_depth =  1000000;
insert into cost1_range(c1, c2)
with recursive nums(n) as (
  select 1
  union all
  select n + 1 from nums where n < 1000000
)
select n, n from nums;

create table cost2 (c1 int, c2 date) with column group (all columns, each column);
create index k1 on cost2(c1);
set cte_max_recursion_depth = 1000000;
insert into cost2 (c1, c2)
with recursive nums1 (n, start_date) as (
    select 1, '2023-01-01'
    union all
    select n + 1, date_add(start_date, interval 1 day)
    from nums1
    where n < 1000000
)
select n, start_date from nums1;

create table cost3 (c1 int, c2 float) with column group (all columns, each column);
create index k1 on cost3(c1);
Insert /*+ append enable_parallel_dml parallel(8) */ into cost3 select random(100)%100, random(100)%100 from table(generator(1000000));

alter system major freeze;

