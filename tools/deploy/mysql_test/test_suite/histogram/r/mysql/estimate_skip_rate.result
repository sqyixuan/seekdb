--clean
call dbms_stats.SET_TABLE_PREFS('TEST','test', 'SKIP_RATE_SAMPLE_COUNT', '0');
drop table test;
drop table test_hash;
drop table test_hash_hash;
drop procedure InsertTestData;
drop table cost1;
drop table cost2;
drop table cost3;
drop table cost1_range;
set _enable_storage_cardinality_estimation = True;
set optimizer_dynamic_sampling = 1;
