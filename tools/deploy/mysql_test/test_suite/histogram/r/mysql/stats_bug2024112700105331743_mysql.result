drop table if exists t1;
drop table if exists TEST_STAT_1;
create table t1 (
c1 int primary key,
c2 int
);
set @num = 0;
insert into t1 select @num := @num + 1, case when @num < 500 then @num else null end from table(generator(100000));
call dbms_stats.gather_table_stats('TEST', 'T1', degree=>2, method_opt=>'FOR ALL COLUMNS SIZE 256');
query_sql
call dbms_stats.gather_table_stats('TEST', 'T1', degree=>2, method_opt=>'FOR ALL COLUMNS SIZE 256')
SELECT /*+ NO_REWRITE DBMS_STATS OPT_PARAM('ROWSETS_MAX_ROWS', 256) FULL(`T1`)  USE_PLAN_CACHE(NONE) USE_PX, PARALLEL(2)*/  COUNT(*),  MAX(`c1`),  MIN(`c1`),  COUNT(`c1`),  APPROX_COUNT_DISTINCT(`c1`),  (20 * COUNT(`c1`))/(case when COUNT(*) = 0 then 1 else COUNT(*) end),  APPROX_COUNT_DISTINCT_SYNOPSIS(`c1`),  MAX(`c2`),  MIN(`c2`),  COUNT(`c2`),  APPROX_COUNT_DISTINCT(`c2`),  (20 * COUNT(`c2`))/(case when COUNT(*) = 0 then 1 else COUNT(*) end),  APPROX_COUNT_DISTINCT_SYNOPSIS(`c2`),  1 FROM `TEST`.`T1`     
SELECT /*+ NO_REWRITE DBMS_STATS OPT_PARAM('ROWSETS_MAX_ROWS', 256) FULL(`T1`)  USE_PLAN_CACHE(NONE) USE_PX, PARALLEL(2)*/  HYBRID_HIST(`c1`, 256) FROM `TEST`.`T1`  SAMPLE (6.550000)   
SELECT /*+ NO_REWRITE DBMS_STATS OPT_PARAM('ROWSETS_MAX_ROWS', 256) FULL(`T1`)  USE_PLAN_CACHE(NONE) USE_PX, PARALLEL(2)*/  HYBRID_HIST(`c2`, 256) FROM `TEST`.`T1`     
call dbms_stats.create_stat_table('TEST', 'TEST_STAT_1');
call dbms_stats.export_schema_stats('TEST',stattab=>'TEST_STAT_1',statid=>'1');
call dbms_stats.import_schema_stats('TEST',stattab=>'TEST_STAT_1',statid=>'1');
drop table t1;
drop table TEST_STAT_1;
