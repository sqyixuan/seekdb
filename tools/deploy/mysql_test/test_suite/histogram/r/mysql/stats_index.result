##comprehensive test
call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T_PART');
call dbms_stats.gather_index_stats('TEST', 'idx2_part', tabname=>'T_PART');
call dbms_stats.gather_index_stats('TEST', 'idx3_part', tabname=>'T_PART');
drop table if exists t_stat;
call dbms_stats.create_stat_table('TEST', 'T_STAT');
call dbms_stats.export_table_stats('TEST', 'T1', stattab=>'T_STAT', statown=>'TEST');
call dbms_stats.export_table_stats('TEST', 'T_PART', stattab=>'T_STAT', statown=>'TEST');

