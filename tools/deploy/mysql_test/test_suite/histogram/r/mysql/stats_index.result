| NULL   | I    |       8 |  NULL | idx1_t1 | NULL | NULL | t1   | TEST |  100 |   20 |
+--------+------+---------+-------+---------+------+------+------+------+------+------+

call dbms_stats.export_index_stats('TEST', 'idx2_part', tabname=>'T_PART', stattab=>'t_stat', statown=>'TEST');
