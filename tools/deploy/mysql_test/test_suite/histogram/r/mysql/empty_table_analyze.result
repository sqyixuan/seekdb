result_format: 4
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;

drop table if exists test_global, test_part, test_subpart;
create table test_global (c1 int, c2 int, c3 int);

create table test_part (c1 int primary key, c2 int, c3 int) 
partition by range(c1) 
   (PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (50),
    PARTITION p3 VALUES LESS THAN (150),
   PARTITION p4 VALUES LESS THAN (300),
  PARTITION p5 VALUES LESS THAN (500));
create table test_subpart (
  a int, b int ,c int, d int
) 
partition by range(a) 
 subpartition by key(b,c) subpartitions 3 
   (PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (50),
    PARTITION p3 VALUES LESS THAN (150),
   PARTITION p4 VALUES LESS THAN (300),
  PARTITION p5 VALUES LESS THAN (500));

