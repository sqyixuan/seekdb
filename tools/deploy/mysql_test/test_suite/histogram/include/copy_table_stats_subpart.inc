call DBMS_STATS.delete_table_stats('TEST', 'TH');
call DBMS_STATS.gather_table_stats ('TEST', 'TH', 'P1', granularity=>'PARTITION', method_opt => 'FOR ALL COLUMNS SIZE 2');
call DBMS_STATS.gather_table_stats ('TEST', 'TH', 'P2', granularity=>'SUBPARTITION', method_opt => 'FOR ALL COLUMNS SIZE 2');
call DBMS_STATS.gather_table_stats ('TEST', 'TH', 'P3SS0', granularity=>'SUBPARTITION', method_opt => 'FOR ALL COLUMNS SIZE 2');

SELECT PARTITION_NAME,PARTITION_POSITION,SUBPARTITION_NAME,SUBPARTITION_POSITION,OBJECT_TYPE,NUM_ROWS,BLOCKS,
      EMPTY_BLOCKS,AVG_SPACE,CHAIN_CNT,AVG_ROW_LEN,AVG_SPACE_FREELIST_BLOCKS,NUM_FREELIST_BLOCKS,AVG_CACHED_BLOCKS,
      AVG_CACHE_HIT_RATIO,IM_IMCU_COUNT,IM_BLOCK_COUNT,IM_STAT_UPDATE_TIME,SCAN_RATE,SAMPLE_SIZE,
      GLOBAL_STATS,USER_STATS,STATTYPE_LOCKED,STALE_STATS,SCOPE
from ALL_TAB_STATISTICS WHERE owner = 'TEST' AND table_name = 'TH' ORDER BY PARTITION_NAME, SUBPARTITION_NAME;
SELECT PARTITION_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE,DENSITY,NUM_NULLS,NUM_BUCKETS,
       SAMPLE_SIZE,GLOBAL_STATS,USER_STATS,NOTES,AVG_COL_LEN,HISTOGRAM
from ALL_PART_COL_STATISTICS WHERE owner = 'TEST' AND table_name = 'TH' order by PARTITION_NAME,COLUMN_NAME;
SELECT * FROM ALL_PART_HISTOGRAMS WHERE owner = 'TEST' AND table_name = 'TH' order by PARTITION_NAME,COLUMN_NAME,ENDPOINT_NUMBER;

