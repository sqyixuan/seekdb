#普通索引
create table t1(
    c1 int primary key,
    c2 char(20) ,
    c3 varchar(20) ,
    c4 varchar(20) ,
    index index_no(c1)
  );
affected rows: 0
alter system flush plan cache global;
affected rows: 0
