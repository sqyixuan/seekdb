CREATE TABLE t1 (
    c1 INT,
    c2 INT
)
PARTITION BY RANGE COLUMNS(c1, c2) (
    PARTITION p1 VALUES LESS THAN (4, 4),
    PARTITION p2 VALUES LESS THAN (8, 8),
    PARTITION p3 VALUES LESS THAN (MAXVALUE, MAXVALUE)
);
