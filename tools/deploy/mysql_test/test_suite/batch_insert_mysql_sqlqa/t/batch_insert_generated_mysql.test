##owner: laibingzheng.lbz
##owner group: SQL2
##description: 生成列
##tags: batch insert
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;



--echo  #生成列
drop table if exists t1,t2;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (5 * c1) VIRTUAL);
CREATE TABLE t2(a1 int,a2 int GENERATED ALWAYS AS (10 * a1) VIRTUAL);
alter system flush plan cache global;
delimiter //;
insert into t1(c1) values(2);insert into t1(c1) values(4);insert into t1(c1) values(6);insert into t1(c1) values(8);insert into t1(c1) values(10);insert into t1(c1) values(14);//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1) %' order by hit_count;
rollback;

delimiter //;
insert into t2(a1) values(1);insert into t2(a1) values(3);insert into t2(a1) values(5);insert into t2(a1) values(7);insert into t2(a1) values(11);//
delimiter ;//
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2(a1) %' order by hit_count;
rollback;

insert into t1(c1) values(1),(2),(3),(4),(5);
commit;
insert into t2(a1) values(1),(2),(3),(4),(5);
commit;

alter system flush plan cache global;
delimiter //;
insert into t1(c1) select a1 from t1 inner join t2 on t1.c1 = t2.a1 where t2.a1 = 1;insert into t1(c1) select a1 from t1 inner join t2 on t1.c1 = t2.a1 where t2.a1 = 2;insert into t1(c1) select a1 from t1 inner join t2 on t1.c1 = t2.a1 where t2.a1 = 3;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1) select a1 from t1 inner join t2 on t1.c1 = t2.a1 where t2.a1 = %' order by hit_count;
rollback;


alter system flush plan cache global;
delimiter //;
insert into t1(c1) select a1 from t1 left join t2 on t1.c1 = t2.a1 where t2.a1 = 1;insert into t1(c1) select a1 from t1 left join t2 on t1.c1 = t2.a1 where t2.a1 = 2;insert into t1(c1) select a1 from t1 left join t2 on t1.c1 = t2.a1 where t2.a1 = 3;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1) select a1 from t1 left join t2 on t1.c1 = t2.a1 where t2.a1 = %' order by hit_count;
rollback;

drop table t1;
drop table t2;



--echo  #unique+生成列
CREATE TABLE t3(c1 int,c2 int GENERATED ALWAYS AS (7 * c1) VIRTUAL unique );
CREATE TABLE t4(a1 int,a2 int GENERATED ALWAYS AS (7 * a1) VIRTUAL unique);
alter system flush plan cache global;
delimiter //;
insert into t3(c1) values(1);insert into t3(c1) values(2);insert into t3(c1) values(5);insert into t3(c1) values(7);insert into t3(c1) values(10);insert into t3(c1) values(14);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1) %' order by hit_count;
rollback;

delimiter //;
insert into t4(a1) values(1);insert into t4(a1) values(3);insert into t4(a1) values(5);insert into t4(a1) values(7);insert into t4(a1) values(11);//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4(a1) %' order by hit_count;
rollback;
drop table t3;
drop table t4;



--echo  #not null + 生成列
create table t5(c1 double,c2 int generated always as (5 * c1) virtual not null);
create table t6(a1 float,a2 int generated always as (5 * a1) virtual not null);
alter system flush plan cache global;
delimiter //;
insert into t5(c1) values(2);insert into t5(c1) values(4.44);insert into t5(c1) values(6.66);insert into t5(c1) values(8.888);insert into t5(c1) values(10.1010);insert into t5(c1) values(14.111);//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5(c1) %' order by hit_count;
rollback;

delimiter //;
insert into t6(a1) values(1.01);insert into t6(a1) values(3.003);insert into t6(a1) values(5.05);insert into t6(a1) values(7.7);insert into t6(a1) values(11.11);//
delimiter ;//
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6(a1) %' order by hit_count;
rollback;

drop table t5;
drop table t6;



--echo  #外键+生成列
create table t7(c1 int,c2 int primary key );
create table t8(a1 int,a2 int generated always as (1 * a1) virtual,CONSTRAINT fk_c2 FOREIGN KEY(a2) REFERENCES t7(c2) );

alter system flush plan cache global;
delimiter //;
insert into t7 values(1,1);insert into t7 values(2,2);insert into t7 values(3,3);insert into t7 values(4,4);insert into t7 values(5,5);insert into t7 values(6,6);//
delimiter ;//
commit;
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t7 %' order by hit_count;


delimiter //;
insert into t8(a1) values(1);insert into t8(a1) values(2);insert into t8(a1) values(3);insert into t8(a1) values(4);insert into t8(a1) values(5);//
delimiter ;//
commit;
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t8(a1) %' order by hit_count;


drop table t8;
drop table t7;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
