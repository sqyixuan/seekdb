##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch insert在复制表中测试
##tags: batch insert
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;



--echo  #insert into tt1 values(....)
--echo  #values值进行运算
create table t1(c1 int,c2 int);
create table tt1 as select * from t1;
delimiter //;
insert into tt1 values(1-2,2-4);insert into tt1 values(2-5,3-7);insert into tt1 values(10-5,1-7);//
insert into tt1 values(1*1,1*2);insert into tt1 values(2*2,2*3);insert into tt1 values(3*3,3*4);//
insert into tt1 values(10/1,11/1);insert into tt1 values(13/1,14/1);insert into tt1 values(15/1,16/1);//
insert into tt1 values(15%10,13%5);insert into tt1 values(31%8,35%9);insert into tt1 values(120%100,121%100);//
delimiter ;//
select * from tt1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt1 %' order by hit_count;
rollback;
drop table tt1;
drop table t1;

--echo #value值为字符串函数
create table t2(c1 varchar(60),c2 varchar(60));
create table tt2 as select * from t2;
delimiter //;
insert into tt2 values(concat('aaa','bbb'),concat('ccc','ddd'));insert into tt2 values(concat('eee','123'),concat('张三','ddd'));//
insert into tt2 values(substr('abcdefg', 3, 2),substr('abcdefg' from -4 for 2));insert into tt2 values(substr('abcdefg', 3, 2),substr('abcdefg' from -4 for 2));//
insert into tt2 values(LENGTH('中国'),LENGTH('hello'));insert into tt2 values(LENGTH('张'),LENGTH('world'));//
insert into tt2 values(UPPER('obclient您好！'),UPPER('AAAcccddd周末！'));insert into tt2 values(UPPER('asdaASD！'),UPPER('13asdg！'));//
insert into tt2 values(lower('AAAA张三@@'),lower('CCaaBB==上'));insert into tt2 values(lower('Abbb张三@@'),lower('yfhf'));//
delimiter ;//
select * from tt2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt2 %' order by hit_count;
rollback;


--echo  #插入format函数,查内部表plan_cache 命中0次,没有进行batch优化
alter system flush plan cache global;
delimiter //;
insert into tt2 values(FORMAT(12332.123456, 4),FORMAT(12332.2, 0));insert into tt2 values(FORMAT(456789.62456, 4),FORMAT(11653.2, 0));//
delimiter ;//
select * from tt2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt2 %' order by hit_count;
rollback;

drop table t2;
drop table tt2;


--echo  #value值为时间函数
create table t3(c1 datetime,c2 timestamp);
create table tt3 as select * from t3;
delimiter //;
insert into tt3 values(CONVERT_TZ('2021-10-18 15:01:49','+00:00','+10:00'),CONVERT_TZ('2021-10-18 15:01:49','+00:00','+10:00'));insert into tt3 values(CONVERT_TZ('2022-10-18 15:01:49','+00:00','+10:00'),CONVERT_TZ('2023-10-18 15:01:49','+00:00','+10:00'));//
insert into tt3 values(curdate(),curdate());insert into tt3 values(curdate(),curdate());//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt3 %' order by hit_count;
rollback;
drop table tt3;
drop table t3;


--echo  #value值为数学函数
create table t4(c1 double,c2 float);
create table tt4 as select * from t4;
delimiter //;
insert into tt4 values(ACOS(-0.5),ACOS(0.5));insert into tt4 values(ACOS(-0.5),ACOS(0.5));//
insert into tt4 values(ATAN(-10),ATAN(10));insert into tt4 values(ATAN(-10),ATAN(10));//
insert into tt4 values(COT(-10),COT(10));insert into tt4 values(COT(-10),COT(10));//
insert into tt4 values(RADIANS(10),RADIANS(-0.5));insert into tt4 values(RADIANS(10),RADIANS(-0.5));//
insert into tt4 values(ceil(1=1),ceil(1>1));insert into tt4 values(ceil(1=1),ceil(1>1));//
delimiter ;//
select * from tt4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt4 %' order by hit_count;
rollback;

--echo  #插入radians函数，没有进行batch优化
alter system flush plan cache global;
delimiter //;
insert into tt4 values(round(2.15,2),round(-15.153,1));insert into tt4 values(round(31.452,2),round(11.111,1));//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into tt4 %' order by hit_count;
select * from tt4;
rollback;
drop table tt4;
drop table t4;


