##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch insert在普通表中测试
##tags: batch insert
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo  #insert into select ....(子查询)
drop table if exists t1,t2,t3,t4;
create table t1(c1 int not null primary key ,c2 varchar(20) not null);
insert into t1 values(0,'牛二'),(1,'张三'),(2,'李四'),(3,'王五'),(4,'马六'),(5,'田七'),(7,'腊八');
commit;
create table t2(a1 int not null,a2 varchar(20));
insert into t2 values(1,'abc'),(2,'def'),(3,'ghi'),(4,'jkl'),(5,null),(6,'mno');
commit;
create table t3(b1 int,b2 varchar(20));
create table t4(d1 int,d2 varchar(20),d3 int,d4 varchar(20));


--echo  #insert + select + order by
delimiter //;
insert into t3 select * from t1 where c1 = 1 order by c2;insert into t3 select * from t1 where c1 = 2 order by c2;insert into t3 select * from t1 where c1 = 3 order by c2;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 select * from t1 where c1 = % order by c2' order by hit_count;
rollback;


--echo  #insert + select + limit
delimiter //;
insert into t3 select * from t1 where c1 = 1 limit 1;insert into t3 select * from t1 where c1 = 2 limit 1;insert into t3 select * from t1 where c1 = 3 limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 select * from t1 where c1 = % order by c2' order by hit_count;
rollback;



--echo  #in关键字  (plan cache命中两次,没有进行batch优化)
alter system flush plan cache global;
delimiter //;
insert into t3 select c1,c2 from t1 where c1 in (select a1 from t2 where a1 = 1);insert into t3 select c1,c2 from t1 where c1 in (select a1 from t2 where a1 = 2);insert into t3 select c1,c2 from t1 where c1 in (select a1 from t2 where a1 = 3);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 in %' order by hit_count;
rollback;


--echo #not in关键字 (plan cache命中一次,没有进行batch优化)
delimiter //;
insert into t3 select c1,c2 from t1 where c1 not in (select a1 from t2 where a1 = 1 order by a2);insert into t3 select c1,c2 from t1 where c1 not in (select a1 from t2 where a1 = 2 order by a2);insert into t3 select c1,c2 from t1 where c1 in (select a1 from t2 where a1 = 3 order by a2);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 not in %' order by hit_count;
rollback;




--echo  #any关键字 (plan cache命中两次,没有进行batch优化)
delimiter //;
insert into t3 select c1,c2 from t1 where c1 = any (select a1 from t2 where a1 = 1);insert into t3 select c1,c2 from t1 where c1 = any (select a1 from t2 where a1 = 2);insert into t3 select c1,c2 from t1 where c1 = any (select a1 from t2 where a1 = 3);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 = any %' order by hit_count;
rollback;



--echo  #all (plan cache命中两次,没有进行batch优化)
delimiter //;
insert into t3 select c1,c2 from t1 where c1 = all (select a1 from t2 where a1 = 1) order by c2;insert into t3 select c1,c2 from t1 where c1 = all (select a1 from t2 where a1 = 2) order by c2;insert into t3 select c1,c2 from t1 where c1 = all (select a1 from t2 where a1 = 3) order by c2;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 = all %' order by hit_count;
rollback;


--echo  #some  (命中1次，没有进行batch优化)
delimiter //;
insert into t3 select c1,c2 from t1 where c1 = some (select min(a1) from t2);insert into t3 select c1,c2 from t1 where c1 = some(select max(a1)from t2);insert into t3 select c1,c2 from t1 where c1 = some (select min(a1) from t2);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 = some %' order by hit_count;
rollback;


--echo  #exists (命中0次，没有进行batch优化)
delimiter //;
insert into t3 select c1,c2 from t1 where exists (select max(a1) from t2) limit 1;insert into t3 select c1,c2 from t1 where exists (select min(a1) from t2) limit 1;insert into t3 select c1,c2 from t1 where exists (select avg(a1) from t2) limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where exists %' order by hit_count;
rollback;


--echo  #not exists
delimiter //;
insert into t3 select c1,c2 from t1 where not exists (select max(a1) from t2) limit 1;insert into t3 select c1,c2 from t1 where not exists (select min(a1) from t2) limit 1;insert into t3 select c1,c2 from t1 where not exists (select avg(a1) from t2) limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where not exists %' order by hit_count;
rollback;


--echo  #like   (命中两次,没有进行batch 优化)
delimiter //;
insert into t3 select * from t1 where c1 like (select a1 from t2 where a1 = 3);insert into t3 select * from t1 where c1 like (select a1 from t2 where a1 = 4);insert into t3 select * from t1 where c1 like (select a1 from t2 where a1 = 5);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 like %' order by hit_count;
rollback;


--echo  #运算符
--echo  # "=" (命中3次,没有进行batch优化)
alter system flush plan cache global;
delimiter //;
insert into t3 select 3*3*3+6,c2 from t1 where c1 = (select a1 from t2 where a1 = 1);insert into t3 select 2*2*2+4,c2 from t1 where c1 = (select a1 from t2 where a1 = 2);//
insert into t3 select 4*4*4+8,c2 from t1 where c1 = (select a1 from t2 where a1 = 3);insert into t3 select 5*5*5+10,c2 from t1 where c1 = (select a1 from t2 where a1 = 4);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 = %' order by hit_count;
rollback;



--echo  # ">" (命中0次，没有进行batch优化)
delimiter //;
insert into t3 select * from t1 where c1 > (select a1 from t2 where a1 = 3);insert into t3 select * from t1 where c1 > (select a1 from t2 where a1 = 4);//
insert into t3 select * from t1 where c1 > (select a1 from t2 where a1 = 5);insert into t3 select * from t1 where c1 > (select a1 from t2 where a1 = 6);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 > %' order by hit_count;
rollback;


--echo  #">=" (命中3次，没有进行batch优化)
delimiter //;
insert into t3 select 10+10,c2 from t1 where c1 >= (select a1 from t2 where a1 = 3);insert into t3 select 30+30,c2 from t1 where c1 >= (select a1 from t2 where a1 = 4);//
insert into t3 select 20+20,c2 from t1 where c1 >= (select a1 from t2 where a1 = 5);insert into t3 select 40+40,c2 from t1 where c1 >= (select a1 from t2 where a1 = 6);//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 >= %' order by hit_count;
rollback;


--echo  #"<" (命中0次,没有进行batch优化)
delimiter //;
insert into t3 select 8/8,c2  from t1 where c1 < (select a1 from t2 where a1 = 3)limit 1;insert into t3 select 8/4,c2  from t1 where c1 < (select a1 from t2 where a1 = 4)limit 1;//
insert into t3 select 9/3,c2  from t1 where c1 < (select a1 from t2 where a1 = 5)limit 1;insert into t3 select 8/2,c2  from t1 where c1 < (select a1 from t2 where a1 = 6)limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 < %' order by hit_count;
rollback;


--echo  #"<="(命中三次，没有进行batch优化)
delimiter //;
insert into t3 select 8*8,c2 from t1 where c1 <= (select a1 from t2 where a1 = 3)limit 1;insert into t3 select 9*9,c2 from t1 where c1 <= (select a1 from t2 where a1 = 4)limit 1;//
insert into t3 select 7*7,c2 from t1 where c1 <= (select a1 from t2 where a1 = 5)limit 1;insert into t3 select 6*6,c2 from t1 where c1 <= (select a1 from t2 where a1 = 6)limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 <= %' order by hit_count;
rollback;


--echo  #"!="(命中3次，没有进行batch优化)
delimiter //;
insert into t3 select 1+1,c2 from t1 where c1 != (select a1 from t2 where a1 = 2)limit 1;insert into t3 select 3+4,c2 from t1 where c1 != (select a1 from t2 where a1 = 4)limit 1;//
insert into t3 select 2+2,c2 from t1 where c1 != (select a1 from t2 where a1 = 3)limit 1;insert into t3 select 5+8,c2 from t1 where c1 != (select a1 from t2 where a1 = 6)limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 != %' order by hit_count;
rollback;


--echo  #"<>"(命中3次，没有进行batch优化)
delimiter //;
insert into t3 select 1+1,c2 from t1 where c1 <> (select a1 from t2 where a1 = 2)limit 1;insert into t3 select 3+4,c2 from t1 where c1 <> (select a1 from t2 where a1 = 4)limit 1;//
insert into t3 select 2+2,c2 from t1 where c1 <> (select a1 from t2 where a1 = 3)limit 1;insert into t3 select 5+8,c2 from t1 where c1 <> (select a1 from t2 where a1 = 6)limit 1;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 % where c1 <> %' order by hit_count;
rollback;



--echo  #insert into select join.....
--echo  #insert into 无条件连接 (命中一次，进行batch优化)
alter system flush plan cache global;
delimiter //;
insert into t4 select * from t1,t2 where t1.c1 = 1 limit 1;insert into t4 select * from t1,t2 where t1.c1 = 2 limit 1;//
insert into t4 select * from t1,t2 where t1.c1 = 3 limit 1;insert into t4 select * from t1,t2 where t1.c1 = 4 limit 1;//
delimiter ;//
select * from t4;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 % where t1.c1 = %';
delete from t4;
commit;


--echo  #insert into select ... cross join ...(命中一次，进行batch优化)
delimiter //;
insert into t4 select 1+1,t1.c2,2+2,t2.a2 from t1 cross join t2 where t1.c1 =1 limit 1;insert into t4 select 3+3,t1.c2,4+4,t2.a2 from t1 cross join t2 where t1.c1 =2 limit 1;//
insert into t4 select 5+5,t1.c2,6+6,t2.a2 from t1 cross join t2 where t1.c1 =3 limit 1;insert into t4 select 7+7,t1.c2,8+8,t2.a2 from t1 cross join t2 where t1.c1 =4 limit 1;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 % cross join %';
delete from t4;
commit;

--echo  #insert into select ... natural join ...
alter system flush plan cache global;
delimiter //;
insert into t4 select 2-1,t1.c2,3-1,t2.a2 from t1 natural join t2 where t1.c1 =1 limit 1;insert into t4 select 4-1,t1.c2,5-1,t2.a2 from t1 natural join t2 where t1.c1 =2 limit 1;//
insert into t4 select 6-1,t1.c2,8-1,t2.a2 from t1 natural join t2 where t1.c1 =3 limit 1;insert into t4 select 10-1,t1.c2,11-1,t2.a2 from t1 natural join t2 where t1.c1 =4 limit 1;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 select %,t1.c2,%,t2.a2 from t1 natural join t2 where t1.c1 =% limit 1' order by hit_count;
delete from t4;
commit;


--echo  #自然连接
--echo  #insert into select ...where t1.c1 = t2.a1 ....
alter system flush plan cache global;
delimiter //;
insert into t4 select 1/1,t1.c2,2/1,t2.a2 from t1,t2 where t1.c1 = t2.a1 and t1.c1 = 1;insert into t4 select 3/1,t1.c2,4/1,t2.a2 from t1,t2 where t1.c1 = t2.a1 and t1.c1 = 2;//
insert into t4 select 5/1,t1.c2,6/1,t2.a2 from t1,t2 where t1.c1 = t2.a1 and t1.c1 = 3;insert into t4 select 7/1,t1.c2,8/1,t2.a2 from t1,t2 where t1.c1 = t2.a1 and t1.c1 = 4;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 select %,t1.c2,%,t2.a2 from t1,t2 where t1.c1 = t2.a1 and t1.c1 = %' order by hit_count;
delete from t4;
commit;


--echo  #内连接
--echo  #insert into select ... inner join ... (命中一次，执行batch优化)
delimiter //;
insert into t4 select asin(t1.c1),t1.c2,asin(t2.a1),t2.a2 from t1 inner join t2 on t1.c1 =t2.a1 where t2.a1 = 1;insert into t4 select asin(t1.c1),t1.c2,asin(t2.a1),t2.a2 from t1 inner join t2 on t1.c1 =t2.a1 where t2.a1 = 2;//
insert into t4 select asin(t1.c1),t1.c2,asin(t2.a1),t2.a2 from t1 inner join t2 on t1.c1 =t2.a1 where t2.a1 = 3;insert into t4 select asin(t1.c1),t1.c2,asin(t2.a1),t2.a2 from t1 inner join t2 on t1.c1 =t2.a1 where t2.a1 = 4;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 % inner join %' order by hit_count;
delete from t4;
commit;


--echo  #外连接
--echo  #insert into select ... left join ...
delimiter //;
insert into t4 select cast(t1.c1 as unsigned)-2.0,t1.c2,cast(t2.a1 as unsigned)-2.0,t2.a2 from t1 left join t2 on t1.c1 =t2.a1 where t2.a1 = 1;insert into t4 select cast(t1.c1 as unsigned)-2.0,t1.c2,cast(t2.a1 as unsigned)-2.0,t2.a2 from t1 left join t2 on t1.c1 =t2.a1 where t2.a1 = 2;//
insert into t4 select cast(t1.c1 as unsigned)-2.0,t1.c2,cast(t2.a1 as unsigned)-2.0,t2.a2 from t1 left join t2 on t1.c1 =t2.a1 where t2.a1 = 3;insert into t4 select cast(t1.c1 as unsigned)-2.0,t1.c2,cast(t2.a1 as unsigned)-2.0,t2.a2 from t1 left join t2 on t1.c1 =t2.a1 where t2.a1 = 4;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 % left join %' order by hit_count;
delete from t4;
commit;


--echo  #insert into select ... right join ... (命中3次，没有执行batch优化)
delimiter //;
insert into t4 select * from t1 right join t2 on t1.c1 =t2.a1 where t2.a1 = 1;insert into t4 select * from t1 right join t2 on t1.c1 =t2.a1 where t2.a1 = 2;//
insert into t4 select * from t1 right join t2 on t1.c1 =t2.a1 where t2.a1 = 3;insert into t4 select * from t1 right join t2 on t1.c1 =t2.a1 where t2.a1 = 4;//
delimiter ;//
commit;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 % right join %' order by hit_count;
delete from t4;
commit;
drop table t1,t2,t3,t4;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

