##owner: laibingzheng.lbz
##owner group: SQL2
##description: 索引
##tags: batch insert
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo  #普通索引
create table t1(
    c1 int primary key,
    c2 char(20) ,
    c3 varchar(20) ,
    c4 varchar(20) ,
    index index_no(c1)
  );
alter system flush plan cache global;
delimiter //;
insert into t1 values(1,'A','B','C');insert into t1 values(2,'张Z','王W','田T');insert into t1 values(3,'A1','B2','C3');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 %' order by hit_count;
select * from t1;
rollback;

--echo  #insert into set....
delimiter //;
insert into t1 set c1 = 1,c2 = '@#$@aasd',c3 = '(){}【】王',c4 = 'GSD';insert into t1 set c1 = 2,c2 = '下雨111',c3 = 'RRRR111',c4 = '123';insert into t1 set c1 = 3,c2 = 'AAa',c3 = 'BBb',c4 = 'CCc';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 set %' order by hit_count;
select * from t1;
rollback;


--echo  #单列或多列插入
delimiter //;
insert into t1(c1) values(1);insert into t1(c1) values(2);insert into t1(c1) values(3);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1) %' order by hit_count;
select * from t1;
rollback;


--echo  #多列插入
delimiter //;
insert into t1(c1,c2,c3) values(1,'A','B');insert into t1(c1,c2,c3) values(2,'张Z','王W');insert into t1(c1,c2,c3) values(3,'A1','B2');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1,c2,c3) %' order by hit_count;
select * from t1;
rollback;

drop table t1;


--echo  #唯一索引
create table t2(
       c1 int  primary key ,
       c2 varchar(20),
       c3 char(20),
       c4 binary(20),
       unique index index_c1(c1)
     );

alter system flush plan cache global;
delimiter //;
insert into t2 values(1,'A','B','C');insert into t2 values(2,'张Z','王W','田T');insert into t2 values(3,'A1','B2','C3');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 %' order by hit_count;
select * from t2;
rollback;


--echo  #异常插入
alter system flush plan cache global;
delimiter //;
--error 1062
insert into t2 values(1,'A','B','C');insert into t2 values(1,'张Z','王W','田T');insert into t2 values(3,'A1','B2','C3');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 %' order by hit_count;
select * from t2;
rollback;




--echo  #insert into set....
delimiter //;
insert into t2 set c1 = 1,c2 = '@#$@aasd',c3 = '(){}【】王',c4 = 'GSD';insert into t2 set c1 = 2,c2 = '下雨111',c3 = 'RRRR111',c4 = '123';insert into t2 set c1 = 3,c2 = 'AAa',c3 = 'BBb',c4 = 'CCc';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 set %' order by hit_count;
select * from t2;
rollback;


--echo  #单列或多列插入
delimiter //;
insert into t2(c1) values(1);insert into t2(c1) values(2);insert into t2(c1) values(3);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2(c1) %' order by hit_count;
select * from t2;
rollback;


--echo  #多列插入
delimiter //;
insert into t2(c1,c2,c3) values(1,'A','B');insert into t2(c1,c2,c3) values(2,'张Z','王W');insert into t2(c1,c2,c3) values(3,'A1','B2');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2(c1,c2,c3) %' order by hit_count;
select * from t2;
rollback;



--echo  #多列索引
create table t3(
       c1 int  primary key,
       c2 char(20) ,
       c3 varbinary(20),
       c4 binary(20),
       key index_c1_c2(c1,c2)
     );


alter system flush plan cache global;
delimiter //;
insert into t3 values(1,'A','B','C');insert into t3 values(2,'张Z','王W','田T');insert into t3 values(3,'A1','B2','C3');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 %' order by hit_count;
select * from t3;
rollback;

--echo  #insert into set....
delimiter //;
insert into t3 set c1 = 1,c2 = '@#$@aasd',c3 = '(){}【】王',c4 = 'GSD';insert into t3 set c1 = 2,c2 = '下雨111',c3 = 'RRRR111',c4 = '123';insert into t3 set c1 = 3,c2 = 'AAa',c3 = 'BBb',c4 = 'CCc';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 set %' order by hit_count;
select * from t3;
rollback;


--echo  #单列或多列插入
delimiter //;
insert into t3(c1) values(1);insert into t3(c1) values(2);insert into t3(c1) values(3);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3(c1) %' order by hit_count;
select * from t3;
rollback;


--echo  #多列插入
delimiter //;
insert into t3(c1,c2,c3) values(1,'A','B');insert into t3(c1,c2,c3) values(2,'张Z','王W');insert into t3(c1,c2,c3) values(3,'A1','B2');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3(c1,c2,c3) %' order by hit_count;
select * from t3;
rollback;
drop table t3;



alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
