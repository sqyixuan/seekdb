##owner: laibingzheng.lbz
##owner group: SQL2
##description: 不同约束
##tags: batch insert
##author : wb-zwc01059807


--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info
--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo	#不同约束。
drop table if exists t1 ;
create table t1(c1 int primary key,c2 varchar(30) not null,c3 year unique key,c4 datetime default '2020-02-02 12:12:12');

delimiter //;
insert into t1 values(1,'aa','2020','2020-10-10 10:10:10');insert into t1 values(2,'bb','2019','2019-09-09 09:09:09');insert into t1 values(3,'cc','2018','2018-08-08 08:08:08');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
rollback;


delimiter //;
insert into t1(c1,c2) values(5,'ASDC');insert into t1(c1,c2) values(6,'QWER');insert into t1(c1,c2) values(7,'ZXCV');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1,c2) values%' order by hit_count;
rollback;


delimiter //;
insert into t1(c1,c2,c3,c4) values(10,'a','2000','2000-01-01 12:12:12');insert into t1(c1,c2,c3,c4) values(11,'b','2001','2001-01-01 12:12:12');insert into t1(c1,c2,c3,c4) values(12,'d','2003','2003-01-01 12:12:12');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1(c1,c2,c3,c4) values%' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
##预期报错，违反主键约束
--error 1062
insert into t1 values(1,'a','1999','1999-09-09');insert into t1 values(1,'a','2000','1999-09-09');insert into t1 values(3,'a','2001','1999-09-09');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
rollback;


alter system flush plan cache global;
delimiter //;
##预期报错，违反not null约束
--error 1048
insert into t1 values(1,'a','1999','1999-09-09');insert into t1 values(2,null,'2000','1999-09-09');insert into t1 values(3,'a','2001','1999-09-09');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
rollback;


alter system flush plan cache global;
delimiter //;
##预期报错，违反唯一约束。
--error 1062
insert into t1 values(1,'a','1999','1999-09-09');insert into t1 values(2,'b','2000','1999-09-09');insert into t1 values(3,'a','1999','1999-09-09');//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
rollback;

drop table t1;


--echo  #foreign key
drop table if exists t2;
CREATE TABLE t2(c1 int primary key ,c2 varchar(60));
insert into t2 values(1,'a'),(2,'b'),(3,'c'),(4,'d'),(5,'e'),(6,'f'),(7,'g'),(8,'h'),(9,'i');
commit;
drop table if exists t3;
create table t3(
        a1 int,
        a2 varchar(60),
        FOREIGN key (a1) REFERENCES t2(c1)
);

alter system flush plan cache global;
delimiter //;
insert into t3 values(2,'啊');insert into t3 values(4,'是');insert into t3 values(6,'了');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 %' order by hit_count;
select * from t3;
rollback;

alter system flush plan cache global;
delimiter //;
insert into t3 set a1 = 1*2,a2 = 'AAaa##';insert into t3 set a1 = 2*2,a2 = 'BBbb*&^&%%';insert into t3 set a1 = 3*3,a2 = 'LJNNsj/*-';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 set %' order by hit_count;
select * from t3;
rollback;

--echo  #预期报错，违反外键约束。
delimiter //;
--error 1452
insert into t3 values(2,'A');insert into t3 values(4,'B');insert into t3 values(10,'C');//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 values%' order by hit_count;

rollback;

drop table t3;
drop table t2;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


