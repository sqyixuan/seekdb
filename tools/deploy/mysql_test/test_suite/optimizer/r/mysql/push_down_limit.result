drop table if exists t1,t2,t3;
create table t1 (pk int primary key, c1 int, c2 int) partition by key(pk) partitions 10;
create table t2 (pk int primary key, c1 int, c2 int) partition by key(pk) partitions 10;
result_format: 4
explain SELECT /*+use_px, use_nl(table1 table2)*/ table1.pk, table2.pk FROM   t1 AS table1 LEFT OUTER JOIN t2 AS table2 USING ( pk ) WHERE  table1.pk < 20 ORDER  BY table1.pk, table1.c1 ASC, table1.c2, table1.pk, table2.pk LIMIT  2;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |LIMIT                            |        |2       |171         |
|1 |└─PX COORDINATOR MERGE SORT      |        |2       |170         |
|2 |  └─EXCHANGE OUT DISTR           |:EX10000|2       |170         |
|3 |    └─TOP-N SORT                 |        |2       |169         |
|4 |      └─PX PARTITION ITERATOR    |        |9       |167         |
|5 |        └─NESTED-LOOP OUTER JOIN |        |9       |167         |
|6 |          ├─TABLE RANGE SCAN     |table1  |9       |22          |
|7 |          └─TABLE GET            |table2  |1       |154         |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      limit(2), offset(nil)
  1 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      sort_keys([table1.pk, ASC])
  2 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      dop=1
  3 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      sort_keys([table1.pk, ASC]), topn(2), local merge sort
  4 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      partition wise, force partition granule
  5 - output([table1.pk], [table2.pk]), filter(nil), rowset=16
      conds(nil), nl_params_([table1.pk(:0)]), use_batch=true
  6 - output([table1.pk]), filter(nil), rowset=16
      access([table1.pk]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, 
      range_key([table1.pk]), range(NULL ; 20), 
      range_cond([table1.pk < 20])
  7 - output([table2.pk]), filter(nil), rowset=16
      access([GROUP_ID], [table2.pk]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, 
      range_key([table2.pk]), range(MIN ; MAX), 
      range_cond([:0 = table2.pk])
SELECT /*+use_px, use_nl(table1 table2)*/ table1.pk, table2.pk FROM   t1 AS table1 LEFT OUTER JOIN t2 AS table2 USING ( pk ) WHERE  table1.pk < 20 ORDER  BY table1.pk, table1.c1 ASC, table1.c2, table1.pk, table2.pk LIMIT  2;
+----+----+
| pk | pk |
+----+----+
|  1 |  1 |
|  2 |  2 |
+----+----+

create table t3(pk int primary key, c2 int) partition by hash(pk) partitions 2;
explain select /*+no_use_px*/ * from (select c2 from t3 order by pk  limit 5) order by c2 desc limit 2;
Query Plan
============================================================================
|ID|OPERATOR                         |NAME           |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------------
|0 |TOP-N SORT                       |               |2       |8           |
|1 |└─SUBPLAN SCAN                   |ANONYMOUS_VIEW1|5       |8           |
|2 |  └─LIMIT                        |               |5       |8           |
|3 |    └─PX COORDINATOR MERGE SORT  |               |5       |8           |
|4 |      └─EXCHANGE OUT DISTR       |:EX10000       |5       |7           |
|5 |        └─TOP-N SORT             |               |5       |6           |
|6 |          └─PX PARTITION ITERATOR|               |6       |5           |
|7 |            └─TABLE FULL SCAN    |t3             |6       |5           |
============================================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      sort_keys([ANONYMOUS_VIEW1.c2, DESC]), topn(2)
  1 - output([ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c2])
  2 - output([t3.c2]), filter(nil), rowset=16
      limit(5), offset(nil)
  3 - output([t3.c2]), filter(nil), rowset=16
      sort_keys([t3.pk, ASC])
  4 - output([t3.c2], [t3.pk]), filter(nil), rowset=16
      dop=1
  5 - output([t3.c2], [t3.pk]), filter(nil), rowset=16
      sort_keys([t3.pk, ASC]), topn(5), local merge sort
  6 - output([t3.pk], [t3.c2]), filter(nil), rowset=16
      force partition granule
  7 - output([t3.pk], [t3.c2]), filter(nil), rowset=16
      access([t3.pk], [t3.c2]), partitions(p[0-1])
      limit(5), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t3.pk]), range(MIN ; MAX)always true
select /*+no_use_px*/ * from (select c2 from t3 order by pk  limit 5) order by c2 desc limit 2;
+------+
| c2   |
+------+
|    5 |
|    4 |
+------+
drop table t1, t2,t3;
