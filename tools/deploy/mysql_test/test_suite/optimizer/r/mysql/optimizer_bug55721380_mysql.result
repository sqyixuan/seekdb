    SELECT t2.c1, t2.c2, t2.c3, t2.c4, t2.c5, t2.c6, t2.c7, t2.c8, t2.c9 FROM t2 ORDER BY 1, 2, 3, 4, 5, 6, 7, 8, 9 LIMIT 999
