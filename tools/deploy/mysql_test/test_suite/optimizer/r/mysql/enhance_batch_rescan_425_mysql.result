## enhance batch rescan 1. upper op is subplan filter/semi join/anti join
EXPLAIN BASIC select /*+no_rewrite*/ sum((select /*+leading(b) use_nl(c)*/ 1 from t1 b, t1 c where b.c2 = c.c1 and b.c1 = a.c3)) s_val
from t1 a;
