-------------------------------------
  0 - output([T_FUN_SUM(T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4))], [T_FUN_SUM(T_FUN_SUM(v.c1 + v.c2 + v.c3))]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_SUM(T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4))], [T_FUN_SUM(T_FUN_SUM(v.c1 + v.c2 + v.c3))])
  1 - output([T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4)], [T_FUN_SUM(v.c1 + v.c2 + v.c3)]), filter(nil), rowset=256
