      access([a.c1], [a.c2], [a.c3], [a.c4]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([a.c1]), range(MIN ; MAX)always true
  7 - output([b.c1], [b.c2], [b.c3], [b.c4]), filter(nil), rowset=256
      access([GROUP_ID], [b.c1], [b.c2], [b.c3], [b.c4]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([b.c1]), range(MIN ; MAX), 
      range_cond([:0 = b.c1])
