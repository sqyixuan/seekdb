result_format: 4
drop table if exists t1;
create table t1(c1 int primary key, c2 int ,c3 int, c4 int) partition by hash(c1) partitions 4;
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1, c1 from cte;

explain_protocol: 1
==================================================================================
====================== test new behaviors in 4_2_5 ===============================
==================================================================================
## basic test
EXPLAIN BASIC select /*+leading(a) use_nl(b)*/ sum(a.c1+a.c2+a.c3+a.c4), sum(b.c1+b.c2+b.c3+b.c4) from t1 a, t1 b where a.c2 = b.c1;
Query Plan
=============================================
|ID|OPERATOR                       |NAME    |
---------------------------------------------
|0 |SCALAR GROUP BY                |        |
|1 |└─PX COORDINATOR               |        |
|2 |  └─EXCHANGE OUT DISTR         |:EX10000|
|3 |    └─MERGE GROUP BY           |        |
|4 |      └─NESTED-LOOP JOIN       |        |
|5 |        ├─PX PARTITION ITERATOR|        |
|6 |        │ └─TABLE FULL SCAN    |a       |
|7 |        └─DISTRIBUTED TABLE GET|b       |
=============================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4))], [T_FUN_SUM(T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4))]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_SUM(T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4))], [T_FUN_SUM(T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4))])
  1 - output([T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4)], [T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4)]), filter(nil), rowset=256
  2 - output([T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4)], [T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4)]), filter(nil), rowset=256
      dop=1
  3 - output([T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4)], [T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_SUM(a.c1 + a.c2 + a.c3 + a.c4)], [T_FUN_SUM(b.c1 + b.c2 + b.c3 + b.c4)])
  4 - output([a.c2], [a.c1], [a.c3], [a.c4], [b.c1], [b.c2], [b.c3], [b.c4]), filter(nil), rowset=256
      conds(nil), nl_params_([a.c2(:0)]), use_batch=true
  5 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=256
      force partition granule
