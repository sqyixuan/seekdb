drop table if exists t1, t2, t3, t4;
create table t1 (c1 int primary key, c2 varchar(200) collate utf8mb4_general_ci, key i1(c2));
create table t2 (c1 int primary key, c2 varchar(200) collate utf16_general_ci, key i1(c2));
create table t3 (c1 int primary key, c2 varchar(200) collate utf16le_general_ci, key i1(c2));
create table t4 (c1 int primary key, c2 varchar(200) collate utf8mb4_bin, key i1(c2));
insert into t1 values (1, 'aaa'), (2, 'AAA'), (3, 'Aaa'), (4, 'bbb'), (5, 'BBB'), (6, 'Bbb'), (7, 'ccc'), (8, 'CCC'), (9, 'Ccc'), (10, '中文'), (11, 'b'), (12, 'B'), (13, 'a A');
insert into t2 values (1, 'aaa'), (2, 'AAA'), (3, 'Aaa'), (4, 'bbb'), (5, 'BBB'), (6, 'Bbb'), (7, 'ccc'), (8, 'CCC'), (9, 'Ccc'), (10, '中文'), (11, 'b'), (12, 'B'), (13, 'a A');
insert into t3 values (1, 'aaa'), (2, 'AAA'), (3, 'Aaa'), (4, 'bbb'), (5, 'BBB'), (6, 'Bbb'), (7, 'ccc'), (8, 'CCC'), (9, 'Ccc'), (10, '中文'), (11, 'b'), (12, 'B'), (13, 'a A');
insert into t4 values (1, 'aaa'), (2, 'AAA'), (3, 'Aaa'), (4, 'bbb'), (5, 'BBB'), (6, 'Bbb'), (7, 'ccc'), (8, 'CCC'), (9, 'Ccc'), (10, '中文'), (11, 'b'), (12, 'B'), (13, 'a A');
