drop table if exists t1,t2,tp,t_cnt;
drop function if exists f;
create table t1(a int, b int);
create table t2(c int, d int);
create table tp(x int, y int) partition by hash(x) partitions 4;
create index i2 on t2(c);
insert into t1 values (1,1),(2,2),(null,null);
insert into t2 values (1,1),(2,2),(null,null);
insert into tp values (1,1),(2,2),(null,null);
create table t_cnt(a int);
create function f() returns int not deterministic
begin
insert into t_cnt values(1);
return 0;
end
