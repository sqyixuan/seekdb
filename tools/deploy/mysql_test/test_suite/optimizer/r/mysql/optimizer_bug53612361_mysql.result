create index idx2 on table10_int_not_null(col_bigint_unique_index);
create index idx5 on table10_int_not_null(col_double_unique_index);

explain basic
select /*+ leading( t1 t2) use_merge(t2) */ 
t1.col_bigint_index 
from table10_int_not_null as t1, table10_int_not_null as t2 
where t2.col_decimal_20_0_index = t1.col_bigint_unique_index 
and t2.col_bigint > 1
and t1.col_double_unique_index >= 2;
Query Plan
==================================
|ID|OPERATOR            |NAME    |
----------------------------------
|0 |MERGE JOIN          |        |
|1 |├─SORT              |        |
|2 |│ └─TABLE RANGE SCAN|t1(idx5)|
|3 |└─SORT              |        |
|4 |  └─TABLE FULL SCAN |t2      |
==================================
Outputs & filters:
-------------------------------------
  0 - output([t1.col_bigint_index]), filter(nil), rowset=16
      equal_conds([t2.col_decimal_20_0_index = cast(t1.col_bigint_unique_index, DECIMAL_INT(20, 0))]), other_conds(nil)
      merge_directions([ASC])
  1 - output([t1.col_bigint_index], [cast(t1.col_bigint_unique_index, DECIMAL_INT(20, 0))]), filter(nil), rowset=16
      sort_keys([cast(t1.col_bigint_unique_index, DECIMAL_INT(20, 0)), ASC])
  2 - output([t1.col_bigint_index], [cast(t1.col_bigint_unique_index, DECIMAL_INT(20, 0))]), filter(nil), rowset=16
      access([t1.pk], [t1.col_bigint_unique_index], [t1.col_bigint_index]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.col_double_unique_index], [t1.pk]), range(2,MIN ; MAX,MAX), 
      range_cond([t1.col_double_unique_index >= cast(2, DOUBLE(-1, -1))])
  3 - output([t2.col_decimal_20_0_index]), filter(nil), rowset=16
      sort_keys([t2.col_decimal_20_0_index, ASC])
  4 - output([t2.col_decimal_20_0_index]), filter([t2.col_bigint > 1]), rowset=16
      access([t2.col_decimal_20_0_index], [t2.col_bigint]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.pk]), range(MIN ; MAX)always true

