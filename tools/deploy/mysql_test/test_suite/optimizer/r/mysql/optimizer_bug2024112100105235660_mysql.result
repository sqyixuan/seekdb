drop table if exists tmp;
result_format: 4
create table tmp(c1 varchar(100), index i1(c1(2)));
insert into tmp select lpad(abs(random()) % 10000, 4, '0') from table (generator(100000));
call dbms_stats.gather_table_stats('TEST', 'TMP');
select COLUMN_NAME,LOW_VALUE,HIGH_VALUE,NUM_DISTINCT,HISTOGRAM,DENSITY,NUM_NULLS,NUM_BUCKETS,SAMPLE_SIZE,GLOBAL_STATS,USER_STATS,AVG_COL_LEN from oceanbase.DBA_TAB_COL_STATISTICS where table_name = 'tmp';
+-------------+-----------+------------+--------------+-----------+---------+-----------+-------------+-------------+--------------+------------+-------------+
| COLUMN_NAME | LOW_VALUE | HIGH_VALUE | NUM_DISTINCT | HISTOGRAM | DENSITY | NUM_NULLS | NUM_BUCKETS | SAMPLE_SIZE | GLOBAL_STATS | USER_STATS | AVG_COL_LEN |
+-------------+-----------+------------+--------------+-----------+---------+-----------+-------------+-------------+--------------+------------+-------------+
| c1          | '0000'    | '9999'     |         9596 | NULL      |       0 |         0 |           0 |      100000 | NO           | NO         |          16 |
+-------------+-----------+------------+--------------+-----------+---------+-----------+-------------+-------------+--------------+------------+-------------+

drop table if exists tmp;
