create table agency(
parent_agency_line varchar(20),
agency_no bigint(32)
);
call dbms_stats.set_table_stats(NULL, 'agency', numrows=>19807);
call dbms_stats.set_column_stats(NULL, 'agency', 'parent_agency_line', distcnt=>10000, nullcnt=>0);
call dbms_stats.set_column_stats(NULL, 'agency', 'agency_no', distcnt=>19807, nullcnt=>0);
call dbms_stats.set_table_stats(NULL, 'trans', 'p20240701', numrows=>16750523);
call dbms_stats.set_column_stats(NULL, 'trans', 'order_no', 'p20240701', distcnt=>16359053, nullcnt=>0);
call dbms_stats.set_column_stats(NULL, 'trans', 'agency_no', 'p20240701', distcnt=>11024, nullcnt=>0);
call dbms_stats.set_column_stats(NULL, 'trans', 'type', 'p20240701', distcnt=>2, nullcnt=>0);
call dbms_stats.set_column_stats(NULL, 'trans', 'trans_time', 'p20240701', distcnt=>326013, nullcnt=>0, minval=>'2024-06-24 00:00:00', maxval=>'2024-06-27 20:46:16');
explain select /*+parallel(14) leading(a t) use_hash(t) opt_param('_ENABLE_STORAGE_CARDINALITY_ESTIMATION', 'false') */
sum(t.amount) AS amount,
count(t.amount) AS count
from
trans t
left join
agency a on t.agency_no = a.agency_no
where
t.type = 'TRANS'
and a.parent_agency_line like CONCAT('%', 30000006, '%')
and t.trans_time >= '2024-06-26 00:00:00'
and t.trans_time <= '2024-06-26 23:59:59';
