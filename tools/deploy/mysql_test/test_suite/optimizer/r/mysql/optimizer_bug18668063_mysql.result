explain SELECT DISTINCT o.id as id ,o.option_type_id as optionTypeId ,o.option_value as optionValue ,o.option_name as optionName ,o.order_num as orderNum ,o.member_id as memberId ,o.permission_entity_id as permissionEntityId ,o.parent_option_id as parentOptionId ,o.parent_option_value as parentOptionValue ,o.create_time as createTime FROM dmp_dynamic_tag_option o WHERE o.parent_option_value = '8598007' AND o.option_type_id = 901000022 limit 5;
