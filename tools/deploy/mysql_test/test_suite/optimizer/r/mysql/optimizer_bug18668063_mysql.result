drop table if exists t, t1, t2, dmp_dynamic_tag_option;
create table t1(pk int primary key, c1 int, c2 int);
create index t1_c2 on t1(c2) local;
create table t2(pk int primary key, c1 int, c2 int) partition by hash(pk) partitions 2;
create index t2_c2 on t2(c2) global;
create table t (c1 int, c2 int, c3 int, primary key (c1));
create index gidx on t (c2, c1) global partition by hash(c2) partitions 4;
CREATE TABLE dmp_dynamic_tag_option (
id int,
option_type_id int,
option_value varchar(200),
option_name varchar(400),
member_id int,
permission_entity_id int,
parent_option_id int,
parent_option_value varchar(200),
order_num int,
create_time timestamp,
PRIMARY KEY (id)
);
create index idx_query on dmp_dynamic_tag_option(option_type_id);
create index idx_optiontype_member on dmp_dynamic_tag_option(option_type_id, member_id);
create index idx_optiontype_parent_optionvalue on dmp_dynamic_tag_option(option_type_id, parent_option_value);
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't');
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
call dbms_stats.gather_table_stats('TEST', 'dmp_dynamic_tag_option');
