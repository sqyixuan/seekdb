EXPLAIN SELECT DISTINCT GRANDPARENT1 . col_varchar_20 AS G1
FROM l AS GRANDPARENT1
WHERE GRANDPARENT1 . `col_int` IN
    (SELECT DISTINCT PARENT1 . `pk` AS P1
     FROM gg AS PARENT1
     LEFT JOIN j AS PARENT2 USING (col_varchar_20)
     WHERE PARENT1 . `col_varchar_20` IN
         (SELECT CHILD1 . `col_varchar_10_key` AS C1
          FROM y AS CHILD1
          LEFT JOIN gg AS CHILD2 ON (CHILD1 . `col_int_key` <> CHILD2 . `col_int_key`)
          WHERE ((CHILD1 . `pk` >= GRANDPARENT1 . `col_int_key`)
                 OR ((CHILD1 . `pk` < GRANDPARENT1 . `col_int_key`)
                     AND ((PARENT1 . `col_varchar_10` >= PARENT1 . `col_varchar_20`)
                          OR NOT ((PARENT1 . `pk` = GRANDPARENT1 . `col_int`)
                                  AND (PARENT1 . `col_int` >= 1))))) )
       AND ((PARENT1 . `col_date` <= PARENT1 . `col_date`)
            OR ((PARENT1 . `col_int` <> GRANDPARENT1 . `pk`)
                AND (PARENT1 . `col_varchar_20_key` > 'o'))) )
  AND GRANDPARENT1 . `col_varchar_20_key` > 'q'
HAVING G1 <> '2006-08-15'
ORDER BY GRANDPARENT1 . col_varchar_20
LIMIT 4;
