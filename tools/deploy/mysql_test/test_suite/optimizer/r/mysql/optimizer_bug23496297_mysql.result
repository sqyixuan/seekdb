SELECT  GRANDPARENT1 . col_date AS G1 
FROM o AS GRANDPARENT1 
WHERE GRANDPARENT1 . `col_varchar_20_key` IN ( 
      SELECT DISTINCT PARENT1 . `col_varchar_20_key` AS P1 
      FROM ii AS PARENT1 LEFT JOIN oo AS PARENT2 USING ( col_date ) 
      WHERE GRANDPARENT1 . `col_varchar_20_key` IN ( 
            SELECT  CHILD1 . `col_varchar_20` AS C1 
            FROM ff AS CHILD1 
            WHERE ( ( CHILD1 . `col_int` < GRANDPARENT1 . `col_int_key` ) OR NOT ( ( CHILD1 . `col_int` > GRANDPARENT1 . `pk` ) OR ( PARENT1 . `col_varchar_10_key` = 'p' ) ) )  ) 
      AND ( GRANDPARENT1 . `pk` > 2 )  ) 
AND ( ( ( GRANDPARENT1 . `col_varchar_20_key` <= 'z' AND GRANDPARENT1 . `col_date` <> '2003-08-09' ) OR GRANDPARENT1 . `col_varchar_20` > 'j' ) OR GRANDPARENT1 . `col_varchar_10` <= 'b' ) 
GROUP BY GRANDPARENT1 . col_date 
HAVING G1 <> '2000-07-07 10:21:59' 
ORDER BY GRANDPARENT1 . col_date 
LIMIT 0;
