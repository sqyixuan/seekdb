drop table if exists bill_account_balance     ;
drop table if exists bill_balance_type        ;
create table bill_account_balance (
id int primary key,
acct_balance_id int,
acct_balance_name varchar(20),
balance_type_id int,
acct_id int,
service_id int,
status_id varchar(20),
index idx(acct_id),
index idx2(service_id, balance_type_id)
);
create table bill_balance_type (
id int primary key,
balance_type_id int,
balance_type_code varchar(20)
);
set @a = 0;
insert into bill_account_balance select @a := @a +1, @a, concat('name', @a), 1, @a, 285, 'ON' from table(generator(100000));
insert into bill_balance_type values (1, 1, 'def_1050');
insert into bill_account_balance values (1094139, 1094139, 'name1', 1, 1094139, 285, 'ON');
call dbms_stats.gather_table_stats('TEST', 'bill_account_balance');
result_format: 4
explain_protocol: 2
EXPLAIN select
  b.acct_balance_id,
  b.acct_balance_name
from
  bill_account_balance b
where
  b.balance_type_id = (
    select
      b1.balance_type_id
    from
      bill_balance_type b1
    where
      b1.balance_type_code = 'def_1050'
  )
  and b.acct_id = 1094139
  and b.service_id = 285;
