drop table if exists t;
drop table if exists t1;
create table t (c1 int, c2 int, index idx_t_c1 (c1) local, index idx_t_c2(c2) local) partition by hash(c1) partitions 4;
create table t1(c1 int, c2 int, index idx_t1_c1(c1) local, index idx_t1_c2(c2) local );
explain_protocol: 2
result_format: 4
EXPLAIN select sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t;
