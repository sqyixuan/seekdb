result_format: 4
explain_protocol: 2
EXPLAIN select
  /*+ NO_EXPAND */
  distinct `OUTR`.`col_int` AS `X`
from
  `test`.`c` `OUTR`
where
  (
    exists(
      (
        select
          1
        from
          `test`.`cc` `INNR2`,
          `test`.`cc` `INNR`
        where
          (
            `INNR`.`col_int` = `OUTR`.`col_int`
          )
          and (`INNR`.`col_int` = `OUTR`.`pk`)
          and (`OUTR`.`col_int` = `OUTR`.`pk`)
          and (
            `INNR2`.`pk` <> `INNR`.`col_int_key`
          )
        limit
          1
      )
    )
    or (`OUTR`.`col_varchar_10` <> 'i')
  );
