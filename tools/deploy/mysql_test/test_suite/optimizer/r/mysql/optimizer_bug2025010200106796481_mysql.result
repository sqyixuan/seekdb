set _enable_storage_cardinality_estimation=0;

## leading(ou wci usr_main scrm_main_joint_follow_3643 usr_info usr_slave  wcec tmp )
explain 
SELECT /*+parallel(1)*/COUNT(0)
       FROM scrm_user_main_3643 usr_main
               INNER JOIN  tmp
               ON tmp.main_id = usr_main.id
                       AND tmp.company_id = usr_main.company_id
               INNER JOIN scrm_user_slave_3643 usr_slave
               ON usr_slave.main_id = usr_main.id
                       AND usr_slave.company_id = usr_main.company_id
               INNER JOIN wechat_cp_external_contact_3643 wcec ON wcec.external_user_id = usr_slave.external_user_id
               INNER JOIN oauth_user_wechat_cp_info wci
               ON wci.company_we_chat = wcec.user_id
                       AND wcec.corp_id = wci.corp_id
                       AND wci.company_id = usr_main.company_id
               INNER JOIN oauth_user ou
               ON ou.id = wci.user_id
                       AND ou.company_id = usr_slave.company_id
               LEFT JOIN scrm_user_info_3643 usr_info
               ON usr_info.scrm_main_id = usr_main.id
                       AND usr_info.company_id = usr_main.company_id
               LEFT JOIN scrm_main_joint_follow_3643
               ON usr_main.id = scrm_main_joint_follow_3643.scrm_main_id
               AND scrm_main_joint_follow_3643.company_id = usr_main.company_id
               AND usr_main.company_id = 1;
