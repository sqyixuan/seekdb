result_format: 4
explain_protocol: 2
use opt_tpch;

EXPLAIN SELECT /*+   TPCH_EQ12 parallel(32) */ n_name,sum(l_tax) as sum
from nation,lineitem,orders,customer
where n_nationkey=c_nationkey and
c_custkey=o_custkey and
o_orderkey=l_orderkey
group by n_name having sum(l_tax) =(
select max(sum) from (
SELECT /*+   TPCH_EQ11 parallel(32) */ n_name,sum(l_tax) as sum
from nation,lineitem,orders,customer
where n_nationkey=c_nationkey and
c_custkey=o_custkey and
o_orderkey=l_orderkey
group by n_name
order by sum desc)
);
