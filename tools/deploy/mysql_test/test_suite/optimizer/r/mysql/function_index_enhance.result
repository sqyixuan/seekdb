result_format: 4
explain_protocol: 2
drop table if exists t1,t2,t3,t4,t5;
explain_protocol: 0
# match date()/timestamp() with implicit cast
create table t1(c1 date, c2 int, index i1((date(c1))), index i2((date(c2))));
create table t2(c1 date, c2 int, index i1((timestamp(c1))), index i2((timestamp(c2))));
create table t3(c1 date, c2 int, c3 date as (date(c1)), c4 date as (date(c2)), index i1(c3), index i2(c4));
create table t4(c1 date, c2 int, c3 datetime as (timestamp(c1)), c4 datetime as (timestamp(c2)), index i1(c3), index i2(c4));
create table t5(c1 date, c2 int, c3 datetime as (c1), c4 datetime as (c2), index i1(c3), index i2(c4), index i3(c1), index i4(c2));
insert into t1(c1,c2) values('2011-1-1',20110101);
insert into t2(c1,c2) values('2011-1-1',20110101);
insert into t3(c1,c2) values('2011-1-1',20110101);
insert into t4(c1,c2) values('2011-1-1',20110101);
