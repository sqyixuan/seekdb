explain_protocol: 0
drop table t1,t3;

# match prefix index for like conditions
create table t1(c1 varchar(20), index i1(c1(5)));
insert into t1 values ('abcdefg');
insert into t1 values ('abccccdefg');
insert into t1 values ('abccdefg');
insert into t1 values ('acccdefg');
insert into t1 values ('acccccdefg');
insert into t1 values ('ab%cdefg');
insert into t1 values ('ab%caaadefg');
select prefix_pattern('a_bc\%abc%aaa',3,'\\') from dual;
+----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',3,'\\') |
+----------------------------------------+
| a_b                                    |
+----------------------------------------+
select prefix_pattern('a_bc\%abc%aaa',5,'\\') from dual;
+----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',5,'\\') |
+----------------------------------------+
| a_bc\%                                 |
+----------------------------------------+
select prefix_pattern('a_bc\%abc%aaa',6,'\\') from dual;
+----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',6,'\\') |
+----------------------------------------+
| a_bc\%a                                |
+----------------------------------------+
select prefix_pattern('a_bc\%abc%aaa',8,'\\') from dual;
+----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',8,'\\') |
+----------------------------------------+
| a_bc\%abc                              |
+----------------------------------------+
select prefix_pattern('a_bc\%abc%aaa',9,'\\') from dual;
+----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',9,'\\') |
+----------------------------------------+
| a_bc\%abc%                             |
+----------------------------------------+
select prefix_pattern('a_bc\%abc%aaa',10,'\\') from dual;
+-----------------------------------------+
| prefix_pattern('a_bc\%abc%aaa',10,'\\') |
+-----------------------------------------+
| a_bc\%abc%                              |
+-----------------------------------------+
select prefix_pattern(NULL,10,'\\') from dual;
+------------------------------+
| prefix_pattern(NULL,10,'\\') |
+------------------------------+
|                         NULL |
+------------------------------+
select prefix_pattern('\\',10,'\\') from dual;
+------------------------------+
| prefix_pattern('\\',10,'\\') |
+------------------------------+
| \                            |
+------------------------------+
select prefix_pattern('bbba',3,'a') from dual;
+------------------------------+
| prefix_pattern('bbba',3,'a') |
+------------------------------+
| bbb                          |
+------------------------------+
select prefix_pattern('bbba',4,'a') from dual;
+------------------------------+
| prefix_pattern('bbba',4,'a') |
+------------------------------+
| bbba                         |
+------------------------------+
select prefix_pattern('bbbab',4,'a') from dual;
+-------------------------------+
| prefix_pattern('bbbab',4,'a') |
+-------------------------------+
| bbbab                         |
+-------------------------------+
select prefix_pattern('bbbabb',4,'a') from dual;
+--------------------------------+
| prefix_pattern('bbbabb',4,'a') |
+--------------------------------+
| bbbab                          |
+--------------------------------+
select prefix_pattern(x'616161',3, '\\') from dual;
+-----------------------------------+
| prefix_pattern(x'616161',3, '\\') |
+-----------------------------------+
| aaa                               |
+-----------------------------------+
##mysql returns null if the result of convert has invalid characters
select convert(x'E4B861' using utf8mb4);
+----------------------------------+
| convert(x'E4B861' using utf8mb4) |
+----------------------------------+
| NULL                             |
+----------------------------------+
select prefix_pattern(convert(x'E4B861' using utf8mb4), 3, '\\') from dual;
+-----------------------------------------------------------+
| prefix_pattern(convert(x'E4B861' using utf8mb4), 3, '\\') |
+-----------------------------------------------------------+
| NULL                                                      |
+-----------------------------------------------------------+
select prefix_pattern(convert(x'6161E4B861' using utf8mb4), 3, '\\') from dual;
+---------------------------------------------------------------+
| prefix_pattern(convert(x'6161E4B861' using utf8mb4), 3, '\\') |
+---------------------------------------------------------------+
| NULL                                                          |
+---------------------------------------------------------------+
select prefix_pattern(convert(x'616161E4B861' using utf8mb4), 3, '\\') from dual;
+-----------------------------------------------------------------+
| prefix_pattern(convert(x'616161E4B861' using utf8mb4), 3, '\\') |
+-----------------------------------------------------------------+
| NULL                                                            |
+-----------------------------------------------------------------+

