--------------------------------------------------
|0 |TABLE RANGE SCAN|t1(i1)|1       |7           |
==================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [column_conv(DECIMAL_INT,PS:(20,5),NULL,cast(t1.c1 + 1, DECIMAL_INT(20, 5)))]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c2]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.c2], [t1.__pk_increment]), range(NULL,MAX ; 1.00000,MIN), 
      range_cond([t1.c2 < cast(1, DECIMAL_INT(20, 5))])
select * from t1 where c1+1 < 1;
