drop table if exists t0, t1;
CREATE TABLE IF NOT EXISTS t0(c0 VARCHAR(500) )  PARTITION BY KEY (c0) partitions 14;
CREATE TABLE IF NOT EXISTS t1 LIKE t0;
UPDATE t1 SET c0="VGQt'<[liB+n";
CREATE UNIQUE INDEX i870 ON t1(c0(4)) global VISIBLE;
INSERT INTO t1(c0) VALUES('H');
CREATE INDEX i780 ON t0(c0(1)) global VISIBLE;
INSERT INTO t1(c0) VALUES('\\1g');
