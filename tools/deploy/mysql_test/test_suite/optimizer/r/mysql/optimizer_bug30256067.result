EXPLAIN SELECT /*+ TOPK (50 50)  */ ALL t0.c0 AS ref0 FROM t0 WHERE (t0.c0) <= ('RL|*8SiBhf/Pa') 
UNION ALL
SELECT /*+ TOPK (50 50)  */ t0.c0 AS ref0 FROM t0 WHERE (! ((t0.c0) <= ('RL|*8SiBhf/Pa')))
UNION ALL
SELECT /*+ TOPK (50 50)  */ ALL t0.c0 AS ref0 FROM t0 WHERE ((t0.c0) <= ('RL|*8SiBhf/Pa')) IS NULL;
