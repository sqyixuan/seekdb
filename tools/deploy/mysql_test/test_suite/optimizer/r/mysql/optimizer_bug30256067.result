EXPLAIN SELECT  /*+ NO_REWRITE leading(a b) use_nl(b)*/  A.col_bigint_key, B.col_bigint_key FROM table1_key_pk_parts_2 A
LEFT OUTER JOIN table30 B ON A.col_bigint_key = B.col_bigint_key
WHERE A.col_bigint_key = B.col_bigint_key;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |NESTED-LOOP OUTER JOIN     |        |1       |21          |
|1 |├─PX COORDINATOR           |        |1       |5           |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|1       |5           |
|3 |│   └─PX PARTITION ITERATOR|        |1       |5           |
|4 |│     └─TABLE FULL SCAN    |A(idx11)|1       |5           |
|5 |└─TABLE RANGE SCAN         |B(idx11)|1       |16          |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([A.col_bigint_key], [B.col_bigint_key]), filter([A.col_bigint_key = B.col_bigint_key]), rowset=16
      conds(nil), nl_params_([A.col_bigint_key(:0)]), use_batch=true
  1 - output([A.col_bigint_key]), filter(nil), rowset=16
  2 - output([A.col_bigint_key]), filter(nil), rowset=16
      dop=1
  3 - output([A.col_bigint_key]), filter(nil), rowset=16
      force partition granule
  4 - output([A.col_bigint_key]), filter(nil), rowset=16
      access([A.col_bigint_key]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([A.col_bigint_key], [A.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
  5 - output([B.col_bigint_key]), filter(nil), rowset=16
      access([GROUP_ID], [B.col_bigint_key]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([B.col_bigint_key], [B.__pk_increment]), range(MIN ; MAX), 
      range_cond([:0 = B.col_bigint_key])
SELECT  /*+ NO_REWRITE leading(a b) use_nl(b)*/  A.col_bigint_key, B.col_bigint_key FROM table1_key_pk_parts_2 A
LEFT OUTER JOIN table30 B ON A.col_bigint_key = B.col_bigint_key
WHERE A.col_bigint_key = B.col_bigint_key;
