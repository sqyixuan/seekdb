drop table if exists t1,tmp;
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, index i1(c1, c2, c3, c5), index i2(c1,c2,c4,c5));
create table tmp(c1 int, c2 int);
insert into tmp values (1, 2);
set ob_enable_transformation = 0;
result_format: 4
explain_protocol: 3
