---------------------------------------------------------------
|0 |NESTED-LOOP JOIN           |        |104     |2516072     |
|1 |├─PX COORDINATOR           |        |99984   |441426      |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|99984   |384447      |
|3 |│   └─PX PARTITION ITERATOR|        |99984   |256484      |
|4 |│     └─TABLE FULL SCAN    |t1(idx) |99984   |256484      |
|5 |└─TABLE RANGE SCAN         |t2(idx) |1       |20          |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=256
      conds(nil), nl_params_([t1.c2(:0)]), use_batch=true
  1 - output([t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=256
  2 - output([t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=256
      dop=1
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      force partition granule
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=256
      access([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), partitions(p[0-7])
      is_index_back=true, is_global_index=false, 
      range_key([t1.c2], [t1.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
  5 - output([t2.c2], [t2.c1], [t2.c3]), filter(nil), rowset=256
      access([GROUP_ID], [t2.__pk_increment], [t2.c2], [t2.c1], [t2.c3]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t2.c2], [t2.__pk_increment]), range(MIN ; MAX), 
      range_cond([:0 = t2.c2])

