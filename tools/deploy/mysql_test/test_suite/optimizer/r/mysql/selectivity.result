drop table if exists t1, t2, t3, t4, t5, t6;
SCHEMA
create table t1 (deci decimal(20, 5));
create table t2 (c1 int) partition by range columns(c1) (
partition p0 VALUES LESS THAN (500),
partition p1 VALUES LESS THAN (1000));
create table t3 (c1 int) partition by range columns(c1) (
partition p0 VALUES LESS THAN (500),
partition p1 VALUES LESS THAN (1000));
create table t4 (c1 int, c2 decimal(15, 2));
create table t5 (c1 int primary key, c2 int) partition by range columns(c1) (
partition p0 VALUES LESS THAN (51),
partition p1 VALUES LESS THAN (101),
partition p2 VALUES LESS THAN (151),
partition p3 VALUES LESS THAN (201));
create table t6 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range columns(c1) 
subpartition by hash (c2) subpartitions 3
(
partition p0 VALUES LESS THAN (51),
partition p1 VALUES LESS THAN (101),
partition p2 VALUES LESS THAN (151),
partition p3 VALUES LESS THAN (201)
);
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
call dbms_stats.gather_table_stats('TEST', 't3');
call dbms_stats.gather_table_stats('TEST', 't4');
call dbms_stats.gather_table_stats('TEST', 't5');
call dbms_stats.gather_table_stats('TEST', 't6');
