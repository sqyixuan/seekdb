);
EXPLAIN SELECT 1 FROM table10_bigint WHERE pk in (
(SELECT pk
FROM table5_key_pk_parts_1_bigint
WHERE 'bbb' NOT LIKE 'aaa'
     OR col_bigint <> 6991
OR EXISTS (SELECT col_bigint FROM table0_key_pk_parts_1_bigint)
AND (col_bigint < 6991 AND (col_decimal_20_0 = 1))));
