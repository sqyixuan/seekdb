SELECT DISTINCT GRANDPARENT1 . col_datetime_key AS G1 FROM jj AS GRANDPARENT1 LEFT JOIN g AS GRANDPARENT2 ON ( GRANDPARENT2 . `col_int_key` >= GRANDPARENT1 . `col_int_key` ) WHERE GRANDPARENT1 . `col_int` IN ( SELECT DISTINCT PARENT1 . `pk` AS P1 FROM k AS PARENT1 LEFT JOIN bb AS PARENT2 USING ( col_datetime_key ) WHERE GRANDPARENT1 . `col_int_key` IN ( SELECT  CHILD1 . `col_int_key` AS C1 FROM y AS CHILD1 LEFT JOIN l AS CHILD2 USING ( col_datetime_key ) WHERE ( ( CHILD1 . `col_int_key` = CHILD1 . `col_int` ) OR ( ( PARENT1 . `col_varchar_10_key` > 'v' ) AND ( GRANDPARENT1 . `col_varchar_10_key` < 'x' ) ) ) ORDER BY CHILD1 . col_datetime_key ) AND ( ( PARENT1 . `col_int` >= PARENT1 . `pk` ) AND ( PARENT1 . `pk` <= 3 ) )  ) AND GRANDPARENT1 . `col_datetime_key` BETWEEN '2008-01-13' AND '2003-09-16' GROUP BY GRANDPARENT1 . col_datetime_key  ORDER BY GRANDPARENT1 . col_datetime_key LIMIT 6;
G1
explain SELECT DISTINCT GRANDPARENT1 . col_datetime_key AS G1 FROM jj AS GRANDPARENT1 LEFT JOIN g AS GRANDPARENT2 ON ( GRANDPARENT2 . `col_int_key` >= GRANDPARENT1 . `col_int_key` ) WHERE GRANDPARENT1 . `col_int` IN ( SELECT DISTINCT PARENT1 . `pk` AS P1 FROM k AS PARENT1 LEFT JOIN bb AS PARENT2 USING ( col_datetime_key ) WHERE GRANDPARENT1 . `col_int_key` IN ( SELECT  CHILD1 . `col_int_key` AS C1 FROM y AS CHILD1 LEFT JOIN l AS CHILD2 USING ( col_datetime_key ) WHERE ( ( CHILD1 . `col_int_key` = CHILD1 . `col_int` ) OR ( ( PARENT1 . `col_varchar_10_key` > 'v' ) AND ( GRANDPARENT1 . `col_varchar_10_key` < 'x' ) ) ) ORDER BY CHILD1 . col_datetime_key ) AND ( ( PARENT1 . `col_int` >= PARENT1 . `pk` ) AND ( PARENT1 . `pk` <= 3 ) )  ) AND GRANDPARENT1 . `col_datetime_key` BETWEEN '2008-01-13' AND '2003-09-16' GROUP BY GRANDPARENT1 . col_datetime_key  ORDER BY GRANDPARENT1 . col_datetime_key LIMIT 6;
