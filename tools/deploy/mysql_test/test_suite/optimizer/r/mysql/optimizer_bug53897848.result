drop table if exists t1;
result_format: 4
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by hash(c1) partitions 100;
create index i1 on t1(c1,c3) local;
create index i2 on t1(c1,c3) global;
insert into t1 values(0,1,1,0),(1,0,0,0),(1,1,0,0),
                     (0,2,2,2),(2,0,2,0),(2,2,0,0),
                     (0,3,3,0),(3,0,0,0),(3,3,0,0),
                     (0,4,4,4),(4,0,4,0),(4,4,0,0);
insert into t1 select c1+4,c2+4,c3+4,c4+4 from t1;
insert into t1 select c1+8,c2+8,c3+8,c4+8 from t1;
call dbms_stats.gather_table_stats('TEST','T1');
explain_protocol: 3
######index back
##different partition count
EXPLAIN EXTENDED_NOADDR select * from t1 where c1 < 1;
