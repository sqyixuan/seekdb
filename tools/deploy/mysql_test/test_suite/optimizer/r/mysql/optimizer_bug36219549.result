drop table if exists t1;
create table t1 (c1 int);
insert into t1(c1) values (0), (1), (0), (-1), (-1), (1);
result_format: 4
explain_protocol: 2
EXPLAIN select t1.c1 as t1c1 from t1 where t1.c1 is true group by t1c1;
