drop table if exists a,b,c,d,pa,pb,pc;
Create table A(a1 int primary key, a2 int, a3 int,a4 int,a5 int,a6 int,a7 int,a8 int);
Create table B(b1 int primary key, b2 int, b3 int,b4 int,b5 int,b6 int,b7 int,b8 int);
Create table C(c1 int primary key, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int);
Create table D(d1 int primary key, d2 int, d3 int,d4 int,d5 int,d6 int,d7 int,d8 int);
Create table PA(a1 int primary key, a2 int, a3 int,a4 int,a5 int,a6 int,a7 int,a8 int) partition by key(a1) partitions 4;
Create table PB(b1 int primary key, b2 int, b3 int,b4 int,b5 int,b6 int,b7 int,b8 int) partition by key(b1) partitions 4;
Create table PC(c1 int, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int, primary key(c1,c2)) partition by key(c1,c2) partitions 5;
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 'A');
call dbms_stats.gather_table_stats('TEST', 'B');
call dbms_stats.gather_table_stats('TEST', 'C');
call dbms_stats.gather_table_stats('TEST', 'D');
call dbms_stats.gather_table_stats('TEST', 'pa');
call dbms_stats.gather_table_stats('TEST', 'pb');
call dbms_stats.gather_table_stats('TEST', 'pc');
select count(1) from A;
count(1)
1000
select count(1) from B;
count(1)
100
select count(1) from C;
count(1)
10
select count(1) from D;
count(1)
1
select count(1) from PA;
count(1)
16
select count(1) from PB;
count(1)
16
select count(1) from PC;
count(1)
20
