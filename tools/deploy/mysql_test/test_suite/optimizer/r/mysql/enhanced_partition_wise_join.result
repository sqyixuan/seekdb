create table t_insert2 (c1 int primary key, c2 int, c3 int) partition by list(c1)
(
  partition p0 values in (1,2,3,4,5),
  partition p1 values in (6,7,8,9,10),
  partition p2 values in (11,12,13,14,15)
);
