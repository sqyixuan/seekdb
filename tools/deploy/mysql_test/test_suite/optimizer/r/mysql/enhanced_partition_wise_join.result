      access([t2.c1], [t2.c2]), partitions(p0sp0, p1sp0, p2sp0, p3sp0, p4sp0, p5sp0, p6sp0, p7sp0, p8sp0, p9sp0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.c1], [t2.c2]), range(MIN,MIN ; MAX,MAX)always true
  8 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([GROUP_ID], [t1.c1], [t1.c2], [t1.c3]), partitions(p0sp0, p1sp0, p2sp0, p3sp0, p4sp0, p5sp0, p6sp0, p7sp0, p8sp0, p9sp0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2]), range(MIN ; MAX), 
      range_cond([t1.c2 = 1], [t1.c1 = :0])
  9 - output(nil), filter(nil), rowset=16
      access([GROUP_ID]), partitions(p0sp2, p1sp2, p2sp2, p3sp2, p4sp2, p5sp2, p6sp2, p7sp2, p8sp2, p9sp2)
      is_index_back=false, is_global_index=false, 
      range_key([t3.c1], [t3.c2]), range(MIN ; MAX), 
      range_cond([t3.c2 > 200], [:1 = t3.c1])
insert into t_insert4
select t1.* from t_hash_list1 t1, t_hash_list2 t2, t_hash_range1 t3
where t1.c1 = t2.c1 and t2.c1 = t3.c1 and t1.c2 = 1 and t2.c2 = 1 and t3.c2 > 200;
select * from t_insert4;
+----+----+------+
| c1 | c2 | c3   |
+----+----+------+
+----+----+------+
rollback;
