drop database if exists opt_pwj;
create database opt_pwj;
use opt_pwj;
set global ob_plan_cache_percentage = 50;
alter system flush plan cache global;
result_format: 4
##
## I. 一级分区
##
##
## I.1 range分区
##
create table t_range1 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
create table t_range2 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (150),
  partition p2 values less than (200),
  partition p3 values less than (300)
);
create table t_range3 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
alter table t_range3 drop partition p2;
alter table t_range3 add partition (partition p3 values less than (300));

create table t_range4 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
insert into t_range1 values (1,1,1),(5,5,5),(51,51,51),(55,55,55),
                            (101,101,101),(105,105,105),(151,151,151),(155,155,155),
                            (201,201,201),(205,205,205),(251,251,251),(255,255,255);
insert into t_range2 values (2,2,2),(5,5,5),(52,52,52),(55,55,55),
                            (102,102,102),(105,105,105),(152,152,152),(155,155,155),
                            (202,202,202),(205,205,205),(252,252,252),(255,255,255);
insert into t_range3 values (3,3,3),(5,5,5),(53,53,53),(55,55,55),
                            (103,103,103),(105,105,105),(153,153,153),(155,155,155),
                            (203,203,203),(205,205,205),(253,253,253),(255,255,255);
insert into t_range4 values (4,4,4),(5,5,5),(54,54,54),(55,55,55),
                            (104,104,104),(105,105,105),(154,154,154),(155,155,155),
                            (204,204,204),(205,205,205),(254,254,254),(255,255,255);
##
## I.1.1 join
##
## logical partition not equal, no pwj
EXPLAIN select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |12      |74          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|12      |63          |
|2 |  └─HASH JOIN                    |        |12      |39          |
|3 |    ├─EXCHANGE IN DISTR          |        |12      |25          |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|12      |20          |
|5 |    │   └─PX PARTITION ITERATOR  |        |12      |8           |
|6 |    │     └─TABLE FULL SCAN      |t1      |12      |8           |
|7 |    └─PX PARTITION ITERATOR      |        |12      |10          |
|8 |      └─TABLE FULL SCAN          |t2      |12      |10          |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t2.c1], [t1.c2], [t1.c3], [t2.c2], [t2.c3]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      (#keys=1, [t1.c1]), dop=1
  5 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      force partition granule
  6 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
  7 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      affinitize, force partition granule
  8 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(MIN ; MAX)always true
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1;
+-----+------+------+-----+------+------+
| c1  | c2   | c3   | c1  | c2   | c3   |
+-----+------+------+-----+------+------+
|   5 |    5 |    5 |   5 |    5 |    5 |
|  55 |   55 |   55 |  55 |   55 |   55 |
| 105 |  105 |  105 | 105 |  105 |  105 |
| 155 |  155 |  155 | 155 |  155 |  155 |
| 205 |  205 |  205 | 205 |  205 |  205 |
| 255 |  255 |  255 | 255 |  255 |  255 |
+-----+------+------+-----+------+------+

## after partition pruning, logical partition equal, pwj
EXPLAIN select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 150 order by t1.c1;
Query Plan
==============================================================
|ID|OPERATOR                  |NAME    |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT |        |6       |28          |
|1 |└─EXCHANGE OUT DISTR      |:EX10000|6       |23          |
|2 |  └─PX PARTITION ITERATOR |        |6       |11          |
|3 |    └─MERGE JOIN          |        |6       |11          |
|4 |      ├─TABLE RANGE SCAN  |t1      |6       |5           |
|5 |      └─TABLE RANGE SCAN  |t2      |6       |5           |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
      sort_keys([t1.c1, ASC])
  1 - output([t1.c1], [INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t2.c1], [t1.c2], [t1.c3], [t2.c2], [t2.c3]), filter(nil), rowset=16
      partition wise, force partition granule, asc
  3 - output([t1.c1], [t2.c1], [t1.c2], [t1.c3], [t2.c2], [t2.c3]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
      merge_directions([ASC])
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p[1-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(150 ; MAX), 
      range_cond([t1.c1 > 150])
  5 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p[2-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(150 ; MAX), 
      range_cond([t2.c1 > 150])
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 150 order by t1.c1;
