## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > ? order by t1.c1';
+-----------+
| hit_count |
+-----------+
|         2 |
