| 205 |  205 |  205 | 205 |  205 |  205 |
| 255 |  255 |  255 | 255 |  255 |  255 |
+-----+------+------+-----+------+------+
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 151 order by t1.c1;
+-----+------+------+-----+------+------+
| c1  | c2   | c3   | c1  | c2   | c3   |
+-----+------+------+-----+------+------+
| 155 |  155 |  155 | 155 |  155 |  155 |
| 205 |  205 |  205 | 205 |  205 |  205 |
| 255 |  255 |  255 | 255 |  255 |  255 |
