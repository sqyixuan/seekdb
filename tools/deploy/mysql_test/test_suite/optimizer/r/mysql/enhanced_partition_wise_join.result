## t1 join t2 is not pwj
## t1 join t3 is pwj
## insert into t_insert1 is not pwj
## t1 join t2 is pwj
## t1 join t3 is pwj
## insert into t_insert1 is pwj
### hit_count should be 2
set autocommit=1;

## 
## I.2 list partition
##
create table t_list1 (c1 int primary key, c2 int, c3 int) partition by list(c1)
(
  partition p0 values in (1,2,3,4,5),
  partition p1 values in (6,7,8,9,10),
  partition p2 values in (11,12,13,14,15)
);
create table t_list2 (c1 int primary key, c2 int, c3 int) partition by list(c1)
(
  partition p0 values in (6,7,8,9,10),
  partition p1 values in (1,2,3,4,5),
  partition p2 values in (11,12,13,14,15)
);
create table t_list3 (c1 int primary key, c2 int, c3 int) partition by list(c1)
(
  partition p0 values in (11,12,13,14,15),
  partition p1 values in (1,2,3,4,5),
  partition p2 values in (6,7,8,9,10)
);
create table t_list4 (c1 int primary key, c2 int, c3 int) partition by list(c1)
(
  partition p0 values in (1,2,3,4,5),
  partition p1 values in (6,7,8,9,10),
  partition p2 values in (11,12,13,14,15)
);
alter table t_list4 drop partition p2;
alter table t_list4 add partition (partition p3 values in (11,12,13,14,15));
insert into t_list1 values (1,1,1),(5,5,5),(6,6,6),(10,10,10),(11,11,11),(15,15,15);
insert into t_list2 values (2,2,2),(5,5,5),(7,7,7),(10,10,10),(12,12,12),(15,15,15);
insert into t_list3 values (3,3,3),(5,5,5),(8,8,8),(10,10,10),(13,13,13),(15,15,15);
insert into t_list4 values (4,4,4),(5,5,5),(9,9,9),(10,10,10),(14,14,14),(15,15,15);
