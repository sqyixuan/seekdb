#
# Bug #59326: Greedy optimizer produce stupid query execution plans.
#
drop table if exists t10,t100,t10000;
CREATE TABLE t10( K INT NOT NULL AUTO_INCREMENT, I INT, PRIMARY KEY(K));
INSERT INTO t10(I) VALUES (1),(2),(3),(4),(5),(6),(7),(8),(9),(0);
CREATE TABLE t100( K INT NOT NULL AUTO_INCREMENT, I INT, PRIMARY KEY(K));
INSERT INTO t100(I) SELECT X.I FROM t10 AS X,t10 AS Y;
CREATE TABLE t10000( K INT NOT NULL AUTO_INCREMENT, I INT, PRIMARY KEY(K));
INSERT INTO t10000(I) SELECT X.I FROM t100 AS X, t100 AS Y;
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't10');
call dbms_stats.gather_table_stats('TEST', 't100');
call dbms_stats.gather_table_stats('TEST', 't10000');
