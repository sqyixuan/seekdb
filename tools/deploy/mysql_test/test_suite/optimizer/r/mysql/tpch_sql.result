      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false,false,false], 
      range_key([lineitem.l_orderkey], [lineitem.l_linenumber]), range(MIN,MIN ; MAX,MAX)always true
  4 - output([orders.o_orderkey], [orders.o_orderpriority]), filter(nil), rowset=256
      access([orders.o_orderkey], [orders.o_orderpriority]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([orders.o_orderkey]), range(MIN ; MAX)always true
