|6 |    │   └─TABLE FULL SCAN|orders  |1459    |209         |
|7 |    └─TABLE FULL SCAN    |lineitem|6433    |785         |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([lineitem.l_orderkey], [T_FUN_SUM(lineitem.l_extendedprice * cast(1, DECIMAL_INT(11, 2)) - lineitem.l_discount)], [orders.o_orderdate], [orders.o_shippriority]), filter(nil), rowset=256
      sort_keys([T_FUN_SUM(lineitem.l_extendedprice * cast(1, DECIMAL_INT(11, 2)) - lineitem.l_discount), DESC], [orders.o_orderdate, ASC]), topn(10)
  1 - output([T_FUN_SUM(lineitem.l_extendedprice * cast(1, DECIMAL_INT(11, 2)) - lineitem.l_discount)], [orders.o_orderdate], [lineitem.l_orderkey], [orders.o_shippriority]), filter(nil), rowset=256
      group([lineitem.l_orderkey]), agg_func([T_FUN_SUM(lineitem.l_extendedprice * cast(1, DECIMAL_INT(11, 2)) - lineitem.l_discount)])
  2 - output([orders.o_orderdate], [lineitem.l_orderkey], [orders.o_shippriority], [lineitem.l_extendedprice], [lineitem.l_discount]), filter(nil), rowset=256
      equal_conds([lineitem.l_orderkey = orders.o_orderkey]), other_conds(nil)
      merge_directions([ASC])
  3 - output([orders.o_orderdate], [orders.o_shippriority], [orders.o_orderkey]), filter(nil), rowset=256
