      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([customer.c_custkey]), range(MIN ; MAX)always true
  6 - output([orders.o_orderkey], [orders.o_custkey], [orders.o_orderdate], [orders.o_shippriority]), filter([orders.o_orderdate < demote_cast('1995-03-15',
       MYSQL_DATE(10, 0))]), rowset=256
      access([orders.o_orderkey], [orders.o_custkey], [orders.o_orderdate], [orders.o_shippriority]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([orders.o_orderkey]), range(MIN ; MAX)always true
  7 - output([lineitem.l_orderkey], [lineitem.l_extendedprice], [lineitem.l_discount]), filter([lineitem.l_shipdate > demote_cast('1995-03-15', MYSQL_DATE(10,
       0))]), rowset=256
