====================================================================
|ID|OPERATOR                        |NAME    |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------
|0 |TOP-N SORT                      |        |1       |57          |
|1 |└─SUBPLAN SCAN                  |VIEW1   |1       |56          |
|2 |  └─WINDOW FUNCTION             |        |1       |56          |
|3 |    └─SORT                      |        |1       |55          |
|4 |      └─HASH JOIN               |        |1       |55          |
|5 |        ├─TABLE FULL SCAN       |region  |1       |3           |
|6 |        └─HASH JOIN             |        |4       |52          |
|7 |          ├─HASH JOIN           |        |4       |44          |
|8 |          │ ├─NESTED-LOOP JOIN  |        |4       |37          |
|9 |          │ │ ├─TABLE FULL SCAN |part    |1       |21          |
|10|          │ │ └─TABLE RANGE SCAN|partsupp|4       |16          |
|11|          │ └─TABLE FULL SCAN   |supplier|20      |5           |
|12|          └─TABLE FULL SCAN     |nation  |25      |4           |
====================================================================
Outputs & filters:
-------------------------------------
  0 - output([VIEW1.supplier.s_acctbal], [VIEW1.supplier.s_name], [VIEW1.nation.n_name], [VIEW1.part.p_partkey], [VIEW1.part.p_mfgr], [VIEW1.supplier.s_address],
       [VIEW1.supplier.s_phone], [VIEW1.supplier.s_comment]), filter(nil), rowset=256
      sort_keys([VIEW1.supplier.s_acctbal, DESC], [VIEW1.nation.n_name, ASC], [VIEW1.supplier.s_name, ASC], [VIEW1.part.p_partkey, ASC]), topn(100)
  1 - output([VIEW1.supplier.s_acctbal], [VIEW1.supplier.s_name], [VIEW1.supplier.s_address], [VIEW1.supplier.s_phone], [VIEW1.supplier.s_comment], [VIEW1.nation.n_name],
       [VIEW1.part.p_partkey], [VIEW1.part.p_mfgr]), filter([VIEW1.partsupp.ps_supplycost = VIEW1.min(ps_supplycost)]), rowset=256
      access([VIEW1.min(ps_supplycost)], [VIEW1.partsupp.ps_supplycost], [VIEW1.supplier.s_acctbal], [VIEW1.supplier.s_name], [VIEW1.supplier.s_address],
       [VIEW1.supplier.s_phone], [VIEW1.supplier.s_comment], [VIEW1.nation.n_name], [VIEW1.part.p_partkey], [VIEW1.part.p_mfgr])
  2 - output([T_FUN_MIN(partsupp.ps_supplycost)], [partsupp.ps_supplycost], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone],
       [supplier.s_comment], [nation.n_name], [part.p_partkey], [part.p_mfgr]), filter(nil), rowset=256
      win_expr(T_FUN_MIN(partsupp.ps_supplycost)), partition_by([partsupp.ps_partkey]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  3 - output([partsupp.ps_supplycost], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment], [nation.n_name],
       [part.p_partkey], [part.p_mfgr], [partsupp.ps_partkey]), filter(nil), rowset=256
      sort_keys([partsupp.ps_partkey, ASC])
  4 - output([partsupp.ps_supplycost], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment], [nation.n_name],
       [part.p_partkey], [part.p_mfgr], [partsupp.ps_partkey]), filter(nil), rowset=256
      equal_conds([nation.n_regionkey = region.r_regionkey]), other_conds(nil)
  5 - output([region.r_regionkey]), filter([region.r_name = 'ASIA']), rowset=256
      access([region.r_regionkey], [region.r_name]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([region.r_regionkey]), range(MIN ; MAX)always true
  6 - output([partsupp.ps_supplycost], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment], [nation.n_name],
       [part.p_partkey], [part.p_mfgr], [partsupp.ps_partkey], [nation.n_regionkey]), filter(nil), rowset=256
      equal_conds([supplier.s_nationkey = nation.n_nationkey]), other_conds(nil)
  7 - output([partsupp.ps_supplycost], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment], [part.p_partkey],
       [part.p_mfgr], [partsupp.ps_partkey], [supplier.s_nationkey]), filter(nil), rowset=256
      equal_conds([supplier.s_suppkey = partsupp.ps_suppkey]), other_conds(nil)
  8 - output([partsupp.ps_supplycost], [part.p_partkey], [part.p_mfgr], [partsupp.ps_partkey], [partsupp.ps_suppkey]), filter(nil), rowset=256
      conds(nil), nl_params_([part.p_partkey(:0)]), use_batch=true
  9 - output([part.p_partkey], [part.p_mfgr]), filter([part.p_size = 30], [(T_OP_LIKE, part.p_type, '%STEEL', '\\')]), rowset=256
      access([part.p_partkey], [part.p_size], [part.p_type], [part.p_mfgr]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([part.p_partkey]), range(MIN ; MAX)always true
 10 - output([partsupp.ps_partkey], [partsupp.ps_suppkey], [partsupp.ps_supplycost]), filter(nil), rowset=256
      access([GROUP_ID], [partsupp.ps_partkey], [partsupp.ps_suppkey], [partsupp.ps_supplycost]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([partsupp.ps_partkey], [partsupp.ps_suppkey]), range(MIN ; MAX), 
      range_cond([partsupp.ps_partkey = :0])
 11 - output([supplier.s_suppkey], [supplier.s_nationkey], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment]), filter(nil), rowset=256
      access([supplier.s_suppkey], [supplier.s_nationkey], [supplier.s_acctbal], [supplier.s_name], [supplier.s_address], [supplier.s_phone], [supplier.s_comment]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([supplier.s_suppkey]), range(MIN ; MAX)always true
 12 - output([nation.n_nationkey], [nation.n_regionkey], [nation.n_name]), filter(nil), rowset=256
      access([nation.n_nationkey], [nation.n_regionkey], [nation.n_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([nation.n_nationkey]), range(MIN ; MAX)always true
