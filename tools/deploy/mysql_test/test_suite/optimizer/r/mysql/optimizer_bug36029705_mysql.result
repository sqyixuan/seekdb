drop table if exists t41, t68;
create table t41 (c1 CHAR(103) ,c2 INT(72) , primary key(c2))DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c2) PARTITIONS 20;
create table t68 (c1 INT(2) ,c2 DECIMAL(22,0) ,c3 INT(80) ,c4 NUMERIC(6,6) ,c5 NUMERIC(41,9) ,c6 SMALLINT(12) ,c7 BIGINT(99) ,c8 INTEGER(84) , primary key(c8,c2,c5,c6,c1))DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c8,c2,c5,c6,c1) PARTITIONS 20;
explain_protocol: 2
result_format: 4
EXPLAIN SELECT /*+ parallel(2) LEADING(t68_87222 t41_805) */ count(*) FROM ( SELECT t41_805.c1, t41_805.c2 FROM t41 AS t41_805 ) AS t41_805 RIGHT OUTER JOIN t68 AS t68_87222 ON t41_805.c2 = t68_87222.c4 AND t41_805.c1 < 135 OR t41_805.c2 = 986 OR t41_805.c2 = t68_87222.c6 WHERE t41_805.c2 <= 8 AND t41_805.c2 = t41_805.c1 OR t41_805.c1 < t41_805.c2 ORDER BY 1;
