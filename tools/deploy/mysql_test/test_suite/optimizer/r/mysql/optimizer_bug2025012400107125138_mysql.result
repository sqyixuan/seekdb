drop table if exists t0, t1, t2;
create table t0(c1 int primary key) ORGANIZATION INDEX;
create table t1(c1 int primary key) ORGANIZATION HEAP;
create table t2(c1 int) ORGANIZATION HEAP;
insert into t0 select row_number() over () from table(generator(204000));
insert into t1 select row_number() over () from table(generator(204000));
insert into t2 select row_number() over () from table(generator(204000));
call dbms_stats.gather_table_stats(null, 't0');
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
set _enable_storage_cardinality_estimation = 0;
result_format: 4
select table_name, COLUMN_NAME, num_distinct from oceanbase.dba_tab_col_statistics where OWNER = 'test' and table_name in ('t0', 't1', 't2') order by 1,2,3;
+------------+-------------+--------------+
| table_name | COLUMN_NAME | num_distinct |
+------------+-------------+--------------+
| t0         | c1          |       192480 |
| t1         | c1          |       192480 |
| t2         | c1          |       192480 |
+------------+-------------+--------------+

explain select /*+no_rewrite*/ count(*) from t0 group by c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |MERGE GROUP BY   |    |204000  |18826       |
|1 |└─TABLE FULL SCAN|t0  |204000  |5263        |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group([t0.c1]), agg_func([T_FUN_COUNT(*)])
  1 - output([t0.c1]), filter(nil), rowset=256
      access([t0.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t0.c1]), range(MIN ; MAX)always true
explain select /*+no_rewrite*/ count(*) from t1 group by c1;
