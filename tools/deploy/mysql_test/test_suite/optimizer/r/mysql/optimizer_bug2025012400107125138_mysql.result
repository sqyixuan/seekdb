===================================================
|ID|OPERATOR         |NAME  |EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |MERGE GROUP BY   |      |204000  |18826       |
|1 |└─TABLE FULL SCAN|t1(c1)|204000  |5263        |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group([t1.c1]), agg_func([T_FUN_COUNT(*)])
  1 - output([t1.c1]), filter(nil), rowset=256
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.shadow_pk_0]), range(MIN,MIN ; MAX,MAX)always true
explain select /*+no_rewrite*/ count(*) from t2 group by c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |192480  |57181       |
|1 |└─TABLE FULL SCAN|t2  |204000  |5263        |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group([t2.c1]), agg_func([T_FUN_COUNT(*)])
  1 - output([t2.c1]), filter(nil), rowset=256
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true

drop table t0,t1,t2;
