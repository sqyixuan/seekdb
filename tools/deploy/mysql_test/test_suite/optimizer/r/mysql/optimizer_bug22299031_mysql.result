drop table if exists t1, t2;
create table t1(a int, b int, c int, primary key(a,b));
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
result_format: 4
explain_protocol: 2
EXPLAIN insert into t1 select b, sum(a), sum(c) from t2 group by b;
Query Plan
================================================================================
|ID|OPERATOR                             |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------------------
|0 |INSERT                               |               |9       |120         |
|1 |└─PX COORDINATOR                     |               |9       |56          |
|2 |  └─EXCHANGE OUT DISTR               |:EX10001       |9       |50          |
|3 |    └─SUBPLAN SCAN                   |ANONYMOUS_VIEW1|9       |36          |
|4 |      └─HASH GROUP BY                |               |9       |36          |
|5 |        └─EXCHANGE IN DISTR          |               |9       |33          |
|6 |          └─EXCHANGE OUT DISTR (HASH)|:EX10000       |9       |26          |
|7 |            └─HASH GROUP BY          |               |9       |13          |
|8 |              └─PX PARTITION ITERATOR|               |9       |10          |
|9 |                └─TABLE FULL SCAN    |t2             |9       |10          |
================================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.a, t1.b, t1.c)})}]), partitions(p0), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW1.b)], [column_conv(INT,PS:(11,0),NOT NULL,cast(ANONYMOUS_VIEW1.sum(a), INT(-1, 0)))],
       [column_conv(INT,PS:(11,0),NULL,cast(ANONYMOUS_VIEW1.sum(c), INT(-1, 0)))])
  1 - output([ANONYMOUS_VIEW1.b], [ANONYMOUS_VIEW1.sum(a)], [ANONYMOUS_VIEW1.sum(c)]), filter(nil), rowset=16
  2 - output([ANONYMOUS_VIEW1.b], [ANONYMOUS_VIEW1.sum(a)], [ANONYMOUS_VIEW1.sum(c)]), filter(nil), rowset=16
      dop=1
  3 - output([ANONYMOUS_VIEW1.b], [ANONYMOUS_VIEW1.sum(a)], [ANONYMOUS_VIEW1.sum(c)]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.b], [ANONYMOUS_VIEW1.sum(a)], [ANONYMOUS_VIEW1.sum(c)])
  4 - output([t2.b], [T_FUN_SUM(T_FUN_SUM(t2.a))], [T_FUN_SUM(T_FUN_SUM(t2.c))]), filter(nil), rowset=16
      group([t2.b]), agg_func([T_FUN_SUM(T_FUN_SUM(t2.a))], [T_FUN_SUM(T_FUN_SUM(t2.c))])
  5 - output([t2.b], [T_FUN_SUM(t2.a)], [T_FUN_SUM(t2.c)]), filter(nil), rowset=16
  6 - output([t2.b], [T_FUN_SUM(t2.a)], [T_FUN_SUM(t2.c)]), filter(nil), rowset=16
      (#keys=1, [t2.b]), dop=1
  7 - output([t2.b], [T_FUN_SUM(t2.a)], [T_FUN_SUM(t2.c)]), filter(nil), rowset=16
      group([t2.b]), agg_func([T_FUN_SUM(t2.a)], [T_FUN_SUM(t2.c)])
  8 - output([t2.a], [t2.b], [t2.c]), filter(nil), rowset=16
      force partition granule
  9 - output([t2.a], [t2.b], [t2.c]), filter(nil), rowset=16
      access([t2.a], [t2.b], [t2.c]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.a], [t2.b]), range(MIN,MIN ; MAX,MAX)always true
insert into t1 select b, sum(a), sum(c) from t2 group by b;

EXPLAIN select * from t1;
