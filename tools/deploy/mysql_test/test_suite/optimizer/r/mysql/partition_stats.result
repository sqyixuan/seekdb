drop table if exists t1,t2;
set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 0;
set optimizer_dynamic_sampling = 0;
create table t1(pid int, c1 int, c2 int) partition by hash(pid) partitions 4;
insert into t1 select row_number() over () % 4, abs(random(1)) % 4, abs(random(2)) % 100 from table(generator(10000));
insert into t1 select row_number() over () % 4, abs(random(3)) % 4, 0 from table(generator(10000));
create table t2(pid int, c1 int, c2 int) partition by hash(pid) partitions 4 subpartition by hash(c1) subpartitions 4;
insert into t2 select * from t1;
alter system minor freeze;
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'for columns c2 size 100 for columns pid size 1 for columns c1 size 1');
call dbms_stats.gather_table_stats(null, 't2', method_opt=>'for columns c2 size 100 for columns pid size 1 for columns c1 size 1');
result_format: 4
explain_protocol: 3
EXPLAIN EXTENDED_NOADDR select count(*) from t1 where c2 = 0;
