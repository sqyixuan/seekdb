      is_index_back=false, is_global_index=false, 
      range_key([t6.c3], [t6.c5], [t6.c17], [t6.c4], [t6.c18], [t6.c11], [t6.c9]), range(MIN,MIN,MIN,MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX,MAX,MAX,MAX)always 
      true
select c3 + c5 from t6 order by 1;
