-------------------------------------
  0 - output([1]), filter(nil), rowset=16
      conds(nil), nl_params_([ref_1.a(:0)]), use_batch=false
  1 - output([ref_1.a]), filter(nil), rowset=16
      access([ref_1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([ref_1.__pk_increment]), range(MIN ; MAX)always true
  2 - output(nil), filter(nil), rowset=16
      exec_params_(nil), onetime_exprs_([(T_OP_EXISTS, subquery(1))(:1)]), init_plan_idxs_(nil), use_batch=false
  3 - output(nil), filter(nil), startup_filter([:1]), rowset=16
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([ref_0.__pk_increment]), range(MIN ; MAX)
  4 - output([1]), filter(nil), startup_filter([(T_OP_BIT_RIGHT_SHIFT, cast(:0, BIGINT(-1, 0)), cast(:0, BIGINT(-1, 0)))]), rowset=16
      access(nil), partitions(p0)
      limit(1), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([ref_2.__pk_increment]), range(MIN ; MAX)always true
SELECT    /*+leading(ref_1) use_nl(ref_0)*/  1
FROM       (t9 AS ref_0
    RIGHT JOIN
    (SELECT ref_1.a       AS c0,
     ref_1.a       AS c1
     FROM   t1vygkbs AS ref_1) AS subq_0
    ON EXISTS
    (SELECT 1
     FROM   t2c6raex AS ref_2
     WHERE  subq_0.c1 >> subq_0.c0 limit 106));
