drop table if exists t9;
drop table if exists t1vygkbs;
drop table if exists t2c6raex;
drop table if exists t6;
create table if not exists `t9` (
`c1` char(5)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create index `c1` on `t9` (`c1` ASC) ;
create table if not exists `t1vygkbs` (
`a` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create table if not exists `t2c6raex` (
`c1` int(11),
`c2` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
CREATE TABLE `t6` (
`c1` bigint(127) DEFAULT NULL,
`c2` datetime DEFAULT NULL,
`c3` int(127) NOT NULL,
`c4` binary(110) NOT NULL,
`c5` int(127) NOT NULL,
`c6` binary(138) DEFAULT NULL,
`c7` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
`c8` time DEFAULT NULL,
`c9` binary(116) NOT NULL,
`c10` year(4) DEFAULT NULL,
`c11` bigint(127) NOT NULL,
`c12` year(4) DEFAULT NULL,
`c13` timestamp(1) NOT NULL DEFAULT '0000-00-00 00:00:00.0',
`c14` year(4) DEFAULT NULL,
`c15` date DEFAULT NULL,
`c16` int(127) NOT NULL AUTO_INCREMENT,
`c17` varchar(86) COLLATE utf8mb4_bin NOT NULL,
`c18` decimal(64,27) NOT NULL,
`c19` int(127) DEFAULT NULL,
PRIMARY KEY (`c3`, `c5`, `c17`, `c4`, `c18`, `c11`, `c9`)
)
partition by hash(c3+c5+c11)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);
explain_protocol: 2
result_format: 4
EXPLAIN SELECT    /*+leading(ref_1) use_nl(ref_0)*/  1
FROM       (t9 AS ref_0
    RIGHT JOIN
    (SELECT ref_1.a       AS c0,
     ref_1.a       AS c1
     FROM   t1vygkbs AS ref_1) AS subq_0
    ON EXISTS
    (SELECT 1
     FROM   t2c6raex AS ref_2
     WHERE  subq_0.c1 >> subq_0.c0 limit 106));
