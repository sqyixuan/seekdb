WITH t0 AS (
    (WITH cte1 AS
        (
            SELECT *
            FROM   d
            WHERE     col_int_unsigned_key >
            		(
                    SELECT col_int_unsigned_key
                    FROM   (
                        (
                            SELECT   *
                            FROM     f
                            WHERE    1 = 0)
                        UNION ALL
                        (
                            SELECT   *
                            FROM     (
                            SELECT *
                            FROM   f) t1
                    				ORDER BY 1 DESC limit 0)) vt4
                    ORDER BY  1 limit 1))
    SELECT 1
    FROM   cte1)
    UNION ALL
        (WITH cte5 AS 
        		(WITH cte AS
        				(
                    SELECT *
                    FROM   d )
            SELECT 1
            FROM   cte a,
                cte b
            WHERE  1
            AND    b.pk < 744488960)
        SELECT *
        FROM   cte5))
SELECT
       /*+ ENABLE_PARALLEL_DML PARALLEL(5) no_rewrite */
       count(*)
FROM   t0;
