drop table if exists t1;
drop view if exists v1;
CREATE TABLE t1 (pk INTEGER PRIMARY KEY, a INTEGER NOT NULL, b CHAR(1), KEY(b));
CREATE VIEW v1 AS SELECT * FROM t1;
result_format: 4
explain_protocol: 2
EXPLAIN SELECT a1.pk FROM v1 AS a1 JOIN (SELECT * FROM v1 LIMIT 1) AS a2 ON a2.b = a1.b WHERE a1.a = (SELECT pk FROM v1 LIMIT 1) AND (a1.a != a2.a OR a1.b IS NULL);
