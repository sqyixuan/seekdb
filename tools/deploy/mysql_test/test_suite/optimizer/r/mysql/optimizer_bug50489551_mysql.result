-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter([t1.c1 = 1]), rowset=16
      access([t1.c2], [t1.c3], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c2], [t1.c3]), range(0,MIN ; 0,MAX), 
      range_cond([t1.c2 = 0])
select * from t1 where c1 =  1 and c2 = 0;
