drop table if exists `t1`;
create table t1(c1 int(11) , c2 int(11) , c3 int(11), primary key (c2, c3)) partition by range columns(c2, c3) (partition p0 values less than (1,1), partition p1 values less than (100,100));
insert into t1 values (1, 0, 1);
insert into t1 values (2, 2, 0);
explain_protocol: 2
result_format: 4
EXPLAIN insert INTO t1 (c2,c3) select c3, c2 from (select c2, c3 FROM t1  group by c2, c3);
Query Plan
========================================================================
|ID|OPERATOR                     |NAME           |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------------------
|0 |DISTRIBUTED INSERT           |               |2       |26          |
|1 |└─PX COORDINATOR             |               |2       |7           |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000       |2       |6           |
|3 |    └─SUBPLAN SCAN           |ANONYMOUS_VIEW2|2       |5           |
|4 |      └─PX PARTITION ITERATOR|               |2       |5           |
|5 |        └─TABLE FULL SCAN    |t1             |2       |5           |
========================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.c2, t1.c3, t1.c1)})}]), partitions(p[0-1]), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW2.c3)], [column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW2.c2)], [column_conv(INT,
      PS:(11,0),NULL,cast(NULL, INT(11, 0)))])
  1 - output([ANONYMOUS_VIEW2.c3], [ANONYMOUS_VIEW2.c2]), filter(nil), rowset=16
  2 - output([ANONYMOUS_VIEW2.c3], [ANONYMOUS_VIEW2.c2]), filter(nil), rowset=16
      dop=1
  3 - output([ANONYMOUS_VIEW2.c3], [ANONYMOUS_VIEW2.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW2.c3], [ANONYMOUS_VIEW2.c2])
  4 - output([t1.c3], [t1.c2]), filter(nil), rowset=16
      force partition granule
  5 - output([t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c2], [t1.c3]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c2], [t1.c3]), range(MIN,MIN ; MAX,MAX)always true
insert INTO t1 (c2,c3) select c3, c2 from (select c2, c3 FROM t1  group by c2, c3);

EXPLAIN select * from t1 where c1 =  1 and c2 = 0;
