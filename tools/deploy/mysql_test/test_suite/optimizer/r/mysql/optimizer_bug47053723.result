drop table t1;
drop table t2;
drop procedure p1;
drop function f1;
result_format: 4
create table t1(c1 int);
create table t2(c1 int);

create function f1() returns int        
begin
  insert into t2 values(2);
  return 1;
end//

create procedure p1()
begin
  declare i int  default 0;
  repeat
      set i = i+1;
      insert into t1 values (ceil(rand(3)*26*i));
    until i>50 end repeat;
end//


call p1();

explain select /*+parallel(1)*/ c1, f1() from t1 order by c1;
Query Plan
=============================================================
|ID|OPERATOR                     |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |SORT                         |    |51      |9           |
|1 |└─DISTRIBUTED TABLE FULL SCAN|t1  |51      |4           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [f1()]), filter(nil)
      sort_keys([t1.c1, ASC])
  1 - output([t1.c1]), filter(nil)
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

