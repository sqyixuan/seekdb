drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 varchar(32)) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int, c3 varchar(32)) partition by hash(c1) partitions 6;
result_format: 4
explain_protocol: 2
EXPLAIN select * from (     select c1 a, case when exists(select 1 from t2 where t1.c1=t2.c1) then 4 else 5 end b from t1     union all     select c1,c2 from t1) v where b= 4;
