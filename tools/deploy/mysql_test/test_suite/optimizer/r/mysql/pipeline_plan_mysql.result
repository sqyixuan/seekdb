drop table if exists audit_regular_simple_dictionary;
CREATE TABLE `audit_regular_simple_dictionary` (
`codetype` varchar(40) COLLATE utf8_bin NOT NULL COMMENT 'DIC_为保留字段不要拿这个开头',
`code` varchar(20) COLLATE utf8_bin NOT NULL COMMENT '其他和tb_sys_code一致',
`codename` varchar(80) COLLATE utf8_bin DEFAULT NULL,
`codealias` varchar(100) COLLATE utf8_bin DEFAULT NULL,
`codeorder` int(11) DEFAULT NULL,
PRIMARY KEY (`codetype`,`code`),
KEY `1` (`code`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
drop table if exists tb_flow_instance_his;
CREATE TABLE `tb_flow_instance_his` (
`PROCESSID` int(11) NOT NULL COMMENT '流程类型',
`ISERIALNO` varchar(20) CHARACTER SET utf8 NOT NULL COMMENT '工单流水',
`NODE_ID` varchar(64) CHARACTER SET utf8 NOT NULL COMMENT '稽核ID',
`CREATE_DATE` varchar(32) CHARACTER SET utf8 DEFAULT NULL COMMENT '工单创建时间',
`SUBMIT_DATE` varchar(32) CHARACTER SET utf8 DEFAULT NULL COMMENT '工单提交时间',
`REGULAR_SERIALNO` varchar(64) CHARACTER SET utf8 DEFAULT NULL COMMENT '差异数据唯一标识',
`REGULAR_AUDITTIME` varchar(10) CHARACTER SET utf8 DEFAULT NULL COMMENT '稽核时间',
`REGULAR_DATATIME` varchar(10) CHARACTER SET utf8 DEFAULT NULL,
`ACCEPT_DATE` varchar(32) CHARACTER SET utf8 DEFAULT NULL COMMENT '受理时间',
`LOGIN_ID` varchar(32) CHARACTER SET utf8 DEFAULT NULL COMMENT '差异数据表中的login_id字段',
`ACCEPT_LOGINID` varchar(64) CHARACTER SET utf8 DEFAULT NULL COMMENT '工单接受人',
`DLOGIN_ID` varchar(64) CHARACTER SET utf8 DEFAULT NULL COMMENT '整改人工号',
`REGION_CODE` varchar(16) COLLATE utf8_bin DEFAULT NULL COMMENT '受理人归属渠道编码',
`DIS_REGION_CODE` varchar(16) CHARACTER SET utf8 DEFAULT NULL COMMENT '受理人归属区县编码',
`CITY_REGION_CODE` varchar(16) CHARACTER SET utf8 DEFAULT NULL COMMENT '受理人归属地市编码',
`SERIALNO` varchar(64) CHARACTER SET utf8 DEFAULT NULL COMMENT '号码',
`USER_ID` varchar(64) CHARACTER SET utf8 DEFAULT '0' COMMENT '用户标识',
`CUST_ID` varchar(64) CHARACTER SET utf8 DEFAULT NULL COMMENT '客户标识',
`REGULAR_ERROR_REASON` varchar(1024) CHARACTER SET utf8 DEFAULT NULL COMMENT '差错原因，包含差错值',
`DEAL_REMARK` varchar(512) CHARACTER SET utf8 DEFAULT NULL COMMENT '处理原因',
`DEAL_ROLEID` varchar(8) CHARACTER SET utf8 DEFAULT NULL,
`FROM_SOURCE` varchar(512) CHARACTER SET utf8 DEFAULT NULL COMMENT '工单来源，判断ISALE,存放orderNum',
`CHN_SUB_TYPE` varchar(128) CHARACTER SET utf8 DEFAULT NULL,
`IS_BACK` varchar(1) CHARACTER SET utf8 DEFAULT '0' COMMENT '是否打回标识 1是',
`ORDER_NUM` varchar(64) CHARACTER SET utf8 DEFAULT NULL,
`ERROR_DATA` varchar(4000) COLLATE utf8_bin DEFAULT NULL,
`INSERTTIME` timestamp NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '生成时间',
`sign` int(11) DEFAULT NULL,
`ORDER_TEXT` varchar(5000) COLLATE utf8_bin DEFAULT NULL,
PRIMARY KEY (`ISERIALNO`),
KEY `index_dlogin_id` (`DLOGIN_ID`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
drop table if exists tb_flow_danjzhg;
CREATE TABLE `tb_flow_danjzhg` (
`iserialno` varchar(32) NOT NULL,
`icurractid` varchar(32) DEFAULT NULL,
`firstLoginId` varchar(32) DEFAULT NULL,
`firstSubmitDate` varchar(255) DEFAULT NULL,
`secondLoginId` varchar(32) DEFAULT NULL,
`secondSubmitDate` varchar(255) DEFAULT NULL,
`firstDealRemark` varchar(1000) DEFAULT NULL,
`secondDealRemark` varchar(1000) DEFAULT NULL,
`danjFlg` varchar(32) DEFAULT NULL,
`gd_remark` varchar(400) DEFAULT NULL COMMENT '归档审核意见',
`handel_reason_flag` varchar(255) DEFAULT NULL,
PRIMARY KEY (`iserialno`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
drop table if exists tb_flow_instance;
CREATE TABLE `tb_flow_instance` (
`PROCESSID` int(11) NOT NULL COMMENT '流程类型',
`ISERIALNO` varchar(20) NOT NULL COMMENT '工单流水',
`NODE_ID` varchar(64) DEFAULT NULL COMMENT '稽核ID',
`CREATE_DATE` varchar(32) DEFAULT NULL COMMENT '工单创建时间',
`SUBMIT_DATE` varchar(32) DEFAULT NULL COMMENT '工单提交时间',
`REGULAR_SERIALNO` varchar(64) DEFAULT NULL COMMENT '差异数据唯一标识',
`REGULAR_AUDITTIME` varchar(10) DEFAULT NULL COMMENT '稽核时间',
`REGULAR_DATATIME` varchar(10) DEFAULT NULL,
`ACCEPT_DATE` varchar(32) DEFAULT NULL COMMENT '受理时间',
`LOGIN_ID` varchar(32) DEFAULT NULL COMMENT '差异数据表中的login_id字段',
`ACCEPT_LOGINID` varchar(64) DEFAULT NULL COMMENT '工单接受人',
`DLOGIN_ID` varchar(64) DEFAULT NULL COMMENT '整改人工号',
`REGION_CODE` varchar(16) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL COMMENT '受理人归属渠道编码',
`DIS_REGION_CODE` varchar(16) DEFAULT NULL COMMENT '受理人归属区县编码',
`CITY_REGION_CODE` varchar(16) DEFAULT NULL COMMENT '受理人归属地市编码',
`SERIALNO` varchar(64) DEFAULT NULL COMMENT '号码',
`USER_ID` varchar(64) DEFAULT '0' COMMENT '用户标识',
`CUST_ID` varchar(64) DEFAULT NULL COMMENT '客户标识',
`REGULAR_ERROR_REASON` varchar(1024) DEFAULT NULL COMMENT '差错原因，包含差错值',
`DEAL_REMARK` varchar(512) DEFAULT NULL COMMENT '处理原因',
`DEAL_ROLEID` varchar(8) DEFAULT NULL,
`FROM_SOURCE` varchar(512) DEFAULT NULL COMMENT '工单来源，判断ISALE,存放orderNum',
`CHN_SUB_TYPE` varchar(128) DEFAULT NULL,
`IS_BACK` varchar(1) DEFAULT '0' COMMENT '是否打回标识 1是',
`ORDER_NUM` varchar(128) DEFAULT NULL COMMENT '订单编号',
`ERROR_DATA` varchar(7500) DEFAULT NULL,
`ORDER_TEXT` varchar(5000) DEFAULT NULL COMMENT '订单备注',
PRIMARY KEY (`ISERIALNO`),
KEY `instance_node_id` (`NODE_ID`) USING BTREE,
KEY `index_region_code` (`REGION_CODE`) USING BTREE,
KEY `index_ORDER_NUM` (`ORDER_NUM`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='工单实体表';
drop table if exists audit_regular_node;
CREATE TABLE `audit_regular_node` (
`NODE_ID` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin NOT NULL,
`ROOT_ID` varchar(36) DEFAULT NULL,
`NODE_NAME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_CONTENT` varchar(1000) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_AREA` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`STORAGE_ID` varchar(10) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_STATE` varchar(2) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_SPHERE` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_CYCLE` varchar(15) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_EXECUTE_DAY` varchar(15) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_OPTTIME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_INVALIDTIME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_IDOPT` varchar(8) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_OPTOR_NAME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_ISORDER` varchar(2) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_DUTY` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_DUTY_TIME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_REVIEW` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_REVIEW_TIME` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`RULE_ID` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_SIMPLE_TABLE` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_ERROR_TABLE` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_FLOW_SEND` varchar(2) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_FLOW_TYPE` varchar(10) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`TYPE` varchar(10) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_PRIORITY` varchar(2) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_COMPARE` varchar(10) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_CHECK_TABLE` varchar(36) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_AUDIT_TYPE` int(1) DEFAULT '0' COMMENT '1 是正式运行稽核点',
`NODE_TYPE` varchar(10) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`NODE_BATCH` int(10) unsigned DEFAULT NULL COMMENT '稽核点批次，根据系统表tb_Sys_varibale自动生成',
`NODE_ORDER` varchar(12) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`LOGIN_ID` varchar(32) DEFAULT NULL COMMENT '操作人工号',
`OP_TIME` datetime DEFAULT NULL COMMENT '最后修改时间',
`PARENT_MENU_ID` varchar(10) DEFAULT NULL COMMENT '报表父级菜单',
`MAX_DATA_TIME` varchar(20) DEFAULT NULL COMMENT '最新数据时间',
PRIMARY KEY (`NODE_ID`),
KEY `FK_Reference_2` (`ROOT_ID`) USING BTREE,
KEY `index_node_order` (`NODE_ORDER`) USING BTREE,
KEY `node_state` (`NODE_STATE`,`NODE_TYPE`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
drop table if exists tb_sys_code;
CREATE TABLE `tb_sys_code` (
`codetype` varchar(64) CHARACTER SET utf8 COLLATE utf8_bin NOT NULL,
`code` varchar(64) CHARACTER SET utf8 COLLATE utf8_bin NOT NULL,
`codename` varchar(250) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`codealias` varchar(2250) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`codeorder` int(11) DEFAULT NULL,
PRIMARY KEY (`codetype`,`code`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
drop table if exists to_do_task_list;
CREATE TABLE `to_do_task_list` (
`ITASKID` varchar(20) DEFAULT NULL,
`ICURRACTID` int(11) DEFAULT NULL,
`ISERIALNO` varchar(20) NOT NULL,
`IPREACTID` int(11) DEFAULT NULL,
`ISTAFFID` varchar(60) DEFAULT NULL,
`CTITLE` varchar(7500) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`IPRETASKID` varchar(20) DEFAULT NULL,
`IPROCESSID` int(11) DEFAULT NULL,
`DTASKTIME` timestamp NULL DEFAULT CURRENT_TIMESTAMP COMMENT '任务生成时间',
PRIMARY KEY (`ISERIALNO`),
KEY `index_istakid` (`ITASKID`) USING BTREE,
KEY `index_istaffid` (`ISTAFFID`) USING BTREE,
KEY `index_iserialno_itaskid` (`ITASKID`,`ISERIALNO`) USING BTREE,
KEY `index_ICURRACTID` (`ICURRACTID`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
drop table if exists fw_def_activity;
CREATE TABLE `fw_def_activity` (
`I_ACTIVITY_ID` int(11) NOT NULL DEFAULT '0' COMMENT '环节ID',
`C_ACTIVITY_NAME` varchar(32) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`I_PROCESS_ID` varchar(6) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`I_ACTIVITY_TYPE` varchar(5) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`I_ROLE_IDS` varchar(128) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
`C_FORMID` varchar(32) CHARACTER SET utf8 COLLATE utf8_bin DEFAULT NULL,
PRIMARY KEY (`I_ACTIVITY_ID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
drop table if exists tb_sys_loginmsg_his;
CREATE TABLE `tb_sys_loginmsg_his` (
`login_id` varchar(60) CHARACTER SET utf8 NOT NULL,
`name` varchar(150) CHARACTER SET utf8 NOT NULL,
`login_passwd` varchar(300) CHARACTER SET utf8 NOT NULL,
`login_phone` varchar(60) CHARACTER SET utf8 DEFAULT NULL,
`login_state` varchar(3) CHARACTER SET utf8 DEFAULT NULL,
`comp_id` varchar(30) CHARACTER SET utf8 DEFAULT NULL,
`dept_id` varchar(30) CHARACTER SET utf8 DEFAULT NULL,
`email_addr` varchar(180) CHARACTER SET utf8 DEFAULT NULL,
`lockstate` varchar(6) CHARACTER SET utf8 DEFAULT NULL,
`user_id` varchar(120) CHARACTER SET utf8 DEFAULT NULL,
`local_phone` varchar(90) CHARACTER SET utf8 DEFAULT NULL,
`audit_level` varchar(3) CHARACTER SET utf8 DEFAULT NULL,
`parent_login_id` varchar(60) CHARACTER SET utf8 DEFAULT NULL,
`last_passwd` varchar(300) CHARACTER SET utf8 DEFAULT NULL,
`last_modify` varchar(32) CHARACTER SET utf8 DEFAULT NULL,
`LOGIN_SOURCE` varchar(20) CHARACTER SET utf8 DEFAULT NULL,
`LOGIN_CARD` varchar(20) CHARACTER SET utf8 DEFAULT NULL,
`MAIN_GROUP_ID` varchar(32) CHARACTER SET utf8 DEFAULT NULL,
`MAIN_ROLE_ID` varchar(32) CHARACTER SET utf8 DEFAULT NULL,
`CREATE_TIME` datetime DEFAULT NULL,
`account4A` varchar(32) CHARACTER SET utf8 NOT NULL,
`SYSTEM_ID` varchar(32) CHARACTER SET utf8 NOT NULL,
`SYSTEM_NAME` varchar(32) CHARACTER SET utf8 DEFAULT NULL,
PRIMARY KEY (`login_id`,`account4A`,`SYSTEM_ID`),
KEY `index_tb_sys_loginmsg_login_id` (`login_id`) USING BTREE,
KEY `index_tb_sys_loginmsg_login_id1` (`name`) USING BTREE
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
drop table if exists tb_chngroup_dict;
CREATE TABLE `tb_chngroup_dict` (
`group_id` varchar(20) COLLATE utf8_bin NOT NULL COMMENT '行政机构编码',
`group_name` varchar(200) COLLATE utf8_bin DEFAULT NULL COMMENT '行政机构名称',
`has_child` varchar(1) COLLATE utf8_bin DEFAULT NULL COMMENT 'Y:有 N:没有',
`is_active` varchar(1) COLLATE utf8_bin DEFAULT NULL COMMENT 'Y:有效 N:无效',
`parent_group_id` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`parent_group_id1` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`parent_group_id2` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`ORDERING` int(20) DEFAULT '999',
`TYPE` int(20) DEFAULT NULL,
`GROUP_level` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`channel_type` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`parent_group_id3` varchar(30) COLLATE utf8_bin DEFAULT NULL,
`CITY_G_ID` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '地市GROUP_ID',
`CITY_G_NAME` varchar(200) COLLATE utf8_bin DEFAULT NULL COMMENT '地市名称',
`AREA_G_ID` varchar(20) COLLATE utf8_bin DEFAULT NULL COMMENT '区县GROUP_ID',
`AREA_G_NAME` varchar(200) COLLATE utf8_bin DEFAULT NULL COMMENT '区县名称',
PRIMARY KEY (`group_id`),
KEY `IDX_GROUP_DICT_C_G` (`CITY_G_ID`),
KEY `IDX_GROUP_DICT_A_G` (`AREA_G_ID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
drop table if exists bs_district;
CREATE TABLE `bs_district` (
`DISTRICT_ID` varchar(20) COLLATE utf8_bin NOT NULL,
`REGION_ID` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`DISTRICT_NAME` varchar(200) COLLATE utf8_bin DEFAULT NULL,
`DISTRICT_TYPE_ID` varchar(20) COLLATE utf8_bin DEFAULT NULL,
`PARENT_DISTRICT_ID` varchar(20) COLLATE utf8_bin DEFAULT NULL,
PRIMARY KEY (`DISTRICT_ID`),
KEY `1` (`REGION_ID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
drop table if exists tb_chngroup_rel;
CREATE TABLE `tb_chngroup_rel` (
`group_id` varchar(10) COLLATE utf8_bin NOT NULL COMMENT '行政机构编码',
`parent_group_id` varchar(10) COLLATE utf8_bin NOT NULL COMMENT '行政机构上级编码',
`denorm_level` int(6) DEFAULT NULL COMMENT '本节点与上级节点的距离',
`parent_level` int(10) DEFAULT NULL COMMENT '本节点与根节点的距离',
`current_level` int(10) DEFAULT NULL COMMENT '当前节点深度',
PRIMARY KEY (`group_id`,`parent_group_id`),
KEY `idx_group_id_parent_1` (`parent_group_id`,`denorm_level`),
KEY `idx_group_id_parent_2` (`group_id`,`denorm_level`),
KEY `idx_group_id_parent_3` (`group_id`),
KEY `idx_group_id_parent_4` (`parent_group_id`),
KEY `idx_group_id_parent_5` (`denorm_level`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COLLATE=utf8_bin;
explain select
AUDIT.*
FROM TB_FLOW_ISER_AUDIT AUDIT 
JOIN audit_PK_NODE00050_simple202108 simple ON AUDIT.REGULAR_SERIALNO = simple.REGULAR_SERIALNO 
LEFT JOIN audit_PK_NODE00050_error202108 error ON AUDIT.REGULAR_SERIALNO = error.REGULAR_SERIALNO 
LEFT JOIN audit_regular_simple_dictionary dictionary1 on simple.node1=dictionary1.code and dictionary1.codetype='NODE1' 
LEFT JOIN audit_regular_simple_dictionary dictionary2 on simple.node2=dictionary2.code and dictionary2.codetype='NODE1'
LEFT JOIN TB_FLOW_INSTANCE_HIS HIS_INSTANCE ON AUDIT.ISERIALNO = HIS_INSTANCE.ISERIALNO 
LEFT JOIN tb_flow_danjzhg danjzhg on danjzhg.iserialno = AUDIT.iserialno 
LEFT JOIN TB_FLOW_INSTANCE INSTANCE ON AUDIT.ISERIALNO = INSTANCE.ISERIALNO 
LEFT JOIN AUDIT_REGULAR_NODE NODE ON AUDIT.NODE_ID = NODE.NODE_ID 
LEFT JOIN TB_SYS_CODE CODETYPE ON AUDIT.PRO_STATUS = CODETYPE.CODE 
LEFT JOIN TO_DO_TASK_LIST LIST1 ON AUDIT.ISERIALNO = LIST1.ISERIALNO
LEFT JOIN fw_def_activity ACT ON LIST1.ICURRACTID = ACT.I_ACTIVITY_ID 
LEFT JOIN TB_SYS_LOGINMSG_HIS LOGINMSG ON LIST1.ISTAFFID = LOGINMSG.LOGIN_ID 
LEFT JOIN tb_chngroup_dict DICT ON AUDIT.REGION_CODE = DICT.GROUP_ID
LEFT JOIN bs_district BS1 ON BS1.district_id = DICT.PARENT_GROUP_ID1 
LEFT JOIN bs_district BS2 ON BS2.district_id = DICT.PARENT_GROUP_ID2
INNER JOIN TB_CHNGROUP_REL REL1 ON AUDIT.REGION_CODE = REL1.GROUP_ID
WHERE CODETYPE.CODETYPE = 'PRO_STATUS' AND NODE.NODE_ID='PK_NODE00050' limit 100;
