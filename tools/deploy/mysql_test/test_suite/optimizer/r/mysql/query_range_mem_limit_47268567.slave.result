GROUP  BY B.`district_name`,
A.iserialno) T
GROUP  BY district_name) QIANGZHI
ON QIANGZHI.district_name =
PAIDANLAING.district_name) MM
UNION ALL
SELECT PAIDANLAING.district_name,
PAIDANLAING.task        AS PAIDANLIANGLIANGSM,
HUIDAN.huidansm         AS HUIDANDATA,
SHENPITONGGUO.kuandaiyi AS SHENPITONGGUOSM,
ZAIZHENGGAI.kuandaier   AS ZAIZHENGGAISM,
YIDONGYICI.yidongyism   AS YIDONGYICISM,
YIDONGERCI.yidongercism AS YIDONGERCISM,
QIANGZHI.qiangzhigd     AS QIANGZHISM
FROM   (SELECT district_name,
Count(*) TASK
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id = DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE Concat('202211', '%')
AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                   ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                       ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                       ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                       ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                       ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
GROUP  BY B.`district_name`,
A.iserialno) T
GROUP  BY district_name) PAIDANLAING
LEFT JOIN (SELECT t.district_name,
Count(*) huidansm
FROM   (SELECT b.`district_name`
                                  FROM   tb_flow_iser_audit a
LEFT JOIN tb_chngroup_dict DICT
ON a.region_code = DICT.group_id
LEFT JOIN bs_district b
ON b.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node node
ON node.node_id = a.node_id
INNER JOIN tb_flow_form c
ON a.iserialno = c.iserialno
WHERE  a.regular_datatime LIKE
Concat('202211', '%')
AND a.regular_datatime >=
Date_format(Date_sub(Now(),
INTERVAL 3 month
),
'%Y%m%d')
AND c.is_pass IN ( '1', '1B' )
AND c.icurractid IN (
'50009603', '50010304',
'50010404',
'50010405',
'50010305', '50010905' )
AND node.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00535',
'PK_NODE00388'
                                                 ,
'PK_NODE00500', 'PK_NODE00481',
'PK_NODE00499',
'PK_NODE00743'
                                                 ,
'PK_NODE00886', 'PK_NODE00627',
'PK_NODE00977',
'PK_NODE01004'
                                                 ,
'PK_NODE01015', 'PK_NODE01154',
'PK_NODE01152' )
GROUP  BY b.`district_name`,
a.iserialno) t
GROUP  BY district_name) HUIDAN
ON HUIDAN.district_name = PAIDANLAING.district_name
LEFT JOIN (SELECT district_name,
Count(*) KUANDAIYI
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE
Concat('202211', '%')
AND C.icurractid = '50010905'
                                         AND A.pro_status = '1'
                                         AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                                 ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                                 ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                                 ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
GROUP  BY B.`district_name`,
A.iserialno
HAVING Count(*) = 1) T
GROUP  BY district_name) SHENPITONGGUO
ON SHENPITONGGUO.district_name = PAIDANLAING.district_name
LEFT JOIN (SELECT district_name,
Count(*) KUANDAIER
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE
Concat('202211', '%')
AND C.icurractid = '50010905'
                                         AND A.pro_status = '1'
                                         AND A.no_audit != '1'
                                         AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                                 ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                                 ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                                 ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
GROUP  BY B.`district_name`,
A.iserialno
HAVING Count(*) > 1) T
GROUP  BY district_name) ZAIZHENGGAI
ON ZAIZHENGGAI.district_name = PAIDANLAING.district_name
LEFT JOIN (SELECT district_name,
Count(*) YIDONGYISM
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE
Concat('202211', '%')
AND C.icurractid IN (
'50009603', '50010304',
'50010404',
'50010405',
'50010305'
                                                             )
AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                                 ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                                 ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                                 ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
AND C.is_pass IN ( '1', '1B', '1A' )
AND A.pro_status = '1'
                                  GROUP  BY B.`district_name`,
A.iserialno
HAVING Count(*) = 1) T
GROUP  BY district_name) YIDONGYICI
ON YIDONGYICI.district_name = PAIDANLAING.district_name
LEFT JOIN (SELECT district_name,
Count(*) YIDONGERCISM
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE
Concat('202211', '%')
AND A.no_audit != '1'
                                         AND C.icurractid IN (
'50009603', '50010304',
'50010404',
'50010405',
'50010305'
                                                             )
AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                                 ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                                 ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                                 ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
AND C.is_pass IN ( '1', '1B', '1A' )
AND A.pro_status = '1'
                                  GROUP  BY B.`district_name`,
A.iserialno
HAVING Count(*) > 1) T
GROUP  BY district_name) YIDONGERCI
ON YIDONGERCI.district_name = PAIDANLAING.district_name
LEFT JOIN (SELECT district_name,
Count(*) QIANGZHIGD
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
LEFT JOIN bs_district B
ON B.district_id =
DICT.parent_group_id2
LEFT JOIN audit_regular_node NODE
ON NODE.node_id = A.node_id
INNER JOIN tb_flow_form C
ON A.iserialno = C.iserialno
WHERE  A.regular_datatime LIKE
Concat('202211', '%')
AND A.pro_status = '10'
                                         AND NODE.node_id IN (
'PK_NODE00453', 'PK_NODE00451',
'PK_NODE00501',
'PK_NODE00424'
                                             ,
'PK_NODE00697', 'PK_NODE00422',
'PK_NODE00627',
'PK_NODE00571'
                                                 ,
'PK_NODE00524', 'PK_NODE00572',
'PK_NODE00388',
'PK_NODE00500'
                                                 ,
'PK_NODE00481', 'PK_NODE01015',
'PK_NODE01004',
'PK_NODE00977'
                                                 ,
'PK_NODE00627', 'PK_NODE00886',
'PK_NODE00743',
'PK_NODE00499'
                                                 ,
'PK_NODE00535', 'PK_NODE01154',
'PK_NODE01152' )
GROUP  BY B.`district_name`,
A.iserialno) T
GROUP  BY district_name) QIANGZHI
ON QIANGZHI.district_name = PAIDANLAING.district_name) K
WHERE  k.district_name LIKE Concat('%', '');
