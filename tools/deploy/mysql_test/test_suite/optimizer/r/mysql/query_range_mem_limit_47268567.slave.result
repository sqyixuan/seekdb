SELECT /*+no_rewrite*/Count(0)
FROM   (SELECT '总计'            AS DISTRICT_NAME,
MM.paidanlaingsm    AS PAIDANLIANGLIANGSM,
MM.huidandata       AS HUIDANSM,
MM.kuandaiyidata    AS SHENPITONGGUOSM,
MM.kuandaierdata    AS ZAIZHENGGAISM,
MM.yidongyismdata   AS YIDONGYICISM,
MM.yidongercismdata AS YIDONGERCISM,
MM.qiangzhigddata   AS QIANGZHISM
FROM   (SELECT Sum(PAIDANLAING.task)        AS PAIDANLAINGSM,
Sum(HUIDAN.huidansm)         AS HUIDANDATA,
Sum(SHENPITONGGUO.kuandaiyi) AS KUANDAIYIDATA,
Sum(ZAIZHENGGAI.kuandaier)   AS KUANDAIERDATA,
Sum(YIDONGYICI.yidongyism)   AS YIDONGYISMDATA,
Sum(YIDONGERCI.yidongercism) AS YIDONGERCISMDATA,
Sum(QIANGZHI.qiangzhigd)     AS QIANGZHIGDDATA
FROM   (SELECT district_name,
Count(*) TASK
FROM   (SELECT B.`district_name`,
A.iserialno
FROM   tb_flow_iser_audit A
LEFT JOIN tb_chngroup_dict DICT
ON A.region_code = DICT.group_id
