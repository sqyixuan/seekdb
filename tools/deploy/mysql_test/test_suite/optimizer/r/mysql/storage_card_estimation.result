-------------------------------------
  0 - output([a.c1], [a.c2], [a.c3], [b.c1], [b.c2], [b.c3]), filter(nil), rowset=256
      equal_conds([a.c1 = b.c3]), other_conds(nil)
      merge_directions([ASC])
  1 - output([a.c2], [a.c1], [a.c3]), filter(nil), rowset=256
      access([a.__pk_increment], [a.c2], [a.c1], [a.c3]), partitions(p2)
      is_index_back=true, is_global_index=false, 
      range_key([a.c2], [a.c1], [a.shadow_pk_0]), range(11,MIN,MIN ; 11,MAX,MAX), 
      range_cond([a.c2 = 11])
  2 - output([b.c2], [b.c3], [b.c1]), filter(nil), rowset=256
      access([b.__pk_increment], [b.c2], [b.c3], [b.c1]), partitions(p2)
