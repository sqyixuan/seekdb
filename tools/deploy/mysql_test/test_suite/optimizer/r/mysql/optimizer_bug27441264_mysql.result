result_format: 4
explain_protocol: 2
use opt_tpch;

##
##test group by no push down
EXPLAIN SELECT
         /*+parallel(512)*/
         c_count,
         Count(*) AS custdist
FROM     (
                   SELECT    c_custkey,
                             Count(o_orderkey) as c_count
                   FROM      customer
                   LEFT JOIN orders
                   ON        c_custkey = o_custkey
                   AND       o_comment NOT LIKE '%special%requests%'
                   GROUP BY  c_custkey) c_orders
GROUP BY c_count
ORDER BY custdist DESC,
         c_count DESC;
Query Plan
