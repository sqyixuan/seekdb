      sort_keys([T_FUN_COUNT_SUM(T_FUN_COUNT(*)), DESC], [CASE WHEN VIEW1.T_FUN_COUNT(orders.o_orderkey) IS NOT NULL THEN VIEW1.T_FUN_COUNT(orders.o_orderkey) 
