      dop=512
  2 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))], [CASE WHEN VIEW1.T_FUN_COUNT(orders.o_orderkey) IS NOT NULL THEN VIEW1.T_FUN_COUNT(orders.o_orderkey) ELSE 
      0 END]), filter(nil), rowset=256
