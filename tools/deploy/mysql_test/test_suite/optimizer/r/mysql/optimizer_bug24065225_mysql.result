      access([t1.__pk_increment], [t1.c1], [t1.c2]), partitions(p[0-2])
      is_index_back=true, is_global_index=false, 
      range_key([t1.c1], [t1.__pk_increment]), range(0,MIN ; 0,MAX), (1,MIN ; 1,MAX), (3,MIN ; 3,MAX), (4,MIN ; 4,MAX), (6,MIN ; 6,MAX), (7,MIN ; 7,MAX),
       (9,MIN ; 9,MAX), (10,MIN ; 10,MAX), (11,MIN ; 11,MAX), 
      range_cond([t1.c1 IN (0, 1, 3, 4, 6, 7, 9, 10, 11)])
