drop table if exists t1, t2, t3, t4;
create table t1 (id int, c1 int, c2 int, c3 int,
primary key(id, c1),
index t1_idx_c2(c2) local,
index t1_gidx_c2(c2) global)
partition by hash(c1) partitions 5;
create table t2 (id int, c1 int, c2 int, c3 int,
primary key(id, c1),
index t2_idx_c2(c2) local)
partition by hash(c1) partitions 5;
create index t2_gidx_c2 on t2(c2) global partition by hash(c2) partitions 5;
create table t3 (c1 int primary key) partition by hash(c1) partitions 4;
create table t4 (c1 int primary key);
explain_protocol: 2
result_format: 4
