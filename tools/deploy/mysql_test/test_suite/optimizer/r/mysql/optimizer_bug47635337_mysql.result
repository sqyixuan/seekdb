drop table if exists t1;
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
explain_protocol: 2
result_format: 4
EXPLAIN select * from t1 for update;
Query Plan
=================================================================
|ID|OPERATOR                     |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |MATERIAL                     |        |4       |16          |
|1 |└─PX COORDINATOR             |        |4       |15          |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000|4       |13          |
|3 |    └─DISTRIBUTED FOR UPDATE |        |4       |9           |
|4 |      └─PX PARTITION ITERATOR|        |4       |9           |
|5 |        └─TABLE FULL SCAN    |t1      |4       |9           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      dop=1
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      lock tables(t1)
  4 - output([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      force partition granule
  5 - output([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 for update;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    4 |    4 |    4 |
|    1 |    1 |    1 |
|    2 |    2 |    2 |
|    3 |    3 |    3 |
+------+------+------+

EXPLAIN select * from t1 where c1 = 0 for update;
Query Plan
========================================================
|ID|OPERATOR                |NAME|EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |MATERIAL                |    |1       |3           |
|1 |└─DISTRIBUTED FOR UPDATE|    |1       |3           |
|2 |  └─TABLE FULL SCAN     |t1  |1       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      lock tables(t1)
  2 - output([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), filter([t1.c1 = 0]), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where c1 = 0 for update;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
+------+------+------+

drop table if exists t1;
