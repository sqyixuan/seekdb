result_format: 4
explain_protocol: 2
explain WITH RECURSIVE temp AS
(
SELECT /*+ leading((a c) t) use_nl(t) use_hash_aggregation */ distinct t.cat_id,cast(t.name as char(1000)) name ,sum(t.product_count) sum_count ,t.parent_cid ,c.prices,c.num FROM t_2 t RIGHT JOIN t_1 a ON t.cat_id=a.cat_id INNER JOIN t_3 c ON a.num=c.num GROUP BY t.cat_level
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,1,c.parent_cid,r.prices,r.num FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id)
)
SELECT sum(r.prices)*sum(sum_count) FROM temp r;
Query Plan
=================================================================
|ID|OPERATOR                       |NAME  |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |SCALAR GROUP BY                |      |1       |130         |
|1 |└─SUBPLAN SCAN                 |temp  |6       |130         |
|2 |  └─RECURSIVE UNION ALL        |      |6       |130         |
|3 |    ├─HASH GROUP BY            |      |5       |121         |
|4 |    │ └─NESTED-LOOP OUTER JOIN |      |7       |119         |
|5 |    │   ├─MERGE JOIN           |      |7       |6           |
|6 |    │   │ ├─TABLE FULL SCAN    |a(num)|8       |3           |
|7 |    │   │ └─TABLE FULL SCAN    |c     |7       |3           |
|8 |    │   └─TABLE GET            |t     |1       |16          |
|9 |    └─HASH JOIN                |      |1       |9           |
|10|      ├─MATERIAL               |      |1       |7           |
|11|      │ └─MERGE JOIN           |      |1       |7           |
|12|      │   ├─TABLE FULL SCAN    |c     |1       |4           |
|13|      │   └─TABLE FULL SCAN    |t_1   |6       |3           |
|14|      └─TABLE FULL SCAN        |r     |5       |1           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([cast(T_FUN_SUM(r.prices), DECIMAL_INT(80, 2)) * cast(T_FUN_SUM(r.sum_count), DECIMAL_INT(80, 0))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(r.prices)], [T_FUN_SUM(r.sum_count)])
  1 - output([r.prices], [r.sum_count]), filter(nil), rowset=16
      access([r.prices], [r.sum_count])
  2 - output([UNION([1])], [UNION([2])], [UNION([3])], [UNION([4])], [UNION([5])], [UNION([6])]), filter(nil), rowset=16
  3 - output([t.cat_id], [cast(t.name, CHAR(1000))], [T_FUN_SUM(t.product_count)], [t.parent_cid], [c.prices], [c.num]), filter(nil), rowset=16
      group([t.cat_level]), agg_func([T_FUN_SUM(t.product_count)])
  4 - output([t.cat_level], [t.cat_id], [t.parent_cid], [c.prices], [c.num], [t.name], [t.product_count]), filter(nil), rowset=16
      conds(nil), nl_params_([a.cat_id(:0)]), use_batch=true
  5 - output([c.prices], [c.num], [a.cat_id]), filter(nil), rowset=16
      equal_conds([a.num = c.num]), other_conds(nil)
      merge_directions([ASC])
  6 - output([a.cat_id], [a.num]), filter(nil), rowset=16
      access([a.cat_id], [a.num]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([a.num], [a.shadow_pk_0]), range(MIN,MIN ; MAX,MAX)always true
  7 - output([c.num], [c.prices]), filter(nil), rowset=16
      access([c.num], [c.prices]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([c.num]), range(MIN ; MAX)always true
  8 - output([t.cat_id], [t.name], [t.product_count], [t.parent_cid], [t.cat_level]), filter(nil), rowset=16
      access([GROUP_ID], [t.cat_id], [t.name], [t.product_count], [t.parent_cid], [t.cat_level]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t.cat_id]), range(MIN ; MAX), 
      range_cond([t.cat_id = :0])
  9 - output([column_conv(INT,PS:(11,0),NULL,c.cat_id)], [column_conv(TEXT,utf8mb4_general_ci,length:16383,NULL,cast(CONCAT(cast(r.name, LONGTEXT(536870911)),
       cast('>', LONGTEXT(536870911)), cast(c.name, LONGTEXT(536870911))), TEXT(65536)))], [column_conv(DECIMAL_INT,PS:(27,0),NULL,cast(1, DECIMAL_INT(27, 0)))],
       [column_conv(DECIMAL_INT,PS:(5,0),NULL,c.parent_cid)], [column_conv(DECIMAL_INT,PS:(9,2),NULL,r.prices)], [column_conv(INT,PS:(11,0),NULL,r.num)]), filter(nil), rowset=16
      equal_conds([cast(c.cat_id, DECIMAL_INT(5, 0)) = r.parent_cid], [c.cat_id = r.cat_id], [c.name = r.name]), other_conds(nil)
 10 - output([c.cat_id], [c.name], [c.parent_cid], [cast(c.cat_id, DECIMAL_INT(5, 0))]), filter(nil), rowset=16
 11 - output([c.cat_id], [c.name], [c.parent_cid], [cast(c.cat_id, DECIMAL_INT(5, 0))]), filter(nil), rowset=16
      equal_conds([c.cat_id = t_1.cat_id]), other_conds(nil)
      merge_directions([ASC])
 12 - output([c.cat_id], [c.name], [c.parent_cid], [cast(c.cat_id, DECIMAL_INT(5, 0))]), filter([cast(c.cat_id, DECIMAL_INT(5, 0)) = c.parent_cid]), rowset=16
      access([c.cat_id], [c.name], [c.parent_cid]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([c.cat_id]), range(MIN ; MAX)always true
 13 - output([t_1.cat_id]), filter([t_1.product_time <= demote_cast('1988-04-07', MYSQL_DATE(10, 0))]), rowset=16
      access([t_1.cat_id], [t_1.product_time]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_1.cat_id]), range(MIN ; MAX)always true
 14 - output([r.cat_id], [r.name], [r.parent_cid], [r.prices], [r.num]), filter(nil), rowset=16
      access([r.cat_id], [r.name], [r.parent_cid], [r.prices], [r.num])
      is_index_back=false, is_global_index=false, 
      range_key(nil), range(MIN ; MAX)

WITH RECURSIVE temp AS
(
SELECT /*+ leading((a c) t) use_nl(t) use_hash_aggregation */ distinct t.cat_id,cast(t.name as char(1000)) name ,sum(t.product_count) sum_count ,t.parent_cid ,c.prices,c.num FROM t_2 t RIGHT JOIN t_1 a ON t.cat_id=a.cat_id INNER JOIN t_3 c ON a.num=c.num GROUP BY t.cat_level
UNION ALL
SELECT c.cat_id,CONCAT(r.name, '>', c.name) as name,1,c.parent_cid,r.prices,r.num FROM t_2 c NATURAL JOIN temp r WHERE  c.cat_id=r.parent_cid  AND
c.cat_id  IN (
select cat_id from t_1 where product_time<='1988-04-07' order by cat_id)
)
SELECT sum(r.prices)*sum(sum_count) FROM temp r;
+------------------------------+
| sum(r.prices)*sum(sum_count) |
+------------------------------+
|                   5384561.60 |
+------------------------------+

explain with recursive cte(n) as  (   select cat_id from t_1 union all select n + 1 from cte where n < 100 ) select sum(cat_id) from t_1,cte where t_1.cat_id = cte.n;
Query Plan
===========================================================
|ID|OPERATOR                   |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |SCALAR GROUP BY            |    |1       |7           |
|1 |└─MERGE JOIN               |    |8       |7           |
|2 |  ├─TABLE FULL SCAN        |t_1 |8       |3           |
|3 |  └─SORT                   |    |9       |4           |
|4 |    └─SUBPLAN SCAN         |cte |9       |4           |
|5 |      └─RECURSIVE UNION ALL|    |9       |4           |
|6 |        ├─TABLE FULL SCAN  |t_1 |8       |3           |
|7 |        └─TABLE FULL SCAN  |cte |1       |1           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(t_1.cat_id)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(t_1.cat_id)])
  1 - output([t_1.cat_id]), filter(nil), rowset=16
      equal_conds([t_1.cat_id = cte.n]), other_conds(nil)
      merge_directions([ASC])
  2 - output([t_1.cat_id]), filter(nil), rowset=16
      access([t_1.cat_id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t_1.cat_id]), range(MIN ; MAX)always true
  3 - output([cte.n]), filter(nil), rowset=16
      sort_keys([cte.n, ASC])
  4 - output([cte.n]), filter(nil), rowset=16
      access([cte.n])
  5 - output([UNION([1])]), filter(nil), rowset=16
  6 - output([t_1.cat_id]), filter(nil), rowset=16
      access([t_1.cat_id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t_1.cat_id]), range(MIN ; MAX)always true
  7 - output([column_conv(INT,PS:(11,0),NULL,cast(cte.n + 1, INT(-1, 0)))]), filter([cte.n < 100]), rowset=16
      access([cte.n])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key(nil), range(MIN ; MAX)

drop table t_1;
drop table t_2;
drop table t_3;
