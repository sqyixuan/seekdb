CREATE TABLE `fin_trans_order_41` (
`order_id` varchar(64) NOT NULL COMMENT '订单ID',
`user_id` varchar(16) NOT NULL COMMENT '用户ID',
`order_type` varchar(64) NOT NULL COMMENT '订单类型',
`apply_time` timestamp NOT NULL COMMENT '申请时间',
`order_status` varchar(16) NOT NULL COMMENT '订单状态',
PRIMARY KEY (`order_id`),
KEY `idx_fin_trans_order_ooa` (`order_type`, `order_status`, `apply_time`) BLOCK_SIZE 16384
);
