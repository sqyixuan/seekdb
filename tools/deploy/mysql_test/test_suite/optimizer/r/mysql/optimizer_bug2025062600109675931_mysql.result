drop table if exists t1,t11,t12;
drop table if exists t2;
drop table if exists dup1;
create table t1 (c1 int, c2 int, c3 int) ;
create table t2 (c1 int, c2 int, c3 int);
create table dup1 (c1 int, c2 int , c3 int);
explain select /*+ ordered */ * from t2, (select /*+ no_merge */ t1.c1 as t1c1, dup1.c1 as dc1 from t1, dup1 where t1.c1 = dup1.c1) v where t2.c1 = v.t1c1;
