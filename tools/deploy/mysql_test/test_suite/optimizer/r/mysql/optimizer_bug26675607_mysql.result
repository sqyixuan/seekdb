drop table if exists t1,t2,t3,t4;
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 3;
create table t2 (c1 int, c2 int, c3 int) partition by key(c1, c2) partitions 3;
create table t3 (c1 int, c2 int, c3 int) partition by hash(c1) 
subpartition by range (c2) subpartition template
(
subpartition p0 values less than (10),
subpartition p1 values less than (20),
subpartition p2 values less than (maxvalue)
) partitions 3;
create table t4 (c1 int, c2 int, c3 int);
insert into t1 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
(5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t2 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
(5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t3 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
(5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t4 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
(5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
result_format: 4
explain_protocol: 2
EXPLAIN select count(distinct c1) from t1;
