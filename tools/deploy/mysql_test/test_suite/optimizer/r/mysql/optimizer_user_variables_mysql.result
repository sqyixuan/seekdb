## 3. 用于分类
set @type := '', @num := 1;
EXPLAIN select type, variety,
       @num := if(@type = type, @num + 1, 1) as type_id,
       @type := type as dummy
from fruits
order by type, variety;
Query Plan
===============================================================
|ID|OPERATOR                     |NAME  |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |SORT                         |      |9       |5           |
|1 |└─DISTRIBUTED TABLE FULL SCAN|fruits|9       |3           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([fruits.type], [fruits.variety], [(T_OP_ASSIGN, 'num', CASE WHEN ('type') = fruits.type THEN ('num') + 1 ELSE 1 END)], [(T_OP_ASSIGN, 'type',
       fruits.type)]), filter(nil)
      sort_keys([fruits.type, ASC], [fruits.variety, ASC])
  1 - output([fruits.type], [fruits.variety]), filter(nil)
      access([fruits.type], [fruits.variety]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([fruits.id]), range(MIN ; MAX)always true
select type, variety,
       @num := if(@type = type, @num + 1, 1) as type_id,
       @type := type as dummy
from fruits
order by type, variety;
+--------+------------+---------+--------+
| type   | variety    | type_id | dummy  |
+--------+------------+---------+--------+
| apple  | fuji       |       1 | apple  |
| apple  | gala       |       2 | apple  |
| apple  | limbertwig |       3 | apple  |
| cherry | bing       |       1 | cherry |
| cherry | chelan     |       2 | cherry |
| orange | navel      |       1 | orange |
| orange | valencia   |       2 | orange |
| pear   | bartlett   |       1 | pear   |
| pear   | bradford   |       2 | pear   |
+--------+------------+---------+--------+

