drop table if exists t1,t2,t3,t4;
create table t1(a int, b int);
create table t2(a int, b int);
create table t3(a int, b int);
create table t4(a int, b int);
insert into t1 values (0,1);
insert into t2 values (0,1),(0,2);
insert into t3 values (0,1),(0,2),(0,3);
insert into t4 values (0,1),(0,2),(0,3),(0,4);
result_format: 4
explain_protocol: 1
EXPLAIN BASIC select /*+parallel(1)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
