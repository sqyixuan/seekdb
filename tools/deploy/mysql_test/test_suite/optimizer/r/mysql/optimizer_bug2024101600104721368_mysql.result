drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int, index idx1(c1,c2,c3,c4));
create index i1 on t1((c1 + c2)) global;
set @a = 0;
insert into t1 select level, level + 10, level + 20, level + 30
from (select @a := @a + 1 as level from table(generator(31)));
call dbms_stats.gather_table_stats('TEST', 'T1');
select sql_id,query_sql from oceanbase.gv$ob_sql_audit where sql_id = '753A0DB5EC4A499FE356963A594D0096' limit 1;
sql_id	query_sql
drop table t1;
