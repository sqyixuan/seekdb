drop table if exists t1;
drop table if exists plan_table;
result_format: 4
create table plan_table (
statement_id varchar(30),
plan_id int,
gmt_create timestamp,
remarks varchar(4000),
operator varchar(255),
options varchar(255),
object_node varchar(40),
object_owner varchar(128),
object_name varchar(128),
object_alias varchar(261),
object_instance int,
object_type varchar(30),
optimizer varchar(4000),
search_columns int,
id int,
parent_id int,
depth int,
position int,
is_last_child int,
cost int,
cardinality int,
bytes int,
rowset int,
other_tag varchar(4000),
partition_start varchar(4000),
partition_stop varchar(4000),
partition_id int,
other varchar(4000),
distribution varchar(64),
cpu_cost int,
io_cost int,
temp_space int,
access_predicates varchar(4000),
filter_predicates varchar(4000),
startup_predicates varchar(4000),
projection varchar(4000),
special_predicates varchar(4000),
time int,
qblock_name varchar(128),
other_xml varchar(4000)
);

create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;
create index i1 on t1(c2) global;

insert into t1 values(5,5,5);
insert into t1 values(4,4,4);
insert into t1 values(3,3,3);

预期DAS SCAN算子有keep_ordering=true
(select /*+NO_USE_HASH_SET(@"SET$1") index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1) union (select /*+ index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1);
+------+
| c3   |
+------+
|    3 |
+------+

预期DAS SCAN算子有keep_ordering=true
select /*+ index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1;
+------+
| c3   |
+------+
|    3 |
+------+

explain (select /*+NO_USE_HASH_SET(@"SET$1") index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1) union (select /*+ index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1);
Query Plan
=================================================================
|ID|OPERATOR                       |NAME  |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |MERGE UNION DISTINCT           |      |2       |61          |
|1 |├─SORT                         |      |1       |31          |
|2 |│ └─DISTRIBUTED TABLE FULL SCAN|t1(i1)|1       |31          |
|3 |└─SORT                         |      |1       |31          |
|4 |  └─DISTRIBUTED TABLE FULL SCAN|t1(i1)|1       |31          |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])]), filter(nil), rowset=16
  1 - output([t1.c3]), filter(nil), rowset=16
      sort_keys([t1.c3, ASC])
  2 - output([t1.c3]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c3]), partitions(p0)
      limit(1), offset(nil), is_index_back=true, is_global_index=true, keep_ordering=true, 
      range_key([t1.c2], [t1.__pk_increment], [t1.c1]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  3 - output([t1.c3]), filter(nil), rowset=16
      sort_keys([t1.c3, ASC])
  4 - output([t1.c3]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c3]), partitions(p0)
      limit(1), offset(nil), is_index_back=true, is_global_index=true, keep_ordering=true, 
      range_key([t1.c2], [t1.__pk_increment], [t1.c1]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
预期两个keep_ordering=true
select 
CASE
WHEN plan IS NULL OR CHAR_LENGTH(plan) = 0 THEN 0
WHEN plan IS NULL THEN 0
ELSE cast((CHAR_LENGTH(plan) - CHAR_LENGTH(REPLACE(plan, 'keep_ordering=true', ''))) / CHAR_LENGTH('keep_ordering=true') as decimal(7,0))
END AS count
from(
select dbms_xplan.display() as plan from dual);
+-------+
| count |
+-------+
|     2 |
+-------+

explain select /*+ index(t1 i1) use_das(t1)*/ c3 from t1 order by c2 limit 1;
Query Plan
=============================================================
|ID|OPERATOR                   |NAME  |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |DISTRIBUTED TABLE FULL SCAN|t1(i1)|1       |31          |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c3]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c1], [t1.c3]), partitions(p0)
      limit(1), offset(nil), is_index_back=true, is_global_index=true, keep_ordering=true, 
      range_key([t1.c2], [t1.__pk_increment], [t1.c1]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
预期一个keep_ordering=true
select 
CASE
WHEN plan IS NULL OR CHAR_LENGTH(plan) = 0 THEN 0
WHEN plan IS NULL THEN 0
ELSE cast((CHAR_LENGTH(plan) - CHAR_LENGTH(REPLACE(plan, 'keep_ordering=true', ''))) / CHAR_LENGTH('keep_ordering=true') as decimal(7,0))
END AS count
from(
select dbms_xplan.display() as plan from dual);
+-------+
| count |
+-------+
|     1 |
+-------+

drop table if exists t1;
drop table if exists plan_table;
