  subq_0.searchStr as subq_0_c0, 
  ref_1.c3
from 
  test.t_kms_a_key as subq_0 
  right join test.t1gy8zn0 as ref_1 on (
    (ref_1.c3 <> ref_1.c3) 
    and EXISTS (
      select 
        1
      from 
        test.t1ljvchu as ref_2 
      where 
        ref_1.c3
    )
  ) 
where 
  (ref_1.c3 <> ref_1.c3)  
limit 
