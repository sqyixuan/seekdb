CREATE TABLE `no_pk` (
`name` varchar(20) NOT NULL,
`age` int(10) NOT NULL,
`address` varchar(20) NOT NULL,
`sex` float NOT NULL,
`class` int(10) NOT NULL
);
create table if not exists `t1gbeh4t` (
`c1` varchar(10) not null comment 'c1 comment',
`c2` int(11),
`c3` int(11) comment '',
`c4` int(11),
`c5` int(11),
`c6` int(11),
`c7` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
comment='';
create index `i1` on `t1gbeh4t` (`c1` ASC) ;
create index `i2` on `t1gbeh4t` (`c2` ASC) ;
CREATE TABLE `cool_bill_20181009` (
`bill_id` int(11) NOT NULL AUTO_INCREMENT,
`trade_time` varchar(30) DEFAULT NULL ,
`app_id` varchar(20) DEFAULT NULL ,
`mch_id` varchar(30) DEFAULT NULL ,
`sub_mch` varchar(30) DEFAULT NULL ,
`device_id` varchar(50) DEFAULT NULL ,
`wx_order` varchar(50) DEFAULT NULL ,
`order_no` varchar(50) DEFAULT NULL ,
`openid` varchar(50) DEFAULT NULL ,
`trade_type` varchar(50) DEFAULT NULL ,
`trade_status` varchar(50) DEFAULT NULL ,
`bank` varchar(100) DEFAULT NULL ,
`cny` varchar(20) DEFAULT NULL ,
`total_money` varchar(20) DEFAULT NULL ,
`redpacket_money` varchar(20) DEFAULT NULL ,
`aprefund_time` varchar(30) DEFAULT NULL ,
`surefund_time` varchar(30) DEFAULT NULL ,
`wxrefund_no` varchar(50) DEFAULT NULL ,
`mcrefund_no` varchar(50) DEFAULT NULL ,
`refund_money` varchar(20) DEFAULT NULL ,
`redpacket_refund_money` varchar(20) DEFAULT NULL ,
`refund_type` varchar(20) DEFAULT NULL ,
`refund_status` varchar(20) DEFAULT NULL ,
`product_target_name` varchar(100) DEFAULT NULL ,
`data_packet` varchar(255) DEFAULT NULL ,
`fee` varchar(20) DEFAULT NULL ,
`rate` varchar(20) DEFAULT NULL ,
`business_id` varchar(100) DEFAULT NULL,
`door_id` varchar(100) DEFAULT NULL,
`pay_type` varchar(100) DEFAULT NULL ,
`pay_pass` varchar(100) DEFAULT NULL,
`agent_id` varchar(100) DEFAULT NULL ,
`agent_fr_fee` varchar(100) DEFAULT NULL ,
`qd_fr_fee` varchar(100) DEFAULT NULL ,
`td_cost_fee` varchar(100) DEFAULT NULL ,
`from_business_trade_id` varchar(128) DEFAULT NULL,
`bill_time` varchar(30) DEFAULT NULL,
`channel_id` int(10) DEFAULT NULL ,
`activity_type` varchar(30) DEFAULT NULL ,
`pay_log_id` varchar(40) DEFAULT NULL ,
`user_id` varchar(11) DEFAULT NULL ,
PRIMARY KEY (`bill_id`),
UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
KEY `mch_id_idx` (`mch_id`),
KEY `agent_id_idx` (`agent_id`),
KEY `bill_time_idx` (`bill_time`),
KEY `trade_time_idx` (`trade_time`),
KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB AUTO_INCREMENT=119478 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_inc_incident` (
`incId` int(10) NOT NULL AUTO_INCREMENT COMMENT ' 告警信息ID',
`incName` varchar(500) DEFAULT NULL COMMENT '告警信息名称',
`incLevel` int(20) DEFAULT NULL COMMENT '告警信息级别,1:一般,2：警告,3：严重,4：极度严重',
`incObjectUuid` varchar(100) DEFAULT NULL COMMENT '告警对象UUID',
`UUID` varchar(100) DEFAULT NULL COMMENT '设备uuid',
`categoryId` int(50) DEFAULT NULL COMMENT '告警类别Id',
`incContent` varchar(3000) DEFAULT NULL COMMENT '告警内容',
`incObjectType` int(10) DEFAULT NULL COMMENT '告警对象类型 1：实体机，2：应用',
`count` int(20) DEFAULT NULL COMMENT '告警次数',
`incPolicyId` varchar(20) DEFAULT NULL COMMENT 'incPolicyId',
`incStatus` int(20) DEFAULT '0' COMMENT '告警状态: 1,待确认；2,已确认',
`incCreatedOn` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '告警产生时间',
`incUpdatedOn` timestamp NULL DEFAULT NULL COMMENT '告警确认时间',
PRIMARY KEY (`incId`)
) ENGINE=InnoDB AUTO_INCREMENT=23 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_kms_a_key` (
`id` varchar(64) NOT NULL COMMENT '非对称密钥ID,UUID形式',
`create_by` varchar(50) DEFAULT NULL COMMENT '创建人登录名称',
`create_date` varchar(32) DEFAULT NULL COMMENT '创建日期',
`update_by` varchar(50) DEFAULT NULL COMMENT '更新人登录名称',
`update_date` varchar(32) DEFAULT NULL COMMENT '更新日期',
`key_name` varchar(50) NOT NULL COMMENT '别名',
`key_algorithm` varchar(32) NOT NULL COMMENT '密钥算法',
`begin_date` varchar(32) DEFAULT NULL COMMENT '生效日期',
`expiry_date` varchar(32) DEFAULT NULL COMMENT '有效期',
`key_length` varchar(32) DEFAULT NULL COMMENT '密钥长度',
`key_purpose` varchar(50) DEFAULT NULL COMMENT '用途加密数据kp1解密数据kp2生成验证MACkp3派生密钥kp5加密导出导入其他密钥kp6解密数据密钥kp7生成索引kp8',
`key_describe` longtext COMMENT '描述',
`key_state` varchar(2) DEFAULT NULL COMMENT '状态11已创建21已生成31已启用22已停用12已归档',
`symm_e` varchar(10) DEFAULT NULL COMMENT '公钥指数E',
`is_imme` varchar(5) DEFAULT NULL COMMENT '是否立即生成',
`curve` varchar(32) DEFAULT NULL COMMENT '曲线参数',
`public_key` longtext COMMENT '公钥',
`private_key` longtext COMMENT '私钥',
`key_version` int(5) DEFAULT NULL COMMENT '版本号',
`searchStr` varchar(512) DEFAULT NULL COMMENT '搜索条件拼接',
PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `t_kms_equip_group` (
`group_id` varchar(36) NOT NULL COMMENT 'f分组id',
`group_name` varchar(36) DEFAULT NULL COMMENT '分组名称',
`equip_desc` varchar(255) DEFAULT NULL COMMENT '描述',
`create_time` varchar(32) DEFAULT NULL COMMENT '创建时间',
`app_id` varchar(36) DEFAULT NULL COMMENT '应用id',
PRIMARY KEY (`group_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `t1gy8zn0` (
`c1` varchar(1),
`c2` varchar(1),
`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
create table if not exists `t1ljvchu` (
`pk` int(11) not null,
`a` int(11),
primary key (`pk`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
CREATE TABLE `t_mon_statistics_lock` (
`uuid` varchar(50) NOT NULL DEFAULT '',
`createDate` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '时间',
PRIMARY KEY (`uuid`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;
