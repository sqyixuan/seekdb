drop table if exists d1,d2;
create table d1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;
create table d2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;
insert into d1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6);
insert into d2 values (1,1,1),(2,null,2),(3,3,3),(4,4,null),(null,null,null);
result_format: 4
explain_protocol: 2
set ob_enable_transformation = 0;
explain with temp1 as (select /*+no_gby_pushdown*/ c3, min(c2) as m from d1 group by c3), temp2 as (select /*+no_gby_pushdown*/ c2, min(c3) as m from d2 group by c2) SELECT /*+parallel(2) */ * FROM (select * from temp1 union all select * from temp2);
