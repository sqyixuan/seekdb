      distinct([T_WIN_FUN_ROW_NUMBER()])
  1 - output([T_WIN_FUN_ROW_NUMBER()]), filter(nil), rowset=256
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
