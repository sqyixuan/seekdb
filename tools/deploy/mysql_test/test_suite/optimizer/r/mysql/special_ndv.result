# create table for test
result_format: 4
drop table if exists uniform_t;
drop database if exists special_ndv;
create database special_ndv;
use special_ndv;
create table uniform_t (c1 int, c2 int);
insert into uniform_t select uniform(1,10,random(3)), abs(random(3)%40) from table(generator(1000));
call DBMS_STATS.GATHER_TABLE_STATS('special_ndv','uniform_t');
select COLUMN_NAME, NUM_DISTINCT from oceanbase.DBA_TAB_COL_STATISTICS where table_name ='uniform_t' and OWNER='special_ndv';
+-------------+--------------+
| COLUMN_NAME | NUM_DISTINCT |
+-------------+--------------+
| c1          |           10 |
| c2          |           40 |
+-------------+--------------+

----------------------------test row_number----------------------------
select count(1) from ( select distinct row_number() over () from uniform_t);
+----------+
| count(1) |
+----------+
|     1000 |
+----------+
explain select * from ( select distinct row_number() over () from uniform_t);
Query Plan
========================================================
|ID|OPERATOR           |NAME     |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |HASH DISTINCT      |         |1000    |900         |
|1 |└─WINDOW FUNCTION  |         |1000    |660         |
|2 |  └─TABLE FULL SCAN|uniform_t|1000    |5           |
========================================================
