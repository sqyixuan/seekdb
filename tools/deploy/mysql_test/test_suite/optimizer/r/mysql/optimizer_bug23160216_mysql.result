drop table if exists table2_bigint, table10_bigint, table100_bigint;
CREATE TABLE table2_bigint (
col_char_20 char(20),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
pk bigint,
col_bigint bigint,
col_decimal_20_0 decimal(20,0),
/*Indices*/
primary key (pk) ) ;
CREATE TABLE table10_bigint (
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
pk bigint,
col_char_20 char(20),
/*Indices*/
primary key (pk) ) ;
CREATE TABLE table100_bigint (
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_char_20 char(20),
pk bigint,
/*Indices*/
primary key (pk) ) ;
result_format: 4
explain_protocol: 2
EXPLAIN SELECT pk
FROM table10_bigint
WHERE (col_decimal_20_0, pk) = ANY
    (SELECT col_decimal_20_0, col_bigint
     FROM table100_bigint
     WHERE (SELECT (SELECT col_bigint FROM table2_bigint order by col_bigint desc LIMIT 1)) <=> ROUND(col_decimal_20_0));
