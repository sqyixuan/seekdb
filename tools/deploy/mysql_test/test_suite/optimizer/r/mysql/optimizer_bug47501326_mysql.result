drop table if exists t4;
drop table if exists t19;
create table t4 (c1 TIMESTAMP(1)  NOT NULL default 0,c2 INT(127) ,c3 DATE,c4 CHAR(152) ,c5 BINARY(131) ,c6 BIGINT(127) ,c7 DECIMAL(64,20) ,c8 YEAR(4) ,c9 VARBINARY(58) ,c10 DATETIME,c11 CHAR(152) ,c12 YEAR(4) ,c13 YEAR(4) ,c14 INT(127) ,c15 TIME,c16 YEAR(4) , primary key(c13,c12,c16,c4,c8,c5,c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c13+c12+c16+c8) PARTITIONS 168;
create table t19 (c1 DATETIME,c2 DATE,c3 DATETIME,c4 VARCHAR(86) ,c5 BINARY(131) ,c6 BIGINT(127) ,c7 NUMERIC(64,20) ,c8 BIGINT(127) ,c9 VARCHAR(86) ,c10 DATETIME,c11 DATE,c12 YEAR(4) ,c13 VARBINARY(86) , primary key(c8,c9,c1))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c8) PARTITIONS 26;
explain_protocol: 2
result_format: 4
EXPLAIN select count(*) from t4 RIGHT JOIN t19 ON t19.c8 > '695' AND t19.c7 = t19.c7 ;
