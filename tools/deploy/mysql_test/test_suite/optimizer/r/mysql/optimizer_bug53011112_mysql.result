drop table if exists t1;
create table t1(c1 int, c2 varchar(100), c3 int);
insert into t1 values(1, 'a', 3);
insert into t1 values(1, 'A', 3);
explain_protocol: 1
result_format: 4
EXPLAIN BASIC select distinct c1, c1 + 1 from t1;
Query Plan
===========================
|ID|OPERATOR         |NAME|
---------------------------
|0 |HASH DISTINCT    |    |
|1 |└─TABLE FULL SCAN|t1  |
===========================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c1 + 1]), filter(nil), rowset=16
      distinct([t1.c1])
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select distinct c1, c1 + 1 from t1;
+------+--------+
| c1   | c1 + 1 |
+------+--------+
|    1 |      2 |
+------+--------+
