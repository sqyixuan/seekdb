drop table if exists t1,t2,t3;
create table t1(pk int primary key, c1 int, c2 int, c3 int, index i1(c1, c2));
insert into t1 select row_number() over (), uniform(0, 99, random(1)), uniform(0, 99, random(2)), uniform(0, 99, random(3)) from table(generator(10000));
call dbms_stats.gather_table_stats(null, 't1');
create table t2(pk int primary key, c1 int, c2 int, c3 int, index i1(c1,c2,c3));
create table t3(pk int primary key, c1 int, c2 int, c3 int) with column group (each column);
create index i1 on t3(c1,c2,c3) with column group (each column);
create index i2 on t3(c3,c2,c1) with column group (all columns);
insert into t3 select row_number() over (), uniform(0, 99, random(1)), uniform(0, 99, random(2)), uniform(0, 99, random(3)) from table(generator(10000));
call dbms_stats.gather_table_stats(null, 't3');
set _ENABLE_STORAGE_CARDINALITY_ESTIMATION = 0;
explain_protocol: 2
result_format: 4
EXPLAIN select count(*) from t1 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0);
