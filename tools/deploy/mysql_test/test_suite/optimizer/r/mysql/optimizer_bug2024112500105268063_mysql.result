      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
  1 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      access(nil), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2], [t1.pk]), range(1,1,MIN ; 1,1,MAX), (1,2,MIN ; 1,2,MAX), (1,3,MIN ; 1,3,MAX), (1,4,MIN ; 1,4,MAX), (1,5,MIN ; 1,5,MAX),
       (1,6,MIN ; 1,6,MAX), (1,7,MIN ; 1,7,MAX), (1,8,MIN ; 1,8,MAX), (1,9,MIN ; 1,9,MAX), (1,0,MIN ; 1,0,MAX), 
      range_cond([t1.c1 = 1], [t1.c2 IN (1, 2, 3, 4, 5, 6, 7, 8, 9, 0)]), 
      pushdown_aggregation([T_FUN_COUNT(*)])
select count(*) from t1 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0);
