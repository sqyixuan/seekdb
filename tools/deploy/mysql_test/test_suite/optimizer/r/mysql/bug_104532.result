set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop table if exists table2_key_pk_parts_2_int;
CREATE TABLE table2_key_pk_parts_2_int (
col_int_key INT
, col_char_12 VARCHAR(12)
, col_int INT
, col_char_12_key VARCHAR(12)
, pk INT
, PRIMARY KEY(pk)
)DEFAULT CHARSET = 'utf8' ;
CREATE INDEX idx_table2_key_pk_parts_2_int_col_int_key ON table2_key_pk_parts_2_int(col_int_key);
CREATE INDEX idx_table2_key_pk_parts_2_int_col_char_12_key ON table2_key_pk_parts_2_int(col_char_12_key);
insert into table2_key_pk_parts_2_int values
(10811, NULL, NULL, NULL, -30278),
(10811, NULL, NULL, '-165', -29073),
(10811, '-100.12345', NULL, '-100.12345', -28526),
(100, '-100.12345', -28335, '10', -28335),
(100, '-100.12345', NULL, '10', -28285),
(100, '-100.12345', -27650, '10', -27650),
(100, NULL, NULL, NULL, -27180),
(100, '-100.12345', NULL, '10', -27038),
(100, '-473413.6329', NULL, '10', -26995),
(100, NULL, NULL, '10', -26956);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
SELECT pk , col_int_key
FROM table2_key_pk_parts_2_int
WHERE  ( CAST( pk AS CHAR(100) ) != CAST( col_char_12 AS CHAR(100) )  )
AND  ( ROW ( SUBSTR( CAST( ( -100.1234500 ) AS CHAR(100) ) , 1 , 12 ) , '1') = ROW ( col_char_12_key , col_int_key ) );
pk	col_int_key
SELECT pk , col_int_key
FROM table2_key_pk_parts_2_int
WHERE  ( CAST( pk AS CHAR(100) ) !=  CAST( col_char_12 AS CHAR(100) ) )
AND  ( ROW ( -100.12345 , 100) = ROW ( col_char_12_key , col_int_key ) );
pk	col_int_key
SELECT pk , col_int_key
FROM table2_key_pk_parts_2_int
WHERE   CAST( (case when pk>0 then 1 else 0 end) AS CHAR(100)  ) != CAST( col_char_12 AS CHAR(100) ) 
AND   ROW ( -100.12345 , 100) = ROW ( col_char_12_key , col_int_key ) ;
pk	col_int_key
select * from table2_key_pk_parts_2_int where col_int<=10 and abs(col_char_12_key)=100;
col_int_key	col_char_12	col_int	col_char_12_key	pk
select * from table2_key_pk_parts_2_int where col_int<=10 and abs(col_char_12_key) in (1,100,1000);
col_int_key	col_char_12	col_int	col_char_12_key	pk
drop table table2_key_pk_parts_2_int;
