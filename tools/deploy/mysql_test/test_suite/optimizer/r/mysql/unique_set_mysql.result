## semi/anti join + distinct
EXPLAIN select distinct c1, c2, c3 from t1 where t1.c1 > 0 and t1.c2 > 0 and t1.c3 > any (select c3 from t2);
Query Plan
=============================================================
|ID|OPERATOR              |NAME       |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |NESTED-LOOP SEMI JOIN |           |2       |13          |
|1 |├─TABLE RANGE SCAN    |t1(u_c1_c2)|2       |10          |
|2 |└─MATERIAL            |           |6       |3           |
|3 |  └─TABLE FULL SCAN   |t2         |6       |3           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      conds([t1.c3 > t2.c3]), nl_params_(nil), use_batch=false
  1 - output([t1.c1], [t1.c2], [t1.c3]), filter([t1.c2 > 0]), rowset=16
      access([t1.pk], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[true], 
      range_key([t1.c1], [t1.c2], [t1.shadow_pk_0]), range(0,MAX,MAX ; MAX,MAX,MAX), 
      range_cond([t1.c1 > 0])
  2 - output([t2.c3]), filter(nil), rowset=16
  3 - output([t2.c3]), filter(nil), rowset=16
      access([t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.pk]), range(MIN ; MAX)always true
select distinct c1, c2, c3 from t1 where t1.c1 > 0 and t1.c2 > 0 and t1.c3 > any (select c3 from t2);
