drop table if exists t1, t2, t3;
create table t1 (pk int primary key, c1 int, c2 int, c3 int, unique index u_c1_c2(c1, c2));
create table t2 (pk int primary key, c1 int, c2 int, c3 int,
unique index u_c1_c2(c1, c2),
unique index u_c1 (c1),
unique index u_c2 (c2));
create table t3(a int, b int, c int, d int, unique key k1(b,c));
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
call dbms_stats.gather_table_stats('TEST', 't3');
explain_protocol: 2
result_format: 4
## basic table + distinct
EXPLAIN select distinct * from t1;
