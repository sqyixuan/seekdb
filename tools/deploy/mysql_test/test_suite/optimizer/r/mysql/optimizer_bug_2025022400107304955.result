drop table if exists ts_wholesale_order;
drop table if exists ts_wholesale_order_detail;
CREATE TABLE `ts_wholesale_order` (
`id` int(11) unsigned NOT NULL AUTO_INCREMENT,
`add_time` int(11) unsigned NOT NULL DEFAULT '0',
PRIMARY KEY (`id`),
KEY `add_time_idx` (`add_time`) BLOCK_SIZE 16384 LOCAL
) partition by range(id)
(partition `order1` values less than (100000000),
partition `order15` values less than (950000000));
CREATE TABLE `ts_wholesale_order_detail` (
`order_detail_id` bigint(20) NOT NULL AUTO_INCREMENT,
`order_id` int(11) NOT NULL COMMENT '主订单号',
PRIMARY KEY (`order_id`, `order_detail_id`),
KEY `order_detail_idx` (`order_detail_id`) BLOCK_SIZE 16384 LOCAL,
KEY `order_idx` (`order_id`) BLOCK_SIZE 16384 LOCAL
) partition by range(order_id)
(partition `order1` values less than (100000000),
partition `order15` values less than (950000000));
alter system set _inlist_rewrite_threshold = 1;
select 1
from ts_wholesale_order two
inner join(
select distinct childOrder.id as orderId
FROM ts_wholesale_order two
INNER JOIN ts_wholesale_order childOrder ON 1
INNER JOIN ts_wholesale_order_detail twod ON twod.order_id = childOrder.id
WHERE two.id IN ('1', '2')
) temp on two.id = temp.orderId;
1
alter system set _inlist_rewrite_threshold = 1000;
drop table ts_wholesale_order;
drop table ts_wholesale_order_detail;
