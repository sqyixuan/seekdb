drop table t1;

create table t1(
  id bigint(20) not null auto_increment,
  test_json json,
  json_ind_col varchar(30) as (json_unquote(json_extract(test_json,'$.name'))) stored,
  primary key(id),
  key idx_json_index(json_ind_col)
);

explain select count(json_ind_col) from t1;
Query Plan
===============================================================
|ID|OPERATOR         |NAME              |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |SCALAR GROUP BY  |                  |1       |12          |
|1 |└─TABLE FULL SCAN|t1(idx_json_index)|1       |12          |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(t1.json_ind_col))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(t1.json_ind_col))])
  1 - output([T_FUN_COUNT(t1.json_ind_col)]), filter(nil), rowset=16
      access([t1.json_ind_col]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.json_ind_col], [t1.id]), range(MIN,MIN ; MAX,MAX)always true, 
      pushdown_aggregation([T_FUN_COUNT(t1.json_ind_col)])
select count(json_ind_col) from t1;
+---------------------+
| count(json_ind_col) |
+---------------------+
|                   0 |
+---------------------+

