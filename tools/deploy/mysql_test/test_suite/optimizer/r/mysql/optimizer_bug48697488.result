result_format: 4
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int as(c1+c2), c4 int, c5 int as (c1+c4) stored) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than MAXVALUE
);

insert into t1(c1,c2,c4) values(1,1,1),(102,102,102),(203,203,203);

create index i1 on t1(c3);
create index i2 on t1(c5);

#test virtual generated column
##index back is false
explain select count(c3) from t1;
Query Plan
=================================================================
|ID|OPERATOR                     |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |SCALAR GROUP BY              |        |1       |10          |
|1 |└─PX COORDINATOR             |        |1       |10          |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000|1       |10          |
|3 |    └─MERGE GROUP BY         |        |1       |9           |
|4 |      └─PX PARTITION ITERATOR|        |3       |9           |
|5 |        └─TABLE FULL SCAN    |t1(i1)  |3       |9           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c3))]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c3))])
  1 - output([T_FUN_COUNT(t1.c3)]), filter(nil), rowset=16
  2 - output([T_FUN_COUNT(t1.c3)]), filter(nil), rowset=16
      dop=1
  3 - output([T_FUN_COUNT(t1.c3)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_COUNT(t1.c3)])
  4 - output([t1.c3]), filter(nil), rowset=16
      force partition granule
  5 - output([t1.c3]), filter(nil), rowset=16
      access([t1.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c3], [t1.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
select count(c3) from t1;
+-----------+
| count(c3) |
+-----------+
|         3 |
+-----------+

