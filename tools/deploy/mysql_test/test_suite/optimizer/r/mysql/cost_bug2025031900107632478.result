-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil), rowset=16
      conds(nil), nl_params_([t1.c1(:0)], [t1.c2(:1)]), use_batch=true
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c1], [t2.c2]), filter([t2.c1 = :0]), rowset=16
      access([GROUP_ID], [t2.__pk_increment], [t2.c1], [t2.c2]), partitions(p[0-255])
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.c2], [t2.__pk_increment]), range(MIN ; MAX), 
      range_cond([t2.c2 = :1])
