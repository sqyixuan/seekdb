drop table if exists t1,t2;
create table t1(c1 int, c2 int);
insert into t1 select uniform(1, 10000, random(0)), uniform(1, 10000, random(0)) from table(generator(10));
create table t2(c1 int, c2 int, index i1(c2) )  partition by hash(c1) partitions 256;
insert /*+query_timeout(100000000)*/ into t2 select uniform(1, 10000, random(1)), uniform(1, 10000, random(2)) from table(generator(100000));
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
alter system minor freeze;
explain_protocol: 2
result_format: 4
EXPLAIN select * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
Query Plan
================================================================
|ID|OPERATOR                      |NAME  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |NESTED-LOOP JOIN              |      |11      |186         |
|1 |├─TABLE FULL SCAN             |t1    |10      |3           |
|2 |└─DISTRIBUTED TABLE RANGE SCAN|t2(i1)|1       |4484        |
================================================================
