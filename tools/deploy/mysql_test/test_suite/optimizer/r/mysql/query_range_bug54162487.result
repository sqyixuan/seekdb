DROP TABLE if exists t1,t2;
CREATE TABLE `t1` (
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`col_timestamp_unique_index` timestamp NULL DEFAULT NULL,
`col_timestamp` timestamp NULL DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_varchar_20_unique_index` varchar(20) DEFAULT NULL,
`col_decimal_20_0_unique_index` decimal(20,0) DEFAULT NULL,
`col_decimal_20_0_index` decimal(20,0) DEFAULT NULL,
`col_bigint_unique_index` bigint(20) DEFAULT NULL,
`col_double_index` double DEFAULT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
`col_bigint_index` bigint(20) DEFAULT NULL,
`col_varchar_20_index` varchar(20) DEFAULT NULL,
`col_double_unique_index` double DEFAULT NULL,
`col_timestamp_index` timestamp NULL DEFAULT NULL,
`col_double` double DEFAULT NULL,
PRIMARY KEY (`pk`),
KEY `idx10` (`col_varchar_20_index`) BLOCK_SIZE 16384 GLOBAL
);
CREATE TABLE `t2` (
`col_varchar_20_index` varchar(20) DEFAULT NULL,
`col_double_index` double DEFAULT NULL,
`pk` int(11) NOT NULL,
`col_timestamp_index` timestamp NULL DEFAULT NULL,
`col_bigint` bigint(20) DEFAULT NULL,
`col_double` double DEFAULT NULL,
`col_varchar_20_unique_index` varchar(20) DEFAULT NULL,
`col_decimal_20_0_unique_index` decimal(20,0) DEFAULT NULL,
`col_varchar_20` varchar(20) DEFAULT NULL,
`col_double_unique_index` double DEFAULT NULL,
`col_decimal_20_0_index` decimal(20,0) DEFAULT NULL,
`col_bigint_index` bigint(20) DEFAULT NULL,
`col_bigint_unique_index` bigint(20) DEFAULT NULL,
`col_timestamp` timestamp NULL DEFAULT NULL,
`col_decimal_20_0` decimal(20,0) DEFAULT NULL,
`col_timestamp_unique_index` timestamp NULL DEFAULT NULL
);
result_format: 4
explain_protocol: 2
EXPLAIN select /*+ no_rewrite leading(v t1) use_nl(v t1)*/ * from t1, t2 as v 
where t1.col_varchar_20_unique_index <= v.col_varchar_20 
  and t1.pk IN (8,6) 
  and t1.col_varchar_20_index = 'm'
or  (t1.col_varchar_20_index,t1.col_varchar_20_index) > ('t','v');
