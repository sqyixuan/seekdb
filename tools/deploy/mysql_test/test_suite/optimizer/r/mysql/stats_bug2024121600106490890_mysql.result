`REMARK12` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '备注12',
`USER_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '柜员流水号|柜员流水号',
