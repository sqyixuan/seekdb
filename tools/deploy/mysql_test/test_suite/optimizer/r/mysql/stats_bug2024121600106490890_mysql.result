explain 
SELECT SEQ_NO, CHANNEL_SEQ_NO, SUB_SEQ_NO, TAE_SUB_SEQ_NO, SOURCE_TYPE
, REFERENCE, CLIENT_NO, INTERNAL_KEY, BASE_ACCT_NO, PROD_TYPE
