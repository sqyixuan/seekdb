drop table if exists rb_tran_hist;
CREATE TABLE `rb_tran_hist` (
`SEQ_NO` varchar(50) COLLATE utf8mb4_bin NOT NULL COMMENT '序号|序号',
`CHANNEL_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '渠道流水号|渠道流水号',
`SUB_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '子流水号|子流水号',
`TAE_SUB_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT 'TAE子流水序号|用于登记tae子流水号的序号',
`SOURCE_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '渠道|渠道细类|具体参见fm_channel表',
`REFERENCE` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易参考号|交易参考号',
`CLIENT_NO` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '客户号|客户号',
`INTERNAL_KEY` decimal(15,0) DEFAULT NULL COMMENT '账户内部键值|账户内部键值',
`BASE_ACCT_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账号/卡号|用于描述不同账户结构下的账号，如果是卡的话代表卡号，否则代表账号',
`PROD_TYPE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '产品类型|产品类型',
`ACCT_CCY` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户币种|账户币种 对于AIO账户和一本通账户',
`ACCT_SEQ_NO` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户序号|账户序列号，采用顺序数字，表示在同一账号、账户类型、币种下的不同子账户，比如定期存款序列号，卡下选择账户',
`SUB_ACCT_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '子账户|子账户',
`ACCT_STATUS` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户状态|描述账户生命周期不同阶段的划分|N-新建,H-待激活,A-活动,D-睡眠,S-久悬,O-转营业外,P-逾期,C-关闭 ,U-手工解除',
`ACCT_REAL_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户虚实标志|账户虚实标志，虚账户不产生核算，不进行监管报送|Y-实账户,N-虚账户',
`ACCT_TRAN_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户交易标志|目前使用M代表现金交易|M-非账户交易,T-账户交易',
`ACCT_DESC` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户描述|账户描述,目前同账户名称',
`ACCT_BRANCH` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户开户行|账户实际开户机构，柜面为实际网点机构，线上渠道一般为对应主账户的实际开户机构',
`EVENT_TYPE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '事件类型|事件类型',
`TRAN_DATE` date NOT NULL COMMENT '交易日期|交易日期',
`TRAN_BRANCH` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易机构|交易机构',
`CR_DR_IND` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '借贷标志|借贷标志|C-贷 ,D-借',
`CCY` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '币种|币种',
`TRAN_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易类型|交易类型',
`TRAN_DESC` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易描述|交易描述',
`PREVIOUS_BAL_AMT` decimal(17,2) DEFAULT NULL COMMENT '交易前余额|交易前余额',
`TRAN_AMT` decimal(17,2) DEFAULT NULL COMMENT '交易金额|交易金额',
`ACTUAL_BAL` decimal(17,2) DEFAULT NULL COMMENT '实际余额|实际余额',
`OTH_INTERNAL_KEY` decimal(15,0) DEFAULT NULL COMMENT '对手账户内部键|对手账户内部键',
`OTH_BASE_ACCT_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账号/卡号|对方账号/卡号',
`OTH_ACCT_CCY` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账户币种|对方账户币种',
`OTH_ACCT_SEQ_NO` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账户序列号|对方账户序列号',
`FH_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '资金冻结流水号|记录冻结编号信息',
`OTH_PROD_TYPE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账户产品类型|对方账户产品类型',
`OTH_ACCT_DESC` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账户描述|对方账户描述',
`OTH_BANK_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方银行代码|对方银行代码',
`OTH_BANK_NAME` varchar(110) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方银行名称|对方银行名称',
`OTH_BRANCH` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对方账户开户机构|对方账户开户机构',
`OTH_REAL_BANK_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实对方金融机构代码|真实对方金融机构代码',
`OTH_REAL_BANK_NAME` varchar(110) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实对方金融机构名称|真实对方金融机构名称',
`OTH_REAL_PROD_TYPE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实交易对手账户类型|真实交易对手账户类型',
`OTH_REAL_BASE_ACCT_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实交易对手账号|真实交易对手账号',
`PRIMARY_TRAN_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '主交易序号|主交易序号',
`DOC_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '凭证类型|凭证类型',
`VOUCHER_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '凭证号码|凭证号码',
`DOCUMENT_ID` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '证件号码|证件号码',
`CLIENT_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '客户名称|客户名称',
`CLIENT_TYPE` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '客户类型|客户大类，目前一般分为个人，公司，金融机构和内部客户。取之于CIF_CLIENT_TYPE.CLIENT_TYPE',
`CASH_ITEM` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现金项目|现金项目',
`TRAN_NOTE` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易附言|交易附言',
`TRAN_STATUS` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '业务处理状态/交易状态|业务处理状态|N-正常,X-被冲正,R-冲正',
`AUTO_REVERSAL_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '自动冲正标志|自动冲正标志。用于区分流水属于分布式事务下的内部冲正还正常的业务冲正|Y-系统自动冲正,N-业务冲正',
`AMT_CALC_TYPE` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '金额计算类型|金额计算类型|0-余额增加,1-余额减少,2-发放金额增加,3-未到期本金增加,4-逾期利息增加,5-逾期罚息增加,6-逾期复利增加,7-逾期本金减少,8-逾期利息减少,9-逾期罚息减少,a-逾期复利减少,b-未到期本金减少,c-逾期本金增加,d-未到期本金减少,e-余额增加无流水,f-发放金额增加无流水,g-余额减少无流水,h-额度减少无流水,i-透支金额减少无流水,j-透支金额增加无流水,k-贴现利息,l-当日结息利息,m-当日结息罚息,n-当日结息复利,q-未到期本金减少,o-久悬余额增加,p-久悬余额减少,r-宽限期内未到期本金减少,s-逾期余额增加,t-逾期余额减少,u-未实现利息,v-宽限期内到期本金减少',
`AMT_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '金额类型|金额类型|BAL-余额,DDA-发放金额,INTP-逾期利息,LIM-额度金额,OD-透支金额,ODIP-逾期复利,ODPP-逾期罚息,OSL-未到期本金,PRD-逾期本金,PRI-本金,DOS-久悬余额',
`BAL_TYPE` varchar(2) COLLATE utf8mb4_bin DEFAULT '' COMMENT '余额类型|余额类型|TT-汇余额,CA-钞余额',
`CONTRA_EQUIV_AMT` decimal(17,2) DEFAULT NULL COMMENT '他行等值金额|对方等值金额',
`FLAT_RATE` decimal(15,8) DEFAULT NULL COMMENT '平盘汇率|平盘汇率',
`OV_TO_AMOUNT` decimal(17,2) DEFAULT NULL COMMENT '根据实际交易时修改交叉汇率计算的金额|根据实际交易时修改交叉汇率计算的金额',
`CROSS_RATE` decimal(15,8) DEFAULT NULL COMMENT '交叉汇率|交叉汇率',
`ORIG_SYSTEM` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易发起方业务分类|交易发起方业务分类|RB-存款业务,CL-贷款业务,GL-内部账业务,CM-公共业务',
`PBK_UPD_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '是否补登存|是否补登存|Y-是 ,N-否',
`PRIMARY_EVENT_TYPE` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '主事件类型|主事件类型|CRET-贷记事件 ,DEBT-借记事件',
`TRAN_METHOD` varchar(2) COLLATE utf8mb4_bin DEFAULT '' COMMENT '到账方式|到账方式|02-次日到账,03-普通到账',
`WITHDRAWAL_TYPE` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '支取方式|支取方式|0-凭证,1-密码,2-证件,3-印鉴,4-印鉴和支付密码',
`BATCH_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '批次号|批次号',
`LIMIT_REF` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '限额编码|限额编码',
`OTH_REAL_DOCUMENT_ID` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实交易对手身份证件/证明文件号码|真实交易对手身份证件/证明文件号码',
`OTH_REAL_DOCUMENT_TYPE` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实交易对手身份证件/证明文件类型|真实交易对手身份证件/证明文件类型',
`OTH_TRAN_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易对手名称|交易对手名称',
`OTH_REAL_TRAN_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '真实交易对手名称|真实交易对手名称',
`RECEIPT_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '回收号|回收号',
`SERV_CHARGE` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '服务费标识|服务费标识|Y-是, N-否',
`PROGRAM_ID` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易代码|交易代码',
`SOURCE_MODULE` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '源模块|源模块|RB-存款,CL-贷款,GL-总账,ALL-所有',
`EFFECT_DATE` date DEFAULT NULL COMMENT '生效日期|生效日期',
`SYSTEM_CODE` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '系统编码|系统编码-外围系统编号 取报文头systemId',
`REVERSAL_SEQ_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '冲正流水号|冲正流水号',
`TRACE_ID` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '跟踪ID|跟踪ID',
`REVERSAL_TRAN_TYPE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '冲正交易类型|冲正交易类型',
`REVERSAL_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易是否已冲正|交易是否已冲正|Y-是,N-否',
`REVERSAL_DATE` date DEFAULT NULL COMMENT '冲正日期|冲正日期',
`CHANNEL_DATE` date DEFAULT NULL COMMENT '渠道日期|渠道日期',
`SETTLEMENT_DATE` date DEFAULT NULL COMMENT '清算日期|清算日期',
`ACCOUNTING_STATUS` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '核算状态|核算状态，为贷款核算状态类型，会计部门根据借款凭证针对借款合同进行审核的贷款核算分级审批制度|ZHC-正常,YUQ_逾期,FYJ-非应计,FY-手工转非应计,WRN-核销,TER-终止',
`GL_POSTED_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '过账标记|过账标记|Y-是 ,N-否',
`NARRATIVE` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '摘要|开户时的账号用途，销户时的销户原因',
`APPR_USER_ID` varchar(30) COLLATE utf8mb4_bin DEFAULT '' COMMENT '复核柜员|复核柜员',
`AUTH_USER_ID` varchar(30) COLLATE utf8mb4_bin DEFAULT '' COMMENT '授权柜员|授权柜员',
`ORIG_TRAN_TIMESTAMP` varchar(26) COLLATE utf8mb4_bin DEFAULT '' COMMENT '原始交易时间戳|原始交易时间戳',
`TRAN_TIMESTAMP` varchar(26) COLLATE utf8mb4_bin NOT NULL COMMENT '交易时间戳|交易时间戳',
`USER_ID` varchar(30) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易柜员|交易柜员',
`COMPANY` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '法人|法人',
`REMARK` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '备注|备注',
`CASH_USE_PLACE_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞去向国家地区代码|现钞去向国家(地区)代码|现钞去向国家(地区)代码',
`CASH_USE_REMARK` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞提取用途说明|现钞提取用途说明|01-船长借支,02-对外劳务合作或对外承包工程,03-境外代表处（办事处）办事经费,04-公务出国,05-司法和行政执法机关的罚没款、暂扣款和专项收缴款,06-对|现钞提取用途说明|现钞提取用途说明|01-船长借支,02-对外劳务合作或对外承包工程,03-境外代表处（办事处）办公经费,04-公务出国,05-司法和行政执法机关的罚没款、暂扣款和专项收缴款,06-对台小额贸易,07-对台小额商品交易市场,08-其他,1101-职工津贴与工资',
`CASH_SOURCE_COUNTRY` varchar(5) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现金来源国家地区代码|现钞来源国家(地区)代码|现钞来源国家(地区)代码',
`CASH_SOURCE_REMARK` varchar(2) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞来源说明|现钞来源说明|01-已提取未使用完现钞,02-机场或港口零星现钞收入,03-司法和行政执法机关的罚没款、暂扣款和专项收缴款,04-宗教类接收捐赠现钞收入,05旅游购物商品,06-销售免|现钞来源说明|现钞来源说明|01-已提取未使用完现钞,02-机场或港口零星现钞收入,03-司法和行政执法机关的罚没款、暂扣款和专项收缴款,04-宗教类接收捐赠现钞收入,05-旅游购物商品,06-销售免税商品收入的外币现钞,07-对台小额贸易,08-对台小额商品交易市场,09-其他,10-边贸收入',
`IS_TAE` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '是否tae记账|是否tae记账|Y-是,N-否',
`APPR_INDICATOR` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '复核标识|复核标识 L-本地授权，R-远端授权|L-本地授权,R-远端授权',
`APPR_TERMINAL_ID` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '复核终端ID|复核终端ID',
`PRINT_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '打印标识|打印标识|0-柜面签约已打凭证,1-柜面解约已打凭证,2-网银签约未打凭证,3-网银签约已打凭证,4-网银解约未打凭证,5-网银签约已打凭证,7-其他',
`LCY_TRAN_AMT` decimal(17,2) DEFAULT NULL COMMENT '本地币种交易金额|本地币种交易金额',
`AUTO_TRADE_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '系统自动交易标识|系统自动交易标识Y-自动/批量交易，N-人为发起交易',
`MATURITY_NARRATIVE1` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '到期说明1|备用字段1',
`MATURITY_NARRATIVE2` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '到期说明2|备用字段2',
`MATURITY_NARRATIVE3` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '到期说明3|备用字段3',
`MATURITY_NARRATIVE4` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '到期说明4|备用字段4',
`CASH_FROM_CODE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞来源代码|现钞来源代码',
`CASH_FROM_COUNTRY` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞来源国家(地区)代码|现钞来源国家(地区)代码',
`CASH_TO_CODE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞提取用途说明|现钞提取用途说明',
`CASH_TO_COUNTRY` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现钞去向国家(地区)代码|现钞去向国家(地区)代码',
`NARRATIVE_CODE` varchar(30) COLLATE utf8mb4_bin NOT NULL COMMENT '摘要码|摘要码',
`PI_FLAG` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '小额免密标志|小额免密标志|Y-做小额免密校验,N-不做小额免密校验',
`REACCOUNT_CD` varchar(100) COLLATE utf8mb4_bin DEFAULT '' COMMENT '对账代码|对账代码',
`MAIN_SOURCE_MODULE` varchar(3) COLLATE utf8mb4_bin DEFAULT '' COMMENT '主模块|主模块',
`CASH_RANGE` varchar(2) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现金范围|记录开户现金来源',
`DEPOSIT_SOURCE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '存款来源|记录开户存款来源代码',
`INDUSTRY` varchar(20) COLLATE utf8mb4_bin DEFAULT '' COMMENT '通用行业代码|通用行业代码',
`CASH_REMARK` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '现金备注|现金备注',
`ACCT_EXEC` varchar(30) COLLATE utf8mb4_bin DEFAULT '' COMMENT '客户经理|客户经理',
`DRAW_PURPOSE` varchar(10) COLLATE utf8mb4_bin DEFAULT '' COMMENT '取款用途|取款用途',
`DRAW_PURPOSE_REMARK` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '取款用途备注|取款用途备注',
`MACHINE_DATE` date DEFAULT NULL COMMENT '服务器日期|服务器日期',
`MARKETING_CODE` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '营销代码|营销代码',
`TRAN_TERMINAL_MAC` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '交易终端mac地址|交易终端mac地址',
`MERCHANT_CODE` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '商行编号|商行编号',
`MERCHANT_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '商户名称|商户名称',
`JSON_DATA_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '报文标识号|报文标识号',
`SETTLE_BUSI_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '结算业务序号|结算业务序号',
`SIGN_NO` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '签约编号|签约编号',
`DEPOSIT_NATURE` varchar(100) COLLATE utf8mb4_bin DEFAULT '' COMMENT '存款性质|存款性质',
`DEPOSIT_SOURCE_REMARK` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '存款来源备注|存款来源备注',
`CASH_FROM_TO` char(1) COLLATE utf8mb4_bin DEFAULT '' COMMENT '资金去向来源|资金去向来源，主要用于现金长短款|C-现金,R-账户,G-总账账户,D-信用卡账户,Y-银联清算',
`REASON_CODE` varchar(200) COLLATE utf8mb4_bin DEFAULT '' COMMENT '账户用途|账户用途',
`FUND_DESTINATION` varchar(2) COLLATE utf8mb4_bin DEFAULT '' COMMENT '资金去向|资金去向|01-现金,02-行内转账,03-汇款,04-转营业外收入',
`IP` varchar(50) COLLATE utf8mb4_bin DEFAULT '' COMMENT '请求方IP地址',
