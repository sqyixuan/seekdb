, DOCUMENT_ID, CLIENT_NAME, CLIENT_TYPE, CASH_ITEM, TRAN_NOTE
, TRAN_STATUS, AUTO_REVERSAL_FLAG, AMT_CALC_TYPE, AMT_TYPE, BAL_TYPE
, CONTRA_EQUIV_AMT, FLAT_RATE, OV_TO_AMOUNT, CROSS_RATE, ORIG_SYSTEM
, PBK_UPD_FLAG, PRIMARY_EVENT_TYPE, TRAN_METHOD, WITHDRAWAL_TYPE, BATCH_NO
, LIMIT_REF, OTH_REAL_DOCUMENT_ID, OTH_REAL_DOCUMENT_TYPE, OTH_TRAN_NAME, OTH_REAL_TRAN_NAME
, RECEIPT_NO, SERV_CHARGE, PROGRAM_ID, SOURCE_MODULE, EFFECT_DATE
, SYSTEM_CODE, REVERSAL_SEQ_NO, TRACE_ID, REVERSAL_TRAN_TYPE, REVERSAL_FLAG
, REVERSAL_DATE, CHANNEL_DATE, SETTLEMENT_DATE, ACCOUNTING_STATUS, GL_POSTED_FLAG
, NARRATIVE, APPR_USER_ID, AUTH_USER_ID, ORIG_TRAN_TIMESTAMP, TRAN_TIMESTAMP
, USER_ID, COMPANY, REMARK, CASH_USE_PLACE_CODE, CASH_USE_REMARK
, CASH_SOURCE_COUNTRY, CASH_SOURCE_REMARK, IS_TAE, APPR_INDICATOR, APPR_TERMINAL_ID
, PRINT_FLAG, LCY_TRAN_AMT, AUTO_TRADE_FLAG, MATURITY_NARRATIVE1, MATURITY_NARRATIVE2
, MATURITY_NARRATIVE3, MATURITY_NARRATIVE4, CASH_FROM_CODE, CASH_FROM_COUNTRY, CASH_TO_CODE
, CASH_TO_COUNTRY, NARRATIVE_CODE, PI_FLAG, REACCOUNT_CD, MAIN_SOURCE_MODULE
, CASH_RANGE, DEPOSIT_SOURCE, INDUSTRY, CASH_REMARK, ACCT_EXEC
, DRAW_PURPOSE, DRAW_PURPOSE_REMARK, MACHINE_DATE, MARKETING_CODE, TRAN_TERMINAL_MAC
, MERCHANT_CODE, MERCHANT_NAME, JSON_DATA_NO, SETTLE_BUSI_NO, SIGN_NO
, DEPOSIT_NATURE, DEPOSIT_SOURCE_REMARK, CASH_FROM_TO, REASON_CODE, FUND_DESTINATION
, IP, TRAN_SEQ, TRANSFER_PURPOSE, CREATE_TIME, REMARK12
, USER_SEQ_NO
FROM RB_tran_hist
WHERE INTERNAL_KEY = 5682009
AND CLIENT_NO = '0200081066'
        AND TRAN_DATE >= '2024-01-01 00:00:00'
        AND TRAN_DATE <= '2024-09-01 00:00:00'
        AND (REMARK12 != 'TLTOPG'
                OR REMARK12 IS NULL)
AND (AUTO_REVERSAL_FLAG != 'Y'
                OR AUTO_REVERSAL_FLAG IS NULL)
AND rb_tran_hist.TRAN_DATE <= '2024-06-26'
ORDER BY ORIG_TRAN_TIMESTAMP DESC, SEQ_NO + 0 DESC
LIMIT 10,10;
