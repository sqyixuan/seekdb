      dop=1
  2 - output([UNION([1])]), filter(nil), rowset=16
  3 - output([t2.cc2]), filter(nil), rowset=16
      affinitize, force partition granule
  4 - output([t2.cc2]), filter(nil), rowset=16
      access([t2.cc2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.cc1], [t2.cc2]), range(MIN,MIN ; MAX,MAX)always true
  5 - output([t1.c3]), filter(nil), rowset=16
  6 - output([t1.c3]), filter(nil), rowset=16
      (#keys=1, [t1.c3]), dop=1
  7 - output([t1.c3]), filter(nil), rowset=16
      distinct([t1.c3])
  8 - output([t1.c3]), filter(nil), rowset=16
      force partition granule
  9 - output([t1.c3]), filter(nil), rowset=16
      access([t1.c3]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2]), range(MIN,MIN ; MAX,MAX)always true
select c3 from t1 union select cc2 from t2;
