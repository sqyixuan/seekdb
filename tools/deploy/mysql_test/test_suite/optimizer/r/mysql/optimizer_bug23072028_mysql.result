drop table if exists t1;
drop table if exists t2;
create table t1(c1 int, c2 int, c3 int,primary key(c1,c2)) partition by hash(c2) partitions 4;
create table t2(cc1 int, cc2 int, cc3 int,primary key(cc1,cc2)) partition by hash(cc2) partitions 4;
result_format: 4
explain_protocol: 2
## hash union/intersect/except distinct
EXPLAIN select c3 from t1 union select cc2 from t2;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |5       |23          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|5       |22          |
|2 |  └─HASH UNION DISTINCT          |        |5       |20          |
|3 |    ├─PX PARTITION ITERATOR      |        |2       |9           |
|4 |    │ └─TABLE FULL SCAN          |t2      |2       |9           |
|5 |    └─EXCHANGE IN DISTR          |        |2       |11          |
|6 |      └─EXCHANGE OUT DISTR (PKEY)|:EX10000|2       |10          |
|7 |        └─HASH DISTINCT          |        |2       |10          |
|8 |          └─PX PARTITION ITERATOR|        |3       |9           |
|9 |            └─TABLE FULL SCAN    |t1      |3       |9           |
=====================================================================
