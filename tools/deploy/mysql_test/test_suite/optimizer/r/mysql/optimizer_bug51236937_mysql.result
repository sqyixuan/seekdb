drop table if exists t1,t2;
create table t1(a int);
create table t2(b int);
insert into t1 values (null),(1);
insert into t2 values (null),(1);
result_format: 4
explain_protocol: 2
EXPLAIN select * from t1,t2 where a+b = a+b;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |NESTED-LOOP JOIN   |    |4       |5           |
|1 |├─TABLE FULL SCAN  |t1  |2       |3           |
|2 |└─MATERIAL         |    |2       |3           |
|3 |  └─TABLE FULL SCAN|t2  |2       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t2.b]), filter(nil), rowset=16
      conds([t1.a + t2.b = t1.a + t2.b]), nl_params_(nil), use_batch=false
  1 - output([t1.a]), filter(nil), rowset=16
      access([t1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.b]), filter(nil), rowset=16
  3 - output([t2.b]), filter(nil), rowset=16
      access([t2.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select * from t1,t2 where a+b = a+b;
