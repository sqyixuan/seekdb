drop table if exists t1,phash,pkey,sp;
create table t1(c1 int, c2 int);
create table phash(c1 int, c2 int) partition by hash(c1) partitions 10;
create table pkey(c1 int, c2 int) partition by key(c1) partitions 2;
create table sp(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2016-10-10'),  subpartition p1 values less than ('2116-3-30')) partitions 2;
alter system minor freeze;
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 'phash');
call dbms_stats.gather_table_stats('TEST', 'pkey');
call dbms_stats.gather_table_stats('TEST', 'sp');
explain select * from t1 where c1 > 1000;
