drop table if exists t1, t2;
create table t1(a int, b int, c int, primary key(a,b));
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(b) partitions 4;
result_format: 4
explain_protocol: 2
EXPLAIN select /*+no_use_hash_aggregation*/ a, sum(b) from t1 group by a order by a;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |MERGE GROUP BY   |    |7       |4           |
|1 |└─TABLE FULL SCAN|t1  |7       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [T_FUN_SUM(t1.b)]), filter(nil), rowset=16
      group([t1.a]), agg_func([T_FUN_SUM(t1.b)])
  1 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.a], [t1.b]), range(MIN,MIN ; MAX,MAX)always true
select /*+no_use_hash_aggregation*/ a, sum(b) from t1 group by a order by a;
+---+--------+
| a | sum(b) |
+---+--------+
| 1 |      6 |
| 2 |      5 |
| 3 |      3 |
| 4 |      5 |
| 5 |      6 |
+---+--------+
