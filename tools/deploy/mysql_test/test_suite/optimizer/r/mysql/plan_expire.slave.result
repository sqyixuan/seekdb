## test plan expiration partition table
explain select * from tp where c2 < 1 and c1 > 0;
Query Plan
===============================================================
|ID|OPERATOR                    |NAME   |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |DISTRIBUTED TABLE RANGE SCAN|tp(idx)|1       |5           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([tp.c1], [tp.c2], [tp.c3]), filter([tp.c1 > 0]), rowset=256
      access([tp.c1], [tp.c2], [tp.c3]), partitions(p0)
      is_index_back=true, is_global_index=true, filter_before_indexback[true], 
      range_key([tp.c2], [tp.c1]), range(NULL,MAX ; 1,MIN), 
      range_cond([tp.c2 < 1])
explain select * from tp where c2 < 10000 and c1 > 9999;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |19          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |18          |
|2 |  └─PX PARTITION ITERATOR|        |1       |17          |
|3 |    └─TABLE RANGE SCAN   |tp      |1       |17          |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(tp.c1, tp.c2, tp.c3)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(tp.c1, tp.c2, tp.c3)]), filter(nil), rowset=256
      dop=1
  2 - output([tp.c1], [tp.c2], [tp.c3]), filter(nil), rowset=256
      force partition granule
  3 - output([tp.c1], [tp.c2], [tp.c3]), filter([tp.c2 < 10000]), rowset=256
      access([tp.c1], [tp.c2], [tp.c3]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([tp.c1]), range(9999 ; MAX), 
      range_cond([tp.c1 > 9999])

