drop table if exists t1, t2;
create table t1 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk);
create index idx_t1 on t1 (c1,c2) global;
create table t2 (pk int primary key, c1 int, c2 int, c3 int);
result_format: 4
explain_protocol: 2
EXPLAIN SELECT * FROM t1,t2 WHERE t1.pk = t2.pk and t1.c1 = 100 AND t1.c2 < 100;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |NESTED-LOOP JOIN |    |1       |19          |
|1 |├─TABLE FULL SCAN|t2  |1       |3           |
|2 |└─TABLE GET      |t1  |1       |16          |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.pk], [t1.c1], [t1.c2], [t1.c3], [t2.pk], [t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      conds(nil), nl_params_([t2.pk(:0)]), use_batch=true
  1 - output([t2.pk], [t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      access([t2.pk], [t2.c1], [t2.c2], [t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.pk]), range(MIN ; MAX)always true
  2 - output([t1.pk], [t1.c1], [t1.c2], [t1.c3]), filter([t1.c2 < 100], [t1.c1 = 100]), rowset=16
      access([GROUP_ID], [t1.pk], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t1.pk]), range(MIN ; MAX), 
      range_cond([t1.pk = :0])
SELECT * FROM t1,t2 WHERE t1.pk = t2.pk and t1.c1 = 100 AND t1.c2 < 100;
