drop table if exists t1,t2;
create table t1(id int primary key, c1 int, c2 int);
create table t2(c1 int, c2 int, c3 int);
result_format: 4
explain_protocol: 2
EXPLAIN select t1.id from t1, (select c1 from t2 group by c1 having sum(t2.c1) = 0) view where t1.c1 = view.c1;
