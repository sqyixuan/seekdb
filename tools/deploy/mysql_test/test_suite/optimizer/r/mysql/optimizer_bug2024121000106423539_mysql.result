drop table if exists t1;
result_format: 4
create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 8;

explain basic
select /*+parallel(1)*/ * from t1
union all
select c2, c1, c3 from t1;
Query Plan
=========================================
|ID|OPERATOR                   |NAME    |
-----------------------------------------
|0 |PX COORDINATOR             |        |
|1 |└─EXCHANGE OUT DISTR       |:EX10000|
|2 |  └─UNION ALL              |        |
|3 |    ├─PX PARTITION ITERATOR|        |
|4 |    │ └─TABLE FULL SCAN    |t1      |
|5 |    └─PX PARTITION ITERATOR|        |
|6 |      └─TABLE FULL SCAN    |t1      |
=========================================
