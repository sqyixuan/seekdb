result_format: 4

##bug 

drop table if exists t1;
drop table if exists t2;
drop table if exists tp1;
drop table if exists tp2;
create table t1 (c1 int, c2 int, unique idx (c2), index idx_c1(c1));
create table t2 (c1 int, c2 int, unique idx (c2), index idx_c1(c1));
create table tp1 (c1 int, c2 int, unique idx (c2) global, index idx_c1(c1)) partition by hash(c1) partitions 5;
create table tp2 (c1 int, c2 int, unique idx (c2) global, index idx_c1(c1)) partition by hash(c1) partitions 5;

explain_protocol: 2
EXPLAIN select * from t1 where c2 is null;
Query Plan
===================================================
|ID|OPERATOR        |NAME   |EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |TABLE RANGE SCAN|t1(idx)|1       |7           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.c2], [t1.c1]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.c2], [t1.shadow_pk_0]), range(NULL,MIN ; NULL,MAX), 
      range_cond([t1.c2 IS NULL])
select * from t1 where c2 is null;
+------+------+
| c1   | c2   |
+------+------+
+------+------+
