drop table if exists td, t;
create table t (pk int primary key, c1 int, c2 int);
create index idx_c2 on t (c2, c1, pk) global;
create index dis_idx_c2 on t (c2, c1, pk) global
partition by range columns (c2)
(partition p0 values less than (5),
partition p1 values less than (20),
partition p3 values less than (40),
partition p4 values less than (2000));
create table td (pk int primary key, c1 int, c2 int)
partition by range columns (pk)
(partition p0 values less than (5),
partition p1 values less than (20),
partition p3 values less than (40),
partition p4 values less than (2000));
create index idx_c2 on td (c2, c1, pk) global;
create index dis_idx_c2 on td (c2, c1, pk) global
partition by range columns (c2)
(partition p0 values less than (5),
partition p1 values less than (20),
partition p3 values less than (40),
partition p4 values less than (2000));
drop table if exists t_pg_table;
purge recyclebin;
drop tablegroup if exists tpg;
create tablegroup if not exists tpg binding true;
create table t_pg_table (pk int primary key, c1 int, c2 int) tablegroup = 'tpg';
explain  select /*+index(t primary)*/ * from t where pk > 0;
Query Plan
================================================
|ID|OPERATOR        |NAME|EST.ROWS|EST.TIME(us)|
------------------------------------------------
|0 |TABLE RANGE SCAN|t   |995     |74          |
================================================
