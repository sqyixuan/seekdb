      access([t.pk], [t.c2], [t.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t.pk]), range(0 ; MAX), 
      range_cond([t.pk > 0])
explain  select /*+index(t idx_c2)*/ * from t where pk > 0;
