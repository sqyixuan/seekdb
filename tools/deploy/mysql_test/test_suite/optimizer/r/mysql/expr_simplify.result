create or replace view v1 as select * from T1 T1_29 where concat(T1_29.C2, T1_29.C2) like '%Ab%' OR concat(T1_29.C2, T1_29.C2) like '%Ab%';

show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `T1_29`.`c1` AS `c1`,`T1_29`.`c2` AS `c2` from `test`.`t1` `T1_29` where ((concat(`T1_29`.`c2`,`T1_29`.`c2`) like '%Ab%' escape '\\') or (concat(`T1_29`.`c2`,`T1_29`.`c2`) like '%Ab%' escape '\\'))	utf8mb4	utf8mb4_general_ci

