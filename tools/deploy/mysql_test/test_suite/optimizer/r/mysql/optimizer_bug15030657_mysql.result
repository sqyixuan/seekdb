drop table if exists t1;
create table t1(a int primary key, b int, c int, d int, index k1(b) storing (c));
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
explain  select/*+index(t1 k1)*/ * from t1 where t1.b < 300 and t1.c > 200 and t1.d < 500 order by a;
Query Plan
====================================================
|ID|OPERATOR          |NAME  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |SORT              |      |200     |800         |
|1 |└─TABLE RANGE SCAN|t1(k1)|200     |750         |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=256
      sort_keys([t1.a, ASC])
  1 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter([t1.d < 500], [t1.c > 200]), rowset=256
      access([t1.a], [t1.b], [t1.c], [t1.d]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false,true], 
      range_key([t1.b], [t1.a]), range(NULL,MAX ; 300,MIN), 
      range_cond([t1.b < 300])
