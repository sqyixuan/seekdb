create table t1(pk1 int, pk2 varchar(10), c1 int, c2 int, c3 varchar(20), c4  timestamp(6) default "2012-01-01 12:00:00", c5 int, primary key(pk1, pk2));
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1,c2);
create index i4 on t1(c2, c3, c4);
create index i5 on t1(c2, c3) storing(c1);
create index i6 on t1(c3);
