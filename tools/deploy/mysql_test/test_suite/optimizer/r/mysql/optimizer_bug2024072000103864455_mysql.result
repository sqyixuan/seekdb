result_format: 4
drop table if exists t1,d1;
create table t1(c1 int primary key, c2 int ,c3 int, c4 int, index i1(c2, c3));
insert into t1 select row_number() over (), abs(random(2) % 100), abs(random(3) % 100), abs(random(4) % 100) from table(generator(100000));

create table d1(c1 int, c2 int, index i1(c1));
create INDEX i2 on d1 (c2);
insert into d1 select 1,1 from table(generator(100000));
alter system minor freeze;
call dbms_stats.gather_table_stats(null, 't1');

