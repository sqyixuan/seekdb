    MODEL_KEY,CACHE_SYNCER,GMT_MODIFIED,SLA_SEQ_ID,STATUS 
FROM
    CS_CACHE_COMPENSATION 
WHERE 
    GMT_MODIFIED < DATE_SUB(current_timestamp(6), INTERVAL 30 SECOND) and
    GMT_MODIFIED > DATE_SUB(current_timestamp(6), INTERVAL 1 MINUTE) 
