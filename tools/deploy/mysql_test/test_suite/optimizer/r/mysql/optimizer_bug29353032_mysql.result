       range(1970-01-01 00:01:13.345000,MAX,MAX,MAX ; 1970-01-01 00:01:43.345000,MIN,MIN,MIN), 
      range_cond([cs_cache_compensation.gmt_modified < demote_cast(date_sub(current_timestamp(), cast(30, VARCHAR(1048576)), 1), TIMESTAMP(25, 6))], [cs_cache_compensation.gmt_modified 
      > demote_cast(date_sub(current_timestamp(), cast(1, VARCHAR(1048576)), 2), TIMESTAMP(25, 6))])
