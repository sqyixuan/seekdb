drop table if exists t1, t2;
create table t1(c1 int ,c2 int);
create table t2(c1 int, c2 int);
create index t1_i1 on t1(c1);
create index t2_i1 on t2(c1);
insert into t1 select 1,random()%100 from table(generator(10000));
insert into t2 select random()%100,random()%100 from table(generator(10000));
select count(*) from t1;
count(*)
10000
select count(*) from t2;
count(*)
10000
explain basic select (select /*+index(t2 t2_i1)*/  c1 from t2 where t2.c2 = t1.c1) as ref 
from t1
where t1.c1 < 0
and t1.c2 > 1;
Query Plan
============================================
|ID|OPERATOR                     |NAME     |
--------------------------------------------
|0 |SUBPLAN FILTER               |         |
|1 |├─TABLE RANGE SCAN           |t1(t1_i1)|
|2 |└─DISTRIBUTED TABLE FULL SCAN|t2(t2_i1)|
============================================
Outputs & filters:
-------------------------------------
  0 - output([subquery(1)]), filter(nil), rowset=256
      exec_params_([t1.c1(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  1 - output([t1.c1]), filter([t1.c2 > 1]), rowset=256
      access([t1.__pk_increment], [t1.c1], [t1.c2]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1], [t1.__pk_increment]), range(NULL,MAX ; 0,MIN), 
      range_cond([t1.c1 < 0])
  2 - output([t2.c1]), filter([t2.c2 = :0]), rowset=256
      access([t2.__pk_increment], [t2.c2], [t2.c1]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.c1], [t2.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
explain basic select /*+leading(t1 t2) use_nl(t2)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c1 
and t1.c1 < 0
and t1.c2 > 1;
