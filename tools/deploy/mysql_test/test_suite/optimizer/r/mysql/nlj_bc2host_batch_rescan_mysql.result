result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1;
create table t1(c1 int primary key, c2 int , c3 int, c4 int) partition by hash(c1) partitions 2;
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1 + 1, c1 from cte;

call dbms_stats.gather_table_stats('test', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);

explain_protocol: 2
EXPLAIN select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(1) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'true')*/ a.c1, b.c2, a.c3, b.c4 from t1 a, t1 partition (p0) b where a.c1 = b.c1) v;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |SCALAR GROUP BY                  |        |1       |16184       |
|1 |└─PX COORDINATOR                 |        |1       |16184       |
|2 |  └─EXCHANGE OUT DISTR           |:EX10000|1       |16184       |
|3 |    └─MERGE GROUP BY             |        |1       |16183       |
|4 |      └─SUBPLAN SCAN             |v       |500     |16166       |
|5 |        └─NESTED-LOOP JOIN       |        |500     |16164       |
|6 |          ├─PX PARTITION ITERATOR|        |1000    |54          |
|7 |          │ └─TABLE FULL SCAN    |a       |1000    |54          |
|8 |          └─DISTRIBUTED TABLE GET|b       |1       |16          |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))], [T_FUN_SUM(T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4))]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))], [T_FUN_SUM(T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4))])
  1 - output([T_FUN_COUNT(*)], [T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4)]), filter(nil), rowset=256
  2 - output([T_FUN_COUNT(*)], [T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4)]), filter(nil), rowset=256
      dop=1
  3 - output([T_FUN_COUNT(*)], [T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)], [T_FUN_SUM(v.c1 + v.c2 + v.c3 + v.c4)])
  4 - output([v.c1], [v.c2], [v.c3], [v.c4]), filter(nil), rowset=256
      access([v.c1], [v.c2], [v.c3], [v.c4])
  5 - output([a.c1], [b.c2], [a.c3], [b.c4]), filter(nil), rowset=256
      conds(nil), nl_params_([a.c1(:0)]), use_batch=true
  6 - output([a.c1], [a.c3]), filter(nil), rowset=256
      force partition granule
  7 - output([a.c1], [a.c3]), filter(nil), rowset=256
      access([a.c1], [a.c3]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([a.c1]), range(MIN ; MAX)always true
  8 - output([b.c2], [b.c4]), filter(nil), rowset=256
      access([GROUP_ID], [b.c2], [b.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([b.c1]), range(MIN ; MAX), 
      range_cond([:0 = b.c1])
