result_format: 4
set ob_query_timeout = 1000000000;

drop table if exists t1;
create table t1(c1 int primary key, c2 int , c3 int, c4 int) partition by hash(c1) partitions 2;
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1 + 1, c1 from cte;

call dbms_stats.gather_table_stats('test', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);

explain_protocol: 2
EXPLAIN select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'false')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p0) b where a.c1 = b.c1) v;
