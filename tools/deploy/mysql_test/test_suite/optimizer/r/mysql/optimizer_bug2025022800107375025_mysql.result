drop table if exists t1,t2,t3;
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1, c2), unique index i1(c1) global) partition by hash(c2) partitions 256;
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, unique index i1(c1), index i2(c4,c3,c2,c1));
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, unique index i1(c1,c2,c3), index i2(c5,c4,c3,c2,c1));
call dbms_stats.set_table_stats('test', 't3', numrows=>100000);
call dbms_stats.set_column_stats('test', 't3', 'c1', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c2', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c3', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c4', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c5', distcnt=>1);
set _enable_storage_cardinality_estimation = 0;
result_format: 4
explain_protocol: 3
EXPLAIN EXTENDED_NOADDR select * from t1 where c1 = 1;
