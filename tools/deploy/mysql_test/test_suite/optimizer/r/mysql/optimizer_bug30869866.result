explain
WITH jennifer_1 AS
(
                SELECT DISTINCT c10
                FROM            t6
                WHERE           EXISTS
                                (
                                       SELECT 1
                                       FROM   dual
                                       WHERE  4 IN (EXISTS
                                                    (
                                                           SELECT 1
                                                           FROM   t1 ) ,
                                                    (
                                                             SELECT   count(c5)
                                                             FROM     t5) ) ))
SELECT EXISTS
       (
              SELECT 1
              FROM   jennifer_1 AS ref_44) as ref0
FROM   jennifer_1;
