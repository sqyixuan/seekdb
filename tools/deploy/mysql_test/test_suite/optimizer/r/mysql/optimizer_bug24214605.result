      update([A.MSG_CODE=column_conv(INT,PS:(11,0),NOT NULL,31110049)], [A.MSG_TEXT=column_conv(VARCHAR,utf8mb4_general_ci,length:256,NOT NULL,'证券账户所属客户号与申报客户号不一致')]
      )
  4 - output([A.KHH], [A.ZQZH], [A.SERIAL_NO], [A.YMTH], [A.DRRQ], [A.QRRQ], [A.MSG_CODE], [A.MSG_TEXT]), filter(nil), rowset=16
      equal_conds([A.KHH = VIEW1.B.CUSTOMER_ID], [VIEW1.B.SECURITY_ACCOUNT_ID = A.ZQZH], [VIEW1.B.ACCOUNT_ID = A.YMTH]), other_conds(nil)
      merge_directions([ASC], [ASC], [ASC])
  5 - output([A.KHH], [A.ZQZH], [A.MSG_CODE], [A.MSG_TEXT], [A.SERIAL_NO], [A.YMTH], [A.DRRQ], [A.QRRQ]), filter([A.MSG_CODE = -1]), rowset=16
      access([A.KHH], [A.ZQZH], [A.MSG_CODE], [A.MSG_TEXT], [A.SERIAL_NO], [A.YMTH], [A.DRRQ], [A.QRRQ]), partitions(p[0-5])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([A.KHH], [A.ZQZH]), range(0,MIN ; 100,MAX), 
      range_cond([A.KHH >= 0], [A.KHH <= 100])
  6 - output([VIEW1.B.CUSTOMER_ID], [VIEW1.B.SECURITY_ACCOUNT_ID], [VIEW1.B.ACCOUNT_ID]), filter(nil), rowset=16
      access([VIEW1.B.CUSTOMER_ID], [VIEW1.B.SECURITY_ACCOUNT_ID], [VIEW1.B.ACCOUNT_ID])
