drop table if exists t1, t41;
create table t1 (c1 int primary key, c2 int);
create table t41 (c1 CHAR(103) ,c2 INT(72) , primary key(c2)) PARTITION BY HASH(c2) PARTITIONS 20;
explain_protocol: 2
result_format: 4
EXPLAIN SELECT t41_295.c2 FROM (SELECT t41_295.c1, t41_295.c2 FROM t41 AS t41_295) AS t41_295 WHERE t41_295.c2 = (SELECT t41_295.c2 FROM t41 AS t41_295 ORDER BY 1 LIMIT 1) OR t41_295.c2 = 654 AND t41_295.c2 <> t41_295.c1 ORDER BY 1;
