drop table if exists t1;
CREATE TABLE t1 (
`c1` bigint(20) NOT NULL,
`c2` varchar(100) DEFAULT NULL,
`c3` varchar(100) DEFAULT NULL,
`c4` datetime DEFAULT NULL,
`c5` bigint(20) DEFAULT NULL,
PRIMARY KEY (`c1`),
KEY `i1` (`c2`) BLOCK_SIZE 16384 LOCAL
)
partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);
call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', '50000');
set @a = 0;
insert /*+ query_timeout(100000000000) */  into t1 select @a := @a + 1, concat('ANY_', @a), concat('ROW_', @a), '2023-09-22 09:20:00', @a from table(generator(200000));
alter system major freeze;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC(1000000000);
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', '5000000');
result_format: 4
