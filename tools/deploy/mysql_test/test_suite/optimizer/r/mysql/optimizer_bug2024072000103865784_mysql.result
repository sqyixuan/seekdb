drop table if exists t1;
drop PROCEDURE if exists mylobProcedure;
set ob_default_lob_inrow_threshold=1;
create table t1(c1 text, c2 mediumtext, c3 longtext);
insert into t1 values (repeat('9', 1000), repeat('9', 100000), repeat('9', 10000000));
call dbms_stats.gather_table_stats(null, 't1');
result_format: 4
select 1 from t1 where ifnull(c1, '1') > '2';
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from t1 where ifnull(c2, '1') > '2';
+---+
| 1 |
+---+
| 1 |
+---+
select 1 from t1 where ifnull(c3, '1') > '2';
+---+
| 1 |
+---+
| 1 |
+---+
select length(c1),length(c2),length(c3) from (select /*+no_rewrite*/ c1,c2,c3 from t1);
+------------+------------+------------+
| length(c1) | length(c2) | length(c3) |
+------------+------------+------------+
|       1000 |     100000 |   10000000 |
+------------+------------+------------+

create PROCEDURE mylobProcedure()
BEGIN
declare v1 text;
declare v2 mediumtext;
declare v3 longtext;
SELECT * into v1, v2, v3 From t1 limit 1;
insert into t1 select v1, v2, v3 from dual;
insert into t1 select * from t1 where c1 > v1 and c1 < '2' and c2 > v2 and c2 < '2' and c3 > v2 and c3 < '2';
insert into t1 select /*+no_rewrite*/ * from t1 where c1 > v1 and c1 > '2' and c2 > v2 and c2 > '2' and c3 > v2 and c3 > '2';
insert into t1 select * from t1 where c1 >= v1 and c1 <= v1 and c2 >= v2 and c2 <= v2 and c3 >= v3 and c3 <= v3;
END
//
call mylobProcedure();
select length(c1),length(c2),length(c3) from (select /*+no_rewrite*/ c1,c2,c3 from t1);
+------------+------------+------------+
| length(c1) | length(c2) | length(c3) |
+------------+------------+------------+
|       1000 |     100000 |   10000000 |
|       1000 |     100000 |   10000000 |
|       1000 |     100000 |   10000000 |
|       1000 |     100000 |   10000000 |
+------------+------------+------------+

drop table t1;
drop PROCEDURE mylobProcedure;
