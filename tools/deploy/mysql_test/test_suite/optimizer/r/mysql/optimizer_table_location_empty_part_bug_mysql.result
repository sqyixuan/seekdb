result_format: 4
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table t2(c1 int primary key, c2 int);

select /*+leading(t2 t1) use_nl(t1) use_das(t1) */ * from t1, t2 where t1.c1 = t2.c1;
+----+------+----+------+
| c1 | c2   | c1 | c2   |
+----+------+----+------+
+----+------+----+------+

drop table t1;
drop table t2;
