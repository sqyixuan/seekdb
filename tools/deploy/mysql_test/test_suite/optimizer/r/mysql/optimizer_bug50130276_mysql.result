drop table if exists `t_hsm_log`, `uc_staff_job_info`, `t1cjbsaz` ,`cool_business_delete_record`, `wechat_reply`;
CREATE TABLE `t_hsm_log` (
`logID` int(20) NOT NULL AUTO_INCREMENT COMMENT '日志ID',
`operationTime` datetime DEFAULT NULL COMMENT '操作时间',
`operationContent` text COMMENT '操作内容',
`operationStatus` char(100) DEFAULT NULL COMMENT '日志状态',
`operationObject` char(100) DEFAULT NULL COMMENT '操作对象',
`chsmID` int(11) DEFAULT NULL COMMENT '主机ID',
PRIMARY KEY (`logID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='主机日志表';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `uc_staff_job_info` (
`id` bigint(20) NOT NULL AUTO_INCREMENT,
`version` int(10) NOT NULL DEFAULT 1 COMMENT '版本号',
`create_time` datetime NOT NULL COMMENT '创建时间',
`create_user_id` bigint(20) DEFAULT NULL COMMENT '创建人',
`job_name` varchar(255) NOT NULL COMMENT '岗位名称',
`sort` bigint(20) DEFAULT NULL COMMENT '排序',
`org_id` bigint(20) NOT NULL COMMENT '组织ID',
`job_status` varchar(6) NOT NULL DEFAULT 'US01' COMMENT '状态:US01-生效,US02-失效',
`update_time` datetime NOT NULL COMMENT '更新时间',
`update_user_id` bigint(20) DEFAULT NULL COMMENT '更新人',
`description` varchar(255) DEFAULT NULL COMMENT '备注',
PRIMARY KEY (`id`) USING BTREE
) ENGINE=InnoDB AUTO_INCREMENT=68 DEFAULT CHARSET=utf8 ROW_FORMAT=DYNAMIC COMMENT='系统管理岗位信息';
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
create table if not exists `t1cjbsaz` (
`c1` varchar(10) not null comment 'c1 comment',
`c2` int(11),
`c3` int(11) comment '',
`c4` int(11),
`c5` int(11),
`c6` int(11),
`c7` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
comment='';
create index `i1` on `t1cjbsaz` (`c1` ASC) ;
create index `i2` on `t1cjbsaz` (`c2` ASC) ;
CREATE TABLE `cool_business_delete_record` (
`record_id` int(11) NOT NULL AUTO_INCREMENT ,
`admin_id` int(11) DEFAULT NULL ,
`regtime` int(11) DEFAULT NULL ,
`created_at` int(11) DEFAULT NULL ,
`business_id` int(11) DEFAULT NULL ,
`agent_id` int(11) DEFAULT NULL ,
`all_title` varchar(255) DEFAULT NULL ,
`title` varchar(255) DEFAULT NULL ,
`business_info` text ,
PRIMARY KEY (`record_id`)
) ENGINE=InnoDB AUTO_INCREMENT=3 DEFAULT CHARSET=utf8 ;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
CREATE TABLE `wechat_reply` (
`wechat_reply_id` int(11) NOT NULL AUTO_INCREMENT,
`name` char(32) DEFAULT NULL,
`type` char(32) DEFAULT NULL ,
`file` char(50) DEFAULT NULL ,
`message` text ,
PRIMARY KEY (`wechat_reply_id`)
) ENGINE=InnoDB AUTO_INCREMENT=38 DEFAULT CHARSET=utf8;
Warnings:
Warning	1286	Unknown storage engine 'InnoDB'
