EXPLAIN BASIC select 
  group_concat(
    cast(
      (
        select 
          name 
        from 
          test.wechat_reply 
        limit 
          1 offset 4
      ) as CHAR
    )
  ) over (
    partition by ref_2.record_id, 
    ref_2.agent_id 
    order by 
      subq_0.c5
  ) as c10, 
  sum(
    cast(subq_0.c2 as DECIMAL)
  ) over (
    partition by ref_2.record_id, 
    subq_0.c5 
    order by 
      ref_2.business_id, 
      subq_0.c1
  ) as c15
from 
  (
    (
      select 
        ref_0.operationTime as c0, 
        ref_0.chsmID as c1, 
        ref_1.org_id as c2, 
        ref_0.operationObject as c5, 
        ref_0.chsmID as c6 
      from 
        (
          test.t_hsm_log as ref_0 
          inner join test.uc_staff_job_info as ref_1
        ) 
    ) as subq_0 
    inner join test.cool_business_delete_record as ref_2 on (subq_0.c6 = ref_2.record_id)
  );
