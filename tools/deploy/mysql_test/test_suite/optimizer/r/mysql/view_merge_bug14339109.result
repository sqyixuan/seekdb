| dname | subq_col |
+-------+----------+
| C     |     4400 |
| D     |     4500 |
+-------+----------+

EXPLAIN select /*+ NO_REWRITE */
V.dname, V.subq_col
from
  ( select /*+ NO_REWRITE */
   ( select /*+ NO_REWRITE */ max(e.sal)
   from ( select /*+ NO_REWRITE */  * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select /*+ NO_REWRITE */  * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;
Query Plan
=========================================================
|ID|OPERATOR                 |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------------
|0 |SORT                     |    |1       |111         |
|1 |└─SUBPLAN SCAN           |V   |1       |111         |
|2 |  └─SUBPLAN FILTER       |    |6       |111         |
|3 |    ├─SUBPLAN SCAN       |d   |6       |3           |
|4 |    │ └─TABLE FULL SCAN  |dept|6       |3           |
|5 |    └─SCALAR GROUP BY    |    |1       |18          |
|6 |      └─SUBPLAN SCAN     |e   |1       |18          |
|7 |        └─TABLE FULL SCAN|emp |1       |18          |
=========================================================
Outputs & filters:
-------------------------------------
  0 - output([V.dname], [V.subq_col]), filter(nil), rowset=16
      sort_keys([V.dname, ASC], [V.subq_col, ASC])
  1 - output([V.subq_col], [V.dname]), filter([V.subq_col < 5000], [V.subq_col > 0]), rowset=16
      access([V.subq_col], [V.dname])
  2 - output([subquery(1)], [d.DNAME]), filter(nil), rowset=16
      exec_params_([d.DEPTNO(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  3 - output([d.DEPTNO], [d.DNAME]), filter(nil), rowset=16
      access([d.DEPTNO], [d.DNAME])
  4 - output([dept.DEPTNO], [dept.DNAME]), filter(nil), rowset=16
      access([dept.DEPTNO], [dept.DNAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([dept.__pk_increment]), range(MIN ; MAX)always true
  5 - output([T_FUN_MAX(e.SAL)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_MAX(e.SAL)])
  6 - output([e.SAL]), filter(nil), rowset=16
      access([e.SAL])
  7 - output([emp.EMPno], [emp.SAL], [emp.DEPTNO]), filter([emp.DEPTNO = :0]), rowset=16
      access([emp.EMPno], [emp.SAL], [emp.DEPTNO]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
