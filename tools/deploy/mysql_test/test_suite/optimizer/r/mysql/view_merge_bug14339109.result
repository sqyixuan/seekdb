DROP DATABASE IF EXISTS opt;
create database opt;
use opt;
create table EMP (
EMPno  integer,
SAL integer,
DEPTNO integer
) ;
create table DEPT(
DEPTNO integer,
DNAME char(45)
) ;
insert into EMP values (0, 0 , 0);
insert into EMP values (1, 5000 , 0);
insert into EMP values (2, 0 , 1);
insert into EMP values (3, 4400 , 2);
insert into EMP values (4, 4500 , 3);
insert into DEPT values (0, 'A');
insert into DEPT values (1, 'B');
insert into DEPT values (2, 'C');
insert into DEPT values (3, 'D');
insert into DEPT values (4, 'E');
insert into DEPT values (5, 'F');
result_format: 4
explain_protocol: 2
EXPLAIN select
V.dname, V.subq_col
from
  ( select
   ( select max(e.sal)
   from ( select * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;
Query Plan
========================================================
|ID|OPERATOR               |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |SORT                   |     |1       |6           |
|1 |└─HASH JOIN            |     |1       |6           |
|2 |  ├─SUBPLAN SCAN       |VIEW1|1       |3           |
|3 |  │ └─HASH GROUP BY    |     |1       |3           |
|4 |  │   └─TABLE FULL SCAN|emp  |1       |3           |
|5 |  └─TABLE FULL SCAN    |dept |6       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([dept.DNAME], [VIEW1.max(e.sal)]), filter(nil), rowset=16
      sort_keys([dept.DNAME, ASC], [VIEW1.max(e.sal), ASC])
  1 - output([dept.DNAME], [VIEW1.max(e.sal)]), filter(nil), rowset=16
      equal_conds([VIEW1.emp.DEPTNO = dept.DEPTNO]), other_conds(nil)
  2 - output([VIEW1.max(e.sal)], [VIEW1.emp.DEPTNO]), filter(nil), rowset=16
      access([VIEW1.max(e.sal)], [VIEW1.emp.DEPTNO])
  3 - output([T_FUN_MAX(emp.SAL)], [emp.DEPTNO]), filter([T_FUN_MAX(emp.SAL) < 5000]), rowset=16
      group([emp.DEPTNO]), agg_func([T_FUN_MAX(emp.SAL)])
  4 - output([emp.SAL], [emp.DEPTNO]), filter([emp.SAL > 0]), rowset=16
      access([emp.SAL], [emp.DEPTNO]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
  5 - output([dept.DEPTNO], [dept.DNAME]), filter(nil), rowset=16
      access([dept.DEPTNO], [dept.DNAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([dept.__pk_increment]), range(MIN ; MAX)always true
select
V.dname, V.subq_col
from
  ( select
   ( select max(e.sal)
   from ( select * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;
