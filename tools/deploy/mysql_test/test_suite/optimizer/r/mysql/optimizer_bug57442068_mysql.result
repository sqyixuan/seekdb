result_format: 4
drop table if exists t1, t2, t3;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 2;
create table t2(c1 int, c2 int) partition by hash(c1) partitions 2;
create table t3(c1 int, c2 int) partition by hash(c1) partitions 2;
insert into t1 values (1,1),(1,2),(1,3),(2,1),(2,2),(2,3),(3,1),(3,2),(3,3);
insert into t2 values (1,1),(2,2),(3,3);
insert into t3 values (1,1),(2,2),(3,3);
create index i1 on t1(c1) local;
create index i2 on t1(c2) local;
create index i1 on t3(c1) local;

set ob_enable_transformation = 0;

explain_protocol: 1
