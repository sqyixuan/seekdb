CREATE TABLE table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_ (
  col_int int,
  pk int,
  col_tinyint tinyint,
  col_bigint bigint,
  col_float float,
  col_decimal_20_0 decimal(20,0),
  col_datetime datetime,
  col_smallint smallint)    PARTITION BY hash(pk)
                  subpartition by range columns(col_datetime)
                                subpartition template
                                             (subpartition p0 values less than ('2001-01-01 00:00:00'),
                                                    subpartition p1 values less than ('2003-01-01 00:00:00'),
                                                    subpartition p2 values less than ('2005-01-01 00:00:00'),
                                                    subpartition p3 values less than (maxvalue))
                                                  partitions 10  ;

