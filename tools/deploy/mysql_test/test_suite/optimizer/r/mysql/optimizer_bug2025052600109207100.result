alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 1;
drop table if exists t1;
explain_protocol: 2
result_format: 4
create table t1 (c1 int, c2 int);
# group by 会下压到 table scan, 计划可以正常执行
EXPLAIN select count(*), c1 from t1 where ora_rowscn > 1748210020567564005 and ora_rowscn <= 1748211303993768010 group by c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |1       |3           |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))], [t1.c1]), filter(nil), rowset=16
      group([t1.c1]), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
  1 - output([t1.c1], [T_FUN_COUNT(*)]), filter([ORA_ROWSCN > 1748210020567564005], [ORA_ROWSCN <= 1748211303993768010]), rowset=16
      access([t1.c1], [ORA_ROWSCN]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true, 
      pushdown_groupby([t1.c1]), pushdown_aggregation([T_FUN_COUNT(*)])
select count(*), c1 from t1 where ora_rowscn > 1748210020567564005 and ora_rowscn <= 1748211303993768010 group by c1;
