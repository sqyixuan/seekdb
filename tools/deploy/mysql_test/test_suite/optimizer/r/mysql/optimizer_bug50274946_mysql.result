alter tenant sys set primary_zone = 'RANDOM';
drop table if exists `gf_ar_dly_bill`;
drop table if exists `ob_causal_ordering2`;
drop table if exists `insertintot2`;
drop table if exists `upp_online_checktrans_92`;
CREATE TABLE `gf_ar_dly_bill` (                                         
`tnt_inst_id` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT '租户机构id',                              
`bill_no` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT '账单号',
`ip_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '结算对象ipid',                  
`ip_role_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '结算对象pid', 
`inst_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '分支机构',       
`pd_code` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT '产品码',                                                              
`ar_no` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT '合约号',                   
`bill_tp` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT '账单类型11：正常日账单12：汇总调整日账单',
`setl_tp` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT '结算方式01：实时账单02：预收账单03：后收账单04：周期性账单05：日结账单（暂无）',
`bill_st` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT '核销状态01：未结算02：部分结算03：完全结算',
`bill_dt` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT '账单日期',                            
`actg_dt` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT '登账日期',                              
`acrd_dt` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应收日期',                     
`gmt_pay` timestamp(6) NULL DEFAULT NULL COMMENT '付款时间',
`payee_ac` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收款方账号',                    
`payer_ac` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款方账号（扣款账号，非银行卡时为空）',
`pay_way` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付方式 1:资金2.包量3：包次数4：包时间5：走量',
`pay_orig` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付来源1：主账务2：包量3：预收4：预存5：银行6：积分',   
`clcn_bsc_amt` decimal(25,4) DEFAULT NULL COMMENT '计费交易量',                                        
`clcn_bsc_tp` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '计费依据01：交易金额02：交易笔数',    
`clcn_mthd` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '计费方法01：差额累进02：全额累进',                         
`chrg_itm_code` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '收费项编码',                                          
`ccy` varchar(3) COLLATE utf8mb4_bin NOT NULL COMMENT '币种',                     
`bill_amt` bigint(20) NOT NULL COMMENT '账单金额',                                  
`rcvd_amt` bigint(20) NOT NULL COMMENT '已收金额',                                                                                                                                                                     
`tax_tp` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT '税种01:增值税02：营业税',
`tax_rate` decimal(10,8) NOT NULL COMMENT '税率',
`tax_amt` bigint(20) NOT NULL COMMENT '税额',
`exn_inf` varchar(40960) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '扩展信息',
`orig_rcrd_id` varchar(128) COLLATE utf8mb4_bin NOT NULL COMMENT '源记录id',
`mthly_bill_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '月账单号',
`wrtof_dtl_cnt` bigint(20) DEFAULT NULL COMMENT '已核销明细数量',
`to_wrtof_dtl_cnt` bigint(20) DEFAULT NULL COMMENT '待核销明细数量',
`anl_dmsn1` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分析维度1',
`anl_dmsn2` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分析维度2',
`anl_dmsn3` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分析维度3',
`anl_dmsn4` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分析维度4',
`last_moder` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '最近修改人',
`gmt_create` timestamp(6) NOT NULL COMMENT '创建时间',
`gmt_modified` timestamp(6) NOT NULL COMMENT '修改时间',
`charge_tp` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '计收费环境类型01  主站云计收费02  主站离线计收费03  主站老计收费',
`stl_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '结算对象(已废弃，值等于ip_role_id)',
`svc_amt` bigint(20) DEFAULT NULL COMMENT '交易金额',
`chk_rcrd_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联的确认记录id，若为空，说明该日账单并没有发生过确认',
`tp` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '应收1返点2',
`actg_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'N：不发送核算消息Y：发送核算消息',
`payer_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '扣款对象pid',
`sgn_ip_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '签约对象ipid',
`sgn_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '签约对象pid',
`memo` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '原因（如果是调整账单，调整原因放入此列）',
`writingoff_amt` bigint(20) DEFAULT '0' COMMENT '核销中金额',
`svc_bill_amt` bigint(20) DEFAULT NULL COMMENT '账单计费金额，计收费计费时生成的中间金额',
`svc_ccy` varchar(3) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账单计费币种',
`env_source` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '环境标识',
`metadata_source` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '元数据来源标识，包括(用户、商户、产品、合约、计费)来源',
`setl_time_zone` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账单结算时区',
`actg_time_zone` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '账单核算时区',
`inter_trade_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Y: 是关联交易 N: 不是关联交易',
`actg_bill_dt` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '核算时区账单日期',
`auto_writeoff_group_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '自动核销关联组号',
`partition_id` char(4) COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`bill_no`,23,2)) VIRTUAL,
`anl_dmsn_agg_sum` varchar(20480) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分析维度汇总信息',
PRIMARY KEY (`tnt_inst_id`, `bill_no`),
UNIQUE KEY `uk_tnt_inst_id_orig_rcrd_id` (`tnt_inst_id`, `orig_rcrd_id`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx_tnt_inst_id_chk_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `chk_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_bill_no_ip_role_id` (`tnt_inst_id`, `bill_no`, `ip_role_id`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_mthly_bill_no_chk_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `mthly_bill_no`, `chk_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_ip_role_id_orig_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `orig_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_tnt_inst_id_ip_role_id_bill_dt` (`tnt_inst_id`, `ip_role_id`, `bill_dt`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_mthly_bill_no_ip_role_id_bill_st` (`tnt_inst_id`, `mthly_bill_no`, `ip_role_id`, `bill_st`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_mthly_bill_no_ip_role_id_bill_tp` (`tnt_inst_id`, `mthly_bill_no`, `ip_role_id`, `bill_tp`) BLOCK_SIZE 16384 LOCAL,
CONSTRAINT `gf_ar_dly_bill1` CHECK ((`partition_id` = substr(`ip_role_id`,-3,2))),
CONSTRAINT `gf_ar_dly_bill2` CHECK ((`partition_id` = substr(`mthly_bill_no`,23,2)))
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '应收日账单表'
