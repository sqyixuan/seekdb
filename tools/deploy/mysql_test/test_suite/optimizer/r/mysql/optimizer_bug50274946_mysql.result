CREATE TABLE `ob_causal_ordering2` (
`grp_num` bigint(20) NOT NULL,
`row_num` bigint(20) NOT NULL,
`version` bigint(20) NOT NULL DEFAULT '0',
`gm_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gm_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
PRIMARY KEY (`grp_num`, `row_num`, `version`),
KEY `version` (`version`) BLOCK_SIZE 16384 LOCAL 
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 ;
CREATE TABLE `insertintot2` (
`a` varchar(10) NOT NULL,
`b` varchar(10) DEFAULT NULL,
`c` int(11) DEFAULT NULL,
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
PRIMARY KEY (`a`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `upp_online_checktrans_92` (
`trans_seqno` varchar(64) NOT NULL,
`trans_reqseqno` varchar(64) NOT NULL,
`trans_reqdate` varchar(32) NOT NULL,
`trans_departmentid` varchar(32) NOT NULL,
`trans_sequence` bigint(20) NOT NULL,
`trans_reqtime` varchar(64) DEFAULT NULL,
`sharding_key` bigint(20) NOT NULL,
`gmt_create` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
`Trans_ClearDate` varchar(32) NOT NULL,
`trans_code` varchar(64) DEFAULT NULL,
`trans_id` varchar(64) NOT NULL,
`user_acctno` varchar(64) NOT NULL,
`trans_rcvacctno` varchar(64) NOT NULL,
`trans_amt` decimal(15,2) NOT NULL,
`trans_checkstatus` char(1) NOT NULL,
`trans_respcode` varchar(20) DEFAULT NULL,
`trans_respmsg` varchar(200) DEFAULT NULL,
`trans_step` char(1) DEFAULT NULL,
`trans_status` char(2) DEFAULT NULL,
`trans_hostseqno` varchar(32) DEFAULT NULL,
`trans_hostdate` date DEFAULT NULL,
`trans_picino` varchar(32) DEFAULT NULL,
`trans_czseqno` varchar(32) DEFAULT NULL,
`trans_cztranscode` char(2) DEFAULT NULL,
`trans_bankid` varchar(12) DEFAULT NULL,
`trans_accttype` varchar(5) DEFAULT NULL,
`trans_validdate` varchar(12) DEFAULT NULL,
`trans_cvn` varchar(32) DEFAULT NULL,
`trans_accountname` varchar(132) DEFAULT NULL,
`trans_idtype` varchar(1) DEFAULT NULL,
`trans_idno` varchar(32) DEFAULT NULL,
`trans_phone` varchar(32) DEFAULT NULL,
`trans_signo` varchar(64) DEFAULT NULL,
`trans_instid` varchar(32) DEFAULT NULL,
`trans_remark1` varchar(132) DEFAULT NULL,
`trans_remark2` varchar(132) DEFAULT NULL,
`mer_code` varchar(32) DEFAULT NULL,
`trans_marking` varchar(32) DEFAULT NULL,
`is_sett` char(1) DEFAULT NULL,
`user_acctname` varchar(120) DEFAULT NULL,
`trans_rcvacctname` varchar(120) DEFAULT NULL,
`corporation_code` char(4) DEFAULT NULL,
`corporation_deptid` varchar(32) DEFAULT NULL,
PRIMARY KEY (`trans_seqno`, `trans_departmentid`, `trans_sequence`),
KEY `idx_trans_cleardate` (`Trans_ClearDate`, `trans_departmentid`, `trans_step`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_check_gmt_cleardate` (`gmt_create`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_passagewayid_instid` (`Trans_ClearDate`, `trans_departmentid`, `trans_instid`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_upp_online_checktrans_09_batchpici` (`trans_marking`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_checktrans_departmentid_picino` (`trans_departmentid`, `trans_picino`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_checktrans_departmentid_step_key_cleardate` (`trans_departmentid`, `trans_step`, `sharding_key`, `Trans_ClearDate`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_checktrans_transcode_gmtcreate` (`trans_code`, `gmt_create`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
result_format: 4
SELECT EXISTS (SELECT 1
               FROM   upp_online_checktrans_92 AS ref_3
               WHERE  EXISTS (SELECT 1
                              FROM   insertintot2 AS ref_4
                              WHERE  EXISTS (SELECT /*+index(ref_5 uk_tnt_inst_id_orig_rcrd_id)*/   1
                                             FROM   gf_ar_dly_bill
                                                    AS ref_5
                                             WHERE  EXISTS (SELECT 1
                                                            FROM
ob_causal_ordering2 AS
ref_6)))) AS c1
FROM   dual;
+----+
| c1 |
+----+
|  0 |
+----+

drop table if exists `gf_ar_dly_bill`;
drop table if exists `ob_causal_ordering2`;
drop table if exists `insertintot2`;
drop table if exists `upp_online_checktrans_92`;

