drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (a int primary key, b int, c int);
create table t2 (a int , b int primary key, c int);
create table t3 (a int, b int , c int primary key);
explain_protocol: 2
EXPLAIN select /*+ leading(t1 v) use_nl(v)*/ * from t1, (select /*+ no_merge */ t2.b, t3.c from t2,t3 where t2.c>t3.c) v  where t1.a < v.c and t1.b = v.b;
