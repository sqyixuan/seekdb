select /*+ leading(t1 v) use_nl(v)*/ * from t1, (select /*+ no_merge */ t2.b, t3.c from t2,t3 where t2.c>t3.c) v  where t1.a < v.c and t1.b = v.b;
a	b	c	b	c
EXPLAIN select /*+ use_plan_cache(none) */ a from t1 where EXISTS (select /*+ no_unnest */ a from t2 where  EXISTS (select /*+ no_unnest */ a from t3 where t1.a > t3.a and t2.b < t3.a) and t1.c = t2.a);
