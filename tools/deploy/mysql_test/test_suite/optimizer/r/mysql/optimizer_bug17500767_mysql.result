      (#keys=1, [teacher.tid]), dop=2
 10 - output([teacher.tid], [teacher.subject = 'KY'], [teacher.subject IN ('WI', 'MO', 'WV')]), filter(nil), rowset=16
 11 - output([teacher.tid], [teacher.subject = 'KY'], [teacher.subject IN ('WI', 'MO', 'WV')]), filter(nil), rowset=16
 12 - output([teacher.tid], [teacher.subject = 'KY'], [teacher.subject IN ('WI', 'MO', 'WV')]), filter([teacher.subject = 'KY' OR teacher.subject IN ('WI',
       'MO', 'WV')], [RF_IN_FILTER(teacher.tid)], [RF_RANGE_FILTER(teacher.tid)], [RF_BLOOM_FILTER(teacher.tid)]), rowset=16
      access([teacher.tid], [teacher.subject]), partitions(p[0-7])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false,false], 
      range_key([teacher.tid]), range(MIN ; MAX)always true
explain 
select /*+leading(stu, teacher) use_nl(teacher)*/ 
sum (cls)
from stu, teacher
where 
tid = sid
and teacher.name = 'X'
 limit 10;
