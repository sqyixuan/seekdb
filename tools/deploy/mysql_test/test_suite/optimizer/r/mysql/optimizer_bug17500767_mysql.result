      is_index_back=false, is_global_index=false, 
      range_key([score.sid], [score.subject]), range(MIN,MIN ; MAX,MAX)always true
create table t1(a int, b int, c int) partition by hash(a) partitions 5;
explain select * from (select a from t1 union all select a from t1 as t2) as t3, t1 as t4 where t3.a = t4.a;
