      equal_conds([teacher.tid = stu.sid]), other_conds([(T_OP_AND, teacher.subject = 'KY', stu.cls >= 0, stu.cls <= 2000) OR teacher.subject IN ('WI', 
      'MO', 'WV')])
  5 - output([stu.cls], [stu.sid]), filter(nil), rowset=16
