      access([stu.sid]), partitions(p[0-5])
      is_index_back=false, is_global_index=false, 
      range_key([stu.cls], [stu.sid]), range(MIN,MIN ; MAX,MAX)always true
  5 - output([score.score]), filter(nil), rowset=16
