result_format: 4
explain_protocol: 2
drop table if exists t1,t2;
drop function if exists f1;
drop function if exists f2;
explain_protocol: 0
create table t1(c1 int, c2 varchar(10), c3 date);
create table t2(c1 int, c2 int);
insert into t1 values(10, 'aaa', DATE'2011-01-01'),
                     (11, 'aba', DATE'2011-02-01'),
                     (12, 'abc', DATE'2011-03-01'),
                     (12, 'abc', DATE'2021-03-01');
insert into t1 select c1+5, concat(c2,'def'), c3 from t1;
insert into t2 values(1,0),(1,1),(0,1),(2,0),(2,1),(1,2);
insert into t2 select c1 + 5, c2 + 5 from t2;
create function f1(a int)
returns int
begin
	return a;
end;
//

create function f2(a int)
returns int deterministic
begin
	return a;
end;
//
explain_protocol: 2
#basic test
EXPLAIN select * from t1 where JSON_VALID(c2)
                                and st_isvalid(ST_GeomFromText(c2,26918))
                                and c1+1 = 20
                                and c3 = '2011-01-01'
                                and f1(c1) = 1
                                and f2(c1) = 1
                                and f1(1) = c1 + 10
                                and f2(1) = c1 + 10;
