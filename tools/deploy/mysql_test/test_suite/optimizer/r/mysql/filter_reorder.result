#join filter
EXPLAIN select * from t1, t2 where JSON_VALID(concat(t1.c2,t2.c1))
                            and st_isvalid(ST_GeomFromText(t1.c2,t2.c1))
                            and t1.c1+1 > t2.c2 + 5
                            and t1.c3  > t2.c1
                            and f1(t1.c1) > t2.c2
                            and f2(t1.c1) > t2.c2;
