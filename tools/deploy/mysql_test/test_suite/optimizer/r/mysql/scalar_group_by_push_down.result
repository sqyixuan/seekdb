result_format: 4
explain_protocol: 2
##
## Test Name: scalar_group_by_push_down
##
##
##
drop table if exists t1, t2, t3;
create table t1 (c1 int, c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;

# should use hash
EXPLAIN select count(distinct c2) from t1;
Query Plan
===========================================================================
|ID|OPERATOR                               |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------
|0 |SCALAR GROUP BY                        |        |1       |234         |
|1 |└─PX COORDINATOR                       |        |1       |234         |
|2 |  └─EXCHANGE OUT DISTR                 |:EX10001|1       |233         |
|3 |    └─MERGE GROUP BY                   |        |1       |233         |
|4 |      └─SUBPLAN SCAN                   |VIEW1   |100     |231         |
|5 |        └─HASH DISTINCT                |        |100     |231         |
|6 |          └─EXCHANGE IN DISTR          |        |100     |207         |
|7 |            └─EXCHANGE OUT DISTR (HASH)|:EX10000|100     |192         |
|8 |              └─HASH DISTINCT          |        |100     |157         |
|9 |                └─PX PARTITION ITERATOR|        |1000    |58          |
|10|                  └─TABLE FULL SCAN    |t1      |1000    |58          |
===========================================================================
