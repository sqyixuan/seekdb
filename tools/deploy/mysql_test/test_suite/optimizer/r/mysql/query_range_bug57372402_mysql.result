DROP TABLE if exists t1,t2;
CREATE TABLE t1 (
c1 datetime,
KEY idx1 (c1)
);
insert into t1 values ('2024-01-02 12:00:00');
result_format: 4
explain select /*+index(t1 idx1)*/ * from t1 where c1 < time '10:00:00';
