      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.__pk_increment]), range(NULL,MAX ; CURRENT_DATE 10:00:00.000000,MIN), 
      range_cond([t1.c1 < cast('10:00:00', MYSQL_DATETIME(-1, -1))])
