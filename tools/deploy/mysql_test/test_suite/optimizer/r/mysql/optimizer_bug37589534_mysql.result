drop table if exists t1;
drop table if exists t2;
create table t1 (pk int not null, primary key (`pk`));
create table t2 (c1 int);
result_format: 4
explain_protocol: 2
##distinct const elimination
EXPLAIN select distinct 1 from t1 limit 1;
