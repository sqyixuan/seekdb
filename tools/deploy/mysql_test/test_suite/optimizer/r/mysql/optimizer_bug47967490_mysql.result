              FROM   (SELECT DISTINCT GRANDPARENT1 . col_varchar_20_key AS G1
                      FROM   g AS GRANDPARENT1
                      WHERE  ( GRANDPARENT1 . `col_int_key`, GRANDPARENT1 . `pk` )
                             IN
                                     (SELECT PARENT1 . `col_int_key` AS P1,
                                     PARENT1 . `col_int_key` AS P2
                                     FROM
                                     x AS
                                     PARENT1
                                     LEFT JOIN i AS PARENT2
                                            ON ( PARENT1 . `pk` >=
                                                 PARENT2 . `col_int` )
                                     WHERE
                                     (
                                     PARENT1 . `col_int`,
                                     GRANDPARENT1 . `col_int_key` )
                                     IN
                                           (SELECT DISTINCT CHILD1 . `col_int` AS
                                                            C1,
                                                    CHILD1 . `pk`      AS C2
                                           FROM
                                           bb AS
                                           CHILD1
                                           WHERE  (
                                           GRANDPARENT1 . `col_datetime_key`
                                           BETWEEN
                                           '2008-12-21' AND '2007-01-24'
                                                          ))
                                     AND ( (
                                     PARENT1 . `pk` < PARENT1 . `col_int` )
                                     OR
                                     GRANDPARENT1 . col_varchar_20_key IS NOT
