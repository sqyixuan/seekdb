result_format: 4
drop table if exists t1;
drop table if exists tp1;
create table t1(c1 int primary key, c2 int ,c3 int, c4 int);
create table tp1(c1 int primary key, c2 int ,c3 int, c4 int) partition by hash(c1) partitions 4;
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1, c1 from cte;
insert into tp1 select * from t1;

explain_protocol: 1
==================================================================================
====================== test new behaviors in 4_2_5 ===============================
==================================================================================
## DIST_BASIC_METHOD
EXPLAIN BASIC select sum((select /*+no_use_das(a)*/ a.c2+a.c3 from t1 a where a.c1 = t_outer.c1)) s_val from t1 t_outer;
