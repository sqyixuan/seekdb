drop table if exists t1, test45, test4;
create table t1(c1 int, c2 int)partition by hash(c1) partitions 5;
create index i1 on t1(c2);
insert into t1 values(1,1);
insert into t1 values(2,2);
CREATE TABLE `test45` (
`c81` blob DEFAULT NULL
);
CREATE TABLE `test4` (
`c80` float NOT NULL
)        
partition by key(c80) 
(partition p0,
partition p1);
