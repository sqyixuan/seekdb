drop table if exists t1;
create table t1(a int primary key, b int, c int, d int) partition by hash(a) partitions 4;
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
result_format: 4
explain_protocol: 2
EXPLAIN select * from (select * from t1 order by b) where a+b < 10 limit 10;
Query Plan
=================================================================
|ID|OPERATOR                     |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |LIMIT                        |        |1       |16          |
|1 |└─PX COORDINATOR MERGE SORT  |        |1       |16          |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000|1       |16          |
|3 |    └─TOP-N SORT             |        |1       |15          |
|4 |      └─PX PARTITION ITERATOR|        |1       |15          |
|5 |        └─TABLE FULL SCAN    |t1      |1       |15          |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      limit(10), offset(nil)
  1 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      sort_keys([t1.b, ASC])
  2 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      dop=1
  3 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      sort_keys([t1.b, ASC]), topn(10)
  4 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter(nil), rowset=16
      force partition granule
  5 - output([t1.a], [t1.b], [t1.c], [t1.d]), filter([t1.a + t1.b < 10]), rowset=16
      access([t1.a], [t1.b], [t1.c], [t1.d]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.a]), range(MIN ; MAX)always true
select * from (select * from t1 order by b) where a+b < 10 limit 10;
