drop table if exists t1;
CREATE TABLE `t1` (
`c1` int(11) NOT NULL,
`c2` enum('aaa','bbbb','cccc') DEFAULT NULL,
PRIMARY KEY (`c1`),
KEY `i2` (`c2`) BLOCK_SIZE 16384 LOCAL
);
insert into t1 values (1, 'aaa');
insert into t1 values (2, 'bbbb');
insert into t1 values (3, 'cccc');
result_format: 4
explain select /*+ parallel(2) */ * from t1 where c2 = 'bbbb';
