result_format: 4
DROP TABLE if exists t1, src;

CREATE TABLE t1 (c1 INT, c2 INT, c3 INT, c4 INT, primary key(c1,c2,c3,c4));
CREATE TABLE src (c1 INT);
insert into src WITH RECURSIVE cte AS (SELECT 1 AS num UNION ALL SELECT num + 1 FROM cte WHERE num < 20) SELECT num FROM cte;
insert into t1 select s1.c1,s2.c1,s3.c1,s4.c1 from src s1, src s2, src s3, src s4;

explain_protocol: 2
EXPLAIN select * from t1 where c1 between 9 and 4 and c3 = 3 or c1 like 4 and c1 between 9 and 0 and c3 between 9 and 7 order by 1,2,3,4;
