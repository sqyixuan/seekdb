drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
explain_protocol: 2
result_format: 4

# shared exprs in sort
EXPLAIN select /*+no_rewrite*/ c1 from t1 order by c1+1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |SORT             |    |1       |3           |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1]), filter(nil), rowset=16
      sort_keys([t1.c1 + 1, ASC])
  1 - output([t1.c1], [t1.c1 + 1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select /*+no_rewrite*/ c1 from t1 order by c1+1;
