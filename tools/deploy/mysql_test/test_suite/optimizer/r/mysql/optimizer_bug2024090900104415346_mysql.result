drop table if exists t1;
CREATE TABLE `t1` (
`id` bigint(20) NOT NULL AUTO_INCREMENT,
`customer_id` bigint(20) NOT NULL ,
`period` varchar(6) NOT NULL,
`tax_code` varchar(16) NOT NULL,
`ssd_id` bigint(20) NOT NULL,
`final_tax_credit` decimal(16,2),
`last_tax_credit` decimal(16,2),
`payable_amt` decimal(16,2) DEFAULT NULL,
`paid_amt` decimal(16,2) DEFAULT NULL,
`tax_basis` decimal(16,2) DEFAULT NULL,
`vat_payable_amt` decimal(16,2) DEFAULT NULL,
`add_city_build_amt` decimal(16,2) DEFAULT NULL,
`add_education_amt` decimal(16,2) DEFAULT NULL,
`add_location_education_amt` decimal(16,2) DEFAULT NULL,
`current_sales_revenue` decimal(16,2) DEFAULT NULL,
`cumulative_sales_revenue` decimal(16,2) DEFAULT NULL,
`total_profit_amount` decimal(16,2) DEFAULT NULL,
`output_tax_amount` decimal(16,2) DEFAULT NULL,
`input_tax_amount` decimal(16,2) DEFAULT NULL,
`input_tax_turns_out_amount` decimal(16,2) DEFAULT NULL,
`simple_tax_amount` decimal(16,2) DEFAULT NULL,
`business_cost` decimal(16,2) DEFAULT NULL,
`reduce_amount` decimal(16,2) DEFAULT NULL,
`review_status` int(1) DEFAULT NULL,
`create_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
`modify_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
`ct_period_start_people_num` decimal(16,2) DEFAULT NULL,
`ct_period_end_people_num` decimal(16,2) DEFAULT NULL,
`ct_period_start_property` decimal(16,2) DEFAULT NULL,
`ct_period_end_property` decimal(16,2) DEFAULT NULL ,
`cur_period_sales_revenue` decimal(18,2) DEFAULT NULL ,
PRIMARY KEY (`id`, `customer_id`),
UNIQUE KEY `UK_TX_BATCH_REVIEW` (`customer_id`, `ssd_id`) BLOCK_SIZE 16384 LOCAL,
KEY `IDX_CUSTOMER_ID_PERIOD` (`customer_id`, `period`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_create_date` (`create_date`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_modify_date` (`modify_date`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 257890105 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '批量审核'
