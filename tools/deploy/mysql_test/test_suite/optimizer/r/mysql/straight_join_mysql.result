drop table if exists t1,t2,t3,t4,t5;
drop view if exists v1, v2;
drop sequence if exists s1;
create table t1 (c1 int primary key, c2 int);
create sequence s1 cache 1000 noorder;
create table t2 (c1 int, c2 int, index id2_1 (c1));
create table t3 (c1 int, c2 int);
create index id3_1 on t3(c1,c2);
create table t4 (c1 int, c2 int, index id4_1 (c2));
create table t5 (c1 int, c2 int);
insert into t1 select s1.nextval, uniform(1,10000,random(1)) from table(generator(10));
insert into t2 select uniform(1,10000,random(1)), uniform(1,10000,random(1)) from table(generator(100));
insert into t3 select uniform(1,10000,random(1)), uniform(1,10000,random(1)) from table(generator(1000));
insert into t4 select uniform(1,10000,random(1)), uniform(1,10000,random(1)) from table(generator(10000));
insert into t5 select uniform(1,10000,random(1)), uniform(1,10000,random(1)) from table(generator(10000));
result_format: 4
explain_protocol: 2
