drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int, primary key(c1, c2));
result_format: 4
explain_protocol: 1
EXPLAIN BASIC select /*+ opt_param('NESTED_LOOP_JOIN_ENABLED', 'true') */ * from t1, t2 where t1.c1 < t2.c1;
