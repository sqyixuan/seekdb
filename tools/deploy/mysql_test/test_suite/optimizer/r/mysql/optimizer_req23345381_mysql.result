drop table if exists t1, t2;
create table t1 (c1 int, c2 int, c3 int, c4 int);
create table t2 (c1 int, c2 int, c3 int, c4 int, index idx_t2_c1 (c1), index idx_t2_c1_c2 (c1, c2));
result_format: 4
explain_protocol: 2
merge group by, 优先利用下层算子的序
EXPLAIN select /*+index(t2 idx_t2_c1) no_use_hash_aggregation*/ c1, c2, c3 from t2 group by c1, c2, c3 order by c2;
