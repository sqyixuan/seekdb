drop table if exists target1;
drop table if exists target2;
drop table if exists t1;
drop table if exists t2;
create table target1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create table target2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t1 (c1 int, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int, c2 int) partition by hash(c1) partitions 4;
insert into t1 values (1, 2), (2, 2), (3, 4), (4, 4);
insert into t2 values (0, 1), (1, 5), (2, 4), (3, 3);
explain_protocol: 2
result_format: 4
set autocommit = 0;
## simple select
EXPLAIN insert into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1;
Query Plan
====================================================================
|ID|OPERATOR                 |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------
|0 |PX COORDINATOR           |               |4       |54          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000       |4       |52          |
|2 |  └─PX PARTITION ITERATOR|               |4       |48          |
|3 |    └─INSERT             |               |4       |48          |
|4 |      └─SUBPLAN SCAN     |ANONYMOUS_VIEW1|4       |16          |
|5 |        └─TABLE FULL SCAN|t1             |4       |16          |
====================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=1
  2 - output(nil), filter(nil), rowset=16
      partition wise, force partition granule
  3 - output(nil), filter(nil)
      columns([{target1: ({target1: (target1.c1, target1.c2, target1.c3)})}]), partitions(p[0-3]), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW1.c1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)], [column_conv(INT,PS:(11,
      0),NULL,cast(ANONYMOUS_VIEW1.t1.c1 + t1.c2, INT(-1, 0)))])
  4 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2])
  5 - output([t1.c1], [t1.c2], [t1.c1 + t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
insert into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1;
(select * from target1);
+----+------+------+
| c1 | c2   | c3   |
+----+------+------+
|  4 |    4 |    8 |
|  1 |    2 |    3 |
|  2 |    2 |    4 |
|  3 |    4 |    7 |
+----+------+------+
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1);
+------+------+---------------+
| c1   | c2   | t1.c1 + t1.c2 |
+------+------+---------------+
|    4 |    4 |             8 |
|    1 |    2 |             3 |
|    2 |    2 |             4 |
|    3 |    4 |             7 |
+------+------+---------------+
rollback;

