|0 |DISTRIBUTED INSERT    |               |1       |24          |
|1 |└─PX COORDINATOR      |               |1       |4           |
|2 |  └─EXCHANGE OUT DISTR|:EX10000       |1       |4           |
|3 |    └─SUBPLAN SCAN    |ANONYMOUS_VIEW1|1       |3           |
|4 |      └─TABLE GET     |t1             |1       |3           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{target1: ({target1: (target1.c1, target1.c2, target1.c3)}, {idx_target1: (target1.c2, target1.c1)})}]), partitions(p0), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW1.c1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)], [column_conv(INT,PS:(11,
      0),NULL,cast(ANONYMOUS_VIEW1.t1.c1 + t1.c2, INT(-1, 0)))])
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2]), filter(nil), rowset=16
  2 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2]), filter(nil), rowset=16
      is_single, dop=1
  3 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2], [ANONYMOUS_VIEW1.t1.c1 + t1.c2])
  4 - output([t1.c1], [t1.c2], [cast(10, INT(11, 0)) + t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range[10 ; 10], 
      range_cond([t1.c1 = 10])
