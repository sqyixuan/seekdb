  `b_tag` varchar (120) DEFAULT NULL COMMENT 'b标签',
  `m_tag` varchar (120) DEFAULT NULL COMMENT 'm标签',
  `ext_json` mediumtext DEFAULT NULL COMMENT '请求体',
  `gmt_create` datetime DEFAULT CURRENT_TIMESTAMP COMMENT '插入时间',
  PRIMARY KEY (`ds`, `city_id`, `id`)
) AUTO_INCREMENT = 210053446 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '推荐有奖请求入参数' LOB_INROW_THRESHOLD = 40960 
