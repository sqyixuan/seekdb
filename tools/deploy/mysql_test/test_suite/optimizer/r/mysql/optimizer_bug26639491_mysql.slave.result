SELECT
 (SELECT DISTINCT COUNT(OUTR . `col_varchar_20`) AS X
  FROM C AS OUTR2
  LEFT JOIN B AS OUTR ON (OUTR2 . `pk` = OUTR . `col_int`)
  WHERE OUTR . `col_int` IN
    (SELECT DISTINCT INNR . `col_int_key` AS Y
     FROM BB AS INNR2
     LEFT JOIN CC AS INNR ON (INNR2 . `pk` <= INNR . `col_int`)
     WHERE INNR . `col_date` BETWEEN '2003-03-18' AND '2000-02-23')
   AND OUTR . `col_varchar_10` = 'm'
  ORDER BY 1 DESC, OUTR . `col_int_key` ASC , OUTR . `pk` LIMIT 1),
 (SELECT DISTINCT OUTR . `col_date` AS X
  FROM B AS OUTR
  WHERE OUTR . `pk` IN
    (SELECT DISTINCT INNR . `col_int` AS Y
     FROM CC AS INNR
     WHERE OUTR . `col_datetime` IS NOT NULL)
   AND OUTR . `col_varchar_10` < 'h'
  ORDER BY 1 ASC, OUTR . `col_date` ,
                  OUTR . `pk` LIMIT 1)
FROM DUAL;
