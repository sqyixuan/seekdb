=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |1       |114         |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|1       |113         |
|2 |  └─HASH JOIN                    |        |1       |111         |
|3 |    ├─PX PARTITION ITERATOR      |        |1       |7           |
|4 |    │ └─TABLE RANGE SCAN         |t1      |1       |7           |
|5 |    └─EXCHANGE IN DISTR          |        |12      |103         |
|6 |      └─EXCHANGE OUT DISTR (PKEY)|:EX10000|12      |98          |
|7 |        └─PX PARTITION ITERATOR  |        |12      |85          |
|8 |          └─TABLE FULL SCAN      |t2      |12      |85          |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t2.c1, t2.c2, t2.c3)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c2], [t2.c2], [t1.c1], [t1.c3], [t2.c1], [t2.c3]), filter(nil), rowset=16
      equal_conds([t1.c2 = t2.c2]), other_conds(nil)
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      affinitize, force partition granule
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p1sp[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2]), range(1,MIN ; 1,MAX), 
      range_cond([t1.c1 = 1])
  5 - output([t2.c2], [t2.c1], [t2.c3]), filter(nil), rowset=16
  6 - output([t2.c2], [t2.c1], [t2.c3]), filter(nil), rowset=16
      (#keys=1, [t2.c2]), dop=1
  7 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      force partition granule
  8 - output([t2.c1], [t2.c2], [t2.c3]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3]), partitions(p0sp[0-3], p1sp[0-3], p2sp[0-3], p3sp[0-3], p4sp[0-3], p5sp[0-3], p6sp[0-3], p7sp[0-3], p8sp[0-3], p9sp[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2]), range(MIN,MIN ; MAX,MAX)always true
