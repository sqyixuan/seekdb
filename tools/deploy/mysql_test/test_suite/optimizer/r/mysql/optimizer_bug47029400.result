drop table if exists bmsql_order_line, bmsql_district;
create table bmsql_order_line (
ol_w_id         integer   not null,
ol_d_id         integer   not null,
ol_o_id         integer   not null,
ol_number       integer   not null,
ol_i_id         integer   not null,
ol_delivery_d   timestamp default current_timestamp,
ol_amount       decimal(6,2),
ol_supply_w_id  integer,
ol_quantity     integer,
ol_dist_info    char(24),
PRIMARY KEY (ol_w_id, ol_d_id, ol_o_id, ol_number)
)  partition by hash(ol_w_id) subpartition by hash(ol_d_id) subpartitions 11 partitions 128;
create table bmsql_district (
d_w_id       integer       not null,
d_id         integer       not null,
d_ytd        decimal(12,2),
d_tax        decimal(4,4),
d_next_o_id  integer,
d_name       varchar(10),
d_street_1   varchar(20),
d_street_2   varchar(20),
d_city       varchar(20),
d_state      char(2),
d_zip        char(9),
PRIMARY KEY (d_w_id, d_id)
) partition by hash(d_w_id) partitions 128;
explain_protocol: 2
result_format: 4

EXPLAIN SELECT ol_i_id                 
FROM bmsql_district                 
JOIN bmsql_order_line ON ol_w_id = d_w_id                  
     AND ol_d_id = d_id                  
     AND ol_o_id >= d_next_o_id - 20                  
     AND ol_o_id < d_next_o_id                 
WHERE d_w_id = 392 AND d_id = 4
;
Query Plan
==============================================================
|ID|OPERATOR          |NAME            |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |NESTED-LOOP JOIN  |                |1       |21          |
|1 |├─TABLE GET       |bmsql_district  |1       |5           |
|2 |└─TABLE RANGE SCAN|bmsql_order_line|1       |16          |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output([bmsql_order_line.ol_i_id]), filter(nil), rowset=16
      conds(nil), nl_params_([bmsql_district.d_next_o_id(:0)]), use_batch=true
  1 - output([bmsql_district.d_next_o_id]), filter([bmsql_district.d_next_o_id > bmsql_district.d_next_o_id + -20]), rowset=16
      access([bmsql_district.d_next_o_id]), partitions(p8)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([bmsql_district.d_w_id], [bmsql_district.d_id]), range[392,4 ; 392,4], 
      range_cond([bmsql_district.d_w_id = 392], [bmsql_district.d_id = 4])
  2 - output([bmsql_order_line.ol_i_id]), filter(nil), rowset=16
      access([GROUP_ID], [bmsql_order_line.ol_i_id]), partitions(p8sp4)
      is_index_back=false, is_global_index=false, 
      range_key([bmsql_order_line.ol_w_id], [bmsql_order_line.ol_d_id], [bmsql_order_line.ol_o_id], [bmsql_order_line.ol_number]), range(MIN ; MAX), 
      range_cond([bmsql_order_line.ol_w_id = 392], [bmsql_order_line.ol_d_id = 4], [bmsql_order_line.ol_o_id >= :0 + -20], [bmsql_order_line.ol_o_id < :0])
SELECT ol_i_id                 
FROM bmsql_district                 
JOIN bmsql_order_line ON ol_w_id = d_w_id                  
     AND ol_d_id = d_id                  
     AND ol_o_id >= d_next_o_id - 20                  
     AND ol_o_id < d_next_o_id                 
WHERE d_w_id = 392 AND d_id = 4
;
