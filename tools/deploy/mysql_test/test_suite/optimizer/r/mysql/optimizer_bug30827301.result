explain basic WITH  jennifer_0 AS (
    select distinct  100 as c0,  ref_0.c1 as c1,  26 as c2
    from  t1 as ref_0
    where (select count(c2) from t2)  not  in ( (select c1 from t3 order by 1 limit 2) )
    order by c0 desc ,c1 desc ,c2 desc )
SELECT /*+PARALLEL( 5 )*/* FROM jennifer_0;
