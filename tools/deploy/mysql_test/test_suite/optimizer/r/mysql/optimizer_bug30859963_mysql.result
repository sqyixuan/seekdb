drop table if exists t1, t2;
create table t1(c1 int , c2 int , c3 int) partition by hash(c1) partitions 4;
create table t2(c1 int , c2 int , c3 int) partition by hash(c1) partitions 6;
result_format: 4
explain basic select /*+no_rewrite*/ count(distinct v.c3) from (select distinct c3 from t1) v;
