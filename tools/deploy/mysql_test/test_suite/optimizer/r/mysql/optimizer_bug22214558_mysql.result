drop table if exists t1;
create table t1 (c1 int, c2 int, c3 int) partition by hash (c3) partitions 3;
result_format: 4
explain_protocol: 2
EXPLAIN select /*+topk(0 10)*/ c2, count(c3) from t1 where c2 <12 group by c2 order by avg(c3) desc limit 5;
