CREATE TABLE t3(c0 DATETIME , c1 DOUBLE(60, 4)  COMMENT 'asdf'  , PRIMARY KEY(c1)) AUTO_INCREMENT = 3514530942945748,   USE_BLOOM_FILTER =  FALSE ,  BLOCK_SIZE =  16384  PARTITION BY KEY (c1) partitions 1;
CREATE VIEW v_t3 AS select /*+no_mv_rewrite*/ c0, c1,count(*) as c from t3 group by c0, c1;
