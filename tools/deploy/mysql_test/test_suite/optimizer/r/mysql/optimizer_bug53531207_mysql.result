drop table if exists t1;
drop table if exists t2;
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3));
create table t2(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3)) partition by hash(c1) partitions 10;
create index idx on t2(c2, c1) local;
result_format: 4
explain_protocol: 2
EXPLAIN select /*+leading(t1) use_nl(t2) no_expand */ *
from t1
	left join (select /*+no_merge*/ * from t2) t2
	on (t2.c2 = t1.c2 or t2.c2 = 4) and t1.c1 < 10;
Query Plan
===================================================================
|ID|OPERATOR                        |NAME   |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |NESTED-LOOP OUTER JOIN          |       |1       |227         |
|1 |├─TABLE FULL SCAN               |t1     |1       |3           |
|2 |└─SUBPLAN SCAN                  |t2     |1       |224         |
|3 |  └─DISTRIBUTED TABLE RANGE SCAN|t2(idx)|1       |224         |
===================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      conds(nil), nl_params_([t1.c2(:0)], [t1.c1(:1)]), use_batch=false
  1 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2], [t1.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
  2 - output([t2.c2], [t2.c1], [t2.c3], [t2.c4]), filter(nil), startup_filter([:1 < 10]), rowset=16
      access([t2.c2], [t2.c1], [t2.c3], [t2.c4])
  3 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3], [t2.c4]), partitions(p[0-9])
      is_index_back=true, is_global_index=false, 
      range_key([t2.c2], [t2.c1], [t2.c3]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true, 
      range_cond([t2.c2 = :0 OR t2.c2 = 4])
select /*+leading(t1) use_nl(t2) no_expand */ *
from t1
	left join (select /*+no_merge*/ * from t2) t2
	on (t2.c2 = t1.c2 or t2.c2 = 4) and t1.c1 < 10;
