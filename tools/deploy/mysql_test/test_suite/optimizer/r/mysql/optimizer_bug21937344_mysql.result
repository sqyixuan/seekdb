drop table if exists t1, t2;
create table t1(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
result_format: 4
explain_protocol: 2
EXPLAIN select /*+parallel(2)*/ b, sum(a) from t1 group by b union select b, sum(a) from t2 group by b order by 1;
