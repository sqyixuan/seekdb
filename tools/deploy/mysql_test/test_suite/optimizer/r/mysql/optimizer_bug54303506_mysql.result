## issue: 
drop table if exists t_testdata;
drop table if exists t_part_sub;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);
CREATE TABLE t_part_sub (
  empno varchar(20), 
  empname varchar(20), 
  deptno int, 
  birthdate date NOT NULL, 
  salary int
) PARTITION BY list (deptno) subpartition by key(birthdate)
 subpartitions 3 (  PARTITION p0 VALUES in (null, 10, 15), 
                    PARTITION p1 VALUES in (20, 25), 
                    PARTITION p2 VALUES in (30, 35));

EXPLAIN BASIC select * from t_testdata t1 where c1 > (select t2.birthdate from t_part_sub t2 where t1.c1 = t2.birthdate and t2.deptno in (20,25) and t2.birthdate in ('2000-05-31','2001-01-01'));
