result_format: 4
drop table if exists t1;
create table t1(c1 int primary key, c2 int ,c3 int, c4 int);
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1, c1 from cte;

explain_protocol: 1
set @a = 0;
EXPLAIN BASIC select sum(s_val), sum(c1), sum(old_a), sum(new_a)
from (select (select /*+use_das(t1)*/ @a from t1 where c1 = a.c1 and c2 = @a) s_val, c1, @a old_a, @a := @a + 1 as new_a from t1 a);
Query Plan
======================================================
|ID|OPERATOR                         |NAME           |
------------------------------------------------------
|0 |SCALAR GROUP BY                  |               |
|1 |└─SUBPLAN SCAN                   |ANONYMOUS_VIEW1|
|2 |  └─SUBPLAN FILTER               |               |
|3 |    ├─DISTRIBUTED TABLE FULL SCAN|a              |
|4 |    └─DISTRIBUTED TABLE GET      |t1             |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(ANONYMOUS_VIEW1.s_val)], [T_FUN_SUM(ANONYMOUS_VIEW1.c1)], [T_FUN_SUM(ANONYMOUS_VIEW1.old_a)], [T_FUN_SUM(ANONYMOUS_VIEW1.new_a)]), filter(nil)
      group(nil), agg_func([T_FUN_SUM(ANONYMOUS_VIEW1.s_val)], [T_FUN_SUM(ANONYMOUS_VIEW1.c1)], [T_FUN_SUM(ANONYMOUS_VIEW1.old_a)], [T_FUN_SUM(ANONYMOUS_VIEW1.new_a)])
  1 - output([ANONYMOUS_VIEW1.s_val], [ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.old_a], [ANONYMOUS_VIEW1.new_a]), filter(nil)
      access([ANONYMOUS_VIEW1.s_val], [ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.old_a], [ANONYMOUS_VIEW1.new_a])
  2 - output([subquery(1)], [a.c1], [('a')], [(T_OP_ASSIGN, 'a', ('a') + 1)]), filter(nil)
      exec_params_([a.c1(:0)]), onetime_exprs_(nil), init_plan_idxs_(nil), use_batch=false
  3 - output([a.c1]), filter(nil)
      access([a.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([a.c1]), range(MIN ; MAX)always true
  4 - output([('a')]), filter([t1.c2 = ('a')])
      access([t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1]), range(MIN ; MAX)always true, 
      range_cond([t1.c1 = :0])
select sum(s_val), sum(c1), sum(old_a), sum(new_a)
from (select (select /*+use_das(t1)*/ @a from t1 where c1 = a.c1 and c2 = @a) s_val, c1, @a old_a, @a := @a + 1 as new_a from t1 a);
