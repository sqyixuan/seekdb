drop table if exists t1;
create table t1(
c1 char(20) default null, 
key idx1 (c1)
) DEFAULT CHARSET = utf16;
insert into t1 values(0xd878dc00), (0xd878dfff);
result_format: 4
explain_protocol: 2
# like 表达式是一个非法的 utf16 字符串, 应该返回一个 empty set 而不是报错.
EXPLAIN select * from t1 where c1 like concat(0xD878, '_a');
