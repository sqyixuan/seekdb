       '\\')]), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1], [t1.__pk_increment]), range(MAX,MAX ; MIN,MIN)always false, 
      range_cond([(T_OP_LIKE, cast(t1.c1, VARCHAR(1048576)), cast(concat(cast(X'D878', VARCHAR(1048576)), cast('_a', VARCHAR(1048576))), VARCHAR(1048576)),
