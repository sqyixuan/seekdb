drop table if exists t1;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;
result_format: 4
explain_protocol: 2
EXPLAIN select gt1.c2 from t1 gt1 right join t1 gt2 on gt1.c2 = gt2.c2 where (gt2.c2 + gt1.c2) = gt2.c1;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |HASH JOIN                  |        |1       |19          |
|1 |├─PX COORDINATOR           |        |1       |9           |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|1       |9           |
|3 |│   └─PX PARTITION ITERATOR|        |1       |9           |
|4 |│     └─TABLE FULL SCAN    |gt1     |1       |9           |
|5 |└─PX COORDINATOR           |        |1       |10          |
|6 |  └─EXCHANGE OUT DISTR     |:EX20000|1       |10          |
|7 |    └─PX PARTITION ITERATOR|        |1       |9           |
|8 |      └─TABLE FULL SCAN    |gt2     |1       |9           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([gt1.c2]), filter(nil), rowset=16
      equal_conds([gt1.c2 = gt2.c2]), other_conds([gt2.c2 + gt1.c2 = gt2.c1])
  1 - output([gt1.c2]), filter(nil), rowset=16
  2 - output([gt1.c2]), filter(nil), rowset=16
      dop=1
  3 - output([gt1.c2]), filter(nil), rowset=16
      force partition granule
  4 - output([gt1.c2]), filter(nil), rowset=16
      access([gt1.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([gt1.__pk_increment]), range(MIN ; MAX)always true
  5 - output([gt2.c2], [gt2.c1]), filter(nil), rowset=16
  6 - output([gt2.c2], [gt2.c1]), filter(nil), rowset=16
      dop=1
  7 - output([gt2.c1], [gt2.c2]), filter(nil), rowset=16
      force partition granule
  8 - output([gt2.c1], [gt2.c2]), filter(nil), rowset=16
      access([gt2.c1], [gt2.c2]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([gt2.__pk_increment]), range(MIN ; MAX)always true
select gt1.c2 from t1 gt1 right join t1 gt2 on gt1.c2 = gt2.c2 where (gt2.c2 + gt1.c2) = gt2.c1;
