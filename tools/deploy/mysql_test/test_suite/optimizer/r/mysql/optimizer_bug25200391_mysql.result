insert into t1 values (1,1,1),(2,2,2),(3,3,3);

alter system set ob_enable_batched_multi_statement = 'False';

drop table if exists t1,t2,t3,t4,t5,t6;
create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int, c2 int);
create table t4(c3 int);
create table t5(c1 int);
create table t6(c1 int);

explain SELECT /*+leading(ref_0 ((ref_2 (ref_4 ref_3)) ref_1))*/ 1
FROM  t1 AS ref_0
      LEFT JOIN 
      (t2 AS ref_1
        RIGHT JOIN (t3 AS ref_2
                    inner JOIN (t4 AS ref_3
                    RIGHT JOIN t5 AS ef_4
                            ON 1 =1 )
                            ON EXISTS (SELECT 1
                                         FROM   t6
                                         WHERE  ref_3.c3 IS NULL
                                         LIMIT  113))
                            ON 1=1)
      ON ref_2.c2 >= ref_2.c1;
