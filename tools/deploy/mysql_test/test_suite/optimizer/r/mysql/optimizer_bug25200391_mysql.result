drop table if exists t1,t2,t3,t4,t5,t6;
create table t1(c1 int ,c2 int, c3 int);
create index t1_i1 on t1(c1,c2);
EXPLAIN select /*+index(t1 t1_i1)*/ * from t1 order by c1,c2,c3 limit 10000000000;
