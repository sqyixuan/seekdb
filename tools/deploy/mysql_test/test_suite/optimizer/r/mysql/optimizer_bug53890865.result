result_format: 4
drop table if exists t1,t2;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert into t1 values(1,1);

explain insert into t2 select * from t1;
Query Plan
==============================================================
|ID|OPERATOR           |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------
|0 |INSERT             |               |1       |16          |
|1 |└─SUBPLAN SCAN     |ANONYMOUS_VIEW1|1       |3           |
|2 |  └─TABLE FULL SCAN|t1             |1       |3           |
==============================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t2: ({t2: (t2.__pk_increment, t2.c1, t2.c2)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)])
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2])
  2 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
insert into t2 select * from t1;

explain insert into t2 select /*+use_das(t1)*/ * from t1;
Query Plan
==========================================================================
|ID|OPERATOR                       |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------------
|0 |INSERT                         |               |1       |16          |
|1 |└─SUBPLAN SCAN                 |ANONYMOUS_VIEW1|1       |3           |
|2 |  └─DISTRIBUTED TABLE FULL SCAN|t1             |1       |3           |
==========================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t2: ({t2: (t2.__pk_increment, t2.c1, t2.c2)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.c2)])
  1 - output([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.c1], [ANONYMOUS_VIEW1.c2])
  2 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
insert into t2 select /*+use_das(t1)*/ * from t1;
