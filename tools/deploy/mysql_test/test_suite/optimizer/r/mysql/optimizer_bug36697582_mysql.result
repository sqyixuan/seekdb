drop table if exists t1, t2;
create table t1 (c1 int primary key, c2 int) partition by range(c1) ( partition p0 values less than (3), partition p1 values less than (30));
create table t2 (c1 int primary key, c2 int) partition by range(c1) ( partition p0 values less than (3), partition p1 values less than (30));
explain_protocol: 2
result_format: 4
EXPLAIN select * from t1, t2 where t1.c1 = t2.c1 order by t1.c1 desc;
Query Plan
=================================================================
|ID|OPERATOR                  |NAME       |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT |           |5       |20          |
|1 |└─EXCHANGE OUT DISTR      |:EX10000   |5       |17          |
|2 |  └─PX PARTITION ITERATOR |           |5       |10          |
|3 |    └─MERGE JOIN          |           |5       |10          |
|4 |      ├─TABLE FULL SCAN   |t1(Reverse)|5       |5           |
|5 |      └─TABLE FULL SCAN   |t2(Reverse)|5       |5           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t2.c1, t2.c2)]), filter(nil), rowset=16
      sort_keys([t1.c1, DESC])
  1 - output([t1.c1], [INTERNAL_FUNCTION(t1.c1, t1.c2, t2.c1, t2.c2)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t2.c1], [t1.c2], [t2.c2]), filter(nil), rowset=16
      partition wise, force partition granule, desc
  3 - output([t1.c1], [t2.c1], [t1.c2], [t2.c2]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
      merge_directions([DESC])
  4 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
  5 - output([t2.c1], [t2.c2]), filter(nil), rowset=16
      access([t2.c1], [t2.c2]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(MIN ; MAX)always true
select * from t1, t2 where t1.c1 = t2.c1 order by t1.c1 desc;
