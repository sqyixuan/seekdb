  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, t2.c1, t2.c2, t2.c3, t2.c4)]), filter(nil), rowset=16
      dop=2
  2 - output([t1.c2], [t2.c1], [t1.c4], [t1.c1], [t1.c3], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      equal_conds([t1.c2 = t2.c1]), other_conds(nil)
      merge_directions([ASC])
  3 - output([t1.c2], [t1.c4], [t1.c1], [t1.c3]), filter(nil), rowset=16
      sort_keys([t1.c2, ASC])
  4 - output([t1.c2], [t1.c4], [t1.c1], [t1.c3]), filter(nil), rowset=16
  5 - output([t1.c2], [t1.c4], [t1.c1], [t1.c3]), filter(nil), rowset=16
      dop=2
  6 - output([t1.c4], [t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=16
  7 - output([t1.c4], [t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=16
      access([t1.c4], [t1.c2], [t1.c1], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c4]), range(MIN ; MAX)always true
  8 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      sort_keys([t2.c1, ASC]), local merge sort
  9 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
 10 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3], [t2.c4]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.c2]), range(MIN,MIN ; MAX,MAX)always true
