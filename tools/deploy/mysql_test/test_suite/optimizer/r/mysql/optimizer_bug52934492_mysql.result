drop table if exists t1,t2;
create table t1(c1 int, c2 int, c3 int, c4 int, constraint uk41 unique(c1,c2), constraint uk42 unique(c3), constraint t4_pk primary key(c4));
create table t2(c1 int, c2 int, c3 int, c4 int, primary key (c1, c2))  partition by hash(c2) partitions 4;
result_format: 4
explain_protocol: 1
EXPLAIN BASIC select /*+ parallel(2) pq_map(t2) pq_distribute(t2 broadcast none) leading(t1 t2) use_merge(t2)*/ * from t1 join t2 on t1.c2 = t2.c1;
Query Plan
======================================================
|ID|OPERATOR                                |NAME    |
------------------------------------------------------
|0 |PX COORDINATOR                          |        |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|
|2 |  └─MERGE JOIN                          |        |
|3 |    ├─SORT                              |        |
|4 |    │ └─EXCHANGE IN DISTR               |        |
|5 |    │   └─EXCHANGE OUT DISTR (BROADCAST)|:EX10000|
|6 |    │     └─PX BLOCK ITERATOR           |        |
|7 |    │       └─TABLE FULL SCAN           |t1      |
|8 |    └─SORT                              |        |
|9 |      └─PX BLOCK ITERATOR               |        |
|10|        └─TABLE FULL SCAN               |t2      |
======================================================
