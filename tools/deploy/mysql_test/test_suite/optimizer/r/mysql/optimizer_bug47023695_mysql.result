drop table if exists c;
drop table if exists bb;
drop table if exists oo;
create table c(
pk int,
col_int_key int,
col_datetime datetime,
col_date_key date,
col_datetime_key datetime,
PRIMaRY KEY (`pk`),
KEY `idx1` (`pk`, `col_int_key`) ,
KEY `idx2` (`pk`, `col_date_key`) ,
KEY `idx3` (`pk`, `col_datetime_key`) 
);
create table bb(
pk int,
col_int int,
col_date_key date,
col_datetime_key datetime,
PRIMaRY KEY (`pk`),
KEY `idx2` (`pk`, `col_date_key`) ,
KEY `idx3` (`pk`, `col_datetime_key`) 
);
create table oo(
pk int,
col_int int,
col_date_key date,
col_datetime_key datetime,
PRIMaRY KEY (`pk`),
KEY `idx2` (`pk`, `col_date_key`) ,
KEY `idx3` (`pk`, `col_datetime_key`) 
);
explain_protocol: 2
result_format: 4
EXPLAIN DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ FROM oo WHERE PK IN (SELECT PK FROM (SELECT  OUTR . `col_datetime_key` AS X FROM C AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_datetime` = OUTR . `col_datetime` ) WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `col_int` AS Y FROM BB AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `col_int` >= INNR . `pk` ) WHERE INNR . `col_date_key` <> INNR . `col_datetime_key` OR NOT OUTR . `col_datetime` IS NOT NULL ORDER BY INNR . `col_int` ) AND OUTR . `col_int_key` < 8 OR OUTR . `col_int_key` > 9 HAVING X >= '2006-04-26 05:38:31' ORDER BY OUTR . `col_int_key` , OUTR . `pk`)TC1);
