drop table if exists t1;
drop view if exists v1;
drop database if exists db1;
drop user if exists u1;
drop catalog if exists ca1;
create table t1(c1 int);
create index it1c1 on t1(c1);
create view v1 as select * from t1;
create database db1;
create user u1;
create external catalog ca1 properties (type='odps' project_name='test');
set tx_read_only=on;
SHOW COLUMNS FROM t1;
SHOW TABLES;
SHOW DATABASES;
SHOW TABLE STATUS;
SHOW VARIABLES;
SHOW CREATE DATABASE db1;
SHOW CREATE TABLE t1;
SHOW CREATE VIEW v1;
SHOW WARNINGS;
SHOW ERRORS;
SHOW GRANTS;
SHOW CHARSET;
SHOW COLLATION;
SHOW PARAMETERS;
SHOW INDEX FROM t1;
SHOW PROCESSLIST;
SHOW TABLEGROUPS;
SHOW TRIGGERS;
SHOW RECYCLEBIN;
SHOW PROFILE;
SHOW TENANT;
SHOW SEQUENCES;
SHOW ENGINES;
SHOW ENGINE INNODB STATUS;
SHOW OPEN TABLES;
SHOW CREATE USER u1;
SHOW CATALOGS;
SHOW CREATE CATALOG ca1;
SHOW SESSION STATUS;
SHOW PLUGINS;
SHOW JOB STATUS;
CHECK TABLE T1;
set tx_read_only=off;
drop table t1;
drop view v1;
drop database db1;
drop user u1;
drop catalog ca1;
