      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c2], [t1.c3], [t1.c1]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select c1, @a := c2 + 10 as new_a from t1 where c1 = @a;
