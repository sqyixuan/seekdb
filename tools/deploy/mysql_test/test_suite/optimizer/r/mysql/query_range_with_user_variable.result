drop table if exists t1,t2;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int, index idx_t1(c2,c3));
create table t2 (c1 int primary key, c2 int);
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
result_format: 4
explain_protocol: 2
## user variable + no assign
set @a = 3, @b = 90;
EXPLAIN select * from t1 where c1 = @a;
