drop table if exists t1, t2;
create table t1(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
result_format: 4
explain_protocol: 2
EXPLAIN select count(distinct a) from t1 partition(p0);
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |SCALAR GROUP BY      |     |1       |3           |
|1 |└─SUBPLAN SCAN       |VIEW1|2       |3           |
|2 |  └─MERGE DISTINCT   |     |2       |3           |
|3 |    └─TABLE FULL SCAN|t1   |2       |3           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(VIEW1.t1.a)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_COUNT(VIEW1.t1.a)])
  1 - output([VIEW1.t1.a]), filter(nil), rowset=16
      access([VIEW1.t1.a])
  2 - output([t1.a]), filter(nil), rowset=16
      distinct([t1.a])
  3 - output([t1.a]), filter(nil), rowset=16
      access([t1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.a], [t1.b]), range(MIN,MIN ; MAX,MAX)always true
select count(distinct a) from t1 partition(p0);
