drop table if exists t1,t2,t3,t4,t5;
drop sequence if exists seq1;
drop sequence if exists seq2;
drop sequence if exists seq3;
drop sequence if exists seq4;
drop sequence if exists seq5;
create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int)partition by hash(c1) partitions 16;
create table t3(c1 int, c2 int, c3 int, c4 int)partition by hash(c1) partitions 16 subpartition by hash(C2) subpartitions 16;
create table t4(c1 int primary key, c2 int, c3 int, c4 int)partition by hash(c1) partitions 128;
create table t5(c1 int, c2 int, c3 int, c4 int);
create index t1_i1 on t1(c4);
create index t1_i2 on t1(c3);
create index t2_i1 on t2(c4);
create index t2_i2 on t2(c1);
create index t3_i1 on t3(c4);
create index t4_i1 on t4(c4) partition by hash(c4) partitions 16;
create index t5_i1 on t5(c4);
create index t5_i2 on t5(c3);
create sequence seq1;
create sequence seq2;
create sequence seq3;
create sequence seq4;
create sequence seq5;
insert into t1 select seq1.nextval, seq1.currval, seq1.currval, seq1.currval from table(generator(10000));
insert into t2 select seq2.nextval, seq2.currval, seq2.currval, seq2.currval from table(generator(10000));
insert into t3 select seq3.nextval, seq3.currval, seq3.currval, seq3.currval from table(generator(10000));
insert into t4 select seq4.nextval, seq4.currval, seq4.currval, case when seq4.currval > 9900 then 9900 else seq4.currval end from table(generator(10000));
insert into t5 select seq5.nextval, seq5.currval, seq5.currval, case when seq5.currval > 9900 then 9900 else seq5.currval end from table(generator(10000));
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
call dbms_stats.gather_table_stats(NULL, 't4');
call dbms_stats.gather_table_stats(NULL, 't5', method_opt=>'for all columns size 1');
explain_protocol: 2
result_format: 3
