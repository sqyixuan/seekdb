  5 - output([B.c2], [B.c1]), filter([B.c4 > 5000], [B.c3 IS NOT NULL]), rowset=256
      access([B.c2], [B.c1], [B.c3], [B.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([B.__pk_increment]), range(MIN ; MAX)always true
select * from t5 A where
not exists(select 1 from t5 B where A.c4 = B.c2 and A.c2 > B.c1 and B.c3 is not null and B.c4 > 5000)
order by A.c4 limit 10;
