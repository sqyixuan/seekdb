drop table t;
drop table t2;
create table t (c1 int, c2 int, c3 int, c4 int, primary key (c1, c2, c3, c4));
create table t2 (c1 int, c2 int, c3 int, c4 int, primary key (c1, c2, c3, c4));
insert into t values (1, 1, 1, 1);
insert into t values (1, 2, 1, 1);
insert into t values (1, 3, 1, 1);
insert into t values (1, 4, 1, 1);
insert into t values (1, 5, 1, 1);
insert into t values (1, 6, 1, 1);
insert into t values (1, 7, 1, 1);
insert into t values (1, 8, 1, 1);
insert into t values (1, 9, 1, 1);
result_format: 4
alter system flush sql audit global;

explain extended_noaddr select min(c4) from t where (c1, c2) >= (1, 1) and (c1, c2) <= (1, 1);
