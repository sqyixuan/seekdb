result_format: 4
explain_protocol: 2
##
## Test Name: scalar_group_by_push_down
##
##
##
drop table if exists t1, t2;
create table t1 (c1 int, c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;

# should use hash
EXPLAIN select count(distinct c2) from t1;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SCALAR GROUP BY     |    |1        |678 |
|1 | EXCHANGE IN DISTR  |    |1        |678 |
|2 |  EXCHANGE OUT DISTR|    |1        |678 |
|3 |   HASH GROUP BY    |    |1        |678 |
|4 |    TABLE SCAN      |t1  |1000     |296 |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([T_FUN_COUNT(distinct t1.c2)]), filter(nil), 
      group(nil), agg_func([T_FUN_COUNT(distinct t1.c2)])
  1 - output([t1.c2]), filter(nil)
  2 - output([t1.c2]), filter(nil)
  3 - output([t1.c2]), filter(nil), 
      group([t1.c2]), agg_func(nil)
  4 - output([t1.c2]), filter(nil), 
      access([t1.c2]), partitions(p[0-3])

select count(distinct c2) from t1;
+--------------------+
| count(distinct c2) |
+--------------------+
|                  1 |
+--------------------+

