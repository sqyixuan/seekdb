-------------------------------------
  0 - output([.DBMS_RANDOM.VALUE], [.A], [.B]), filter(nil)
      limit(cast(CEIL(10) - cast(1, NUMBER(-1, -1)), BIGINT(-1, 0))), offset(nil)
  1 - output([.DBMS_RANDOM.VALUE], [.A], [.B]), filter(nil)
      access([.DBMS_RANDOM.VALUE], [.A], [.B])
  2 - output([oceanbase.DBMS_RANDOM.VALUE()], [T1.A], [T1.B]), filter(nil)
