      access([T1.A], [T1.B]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true

drop table t1;
create table t1 (c1 INT,c2 CHAR(151) ,c3 VARCHAR(57) ,c4 DECIMAL(37,10) ,c5 INT,c6 CHAR(70) ,c7 INT,c8 CHAR(126) ,c9 NUMBER(37,27) ,c10 NUMBER(37,6) ,c11 NUMERIC(37,22) ,c12 INT,c13 INT,c14 DECIMAL(37,17) ,c15 CHAR(81) ,c16 CHAR(119) ,c17 INT, primary key(c11,c17,c16)) PARTITION BY HASH(c17) PARTITIONS 20;

