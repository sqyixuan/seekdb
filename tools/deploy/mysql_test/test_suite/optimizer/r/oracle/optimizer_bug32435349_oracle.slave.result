drop table t1;
create table t1(a int, b int, c int);
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
result_format: 4
explain_protocol: 2
explain select * from (select dbms_random.value, a, b from t1 order by 1) where rownum < 10;
