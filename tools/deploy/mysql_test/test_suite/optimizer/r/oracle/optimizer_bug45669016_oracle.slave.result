drop table t1;
drop table t2;
drop table t3;
create TABLE t1 (c1 int, c2 int, c3 int) partition by list (c1,c2) (partition p0 values('1','2'));
create TABLE t2 (c1 int, c2 int, c3 int) partition by range (c1) (partition p0 values less than (100));
create TABLE t3 (c1 int, c2 int, c3 int);
result_format: 4
explain_protocol: 2
explain insert INTO t1 (c1, c2) select 4, level from dual connect by level <= 400;
Query Plan
======================================================================
|ID|OPERATOR                   |NAME           |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |DISTRIBUTED INSERT         |               |2       |17          |
|1 |└─SUBPLAN SCAN             |ANONYMOUS_VIEW2|2       |1           |
|2 |  └─NESTED-LOOP CONNECT BY |               |2       |1           |
|3 |    ├─SUBPLAN SCAN         |VIEW1          |1       |1           |
|4 |    │ └─EXPRESSION         |               |1       |1           |
|5 |    └─SUBPLAN SCAN         |VIEW2          |1       |1           |
|6 |      └─EXPRESSION         |               |1       |1           |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{T1: ({T1: (T1.__pk_increment, T1.C1, T1.C2, T1.C3)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(NUMBER,PS:(-1,0),NULL,4)], [column_conv(NUMBER,PS:(-1,0),NULL,ANONYMOUS_VIEW2.LEVEL)], [column_conv(NUMBER,
      PS:(-1,0),NULL,cast(NULL, NUMBER(-1, -1)))])
  1 - output([ANONYMOUS_VIEW2.LEVEL]), filter(nil), rowset=256
      access([ANONYMOUS_VIEW2.LEVEL])
  2 - output([4], [LEVEL]), filter(nil)
      conds([LEVEL <= 400]), nl_params_(nil), use_batch=false
  3 - output(nil), filter(nil), rowset=256
      access(nil)
  4 - output([1]), filter(nil)
      values({1})
  5 - output(nil), filter(nil), rowset=256
      access(nil)
  6 - output([1]), filter(nil)
      values({1})
