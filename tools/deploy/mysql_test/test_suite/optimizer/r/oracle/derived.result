FROM 
( SELECT * FROM C  ) table1  
JOIN ( SELECT * FROM C  ) table2  ON table2.col_varchar = table1.col_varchar
WHERE 
table2.col_varchar < table2.col_varchar
AND table1.col_varchar != 'k' 
LIMIT  1;
