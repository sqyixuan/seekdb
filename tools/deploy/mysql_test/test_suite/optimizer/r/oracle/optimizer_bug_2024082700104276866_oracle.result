drop table t1;
drop table t2;
create table t2(id int, sales int, v int, primary key(id, sales));
create table t1(id int, sales int, v int, primary key(id, sales));
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t2 values(1,2,2);
insert into t2 values(-1,-2,-2);
insert into t2 values(2,4,4);
insert into t2 values(-2,-4,-4);
explain basic merge /*+use_px, parallel(8)*/ into t1 using t2 on (t1.id = t2.id) when matched then update set (t1.sales,t1.v)= (select 1, t2.v from dual);
