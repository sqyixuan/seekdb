DROP TABLE tt1;
DROP TABLE tt2;
drop type nt_obj;
explain_protocol: 0
create table tt1(c1 number, c2 varchar2(10), c3 nchar(10), c4 nvarchar2(10), c5 int);
insert into tt1 values(10,10,10,10,10);
insert into tt1 values(20,20,20,20,20);

create table tt2(c1 number, c2 varchar2(10), c3 nchar(10));
insert into tt2 values(10,20,30);

create or replace type type_obj as object(c1 number, c2 number);

create or replace type nt_obj is table of type_obj;

create or replace function normal_func(p1 number, p2 number default 1) return nt_obj
as
  obj nt_obj := nt_obj();
begin
  for i in 1..p1 loop
    obj.extend;
    obj(i) := type_obj(i,p2);
  end loop;
  return obj;
end;//

create or replace function pip_func(p1 number, p2 number default 1) return nt_obj pipelined
as
begin
  for i in 1..p1 loop
    pipe row(type_obj(i,p2));
  end loop;
  return;
end;//

explain_protocol: 2
