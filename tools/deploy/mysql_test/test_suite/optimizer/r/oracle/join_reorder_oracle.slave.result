#创建普通表
CREATE TABLE a5(id int, name varchar2(10), birthday DATE, p_id_a5 int);
INSERT INTO a5 VALUES(1,'admin1',TO_DATE('20010101','yyyymmdd'), NULL);
INSERT INTO a5 VALUES(2,'admin2',TO_DATE('20020101','yyyymmdd'), 1);
INSERT INTO a5 VALUES(3,'admin3',TO_DATE('20030101','yyyymmdd'), 1);
INSERT INTO a5 VALUES(4,'admin4',TO_DATE('20040101','yyyymmdd'), 2);
INSERT INTO a5 VALUES(5,'admin5',TO_DATE('20050101','yyyymmdd'), 3);
INSERT INTO a5 VALUES(6,'admin6',TO_DATE('20060101','yyyymmdd'), 2);
INSERT INTO a5 VALUES(7,'admin7',TO_DATE('20070101','yyyymmdd'), 3);
INSERT INTO a5 VALUES(8,'admin8',TO_DATE('20080101','yyyymmdd'), 4);
INSERT INTO a5 VALUES(9,'admin9',TO_DATE('20090101','yyyymmdd'), 5);
INSERT INTO a5 VALUES(10,'admin10',TO_DATE('20100101','yyyymmdd'), 4);
CREATE TABLE a4(id int, name varchar2(10), birthday DATE, p_id_a4 int);
CREATE TABLE a3(id int, name varchar2(10), birthday DATE, p_id_a3 int);
CREATE TABLE a2(id int, name varchar2(10), birthday DATE, p_id_a2 int);
CREATE TABLE a1(id int, name varchar2(10), birthday DATE, p_id_a1 int);
INSERT ALL WHEN id<=3 THEN INTO a1 WHEN id<=5 THEN INTO a2 INTO a3 WHEN id<=8 THEN INTO a4 SELECT * FROM a5;
INSERT ALL INTO a1 INTO a2 INTO a3 INTO a4 INTO a5 SELECT NULL id,NULL name,NULL birthday,NULL p_id FROM dual;
#创建含主键的普通表
CREATE TABLE b5(id int PRIMARY KEY, name varchar2(10), birthday DATE, p_id_b5 int);
CREATE TABLE b4(id int PRIMARY KEY, name varchar2(10), birthday DATE, p_id_b4 int);
CREATE TABLE b3(id int PRIMARY KEY, name varchar2(10), birthday DATE, p_id_b3 int);
CREATE TABLE b2(id int PRIMARY KEY, name varchar2(10), birthday DATE, p_id_b2 int);
CREATE TABLE b1(id int PRIMARY KEY, name varchar2(10), birthday DATE, p_id_b1 int);
INSERT ALL WHEN id<=3 THEN INTO b1 WHEN id<=5 THEN INTO b2 INTO b3 WHEN id<=8 THEN INTO b4 WHEN id<=10 THEN INTO b5 SELECT * FROM a5;
INSERT ALL INTO b1 INTO b2 INTO b3 INTO b4 INTO b5 SELECT 11 id,NULL name,NULL birthday,NULL p_id FROM dual;
#创建分区表
CREATE TABLE c5(id int, name varchar2(10), birthday DATE, p_id_c5 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE c4(id int, name varchar2(10), birthday DATE, p_id_c4 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE c3(id int, name varchar2(10), birthday DATE, p_id_c3 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE c2(id int, name varchar2(10), birthday DATE, p_id_c2 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE c1(id int, name varchar2(10), birthday DATE, p_id_c1 int) PARTITION BY hash(birthday) PARTITIONS 3;
INSERT ALL WHEN id<=3 THEN INTO c1 WHEN id<=5 THEN INTO c2 INTO c3 WHEN id<=8 THEN INTO c4 WHEN id<=10 THEN INTO c5 SELECT * FROM a5;
INSERT ALL INTO c1 INTO c2 INTO c3 INTO c4 INTO c5 SELECT NULL id,NULL name,NULL birthday,NULL p_id FROM dual;
#创建含索引的分区表
CREATE TABLE d5(id int, name varchar2(10), birthday DATE, p_id_d5 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE d4(id int, name varchar2(10), birthday DATE, p_id_d4 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE d3(id int, name varchar2(10), birthday DATE, p_id_d3 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE d2(id int, name varchar2(10), birthday DATE, p_id_d2 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE TABLE d1(id int, name varchar2(10), birthday DATE, p_id_d1 int) PARTITION BY hash(birthday) PARTITIONS 3;
CREATE INDEX in5 ON d5(id) GLOBAL;
CREATE INDEX in4 ON d4(id) GLOBAL;
CREATE INDEX in3 ON d3(id) GLOBAL;
CREATE INDEX in2 ON d2(id) GLOBAL;
CREATE INDEX in1 ON d1(id) GLOBAL;
INSERT ALL WHEN id<=3 THEN INTO d1 WHEN id<=5 THEN INTO d2 INTO d3 WHEN id<=8 THEN INTO d4 WHEN id<=10 THEN INTO d5 SELECT * FROM a5;
INSERT ALL INTO d1 INTO d2 INTO d3 INTO d4 INTO d5 SELECT NULL id,NULL name,NULL birthday,NULL p_id FROM dual;
result_format: 4
explain_protocol: 2
set autocommit = 0;

## 连接分类(inner join、left join、right join、full join、semi join、anti join、connect by join)测试
EXPLAIN select * from t1,t2,t3,t4 where t1.c1 = t2.c1 and t2.c2 = t3.c1 and t3.c2 = t4.c1;
Query Plan
=========================================================
|ID|OPERATOR                 |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------------
|0 |EXCHANGE IN REMOTE       |    |10      |93          |
|1 |└─EXCHANGE OUT REMOTE    |    |10      |70          |
|2 |  └─HASH JOIN            |    |10      |18          |
|3 |    ├─TABLE FULL SCAN    |T4  |5       |3           |
|4 |    └─HASH JOIN          |    |10      |13          |
|5 |      ├─TABLE FULL SCAN  |T3  |10      |3           |
|6 |      └─MERGE JOIN       |    |10      |7           |
|7 |        ├─TABLE FULL SCAN|T1  |10      |3           |
|8 |        └─TABLE FULL SCAN|T2  |10      |3           |
=========================================================
Outputs & filters:
-------------------------------------
  0 - output([T1.C1], [T1.C2], [T2.C1], [T2.C2], [T3.C1], [T3.C2], [T4.C1], [T4.C2]), filter(nil)
  1 - output([T1.C1], [T1.C2], [T2.C1], [T2.C2], [T3.C1], [T3.C2], [T4.C1], [T4.C2]), filter(nil)
  2 - output([T1.C1], [T1.C2], [T2.C1], [T2.C2], [T3.C1], [T3.C2], [T4.C1], [T4.C2]), filter(nil), rowset=16
      equal_conds([T3.C2 = T4.C1]), other_conds(nil)
  3 - output([T4.C1], [T4.C2]), filter(nil), rowset=16
      access([T4.C1], [T4.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T4.C1]), range(MIN ; MAX)always true
  4 - output([T1.C1], [T1.C2], [T2.C1], [T2.C2], [T3.C1], [T3.C2]), filter(nil), rowset=16
      equal_conds([T2.C2 = T3.C1]), other_conds(nil)
  5 - output([T3.C1], [T3.C2]), filter(nil), rowset=16
      access([T3.C1], [T3.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T3.C1]), range(MIN ; MAX)always true
  6 - output([T1.C1], [T1.C2], [T2.C1], [T2.C2]), filter(nil), rowset=16
      equal_conds([T1.C1 = T2.C1]), other_conds(nil)
      merge_directions([ASC])
  7 - output([T1.C1], [T1.C2]), filter(nil), rowset=16
      access([T1.C1], [T1.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.C1]), range(MIN ; MAX)always true
  8 - output([T2.C1], [T2.C2]), filter(nil), rowset=16
      access([T2.C1], [T2.C2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.C1]), range(MIN ; MAX)always true
