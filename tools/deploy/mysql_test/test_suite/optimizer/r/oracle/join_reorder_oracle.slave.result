FROM a2 INNER JOIN b2 ON a2.id=b2.id FULL JOIN c2 ON b2.id=c2.id LEFT JOIN d2 ON c2.id=d2.id RIGHT JOIN a1 ON d2.id=a1.id LEFT JOIN b1 ON a1.id=b1.id
