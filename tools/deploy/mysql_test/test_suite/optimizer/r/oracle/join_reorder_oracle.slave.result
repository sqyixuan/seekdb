create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);

CREATE TABLE qry_ran_o1 (
col_date date,
col_ts timestamp,
col_number number,
col_nvarchar2_20 nvarchar2(20),
col_varchar2_20 varchar2(20),
pk smallint,
col_int int,
col_decimal_20_2 decimal(20,2),
/*Indices*/
primary key (pk) )  PARTITION BY hash(pk) partitions 4;

CREATE TABLE qry_ran_o2 (
col_varchar2_20 varchar2(20),
col_nvarchar2_20 nvarchar2(20),
col_date date,
col_number number,
pk varchar2(20),
col_int int,
col_decimal_20_2 decimal(20,2),
col_ts timestamp,
/*Indices*/
primary key (pk) )  PARTITION BY hash(pk) partitions 4;

