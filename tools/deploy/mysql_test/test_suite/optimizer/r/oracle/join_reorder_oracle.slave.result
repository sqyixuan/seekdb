SELECT /*+ ordered */ a1.p_id_a1,b1.id,c1.id,d1.p_id_d1,a2.id,b2.id,c2.id,d2.id
FROM (b2 RIGHT JOIN c2 ON b2.id=c2.p_id_c2 FULL JOIN (a1 NATURAL JOIN d1) ON a1.p_id_a1+d1.p_id_d1=b2.id+c2.id) INNER JOIN (d2 FULL JOIN c1 ON d2.id=c1.id CROSS JOIN b1 LEFT JOIN a2 ON d2.id=b1.id+a2.id) ON b1.id=b2.id
ORDER BY 1,2,3,4,5,6,7,8;
