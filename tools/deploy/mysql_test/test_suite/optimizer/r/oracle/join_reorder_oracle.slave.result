                    where not exists(select 1 from  t5 where t1.c2 = t5.c2 and t5.c1 = 4)
                    and  exists(select 1 from  t6 where t6.c2 = t2.c2)
                    and t1.c2 = t4.c1 and t2.c2 = t4.c2 and t2.c2 = t3.c2 and t2.c1 = 1
                    and t4.c1 = 1;
