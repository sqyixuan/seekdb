left join psi_flow_stockbill_entity t2 on P.region = t2.region and P.stock_bill_id = t2.out_bill_id
left join tt on p.region = tt.c1
left join  im_inv_mobtel on im_inv_mobtel.SETTLE_MODE = 'qqqq' and im_inv_mobtel.SUPPLIER_ID = 'bbbb' and im_inv_mobtel.region = P.region and im_inv_mobtel.inv_id = t2.inv_id
left join loc_erp_materielcode MA on MA.res_type_id = t2.res_type_id and MA.sku_name = im_inv_mobtel.REAL_COLOR
where im_inv_mobtel.inv_Id is not null;
