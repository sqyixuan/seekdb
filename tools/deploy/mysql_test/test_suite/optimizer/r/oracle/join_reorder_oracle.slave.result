EXPLAIN select * from (
SELECT t2.*
  FROM t2
       LEFT JOIN
       (t3 join t4 on 1=1)
       ON t3.c1=1 AND t2.c2=t4.c2,
       t5
       LEFT JOIN
       (
         (t6 join t7 on 1=1)
         LEFT JOIN
         t8
         ON t7.c2=t8.c2 AND t6.c2 < 10
       )
       ON t6.c2 >= 2 AND t5.c2=t7.c2
) where rownum <= 20;
