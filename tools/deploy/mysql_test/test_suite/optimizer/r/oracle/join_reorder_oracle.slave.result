SELECT I.OWNER AS OWNER,
  I.INDEX_NAME AS INDEX_NAME,
  I.INDEX_TYPE AS INDEX_TYPE,
  I.UNIQUENESS AS UNIQUENESS,
  I.COMPRESSION AS COMPRESSION,
  I.PREFIX_LENGTH AS PREFIX_LENGTH,
  I.TABLESPACE_NAME AS TABLESPACE_NAME,
  I.INCLUDE_COLUMN AS INCLUDE_COLUMN,
  I.LOGGING AS LOGGING,
  I.PARTITIONED AS PARTITIONED,
  I.TEMPORARY AS TEMPORARY,
  I."GENERATED" AS "GENERATED",
  I.SECONDARY AS SECONDARY,
  I.ITYP_OWNER AS ITYP_OWNER,
  I.ITYP_NAME AS ITYP_NAME,
  I.PARAMETERS AS PARAMETERS,
  I.DOMIDX_STATUS AS DOMIDX_STATUS,
  I.DOMIDX_OPSTATUS AS DOMIDX_OPSTATUS,
  I.FUNCIDX_STATUS AS FUNCIDX_STATUS,
  I.JOIN_INDEX AS JOIN_INDEX,
  I.IOT_REDUNDANT_PKEY_ELIM AS IOT_REDUNDANT_PKEY_ELIM,
  I.DROPPED AS DROPPED,
  I.VISIBILITY AS VISIBILITY,
  I.DOMIDX_MANAGEMENT AS DOMIDX_MANAGEMENT,
  C.COLUMN_NAME AS COLUMN_NAME,
  C.COLUMN_POSITION AS C_COLUMN_POSITION,
  C.COLUMN_LENGTH AS COLUMN_LENGTH,
  C.CHAR_LENGTH AS CHAR_LENGTH,
  C.DESCEND AS DESCEND,
  E.COLUMN_EXPRESSION AS COLUMN_EXPRESSION,
  E.COLUMN_POSITION AS E_COLUMN_POSITION
  FROM ALL_INDEXES I
  LEFT JOIN ALL_IND_COLUMNS C
  ON I.TABLE_OWNER=C.TABLE_OWNER AND I.TABLE_NAME=C.TABLE_NAME AND I.OWNER=C.INDEX_OWNER AND I.INDEX_NAME=C.INDEX_NAME
  LEFT JOIN ALL_IND_EXPRESSIONS E
  ON I.TABLE_OWNER=E.TABLE_OWNER AND I.TABLE_NAME=E.TABLE_NAME AND I.OWNER=E.INDEX_OWNER AND I.INDEX_NAME=E.INDEX_NAME AND C.COLUMN_POSITION=E.COLUMN_POSITION
  WHERE I.TABLE_OWNER='JSSIA_ZTZJZX' AND I.TABLE_NAME='AC43' AND I.TABLE_TYPE='TABLE' AND I.INDEX_TYPE!='LOB' AND (I.STATUS LIKE 'VALID' OR I.STATUS='N/A')
  AND NOT EXISTS (SELECT 1 FROM ALL_CONSTRAINTS T1 WHERE I.TABLE_NAME=T1.TABLE_NAME AND I.INDEX_NAME=T1.CONSTRAINT_NAME AND (T1.CONSTRAINT_TYPE IN ('P','C') OR (T1.CONSTRAINT_TYPE='U' AND I.INDEX_TYPE='NORMAL') OR (T1.CONSTRAINT_TYPE!='U' AND I.INDEX_TYPE LIKE 'FUNCTION-BASED%')))
  ORDER BY I.LAST_ANALYZED, I.INDEX_NAME, C.COLUMN_POSITION, E.COLUMN_POSITION ASC;
