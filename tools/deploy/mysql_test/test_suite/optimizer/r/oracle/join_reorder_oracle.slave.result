FROM a2 FULL JOIN b2 ON a2.id=b2.id FULL JOIN c2 ON c2.id>3 RIGHT JOIN d2 ON d2.id=c2.id LEFT JOIN a1 ON a1.id=c2.id+a2.id LEFT JOIN b1 ON b1.id<2
FULL JOIN c1 ON c1.id!=c2.id INNER JOIN d1 ON c1.id=2 INNER JOIN a3 ON a3.id=d2.id+c2.id INNER JOIN b3 ON b3.id=b1.id RIGHT JOIN c3 ON c3.id=b3.id RIGHT JOIN d3 ON d3.id<3
