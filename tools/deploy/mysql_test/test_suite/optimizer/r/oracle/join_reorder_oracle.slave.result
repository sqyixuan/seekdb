EXPLAIN SELECT 1
FROM    t1  A
        LEFT OUTER JOIN  
        (   t1  B
            INNER JOIN t1  D
            ON 1=1
            INNER JOIN t1  F
            ON  D.c1 >= some (SELECT 1 FROM t1 E)
        ) ON 1=1
;
