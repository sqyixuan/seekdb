drop table psi_flow_stockout;
drop table psi_flow_stockbill_entity;
drop table im_inv_mobtel;
drop table loc_erp_materielcode;
drop table tt;
create table psi_flow_stockout
(
  region number(5) not null,
  stock_bill_id varchar2(32) not null
) partition by hash(region) partitions 5;

create index idx1 on psi_flow_stockout(stock_bill_id) local;

create table psi_flow_stockbill_entity
(
  region number(5) not null,
  out_bill_id varchar2(32) not null,
  inv_id varchar2(32) not null,
  res_type_id varchar2(32) not null
) partition by hash(region) partitions 5;

create index idx2 on psi_flow_stockbill_entity(out_bill_id) local;

create table im_inv_mobtel
(
  region number(5) not null,
  "INV_ID" VARCHAR2(32) not null, 
  "SETTLE_MODE" VARCHAR2(32), 
  "SUPPLIER_ID" VARCHAR2(32) DEFAULT 'UNKNOWN', 
  "REAL_COLOR" VARCHAR2(32)
) partition by hash(region) partitions 3;
create unique index idx3 on im_inv_mobtel (inv_id, region) local;

create table loc_erp_materielcode
(
  res_type_id VARCHAR2(32), 
  sku_name VARCHAR2(32)
);

create table tt (c1 int, c2 varchar(32));

EXPLAIN select  /*+leading(t2,t1,tt,im_inv_mobtel) use_nl(im_inv_mobtel)*/ count(*) from 
(select * from psi_flow_stockout t1 where stock_bill_id = '123123123123') P
left join psi_flow_stockbill_entity t2 on P.region = t2.region and P.stock_bill_id = t2.out_bill_id
left join tt on p.region = tt.c1
left join  im_inv_mobtel on im_inv_mobtel.SETTLE_MODE = 'qqqq' and im_inv_mobtel.SUPPLIER_ID = 'bbbb' and im_inv_mobtel.region = P.region and im_inv_mobtel.inv_id = t2.inv_id
left join loc_erp_materielcode MA on MA.res_type_id = t2.res_type_id and MA.sku_name = im_inv_mobtel.REAL_COLOR
where im_inv_mobtel.inv_Id is not null;
