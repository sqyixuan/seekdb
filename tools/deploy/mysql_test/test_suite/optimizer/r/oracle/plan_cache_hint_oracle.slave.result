drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t6;
drop table t7;
drop table t8;
drop table t9;
create table t1(a int, b int, c int, d int, e int, primary key(a, b, c, d));
create index ti1 on t1 (b);
insert into t1 values(1, 2, 3, 4, 5);
insert into t1 values(1, 2, 3, 6, 6);
insert into t1 values(2, 2, 3, 6, 6);
insert into t1 values(2, 4, 3, 6, 6);
create table t2(a int, b int, c int);
insert into t2 values(1, 2, 3);
insert into t2 values(2, 3, 4);
create table t3 (a int, b int, c int);
create index i1 on t3 (b);
create table t4 (a int, b int, c int);
create table t5 (a int, b int, c int);
create table t6 (a int, b int, c int);
create table t7 (a int, b int, c int);
create table t8 (a int, b int, c int);
create table t9 (a int, b int, c int);

