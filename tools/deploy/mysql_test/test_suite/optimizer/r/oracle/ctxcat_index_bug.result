drop table if exists node_template_type_conf, process_instance, ops_order;
CREATE TABLE `node_template_type_conf` (   `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '业务无关ID，自增，仅系统内部维护',   `identity` varchar(255) NOT NULL,   `node_template_type_identity` varchar(70) NOT NULL,   `cloud_name` varchar(50) DEFAULT NULL,   `region_id` varchar(50) DEFAULT NULL,   `available_tenant_ids` varchar(256) DEFAULT NULL,   `version` varchar(70) NOT NULL,   `origin_type` varchar(50) NOT NULL COMMENT '节点的来源，SYSTEM OPSCOMPOSE提供的节点， CUSTOM 用户提交的节点，仅自己可见, 考虑到兼容以前的老数据，空代表 SYSTEM',   `description` varchar(256) DEFAULT NULL COMMENT '配置的描述',   `server_schema` varchar(256) DEFAULT NULL,   `ui_schema` varchar(256) DEFAULT NULL,   `extra_info` varchar(256) DEFAULT NULL,   `tenant_dependent` bit(1) DEFAULT NULL,   `region_dependent` bit(1) DEFAULT NULL,   `workspace_dependent` bit(1) DEFAULT NULL,   `workspace_group_dependent` bit(1) DEFAULT NULL,   `cell_dependent` bit(1) DEFAULT NULL,   `beijing_modified` datetime(3) NOT NULL,   `local_created` datetime(3) NOT NULL,   `local_modified` datetime(3) NOT NULL,   `utc_created` datetime(3) NOT NULL,   `utc_modified` datetime(3) NOT NULL,   `beijing_created` datetime(3) NOT NULL,   `order_creatable` bit(1) DEFAULT b'1',   `documentation` varchar(256) DEFAULT NULL,   PRIMARY KEY (`id`),   UNIQUE KEY `identity_index` (`identity`) BLOCK_SIZE 16384,   UNIQUE KEY `type_conf_unique_index` (`node_template_type_identity`, `cloud_name`, `region_id`, `version`) BLOCK_SIZE 16384,   KEY `node_template_type_identity_index` (`node_template_type_identity`) BLOCK_SIZE 16384,   KEY `node_template_type_conf_orginType_index` (`cloud_name`, `origin_type`) BLOCK_SIZE 16384,  FULLTEXT KEY `available_tenant_ids_index` (`available_tenant_ids`) CTXCAT(`available_tenant_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384 );
CREATE TABLE `process_instance` (   `id` varchar(50) NOT NULL COMMENT '业务无关的ID，云内唯一，16位数字字符',   `name` varchar(255) NOT NULL COMMENT '流程实例名称， 租户内唯一',   `description` varchar(256) DEFAULT NULL COMMENT '流程实例描述',   `status` varchar(50) NOT NULL COMMENT '流程实例状态，有如下取值：\n状态有 \nEXECUTING 执行中\nCOMPLETED 已完成\nCANCELED 已取消\nEXECUTING_WITH_FAILED 有错误\nTO_BE_APPROVED 待审批\nCANCELING 取消中',   `sub_status` varchar(50) DEFAULT NULL,   `process_template_id` varchar(50) NOT NULL COMMENT '该 流程实例是由哪个流程模板创建的',   `process_template_identity` varchar(255) NOT NULL,   `executor_id` varchar(50) NOT NULL COMMENT '流程实例执行人ID（OperatorVO.uniqueId）',   `transition_info` varchar(256) DEFAULT NULL,   `current_assignee_ids` varchar(256) DEFAULT NULL COMMENT '流程实例当前的待审批人都有哪些（OperatorVO.uniqueId），随着流程实例的运行，该字段会被及时更新',   `involved_assignee_ids` varchar(256) DEFAULT NULL COMMENT '流程实例已经参与的待审批人都有哪些（OperatorVO.uniqueId）即做过审批同意或驳回动作的人都有哪些，随着流程实例的运行，该字段会被及时更新',   `future_assignee_ids` varchar(256) DEFAULT NULL COMMENT '流程实例即将的待审批人都有哪些（OperatorVO.uniqueId）即未来有哪些人会参与到该流程审批中，随着流程实例的运行，该字段会被及时更新',   `tenant_id` varchar(200) NOT NULL COMMENT '流程实例所属的租户ID（现在的projectId）',   `cloud_name` varchar(50) DEFAULT NULL,   `approval_assignee_ids` varchar(256) DEFAULT NULL,   `approval_rule` varchar(45) DEFAULT NULL,   `approval_infos` varchar(256) DEFAULT NULL,   `actual_approved_assignee_ids` varchar(256) DEFAULT NULL,   `actual_rejected_assignee_ids` varchar(256) DEFAULT NULL,   `beijing_started` datetime(3) DEFAULT NULL COMMENT '流程实例的开始执行时间',   `beijing_finished` datetime(3) DEFAULT NULL,   `utc_started` datetime(3) DEFAULT NULL,   `utc_finished` datetime(3) DEFAULT NULL,   `local_started` datetime(3) DEFAULT NULL,   `local_finished` datetime(3) DEFAULT NULL,   `beijing_created` datetime(3) NOT NULL,   `beijing_modified` datetime(3) NOT NULL,   `local_created` datetime(3) NOT NULL,   `local_modified` datetime(3) NOT NULL,   `utc_created` datetime(3) NOT NULL,   `utc_modified` datetime(3) NOT NULL,   `event_routing_rule_values` varchar(256) DEFAULT NULL,   `global_variables` varchar(256) DEFAULT NULL,   `trigger_id` varchar(50) DEFAULT NULL,   `trigger_type` varchar(100) DEFAULT NULL,   `tags` varchar(256) DEFAULT NULL,   PRIMARY KEY (`id`),   UNIQUE KEY `tenant_id_index` (`tenant_id`, `name`) BLOCK_SIZE 16384,   KEY `status_index` (`tenant_id`, `status`, `sub_status`) BLOCK_SIZE 16384,   KEY `process_template_id_index` (`tenant_id`, `process_template_id`) BLOCK_SIZE 16384,   KEY `sub_status_index` (`tenant_id`, `sub_status`, `approval_rule`) BLOCK_SIZE 16384,   KEY `exeuctor_id_index` (`tenant_id`, `executor_id`) BLOCK_SIZE 16384,   KEY `created_time_index` (`tenant_id`, `utc_created`) BLOCK_SIZE 16384,  FULLTEXT KEY `involved_assignee_ids_fulltext` (`involved_assignee_ids`) CTXCAT(`involved_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `actual_approved_assignee_ids_fulltext` (`actual_approved_assignee_ids`) CTXCAT(`actual_approved_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `actual_rejected_assignee_ids_fulltext` (`actual_rejected_assignee_ids`) CTXCAT(`actual_rejected_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `approval_assignee_ids_fulltext` (`approval_assignee_ids`) CTXCAT(`approval_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `current_assignee_ids_fulltext` (`current_assignee_ids`) CTXCAT(`current_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `future_assignee_ids_fulltext` (`future_assignee_ids`) CTXCAT(`future_assignee_ids`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384,  FULLTEXT KEY `tags_full_index` (`tags`) CTXCAT(`tags`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384 );
CREATE TABLE `ops_order` (   `id` varchar(50) NOT NULL COMMENT '业务无关的ID，云内唯一，16位数字字符',   `name` varchar(255) NOT NULL COMMENT '工单名称，租户内唯一',   `description` varchar(256) DEFAULT NULL COMMENT '工单描述',   `process_instance_id` varchar(50) NOT NULL COMMENT '工单对应的流程实例',   `created_source_id` varchar(50) NOT NULL,   `created_source_type` varchar(50) NOT NULL,   `creator_id` varchar(50) DEFAULT NULL,   `tenant_id` varchar(200) NOT NULL COMMENT '工单所属的租户ID（现在的projectId）',   `beijing_created` datetime(3) NOT NULL,   `beijing_modified` datetime(3) NOT NULL,   `local_created` datetime(3) NOT NULL,   `local_modified` datetime(3) NOT NULL,   `utc_created` datetime(3) NOT NULL,   `utc_modified` datetime(3) NOT NULL,   `tags` varchar(256) DEFAULT NULL,   `category` varchar(255) DEFAULT NULL,   PRIMARY KEY (`id`),   UNIQUE KEY `tenant_id_index` (`tenant_id`, `name`) BLOCK_SIZE 16384,   KEY `process_instance_id_index` (`tenant_id`, `process_instance_id`) BLOCK_SIZE 16384,   KEY `creator_id_index` (`tenant_id`, `creator_id`) BLOCK_SIZE 16384,   KEY `created_time_index` (`tenant_id`, `utc_created`) BLOCK_SIZE 16384,  FULLTEXT KEY `tags_full_index` (`tags`) CTXCAT(`tags`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384 );
