result_format: 4
explain_protocol: 2
drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t6;
drop table t7;
# match to_number/to_char/to_nchar/to_binary_float/to_binary_double with implicit cast
create table t1(c1 number(12,0), c2 varchar(10), c3 number as (to_number(c1)), c4 number as (to_number(c2)));
create index i1 on t1(c3);
create index i2 on t1(c4);
create table t2(c1 number(12,0), c2 varchar(10), c3 varchar(80) as (to_char(c1)), c4 varchar(80) as (to_char(c2)));
create index i3 on t2(c3);
create index i4 on t2(c4);
create table t3(c1 number(12,0), c2 nvarchar2(10), c3 nvarchar2(80) as (to_nchar(c1)), c4 nvarchar2(80) as (to_nchar(c2)));
create index i5 on t3(c3);
create index i6 on t3(c4);
create table t4(c1 number(12,0), c2 varchar(10), c3 number as (c1+1), c4 number as (concat(c2,'a')));
create index i7 on t4(c3);
create index i8 on t4(c4);
create table t5(c1 number(12,0), c2 varchar(10), c3 varchar(40) as (c1+1), c4 varchar(40) as (concat(c2,'a')));
create index i9 on t5(c3);
create index i10 on t5(c4);
create table t6(c1 binary_float, c2 varchar(10), c3 binary_float as (to_binary_float(c1+1)), c4 binary_float as (to_binary_float(c2)));
create index i11 on t6(c3);
create index i12 on t6(c4);
create table t7(c1 binary_float, c2 varchar(10), c3 binary_double as (to_binary_double(c1+1)), c4 binary_double as (to_binary_double(c2)));
create index i13 on t7(c3);
create index i14 on t7(c4);
explain_protocol: 2
EXPLAIN select * from t1 where c1 = 1;
Query Plan
=======================================================
|ID|OPERATOR             |NAME  |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |EXCHANGE IN REMOTE   |      |1       |10          |
|1 |└─EXCHANGE OUT REMOTE|      |1       |9           |
|2 |  └─TABLE RANGE SCAN |T1(I1)|1       |7           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([T1.C1], [T1.C2], [TO_NUMBER(T1.C1)], [TO_NUMBER(T1.C2)]), filter(nil)
  1 - output([T1.C1], [T1.C2], [TO_NUMBER(T1.C1)], [TO_NUMBER(T1.C2)]), filter(nil)
  2 - output([T1.C1], [T1.C2], [TO_NUMBER(T1.C1)], [TO_NUMBER(T1.C2)]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.C1], [T1.C3], [T1.C2]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([T1.C3], [T1.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([T1.C3 = cast(cast(1, DECIMAL_INT(12, 0)), NUMBER(-1, -85))])
select * from t1 where c1 = 1;
+------+------+------+------+
| C1   | C2   | C3   | C4   |
+------+------+------+------+
+------+------+------+------+
