# create table for test
result_format: 4

drop user master cascade;

create user master identified by 123456;
grant dba to master;


================ conn_master to create local table t1,t2,t3 ================
drop table t1;
drop table t2;
drop table t3;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);

INSERT INTO t1 VALUES (5,6,7);
INSERT INTO t1 VALUES (7,5,9);
INSERT INTO t1 VALUES (9,4,11);
INSERT INTO t1 VALUES (12,12,3);
INSERT INTO t2 VALUES (2,3,4);
INSERT INTO t2 VALUES (4,5,6);
INSERT INTO t2 VALUES (5,6,7);
INSERT INTO t2 VALUES (9,3,11);
INSERT INTO t3 VALUES (1,2,3);
INSERT INTO t3 VALUES (10,11,12);
INSERT INTO t3 VALUES (3,4,5);
INSERT INTO t3 VALUES (5,6,7);
INSERT INTO t3 VALUES (9,4,11);

================ conn_slave to create remote table t4 ================

drop table t4;

create table t4(c1 int, c2 int, c3 int);
INSERT INTO t4 VALUES (1,2,3);
INSERT INTO t4 VALUES (10,11,12);
INSERT INTO t4 VALUES (3,4,5);
INSERT INTO t4 VALUES (5,6,7);
INSERT INTO t4 VALUES (9,4,11);

explain_protocol: 2

================ conn_master: test for local plan ================
set "_force_order_preserve_set" = 1;

================ test for union all ================
EXPLAIN select * from t1 union all select * from t2;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |UNION ALL        |    |8       |4           |
|1 |├─TABLE FULL SCAN|T1  |4       |2           |
|2 |└─TABLE FULL SCAN|T2  |4       |2           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])], [UNION([3])]), filter(nil), rowset=256
  1 - output([T1.C1], [T1.C2], [T1.C3]), filter(nil), rowset=256
      access([T1.C1], [T1.C2], [T1.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([T2.C1], [T2.C2], [T2.C3]), filter(nil), rowset=256
      access([T2.C1], [T2.C2], [T2.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
select * from t1 union all select * from t2;
