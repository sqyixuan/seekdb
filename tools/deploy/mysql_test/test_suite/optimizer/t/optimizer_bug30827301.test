#owner: zhenling.zzg
#tags: optimizer
#owner group: SQL1



--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--disable_result_log
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
insert into t1 values(1,1);
insert into t2 values(1,1);
insert into t3 values(1,1);
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log


--explain_protocol 2
--result_format 4

select /*+parallel(4)*/ count(*) cnt from t1, t2
 where t1.c1=t2.c1
 and t1.c2 = (select distinct(c2) from t3 where c1=1);

explain basic WITH  jennifer_0 AS (
    select distinct  100 as c0,  ref_0.c1 as c1,  26 as c2
    from  t1 as ref_0
    where (select count(c2) from t2)  not  in ( (select c1 from t3 order by 1 limit 2) )
    order by c0 desc ,c1 desc ,c2 desc )
SELECT /*+PARALLEL( 5 )*/* FROM jennifer_0;

WITH  jennifer_0 AS (
    select distinct  100 as c0,  ref_0.c1 as c1,  26 as c2
    from  t1 as ref_0
    where (select count(c2) from t2)  not  in ( (select c1 from t3 order by 1 limit 2) )
    order by c0 desc ,c1 desc ,c2 desc )
SELECT /*+PARALLEL( 5 )*/* FROM jennifer_0;
