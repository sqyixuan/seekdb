# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int ,c2 int);
create table t2(c1 int, c2 int);
create index t1_i1 on t1(c1);
create index t2_i1 on t2(c1);

insert into t1 select 1,random()%100 from table(generator(10000));
insert into t2 select random()%100,random()%100 from table(generator(10000));

select count(*) from t1;
select count(*) from t2;

explain basic select (select /*+index(t2 t2_i1)*/  c1 from t2 where t2.c2 = t1.c1) as ref 
from t1
where t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c1 
and t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2) parallel(10)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c1 
and t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2) parallel(2) no_use_das(t2)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c1 
and t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2) parallel(20) no_use_das(t2) pq_distribute(t2 local local)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c1 
and t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2) parallel(2) no_use_das(t2) pq_distribute(t2 none broadcast)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c2 
and t1.c1 < 0
and t1.c2 > 1;

explain basic select /*+leading(t1 t2) use_nl(t2) parallel(2) no_use_das(t2) pq_distribute(t2  broadcast none)*/ sum(t2.c2) 
from t1, t2 where t1.c2 = t2.c2 
and t1.c1 < 0
and t1.c2 > 1;

drop table t1;
drop table t2;
