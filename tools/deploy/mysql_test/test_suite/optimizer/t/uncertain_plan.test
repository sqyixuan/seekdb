# owner: link.zt
# owner group: SQL1
# tags: optimizer

# init env
--disable_warnings
drop table if exists t, tmp;
--enable_warnings
create table t (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create index idx on t (c2) global;
create table tmp (c1 int);
insert into t values (1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 5, 5);
--explain_protocol 2
--result_format 4

sleep 5;
# start tests
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--error 0, 1235
select /*+index(t idx)*/ * from t where c2 = 1;
--error 0, 1235
select * from (select /*+index(t idx), no_merge*/ * from t where c2 = 1);

--error 0, 1235
select (select /*+index(t idx)*/ sum(c1 + c2 + c3) from t where c2 = 1) from dual;
--error 0, 1235
select /*+no_rewrite*/ (select /*+index(t idx)*/ sum(c1 + c2 + c3) from t where c2 = 1) from dual;
--error 0, 1235
select /*+index(t idx)*/ * from t where c2 = 1 union select /*+index(t idx)*/ * from t where c2 = 2;
--error 0, 1235
insert into tmp select /*+index(t idx)*/ c3 from t where c2 = 1;

sleep 3;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn2;

select /*+index(t idx)*/ * from t where c2 = 1;
select * from (select /*+index(t idx), no_merge*/ * from t where c2 = 1);
select (select /*+index(t idx)*/ sum(c1 + c2 + c3) from t where c2 = 1) from dual;
select /*+no_rewrite*/ (select /*+index(t idx)*/ sum(c1 + c2 + c3) from t where c2 = 1) from dual;
select /*+index(t idx)*/ * from t where c2 = 1 union select /*+index(t idx)*/ * from t where c2 = 2;
insert into tmp select /*+index(t idx)*/ c3 from t where c2 = 1;

--disable_warnings
drop table if exists t0,t1,t2;
--enable_warnings
CREATE TABLE IF NOT EXISTS t0(c0 VARCHAR(500) , c1 FLOAT ZEROFILL NULL  COMMENT 'asdf' )  PARTITION BY KEY (c1, c0) partitions 20;
create unique index idx_c1 on t0(c1) global;
CREATE TABLE IF NOT EXISTS t1 LIKE t0;
CREATE TABLE t2 LIKE t0;
CREATE INDEX i780 ON t0(c1, c0(4));

SELECT t1.c0 AS ref0 FROM t1, t0, t2 WHERE ( EXISTS (SELECT 1)) && ((t2.c1) || ((CAST(( EXISTS (SELECT 1)) IS NOT NULL AS SIGNED)) IS NULL)) 
UNION ALL 
SELECT ALL t1.c0 AS ref0 FROM t1, t0, t2 WHERE (! (( EXISTS (SELECT 1)) && ((t2.c1) || ((CAST(( EXISTS (SELECT 1)) IS NOT UNKNOWN AS SIGNED)) IS NULL))));

--disable_warnings
drop table if exists t0,t1,t2;
--enable_warnings

# clean env
connection default;
drop table t, tmp;
