--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: pl, optimizer
#description: test function dependence

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings
--disable_result_log
create table t1 (pk int primary key, c1 int not null, c2 int not null, c3 int, unique index uidx_c1_c2(c1,c2));
create table t2 (pk int primary key, c1 int, c2 int, c3 int, unique index uidx_c1_c2(c1,c2));
create table t3 (pk int primary key, c1 int, c2 int, c3 int);
insert into t1 values (1,1,1,1),(2,1,2,1),(3,2,1,null),(4,2,2,4),(5,3,3,null),(6,5,4,3);
insert into t2 values (1,1,1,1),(2,1,2,1),(3,2,null,null),(4,2,null,4),(5,3,3,null),(6,5,4,3);
insert into t3 values (1,1,1,1),(2,1,2,1),(3,1,2,null),(4,2,2,4),(5,3,3,null),(6,null,4,3);
--disable_query_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log
--enable_query_log
--result_format 4
--explain_protocol 2
# simple scan
select * from t1 order by pk, c1, c2, c3;
select /*+index(t1 uidx_c1_c2)*/ * from t1 order by c1, c2, c3;
select /*+index(t1 uidx_c1_c2)*/ * from t2 order by c1, c2, c3;
select /*+index(t1 uidx_c1_c2)*/ * from t2 where c1 > 0 and c2 > 0 order by c1, c2, c3;
select c1,c2,c3 from t1 group by c1,c2,c3;
select c1,c2,c3 from t2 group by c1,c2,c3;
select c1,c2,c3 from t2 where c1 > 0 and c2 > 0 group by c1,c2,c3;

# inner join
select t1.pk, t1.c1, t1.c2, t1.c3 from t1,t3 where t1.pk = t3.pk group by t1.pk, t1.c1, t1.c2, t1.c3;
select t1.pk, t1.c1, t1.c2, t1.c3 from t1,t3 where t1.pk = t3.c1 group by t1.pk, t1.c1, t1.c2, t1.c3;
select t1.c1, t1.c2, t1.c3 from t1,t3 where t1.pk = t3.pk group by t1.c1, t1.c2, t1.c3;
select t1.c1, t1.c2, t1.c3 from t1,t3 where t1.pk = t3.c1 group by t1.c1, t1.c2, t1.c3;
select t2.c1, t2.c2, t2.c3 from t2,t3 where t2.c1 = t3.c1 group by t2.c1, t2.c2, t2.c3;
select t2.c1, t2.c2, t2.c3 from t2,t3 where t2.c1 = t3.c1 and t2.c2 = t3.c2 group by t2.c1, t2.c2, t2.c3;
select /*+ordered use_nl(t3)*/ * from t1,t3 where t1.pk = t3.pk order by t1.pk, t1.c3;
select /*+ordered use_nl(t3)*/ * from t1,t3 where t1.pk = t3.c1 order by t1.pk, t1.c3;
select /*+ordered use_nl(t3)*/ * from t2,t3 where t2.c1 = t3.c1 order by t2.c1, t2.c2, t2.c3;
select /*+ordered use_nl(t3)*/ * from t2,t3 where t2.c1 = t3.c1 and t2.c2 = t3.c2 order by t2.c1, t2.c2, t2.c3;
# n to n join
select t1.pk, t1.c3, t2.pk, t2.c1 from t1, t2 where t1.c2 = t2.c2 group by t1.pk, t1.c3, t2.pk, t2.c1 order by 1,2,3,4;
select /*+no_rewrite*/ t1.pk, t1.c3, t2.pk, t2.c1 from t1, t2 where t1.c2 = t2.c2 group by t1.pk, t1.c3, t2.pk, t2.c1 order by 1,2,3,4;
select distinct t1.pk, t1.c1, t2.pk, t2.c3 from t1, t2 where t1.c2 = t2.c2 order by 1,2,3,4;
select /*+no_rewrite*/ distinct t1.pk, t1.c1, t2.pk, t2.c3 from t1, t2 where t1.c2 = t2.c2 order by 1,2,3,4;
select /*+ordered*/ t3.pk, t1.c1, t2.c2 from t1, t2, t3 
where t1.c2 = t2.c2 and t3.c1 = t1.pk and t3.c2 = t2.pk group by t3.pk, t1.c1, t2.c2 order by 1,2,3;
select /*+no_rewrite ordered*/ t3.pk, t1.c1, t2.c2 from t1, t2, t3 
where t1.c2 = t2.c2 and t3.c1 = t1.pk and t3.c2 = t2.pk group by t3.pk, t1.c1, t2.c2 order by 1,2,3;
select distinct t1.c1, t2.c2, t1.c3, t2.pk, t2.c1, t3.pk, t3.c3 from t1, t2, t3 where t1.c2 = t2.c2 and t3.c3 = t2.c3 order by 1,2,3,4,5,6;
select /*+no_rewrite*/ distinct t1.c1, t2.c2, t1.c3, t2.pk, t2.c1, t3.pk, t3.c3 from t1, t2, t3 where t1.c2 = t2.c2 and t3.c3 = t2.c3 order by 1,2,3,4,5,6;

# cartisian join
select * from t1,t2 order by t1.pk, t1.c1, t1.c2, t1.c3;
select * from t1,t2 order by t1.c1, t1.c2, t1.c3;
select * from t1,t2 order by t2.c1, t2.c2, t2.c3;
select * from t1,t2 where t2.c1 > 0 and t2.c2 > 0 order by t2.c1, t2.c2, t2.c3;
select t1.pk, t1.c1, t1.c2, t1.c3 from t1,t2 group by t1.pk, t1.c1, t1.c2, t1.c3;
select t1.c1, t1.c2, t1.c3 from t1,t2 group by t1.c1, t1.c2, t1.c3;
select t2.c1, t2.c2, t2.c3 from t1,t2 group by t2.c1, t2.c2, t2.c3;
select t2.c1, t2.c2, t2.c3 from t1,t2 where t2.c1 > 0 and t2.c2 > 0 group by t2.c1, t2.c2, t2.c3;
select t1.c1, t1.c2, t1.c3, t2.pk, t2.c3 from t1,t2 group by t1.c1, t1.c2, t1.c3, t2.pk, t2.c3;
select /*+no_rewrite*/ t1.c1, t1.c2, t1.c3, t2.pk, t2.c3 from t1,t2 group by t1.c1, t1.c2, t1.c3, t2.pk, t2.c3;
select distinct t1.c1, t1.c2, t1.c3, t2.pk, t2.c3 from t1,t2;
select /*+no_rewrite*/ distinct t1.c1, t1.c2, t1.c3, t2.pk, t2.c3 from t1,t2;

# semi/anti join
select t1.c1, t1.c2, t1.c3 from t1 where exists (select 1 from t3 where t3.c1 = t1.c1) group by t1.c1, t1.c2, t1.c3;
select t2.c1, t2.c2, t2.c3 from t2 where exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c2 = t2.c2) group by t2.c1, t2.c2, t2.c3;
select t1.c1, t1.c2, t1.c3 from t1 where not exists (select 1 from t3 where t3.c1 = t1.c1) group by t1.c1, t1.c2, t1.c3;
select t2.c1, t2.c2, t2.c3 from t2 where not exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c2 = t2.c2) group by t2.c1, t2.c2, t2.c3;
select * from t1 where t1.c1 > 0 and exists (select 1 from t3 where t3.c1 = t1.c1) order by t1.c1, t1.c2, t1.c3;
select * from t2 where t2.c1 > 0 and exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c2 = t2.c2) order by t2.c1, t2.c2, t2.c3;
select * from t1 where t1.c1 > 0 and not exists (select 1 from t3 where t3.c1 = t1.c1) order by t1.c1, t1.c2, t1.c3;
select * from t2 where t2.c1 > 0 and not exists (select 1 from t3 where t3.c1 = t2.c1 and t3.c2 = t2.c2) order by t2.c1, t2.c2, t2.c3;

# outer join
select t1.pk, t1.c1 from t1 left join t3 on t1.pk = t3.pk group by t1.pk, t1.c1;
select t1.pk, t1.c1 from t1 left join t3 on t1.pk = t3.c1 group by t1.pk, t1.c1;
select t2.c1, t2.c2, t2.c3 from t2 left join t3 on t2.c1 = t3.c1 group by t2.c1, t2.c2, t2.c3;
select t2.c1, t2.c2, t2.c3 from t2 left join t3 on t2.c1 = t3.c1 where t2.c2 > 0 and t2.c1 > 0 group by t2.c1, t2.c2, t2.c3;
select t1.pk, t1.c1 from t1 left join t3 on t1.pk = t3.pk where t1.c2 > 0 order by t1.pk, t1.c1;
select t1.pk, t1.c1 from t1 left join t3 on t1.pk = t3.c1 where t1.c2 > 0 order by t1.pk, t1.c1;
select t2.c1, t2.c2, t2.c3 from t2 left join t3 on t2.c1 = t3.c1 where t2.c2 > 0 order by t2.c1, t2.c2, t2.c3;
select t2.c1, t2.c2, t2.c3 from t2 left join t3 on t2.c1 = t3.c1 where t2.c2 > 0 and t2.c1 > 0 order by t2.c1, t2.c2, t2.c3;

# sbuplan scan
select v.pk, v.c1 from t3, (select t1.pk, t1.c1, t1.c2, t1.c3 from t1 limit 10) v 
where v.c1 = t3.pk group by v.pk, v.c1;
select v.pk, v.c1 from t3, (select t1.pk, t1.c1, t1.c2, t1.c3 from t1 limit 10) v 
where v.c1 = t3.c1 group by v.pk, v.c1;
select v.pk, v.c1 from t3, (select t2.pk, t2.c1, t2.c2, t2.c3 from t2 limit 10) v 
where v.c1 = t3.pk group by v.pk, v.c1;
select v.pk, v.c1 from t3, (select t2.pk, t2.c1, t2.c2, t2.c3 from t2 limit 10) v 
where v.c1 = t3.c1 group by v.pk, v.c1;
select pk,c1,c2,c3 from (select pk,c1,c2,c3 from t1 union select pk,c1,c2,c3 from t2) v 
where v.pk > 0 group by pk,c1,c2,c3;
select pk,c1,c2,c3 from (select pk,c1,c2,c3 from t1 union all select pk,c1,c2,c3 from t2) v 
where v.pk > 0 group by pk,c1,c2,c3;
select pk,c1,c2,c3 from (select pk,c1,c2,c3 from t1 intersect select pk,c1,c2,c3 from t2) v 
where v.pk > 0 group by c1,c2,c3;
select pk,c1,c2,c3 from (select pk,c1,c2,c3 from t2 except select pk,c1,c2,c3 from t1) v 
where v.pk > 0 group by c1,c2,c3;

drop table t1,t2,t3;

## const in fd
--disable_warnings
drop table if exists t1, t2, t3, tp1;
--enable_warnings
--disable_result_log
create table t1 (c1 int, c2 int, c3 int, primary key(c1, c2));
create table t2 (c1 int, c2 int, c3 int, primary key(c1, c2));
create table t3 (c1 int, c2 int, c3 int, primary key(c1));
create table tp1 (c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 2;

--disable_query_log
insert into t1 values(1,2,3);
insert into t1 values(1,3,3);
insert into t1 values(2,2,3);
insert into t2 values(1,2,3);
insert into t2 values(1,3,3);
insert into t2 values(2,2,3);
insert into t3 values(1,2,3);
insert into t3 values(2,3,3);
insert into t3 values(3,2,3);
insert into tp1 values (1,1,1), (2,2,2), (3,3,3);
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from tp1;
--enable_result_log
--enable_query_log

select t1.c1, t1.c2, t3.c1 from t1, t3 where t1.c2 = t3.c2 group by t1.c1, t1.c2, t3.c1 order by 1,2,3;

## order by
select * from t3 order by c1, c2, c3;
select * from t3 order by c2, c1, c3;
select * from t3 order by c2, c3, c1;
select * from tp1 order by c2, c1, c3;
select * from t3 where c2 = 1 order by c2, c3, c1;
select * from t3 where c3 = 1 order by c3, c1, c2;
select * from tp1 where c2 = 1 order by c2, c1, c3;
select * from tp1 where c2 = 1 order by c2, c3, c1;
select * from t1,t2 order by t1.c1, t2.c1, t1.c2, t2.c2, t1.c3, t2.c3;
select * from t1 where c1 = 4 and c3 = 4 order by c2;
select * from tp1 where c1 = 4 and c3 = 4 order by c2;

## group by
select c1,c2,c3 from t1 group by c1,c2,c3;
select c1,c2,c3 from t1 where c2 = 1 group by c1,c3;
select c1,c2,c3 from tp1 group by c1,c2,c3;
select c1,c2,c3 from tp1 where c2 = 1 group by c1,c3;
select t1.c1, t3.c1 from t1, t3 where t1.c2 = t3.c2 group by t1.c1, t3.c1, t3.c2 order by 1,2;
select t1.c1, t3.c1 from t1, t3 where t1.c2 = t3.c2 group by t1.c1, t3.c1 order by 1,2;
select tp1.c1, t3.c1 from tp1, t3 where tp1.c2 = t3.c2 group by tp1.c1, t3.c1, t3.c2;
select tp1.c1, t3.c1 from tp1, t3 where tp1.c2 = t3.c2 group by tp1.c1, t3.c1;

## distinct
select distinct t1.*, t2.c2, t2.c3 from t1,t2;
select distinct t1.c1, t3.c2, t3.c1 from t1, t3 where t1.c2 = t3.c2 order by 1,2,3;
select distinct t1.c1, t3.c1 from t1, t3 where t1.c2 = t3.c2 order by 1,2;
select distinct * from (select /*+no_merge */ c1,c3 from t1 where c2 = 2);
select distinct * from (select /*+ no_merge */ t2.c1 a from t1, t2 where t1.c1 = 2 and t2.c1 = t1.c1);
select distinct * from (select /*+no_merge */ c1,c3 from tp1 where c2 = 2);
select distinct * from (select /*+ no_merge */ t2.c1 a from tp1, t2 where tp1.c1 = 2 and t2.c1 = tp1.c1);

## set op const
select * from t1 where c2 = 2 union select * from t2 where c2 = 2 order by c3,c2,c1;
select * from t1 where c2 = 2 union select * from t2 where c2 = 2 order by c2,c1,c3;
select * from t1 where c2 = 2 union select * from t2 where c2 = 1 order by c3,c2,c1;
select * from t1 where c2 = 2 union select * from t2 where c2 = 1 order by c2,c1,c3;

select * from t1 intersect select * from t2 where c2 = 1 order by c3,c2,c1;
select * from t1 intersect select * from t2 where c2 = 1 order by c2,c1,c3;
select * from tp1 intersect select * from t1 where c2 = 1 order by c2,c1,c3;
select * from tp1 intersect select * from tp1 where c2 = 1 order by c2,c1,c3;
select * from t1 where c2 = 1 intersect select * from t2 order by c3,c2,c1;
select * from t1 where c2 = 1 intersect select * from t2 order by c2,c1,c3;
select * from tp1 where c2 = 1 intersect select * from t1 order by c2,c1,c3;
select * from tp1 where c2 = 1 intersect select * from tp1 order by c2,c1,c3;

select * from t1 except select * from t2 where c2 = 2 order by c3,c2,c1;
select * from t1 except select * from t2 where c2 = 2 order by c2,c1,c3;
select * from tp1 except select * from t1 where c2 = 2 order by c2,c1,c3;
select * from tp1 except select * from tp1 where c2 = 2 order by c2,c1,c3;
select * from t1 where c2 = 2 except select * from t2 order by c3,c2,c1;
select * from t1 where c2 = 2 except select * from t2 order by c2,c1,c3;
select * from tp1 where c2 = 2 except select * from t1 order by c2,c1,c3;
select * from tp1 where c2 = 2 except select * from tp1 order by c2,c1,c3;

## const expr from in generate table select
select distinct a from (select /*+no_merge*/ 1 as a from t1) V;

drop table t1,t2,t3, tp1;

--disable_warnings
drop table if exists t1, t2, t4, t5;
--enable_warnings

CREATE TABLE t1(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13)) ;
CREATE TABLE t2(EMPNO INT UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMBER(4),HIREDATE DATE,SAL NUMBER(7,2),COMM NUMBER(7,2),DEPTNO NUMBER(2));
CREATE TABLE t4(DEPTNO INT PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13));
CREATE TABLE t5(EMPNO INT UNIQUE,ENAME VARCHAR(10) NOT NULL,JOB VARCHAR(9),MGR NUMBER(4),HIREDATE DATE,SAL NUMBER(7,2),COMM NUMBER(7,2),DEPTNO NUMBER(2));

SELECT distinct deptno, ename FROM (SELECT e.deptno,e.dname,p.ename,p.job,p.sal FROM t1 e,t2 p WHERE e.deptno = p.deptno 
INTERSECT 
SELECT e.deptno,e.dname,p.ename,p.job,p.sal FROM t4 e,t5 p WHERE e.deptno = p.deptno);

--disable_warnings
drop table if exists t1, t2, t4, t5;
--enable_warnings

## candi fd check exprs unique bug:2025051600109048891

--disable_warnings
drop table if exists t6;
--enable_warnings

CREATE TABLE `t6` (
`c0` float(43,25) unsigned DEFAULT NULL,
`c1` datetime DEFAULT NULL,
`c2` float DEFAULT NULL COMMENT 'asdf',
`c3` datetime DEFAULT NULL,
UNIQUE KEY `c3` (`c3`) BLOCK_SIZE 16384 LOCAL
) ;

--disable_result_log
--disable_query_log
insert into t6 values(1,0,1,null);
insert into t6 values(2,0,1,null);
insert into t6 values(3,0,1,null);
--enable_result_log
--enable_query_log

## expect 3 rows
SELECT /*+semi_to_inner*/ * FROM t6 WHERE  t6.c2 In  (SELECT  t6.c2 FROM t6 WHERE (t6.c3) IS NULL) ORDER BY 1 ;

--disable_warnings
drop table if exists t1, t2, t4, t5;
--enable_warnings
