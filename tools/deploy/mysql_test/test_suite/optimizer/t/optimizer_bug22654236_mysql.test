--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists t1,t2, t3;
--enable_warnings
create table t1(a int, b int);
create table t2 (a int, b int) partition by hash (a) partitions 3;
CREATE TABLE `t3` (
  `pk` int(11) NOT NULL,
  `col_timestamp_6_index` timestamp(6) NULL DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx17` (`pk`, `col_timestamp_6_index`)
  );

--disable_query_log
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,4);
insert into t1 values(5,5);
insert into t2 values(1,1);
insert into t2 values(2,2);
insert into t2 values(3,3);
insert into t2 values(4,4);
insert into t2 values(5,5);
insert into t3 values (1,now()),(2,now()),(3,null),(4,null);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log
--enable_query_log


--result_format 4
--explain_protocol 2

select distinct 1 from t1 limit 3;
select distinct 1 from t1 limit 0,3;
select distinct 1 from t1 limit 1,5;
select distinct 1 from t2 limit 3;
select distinct 1 from t2 limit 0,3;
select distinct 1 from t2 limit 1,5;
SELECT distinct count(1) from t3 GROUP BY pk ORDER BY pk DESC LIMIT 0 , 2;

drop table t1, t2, t3;
