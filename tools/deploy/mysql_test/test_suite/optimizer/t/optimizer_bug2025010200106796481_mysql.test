--disable_warnings

drop table if exists t1,t2,t3;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
create table t3 (c1 int, c2 int, c3 int);

--result_format 4
explain select * from t1,t2,t3 where t1.c1 = 1 and t1.c1 = t2.c1 and t1.c2 = t3.c2;
explain select * from t1,t2,t3 where t1.c1 = 1 and t1.c1 = t2.c1 and t1.c2 = t3.c2 and t2.c3 = t3.c3;

drop table t1,t2,t3;

--disable_warnings
drop table if exists scrm_user_main_3643;
