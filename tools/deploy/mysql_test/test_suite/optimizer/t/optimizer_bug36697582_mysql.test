# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1 (c1 int primary key, c2 int) partition by range(c1) ( partition p0 values less than (3), partition p1 values less than (30));
create table t2 (c1 int primary key, c2 int) partition by range(c1) ( partition p0 values less than (3), partition p1 values less than (30));
--disable_query_log
--disable_result_log
insert into t1 values (1,1),(2,2),(10,3),(20,4),(29,5);
insert into t2 values (1,1),(2,2),(10,3),(20,4),(29,5);
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

select * from t1, t2 where t1.c1 = t2.c1 order by t1.c1 desc;
select t1.c1 from t1 union select t2.c1 from t2;
