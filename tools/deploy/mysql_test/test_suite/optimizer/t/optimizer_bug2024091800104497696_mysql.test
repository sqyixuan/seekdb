--disable_warnings
drop table if exists t_index;
drop table if exists t11;
--enable_warnings

create table t_index(c_index int,index t11(c_index));
create table t11(c1 int);
call dbms_stats.gather_schema_stats('TEST');

drop table if exists t_index;
drop table if exists t11;
