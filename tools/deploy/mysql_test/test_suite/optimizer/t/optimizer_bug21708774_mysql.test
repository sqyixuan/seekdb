--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists `ren_acc_item_32`, `ren_inst_item_32`;
--enable_warnings

CREATE TABLE `ren_acc_item_32` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增id',
  `tnt_inst_id` varchar(8) NOT NULL COMMENT '租户id',
  `external_event_id` varchar(64) NOT NULL COMMENT '外部事件ID',
  `amount` bigint(20) NOT NULL COMMENT '金额',
  `status` varchar(1) NOT NULL COMMENT '对账状态。I初始；S成功',
  `recon_date` varchar(8) DEFAULT NULL COMMENT '对帐日期',
  `batch_no` varchar(64) DEFAULT NULL COMMENT '对帐批次号',
  `settle_date` varchar(8) NOT NULL COMMENT '应清算日期',
  `target_code` varchar(20) NOT NULL COMMENT '目标代码',
  `direction` varchar(1) NOT NULL COMMENT '分录方向',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_tnt_external` (`tnt_inst_id`, `external_event_id`) BLOCK_SIZE 16384,
  KEY `idx_stat_target_ex` (`status`, `target_code`, `amount`, `direction`) BLOCK_SIZE 16384
);

CREATE TABLE `ren_inst_item_32` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '自增id',
  `settle_inst_date` varchar(8) NOT NULL COMMENT '机构日期',
  `tnt_inst_id` varchar(8) NOT NULL COMMENT '租户',
  `external_event_id` varchar(64) NOT NULL COMMENT '外部事件ID',
  `target_code` varchar(20) DEFAULT NULL COMMENT '目标代码',
  `operator` varchar(32) NOT NULL COMMENT '操作员',
  `amount` bigint(20) NOT NULL COMMENT '金额',
  `direction` varchar(1) NOT NULL COMMENT '分录方向',
  `status` varchar(1) NOT NULL COMMENT '对账状态。I初始；S成功',
  `batch_no` varchar(64) DEFAULT NULL COMMENT '对帐批次号',
  PRIMARY KEY (`id`),
  KEY `idx_tnt_target_settle_operator` (`tnt_inst_id`, `settle_inst_date`, `target_code`, `operator`) BLOCK_SIZE 16384
);

explain select a.id from ren_acc_item_32 a, ren_inst_item_32 b
where
  a.target_code in ('030099000048')
  and a.status = 'I'
  and a.tnt_inst_id = 'MYBKC1CN'
  and a.target_code = b.target_code
  and a.external_event_id = b.external_event_id
  and a.amount = b.amount
  and a.direction = b.direction
  and b.status = 'S'
  and b.tnt_inst_id = 'MYBKC1CN'
  and b.settle_inst_date = '20190709'
  and b.operator = '777777'
  and b.batch_no = '20190711TkvicbrmDBSKJwvMEWUO5300'
limit 2500;

drop table `ren_acc_item_32`, `ren_inst_item_32`;
