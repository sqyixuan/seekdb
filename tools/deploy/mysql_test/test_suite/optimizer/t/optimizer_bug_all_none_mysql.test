#owner: zhenling.zzg
#owner group: SQL1
#tag: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);

call dbms_stats.set_table_stats(NULL, 't1', numrows=>100000);

--explain_protocol 2

select /*+parallel(2) opt_param('_ENABLE_STORAGE_CARDINALITY_ESTIMATION','false')*/ count(*) from (select 1 as c1 union all select 2 union all select 3)v,t1 
where t1.c1 = V.c1;
select /*+parallel(2) opt_param('_ENABLE_STORAGE_CARDINALITY_ESTIMATION','false')*/ count(*) from (select 1 as c1 union all select 2 union all select 3)v
left join t1 
on t1.c1 = V.c1;

--disable_warnings
drop table if exists t1;
--enable_warnings
