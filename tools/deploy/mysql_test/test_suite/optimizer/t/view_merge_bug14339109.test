--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer
# Test view merge bug T14339109

# schema
--disable_warnings
DROP DATABASE IF EXISTS opt;
--enable_warnings

create database opt;
use opt;

create table EMP (
  EMPno  integer,
  SAL integer,
  DEPTNO integer
) ;
create table DEPT(
  DEPTNO integer,
  DNAME char(45)
) ;

# data
insert into EMP values (0, 0 , 0);
insert into EMP values (1, 5000 , 0);
insert into EMP values (2, 0 , 1);
insert into EMP values (3, 4400 , 2);
insert into EMP values (4, 4500 , 3);

insert into DEPT values (0, 'A');
insert into DEPT values (1, 'B');
insert into DEPT values (2, 'C');
insert into DEPT values (3, 'D');
insert into DEPT values (4, 'E');
insert into DEPT values (5, 'F');

# test query
--result_format 4
--explain_protocol 2

select
V.dname, V.subq_col
from
  ( select
   ( select max(e.sal)
   from ( select * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;

select /*+ NO_REWRITE */
V.dname, V.subq_col
from
  ( select /*+ NO_REWRITE */
   ( select /*+ NO_REWRITE */ max(e.sal)
   from ( select /*+ NO_REWRITE */  * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select /*+ NO_REWRITE */  * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;

# delete schema
--result_format 2
--explain_protocol 1
--disable_warnings
DROP DATABASE IF EXISTS opt;
--enable_warnings
