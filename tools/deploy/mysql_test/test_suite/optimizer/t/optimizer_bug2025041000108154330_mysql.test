#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int, primary key(c1, c2));

--result_format 4
--explain_protocol 1

select /*+ opt_param('NESTED_LOOP_JOIN_ENABLED', 'true') */ * from t1, t2 where t1.c1 < t2.c1;
select /*+ opt_param('NESTED_LOOP_JOIN_ENABLED', 'false') */ * from t1, t2 where t1.c1 < t2.c1;

select /*+ opt_param('NESTED_LOOP_JOIN_ENABLED', 'false') */ * from t1, t2 where t1.c1 < t2.c1 and t1.c2 = t2.c2;
select /*+ opt_param('NESTED_LOOP_JOIN_ENABLED', 'false') leading(t1) use_nl(t2)*/ * from t1, t2 where t1.c1 < t2.c1 and t1.c2 = t2.c2;

drop table t1, t2;
