#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

--disable_result_log
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 3;
create table t2 (c1 int, c2 int, c3 int) partition by key(c1, c2) partitions 3;
create table t3 (c1 int, c2 int, c3 int) partition by hash(c1) 
subpartition by range (c2) subpartition template
(
  subpartition p0 values less than (10),
  subpartition p1 values less than (20),
  subpartition p2 values less than (maxvalue)
) partitions 3;
create table t4 (c1 int, c2 int, c3 int);

insert into t1 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
                      (5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t2 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
                      (5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t3 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
                      (5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);
insert into t4 values (1,1,1),(1,1,1),(2,2,2),(2,null,2),(3,3,3),(3,3,null),(4,4,null),
                      (5,null,null),(null,null,null),(6,null,6),(6,null,null),(null,7,7),(null,null,null);

--disable_query_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select count(distinct c1) from t1;
select count(distinct c2) from t1;
select count(distinct c1,c2) from t1;
select sum(distinct c1) from t1;
select sum(distinct c2) from t1;

select count(distinct c1) from t2;
select count(distinct c2) from t2;
select count(distinct c1,c2) from t2;
select count(distinct c1,c2,c3) from t2;
select sum(distinct c1) from t2;

select count(distinct c1) from t3;
select count(distinct c2) from t3;
select count(distinct c1,c2) from t3;
select count(distinct c1,c2,c3) from t3;
select sum(distinct c1) from t3;

select count(distinct c1) from t4;
select /*+parallel(3)*/ count(distinct c1) from t4;
select count(distinct c1,c2) from t4;
select /*+parallel(3)*/ count(distinct c1,c2) from t4;
select sum(distinct c1) from t4;
select /*+parallel(3)*/ sum(distinct c1) from t4;

select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1) from t1,t2 where t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c2) from t1,t2 where t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1,t1.c2) from t1,t2 where t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c1) from t1,t2 where t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c2) from t1,t2 where t1.c1 = t2.c2;

select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1) from t1 right join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c2) from t1 right join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1,t1.c2) from t1 right join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c1) from t1 right join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c2) from t1 right join t2 on t1.c1 = t2.c2;

select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1) from t1 left join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c2) from t1 left join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ count(distinct t1.c1,t1.c2) from t1 left join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c1) from t1 left join t2 on t1.c1 = t2.c2;
select /*+ordered pq_distribute(t2 none partition)*/ sum(distinct t1.c2) from t1 left join t2 on t1.c1 = t2.c2;

drop table if exists t1,t2,t3,t4;
