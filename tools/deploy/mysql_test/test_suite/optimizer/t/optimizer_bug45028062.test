#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t_1;
drop table if exists t_2;
drop table if exists t_3;


CREATE TABLE t_1 ( 
  cat_id int PRIMARY KEY ,
  product_time date,
  num int UNIQUE,
  UNIQUE INDEX index_num (num));
CREATE TABLE t_2 ( 
  cat_id int PRIMARY KEY ,
  name varchar(10) ,
  parent_cid DECIMAL(5),
  cat_level DECIMAL(5) ,
  product_count DECIMAL(5));
CREATE TABLE t_3 ( 
  num int PRIMARY KEY ,
  prices DECIMAL(9,2),
  status int);

