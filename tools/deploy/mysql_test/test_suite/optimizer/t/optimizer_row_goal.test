#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
--disable_warnings
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int, index i1(c1,c2,c3));
--enable_warnings

insert into t1 select uniform(0, 99, random(1)), uniform(0, 99, random(2)), uniform(0, 99, random(3)), uniform(0, 99, random(4)) from table(generator(10000));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');

--enable_query_log
--result_format 4
--explain_protocol 2

select /*+opt_param('enable_optimizer_rowgoal', 'auto')*/ * from t1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'off') */ * from t1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'auto')*/ * from t1 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'off') */ * from t1 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'auto')*/ c1 from t1 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'off') */ c1 from t1 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'auto')*/ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 1)     */ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'on')  */ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 2)     */ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'off') */ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 0)     */ * from t1 where c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'auto')*/ * from t1 where c1 > 50 and c2 > 50 order by c1 limit 1;
select /*+opt_param('enable_optimizer_rowgoal', 'off') */ * from t1 where c1 > 50 and c2 > 50 order by c1 limit 1;
select /*+no_semi_to_inner leading(t1 t2) use_nl(t2) opt_param('enable_optimizer_rowgoal', 'auto')*/ count(*) from t1 where exists (select 1 from t1 t2 where t2.c1 = t1.c4);
select /*+no_semi_to_inner leading(t1 t2) use_nl(t2) opt_param('enable_optimizer_rowgoal', 'off') */ count(*) from t1 where exists (select 1 from t1 t2 where t2.c1 = t1.c4);
select /*+no_semi_to_inner leading(t1 t2) use_nl(t2) opt_param('enable_optimizer_rowgoal', 'auto')*/ count(*) from t1 where not exists (select 1 from t1 t2 where t2.c1 = t1.c4);
select /*+no_semi_to_inner leading(t1 t2) use_nl(t2) opt_param('enable_optimizer_rowgoal', 'off') */ count(*) from t1 where not exists (select 1 from t1 t2 where t2.c1 = t1.c4);

set enable_optimizer_rowgoal = 'off';
select /*+no_rewrite*/ * from t1 v1, t1 v2 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c4 = v2.c4 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c1 = v2.c1 order by v1.c1 limit 1;
select c1, count(*) from t1 group by c1 order by c1 limit 1;
select distinct c1 from t1 limit 1;

set enable_optimizer_rowgoal = 'auto';
select /*+no_rewrite*/ * from t1 v1, t1 v2 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c4 = v2.c4 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c1 = v2.c1 order by v1.c1 limit 1;
select c1, count(*) from t1 group by c1 order by c1 limit 1;
select distinct c1 from t1 limit 1;

set enable_optimizer_rowgoal = 2;
select /*+no_rewrite*/ * from t1 v1, t1 v2 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c4 = v2.c4 limit 1;
select /*+no_rewrite*/ * from t1 v1, t1 v2 where v1.c1 = v2.c1 order by v1.c1 limit 1;
select c1, count(*) from t1 group by c1 order by c1 limit 1;
select distinct c1 from t1 limit 1;

drop table t1;