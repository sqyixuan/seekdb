# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2, t3;
drop table if exists t16;
--enable_warnings

create table t16 (c1 INTEGER(127) , c14 BIGINT(127) ,c15 CHAR(152) ,c16 INT(127) , primary key(c1)) ; 
create unique index g_u_0_BBx on t16(c16,c1,c14) global ; 
insert into t16 values(1,1,'1',1);

create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create index t2_i1 on t2(c1);

--result_format 4
--explain_protocol 2

SELECT
/*+no_rewrite  parallel(2)leading(B,A) use_nl(B,A) PQ_SET(@"SET$2"  RANDOM NONE) */ B.c16
FROM   (SELECT c16
         FROM   t16
        UNION ALL
        SELECT
        /*+no_rewrite leading(B,A) use_nl(B,A)*/ B.c16
          FROM  (SELECT c16
                   FROM   t16
                  UNION ALL
                  SELECT
                  /*+no_rewrite leading(B,A) use_nl(B,A) no_use_das(A)*/ B.c16
                      FROM   t16 A,
                             t16 B
                      WHERE  A.c16 >= B.c16) B
          ) B ;

select /*+leading(t1 t2 t3) no_use_merge(t2)*/ 1 from t1 left join t2 on t1.c2 = t2.c1 left join t3 on t1.c2 = t3.c2 order by t1.c1;

select /*+leading(t1 t2) use_hash(t2) parallel(t1 2) parallel(t2 3) pq_distribute(t2 hash hash)*/ 
count(*) from t1, t2 where t1.c1 = t2.c1;

select /*+leading(t1 t2) use_hash(t2) parallel(t1 2) parallel(t2 3) pq_distribute(t2 BC2HOST NONE)*/ 
count(*) from t1, t2 where t1.c1 = t2.c1;

select /*+leading(t1 t2) use_hash(t2) parallel(t1 2) parallel(t2 3) pq_distribute(t2 NONE BROADCAST)*/ 
count(*) from t1, t2 where t1.c1 = t2.c1;

select /*+leading(t1 t2) use_hash(t2) parallel(t1 2) parallel(t2 3) use_das(t2)*/ 
count(*) from t1, t2 where t1.c1 = t2.c1;

select /*+parallel(t1 2)*/ * from t1 union all select /*+parallel(t2 3)*/ * from t2;
