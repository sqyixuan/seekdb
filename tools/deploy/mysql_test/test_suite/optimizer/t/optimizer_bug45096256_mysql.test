CREATE TABLE `t_plupaq` (
  `UpdateType` decimal(10,0) DEFAULT NULL COMMENT '更新类型',
  `PLU` text DEFAULT NULL COMMENT 'sku编码',
  `OldPLU` text DEFAULT NULL COMMENT 'null',
  `Departamento` text DEFAULT NULL COMMENT '二级类目编码',
  `PLUDescription` text DEFAULT NULL COMMENT 'sku名称',
  `RetailPrice` decimal(10,1) DEFAULT NULL COMMENT '价格组价格',
  `MixMatchID` text DEFAULT NULL COMMENT 'null',
  `TaxTable1` text DEFAULT NULL COMMENT 'IVA是否生效判断根据二级类目的hasIva和item表的hasIva字段判断\n    IEPS是否存在根据Item的ieps判断',
  `TaxTable2` text DEFAULT NULL COMMENT 'IVA是否生效判断根据二级类目的hasIva和item表的hasIva字段判断\n    IEPS是否存在根据Item的ieps判断',
  `LinkItemFlag` text DEFAULT NULL COMMENT 'null',
  `Discountable` text DEFAULT NULL COMMENT 'null',
  `CommissionID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `VendorID` text DEFAULT NULL COMMENT '供应商编码',
  `UserFlag1` text DEFAULT NULL COMMENT 'null',
  `PromptID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Family` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `FrequentBuyerCode` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `UseDepartmentflags` text DEFAULT NULL COMMENT 'Fixed value N',
  `ScaleItem` text DEFAULT NULL COMMENT 'null',
  `Returnable` text DEFAULT NULL COMMENT 'null',
  `CouponItem` text DEFAULT NULL COMMENT 'null',
  `TaxTable3` text DEFAULT NULL COMMENT 'IVA是否生效判断根据二级类目的hasIva和item表的hasIva字段判断\n    IEPS是否存在根据Item的ieps判断',
  `TaxTable4` text DEFAULT NULL COMMENT 'IVA是否生效判断根据二级类目的hasIva和item表的hasIva字段判断\n    IEPS是否存在根据Item的ieps判断',
  `Itemizer1` text DEFAULT NULL COMMENT 'null',
  `ItemizerTax1` text DEFAULT NULL COMMENT 'null',
  `ItemizerTax2` text DEFAULT NULL COMMENT 'null',
  `ItemizerTax3` text DEFAULT NULL COMMENT 'null',
  `ItemizerTax4` text DEFAULT NULL COMMENT 'null',
  `ActivationDate` text DEFAULT NULL COMMENT '当前日期 Format MM/DD/AA',
  `TareWeight` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `HasCrossRefPLU` text DEFAULT NULL COMMENT 'null',
  `HasQuantityPrice` text DEFAULT NULL COMMENT 'null',
  `HasLevelPrice` text DEFAULT NULL COMMENT 'null',
  `MixMatch2` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `MixMatch3` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `MixMatch4` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Itemizer2` text DEFAULT NULL COMMENT 'null',
  `Itemizer2Tax1` text DEFAULT NULL COMMENT 'null',
  `Itemizer2Tax2` text DEFAULT NULL COMMENT 'null',
  `Itemizer2Tax3` text DEFAULT NULL COMMENT 'null',
  `Itemizer2Tax4` text DEFAULT NULL COMMENT 'null',
  `Itemizer3` text DEFAULT NULL COMMENT 'null',
  `Itemizer3Tax1` text DEFAULT NULL COMMENT 'null',
  `Itemizer3Tax2` text DEFAULT NULL COMMENT 'null',
  `Itemizer3Tax3` text DEFAULT NULL COMMENT 'null',
  `Itemizer3Tax4` text DEFAULT NULL COMMENT 'null',
  `Itemizer4` text DEFAULT NULL COMMENT 'null',
  `Itemizer4Tax1` text DEFAULT NULL COMMENT 'null',
  `Itemizer4Tax2` text DEFAULT NULL COMMENT 'null',
  `Itemizer4Tax3` text DEFAULT NULL COMMENT 'null',
  `Itemizer4Tax4` text DEFAULT NULL COMMENT 'null',
  `VerifyPricewhensold` text DEFAULT NULL COMMENT '根据Devision编码判断',
  `QuantityDescription` text DEFAULT NULL COMMENT 'size属性',
  `LimitedQuantity` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `ItemSize` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `EmployeeDiscAllowed` text DEFAULT NULL COMMENT 'null',
  `SuggestedRetail` decimal(10,1) DEFAULT NULL COMMENT '组合商品1 非组合0',
  `UserFlag2` text DEFAULT NULL COMMENT 'null',
  `UserFlag3` text DEFAULT NULL COMMENT 'null',
  `UserFlag4` text DEFAULT NULL COMMENT 'null',
  `UserFlag5` text DEFAULT NULL COMMENT 'null',
  `UserFlag6` text DEFAULT NULL COMMENT 'null',
  `GenerateCouponID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AutoDiscID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Filler1` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Filler2` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Filler3` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `QuantityMode` text DEFAULT NULL COMMENT 'null',
  `SellingQuantity` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AllowonLayaways` text DEFAULT NULL COMMENT ' Fixed value N',
  `MatchMFGCode` text DEFAULT NULL COMMENT 'null',
  `TaxTable5` text DEFAULT NULL COMMENT 'null',
  `TaxTable6` text DEFAULT NULL COMMENT 'null',
  `TaxTable7` text DEFAULT NULL COMMENT 'null',
  `TaxTable8` text DEFAULT NULL COMMENT 'null',
  `TaxTable9` text DEFAULT NULL COMMENT 'null',
  `TaxTable10` text DEFAULT NULL COMMENT 'null',
  `TaxTable11` text DEFAULT NULL COMMENT 'null',
  `TaxTable12` text DEFAULT NULL COMMENT 'null',
  `TaxTable13` text DEFAULT NULL COMMENT 'null',
  `TaxTable14` text DEFAULT NULL COMMENT 'null',
  `TaxTable15` text DEFAULT NULL COMMENT 'null',
  `TaxTable16` text DEFAULT NULL COMMENT 'null',
  `Cost` decimal(10,2) DEFAULT NULL COMMENT 'item_center__sku_store_group_price.priceCost',
  `CompetitivePrice1` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `CompetitivePrice2` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AlternateVendor1` text DEFAULT NULL COMMENT 'null',
  `AlternateVendor2` text DEFAULT NULL COMMENT 'null',
  `PriceLabelFormatID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `ShelfLabelFormatID` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `InventoryGroupID` text DEFAULT NULL COMMENT 'sku barcode',
  `SupplementalLength` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `LoyaltyProgramID1` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `LoyaltyProgramID2` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `LoyaltyProgramID3` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `LoyaltyProgramID4` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AllowReturns` text DEFAULT NULL,
  `DisallowSelling` text DEFAULT NULL COMMENT 'null',
  `DisallowExchangesString1YNor10` text DEFAULT NULL COMMENT 'null',
  `OrderingNumber` text DEFAULT NULL COMMENT 'null',
  `AllowPLUUpdate` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AllowPriceUpdate` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `MeasurmentID` text DEFAULT NULL COMMENT 'null',
  `UsedbyDays` text DEFAULT NULL COMMENT 'null',
  `OriginalPrice` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `NonmerchandiseID` text DEFAULT NULL COMMENT 'null',
  `Nonmerchandisesellingquantity` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Allowinmerchandisetypemixmatch` text DEFAULT NULL COMMENT 'Fixed value N',
  `Allowdepartmentupdate` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Size` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `Sizetype` text DEFAULT NULL COMMENT 'Fixed value PZA',
  `Inventorycontrolled` text DEFAULT NULL COMMENT 'null',
  `PriceChangeBatchid` text DEFAULT NULL COMMENT 'null',
  `IsDepositFee` text DEFAULT NULL COMMENT 'null',
  `UseQuantityFromParentPLU` text DEFAULT NULL COMMENT 'null',
  `IsMRP` text DEFAULT NULL COMMENT 'null',
  `Servicecode` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `AmountDiscount` decimal(10,1) DEFAULT NULL COMMENT 'promotionPrice',
  `FromDiscount` text DEFAULT NULL COMMENT 'startAt Format DD/MM/AAAA',
  `ToDiscount` text DEFAULT NULL COMMENT 'expireAt Format DD/MM/AAAA',
  `AmountDiscount1` decimal(10,2) DEFAULT NULL COMMENT 'null',
  `FromDiscount1` text DEFAULT NULL COMMENT 'null',
  `ToDiscount1` text DEFAULT NULL COMMENT 'null',
  `Sale` text DEFAULT NULL COMMENT '是否有这个固定标签 Y|N',
  `BigTicket` text DEFAULT NULL COMMENT '是否有改标签 Y|N',
  `Linea` text DEFAULT NULL COMMENT '三级类目编码',
  `Clase` text DEFAULT NULL COMMENT '四级类目编码',
  `SubClase` text DEFAULT NULL COMMENT '五级类目编码',
  `Marca` text DEFAULT NULL COMMENT '品牌code',
  `Clase1` text DEFAULT NULL COMMENT 'sku 上的class1 价格',
  `VentaPaquetes` text DEFAULT NULL COMMENT 'Fixed value = \"Y\" meas bundle',
  `Bandera2` text DEFAULT NULL COMMENT 'null',
  `Bandera3` text DEFAULT NULL COMMENT 'null',
  `Bandera4` text DEFAULT NULL COMMENT 'null',
  `Bandera5` text DEFAULT NULL COMMENT 'null',
  `Bandera6` text DEFAULT NULL COMMENT 'null',
  `Bandera7` text DEFAULT NULL COMMENT 'null',
  `Bandera8` text DEFAULT NULL COMMENT 'null',
  `Bandera9` text DEFAULT NULL COMMENT 'null',
  `Bandera10` text DEFAULT NULL COMMENT 'null',
  `Contratable` text DEFAULT NULL COMMENT '是否维保合同',
  `Textil` text DEFAULT NULL,
  `SlowDisplace` text DEFAULT NULL,
  `Consignment` text DEFAULT NULL COMMENT '是否关联了改固定标签',
  `Hechoalamedida` text DEFAULT NULL COMMENT '根据division判断',
  `Color` text DEFAULT NULL COMMENT 'sku color销售属性',
  `SearsVerde` text DEFAULT NULL,
  `Hipotecaverde` text DEFAULT NULL,
  `Sustentable` text DEFAULT NULL COMMENT 'Fixed value N',
  `storeCode` text DEFAULT NULL COMMENT '门店编码',
  `storeGroupCode` text DEFAULT NULL COMMENT '门店组编码'
);

create index idx on `t_plupaq`(`LoyaltyProgramID1`);

