--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
#tags: optimizer
#tags: cost
#description:

--disable_warnings
drop table if exists a,b,c,d,pa,pb,pc;
--enable_warnings
Create table A(a1 int primary key, a2 int, a3 int,a4 int,a5 int,a6 int,a7 int,a8 int);
Create table B(b1 int primary key, b2 int, b3 int,b4 int,b5 int,b6 int,b7 int,b8 int);
Create table C(c1 int primary key, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int);
Create table D(d1 int primary key, d2 int, d3 int,d4 int,d5 int,d6 int,d7 int,d8 int);
Create table PA(a1 int primary key, a2 int, a3 int,a4 int,a5 int,a6 int,a7 int,a8 int) partition by key(a1) partitions 4;
Create table PB(b1 int primary key, b2 int, b3 int,b4 int,b5 int,b6 int,b7 int,b8 int) partition by key(b1) partitions 4;
Create table PC(c1 int, c2 int, c3 int,c4 int,c5 int,c6 int,c7 int,c8 int, primary key(c1,c2)) partition by key(c1,c2) partitions 5;

--disable_query_log
--let $i=1
while($i < 501)
{
  eval insert into A values($i,$i,$i,1,0,1,null,1001-$i);
  inc $i;
}
while($i < 1001)
{
  eval insert into A values($i,$i,$i,1,1,null,null,1001-$i);
  inc $i;
}
--let $i=1
while($i < 51)
{
  eval insert into B values($i,$i,$i,1,0,1,null,101-$i);
  inc $i;
}
while($i < 101)
{
  eval insert into B values($i,$i,$i,1,1,null,null,101-$i);
  inc $i;
}
--let $i=1
while($i < 11)
{
  eval insert into C values($i,$i,$i,1,0,1,null,11-$i);
  inc $i;
}
insert into D values(1,1,1,1,0,1,null,1);

--let $i=1
while($i < 17)
{
  eval insert into PA values($i,$i,$i,1,0,1,null,$i);
  inc $i;
}

--let $i=1
while($i < 17)
{
  eval insert into PB values($i,$i,$i,1,0,1,null,$i);
  inc $i;
}

--let $i=1
while($i < 21)
{
  eval insert into PC values($i,$i,$i,1,0,1,null,$i);
  inc $i;
}

