##bug:
--disable_query_log
--enable_query_log
--disable_warnings
drop table if exists T1,T2,T11;
--enable_warnings
create table T1(tenant_id int, table_id int, c1 int, primary key(tenant_id, table_id));
create table T2(tenant_id int, database_id int, c2 int, primary key (tenant_id, database_id)) partition by hash(tenant_id) partitions 16;
explain  select v2.c1 from  (select a.c1 as c1 from T1 a left join T2 b on a.tenant_id = b.tenant_id and a.table_id = b.database_id where a.tenant_id = 1) v1  inner join  (select a.c1 as c1 from T1 a left join T2 b on a.tenant_id = b.tenant_id and a.table_id = b.database_id where a.tenant_id = 1) v2;

create table T11(tenant_id int, table_id int, c1 int, primary key(tenant_id, table_id)) partition by hash(tenant_id) partitions 16;
explain  select v2.c1 from  (select a.c1 as c1 from T11 a left join T2 b on a.tenant_id = b.tenant_id and a.table_id = b.database_id where a.tenant_id = 1) v1  inner join  (select a.c1 as c1 from T11 a left join T2 b on a.tenant_id = b.tenant_id and a.table_id = b.database_id where a.tenant_id = 1) v2;

explain  select * from PA, A order by PA.a1 limit 10;
explain  select * from PA, PB order by PA.a1 limit 10;
