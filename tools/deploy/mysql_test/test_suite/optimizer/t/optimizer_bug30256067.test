#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: SQLancer bug, deduce wrong generated exprs for prefix index 

--disable_abort_on_error

--disable_warnings
drop table if exists t0, t1;
--enable_warnings

--disable_result_log
CREATE TABLE IF NOT EXISTS t0(c0 VARCHAR(500) )  PARTITION BY KEY (c0) partitions 14;
CREATE TABLE IF NOT EXISTS t1 LIKE t0;
UPDATE t1 SET c0="VGQt'<[liB+n";
CREATE UNIQUE INDEX i870 ON t1(c0(4)) global VISIBLE;
INSERT INTO t1(c0) VALUES('H');
CREATE INDEX i780 ON t0(c0(1)) global VISIBLE;
INSERT INTO t1(c0) VALUES('\\1g');
INSERT  INTO t0(c0) VALUES('LPKBH-KU65&3]+VS/PRWADHT'), ('CdB1Gmt'), ("INyF|C{85RQb}tT!S[rpd<r0GZz");
INSERT INTO t0(c0) VALUES("e!"), ("CY7Y,f4M");
CREATE INDEX i210 USING BTREE ON t0(c0(3)) global INVISIBLE;
UPDATE t1 SET c0='nOE';
INSERT INTO t0(c0) VALUES("vgqt'<[lib+n");
INSERT  INTO t1(c0) VALUES("NOE");
CREATE INDEX i180 ON t1(c0(3)) global;
UPDATE t1 SET c0='';
INSERT  INTO t1(c0) VALUES("Ve<MEI>[x%N/8J,~ScIcu");
INSERT  INTO t0(c0) VALUES('rPQ');
INSERT  INTO t0(c0) VALUES("R9f'0*eI#|4D9rtz"), ("H"), ('g'), (''), ('yb1'), ('rL2OuADo3}yT''''''58.JWiXac,a}'), ("inyf|c{85rqb}tt!s[rpd<r0gzz");
INSERT  INTO t0(c0) VALUES('a');
INSERT  INTO t0(c0) VALUES('R9f''0*eI#|4D9rtz');

--disable_query_log
select count(*) from t0;
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

## 以下两条SQL返回的结果集应该相同
SELECT /*+ TOPK (50 50)  */ t0.c0 AS ref0 FROM t0;

SELECT /*+ TOPK (50 50)  */ ALL t0.c0 AS ref0 FROM t0 WHERE (t0.c0) <= ('RL|*8SiBhf/Pa') 
UNION ALL
SELECT /*+ TOPK (50 50)  */ t0.c0 AS ref0 FROM t0 WHERE (! ((t0.c0) <= ('RL|*8SiBhf/Pa')))
UNION ALL
SELECT /*+ TOPK (50 50)  */ ALL t0.c0 AS ref0 FROM t0 WHERE ((t0.c0) <= ('RL|*8SiBhf/Pa')) IS NULL;

drop table if exists mail4;

--disable_warnings
DROP TABLE /*! IF EXISTS*/ table1_key_pk_parts_2; 
DROP TABLE /*! IF EXISTS*/ table30; 
--enable_warnings

CREATE TABLE table1_key_pk_parts_2 (
col_char_30 char(30),
col_char_20 char(20),
col_bigint_key bigint,
col_integer_key integer,
col_integer integer,
col_date_key date,
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_key char(20),
col_decimal_20_0 decimal(20,0),
col_char_30_key char(30),
col_timestamp_key timestamp NULL DEFAULT NULL,
col_datetime datetime,
col_smallint_key smallint,
col_int int,
col_datetime_key datetime,
col_varchar_10_key varchar(10),
col_varchar_10 varchar(10),
col_int_key int,
col_tinyint_key tinyint,
pk int,
col_mediumint_key mediumint,
col_tinyint tinyint,
col_decimal_20_0_key decimal(20,0),
col_decimal_30_5 decimal(30,5),
col_bigint bigint,
col_mediumint mediumint,
col_date date,
col_decimal_30_5_key decimal(30,5),
col_smallint smallint,
/*Indices*/
key idx11(col_bigint_key ),
key idx9(col_integer_key ),
key idx23(col_date_key ),
key idx17(col_char_20_key ),
key idx19(col_char_30_key ),
key idx27(col_timestamp_key ),
key idx3(col_smallint_key ),
key idx25(col_datetime_key ),
key idx21(col_varchar_10_key ),
key idx7(col_int_key ),
key idx1(col_tinyint_key ),
key idx5(col_mediumint_key ),
key idx13(col_decimal_20_0_key ),
key idx15(col_decimal_30_5_key ))    PARTITION BY key(pk) partitions 2 ; 


CREATE TABLE table30 (
col_decimal_20_0_key decimal(20,0),
col_int_key int,
col_char_30 char(30),
col_timestamp timestamp NULL DEFAULT NULL,
col_tinyint tinyint,
col_date_key date,
col_char_20 char(20),
col_mediumint_key mediumint,
col_date date,
col_tinyint_key tinyint,
col_varchar_10 varchar(10),
col_char_30_key char(30),
col_bigint_key bigint,
col_int int,
col_bigint bigint,
col_decimal_30_5 decimal(30,5),
col_integer_key integer,
pk int,
col_smallint smallint,
col_decimal_20_0 decimal(20,0),
col_varchar_10_key varchar(10),
col_timestamp_key timestamp NULL DEFAULT NULL,
col_mediumint mediumint,
col_decimal_30_5_key decimal(30,5),
col_datetime_key datetime,
col_smallint_key smallint,
col_datetime datetime,
col_integer integer,
col_char_20_key char(20),
/*Indices*/
key idx13(col_decimal_20_0_key ),
key idx7(col_int_key ),
key idx23(col_date_key ),
key idx5(col_mediumint_key ),
key idx1(col_tinyint_key ),
key idx19(col_char_30_key ),
key idx11(col_bigint_key ),
key idx9(col_integer_key ),
key idx21(col_varchar_10_key ),
key idx27(col_timestamp_key ),
key idx15(col_decimal_30_5_key ),
key idx25(col_datetime_key ),
key idx3(col_smallint_key ),
key idx17(col_char_20_key ))    ; 

SELECT  /*+ NO_REWRITE leading(a b) use_nl(b)*/  A.col_bigint_key, B.col_bigint_key FROM table1_key_pk_parts_2 A
LEFT OUTER JOIN table30 B ON A.col_bigint_key = B.col_bigint_key
WHERE A.col_bigint_key = B.col_bigint_key;

DROP TABLE /*! IF EXISTS*/ table1_key_pk_parts_2; 
DROP TABLE /*! IF EXISTS*/ table30; 

--disable_warnings
drop table if exists t1,t3;
--enable_warnings
create table t1 (c1 int, c2 int);
create table t3 (c1 int);
select * from t1 join t3 on t1.c2=t3.c1 and 2 = last_insert_id(2);