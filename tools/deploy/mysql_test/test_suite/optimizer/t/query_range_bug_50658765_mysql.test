--explain_protocol 2
select /*+index(t1 idx)*/ * from t1, t2 where t1.c3 = t2.c1 and (t1.c1 = 1 and t1.c2 like '1%') or (t1.c1, t1.c2) < (1,'2');
select /*+full(t1)*/ * from t1, t2 where t1.c3 = t2.c1 and (t1.c1 = 1 and t1.c2 like '1%') or (t1.c1, t1.c2) < (1,'2');
select /*+index(t1 idx)*/ * from t1, t2 where t1.c3 = t2.c1 and (t1.c1 = 1 and t1.c2 in ('1','2','3')) or (t1.c1, t1.c2) < (1,'2');
select /*+full(t1)*/ * from t1, t2 where t1.c3 = t2.c1 and (t1.c1 = 1 and t1.c2 in ('1','2','3')) or (t1.c1, t1.c2) < (1,'2');
