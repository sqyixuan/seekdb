--disable_warnings
drop table if exists `doc_audits`;
--enable_warnings
CREATE TABLE `doc_audits` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `doc_id` bigint(20) NOT NULL,
  `labels` varchar(500) DEFAULT NULL,
  `status` int(11) NOT NULL DEFAULT '0',
  `details` text DEFAULT NULL,
  `auditor_id` bigint(20) DEFAULT NULL,
  `audited_at` datetime DEFAULT NULL,
  `created_at` datetime DEFAULT NULL,
  `updated_at` datetime DEFAULT NULL,
  `type` varchar(50) NOT NULL DEFAULT 'Doc',
  `event_id` varchar(190) DEFAULT NULL,
  `target_field` varchar(128) DEFAULT NULL,
  `content_hash` varchar(255) DEFAULT NULL,
  `extra` text DEFAULT NULL,
  `source` tinyint(4) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_created_at` (`created_at`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_doc_id_type_target_field_created_at` (`doc_id`, `type`, `created_at`) BLOCK_SIZE 16384 GLOBAL
);
