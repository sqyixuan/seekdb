--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 varchar(32)) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int, c3 varchar(32)) partition by hash(c1) partitions 6;

--disable_query_log
--disable_result_log
insert into t1 values (1, 1, 'x');
insert into t1 values (2, 5, 'u');
insert into t1 values (3, 2, 'z');
insert into t1 values (4, 6, 'e');
insert into t1 values (5, 4, 'g');
insert into t1 values (6, 7, 'h');

insert into t2 values (1, 1, 'o');
insert into t2 values (2, 5, 'c');
insert into t2 values (3, 5, 'b');
insert into t2 values (4, 6, 'o');
insert into t2 values (5, 7, 'd');
insert into t2 values (6, 8, 'c');
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select * from (     select c1 a, case when exists(select 1 from t2 where t1.c1=t2.c1) then 4 else 5 end b from t1     union all     select c1,c2 from t1) v where b= 4;
