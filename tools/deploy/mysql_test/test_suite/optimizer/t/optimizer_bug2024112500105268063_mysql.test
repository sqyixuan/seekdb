--enable_query_log
#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(pk int primary key, c1 int, c2 int, c3 int, index i1(c1, c2));
insert into t1 select row_number() over (), uniform(0, 99, random(1)), uniform(0, 99, random(2)), uniform(0, 99, random(3)) from table(generator(10000));
call dbms_stats.gather_table_stats(null, 't1');

create table t2(pk int primary key, c1 int, c2 int, c3 int, index i1(c1,c2,c3));

create table t3(pk int primary key, c1 int, c2 int, c3 int) with column group (each column);
create index i1 on t3(c1,c2,c3) with column group (each column);
create index i2 on t3(c3,c2,c1) with column group (all columns);
insert into t3 select row_number() over (), uniform(0, 99, random(1)), uniform(0, 99, random(2)), uniform(0, 99, random(3)) from table(generator(10000));
call dbms_stats.gather_table_stats(null, 't3');

set _ENABLE_STORAGE_CARDINALITY_ESTIMATION = 0;
--explain_protocol 2
--result_format 4

# issue 2025010700106904875
select count(*) from t1 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0);
select count(*) from t1 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,(select /*+no_rewrite*/ 0 from dual));
select count(*) from t1 v1, t1 v2 where v1.pk < 40 and v1.c1 = v2.c1 and v2.c2 in (1,2,3,4,5,6,7,8,9,0);
select /*+use_nl(v1 v2)*/ count(*) from t1 v1, t1 v2 where v1.pk < 40 and v1.c1 = v2.c1 and v2.c2 in (1,2,3,4,5,6,7,8,9,0);

# issue 2025010900106952511
select /*+leading(v1 v2) use_nl(v2) index_ss(v2 i1) dynamic_sampling(1)*/ 1 from t2 v1, t2 v2 where v1.c1 = v2.c1 and v1.c3 = v2.c3;

# issue 2024112500105268063
select SQL_CALC_FOUND_ROWS * from t3 where c1 = 1 and c3 = 1 limit 0;
select /*+index(t3 i1)*/ SQL_CALC_FOUND_ROWS * from t3 where c1 = 1 and c3 = 1 limit 0; 
select /*+index(t3 i2)*/ SQL_CALC_FOUND_ROWS * from t3 where c1 = 1 and c3 = 1 limit 0; 

drop table t1,t2,t3;