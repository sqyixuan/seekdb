--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yibo.tyf
#owner group: sql1
# tags: optimizer
#bug 


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b int, c int, d int) partition by hash(a) partitions 4;
--disable_query_log
--let $count = 0
while($count < 100)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, $count, $count, $count)
  eval $stmt;
  inc $count;
}
--sleep 1
--enable_query_log
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');

--result_format 4
--explain_protocol 2
select * from (select * from t1 order by b) where a+b < 10 limit 10;
select * from (select * from t1 order by b) where a+b < 10 limit 2;
