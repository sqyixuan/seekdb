# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: optimizer
# description: 测试存储层 groupby 下压 + 含 ora_rowscn 过滤条件的 query

connect(conn_sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 1;

connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings

--explain_protocol 2
--result_format 4

create table t1 (c1 int, c2 int);
-- echo # group by 会下压到 table scan, 计划可以正常执行
select count(*), c1 from t1 where ora_rowscn > 1748210020567564005 and ora_rowscn <= 1748211303993768010 group by c1;

drop table t1;

connection conn_sys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 0, frequency = 0;