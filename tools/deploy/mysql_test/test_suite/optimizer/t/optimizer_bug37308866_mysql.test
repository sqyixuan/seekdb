# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;

--enable_warnings
create table t1(c1 int, c2 int);

--disable_query_log
--disable_result_log
insert into t1 values (1,1),(2,2);
select count(*) from t1;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

select (select /*+no_unnest*/ max(c1) from t1 where a.c1 = c1) sub from t1 a order by c1;
select (select /*+no_unnest*/ max(c1) from t1 where a.c1 = c1) sub from t1 a order by sub + c1;
select (select /*+no_unnest*/ max(c1) from t1 where a.c1 = c1) sub from t1 a group by sub, c1 order by sub + c1;
select (select /*+no_unnest*/ max(c1) from t1 where a.c1 = c1) sub, max(c2) mc2 from t1 a group by sub order by sub + mc2;

drop table t1;