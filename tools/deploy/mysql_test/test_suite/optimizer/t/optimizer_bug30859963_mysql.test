#owner: dachuan.sdc
#tags: optimizer
#owner group: sql2

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int , c2 int , c3 int) partition by hash(c1) partitions 4;

create table t2(c1 int , c2 int , c3 int) partition by hash(c1) partitions 6;

--disable_query_log
--disable_result_log
insert into t1 values(1, 2, 3), (2, 3 ,4);
insert into t2 values(1, 2, 3), (2, 3, 4);
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log

--result_format 4

explain basic select /*+no_rewrite*/ count(distinct v.c3) from (select distinct c3 from t1) v;
select /*+no_rewrite*/ count(distinct v.c3) from (select distinct c3 from t1) v;

