--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:link.zt
#owner group: sql1
# tags: optimizer
#bug 

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b int, c int, d int, index idx_b(b), index idx_b_c(b, c));

## all the data are in memory
--let $count = 0
while($count < 100)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 1, $count, 1)
  eval $stmt;
  inc $count;
}

--let $count = 100
while($count < 300)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 2, $count, 2)
  eval $stmt;
  inc $count;
}
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');
explain select/*+index(t1 primary)*/ * from t1 where a = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where a = 1;
explain select/*+index(t1 idx_b_c)*/ * from t1 where a = 1;
explain select * from t1 where a = 1;
explain select/*+index(t1 primary)*/ * from t1 where b = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 1;
explain select/*+index(t1 idx_b_c)*/ * from t1 where b = 1;
explain select * from t1 where b = 1;
explain select/*+index(t1 primary)*/ * from t1 where b = 2;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 2;
explain select/*+index(t1 idx_b_c)*/ * from t1 where b = 2;
explain select * from t1 where b = 2;
explain select/*+index(t1 primary)*/ * from t1 where b = 2 and c < 100;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 2 and c < 100;
explain select/*+index(t1 idx_b_c)*/ * from t1 where b = 2 and c < 100;
explain select * from t1 where b = 2 and c < 100;
explain select/*+index(t1 primary)*/ * from t1 where b = 2 and c > 100;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 2 and c > 100;
explain select/*+index(t1 idx_b_c)*/ * from t1 where b = 2 and c > 100;
explain select * from t1 where b = 2 and c > 100;
