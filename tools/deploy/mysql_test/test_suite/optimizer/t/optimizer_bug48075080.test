# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

CREATE TABLE `t1` (
  `c1` tinyint(4) NOT NULL primary key
) CHARSET = binary 
partition by list(c1)
(partition p0 values in (-123,-118,-104,-82,-71,-60,-58,-57,-49),
 partition p1 values in (-40,-17,-13,-11,19,27,33,51,89,91,93));

CREATE TABLE `t2` (
  `c1` int(10) unsigned DEFAULT '3793970761'
)CHARSET = binary
partition by list(c1)
(partition p0 values in (252738717,536323019,953293736,1022843821,1335158449,1419359738,1571454214,1715466322,1774937755),
 partition p1 values in (2016653363,2261616836,2712658913,2726525432,2800293888,2959302613,3000448072,3030821812,3307192546,3403145169,3857859775));

--explain_protocol 2
--result_format 3

explain (select c1 as r1 from t1) union all (select c1 as r1 from t2);

(select c1 as r1 from t1) union all (select c1 as r1 from t2);

drop table if exists t1, t2;
