# owner: dingjincheng.djc
#tags: optimizer
# owner group: SQL1

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1 (a int primary key, b int, c int);
create table t2 (a int , b int primary key, c int);
create table t3 (a int, b int , c int primary key);

--explain_protocol 2
select /*+ leading(t1 v) use_nl(v)*/ * from t1, (select /*+ no_merge */ t2.b, t3.c from t2,t3 where t2.c>t3.c) v  where t1.a < v.c and t1.b = v.b;

select /*+ use_plan_cache(none) */ a from t1 where EXISTS (select /*+ no_unnest */ a from t2 where  EXISTS (select /*+ no_unnest */ a from t3 where t1.a > t3.a and t2.b < t3.a) and t1.c = t2.a);

drop table t1;
drop table t2;
drop table t3;

