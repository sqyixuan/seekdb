# owner: zhanyue.zzy
# owner group: SQL1
#description: test das batch rescan cost
# tags: optimizer

--result_format 4
set ob_query_timeout = 1000000000;

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
let $saved_primary_zone=`select primary_zone from oceanbase.__all_tenant where tenant_name = 'sys'`;
alter tenant sys set primary_zone = 'RANDOM';
sleep 5;

connection default;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key, c2 int , c3 int, c4 int) partition by hash(c1) partitions 2;
insert into t1
with recursive cte as (select 1 as c1 union all select c1+1 from cte where c1 < 1000)
select c1, c1, c1 + 1, c1 from cte;

call dbms_stats.gather_table_stats('test', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);

--explain_protocol 2
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'false')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p0) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'true')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p0) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'false')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p1) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) use_das(b) opt_param('NLJ_BATCHING_ENABLED', 'true')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p1) b where a.c1 = b.c1) v;

select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) opt_param('NLJ_BATCHING_ENABLED', 'true')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p0) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) opt_param('NLJ_BATCHING_ENABLED', 'true')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p1) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) opt_param('NLJ_BATCHING_ENABLED', 'false')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p0) b where a.c1 = b.c1) v;
select count(*), sum(c1+c2+c3+c4) from (select /*+parallel(2) no_rewrite leading(a) use_nl(b) opt_param('NLJ_BATCHING_ENABLED', 'false')*/ a.c1, b.c2, a.c3, b.c4 from t1 partition (p0) a, t1 partition (p1) b where a.c1 = b.c1) v;


drop table if exists t1;

--disable_query_log
connection sys;
eval alter tenant sys set primary_zone = "$saved_primary_zone";
--enable_query_log
