--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
#description: 

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int, c3 int) partition by hash (c3) partitions 3;
--disable_query_log
--disable_result_log
select count(*) from t1;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
select /*+topk(0 10)*/ c2, count(c3) from t1 where c2 <12 group by c2 order by avg(c3) desc limit 5;
select /*+topk(0 10)*/ c2, count(c3) from t1 where c2 <12 group by c2 with rollup order by avg(c3) desc limit 5;

drop table t1;
