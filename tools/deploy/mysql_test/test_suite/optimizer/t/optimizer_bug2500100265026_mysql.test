# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--result_format 1
--explain_protocol 2

--disable_warnings

drop table if exists t1_dml;

--enable_warnings

create table t1_dml(
  c1 int,
  c2 int,
  c3 int,
  c4 int);

connect(sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
connection sys;
alter system set_tp tp_no = 553, error_code = 1, frequency = 1;
connection default;

select * from t1_dml;

connection sys;
alter system set_tp tp_no = 553, error_code = 1, frequency = 0;
