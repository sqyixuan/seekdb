--disable_warnings
drop table if exists t2, t14, t26;
--enable_warnings

create table t2 (c1 VARBINARY(59) ,c2 TIME,c3 DECIMAL(64,25) ,c4 INTEGER(127) ,c5 NUMERIC(64,8) ,c6 NUMERIC(64,13) ,c7 VARCHAR(86) ,c8 INTEGER(127) ,c9 TIME,c10 BIGINT(127)  auto_increment,c11 DATE, primary key(c1,c7))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ; create unique index g_u_0_qGbtKLNO on t2(c7,c6) global ; create unique index g_u_1_XBNIOMXe on t2(c7,c8,c4,c3) global ; create unique index g_u_2_XdlXCLlo on t2(c8,c5,c7,c6) global ; create unique index g_u_3_RLxI on t2(c10,c3,c4,c8) global ; create index g_i_1_VnlorUya on t2(c7,c5,c3) global ; create index i_2_CFCLnrS on t2(c1); create index g_i_3_HWU on t2(c3,c4) global ;

create table t14 (c1 INT(127)  auto_increment,c2 BINARY(63) ,c3 YEAR(4) ,c4 INT(127) ,c5 BIGINT(127) ,c6 INTEGER(127) ,c7 VARCHAR(86) ,c8 INT(127) ,c9 CHAR(152) ,c10 TIMESTAMP NOT NULL default 0,c11 DECIMAL(64,25) ,c12 DATE,c13 YEAR(4) ,c14 INTEGER(127) ,c15 BINARY(140) ,c16 INT(127) ,c17 DATE, primary key(c1,c4,c6,c15,c5,c8,c9))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY HASH(c1+c4) PARTITIONS 10;

create table t26 (c1 DATETIME,c2 BINARY(138) ,c3 TIME,c4 TIMESTAMP(2)  NOT NULL default 0,c5 DATE,c6 INT(127)  auto_increment,c7 TIMESTAMP(2)  NOT NULL default 0,c8 VARBINARY(53) ,c9 BIGINT(127) ,c10 BIGINT(127) ,c11 INTEGER(127) ,c12 DECIMAL(64,5) ,c13 CHAR(152) ,c14 TIME,c15 DECIMAL(64,9) ,c16 CHAR(152) ,c17 DATE,c18 DECIMAL(64,25) , primary key(c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c2) PARTITIONS 10; create unique index g_u_0_Tt on t26(c18,c10,c2,c13) global ; create unique index g_u_1_SGvBH on t26(c6,c8,c11,c2) global ; create unique index g_u_2_OI on t26(c6,c12,c8,c18) global ; create unique index g_u_3_qxqL on t26(c16,c12,c18,c6) global ; create index i_1_jqlWEkyEC on t26(c10,c6); create index i_2_OPfnnUoE on t26(c11,c13,c8);

--explain_protocol 1
--result_format 4

SELECT
    t26_49.c9 AS c1,
    t26_49.c15 AS c2,
    t26_49.c11 AS c3,
    t26_49.c13 AS c4,
    t26_49.c7 AS c5,
    t26_49.c16 AS c6
FROM t26 AS t26_49
WHERE t26_49.c13 LIKE '%baixian%'
UNION ALL 
(
    SELECT DISTINCT concat
    (
        t2_85.c10,
        t2_85.c1
    ),
    t14_323_1.c6,
    t14_323_1.c3,
    repeat
    (
        t2_85.c10,
        1
    ),
    1019,
    t2_85.c1
    FROM t2 AS t2_85 
    LEFT OUTER JOIN t14 AS t14_323_1 
    ON  t14_323_1.c14 = t14_323_1.c11
    WHERE t2_85.c2 < t2_85.c9
    ORDER BY 5,
    6,
    1 DESC,
    2 ASC,
    3,
    4 LIMIT 4944
);

drop table t2, t14, t26;
