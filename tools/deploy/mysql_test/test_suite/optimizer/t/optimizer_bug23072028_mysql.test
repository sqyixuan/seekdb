#owner: dachuan.sdc
#owner group: sql2
# tags:optimizer
# description:

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int,primary key(c1,c2)) partition by hash(c2) partitions 4;
create table t2(cc1 int, cc2 int, cc3 int,primary key(cc1,cc2)) partition by hash(cc2) partitions 4;
--disable_query_log
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t2 values(3,3,3);
insert into t2 values(4,4,4);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
## hash union/intersect/except distinct
select c3 from t1 union select cc2 from t2;
select c3 from t1 intersect select cc2 from t2;
select c3 from t1 minus select cc2 from t2;
## merge union all
select sum(c2),c1 from t1 group by c1 union all select sum(cc2),cc1 from t2 group by cc1;
## hash join
select /*+ pq_distribute(t1,hash,hash) */ c3, cc3 from t1,t2 where c3 = cc3;
