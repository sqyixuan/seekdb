--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
#bug:

--disable_warnings
drop table if exists t1, test45, test4;
--enable_warnings

 create table t1(c1 int, c2 int)partition by hash(c1) partitions 5; 
 create index i1 on t1(c2); 
 insert into t1 values(1,1);
 insert into t1 values(2,2);

CREATE TABLE `test45` (
  `c81` blob DEFAULT NULL
);

CREATE TABLE `test4` (
  `c80` float NOT NULL
)        
 partition by key(c80) 
(partition p0,
partition p1);

--result_format 4
--explain_protocol 3

delete /*+use_concat enable_parallel_dml parallel(2)*/ from t1 where c1 = 1 or c2 = 2;

insert into test45 values (
(select   /*+no_rewrite full(test4)*/ 1 from  test45 left join test4 on ( select   1 from  dual )  ));