#owner: guohanyun.ghy
#owner group: SQL1
#tag: optimizer, cross_validation

--disable_warnings
drop table if exists t1, t2, t3, t4;
drop view if exists vp, vn;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, key idx(c3, c1, c2) local) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int, c3 int) partition by hash(c2) partitions 4;
create table t3(c1 int, c2 int, c3 int, key idx(c1, c2, c3) local) partition by hash(c1) partitions 4;
create table t4(c1 int, c2 int, c3 int) partition by hash(c2) partitions 4;
insert into t1 values(1, 1, 1);
insert into t2 values(1, 1, 1);
insert into t3 values(2, 2, 2);
insert into t4 values(2, 2, 2);

create view vp as (select /*+ leading(t1 t2) use_nl(t2) use_das(t2) */ t1.* from t1, t2 where t1.c2 = t2.c1 order by t1.c3) union (select /*+ leading(t3 t4) use_das(t4) */ t3.* from t3, t4 where t3.c1 = t4.c2 order by t3.c3);
create view vn as (select t1.* from t1, t2 where t1.c2 = t2.c1 order by t1.c3) union (select t3.* from t3, t4 where t3.c1 = t4.c2 order by t3.c3);

# merge distinct
explain basic select distinct c3 from vp;
select distinct c3 from vp;
select distinct c3 from vn;

# merge group by
explain basic select count(*) from vp group by c3;
select count(*) from vp group by c3;
select count(*) from vn group by c3;

# merge set
explain basic (select /*+PQ_SET(@"SET$1"  HASH HASH)*/ * from (select /*+USE_MERGE(@"SEL$1") NO_MERGE*/ t31.c1 from t3 t31, t3 t32 where t31.c1 = t32.c1)) union (select t3.c1 from t3);
(select /*+PQ_SET(@"SET$1"  HASH HASH)*/ * from (select /*+USE_MERGE(@"SEL$1") NO_MERGE*/ t31.c1 from t3 t31, t3 t32 where t31.c1 = t32.c1)) union (select t3.c1 from t3);
(select * from (select t31.c1 from t3 t31, t3 t32 where t31.c1 = t32.c1)) union (select t3.c1 from t3);

drop table t1, t2, t3, t4;
drop view vp, vn;