# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings
 
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c3);
create index i4 on t1(c4);
create index i5 on t1(c5);
create index i6 on t1(c6);
create index i8 on t1(c1, c2);
create index i9 on t1(c1, c2, c3);
create index i10 on t1(c1, c2, c3, c4);
create index i11 on t1(c1, c2, c3, c4, c5);
create index i12 on t1(c1, c2, c3, c4, c5, c6);
 
insert into t1 values(1,1,1,1,1,1);
insert into t1 values(2,2,2,2,2,2);
insert into t1 values(3,3,3,3,3,3);
insert into t1 values(4,4,4,4,4,4);
insert into t1 values(5,5,5,5,5,5);
insert into t1 values(6,6,6,6,6,6);
insert into t1 values(7,7,7,7,7,7);
insert into t1 values(8,8,8,8,8,8);
insert into t1 values(9,9,9,9,9,9);

call dbms_stats.gather_table_stats(NULL, 't1');

--explain_protocol 2
--result_format 4

alter system set _optimizer_better_inlist_costing = 1;

select /*+ index(t1 i12) */ count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6,7)
and c3 in (3,4,5,6)
and c4 in (4,5,6,7,8,9,10)
and c5 in (5,6,7,8,9,10,11,12,13);
 
select /*+ index(t1 i12) */ count(*) from t1 
where (c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5)
and (c2 = 2 or c2 = 3 or c2 = 4 or c2 = 5 or c2 = 6 or c2 = 7)
and (c3 = 3 or c3 = 4 or c3 = 5 or c3 = 6)
and (c4 = 4 or c4 = 5 or c4 = 6 or c4 = 7 or c4 = 8 or c4 = 9 or c4 = 10)
and (c5 = 5 or c5 = 6 or c5 = 7 or c5 = 8 or c5 = 9 or c5 = 10 or c5 = 11 or c5 = 12 or c5 = 13);

explain outline select /*+ index(t1 i12) */ count(*) from t1 
where (c1 = 1 or c1 = 2 or c1 = 3 or c1 = 4 or c1 = 5)
and (c2 = 2 or c2 = 3 or c2 = 4 or c2 = 5 or c2 = 6 or c2 = 7)
and (c3 = 3 or c3 = 4 or c3 = 5 or c3 = 6)
and (c4 = 4 or c4 = 5 or c4 = 6 or c4 = 7 or c4 = 8 or c4 = 9 or c4 = 10)
and (c5 = 5 or c5 = 6 or c5 = 7 or c5 = 8 or c5 = 9 or c5 = 10 or c5 = 11 or c5 = 12 or c5 = 13);

alter system set _optimizer_better_inlist_costing = 0;
sleep 1;

drop table t1;