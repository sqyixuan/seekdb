--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists table2_bigint, table10_bigint, table100_bigint;
--enable_warnings
--disable_result_log
CREATE TABLE table2_bigint (
col_char_20 char(20),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
pk bigint,
col_bigint bigint,
col_decimal_20_0 decimal(20,0),
/*Indices*/
primary key (pk) ) ;
CREATE TABLE table10_bigint (
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
pk bigint,
col_char_20 char(20),
/*Indices*/
primary key (pk) ) ;
CREATE TABLE table100_bigint (
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_char_20 char(20),
pk bigint,
/*Indices*/
primary key (pk) ) ;

