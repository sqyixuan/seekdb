--enable_result_log
--enable_query_log


--result_format 4
--explain_protocol 2

SELECT pk
FROM table10_bigint
WHERE (col_decimal_20_0, pk) = ANY
    (SELECT col_decimal_20_0, col_bigint
     FROM table100_bigint
     WHERE (SELECT (SELECT col_bigint FROM table2_bigint order by col_bigint desc LIMIT 1)) <=> ROUND(col_decimal_20_0));

drop table table2_bigint, table10_bigint, table100_bigint;
