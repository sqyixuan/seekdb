--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: SQL3
# tags: optimizer, cross_validation

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 varchar(20), c2 varchar(4096), c3 varchar(8) ,KEY `idx_c1_c2_c3`(c1,c2(128),c3), KEY `idx_c2_c3`(c3,c2(100)));

--result_format 4

explain select /*+index(t2 idx_c1_c2_c3)*/* from t2 where c1='123' and c2='abc' and c3='456';
select * from t2 where c1='123' and c2='abc' and c3='456';

explain select /*+index(t2 idx_c2_c3)*/* from t2 where c1='123' and c2='abc' and c3='456';
select * from t2 where c1='123' and c2='abc' and c3='456';

drop table t2;
