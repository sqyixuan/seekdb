#owner: link.zt
#owner group: SQL1
#tag: optimizer

--disable_warnings
drop table if exists edf_dormancy_acct;
drop table if exists security_account;
--enable_warnings

CREATE TABLE `edf_dormancy_acct` (
    `SERIAL_NO` bigint(20) NOT NULL DEFAULT '0',
    `KHH` bigint(20) NOT NULL DEFAULT '0',
    `ZQZH` varchar(20) NOT NULL DEFAULT '',
    `YMTH` varchar(20) NOT NULL DEFAULT '',
    `DRRQ` int(11) NOT NULL DEFAULT '0',
    `QRRQ` int(11) NOT NULL DEFAULT '0',
    `MSG_CODE` int(11) NOT NULL DEFAULT '0',
    `MSG_TEXT` varchar(256) NOT NULL DEFAULT '',
    PRIMARY KEY (`KHH`, `ZQZH`)
    )
partition by range(KHH)
  (partition part_0 values less than (10),
   partition part_1 values less than (20),
   partition part_2 values less than (30),
   partition part_3 values less than (40),
   partition part_4 values less than (50),
   partition part_5 values less than (60));

INSERT INTO edf_dormancy_acct VALUES (10, 10, 'A', 'A', 10, 10, -1, 'A');
INSERT INTO edf_dormancy_acct VALUES (20, 20, 'B', 'B', 20, 20, -1, 'B');
INSERT INTO edf_dormancy_acct VALUES (30, 30, 'C', 'C', 30, 30, -1, 'C');
INSERT INTO edf_dormancy_acct VALUES (40, 40, 'D', 'D', 40, 40, -1, 'D');

CREATE TABLE `security_account` (
     `SECURITY_ACCOUNT_ID` varchar(20) NOT NULL,
     `CUSTOMER_ID` bigint(20) NOT NULL,
     `ID_SN` bigint(20) DEFAULT NULL,
     `INFO_SN` bigint(20) DEFAULT NULL,
     `ACCOUNT_ID` varchar(20) DEFAULT NULL,
     `CUSTOMER_TYPE` varchar(2) DEFAULT NULL,
     `EXCHANGE_ID` char(1) DEFAULT NULL,
     PRIMARY KEY (`CUSTOMER_ID`, `SECURITY_ACCOUNT_ID`)
     )
partition by range(CUSTOMER_ID)
  (partition part_0 values less than (10),
   partition part_1 values less than (20),
   partition part_2 values less than (30),
   partition part_3 values less than (40),
   partition part_4 values less than (50),
   partition part_5 values less than (60));

CREATE INDEX SECURITY_ACCOUNT_IDX2  ON security_account (ACCOUNT_ID) GLOBAL  BLOCK_SIZE 16384 partition by key(account_id) partitions 6;

INSERT INTO security_account values ('A', 10, 10, 10, 'A', 'A', 'A');
INSERT INTO security_account values ('B', 20, 20, 20, 'B', 'B', 'B');
INSERT INTO security_account values ('C', 30, 30, 30, 'C', 'C', 'C');
INSERT INTO security_account values ('D', 40, 40, 40, 'D', 'D', 'D');

EXPLAIN
UPDATE /*+no_use_px, index(B SECURITY_ACCOUNT_IDX2), use_nl(A B), leading(A, B)*/ EDF_DORMANCY_ACCT A   SET A.MSG_CODE = 31110049,A.MSG_TEXT = '证券账户所属客户号与申报客户号不一致'   WHERE KHH BETWEEN 0 AND 100    AND NOT EXISTS (  SELECT B.SECURITY_ACCOUNT_ID  FROM SECURITY_ACCOUNT B  WHERE A.khh = B.CUSTOMER_ID  and B.SECURITY_ACCOUNT_ID = A.ZQZH  AND B.ACCOUNT_ID = A.YMTH)   AND A.MSG_CODE = -1;

UPDATE /*+no_use_px, index(B SECURITY_ACCOUNT_IDX2), use_nl(A B), leading(A, B)*/ EDF_DORMANCY_ACCT A   SET A.MSG_CODE = 31110049,A.MSG_TEXT = '证券账户所属客户号与申报客户号不一致'   WHERE KHH BETWEEN 0 AND 100    AND NOT EXISTS (  SELECT B.SECURITY_ACCOUNT_ID  FROM SECURITY_ACCOUNT B  WHERE A.khh = B.CUSTOMER_ID  and B.SECURITY_ACCOUNT_ID = A.ZQZH  AND B.ACCOUNT_ID = A.YMTH)   AND A.MSG_CODE = -1;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int,c2 int)partition by hash(c1) partitions 8;
select * from t1 where c1=1 and c1=2 and c1=3;
begin;
select * from t1 where c1=1 and c1=2 and c1=3;
select * from t1 where c1=4 and c1=5 and c1=6;
rollback;

drop table if exists t1;