--disable_warnings
DROP TABLE IF EXISTS `cc`;
DROP TABLE IF EXISTS `c`;
--enable_warnings

CREATE TABLE `cc` (
  `col_datetime_key` datetime DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_date` date DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx9` (`pk`, `col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`pk`, `col_date_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `c` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_date` date DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_date_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx9` (`pk`, `col_datetime_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

insert into c values ('english','ypsi','2001-06-27','english','2009-12-27 22:01:30',1,'2002-08-28','2007-12-25 19:05:07',NULL,-1520828416,'english');

insert into c values ('mypsixog','english','2006-09-11','imy','2008-02-02 17:21:36',2,'2009-08-07','2005-01-10 14:04:07',NULL,NULL,'ri');

--result_format 4
--explain_protocol 2

select
  /*+ NO_EXPAND */
  distinct `OUTR`.`col_int` AS `X`
from
  `test`.`c` `OUTR`
where
  (
    exists(
      (
        select
          1
        from
          `test`.`cc` `INNR2`,
          `test`.`cc` `INNR`
        where
          (
            `INNR`.`col_int` = `OUTR`.`col_int`
          )
          and (`INNR`.`col_int` = `OUTR`.`pk`)
          and (`OUTR`.`col_int` = `OUTR`.`pk`)
          and (
            `INNR2`.`pk` <> `INNR`.`col_int_key`
          )
        limit
          1
      )
    )
    or (`OUTR`.`col_varchar_10` <> 'i')
  );

DROP TABLE IF EXISTS `cc`;
DROP TABLE IF EXISTS `c`;