--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
# tags: optimizer
#description: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
--disable_query_log
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(8,8,8),(9,9,9),(10,10,10);
insert into t2 values (1,1,1),(2,2,2),(6,6,6),(7,7,7),(8,8,8);
--enable_query_log

--result_format 4
--explain_protocol 2
select count(distinct a) from t1 partition(p0);
select /*+parallel(4)*/ count(distinct a) from t1 partition(p0);

--sorted_result
select distinct a from t1 partition(p0);
--sorted_result
select /*+parallel(4)*/ distinct a from t1 partition(p0);

select count(*) from t1 partition(p0), t2 partition(p0) where t1.a = t2.a;
select /*+parallel(4)*/ count(*) from t1 partition(p0), t2 partition(p0) where t1.a = t2.a;
