# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings


CREATE TABLE t1 (
  `c1` bigint(20) NOT NULL,
  `c2` varchar(100) DEFAULT NULL,
  `c3` varchar(100) DEFAULT NULL,
  `c4` datetime DEFAULT NULL,
  `c5` bigint(20) DEFAULT NULL,
  PRIMARY KEY (`c1`),
  KEY `i1` (`c2`) BLOCK_SIZE 16384 LOCAL
)
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);

call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', '50000');

set @a = 0;
insert /*+ query_timeout(100000000000) */  into t1 select @a := @a + 1, concat('ANY_', @a), concat('ROW_', @a), '2023-09-22 09:20:00', @a from table(generator(200000));

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;

call dbms_stats.GATHER_DATABASE_STATS_JOB_PROC(1000000000);

connection conn_admin;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;

call dbms_stats.set_global_prefs('AUTO_SAMPLE_ROW_COUNT', '5000000');
--result_format 4

--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position, object_type, num_rows, avg_row_len, sample_size FROM oceanbase.DBA_TAB_STATISTICS WHERE table_name='t1';

drop table if exists t1;

