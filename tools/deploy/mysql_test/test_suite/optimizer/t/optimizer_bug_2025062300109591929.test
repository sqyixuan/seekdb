#owner: guohanyun.ghy
#owner group: SQL1
#tag: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE `t1` (
    `pk` bigint(20) NOT NULL,
    PRIMARY KEY (`pk`)
) partition by hash(mod(pk, 4)) (partition `p0`, partition `p1`, partition `p2`);

select pk
from t1
where (
        pk % 10 in (0 | 1)
        or pk % 5 not in (0, 2, 3)
    );

select
    /*+groupby_push_down_case1.yaml ENABLE_PARALLEL_DAS_DML ENABLE_PARALLEL_DML parallel(2) */
    pk
from t1 A
where exists(
        select pk
        from (
                select
                    /*+groupby_push_down_case1.yaml use_hash_aggregation ENABLE_PARALLEL_DAS_DML ENABLE_PARALLEL_DML parallel(2) */
                    pk
                from t1
                where (
                        1 = 1
                        and pk % 10 in (0 | 1)
                        or pk % 5 not in (0, 2, 3)
                    )
                group by pk
                order by pk desc
            ) B
        where A.pk <> B.pk
    )
order by 1;

drop table t1;