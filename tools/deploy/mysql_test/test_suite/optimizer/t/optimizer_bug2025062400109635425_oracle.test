# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

--disable_warnings
--error 0,942
drop table t1;
--error 0,942
drop table t2;
--error 0,942
drop table t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t3(c1 int, c2 int, c3 int);

insert into t1 values (1,1,1),(2,2,2),(3,3,3);
insert into t2 values (1,2,3),(2,3,4),(3,4,5),(4,5,6);
insert into t3 values (1,1,1),(2,2,2),(3,3,3);

set autocommit = false;

--result_format 4
--explain_protocol 0

explain basic merge into t1 using (select * from t2 where c1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2;
merge into t1 using (select * from t2 where c1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2;
select * from t1;
rollback;
merge into t1 using (select * from t2 where c1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 partition (p0) using (select * from t2 partition (p0)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3;
merge into t1 partition (p0) using (select * from t2 partition (p0)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3;
select * from t1;
rollback;
merge into t1 partition (p0) using (select * from t2 partition (p0)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c1 = t2.c1) when matched then update set c3 = t2.c3 where 1 = 1;
merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c1 = t2.c1) when matched then update set c3 = t2.c3 where 1 = 1;
select * from t1;
rollback;
merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c1 = t2.c1) when matched then update set c3 = t2.c3 where 1 = 1;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where 1 = 1;
merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where 1 = 1;
select * from t1;
rollback;
merge into t1 using (select * from t2 where 1 = 1) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where 1 = 1;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c3, t2.c2, t2.c1);
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c3, t2.c2, t2.c1);
select * from t1;
rollback;
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c3, t2.c2, t2.c1);
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c1, t2.c2, t2.c3);
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c1, t2.c2, t2.c3);
select * from t1;
rollback;
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 when not matched then insert values (t2.c1, t2.c2, t2.c3);
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 delete where t1.c3 <= 3;
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 delete where t1.c3 <= 3;
select * from t1;
rollback;
merge into t1 using (select * from t2 partition (p1)) t2 on (t1.c2 = t2.c2) when matched then update set c3 = t2.c3 where t1.c1 = 2 delete where t1.c3 <= 3;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';
rollback;

explain basic merge /*+PQ_DISTRIBUTE(T1 PARTITION NONE) LEADING(T2 T1) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = t2.c2) when matched then update set c3 = t2.c3;
merge /*+PQ_DISTRIBUTE(T1 PARTITION NONE) LEADING(T2 T1) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = t2.c2) when matched then update set c3 = t2.c3;
select * from t1;
rollback;

explain basic merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T3 T2) NO_USE_DISTRIBUTED_DML FULL(t3)*/ into t3 using t2 on (t3.c2 = t2.c1) when matched then update set c3 = t2.c3;
merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T3 T2) NO_USE_DISTRIBUTED_DML FULL(t3)*/ into t3 using t2 on (t3.c2 = t2.c1) when matched then update set c3 = t2.c3;
select * from t3;
rollback;

explain basic merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T1 T2) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = 1 and t1.c2 = t2.c1) when matched then update set c3 = t2.c3;
merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T1 T2) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = 1 and t1.c2 = t2.c1) when matched then update set c3 = t2.c3;
select * from t1;
rollback;

explain basic merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T1 T2) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = 1 and t1.c2 = t2.c1) when not matched then insert values (1,t2.c2,t2.c3);
merge /*+PQ_DISTRIBUTE(T2 PARTITION NONE) LEADING(T1 T2) NO_USE_DISTRIBUTED_DML*/ into t1 using t2 on (t1.c1 = 1 and t1.c2 = t2.c1) when not matched then insert values (1,t2.c2,t2.c3);
select * from t1;
rollback;

drop table t1;
drop table t2;
drop table t3;

create global temporary table t1(c1 int, c2 int, c3 int) ON COMMIT PRESERVE ROWS;
create global temporary table t2(c1 int, c2 int, c3 int) ON COMMIT PRESERVE ROWS;
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4);
insert into t2 values (1,2,3),(2,3,4),(3,4,5),(5,6,7);

--replace_regex /[0-9]{15}/sessionid/g /partitions\(p[0-9]*\)/partition/g
explain basic merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set T1.c2 = t2.c2;

merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set T1.c2 = t2.c2;
select * from t1;
rollback;

merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set T1.c2 = t2.c2;
select is_hit_plan from sys.gv$ob_sql_audit where trace_id = last_trace_id() and query_sql like 'merge into%';

drop table t1;
drop table t2;