--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: wuyuming.wym
# owner group: sql
# tags: optimizer
# description: test _enable_storage_cardinality_estimation_hint
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (oracle,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);

connection sys;
alter system set_tp tp_no = 551, error_code = 5434, frequency = 0;
--result_format 4
--disable_warnings
drop table if exists test;
--enable_warnings

create table test (c1 int auto_increment, c2 int,c3 int ,unique key p1(c2,c1), unique key p2(c2,c3)) partition by hash(c2) partitions 3;
--disable_result_log
insert ignore into test (c2, c3) select abs(random(3))%100,abs(random(5))%100 from table(generator(1000));
--enable_result_log
select count(1) from test where c2=11;


--echo ------------------close dynamic sampling------------------
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;

--echo ------------------test sys_var _enable_storage_cardinality_estimation------------------

--echo ------------------test single table
set _enable_storage_cardinality_estimation = 1;
show variables like "%storage_cardinality_estimation%";
explain select * from test where c2=11;

set _enable_storage_cardinality_estimation = 0;
show variables like "%storage_cardinality_estimation%";
explain select * from test where c2=11;

select count(1) from test where c2=11;

--echo ------------------test partition
set _enable_storage_cardinality_estimation = 1;
show variables like "%storage_cardinality_estimation%";
explain select  * from test partition(p1)  where c2=11;

set _enable_storage_cardinality_estimation = 0;
show variables like "%storage_cardinality_estimation%";
explain select  * from test partition(p1)  where c2=11;

select count(1) from test partition(p1)  where c2=11;

--echo ------------------test join
set _enable_storage_cardinality_estimation = 1;
show variables like "%storage_cardinality_estimation%";
explain select * from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

set _enable_storage_cardinality_estimation = 0;
show variables like "%storage_cardinality_estimation%";
explain select * from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

select count(1) from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

--echo ------------------test generated table
set _enable_storage_cardinality_estimation = 1;
show variables like "%storage_cardinality_estimation%";
explain select /*+NO_REWRITE*/ distinct c1 from (select c1 from test where c2=11) order by c1 limit 10 ;

set _enable_storage_cardinality_estimation = 0;
show variables like "%storage_cardinality_estimation%";
explain select /*+NO_REWRITE*/ distinct c1 from (select c1 from test where c2=11) order by c1 limit 10 ;

select count(distinct c1) from (select c1 from test where c2=11) order by c1 limit 10 ;

--echo ------------------test opt_param_hint:_enable_storage_cardinality_estimation------------------
set optimizer_dynamic_sampling = 0;
set _enable_storage_cardinality_estimation = 0;
show variables like 'optimizer_dynamic_sampling';
show variables like "%storage_cardinality_estimation%";

--echo ------------------test single table
explain select /*+opt_param('_enable_storage_cardinality_estimation','true')*/ * from test where c2=11;

explain select /*+opt_param('_enable_storage_cardinality_estimation','false')*/ * from test where c2=11;

select count(1) from test where c2=11;

--echo ------------------test partition

explain select /*+opt_param('_enable_storage_cardinality_estimation','true')*/ * from test partition(p1)  where c2=11;

explain select /*+opt_param('_enable_storage_cardinality_estimation','false')*/ * from test partition(p1)  where c2=11;

select count(1) from test partition(p1)  where c2=11;

--echo ------------------test join

explain select /*+opt_param('_enable_storage_cardinality_estimation','true')*/ * from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

explain select /*+opt_param('_enable_storage_cardinality_estimation','false')*/ * from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

select count(1) from test a,test b where a.c2=11 and b.c2=11 and a.c1=b.c3;

--echo ------------------test generated table

explain select /*+opt_param('_enable_storage_cardinality_estimation','true')*/  distinct c1 from (select c1 from test where c2=11) a order by c1 limit 10 ;

explain select /*+opt_param('_enable_storage_cardinality_estimation','false')*/  distinct c1 from (select c1 from test where c2=11) a order by c1 limit 10 ;

select count(distinct c1) from (select c1 from test where c2=11) order by c1 limit 10 ;

drop table test;