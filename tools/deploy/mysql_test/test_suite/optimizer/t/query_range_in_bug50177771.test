--echo issue: 
--disable_warnings
drop table if exists t1;
--enable_warnings
--explain_protocol 0
--result_format 4
create table t1(c1 int, c2 int, c3 int);
create index idx on t1(c1,c2);
insert into t1 values(1,2,3),(1,3,4),(1,4,5),(1,5,6);
set @@ob_enable_plan_cache = 0;

--explain_protocol 2
select /*+index(t1 idx)*/ * from t1 where c1 in (1,1,1,1,1) and c2 > 2;
select /*+full(t1)*/ * from t1 where c1 in (1,1,1,1,1) and c2 > 2;
--explain_protocol 0

set @@ob_enable_plan_cache = 1;
--disable_warnings
drop table if exists t1;
--enable_warnings
