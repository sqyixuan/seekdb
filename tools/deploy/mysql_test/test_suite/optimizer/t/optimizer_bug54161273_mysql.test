#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop procedure if exists proc1;
--enable_warnings

create table t1 (c1 int primary key, c2 varchar(200), c3 varchar(200), c4 datetime, c5 datetime);

delimiter $$;
create procedure proc1(in args int)
begin
  declare i int;
  set i = 0;
  start transaction;
  while i < args do
    insert into t1(c1,c2,c3,c4,c5) values(i, concat('C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_', i), concat('C3_MKKHJHHS_XXXMMMMMMJJJDSHH_', i), '2020-01-20 10:01:00', '2020-01-20 10:01:00');
    set i = i+1;
	if i % 10000 = 0 then
	  commit;
	end if;
  end while;
  commit;
end $$
delimiter ;$$

call proc1(10000);

call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'FOR ALL COLUMNS SIZE 64');
let $table_id = query_get_value(select table_id from oceanbase.__all_table where table_name = 'T1', table_id, 1);
let $tenant_id = query_get_value(select effective_tenant_id() as tenant_id, tenant_id, 1);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_query_log
eval delete from oceanbase.__all_histogram_stat where table_id = $table_id;
--enable_query_log

connection default;

--result_format 4
--explain_protocol 2

select * from t1 where c2 = 'C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_1';

--disable_warnings
drop table if exists t1;
drop procedure if exists proc1;
--enable_warnings

