select /*+ index(t1 idx11) */ pk from table10_key_pk_parts_10_int_not_null as t1 
where (t1.col_varchar_20_unique_index,t1.col_varchar_20_unique_index) = ('ra','a') 
  or (t1.col_varchar_20_unique_index,t1.col_varchar_20_unique_index,t1.col_varchar_20_index) <= ('r','nr','k') and t1.col_varchar_20_unique_index NOT IN ('az','f');

select /*+ use_nl(t1 t2) leading(t1 t2) index(t1 idx11) */ * from table10_key_pk_parts_10_int_not_null as t1, table10_key_pk_parts_10_int_not_null as t2
where t1.col_varchar_20_index < t2.col_varchar_20_unique_index 
  and (t1.col_varchar_20,t1.col_varchar_20_unique_index,t1.col_varchar_20,t1.col_varchar_20_unique_index) = ('w','ra','p','a') 
   or (t1.col_varchar_20_unique_index,t1.col_varchar_20_unique_index,t1.col_varchar_20_index) <= ('r','nr','k') and t1.col_varchar_20_unique_index NOT IN ('z','zn','o','d','p','az','g','g','f','f')
