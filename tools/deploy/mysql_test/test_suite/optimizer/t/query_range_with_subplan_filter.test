select * from t1 left join t2 on t1.c1=t2.c1 where t1.c2 > exists(select /*+no_unnest*/c3 from t3) and t1.c3 = 3;
select * from t1 left join t2 on t1.c1=t2.c1 where t1.c3 > exists(select /*+no_unnest*/c3 from t3) and t1.c2 = 3;

select * from t1 right join t2 on t1.c1=t2.c1 where cast(t1.c2 as number) > exists(select /*+no_unnest*/c3 from t3) and t1.c3 = 4;
