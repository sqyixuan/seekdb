--explain_protocol 3

SELECT /*+use_nl(t1,t2)*/t1.c0 AS ref0 
FROM   t1, t2 
WHERE  t1.c0  IN ( EXISTS (SELECT 1), (EXISTS ( SELECT 1)) <= t2.c0 );

