--disable_warnings
drop table if exists t1,t2;
--enable_warnings

CREATE TABLE t1(c0 SMALLINT  PRIMARY KEY) ;
CREATE TABLE t2(c0 SMALLINT  PRIMARY KEY) ;

--explain_protocol 0
--disable_query_log
--disable_result_log
INSERT  INTO t1(c0) VALUES(0),(1),(-1);
INSERT  INTO t2(c0) VALUES(0),(1),(-1);
