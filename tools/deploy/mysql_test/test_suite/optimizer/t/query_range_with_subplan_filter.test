CREATE TABLE t0(c0 FLOAT  )  PARTITION BY KEY (c0) partitions 18;
CREATE TABLE IF NOT EXISTS t1 LIKE t0;

--explain_protocol 0
--disable_query_log
--disable_result_log
INSERT  INTO t0(c0) VALUES(0.0);
INSERT  INTO t1(c0) VALUES(-0.0);
select count(*) from t0;
select count(*) from t1;
--enable_query_log
--enable_result_log
--explain_protocol 2

SELECT /*+ TOPK (50 50)  */ t1.c0 AS ref0 FROM t1, t0 WHERE (! ((CAST((CAST(CAST(( EXISTS (SELECT 1)) IS FALSE AS SIGNED) AS SIGNED)) < ((t0.c0) AND (t0.c0)) AS SIGNED)) < (t1.c0)));


