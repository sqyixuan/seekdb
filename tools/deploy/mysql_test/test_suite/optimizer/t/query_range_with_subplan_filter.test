# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

# init env

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int primary key, c2 int, c3 int, c4 int);
create table t3(c1 int primary key, c2 int, c3 int, c4 int);
create table t4(c1 int primary key, c2 int, c3 int, c4 int);

create unique index i1 on t1(c2,c3);
create index i2 on t1(c3,c2);
create index i3 on t1(c4);
create index i4 on t3(c2,c3,c4);
create index i5 on t3(c3);

--disable_query_log
insert into t1 values (1, 1, 1, 1);
insert into t1 values (2, 2, 2, 2);
insert into t1 values (3, 3, 3, 3);
insert into t1 values (4, 4, 4, 4);
insert into t1 values (5, 5, 5, 5);

insert into t2 values (1, 1, 1, 1);
insert into t2 values (2, 2, 2, 2);
insert into t2 values (3, 3, 3, 3);
insert into t2 values (4, 4, 4, 4);
insert into t2 values (5, 5, 5, 5);

insert into t3 values (1, 1, 1, 1);
insert into t3 values (2, 2, 2, 2);
insert into t3 values (3, 3, 3, 3);
insert into t3 values (4, 4, 4, 4);
insert into t3 values (5, 5, 5, 5);

insert into t4 values (1, 1, 1, 1);
insert into t4 values (2, 2, 2, 2);
insert into t4 values (3, 3, 3, 3);
insert into t4 values (4, 4, 4, 4);
insert into t4 values (5, 5, 5, 5);

select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
--enable_query_log

--result_format 4
--explain_protocol 3
--enable_sorted_result
set autocommit = 0;

##基础条件
##单表的subplan filter,没有索引
select * from t2 where c2 = (select c3 from t3 limit 1);
select * from t2 where c2 = (select /*+no_unnest*/max(c2) from t3);
select * from t2 where c2 = (select t2.c2 as c from t2 t having c2 >= (select c from t2 limit 1) limit 1);
select * from t2 where c2 = any(select /*+no_unnest*/ c3 from t3);
select * from t2 where c2 > exists(select /*+no_unnest*/c3 from t3);
select * from (select /*+no_merge*/* from t2) where c2 = (select c3 from t3 limit 1);

##单表的subplan filter,有索引
select * from t1 where c2 = (select c3 from t3 limit 1) and c3 = 1;
select * from t1 where c3 = (select c3 from t3 limit 1) and c2 = 1;

select * from t1 where c2 = (select /*+no_unnest*/max(c2) from t3) and c3 = 5;
select * from t1 where c3 = (select /*+no_unnest*/max(c2) from t3) and c2 = 5;

select * from t1 where c2 = (select t1.c2 as c from t1 t where c2 = (select t1.c1 from t2 limit 1) and c3 = 1 limit 1);
select * from t1 where c2 = (select t1.c2 as c from t1 t where c3 = (select t1.c1 from t2 limit 1) and c2 = 1 limit 1);

select * from t1 where c2 = any(select /*+no_unnest*/c3 from t3) and c3 = 1;
select * from t1 where c3 = any(select /*+no_unnest*/c3 from t3) and c2 = 1;

select * from t1 where c2 > exists(select /*+no_unnest*/c3 from t3) and c3 = 3;
select * from t1 where c3 > exists(select /*+no_unnest*/c3 from t3) and c2 = 3;

##单表的subplan filter, filter after indexback
select * from t1 where c2 = (select c3 from t3 limit 1);
select * from t1 where c2 = (select /*+no_unnest*/max(c2) from t3);
select * from t1 where c2 = (select t1.c2 as c from t1 t where c2 = (select t1.c1 from t2 limit 1) limit 1);
select * from t1 where c2 = any(select /*+no_unnest*/c3 from t3);
select * from t1 where c2 > exists(select /*+no_unnest*/c3 from t3);

##单表的subplan filter, 主键
select * from t1 where c1 = (select c3 from t3 limit 1);
select * from t1 where c1 = (select /*+no_unnest*/max(c2) from t3);
select * from t1 where c1 = (select t1.c2 as c from t1 t where c2 = (select t1.c1 from t2 limit 1) limit 1);
select * from t1 where c1 = any(select /*+no_unnest*/c3 from t3);
select * from t1 where c1 > exists(select /*+no_unnest*/c3 from t3);

##OUTER JOIN的subplan filter,没有索引
select * from t2 left join t1 on t1.c1=t2.c1 where t2.c2 = (select c3 from t3 limit 1);
select * from t2 right join t1 on t1.c1=t2.c1 where cast(t2.c2 as number) = (select c3 from t3 limit 1);

select * from t2 left join t1 on t1.c1=t2.c1 where t2.c2 = (select /*+no_unnest*/max(c2) from t3);
select * from t2 right join t1 on t1.c1=t2.c1 where cast(t2.c2 as number) = (select /*+no_unnest*/max(c2) from t3);

select * from t2 left join t1 on t1.c1=t2.c1 where t2.c2 = (select t2.c2 as c from t2 t having t2.c2 >= (select c from t2 limit 1) limit 1);
select * from t2 right join t1 on t1.c1=t2.c1 where cast(t2.c2 as number) = (select t2.c2 as c from t2 t having t2.c2 >= (select c from t2 limit 1) limit 1);

select * from t2 left join t1 on t1.c1=t2.c1 where t2.c2 = any(select /*+no_unnest*/ c3 from t3);
select * from t2 right join t1 on t1.c1=t2.c1 where cast(t2.c2 as number) = any(select /*+no_unnest*/ c3 from t3);

select * from t2 left join t1 on t1.c1=t2.c1 where t2.c2 > exists(select /*+no_unnest*/c3 from t3);
select * from t2 right join t1 on t1.c1=t2.c1 where cast(t2.c2 as number) > exists(select /*+no_unnest*/c3 from t3);

