select * from t1 inner join t2 on t1.c1=t2.c1, t3 where t1.c2+t2.c2 > exists(select /*+no_unnest*/c3 from t3) and t1.c2 = 2;

##复杂表达式
select * from t1 where c2 between (select c3 from t3 limit 1) and (select c3 from t3 limit 1) and c3 = 1;

select * from t1, t2 where t1.c1 = t2.c1 and t1.c2 between (select c3 from t3 limit 1) and (select c3 from t3 limit 1) and t1.c3 = 1;

select c3,c2 from t2 group by c3,c2 having c2 between (select c3 from t3 limit 1) and (select c3 from t3 limit 1) and c3 = 1;

select * from t1 where c2 = case when (select c3 from t3 limit 1) = 1 then 2 else (select c3 from t3 limit 1) end and c3 = 2;

select * from t1 left join t2 on t1.c1=t2.c1 where exists( select null from t3 left join t4 on t3.c1=t4.c1 where exists(select null from t3 A left join t4 B on A.c1=B.c1 where t1.c1=B.c1));
set autocommit = 1;

## bug: 
drop table t1, t2;
create table t2(c0 int, c1 int);
CREATE TABLE t1(c0 SMALLINT ZEROFILL, c1 INT(41) , c2 DECIMAL );

--explain_protocol 0
--disable_query_log
--disable_result_log
INSERT  INTO t1(c1) VALUES(1), (0);
CREATE UNIQUE INDEX i1 ON t1(c1);
select count(*) from t1;
--enable_query_log
--enable_result_log
--explain_protocol 2

SELECT /*+  parallel(10)  */ t2.c0 AS ref0 
FROM t2 
WHERE  false
UNION ALL 
SELECT /*+ parallel(10)  */ t1.c0 AS ref0 
FROM    
       t1 
WHERE  ( ( (( +( EXISTS (SELECT 1 
                             FROM   DUAL 
                             WHERE  false) ) )) = ( t1.c1 ) ) ) ;

# clean env
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

## bug: 
--disable_warnings
drop table if exists A;
--enable_warnings

create table A(col_int int, col_int_key int);

--disable_query_log
--disable_result_log
--explain_protocol 0
insert into A values(1,1);
insert into A values(2,2);
insert into A values(3,3);
insert into A values(4,4);
select count(*) from A;
--explain_protocol 2
--enable_result_log
--enable_query_log

SELECT *
FROM   (a AS table1, a AS table2) 
WHERE  ((1, 1) NOT IN (SELECT 1 , 1))
        OR     (table1 . `col_int` = table2 . `col_int_key` 
            AND    EXISTS (SELECT 1));

SELECT table1.*
FROM   (a AS table1, a AS table2) 
WHERE  ((1, 1) NOT IN (SELECT 1 , 1))
        OR     (table2 . `col_int` = table2 . `col_int_key` 
            AND    EXISTS (SELECT 1));

SELECT *
FROM   (a AS table1, a AS table2) 
WHERE  ((1, 1) NOT IN (SELECT 1 , 1))
        OR     (1=1
            AND    EXISTS (SELECT 1));

--disable_warnings
drop table if exists A;
