# BUG T12618250
create table t1(pk int, col_char_20_index char(20) DEFAULT NULL,KEY `idx11` (`col_char_20_index`));
insert into t1(pk) values(1),(2);
SELECT * FROM t1 WHERE col_char_20_index LIKE 'a' having col_char_20_index='a';

# BUG 23278614
--disable_warnings
drop table if exists fin_trans_order_41;
--enable_warnings
CREATE TABLE `fin_trans_order_41` (
    `order_id` varchar(64) NOT NULL COMMENT '订单ID',
    `user_id` varchar(16) NOT NULL COMMENT '用户ID',
    `order_type` varchar(64) NOT NULL COMMENT '订单类型',
    `apply_time` timestamp NOT NULL COMMENT '申请时间',
    `order_status` varchar(16) NOT NULL COMMENT '订单状态',
    PRIMARY KEY (`order_id`),
    KEY `idx_fin_trans_order_ooa` (`order_type`, `order_status`, `apply_time`) BLOCK_SIZE 16384
    );

explain extended_noaddr
select /*+index(fin_trans_order_41  idx_fin_trans_order_ooa), no_expand*/ count(*)
  from fin_trans_order_41
  where user_id= '2088112078201419'
  and(apply_time< '2019-10-21 22:02:52'or
      (apply_time= '2019-10-21 22:02:52' and order_id< '2019102200903000020000000000410000005588'))
  and order_status in( 'FAILURE')
  and order_type in('PRE_AUTH_USER_PURCHASE', 'PRE_AUTH_USER_SUBSCRIBE');

explain extended_noaddr
select /*+index(fin_trans_order_41  idx_fin_trans_order_ooa), no_expand*/ count(*)
  from fin_trans_order_41
  where user_id= '2088112078201419'
  and(apply_time< '2019-10-11 22:02:52'or
      (apply_time= '2019-10-21 22:02:52' and order_id< '2019102200903000020000000000410000005588'))
  and order_status in( 'FAILURE')
  and order_type in('PRE_AUTH_USER_PURCHASE', 'PRE_AUTH_USER_SUBSCRIBE');

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int , c2 int, c3 int, primary key (c3, c1, c2));
insert into t values (0, 0, 3);
insert into t values (1, 0, 3);
insert into t values (0, 0, 4);
insert into t values (1, 0, 4);
insert into t values (0, 10, 3);
insert into t values (1, 10, 3);
insert into t values (0, 10, 4);
insert into t values (1, 10, 4);

select /*+no_expand*/ * from t where (c1 < 1 or (c1 = 1 and c2 < 2)) and c3 in (3,4);

explain extended_noaddr
select /*+no_expand*/ * from t where (c1 < 1 or (c1 = 1 and c2 < 2)) and c3 in (3,4);

--disable_warnings
drop table if exists v0;
--enable_warnings
CREATE TABLE v0 ( v1 INTEGER ) DEFAULT CHARSET utf8mb4 COLLATE utf8mb4_general_ci ;
INSERT INTO v0 VALUES ( v1 NOT LIKE 32487725.000000 >= - 56 OR ( v1 > - 91 AND v1 < - DATE_ADD ( v1 ,INTERVAL @var_17 SECOND ) ) ) ;
drop table v0;

