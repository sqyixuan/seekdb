--disable_warnings
drop table if exists t1,t2,tp,t_cnt;
drop function if exists f;
--enable_warnings

create table t1(a int, b int);
create table t2(c int, d int);
create table tp(x int, y int) partition by hash(x) partitions 4;
create index i2 on t2(c);

insert into t1 values (1,1),(2,2),(null,null);
insert into t2 values (1,1),(2,2),(null,null);
insert into tp values (1,1),(2,2),(null,null);

create table t_cnt(a int);
delimiter //;
create function f() returns int not deterministic
begin
  insert into t_cnt values(1);
  return 0;
end
//
delimiter ;//

--result_format 4
--explain_protocol 3
select * from (with cte as (select /*+materialize*/ * from t1) select * from cte limit 0);
select * from (with cte as (select /*+materialize*/ * from t1) select * from cte limit 1);
--explain_protocol 2
select * from (with cte as (select /*+materialize*/ f() from t1) select * from cte limit 0);
select count(*) as cnt from t_cnt having cnt = 0;
select SQL_CALC_FOUND_ROWS * from (with cte as (select /*+materialize*/ * from t1) select * from cte limit 0);
select SQL_CALC_FOUND_ROWS * from tp limit 0;
select /*+ use_nl(t tp) no_rewrite leading(tp t) PQ_DISTRIBUTE(t bc2host NONE)*/ * from t2 t right join tp on c=x limit 0;
select /*+parallel(2) no_rewrite*/ * from t1, t2 where a=c and exists (select * from tp limit 0);
select /*+parallel(2) no_rewrite*/ * from (select * from t1 limit 0) where exists (select * from tp limit 0);
select /*+no_rewrite*/ * from t1, (select * from tp limit 0) v where a=x;
select /*+no_rewrite*/ * from (select * from t1 limit 0), (select * from tp limit 0) v where a=x;
select /*+no_rewrite*/ * from t1 left join (select * from tp limit 0) v on a=x;
select * from t1, tp limit 0;
select * from t1 union all select * from tp limit 0;
select * from t1 intersect select * from tp limit 0;
select * from ((select * from t1 limit 1) union all (select * from tp limit 1) limit 0);
update tp set x = 0 where y = 1 limit 0;
delete from tp where x = 0 limit 0;
insert into tp select * from t1 limit 0;
select * from tp;
select * from tp limit 0;

drop table t1,t2,tp,t_cnt;
drop function f;
