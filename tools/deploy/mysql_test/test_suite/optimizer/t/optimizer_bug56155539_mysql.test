insert into t1 values ('aaaa', '腌腌腌', '⻁⻁⻁', '婏婏婏婏');

insert into t2 values ('a', 1), ('a0001', 2), ('A', 3), ('An123', 4), ('b123', 5);

call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');

--explain_protocol 2
select distinct c1, hex(c1), hex(weight_string(c1)), c2, hex(c2), hex(weight_string(c2)), c3, hex(c3), hex(weight_string(c3)), c4, hex(c4), hex(weight_string(c4)) from t1;

select count(*) from t1 where c1 like '';
select count(*) from t1 where c1 like '%';
select count(*) from t1 where c1 like 'a%';
select count(*) from t1 where c2 like '云云%';
select count(*) from t1 where c3 like '⺀%';
select count(*) from t1 where c4 like '⻟%';
select count(*) from t1 where c1 < 'b';
select * from t2 where c1 like 'a%';

drop table t1, t2;