--enable_query_log
#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int);
insert into t1 select uniform(1, 10000, random(0)), uniform(1, 10000, random(0)) from table(generator(10));
create table t2(c1 int, c2 int, index i1(c2) )  partition by hash(c1) partitions 256;
insert /*+query_timeout(100000000)*/ into t2 select uniform(1, 10000, random(1)), uniform(1, 10000, random(2)) from table(generator(100000));
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');

--source mysql_test/include/minor_merge_tenant.inc
--explain_protocol 2
--result_format 4

select * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
select /*+no_use_das(t2)*/ * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
select /*+parallel(2)*/ * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
select /*+use_hash(t1 t2)*/ * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
select /*+use_nl(t1 t2)*/ * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;
select /*+use_merge(t1 t2)*/ * from t1,t2 where t2.c1 = t1.c1 and t2.c2 = t1.c2;

drop table t1,t2;