--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer, cross_validation

--disable_warnings
drop table if exists t5;
--enable_warnings

create table t5 (c25 int, c27 varchar(200), c7 varchar(200));

insert into t5 values (85592847, NULL, 'KGkRnLEkqHJXiNtycqJqHaQTP85592847');
insert into t5 values (50752510, NULL, 'KpytDHeJULKgSaUgXRVrYQS50752510');

--result_format 4
--explain_protocol 2

SELECT 
  MAX(t5_139.c25) OVER (
    PARTITION BY t5_139.c27 
    ORDER BY 
      t5_139.c7
  ) as W1, 
  MIN(t5_139.c7) OVER (
    PARTITION BY t5_139.c7 
    ORDER BY 
      t5_139.c7
  ) as W2 
FROM 
  (
    SELECT 
      t5.c7, 
      t5.c25, 
      (
        SELECT 
          t5.c27 
        FROM 
          t5 
        ORDER BY 
          1 ASC 
        LIMIT 
          1
      ) AS c27 
    FROM 
      t5
  ) AS t5_139;

--disable_warnings
drop table if exists t5;
--enable_warnings
