select * from t2 where not exists (select /*+no_simplify_expr*/ 1 from t1 where (a=b+1 or a is null) and b is not null);
select /*+no_rewrite*/ * from t2 where not exists (select /*+no_simplify_expr*/ 1 from t1 where (a=b+1 or a is null) and b is not null);

select * from t2 where not exists (select /*+no_simplify_expr*/ 1 from t1 where (a=b+1 or a is null)) and b is not null;
select /*+no_rewrite*/ * from t2 where not exists (select /*+no_simplify_expr*/ 1 from t1 where (a=b+1 or a is null)) and b is not null;

select * from t2 where not exists (select 1 from t1 where (a=b or a is null) and b is not null);
select /*+no_rewrite*/ * from t2 where not exists (select 1 from t1 where (a=b or a is null) and b is not null);

select * from t2 where not exists (select 1 from t1 where (a=b or a is null)) and b is not null;
select /*+no_rewrite*/ * from t2 where not exists (select 1 from t1 where (a=b or a is null)) and b is not null;

select * from t1 where not exists (select 1 from t2 where (a+2=b+1 or a is null) and b is not null);
select /*+no_rewrite*/ * from t1 where not exists (select 1 from t2 where (a+2=b+1 or a is null) and b is not null);
 
select * from t1 where not exists (select 1 from t2 where a=b or a+b is null);
select /*+no_rewrite*/ * from t1 where not exists (select 1 from t2 where a=b or a+b is null);

select * from t1 where not exists (select 1 from t3 where a=c or a is null);
select /*+no_rewrite*/ * from t1 where not exists (select 1 from t3 where a=c or a is null);

select * from t3 where not exists (select 1 from t1 where a=c or a is null);
select /*+no_rewrite*/ * from t3 where not exists (select 1 from t1 where a=c or a is null);

select * from t1 join t2 on a = b where not exists (select 1 from t3 where a=c or a is null);
select /*+no_rewrite*/ * from t1 join t2 on a = b where not exists (select 1 from t3 where a=c or a is null);

select * from t1 join t2 on a <=> b where not exists (select 1 from t3 where a=c or a is null);
select /*+no_rewrite*/ * from t1 join t2 on a <=> b where not exists (select 1 from t3 where a=c or a is null);

select * from t1 join t2 on a <=> b where not exists (select 1 from t4 where a=d or a is null);
select /*+no_rewrite*/ * from t1 join t2 on a <=> b where not exists (select 1 from t4 where a=d or a is null);

select * from t1 join t2 on a <=> b where not exists (select 1 from t4 where a=d or a is null or d is null);
select /*+no_rewrite*/ * from t1 join t2 on a <=> b where not exists (select 1 from t4 where a=d or a is null or d is null);

select * from t1 join t2 on a = b where not exists (select 1 from t4 where a=d or a is null or d is null);
select /*+no_rewrite*/ * from t1 join t2 on a = b where not exists (select 1 from t4 where a=d or a is null or d is null);

select * from t1 join t2 on a = b where not exists (select 1 from t4 where a=d or d is null);
select /*+no_rewrite*/ * from t1 join t2 on a = b where not exists (select 1 from t4 where a=d or d is null);

select * from t4 where not exists (select 1 from t1 join t2 on a = b where a=d or d is null);
select /*+no_rewrite*/ * from t4 where not exists (select 1 from t1 join t2 on a = b where a=d or d is null);

select * from t4 where not exists (select 1 from t1 join t2 on a <=> b where a=d or d is null);
