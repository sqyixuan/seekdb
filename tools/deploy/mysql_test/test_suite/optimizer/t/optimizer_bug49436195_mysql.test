select * from t1 join t2 on a = b where not exists (select 1 from t4 where a+b=d or d is null);
select /*+no_rewrite*/ * from t1 join t2 on a = b where not exists (select 1 from t4 where a+b=d or d is null);

select * from t1 where not exists (select 1 from t3 where a=c or a is null or a > 0);
select /*+no_rewrite*/ * from t1 where not exists (select 1 from t3 where a=c or a is null or a > 0);

select * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t3 where a=c or a is null or 0 > 0);
select /*+no_rewrite*/ * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t3 where a=c or a is null or 0 > 0);

select * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t3 where a=c or a is null or 1 > 0);
select /*+no_rewrite*/ * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t3 where a=c or a is null or 1 > 0);

select * from t5 where not exists (select 1 from t4 where d=e+f or d is null or e is null);
select /*+no_rewrite*/ * from t5 where not exists (select 1 from t4 where d=e+f or d is null or e is null);

select * from t5 where not exists (select 1 from t4 where d=e+f or d is null or e+f is null);
select /*+no_rewrite*/ * from t5 where not exists (select 1 from t4 where d=e+f or d is null or e+f is null);

drop table t1,t2,t3,t4,t5;