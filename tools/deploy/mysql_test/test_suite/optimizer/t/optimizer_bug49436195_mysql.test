## 


--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

create table t1(a int);
create table t2(b int);
create table t3(c int not null);
create table t4(d int);
create table t5(e int, f int);
insert into t1 values (NULL),(0),(1),(-1);
insert into t2 values (NULL),(0),(2),(-1);
insert into t3 values (0),(3);
insert into t4 values (0),(4);
insert into t5 values (0,0),(5,NULL),(5,0);

--explain_protocol 1
--result_format 4

select * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t2 where a=b+1 or a is null or b+1 is null);
select /*+no_rewrite*/ * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t2 where a=b+1 or a is null or b+1 is null);

select * from t1 where not exists (select /*+no_simplify_expr*/ 1 from t2 where a=b+NULL or a is null or b+NULL is null);
