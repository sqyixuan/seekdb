--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
#tags: optimizer
#description: plan base line for schema sql

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
use oceanbase;
EXPLAIN BASIC SELECT row_id, column_name, column_value FROM __all_core_table WHERE table_name = '__all_global_stat' ORDER BY row_id, column_name;
EXPLAIN BASIC SELECT MAX(schema_version) as version FROM __all_ddl_operation;
EXPLAIN BASIC SELECT /*+ FROZEN_VERSION(%ld) */ MAX(schema_version) as version FROM __all_ddl_operation;
EXPLAIN BASIC SELECT  row_id, column_name, column_value FROM __all_core_table WHERE table_name = '__all_global_stat' ORDER BY row_id, column_name;
EXPLAIN BASIC SELECT  row_id, column_name, column_value FROM __all_core_table WHERE table_name = '__all_table' ORDER BY row_id, column_name;
EXPLAIN BASIC SELECT  row_id, column_name, column_value FROM __all_core_table WHERE table_name = '__all_column' ORDER BY row_id, column_name;
EXPLAIN BASIC SELECT 1 FROM __all_ddl_operation WHERE SCHEMA_VERSION <= 1450751726184000 AND SCHEMA_VERSION > 1450751726184000 AND TABLE_ID IN (1099511627877,1099511627878,1099511627879);
EXPLAIN BASIC SELECT tenant_id, table_id, table_name, database_id, table_type, load_type, def_type, rowkey_column_num, index_column_num, max_used_column_id, autoinc_column_id, read_only, rowkey_split_pos,compress_func_name,expire_condition, is_use_bloomfilter,  comment,block_size, collation_type, data_table_id, index_status, tablegroup_id, progressive_merge_num,index_type, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, schema_version, view_definition, view_check_option, view_is_updatable FROM __all_table_history WHERE tenant_id = 'tenant_id' AND table_id IN (1099511627877,1099511627878,1099511627879) AND SCHEMA_VERSION <= 'schema_version' ORDER BY TABLE_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, table_id, table_name, database_id, table_type, load_type, def_type, rowkey_column_num, index_column_num, max_used_column_id, autoinc_column_id, read_only, rowkey_split_pos,compress_func_name,expire_condition, is_use_bloomfilter,  comment,block_size, collation_type, data_table_id, index_status, tablegroup_id, progressive_merge_num,index_type, part_level, part_func_type, part_func_expr, part_num, sub_part_func_type, sub_part_func_expr, sub_part_num, schema_version, view_definition, view_check_option, view_is_updatable FROM __all_table_history WHERE tenant_id = 'tenant_id' AND table_id IN (1099511627877,1099511627878,1099511627879);
EXPLAIN BASIC SELECT tenant_id, table_id, column_id, schema_version, column_name, rowkey_position, index_position, order_in_rowkey, partition_key_position,data_type, data_length, data_precision, data_scale, zero_fill, nullable, autoincrement, is_hidden, on_update_current_timestamp, collation_type, orig_default_value, cur_default_value, comment, is_deleted FROM __all_column_history WHERE tenant_id = 1 AND table_id IN (1099511627877,1099511627878,1099511627879) AND SCHEMA_VERSION <= 1450751726184000 ORDER BY TABLE_ID, COLUMN_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, table_id, column_id, schema_version, column_name, rowkey_position, index_position, order_in_rowkey, partition_key_position,data_type, data_length, data_precision, data_scale, zero_fill, nullable, autoincrement, is_hidden, on_update_current_timestamp, collation_type, orig_default_value, cur_default_value, comment FROM __all_column WHERE table_id IN (1099511627877, 1099511627878, 1099511627879) AND tenant_id = 1;
EXPLAIN BASIC SELECT schema_version, tenant_id, user_id, table_id, table_name, database_id, database_name, tablegroup_id, operation_type  FROM __all_ddl_operation WHERE schema_version <= 1450754458962928 AND schema_version > 1450754458962928;
EXPLAIN BASIC SELECT tenant_id, database_id, schema_version, database_name, collation_type, comment, read_only, default_tablegroup_id, is_deleted FROM __all_database_history WHERE tenant_id = 1 AND SCHEMA_VERSION <= 1450751726184000 ORDER BY DATABASE_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, tablegroup_id, schema_version, tablegroup_name, comment, is_deleted FROM __all_tablegroup_history WHERE SCHEMA_VERSION <= 1450751726184000 AND tenant_id = 1 ORDER BY TABLEGROUP_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, schema_version, tenant_name, primary_zone, locked, collation_type, info, is_deleted FROM __all_tenant_history WHERE tenant_id IN (1) AND SCHEMA_VERSION <= 1450751726184000 ORDER BY TENANT_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, user_id, schema_version, user_name, passwd, info, is_locked, priv_alter, priv_create, priv_create_user, priv_delete, priv_drop, priv_grant_option, priv_insert, priv_update, priv_select, priv_super, priv_index, priv_create_view, priv_show_view, priv_show_db, priv_process, is_deleted FROM __all_virtual_user_history WHERE tenant_id = 1 AND SCHEMA_VERSION <= 1450751726184000 ORDER BY USER_ID, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, user_id, database_name, schema_version, priv_alter, priv_create, priv_delete, priv_drop, priv_grant_option, priv_insert, priv_update, priv_select, priv_index, priv_create_view, priv_show_view, is_deleted FROM __all_virtual_database_privilege_history WHERE tenant_id = 1 AND SCHEMA_VERSION <= 1450751726184000 ORDER BY USER_ID, DATABASE_NAME, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT tenant_id, user_id, database_name, table_name, schema_version, priv_alter, priv_create, priv_delete, priv_drop, priv_grant_option, priv_insert, priv_update, priv_select, priv_index, priv_create_view, priv_show_view, is_deleted FROM __all_virtual_table_privilege_history WHERE tenant_id = 1 AND SCHEMA_VERSION <= 1450751726184000 ORDER BY USER_ID, DATABASE_NAME, TABLE_NAME, SCHEMA_VERSION DESC;
EXPLAIN BASIC SELECT MAX(TABLE_ID) from __all_table_history where SCHEMA_VERSION <= 1450751726184000 AND tenant_id = 1;
EXPLAIN BASIC SELECT tenant_id, max(schema_version) FROM __all_tenant_history WHERE schema_version <= 1450751726184000 GROUP BY tenant_id ORDER by tenant_id;
disconnect obsys;
connection default;
