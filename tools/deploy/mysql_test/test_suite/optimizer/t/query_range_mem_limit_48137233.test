drop table test_unequal_bug;
CREATE TABLE test_unequal_bug(id int, CONSTRAINT pk_test_unequal_bug_id PRIMARY KEY(id));
SELECT * FROM test_unequal_bug r
WHERE r.ID IN ('1','2','3','4','5','6','7')
AND (r.ID !='11'
    AND r.ID !='1111'
    AND r.ID !='1112'
    AND r.ID !='1113'
    AND r.ID !='1114'
    AND r.ID !='1115'
    AND r.ID !='1116'
    AND r.ID !='1117'
    AND r.ID !='1118'
    AND r.ID !='1119'
    AND r.ID !='1110'
    AND r.ID !='1111'
    AND r.ID !='1112'
    AND r.ID !='1113'
    AND r.ID !='1114'
    AND r.ID !='1115'
    AND r.ID !='1116'
    AND r.ID !='1117'
    AND r.ID !='1118'
    AND r.ID !='1119'
    AND r.ID !='1110'
);
--explain_protocol 0

set ob_query_timeout = 10000000;
