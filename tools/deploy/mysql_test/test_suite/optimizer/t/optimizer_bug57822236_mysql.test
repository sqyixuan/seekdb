# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer

--result_format 4
--enable_sorted_result

## issue: 

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table t2(c1 varchar(5), c2 int, c3 int) partition by key(c1) partitions 2;
insert into t1 values(1,1,1), (2,1,1), (3,2,2), (4,2,2);
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t2 select * from t1;

--explain_protocol 1

select /*+parallel(2) no_rewrite*/ c2, c3 from t1 intersect select 1, 1;
## can not use DIST_NONE_ALL now. there is no part key in sharding info due to the cast BIGINT above c1
select /*+parallel(2) no_rewrite*/ c1, c2, c3 from t1 intersect select 1, 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c2, c3 from t1 intersect select 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c1, c2, c3 from t1 intersect select 1, 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c2, c3 from t1 intersect (select 1, 1 union all select 2, 2);
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c1, c2, c3 from t1 intersect (select 1, 1, 1 union all select 3, 2, 2);

select /*+parallel(2) no_rewrite*/ c2, c3 from t1 except select 1, 1;
select /*+parallel(2) no_rewrite*/ c1, c2, c3 from t1 except select 1, 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c2, c3 from t1 except select 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c1, c2, c3 from t1 except select 1, 1, 1;

select /*+parallel(2) no_rewrite*/ c1, c2, c3 from t2 intersect select '1', 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite */ c1, c2, c3 from t2 intersect select '1', 1, 1;
select /*+parallel(2) pq_set(@set$1 none all) no_rewrite*/ c1, c2, c3 from t2 intersect (select '1', 1, 1 union all select '3', 2, 2);

## disable DIST_ALL_NONE for except
(select /*+parallel(2) pq_set(@set$1 all none)*/ '1' a, 1 b, 1 c from dual union all select '2' a, 1 b, 1 c from dual) except select /*+no_rewrite*/ * from t2;

drop table t1;
