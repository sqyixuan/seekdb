create table t1(c1 int, c2 int, c3 int);
insert into t1 values(0,0,0);
create index idx on t1(c1,c2);

--explain_protocol 3
select /*+index(t1 idx)*/ * from t1 where (c1,c2) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
select /*+full(t1)*/ * from t1 where (c1,c2) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
select /*+index(t1 idx)*/ * from t1 where (c1,c1) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
select /*+full(t1)*/ * from t1 where (c1,c1) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);

set @@ob_enable_plan_cache = 1;
select /*+index(t1 idx)*/ * from t1 where (c1,c2) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
select /*+full(t1)*/ * from t1 where (c1,c2) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
select /*+index(t1 idx)*/ * from t1 where (c1,c1) > (1,1) or (c1 != 2 and c1 != 3 and c1 != 4);
