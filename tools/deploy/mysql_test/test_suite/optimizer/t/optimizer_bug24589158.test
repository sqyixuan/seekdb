WITH t0 AS (
    (WITH cte1 AS
        (
            SELECT *
            FROM   d
            WHERE     col_int_unsigned_key >
            		(
                    SELECT col_int_unsigned_key
                    FROM   (
                        (
                            SELECT   *
                            FROM     f
                            WHERE    1 = 0)
                        UNION ALL
                        (
                            SELECT   *
                            FROM     (
                            SELECT *
                            FROM   f) t1
                    				ORDER BY 1 DESC limit 0)) vt4
                    ORDER BY  1 limit 1))
    SELECT 1
    FROM   cte1)
    UNION ALL
        (WITH cte5 AS 
        		(WITH cte AS
        				(
                    SELECT *
                    FROM   d )
            SELECT 1
            FROM   cte a,
                cte b
            WHERE  1
            AND    b.pk < 744488960)
        SELECT *
        FROM   cte5))
SELECT
       /*+ ENABLE_PARALLEL_DML PARALLEL(5) no_rewrite */
       count(*)
FROM   t0;
drop table if exists d, f;

--disable_warnings
drop table if exists t1;
drop function if exists a;
--enable_warnings

create table t1(c int);
create function a() returns int return 42+13;

SELECT * FROM t1 WHERE a IN (SELECT a FROM t1 UNION SELECT SQL_CACHE a FROM t1);
drop table if exists t1;
drop function if exists a;