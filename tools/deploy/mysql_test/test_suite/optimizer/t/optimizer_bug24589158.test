# owner: link.zt
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists tpart, spart, t, s, v1, v2, t1, t2, t3, s1, s2, s3;
drop view if exists v1, v2;
--enable_warnings

create table tpart (c1 int) partition by hash(c1) partitions 4;
create table spart (c1 int) partition by hash(c1) partitions 4;
create table t (c1 int);
create table s (c1 int);

create table t1 (c1 int, c2 int) partition by hash(c1) partitions 5;
create table t2 (d1 int, d2 int) partition by hash(d1) partitions 5;
create table t3 (e1 int, e2 int) partition by hash(e1) partitions 5;

create table s1 (c1 int, c2 int);
create table s2 (d1 int, d2 int);
create table s3 (e1 int, e2 int);

--disable_query_log
insert into tpart values (1), (2), (3), (4);
insert into t     values (1), (2), (3), (4);

insert into t1 values (1, 2);
insert into t1 values (2, 2);
insert into t3 values (2, 3);

insert into s1 values (1, 2);
insert into s1 values (2, 2);
insert into s3 values (2, 3);
--disable_result_log
select count(*) from t, tpart, s, spart;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

select distinct spart.c1 from tpart left join spart on tpart.c1 = spart.c1;
select distinct s.c1 from t left join s on t.c1 = s.c1;

select spart.c1, count(*) from tpart left join spart on tpart.c1 = spart.c1 group by spart.c1;
select s.c1, count(*) from t left join s on t.c1 = s.c1 group by s.c1;

select sum(tpart.c1) over (partition by spart.c1) from tpart left join spart on tpart.c1 = spart.c1;
select sum(t.c1) over (partition by s.c1) from t left join s on t.c1 = s.c1;

create view v1 as (select tpart.c1 as a, spart.c1 as b from tpart left join spart on tpart.c1 = spart.c1);
create view v2 as (select t.c1 as a, s.c1 as b from t left join s on t.c1 = s.c1);

select * from v1 t1 left join v1 t2 on t1.b <=> t2.b order by t1.a, t1.b, t2.a, t2.b;
select * from v2 t1 left join v2 t2 on t1.b <=> t2.b order by t1.a, t1.b, t2.a, t2.b;

select * from v1 t1 left join v1 t2 on t1.b = t2.b order by t1.a, t1.b, t2.a, t2.b;
select * from v2 t1 left join v2 t2 on t1.b = t2.b order by t1.a, t1.b, t2.a, t2.b;

select /*+no_rewrite*/ * from v1 t1 where exists (select 1 from v1 t2 where t1.b <=> t2.b);
select /*+no_rewrite*/ * from v2 t1 where exists (select 1 from v2 t2 where t1.b <=> t2.b);
select /*+no_rewrite*/ * from v1 t1 where exists (select /*+no_rewrite, no_pred_deduce(@SEL$4)*/ 1 from v1 t2 where t1.b = t2.b);
select /*+no_rewrite*/ * from v2 t1 where exists (select /*+no_rewrite, no_pred_deduce(@SEL$4)*/ 1 from v2 t2 where t1.b = t2.b);

select b from v1 union select b from v1;
select b from v2 union select b from v2;

select a from v1 union select a from v1;
select a from v2 union select a from v2;

## bug: inherit partition expr from the outer join's right table
## the sharding info may take spart.c1 as the partition expr
## and we found the distinct expr is the same as the partition expr
## As a consequnce, no exchange operator is allocated.
select /*+leading(spart tpart)*/ distinct spart.c1 from tpart left join spart on tpart.c1 = spart.c1;
select distinct s.c1 from t left join s on t.c1 = s.c1;

## bug: convert partition expr from the outer join's right table
## spart.c1 is converted as view V's partition expr
select /*+no_rewrite*/ distinct V.c1 from (select /*+no_rewrite*/ spart.c1 from tpart left join spart on tpart.c1 = spart.c1) V;

## bug: deducing invalid sharding equal sets
## records are not partition by t1.c2 even though there is t1.c1 = t1.c2;
select distinct t1.c2, t2.d1 + 1 from t1 left join t2 on t1.c1 = t1.c2 and t1.c1 = t2.d1;
select distinct s1.c2, s2.d1 + 1 from s1 left join s2 on s1.c1 = s1.c2 and s1.c1 = s2.d1;

select * from t1 left join t2 on t1.c1 = t1.c2 and t1.c1 = t2.d1 left join t3 on t1.c2 = t3.e1;
select * from s1 left join s2 on s1.c1 = s1.c2 and s1.c1 = s2.d1 left join s3 on s1.c2 = s3.e1;

select * from t1 left join t2 on t1.c1 = t2.d1 and t1.c2 = t2.d1 left join t3 on t1.c2 = t3.e1;
select * from s1 left join s2 on s1.c1 = s2.d1 and s1.c2 = s2.d1 left join s3 on s1.c2 = s3.e1;

select * from t1 left join t2 on t2.d1 = t2.d2 and t1.c1 = t2.d1 left join t3 on t2.d2 = t3.e1;
select * from s1 left join s2 on s2.d1 = s2.d2 and s1.c1 = s2.d1 left join s3 on s2.d2 = s3.e1;

drop view v1, v2;
drop table t, s, tpart, spart, t1, t2, t3, s1, s2, s3;

--disable_warnings
drop table if exists d, f;
--enable_warnings

CREATE TABLE d (
col_varchar_100_key varchar(100),
col_int_signed_key int signed,
col_varchar_100 varchar(100),
col_varchar_30 varchar(30),
col_int_unsigned int unsigned,
col_varchar_30_key varchar(30),
col_int_signed int signed,
col_int_unsigned_key int unsigned,
pk integer auto_increment,
/*Indices*/
key idx5(pk, col_varchar_100_key ),
key idx1(pk, col_int_signed_key ),
key idx7(pk, col_varchar_30_key ),
key idx3(pk, col_int_unsigned_key ),
primary key (pk) )     ; 
