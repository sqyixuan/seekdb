# owner: link.zt
# owner group: SQL1
# tags: optimizer
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int primary key, c2 int) partition by hash(c1) partitions 4;

insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
insert into t1 values (4, 4);
insert into t1 values (6, 6);
insert into t1 values (8, 8);


insert into t2 values (1, 1);
insert into t2 values (2, 2);
insert into t2 values (3, 3);
insert into t2 values (4, 4);

--explain_protocol 2
--result_format 4

# union, use repart
select c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3);
select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3);

# union, can not use repart
select c2, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3);
select /*+no_use_px*/ c2, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3);

# union, test sharding
explain (select c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3)) union (select c1, c2 from t2 tmp);
(select c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3)) union (select c1, c2 from t2 tmp);

explain (select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3)) union (select c1, c2 from t2 tmp);
(select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) union select c1, c2 from t2 where t2.c1 in (1, 2, 3)) union (select c1, c2 from t2 tmp);

explain (select c1, c2 from t2 where t2.c1 in (1, 2, 3) union select c1, c2 from t1 where c1 in (2,4)) union (select c1, c2 from t2 tmp);
(select c1, c2 from t2 where t2.c1 in (1, 2, 3) union select c1, c2 from t1 where c1 in (2,4)) union (select c1, c2 from t2 tmp);

explain (select /*+no_use_px*/ c1, c2 from t2 where t2.c1 in (1, 2, 3) union select c1, c2 from t1 where c1 in (2,4)) union (select c1, c2 from t2 tmp);
(select /*+no_use_px*/ c1, c2 from t2 where t2.c1 in (1, 2, 3) union select c1, c2 from t1 where c1 in (2,4)) union (select c1, c2 from t2 tmp);

# except
select c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3);
select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3);

select c2, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3);
select /*+no_use_px*/ c2, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3);

# except, test sharding
explain (select c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3)) intersect (select c1, c2 from t2 tmp);
(select c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3)) intersect (select c1, c2 from t2 tmp);

explain (select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3)) intersect (select c1, c2 from t2 tmp);
(select /*+no_use_px*/ c1, c2 from t1 where c1 in (2,4) except select c1, c2 from t2 where t2.c1 in (1, 2, 3)) intersect (select c1, c2 from t2 tmp);

explain (select c1, c2 from t2 except select c1, c2 from t1 where c1 in (2,4)) intersect (select c1, c2 from t2 tmp);
(select c1, c2 from t2 except select c1, c2 from t1 where c1 in (2,4)) intersect (select c1, c2 from t2 tmp);

explain (select /*+no_use_px*/ c1, c2 from t2 except select c1, c2 from t1 where c1 in (2,4)) intersect (select c1, c2 from t2 tmp);
(select /*+no_use_px*/ c1, c2 from t2 except select c1, c2 from t1 where c1 in (2,4)) intersect (select c1, c2 from t2 tmp);

# semi
select /*+no_pred_deduce*/ * from t1 where exists (select 1 from t2 where t2.c1 = t1.c1 and t2.c1 in (1,2,3)) and t1.c1 in (2, 4);
select /*+no_pred_deduce,no_use_px*/ * from t1 where exists (select 1 from t2 where t2.c1 = t1.c1 and t2.c1 in (1,2,3)) and t1.c1 in (2, 4);

select /*+no_pred_deduce*/ * from t1, t2 where t2.c1 = t1.c1 and t2.c1 in (1,2,3) and t1.c1 in (2, 4, 6, 8);
select /*+no_pred_deduce,no_use_px*/ * from t1, t2 where t2.c1 = t1.c1 and t2.c1 in (1,2,3) and t1.c1 in (2, 4, 6, 8);

drop table t1;
drop table t2;
