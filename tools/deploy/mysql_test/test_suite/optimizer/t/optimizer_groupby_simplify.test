--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:link.zt
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(a int primary key, b int not null, c int not null, d int not null, index idx_b(b), unique index uidx_d_c(d,c));
create table t2(a int primary key, b int, c int, d int, index idx_b(b), unique index uidx_d_c(d,c));
create table t3(a int primary key, b int, c int, d int, index idx_b(b));

## all the data are in memory
--let $count = 0
while($count < 10)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 1, 1, $count)
  eval $stmt;
  inc $count;
}

insert into t2 select a+1,b,c,d from t1;
insert into t3 select a+2,b,c,d from t1;

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
call dbms_stats.gather_table_stats('TEST', 't3');

--explain_protocol 2
--result_format 4

select count(*) from t1, t2 group by t1.d, t1.c, t1.b order by t1.a limit 10;

select count(*) from t1, t2 group by t2.d, t2.c, t2.b order by t2.a limit 10;

select count(*) from t1, t2 group by t1.a, t1.d, t1.c, t1.b order by t1.a limit 10;

select count(*) from t1, t2 group by t2.a, t2.d, t2.c, t2.b order by t2.a limit 10;

select count(*) from t1, t2, t3 group by t1.a, t1.b, t2.a, t2.b, t3.a, t3.b order by t1.a limit 10;

select count(*) from t1, t2 where t1.b = t2.a group by t1.a, t1.b, t2.b order by t1.a limit 10;

# unique key t1 (c,d)
# unique key t2 (c,d)
# based on where condition, we can deduce t1 (b,c) is unique
select /*+leading(t1, t2)*/ sum(t2.a) from t1, t2 where t1.b = t2.c and t1.c = t2.d group by t1.b, t1.c, t1.d;
select /*+leading(t2, t1)*/ sum(t2.a) from t1, t2 where t1.b = t2.c and t1.c = t2.d group by t1.b, t1.c, t1.d;
select /*+leading(t2, t1)*/ sum(t2.a) from t1, t2 where t1.b = t2.c and t1.c = t2.d and t2.c > 1 and t2.d > 1 group by t2.b, t2.c, t2.d;
select /*+leading(t2, t1)*/ sum(t2.a) from t1, t2 where t1.b = t2.c and t1.c = t2.d and t2.c > 1 and t2.d > 1 group by t1.b, t1.c, t2.b;
