--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1;
drop view if exists t1;
--enable_warnings

--disable_query_log
create table t1(c1 int, c2 int, primary key(c1)) partition by range(c1)
  (partition p0 values less than(10), partition p1 values less than(100),
   partition p2 values less than(1000));

insert into t1 values (1,1), (20,20), (300, 300);
--enable_query_log

--disable_query_log
--disable_result_log
select count(*) from t1;
--enable_result_log
--enable_query_log

--let $query =select * from t1 order by t1.c1
--eval EXPLAIN EXTENDED_NOADDR $query;
--eval $query;

--let $query =select * from t1 where c1 < 1000 order by t1.c1
--eval EXPLAIN EXTENDED_NOADDR $query;
--eval $query;

--let $query =select * from t1 where c1 < 100 order by t1.c1
--eval EXPLAIN EXTENDED_NOADDR $query;
--eval $query;

--disable_warnings
drop table if exists t1;
--enable_warnings
