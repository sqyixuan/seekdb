# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer
## test for double as int query range

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

create table t1 (c1 int primary key, c2 tinyint, c3 tinyint, c4 tinyint, key i1(c2, c3, c4));
create table t2 (c1 int primary key, c2 mediumint, c3 mediumint, c4 mediumint, key i1(c2, c3, c4));
create table t3 (c1 int primary key, c2 int, c3 int, c4 int, key i1(c2, c3, c4));
create table t4 (c1 int primary key, c2 bigint, c3 bigint, c4 bigint, key i1(c2, c3, c4));

insert into t1 values (1, 1, 1, 1);
insert into t1 values (2, 2, 2, 2);
