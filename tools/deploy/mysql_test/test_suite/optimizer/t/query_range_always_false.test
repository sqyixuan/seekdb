# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--result_format 4
--disable_warnings
DROP TABLE if exists t1, src;
--enable_warnings


CREATE TABLE t1 (c1 INT, c2 INT, c3 INT, c4 INT, primary key(c1,c2,c3,c4));
CREATE TABLE src (c1 INT);
insert into src WITH RECURSIVE cte AS (SELECT 1 AS num UNION ALL SELECT num + 1 FROM cte WHERE num < 20) SELECT num FROM cte;insert into t1 select s1.c1,s2.c1,s3.c1,s4.c1 from src s1, src s2, src s3, src s4;

--explain_protocol 2
# bug: 53522776
select * from t1 where c1 between 9 and 4 and c3 = 3 or c1 like 4 and c1 between 9 and 0 and c3 between 9 and 7 order by 1,2,3,4;

# single always fasle condition
select /*+no_rewrite*/ count(*) from t1 where c1 = null;
select count(*) from t1 where c1 > 4 and c1 < 3;
select count(*) from t1 where c1 = 999999999999999999999999999;
select /*+no_rewrite*/ count(*) from t1 where c1 in (null, null);
select count(*) from t1 where c1 between 5 and 3;

# common condition and single always false condition
select /*+no_rewrite*/ count(*) from t1 where c1 = 1 and c1 = null;
select count(*) from t1 where c1 = 1 and c1 > 4 and c1 < 3;
select count(*) from t1 where c1 = 1 and c2 = 999999999999999999999999999;
select /*+no_rewrite*/ count(*) from t1 where c1 = 1 and c3 in (null, null);
select count(*) from t1 where c1 = 1 and c4 between 5 and 3;

# common condition or single always false condition
select /*+no_rewrite*/ count(*) from t1 where c1 = 1 or c1 = null;
select count(*) from t1 where c1 = 1 or c1 > 4 and c1 < 3;
select count(*) from t1 where c1 = 1 or c2 = 999999999999999999999999999;
select /*+no_rewrite*/ count(*) from t1 where c1 = 1 or c3 in (null, null);
select count(*) from t1 where c1 = 1 or c4 between 5 and 3;

# always false condition and always false condition 
select /*+no_rewrite*/ count(*) from t1 where c1 = null and c1 > 4 and c1 < 3;
select count(*) from t1 where c1 = 999999999999999999999999999 and c2 between 5 and 3;

# always false condition or always false condition 
select /*+no_rewrite*/ count(*) from t1 where c1 = null or c1 > 4 and c1 < 3;
select count(*) from t1 where c1 = 999999999999999999999999999 or c2 between 5 and 3;

DROP TABLE t1, src;