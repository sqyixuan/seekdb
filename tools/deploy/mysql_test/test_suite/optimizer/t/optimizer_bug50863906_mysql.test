#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (a int, b int, c int, primary key(a, b)) partition by hash(a) partitions 2;
insert INTO t1  values(25, 1, 0);
insert into t1 values (5,127,127);
INSERT INTO t1(a,b) VALUES (4,1);

--result_format 4
--explain_protocol 1
set autocommit = 0;
delete /*+use_concat parallel(2)*/from t1 where t1.a = 1 or t1.b = 1;
rollback;
delete /*+use_concat parallel(1)*/from t1 where t1.a = 1 or t1.b = 1;
set autocommit = 1;

drop table t1;