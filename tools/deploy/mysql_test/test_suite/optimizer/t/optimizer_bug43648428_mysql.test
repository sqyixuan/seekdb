--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenling.zzg
# owner group: sql1
# tags: optimizer
# description:

--disable_warnings
drop table if exists t0, t1, t2;
--enable_warnings
CREATE TABLE t0(c0 int UNIQUE KEY)  duplicate_scope='cluster' ;
CREATE TABLE t1(c0 int)  duplicate_scope='cluster' ;
CREATE TABLE t2(c0 int ) ;

--explain_protocol 2
--result_format 3

SELECT t0.c0 FROM t2, t1, t0 WHERE (t1.c0) <= (t0.c0);

drop table t0;
drop table t1;
drop table t2;
