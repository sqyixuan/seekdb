# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--disable_warnings
--result_format 4
--explain_protocol 2
--enable_sorted_result

--disable_warnings
drop table if exists t1,t2;
drop function if exists f1;
drop function if exists f2;
--disable_warnings
--explain_protocol 0

create table t1(c1 int, c2 varchar(10), c3 date);
create table t2(c1 int, c2 int);
insert into t1 values(10, 'aaa', DATE'2011-01-01'),
                     (11, 'aba', DATE'2011-02-01'),
                     (12, 'abc', DATE'2011-03-01'),
                     (12, 'abc', DATE'2021-03-01');
insert into t1 select c1+5, concat(c2,'def'), c3 from t1;
insert into t2 values(1,0),(1,1),(0,1),(2,0),(2,1),(1,2);
insert into t2 select c1 + 5, c2 + 5 from t2;
#non-deterministic function
delimiter //;
create function f1(a int)
returns int
begin
	return a;
end;
//

#deterministic function
create function f2(a int)
returns int deterministic
begin
	return a;
end;
//
delimiter ;//
--explain_protocol 2
--echo #basic test
select * from t1 where JSON_VALID(c2)
                                and st_isvalid(ST_GeomFromText(c2,26918))
                                and c1+1 = 20
                                and c3 = '2011-01-01'
                                and f1(c1) = 1
                                and f2(c1) = 1
                                and f1(1) = c1 + 10
                                and f2(1) = c1 + 10;
--echo #group by
select /*+no_rewrite*/ * from t1 group by c1 having JSON_VALID(c2)
                              and st_isvalid(ST_GeomFromText(c2,26918))
                              and c1+1 = 20
                              and c3 = '2011-01-01'
                              and f1(c1) = 1
                              and f2(c1) = 1;

select /*+no_rewrite*/ * from t1 group by c1 with rollup having JSON_VALID(c2)
                              and st_isvalid(ST_GeomFromText(c2,26918))
                              and c1+1 = 20
                              and c3 = '2011-01-01'
                              and f1(c1) = 1
                              and f2(c1) = 1;

--echo #join filter
select * from t1, t2 where JSON_VALID(concat(t1.c2,t2.c1))
                            and st_isvalid(ST_GeomFromText(t1.c2,t2.c1))
                            and t1.c1+1 > t2.c2 + 5
                            and t1.c3  > t2.c1
                            and f1(t1.c1) > t2.c2
                            and f2(t1.c1) > t2.c2;

--echo #subplan scan
select /*+NO_REWRITE*/* from (select distinct c1,c2,c3 from t1)
         where  JSON_VALID(c2)
                and st_isvalid(ST_GeomFromText(c2,26918))
                and c1+1 = 20
                and c3 = '2011-01-01'
                and f1(c1) = 1
                and f2(c1) = 1
                and f1(1) = c1 + 10
                and f2(1) = c1 + 10;

--echo #subplan filter
select /*+NO_REWRITE*/* from t1 where f2(c1) = ANY(select c1 from t2)
                                      and c1+1 = ANY(select c2 from t2)
                                      and f2(1) + c1 = ANY(select c2 from t2);

drop table t1,t2;