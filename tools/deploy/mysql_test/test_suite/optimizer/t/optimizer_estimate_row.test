--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yibo.tyf
#owner group: sql1
# tags: optimizer
#this file try to verify the output rows estimated from storage engine

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(a int primary key, b int, c int, d int, index idx_b(b), index idx_c(c), index idx_d(d));
create table t2(a int primary key, b int, c int, d int, index idx_b(b), index idx_c(c), index idx_d(d));
create table t3(a int primary key, b int, c int, d int, index idx_b(b), index idx_c(c), index idx_d(d));

## all the data are in memory
--let $count = 0
while($count < 100)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 1, 1, 1)
  eval $stmt;
  inc $count;
}

--let $count = 100
while($count < 200)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 2, 2, 2)
  eval $stmt;
  inc $count;
}

--let $count = 200
while($count < 300)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 3, 3, 3)
  eval $stmt;
  inc $count;
}

select count(*) from t1;
explain select * from t1;
select count(*) from t1 where b = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 1;
select count(*) from t1 where c >= 2;
explain select/*+index(t1 idx_c)*/ * from t1 where c >= 2;
select count(*) from t1 where d < 3;
explain select/*+index(t1 idx_d)*/ * from t1 where d < 3; 

### do insert
--let $count = 300
while($count < 400)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, 1, 1, 1)
  eval $stmt;
  inc $count;
}
select count(*) from t1;
explain select * from t1;
select count(*) from t1 where b = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 1;
select count(*) from t1 where c >= 2;
explain select/*+index(t1 idx_c)*/ * from t1 where c >= 2;
select count(*) from t1 where d < 3;
explain select/*+index(t1 idx_d)*/ * from t1 where d < 3;

### do update
update t1 set b = 3, c = 3, d = 3 where b = 1 and c = 1 and d = 1;
select count(*) from t1;
explain select * from t1;
select count(*) from t1 where b = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 1;
select count(*) from t1 where c >= 2;
explain select/*+index(t1 idx_c)*/ * from t1 where c >= 2;
select count(*) from t1 where d < 3;
explain select/*+index(t1 idx_d)*/ * from t1 where d < 3;

### do delete
delete from t1 where b = 2 and c = 2 and d = 2;
select count(*) from t1;
explain select * from t1;
select count(*) from t1 where b = 1;
explain select/*+index(t1 idx_b)*/ * from t1 where b = 1;
select count(*) from t1 where c >= 2;
explain select/*+index(t1 idx_c)*/ * from t1 where c >= 2;
select count(*) from t1 where d < 3;
explain select/*+index(t1 idx_d)*/ * from t1 where d < 3;
drop table t1;

