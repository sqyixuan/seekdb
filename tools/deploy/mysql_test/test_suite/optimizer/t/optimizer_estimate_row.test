### do minor freeze
--disable_warnings
drop table if exists t1_minor_freeze;
--enable_warnings
create table t1_minor_freeze(a int primary key);
--let $count = 0
while($count < 100)
{
  --let $stmt=insert into t1_minor_freeze(a) values ($count)
  eval $stmt;
  inc $count;
}

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1_minor_freeze');
explain select count(*) from t1_minor_freeze where a > 9 and a < 11;
drop table t1_minor_freeze;
