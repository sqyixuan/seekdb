call dbms_stats.gather_table_stats('TEST', 't2', method_opt=>'for all columns size 10');
select TABLE_NAME, NUM_ROWS, AVG_ROW_LEN from oceanbase.dba_tab_statistics where table_name='T2' and owner='TEST';
select count(*) from t2;
explain select * from t2;
select count(*) from t2 where b = 1;
explain select/*+index(t2 idx_b)*/ * from t2 where b = 1;
select count(*) from t2 where c >= 2;
explain select/*+index(t2 idx_c)*/ * from t2 where c >= 2;
