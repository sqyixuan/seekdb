--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
#bug:

--disable_warnings
drop table if exists t0,t1;
--enable_warnings

CREATE TABLE `t0` (
`c0` varchar(500) DEFAULT NULL COMMENT 'asdf',
`c1` float DEFAULT NULL,
`c2` smallint(5) unsigned zerofill DEFAULT NULL,
`c3` mediumint(8) unsigned zerofill DEFAULT NULL COMMENT 'asdf',
KEY `i300` (`c0`(3), `c1`, `c2`, `c3`) BLOCK_SIZE 16384 GLOBAL,
KEY `i650` (`c3`) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `t1` (
`c0` double DEFAULT NULL,
`c1` smallint(14) unsigned zerofill DEFAULT NULL COMMENT 'asdf',
UNIQUE KEY `c0` (`c0`) BLOCK_SIZE 16384 GLOBAL,
UNIQUE KEY `c1` (`c1`) BLOCK_SIZE 16384 GLOBAL,
KEY `i320` (`c0`) BLOCK_SIZE 16384 GLOBAL
) partition by key(c1, c0)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9,
partition p10);

--disable_query_log
--disable_result_log
insert into t0 values('-',NULL,NULL,NULL);
insert into t1 values('-1916917789', NULL);
insert into t1 values('724800132', NULL);
select count(*) from t0;
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

SELECT count(*) as rowCount FROM (SELECT t0.c0 AS t0c0 FROM t0 WHERE t0.c2 IS NULL ORDER BY t0.c3 ASC LIMIT 1)as result WHERE result.t0c0 = '-' ;

SELECT count(*) as rowCount FROM (SELECT /*+ TOPK (50 50)  */ ALL t1.c0 AS t1c0, t1.c1 AS t1c1 FROM t1 WHERE (t1.c1)
IS UNKNOWN GROUP BY t1.c0, t1.c1 ORDER BY t1.c1 DESC LIMIT 2147483647 OFFSET 0)
as result WHERE result.t1c0 = -1.916917789E9 AND result.t1c1 IS NULL;

select 1 from t0 where 'a' = 'b';

drop table t0,t1;

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int)partition by hash(c1) partitions 5;
create table t2(c1 int, c2 int, c3 int)partition by hash(c1) partitions 6;
create table t3(c1 int, c2 int, c3 int)partition by hash(c1) partitions 5;
select /*+parallel(4)*/ * from t1, t3 where t1.c1 = t3.c1;
select /*+parallel(6)*/ * from t1, t3 where t1.c1 = t3.c1;
select /*+parallel(6) leading(t1 t2) pq_distribute(t2 partition none)*/ * from t1, t2 where t1.c2 = t2.c1;
select /*+parallel(8) leading(t1 t2) pq_distribute(t2 partition none)*/ * from t1, t2 where t1.c2 = t2.c1;
select /*+parallel(3) no_place_group_by leading(t2 t1) pq_distribute(t1 broadcast none)*/ count(*) from t1, t2 where t1.c2 = t2.c2 group by t1.c1;
select /*+parallel(8) no_place_group_by leading(t2 t1) pq_distribute(t1 broadcast none)*/ count(*) from t1, t2 where t1.c2 = t2.c2 group by t1.c1;
drop table t1,t2,t3;
