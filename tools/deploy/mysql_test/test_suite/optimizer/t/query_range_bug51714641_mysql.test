# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer,cross_validation

--disable_warnings
DROP TABLE if exists sample_basic_image;
--enable_warnings
CREATE TABLE `sample_basic_image` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '自增主键',
  `file_id` varchar(150) NOT NULL DEFAULT '' COMMENT '数据唯一ID',
  `vin` varchar(40) NOT NULL DEFAULT '' COMMENT 'vin',
  `collect_time` bigint(20) NOT NULL DEFAULT '0' COMMENT '数据采集时间毫秒',
  `file_name` varchar(255) NOT NULL DEFAULT '' COMMENT '文件名称',
  `bucket_name` varchar(60) NOT NULL DEFAULT '' COMMENT 'bucketName',
  `object_key` varchar(500) NOT NULL DEFAULT '' COMMENT '源数据Bos存储地址',
  `frame_ts` bigint(20) unsigned NOT NULL DEFAULT '0' COMMENT '图片帧-毫秒',
  `frame_id` int(10) NOT NULL DEFAULT '0' COMMENT '图片帧ID',
  `position` varchar(16) NOT NULL DEFAULT '' COMMENT '相机位置',
  `vid` varchar(60) NOT NULL DEFAULT '' COMMENT '数据采集编码',
  `clip_vid` varchar(60) NOT NULL DEFAULT '' COMMENT 'clip-vid',
  `ctime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `mtime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`, `collect_time`),
  UNIQUE KEY `uniq_cltime_fid` (`collect_time`, `file_id`) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY `uniq_fid_cltime` (`file_id`, `collect_time`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_fname` (`file_name`(60)) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_cvid` (`clip_vid`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 8000001 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '原始基本图片表'
 partition by range(`collect_time`)
(partition M202301 values less than (1675180800000),
partition M202302 values less than (1677600000000),
partition M202303 values less than (1680278400000),
partition M202304 values less than (1682870400000),
partition M202305 values less than (1685548800000),
partition M202306 values less than (1688140800000),
partition M202307 values less than (1690819200000),
partition M202308 values less than (1693497600000),
partition M202309 values less than (1696089600000),
partition M202310 values less than (1698768000000),
partition M202311 values less than (1701360000000),
partition M202312 values less than (1704038400000));

--result_format 4
--explain_protocol 2
SELECT file_id,file_name,frame_ts,bucket_name,object_key,position,clip_vid FROM `sample_basic_image`
