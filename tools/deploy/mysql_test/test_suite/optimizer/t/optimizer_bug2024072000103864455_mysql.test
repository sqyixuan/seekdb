# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer,cross_validation

--result_format 4

--disable_warnings
drop table if exists t1,d1;
--enable_warnings

create table t1(c1 int primary key, c2 int ,c3 int, c4 int, index i1(c2, c3));
insert into t1 select row_number() over (), abs(random(2) % 100), abs(random(3) % 100), abs(random(4) % 100) from table(generator(100000));

create table d1(c1 int, c2 int, index i1(c1));
create INDEX i2 on d1 (c2);
insert into d1 select 1,1 from table(generator(100000));
--source mysql_test/include/minor_merge_tenant.inc

call dbms_stats.gather_table_stats(null, 't1');

--explain_protocol 2

select * from t1 limit 20000, 1;
select * from t1 where c2 >=0 limit 20000, 1;
select * from t1 where c2 = 1 limit 20000, 1;
select * from t1 where c2 > 60 and c3 = 1 limit 20000, 1;
select * from t1 where c2 > 60 and c4 = 1 limit 20000, 1;
select * from t1 where c2 > 60 order by c2 desc limit 20000, 1;
select * from t1 where c2 = 1 order by c3 desc limit 20000, 1;
select * from t1 where c2 > 60 order by c4 desc limit 20000, 1;

select /*+index(t1 i1)*/ * from t1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 >=0 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 and c3 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 and c4 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 order by c2 desc limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 = 1 order by c3 desc limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 order by c4 desc limit 20000, 1;

explain select /*+parallel(1) index(d1 i1)*/ * from d1 where c1 = 1 limit 80000, 1;
explain select /*+parallel(1) */ * from d1 order by c2 desc limit 80000, 1;
explain select /*+parallel(1) */ * from d1 where c1 = 1 order by c2 desc limit 80000, 1;
explain select /*+parallel(1) index(d1 i1) */ * from d1 where c1 = 1 order by c2 desc limit 80000, 1;
explain select /*+parallel(1) index(d1 i2) */ * from d1 where c1 = 1 order by c2 desc limit 80000, 1;

drop table t1,d1;

--explain_protocol 0
create table t1(c1 int primary key, c2 int ,c3 int, c4 int, index i1(c2, c3) local with column group (each column)) with column group (each column);
insert into t1 select row_number() over (), abs(random(2) % 100), abs(random(3) % 100), abs(random(4) % 100) from table(generator(100000));

--source mysql_test/include/minor_merge_tenant.inc

call dbms_stats.gather_table_stats(null, 't1');

--explain_protocol 2

select * from t1 limit 20000, 1;
select * from t1 where c2 >=0 limit 20000, 1;
select * from t1 where c2 = 1 limit 20000, 1;
select * from t1 where c2 > 60 and c3 = 1 limit 20000, 1;
select * from t1 where c2 > 60 and c4 = 1 limit 20000, 1;
select * from t1 where c2 > 60 order by c2 desc limit 20000, 1;
select * from t1 where c2 = 1 order by c3 desc limit 20000, 1;
select * from t1 where c2 > 60 order by c4 desc limit 20000, 1;

select /*+index(t1 i1)*/ * from t1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 >=0 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 and c3 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 and c4 = 1 limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 order by c2 desc limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 = 1 order by c3 desc limit 20000, 1;
select /*+index(t1 i1)*/ * from t1 where c2 > 60 order by c4 desc limit 20000, 1;

drop table t1;