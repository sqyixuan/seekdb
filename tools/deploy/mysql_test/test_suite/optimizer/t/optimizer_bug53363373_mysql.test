--enable_result_log

--enable_sorted_result

SELECT * FROM table100_bigint WHERE (col_bigint, col_decimal_20_0) 
NOT IN ( SELECT pk, col_decimal_20_0 FROM table1_bigint partition (p0) WHERE col_char_20 != SUBSTR( HEX( SUBSTR( 'FBDCE' , 1, 20) ) , 1, 20) ORDER BY col_char_20  , col_char_20 ASC , col_char_20 ASC , col_char_20 DESC , pk  ) 
ORDER BY 1 DESC, pk ASC FOR UPDATE;

SELECT * FROM table100_bigint WHERE (col_bigint, col_decimal_20_0) 
NOT IN ( SELECT pk, col_decimal_20_0 FROM table1_bigint partition (p1) WHERE col_char_20 != SUBSTR( HEX( SUBSTR( 'FBDCE' , 1, 20) ) , 1, 20) ORDER BY col_char_20  , col_char_20 ASC , col_char_20 ASC , col_char_20 DESC , pk  ) 
ORDER BY 1 DESC, pk ASC FOR UPDATE;

DROP TABLE `table100_bigint`;
DROP TABLE `table1_bigint`;

--disable_query_log
connection sys;
eval alter tenant sys set primary_zone = "$saved_primary_zone";
--enable_query_log
