#owner: zhanyue.zzy
#owner group: sql1
#tags: optimizer
#description: allocate multi part dml for select for update when is result local

--result_format 4

--disable_query_log
connect (sys,$OBMYSQL_MS0,root,"",oceanbase,$OBMYSQL_PORT);
connection sys;
let $saved_primary_zone=`select primary_zone from oceanbase.__all_tenant where tenant_name = 'sys'`;
alter tenant sys set primary_zone = 'RANDOM';
sleep 2;

connection default;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS `table100_bigint`;
DROP TABLE IF EXISTS `table1_bigint`;
--enable_warnings

--disable_result_log
CREATE TABLE `table100_bigint` (
  `col_char_20` char(20) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  PRIMARY KEY (`pk`)
) ;

CREATE TABLE `table1_bigint` (
  `col_bigint` bigint(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_char_20` char(20) DEFAULT NULL,
  `col_timestamp_6` timestamp(6) NULL DEFAULT NULL,
  PRIMARY KEY (`pk`)
) partition by hash(`pk`) partitions 2;

