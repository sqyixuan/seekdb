#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_result_log
create table t1(a int primary key, b int, c int) partition by hash(a) partitions 2;
create index idx on t1(b) partition by range columns(b) (partition p0 values less than (1), partition p1 values less than (100));

--disable_query_log
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2
--error 1526
insert into t1 values(2, 101, 1);

drop table if exists t1;
