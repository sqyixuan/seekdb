--disable_warnings
drop table if exists tbl_805, tbl_416;
--enable_warnings

CREATE TABLE `tbl_805` (
  `col_13293` int(10) unsigned NOT NULL DEFAULT '4185936690',
  `col_13294` char(159) DEFAULT NULL,
  UNIQUE KEY `idx_1568` (`col_13293`, `col_13294`) LOCAL
) partition by range(col_13293)
(partition p0 values less than (86346407),
partition p1 values less than (4279228207));

CREATE TABLE `tbl_416` (
  `col_6895` mediumint(9) NOT NULL DEFAULT '2498612',
  `col_6896` set('Alice','Bob','Charlie','David') NOT NULL,
  `col_6897` bit(51) NOT NULL,
  `col_6898` set('Alice','Bob','Charlie','David') NOT NULL,
  PRIMARY KEY (`col_6895`, `col_6898`, `col_6897`, `col_6896`),
  KEY `idx_805` (`col_6897`, `col_6895`) LOCAL
) partition by range(col_6895)
(partition p0 values less than (8048790),
partition p1 values less than (MAXVALUE));

--result_format 4
--explain_protocol 2
select 1 from  tbl_805 as ref_49 inner join tbl_416 as ref_50 on ref_49.col_13293 = ref_50.col_6895;

drop table tbl_805, tbl_416;
