# owner: lijinmao.ljm
# owner group: SQL1
# tags: optimizer,cross_validation

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings

alter system flush plan cache;

create table t2(c1 varchar(3));
create index i1 on t2(c1);
insert into t2 values('aaa');
insert into t2 values('哈哈哈');
insert into t2 values('aa\0');
insert into t2 values('哈哈\0');

create table t3(c1 varchar(3) character set utf16);
create index i2 on t3(c1);
insert into t3 values('aaa');
insert into t3 values('哈哈哈');

create table t4(c1 varchar(3) collate latin1_german2_ci);
create index i1 on t4(c1);
insert into t4 values('a');
insert into t4 values('aa');
insert into t4 values('aaa');
insert into t4 values('a%');
insert into t4 values('a_');
insert into t4 values('a\0');

create table t5(c1 varchar(3) collate utf8mb4_hu_0900_as_cs);
create index i1 on t5(c1);
insert into t5 values('ac');
insert into t5 values('aC');
insert into t5 values('acs');
insert into t5 values('acz');
insert into t5 values('aD');

create table t1 (c1 varchar(20));
insert into t1 values ("a%"),("aa%"),("aaa%"),("aaaa%"),("a_"),("aa_"),("aaa_"),("aaaa_");
insert into t1 values ("哈%"),("哈哈%"),("哈哈哈%"),("哈哈哈哈%"),("哈_"),("哈哈_"),("哈哈哈_"),("哈哈哈哈_");

--explain_protocol 2
--result_format 4

#
# utf-8 -> mb
#
select * from t2 where c1 like "a%";
select * from t2 where c1 like "哈%";
select * from t2 where c1 like "aa%";
select * from t2 where c1 like "哈哈%";
select * from t2 where c1 like "aaa%";
select * from t2 where c1 like "哈哈哈%";
select * from t2 where c1 like "aaaa%";
select * from t2 where c1 like "哈哈哈哈%";
select * from t2 where c1 like "a_";
select * from t2 where c1 like "哈_";
select * from t2 where c1 like "aa_";
select * from t2 where c1 like "哈哈_";
select * from t2 where c1 like "aaa_";
select * from t2 where c1 like "哈哈哈_";
select * from t2 where c1 like "aaaa_";
select * from t2 where c1 like "哈哈哈哈_";
select /*+index(t2 i1)*/ * from t1, t2 where t2.c1 like t1.c1;

#
# utf-16 ->generic
#

select * from t3 where c1 like _utf16 0x00610025;
select * from t3 where c1 like _utf16 0x54C80025;
select * from t3 where c1 like _utf16 0x006100610025;
select * from t3 where c1 like _utf16 0x54C854C80025;
select * from t3 where c1 like _utf16 0x0061006100610025;
select * from t3 where c1 like _utf16 0x54C854C854C80025;
select * from t3 where c1 like _utf16 0x00610061006100610025;
select * from t3 where c1 like _utf16 0x54C854C854C854C80025;
select * from t3 where c1 like _utf16 0x0061005F;
select * from t3 where c1 like _utf16 0x54C8005F;
select * from t3 where c1 like _utf16 0x00610061005F;
select * from t3 where c1 like _utf16 0x54C854C8005F;
select * from t3 where c1 like _utf16 0x006100610061005F;
select * from t3 where c1 like _utf16 0x54C854C854C8005F;
select * from t3 where c1 like _utf16 0x0061006100610061005F;
select * from t3 where c1 like _utf16 0x54C854C854C854C8005F;
select /*+index(t3 i2)*/ * from t1, t3 where t3.c1 like t1.c1;

#
# latin1 -> simple
#
set collation_connection='latin1_german2_ci';

select * from t4 where c1 like "a%";
select * from t4 where c1 like "aaaaa%";
select * from t4 where c1 like "a_";
select * from t4 where c1 like "aaaaa_";
select * from t4 where c1 like "a\0%";
select * from t4 where c1 like "a\%%";
select * from t4 where c1 like "a%\%";
select * from t4 where c1 like "a_%";
select * from t4 where c1 like "a\_%";
select * from t4 where c1 like "a%\_";

#
# \0 and invalid character
#
set collation_connection='utf8mb4_general_ci';
select * from t2 where c1 like 'a\0';
select * from t2 where c1 like '哈\0';
select * from t2 where c1 like 'a\0%';
select * from t2 where c1 like '哈\0%';
select * from t2 where c1 like 'a\0_';
select * from t2 where c1 like '哈\0_';
select * from t2 where c1 like 'aa\0';
select * from t2 where c1 like '哈哈\0';
select * from t2 where c1 like 'aa\0%';
select * from t2 where c1 like '哈哈\0%';
select * from t2 where c1 like 'aa\0_';
select * from t2 where c1 like '哈哈\0_';
select * from t2 where c1 like 0x6125;
select * from t2 where c1 like 0x61ff25;
select * from t2 where c1 like 0x6125ff;

#
# uca
#
set collation_connection='utf8mb4_hu_0900_as_cs';

select * from t5 order by c1;
select * from t5 where c1 like 'a%';
select * from t5 where c1 like 'ac%';


drop table t1, t2, t3, t4, t5;