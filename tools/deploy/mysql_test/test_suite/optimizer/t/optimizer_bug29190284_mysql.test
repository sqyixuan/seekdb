#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_result_log
create table t1 (c1 int primary key, c2 int, c3 int) partition by hash (c1) partitions 3;
insert into t1 (c1) values (1),(2),(3),(4);

--disable_query_log
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select /*+NO_REWRITE*/ count(*) from t1 group by 1 + (select 1 > all (select 0));

drop table if exists t1;
