--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

--result_format 4
--explain_protocol 2

select t1.c1 from t1,t2 where (t1.c1 and t2.c1) or (not 2014);

drop table t1;
drop table t2;