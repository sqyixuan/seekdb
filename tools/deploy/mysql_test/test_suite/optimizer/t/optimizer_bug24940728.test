--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(a int, b int, c int, primary key(a,b));
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(b) partitions 4;

--disable_query_log
insert into t1 values (1,1,1), (1,2,2), (1,3,4), (2,5,6),(3,3,5),(4,5,6),(5,6,4);
insert into t2 values (1,1,1), (1,2,2), (1,3,4), (2,5,6),(3,3,5),(4,5,6),(5,6,4);
--disable_result_log
select count(*) from t1;
select count(*) from t2;
set _GROUPBY_NOPUSHDOWN_CUT_RATIO = 1;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
select /*+no_use_hash_aggregation*/ a, sum(b) from t1 group by a order by a;
select /*+no_use_hash_aggregation, parallel(2)*/ a, sum(b) from t1 group by a order by a;

select /*+no_use_hash_aggregation*/ a, sum(b) from t2 group by a order by a;
select /*+no_use_hash_aggregation, parallel(16)*/ a, sum(b) from t2 group by a order by a;

select /*+no_use_hash_aggregation*/ distinct a from t1 order by a;
select /*+no_use_hash_aggregation, parallel(2)*/ distinct a from t1 order by a;

select /*+no_use_hash_aggregation*/ distinct a from t2 order by a;
select /*+no_use_hash_aggregation, parallel(16)*/ distinct a from t2 order by a;

--disable_query_log
set _GROUPBY_NOPUSHDOWN_CUT_RATIO = 3;
--enable_query_log
