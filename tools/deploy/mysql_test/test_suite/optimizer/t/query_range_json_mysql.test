## test for row in query range

--disable_warnings
drop table if exists customers;
--enable_warnings
--explain_protocol 0
CREATE TABLE customers (
    id BIGINT not null primary key,
    modified  BIGINT not null,
    custinfo JSON,
    INDEX zips1( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);

INSERT INTO customers VALUES 
  (10, 21, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}'),
  (11, 22, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}'),
  (12, 23, '{"user":"Bob","user_id":31,"zipcode":[94477,94507]}'),
  (13, 24, '{"user":"Mary","user_id":72,"zipcode":[94536]}'),
  (14, 25, '{"user":"Ted","user_id":56,"zipcode":[94507,94582]}');

--result_format 4
--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode');
SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode');

--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers 
  WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));
SELECT * FROM customers 
  WHERE JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));
SELECT * FROM customers
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers 
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', 
                      CAST('[94507,94582,34723,23014,10739,21732,94573,27320,28230,29273,82392]' AS JSON));
SELECT * FROM customers 
  WHERE JSON_OVERLAPS(custinfo->'$.zipcode', 
                      CAST('[94507,94582,34723,23014,10739,21732,94573,27320,28230,29273,82392]' AS JSON));

--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode') OR
        94582 MEMBER OF(custinfo->'$.zipcode');
SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode') OR
        94582 MEMBER OF(custinfo->'$.zipcode');

--replace_regex /_[0-9]+/_xxx/
explain SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode') AND
  JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));
SELECT * FROM customers 
  WHERE 94507 MEMBER OF(custinfo->'$.zipcode') AND
  JSON_CONTAINS(custinfo->'$.zipcode', CAST('[94507,94582]' AS JSON));

--disable_warnings
drop table if exists customers;
--enable_warnings

CREATE TABLE customers (
    id BIGINT not null primary key,
    c1 BIGINT not null,
    modified  BIGINT not null,
    custinfo JSON,
    INDEX comp(c1, modified,
        (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY)) )
);

INSERT INTO customers VALUES 
  (10, 21, 101, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}'),
  (11, 22, 102, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}'),
  (12, 23, 103, '{"user":"Bob","user_id":31,"zipcode":[94477,94507]}'),
  (13, 24, 104, '{"user":"Mary","user_id":72,"zipcode":[94536]}'),
  (14, 25, 105, '{"user":"Ted","user_id":56,"zipcode":[94507,94582]}');

--replace_regex /_[0-9]+/_xxx/
explain select * from customers 
  where c1 = 23 and modified = 103 and  94507 MEMBER OF(custinfo->'$.zipcode');

select * from customers 
  where c1 = 23 and modified = 103 and  94507 MEMBER OF(custinfo->'$.zipcode');
  
--explain_protocol 0
--disable_warnings
drop table if exists customers;
--enable_warnings
