# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer,cross_validation 

--result_format 4
--enable_sorted_result

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (c1 int, c2 int);
insert into t1 values (1,0);
create table t2 (c1 int, c2 int);
insert into t2 values (1,1),(1,2),(2,1),(2,2);

--result_format 4
explain update /*+parallel(2) enable_parallel_dml use_concat*/ t1 left join t2 on t1.c1 = t2.c2 set t1.c2 = t2.c2 where t1.c1 = 1 or t2.c1 = 2;
update /*+parallel(2) enable_parallel_dml use_concat*/ t1 left join t2 on t1.c1 = t2.c2 set t1.c2 = t2.c2 where t1.c1 = 1 or t2.c1 = 2;
select * from t1;

drop table t1,t2;
