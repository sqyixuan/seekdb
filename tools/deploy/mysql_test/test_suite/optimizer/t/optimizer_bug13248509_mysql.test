--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:link.zt
#owner group: sql1
# tags: optimizer
#this file try to verify the output rows estimated from storage engine

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int, c int, primary key(a,b), key idx_c(c) local) partition by hash(a) partitions 2;
## all the data are in memory
--let $count = 0
while($count < 500)
{
  --let $stmt=insert into t1(a, b, c) values (1, $count, 1)
  eval $stmt;
  inc $count;
}

--let $count = 500
while($count < 2000)
{
  --let $stmt=insert into t1(a, b, c) values (2, $count, 2)
  eval $stmt;
  inc $count;
}
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');

select count(*) from t1 partition(p0) where a = 1;
select count(*) from t1 partition(p1) where a = 1;
select count(*) from t1 partition(p0) where a = 2;
select count(*) from t1 partition(p1) where a = 2;
explain select count(*) from t1 where c = 1;
explain select count(*) from t1 where c = 2;

