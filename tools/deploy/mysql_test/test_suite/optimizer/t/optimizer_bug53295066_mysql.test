CREATE TABLE T_VARBINARY_40 (c1 int primary key, c2 VARBINARY(40), key I_VARBINARY_40(c2));
CREATE TABLE T_TINYBLOB (c1 int primary key, c2 TINYBLOB);
CREATE TABLE T_BLOB (c1 int primary key, c2 BLOB);
CREATE TABLE T_MEDIUMBLOB (c1 int primary key, c2 MEDIUMBLOB);
CREATE TABLE T_LONGBLOB (c1 int primary key, c2 LONGBLOB);
