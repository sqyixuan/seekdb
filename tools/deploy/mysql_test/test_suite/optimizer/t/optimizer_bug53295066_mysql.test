CREATE TABLE T_TINYTEXT (c1 int primary key, c2 TINYTEXT);
CREATE TABLE T_MEDIUMTEXT (c1 int primary key, c2 MEDIUMTEXT);
CREATE TABLE T_LONGTEXT (c1 int primary key, c2 LONGTEXT);
EXPLAIN SELECT /*+ LEADING(T1 T2) USE_NL(T2) */ T2.C1,T2.C1 FROM T_TINYINT T1, T_SMALLINT T2 WHERE T1.C2 = T2.C2;
