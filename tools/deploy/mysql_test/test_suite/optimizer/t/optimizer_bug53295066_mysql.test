--enable_warnings
CREATE TABLE T_TINYINT (c1 int primary key, c2 TINYINT, key I_TINYINT(c2));
CREATE TABLE T_SMALLINT (c1 int primary key, c2 SMALLINT, key I_SMALLINT(c2));
CREATE TABLE T_MEDIUMINT (c1 int primary key, c2 MEDIUMINT, key I_MEDIUMINT(c2));
CREATE TABLE T_INTEGER (c1 int primary key, c2 INTEGER, key I_INTEGER(c2));
CREATE TABLE T_BIGINT (c1 int primary key, c2 BIGINT, key I_BIGINT(c2));
CREATE TABLE T_DECIMAL (c1 int primary key, c2 DECIMAL, key I_DECIMAL(c2));
CREATE TABLE T_DECIMAL_20_10 (c1 int primary key, c2 DECIMAL(20, 10), key I_DECIMAL_20_10(c2));
CREATE TABLE T_DECIMAL_20_1 (c1 int primary key, c2 DECIMAL(20, 1), key I_DECIMAL_20_1(c2));
CREATE TABLE T_DECIMAL_10_1 (c1 int primary key, c2 DECIMAL(10, 1), key I_DECIMAL_10_1(c2));
CREATE TABLE T_DECIMAL_10_10 (c1 int primary key, c2 DECIMAL(10, 10), key I_DECIMAL_10_10(c2));
CREATE TABLE T_FLOAT (c1 int primary key, c2 FLOAT, key I_FLOAT(c2));
CREATE TABLE T_DOUBLE (c1 int primary key, c2 DOUBLE, key I_DOUBLE(c2));
CREATE TABLE T_BIT (c1 int primary key, c2 BIT, key I_BIT(c2));
CREATE TABLE T_BIT_10 (c1 int primary key, c2 BIT(10), key I_BIT_10(c2));
CREATE TABLE T_BIT_20 (c1 int primary key, c2 BIT(20), key I_BIT_20(c2));
CREATE TABLE T_DATE (c1 int primary key, c2 DATE, key I_DATE(c2));
CREATE TABLE T_TIME (c1 int primary key, c2 TIME, key I_TIME(c2));
CREATE TABLE T_DATETIME (c1 int primary key, c2 DATETIME, key I_DATETIME(c2));
CREATE TABLE T_TIMESTAMP (c1 int primary key, c2 TIMESTAMP, key I_TIMESTAMP(c2));
CREATE TABLE T_YEAR (c1 int primary key, c2 YEAR, key I_YEAR(c2));
CREATE TABLE T_CHAR_20 (c1 int primary key, c2 CHAR(20), key I_CHAR_20(c2));
CREATE TABLE T_CHAR_30 (c1 int primary key, c2 CHAR(30), key I_CHAR_30(c2));
CREATE TABLE T_CHAR_40 (c1 int primary key, c2 CHAR(40), key I_CHAR_40(c2));
CREATE TABLE T_VARCHAR_20 (c1 int primary key, c2 VARCHAR(20), key I_VARCHAR_20(c2));
CREATE TABLE T_VARCHAR_30 (c1 int primary key, c2 VARCHAR(30), key I_VARCHAR_30(c2));
CREATE TABLE T_VARCHAR_40 (c1 int primary key, c2 VARCHAR(40), key I_VARCHAR_40(c2));
CREATE TABLE T_BINARY_20 (c1 int primary key, c2 BINARY(20), key I_BINARY_20(c2));
CREATE TABLE T_BINARY_30 (c1 int primary key, c2 BINARY(30), key I_BINARY_30(c2));
