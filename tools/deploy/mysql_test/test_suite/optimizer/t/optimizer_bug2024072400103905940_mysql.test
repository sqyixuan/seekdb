# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop procedure if exists proc1;
--enable_warnings


CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` varchar(256) DEFAULT NULL,
  `c5` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) VIRTUAL,
  `c6` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) STORED,
  PRIMARY KEY (`c1`),
  KEY `i1` (`c4`(128)) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `t2` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` varchar(256) DEFAULT NULL,
  `c5` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) VIRTUAL,
  `c6` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) STORED,
  PRIMARY KEY (`c1`),
  KEY `i1` (`c4`(128)) BLOCK_SIZE 16384 LOCAL
) partition by hash(c1) partitions 4;

CREATE TABLE `t3` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` varchar(256) DEFAULT NULL,
  `c5` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) VIRTUAL,
  `c6` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) STORED,
  PRIMARY KEY (`c1`)
) partition by hash(c1) partitions 4;

create index i1 on t3(c4(128)) global;

CREATE TABLE `t4` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` varchar(256) NOT NULL,
  `c5` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) VIRTUAL,
  `c6` int(11) GENERATED ALWAYS AS ((`c3` + `c2`)) STORED,
  PRIMARY KEY (`c1`, `c4`),
  KEY `i1` (`c4`(128)) BLOCK_SIZE 16384 LOCAL
) 
partition by range columns(c1) subpartition by key(c4) subpartitions 4
(
partition p1 values less than (25000),
partition p2 values less than (50000),
partition p3 values less than (75000),
partition p4 values less than (MAXVALUE)
);

delimiter $$;
create procedure proc1(in args int)
begin
  declare i int;
  set i = 0;
  start transaction;
  while i < args do
    insert into t1(c1,c2,c3,c4) values(i, i, i, concat('C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_SLKJLDFLKJSKLDFJKLSDFJSL_DFJSKJKLSDJKLJSKDJFKLS_DJFSLLLLLLLLLLLLLLLLLLLLLLJJJJJJJJJJJJ_', i));
    set i = i+1;
	if i % 10000 = 0 then
	  commit;
	end if;
  end while;
  commit;
end $$
delimiter ;$$

call proc1(100000);
insert into t2 (c1, c2, c3, c4) select c1, c2, c3, c4 from t1;
insert into t3 (c1, c2, c3, c4) select c1, c2, c3, c4 from t1;
insert into t4 (c1, c2, c3, c4) select c1, c2, c3, c4 from t1;

call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T3');
call dbms_stats.gather_table_stats('TEST', 'T4');
--explain_protocol 2
--result_format 4
--enable_sorted_result
