--echo issue: 
--disable_warnings
DROP TABLE if exists table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_;
--enable_warnings
--result_format 4
set ob_query_timeout=6000000000;
CREATE TABLE table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_ (
  col_int int,
  pk int,
  col_tinyint tinyint,
  col_bigint bigint,
  col_float float,
  col_decimal_20_0 decimal(20,0),
  col_datetime datetime,
  col_smallint smallint)    PARTITION BY hash(pk)
                  subpartition by range columns(col_datetime)
                                subpartition template
                                             (subpartition p0 values less than ('2001-01-01 00:00:00'),
                                                    subpartition p1 values less than ('2003-01-01 00:00:00'),
                                                    subpartition p2 values less than ('2005-01-01 00:00:00'),
                                                    subpartition p3 values less than (maxvalue))
                                                  partitions 10  ;

create index idx4 on table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_ (col_decimal_20_0);

--explain_protocol 2
select /*+index(table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_ idx4) use_plan_cache(none)*/* from table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_ where col_decimal_20_0 in (1,7,4,2,9,4,1,1,5,0,4,9,3,9,9,1,7,6,5,2,5,9,1,5,6,4,5,5,0,1,9,0,0,4,3,0,3,4,3,9,3,9,7,2,4,2, 3) and col_decimal_20_0 <= 3 and pk < 7 and col_smallint <> 7 and col_decimal_20_0 in (1,4,8,9,9,3,1,8,1,4,2,6,1,6,8,0,5,1,2,9,0,0,8,8,6,6,3,1,4,3,8,0,9,4,3,7,6,0,7,6, 5) and col_decimal_20_0 <= 8 and col_datetime >= 5 and pk >= 9 and col_decimal_20_0 in (3,2,0,2,5,9,8,8,0,3,8,8,1,2,0,7,9,2,3, 1) order by 1,2,3,4,5,6;
--explain_protocol 0

set ob_query_timeout=10000000;
--disable_warnings
DROP TABLE if exists table1000_hash_pk_subpart_by_range_columns_col_datetime_subpart_;
--enable_warnings
