# owner group: SQL1
# tags: optimizer, cross_validation
# issue: 

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int as(c1+c2), c4 int, c5 int as (c1+c4) stored) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than MAXVALUE
);

insert into t1(c1,c2,c4) values(1,1,1),(102,102,102),(203,203,203);

create index i1 on t1(c3);
create index i2 on t1(c5);

--echo #test virtual generated column

--echo ##index back is false

explain select count(c3) from t1;
select count(c3) from t1;

--echo ##index back is true

explain select count(c3),c1 from t1;
select count(c3),c1 from t1;

explain select count(c3),c4 from t1;
select count(c3),c1 from t1;

explain select /*+index(t1 i1)*/ count(c3),c4 from t1;
select /*+index(t1 i1)*/ count(c3),c4 from t1;

--echo #test stored generated column

--echo ##index back is false
explain select count(c5) from t1;
select count(c5) from t1;

--echo ##index back is true

explain select count(c5),c2 from t1;
select count(c5),c2 from t1;

explain select /*+index(t1 i2)*/ count(c5),c2 from t1;
select /*+index(t1 i2)*/ count(c5),c2 from t1;

explain select count(c5),c1,c4 from t1;
select count(c5),c1 from t1;

explain select /*+index(t1 i1)*/count(c5),c1,c4 from t1;
select /*+index(t1 i1)*/count(c5),c1,c4 from t1;


explain select count(c3) from t1 where c1 < 100;
select count(c3) from t1 where c1 < 100;

explain select /*+index(t1 primary)*/ count(c3) from t1 where c1 < 100;
select /*+index(t1 primary)*/ count(c3) from t1 where c1 < 100;

drop table t1;

create table t1(
  id bigint(20) not null auto_increment,
  test_json json,
  json_ind_col varchar(30) as (json_unquote(json_extract(test_json,'$.name'))) stored,
  primary key(id),
  key idx_json_index(json_ind_col)
);

explain select count(json_ind_col) from t1;
select count(json_ind_col) from t1;

explain select /*+index(t1 primary)*/ count(json_ind_col) from t1;
select /*+index(t1 primary)*/ count(json_ind_col) from t1;

drop table t1;