CREATE TABLE `to_taxtypeconfig` (
  `serial_id` bigint(20) NOT NULL DEFAULT '0',
  `solution_id` int(11) NOT NULL DEFAULT '0',
  `taxasset_type` tinyint(4) NOT NULL DEFAULT '0',
  `taxplan_type` varchar(20) NOT NULL DEFAULT '',
  `taxbase_type` tinyint(4) NOT NULL DEFAULT '0',
  `tax_flag` tinyint(4) NOT NULL DEFAULT '0',
  `tax_rate` decimal(19,12) NOT NULL DEFAULT '0.000000000000',
  `tax_freecode` varchar(20) NOT NULL DEFAULT '',
  `iscarryover` tinyint(4) NOT NULL DEFAULT '0',
  `taxinput_state` tinyint(4) NOT NULL DEFAULT '0',
  `user_operate` bigint(20) NOT NULL DEFAULT '0',
  `dtime_operate` decimal(14,6) NOT NULL DEFAULT '0.000000',
  `user_verify` bigint(20) NOT NULL DEFAULT '0',
  `dtime_verify` decimal(14,6) NOT NULL DEFAULT '0.000000',
  PRIMARY KEY (`serial_id`),
  KEY `Idx_TaxTypeConfig_1` (`solution_id`, `taxplan_type`, `taxbase_type`)
);
