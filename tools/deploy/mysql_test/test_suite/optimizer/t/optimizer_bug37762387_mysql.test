SET @seq_curvalue = 0;
SET @rownum := 0;
SET @total_num = 0;
SELECT count( 1 ) INTO @total_num 
FROM  to_taxsoulution a,  to_taxtypeconfig b 
WHERE b.taxplan_type IN ( 'STDBondForward02' ) 
  AND b.solution_id = - 1
  AND a.taxlevy_method = 2
  AND a.solution_type = 1
  AND a.solution_id NOT IN ( SELECT DISTINCT ( c.solution_id ) FROM to_taxtypeconfig c WHERE c.taxplan_type IN ( 'STDBondForward02' ) );

SELECT a.seq_curvalue INTO @seq_curvalue FROM  tsequence a WHERE  a.seq_name = 'seq_totaxtypeconfig';

--explain_protocol 2
--result_format 4
INSERT INTO to_taxtypeconfig ( serial_id, solution_id, taxplan_type, taxbase_type, tax_flag, tax_rate, tax_freecode, iscarryover, user_operate, taxinput_state, taxasset_type )
SELECT
( SELECT @rownum := @rownum + 1 ) + @seq_curvalue AS serial_id,
a.solution_id,
b.taxplan_type,
b.taxbase_type,
b.tax_flag,
b.tax_rate,
b.tax_freecode,
b.iscarryover,
0 AS user_operate,
b.taxinput_state,
b.taxasset_type 
FROM
  to_taxsoulution a,
  to_taxtypeconfig b 
WHERE
  b.taxplan_type IN ( 'STDBondForward02' )   
  AND b.solution_id = - 1
  AND a.taxlevy_method = 2
  AND a.solution_type = 1
  AND a.solution_id NOT IN ( SELECT DISTINCT ( c.solution_id ) FROM to_taxtypeconfig c WHERE c.taxplan_type IN ( 'STDBondForward02' ) );

UPDATE tsequence SET seq_curvalue = @seq_curvalue + @total_num WHERE  seq_name = 'seq_totaxtypeconfig';

drop table tsequence,to_taxsoulution,to_taxtypeconfig;