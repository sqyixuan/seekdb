--disable_warnings
drop table if exists tsequence,to_taxsoulution,to_taxtypeconfig;
--enable_warnings

 CREATE TABLE `tsequence` (
  `sort_id` decimal(5,0) NOT NULL DEFAULT '0',
  `seq_name` varchar(32) NOT NULL DEFAULT ' ',
  `seq_cachsize` decimal(10,0) NOT NULL DEFAULT '0',
  `seq_curvalue` decimal(20,0) NOT NULL DEFAULT '0',
  `seqvalue_max` decimal(20,0) NOT NULL DEFAULT '0',
  `comments` varchar(128) NOT NULL DEFAULT ' ',
  PRIMARY KEY (`seq_name`)
);
insert into tsequence values (0,'seq_totaxtypeconfig',1000,5000,9999999999999999,'增值税品种方案设置表序号');

CREATE TABLE `to_taxsoulution` (
  `rowid` bigint(20) NOT NULL AUTO_INCREMENT,
  `solution_id` int(11) NOT NULL DEFAULT '0',
  `solution_code` varchar(32) NOT NULL DEFAULT '',
  `solution_name` varchar(128) NOT NULL DEFAULT '',
  `solution_type` tinyint(4) NOT NULL DEFAULT '0',
  `taxlevy_method` tinyint(4) NOT NULL DEFAULT '0',
  `description` varchar(500) NOT NULL DEFAULT '',
  `manager_id` int(11) NOT NULL DEFAULT '0',
  `user_operate` bigint(20) NOT NULL DEFAULT '0',
  `dtime_operate` decimal(14,6) NOT NULL DEFAULT '0.000000',
  `isdefault` tinyint(4) NOT NULL DEFAULT '0',
  PRIMARY KEY (`rowid`),
  KEY `Idx_TaxSoulution_1` (`solution_code`, `solution_type`),
  KEY `Idx_TaxSoulution_2` (`solution_id`)
) ;
