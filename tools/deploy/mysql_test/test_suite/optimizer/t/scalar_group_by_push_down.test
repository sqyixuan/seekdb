--result_format 4
--explain_protocol 2
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer

##
## Test Name: scalar_group_by_push_down
##
##
##

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, primary key(c1)) partition by hash(c1) partitions 4;


--let $i=0
--disable_query_log
--disable_result_log
while($i<1000)
{
  eval insert into t1 values($i, 2, $i * 1.0 / 100);
  inc $i;
}
--enable_query_log
--enable_result_log

--echo # should use hash
select count(distinct c2) from t1;

--echo # should use merge without sort 
select count(distinct c1) from t1;

--echo # should use merge without sort 
select count(distinct c2) from t1 where c1 = c2;

select /*+ use_hash_aggregation() */ count(distinct c1) from t1;
select /*+ no_use_hash_aggregation() */ count(distinct c1) from t1;
select /*+ use_hash_aggregation() */ count(distinct c2) from t1;
select /*+ no_use_hash_aggregation() */ count(distinct c2) from t1;

select count(distinct c3) from t1;
select /*+ use_hash_aggregation() */ count(distinct c3) from t1;
select /*+ no_use_hash_aggregation() */ count(distinct c3) from t1;

select count(distinct c2) from t1 group by c3;
select count(distinct c3) from t1 group by c2;
select count(c2) from t1 group by c3;
select count(c3) from t1 group by c2;

--echo # non-partition table
create table t2 (c1 int, c2 int, c3 int);

--let $i=0
--disable_query_log
--disable_result_log
while($i<1000)
{
  eval insert into t2 values($i, 2, $i / 100);
  inc $i;
}
--enable_query_log
--enable_result_log

select count(distinct c2) from t2;
select /*+ use_hash_aggregation() */ count(distinct c2) from t2;
select /*+ no_use_hash_aggregation() */ count(distinct c2) from t2;

select count(distinct c3) from t2;
select /*+ use_hash_aggregation() */ count(distinct c3) from t2;
select /*+ no_use_hash_aggregation() */ count(distinct c3) from t2;

select count(distinct c2) from t2 group by c3;
select count(distinct c3) from t2 group by c2;

create table t3 (c1 int, c2 int) partition by hash(c1) partitions 4;

--disable_query_log
--disable_result_log
insert into t3 values(1,1);
--enable_query_log
--enable_result_log

select c2, sum(c1) from t3;

drop table t1, t2, t3;
