select count(*) from t41;
select count(*) from t68;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

SELECT /*+ parallel(2) LEADING(t68_87222 t41_805) */ count(*) FROM ( SELECT t41_805.c1, t41_805.c2 FROM t41 AS t41_805 ) AS t41_805 RIGHT OUTER JOIN t68 AS t68_87222 ON t41_805.c2 = t68_87222.c4 AND t41_805.c1 < 135 OR t41_805.c2 = 986 OR t41_805.c2 = t68_87222.c6 WHERE t41_805.c2 <= 8 AND t41_805.c2 = t41_805.c1 OR t41_805.c1 < t41_805.c2 ORDER BY 1;

SELECT /*+ 
     NO_PX_JOIN_FILTER(@"SEL$2" ("t41_805"@"SEL$2" ))
      LEADING(@"SEL$2" ("t68_87222"@"SEL$2" "t41_805"@"SEL$2"  ))
      USE_hash(@"SEL$2" ("t41_805"@"SEL$2" ))
      PQ_DISTRIBUTE(@"SEL$2" ("t41_805"@"SEL$2" )  partition none)
      PARALLEL(6)
  */
c2, c1 FROM (
SELECT t41_805.c2, t41_805.c1 from t41 AS t41_805, t68 AS t68_87222
where t41_805.c2 = t68_87222.c6
union all
SELECT 2 c2, 'abc' c1 from t68 where false
)order by c2;

SELECT /*+
      NO_PX_JOIN_FILTER(@"SEL$3" ("t41_805"@"SEL$3" ))
      LEADING(@"SEL$3" ("t68_87222"@"SEL$3" "t41_805"@"SEL$3"  ))
      USE_hash(@"SEL$3" ("t41_805"@"SEL$3" ))
      PQ_DISTRIBUTE(@"SEL$3" ("t41_805"@"SEL$3" ) partition none)
      PARALLEL(6)
  */
c2, c1 FROM (
SELECT 2 c2, 'abc' c1 from t68 where false
union all
SELECT t41_805.c2, t41_805.c1 from t41 AS t41_805, t68 AS t68_87222
where t41_805.c2 = t68_87222.c6
) order by c2;

SELECT /*+
      NO_PX_JOIN_FILTER(@"SEL$3" ("t41_805"@"SEL$3" ))
      LEADING(@"SEL$3" ("t68_87222"@"SEL$3" "t41_805"@"SEL$3"  ))
      USE_hash(@"SEL$3" ("t41_805"@"SEL$3" ))
      PQ_DISTRIBUTE(@"SEL$3" ("t41_805"@"SEL$3" ) partition none)
      NO_USE_PX
  */
c2, c1 FROM (
SELECT 2 c2, 'abc' c1 from t68 where false
union all
SELECT t41_805.c2, t41_805.c1 from t41 AS t41_805, t68 AS t68_87222
where t41_805.c2 = t68_87222.c6
) order by c2;

drop table t41, t68;

--enable_warnings
