#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t0, t1, t2, t3;
--enable_warnings

create table t0(pk int primary key, c1 int);
create table t1(c1 int, c2 int, c3 int) partition by hash (c1) partitions 4;
create table t2(c1 int, c2 int, c3 int) partition by hash (c1) partitions 4;
create table t3(c1 int);
set ob_enable_transformation = 0;
insert into t0 values (1, 1);
insert into t1 values (1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4);
insert into t2 values (1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4);
insert into t3 values (1), (2), (3), (4), (5), (1);

--result_format 4
--explain_protocol 1
select /*+parallel(t1 4) parallel(t2 4)*/ t1.c3, t2.c3, sum(t0.c1 * t2.c1) from t0, t1, t2 where t0.pk = 1 and t1.c2 = t2.c2 group by t1.c3, t2.c3 order by 1,2,3;
select /*+parallel(t1 4) parallel(t2 4) leading(t0 (t2 t1)) PQ_DISTRIBUTE((t2 t1) BROADCAST NONE)*/ t1.c3, t2.c3, sum(t0.c1 * t2.c1) from t0, t1, t2 where t0.pk = 1 and t1.c2 = t2.c2 group by t1.c3, t2.c3 order by 1,2,3;
select /*+parallel(t1 4) parallel(t2 4) leading(t0 (t2 t1)) PQ_DISTRIBUTE((t2 t1) BROADCAST NONE) NO_USE_NL_MATERIALIZATION((t2 t1))*/ t1.c3, t2.c3, sum(t0.c1 * t2.c1) from t0, t1, t2 where t0.pk = 1 and t1.c2 = t2.c2 group by t1.c3, t2.c3 order by 1,2,3;
select c1, (select group_concat(agg) from (select /*+parallel(t1 4) parallel(t2 4) no_use_das(t1) no_use_das(t2) leading(t0 (t2 t1)) PQ_DISTRIBUTE((t2 t1) BROADCAST NONE)*/ sum(t0.c1 * t2.c1) as agg from t0, t1, t2 where t0.pk = 1 and t1.c2 = t2.c2 and t2.c3 = t3.c1 group by t1.c3, t2.c3) v) as c2 from t3 order by 1,2;
select * from (with cte as (select c2, count(*) as cnt from t1 group by c2) select /*+parallel(4)*/ v1.c2 as v1c2, v1.cnt as v1cnt, v2.c2 as v2c2, v2.cnt as v2cnt from cte v1, cte v2) order by 1,2,3,4;
select * from (with cte as (select c2, count(*) as cnt from t1 group by c2) select /*+parallel(4) ordered pq_distribute(v2 BROADCAST NONE)*/ v1.c2 as v1c2, v1.cnt as v1cnt, v2.c2 as v2c2, v2.cnt as v2cnt from cte v1, cte v2) order by 1,2,3,4;
select * from (with cte as (select c2, count(*) as cnt from t1 group by c2) select /*+parallel(4) ordered pq_distribute(v2 BROADCAST NONE) NO_USE_NL_MATERIALIZATION(v2)*/ v1.c2 as v1c2, v1.cnt as v1cnt, v2.c2 as v2c2, v2.cnt as v2cnt from cte v1, cte v2) order by 1,2,3,4;

drop table t0, t1, t2;