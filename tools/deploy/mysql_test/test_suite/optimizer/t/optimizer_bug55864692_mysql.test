explain basic
(SELECT /*+ use_nl(t1 t2) leading(t1 t2) use_concat*/ t1.pk,t2.pk, 
                                                     (SELECT t4.col_decimal_20_0_index
                                                      FROM table10_key_pk_parts_10_int_not_null AS t4
                                                      WHERE t4.col_bigint_index > t1.col_double_index
                                                        AND t4.col_bigint_unique_index >= t1.col_bigint_index
                                                      ORDER BY 1 LIMIT 1) mm
   FROM table10_hash_pk_parts_10_int_not_null AS t1,
        table10_key_pk_parts_10_int_not_null AS t2
   WHERE t1.col_double_unique_index = t2.col_decimal_20_0_unique_index
     AND t2.col_double < t1.col_bigint_index
     AND t2.col_bigint_index < 2
     AND t1.col_varchar_20 NOT IN ('z')
     AND (t1.col_double_index,t1.col_bigint_index,t1.col_double,t1.col_bigint_unique_index) < (1,1,0,5)
     OR (t1.col_decimal_20_0_unique_index,t1.col_double_unique_index,t1.col_double) < (2,5,7)
   ORDER BY 1,2 LIMIT 100) 
INTERSECT
  (SELECT /*+ use_nl(t1 t2) leading(t1 t2) */ t1.pk,t2.pk, NULL
   FROM table10_hash_pk_parts_10_int_not_null AS t1,
        table10_key_pk_parts_10_int_not_null AS t2)
ORDER BY 1,2 LIMIT 11;

