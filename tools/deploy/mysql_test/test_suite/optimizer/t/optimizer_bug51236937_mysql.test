--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(a int);
create table t2(b int);
insert into t1 values (null),(1);
insert into t2 values (null),(1);

--result_format 4
--explain_protocol 2

select * from t1,t2 where a+b = a+b;
select * from t1,t2 where a+b <=> a+b;
select * from t1,t2 where (a<b) = (b>a);
select * from t1,t2 where (a<b) <=> (b>a);

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
