--echo issue: 
--disable_warnings
DROP TABLE if exists t1;
DROP TABLE if exists t2;
--enable_warnings
--result_format 4

create table t1(c1 varchar(20));
create table t2(c1 int primary key, c2 varchar(20));
create index idx on t2(c2);
--explain_protocol 2
select (select c2 from t2 where c1 in (3,8) and c2 in ('s','j') and c2 <= t1.c1) from t1;
--explain_protocol 0

--disable_warnings
DROP TABLE t1;
DROP TABLE t2;
--enable_warnings
