
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: lijinmao.ljm
# owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, tbl_175;
--enable_warnings

create TABLE t1 (a varchar(1500), b varchar(1570)) partition by list columns(a,b) ( partition p0 values in (('a','b'))); 
CREATE FULLTEXT INDEX idx on t1 (a,b); 

CREATE TABLE `tbl_175` (
  `col_3418` timestamp NULL DEFAULT '1990-11-01 00:00:00',
  `col_2656` bit(55) NOT NULL,
  `col_2657` mediumint(8) unsigned NOT NULL DEFAULT '326651',
  `col_2659` json DEFAULT NULL,
  `col_2660` float DEFAULT NULL,
  `col_2661` mediumint(9) NOT NULL DEFAULT '-1090080',
  `col_2662` smallint(5) unsigned DEFAULT NULL,
  `col_2663` char(142) CHARACTER SET latin1 DEFAULT '09',
  `col_2664` varchar(194) CHARACTER SET latin1 NOT NULL DEFAULT '~L@d~G98*_3-I&1t'
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'snappy_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by list(col_2657)
(partition `p0` values in (42323,2193825,2379185,4070333,5319371,7033511,7916106,7998569,8871011,9518474,9627558,10017556,10284002,11302111,11430433,12154931,12713573,13153861,14862105,15705982)) WITH COLUMN GROUP(each column);

--explain_protocol 1
--result_format 4

SELECT * FROM t1  WHERE MATCH (a,b) AGAINST ('+mail +MySQL' IN BOOLEAN MODE);

SELECT cast(1 AS CHAR) AS c0
FROM tbl_175 AS ref_1 
WHERE 1 NOT IN (CASE WHEN 0 THEN ref_1.col_2657 ELSE 11 END, 53);

drop table t1, tbl_175;