#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
--disable_warnings
drop table if exists t0;
--enable_warnings

create table t0(c1 int, c2 int, c3 int, c4 int, index i1(c1, c2, c3), index i2(c1, c4, c3, c2));
insert /*+query_timeout(100000000)*/ into t0 select uniform(1, 2, random(1)), uniform(1, 5, random(2)), uniform(1, 1000, random(3)), uniform(1, 2, random(4)) from table(generator(200000));

call dbms_stats.gather_table_stats(null, 't0');
set _enable_storage_cardinality_estimation = 0;

--enable_query_log
--result_format 4

explain select /*+index(t0 i1)*/ c2, max(c4) from t0 where c1 = 1 group by c2 limit 10;
explain select /*+index(t0 i2)*/ c2, max(c4) from t0 where c1 = 1 group by c2 limit 10;
explain select c2, max(c4) from t0 where c1 = 1 group by c2 limit 10;

explain select /*+index(t0 i1)*/ distinct c1, c2, c4 from t0 where c1 = 1 limit 10;
explain select /*+index(t0 i2)*/ distinct c1, c2, c4 from t0 where c1 = 1 limit 10;
explain select distinct c1, c2, c4 from t0 where c1 = 1 limit 10;

explain select /*+index(t0 i1)*/ c1, c2, c4 from t0 order by c1, c3 limit 10;
explain select /*+index(t0 i2)*/ c1, c2, c4 from t0 order by c1, c3 limit 10;
explain select c1, c2, c4 from t0 order by c1, c3 limit 10;

explain select /*+index(t0 i1)*/ c1, c2, c4, count(*) over (partition by c2) from t0 where c1 = 1 limit 10;
explain select /*+index(t0 i2)*/ c1, c2, c4, count(*) over (partition by c2) from t0 where c1 = 1 limit 10;
explain select c1, c2, c4, count(*) over (partition by c2) from t0 where c1 = 1 limit 10;

drop table t0;