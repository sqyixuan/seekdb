--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
#bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int);
insert into t1(c1) values (0), (1), (0), (-1), (-1), (1);

--result_format 4
--explain_protocol 2

select t1.c1 as t1c1 from t1 where t1.c1 is true group by t1c1;

select t1.c1 as t1c1 from t1 where t1.c1 is false group by t1c1;

select t1.c1 as t1c1 from t1 where (!((t1.c1) is not true)) group by t1c1;

select t1.c1 as t1c1 from t1 where (!((t1.c1) is true)) group by t1c1;

select t1.c1 as t1c1 from t1 where t1.c1 is true order by t1c1;

select t1.c1 as t1c1 from t1 where t1.c1 is false order by t1c1;

select t1.c1 as t1c1 from t1 where (!((t1.c1) is not true)) order by t1c1;

select t1.c1 as t1c1 from t1 where (!((t1.c1) is true)) order by t1c1;

--disable_warnings
drop table if exists t1;
--enable_warnings
