--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

--result_format 4

create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 8;

explain basic
select /*+parallel(1)*/ * from t1
union all
select c2, c1, c3 from t1;

explain basic
select /*+parallel(4)*/ * from t1
union all
select c2, c1, c3 from t1;

explain basic
select /*+parallel(8)*/ * from t1
union all
select c2, c1, c3 from t1;

explain basic
select /*+parallel(16) pq_set(@set$1 none none)*/ * from t1
union all
select c2, c1, c3 from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
