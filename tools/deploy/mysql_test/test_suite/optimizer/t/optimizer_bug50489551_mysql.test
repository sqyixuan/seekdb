# tags: optimizer,cross_validation
# issue: 

--disable_warnings
drop table if exists `t1`;
--enable_warnings

create table t1(c1 int(11) , c2 int(11) , c3 int(11), primary key (c2, c3)) partition by range columns(c2, c3) (partition p0 values less than (1,1), partition p1 values less than (100,100));

insert into t1 values (1, 0, 1);
insert into t1 values (2, 2, 0);

--explain_protocol 2
--result_format 4

insert INTO t1 (c2,c3) select c3, c2 from (select c2, c3 FROM t1  group by c2, c3);

select * from t1 where c1 =  1 and c2 = 0;

drop table if exists `t1`;
