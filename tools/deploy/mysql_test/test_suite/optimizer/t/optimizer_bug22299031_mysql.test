--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
#description: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(a int, b int, c int, primary key(a,b));
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
--disable_query_log
--disable_result_log
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(8,8,8),(9,9,9),(10,10,10);
select count(*) from t1;
select count(*) from t2;
set _GROUPBY_NOPUSHDOWN_CUT_RATIO = 1;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
insert into t1 select b, sum(a), sum(c) from t2 group by b;

--disable_query_log
--disable_result_log
select count(*) from t1;
--enable_result_log
--enable_query_log

select * from t1;

