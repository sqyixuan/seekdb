# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings
create table t1(c1 double(2,1) unsigned,KEY idx3319 (c1) );
create table t2(c1 double(2,1),KEY idx3319 (c1) );
create table t3(c1 double unsigned);
insert into t1 values (9.9);
insert into t1 values (0.);
insert into t2 values (9.9);
insert into t2 values (0.);
insert into t2 values (-9.9);
insert into t3 values (6.02E23);
insert into t3 values (1.175494351e-38);

--result_format 4
--explain_protocol 2
select * from t1 where c1 <= 6.02E23;
select * from t1 where c1 < 6.02E23;
select * from t1 where c1 > 6.02E23;
select * from t1 where c1 >= 6.02E23;
select * from t1 where c1 <= -6.02E23;
select * from t1 where c1 < -6.02E23;
select * from t1 where c1 > -6.02E23;
select * from t1 where c1 >= -6.02E23;

select /*+ leading(t3 t2) use_nl(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 = t3.c1;
select /*+ leading(t3 t2) use_hash(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 = t3.c1;

select /*+ leading(t3 t2) use_nl(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 <= t3.c1;
select /*+ leading(t3 t2) use_hash(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 <= t3.c1;

select /*+ leading(t3 t2) use_nl(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 < t3.c1;
select /*+ leading(t3 t2) use_hash(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 < t3.c1;

select /*+ leading(t3 t2) use_nl(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 >= t3.c1;
select /*+ leading(t3 t2) use_hash(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 >= t3.c1;

select /*+ leading(t3 t2) use_nl(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 > t3.c1;
select /*+ leading(t3 t2) use_hash(t2) */ t2.c1 as t2c1, t3.c1 as t3c1 from t2,t3 where t2.c1 > t3.c1;

DROP TABLE t1;
drop table t2;
drop table t3;