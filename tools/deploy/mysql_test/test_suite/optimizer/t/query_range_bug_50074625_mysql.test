# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer
set @@ob_enable_plan_cache = 0;

--result_format 4
--echo issue: 
--disable_warnings
DROP TABLE if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create index idx on t1(c1);
insert into t1 values(1,1,1),(5,1,5),(6,1,6);

--explain_protocol 3
select /*+index(t1 idx)*/ * from t1 where (c2, c1) <= (5,5) or c1 in (1,2);
select /*+full(t1)*/ * from t1 where (c2, c1) <= (5,5) or c1 in (1,2);
--explain_protocol 0

set @@ob_enable_plan_cache = 1;
--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
