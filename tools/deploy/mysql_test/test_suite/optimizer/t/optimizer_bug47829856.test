--echo ##test major freeze

create table t_part3 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t_subpart (c1 int, c2 int, c3 int) partition by hash(c1)
subpartition by hash(c2)
subpartition template
(
  subpartition p0,
  subpartition p1,
  subpartition p2
)
partitions 3;
--disable_query_log
--disable_result_log
