--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection conn_stat_test_sys_mysql;
use test;
alter system set _enable_adaptive_compaction = 1;

select count(*) from t_part3;
select count(*) from t_part3 where c2 = 100;
select count(*) from t_part3 where c2 > 100;
select count(*) from t_part3 where c2 < 100;
select count(*) from t_part3 partition(p0, p1);
select count(*) from t_part3 partition(p0, p1) where c3 = 100;
select count(*) from t_part3 partition(p0, p1) where c3 > 100;
select count(*) from t_part3 partition(p0, p1) where c3 < 100;
select count(*) from t_subpart;
select count(*) from t_subpart where c1 = 100;
select count(*) from t_subpart where c1 > 100;
select count(*) from t_subpart where c1 < 100;
select count(*) from t_subpart partition(p0sp0,p1sp2);
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 = 100;
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 > 100;
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 < 100;

--disable_query_log
--disable_result_log
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
insert into t_subpart select * from t_subpart;
--enable_query_log
--enable_result_log

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--sleep 5

select count(*) from t_subpart;
select count(*) from t_subpart where c1 = 100;
select count(*) from t_subpart where c1 > 100;
select count(*) from t_subpart where c1 < 100;
select count(*) from t_subpart partition(p0sp0,p1sp2);
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 = 100;
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 > 100;
select count(*) from t_subpart partition(p0sp0,p1sp2) where c2 < 100;

drop table if exists t_part1, t_part2, t_part3, t_subpart;
alter system set _enable_adaptive_compaction = 0;
##drop tenant
--source mysql_test/test_suite/histogram/include/drop_mysql_tenant.inc
connection default;
