--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
#tags: optimizer

--result_format 4

--disable_warnings
DROP TABLE IF EXISTS `ttm1`;
--enable_warnings

set range_index_dive_limit = -1;
set partition_index_dive_limit = -1;

create table ttm1(
  c1 bigint,
  c2 datetime,
  primary key (c2, c1)
)
partition by range columns(c2) subpartition by key(c1) subpartitions 5
(
partition p202411 values less than ('2024-12-01 00:00:00'),
partition p202412 values less than ('2025-01-01 00:00:00')
);

set @rownum=0;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-01 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-02 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-03 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-04 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-05 00:00:00' from table(generator(1000)) t;

call dbms_stats.gather_table_stats('TEST', 'TTM1', method_opt=>'FOR ALL COLUMNS SIZE 128');
--replace_regex /version=[^,]*/version=1234/
explain extended_noaddr select * from ttm1 where c2 = '2024-11-19 00:00:00';

set @rownum=0;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-11 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-12 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-13 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-14 00:00:00' from table(generator(1000)) t;
insert into ttm1 select @rownum:=@rownum+1, '2024-11-19 00:00:00' from table(generator(1000)) t;

call dbms_stats.gather_table_stats('TEST', 'TTM1', method_opt=>'FOR ALL COLUMNS SIZE 128');
--replace_regex /version=[^,]*/version=1234/
explain extended_noaddr select * from ttm1 where c2 = '2024-11-19 00:00:00';

drop table ttm1;
