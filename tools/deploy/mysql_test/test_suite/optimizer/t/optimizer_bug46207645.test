--enable_warnings
create table if not exists `t3tuwdx4` (
	`a` int(11),
	`b` int(11),
	`c` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (a)
(
	PARTITION `p0`,
	PARTITION `p1`,
	PARTITION `p2`,
	PARTITION `p3`
);

create table if not exists `test1p2u4tt` (
	`i1` int(11) not null,
	`i2` longtext,
	`i4` float,
	`i5` datetime(6),
	`i6` decimal(5,3),
	`i7` longtext,
	`i8` longtext,
	`i9` longtext,
	`i10` longtext,
	primary key (`i1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY HASH (i1)
(
	PARTITION `p0`,
	PARTITION `p1`
);
create index `gkey8oofvq` on `test1p2u4tt` (`i1` ASC, `i5` ASC) ;

CREATE TABLE `cool_business_service` (
  `business_service_id` int(11) NOT NULL AUTO_INCREMENT,
  `companytitle` varchar(255) DEFAULT NULL ,
  `service` varchar(255) DEFAULT NULL ,
  `imageface` varchar(255) DEFAULT NULL ,
  `contact` varchar(255) DEFAULT NULL ,
  `tel` varchar(30) DEFAULT NULL ,
  `change_time` varchar(20) DEFAULT NULL ,
  PRIMARY KEY (`business_service_id`)
) ENGINE=InnoDB AUTO_INCREMENT=39 DEFAULT CHARSET=utf8;

CREATE TABLE `t_kms_equip_group` (
  `group_id` varchar(36) NOT NULL COMMENT 'f分组id',
  `group_name` varchar(36) DEFAULT NULL COMMENT '分组名称',
  `equip_desc` varchar(255) DEFAULT NULL COMMENT '描述',
  `create_time` varchar(32) DEFAULT NULL COMMENT '创建时间',
  `app_id` varchar(36) DEFAULT NULL COMMENT '应用id',
  PRIMARY KEY (`group_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `cool_bill_20181008` (
  `bill_id` int(11) NOT NULL AUTO_INCREMENT,
  `trade_time` varchar(30) DEFAULT NULL ,
  `app_id` varchar(20) DEFAULT NULL ,
  `mch_id` varchar(30) DEFAULT NULL ,
  `sub_mch` varchar(30) DEFAULT NULL ,
  `device_id` varchar(50) DEFAULT NULL ,
  `wx_order` varchar(50) DEFAULT NULL ,
  `order_no` varchar(50) DEFAULT NULL ,
  `openid` varchar(50) DEFAULT NULL ,
  `trade_type` varchar(50) DEFAULT NULL ,
  `trade_status` varchar(50) DEFAULT NULL ,
  `bank` varchar(100) DEFAULT NULL ,
  `cny` varchar(20) DEFAULT NULL ,
  `total_money` varchar(20) DEFAULT NULL ,
  `redpacket_money` varchar(20) DEFAULT NULL ,
  `aprefund_time` varchar(30) DEFAULT NULL ,
  `surefund_time` varchar(30) DEFAULT NULL ,
  `wxrefund_no` varchar(50) DEFAULT NULL ,
  `mcrefund_no` varchar(50) DEFAULT NULL ,
  `refund_money` varchar(20) DEFAULT NULL ,
  `redpacket_refund_money` varchar(20) DEFAULT NULL ,
  `refund_type` varchar(20) DEFAULT NULL ,
  `refund_status` varchar(20) DEFAULT NULL ,
  `product_target_name` varchar(100) DEFAULT NULL ,
  `data_packet` varchar(255) DEFAULT NULL ,
  `fee` varchar(20) DEFAULT NULL ,
  `rate` varchar(20) DEFAULT NULL ,
  `business_id` varchar(100) DEFAULT NULL,
  `door_id` varchar(100) DEFAULT NULL,
  `pay_type` varchar(100) DEFAULT NULL ,
  `pay_pass` varchar(100) DEFAULT NULL,
  `agent_id` varchar(100) DEFAULT NULL ,
  `agent_fr_fee` varchar(100) DEFAULT NULL ,
  `qd_fr_fee` varchar(100) DEFAULT NULL ,
  `td_cost_fee` varchar(100) DEFAULT NULL ,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `bill_time` varchar(30) DEFAULT NULL,
  `channel_id` int(10) DEFAULT NULL ,
  `activity_type` varchar(30) DEFAULT NULL ,
  `pay_log_id` varchar(40) DEFAULT NULL ,
  `user_id` varchar(11) DEFAULT NULL ,
  PRIMARY KEY (`bill_id`),
  UNIQUE KEY `uiq_order_type_refund` (`order_no`,`trade_type`,`wxrefund_no`),
  KEY `mch_id_idx` (`mch_id`),
  KEY `agent_id_idx` (`agent_id`),
  KEY `bill_time_idx` (`bill_time`),
  KEY `trade_time_idx` (`trade_time`),
  KEY `business_id_idx` (`business_id`)
) ENGINE=InnoDB AUTO_INCREMENT=80478 DEFAULT CHARSET=utf8;

create table `int_varchar_pk` (
`c01` int(255),
`c02` numeric,
`c03` decimal(10,5),
`c04` bit(64),
`c05` tinyint(255),
`c06` smallint,
`c07` mediumint,
`c08` bigint,
`c09` float(20),
`c10` double,
`c11` varchar(255),
`c12` char(255),
`c13` tinytext,
`c14` mediumtext,
`c15` tinyblob,
`c16` longtext,
`c17` mediumblob,
`c18` longblob,
`c19` binary(255),
`c20` varbinary(255),
`c21` timestamp,
`c22` date,
`c23` time,
`c24` datetime,
`c25` year,
`c26` blob,
 primary key(`c01`,`c11`));

create table t1 (
	c1 int primary key,
	c2 int,
	c3 int
) partition by hash(c1) partitions 4;

create table t2 (
	c1 int primary key,
	c2 int,
	c3 int
) partition by hash(c1) partitions 4;

create table t3 (
	c1 int primary key,
	c2 int,
	c3 int
) partition by hash(c1) partitions 4;

create table t4 (
	c1 int,
	c2 int,
	c3 int
);
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
insert into t3 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
insert into t4 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
--explain_protocol 2
select ref_2.tel as c0, ref_0.b as c1, ref_2.companytitle as c2, ref_2.contact as c3, ref_1.i8 as c4 from (test.t3tuwdx4 as ref_0 right join ((test.test1p2u4tt as ref_1 inner join test.cool_business_service as ref_2 on (ref_1.i1 & 78)) inner join test.t_kms_equip_group as ref_3 on ((ref_2.business_service_id = ref_2.business_service_id) or (1))) on (ref_0.a = ref_2.business_service_id )) where EXISTS ( select max( cast(ref_4.c09 as DECIMAL(10, 2))) over (partition by ref_0.c,ref_4.c12,ref_0.b order by ref_2.change_time) as c0, ref_2.business_service_id as c1, ref_0.b as c2, (select count(bill_id) from test.cool_bill_20181008) as c3, ref_4.c11 as c4, ref_0.a as c5, ref_2.tel as c6, ref_2.imageface as c7 from test.int_varchar_pk as ref_4 where ref_4.c06 >> ref_2.business_service_id limit 103) limit 107 for update;

select * from t1 left join t4 on t1.c1 = t4.c1 where t1.c1 = 1 limit 10 for update;

--sorted_result
select /*+ parallel(2) use_hash(t3) leading(v t3) PQ_DISTRIBUTE(t3 NONE BROADCAST) */  * from t3, (select /*+ no_merge no_semi_to_inner leading(t2 t1) */ t1.c3,t1.c1 from t1 where exists (select /*+  */ * from t2 where t1.c1 = t2.c1) for update) v, t2 where t3.c2 = v.c1 and v.c1 = t2.c1 for update;

