--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group: sql1
# tags: optimizer

####TITEL: test index with order by
--disable_query_log
source mysql_test/include/index_quick_major.inc;
--real_sleep 10
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, pk2 varchar(10), c1 int, c2 int, c3 varchar(20), c4  timestamp(6) default "2012-01-01 12:00:00", c5 int, primary key(pk1, pk2));
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1,c2);
create index i4 on t1(c2, c3, c4);
create index i5 on t1(c2, c3) storing(c1);
create index i6 on t1(c3);

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(0,'0',0,0,'0','2014-11-03 08:00:00',0),
(0,'1',0,0,'0','2014-11-03 08:00:00',0),
(0,'2',1,0,'1','2014-11-03 08:00:01',0),
(0,'3',1,0,'1','2014-11-03 08:00:01',0);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(1,'0',2,1,'2','2014-11-03 08:00:02',0),
(1,'1',2,1,'2','2014-11-03 08:00:02',0),
(1,'2',3,1,'3','2014-11-03 08:00:03',0),
(1,'3',3,1,'3','2014-11-03 08:00:03',0);

select * from t1;

#### case 1: use t1
# case 1-1, order by, optimized;
echo case 1-1, order by, optimized;
update t1 set c5=0;

--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1=0 order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1=0 order by pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1=1 order by pk1, pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1=1 and pk2>'1' order by pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1>0 and pk1<2 and pk2<'2' order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1>-1 and pk1<2 order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1>=0 and pk1<=1 order by pk1, pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1>=0 and pk1<=1 and pk2='0' order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1 where pk1>=0 and pk1<=1 and pk2>'0' and pk2<='3' order by pk1, pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set c5=c5+1, c2=c2 where pk1=0 and pk2 not in(1,2) order by pk2;
--enable_result_log

update t1 set c5=c5+1 where pk1=0 order by pk1;
update t1 set c5=c5+1 where pk1=0 order by pk2;
update t1 set c5=c5+1 where pk1=1 order by pk1, pk2;
update t1 set c5=c5+1 where pk1=1 and pk2>'1' order by pk2;
update t1 set c5=c5+1 where pk1>0 and pk1<2 and pk2<'2' order by pk1;
update t1 set c5=c5+1 where pk1>-1 and pk1<2 order by pk1;
update t1 set c5=c5+1 where pk1>=0 and pk1<=1 order by pk1, pk2;
update t1 set c5=c5+1 where pk1>=0 and pk1<=1 and pk2='0' order by pk1;
update t1 set c5=c5+1 where pk1>=0 and pk1<=1 and pk2>'0' and pk2<='3' order by pk1, pk2;
update t1 set c5=c5+1, c2=c2 where pk1=0 and pk2 not in(1,2) order by pk2;
select * from t1;

