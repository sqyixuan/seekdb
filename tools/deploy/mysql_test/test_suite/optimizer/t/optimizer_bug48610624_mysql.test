--disable_warnings
drop table if exists t0,t1;
--enable_warnings

CREATE TABLE IF NOT EXISTS t0(c0 DECIMAL(37, 0) , c1 FLOAT  COMMENT 'asdf'  NULL, c2 FLOAT   COMMENT 'asdf' , c3 FLOAT(49, 0)  COMMENT 'asdf' )  BLOCK_SIZE =  16384  PARTITION BY KEY (c2, c3, c1, c0) partitions 3;
CREATE TABLE IF NOT EXISTS t1(c0 DOUBLE(10, 0) ZEROFILL , c1 DOUBLE(37, 0) ZEROFILL  COMMENT 'asdf'  PRIMARY KEY NOT NULL UNIQUE KEY, c2 DOUBLE(47, 0)   UNIQUE KEY, c3 FLOAT(47, 0)  COMMENT 'asdf'  UNIQUE KEY , c4 DOUBLE  ) ;
INSERT /*+parallel(2) enable_parallel_dml */ INTO t0(c0) select c0 from t0 ORDER BY RAND() limit 3;
CREATE INDEX i340 ON t1(c2, c1, c3) ;
CREATE INDEX i790 ON t0(c1, c3, c2);
DELETE FROM t1;
CREATE INDEX i740 USING BTREE ON t1(c1, c0, c3, c2, c4);
CREATE INDEX i430 USING HASH ON t1(c0, c1, c4);
REPLACE INTO t0 select * from t0 ORDER BY RAND() limit 3;
DELETE /*+parallel(9) enable_parallel_dml*/  FROM t1;
ALTER TABLE t0 COMPRESSION 'LZ4_1.0';
REPLACE INTO t1(c1) VALUES(1.672042342E9);
DELETE /*+parallel(1) enable_parallel_dml*/  FROM t0;
REPLACE INTO t0 select * from t0 ORDER BY RAND() limit 3;
ALTER TABLE t1 COMPRESSION 'zstd_1.0';

--explain_protocol 2
--result_format 4

SELECT /*+ no_rewrite */  concat(t1.c0,'') AS t1c0 FROM t1  ORDER BY t1.c2 DESC, concat(t1.c3,'') ASC limit 1;

drop table if exists t0,t1;
