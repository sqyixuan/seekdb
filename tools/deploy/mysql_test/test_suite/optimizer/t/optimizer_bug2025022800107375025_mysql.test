--disable_query_log
--enable_query_log
#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1, c2), unique index i1(c1) global) partition by hash(c2) partitions 256;
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, unique index i1(c1), index i2(c4,c3,c2,c1));
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, unique index i1(c1,c2,c3), index i2(c5,c4,c3,c2,c1));
call dbms_stats.set_table_stats('test', 't3', numrows=>100000);
call dbms_stats.set_column_stats('test', 't3', 'c1', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c2', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c3', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c4', distcnt=>1);
call dbms_stats.set_column_stats('test', 't3', 'c5', distcnt=>1);
set _enable_storage_cardinality_estimation = 0;

--result_format 4
--explain_protocol 3

select * from t1 where c1 = 1;
select * from t1 where c1 = 1 and c3 = 1;
select * from t1 where c1 = 1 order by c2;

select * from t1 where c1 = ifnull((select c2 from t2 order by c1 limit 1), 1);
select * from t1 where c1 = 1 and c2 = ifnull((select c2 from t2 order by c1 limit 1), 1);

select * from t2 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 = 1 and c4 in (1,2,3,4,5,6,7,8,9,0);
select c1,c2,c3,c4 from t2 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 = 1 and c4 in (1,2,3,4,5,6,7,8,9,0);

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select * from t3 where c1 = 1 and c2 = 1 and c3 = 1 and c5 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select * from t3 where c1 is null and c2 = 1 and c3 = 1 and c5 is null;

# refine normal index range rows
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select /*+opt_param('optimizer_better_inlist_costing' 'false')*/ count(*) from t3 where c1 in (1,2,3,4,5,6,7,8,9,0) and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 in (1,2,3,4,5,6,7,8,9,0) and c4 in (0,1) and c5 = 0;

#alter system set _enable_new_query_range_extraction = 0;
--sleep 1

select * from t1 where c1 = 1;
select * from t1 where c1 = 1 and c3 = 1;
select * from t1 where c1 = 1 order by c2;

select * from t1 where c1 = ifnull((select c2 from t2 order by c1 limit 1), 1);
select * from t1 where c1 = 1 and c2 = ifnull((select c2 from t2 order by c1 limit 1), 1);

select * from t2 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 = 1 and c4 in (1,2,3,4,5,6,7,8,9,0);
select c1,c2,c3,c4 from t2 where c1 = 1 and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 = 1 and c4 in (1,2,3,4,5,6,7,8,9,0);

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select * from t3 where c1 = 1 and c2 = 1 and c3 = 1 and c5 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select * from t3 where c1 is null and c2 = 1 and c3 = 1 and c5 is null;

# refine normal index range rows
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=valid_version/
select /*+opt_param('optimizer_better_inlist_costing' 'false')*/ count(*) from t3 where c1 in (1,2,3,4,5,6,7,8,9,0) and c2 in (1,2,3,4,5,6,7,8,9,0) and c3 in (1,2,3,4,5,6,7,8,9,0) and c4 in (0,1) and c5 = 0;

#alter system set _enable_new_query_range_extraction = 1;

drop table t1,t2,t3;
