#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

#bug: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists stu, teacher, score, t1;
--enable_warnings

create table stu (
sid     int,
name    varchar(32),
cls     int,
primary key (cls, sid)
) partition by hash(sid) partitions 6;

create table teacher (
tid        int,
name       varchar(32),
subject    varchar(4),
primary key (tid)
) partition by hash(tid) partitions 8;

create table score (
sid     int,
subject varchar(4),
score   int,
primary key (sid, subject)
) partition by hash(sid) partitions 6;

explain select /*+no_use_px*/ distinct sid from (select sid from stu union all select score sid from score) t1;


create table t1(a int, b int, c int) partition by hash(a) partitions 5;
explain select * from (select a from t1 union all select a from t1 as t2) as t3, t1 as t4 where t3.a = t4.a;
explain select * from (select a from t1 union all select b from t1 as t2) as t3, t1 as t4 where t3.a = t4.a;


explain SELECT /*+no_rewrite*/ S1  FROM (SELECT  a S1 FROM T1 limit 100, 10000)V  limit 10, 100;

explain 
select /*+parallel(2) leading(stu, teacher) use_hash(teacher) px_join_filter(teacher)*/ 
sum (cls)
 from stu, teacher
 where 
 tid = sid
 and
 (subject in ('KY') and cls between 0 and 2000  
 or subject in ('WI', 'MO', 'WV')
 );

explain 
select /*+leading(stu, teacher) use_nl(teacher)*/ 
sum (cls)
 from stu, teacher
 where 
 tid = sid
 and teacher.name = 'X'
 limit 10;


--disable_warnings
drop table if exists stu, teacher, score, t1;
--enable_warnings
