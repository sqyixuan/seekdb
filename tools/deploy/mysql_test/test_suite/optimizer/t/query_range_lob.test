# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer
## test for nvl text

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int primary key, c2 text);
create table t2(c1 int, c2 varchar(2));
create index i2 on t2 (c2);
create index i3 on t2 (c1, c2);
create table t3 (c1 varchar(1), c2 int , c3 int);
create index i3 on t3(c1,c2,c3);
insert into t1 values (1, '1');
insert into t1 values (2, '1 test');
insert into t2 values (1, '1');
insert into t2 values (2, '1 ');
insert into t3 values ('1', 1, 1);
--result_format 4
--explain_protocol 2

select /*+ leading(t1 t2) use_nl(t2) */ * from t1,t2 where t1.c2 = t2.c2;
select /*+ leading(t1 t2) use_nl(t2) */ * from t1,t2 where t1.c2 > t2.c2;
select /*+ leading(t1 t2) use_nl(t2) */ * from t1,t2 where t1.c2 >= t2.c2;
select /*+ leading(t1 t2) use_nl(t2) */ * from t1,t2 where t1.c2 < t2.c2;
select /*+ leading(t1 t2) use_nl(t2) */ * from t1,t2 where t1.c2 <= t2.c2;
select /*+ no_rewrite index(@"SEL$2" t2 i3) */ * from t1 where exists (select 1 from t2 where (t1.c1,t1.c2) = (t2.c1, t2.c2));
select /*+ no_rewrite index(@"SEL$2" t2 i3) */ * from t1 where exists (select 1 from t2 where (t1.c1,t1.c2) > (t2.c1, t2.c2));
select /*+ no_rewrite index(@"SEL$2" t2 i3) */ * from t1 where exists (select 1 from t2 where (t1.c1,t1.c2) >= (t2.c1, t2.c2));
select /*+ no_rewrite index(@"SEL$2" t2 i3) */ * from t1 where exists (select 1 from t2 where (t1.c1,t1.c2) < (t2.c1, t2.c2));
select /*+ no_rewrite index(@"SEL$2" t2 i3) */ * from t1 where exists (select 1 from t2 where (t1.c1,t1.c2) <= (t2.c1, t2.c2));

select /*+ no_rewrite index(@"SEL$2" t3 i3) */ * from t1 where exists (select 3 from t3 where (t3.c1, t3.c2, t3.c3) < (t1.c2, t1.c1, t1.c1));
select /*+ no_rewrite index(@"SEL$2" t3 i3) */ * from t1 where exists (select 3 from t3 where (t3.c1, t3.c2, t3.c3) <= (t1.c2, t1.c1, t1.c1));

drop table t1;
drop table t2;
drop table t3;
