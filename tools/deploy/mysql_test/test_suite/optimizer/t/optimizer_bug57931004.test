#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists trans;
drop table if exists agency;
--enable_warnings

CREATE TABLE `trans` (
  `order_no` bigint(32) NOT NULL COMMENT '交易编号',
  `create_time` datetime DEFAULT NULL,
  `optimistic` int(11) DEFAULT NULL,
  `update_time` datetime DEFAULT NULL,
  `agency_no` bigint(32) NOT NULL COMMENT '机构号',
  `agent_no` bigint(32) NOT NULL COMMENT '服务商编号 ',
  `amount` bigint(20) NOT NULL COMMENT '交易金额(分)',
  `commission_status` varchar(50) NOT NULL COMMENT '分润状态 INIT:未给 SUCCESS:已给',
  `coupon_customer_name` varchar(64) DEFAULT NULL COMMENT '优选商户名称',
  `coupon_customer_no` varchar(32) DEFAULT NULL COMMENT '优选商户号',
  `customer_no` bigint(32) NOT NULL COMMENT '商户编号 ',
  `external_customer_no` varchar(32) NOT NULL COMMENT '外部商户编号 ',
  `external_no` varchar(32) NOT NULL COMMENT '外部交易编号',
  `fee` bigint(20) DEFAULT '0' COMMENT '手续费(分)',
  `fee_rate` double(12,8) DEFAULT '0.00000000' COMMENT '费率-不带百分号',
  `platform` varchar(32) NOT NULL COMMENT '平台标识',
  `pos_sn` varchar(50) NOT NULL COMMENT '机具序列号',
  `settle_fee` bigint(20) DEFAULT '0' COMMENT '结算手续费-分(暂时用不到)',
  `settle_type` varchar(32) NOT NULL COMMENT '结算类型',
  `trade_type` varchar(32) NOT NULL COMMENT '交易类型 借记贷记 扫码',
  `trans_time` datetime NOT NULL COMMENT '交易时间',
  `type` varchar(32) NOT NULL COMMENT '类型 TRANS:正常交易 DEPOSIT:押金类型',
  `trans_type` varchar(16) NOT NULL,
  `trans_card_type` varchar(16) NOT NULL,
  `trans_code` varchar(32) DEFAULT NULL,
  `ext_trans_code` varchar(32) DEFAULT NULL,
  `biz_type` varchar(50) DEFAULT NULL COMMENT '业务类型[BPOS:传统POS,ZPOS:电签POS]',
  `activity_flag` varchar(100) DEFAULT NULL COMMENT '活动标签',
  PRIMARY KEY (`order_no`,`trans_time`),
  KEY `idx_trans` (`agency_no`,`platform`,`agent_no`,`trans_time`,`customer_no`),
  KEY `idx_cpo` (`agency_no`,`platform`,`agent_no`,`customer_no`,`pos_sn`,`order_no`),
  KEY `idx_external_no` (`external_no`)   ,
  KEY `idx_agent_no` (`agent_no`)   ,
  KEY `idx_pos_sn` (`pos_sn`)   ,
  KEY `idx_ext_cus_no` (`external_customer_no`)   ,
  KEY `idx_time` (`create_time`)   ,
  KEY `idx_agentno_type_transtime` (`agent_no`,`type`,`trans_time`),
  KEY `idx_customer_no` (`customer_no`)
)    DEFAULT CHARSET=utf8mb4 collate=utf8mb4_bin
PARTITION BY RANGE (TO_DAYS(trans_time))
