--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer
#bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;

--result_format 4
--explain_protocol 3

select l.c1 + r.c1,l.c2 + r.c2 from (select /*+ no_merge*/ c1,c2 from t1 where c1 in (1001, 1002) ) l left join (select c1,c2 from t1) r on l.c1 = r.c1 where l.c1 = 1001;

select l.c1 + r.c1,l.c2 + r.c2 from (select /*+ no_merge*/ c1,c2 from t1 where c1 in (1001, 1002) ) l left join (select /*+ no_merge*/ c1,c2 from t1) r on l.c1 = r.c1 where l.c1 = 1001;

select l.c1 + r.c1,l.c2 + r.c2 from (select c1,c2 from t1 where c1 in (1001, 1002) ) l left join (select c1,c2 from t1) r on l.c1 = r.c1 where l.c1 = 1001;

