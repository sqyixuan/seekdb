#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--disable_result_log
create table t1
(
  c1    datetime,
  c2    int,
  primary key(c1,c2),
  constraint t1_eq_cons check (c1 = c2)
)
partition by range columns (c1)
subpartition by hash (c2) subpartitions 3
(
  partition p0 values less than ('2020-01-01 12:34:56'),
  partition p1 values less than ('2020-02-01 12:34:56'),
  partition p2 values less than ('2020-03-01 12:34:56')
);
create table t2
(
  c1    int,
  c2    datetime,
  primary key(c1,c2),
  constraint t2_eq_cons check (c1 = c2)
)
partition by hash (c1) 
subpartition by range columns (c2)
subpartition template
(
  subpartition p0 values less than ('2020-01-01 12:34:56'),
  subpartition p1 values less than ('2020-02-01 12:34:56'),
  subpartition p2 values less than ('2020-03-01 12:34:56')
) partitions 3;



--disable_query_log
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

SELECT * FROM t1  WHERE c2 <> '9999-12-31';
SELECT * FROM t2  WHERE c1 <> '9999-12-31';

drop table if exists t1,t2;
