--disable_warnings
drop table if exists str_table, t1;
--enable_warnings
--explain_protocol 0

create table str_table (
  id int not null,
  c1_tint tinyint,
  c2_mint mediumint,
  c3_bint bigint,
  c4_doub double,
  c5_year year,
  c6_time time,
  c7_dtim datetime,
  c8_enum ENUM('枚举','','1','1.5','enum1','enum2 ','enum3','ENUM4','2022-09-28','12:00:00') DEFAULT NULL,
  c9_set1 set('集合','','1','1.5','set1','set2      ','set3','SET4','2022-09-28','12:00:00') DEFAULT NULL,
  primary key (id,c1_tint,c2_mint)
)charset = utf8mb4 partition by hash(c2_mint)  partitions 4;
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2,c3));

create index idx1 on str_table(c3_bint);
create index idx2 on str_table(c4_doub,c5_year);

