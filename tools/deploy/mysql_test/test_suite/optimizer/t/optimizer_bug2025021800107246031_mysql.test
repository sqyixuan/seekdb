#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings

drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int , c3 int);

--result_format 4
sleep 10;
explain select * from t1 where c1=1 and c2=1;
select * from t1 where c1=1 and c2=1;
let $trace_id=`select last_trace_id() from dual`;
--disable_query_log
eval select partition_hit,query_sql from oceanbase.gv\$ob_sql_audit where trace_id = '$trace_id' and query_sql like '%c1=1 and c2=1%';
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings
