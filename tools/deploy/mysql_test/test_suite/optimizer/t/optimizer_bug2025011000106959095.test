#owner: zhuangyifeng.zyf
#owner group: sql1
# tags: optimizer
# description: 测试大 IN 计划生成效率

--disable_warnings
drop table if exists standard_enterprise_standard_init;
drop table if exists standard_approve_comment;
--enable_warnings

CREATE TABLE
	standard_enterprise_standard_init (
		id bigint (20) NOT NULL,
		process_instance_id bigint (20) DEFAULT NULL,
    committee_id bigint (20) DEFAULT NULL,
    apply_org_id bigint (20) DEFAULT NULL,
    work_group text DEFAULT NULL,
    enterprise_status varchar(20) DEFAULT NULL,
		status tinyint (4) DEFAULT NULL,
		create_user bigint (20) DEFAULT NULL,
    is_draft int (11) DEFAULT NULL,
		PRIMARY KEY (id)
	) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

create table
	standard_approve_comment (
		id BIGINT (19) not null,
    approve_user_id BIGINT (19) default NULL null,
    process_inst_id VARCHAR(20) default 'NULL' null
	);

alter system flush plan cache;

--echo # inlist 有隐式强转
