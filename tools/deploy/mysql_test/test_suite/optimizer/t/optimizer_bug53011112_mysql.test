# owner group: SQL1
# tags: optimizer
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 varchar(100), c3 int);
insert into t1 values(1, 'a', 3);
insert into t1 values(1, 'A', 3);

--explain_protocol 1
--result_format 4

select distinct c1, c1 + 1 from t1;
select distinct c1, c3, c1 + c3 from t1;
select c1 from (select distinct c1, rand() from t1) v;
select c1 from (select distinct c1, rand(10) from t1) v;
select distinct c2, concat(c2, 'b') from t1;
select distinct c2, concat(c2, 'b' collate utf8mb4_bin) from t1;

drop table t1;
