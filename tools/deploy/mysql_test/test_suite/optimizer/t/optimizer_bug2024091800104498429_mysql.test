# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c0 int, c1 int);
insert into t1 values (0,1),(0,2),(0,3),(0,4);

call dbms_stats.gather_table_stats(null, 't1');
set ob_enable_transformation = 0;

--result_format 4
--explain_protocol 2

explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 = 2;
explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c1 = 4;
explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 = c1;
explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 != c1;
explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 != c0 + 1;
explain with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c1 = c1;
explain with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c0 = 1;
explain with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c1 = 1;
explain with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c0 = c1;
explain with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c1 != c0;

with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 = 2;
with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c1 = 4;
with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 = c1;
with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 != c1;
with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c0 != c0 + 1;
with cte(c0, c1) as (select row_number() over (), count(*) over () + c1 from t1) select * from cte where c1 = c1;
with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c0 = 1;
with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c1 = 1;
with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c0 = c1;
with cte(c0, c1) as (select row_number() over (partition by c0), count(*) over (partition by c1) from t1) select * from cte where c1 != c0;

drop table t1;