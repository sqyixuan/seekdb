#owner: yibo.tyf
#owner group: SQL1
#tag: optimizer
#link: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 json);
create table t2(c1 enum('alice', 'bob'), c2 set('1','2','3'));

--explain_protocol 2
(select nvl(t1.c1, 1) from t1) union (select t2.c1 from t2);
(select nvl(t1.c1, 1) from t1) union (select t2.c2 from t2);
--explain_protocol 0
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
