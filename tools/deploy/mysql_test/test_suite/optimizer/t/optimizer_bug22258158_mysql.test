--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
#description: 

--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (pk INTEGER PRIMARY KEY, a INTEGER NOT NULL, b CHAR(1), KEY(b));
CREATE VIEW v1 AS SELECT * FROM t1;
--disable_query_log
--disable_result_log
INSERT INTO t1 VALUES (23,5,'d');
select count(*) from t1;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
SELECT a1.pk FROM v1 AS a1 JOIN (SELECT * FROM v1 LIMIT 1) AS a2 ON a2.b = a1.b WHERE a1.a = (SELECT pk FROM v1 LIMIT 1) AND (a1.a != a2.a OR a1.b IS NULL);