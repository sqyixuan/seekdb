--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (pk int not null, primary key (`pk`));
create table t2 (c1 int);

--disable_query_log
--disable_result_log
insert into t1 values (1);
insert into t1 values (2);

insert into t2 values (1);
insert into t2 values (2);
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

##distinct const elimination
select distinct 1 from t1 limit 1;
select distinct 1 from t1 limit 1, 1;
select distinct 1 from t2 a, t2 b where a.c1 = b.c1 limit 1, 1;
select distinct count(1) from t1 group by pk limit 1;
select distinct count(1) from t1 group by pk limit 1, 1;

--disable_warnings
drop table if exists t1;
--enable_warnings
