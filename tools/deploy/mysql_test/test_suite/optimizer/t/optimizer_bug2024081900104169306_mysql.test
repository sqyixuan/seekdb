# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer, cross_validation

--disable_query_log
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 551, error_code = 5434, frequency = 0;
connection default;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(a int, b int);
create table t2(a int, b int);
create table t3(a int, b int);
create table t4(a int, b int);
insert into t1 values (0,1);
insert into t2 values (0,1),(0,2);
insert into t3 values (0,1),(0,2),(0,3);
insert into t4 values (0,1),(0,2),(0,3),(0,4);

--result_format 4
--explain_protocol 1

select /*+parallel(1)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;

select /*+parallel(32)*/ * from (select t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(32)*/ * from (select /*+no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(32)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(33)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(32)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t3,t1,t2 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(32) ordered*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;
select /*+parallel(32) ordered pq_distribute(v none hash)*/ * from (select /*+pq_distribute(t1 hash hash) pq_distribute(t2 hash hash) pq_distribute(t3 hash hash) no_rewrite*/ t1.* from t1,t2,t3 where t1.b=t2.b and t1.a=t2.a and t3.a=t1.a and t3.b=t1.b and t2.b=t3.b and t2.a=t3.a) v,t4 where v.b = t4.b and v.a=t4.a;

drop table t1,t2,t3,t4;

connection conn_admin;
alter system set_tp tp_no = 551, error_code = 5434, frequency = 1;
connection default;