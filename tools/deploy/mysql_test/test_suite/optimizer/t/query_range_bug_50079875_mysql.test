# tags: optimizer
set @@ob_enable_plan_cache = 0;

--result_format 4
--echo issue: 
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
insert into t1 values(0,0,0);
--explain_protocol 3
select * from t1 where (c1, 'xqqmx') <= (2, 'br');
--explain_protocol 0

set @@ob_enable_plan_cache = 1;
--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
