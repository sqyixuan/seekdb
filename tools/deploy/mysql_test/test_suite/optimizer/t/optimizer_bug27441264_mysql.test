# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
--source mysql_test/include/sql_import_opt_tpch.inc
--enable_warnings
--result_format 4
--explain_protocol 2

use opt_tpch;

##

##test group by no push down
SELECT
         /*+parallel(512)*/
         c_count,
         Count(*) AS custdist
FROM     (
                   SELECT    c_custkey,
                             Count(o_orderkey) as c_count
                   FROM      customer
                   LEFT JOIN orders
                   ON        c_custkey = o_custkey
                   AND       o_comment NOT LIKE '%special%requests%'
                   GROUP BY  c_custkey) c_orders
GROUP BY c_count
ORDER BY custdist DESC,
         c_count DESC;

##test group by push down
SELECT
         /*+parallel(2)*/
         c_count,
         Count(*) AS custdist
FROM     (
                   SELECT    c_custkey,
                             Count(o_orderkey) as c_count
                   FROM      customer
                   LEFT JOIN orders
                   ON        c_custkey = o_custkey
                   AND       o_comment NOT LIKE '%special%requests%'
                   GROUP BY  c_custkey) c_orders
GROUP BY c_count
ORDER BY custdist DESC,
         c_count DESC;

##test distinct no push down
SELECT
         /*+parallel(2)*/
         distinct c_count
FROM     (
                   SELECT    c_custkey,
                             Count(o_orderkey) as c_count
                   FROM      customer
                   LEFT JOIN orders
                   ON        c_custkey = o_custkey
                   AND       o_comment NOT LIKE '%special%requests%'
                   GROUP BY  c_custkey) c_orders
ORDER BY c_count DESC;

##test distinct push down
set _groupby_nopushdown_cut_ratio=1;
SELECT
         /*+parallel(2)*/
         distinct c_count
FROM     (
                   SELECT    c_custkey,
                             Count(o_orderkey) as c_count
                   FROM      customer
                   LEFT JOIN orders
                   ON        c_custkey = o_custkey
                   AND       o_comment NOT LIKE '%special%requests%'
                   GROUP BY  c_custkey) c_orders
ORDER BY c_count DESC;
set _groupby_nopushdown_cut_ratio=3;

