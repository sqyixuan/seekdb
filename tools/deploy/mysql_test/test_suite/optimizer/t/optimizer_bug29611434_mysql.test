#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_abort_on_error

--disable_warnings
drop table if exists mail4;
--enable_warnings

--disable_result_log
create table mail4
(
c0 int,
c1 varchar(200) character set gbk,
c2 char(200) character set gbk,
c3 blob,
c4 TEXT,
c5 Float(6,2),
c6 Double(6,2),
c7 Decimal(6,2),
c8 time,
c9 datetime,
c10 timestamp,
c11 enum('RED','GREEN','BLUE'),
c12 set('RED','GREEN','BLUE'),
PRIMARY KEY (`c1`)
)DEFAULT CHARACTER SET = gbk;

insert into mail4 values(1,'中文测试001','中文测试001','中文测试001','RED',1.11,0.111,0.0111,'838:59:59','1000-01-01 00:00:00','1970-12-31 23:59:59','RED','RED');
