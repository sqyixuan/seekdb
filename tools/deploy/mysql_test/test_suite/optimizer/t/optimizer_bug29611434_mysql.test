insert into mail4 values(4,'BLUE','BLUE','BLUE','2038-12-31 23:59:59',3.11,0.311,0.0311,'01:59:59','2020-01-01 00:00:00','2037-12-31 23:59:59','BLUE','BLUE');
insert into mail4 values(5,'2020-01-01 00:00:00','BLUE','BLUE','2038-12-31 23:59:59',3.11,0.311,0.0311,'01:59:59','2020-01-01 00:00:00','2037-12-31 23:59:59','BLUE','BLUE');
insert into mail4 values(6,'0.311','BLUE','BLUE','2038-12-31 23:59:59',3.11,0.311,0.0311,'01:59:59','2020-01-01 00:00:00','2037-12-31 23:59:59','BLUE','BLUE');
insert into mail4 values(7,'2038-12-31 23:59:59','BLUE','BLUE','2038-12-31 23:59:59',3.11,0.311,0.0311,'01:59:59','2020-01-01 00:00:00','2037-12-31 23:59:59','BLUE','BLUE');

--disable_query_log
select count(*) from mail4;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select * from mail4 t where t.c1 NOT LIKE '中文%';
select * from mail4 t where t.c1 LIKE '中文%';

drop table if exists mail4;
