--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer,cross_validation
# issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings

--result_format 4
create table t1(c1 int, c2 int) partition by hash(c1) partitions 10;
let $cnt=1;
--disable_query_log
while ($cnt < 100)
{
  let $sql = insert into t1 values($cnt, $cnt);
  eval $sql;
  inc $cnt;
}
--enable_query_log
--explain_protocol 2
select @var:=0 as init, @var:=@var+1 as assign from t1 limit 10;
select /*+parallel(10)*/@var:=0 as init, @var:=@var+1 as assign from t1 limit 10;
select @var:=0 as init, @var:=@var + 1 as assign from t1, t1 t2 limit 10;

select /*+parallel(10)*/c1, @var:=@var + 1, @var - c1 as diff, var_init from t1, (select @var:=0 as var_init from dual) tt order by c1;
select c1, @var:=@var + 1, @var - c1 as diff, var_init from t1, (select @var:=0 as var_init from dual) tt order by c1;
set autocommit = 0;
update /*+parallel(10) enable_parallel_dml*/t1 set c1 = (@a:=@a + 1), c2 = (select @a:=0 from dual);
select * from t1; 
ROLLBACK;
update t1 set c1 = (@b:=@b + 1), c2 = (select @b:=0 from dual);
select * from t1; 
ROLLBACK;
set autocommit = 1;

--explain_protocol 0

drop table t1;
