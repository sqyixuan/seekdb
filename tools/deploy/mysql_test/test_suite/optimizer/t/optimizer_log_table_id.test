# owner: zhanyue.zzy
# owner group: SQL1

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int);
insert into t values(1);

--result_format 4
set ob_query_timeout = 600000000;

## logical table id count: 10 * 5 * 25 = 1250
let $cnt = 0;
let $sel_sql=select 1 a from t;
while($cnt < 10)
{
  let $sel_sql=select 1 a from ($sel_sql);
  inc $cnt;
}
let $sel_sql=select 1 a from ($sel_sql) t1,  ($sel_sql) t2, ($sel_sql) t3, ($sel_sql) t4, ($sel_sql) t5;

let $cnt = 0;
let $sql=$sel_sql;
while($cnt < 25)
{
  let $sql=$sql union all $sel_sql;
  inc $cnt;
}
let $sql=$sql limit 10;
eval $sql;

drop table t;

