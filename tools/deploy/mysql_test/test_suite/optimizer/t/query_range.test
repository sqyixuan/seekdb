  AND is_delete = 0 ORDER BY id;
 
--disable_warnings
drop table if exists t1;
--enable_warnings
 
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int);
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c3);
create index i4 on t1(c4);
create index i5 on t1(c5);
create index i6 on t1(c6);
create index i8 on t1(c1, c2);
create index i9 on t1(c1, c2, c3);
create index i10 on t1(c1, c2, c3, c4);
create index i11 on t1(c1, c2, c3, c4, c5);
create index i12 on t1(c1, c2, c3, c4, c5, c6);
 
insert into t1 values(1,1,1,1,1,1);
insert into t1 values(2,2,2,2,2,2);
insert into t1 values(3,3,3,3,3,3);
insert into t1 values(4,4,4,4,4,4);
insert into t1 values(5,5,5,5,5,5);
insert into t1 values(6,6,6,6,6,6);
insert into t1 values(7,7,7,7,7,7);
insert into t1 values(8,8,8,8,8,8);
insert into t1 values(9,9,9,9,9,9);

call dbms_stats.gather_table_stats(NULL, 't1');

--explain_protocol 2
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c1 in (2,3,4,5,6,7)
and c1 in (3,4,5,6)
and c1 in (4,5,6,7,8,9,10)
and c1 in (5,6,7,8,9,10,11,12,13);
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6,7)
and c3 in (3,4,5,6)
and c4 in (4,5,6,7,8,9,10)
and c5 in (5,6,7,8,9,10,11,12,13);
 
select count(*) from t1 
where c1 in (1,2,3,4,5) and c1 in (2,3,4)
and c2 in (2,3,4,5,6)
and c3 in (3,4,5,6,7)
and c4 in (4,5,6,7,8)
and c5 in (5,6,7,8,9);
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6) and c2 in (4,5,6)
and c3 in (3,4,5,6,7)
and c4 in (4,5,6,7,8)
and c5 in (5,6,7,8,9);
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6)
and c3 in (3,4,5,6,7) and c3 in (2,3,6)
and c4 in (4,5,6,7,8)
and c5 in (5,6,7,8,9);
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6)
and c3 in (3,4,5,6,7)
and c4 in (4,5,6,7,8) and c4 in (2,3)
and c5 in (5,6,7,8,9);
 
select count(*) from t1 
where c1 in (1,2,3,4,5)
and c2 in (2,3,4,5,6)
and c3 in (3,4,5,6,7)
and c4 in (4,5,6,7,8)
and c5 in (5,6,7,8,9) and c5 in (2,6);
 
select count(*) from t1 
where c1 in (1,2,3,4,5) and c1 in (2,3,5,6)
and c2 in (2,3,4,6) and c2 in (2,3,4,5,6)
and c3 in (3,4,5,6,7) and c3 in (2,4,5,6)
and c4 in (4,5,7,8) and c4 in (2,3,4,5,6)
and c5 in (5,6,7,8,9);
 
select count(*) from t1 
where c1 in (1,2,3,4,5) and c1 in (2,4,5,6)
and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6,7) and c2 in (2,3,5,6,8) and c2 in (2,3,4,5,6,9)
and c3 in (3,4,5,6,7) and c3 in (2,3,5,6) and c3 in (2,3,4,5,6,7) and c3 in (2,3,4,5,6,8) and c3 in (2,3,4,5,6,9)
and c4 in (4,5,6,7,8) and c4 in (2,3,4,5,6) and c4 in (2,3,5,6,7) and c4 in (2,3,4,5,6,8) and c4 in (2,3,4,5,6,9)
and c5 in (5,6,7,8,9);

select /*+opt_param('optimizer_better_inlist_costing' 'false')*/ count(*) from t1 
where c1 in (1,2,3,4,5) and c1 in (2,4,5,6)
and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6,7) and c2 in (2,3,5,6,8) and c2 in (2,3,4,5,6,9)
and c3 in (3,4,5,6,7) and c3 in (2,3,5,6) and c3 in (2,3,4,5,6,7) and c3 in (2,3,4,5,6,8) and c3 in (2,3,4,5,6,9)
and c4 in (4,5,6,7,8) and c4 in (2,3,4,5,6) and c4 in (2,3,5,6,7) and c4 in (2,3,4,5,6,8) and c4 in (2,3,4,5,6,9)
and c5 in (5,6,7,8,9);
 
alter system set _optimizer_better_inlist_costing = 0;
sleep 1;

select /*+opt_param('optimizer_better_inlist_costing' 'true')*/ count(*) from t1 
where c1 in (1,2,3,4,5) and c1 in (2,4,5,6)
and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6) and c2 in (2,3,4,5,6,7) and c2 in (2,3,5,6,8) and c2 in (2,3,4,5,6,9)
and c3 in (3,4,5,6,7) and c3 in (2,3,5,6) and c3 in (2,3,4,5,6,7) and c3 in (2,3,4,5,6,8) and c3 in (2,3,4,5,6,9)
and c4 in (4,5,6,7,8) and c4 in (2,3,4,5,6) and c4 in (2,3,5,6,7) and c4 in (2,3,4,5,6,8) and c4 in (2,3,4,5,6,9)
and c5 in (5,6,7,8,9);