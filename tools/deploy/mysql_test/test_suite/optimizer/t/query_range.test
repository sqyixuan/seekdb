--disable_warnings
drop table if exists t1;
drop table if exists `risk_rule_calculated_score`;
--enable_warnings

CREATE TABLE `risk_rule_calculated_score` (
`id` int(20) NOT NULL,
`user_id` int(20) NOT NULL DEFAULT '0',
`group_id` varchar(64) NOT NULL DEFAULT '0' COMMENT '同一批记录规则的 id',
`withdraw_id` varchar(64) NOT NULL DEFAULT '' COMMENT '提现ID',
`rule_name` varchar(64) NOT NULL DEFAULT '' COMMENT '规则的名字',
`hit_result` bit(1) NOT NULL DEFAULT b'0' COMMENT '规则命中结果,1 - 命中 ; 0 - 未命中',
`weight_score` float NOT NULL DEFAULT '0' COMMENT '规则的权重分',
`feature` text DEFAULT NULL COMMENT '规则关联的特征值信息',
`is_test` bit(1) DEFAULT b'0',
`version` int(4) DEFAULT '1',
`remark` varchar(45) NOT NULL DEFAULT '' COMMENT '规则备注信息(比如使用场景之类)',
`merchant` varchar(64) NOT NULL DEFAULT '' COMMENT '租户',
`create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
`update_time` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
UNIQUE KEY `index_group_rule` (`group_id`, `rule_name`) BLOCK_SIZE 16384 GLOBAL,
KEY `idx_id` (`id`) BLOCK_SIZE 16384 GLOBAL,
KEY `index_create_time` (`create_time`) BLOCK_SIZE 16384 GLOBAL,
KEY `index_user_id` (`user_id`) BLOCK_SIZE 16384 GLOBAL,
KEY `index_rule_name_hit_result_create_time` (`rule_name`, `hit_result`, `create_time`) BLOCK_SIZE 16384 GLOBAL,
KEY `index_rule_name_create_time` (`rule_name`, `create_time`) BLOCK_SIZE 16384 GLOBAL
);

create table t1(c1 bit(1), c2 bit(2), c3 bit(8), index idxt1c1(c1), index idxt1c2(c2), index idxt1c3(c3));

--disable_result_log
--disable_query_log
insert into t1 values(b'1', b'11', b'11111111');
select count(*) from t1;
--enable_query_log
--enable_result_log

SELECT * FROM risk_rule_calculated_score WHERE rule_name='spot_reset_2fa_rule' AND create_time > '2021-06-15' AND hit_result=b'1' LIMIT 10;

select * from t1 where c1 = b'1';
select * from t1 where c2 = b'1';
select * from t1 where c2 = b'11';
select * from t1 where cast(c2 as decimal(1,0)) = b'11';
select * from t1 where c3 = 255;
select * from t1 where cast(c3 as decimal(2,0)) = b'111';

drop table t1;
drop table `risk_rule_calculated_score`;


alter system set _optimizer_better_inlist_costing = 1;
sleep 1;
 
--disable_warnings
drop table if exists `hc_employee_insurance_category`;
drop table if exists `hc_payment_radix_detail`;
drop table if exists `hpc_business_task_detail`;
drop table if exists `hpc_new_payment_radix`;
--enable_warnings
 
CREATE TABLE `hc_employee_insurance_category` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `customer_id` bigint(20) NOT NULL COMMENT '企业id',
  `dept_id` bigint(20) NOT NULL DEFAULT '0' COMMENT '部门id',
  `socins_number` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '单位编号',
  `employee_id` bigint(20) NOT NULL COMMENT '人员id',
  `employee_socins_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '社保个人编号/个人社保登记码(上海)/电脑号（深圳）',
  `insurance_category` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT 'SOCINS' COMMENT '险种类别：SOCINS 社保/MEDICAL 医保',
  `insurance_type_list` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '险种列表',
  `state` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '99' COMMENT '参保状态，待参保01/ 参保中02/ 已参保03/ 待停保04/ 停保中05/ 已停保06/ 未知99',
  `insurance_month_start` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '开始参保年月',
  `insurance_month_end` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '停止参保年月',
  `insurance_date_start` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '参保日期（yyyy-MM-dd）',
  `insurance_date_end` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '停保日期（yyyy-MM-dd）',
  `voluntary` tinyint(1) DEFAULT NULL COMMENT '是否本人意愿',
  `medical_level` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '医疗档次 一档/二档/三档',
  `first_insurance_month` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '本人首次参保年月(yyyyMM)',
  `first_insurance_date` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '首次参保年月日（yyyy-MM-dd）',
  `payment_income` decimal(18,6) DEFAULT NULL COMMENT '缴费收入',
  `payment_salary` decimal(18,6) DEFAULT NULL COMMENT '缴费工资',
  `payment_radix` decimal(18,6) DEFAULT NULL COMMENT '缴费基数',
  `insured_reason` varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '个人缴费原因',
  `stop_reason` varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '停保原因',
  `remark` varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '备注',
  `extend_info` varchar(256) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '拓展信息，保存格式:{key:value}',
  `is_delete` bigint(20) NOT NULL DEFAULT '0' COMMENT '逻辑删除',
  `creator_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '创建人id',
  `modifier_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '更新人id',
  `create_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `modify_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`, `customer_id`),
  UNIQUE KEY `id` (`id`) global,
  UNIQUE KEY `uk_customer_id_socins_number_employee_id_insurance_category` (`customer_id`, `socins_number`, `employee_id`, `insurance_category`, `is_delete`) ,
  KEY `idx_create_date` (`create_date`) ,
  KEY `idx_modify_date` (`modify_date`) ,
  KEY `idx_customer_id_is_delete_employee_id` (`customer_id`, `is_delete`, `employee_id`) 
) 
 partition by key(customer_id) partitions 128;
 
 
 CREATE TABLE `hc_payment_radix_detail` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `customer_id` bigint(20) NOT NULL COMMENT '企业id',
  `payment_radix_uuid` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '员工缴费基数uuid',
  `unique_key` varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '唯一键，组成为：payment_radix_uuid + insurance_type +MD5( correspond_period_start + correspond_period_end + payment_type)',
  `insurance_type` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '险种',
  `socins_number` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '单位编号',
  `serial_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT '' COMMENT '流水号',
  `payment_type` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL DEFAULT '' COMMENT '应缴类型',
  `correspond_period_start` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT '' COMMENT '对应费款所属期起',
  `correspond_period_end` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT '' COMMENT '对应费款所属期止',
  `payment_radix` decimal(18,6) DEFAULT NULL COMMENT '缴费基数',
  `payment_salary` decimal(18,6) DEFAULT NULL COMMENT '缴费工资',
  `company_payment_amount` decimal(18,6) DEFAULT NULL COMMENT '公司缴费金额',
  `company_account_amount` decimal(18,6) DEFAULT NULL COMMENT '单位应缴划入个人账户金额',
  `company_ratio` decimal(9,6) DEFAULT NULL COMMENT '公司比例',
  `personal_payment_amount` decimal(18,6) DEFAULT NULL COMMENT '个人缴费金额',
  `personal_account_amount` decimal(18,6) DEFAULT NULL COMMENT '个人应缴划入个人账户金额',
  `personal_ratio` decimal(9,6) DEFAULT NULL COMMENT '个人比例',
  `free_medical_assistance_amount` decimal(18,6) DEFAULT NULL COMMENT '公费医疗补助金额',
  `company_late_fee` decimal(18,6) DEFAULT NULL COMMENT '单位应缴滞纳金金额',
  `personal_late_fee` decimal(18,6) DEFAULT NULL COMMENT '个人应缴滞纳金额',
  `total_late_fee` decimal(18,6) DEFAULT NULL COMMENT '滞纳金总额',
  `company_payment_interest` decimal(18,6) DEFAULT NULL COMMENT '单位应缴利息',
  `personal_payment_interest` decimal(18,6) DEFAULT NULL COMMENT '个人应缴利息',
  `total_payment_interest` decimal(18,6) DEFAULT NULL COMMENT '利息总额',
  `payment_flag` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '缴费标识',
  `company_account_ratio` decimal(18,6) DEFAULT NULL COMMENT '单位缴费划入个人账户比例或定额标准',
  `personal_account_ratio` decimal(18,6) DEFAULT NULL COMMENT '个人缴费划入个人账户比例或定额标准',
  `arrival_account_date` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '到账日期yyyy-MM-dd',
  `remark` varchar(200) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '备注',
  `is_delete` bigint(20) NOT NULL DEFAULT '0' COMMENT '逻辑删除',
  `creator_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '创建人id',
  `modifier_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '更新人id',
  `create_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `modify_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`, `customer_id`),
  UNIQUE KEY `id` (`id`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `uk_customer_id_unique_key_is_delete` (`customer_id`, `unique_key`, `is_delete`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_create_date` (`create_date`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_modify_date` (`modify_date`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_customer_id_is_delete_socins_number_serial_number` (`customer_id`, `is_delete`, `socins_number`, `serial_number`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_customer_id_is_delete_payment_radix_uuid` (`customer_id`, `is_delete`, `payment_radix_uuid`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 13027101998 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '个人月缴费基数明细'
 partition by key(customer_id)partitions 128;
 
 
CREATE TABLE `hpc_business_task_detail` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `parent_id` bigint(20) DEFAULT NULL COMMENT '父任务ID',
  `customer_id` bigint(20) NOT NULL COMMENT '企业id',
  `socins_number` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `task_id` bigint(20) DEFAULT NULL COMMENT '任务id，对应任务表中的id',
  `website_code` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '网厅代码',
  `website_business_code` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '网厅业务代码',
  `insurance_category` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '参险类别',
  `name` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '姓名，加密存储',
  `license_type_code` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `license_number` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `submit_async_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '提交异步流水号',
  `feedback_async_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '反馈异步流水号',
  `submit_state` varchar(6) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '提交状态 01未提交，02提交未反馈，03提交已反馈',
  `process_state` varchar(6) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '处理状态 01待提交，02提交中，03提交成功，04提交失败，05未审核，06审核中，07审核成功，08部分审核成功，09审核失败，10无法提交，11校验失败',
  `approval_level` tinyint(1) DEFAULT '0' COMMENT '0不审核，1要审核',
  `business_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '业务办理编号（这里是网厅对应的业务办理编号）',
  `business_data` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '业务办理数据',
  `original_business_data` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '原始任务数据',
  `submit_time` datetime DEFAULT NULL COMMENT '提交时刻',
  `submit_feedback_time` datetime DEFAULT NULL COMMENT '提交反馈时间',
  `business_result` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '业务办理结果',
  `error_code` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '错误码',
  `feedback_data` text CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '返回上层数据',
  `processing_feedback_time` datetime DEFAULT NULL COMMENT '查询任务办理结果反馈时间',
  `retry_count` tinyint(2) DEFAULT NULL COMMENT '已完成重试次数',
  `is_delete` bigint(20) NOT NULL DEFAULT '0' COMMENT '逻辑删除',
  `creator_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '创建人id',
  `modifier_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '更新人id',
  `modify_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  `create_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  PRIMARY KEY (`id`, `customer_id`),
  UNIQUE KEY `id` (`id`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_create_date` (`create_date`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_modify_date` (`modify_date`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_customer_id_submit_async_number` (`customer_id`, `submit_async_number`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_customer_id_task_id` (`customer_id`, `task_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_customer_id_feedback_async_number` (`customer_id`, `feedback_async_number`) BLOCK_SIZE 16384 LOCAL
) AUTO_INCREMENT = 2200845412 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '区域网厅任务明细'
 partition by key(customer_id)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4);
 
CREATE TABLE `hpc_new_payment_radix` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `uuid` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT 'uuid',
  `customer_id` bigint(20) NOT NULL COMMENT '企业id',
  `period` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '费款所属期',
  `socins_number` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '单位编号',
  `insurance_category` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '参险类别',
  `standing_book_type` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL COMMENT '台账类型',
  `serial_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '流水号',
  `employee_number` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '员工编号，对应网厅个人编号',
  `name` varchar(250) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `license_type_code` varchar(4) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '证件类型',
  `license_number` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '证件号码，加密存储',
  `payment_radix` decimal(18,6) DEFAULT NULL COMMENT '缴费基数',
  `available` tinyint(1) DEFAULT '1' COMMENT '有效标志 1有效，0无效',
  `download_stamp` datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '最近一次更新时间',
  `is_delete` bigint(20) NOT NULL DEFAULT '0' COMMENT '逻辑删除',
  `creator_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '创建人id',
  `modifier_id` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL COMMENT '更新人id',
  `create_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `modify_date` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  PRIMARY KEY (`id`, `customer_id`),
