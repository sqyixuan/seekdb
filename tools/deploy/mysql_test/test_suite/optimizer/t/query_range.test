# bug: 
CREATE TABLE `mkt_campaign_obj` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `start_time` datetime NOT NULL COMMENT '开始时间',
  `end_time` datetime NOT NULL COMMENT '结束时间',
  PRIMARY KEY (`id`),
  KEY `idx_time` (`start_time`, `end_time`)
);
EXPLAIN
SELECT /*+index(a1 idx_time)*/ id
FROM   mkt_campaign_obj a1 
WHERE  id > 0 
       AND ( ( a1.start_time <= '2020-02-28 22:09:03' and a1.end_time >= 
               '2020-02-28 22:09:03' ) 
             OR ( a1.start_time >= '2020-02-28 22:09:03' and a1.start_time <= 
                  '2020-02-28 23:09:03' ) ) 
ORDER  BY id ASC 
LIMIT  100 ;

SELECT /*+index(a1 idx_time)*/ id
FROM   mkt_campaign_obj a1 
WHERE  id > 0 
       AND ( ( a1.start_time <= '2020-02-28 22:09:03' and a1.end_time >= 
               '2020-02-28 22:09:03' ) 
             OR ( a1.start_time >= '2020-02-28 22:09:03' and a1.start_time <= 
                  '2020-02-28 23:09:03' ) ) 
ORDER  BY id ASC 
LIMIT  100 ;


