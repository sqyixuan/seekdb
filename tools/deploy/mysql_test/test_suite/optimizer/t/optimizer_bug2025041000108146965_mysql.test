#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 4016, frequency = 1;
connection default;

create table t1(c1 int, c2 int, c3 int, primary key(c1,c2,c3));
insert into t1 select uniform(1, 10, random()), uniform(1, 1000, random()),row_number() over () from table(generator(100000));
--replace_regex /table_rows:[0-9]*/table_rows:1/g
explain extended_noaddr select /*+use_hash_distinct*/ distinct c3 from t1 where c1 = 0 order by c3 desc limit 1;

connection obsys;
alter system set_tp tp_name = "EN_FORCE_GBY_PUSHDOWN_STORAGE", error_code = 0, frequency = 0;
connection default;

drop table t1;