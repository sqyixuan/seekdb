--disable_warnings
drop table if exists t3;
drop view if exists v_t3;
--enable_warnings
CREATE TABLE t3(c0 DATETIME , c1 DOUBLE(60, 4)  COMMENT 'asdf'  , PRIMARY KEY(c1)) AUTO_INCREMENT = 3514530942945748,   USE_BLOOM_FILTER =  FALSE ,  BLOCK_SIZE =  16384  PARTITION BY KEY (c1) partitions 1;
CREATE VIEW v_t3 AS select /*+no_mv_rewrite*/ c0, c1,count(*) as c from t3 group by c0, c1;
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS GATHER_OPTIMIZER_STATISTICS parallel(1) enable_parallel_dml */ INTO t3(c1, c0) VALUES(5842262.6892, '2024-12-03 10:09:51');
REPLACE INTO t3(c0, c1) VALUES("2024-12-03 10:10:04", 9.659203);
--result_format 4

--explain_protocol 2

select * from v_t3 where c1 = 5842262.6892;
select * from v_t3 where c1 in (5842262.6892,9.659203);
select /*+no_rewrite*/ * from v_t3 where c1 in (5842262.6892,9.659203);

--explain_protocol 0
--disable_warnings
drop table if exists t3;
drop view if exists v_t3;
--enable_warnings
