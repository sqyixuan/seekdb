# owner: sean.yyj
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int) partition by hash(c2) subpartition by key(c1) subpartitions 2 partitions 2;

--explain_protocol 1
insert into t1 select 1, 2 from dual ON DUPLICATE KEY UPDATE c2=3;

drop table t1;
