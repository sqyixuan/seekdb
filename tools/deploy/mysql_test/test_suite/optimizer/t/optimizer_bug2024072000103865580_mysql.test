# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

--result_format 4
--enable_sorted_result

--disable_warnings

create table t1(c1 int, c2 int)partition by hash(c1) partitions 2;
create table t2(c1 int);

--explain_protocol 1

select /*+parallel(2) leading(B(C A)) no_rewrite pq_distribute( A local local) px_join_filter(A) pq_distribute((C A) hash hash)*/ count(*) from t1 A, t2 B, (select count(*) from t2) C where A.c2 = B.c1;

drop table t1;
drop table t2;