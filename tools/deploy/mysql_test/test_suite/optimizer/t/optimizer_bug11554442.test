#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
insert into t1 values (5),(3),(1);
insert into t1 values (4),(2);

--result_format 4
--explain_protocol 2

select * from t1 union select * from t2;
select /*+no_use_hash_set(@"SET$1")*/ * from t1 union select * from t2;
select /*+use_hash_set(@"SET$1")*/ * from t1 union select * from t2;
select * from t1 union select * from t2 order by c1;
select /*+use_hash_set(@"SET$1")*/ * from t1 union select * from t2 order by c1;
select /*+no_use_hash_set(@"SET$1")*/ * from t1 union select * from t2 order by c1;
select /*+no_use_hash_set(@"SET$1")*/ * from t1 minus select * from t2;
select * from t1 union (select /*+no_use_hash_set(@"SET$1")*/ * from t1 minus select * from t2);

drop table t1;
drop table t2;