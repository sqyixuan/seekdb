## 1.2.3 window function 下推
##
EXPLAIN select sum(c3) over(partition by c1) from t_range_list2 where c2 in (1,2,3,4);
select sum(c3) over(partition by c1) from t_range_list2 where c2 in (1,2,3,4);
select sum(c3) over(partition by c1) from t_range_list2 where c2 in (6,7,8,9);
select sum(c3) over(partition by c1) from t_range_list2 where c2 in (11,13,14,15);
## hit_count should be 2
