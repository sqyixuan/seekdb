EXPLAIN select distinct c1 from t_range_list2 where c2 in (2,3,4,5);
select distinct c1 from t_range_list2 where c2 in (2,3,4,5);
select distinct c1 from t_range_list2 where c2 in (7,8,9,10);
select distinct c1 from t_range_list2 where c2 in (12,13,14,15);
