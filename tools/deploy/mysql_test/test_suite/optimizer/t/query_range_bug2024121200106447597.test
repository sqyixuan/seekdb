# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer, cross_validation

--disable_warnings
DROP TABLE if exists t1;
DROP TABLE if exists t2;
drop MATERIALIZED VIEW if exists mv;
--enable_warnings

CREATE TABLE t1 (
    c1 INTEGER PRIMARY KEY ,
    c2 INTEGER); 

CREATE TABLE t2(
    c1 INTEGER PRIMARY KEY ,
    c2 INTEGER
);
CREATE MATERIALIZED VIEW mv AS SELECT c1 FROM t1 WHERE c1 < - 'x' ;

explain extended_noaddr insert into t1 select * from t2 WHERE c1 < - 'x';

drop table t1;
drop table t2;
drop MATERIALIZED VIEW mv;
