--echo issue: 

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (pk int primary key); 
INSERT INTO t1 VALUES (1), (2), (11);
COMMIT;
--result_format 4

--explain_protocol 3
set @@ob_enable_plan_cache = 0;
SELECT  * FROM t1 WHERE PK IN (7,10) OR pk < 3 or pk > 10;

set @@ob_enable_plan_cache = 1;
SELECT * FROM t1 WHERE PK IN (7,10) OR pk < 3 or pk > 10;
--explain_protocol 0

--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
