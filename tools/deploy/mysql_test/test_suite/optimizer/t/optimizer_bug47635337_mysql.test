--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer,cross_validation
# link: 
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;
--disable_query_log
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4);
--enable_query_log
--explain_protocol 2
--result_format 4

select * from t1 for update;

select * from t1 where c1 = 0 for update;

--disable_warnings
drop table if exists t1;
--enable_warnings
