# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE if exists t1;
--enable_warnings

CREATE TABLE `t1` (
  `c1` double NOT NULL,
  `c2` bigint(20) NOT NULL,
  `pk` int(11) NOT NULL,
  PRIMARY KEY (`c2`, `pk`, `c1`)
);

--result_format 4
--explain_protocol 2
select /*+no_rewrite*/ * from t1 where (t1.c1,t1.c1,t1.c2) IN ((0,5,0),(2,9,4)) and (t1.c2,t1.pk) < (6,3);

DROP TABLE t1;