#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_result_log
create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;
--disable_query_log
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2
select gt1.c2 from t1 gt1 right join t1 gt2 on gt1.c2 = gt2.c2 where (gt2.c2 + gt1.c2) = gt2.c1;
select /*+no_use_px*/ gt1.c2 from t1 gt1 right join t1 gt2 on gt1.c2 = gt2.c2 where (gt2.c2 + gt1.c2) = gt2.c1;
select gt1.c2 from t1 gt1 join t1 gt2 where (gt2.c2 + gt1.c2) = gt2.c1;
select /*+no_use_px*/ gt1.c2 from t1 gt1 join t1 gt2 where (gt2.c2 + gt1.c2) = gt2.c1;

drop table t1;