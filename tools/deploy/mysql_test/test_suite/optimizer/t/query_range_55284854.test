## test for query range crop

--disable_warnings
drop table if exists t22;
--enable_warnings

CREATE TABLE t22 (
  c1 mediumint(49) DEFAULT NULL,
  c2 char(15) COLLATE utf8mb4_bin NOT NULL,
  c3 int(87) NOT NULL,
  c4 smallint(11) NOT NULL,
  c5 varchar(46) COLLATE utf8mb4_bin DEFAULT NULL,
  PRIMARY KEY (c4, c2, c3),
  UNIQUE KEY u_u (c4, c1) BLOCK_SIZE 16384 LOCAL,
  UNIQUE KEY u_iFLGVMh (c1, c3) BLOCK_SIZE 16384 LOCAL,
  KEY i_r (c1, c4) BLOCK_SIZE 16384 LOCAL
);


--result_format 4
--explain_protocol 2

select /*+ index(t22 u_iFLGVMh) */  * from t22 where (c3 not in (893 ,  893)) and (((c3 > 237)) or (c1 = 541));

drop table t22;
