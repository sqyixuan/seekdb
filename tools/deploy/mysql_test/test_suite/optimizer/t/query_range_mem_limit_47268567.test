# tags: optimizer
set ob_query_timeout = 6000000000;

--echo issue: 
--disable_warnings
drop table if exists tb_flow_iser_audit, bs_district, audit_regular_node, tb_flow_form, tb_chngroup_dict;
--enable_warnings

CREATE TABLE `tb_flow_iser_audit` (
  `ISERIALNO` varchar(20) NOT NULL COMMENT '工单流水',
  `NODE_ID` varchar(32) DEFAULT NULL COMMENT '业务标识',
  `REGULAR_SERIALNO` varchar(64) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL COMMENT '差异唯一标识',
  `REGULAR_AUDITTIME` varchar(8) DEFAULT NULL COMMENT '稽核时间',
  `REGULAR_DATATIME` varchar(32) DEFAULT NULL COMMENT '受理时间',
  `PRO_STATUS` varchar(2) DEFAULT NULL COMMENT '默认 没有结束的工单；1 结束工单',
  `DLOGIN_ID` varchar(32) DEFAULT NULL COMMENT '营业员处理工号',
  `REGION_CODE` varchar(16) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `LAST_MOD_DATE` varchar(32) DEFAULT NULL COMMENT '状态最后一次修改时间',
  `AUDIT_DESC` varchar(2000) DEFAULT NULL COMMENT '稽核备注',
  `REVIEW_TIME` varchar(32) DEFAULT NULL COMMENT '复核时间',
  `AUDIT_LOGIN` varchar(32) DEFAULT NULL COMMENT '人工派发工单用户',
  `AUDIT_RESULT` varchar(2) DEFAULT NULL COMMENT '人工稽核结论',
  `AUDIT_TIME` datetime DEFAULT NULL COMMENT '人工稽核时间',
  `ERROR_TYPE` varchar(6) DEFAULT NULL COMMENT '差异分类',
  `ORDER_NUM` varchar(40) DEFAULT NULL,
  `BUSINESS_ID` varchar(20) DEFAULT NULL COMMENT '业务类型，辽宁添加',
  `TIMEOUT` char(1) DEFAULT NULL,
  `AUDIT_TYPE` varchar(32) DEFAULT NULL,
  `ERROR_REMARK` varchar(1000) DEFAULT NULL,
  `NO_ERROR` char(1) DEFAULT NULL,
  `NO_AUDIT` char(1) DEFAULT NULL,
  `CHECK_TYPE` char(1) DEFAULT NULL,
  `CHECK_REMARK` varchar(1000) DEFAULT NULL,
  `FIRSTAUDITTIME` varchar(32) DEFAULT NULL,
  `SECONDAUDITTIME` varchar(32) DEFAULT NULL,
  `RECTIFICATIONTIME` varchar(32) DEFAULT NULL,
  `YSJH1` varchar(32) DEFAULT NULL,
  `YSJH2` varchar(32) DEFAULT NULL,
  `CHECK_LOGINID` varchar(32) DEFAULT NULL,
  `CHECK_TIME` varchar(32) DEFAULT NULL,
  `CHECK_NOTE` varchar(32) DEFAULT NULL,
  `FIRSTLOGINID` varchar(32) DEFAULT NULL,
  `SECONDLOGINID` varchar(32) DEFAULT NULL,
  `RECTIFICATIONLOGINID` varchar(32) DEFAULT NULL,
  `RECTIFICATIONCOUNT` int(10) DEFAULT '0',
  `ZQ_END_TIME` varchar(32) DEFAULT NULL,
  `PHY_WRONGTYPE` varchar(32) DEFAULT NULL,
  `ALERT_LEVEL` varchar(32) DEFAULT NULL,
  `EARLY_TYPE` varchar(255) DEFAULT NULL,
  `EARLY_LEVEL` varchar(255) DEFAULT NULL,
  `complaint_serialno` varchar(32) DEFAULT NULL,
  `gd_time` varchar(32) DEFAULT NULL,
  PRIMARY KEY (`ISERIALNO`),
  KEY `1` (`BUSINESS_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_DLOGIN_ID` (`DLOGIN_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_NODE_ID` (`NODE_ID`, `REGULAR_DATATIME`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_PRO_STATUS` (`PRO_STATUS`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_REGION_CODE` (`REGION_CODE`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_REGULAR_AUDITTIME` (`REGULAR_AUDITTIME`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_REGULAR_DATATIME` (`REGULAR_DATATIME`) BLOCK_SIZE 16384 LOCAL,
  KEY `INDEX_REGULAR_SERIALNO` (`REGULAR_SERIALNO`) BLOCK_SIZE 16384 LOCAL,
  KEY `node_id` (`NODE_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `REGULAR_DATATIME` (`REGULAR_DATATIME`) BLOCK_SIZE 16384 LOCAL,
  KEY `REGULAR_SERIALNO` (`REGULAR_SERIALNO`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `bs_district` (
  `DISTRICT_ID` varchar(20) COLLATE utf8mb4_bin NOT NULL,
  `REGION_ID` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `DISTRICT_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL,
  `DISTRICT_TYPE_ID` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `PARENT_DISTRICT_ID` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  PRIMARY KEY (`DISTRICT_ID`),
  KEY `1` (`REGION_ID`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `audit_regular_node` (
  `NODE_ID` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL,
  `ROOT_ID` varchar(36) DEFAULT NULL,
  `NODE_NAME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_CONTENT` varchar(1000) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_AREA` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `STORAGE_ID` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_STATE` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_SPHERE` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_CYCLE` varchar(15) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_EXECUTE_DAY` varchar(15) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_OPTTIME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_INVALIDTIME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_IDOPT` varchar(8) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_OPTOR_NAME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_ISORDER` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_DUTY` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_DUTY_TIME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_REVIEW` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_REVIEW_TIME` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `RULE_ID` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_SIMPLE_TABLE` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_ERROR_TABLE` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_FLOW_SEND` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_FLOW_TYPE` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `TYPE` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_PRIORITY` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_COMPARE` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_CHECK_TABLE` varchar(36) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_AUDIT_TYPE` int(1) DEFAULT '0' COMMENT '1 是正式运行稽核点',
  `NODE_TYPE` varchar(10) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `NODE_BATCH` int(10) unsigned DEFAULT NULL COMMENT '稽核点批次，根据系统表tb_Sys_varibale自动生成',
  `NODE_ORDER` varchar(12) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `LOGIN_ID` varchar(32) DEFAULT NULL COMMENT '操作人工号',
  `OP_TIME` datetime DEFAULT NULL COMMENT '最后修改时间',
  `PARENT_MENU_ID` varchar(10) DEFAULT NULL COMMENT '报表父级菜单',
  `MAX_DATA_TIME` varchar(20) DEFAULT NULL COMMENT '最新数据时间',
  PRIMARY KEY (`NODE_ID`),
  KEY `FK_Reference_2` (`ROOT_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `index_node_order` (`NODE_ORDER`) BLOCK_SIZE 16384 LOCAL,
  KEY `node_state` (`NODE_STATE`, `NODE_TYPE`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `tb_flow_form` (
  `ITASKID` varchar(20) NOT NULL COMMENT '任务ID',
  `ISERIALNO` varchar(20) NOT NULL COMMENT '任务流水',
  `PROCESSID` varchar(32) NOT NULL COMMENT '流程ID',
  `ICURRACTID` varchar(16) NOT NULL COMMENT '当前环节',
  `IS_PASS` varchar(10) DEFAULT NULL COMMENT '判断',
  `DEAL_REMARK` varchar(1000) DEFAULT NULL COMMENT '结论',
  `LOGIN_ID` varchar(32) DEFAULT NULL COMMENT '当前处理人',
  `NEXT_DEAL` varchar(225) DEFAULT NULL COMMENT '下一步处理人',
  `SUBMIT_DATE` varchar(32) DEFAULT NULL COMMENT '工单提交时间',
  `END_DATE` varchar(32) DEFAULT NULL COMMENT '下一步处理提交时间',
  `RANDOMID` varchar(40) DEFAULT NULL COMMENT '文件标识',
  `CHN_ID` varchar(32) DEFAULT NULL COMMENT '当前处理人的组织',
  PRIMARY KEY (`ITASKID`),
  KEY `1` (`DEAL_REMARK`) BLOCK_SIZE 16384 LOCAL,
  KEY `2` (`END_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `3` (`SUBMIT_DATE`) BLOCK_SIZE 16384 LOCAL,
  KEY `4` (`NEXT_DEAL`) BLOCK_SIZE 16384 LOCAL,
  KEY `5` (`LOGIN_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `index_ICURRACTID` (`ICURRACTID`) BLOCK_SIZE 16384 LOCAL,
  KEY `index_iserialno` (`ISERIALNO`) BLOCK_SIZE 16384 LOCAL,
  KEY `index_is_pass` (`IS_PASS`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '表单表';

CREATE TABLE `tb_chngroup_dict` (
  `group_id` varchar(20) COLLATE utf8mb4_bin NOT NULL COMMENT '行政机构编码',
  `group_name` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '行政机构名称',
  `has_child` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Y:有 N:没有',
  `is_active` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Y:有效 N:无效',
  `parent_group_id` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `parent_group_id1` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `parent_group_id2` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `ORDERING` int(20) DEFAULT '999',
  `TYPE` int(20) DEFAULT NULL,
  `GROUP_level` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `channel_type` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
  `parent_group_id3` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL,
  `CITY_G_ID` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '地市GROUP_ID',
  `CITY_G_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '地市名称',
  `AREA_G_ID` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '区县GROUP_ID',
  `AREA_G_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '区县名称',
  PRIMARY KEY (`group_id`),
  KEY `IDX_GROUP_DICT_A_G` (`AREA_G_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `IDX_GROUP_DICT_C_G` (`CITY_G_ID`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

--explain_protocol 3
SELECT /*+no_rewrite*/Count(0)
FROM   (SELECT '总计'            AS DISTRICT_NAME,
               MM.paidanlaingsm    AS PAIDANLIANGLIANGSM,
               MM.huidandata       AS HUIDANSM,
               MM.kuandaiyidata    AS SHENPITONGGUOSM,
               MM.kuandaierdata    AS ZAIZHENGGAISM,
               MM.yidongyismdata   AS YIDONGYICISM,
               MM.yidongercismdata AS YIDONGERCISM,
               MM.qiangzhigddata   AS QIANGZHISM
        FROM   (SELECT Sum(PAIDANLAING.task)        AS PAIDANLAINGSM,
                       Sum(HUIDAN.huidansm)         AS HUIDANDATA,
                       Sum(SHENPITONGGUO.kuandaiyi) AS KUANDAIYIDATA,
                       Sum(ZAIZHENGGAI.kuandaier)   AS KUANDAIERDATA,
                       Sum(YIDONGYICI.yidongyism)   AS YIDONGYISMDATA,
                       Sum(YIDONGERCI.yidongercism) AS YIDONGERCISMDATA,
                       Sum(QIANGZHI.qiangzhigd)     AS QIANGZHIGDDATA
                FROM   (SELECT district_name,
                               Count(*) TASK
                        FROM   (SELECT B.`district_name`,
                                       A.iserialno
                                FROM   tb_flow_iser_audit A
                                       LEFT JOIN tb_chngroup_dict DICT
                                              ON A.region_code = DICT.group_id
                                       LEFT JOIN bs_district B
                                              ON B.district_id =
                                                 DICT.parent_group_id2
                                       LEFT JOIN audit_regular_node NODE
                                              ON NODE.node_id = A.node_id
                                       INNER JOIN tb_flow_form C
                                               ON A.iserialno = C.iserialno
                                WHERE  A.regular_datatime LIKE
                                       Concat('202211', '%')
                                       AND NODE.node_id IN (
                                           'PK_NODE00453', 'PK_NODE00451',
                                           'PK_NODE00501',
                                           'PK_NODE00424'
                                           ,
                                           'PK_NODE00697', 'PK_NODE00422',
                                           'PK_NODE00627',
                                           'PK_NODE00571'
                                               ,
                                           'PK_NODE00524', 'PK_NODE00572',
                                           'PK_NODE00388',
                                           'PK_NODE00500'
                                               ,
                                           'PK_NODE00481', 'PK_NODE01015',
                                           'PK_NODE01004',
                                           'PK_NODE00977'
                                               ,
                                           'PK_NODE00627', 'PK_NODE00886',
                                           'PK_NODE00743',
                                           'PK_NODE00499'
                                               ,
                                           'PK_NODE00535', 'PK_NODE01154',
                                           'PK_NODE01152' )
                                GROUP  BY B.`district_name`,
                                          A.iserialno) T
                        GROUP  BY district_name) PAIDANLAING
                       LEFT JOIN (SELECT t.district_name,
                                         Count(*) huidansm
                                  FROM   (SELECT b.`district_name`
                                          FROM   tb_flow_iser_audit a
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON a.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district b
                                                        ON b.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           node
                                                        ON node.node_id =
                                                           a.node_id
                                                 INNER JOIN tb_flow_form c
                                                         ON a.iserialno =
                                                            c.iserialno
                                          WHERE  a.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND a.regular_datatime >=
                                                     Date_format(Date_sub(Now(),
                                                     INTERVAL 3 month
                                                     ),
                                                     '%Y%m%d')
                                                 AND c.is_pass IN ( '1', '1B' )
                                                 AND c.icurractid IN (
                                                     '50009603', '50010304',
                                                     '50010404',
                                                     '50010405',
                                                     '50010305', '50010905' )
                                                 AND node.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00535',
                                                     'PK_NODE00388'
                                                         ,
                                                     'PK_NODE00500',
                                                     'PK_NODE00481',
                                                     'PK_NODE00499',
                                                     'PK_NODE00743'
                                                         ,
                                                     'PK_NODE00886',
                                                     'PK_NODE00627',
                                                     'PK_NODE00977',
                                                     'PK_NODE01004'
                                                         ,
                                                     'PK_NODE01015',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                          GROUP  BY b.`district_name`,
                                                    a.iserialno) t
                                  GROUP  BY district_name) HUIDAN
                              ON HUIDAN.district_name =
                                 PAIDANLAING.district_name
                       LEFT JOIN (SELECT district_name,
                                         Count(*) KUANDAIYI
                                  FROM   (SELECT B.`district_name`,
                                                 A.iserialno
                                          FROM   tb_flow_iser_audit A
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON A.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district B
                                                        ON B.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           NODE
                                                        ON NODE.node_id =
                                                           A.node_id
                                                 INNER JOIN tb_flow_form C
                                                         ON A.iserialno =
                                                            C.iserialno
                                          WHERE  A.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND C.icurractid = '50010905'
                                                 AND A.pro_status = '1'
                                                 AND NODE.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00388',
                                                     'PK_NODE00500'
                                                         ,
                                                     'PK_NODE00481',
                                                     'PK_NODE01015',
                                                     'PK_NODE01004',
                                                     'PK_NODE00977'
                                                         ,
                                                     'PK_NODE00627',
                                                     'PK_NODE00886',
                                                     'PK_NODE00743',
                                                     'PK_NODE00499'
                                                         ,
                                                     'PK_NODE00535',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                          GROUP  BY B.`district_name`,
                                                    A.iserialno
                                          HAVING Count(*) = 1) T
                                  GROUP  BY district_name) SHENPITONGGUO
                              ON SHENPITONGGUO.district_name =
                                 PAIDANLAING.district_name
                       LEFT JOIN (SELECT district_name,
                                         Count(*) KUANDAIER
                                  FROM   (SELECT B.`district_name`,
                                                 A.iserialno
                                          FROM   tb_flow_iser_audit A
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON A.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district B
                                                        ON B.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           NODE
                                                        ON NODE.node_id =
                                                           A.node_id
                                                 INNER JOIN tb_flow_form C
                                                         ON A.iserialno =
                                                            C.iserialno
                                          WHERE  A.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND C.icurractid = '50010905'
                                                 AND A.no_audit != '1'
                                                 AND A.pro_status = '1'
                                                 AND NODE.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00388',
                                                     'PK_NODE00500'
                                                         ,
                                                     'PK_NODE00481',
                                                     'PK_NODE01015',
                                                     'PK_NODE01004',
                                                     'PK_NODE00977'
                                                         ,
                                                     'PK_NODE00627',
                                                     'PK_NODE00886',
                                                     'PK_NODE00743',
                                                     'PK_NODE00499'
                                                         ,
                                                     'PK_NODE00535',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                          GROUP  BY B.`district_name`,
                                                    A.iserialno
                                          HAVING Count(*) > 1) T
                                  GROUP  BY district_name) ZAIZHENGGAI
                              ON ZAIZHENGGAI.district_name =
                                 PAIDANLAING.district_name
                       LEFT JOIN (SELECT district_name,
                                         Count(*) YIDONGYISM
                                  FROM   (SELECT B.`district_name`,
                                                 A.iserialno
                                          FROM   tb_flow_iser_audit A
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON A.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district B
                                                        ON B.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           NODE
                                                        ON NODE.node_id =
                                                           A.node_id
                                                 INNER JOIN tb_flow_form C
                                                         ON A.iserialno =
                                                            C.iserialno
                                          WHERE  A.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND C.icurractid IN (
                                                     '50009603', '50010304',
                                                     '50010404',
                                                     '50010405',
                                                     '50010305'
                                                                     )
                                                 AND NODE.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00388',
                                                     'PK_NODE00500'
                                                         ,
                                                     'PK_NODE00481',
                                                     'PK_NODE01015',
                                                     'PK_NODE01004',
                                                     'PK_NODE00977'
                                                         ,
                                                     'PK_NODE00627',
                                                     'PK_NODE00886',
                                                     'PK_NODE00743',
                                                     'PK_NODE00499'
                                                         ,
                                                     'PK_NODE00535',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                                 AND C.is_pass IN (
                                                     '1', '1B', '1A' )
                                                 AND A.pro_status = '1'
                                          GROUP  BY B.`district_name`,
                                                    A.iserialno
                                          HAVING Count(*) = 1) T
                                  GROUP  BY district_name) YIDONGYICI
                              ON YIDONGYICI.district_name =
                                 PAIDANLAING.district_name
                       LEFT JOIN (SELECT district_name,
                                         Count(*) YIDONGERCISM
                                  FROM   (SELECT B.`district_name`,
                                                 A.iserialno
                                          FROM   tb_flow_iser_audit A
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON A.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district B
                                                        ON B.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           NODE
                                                        ON NODE.node_id =
                                                           A.node_id
                                                 INNER JOIN tb_flow_form C
                                                         ON A.iserialno =
                                                            C.iserialno
                                          WHERE  A.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND C.icurractid IN (
                                                     '50009603', '50010304',
                                                     '50010404',
                                                     '50010405',
                                                     '50010305'
                                                                     )
                                                 AND A.no_audit != '1'
                                                 AND NODE.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00388',
                                                     'PK_NODE00500'
                                                         ,
                                                     'PK_NODE00481',
                                                     'PK_NODE01015',
                                                     'PK_NODE01004',
                                                     'PK_NODE00977'
                                                         ,
                                                     'PK_NODE00627',
                                                     'PK_NODE00886',
                                                     'PK_NODE00743',
                                                     'PK_NODE00499'
                                                         ,
                                                     'PK_NODE00535',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                                 AND C.is_pass IN (
                                                     '1', '1B', '1A' )
                                                 AND A.pro_status = '1'
                                          GROUP  BY B.`district_name`,
                                                    A.iserialno
                                          HAVING Count(*) > 1) T
                                  GROUP  BY district_name) YIDONGERCI
                              ON YIDONGERCI.district_name =
                                 PAIDANLAING.district_name
                       LEFT JOIN (SELECT district_name,
                                         Count(*) QIANGZHIGD
                                  FROM   (SELECT B.`district_name`,
                                                 A.iserialno
                                          FROM   tb_flow_iser_audit A
                                                 LEFT JOIN tb_chngroup_dict DICT
                                                        ON A.region_code =
                                                           DICT.group_id
                                                 LEFT JOIN bs_district B
                                                        ON B.district_id =
                                                           DICT.parent_group_id2
                                                 LEFT JOIN audit_regular_node
                                                           NODE
                                                        ON NODE.node_id =
                                                           A.node_id
                                                 INNER JOIN tb_flow_form C
                                                         ON A.iserialno =
                                                            C.iserialno
                                          WHERE  A.regular_datatime LIKE
                                                 Concat('202211', '%')
                                                 AND A.pro_status = '10'
                                                 AND NODE.node_id IN (
                                                     'PK_NODE00453',
                                                     'PK_NODE00451',
                                                     'PK_NODE00501',
                                                     'PK_NODE00424'
                                                     ,
                                                     'PK_NODE00697',
                                                     'PK_NODE00422',
                                                     'PK_NODE00627',
                                                     'PK_NODE00571'
                                                         ,
                                                     'PK_NODE00524',
                                                     'PK_NODE00572',
                                                     'PK_NODE00388',
                                                     'PK_NODE00500'
                                                         ,
                                                     'PK_NODE00481',
                                                     'PK_NODE01015',
                                                     'PK_NODE01004',
                                                     'PK_NODE00977'
                                                         ,
                                                     'PK_NODE00627',
                                                     'PK_NODE00886',
                                                     'PK_NODE00743',
                                                     'PK_NODE00499'
                                                         ,
                                                     'PK_NODE00535',
                                                     'PK_NODE01154',
                                                     'PK_NODE01152' )
                                          GROUP  BY B.`district_name`,
                                                    A.iserialno) T
                                  GROUP  BY district_name) QIANGZHI
                              ON QIANGZHI.district_name =
                                 PAIDANLAING.district_name) MM
        UNION ALL
        SELECT PAIDANLAING.district_name,
               PAIDANLAING.task        AS PAIDANLIANGLIANGSM,
               HUIDAN.huidansm         AS HUIDANDATA,
               SHENPITONGGUO.kuandaiyi AS SHENPITONGGUOSM,
               ZAIZHENGGAI.kuandaier   AS ZAIZHENGGAISM,
               YIDONGYICI.yidongyism   AS YIDONGYICISM,
               YIDONGERCI.yidongercism AS YIDONGERCISM,
               QIANGZHI.qiangzhigd     AS QIANGZHISM
        FROM   (SELECT district_name,
                       Count(*) TASK
                FROM   (SELECT B.`district_name`,
                               A.iserialno
                        FROM   tb_flow_iser_audit A
                               LEFT JOIN tb_chngroup_dict DICT
                                      ON A.region_code = DICT.group_id
                               LEFT JOIN bs_district B
                                      ON B.district_id = DICT.parent_group_id2
                               LEFT JOIN audit_regular_node NODE
                                      ON NODE.node_id = A.node_id
                               INNER JOIN tb_flow_form C
                                       ON A.iserialno = C.iserialno
                        WHERE  A.regular_datatime LIKE Concat('202211', '%')
                               AND NODE.node_id IN (
                                   'PK_NODE00453', 'PK_NODE00451',
                                   'PK_NODE00501',
                                   'PK_NODE00424'
                                   ,
                                   'PK_NODE00697', 'PK_NODE00422',
                                   'PK_NODE00627',
                                   'PK_NODE00571'
                                       ,
                                   'PK_NODE00524', 'PK_NODE00572',
                                   'PK_NODE00388',
                                   'PK_NODE00500'
                                       ,
                                   'PK_NODE00481', 'PK_NODE01015',
                                   'PK_NODE01004',
                                   'PK_NODE00977'
                                       ,
                                   'PK_NODE00627', 'PK_NODE00886',
                                   'PK_NODE00743',
                                   'PK_NODE00499'
                                       ,
                                   'PK_NODE00535', 'PK_NODE01154',
                                   'PK_NODE01152' )
                        GROUP  BY B.`district_name`,
                                  A.iserialno) T
                GROUP  BY district_name) PAIDANLAING
               LEFT JOIN (SELECT t.district_name,
                                 Count(*) huidansm
                          FROM   (SELECT b.`district_name`
                                  FROM   tb_flow_iser_audit a
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON a.region_code = DICT.group_id
                                         LEFT JOIN bs_district b
                                                ON b.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node node
                                                ON node.node_id = a.node_id
                                         INNER JOIN tb_flow_form c
                                                 ON a.iserialno = c.iserialno
                                  WHERE  a.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND a.regular_datatime >=
                                             Date_format(Date_sub(Now(),
                                                         INTERVAL 3 month
                                                         ),
                                             '%Y%m%d')
                                         AND c.is_pass IN ( '1', '1B' )
                                         AND c.icurractid IN (
                                             '50009603', '50010304',
                                             '50010404',
                                             '50010405',
                                             '50010305', '50010905' )
                                         AND node.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00535',
                                             'PK_NODE00388'
                                                 ,
                                             'PK_NODE00500', 'PK_NODE00481',
                                             'PK_NODE00499',
                                             'PK_NODE00743'
                                                 ,
                                             'PK_NODE00886', 'PK_NODE00627',
                                             'PK_NODE00977',
                                             'PK_NODE01004'
                                                 ,
                                             'PK_NODE01015', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                  GROUP  BY b.`district_name`,
                                            a.iserialno) t
                          GROUP  BY district_name) HUIDAN
                      ON HUIDAN.district_name = PAIDANLAING.district_name
               LEFT JOIN (SELECT district_name,
                                 Count(*) KUANDAIYI
                          FROM   (SELECT B.`district_name`,
                                         A.iserialno
                                  FROM   tb_flow_iser_audit A
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON A.region_code = DICT.group_id
                                         LEFT JOIN bs_district B
                                                ON B.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node NODE
                                                ON NODE.node_id = A.node_id
                                         INNER JOIN tb_flow_form C
                                                 ON A.iserialno = C.iserialno
                                  WHERE  A.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND C.icurractid = '50010905'
                                         AND A.pro_status = '1'
                                         AND NODE.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00388',
                                             'PK_NODE00500'
                                                 ,
                                             'PK_NODE00481', 'PK_NODE01015',
                                             'PK_NODE01004',
                                             'PK_NODE00977'
                                                 ,
                                             'PK_NODE00627', 'PK_NODE00886',
                                             'PK_NODE00743',
                                             'PK_NODE00499'
                                                 ,
                                             'PK_NODE00535', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                  GROUP  BY B.`district_name`,
                                            A.iserialno
                                  HAVING Count(*) = 1) T
                          GROUP  BY district_name) SHENPITONGGUO
                      ON SHENPITONGGUO.district_name = PAIDANLAING.district_name
               LEFT JOIN (SELECT district_name,
                                 Count(*) KUANDAIER
                          FROM   (SELECT B.`district_name`,
                                         A.iserialno
                                  FROM   tb_flow_iser_audit A
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON A.region_code = DICT.group_id
                                         LEFT JOIN bs_district B
                                                ON B.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node NODE
                                                ON NODE.node_id = A.node_id
                                         INNER JOIN tb_flow_form C
                                                 ON A.iserialno = C.iserialno
                                  WHERE  A.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND C.icurractid = '50010905'
                                         AND A.pro_status = '1'
                                         AND A.no_audit != '1'
                                         AND NODE.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00388',
                                             'PK_NODE00500'
                                                 ,
                                             'PK_NODE00481', 'PK_NODE01015',
                                             'PK_NODE01004',
                                             'PK_NODE00977'
                                                 ,
                                             'PK_NODE00627', 'PK_NODE00886',
                                             'PK_NODE00743',
                                             'PK_NODE00499'
                                                 ,
                                             'PK_NODE00535', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                  GROUP  BY B.`district_name`,
                                            A.iserialno
                                  HAVING Count(*) > 1) T
                          GROUP  BY district_name) ZAIZHENGGAI
                      ON ZAIZHENGGAI.district_name = PAIDANLAING.district_name
               LEFT JOIN (SELECT district_name,
                                 Count(*) YIDONGYISM
                          FROM   (SELECT B.`district_name`,
                                         A.iserialno
                                  FROM   tb_flow_iser_audit A
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON A.region_code = DICT.group_id
                                         LEFT JOIN bs_district B
                                                ON B.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node NODE
                                                ON NODE.node_id = A.node_id
                                         INNER JOIN tb_flow_form C
                                                 ON A.iserialno = C.iserialno
                                  WHERE  A.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND C.icurractid IN (
                                             '50009603', '50010304',
                                             '50010404',
                                             '50010405',
                                             '50010305'
                                                             )
                                         AND NODE.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00388',
                                             'PK_NODE00500'
                                                 ,
                                             'PK_NODE00481', 'PK_NODE01015',
                                             'PK_NODE01004',
                                             'PK_NODE00977'
                                                 ,
                                             'PK_NODE00627', 'PK_NODE00886',
                                             'PK_NODE00743',
                                             'PK_NODE00499'
                                                 ,
                                             'PK_NODE00535', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                         AND C.is_pass IN ( '1', '1B', '1A' )
                                         AND A.pro_status = '1'
                                  GROUP  BY B.`district_name`,
                                            A.iserialno
                                  HAVING Count(*) = 1) T
                          GROUP  BY district_name) YIDONGYICI
                      ON YIDONGYICI.district_name = PAIDANLAING.district_name
               LEFT JOIN (SELECT district_name,
                                 Count(*) YIDONGERCISM
                          FROM   (SELECT B.`district_name`,
                                         A.iserialno
                                  FROM   tb_flow_iser_audit A
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON A.region_code = DICT.group_id
                                         LEFT JOIN bs_district B
                                                ON B.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node NODE
                                                ON NODE.node_id = A.node_id
                                         INNER JOIN tb_flow_form C
                                                 ON A.iserialno = C.iserialno
                                  WHERE  A.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND A.no_audit != '1'
                                         AND C.icurractid IN (
                                             '50009603', '50010304',
                                             '50010404',
                                             '50010405',
                                             '50010305'
                                                             )
                                         AND NODE.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00388',
                                             'PK_NODE00500'
                                                 ,
                                             'PK_NODE00481', 'PK_NODE01015',
                                             'PK_NODE01004',
                                             'PK_NODE00977'
                                                 ,
                                             'PK_NODE00627', 'PK_NODE00886',
                                             'PK_NODE00743',
                                             'PK_NODE00499'
                                                 ,
                                             'PK_NODE00535', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                         AND C.is_pass IN ( '1', '1B', '1A' )
                                         AND A.pro_status = '1'
                                  GROUP  BY B.`district_name`,
                                            A.iserialno
                                  HAVING Count(*) > 1) T
                          GROUP  BY district_name) YIDONGERCI
                      ON YIDONGERCI.district_name = PAIDANLAING.district_name
               LEFT JOIN (SELECT district_name,
                                 Count(*) QIANGZHIGD
                          FROM   (SELECT B.`district_name`,
                                         A.iserialno
                                  FROM   tb_flow_iser_audit A
                                         LEFT JOIN tb_chngroup_dict DICT
                                                ON A.region_code = DICT.group_id
                                         LEFT JOIN bs_district B
                                                ON B.district_id =
                                                   DICT.parent_group_id2
                                         LEFT JOIN audit_regular_node NODE
                                                ON NODE.node_id = A.node_id
                                         INNER JOIN tb_flow_form C
                                                 ON A.iserialno = C.iserialno
                                  WHERE  A.regular_datatime LIKE
                                         Concat('202211', '%')
                                         AND A.pro_status = '10'
                                         AND NODE.node_id IN (
                                             'PK_NODE00453', 'PK_NODE00451',
                                             'PK_NODE00501',
                                             'PK_NODE00424'
                                             ,
                                             'PK_NODE00697', 'PK_NODE00422',
                                             'PK_NODE00627',
                                             'PK_NODE00571'
                                                 ,
                                             'PK_NODE00524', 'PK_NODE00572',
                                             'PK_NODE00388',
                                             'PK_NODE00500'
                                                 ,
                                             'PK_NODE00481', 'PK_NODE01015',
                                             'PK_NODE01004',
                                             'PK_NODE00977'
                                                 ,
                                             'PK_NODE00627', 'PK_NODE00886',
                                             'PK_NODE00743',
                                             'PK_NODE00499'
                                                 ,
                                             'PK_NODE00535', 'PK_NODE01154',
                                             'PK_NODE01152' )
                                  GROUP  BY B.`district_name`,
                                            A.iserialno) T
                          GROUP  BY district_name) QIANGZHI
                      ON QIANGZHI.district_name = PAIDANLAING.district_name) K
WHERE  k.district_name LIKE Concat('%', ''); 
--explain_protocol 0

set ob_query_timeout = 10000000;
--disable_warnings
drop table if exists tb_flow_iser_audit, bs_district, audit_regular_node, tb_flow_form, tb_chngroup_dict;
--enable_warnings

