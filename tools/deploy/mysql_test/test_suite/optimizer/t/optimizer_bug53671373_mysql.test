## 

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
use oceanbase;

--result_format 4
explain basic select 1 from __all_virtual_session_info where id is null;
explain basic select 1 from __all_virtual_table where comment is not null and index_type is not null;
explain basic select 1 from __all_virtual_sql_plan_monitor where trace_id is not null and output_rows is null;
explain basic select 1 from __all_virtual_table_stat where partition_id is not null or object_type is not null;
explain basic select 1 from __all_virtual_histogram_stat where partition_id is not null or object_type is null;
explain basic select 1 from __all_virtual_dblink_info where protocol is null; 
