--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
#tags: pl, optimizer, outline

##
## Test Name: plan_cache_hint
##
## Scope: test function of plan cache hint for mysql mode.
##
##
## Date: 2019-6-22
##
--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
drop table if exists t8;
drop table if exists t9;
--enable_warnings

alter system flush plan cache global;

create table t1(a int primary key, b int, c int, d int);
create index ti1 on t1 (b);
insert into t1 values(1, 2, 3, 4);
insert into t1 values(3, 2, 3, 6);
insert into t1 values(2, 2, 3, 6);
insert into t1 values(4, 4, 3, 6);
create table t2(a int, b int, c int);
insert into t2 values(1, 2, 3);
insert into t2 values(2, 3, 4);
create table t3(a int, b int, c int, d int, primary key(a,b));
create index i1 on t3 (b);
create index i2 on t3 (c, d);
create table t4(a int, b int, c int);
create table t5(a int, b int, c int);
create table t6(a int, b int, c int);
create table t7(a int, b int, c int);
create table t8(a int, b int, c int);
create table t9(a int, b int, c int);

#single hint: use_nl(t1, t2) 当其中任意一个为右表，就使用nl的连接算法
explain select /*+use_nl(t1,t2)*/* from t1,t2 where t1.a=t2.a;
select /*+use_nl(t1,t2)*/* from t1,t2 where t1.a=t2.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='4A21D0F429A318EE2FB66E6C5C5D23DC';

explain select /*+use_hash(t1,t2)*/* from t1,t2 where t1.a=t2.a;
select /*+use_hash(t1,t2)*/* from t1,t2 where t1.a=t2.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='3E3045AEF44A89211B96B344CD5AC70F';

####error test.
explain select /*+use_hash(t1)*/* from t1,t2 where t1.a=t2.a;
select /*+use_hash(t1)*/* from t1,t2 where t1.a=t2.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='FEE03166F84C5526A27274A2475EB14D';

#其中有一个冲突的hint,use_nl没有生效
explain select /*+leading(t1,t2), use_nl(t1)*/* from t1,t2 where t1.a=t2.a;
select /*+leading(t1,t2), use_nl(t1)*/* from t1,t2 where t1.a=t2.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='7344D4E0FA2624FD48519BE103BB94EE';

#两个hint都生效
explain select /*+leading(t1,t2), use_nl(t2)*/* from t1,t2 where t1.a=t2.a;
select /*+leading(t1,t2), use_nl(t2)*/* from t1,t2 where t1.a=t2.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='0500CAF46F9BC75046F2E48EEFC29CC1';

#no_rewrite
explain select /*+no_rewrite*/(select sum(b) from t1 where t1.a = t2.a) from t2 where t2.a > 1;
select /*+no_rewrite*/(select sum(b) from t1 where t1.a = t2.a) from t2 where t2.a > 1;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='4E7B6D20CAEB2357EC00FF73F94170EB';

#none
explain select /*+*/* from t1 where a > 1;
select /*+*/* from t1 where a > 1;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='3401D9B21C1EF8F358B292C2537E68FF';

#用px
explain select /*+use_px*/a, sum(b) from t1 group by a;
select /*+use_px*/a, sum(b) from t1 group by a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='0834E683AFDC510455FB432B189441A9';

####error test.
explain select a, sum(b) from t1 group by a;
select a, sum(b) from t1 group by a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='19EB1CD5A041CFB27F7F68FF689119D6';

explain select /*+leading(t3,(t4,t5)) use_merge((t4,t5))*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select /*+leading(t3,(t4,t5)) use_merge((t4,t5))*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='ECBCA1C03A8A79DE11711A3658CD0418';

explain select /*+leading(t3,(t4,t5)) use_merge(t3, (t4,t5))*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select /*+leading(t3,(t4,t5)) use_merge(t3, (t4,t5))*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='EE919559AAC906A0473C0A1A15EB54BC';

explain select /*+leading(t3,(t4,t5)) use_merge(t3)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select /*+leading(t3,(t4,t5)) use_merge(t3)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='007DA1FE24B83124E10D36A2DAECDF0B';

explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='FE5A57F62460577C1D02CC2080EF98C1';

explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5) use_nl(t6,t7)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5) use_nl(t6,t7)*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='40D3220CF155D8C13B75A5A31537239A';

explain select /*+leading(t3,(t4,t5),(t6,t7)) use_nl(t3,(t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select /*+leading(t3,(t4,t5),(t6,t7)) use_nl(t3,(t4,t5),(t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select hints_info, hints_all_worked from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='47ADF2D5DFBF02D7FC3CFB486A20693C';

explain select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5) use_nl((t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
select /*+leading(t3,(t4,t5),(t6,t7)) use_merge(t3,(t4,t5),(t6,t7)) use_hash(t4,t5) use_nl((t6,t7))*/* from t3,t4,t5,t6,t7 where t3.a=t4.a and t4.a=t5.a and t5.a=t6.a and t6.a=t7.a;
