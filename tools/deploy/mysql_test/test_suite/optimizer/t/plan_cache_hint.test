#pq_distribute
explain select /*+use_px parallel(4) leading(t3,(t4,t5)) pq_distribute((t4,t5) broadcast none)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
select /*+use_px parallel(4) leading(t3,(t4,t5)) pq_distribute((t4,t5) broadcast none)*/* from t3,t4,t5 where t3.a=t4.a and t4.a=t5.a;
