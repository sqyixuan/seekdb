select count(*) from `l`;
select count(*) from `gg`;
select count(*) from `y`;
select count(*) from `j`;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
SELECT  GRANDPARENT1 . col_date AS G1 
FROM o AS GRANDPARENT1 
WHERE GRANDPARENT1 . `col_varchar_20_key` IN ( 
      SELECT DISTINCT PARENT1 . `col_varchar_20_key` AS P1 
      FROM ii AS PARENT1 LEFT JOIN oo AS PARENT2 USING ( col_date ) 
      WHERE GRANDPARENT1 . `col_varchar_20_key` IN ( 
            SELECT  CHILD1 . `col_varchar_20` AS C1 
            FROM ff AS CHILD1 
            WHERE ( ( CHILD1 . `col_int` < GRANDPARENT1 . `col_int_key` ) OR NOT ( ( CHILD1 . `col_int` > GRANDPARENT1 . `pk` ) OR ( PARENT1 . `col_varchar_10_key` = 'p' ) ) )  ) 
      AND ( GRANDPARENT1 . `pk` > 2 )  ) 
AND ( ( ( GRANDPARENT1 . `col_varchar_20_key` <= 'z' AND GRANDPARENT1 . `col_date` <> '2003-08-09' ) OR GRANDPARENT1 . `col_varchar_20` > 'j' ) OR GRANDPARENT1 . `col_varchar_10` <= 'b' ) 
GROUP BY GRANDPARENT1 . col_date 
HAVING G1 <> '2000-07-07 10:21:59' 
ORDER BY GRANDPARENT1 . col_date 
LIMIT 0;

SELECT DISTINCT GRANDPARENT1 . col_varchar_20 AS G1
FROM l AS GRANDPARENT1
WHERE GRANDPARENT1 . `col_int` IN
    (SELECT DISTINCT PARENT1 . `pk` AS P1
     FROM gg AS PARENT1
     LEFT JOIN j AS PARENT2 USING (col_varchar_20)
     WHERE PARENT1 . `col_varchar_20` IN
         (SELECT CHILD1 . `col_varchar_10_key` AS C1
          FROM y AS CHILD1
          LEFT JOIN gg AS CHILD2 ON (CHILD1 . `col_int_key` <> CHILD2 . `col_int_key`)
          WHERE ((CHILD1 . `pk` >= GRANDPARENT1 . `col_int_key`)
                 OR ((CHILD1 . `pk` < GRANDPARENT1 . `col_int_key`)
                     AND ((PARENT1 . `col_varchar_10` >= PARENT1 . `col_varchar_20`)
                          OR NOT ((PARENT1 . `pk` = GRANDPARENT1 . `col_int`)
                                  AND (PARENT1 . `col_int` >= 1))))) )
       AND ((PARENT1 . `col_date` <= PARENT1 . `col_date`)
            OR ((PARENT1 . `col_int` <> GRANDPARENT1 . `pk`)
                AND (PARENT1 . `col_varchar_20_key` > 'o'))) )
  AND GRANDPARENT1 . `col_varchar_20_key` > 'q'
HAVING G1 <> '2006-08-15'
ORDER BY GRANDPARENT1 . col_varchar_20
LIMIT 4;

drop table `oo`,`ff`,`ii`, `o`, `l`,`gg`,`y`,`j`;
