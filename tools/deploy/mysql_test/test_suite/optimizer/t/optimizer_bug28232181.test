--result_format 4


##bug 


--disable_warnings
drop table if exists tp1;
--enable_warnings

create table tp1(c1 int, c2 int) partition by hash(c1) partitions 2;

--disable_query_log
--disable_result_log
--let $count1 = 0
while($count1 < 5)
{
  --let $count2 = 0
  while($count2 < 5)
  {
    --let $stmt=insert into tp1(c1, c2) values ($count1, $count2)
    --let $count3 = 0
    while($count3 < 1000)
    {
      eval $stmt;
      inc $count3;
    }
    inc $count2;
  }
  inc $count1;
}
select count(*) from tp1;
--enable_query_log
--enable_result_log

--explain_protocol 1

select sum(distinct c1) from tp1 group by c2;
select /*+no_use_hash_aggregation*/ sum(distinct c1) from tp1 group by c2;
select /*+no_use_px*/ sum(distinct c1) from tp1 group by c2;

select sum(distinct c2) from tp1 group by c1;
select /*+no_use_hash_aggregation*/ sum(distinct c2) from tp1 group by c1;
select /*+no_use_px*/ sum(distinct c2) from tp1 group by c1;

select sum(distinct c1) from tp1 group by c1;
select /*+no_use_hash_aggregation*/ sum(distinct c1) from tp1 group by c1;
select /*+no_use_px*/ sum(distinct c1) from tp1 group by c1;

drop table tp1;
