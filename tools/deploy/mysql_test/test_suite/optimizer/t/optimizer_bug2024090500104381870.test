INSERT /*+parallel(5) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t1(c4, c1, c0) select c4, c1, c0 from t1;
INSERT /*+parallel(5) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t2(c4, c1, c0) select c4, c1, c0 from t1;

call dbms_stats.gather_table_stats(NULL,'t1');
call dbms_stats.gather_table_stats(NULL,'t2');

INSERT /*+parallel(5) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t1(c4, c1, c0) select c4, c1, c0 from t1;
INSERT /*+parallel(5) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t2(c4, c1, c0) select c4, c1, c0 from t1;

--sorted_result
select /*+ full(t1) */ c4 from t1 where c4 < 'a' and c4 > '0';
--sorted_result
select /*+ full(t1) */ c4 from t2 where c4 < 'a' and c4 > '0';

drop table if exists t1;
drop table if exists t2;

