# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t2,t5;
--enable_warnings
create table t5 (c5 int);
create table t2 (c13 int);

--explain_protocol 2
--result_format 4

SELECT 
/*+                                
      LEADING("T5_27" "T2_3509215_1")
      USE_HASH("T2_3509215_1")
      PQ_DISTRIBUTE("T2_3509215_1" NONE BROADCAST)
      PX_JOIN_FILTER(T2_3509215_1)                                     
      PARALLEL("T2_3509215_1" 2)                                                
  */  
(SELECT /*+no_unnest*/ 1 FROM   dual)
FROM   (SELECT T5_27.c5 C12

        FROM   t5 T5_27) T5_27,
       t2 T2_3509215_1
WHERE  T5_27.c12 = T2_3509215_1.c13;

drop table if exists t2,t5;
