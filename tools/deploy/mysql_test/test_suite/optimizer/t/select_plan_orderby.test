--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
# owner: sean.yyj
# owner group: SQL1
# tags: optimizer
--disable_warnings
drop table if exists select5_t3;
drop table if exists select5_t1;

create table select5_t3(a int primary key, a5 int, c int) partition by hash(a) partitions 3;
create index i_select5_t3 on select5_t3(a5) partition by hash(a5) partitions 4;
create table select5_t1(a int primary key, a5 int, c int) partition by hash(a) partitions 4;
create index i_select5_t1 on select5_t1(a5) partition by hash(a5) partitions 4;
set @rownum=0;
insert into select5_t1(a, a5, c) select @rownum:=@rownum+1, @rownum+1, @rownum+2 from table(generator(30)) t;
set @rownum=0;
insert into select5_t3(a, a5, c) select @rownum:=@rownum+1, @rownum+1, @rownum+2 from table(generator(39)) t;

--enable_query_log
--enable_warnings
--result_format 4
--explain_protocol 1
SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY 1, 2, 3, 4, 5;

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY 1, 2, 3, 4, 5 limit 5;

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY 1, 2, 3, 4, 5, 6;

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY 1, 2, 3, 4, 5, 6 limit 5;

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5);

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5);

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
       limit 5;

SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
       limit 5;

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_sys;
alter system set _enable_px_ordered_coord = true;
connection default;

select /*+no_rewrite*/* from (
SELECT /*+parallel(4)*/
       B.a5,
       B.a,
       B.c,
       B.a5 NOT IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t3 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5),
       B.a5 IN (SELECT /*+no_use_das(A)*/ A.a5 FROM   select5_t1 A WHERE  A.a5 = B.a5)
FROM select5_t3 B ORDER  BY 1, 2, 3, 4, 5 limit 5) order by 1, 2, 3, 4;

drop table select5_t3;
drop table select5_t1;


--disable_warnings
drop table if exists t6;
--enable_warnings
CREATE TABLE `t6` (
  `c1` bigint(127) NOT NULL AUTO_INCREMENT,
  `c2` binary(124) DEFAULT NULL,
  `c3` varbinary(77) DEFAULT NULL,
  `c4` bigint(127) DEFAULT NULL,
  `c5` date DEFAULT NULL,
  `c6` decimal(64,10) DEFAULT NULL,
  `c7` decimal(64,19) DEFAULT NULL,
  `c8` varchar(86) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c9` datetime DEFAULT NULL,
  `c10` int(127) DEFAULT NULL,
  `c11` datetime DEFAULT NULL,
  `c12` decimal(64,8) DEFAULT NULL,
  `c13` int(127) DEFAULT NULL,
  `c14` varchar(86) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c15` bigint(127) DEFAULT NULL,
  `c16` bigint(127) DEFAULT NULL,
  `c17` decimal(64,15) DEFAULT NULL,
  `c18` timestamp(5) NOT NULL DEFAULT '0000-00-00 00:00:00.00000',
  `c19` datetime DEFAULT NULL,
  `c20` date DEFAULT NULL,
  `c21` time DEFAULT NULL,
  `c22` varbinary(82) DEFAULT NULL,
  `c23` varbinary(82) DEFAULT NULL,
  `c24` char(152) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c25` decimal(64,14) DEFAULT NULL,
  `c26` char(152) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c27` decimal(64,28) DEFAULT NULL,
  `c28` varbinary(73) DEFAULT NULL,
  `c29` binary(142) DEFAULT NULL,
  `c30` year(4) DEFAULT NULL,
  `c31` datetime DEFAULT NULL,
  `c32` int(127) DEFAULT NULL,
  `c33` varchar(86) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c34` datetime DEFAULT NULL,
  `c35` binary(74) DEFAULT NULL,
  `c36` varbinary(68) DEFAULT NULL,
  `c37` year(4) DEFAULT NULL,
  `c38` timestamp(2) NOT NULL DEFAULT '0000-00-00 00:00:00.00',
  `c39` date DEFAULT NULL,
  `c40` varchar(86) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c41` int(127) DEFAULT NULL,
  `c42` date DEFAULT NULL,
  `c43` date DEFAULT NULL,
  `c44` timestamp(5) NOT NULL DEFAULT '0000-00-00 00:00:00.00000',
  `c45` decimal(64,28) DEFAULT NULL,
  `c46` bigint(127) DEFAULT NULL,
  `c47` int(127) DEFAULT NULL,
  `c48` timestamp(3) NOT NULL DEFAULT '0000-00-00 00:00:00.000',
  `c49` decimal(64,0) GENERATED ALWAYS AS ((`c32` + `c4`)) VIRTUAL
);
SELECT /*+  use_px parallel(t6, 6) */ t6.c1, t6.c2, t6.c49 FROM t6 ORDER BY 1,2 ,3;
drop table t6;

connection conn_sys;
alter system set _enable_px_ordered_coord = false;