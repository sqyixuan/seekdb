--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhenling.zzg
#owner group: sql1
#tags: optimizer
#bug:

--disable_warnings
drop table if exists t, t1, t2, dmp_dynamic_tag_option;
--enable_warnings

create table t1(pk int primary key, c1 int, c2 int);
create index t1_c2 on t1(c2) local;
create table t2(pk int primary key, c1 int, c2 int) partition by hash(pk) partitions 2;
create index t2_c2 on t2(c2) global;

create table t (c1 int, c2 int, c3 int, primary key (c1));
create index gidx on t (c2, c1) global partition by hash(c2) partitions 4;

## bug 
CREATE TABLE dmp_dynamic_tag_option (
id int,
option_type_id int,
option_value varchar(200),
option_name varchar(400),
member_id int,
permission_entity_id int,
parent_option_id int,
parent_option_value varchar(200),
order_num int,
create_time timestamp,
PRIMARY KEY (id)
);
create index idx_query on dmp_dynamic_tag_option(option_type_id);
create index idx_optiontype_member on dmp_dynamic_tag_option(option_type_id, member_id);
create index idx_optiontype_parent_optionvalue on dmp_dynamic_tag_option(option_type_id, parent_option_value);
--source mysql_test/include/check_all_idx_ok.inc

--disable_query_log
--let $count = 0
while($count < 500)
{
  --let $stmt1=insert into t1(pk, c1, c2) values ($count, 1, 1);
  --let $stmt2=insert into t2(pk, c1, c2) values ($count, 1, 1);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}
while($count < 1000)
{
  --let $stmt1=insert into t1(pk, c1, c2) values ($count, 2, 2);
  --let $stmt2=insert into t2(pk, c1, c2) values ($count, 2, 2);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}
while($count < 1500)
{
  --let $stmt2=insert into t2(pk, c1, c2) values ($count, 3, 3);
  eval $stmt2;
  inc $count;
}
while($count < 2000)
{
  --let $stmt2=insert into t2(pk, c1, c2) values ($count, 4, 4);
  eval $stmt2;
  inc $count;
}
insert into t values (1, 1, 1);
insert into t values (2, 1, 1);
insert into t values (3, 2, 1);
insert into t values (4, 2, 1);

--enable_query_log
--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't');
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 't2');
call dbms_stats.gather_table_stats('TEST', 'dmp_dynamic_tag_option');

--result_format 4
explain select * from t1 where c2 = 2;
explain select * from t1 where c2 = 2 limit 499;
explain select * from t1 where c2 = 2 limit 501;
explain select c1, c2 from t2 where c2 = 2;
explain select /*+full(t2)*/ c1, c2 from t2 where c2 = 2 limit 999;
explain select /*+index(t2 t2_c2)*/ c1, c2 from t2 where c2 = 2 limit 999;
explain select c1, c2 from t2 where c2 = 2 limit 499;
explain select c1, c2 from t2 where c2 = 2 limit 501;
explain select c1, c2 from t2 where c2 = 2 limit 999;
explain select c1, c2 from t2 where c2 = 2 limit 1001;
explain SELECT DISTINCT o.id as id ,o.option_type_id as optionTypeId ,o.option_value as optionValue ,o.option_name as optionName ,o.order_num as orderNum ,o.member_id as memberId ,o.permission_entity_id as permissionEntityId ,o.parent_option_id as parentOptionId ,o.parent_option_value as parentOptionValue ,o.create_time as createTime FROM dmp_dynamic_tag_option o WHERE o.parent_option_value = '8598007' AND o.option_type_id = 901000022 limit 5;

# bug: 
explain select /*+index(t gidx)*/ c2 from t limit 1;
select /*+index(t gidx)*/ c2 from t limit 1;

explain select /*+index(t2 t2_c2), use_px, parallel(2)*/ c2 from t2 limit 1;
select /*+index(t2 t2_c2), use_px, parallel(2)*/ c2 from t2 limit 1;
