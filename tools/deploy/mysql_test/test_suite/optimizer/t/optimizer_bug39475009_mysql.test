--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#bug:

--disable_warnings
--explain_protocol 0
drop table if exists t0, t1;
create table t0(c0 int,c1 int,c2 int);
create table t1(c0 int,c1 int,c2 int);

--explain_protocol 2
SELECT count(*) as rowCount FROM (SELECT /*+  PARALLEL(5)   */ t0.c0 AS t0c0, t1.c0 AS t1c0 FROM t0, t1 
	GROUP BY t0.c0, t1.c0 ORDER BY t0.c0 DESC) as result WHERE result.t0c0 = FALSE AND result.t1c0 = FALSE;

insert into t0 values(0, 0, 0);
insert into t1 values(0, 0, 0);

SELECT count(*) as rowCount FROM (SELECT /*+  PARALLEL(5)   */ t0.c0 AS t0c0, t1.c0 AS t1c0 FROM t0, t1 
	GROUP BY t0.c0, t1.c0 ORDER BY t0.c0 DESC) as result WHERE result.t0c0 = FALSE AND result.t1c0 = FALSE;

drop table if exists t0, t1;
