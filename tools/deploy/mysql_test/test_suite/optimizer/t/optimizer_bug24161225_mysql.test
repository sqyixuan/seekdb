--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
--disable_result_log
create table t1 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk) partitions 4;
create table t2 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk) partitions 5;
create table t3 (pk int primary key, c1 int, c2 int, c3 int, index idx (c1) local) partition by hash(pk) partitions 5;
alter system set ob_enable_batched_multi_statement = true;
sleep 10;

--disable_query_log
--disable_result_log
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2
insert into t1 select /*+use_nl(t1,t2)*/ t1.* from t1, t2 where t1.pk = t2.pk;
insert into t1 select /*+use_merge(t1,t2)*/ t1.* from t1, t2 where t1.pk = t2.pk;
insert into t1 select /*+use_hash(t1,t2)*/ t1.* from t1, t2 where t1.pk = t2.pk;
insert into t1 select distinct c1, 1, 1, 1 from t3;
insert into t1 select /*+index(t3 primary) */ distinct c1, 1, 1, 1 from t3;
insert into t1 select c1, 1, 1, 1 from t3 order by c1 limit 5;
insert into t1 select /*+index(t3 primary) */ c1, 1, 1, 1 from t3 order by c1 limit 5;
alter system set ob_enable_batched_multi_statement = false;
