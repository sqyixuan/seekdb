col_int_key int,
pk int,
/*Indices*/
key idx5(col_varchar_20_key ),
key idx9(col_datetime_key ),
key idx7(col_date_key ),
key idx3(col_varchar_10_key ),
key idx1(col_int_key ))    PARTITION BY key (pk,col_int_key) partitions 13  ; 
