--disable_warnings
DROP TABLE IF EXISTS O; 
--enable_warnings

CREATE  TABLE O (
col_datetime datetime,
col_int int,
col_int_key int,
col_date_key date,
col_varchar_10 varchar(10),
col_date date,
pk int,
col_datetime_key datetime,
col_varchar_20 varchar(20),
col_varchar_20_key varchar(20),
col_varchar_10_key varchar(10),
/*Indices*/
key idx1(col_int_key ),
key idx7(col_date_key ),
key idx9(col_datetime_key ),
key idx5(col_varchar_20_key ),
key idx3(col_varchar_10_key ))    PARTITION BY key (col_varchar_20_key)
                subpartition by range(year(col_datetime_key))
                subpartition template
                (subpartition p0 values less than (2000),
                subpartition p1 values less than (2003),
                subpartition p2 values less than (2007),
                subpartition p3 values less than (2010),
                subpartition p4 values less than (maxvalue))
                partitions 10  ; 
