--explain_protocol 2
SELECT 1 AS Y FROM  C AS OUTR WHERE OUTR . col_varchar_20 IN ( SELECT /*+PUSH_SUBQ*/ DISTINCT INNR . col_varchar_10_key AS Y FROM  C AS INNR ) AND OUTR . `col_date_key` >= '2000-10-22' or 'o' = OUTR . col_varchar_20_key or OUTR . col_varchar_20_key < 'd';
SELECT /*+ no_rewrite */ 1 AS Y FROM  C AS OUTR WHERE OUTR . col_varchar_20 IN ( SELECT /*+PUSH_SUBQ*/ DISTINCT INNR . col_varchar_10_key AS Y FROM  C AS INNR ) AND OUTR . `col_date_key` >= '2000-10-22' or 'o' = OUTR . col_varchar_20_key or OUTR . col_varchar_20_key < 'd';
SELECT /*+ no_rewrite  UNION_MERGE("OUTR"@"SEL$1" "idx7" "idx5" "idx5") */ 1 AS Y FROM  C AS OUTR WHERE OUTR . col_varchar_20 IN ( SELECT /*+PUSH_SUBQ*/ DISTINCT INNR . col_varchar_10_key AS Y FROM  C AS INNR ) AND OUTR . `col_date_key` >= '2000-10-22' or 'o' = OUTR . col_varchar_20_key or OUTR . col_varchar_20_key < 'd';
SELECT  DISTINCT SUM(DISTINCT OUTR . `col_int_key` ) AS X, 1 AS Y FROM  C AS OUTR WHERE OUTR . col_varchar_20 IN ( SELECT /*+PUSH_SUBQ*/ DISTINCT INNR . col_varchar_10_key AS Y FROM  C AS INNR ) AND OUTR . `col_date_key` >= '2000-10-22' or 'o' = OUTR . col_varchar_20_key or OUTR . col_varchar_20_key < 'd'  HAVING X < '2009-01-23' order by X, Y ;
SELECT /*+ no_rewrite  UNION_MERGE("OUTR"@"SEL$1" "idx7" "idx5" "idx5") */ DISTINCT SUM(DISTINCT OUTR . `col_int_key` ) AS X, 1 AS Y FROM  C AS OUTR WHERE OUTR . col_varchar_20 IN ( SELECT /*+PUSH_SUBQ*/ DISTINCT INNR . col_varchar_10_key AS Y FROM  C AS INNR ) AND OUTR . `col_date_key` >= '2000-10-22' or 'o' = OUTR . col_varchar_20_key or OUTR . col_varchar_20_key < 'd'  HAVING X < '2009-01-23' order by X, Y ;

--explain_protocol 0
