--explain_protocol 2
SELECT /*+ ENABLE_PARALLEL_DML PARALLEL(2) */ OUTR . `col_int_key`  AS X, 1 AS Y FROM  T AS OUTR RIGHT JOIN (SELECT * FROM  T WHERE col_varchar_20_key >= 'r' ORDER BY `col_datetime`) OUTR2 ON ( OUTR2 . `col_int_key` = (select INNR . `col_int_key` from  T AS INNR where OUTR . `pk` = INNR . `pk` order by 1 limit 1) ) WHERE  NOT (( OUTR . col_varchar_20 , OUTR . col_varchar_20 ) IN ( SELECT  INNR . col_varchar_20 AS X , INNR . col_varchar_20 AS Y FROM T INNR) OR 'e' <> OUTR . col_varchar_20);
SELECT /*+ NO_REWRITE ENABLE_PARALLEL_DML PARALLEL(2) */ OUTR . `col_int_key`  AS X, 1 AS Y FROM  T AS OUTR RIGHT JOIN (SELECT * FROM  T WHERE col_varchar_20_key >= 'r' ORDER BY `col_datetime`) OUTR2 ON ( OUTR2 . `col_int_key` = (select INNR . `col_int_key` from  T AS INNR where OUTR . `pk` = INNR . `pk` order by 1 limit 1) ) WHERE  NOT (( OUTR . col_varchar_20 , OUTR . col_varchar_20 ) IN ( SELECT  INNR . col_varchar_20 AS X , INNR . col_varchar_20 AS Y FROM T INNR) OR 'e' <> OUTR . col_varchar_20);
SELECT /*+ PARALLEL(1) */ 1 AS Y
FROM T AS OUTR INNER JOIN T OUTR2 ON (
  OUTR2.`col_int_key` = ( select INNR.`col_int_key` from T AS INNR where OUTR.`pk` = INNR.`pk` order by 1 limit 1)
) WHERE 'e' NOT IN ( SELECT INNR2.col_varchar_20 FROM T INNR2);

--explain_protocol 0
DROP TABLE T;

--disable_warnings
DROP TABLE IF EXISTS E; 
--enable_warnings

CREATE  TABLE E (
col_int int,
col_int_key int,
col_varchar_10 varchar(10),
col_varchar_10_key varchar(10),
col_datetime_key datetime,
col_varchar_20_key varchar(20),
pk int,
col_date date,
col_date_key date,
col_varchar_20 varchar(20),
col_datetime datetime,
/*Indices*/
key idx1(col_int_key ),
key idx3(col_varchar_10_key ),
key idx9(col_datetime_key ),
key idx5(col_varchar_20_key ),
key idx7(col_date_key ))    PARTITION BY key (pk,col_datetime_key) partitions 8 ; 

--explain_protocol 2
SELECT 1 from (SELECT * FROM  E WHERE `col_datetime` in ('2005-10-03') ORDER BY col_varchar_10) AS OUTR2,  E AS OUTR where OUTR2 . `col_datetime` = (select /*+PUSH_SUBQ*/ INNR . `col_datetime` from  E AS INNR where OUTR . col_varchar_20_key > 'g' and INNR . col_varchar_10_key > 'n' order by 1 limit 1) and ( exists (select /*+NO_MERGE NO_PUSH_SUBQ*/ `col_int` from  E where OUTR . `col_date_key` BETWEEN '2002-09-03' AND '2008-06-12') AND OUTR . col_varchar_20 <= 'm' );
select 1
from `e` `OUTR`,
     `e` `OUTR2`,
     `e` `OUTR3`
where (
        `OUTR2`.`col_datetime` = (
            select /*+ PUSH_SUBQ */ `INNR`.`col_datetime`
            from `e` `INNR`
            where (`OUTR`.`col_varchar_20_key` > 'g')
            order by 1
            limit 1
        )
    )
    and (`OUTR2`.`col_datetime` = '2005-10-03');
select /*+no_rewrite*/ 1
from `e` `OUTR`,
     `e` `OUTR2`,
     `e` `OUTR3`
where (
        '2005-10-03' = (
            select /*+ PUSH_SUBQ */ `INNR`.`col_datetime`
            from `e` `INNR`
            where (`OUTR`.`col_varchar_20_key` > 'g')
            order by 1
            limit 1
        )
    )
    and (`OUTR2`.`col_datetime` = '2005-10-03');

--explain_protocol 0
DROP TABLE E;

--disable_warnings
DROP TABLE IF EXISTS C; 
--enable_warnings
CREATE  TABLE C (
