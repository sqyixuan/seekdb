drop table if exists factory_order;
drop table if exists factory_order_part;
--enable_warnings

create table service_order_part(id int, order_id int, whether_use int);
create table service_order(order_id int, customer_complaint_type_id int, responsibility_unit_id int, customer_id int, service_type int, ent_id varchar(20), order_status int, invalid int, create_date int);
create table service_order_device(id int, device_id int, order_id int, device_sort int, maintenance_status varchar(20));
create table device(device_id int, equipment_model int);
create table saas_device_model_info(model_id int, series_id int);
create table saas_device_series_info(series_id int);
create table saas_service_order_complaint_type(id int);
create table dictionary_type(type_id int, code varchar(20));
create table user_customer(id int, user_id int);
create table employee_record(emp_id int);
create table service_order_faulty_cause(order_id int, saas_part_id int);
create table saas_device_part_info(part_id int);
create table saas_service_order_type(id int, classify varchar(20));
create table factory_order_materiel(id int, order_id int);
create table factory_order(order_id int, customer_complaint_type_id int, responsibility_unit_id int, device_id int, ent_id varchar(20), order_status int, maintenance_status int, handler_way int, equipment_model int, create_date int);
create table factory_order_part(order_id int);

--explain_protocol 2

SELECT
  count( 0 ) 
FROM
  (
  SELECT DISTINCT
    sop.id,
    'service_order' AS data_source,
    so.create_date 
  FROM
    service_order_part sop
    LEFT JOIN service_order so ON sop.order_id = so.order_id
    LEFT JOIN service_order_device sod ON sod.id = ( SELECT tmp_sod.id FROM service_order_device tmp_sod WHERE tmp_sod.order_id = so.order_id ORDER BY tmp_sod.device_sort ASC LIMIT 1 )
    LEFT JOIN device d ON d.device_id = sod.device_id
    LEFT JOIN saas_device_model_info sdmi ON sdmi.model_id = d.equipment_model
    LEFT JOIN saas_device_series_info sdsi ON sdmi.series_id = sdsi.series_id
    LEFT JOIN saas_service_order_complaint_type ssoct ON so.customer_complaint_type_id = ssoct.id
    LEFT JOIN dictionary_type ctdt ON ctdt.CODE = 'CUSTOMER_COMPLAINT_TYPE' 
    AND ctdt.type_id = so.responsibility_unit_id
    LEFT JOIN user_customer uc ON uc.id = so.customer_id
    LEFT JOIN employee_record sfer ON uc.user_id = sfer.emp_id
    LEFT JOIN service_order_faulty_cause sofc ON sofc.order_id = so.order_id
    LEFT JOIN saas_device_part_info sdpi ON sofc.saas_part_id = sdpi.part_id
    LEFT JOIN saas_service_order_type ssot ON so.service_type = ssot.id 
  WHERE
    sop.whether_use = 1 
    AND so.ent_id = '1d1660aa82a243818d2e1691201df9ef' 
    AND so.order_status IN ( 7, 8 ) 
    AND sod.maintenance_status = 1 
    AND so.invalid = 0 
    AND ssot.classify = 'warranty' 
 UNION ALL
  SELECT DISTINCT
    fom.id,
    'factory_order' AS data_source,
    fo.create_date 
  FROM
    factory_order_materiel fom
    LEFT JOIN factory_order fo ON fo.order_id = fom.order_id
    LEFT JOIN saas_device_model_info sdmi ON sdmi.model_id = fo.equipment_model
    LEFT JOIN device d ON d.device_id = fo.device_id
    LEFT JOIN saas_device_series_info sdsi ON sdmi.series_id = sdsi.series_id
    LEFT JOIN saas_service_order_complaint_type ssoct ON fo.customer_complaint_type_id = ssoct.id
    LEFT JOIN dictionary_type ctdt ON ctdt.CODE = 'CUSTOMER_COMPLAINT_TYPE' 
    AND ctdt.type_id = fo.responsibility_unit_id
    LEFT JOIN factory_order_part fop ON fop.order_id = fo.order_id 
  WHERE
    fo.ent_id = '1d1660aa82a243818d2e1691201df9ef' 
    AND fo.handler_way IN ( 1, 6 ) 
    AND fo.maintenance_status = 1 
    AND fo.order_status >= 4 
  ) tmp;

create index i_sod_id on service_order_device(id);

SELECT
  count( 0 ) 
FROM
  (
  SELECT DISTINCT
    sop.id,
    'service_order' AS data_source,
    so.create_date 
  FROM
    service_order_part sop
    LEFT JOIN service_order so ON sop.order_id = so.order_id
    LEFT JOIN service_order_device sod ON sod.id = ( SELECT tmp_sod.id FROM service_order_device tmp_sod WHERE tmp_sod.order_id = so.order_id ORDER BY tmp_sod.device_sort ASC LIMIT 1 )
    LEFT JOIN device d ON d.device_id = sod.device_id
    LEFT JOIN saas_device_model_info sdmi ON sdmi.model_id = d.equipment_model
    LEFT JOIN saas_device_series_info sdsi ON sdmi.series_id = sdsi.series_id
    LEFT JOIN saas_service_order_complaint_type ssoct ON so.customer_complaint_type_id = ssoct.id
    LEFT JOIN dictionary_type ctdt ON ctdt.CODE = 'CUSTOMER_COMPLAINT_TYPE' 
    AND ctdt.type_id = so.responsibility_unit_id
    LEFT JOIN user_customer uc ON uc.id = so.customer_id
    LEFT JOIN employee_record sfer ON uc.user_id = sfer.emp_id
    LEFT JOIN service_order_faulty_cause sofc ON sofc.order_id = so.order_id
    LEFT JOIN saas_device_part_info sdpi ON sofc.saas_part_id = sdpi.part_id
    LEFT JOIN saas_service_order_type ssot ON so.service_type = ssot.id 
  WHERE
    sop.whether_use = 1 
    AND so.ent_id = '1d1660aa82a243818d2e1691201df9ef' 
    AND so.order_status IN ( 7, 8 ) 
    AND sod.maintenance_status = 1 
    AND so.invalid = 0 
    AND ssot.classify = 'warranty' 
 UNION ALL
  SELECT DISTINCT
    fom.id,
    'factory_order' AS data_source,
    fo.create_date 
  FROM
    factory_order_materiel fom
    LEFT JOIN factory_order fo ON fo.order_id = fom.order_id
    LEFT JOIN saas_device_model_info sdmi ON sdmi.model_id = fo.equipment_model
    LEFT JOIN device d ON d.device_id = fo.device_id
    LEFT JOIN saas_device_series_info sdsi ON sdmi.series_id = sdsi.series_id
    LEFT JOIN saas_service_order_complaint_type ssoct ON fo.customer_complaint_type_id = ssoct.id
    LEFT JOIN dictionary_type ctdt ON ctdt.CODE = 'CUSTOMER_COMPLAINT_TYPE' 
    AND ctdt.type_id = fo.responsibility_unit_id
    LEFT JOIN factory_order_part fop ON fop.order_id = fo.order_id 
  WHERE
    fo.ent_id = '1d1660aa82a243818d2e1691201df9ef' 
    AND fo.handler_way IN ( 1, 6 ) 
    AND fo.maintenance_status = 1 
    AND fo.order_status >= 4 
  ) tmp;

