--disable_warnings
DROP TABLE IF EXISTS OO;
DROP TABLE IF EXISTS EE;
--enable_warnings
CREATE TABLE OO (
    col_varchar_10_key varchar(10),
    col_int_key int,
    key idx3(col_varchar_10_key)
) PARTITION BY hash (col_int_key) subpartition by key(col_varchar_10_key) subpartitions 10 partitions 4;
CREATE TABLE EE (
    col_int int,
    col_varchar_10_key varchar(10),
    key idx3(col_varchar_10_key)
);

--explain_protocol 2
select /*+no_rewrite*/ 1 from `oo` `OUTR2` left join (select /*+no_rewrite use_das(OUTR)*/ `OUTR`.`col_int` AS `OUTR.col_int` from `ee` `OUTR`) `VIEW1` on (`OUTR2`.`col_varchar_10_key` = (select /*+no_rewrite no_push_subq*/ `INNR`.`col_varchar_10_key` from `test`.`ee` `INNR` where (`VIEW1`.`OUTR.col_int` is null) order by 1 limit 1));
select /*+no_rewrite*/ 1 from `oo` `OUTR2` inner join (select /*+no_rewrite use_das(OUTR)*/ `OUTR`.`col_int` AS `OUTR.col_int` from `ee` `OUTR`) `VIEW1` on (`OUTR2`.`col_varchar_10_key` = (select /*+no_rewrite*/ `INNR`.`col_varchar_10_key` from `test`.`ee` `INNR` where (`VIEW1`.`OUTR.col_int` is null) order by 1 limit 1));
select /*+no_rewrite*/ 1 from `oo` `OUTR2`, (select /*+no_rewrite use_das(OUTR)*/ `OUTR`.`col_int` AS `OUTR.col_int` from `ee` `OUTR`) `VIEW1` where (`OUTR2`.`col_varchar_10_key` = (select /*+no_rewrite*/ `INNR`.`col_varchar_10_key` from `test`.`ee` `INNR` where (`VIEW1`.`OUTR.col_int` is null) order by 1 limit 1));

