--explain_protocol 2
SELECT OUTR . col_varchar_10_key AS X, exists (select 1 FROM  O INNR where INNR . col_varchar_20 = OUTR . `col_int_key`) AS Y FROM  O AS OUTR2 LEFT JOIN  O AS OUTR ON ( OUTR2 . `col_datetime` = (select /*+PUSH_SUBQ*/ INNR . `col_datetime` from  O AS INNR where OUTR . col_varchar_20 <> INNR . col_varchar_20_key order by 1 limit 1) ) WHERE  OUTR . col_varchar_20_key > 'n' OR NOT OUTR . `col_date_key` <= '2004-12-04' ;

select /*+no_rewrite*/ 1
from ((select `OUTR`.`col_varchar_20` AS `OUTR.col_varchar_20` from `o` `OUTR`)
    ) `VIEW2`
where (
        `VIEW2`.`OUTR.col_varchar_20` = (
            select /*+ PUSH_SUBQ */ `INNR`.`col_datetime`
            from `o` `INNR`
            where (`VIEW2`.`OUTR.col_varchar_20` <> `INNR`.`col_varchar_20_key`)
            order by 1
            limit 1
        )
    );

select 1
from ((select `OUTR`.`col_varchar_20` AS `OUTR.col_varchar_20` from `o` `OUTR`)
       union all
      (select `OUTR`.`col_varchar_20` AS `OUTR.col_varchar_20` from `o` `OUTR`)
    ) `VIEW2`
where (
        `VIEW2`.`OUTR.col_varchar_20` = (
            select /*+ PUSH_SUBQ */ `INNR`.`col_datetime`
            from `o` `INNR`
            where (`VIEW2`.`OUTR.col_varchar_20` <> `INNR`.`col_varchar_20_key`)
            order by 1
            limit 1
        )
    );

--explain_protocol 0
DROP TABLE O;

--disable_warnings
DROP TABLE IF EXISTS T; 
--enable_warnings

CREATE  TABLE T (
col_date_key date,
col_datetime_key datetime,
col_int_key int,
col_varchar_20_key varchar(20),
col_datetime datetime,
col_int int,
pk int,
col_varchar_10 varchar(10),
col_date date,
col_varchar_20 varchar(20),
col_varchar_10_key varchar(10),
/*Indices*/
key idx7(col_date_key ),
key idx9(col_datetime_key ),
key idx1(col_int_key ),
key idx5(col_varchar_20_key ),
key idx3(col_varchar_10_key ))    PARTITION BY key (pk,col_datetime_key) partitions 8 ; 
