#owner: yibo.tyf
#owner group: sql1
#tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists cs_cache_compensation;
--enable_warnings

--disable_result_log
CREATE TABLE `cs_cache_compensation` (
  `model_key` varchar(192) COLLATE utf8mb4_bin NOT NULL COMMENT '对应cache_syncer上的主键,唯一标识',
  `cache_syncer` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT 'CIF中的类名称',
  `gmt_modified` timestamp(6) NOT NULL COMMENT '修改时间',
  `sla_seq_id` bigint(20) NOT NULL COMMENT 'datasla时序值',
  `status` varchar(48) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '状态属性，竖线分隔。第一位1表示：已经发送消息',
  PRIMARY KEY (`model_key`, `cache_syncer`, `gmt_modified`, `sla_seq_id`),
  KEY `cs_cache_compensation_g_ind` (`gmt_modified`, `model_key`, `cache_syncer`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '缓存同步补偿表';

--disable_query_log
select count(*) from cs_cache_compensation;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2
set timestamp = 133.345;
SELECT /*+index(CS_CACHE_COMPENSATION cs_cache_compensation_g_ind)*/ 
    MODEL_KEY,CACHE_SYNCER,GMT_MODIFIED,SLA_SEQ_ID,STATUS 
FROM
    CS_CACHE_COMPENSATION 
WHERE 
    GMT_MODIFIED < DATE_SUB(current_timestamp(6), INTERVAL 30 SECOND) and
    GMT_MODIFIED > DATE_SUB(current_timestamp(6), INTERVAL 1 MINUTE) 
LIMIT 100;

drop table cs_cache_compensation;
