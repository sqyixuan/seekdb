--disable_warnings
DROP TABLE /*! IF EXISTS*/ V; 
--enable_warnings

CREATE  TABLE V (
col_timestamp_key timestamp NULL DEFAULT NULL,
col_datetime_key datetime,
col_varchar_10_key varchar(10),
col_bigint_key bigint,
col_varchar_20_key varchar(20),
col_int_key int,
col_date_key date,
pk int,
/*Indices*/
key idx6(col_timestamp_key ),
key idx4(col_datetime_key ),
key idx1(col_varchar_10_key ),
key idx5(col_bigint_key ),
key idx2(col_varchar_20_key ),
key idx0(col_int_key ),
key idx3(col_date_key ))    PARTITION BY key (pk,col_varchar_10_key) partitions 40 ; 
