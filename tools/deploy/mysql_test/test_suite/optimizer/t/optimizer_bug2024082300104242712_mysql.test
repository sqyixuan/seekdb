--result_format 4
SELECT DISTINCT COUNT(DISTINCT OUTR . `col_int_key` ) AS X FROM  V AS OUTR2 LEFT JOIN  V AS OUTR ON ( OUTR2 . `pk` > OUTR . `col_bigint_key` ) WHERE  (( OUTR . col_varchar_10_key , OUTR . col_varchar_20_key ) IN ( SELECT DISTINCT INNR . col_varchar_10_key AS X , INNR . col_varchar_20_key AS Y FROM V INNR) AND OUTR . `col_bigint_key` IS NULL) OR (( OUTR . col_varchar_10_key , OUTR . col_varchar_20_key ) IN ( SELECT  INNR . col_varchar_20_key AS X , INNR . col_varchar_10_key AS Y FROM V INNR) AND exists (select `pk` from  V where `col_int_key` <= 5)) HAVING X = '2009-05-25' ORDER BY X ;

DROP TABLE /*! IF EXISTS*/ V; 
