# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer
## test for not in query range

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists table0_bigint;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key(c1, c2, c3, c4, c5, c6));
create table t2(c1 int primary key, c2 int);
CREATE TABLE t3 (
    c1 int(10) NOT NULL AUTO_INCREMENT,
    c2 varchar(256) COLLATE utf8_bin NOT NULL,
    KEY `i_c2` (`c2`)
) COLLATE=utf8_bin;
create table t4(
    c1 int(10) not null auto_increment,
    c2 varchar(256) NOT NULL,
    KEY `i_t4_c2` (c2)
);
create table t5(c1 int primary key, c2 int);
create index i5 on t5(c2);
create table t6(c1 int, c2 int);
create index i6 on t6(c2);
CREATE TABLE `table0_bigint` (
  `col_bigint_key` bigint(20) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_char_12` char(12) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_char_12_key` char(12) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_bigint_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`pk`, `col_char_12_key`) BLOCK_SIZE 16384 LOCAL
);
insert into t1 values (1, 1, 1, 4, 5, 6, 7);
insert into t1 values (1, 2, 1, 4, 5, 6, 7);
insert into t1 values (1, 3, 1, 4, 5, 6, 7);
insert into t1 values (2, 1, 1, 4, 5, 6, 7);
insert into t1 values (2, 2, 1, 4, 5, 6, 7);
insert into t1 values (2, 3, 1, 4, 5, 6, 7);
insert into t1 values (3, 1, 1, 4, 5, 6, 7);
insert into t1 values (3, 2, 1, 4, 5, 6, 7);
insert into t1 values (3, 3, 1, 4, 5, 6, 7);
insert into t2 values (1, 1);
insert into t2 values (2, null);
insert into t2 values (3, 2);
insert into t3 values (1, 'Abc');
insert into t3 values (2, 'abc');
insert into t3 values (3, 'ab');
insert into t3 values (4, 'bc');
insert into t4 values (1, 'Abc');
insert into t4 values (2, 'abc');
insert into t4 values (3, 'ab');
insert into t4 values (4, 'bc');
insert into t5 values (1, 2);
insert into t5 values (2, 3);
insert into t5 values (3, 4);
insert into t5 values (4, null);
insert into t6 values (1, 2);
insert into t6 values (2, 3);
insert into t6 values (3, 4);
insert into t6 values (4, null);

--result_format 4
--explain_protocol 2

select /*+no_rewrite use_plan_cache(none)*/ * from t1 where c1 not in (1,2,4,5);
select /*+no_rewrite use_plan_cache(none)*/ * from t1 where c1 not in (1,2,4,5) and c2 = 3;
select /*+no_rewrite use_plan_cache(none)*/ * from t1 where c1 not in (1,2,4,5) and c2 < 3;
select /*+no_rewrite use_plan_cache(none)*/ * from t1 where c1 = 2 and c2 not in (1,2,4,5);
select /*+no_rewrite use_plan_cache(none)*/ * from t1 where c1 > 2 and c2 not in (1,2,4,5);

select /*+no_rewrite use_plan_cache(none)*/ * from t2 where exists (select 1 from t1 where c1 = t2.c1 and c2 not in (t2.c2 + 1, t2.c2 + 2));

select /*+no_rewrite use_plan_cache(none) */ * from t3 where c2 not in ('a', 'ABC', 'b', 'Ac');
select /*+no_rewrite use_plan_cache(none) */ * from t4 where c2 not in ('a', 'ABC', 'b', 'Ac');

select /*+no_rewrite use_plan_cache(none)*/ * from t5 where c2 not in (1, 3, 6);
select /*+no_rewrite use_plan_cache(none)*/ * from t6 where c2 not in (1, 3, 6);

SELECT col_char_12_key FROM table0_bigint WHERE pk NOT IN ( -100.1234500 , 1.99999 , 99.999 , -100.1234500 ) ;

drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t6;
drop table table0_bigint;