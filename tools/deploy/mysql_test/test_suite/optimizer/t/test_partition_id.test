#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
#description:主要通过代价的估算结果来测试下partition id是否设置正确。

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1,phash,pkey,sp;
--enable_warnings

create table t1(c1 int, c2 int);
create table phash(c1 int, c2 int) partition by hash(c1) partitions 10;
create table pkey(c1 int, c2 int) partition by key(c1) partitions 2;
#subpartition
create table sp(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2016-10-10'),  subpartition p1 values less than ('2116-3-30')) partitions 2;

--source mysql_test/include/minor_merge_tenant.inc
--let $count=0
--disable_query_log
while($count < 2000)
{
  eval insert into t1 values($count, $count);
  eval insert into phash value($count, $count);
  eval insert into pkey value($count, $count);
  inc $count;
}

--let $count=0
while($count < 2000)
{
  eval insert into sp values($count, date_add('2015-01-01', interval $count day));
  inc $count;
}
--enable_query_log

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');
call dbms_stats.gather_table_stats('TEST', 'phash');
call dbms_stats.gather_table_stats('TEST', 'pkey');
call dbms_stats.gather_table_stats('TEST', 'sp');

explain select * from t1 where c1 > 1000;
explain select * from t1 where c1 = 1000;
explain select * from t1 where c1 > 500 and c1 < 1500;
explain select * from t1 where c1 > 500 or c1 < 1500;
explain select * from t1;

select count(1) from phash;
explain select * from phash;
explain select * from phash where c1 > 1000;
explain select * from phash where c1 > 500 and c1 < 1000;
explain select * from phash where c1 + 2 = 100;
select count(1) from pkey;
explain select * from pkey;
explain select * from pkey where c1 > 1000;
explain select * from phash where c1 > 500 and c1 < 1000;
select count(1) from sp;
explain select * from sp;
explain select * from sp where c2 > '2016-01-01';
explain select * from sp where c2 > '2016-01-01';
explain select * from sp where c2 < '2016-10-10';
explain select * from sp where c2 > '2015-01-01';
explain select * from sp where c1 > 1000 and c2 > '2016-01-01';
explain select * from sp where c1 > 500 and c2 > '2016-01-01';
explain select * from sp where c1 > 1500 and c2 > '2016-01-01';
explain select * from sp where  c2 > '2016-10-10';
--disable_warnings
drop table if exists t1,phash,pkey,sp;
--enable_warnings
