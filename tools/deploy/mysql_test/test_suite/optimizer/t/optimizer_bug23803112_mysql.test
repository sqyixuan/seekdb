--disable_query_log
select count(*) from t1;
select count(*) from c;
select count(*) from d;
select count(*) from cc;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select /*+index(t1 primary)*/ * from t1 where c1 = 5 and (c2 = 10 or c2 > 5);
select /*+index(t1 idx1)*/ * from t1 where c1 = 5 and (c2 = 10 or c2 > 5);

SELECT SUM(table1 . `col_int`) AS field1,
       MIN(table2 . `col_int`) AS field2,
       table1 . col_varchar_10_key AS field3
FROM (C AS table1
      RIGHT  JOIN ((
                      (SELECT SUBQUERY1_t1 . *
                       FROM (C AS SUBQUERY1_t1
                             INNER JOIN CC AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_int_key` = SUBQUERY1_t1 . `col_int_key`))) AS table2
                    INNER JOIN D AS table3 ON (table3 . `col_int_key` = table2 . `col_int`
                                               OR table3 . `col_int_key` NOT IN
                                                 (SELECT 3
                                                  FROM DUAL)))) ON (table3 . `pk` = table2 . `pk`))
WHERE (EXISTS (
                 (SELECT SUBQUERY3_t1 . `col_varchar_key` AS SUBQUERY3_field1
                  FROM (C AS SUBQUERY3_t1
                        LEFT OUTER JOIN CC AS SUBQUERY3_t2 ON (SUBQUERY3_t2 . `col_int_key` = SUBQUERY3_t1 . `col_int_key`))
                  GROUP BY SUBQUERY3_field1)))
  AND table1 . `pk` > 1
  AND table1 . `pk` < (1 + 141)
  OR (table1 . `col_int_key` IS NULL
      AND table2 . `col_varchar_10_key` != table2 . `col_varchar`)
GROUP BY field3
ORDER BY 1,
         field1,
         field2,
         field3;

drop table t1, c, d, cc;