#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by hash(c1) partitions 100;
create index i1 on t1(c1,c3) local;
create index i2 on t1(c1,c3) global;
insert into t1 values(0,1,1,0),(1,0,0,0),(1,1,0,0),
                     (0,2,2,2),(2,0,2,0),(2,2,0,0),
                     (0,3,3,0),(3,0,0,0),(3,3,0,0),
                     (0,4,4,4),(4,0,4,0),(4,4,0,0);
insert into t1 select c1+4,c2+4,c3+4,c4+4 from t1;
insert into t1 select c1+8,c2+8,c3+8,c4+8 from t1;
call dbms_stats.gather_table_stats('TEST','T1');
--explain_protocol 3
--echo ######index back
--echo ##different partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 < 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/ * from t1 where c1 < 1;

--echo ##same partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i2)*/ * from t1 where c1 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i1)*/ * from t1 where c1 = 1;

--echo ######no index back
--echo ##different partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 < 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/ c1,c2,c3 from t1 where c1 < 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i1)*/ c1,c2,c3 from t1 where c1 < 1;

--echo ##same partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/ c1,c2,c3 from t1 where c1 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i2)*/ c1,c2,c3 from t1 where c1 = 1;

drop table t1;

--echo #######less partition
--explain_protocol 0
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by hash(c1) partitions 2;
create index i2 on t1(c1,c3) global;
insert into t1 values(0,1,1,0),(1,0,0,0),(1,1,0,0),
                     (0,2,2,2),(2,0,2,0),(2,2,0,0),
                     (0,3,3,0),(3,0,0,0),(3,3,0,0),
                     (0,4,4,4),(4,0,4,0),(4,4,0,0);
insert into t1 select c1+4,c2+4,c3+4,c4+4 from t1;
insert into t1 select c1+8,c2+8,c3+8,c4+8 from t1;
call dbms_stats.gather_table_stats('TEST','T1');
--explain_protocol 3
--echo ##index back
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 < 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i2)*/ * from t1 where c1 < 1;
--echo ##no index back
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 < 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/ * from t1 where c1 < 1;
drop table t1;

--echo #######range partition
--explain_protocol 0
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) partitions 10
(partition p0 values less than (5),
 partition p1 values less than (10),
 partition p2 values less than (15),
 partition p3 values less than (20),
 partition p4 values less than (25),
 partition p5 values less than (30),
 partition p6 values less than (40),
 partition p7 values less than (50),
 partition p8 values less than (60),
 partition p9 values less than (MAXVALUE));
create index i2 on t1(c1,c3) global;
insert into t1 values(0,1,1,0),(1,0,0,0),(1,1,0,0),
                     (0,2,2,2),(2,0,2,0),(2,2,0,0),
                     (0,3,3,0),(3,0,0,0),(3,3,0,0),
                     (0,4,4,4),(4,0,4,0),(4,4,0,0);
insert into t1 select c1+4,c2+4,c3+4,c4+4 from t1;
insert into t1 select c1+8,c2+8,c3+8,c4+8 from t1;
insert into t1 select c1+16,c2+16,c3+16,c4+16 from t1;
insert into t1 select c1+32,c2+32,c3+32,c4+32 from t1;
call dbms_stats.gather_table_stats('TEST','T1');
--explain_protocol 3
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 < 100;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i2)*/* from t1 where c1 < 100;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 < 100;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/c1,c2,c3 from t1 where c1 < 100;
drop table t1;

--echo #######multi-level partition
--explain_protocol 0
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 10 partitions 10
(partition p0 values less than (5),
 partition p1 values less than (10),
 partition p2 values less than (15),
 partition p3 values less than (20),
 partition p4 values less than (25),
 partition p5 values less than (30),
 partition p6 values less than (40),
 partition p7 values less than (50),
 partition p8 values less than (60),
 partition p9 values less than (MAXVALUE));
 create index i2 on t1(c1,c3) global;
insert into t1 select c1+4,c2+4,c3+4,c4+4 from t1;
insert into t1 select c1+8,c2+8,c3+8,c4+8 from t1;
insert into t1 select c1+16,c2+16,c3+16,c4+16 from t1;
insert into t1 select c1+32,c2+32,c3+32,c4+32 from t1;
call dbms_stats.gather_table_stats('TEST','T1');
--explain_protocol 3
--echo ##different partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 < 100 and c2 < 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/* from t1 where c1 < 100 and c2 < 10;

--echo ##same partition count
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select * from t1 where c1 < 10 and c2 = 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 i2)*/* from t1 where c1 < 10 and c2 = 10;

--echo ##no index back
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 < 100 and c2 < 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/c1,c2,c3 from t1 where c1 < 100 and c2 < 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select c1,c2,c3 from t1 where c1 < 10 and c2 = 10;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+index(t1 primary)*/c1,c2,c3 from t1 where c1 < 10 and c2 = 10;

--echo ##test inner sql
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t2(deptno decimal primary key,dname varchar(20),loc varchar(20));
create table t1(EMPNO decimal(4),ENAME varchar(10),JOB varchar(9),MGR decimal(4),HIREDATE date,SAL decimal(7,2),COMM decimal(7,2),DEPTNO decimal(2),total int as (sal+comm) virtual)
partition by range(total)(partition part1 values less than(1000),partition part2 values less than(2000),partition part3 values less than(3000),partition part4 values less than(4000),partition part5 values less than(5000));

alter table t1 add constraint t_u unique(ename, total);

alter table t1 add constraint t_ck check(deptno > 500);
alter table t1 add constraint t1_fk foreign key(deptno) references t2(deptno);

drop table t1;
drop table t2;