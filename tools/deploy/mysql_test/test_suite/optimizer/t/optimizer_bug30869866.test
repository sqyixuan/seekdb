#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description: late materialization bug

--disable_abort_on_error

--disable_warnings
DROP TABLE IF EXISTS `table50_bigint`;
--enable_warnings

CREATE TABLE `table50_bigint` (
  `col_bigint` bigint(20) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_bigint_index` bigint(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx2` (`pk`, `col_bigint_index`) 
) DEFAULT CHARSET = utf8mb4 ;

--result_format 4
--explain_protocol 2

SELECT * 
FROM   ((SELECT /*+USE_LATE_MATERIALIZATION*/ col_bigint, 
                col_bigint_index
         FROM   table50_bigint 
         WHERE  Round(Floor(col_bigint_index)) = 1 
         ORDER  BY 2 ASC
         LIMIT  1) 
        UNION ALL 
        (SELECT col_bigint, 
                col_bigint_index
                 FROM   table50_bigint LIMIT 3)) T ;

--disable_warnings
DROP TABLE IF EXISTS `table50_bigint`;
--enable_warnings

--disable_warnings
DROP TABLE IF EXISTS `t1`, `t5`, `t6`;
--enable_warnings

CREATE TABLE `t1` (
  `c1` varbinary(85) DEFAULT NULL,
  `c2` date DEFAULT NULL,
  `c3` binary(54) DEFAULT NULL,
  `c4` decimal(64,14) NOT NULL,
  `c5` binary(95) NOT NULL,
  `c6` bigint(127) DEFAULT NULL,
  `c7` decimal(64,14) DEFAULT NULL,
  `c8` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00',
  `c9` date DEFAULT NULL,
  `c10` int(127) DEFAULT NULL,
  `c11` binary(85) DEFAULT NULL,
  `c12` time DEFAULT NULL,
  `c13` varbinary(57) DEFAULT NULL,
  `c14` timestamp(4) NOT NULL DEFAULT '0000-00-00 00:00:00.0000',
  `c15` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c16` datetime DEFAULT NULL,
  `c17` bigint(127) NOT NULL AUTO_INCREMENT,
  `c18` year(4) DEFAULT NULL,
  `c19` year(4) DEFAULT NULL,
  `c20` datetime DEFAULT NULL,
  `c21` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c22` year(4) DEFAULT NULL,
  `c23` varbinary(67) DEFAULT NULL,
  `c24` decimal(64,12) NOT NULL,
  `c25` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c26` bigint(127) DEFAULT NULL,
  `c27` decimal(64,29) DEFAULT NULL,
  `c28` bigint(127) NOT NULL,
  `c29` decimal(64,15) DEFAULT NULL,
  `c30` date DEFAULT NULL,
  `c31` datetime DEFAULT NULL,
  PRIMARY KEY (`c4`, `c28`, `c5`, `c24`)
) ;

 CREATE TABLE `t5` (
  `c1` int(127) NOT NULL,
  `c2` varbinary(73) DEFAULT NULL,
  `c3` bigint(127) NOT NULL,
  `c4` time DEFAULT NULL,
  `c5` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c6` int(127) DEFAULT NULL,
  `c7` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c8` binary(123) DEFAULT NULL,
  `c9` bigint(127) DEFAULT NULL,
  `c10` varbinary(61) DEFAULT NULL,
  `c11` time DEFAULT NULL,
  `c12` time DEFAULT NULL,
  `c13` datetime DEFAULT NULL,
  `c14` varbinary(64) DEFAULT NULL,
  `c15` time DEFAULT NULL,
  `c16` int(127) DEFAULT NULL,
  `c17` varbinary(67) DEFAULT NULL,
  `c18` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c19` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c20` year(4) DEFAULT NULL,
  `c21` varbinary(83) DEFAULT NULL,
  `c22` int(127) DEFAULT NULL,
  `c23` timestamp(2) NOT NULL DEFAULT '0000-00-00 00:00:00.00',
  `c24` date DEFAULT NULL,
  `c25` int(127) DEFAULT NULL,
  `c26` varbinary(55) DEFAULT NULL,
  `c27` int(127) NOT NULL AUTO_INCREMENT,
  PRIMARY KEY (`c1`, `c3`)
) ;

CREATE TABLE `t6` (
  `c1` decimal(64,24) NOT NULL,
  `c2` timestamp(4) NOT NULL DEFAULT '0000-00-00 00:00:00.0000',
  `c3` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c4` char(152) COLLATE utf8mb4_bin NOT NULL,
  `c5` binary(72) DEFAULT NULL,
  `c6` bigint(127) NOT NULL,
  `c7` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c8` bigint(127) NOT NULL,
  `c9` int(127) NOT NULL AUTO_INCREMENT,
  `c10` time DEFAULT NULL,
  `c11` binary(140) DEFAULT NULL,
  `c12` decimal(64,26) DEFAULT NULL,
  `c13` int(127) NOT NULL,
  `c14` datetime DEFAULT NULL,
  `c15` year(4) DEFAULT NULL,
  `c16` binary(78) NOT NULL,
  `c17` decimal(64,19) DEFAULT NULL,
  `c18` bigint(127) DEFAULT NULL,
  `c19` int(127) NOT NULL,
  `c20` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c21` decimal(64,14) DEFAULT NULL,
  `c22` int(127) DEFAULT NULL,
  `c23` int(127) NOT NULL,
  `c24` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c25` decimal(64,17) DEFAULT NULL,
  `c26` bigint(127) NOT NULL,
  `c27` time DEFAULT NULL,
  `c28` year(4) DEFAULT NULL,
  `c29` decimal(64,18) DEFAULT NULL,
  `c30` binary(54) DEFAULT NULL,
  `c31` timestamp(1) NOT NULL DEFAULT '0000-00-00 00:00:00.0',
  `c32` binary(81) DEFAULT NULL,
  `c33` year(4) DEFAULT NULL,
  `c34` int(127) DEFAULT NULL,
  `c35` decimal(64,26) NOT NULL,
  `c36` decimal(64,20) NOT NULL,
  `c37` binary(124) NOT NULL,
  `c38` int(127) NOT NULL,
  `c39` int(127) NOT NULL,
  `c40` time DEFAULT NULL,
  `c41` decimal(64,14) DEFAULT NULL,
  `c42` binary(77) NOT NULL,
  `c43` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c44` decimal(64,24) NOT NULL,
  `c45` time DEFAULT NULL,
  `c46` timestamp(1) NOT NULL DEFAULT '0000-00-00 00:00:00.0',
  `c47` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00',
  `c48` int(127) DEFAULT NULL,
  `c49` int(127) DEFAULT NULL,
  PRIMARY KEY (`c35`, `c8`, `c16`, `c23`, `c19`, `c37`, `c36`, `c44`, `c26`, `c6`, `c42`, `c4`, `c1`, `c39`, `c38`, `c13`)
);

explain
WITH jennifer_1 AS
(
                SELECT DISTINCT c10
                FROM            t6
                WHERE           EXISTS
                                (
                                       SELECT 1
                                       FROM   dual
                                       WHERE  4 IN (EXISTS
                                                    (
                                                           SELECT 1
                                                           FROM   t1 ) ,
                                                    (
                                                             SELECT   count(c5)
                                                             FROM     t5) ) ))
SELECT EXISTS
       (
              SELECT 1
              FROM   jennifer_1 AS ref_44) as ref0
FROM   jennifer_1;

WITH jennifer_1 AS
(
                SELECT DISTINCT c10
                FROM            t6
                WHERE           EXISTS
                                (
                                       SELECT 1
                                       FROM   dual
                                       WHERE  4 IN (EXISTS
                                                    (
                                                           SELECT 1
                                                           FROM   t1 ) ,
                                                    (
                                                             SELECT   count(c5)
                                                             FROM     t5) ) ))
SELECT EXISTS
       (
              SELECT 1
              FROM   jennifer_1 AS ref_44) as ref0
FROM   jennifer_1;

--disable_warnings
DROP TABLE IF EXISTS `t1`, `t5`, `t6`;
--enable_warnings

--disable_warnings
DROP TABLE IF EXISTS `item`;
--enable_warnings

create table item
(
    i_item_sk                 integer               not null,
    i_item_id                 char(16)              not null,
    i_rec_start_date          date                          ,
    i_rec_end_date            date                          ,
    i_item_desc               varchar(200)                  ,
    i_current_price           number(7,2)                  ,
    i_wholesale_cost          number(7,2)                  ,
    i_brand_id                integer                       ,
    i_brand                   char(50)                      ,
    i_class_id                integer                       ,
    i_class                   char(50)                      ,
    i_category_id             integer                       ,
    i_category                char(50)                      ,
    i_manufact_id             integer                       ,
    i_manufact                char(50)                      ,
    i_size                    char(20)                      ,
    i_formulation             char(20)                      ,
    i_color                   char(20)                      ,
    i_units                   char(10)                      ,
    i_container               char(10)                      ,
    i_manager_id              integer                       ,
    i_product_name            char(50)                      ,
    primary key (i_item_sk)
) with column group (all columns, each column);

explain select count(*) as item_cnt
        from item
        where 
        (i_category = 'Women' and
        (i_color = 'orchid' or i_color = 'papaya') and
        (i_size = 'petite' or i_size = 'medium')
        ) or
        (i_category = 'Women' and
        (i_size = 'N/A' or i_size = 'extra large')
        ) or
        (i_category = 'Men' and
        (i_size = 'small' or i_size = 'large')
        ) or
        (i_category = 'Men' and
        (i_size = 'petite' or i_size = 'medium')
        );

--disable_warnings
DROP TABLE IF EXISTS `item`;
--enable_warnings
