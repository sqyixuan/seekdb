# owner: wuyuming.wym
# owner group: sql1
# description: test special ndv
--echo # create table for test
--result_format 4

--disable_warnings
drop table if exists uniform_t;
drop database if exists special_ndv;
--enable_warnings

create database special_ndv;
use special_ndv;
create table uniform_t (c1 int, c2 int);
insert into uniform_t select uniform(1,10,random(3)), abs(random(3)%40) from table(generator(1000));
call DBMS_STATS.GATHER_TABLE_STATS('special_ndv','uniform_t');
select COLUMN_NAME, NUM_DISTINCT from oceanbase.DBA_TAB_COL_STATISTICS where table_name ='uniform_t' and OWNER='special_ndv';

--echo ----------------------------test row_number----------------------------
select count(1) from ( select distinct row_number() over () from uniform_t);
explain select * from ( select distinct row_number() over () from uniform_t);
select count(1) from ( select distinct row_number() over (partition by c1) from uniform_t);
explain select * from ( select distinct row_number() over (partition by c1) from uniform_t);
select count(1) from ( select distinct row_number() over (partition by c1 order by c2) from uniform_t);
explain select * from ( select distinct row_number() over (partition by c1 order by c2) from uniform_t);



--echo ----------------------------test rank,dense_rank, percent_rank, cume_dist, count(order by), sum(order by)----------------------------


select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct rank() over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct rank() over (partition by c1 order by c2) from uniform_t);

select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct dense_rank() over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct dense_rank() over (partition by c1 order by c2) from uniform_t);

select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct percent_rank() over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct percent_rank() over (partition by c1 order by c2) from uniform_t);

select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct cume_dist() over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct cume_dist() over (partition by c1 order by c2) from uniform_t);


select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct count(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct count(c1) over (partition by c1 order by c2) from uniform_t);


select count(1) from (select distinct c2 from uniform_t);
select count(1) from (select distinct sum(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct sum(c1) over (partition by c1 order by c2) from uniform_t);



--echo ----------------------------test first_value last_value, nth_value, max, min, median----------------------------
select count(1) from (select distinct first_value(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct first_value(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct first_value(c1) over () from uniform_t);
explain select * from (select distinct first_value(c1) over () from uniform_t);

select count(1) from (select distinct last_value(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct last_value(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct last_value(c1) over () from uniform_t);
explain select * from (select distinct last_value(c1) over () from uniform_t);

select count(1) from (select distinct nth_value(c1,2) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct nth_value(c1,2) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct nth_value(c1,2) over () from uniform_t);
explain select * from (select distinct nth_value(c1,2) over () from uniform_t);

select count(1) from (select distinct max(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct max(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct max(c1) over () from uniform_t);
explain select * from (select distinct max(c1) over () from uniform_t);

select count(1) from (select distinct min(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct min(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct min(c1) over () from uniform_t);
explain select * from (select distinct min(c1) over () from uniform_t);


--echo ----------------------------test lag,lead----------------------------

select count(1) from (select distinct lag(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct lag(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct lag(1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct lag(1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct lag(c1) over () from uniform_t);
explain select * from (select distinct lag(c1) over () from uniform_t);
select count(1) from (select distinct lag(1+1) over () from uniform_t);
explain select * from (select distinct lag(1+1) over () from uniform_t);


select count(1) from (select distinct lead(c1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct lead(c1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct lead(1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct lead(1) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct lead(c1) over () from uniform_t);
explain select * from (select distinct lead(c1) over () from uniform_t);
select count(1) from (select distinct lead(1+1) over () from uniform_t);
explain select * from (select distinct lead(1+1) over () from uniform_t);


--echo ----------------------------test ntile----------------------------


select count(1) from (select distinct ntile(3) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct ntile(3) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct ntile(10000) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct ntile(10000) over (partition by c1 order by c2) from uniform_t);
--error 1210
select count(1) from (select distinct ntile(-1) over (partition by c1 order by c2) from uniform_t);
explain select * from (select distinct ntile(-1) over (partition by c1 order by c2) from uniform_t);
--error 1210
select count(1) from (select distinct ntile(null) over (partition by c1 order by c2) from uniform_t);
--error 1210
explain select * from (select distinct ntile(null) over (partition by c1 order by c2) from uniform_t);
select count(1) from (select distinct ntile(10000) over (partition by c1) from uniform_t);
explain select * from (select distinct ntile(10000) over (partition by c1) from uniform_t);
select count(1) from (select distinct ntile(3) over () from uniform_t);
explain select * from (select distinct ntile(3) over () from uniform_t);

--echo ----------------------------test sum,count----------------------------

select count(1) from (select distinct sum(3) over (partition by c1) from uniform_t);
explain select * from (select distinct sum(3) over (partition by c1) from uniform_t);
select count(1) from (select distinct sum(3) over () from uniform_t);
explain select * from (select distinct sum(3) over () from uniform_t);


select count(1) from (select distinct count(3) over (partition by c1) from uniform_t);
explain select * from (select distinct count(3) over (partition by c1) from uniform_t);
select count(1) from (select distinct count(3) over () from uniform_t);
explain select * from (select distinct count(3) over () from uniform_t);


