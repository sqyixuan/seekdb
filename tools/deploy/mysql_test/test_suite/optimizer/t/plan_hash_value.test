
#owner: xiaoyi.xy
#owner group: sql1
# tags: optimizer
##
## Test Name:plan_hash_value
##
## Date: 2018-07-05
##


--disable_info
--disable_metadata
--disable_abort_on_error
--result_format 4

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
alter system set large_query_threshold = '1s';
disconnect obsys;
connection default;
--sleep 3
--enable_query_log
--enable_result_log
select effective_tenant();

set autocommit = 0;

--disable_warnings
drop table if exists t1, t2;
drop table if exists dist_t, dist_t1;
drop tablegroup if exists phv_group;
--enable_warnings

# --echo
--disable_warnings
drop database if exists phv_db;
create database phv_db;
use phv_db;

create tablegroup phv_group;
create table t1(c1 int, c2 int)  tablegroup='phv_group';
create table t2(c1 int primary key, c2 int, c3 varchar(32)) tablegroup='phv_group';
create table dist_t(c1 int primary key, c2 int) partition by hash (c1) partitions 5;
create table dist_t1(c1 int primary key, c2 int) partition by hash (c1) partitions 5;

alter system flush plan cache global;

--disable_result_log

--echo ## 不同表名
select/*+hash_value*/ * from t1;
select/*+hash_value*/ * hash_value*/ * from t2;

--echo ## 不同filter
select/*+hash_value*/ * from t1 where c1 > 1;
select/*+hash_value*/ * from t1 where c1 > 1 and c2 = 1;
select/*+hash_value*/ * from t1 where c1 > 1 or c2 = 1;
select/*+hash_value*/ * from t1 where c1 + 1 > 10;
select/*+hash_value*/ * from t1 where c1 - 1 > 10;
select/*+hash_value*/ * from t1 where c1 in (1);
select/*+hash_value*/ * from t1 where c1 in (1,2);
select/*+hash_value*/ * from t1 where c1 in (select c1 from t2);
select/*+hash_value*/ * from t1 where c1 in (select c1 from t2 where c1 > 1);
select/*+hash_value*/ * from t1 where c1 in (select c1 from t2 where c1 > 1 and c1 = 2);

--echo ## rownum
if ($TENANT =='oracle') {
  select/*+hash_value*/ * from t1 where rownum < 3;
  select/*+hash_value*/ * from t1 where rownum < 4;
}

--echo ## 不同order by
select /*+hash_value*/* from t1 where c1 > 1 order by c1;
select /*+hash_value*/* from t1 where c1 > 1 order by 1;
select /*+hash_value*/* from t1 where c1 > 1 order by c2;
select /*+hash_value*/* from t1 where c1 > 1 order by c1, c2;
select /*+hash_value*/* from t1 where c1 > 1 order by 2-1;
select /*+hash_value*/* from t1 where c1 > 1 order by 2;
select /*+hash_value*/* from t1 where c1 > 1 order by 1 limit 2;
select /*+hash_value*/* from t1 where c1 > 1 order by 2 limit 2;
select /*+hash_value*/* from t1 where c1 > 1 order by 2 limit 3;

--echo ## 不同group by
select /*+hash_value*/* from t1 group by c2;
select /*+hash_value*/* from t1 group by c1,c2;
select /*+hash_value*/* from t1 group by 1;
select /*+hash_value*/* from t1 group by 2;
select /*+hash_value*/* from t1 group by 1+1;
select /*+hash_value*/* from t1 group by c1-1;
select /*+hash_value*/* from t1 group by c1+1;
select/*+ hash_value USE_HASH_AGGREGATION()*/ sum(c1 + 1) from t1 group by c1;
select/*+ hash_value NO_USE_HASH_AGGREGATION()*/ sum(c1 + 1) from t1 group by c1;
select /*+hash_value*/sum(c1) from t1 group by c1;
select /*+hash_value*/sum(c2) from t1 group by c1;
select /*+hash_value*/sum(c2+1) from t1 group by c1;
select /*+hash_value*/sum(c2), c1 from t1 group by c1;
select /*+hash_value*/count(c1) from t1 group by c1;
select /*+hash_value*/avg(c1) from t1 group by c1;

--echo ## distinct
select /*+hash_value*/c1 from t1;
select /*+hash_value*/distinct c1 from t1;
select /*+hash_value*/sum(distinct c1) from t1 group by c1;

--echo ## for update不同
select /*+hash_value*/* from t1 for update nowait;
select /*+hash_value*/* from t1 for update wait 0;
select /*+hash_value*/* from t1 for update wait 10;

--echo ## limit 值不同
select /*+hash_value*/* from t1 limit 1;
select /*+hash_value*/* from t1 limit 2;
select /*+hash_value*/* from t1 limit 1,2;
select /*+hash_value*/* from t1 limit 2 offset 1;
select /*+hash_value*/* from t1 limit 2,3;
select /*+hash_value*/* from t1 limit 3 offset 2;

--echo ## 指定分区查询
select /*+hash_value*/* from dist_t partition(p0);
select /*+hash_value*/* from dist_t partition(p1);

--echo ##select /*+hash_value*/item不一样
select /*+hash_value*/c1 from t1;
select /*+hash_value*/c1 + 1 from t1;
select /*+hash_value*/c1, c2 from t1;
select /*+hash_value*/c1, (select /*+hash_value*/count(*) from t1) from t1;

--echo ##join
select /*+ hash_value use_hash(t1, t2)*/  * from t1 inner join t2 using (c1);
select /*+ hash_value use_nl(t1, t2)*/  * from t1 inner join t2 using (c1);
select /*+ hash_value use_merge(t1, t2)*/  * from t1 inner join t2 using (c1);

select /*+ hash_value use_hash(t1, t2)*/  * from t1 inner join t2 using (c1) where t1.c1 > 1;
select /*+ hash_value use_nl(t1, t2)*/  * from t1 inner join t2 using (c1) where t1.c1 > 1;
select /*+ hash_value use_merge(t1, t2)*/  * from t1 inner join t2 using (c1) where t1.c1 > 1;

select /*+ hash_value use_hash(t1, t2)*/  * from t1 left join t2 using (c1);
select /*+ hash_value use_nl(t1, t2)*/  * from t1 left join t2 using (c1);
select /*+ hash_value use_merge(t1, t2)*/  * from t1 left join t2 using (c1);

## dist plan
select /*+hash_value*/* from dist_t where c1 in (1,2) order by c2;
select /*+hash_value*/* from dist_t where c1 in (2,3) order by c2;
select/*+ hash_value use_merge(dist_t, dist_t1)*/ * from dist_t, dist_t1 where dist_t.c1 = dist_t1.c1;
select/*+ hash_value use_merge(dist_t, dist_t1)*/ * from dist_t, dist_t1 where dist_t.c1 = dist_t1.c1;
select/*+ hash_value use_nl(dist_t, dist_t1)*/ * from dist_t, dist_t1 where dist_t.c1 = dist_t1.c1;

### insert
insert /*+hash_value*/into t1 values(1,1);
insert /*+hash_value*/into t1 values(1,2);
insert /*+hash_value*/into t1 values(1,1), (2,2);
--sleep 1

## update
update /*+hash_value*/t1 set c1 = 1 where c2 = 1;
update /*+hash_value*/t1 set c1 = 4 where c2 = 4;
update /*+hash_value*/t1 set c1 = 1, c2 = 2 where c2 = 1;

## delete
delete /*+hash_value*/from t1 where c1 > 1;
delete /*+hash_value*/from t1 where c1 = 2;
delete /*+hash_value*/from t1 where c1 in (1,2);
delete /*+hash_value*/from t1 where c1 in (1,2, 3);

--enable_result_log

select plan_hash, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like '%hash_value%' and query_sql not like '%OB_PLAN_CACHE_PLAN_STAT%'   order by query_sql, plan_hash;

drop table t1, t2, dist_t, dist_t1;
drop tablegroup phv_group;
drop database phv_db;

