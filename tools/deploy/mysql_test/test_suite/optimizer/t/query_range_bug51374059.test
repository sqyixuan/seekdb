# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--result_format 4

select /*+query_timeout(600000000)*/  distinct t1.TABLE_SCHEMA,t1.TABLE_NAME 
from (
    select distinct TABLE_SCHEMA,TABLE_NAME,INDEX_SCHEMA,INDEX_NAME 
    from information_schema.STATISTICS 
    where (NON_UNIQUE=0 or COLUMN_NAME='__#alibaba_rds_row_id#__')  
      and ((TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelbelongdic') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelinfo') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channeluiddaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channeluidhourly')
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisitdaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisithourly') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisithourlyacc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_bot_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_devtype_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='cm_ip_check_info_sparkdesk') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='cm_uid_ip_visitdate_sparkdesk') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='comp_info_tyc_gpt') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='comp_name_correct_gpt') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dim_sparkdesk_industry') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_retention_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_active_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_bot_feedback') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_bot_static') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_use_regist_atmin_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_user_device_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_user_use_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_usermetric_acc_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_usermetric_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='input_gpt_customer') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_acc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_daily') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_period') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkdesk_download_actions_hourly') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkdesk_pv_uv_acc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='testaccount_mobile') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='uid_pro_city') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webinfo')
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisitdaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisithourly') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisithourlyacc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='xf_employees_mobile') 
            OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='xhcategory_chat_req') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='bot_type_list') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='call_out_record') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='censor_record') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_appointment_log') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_base') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_list') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_market') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_remove') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_complaint') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_feedback') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_ip_weight') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_list') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_properties') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_reanwser_records') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_record_tree') 
            OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_req_model') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_req_records_hist'))
) t1 
left outer join (
    select distinct TABLE_SCHEMA,TABLE_NAME,INDEX_SCHEMA,INDEX_NAME
    from information_schema.STATISTICS
    where nullable='YES'  
      and ((TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelbelongdic') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelinfo') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channeluiddaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channeluidhourly') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisitdaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisithourly')
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='channelvisithourlyacc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_bot_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid_devtype_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='chat_req_uid') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='cm_ip_check_info_sparkdesk') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='cm_uid_ip_visitdate_sparkdesk') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='comp_info_tyc_gpt') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='comp_name_correct_gpt') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dim_sparkdesk_industry') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_retention_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_active_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_bot_feedback') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_sparkdesk_bot_static') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_use_regist_atmin_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_user_device_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_user_use_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_usermetric_acc_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='dm_usermetric_daily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='input_gpt_customer') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_acc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_daily') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkapp_pv_uv_period') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkdesk_download_actions_hourly') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='sparkdesk_pv_uv_acc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='testaccount_mobile') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='uid_pro_city') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webinfo') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisitdaily') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisithourly') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='webvisithourlyacc') OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='xf_employees_mobile') 
           OR (TABLE_SCHEMA='data_analysis' and TABLE_NAME='xhcategory_chat_req') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='bot_type_list') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='call_out_record') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='censor_record') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_appointment_log') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_base') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_list') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_market') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_bot_remove') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_complaint') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_feedback') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_ip_weight') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_list') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_properties') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_reanwser_records') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_record_tree') 
           OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_req_model') OR (TABLE_SCHEMA='xfyun_gpt' and TABLE_NAME='chat_req_records_hist')) 
) t2
on t1.TABLE_SCHEMA=t2.TABLE_SCHEMA and t1.TABLE_NAME=t2.TABLE_NAME and t1.INDEX_SCHEMA=t2.INDEX_SCHEMA and t1.INDEX_NAME=t2.INDEX_NAME
where t2.TABLE_SCHEMA is null;