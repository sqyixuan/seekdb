col_decimal_20_0 decimal(20,0),
col_timestamp timestamp NULL DEFAULT NULL,
pk int,
col_bigint bigint,
col_varchar_20 varchar(20),
col_double double)    PARTITION BY key (pk) partitions 2 ; 
INSERT INTO table100_key_pk_parts_2 VALUES  (8696, NULL, 535625728, 8, NULL, NULL) ,  (0, NULL, 565248000, -14, 'dwycvxol', 0) ;

create table t1(c1 double, c2 int);
insert into t1 values(1,0),(1,2);
create index idx on t1 (c1);

--explain_protocol 2
set @@ob_enable_plan_cache = 0;
SELECT * FROM table100_key_pk_parts_2 WHERE (PK,0,pk) >= (2,2,2);
SELECT /*+index(t1 idx)*/* FROM t1 WHERE (c1,0) >= (0,2);
SELECT /*+index(t1 idx)*/* FROM t1 WHERE (c1,1) >= (1,1);

set @@ob_enable_plan_cache = 1;
