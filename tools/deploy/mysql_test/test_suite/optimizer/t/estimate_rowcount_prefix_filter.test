#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists tmp,t1,t2;
--enable_warnings

create table tmp(c1 int, c2 int);
create table t1(id int, c1 varchar(10), index i1(c1(5)));
create table t2(c1 int, c2 int, c3 int, c4 int, index i1(c1, c2, c3));
insert into tmp values (1,2);
insert into t1 select row_number() over (), randstr(10, random(1) % 100) from table(generator(10000));
insert into t2 select abs(random(1)) % 10, abs(random(2)) % 10, abs(random(3)) % 10, abs(random(4)) % 10 from table(generator(10000));

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 'tmp');
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
set optimizer_dynamic_sampling = 0;
set cardinality_estimation_model = 0;
--enable_query_log

set _enable_storage_cardinality_estimation = 0;
alter system flush plan cache;

select SQL_CALC_FOUND_ROWS 1 from t1 where c1 = 'v4Fo34ZsDU' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo34%' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo%' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 = (select c1 from t1 where id = 1) limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c4 = 1 or c1 = 2 and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c3 = 1 or c1 = 2 and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where (c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2) and c2 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and (c2, c4) in ((1, 1), (2, 2)) limit 0;
--source mysql_test/include/check_rows.inc

select SQL_CALC_FOUND_ROWS 1 from t2 where c1 = (select c1 from tmp) and c3 = 1 or c1 = (select c2 from tmp) and c3 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = (select c1 from tmp) and c3 = 1 or c1 = (select c2 from tmp) and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = (select c1 from tmp) and c4 = 1 or c1 = (select c2 from tmp) and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc

select SQL_CALC_FOUND_ROWS 1 from tmp, t2 where t2.c1 = tmp.c1 and t2.c3 = tmp.c1 + 1 or t2.c1 = tmp.c2 and t2.c3 = tmp.c2 + 1 limit 0;
--source mysql_test/include/check_rows.inc
select /*+ordered index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from tmp, t2 where t2.c1 = tmp.c1 and t2.c4 = tmp.c1 + 1 or t2.c1 = tmp.c2 and t2.c4 = tmp.c2 + 1 limit 0;
--source mysql_test/include/check_rows.inc
select /*+ordered index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from tmp, t2 where t2.c1 = tmp.c1 and t2.c3 = tmp.c1 + 1 or t2.c1 = tmp.c2 and t2.c4 = tmp.c2 + 1 limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 > 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 < 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 = 5 limit 0;
--source mysql_test/include/check_rows.inc

set _enable_storage_cardinality_estimation = 1;
alter system flush plan cache;

select SQL_CALC_FOUND_ROWS 1 from t1 where c1 = 'v4Fo34ZsDU' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo34%' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo%' limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t1 where c1 = (select c1 from t1 where id = 1) limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c4 = 1 or c1 = 2 and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c3 = 1 or c1 = 2 and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where (c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2) and c2 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and (c2, c4) in ((1, 1), (2, 2)) limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 > 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 < 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 = 5 limit 0;
--source mysql_test/include/check_rows.inc

## test dynamic sampling

select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t1 where c1 = 'v4Fo34ZsDU' limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo34%' limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t1 where c1 like 'v4Fo%' limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t1 where c1 = (select c1 from t1 where id = 1) limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1) dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c4 = 1 or c1 = 2 and c4 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where (c1 = 1 and c3 = 1 or c1 = 2 and c3 = 2) and c2 = 0 limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 = 1 and (c2, c4) in ((1, 1), (2, 2)) limit 0;
--source mysql_test/include/check_rows.inc

select /*+index(t2 i1) dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 > 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1) dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 < 5 limit 0;
--source mysql_test/include/check_rows.inc
select /*+index(t2 i1) dynamic_sampling(1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 between 0 and 10 and c2 = 5 limit 0;
--source mysql_test/include/check_rows.inc

select /*+dynamic_sampling(1) index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where 5 between c1 and c2 limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1) index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where 5 between c1 and c2 or (c1,c2,c3) = (1,1,1) limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1) index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where 5 between c1 and c2 or (c1,c3) = (1,1) limit 0;
--source mysql_test/include/check_rows.inc
select /*+dynamic_sampling(1) index(t2 i1)*/ SQL_CALC_FOUND_ROWS 1 from t2 where c1 > 0 and c1 < 0 or c1 = 1 and c4 = 1 limit 0;
--source mysql_test/include/check_rows.inc
select (select /*+index(v1 i1)*/ count(*) from t2 v1 where v1.c1 = v2.c1 and v1.c4 >= 0 or v1.c1 is null or v2.c1 is null) from t2 v2 limit 1;
--source mysql_test/include/check_rows.inc

drop table tmp,t1, t2;