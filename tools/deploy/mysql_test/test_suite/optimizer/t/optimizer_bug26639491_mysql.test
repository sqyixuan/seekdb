## 完整case
SELECT (SELECT  MIN( OUTR . `col_date_key` ) AS X FROM B AS OUTR WHERE ( OUTR . `col_int_key` , OUTR . `pk` ) IN ( SELECT  INNR . `col_int` AS X , INNR . `col_int_key` AS Y FROM CC AS INNR WHERE OUTR . `col_varchar_20` <= 'k' ORDER BY INNR . `col_datetime` ) OR OUTR . `col_varchar_20` IS NOT NULL  ORDER BY 1 , OUTR . `col_int` DESC , OUTR . `pk` DESC LIMIT 1), (SELECT DISTINCT AVG( OUTR . `col_date` ) AS X FROM B AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_varchar_10_key` <= OUTR . `col_varchar_20_key` ) WHERE ( OUTR . `col_int_key` , OUTR . `col_int_key` ) IN ( SELECT DISTINCT INNR . `pk` AS X , INNR . `col_int` AS Y FROM BB AS INNR WHERE INNR . `col_varchar_10_key` IS NOT NULL OR INNR . `col_varchar_10_key` = INNR . `col_varchar_20` ORDER BY INNR . `col_varchar_10` ) OR OUTR . `col_int_key` IS NOT NULL  ORDER BY 1 , OUTR . `col_int_key`  , OUTR . `pk` DESC LIMIT 1), (SELECT  MAX( OUTR . `col_datetime_key` ) AS X FROM B AS OUTR WHERE ( OUTR . `col_int_key` , OUTR . `col_int_key` ) IN ( SELECT  INNR . `col_int_key` AS X , INNR . `col_int` AS Y FROM CC AS INNR WHERE INNR . `col_varchar_10` < INNR . `col_varchar_20_key` OR INNR . `col_varchar_20_key` <> INNR . `col_varchar_20` ORDER BY INNR . `col_date_key` ) OR OUTR . `col_date` <= '2001-01-14' OR NOT OUTR . `col_datetime_key` = '2004-01-24'  ORDER BY 1 DESC, OUTR . `col_datetime`  , OUTR . `pk` ASC LIMIT 1), (SELECT DISTINCT AVG( OUTR . `col_int` ) AS X FROM B AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_int` < OUTR . `col_int_key` ) WHERE OUTR . `col_varchar_20` IN ( SELECT  INNR . `col_varchar_20` AS Y FROM CC AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `col_int` <> INNR . `col_int_key` ) WHERE INNR . `col_int` < INNR . `col_int` OR NOT INNR . `pk` < INNR . `col_int_key`  ) OR ( OUTR . `col_date` BETWEEN '2006-07-08' AND '2005-04-03' AND OUTR . `col_int_key` IS NOT NULL )  ORDER BY 1 ASC, OUTR . `col_date_key`  , OUTR . `pk`  LIMIT 1), (SELECT DISTINCT SUM( OUTR . `col_varchar_10_key` ) AS X FROM C AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_int` < OUTR . `col_int` ) WHERE ( OUTR . `col_varchar_10_key` , OUTR . `col_varchar_10` ) IN ( SELECT  INNR . `col_varchar_20_key` AS X , INNR . `col_varchar_20` AS Y FROM BB AS INNR WHERE INNR . `col_int_key` IS NOT NULL ORDER BY INNR . `col_int_key` ) OR OUTR . `col_int` IS NULL AND NOT OUTR . `col_varchar_20` <= 'g'  ORDER BY 1 ASC, OUTR . `col_int_key`  , OUTR . `pk` ASC LIMIT 1), (SELECT DISTINCT OUTR . `col_varchar_10_key` AS X FROM C AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_varchar_10` = OUTR . `col_varchar_10` ) WHERE OUTR . `col_int_key` IN ( SELECT  INNR . `pk` AS Y FROM CC AS INNR WHERE OUTR . `col_int_key` <= 1  ) OR ( OUTR . `col_varchar_20_key` <= 't' OR OUTR . `col_int` <= 1 )  ORDER BY 1 ASC, OUTR . `col_varchar_10_key` DESC , OUTR . `pk` DESC LIMIT 1), (SELECT DISTINCT OUTR . `col_varchar_20_key` AS X FROM C AS OUTR WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `col_int_key` AS Y FROM CC AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `col_varchar_20_key` <> INNR . `col_varchar_10_key` ) WHERE INNR . `col_int_key` < INNR . `col_int` AND OUTR . `col_datetime` IS NOT NULL ORDER BY INNR . `col_datetime_key` ) AND OUTR . `col_varchar_20_key` > 't' HAVING X = NULL ORDER BY 1 ASC, OUTR . `col_varchar_10_key`  , OUTR . `pk`  LIMIT 1), (SELECT DISTINCT MIN( OUTR . `col_varchar_10` ) AS X FROM B AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_int` = OUTR . `pk` ) WHERE OUTR . `col_int_key` IN ( SELECT  INNR . `col_int_key` AS Y FROM BB AS INNR WHERE INNR . `col_varchar_10_key` <> INNR . `col_varchar_10` AND OUTR . `col_varchar_20` > 'f' ORDER BY INNR . `col_datetime_key` ) AND OUTR . `col_int_key` IS NULL HAVING X > NULL ORDER BY 1 DESC, OUTR . `col_date` DESC , OUTR . `pk` ASC LIMIT 1), (SELECT  OUTR . `col_datetime_key` AS X FROM B AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_date` >= OUTR . `col_datetime` ) WHERE OUTR . `col_varchar_20_key` IN ( SELECT  INNR . `col_varchar_10` AS Y FROM CC AS INNR WHERE INNR . `col_datetime_key` <> INNR . `col_date` AND NOT OUTR . `col_datetime_key` <= '2005-09-07' ORDER BY INNR . `col_int_key` ) AND OUTR . `col_varchar_20` <= 'q'  ORDER BY 1 ASC, OUTR . `col_int_key` ASC , OUTR . `pk`  LIMIT 1), (SELECT  MAX( OUTR . `col_date` ) AS X FROM C AS OUTR WHERE ( OUTR . `col_int` , OUTR . `pk` ) IN ( SELECT DISTINCT INNR . `col_int_key` AS X , INNR . `pk` AS Y FROM CC AS INNR2 LEFT JOIN CC AS INNR ON ( INNR2 . `col_datetime_key` < INNR . `col_date` ) WHERE INNR . `col_varchar_10_key` <> 'd' ORDER BY INNR . `col_varchar_20_key` ) AND ( OUTR . `col_datetime` BETWEEN '2000-12-28' AND '2002-06-17' OR NOT OUTR . `col_date` BETWEEN '2006-06-17' AND '2007-09-25' ) HAVING X <> '2004-08-07' ORDER BY 1 ASC, OUTR . `col_int` DESC , OUTR . `pk` DESC LIMIT 1), (SELECT  MIN(DISTINCT OUTR . `pk` ) AS X FROM C AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_int` >= OUTR . `pk` ) WHERE OUTR . `pk` IN ( SELECT  INNR . `col_int_key` AS Y FROM CC AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `col_int` = INNR . `col_int` ) WHERE INNR . `col_int` > 5 ORDER BY INNR . `col_varchar_10_key` ) OR OUTR . `col_datetime` IS NULL AND NOT OUTR . `col_varchar_10` <> 'z' HAVING X < '2007-11-08' ORDER BY 1 ASC, OUTR . `col_varchar_10_key`  , OUTR . `pk`  LIMIT 1), (SELECT DISTINCT AVG(DISTINCT OUTR . `col_varchar_20_key` ) AS X FROM C AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_int` <= OUTR . `col_int_key` ) WHERE ( OUTR . `pk` , OUTR . `pk` ) IN ( SELECT DISTINCT INNR . `pk` AS X , INNR . `col_int` AS Y FROM BB AS INNR WHERE INNR . `col_date_key` IS NULL  ) OR OUTR . `col_date` <= '2002-11-15'  ORDER BY 1 , OUTR . `col_int_key` DESC , OUTR . `pk` ASC LIMIT 1), (SELECT  COUNT( OUTR . `pk` ) AS X FROM B AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `col_datetime_key` > OUTR . `col_datetime_key` ) WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `col_int` AS Y FROM BB AS INNR WHERE INNR . `col_int_key` > 6  ) AND OUTR . `col_int` IS NOT NULL HAVING X <> '2006-07-06 18:09:05' ORDER BY 1 ASC, OUTR . `col_varchar_20` ASC , OUTR . `pk` DESC LIMIT 1), (SELECT  OUTR . `col_int` AS X FROM B AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_int_key` < OUTR . `col_int` ) WHERE OUTR . `col_varchar_10_key` IN ( SELECT DISTINCT INNR . `col_varchar_20` AS Y FROM BB AS INNR WHERE INNR . `col_varchar_20` > INNR . `col_varchar_10_key` OR NOT INNR . `col_varchar_10` >= INNR . `col_varchar_20_key`  ) AND OUTR . `col_int` = 4 OR OUTR . `col_varchar_20` IS NULL  ORDER BY 1 ASC, OUTR . `col_datetime_key` ASC , OUTR . `pk` DESC LIMIT 1), (SELECT DISTINCT COUNT( OUTR . `col_varchar_20` ) AS X FROM C AS OUTR2 LEFT JOIN B AS OUTR ON ( OUTR2 . `pk` = OUTR . `col_int` ) WHERE OUTR . `col_int` IN ( SELECT DISTINCT INNR . `col_int_key` AS Y FROM BB AS INNR2 LEFT JOIN CC AS INNR ON ( INNR2 . `pk` <= INNR . `col_int` ) WHERE INNR . `col_date` BETWEEN '2003-03-18' AND '2000-02-23'  ) AND OUTR . `col_varchar_10` = 'm'  ORDER BY 1 DESC, OUTR . `col_int_key` ASC , OUTR . `pk`  LIMIT 1), (SELECT  OUTR . `col_date` AS X FROM B AS OUTR WHERE OUTR . `col_varchar_10` IN ( SELECT DISTINCT INNR . `col_varchar_20` AS Y FROM BB AS INNR WHERE INNR . `col_varchar_10` <= 'u' ORDER BY INNR . `col_datetime_key` ) OR ( OUTR . `col_varchar_20_key` <> 's' OR NOT OUTR . `pk` < 6 ) HAVING X < NULL ORDER BY 1 DESC, OUTR . `col_datetime` ASC , OUTR . `pk` ASC LIMIT 1), (SELECT DISTINCT OUTR . `col_date` AS X FROM B AS OUTR WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `col_int` AS Y FROM CC AS INNR WHERE OUTR . `col_datetime` IS NOT NULL  ) AND OUTR . `col_varchar_10` < 'h'  ORDER BY 1 ASC, OUTR . `col_date`  , OUTR . `pk`  LIMIT 1) FROM DUAL;

## 简化case
SELECT
 (SELECT DISTINCT COUNT(OUTR . `col_varchar_20`) AS X
  FROM C AS OUTR2
  LEFT JOIN B AS OUTR ON (OUTR2 . `pk` = OUTR . `col_int`)
  WHERE OUTR . `col_int` IN
    (SELECT DISTINCT INNR . `col_int_key` AS Y
     FROM BB AS INNR2
     LEFT JOIN CC AS INNR ON (INNR2 . `pk` <= INNR . `col_int`)
     WHERE INNR . `col_date` BETWEEN '2003-03-18' AND '2000-02-23')
   AND OUTR . `col_varchar_10` = 'm'
  ORDER BY 1 DESC, OUTR . `col_int_key` ASC , OUTR . `pk` LIMIT 1),
 (SELECT DISTINCT OUTR . `col_date` AS X
  FROM B AS OUTR
  WHERE OUTR . `pk` IN
    (SELECT DISTINCT INNR . `col_int` AS Y
     FROM CC AS INNR
     WHERE OUTR . `col_datetime` IS NOT NULL)
   AND OUTR . `col_varchar_10` < 'h'
  ORDER BY 1 ASC, OUTR . `col_date` ,
                  OUTR . `pk` LIMIT 1)
FROM DUAL;

drop table if exists `a`,`b`,`c`,`d`,`bb`,`cc`;
