--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
# tags: optimizer
#description: plan cache for common expression

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(a int, b int, c int);
create table t2(a int, b int, c int);
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);

##test the case where we first choose index, then table scan
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
disconnect obsys;
connection default;

select * from t1, t2 where t1.a = t2.a and ((t1.b = 1 and t2.c = 1) or (t1.b = 1 and t2.b = 1));
select query_sql, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '612B15C943C9DA7A2AC87AF1EFDF068A' and type = 1;
select * from t1, t2 where t1.a = t2.a and ((t1.b = 1 and t2.c = 1) or (t1.b = 1 and t2.b = 1));
select query_sql, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '612B15C943C9DA7A2AC87AF1EFDF068A' and type = 1;
select * from t1, t2 where t1.a = t2.a and ((t1.b = 1 and t2.c = 1) or (t1.b = 2 and t2.b = 1));
select query_sql, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '612B15C943C9DA7A2AC87AF1EFDF068A' and type = 1;
select * from t1, t2 where t1.a = t2.a and ((t1.b = 2 and t2.c = 1) or (t1.b = 1 and t2.b = 1));
select query_sql, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '612B15C943C9DA7A2AC87AF1EFDF068A' and type = 1;
select * from t1, t2 where t1.a = t2.a and ((t1.b = 2 and t2.c = 1) or (t1.b = 2 and t2.b = 1));
select query_sql, executions from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id = '612B15C943C9DA7A2AC87AF1EFDF068A' and type = 1;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--explain_protocol 0
CREATE TABLE t1 (c1 int, c2 int)partition by hash(c1) partitions 5 ;
CREATE TABLE t2 (c1 int, c2 int)partition by hash(c1) partitions 5 ;
create index t2_i1 on t2(c2) local;
--explain_protocol 2
select /*+leading(t1 t2) use_nl(t2) no_use_das(t2) parallel(1)*/ count(*) from t1,t2 where t1.c2 = t2.c2;