##
## II.1.2.4 insert
##
create table t_insert4 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by hash(c1)
subpartition by list (c2)
subpartition template
(
  subpartition lp0 values in (1,2,3,4,5),
  subpartition lp1 values in (6,7,8,9,10),
  subpartition lp2 values in (11,12,13,14,15)
) partitions 10;
select count(*) from t_insert4;
set autocommit=0;

## same first partition type, only one partition left after partition pruning,
## subpartition logical equal, pwj
EXPLAIN insert into t_insert4 select * from t_hash_list1 t1 where t1.c1 = 1;
insert into t_insert4 select * from t_hash_list1 t1 where t1.c1 = 1;
select * from t_insert4;
rollback;
insert into t_insert4 select * from t_hash_list1 t1 where t1.c1 = 6;
select * from t_insert4;
rollback;
insert into t_insert4 select * from t_hash_list1 t1 where t1.c1 = 10;
select * from t_insert4;
rollback;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'insert into t_insert4 select * from t_hash_list1 t1 where t1.c1 = ?';

