--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop database if exists opt_pwj;
--enable_warnings
create database opt_pwj;
use opt_pwj;

set global ob_plan_cache_percentage = 50;

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;
connection default;

--result_format 4

##
## I. 一级分区
##
##
## I.1 range分区
##
create table t_range1 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
create table t_range2 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (150),
  partition p2 values less than (200),
  partition p3 values less than (300)
);
create table t_range3 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
alter table t_range3 drop partition p2;
alter table t_range3 add partition (partition p3 values less than (300));

create table t_range4 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300)
);
--disable_result_log
insert into t_range1 values (1,1,1),(5,5,5),(51,51,51),(55,55,55),
                            (101,101,101),(105,105,105),(151,151,151),(155,155,155),
                            (201,201,201),(205,205,205),(251,251,251),(255,255,255);
insert into t_range2 values (2,2,2),(5,5,5),(52,52,52),(55,55,55),
                            (102,102,102),(105,105,105),(152,152,152),(155,155,155),
                            (202,202,202),(205,205,205),(252,252,252),(255,255,255);
insert into t_range3 values (3,3,3),(5,5,5),(53,53,53),(55,55,55),
                            (103,103,103),(105,105,105),(153,153,153),(155,155,155),
                            (203,203,203),(205,205,205),(253,253,253),(255,255,255);
insert into t_range4 values (4,4,4),(5,5,5),(54,54,54),(55,55,55),
                            (104,104,104),(105,105,105),(154,154,154),(155,155,155),
                            (204,204,204),(205,205,205),(254,254,254),(255,255,255);
--disable_query_log
select count(*) from t_range1;
select count(*) from t_range2;
select count(*) from t_range3;
select count(*) from t_range4;
--enable_query_log
--enable_result_log
##
## I.1.1 join
##
## logical partition not equal, no pwj
EXPLAIN select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1;
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1;

## after partition pruning, logical partition equal, pwj
EXPLAIN select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 150 order by t1.c1;
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 150 order by t1.c1;
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 151 order by t1.c1;
select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > 160 order by t1.c1;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'select * from t_range1 t1, t_range2 t2 where t1.c1 = t2.c1 and t1.c1 > ? order by t1.c1';

## t_range3 has partition management, logical partition equal, pwj
EXPLAIN select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 order by t1.c1;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 order by t1.c1;

## t_ragne4 has partition reorganize, logical partition equal, pwj
EXPLAIN select * from t_range2 t1, t_range4 t2 where t1.c1 = t2.c1;
select * from t_range2 t1, t_range4 t2 where t1.c1 = t2.c1;

##
## I.1.2 union/intersect/except
##
## logical partition not equal, no pwj
EXPLAIN select * from t_range1 union select * from t_range2;
select * from t_range1 union select * from t_range2;

## after partition pruning, logical partition equal, pwj
EXPLAIN select * from t_range1 t1 where t1.c1 > 100 union select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 100 union select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 150 union select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 151 union select * from t_range2 t2 where t2.c1 > 160;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'select * from t_range1 t1 where t1.c1 > ? union select * from t_range2 t2 where t2.c1 > ?';

## t_range3 has partition management, logical partition equal, pwj
EXPLAIN select * from t_range1 t1 intersect select * from t_range3 t2;
select * from t_range1 t1 intersect select * from t_range3 t2;

## t_ragne4 has partition reorganize, logical partition equal, pwj
EXPLAIN select * from t_range2 t1 except select * from  t_range4 t2;
select * from t_range2 t1 except select * from  t_range4 t2;

##
## I.1.3 union all
##
## partition number not equal, no pwj
EXPLAIN select * from t_range1 union all select * from t_range2;
select * from t_range1 union all select * from t_range2;

## after partition pruning, partition number equal, pwj
EXPLAIN select * from t_range1 t1 where t1.c1 > 100 union all select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 100 union all select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 150 union all select * from t_range2 t2 where t2.c1 > 150;
select * from t_range1 t1 where t1.c1 > 151 union all select * from t_range2 t2 where t2.c1 > 160;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'select * from t_range1 t1 where t1.c1 > ? union all select * from t_range2 t2 where t2.c1 > ?';

## t_range3 has partition management, partition number equal, pwj
EXPLAIN select * from t_range1 t1 union all select * from t_range3 t2;
select * from t_range1 t1 union all select * from t_range3 t2;

## t_ragne4 has partition reorganize, partition number equal, pwj
EXPLAIN select * from t_range2 t1 union all select * from  t_range4 t2;
select * from t_range2 t1 union all select * from  t_range4 t2;

##
## I.1.4 insert
##
create table t_insert1 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (150),
  partition p2 values less than (200),
  partition p3 values less than (300)
);
set autocommit=0;

## logical partition not equal, no pwj
EXPLAIN insert into t_insert1 select * from t_range1;
insert into t_insert1 select * from t_range1;
select * from t_insert1;
rollback;

## after partition pruning, logical partition equal, pwj
EXPLAIN insert into t_insert1 select * from t_range1 t1 where t1.c1 > 150;
insert into t_insert1 select * from t_range1 t1 where t1.c1 > 150;
select * from t_insert1;
rollback;
insert into t_insert1 select * from t_range1 t1 where t1.c1 > 152;
select * from t_insert1;
rollback;
insert into t_insert1 select * from t_range1 t1 where t1.c1 > 160;
select * from t_insert1;
rollback;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'insert into t_insert1 select * from t_range1 t1 where t1.c1 > ?';

## t_range3 has partition management, after partition pruning, partition number equal, pwj
EXPLAIN insert into t_insert1 select * from t_range3 t1 where t1.c1 > 150;
insert into t_insert1 select * from t_range3 t1 where t1.c1 > 150;
select * from t_insert1;
rollback;

## t_ragne4 has partition reorganize, partition number equal, pwj
EXPLAIN insert into t_insert1 select * from t_range4;
insert into t_insert1 select * from t_range4;
select * from t_insert1;
rollback;

set autocommit=1;

##
## I.1.5 join, union/intersect/except, union all, insert混合
##
## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) union (t3,t4) is not pwj
EXPLAIN select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1
union
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1
union
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1;

## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) intersect (t3,t4) is pwj
EXPLAIN select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 100
intersect
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 100
intersect
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 150
intersect
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 151
intersect
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 155;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT 
where statement = 'select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > ?
intersect
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > ?';

## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) union all (t3,t4) is weak pwj
EXPLAIN select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 100
union all
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 100
union all
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 150
union all
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 150;
select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > 151
union all
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > 155;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'select * from t_range1 t1, t_range3 t2 where t1.c1 = t2.c1 and t1.c1 > ?
union all
select * from t_range2 t3, t_range4 t4 where t3.c1 = t4.c1 and t3.c1 > ?';

## t1 union all t2 is weak pwj
## t3 union all t4 is weak pwj
## (t1,t2) join (t3,t4) is not pwj
EXPLAIN select * from 
(select * from t_range1 t1 union all select * from t_range3 t2) v1,
(select * from t_range2 t3 union all select * from t_range4 t4) v2
where v1.c1 = v2.c1;
--sorted_result
select * from 
(select * from t_range1 t1 union all select * from t_range3 t2) v1,
(select * from t_range2 t3 union all select * from t_range4 t4) v2
where v1.c1 = v2.c1;

set autocommit=0;

## t1 join t2 is not pwj
## t1 join t3 is pwj
## insert into t_insert1 is not pwj
#EXPLAIN insert into t_insert1
#select t1.* from t_range1 t1, t_range2 t2, t_range3 t3
