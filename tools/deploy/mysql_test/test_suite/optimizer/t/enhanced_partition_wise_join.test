select t1.* from t_hash_list1 t1, t_hash_list2 t2, t_range_list1 t3
where t1.c2 = t2.c2 and t2.c2 = t3.c2 and t1.c1 = 1 and t2.c1 = 1 and t3.c1 < 80;
