select * from t_insert4;
rollback;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'insert into t_insert4 select * from t_range_list1 t1 where t1.c1 = ?';

set autocommit=1;

##
## II.1.2.5 join, union/intersect/except, union all, insert混合
##
## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) union (t3,t4) is pwj
EXPLAIN select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 = 5 and t2.c1 = 5
union
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 = 1 and t4.c1 = 1;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 = 5 and t2.c1 = 5
union
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 = 1 and t4.c1 = 1;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 = 105 and t2.c1 = 205
union
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 = 51 and t4.c1 = 6;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 = 201 and t2.c1 = 202
union
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 = 155 and t4.c1 = 10;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 = ? and t2.c1 = ?
union
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 = ? and t4.c1 = ?';

## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) intersect (t3,t4) is pwj
EXPLAIN select /*+no_pred_deduce*/ * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 < 100 and t2.c1 < 90
intersect
select /*+no_pred_deduce*/ * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 > 200 and t4.c1 = 1;
select /*+no_pred_deduce*/ * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 < 100 and t2.c1 < 90
intersect
select /*+no_pred_deduce*/ * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 > 200 and t4.c1 = 1;
select /*+no_pred_deduce*/ * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 < 60 and t2.c1 < 70
intersect
select /*+no_pred_deduce*/ * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 > 220 and t4.c1 = 5;
select /*+no_pred_deduce*/ * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 < 50 and t2.c1 < 20
intersect
select /*+no_pred_deduce*/ * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 > 240 and t4.c1 = 6;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'select /*+no_pred_deduce*/ * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 < ? and t2.c1 < ?
intersect
select /*+no_pred_deduce*/ * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 > ? and t4.c1 = ?';


## t1 join t2 is pwj
## t3 join t4 is pwj
## (t1,t2) union all (t3,t4) is weak pwj
EXPLAIN select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 between 100 and 199 and t2.c1 between 150 and 199
union all
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 between 1 and 80 and t4.c1 = 1;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 between 100 and 199 and t2.c1 between 150 and 199
union all
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 between 1 and 80 and t4.c1 = 1;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 between 150 and 199 and t2.c1 between 153 and 199
union all
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 between 100 and 180 and t4.c1 = 5;
select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 between 150 and 180 and t2.c1 between 150 and 170
union all
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 between 200 and 280 and t4.c1 = 6;
## hit_count should be 2
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT
where statement = 'select * from t_range_list1 t1, t_range_list2 t2 where t1.c2 = t2.c2 and t1.c1 between ? and ? and t2.c1 between ? and ?
union all
select * from t_range_list1 t3, t_hash_list1 t4 where t3.c2 = t4.c2 and t3.c1 between ? and ? and t4.c1 = ?';

set autocommit=0;

## t1 join t2 is pwj
## t1 join t3 is pwj
## insert into t_insert4 is pwj
EXPLAIN insert into t_insert4
select t1.* from t_hash_list1 t1, t_hash_list2 t2, t_range_list1 t3
where t1.c2 = t2.c2 and t2.c2 = t3.c2 and t1.c1 = 1 and t2.c1 = 1 and t3.c1 < 80;
