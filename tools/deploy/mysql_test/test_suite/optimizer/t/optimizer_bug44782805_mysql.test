#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description:

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--result_format 4
--explain_protocol 2

CREATE TABLE t1 (
  `pk` int(11) NOT NULL,
  `col_int` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`)
);

CREATE TABLE t2 (
  `sid` int(11) NOT NULL,
  `subject` varchar(4) NOT NULL,
  PRIMARY KEY (`sid`, `subject`)
) partition by hash(sid)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5);

DELETE /*+ ENABLE_PARALLEL_DML parallel(2) */ t1, t2 FROM t1 LEFT JOIN t2 ON t1.col_int = t2.sid AND t1.pk = t2.sid;

drop table t1, t2;
