#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

alter system set _preserve_order_for_groupby = true;
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
insert into t1 select uniform(1,4,random(1)), uniform(1,2,random(2)), uniform(1,2,random(3)) from table(generator(100));
insert into t2 select * from t1;
--result_format 4
--explain_protocol 1

select c1,c2,count(*) from t1 group by c1,c2;
select v1.c1,v2.c2,count(*) from t1 v1, t1 v2 where v1.c1 = v2.c1 group by v1.c1,v2.c2;
select c1,c2,count(distinct c3) from t1 group by c1,c2;
select c1,c2,count(*) from t1 group by c1,c2 limit 10;
select c1,c2,count(*) from t1 group by c1,c2 with rollup;
#select c1,c2,count(*) from t1 group by c1,rollup(c2);
#select c1,c2,count(*) from t1 group by grouping sets((c1),(c2),(c1,c2));
#select c1,c2,count(*) from t1 group by cube(c1,c2);
select /*+parallel(4)*/ c1,c2,count(*) from t1 group by c1,c2;
select * from (select c1,c2,count(*) as cnt from t1 group by c1,c2) v;
with cte as (select c1,c2,count(*) as cnt from t1 group by c1,c2) select * from cte;
select c1,c2+1,count(*) from t1 group by c1,c2+1;
select c1,(select max(c3) from t1 v2 where c2 = v1.c2) c2,count(*) from t1 v1 group by c1,(select max(c3) from t1 v2 where c2 = v1.c2);

select c1,c2,count(*) from t2 group by c1,c2;
select v1.c1,v2.c2,count(*) from t2 v1, t2 v2 where v1.c1 = v2.c1 group by v1.c1,v2.c2;
select c1,c2,count(distinct c3) from t2 group by c1,c2;
select c1,c2,count(*) from t2 group by c1,c2 limit 10;

## not preserve order
select c1,c2,count(*) from t1 group by c1,c2 order by 2;
select c1,c2,count(*) from t1 group by c1,c2 order by 3;

alter system set _preserve_order_for_groupby = false;
drop table t1,t2;
