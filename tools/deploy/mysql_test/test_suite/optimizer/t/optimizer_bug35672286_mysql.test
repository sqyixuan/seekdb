--explain_protocol 2
--result_format 4

SELECT COUNT(t2_1056.c3)
FROM (SELECT t2_1056.c1, t2_1056.c2,
             (SELECT t2_1056.c3 FROM t2 AS t2_1056 ORDER BY 1 LIMIT 1) AS c3,
             t2_1056.c4,
             (SELECT t2_1056.c5 FROM t2 AS t2_1056 ORDER BY 1 LIMIT 1) AS c5
      FROM t2 AS t2_1056) AS t2_1056
RIGHT OUTER JOIN t21 AS t21_4192 ON t2_1056.c4 < 173 OR t2_1056.c2 < 282
WHERE t2_1056.c4 <= ((SELECT t2_1056.c4 FROM t2 AS t2_1056 ORDER BY 1 LIMIT 1)
                     UNION (SELECT t2_1056.c4 FROM t2 AS t2_1056 ORDER BY 1 LIMIT 1) LIMIT 1)
    AND t2_1056.c5 >= (SELECT t2_1056.c3 FROM t2 AS t2_1056 ORDER BY 1 LIMIT 1)
GROUP BY t2_1056.c3 ORDER BY 1;

SELECT c3
FROM (SELECT (SELECT c3 FROM t2 t_i1 LIMIT 1) AS c3,
             (SELECT c5 FROM t2 t_i2 LIMIT 1) AS c5
      FROM t2 AS t_i3
      union all
      SELECT c3, c5 FROM t2 t_i4
) AS V
WHERE c5 >= (SELECT c3 FROM t2 t_o1 LIMIT 1);

## shared subquery extract onetime expr
select (select c2 from t1 limit 1) a from t1 having sum(a) / count(a) > 4;

drop table t1, t2, t21;

--disable_warnings
drop table if exists etl_cfg_cluster_operator, etl_cfg_cluster, etl_cfg_group, etl_cfg_catalog;
--enable_warnings
CREATE TABLE `etl_cfg_cluster_operator` (
  `ROW_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT 'ROW_ID',
  `USER_ID` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT '用户ID',
  `CLUSTER_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '群组ID',
  `CREATED_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录创建者',
  `CREATED_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',
  `LAST_UPD_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录最后更新者',
  `LAST_UPD_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录最后更新时间',
  PRIMARY KEY (`ROW_ID`),
  KEY `IDX__CFG_CLUSTER_OPERATOR_U1` (`USER_ID`, `CLUSTER_ID`) BLOCK_SIZE 16384 LOCAL,
  KEY `IDX__CFG_CLUSTER_OPERATOR_N1` (`CLUSTER_ID`) BLOCK_SIZE 16384 LOCAL
) ;

CREATE TABLE `etl_cfg_cluster` (
  `CLUSTER_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '群组ID',
  `CLUSTER_NAME` varchar(100) COLLATE utf8mb4_bin NOT NULL COMMENT '群组名称',
  `CLUSTER_DESC` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '群组描述',
  `CLUSTER_TYPE` varchar(1) COLLATE utf8mb4_bin NOT NULL DEFAULT 'S' COMMENT '群组单多业务系统类型：S单 M多',
  `CREATED_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录创建者',
  `CREATED_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',
  `LAST_UPD_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录最后更新者',
  `LAST_UPD_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录最后更新时间',
  PRIMARY KEY (`CLUSTER_ID`),
  UNIQUE KEY `IDX_ETL_CFG_CLUSTER_U1` (`CLUSTER_NAME`) BLOCK_SIZE 16384 LOCAL
) ;

CREATE TABLE `etl_cfg_group` (
  `GROUP_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '任务组ID',
  `GROUP_NAME` varchar(100) COLLATE utf8mb4_bin NOT NULL COMMENT '任务组名称',
  `GROUP_DESC` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '任务组描述',
  `ORDER_BY` int(11) NOT NULL DEFAULT '50' COMMENT '展现序号',
  `CATALOG_ID` varchar(48) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '所属目录ID',
  `CLUSTER_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '所属群组ID',
  `PRIORITY_LVL` int(11) DEFAULT '3' COMMENT '优先级别：1-5（越小优先级越高）',
  `GROUP_ACT_ORDER` int(11) NOT NULL DEFAULT '50' COMMENT '所有任务组执行顺序号： 按执行顺序号串行执行，同序号可并发执行',
  `CREATED_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录创建者',
  `CREATED_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',
  `LAST_UPD_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录最后更新者',
  `LAST_UPD_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录最后更新时间',
  PRIMARY KEY (`GROUP_ID`),
  UNIQUE KEY `IDX_ETL_CFG_GROUP_U1` (`CLUSTER_ID`, `GROUP_NAME`) BLOCK_SIZE 16384 LOCAL
) ;

CREATE TABLE `etl_cfg_catalog` (
  `CATALOG_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '目录ID',
  `CATALOG_NAME` varchar(100) COLLATE utf8mb4_bin NOT NULL COMMENT '目录名称',
  `CATALOG_DESC` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '目录描述',
  `PAR_CATALOG_ID` varchar(48) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '上级目录ID：NULL就是一级目录',
  `ORDER_BY` int(11) NOT NULL DEFAULT '50' COMMENT '展现序号',
  `CLUSTER_ID` varchar(48) COLLATE utf8mb4_bin NOT NULL COMMENT '群组ID',
  `CREATED_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录创建者',
  `CREATED_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录创建时间',
  `LAST_UPD_BY` varchar(48) COLLATE utf8mb4_bin NOT NULL DEFAULT 'admin' COMMENT '记录最后更新者',
  `LAST_UPD_TS` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '记录最后更新时间',
  PRIMARY KEY (`CATALOG_ID`),
  UNIQUE KEY `IDX_ETL_CFG_CATALOG_U1` (`CLUSTER_ID`, `CATALOG_NAME`) BLOCK_SIZE 16384 LOCAL
);
SELECT /*+semi_to_inner(VIEW1) leading(VIEW2 A) use_nl(A)*/ A.*
  ,case  when type= 'GROUP' then concat(NODE_NAME , concat('(', concat(GROUP_ACT_ORDER ,')'))) else NODE_NAME end as NODE_LABEL
  ,concat(NODE_ID  , concat('-', NODE_NAME)) as NODE_TITLE
FROM (
    SELECT
          CLUSTER_ID AS NODE_ID
        , CLUSTER_NAME AS NODE_NAME
        , 'CLUSTER' AS TYPE
        , '' AS PAR_NODE_ID
        , CLUSTER_ID
        , 0 AS ORDER_BY
        , 0 AS GROUP_ACT_ORDER
        , '' as GROUP_DESC
    FROM
      ETL_CFG_CLUSTER
  UNION ALL
    SELECT
          GROUP_ID AS NODE_ID
        , GROUP_NAME AS NODE_NAME
        , 'GROUP' AS TYPE
        , COALESCE(NULLIF(TRIM(CATALOG_ID),''),CLUSTER_ID) AS PAR_NODE_ID
        , CLUSTER_ID
        , ORDER_BY
        , GROUP_ACT_ORDER
        , GROUP_DESC
    FROM ETL_CFG_GROUP
UNION ALL
    SELECT
          CATALOG_ID AS NODE_ID
        , CATALOG_NAME AS NODE_NAME
        , 'CATALOG' AS TYPE
        , COALESCE(NULLIF(TRIM(PAR_CATALOG_ID),''),CLUSTER_ID) AS PAR_NODE_ID
        , CLUSTER_ID
        , ORDER_BY
        , 0 AS GROUP_ACT_ORDER
        , '' as GROUP_DESC
    FROM ETL_CFG_CATALOG
) A
where CLUSTER_ID IN (SELECT CLUSTER_ID FROM ETL_CFG_CLUSTER_OPERATOR WHERE USER_ID = 'URRP');
