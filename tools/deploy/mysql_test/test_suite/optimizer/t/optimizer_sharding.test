# owner: link.zt
# onwer group: SQL1
# tags: optimizer
# description: 测试 sharding 的继承

--disable_warnings
drop table if exists t;
drop table if exists t1;
--enable_warnings
create table t (c1 int, c2 int, index idx_t_c1 (c1) local, index idx_t_c2(c2) local) partition by hash(c1) partitions 4;
create table t1(c1 int, c2 int, index idx_t1_c1(c1) local, index idx_t1_c2(c2) local );
--disable_query_log
insert into t values (1, 4);
insert into t values (1, 1);
insert into t values (2, 1);
insert into t values (2, 2);
insert into t values (3, 2);
insert into t values (3, 3);
insert into t values (4, 3);
insert into t values (4, 4);
insert into t1 select * from t;
--disable_result_log
select count(*) from t1;
select count(*) from t;
--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

select sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t;
select /*+index(t idx_t_c1)*/ sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t;
select /*+index(t idx_t_c2)*/ sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t;

select sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t1;
select /*+index(t1 idx_t1_c1)*/ sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t1;
select /*+index(t1 idx_t1_c2)*/ sum(c1) over (partition by c2), sum(c2) over (partition by c1) from t1;

drop table t1;
drop table t;
