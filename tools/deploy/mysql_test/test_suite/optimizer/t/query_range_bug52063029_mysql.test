# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer,cross_validation

--disable_warnings
DROP TABLE if exists table10_int_not_null;
--enable_warnings
--result_format 4

CREATE TABLE `table10_int_not_null` (
  `pk` int(11) NOT NULL,
  `col_timestamp_unique_index` timestamp NULL DEFAULT NULL,
  `col_decimal_20_0_unique_index` decimal(20,0) DEFAULT NULL,
  `col_varchar_20_unique_index` varchar(20) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_double` double DEFAULT NULL,
  `col_timestamp` timestamp NULL DEFAULT NULL,
  `col_varchar_20_index` varchar(20) DEFAULT NULL,
  `col_bigint_index` bigint(20) DEFAULT NULL,
  `col_double_unique_index` double DEFAULT NULL,
  `col_bigint_unique_index` bigint(20) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_timestamp_index` timestamp NULL DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_decimal_20_0_index` decimal(20,0) DEFAULT NULL,
  `col_double_index` double DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx2` (`col_bigint_unique_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`col_bigint_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx8` (`col_decimal_20_0_unique_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx4` (`col_double_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx14` (`col_timestamp_unique_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx13` (`col_timestamp_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx11` (`col_varchar_20_unique_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx10` (`col_varchar_20_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`col_double_unique_index`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`col_decimal_20_0_index`) BLOCK_SIZE 16384 LOCAL
);

--explain_protocol 2
alter system set _enable_in_range_optimization = true;
alter system flush plan cache global;
select (
    select t2.col_decimal_20_0 
    from table10_int_not_null as t2
    where t2.col_varchar_20_index > t1.col_varchar_20
      and t2.col_varchar_20_index IN ('dq','q','g','s','j','j','s','m','h','u')
      and t2.col_varchar_20_index between 'c' and 's'
      or t2.col_varchar_20_index between 'c' and 'j'
      and t2.col_varchar_20_unique_index between 'c' and 'b'
    order by 1 limit 1
) from table10_int_not_null as t1;


alter system set _enable_in_range_optimization = false;
alter system flush plan cache global;
select (
    select t2.col_decimal_20_0 
    from table10_int_not_null as t2
    where t2.col_varchar_20_index > t1.col_varchar_20
      and t2.col_varchar_20_index IN ('dq','q','g','s','j','j','s','m','h','u')
      and t2.col_varchar_20_index between 'c' and 's'
      or t2.col_varchar_20_index between 'c' and 'j'
      and t2.col_varchar_20_unique_index between 'c' and 'b'
    order by 1 limit 1
) from table10_int_not_null as t1;

DROP TABLE table10_int_not_null;
alter system set _enable_in_range_optimization = true;