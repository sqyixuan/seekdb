--disable_warnings
drop table if exists t0, t1;
--enable_warnings

# init env
CREATE TABLE t0(c0 INT);
INSERT INTO t0(c0) VALUES (2);

CREATE TABLE t1(c0 TINYTEXT , c1 BIGINT(179) ZEROFILL);
INSERT INTO t1(c1, c0) VALUES(959964316, '1891756983'), (631179289, 'jX\\<RU''kIblgaOcH');
INSERT IGNORE INTO t1(c0, c1) VALUES("eYN!9?U!LWAo <", -651747780), ('3*t_sNlGa c', FALSE);
--explain_protocol 2
--result_format 4

# start tests

##  expected: {}, actual: {2}
SELECT t0.c0 FROM t0 WHERE (NOT NOT t0.c0) = t0.c0;

SELECT t1.c0 AS ref0 FROM t1 WHERE ((! (! t1.c0)) IN ('?zoXw?LMtB6'));

SELECT t1.c0 AS ref0 FROM t1 WHERE NOT ((! (! t1.c0)) IN ('?zoXw?LMtB6'));

# clean env
drop table t1, t0;

--disable_warnings
drop table if exists t1;
--enable_warnings

#bug fix:
--explain_protocol 0
create table t1(c1 int, c2 varchar(20));
insert into t1 values(1, 'Abc');
insert into t1 values(-1, 'Abd');
--explain_protocol 2

select c1 from t1 where c1 = ( cast(c1 as signed) or cast(c1 as signed) );

select * from t1 where case when not( 1=null or c1=1) then 1 else 0 end =1;

#bug fix: 
create or replace view v1 as select * from T1 T1_29 where concat(T1_29.C2, T1_29.C2) like '%Ab%' OR concat(T1_29.C2, T1_29.C2) like '%Ab%';

show create view v1;

select * from v1;

drop table t1;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

--explain_protocol 0
create table t1 (pk int primary key, c1 int, c2 date not null, c3 date, c4 datetime not null, c5 datetime);
create table t2 (pk int primary key);
insert into t1 values (0, NULL,'0000-00-00','0000-00-00','0000-00-00','0000-00-00'),(1, 1,'1970-01-01','1970-01-01','1970-01-01','1970-01-01');
insert into t2 values (0),(1),(2);
--explain_protocol 2

select * from t1 where c1 is null and c2 is null and c4 is null;
select * from t1 where c3 is null and c5 is null;
select * from t1 right join t2 on t1.pk=t2.pk where c2 is null and c4 is null;
select * from (select c2 from t1) v where c2 is null;

drop table t1;
drop table t2;