--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL1
# description: 测试`(SELECT * FROM t1) order by c1`这种语法
# 

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings
CREATE TABLE t1 (a INT, b INT, PRIMARY KEY(b));
CREATE TABLE t2 (a INT, b INT, PRIMARY KEY(b));
CREATE TABLE t3 (a INT, b INT, PRIMARY KEY(b));

INSERT INTO t1 VALUES (1,30), (2,20), (1,10), (2,40), (1,50), (2,60);
INSERT INTO t2 VALUES (1,30), (2,20), (1,10);
INSERT INTO t3 VALUES (2,40), (1,50), (2,60);

(SELECT b,a FROM t1 ORDER by b,a LIMIT 3) ORDER by a,b;

(SELECT b,a FROM t1 ORDER by b,a LIMIT 3) ORDER by a,b LIMIT 4;

(SELECT b,a FROM t2 UNION SELECT b,a FROM t3 ORDER by b,a LIMIT 3) ORDER by a,b;

(SELECT b,a FROM t2 UNION SELECT b,a FROM t3 ORDER by b,a LIMIT 3) ORDER by a,b LIMIT 4;

--disable_warnings
DROP TABLE IF EXISTS t1, t2, t3;
--enable_warnings
