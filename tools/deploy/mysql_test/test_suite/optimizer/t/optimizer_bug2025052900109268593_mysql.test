#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,tmp;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, index i1(c1, c2, c3, c5), index i2(c1,c2,c4,c5));
create table tmp(c1 int, c2 int);
insert into tmp values (1, 2);
set ob_enable_transformation = 0;

--result_format 4
--explain_protocol 3

select /*+no_index(t1 primary)*/ * from t1 where c1 = (select c1 from tmp limit 1) and c2 = 1 and c4 = 1;
select /*+no_index(t1 primary)*/ * from t1 where c1 = (select c1 from tmp limit 1) and c2 = 1 and c4 = 1 and c5 = 1;
select /*+no_index(t1 primary)*/ * from t1 where c1 = (select c1 from tmp limit 1) and c2 = 1 and c4 between 1 and 2;
select /*+no_index(t1 primary)*/ * from t1 where (c1 = (select c1 from tmp limit 1) or c1 = 2) and c2 = 1 and c4 = 1;
select /*+no_index(t1 primary)*/ * from t1 where (c1 = (select c1 from tmp limit 1) or c1 = 2) and (c2 = 1 or c2 = 2) and c4 = 1;
select /*+no_index(t1 primary)*/ * from t1 where c1 = (select c1 from tmp limit 1) and c2 = 1 and c4 = 1 or c1 = (select c2 from tmp limit 1) and c2 = 2 and c4 = 2;
select /*+no_index(t1 primary)*/ * from t1 where c1 = (select c1 from tmp limit 1) and c2 = 1 and c4 = 1 or c1 = (select c2 from tmp limit 1) and c2 = 2;
select /*+no_index(t1 primary)*/ * from t1 where c1 = 1 and c2 = 1 and c4 = 1 or c1 = 2 and c2 = 2 and c4 = 2;
select /*+no_index(t1 primary)*/ * from t1 where c1 = 1 and c2 = 1 and c4 = 1 or c1 = 2 and c2 = 2;
select (select /*+no_index(t1 primary)*/ count(*) from t1 B where c1 = A.c1 and c2 = 1 and c4 = 1) as cnt from t1 A;
select /*+use_nl(A b)*/ 1 from t1 A, t1 B where A.c1 = B.c1 and A.c2 = B.c2 and A.c4 = B.c4;
select /*+use_nl(A b) leading(B A)*/ 1 from t1 A, t1 B where A.c1 = B.c1 and A.c2 = B.c2 and A.c4 = 1;
select /*+no_index(t1 i2)*/ c1 from t1 where 2 = (select c1 from tmp limit 1) or 1 = c1;

drop table t1,tmp;
