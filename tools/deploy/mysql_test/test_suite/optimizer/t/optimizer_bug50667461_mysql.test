connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
sleep 3;
connection default;

--disable_warnings
drop table if exists bmsql_item;
drop table if exists supplier;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
--enable_warnings

CREATE TABLE `bmsql_item` (
  `i_id` int(11) NOT NULL,
  `i_name` varchar(24) DEFAULT NULL,
  `i_price` decimal(5,2) DEFAULT NULL,
  `i_data` varchar(50) DEFAULT NULL,
  `i_im_id` int(11) DEFAULT NULL,
  PRIMARY KEY (`i_id`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `supplier` (
  `s_suppkey` bigint(20) NOT NULL,
  `s_name` char(25) DEFAULT NULL,
  `s_address` varchar(40) DEFAULT NULL,
  `s_nationkey` bigint(20) DEFAULT NULL,
  `s_phone` char(15) DEFAULT NULL,
  `s_acctbal` bigint(20) DEFAULT NULL,
  `s_comment` varchar(101) DEFAULT NULL,
  PRIMARY KEY (`s_suppkey`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 
 partition by hash(s_suppkey)
(partition p0);

create table t1 (c1 int, c2 int , c3 int);
create table t2 (c1 int, c2 int , c3 int);
create table t3 (c1 int, c2 int , c3 int);
create table t4 (c1 int, c2 int , c3 int);
create table t5 (c1 int, c2 int , c3 int);
create table t6 (c1 int, c2 int , c3 int);
create table t7 (c1 int, c2 int , c3 int);

--result_format 4
select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t2);

select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t3);

select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t4);

select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t5);

select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t6);

select 1 from dual 
  where exists(
              select 1 from bmsql_item as ref_13,  supplier as ref_14 where (
                  EXISTS (
                    select 1 from t1 as ref_15 
                  )
                )
          ) and
        exists(select 1 from t7);

--disable_warnings
drop table if exists bmsql_item;
drop table if exists supplier;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
