--enable_result_log
--enable_query_log

--explain_protocol 2
--result_format 4

SELECT t41_295.c2 FROM (SELECT t41_295.c1, t41_295.c2 FROM t41 AS t41_295) AS t41_295 WHERE t41_295.c2 = (SELECT t41_295.c2 FROM t41 AS t41_295 ORDER BY 1 LIMIT 1) OR t41_295.c2 = 654 AND t41_295.c2 <> t41_295.c1 ORDER BY 1;

select /*+ no_expand parallel(5)*/ c1 from t1 where c1 = (select 1 from dual limit 1) or c1 = 3 order by 1;

drop table t1, t41;