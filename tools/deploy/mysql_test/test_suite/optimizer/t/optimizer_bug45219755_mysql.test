select /*+ ENABLE_PARALLEL_DML PARALLEL(3) */  * FROM k WHERE PK IN (SELECT PK FROM ( SELECT    table1 . col_int_key AS field1 , table2 . `pk` AS field2 FROM ( CC AS table1 RIGHT OUTER JOIN BB AS table2 ON (table2 . `col_int_key` = table1 . `col_int_key`  ) ) WHERE (  table1 . `pk`  IN ( SELECT 5 UNION  SELECT 3 ) ) AND table1 . `col_int_key` = table2 . `col_int_key`  GROUP BY field1, field2 HAVING (field1 <= 'i' AND field1 <> 237) ORDER BY 1, field1, field2 LIMIT 1)TC1);

SELECT /*+ no_rewrite PARALLEL(3) leading(v) use_nl(table1) PQ_DISTRIBUTE(table1 all none)*/ table1 . col_int_key AS field1 FROM 
CC AS table1, ( SELECT 5 a   ) v where v.a =  table1 . `pk`
ORDER BY 1, field1 LIMIT 10;

SELECT /*+ no_rewrite PARALLEL(3) leading(v) use_nl(table1) */ table1 . col_int_key AS field1 FROM 
CC AS table1, ( SELECT 5 a   ) v where v.a =  table1 . `pk`
ORDER BY 1, field1 LIMIT 10;

DROP TABLE `bb`;
DROP TABLE `cc`;
DROP TABLE `k`;