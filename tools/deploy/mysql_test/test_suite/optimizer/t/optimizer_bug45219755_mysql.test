SELECT  /*+ PARALLEL(2)
      LEADING(@"SEL$2" ("innr" "innr2"))
      USE_NL(@"SEL$2" "innr2")
      PQ_DISTRIBUTE(@"SEL$2" "innr2" all none) */ 1
FROM  b AS outr
WHERE  outr . `col_int` IN ( SELECT innr . `pk` AS y
                             FROM cc innr2, bb innr
                             where innr2 . `pk` >= innr . `pk`);

DELETE /*+ ENABLE_PARALLEL_DML PARALLEL(3)*/ FROM mm WHERE PK IN (SELECT PK FROM (SELECT  OUTR . `col_date` AS X FROM B AS OUTR WHERE OUTR . `col_int` IN ( SELECT DISTINCT INNR . `pk` AS Y FROM CC AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `pk` >= INNR . `pk` ) WHERE INNR . `pk` <= INNR . `col_int_key` OR NOT OUTR . `col_int_key` <= 6 ORDER BY INNR . `col_date` ) OR OUTR . `col_datetime_key` BETWEEN '2001-03-10' AND '2006-07-15' AND NOT OUTR . `pk` <> 4 HAVING X <> '2004-01-22 06:12:54' ORDER BY 1 DESC, OUTR . `col_int_key`  , OUTR . `pk` DESC)TC1);

select count(*) from mm;

DROP TABLE `b`;
DROP TABLE `mm`;
DROP TABLE `bb`;
DROP TABLE `cc`;

--disable_warnings
DROP TABLE IF EXISTS `bb`;
DROP TABLE IF EXISTS `cc`;
DROP TABLE IF EXISTS `k`;
--enable_warnings

CREATE TABLE `bb` (
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) 
) ;

CREATE TABLE `cc` (
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx3` (`pk`, `col_varchar_key`) 
);

CREATE TABLE `k` (
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx3` (`pk`, `col_varchar_key`) ,
  KEY `idx5` (`pk`, `col_varchar_10_key`) ,
  KEY `idx7` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`) 
) ;

