# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int);

--explain_protocol 2
--result_format 4

select * from (select /*+no_rewrite no_merge*/ (select 1 from dual) as onetime from t1) v order by onetime;

drop table t1;
