#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
#description: test prefix_sort func
--disable_warnings
drop table if exists pfs,pfs1,t1,t16;
--enable_warnings

# 多类型建表
create table pfs(c_int_pre int signed,
		c_int int signed,
		c_uint int unsigned,
		c_dec_pre decimal(20,10),
		c_dec decimal(20, 10),
		c_tsp timestamp(6),
		c_year year,
		c_var_pre varchar(30),
		PRIMARY KEY (c_int, c_dec),
		key var_int (c_var_pre, c_int_pre),
		key var_dec (c_var_pre, c_dec_pre)
		);

#数据导入
--let $count = 1
--disable_query_log
while ($count <= 200)
{
	--let $int_len=1
	while ($int_len <= 10) 
	{
		eval insert into pfs values($count%100, $count-$int_len, $count+$int_len, 1, $count/3.0, usec_to_time($count%1000*1000000), $count%150+1970, repeat('abc', $int_len));
		inc $int_len;
	}
	inc $count;
}
--enable_query_log
#索引＋其它键
explain basic select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_int from pfs order by c_var_pre, c_int_pre, c_dec;
explain basic select /*+index(pfs var_dec)*/c_var_pre, c_dec_pre, c_int from pfs order by c_var_pre, c_dec_pre, c_uint;
explain basic select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_year,c_tsp from pfs order by c_var_pre, c_int_pre, c_year,c_tsp;
explain basic select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_year from pfs order by c_var_pre, c_int_pre, c_year limit 100;
explain basic select /*+index(pfs var_int), no_use_hash_aggregation*/c_var_pre, c_int_pre, c_year from pfs group by c_var_pre, c_int_pre, c_year;
explain basic select /*+index(pfs var_dec), no_use_hash_aggregation*/c_var_pre, c_dec_pre, c_int from pfs group by c_var_pre, c_dec_pre, c_year;
explain basic select /*+index(pfs var_int)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre desc, c_int_pre desc ,c_year,c_tsp limit 100;
explain basic select /*+index(pfs var_int)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre desc, c_int_pre desc ,c_year desc,c_tsp desc limit 100;

explain basic select /*+index(pfs var_int), no_use_hash_aggregation*/c_var_pre, c_int_pre, c_year from pfs group by c_var_pre desc, c_int_pre, c_year;
explain basic select /*+index(pfs var_int), no_use_hash_aggregation*/c_var_pre, c_int_pre, c_year from pfs group by c_var_pre desc, c_int_pre desc, c_year;
explain basic select /*+index(pfs var_int)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre, c_year,c_tsp limit 100;
explain basic select /*+index(pfs var_dec)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre, c_year,c_tsp limit 20;

#数据对照
select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_year from pfs order by c_var_pre, c_int_pre, c_year limit 100;
select /*+index(pfs var_dec)*/c_var_pre, c_dec_pre, c_year from pfs order by c_var_pre, c_dec_pre, c_year limit 100;
select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_year,c_tsp from pfs order by c_var_pre, c_int_pre, c_year,c_tsp limit 100,100;
select /*+index(pfs var_int)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre, c_year,c_tsp limit 20;
select /*+index(pfs var_dec)*/c_var_pre, c_year,c_tsp from pfs order by c_var_pre, c_year,c_tsp limit 20;
select /*+index(pfs var_int)*/c_var_pre, c_int_pre, c_year,c_tsp from pfs order by c_var_pre desc, c_int_pre desc ,c_year,c_tsp limit 10;
select /*+index(pfs var_int), no_use_hash_aggregation*/c_var_pre, c_int_pre, c_year from pfs group by c_var_pre desc, c_int_pre desc, c_year limit 20;
select /*+index(pfs var_int), no_use_hash_aggregation*/c_var_pre, c_int_pre, c_year from pfs group by c_var_pre desc, c_int_pre, c_year limit 20; 

--disable_warnings
drop table if exists pfs1;
--enable_warnings
#表2  做join
create table pfs1(c_int_pre int signed,
				 c_int int signed,
			     c_uint int unsigned,
				 c_dec_pre decimal(20,10),
				 c_dec decimal(20, 10),
				 c_tsp timestamp(6),
				 c_year year,
				 c_var_pre varchar(30),
				 PRIMARY KEY (c_int, c_dec),
				 key var_int (c_var_pre, c_int_pre),
				 key var_dec (c_var_pre, c_dec_pre));

#数据导入2
--let $count = 1
--disable_query_log
while ($count <= 100)
{
	--let $int_len=1
		while ($int_len <= 10)
		{
		  eval insert into pfs1 values($count-$int_len, $count-$int_len, $count+$int_len, 1, ($count+$int_len)/3.0, usec_to_time($count%1000*1000000), $count%150+1970, repeat('abc', $int_len));
	      inc $int_len;
		}
		inc $count;
}
--enable_query_log

#join
explain basic select /*+use_merge(pfs,pfs1)*/ pfs.c_int_pre,pfs.c_year from pfs,pfs1 where pfs.c_int_pre=pfs1.c_int_pre order by pfs.c_int_pre,pfs.c_year;
explain basic select /*+use_merge(pfs,pfs1)*/ pfs.c_dec_pre,pfs.c_year from pfs,pfs1 where pfs.c_dec_pre=pfs1.c_dec_pre order by pfs.c_dec_pre,pfs.c_year;
explain basic select /*+use_merge(pfs,pfs1)*/ pfs.c_year,pfs.c_tsp from pfs,pfs1 where pfs.c_year=pfs1.c_year order by pfs.c_year,pfs.c_tsp;
explain basic select /*+use_merge(pfs,pfs1)*/ pfs.c_year,pfs.c_tsp from pfs,pfs1 where pfs.c_year=pfs1.c_year order by pfs.c_year desc,pfs.c_tsp desc limit 10;
explain basic select /*+use_merge(pfs,pfs1)*/ pfs.c_year,pfs.c_tsp from pfs,pfs1 where pfs.c_year=pfs1.c_year order by pfs.c_year,pfs.c_tsp desc limit 10;

select /*+use_merge(pfs,pfs1)*/distinct pfs.c_int_pre,pfs.c_year from pfs,pfs1 where pfs.c_int_pre=pfs1.c_int_pre order by pfs.c_int_pre,pfs.c_year limit 10;
select /*+use_merge(pfs,pfs1)*/ pfs.c_year,pfs.c_tsp from pfs,pfs1 where pfs.c_year=pfs1.c_year order by pfs.c_year,pfs.c_tsp limit 10;

