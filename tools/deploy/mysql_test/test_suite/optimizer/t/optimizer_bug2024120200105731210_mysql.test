--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--result_format 3
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t0;
--enable_warnings
CREATE TABLE IF NOT EXISTS t0(c0 BIT);
INSERT  INTO t0(c0) VALUES(b'1');
CREATE INDEX i2 ON t0(c0);

explain select 1 from t0 where c0 < -1;
select 1 from t0 where c0 < -1;

drop table if exists t0;

