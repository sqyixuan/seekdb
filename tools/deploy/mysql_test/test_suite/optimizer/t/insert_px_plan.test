drop table target1;
drop table target2;
drop table t1;
drop table t2;

set autocommit = 1;
# test range partition
create table target1 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (MAXVALUE)
);

create table target2 (c1 int, c2 int, c3 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (MAXVALUE)
);

create table t1 (c1 int primary key, c2 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (MAXVALUE)
);
create table t2 (c1 int primary key, c2 int) partition by range(c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (MAXVALUE)
);
insert/**/ into t1 values (10,10),(20,20),(110,110),(120,120),(210,210),(220,220),(230,230),(240,240),(250,250),(260,260),(500, 500), (600, 601);
insert/**/ into t2 values (10,10),(20,20),(110,110),(120,120),(210,210),(220,220),(230,230),(240,240),(250,250),(260,260), (500, 501), (600, 600);
