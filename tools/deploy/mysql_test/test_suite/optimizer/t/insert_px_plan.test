--source mysql_test/include/backup_spm_var.inc

--disable_warnings
drop table if exists target1;
drop table if exists target2;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

# init env

# test hash partition
create table target1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create table target2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;

create table t1 (c1 int, c2 int) partition by hash(c1) partitions 4;
create table t2 (c1 int, c2 int) partition by hash(c1) partitions 4;

insert into t1 values (1, 2), (2, 2), (3, 4), (4, 4);
insert into t2 values (0, 1), (1, 5), (2, 4), (3, 3);

--result_format 4
set autocommit = 0;
# start tests

## simple select
insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1;
(select * from target1);
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 = 1;
(select * from target1);
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 = 1);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 < 2;
(select * from target1);
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 < 2);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (1);
(select * from target1);
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (1));
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (0, 2, 3);
(select * from target1);
(select t1.c1, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (0, 2, 3));
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c1 = c2;
(select * from target1);
(select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c1 = c2);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (1, 3);
(select * from target1);
(select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c1 in (1, 3));
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c2 in (1, 3);
(select * from target1);
(select t1.c2, t1.c2, t1.c1 + t1.c2 from t1 where c2 in (1, 3));
rollback;

## select with inner join
insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c1;
(select * from target1);
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c1);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2;
(select 'p0', c1, c2, c3 from target1 partition (p0)) union 
(select 'p1', c1, c2, c3 from target1 partition (p1)) union 
(select 'p2', c1, c2, c3 from target1 partition (p2)) union
(select 'p3', c1, c2, c3 from target1 partition (p3));
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2);

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2 on duplicate key update target1.c2 = -1;
(select 'p0', c1, c2, c3 from target1 partition (p0)) union 
(select 'p1', c1, c2, c3 from target1 partition (p1)) union 
(select 'p2', c1, c2, c3 from target1 partition (p2)) union
(select 'p3', c1, c2, c3 from target1 partition (p3));
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2);

replace into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2;
(select 'p0', c1, c2, c3 from target1 partition (p0)) union 
(select 'p1', c1, c2, c3 from target1 partition (p1)) union 
(select 'p2', c1, c2, c3 from target1 partition (p2)) union
(select 'p3', c1, c2, c3 from target1 partition (p3));
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c2);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c2 = t2.c1;
(select * from target1);
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c2 = t2.c1);
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c1 and t1.c1 in (2, 0);
(select * from target1);
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c1 = t2.c1 and t1.c1 in (2, 0));
rollback;

insert /*+use_px, parallel(4)*/ into target1 select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c2 = t2.c2 and t1.c1 in (2, 0);
(select * from target1);
(select t1.c1, t2.c1, t1.c2 + t2.c2 from t1, t2 where t1.c2 = t2.c2 and t1.c1 in (2, 0));
rollback;

