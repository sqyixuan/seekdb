# tags: optimizer
# issue: 
--result_format 4
--disable_warnings
drop table if exists tt1, tt2;
--enable_warnings

create table tt2(c1 int);
insert into tt2 values(-1);

##single partition and single subpartition
create table tt1(c1 int) partition by range(c1)
subpartition by range(c1) subpartition template (subpartition sp0 values less than (maxvalue))
(partition p0 values less than (0),
partition p1 values less than (10),
partition p2 values less than (maxvalue));

--error 1526
insert /*+enable_parallel_dml parallel(2)*/ into tt1 partition(p1) select c1 from tt2;

drop table tt1;

##single partition, not single subpartition
create table tt1(c1 int, c2 int)
partition by range(c1) subpartition by range(c2)
(partition p0 values less than (0)(subpartition p0sp0 values less than (0), subpartition p0sp1 values less than (maxvalue)),
partition p1 values less than (maxvalue)(subpartition p1sp0 values less than (0), subpartition p1sp1 values less than (maxvalue)));

--error 1526
insert /*+enable_parallel_dml parallel(2)*/ into tt1 partition (p1) select c1,c1 from tt2;

##not single partition, single subpartition
--error 1526
insert /*+enable_parallel_dml parallel(2)*/ into tt1 partition(p1sp1,p0sp1) select c1,c1 from tt2;

drop table tt1;
drop table tt2;