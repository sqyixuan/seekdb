--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

SELECT table1 . col_varchar_20_key AS field1,
       table2 . col_int_key AS field2,
       table1 . `col_varchar` AS field3,
       table1 . `col_int_key` AS field4
FROM ((SELECT SUBQUERY1_t1 . * FROM (D AS SUBQUERY1_t1 INNER JOIN BB AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_10`))) AS table1
RIGHT OUTER JOIN BB AS table2 ON (table2 . `pk` = table1 . `pk`))
WHERE (EXISTS (SELECT SUBQUERY2_t2 . `col_varchar` AS SUBQUERY2_field1
FROM (B AS SUBQUERY2_t1 INNER JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_key`))
WHERE SUBQUERY2_t2 . `col_varchar_20_key` != table1 . `col_varchar_key`OR SUBQUERY2_t1 . `col_varchar_10` < 'm' ))
AND (table1 . `col_int_key` IN (239, 232) OR table1 . `col_varchar_key` >= 'm') OR table1 . `col_varchar_10` IS NULL
ORDER BY 1, field1, field2, field3, field4;


SELECT /*+no_rewrite*/table1 . col_varchar_20_key AS field1,
       table2 . col_int_key AS field2,
       table1 . `col_varchar` AS field3,
       table1 . `col_int_key` AS field4
FROM ((SELECT SUBQUERY1_t1 . * FROM (D AS SUBQUERY1_t1 INNER JOIN BB AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `col_varchar_key` = SUBQUERY1_t1 . `col_varchar_10`))) AS table1
RIGHT OUTER JOIN BB AS table2 ON (table2 . `pk` = table1 . `pk`))
WHERE (EXISTS (SELECT SUBQUERY2_t2 . `col_varchar` AS SUBQUERY2_field1
FROM (B AS SUBQUERY2_t1 INNER JOIN CC AS SUBQUERY2_t2 ON (SUBQUERY2_t2 . `col_varchar_key` = SUBQUERY2_t1 . `col_varchar_key`))
WHERE SUBQUERY2_t2 . `col_varchar_20_key` != table1 . `col_varchar_key`OR SUBQUERY2_t1 . `col_varchar_10` < 'm' ))
AND (table1 . `col_int_key` IN (239, 232) OR table1 . `col_varchar_key` >= 'm') OR table1 . `col_varchar_10` IS NULL
ORDER BY 1, field1, field2, field3, field4;

drop table `b`, `bb`, `cc`, `d`;