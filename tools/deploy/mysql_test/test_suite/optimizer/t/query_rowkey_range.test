drop table t1;
create table t1(a varchar(10), b int, primary key(a, b)) partition by hash(b) partitions 5;

insert into t1 values('1', 1);
insert into t1 values('10', 10);
insert into t1 values('100', 100);
insert into t1 values('1000', 1000);
insert into t1 values('10000', 10000);

select * from t1 where a like '1%';

drop table t1;

create table t1(a int primary key, b int);
explain extended_noaddr select * from t1 where a > 1 or '1' like '11';
explain extended_noaddr select * from t1 where a > 1 and '1' like '11';
explain extended_noaddr select * from t1 where a > 1 or '1' like '11' escape '1';
explain extended_noaddr select * from t1 where a > 1 or 1 like 1;
explain extended_noaddr select * from t1 where a > 1 or 1 like 2;
explain extended_noaddr select * from t1 where a > 1 or 1 like 1.0;
explain extended_noaddr select * from t1 where a > 1 or 1.0 like 1;
explain extended_noaddr select * from t1 where (a > 1 and 1.222 like 1.2220) or false;
explain extended_noaddr select * from t1 where a > 1 or 1 like 11 escape 1;
drop table t1;

set @old_plan_cache_var:=@@ob_enable_plan_cache;
set ob_enable_plan_cache=OFF;
create table t1 (f1 varchar(4), f2 varchar(64), unique key k1 (f1,f2));
insert into t1 values ( 'test',md5('test')), ('test', md5('TEST'));
explain extended_noaddr select * from t1 where f1='test' and (f2= md5("test") or f2= md5("TEST"));
select * from t1 where f1='test' and (f2= md5("test") or f2= md5("TEST"));
drop table t1;

CREATE TABLE t1 (   t1ID int NOT NULL ,   art binary(1) NOT NULL default '',   KNR char(5) NOT NULL default '',   RECHNR char(6) NOT NULL default '',   POSNR char(2) NOT NULL default '',   ARTNR char(10) NOT NULL default '',   TEX char(70) NOT NULL default '',   PRIMARY KEY  (t1ID) );
INSERT INTO t1 (t1ID,art) VALUES  (0,'j'),  (1,'J'),  (2,'J'),  (3,'j'),  (4,'J'),  (5,'J'),  (6,'j'),  (7,'J'),  (8,'J'),  (9,'j'),  (10,'J'),  (11,'J'),  (12,'j'),  (13,'J'),  (14,'J'),  (15,'j'),  (16,'J'),  (17,'J'),  (18,'j'),  (19,'J'),  (20,'J'),  (21,'j'),  (22,'J'),  (23,'J'),  (24,'j'),  (25,'j');
select count(*) from t1;
select count(*) from t1 where art='j';
select count(*) from t1 where art='J';
explain select count(*) from t1 where art='j' or art='J';
select count(*) from t1 where art='j' or art='J';
drop table t1;

create table t1(a int, b int, c varchar(20), primary key(a,b));
explain extended_noaddr select * from t1 where a = 1 and b = 1 and c = "123";
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,"12"));
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,"12"),(3,4,"33"),(5,5,"3"));
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,"12"))  and a = 1;
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) and c > "123"; 
explain extended_noaddr select * from t1 where a = 1 and b = 1 or a = 2 and b = 2;
explain extended_noaddr select * from t1 where a in (1,2,3) and b = 2;
explain extended_noaddr select * from t1 where (a,c) in ((1,2)) and b = 2;
explain extended_noaddr select * from t1 where a in (1,2,3) or (a,b) in ((4,5),(5,6)) and c > "123";
explain extended_noaddr select * from t1 where a > 1 and (a,b) in ((2,2));
explain extended_noaddr select * from t1 where a > 1 and b > 1 and (a,b) in ((0,0));
explain extended_noaddr select * from t1 where a > 1 and b in (1,2,3);
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) or a = 10;
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) or b = 10;
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) or c > "123";
drop table t1;

create table t1 (a int, b int, c varchar(20), d decimal(10,5), primary key(a,b,c));
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,"3")) and d >100;
explain extended_noaddr select * from t1 where (a,b,c,d) in ((1,2,3,4));
explain extended_noaddr select * from t1 where (a,b,c,d) in ((1,2,"3",4),(2,3,"4",5));
explain extended_noaddr select * from t1 where a in (1,2,3) or (a,b) in ((1,2),(2,3)) or (a,b,c) in ((1,2,3),(2,3,4));
explain extended_noaddr select * from t1 where a in (1,2,3) or (a,b) in ((4,5),(5,6)) or (a,b,c) in ((7,8,9));
explain extended_noaddr select * from t1 where (b,c) in ((2,3),(3,4));
explain extended_noaddr select * from t1 where (b = 1 and c = 1) or (a = 1 and b = 1);
explain extended_noaddr select * from t1 where (a,c) in ((1,1),(2,2)) and d = 10;
explain extended_noaddr select * from t1 where (a,c) in ((1,1),(2,2)) and b = 3;
explain extended_noaddr select * from t1 where b > 1 and c > 1 and d > 1 or (a,b) in ((3,3));
drop table t1;

create table t1 (a int, b int, c int, d int, primary key(a,b,c));
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,3)) and d > 100;
explain extended_noaddr select * from t1 where (a,b,c,d) in ((1,2,3,4),(2,3,4,5));
explain extended_noaddr select * from t1 where a in (1,2,3) or (a,b) in ((1,2),(2,3)) or (a,b,c) in ((1,2,3),(2,3,4));
explain extended_noaddr select * from t1 where a in (1,2,3) or (a,b) in ((4,5),(5,6)) or (a,b,c) in ((7,8,9));
drop table t1;
set ob_enable_plan_cache = ON;
create table t1(a bigint, b bigint, c bigint, primary key(a,b));
insert into t1 values(1,1,1);
select * from t1 where a = 1 or (a=1 and b=1);
explain extended_noaddr select * from t1 where (a,b,c) in ((1,2,3),(2,3,4));
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3));
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) or (a = 1 and b = 2);
explain extended_noaddr select * from t1 where (a,b) in ((1,2),(2,3)) or (a,b,c) in ((2,3,4));
drop table t1;

create table t1(a bigint, b bigint, c bigint, primary key(a,b,c));
explain extended_noaddr select * from t1 where a=1 and c in(1,2,3) and (b = 1 or b = 2);
explain extended_noaddr select * from t1 where a=1 and c in(1,2,3);
explain extended_noaddr select * from t1 where a=1 and (b,c) in((1,2),(3,4));
explain extended_noaddr select * from t1 where (a,b,c) in((1,1,2),(2,3,4)) and a = 1;
explain extended_noaddr select * from t1 where (a,b,c) in((1,1,2),(2,3,4));
explain extended_noaddr select * from t1 where a = 1 and b in(1,1,2) and c = 1;
drop table t1;

set ob_enable_plan_cache=@old_plan_cache_var;
