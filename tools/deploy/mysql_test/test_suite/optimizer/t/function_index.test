# function index
--disable_warnings
--result_format 4
--explain_protocol 3
--enable_sorted_result

--disable_warnings
drop table if exists t1;
--disable_warnings
create table t1(c1 int, c2 int as (c1+1));
create index i1 on t1(c2);
select /*+index(t1 i1)*/ c2 from t1 where c1+1 > 1;
select * from t1 where (c1+1, c1+1) in ((2, 2));
drop table t1;

create table t1(c1 int, c2 varchar(10), c3 int as(c1+1), key idx1(c3), KEY idx2(c2(5)));
select /*+index(t1 idx1)*/ c2 from t1 where c1+1 > 1;
select /*+index(t1 idx1)*/ * from t1 where (c1+1, c1+1) in ((2, 2));
select /*+index(t1 idx1)*/ * from t1 where (c1+1, c1+1) in ((3, 5));
select  /*+index(t1 idx2)*/ * from t1 where c2='abc';
select  /*+index(t1 idx2)*/ * from t1 where c2='abc' and c2='cba';
select * from t1 where c2='abcdedfg';
select * from t1 where c2='abcdedfg' and c1+1=1;
select /*+index(t1 idx1)*/* from t1 where c2='abcdedfg' and c1+1=1; 
select /*+index(t1 idx2)*/* from t1 where c2='abcdedfg' and c1+1=1; 
select /*+index(t1 idx2)*/ * from t1 where c2=123;
select /*+index(t1 idx2)*/ * from t1 where c1+1 ='123';
select /*+index(t1 idx2)*/ * from t1 where cast(c2 as unsigned)=123;
select /*+index(t1 idx2)*/ * from t1 where cast(c1 as char)='123';
select /*+index(t1 idx1)*/ c2 from t1 where (c1+1, c1+1) in ((c2 , 5));

drop table t1;
create table t1(c1 int, c2 varchar(10), c3 int as(c1+1), key idx1(c3, c2(5)));
select /*+index(t1 idx1)*/ c2 from t1 where c1+1 > 1;
select /*+index(t1 idx1)*/ c2 from t1 where c1+1 > 1 and c2='abcdedfg';
select /*+index(t1 idx1)*/ c2 from t1 where c1+1 = 1 and c2='abcdedfg';
select /*+index(t1 idx1)*/ c2 from t1 where c1+1 = 1 and c2>'abcdedfg';


drop table t1;
create table t1(
c1 int, 
c2 double,
c3 char(10),
c4 varchar(10),
c7 double as (c1+0.1),
c8 int as (round(c2)),
c9 varchar(20) as (cast(c3 as signed)),  
c10 date as (cast(c4 as date)),
key i1 (c7),
key i2 (c8),
key i3 (c3(3)),
key i4 (c4(4)),
key i9 (c9),
key i10 (c10),
key i5 (c7, c8, c3)
);

select /*+index(t1 i2)*/ 1 from t1 where c8=1;
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=1;
select /*+index(t1 i2)*/ c8 from t1 where c8=1;
select /*+index(t1 i2)*/ c2 from t1 where c8=1;
select /*+index(t1 i2)*/ c2 from t1 where round(c2)=1;
select /*+index(t1 i2)*/ c8 from t1 where round(c2)=1;
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=cast(1 as char);
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=cast(1 as decimal);
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=cast(1 as signed);
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=cast(1 as unsigned);
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=cast(1 as date);
select /*+index(t1 i2)*/ 1 from t1 where round(c2)=1 and c1+0.1 = 1;
select /*+index(t1 i1)*/ 1 from t1 where round(c2)=1 and c1+0.1 = 1;
select /*+index(t1 i3)*/ 1 from t1 where substr(c3,1,3) ='abc';

select /*+index(t1 i3)*/ 1 from t1 where c3='abadasdas';
select /*+index(t1 i3)*/ 1 from t1 where c3=123;
select /*+index(t1 i3)*/ 1 from t1 where c3=cast(123 as char);
select /*+index(t1 i4)*/ 1 from t1 where c4='abadasdas';
select /*+index(t1 i4)*/ 1 from t1 where c4=123;

select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as signed)=1;
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as signed)=1.1;
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as unsigned)=1.1;
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as unsigned)=-1;
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as unsigned)=cast(-1 as unsigned);
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as signed)=cast(-1 as unsigned);
select /*+index(t1 i9)*/ c1 from t1 where cast(c3 as signed)=cast(-1 as decimal);
select /*+index(t1 i9)*/ c1 from t1 where c9=1.1;

select /*+index(t1 i10)*/ 1 from t1 where cast(c4 as date)='2022-09';
select /*+index(t1 i10)*/ 1 from t1 where cast(c4 as date)='2022';
select /*+index(t1 i10)*/ 1 from t1 where cast(c4 as date)=cast('2022' as date);
select /*+index(t1 i10)*/ 1 from t1 where cast(c4 as date)=cast('2022-09' as date);
select /*+index(t1 i10)*/ 1 from t1 where cast(c4 as date)=cast('2022-09-01' as date);

select /*+index(t1 i5)*/ 1 from t1 where round(c2)=1 and c1+0.1 = 2 and c3='abcdedfg';
select /*+index(t1 i5)*/ 1 from t1 where round(c2)=1 and c1+0.1 = 2;
select /*+index(t1 i5)*/ 1 from t1 where round(c2)=1 and c3='abcdedfg';
select /*+index(t1 i5)*/ 1 from t1 where c1+0.1 = 2 and c3='abcdedfg';

select 1 from t1 a , t1 b where round(b.c2)=a.c2 and a.c1+0.1=b.c1;
select 1 from t1 a , t1 b where round(a.c2)=b.c2 and a.c1+0.1=b.c1 and a.c3='abcdedfg';
select 1 from t1 a , t1 b where round(a.c2)=b.c1 and a.c1+0.1=b.c2 and a.c3='abcdedfg';
select 1 from t1 a , t1 b where round(a.c2)=b.c2 and a.c3='abcdedfg';
select /*+use_nl(a b)*/ 1 from t1 a, t1 b where a.c3=b.c3;
select /*+use_nl(a b)*/ 1 from t1 a , t1 b where a.c1+0.1=b.c1+0.1;
select /*+use_nl(a b)*/ 1 from t1 a , t1 b where a.c3 = b.c3 and a.c1+0.1 = b.c1+0.1;

select * from t1 a where (select /*+no_rewrite +index(b i1)*/ max(1)  from t1 b where b.c1+0.1=a.c2);
select * from t1 a where (select /*+no_rewrite +index(b i2)*/ max(1)  from t1 b where round(b.c2)=a.c1);
select * from t1 a where (select /*+no_rewrite +index(b i2)*/ max(1)  from t1 b where round(b.c2)=a.c2);
select * from t1 a where (select /*+no_rewrite +index(b i2)*/ max(1)  from t1 b where round(b.c2)=3);

drop table t1;
create table t1 (c1 int, c2 decimal as (cast(c1 as decimal)), key idx(c2));
select /*+index(t1 idx)*/ * from t1 where c1=1.5;

--disable_warnings
drop table if exists test_json;
--enable_warnings

CREATE TABLE `test_json` (
  `json_data` json DEFAULT NULL,
  `v_id` int(11) GENERATED ALWAYS AS (json_extract(`json_data`,'$.id')) VIRTUAL,
  KEY `idx_id` (`v_id`)
);

select /*+index(test_json idx_id)*/ * from test_json where v_id = 1;
select /*+index(test_json idx_id)*/ * from test_json where v_id = 1;
select /*+index(test_json idx_id)*/ * from test_json where cast(json_data->"$.id" as signed) = 1;
select /*+index(test_json idx_id)*/ * from test_json where cast(json_data->"$.id" as decimal) = 1;

#random_test function index
drop table t1;
create table t1 (
  c1 int, 
  c2 double,
  c3 double as(c1+c2),
  key idx1(c3));


select /*+index(t1 idx1)*/ * from t1 where c1+c2=25.1;
select /*+no_index(t1 idx1)*/ * from t1 where c3=25.1;