--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description:
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
--disable_result_log
create table t1 (pk int primary key, c1 int, c2 int, c3 int) partition by hash(pk);
create index idx_t1 on t1 (c1,c2) global;
create table t2 (pk int primary key, c1 int, c2 int, c3 int);
--disable_query_log
select count(*) from t1;
select count(*) from t2;
--enable_result_log
--enable_query_log
--result_format 4
--explain_protocol 2
SELECT * FROM t1,t2 WHERE t1.pk = t2.pk and t1.c1 = 100 AND t1.c2 < 100;
drop table t1,t2;
