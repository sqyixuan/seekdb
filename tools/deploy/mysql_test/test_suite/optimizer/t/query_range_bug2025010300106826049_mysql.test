# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
  company_name_digest varchar(128),
  STOCK_NAME varchar(128),
  primary key(company_name_digest, STOCK_NAME)
);

--result_format 4
--explain_protocol 2
select 
  /*+ query_timeout(500000) */
  STOCK_NAME, 
  COMPANY_NAME_DIGEST 
from 
  t1 
where 
   (
    company_name_digest = '634847b7f02b03610990ae2a187be794'
