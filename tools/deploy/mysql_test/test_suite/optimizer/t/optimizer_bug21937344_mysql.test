--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
# tags: optimizer
#description: 

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
create table t2(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
--disable_query_log
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(8,8,8),(9,9,9),(10,10,10);
insert into t2 values (1,1,1),(2,2,2),(6,6,6),(7,7,7),(8,8,8);
set _GROUPBY_NOPUSHDOWN_CUT_RATIO = 1;
--enable_query_log

--result_format 4
--explain_protocol 2
select /*+parallel(2)*/ b, sum(a) from t1 group by b union select b, sum(a) from t2 group by b order by 1;
select /*+parallel(2)*/ b, count(*) from t1 group by b union select b, count(*) from t2 group by b order by 1;
select /*+parallel(2)*/ b, min(a) from t1 group by b union select b, min(a) from t2 group by b order by 1;
select /*+parallel(2)*/ b, max(a) from t1 group by b union select b, max(a) from t2 group by b order by 1;
select /*+parallel(2)*/ b, avg(a) from t1 group by b union select b, avg(a) from t2 group by b order by 1;
