#tag: optimizer,cross_validation

--disable_warnings
drop table if exists bug_22957926_t_1, bug_22957926_t_2;
--enable_warnings

create table bug_22957926_t_1(a int, b int, c datetime, primary key(a)) partition by hash(a) partitions 3;
create table bug_22957926_t_2(a int, b int, c datetime, primary key(a)) partition by hash(a) partitions 5;

--disable_query_log
insert into bug_22957926_t_1 values(1, 1, 20161101),(2, 2, 20161102),(3, 3, 20161103),(4, 4, 20161104), (5, 5, 20161105),(6, 6, 20161106);
insert into bug_22957926_t_2 values(9, 9, 20161109);
--enable_query_log

--explain_protocol 2
select /*+leading(A B) */ A.a,CASE B.a not in (select /*+no_use_das(A) */ A.a FROM bug_22957926_t_2 A WHERE A.a = B.a) WHEN 0 then B.a else B.a end a 
FROM bug_22957926_t_1 A, bug_22957926_t_2 B order by A.a;
select /*+leading(A B) */ A.a,CASE B.a not in (select /*+no_use_das(A) */ A.a FROM bug_22957926_t_2 A WHERE A.a = B.a) WHEN 0 then B.a else B.a end a 
FROM bug_22957926_t_1 A, bug_22957926_t_2 B order by A.a,2;

--disable_warnings
drop table if exists bug_22957926_t_1, bug_22957926_t_2;
--enable_warnings
