# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists bmsql_config; 
drop table if exists bmsql_customer;   
drop table if exists bmsql_district;   
drop table if exists bmsql_history;    
drop table if exists bmsql_item;       
drop table if exists bmsql_new_order;  
drop table if exists bmsql_oorder;     
drop table if exists bmsql_order_line; 
drop table if exists bmsql_stock;      
drop table if exists bmsql_warehouse;  
drop table if exists customer;         
drop table if exists lineitem;         
drop table if exists nation;           
drop table if exists orders;           
drop table if exists part;             
drop table if exists partsupp;         
drop table if exists region;           
drop table if exists supplier;         
--enable_warnings

create table bmsql_config (
  cfg_name    varchar(30) primary key,
  cfg_value   varchar(50)
) ;

create table bmsql_warehouse (
  w_id        integer   not null,
  w_ytd       decimal(12,2),
  w_tax       decimal(4,4),
  w_name      varchar(10),
  w_street_1  varchar(20),
  w_street_2  varchar(20),
  w_city      varchar(20),
  w_state     char(2),
  w_zip       char(9),
  primary key(w_id)
)  partition by hash(w_id) partitions 1;

create table bmsql_district (
  d_w_id       integer       not null,
  d_id         integer       not null,
  d_ytd        decimal(12,2),
  d_tax        decimal(4,4),
  d_next_o_id  integer,
  d_name       varchar(10),
  d_street_1   varchar(20),
  d_street_2   varchar(20),
  d_city       varchar(20),
  d_state      char(2),
  d_zip        char(9),
  PRIMARY KEY (d_w_id, d_id)
)  partition by hash(d_w_id) partitions 1;

create table bmsql_customer (
  c_w_id         integer        not null,
  c_d_id         integer        not null,
  c_id           integer        not null,
  c_discount     decimal(4,4),
  c_credit       char(2),
  c_last         varchar(16),
  c_first        varchar(16),
  c_credit_lim   decimal(12,2),
  c_balance      decimal(12,2),
  c_ytd_payment  decimal(12,2),
  c_payment_cnt  integer,
  c_delivery_cnt integer,
  c_street_1     varchar(20),
  c_street_2     varchar(20),
  c_city         varchar(20),
  c_state        char(2),
  c_zip          char(9),
  c_phone        char(16),
  c_since        timestamp,
  c_middle       char(2),
  c_data         varchar(500),
  PRIMARY KEY (c_w_id, c_d_id, c_id)
)  partition by hash(c_w_id) partitions 1;

create table bmsql_history (
  hist_id  integer auto_increment,
  h_c_id   integer,
  h_c_d_id integer,
  h_c_w_id integer,
  h_d_id   integer,
  h_w_id   integer,
  h_date   timestamp,
  h_amount decimal(6,2),
  h_data   varchar(24)
)  partition by hash(h_w_id) partitions 1;

create table bmsql_new_order (
  no_w_id  integer   not null ,
  no_d_id  integer   not null,
  no_o_id  integer   not null,
  PRIMARY KEY (no_w_id, no_d_id, no_o_id)
) TABLE_MODE='QUEUING'  partition by hash(no_w_id) partitions 1;

create table bmsql_oorder (
  o_w_id       integer      not null,
  o_d_id       integer      not null,
  o_id         integer      not null,
  o_c_id       integer,
  o_carrier_id integer,
  o_ol_cnt     integer,
  o_all_local  integer,
  o_entry_d    timestamp,
  PRIMARY KEY (o_w_id, o_d_id, o_id)
)  partition by hash(o_w_id) partitions 1;

create table bmsql_order_line (
  ol_w_id         integer   not null,
  ol_d_id         integer   not null,
  ol_o_id         integer   not null,
  ol_number       integer   not null,
  ol_i_id         integer   not null,
  ol_delivery_d   timestamp,
  ol_amount       decimal(6,2),
  ol_supply_w_id  integer,
  ol_quantity     integer,
  ol_dist_info    char(24),
  PRIMARY KEY (ol_w_id, ol_d_id, ol_o_id, ol_number)
)  partition by hash(ol_w_id) partitions 1;

create table bmsql_item (
  i_id     integer      not null,
  i_name   varchar(24),
  i_price  decimal(5,2),
  i_data   varchar(50),
  i_im_id  integer,
  PRIMARY KEY (i_id)
) ;

create table bmsql_stock (
  s_w_id       integer       not null,
  s_i_id       integer       not null,
  s_quantity   integer,
  s_ytd        integer,
  s_order_cnt  integer,
  s_remote_cnt integer,
  s_data       varchar(50),
  s_dist_01    char(24),
  s_dist_02    char(24),
  s_dist_03    char(24),
  s_dist_04    char(24),
  s_dist_05    char(24),
  s_dist_06    char(24),
  s_dist_07    char(24),
  s_dist_08    char(24),
  s_dist_09    char(24),
  s_dist_10    char(24),
  PRIMARY KEY (s_w_id, s_i_id)
)  partition by hash(s_w_id) partitions 1;

create table lineitem(
    l_orderkey           bigint(20) NOT NULL ,
    l_partkey            bigint(20) NOT NULL ,
    l_suppkey            bigint(20) NOT NULL ,
    l_linenumber         bigint(20) NOT NULL ,
    l_quantity           bigint(20) NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) DEFAULT NULL,
    l_linestatus         char(1) DEFAULT NULL,
    l_shipdate           date NOT NULL,
    l_commitdate         date DEFAULT NULL,
    l_receiptdate        date DEFAULT NULL,
    l_shipinstruct       char(25) DEFAULT NULL,
    l_shipmode           char(10) DEFAULT NULL,
    l_comment            varchar(44) DEFAULT NULL,
    primary key(L_ORDERKEY, L_LINENUMBER))
    
    partition by hash(l_orderkey) partitions 1;


create table orders(
    o_orderkey           bigint(20) NOT NULL ,
    o_custkey            bigint(20) NOT NULL ,
    o_orderstatus        char(1) DEFAULT NULL,
    o_totalprice         decimal(10,2) DEFAULT NULL,
    o_orderdate          date NOT NULL,
    o_orderpriority      char(15) DEFAULT NULL,
    o_clerk              char(15) DEFAULT NULL,
    o_shippriority       bigint(20) DEFAULT NULL,
    o_comment            varchar(79) DEFAULT NULL,
    primary key(o_orderkey,o_orderdate,o_custkey))
    
    partition by hash (o_orderkey) partitions 1;

create table partsupp(
    ps_partkey           bigint(20) NOT NULL ,
    ps_suppkey           bigint(20) NOT NULL ,
    ps_availqty          bigint(20) DEFAULT NULL,
    ps_supplycost        decimal(10,2) DEFAULT NULL,
    ps_comment           varchar(199) DEFAULT NULL,
    primary key (PS_PARTKEY, PS_SUPPKEY))
    
    partition by hash(ps_partkey) partitions 1;

create table part(
    p_partkey            bigint(20) NOT NULL ,
    p_name               varchar(55) DEFAULT NULL,
    p_mfgr               char(25) DEFAULT NULL,
    p_brand              char(10) DEFAULT NULL,
    p_type               varchar(25) DEFAULT NULL,
    p_size               bigint(20) DEFAULT NULL,
    p_container          char(10) DEFAULT NULL,
    p_retailprice        decimal(10,2) DEFAULT NULL,
    p_comment            varchar(23) DEFAULT NULL,
    primary key (P_PARTKEY))
    
    partition by hash(p_partkey) partitions 1;


create table customer(
    c_custkey            bigint(20) NOT NULL ,
    c_name               varchar(25) DEFAULT NULL,
    c_address            varchar(40) DEFAULT NULL,
    c_nationkey          bigint(20) DEFAULT NULL,
    c_phone              char(15) DEFAULT NULL,
    c_acctbal            decimal(10,2) DEFAULT NULL,
    c_mktsegment         char(10) DEFAULT NULL,
    c_comment            varchar(117) DEFAULT NULL,
    PRIMARY KEY (c_custkey))
    
    partition by hash(c_custkey) partitions 1;

create table supplier(
    s_suppkey            bigint(20) NOT NULL ,
    s_name               char(25) DEFAULT NULL,
    s_address            varchar(40) DEFAULT NULL,
    s_nationkey          bigint(20) DEFAULT NULL,
    s_phone              char(15) DEFAULT NULL,
    s_acctbal            bigint(20) DEFAULT NULL,
    s_comment            varchar(101) DEFAULT NULL,
    primary key (S_SUPPKEY))
    
    partition by hash(s_suppkey) partitions 1;

create table nation(
    n_nationkey          bigint(20) NOT NULL ,
    n_name               char(25) DEFAULT NULL,
    n_regionkey          bigint(20) DEFAULT NULL,
    n_comment            varchar(152) DEFAULT NULL,
    primary key (N_NATIONKEY));

create table region(
    r_regionkey          bigint(20) NOT NULL,
    r_name               char(25) DEFAULT NULL,
    r_comment            varchar(152) DEFAULT NULL,
    primary key (R_REGIONKEY));

--result_format 4
explain WITH  jennifer_0 AS (select   90 as c0,  6 as c1 from  (select   ref_0.l_commitdate as c0,  25 as c1,  cast(nullif(43, 64) as DECIMAL) as c2 from  lineitem as ref_0 where EXISTS ( select   96 as c0,  97 as c1,  63 as c2,  84 as c3,  18 as c4,  32 as c5,  36 as c6,  86 as c7,  59 as c8,  31 as c9 from  bmsql_config as ref_1 where (EXISTS ( select   31 as c0,  87 as c1,  30 as c2,  88 as c3,  38 as c4,  100 as c5,  86 as c6,  18 as c7 from  bmsql_config as ref_2 where EXISTS ( select   61 as c0 from  partsupp as ref_3 where 98 not  in ( 48,  92,  67)) limit 74))  or ((66 MOD 10)  or (EXISTS ( select   49 as c0,  9 as c1,  6 as c2,  87 as c3,  65 as c4,  12 as c5,  24 as c6,  82 as c7,  29 as c8,  87 as c9,  57 as c10,  35 as c11,  34 as c12 from  supplier as ref_4 where EXISTS ( select   61 as c0,  100 as c1,  84 as c2,  72 as c3 from  lineitem as ref_5 where EXISTS ( select   39 as c0,  81 as c1,  45 as c2,  62 as c3,  49 as c4,  2 as c5,  1 as c6,  4 as c7,  10 as c8,  27 as c9,  13 as c10,  21 as c11,  86 as c12 from  customer as ref_6 where 42 + 29) limit 23)))) limit 86) limit 99) as subq_0 where 10 < subq_0.c1),   jennifer_1 AS (select   cast(nullif(27, 71) as DECIMAL) as c0,  cast(ifnull(ref_7.no_d_id, ref_7.no_d_id) as DECIMAL) as c1,  84 as c2,   std( cast(cast(null as DECIMAL(10, 2)) as DECIMAL(10, 2))) over (partition by ref_7.no_o_id order by ref_7.no_o_id) as c3,  ref_7.no_w_id as c4,  ref_7.no_w_id as c5,  ref_7.no_d_id as c6,  cast(coalesce(ref_7.no_w_id, 50) as DECIMAL) as c7,   LEAD( cast(cast(null as CHAR) as CHAR)) over (partition by ref_7.no_o_id order by ref_7.no_d_id) as c8 from  bmsql_new_order as ref_7 where ((EXISTS ( select   78 as c0,  92 as c1,  65 as c2 from  bmsql_district as ref_8 where EXISTS ( select distinct  85 as c0,  41 as c1,  13 as c2 from  bmsql_config as ref_9 where 77 <=> 63) limit 150))  or (EXISTS ( select   40 as c0,  9 as c1,  20 as c2,  83 as c3,  60 as c4 from  orders as ref_10 where EXISTS ( select   41 as c0,  53 as c1,  80 as c2,  82 as c3,  58 as c4,  66 as c5,  58 as c6,  60 as c7 from  bmsql_district as ref_11 where (97 >> 7)  and (43 not  in ( 41)) limit 25))))  or ((EXISTS ( select   7 as c0,  50 as c1,  22 as c2,  84 as c3,  8 as c4,  70 as c5,  17 as c6,  81 as c7,  98 as c8,  33 as c9,  90 as c10,  15 as c11,  23 as c12,  76 as c13,  30 as c14,  28 as c15,  80 as c16,  66 as c17,  45 as c18,  71 as c19 from  bmsql_config as ref_12 where EXISTS ( select   38 as c0 from  bmsql_oorder as ref_13 where 97 = 98)))  or (EXISTS ( select   82 as c0,  53 as c1,  14 as c2,  65 as c3 from  bmsql_customer as ref_14 where 90 = 47 limit 142))) limit 137) select   65 as c0,  ref_15.c0 as c1,  ref_15.c0 as c2,   max( cast(cast(null as CHAR) as CHAR)) over (partition by ref_15.c1 order by ref_15.c0) as c3,  ref_15.c0 as c4,  if( cast(null as CHAR) in ( cast(null as CHAR),  cast(ifnull(cast(null as CHAR), cast(null as CHAR)) as CHAR),  cast(null as CHAR),  cast(null as CHAR),  cast(null as CHAR)) , 68 , if( EXISTS ( select   42 as c0,  72 as c1,  67 as c2,  62 as c3,  39 as c4,  70 as c5,  87 as c6,  10 as c7,  8 as c8,  70 as c9,  98 as c10 from  jennifer_0 as ref_16 where EXISTS ( select   25 as c0,  21 as c1,  36 as c2,  8 as c3,  45 as c4 from  bmsql_order_line as ref_17 where EXISTS ( select   86 as c0,  21 as c1,  9 as c2,  9 as c3,  57 as c4,  98 as c5,  57 as c6,  11 as c7 from  region as ref_18 where EXISTS ( select   56 as c0,  25 as c1,  77 as c2,  13 as c3 from  lineitem as ref_19 where 1 limit 113) limit 98)) limit 141) , 26 , 90 )  )  as c5,  ref_15.c1 as c6,  ref_15.c0 as c7,  ref_15.c1 as c8,  25 as c9,  59 as c10 from  jennifer_0 as ref_15 where EXISTS ( select   ref_15.c0 as c0 from  nation as ref_20 where ref_20.n_regionkey < (select c_custkey from customer order by 1 limit 1 offset 6)  limit 133) limit 80 ;

WITH  jennifer_0 AS (select   90 as c0,  6 as c1 from  (select   ref_0.l_commitdate as c0,  25 as c1,  cast(nullif(43, 64) as DECIMAL) as c2 from  lineitem as ref_0 where EXISTS ( select   96 as c0,  97 as c1,  63 as c2,  84 as c3,  18 as c4,  32 as c5,  36 as c6,  86 as c7,  59 as c8,  31 as c9 from  bmsql_config as ref_1 where (EXISTS ( select   31 as c0,  87 as c1,  30 as c2,  88 as c3,  38 as c4,  100 as c5,  86 as c6,  18 as c7 from  bmsql_config as ref_2 where EXISTS ( select   61 as c0 from  partsupp as ref_3 where 98 not  in ( 48,  92,  67)) limit 74))  or ((66 MOD 10)  or (EXISTS ( select   49 as c0,  9 as c1,  6 as c2,  87 as c3,  65 as c4,  12 as c5,  24 as c6,  82 as c7,  29 as c8,  87 as c9,  57 as c10,  35 as c11,  34 as c12 from  supplier as ref_4 where EXISTS ( select   61 as c0,  100 as c1,  84 as c2,  72 as c3 from  lineitem as ref_5 where EXISTS ( select   39 as c0,  81 as c1,  45 as c2,  62 as c3,  49 as c4,  2 as c5,  1 as c6,  4 as c7,  10 as c8,  27 as c9,  13 as c10,  21 as c11,  86 as c12 from  customer as ref_6 where 42 + 29) limit 23)))) limit 86) limit 99) as subq_0 where 10 < subq_0.c1),   jennifer_1 AS (select   cast(nullif(27, 71) as DECIMAL) as c0,  cast(ifnull(ref_7.no_d_id, ref_7.no_d_id) as DECIMAL) as c1,  84 as c2,   std( cast(cast(null as DECIMAL(10, 2)) as DECIMAL(10, 2))) over (partition by ref_7.no_o_id order by ref_7.no_o_id) as c3,  ref_7.no_w_id as c4,  ref_7.no_w_id as c5,  ref_7.no_d_id as c6,  cast(coalesce(ref_7.no_w_id, 50) as DECIMAL) as c7,   LEAD( cast(cast(null as CHAR) as CHAR)) over (partition by ref_7.no_o_id order by ref_7.no_d_id) as c8 from  bmsql_new_order as ref_7 where ((EXISTS ( select   78 as c0,  92 as c1,  65 as c2 from  bmsql_district as ref_8 where EXISTS ( select distinct  85 as c0,  41 as c1,  13 as c2 from  bmsql_config as ref_9 where 77 <=> 63) limit 150))  or (EXISTS ( select   40 as c0,  9 as c1,  20 as c2,  83 as c3,  60 as c4 from  orders as ref_10 where EXISTS ( select   41 as c0,  53 as c1,  80 as c2,  82 as c3,  58 as c4,  66 as c5,  58 as c6,  60 as c7 from  bmsql_district as ref_11 where (97 >> 7)  and (43 not  in ( 41)) limit 25))))  or ((EXISTS ( select   7 as c0,  50 as c1,  22 as c2,  84 as c3,  8 as c4,  70 as c5,  17 as c6,  81 as c7,  98 as c8,  33 as c9,  90 as c10,  15 as c11,  23 as c12,  76 as c13,  30 as c14,  28 as c15,  80 as c16,  66 as c17,  45 as c18,  71 as c19 from  bmsql_config as ref_12 where EXISTS ( select   38 as c0 from  bmsql_oorder as ref_13 where 97 = 98)))  or (EXISTS ( select   82 as c0,  53 as c1,  14 as c2,  65 as c3 from  bmsql_customer as ref_14 where 90 = 47 limit 142))) limit 137) select   65 as c0,  ref_15.c0 as c1,  ref_15.c0 as c2,   max( cast(cast(null as CHAR) as CHAR)) over (partition by ref_15.c1 order by ref_15.c0) as c3,  ref_15.c0 as c4,  if( cast(null as CHAR) in ( cast(null as CHAR),  cast(ifnull(cast(null as CHAR), cast(null as CHAR)) as CHAR),  cast(null as CHAR),  cast(null as CHAR),  cast(null as CHAR)) , 68 , if( EXISTS ( select   42 as c0,  72 as c1,  67 as c2,  62 as c3,  39 as c4,  70 as c5,  87 as c6,  10 as c7,  8 as c8,  70 as c9,  98 as c10 from  jennifer_0 as ref_16 where EXISTS ( select   25 as c0,  21 as c1,  36 as c2,  8 as c3,  45 as c4 from  bmsql_order_line as ref_17 where EXISTS ( select   86 as c0,  21 as c1,  9 as c2,  9 as c3,  57 as c4,  98 as c5,  57 as c6,  11 as c7 from  region as ref_18 where EXISTS ( select   56 as c0,  25 as c1,  77 as c2,  13 as c3 from  lineitem as ref_19 where 1 limit 113) limit 98)) limit 141) , 26 , 90 )  )  as c5,  ref_15.c1 as c6,  ref_15.c0 as c7,  ref_15.c1 as c8,  25 as c9,  59 as c10 from  jennifer_0 as ref_15 where EXISTS ( select   ref_15.c0 as c0 from  nation as ref_20 where ref_20.n_regionkey < (select c_custkey from customer order by 1 limit 1 offset 6)  limit 133) limit 80 ;

drop table if exists bmsql_config; 
drop table if exists bmsql_customer;   
drop table if exists bmsql_district;   
drop table if exists bmsql_history;    
drop table if exists bmsql_item;       
drop table if exists bmsql_new_order;  
drop table if exists bmsql_oorder;     
drop table if exists bmsql_order_line; 
drop table if exists bmsql_stock;      
drop table if exists bmsql_warehouse;  
drop table if exists customer;         
drop table if exists lineitem;         
drop table if exists nation;           
drop table if exists orders;           
drop table if exists part;             
drop table if exists partsupp;         
drop table if exists region;           
drop table if exists supplier; 
