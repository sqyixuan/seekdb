# owner: dingjincheng.djc
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop procedure if exists proc1;
--enable_warnings


CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` TEXT DEFAULT NULL,
  PRIMARY KEY (`c1`),
  KEY `i1` (`c4`(128)) BLOCK_SIZE 16384 LOCAL
);

CREATE TABLE `t2` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` TEXT DEFAULT NULL,
  PRIMARY KEY (`c1`)
);

CREATE TABLE `t3` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` TEXT DEFAULT NULL,
  PRIMARY KEY (`c1`)
);

delimiter $$;
create procedure proc1(in args int)
begin
  declare i int;
  set i = 0;
  start transaction;
  while i < args do
    insert into t1(c1,c2,c3,c4) values(i, i, i, concat('C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_SLKJLDFLKJSKLDFJKLSDFJSL_DFJSKJKLSDJKLJSKDJFKLS_DJFSLLLLLLLLLLLLLLLLLLLLLLJJJJJJJJJJJJ_', i));
    set i = i+1;
	if i % 10000 = 0 then
	  commit;
	end if;
  end while;
  commit;
end $$
delimiter ;$$

call proc1(100000);
insert into t2 (c1, c2, c3, c4) select c1, c2, c3, c4 from t1;
insert into t3 (c1, c2, c3, c4) select c1, c2, c3, c4 from t1;

--result_format 4
select count(1) from t3 where c4 = 'C2_MKKHJHHS_XXXSDSDSDDSDSSJJJJDSHH_SLKJLDFLKJSKLDFJKLSDFJSL_DFJSKJKLSDJKLJSKDJFKLS_DJFSLLLLLLLLLLLLLLLLLLLLLLJJJJJJJJJJJJ_1';

call dbms_stats.gather_table_stats('TEST', 'T1');
call dbms_stats.gather_table_stats('TEST', 'T2');
call dbms_stats.gather_table_stats('TEST', 'T3');

select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE from oceanbase.DBA_TAB_COL_STATISTICS where table_name = 'T1';
select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE from oceanbase.DBA_TAB_COL_STATISTICS where table_name = 'T2';
select TABLE_NAME,COLUMN_NAME,NUM_DISTINCT,LOW_VALUE,HIGH_VALUE from oceanbase.DBA_TAB_COL_STATISTICS where table_name = 'T3';

drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop procedure if exists proc1;
