create table t6 (
    c1 BIGINT(127) auto_increment,
    c2 CHAR(152),
    c3 TIME,
    c4 YEAR(4),
    c5 BINARY(149),
    c6 VARBINARY(58),
    c7 TIMESTAMP(1) NOT NULL default 0,
    c8 INT(127),
    c9 TIME,
    c10 BIGINT(127),
    c11 INTEGER(127),
    c12 DECIMAL(64, 0),
    c13 BIGINT(127),
    c14 TIMESTAMP NOT NULL default 0,
    c15 VARCHAR(86),
    c16 DECIMAL(64, 23),
    c17 CHAR(152),
    c18 BIGINT(127),
    c19 DATETIME,
    c20 INT(127),
    c21 DECIMAL(64, 10),
    c22 CHAR(152),
    c23 BINARY(149),
    c24 BINARY(88),
    c25 DATE,
    c26 NUMERIC(64, 9),
    c27 NUMERIC(64, 7),
    c28 DATE,
    c29 TIMESTAMP(4) NOT NULL default 0,
    c30 INT(127),
    c31 DECIMAL(64, 4),
    c32 BIGINT(127),
    c33 VARCHAR(86),
    c34 DECIMAL(64, 20),
    c35 DATETIME,
    c36 VARBINARY(54),
    c37 CHAR(152),
    c38 DECIMAL(64, 0) generated always as (c18 + c11)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin;


explain basic
UPDATE /*+ ENABLE_PARALLEL_DML parallel(2) WIN_MAGIC */ t6 AS t6_1 SET t6_1.c4 = (SELECT MAX(t6_1.c4) FROM t6 AS t6_1);
