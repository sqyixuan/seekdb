# owner: sean.yyj
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);

--explain_protocol 2
--result_format 4


--echo # shared exprs in sort
select /*+no_rewrite*/ c1 from t1 order by c1+1;
select /*+no_rewrite*/ c1+1+2, c1+1+3 from t1 order by c1;

select /*+no_rewrite*/ c1+1 from t1 order by c1+1;
select /*+no_rewrite*/ c1+1+2 from t1 order by c1+1;
select /*+no_rewrite*/ c1+1 from t1 order by c1+1+2;
select /*+no_rewrite*/ c1+1+2 from t1 order by c1+1+3;

select /*+no_rewrite*/ c1+1 from t1 order by c1+1, c1+1+c3;
select /*+no_rewrite*/ c1+1+2 from t1 order by c1+1, c1+1+c3;
select /*+no_rewrite*/ c1+1 from t1 order by c1+1+2, c1+1+c3;
select /*+no_rewrite*/ c1+1+2 from t1 order by c1+1+3, c1+1+c3;

--echo # shared exprs in group by
select /*+no_rewrite*/ c1+1+2, c1+1+3,count(*) from t1 group by c1;

select /*+no_rewrite*/ c1+1, count(*) from t1 group by c1+1;
select /*+no_rewrite*/ c1+1+2, count(*) from t1 group by c1+1;
select /*+no_rewrite*/ c1+1, count(*) from t1 group by c1+1+2;
select /*+no_rewrite*/ c1+1+2, count(*) from t1 group by c1+1+3;

select /*+no_rewrite*/ c1+1, count(*) from t1 group by c1+1, c1+1+c3;
select /*+no_rewrite*/ c1+1+2, count(*) from t1 group by c1+1, c1+1+c3;
select /*+no_rewrite*/ count(*) from t1 group by c1+1+2, c1+1+c3;
select /*+no_rewrite*/ c1+1, count(*) from t1 group by c1+1+2, c1+1+c3;
select /*+no_rewrite*/ c1+1+2, count(*) from t1 group by c1+1+3, c1+1+c3;
select * from (select /*+merge*/ sum(c1) + 1 a from t1) v where v.a < 5 and v.a > 0;

--echo # shared exprs in sort and group
select /*+no_rewrite*/ count(*) from t1 group by c1+1 order by c1+1;
select /*+no_rewrite*/ count(*) from t1 group by c1+1 order by c1+1+2;

--echo # bad cases
select sum(b), sum(a*a) from (select c1+1 a, c1+2 b from t1) v;

drop table t1, t2;
