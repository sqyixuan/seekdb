# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, primary key(c1,c2,c3));


--result_format 4
--explain_protocol 2
select /*+no_rewrite*/ 1 from t1 where (1 = 1 and c3 = 1 or c3 = null) and c1 = 1;

DROP TABLE t1;