--disable_warnings
drop table if exists t_category;
--enable_warnings
CREATE TABLE
	t_category ( cat_id int(5) PRIMARY KEY ,
	name varchar(50) ,
	parent_cid DECIMAL(5),
	cat_level DECIMAL(5) ,
	product_count DECIMAL(5))
partition by range (cat_id) (partition p0 values less than (10),partition p1 values less than (30));


