--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
# link: 

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int);

--explain_protocol 2
--result_format 4
select /*+no_rewrite*/1 from t1 right join t2 on (EXISTS ( select/*+no_unnest*/ t2.c1 as c3 from t3 )) or (select 1 from dual);
select 1 from t1 right join t2 on (EXISTS ( select t2.c1 as c3 from t3 )) or (select 1 from dual);

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
