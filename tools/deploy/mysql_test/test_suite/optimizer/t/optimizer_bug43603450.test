# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t0,t1;
--enable_warnings

CREATE TABLE t0(c0 VARCHAR(500)   COMMENT 'asdf' ) PARTITION BY KEY (c0) partitions 11;
CREATE TABLE IF NOT EXISTS t1 LIKE t0;
CREATE INDEX i260 ON t0(c0(2)) ;
CREATE INDEX i250 USING BTREE ON t1(c0(3)) ;
CREATE INDEX i900 USING BTREE ON t1(c0(2)) ;

--explain_protocol 2
--result_format 4
SELECT /*+ NO_PRED_DEDUCE index(t0 i260) index(t1 i250) */ t1.c0 FROM t1, t0 WHERE (((-1.347339306E9) & (t0.c0)) IS FALSE) AND (t1.c0 = t0.c0) ;

drop table t0,t1;