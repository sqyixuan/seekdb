--result_format 4

explain with recursive cte as ( select t1.col_bigint_unique_index as num1, t1.col_decimal_20_0 as num2, t1.col_varchar_20_unique_index as var1, t1.col_varchar_20 as var2 from table10_key_pk_parts_10_int_not_null as t1 union all select /*+ no_rewrite leading((cte t2) t3) use_nl((cte t2) t3) */ cte.num1+1, cte.num2+1, cte.var1, cte.var2 from cte, table10_hash_pk_parts_10_int_not_null as t2, table10_hash_pk_parts_10_int_not_null as t3 where cte.num1 = t2.col_double_index and t3.col_double_unique_index < t2.col_double ) select /*+ USE_NL(@"SEL$3" "test"."t2"@"SEL$3") NO_USE_DAS(@"SEL$3" "t3"@"SEL$3") NO_USE_DAS(@"SEL$3" "t2"@"SEL$3") */ * from cte order by 1,2,3,4;

with recursive cte as ( select t1.col_bigint_unique_index as num1, t1.col_decimal_20_0 as num2, t1.col_varchar_20_unique_index as var1, t1.col_varchar_20 as var2 from table10_key_pk_parts_10_int_not_null as t1 union all select /*+ no_rewrite leading((cte t2) t3) use_nl((cte t2) t3) */ cte.num1+1, cte.num2+1, cte.var1, cte.var2 from cte, table10_hash_pk_parts_10_int_not_null as t2, table10_hash_pk_parts_10_int_not_null as t3 where cte.num1 = t2.col_double_index and t3.col_double_unique_index < t2.col_double ) select /*+ USE_NL(@"SEL$3" "test"."t2"@"SEL$3") NO_USE_DAS(@"SEL$3" "t3"@"SEL$3") NO_USE_DAS(@"SEL$3" "t2"@"SEL$3") */ * from cte order by 1,2,3,4;

explain with recursive cte as ( select t1.col_bigint_unique_index as num1, t1.col_decimal_20_0 as num2, t1.col_varchar_20_unique_index as var1, t1.col_varchar_20 as var2 from table10_key_pk_parts_10_int_not_null as t1 union all select /*+ no_rewrite leading((cte t2) t3) use_nl((cte t2) t3) */ cte.num1+1, cte.num2+1, cte.var1, cte.var2 from cte, table10_hash_pk_parts_10_int_not_null as t2, table10_hash_pk_parts_10_int_not_null as t3 where cte.num1 = t2.col_double_index and t3.col_double_unique_index < t2.col_double ) select /*+ USE_NL(@"SEL$3" "test"."t2"@"SEL$3") USE_DAS(@"SEL$3" "t3"@"SEL$3") USE_DAS(@"SEL$3" "t2"@"SEL$3") */ * from cte order by 1,2,3,4;

with recursive cte as ( select t1.col_bigint_unique_index as num1, t1.col_decimal_20_0 as num2, t1.col_varchar_20_unique_index as var1, t1.col_varchar_20 as var2 from table10_key_pk_parts_10_int_not_null as t1 union all select /*+ no_rewrite leading((cte t2) t3) use_nl((cte t2) t3) */ cte.num1+1, cte.num2+1, cte.var1, cte.var2 from cte, table10_hash_pk_parts_10_int_not_null as t2, table10_hash_pk_parts_10_int_not_null as t3 where cte.num1 = t2.col_double_index and t3.col_double_unique_index < t2.col_double ) select /*+ USE_NL(@"SEL$3" "test"."t2"@"SEL$3") USE_DAS(@"SEL$3" "t3"@"SEL$3") USE_DAS(@"SEL$3" "t2"@"SEL$3") */ * from cte order by 1,2,3,4;

explain with recursive cte(n) as (select 1 from dual union all select /*+ leading((cte v1) t3) use_nl(cte v1)*/ v1.pk from (select /*+no_merge*/ * from t2) v1, cte, (select /*+ no_merge */ * from t3) t3 where v1.pk = n and v1.pk = t3.pk) select * from cte;

explain with recursive   cte(n) as    (select 5 from dual     union all select n+1 from cte where n < 10 and  (select /*+ no_unnest */ sum(c2) from t3 where cte.n = t3.pk  ) > 0 and (select /*+ no_unnest */ sum(c2) from t4 where cte.n = t4.pk  ) > 0 ) select * from cte;
--sorted_result
with recursive   cte(n) as    (select 5 from dual     union all select n+1 from cte where n < 10 and  (select /*+ no_unnest */ sum(c2) from t3 where cte.n = t3.pk  ) > 0 and (select /*+ no_unnest */ sum(c2) from t4 where cte.n = t4.pk  ) > 0 ) select * from cte;

explain select /*+ no_simplify_subquery LEADING(@"SEL$0208448F" ("v"@"SEL$4" "cte"@"SEL$4")) */ * from t2 t3 where pk in (with recursive cte(n) as (select 1 from dual union all select n+1 from cte, (select /*+ no_merge*/ * from t2 where pk = t3.pk) v where n = pk and n < 10) select /*+ no_unnest */ * from cte);

select /*+ no_simplify_subquery LEADING(@"SEL$0208448F" ("v"@"SEL$4" "cte"@"SEL$4")) */ * from t2 t3 where pk in (with recursive cte(n) as (select 1 from dual union all select n+1 from cte, (select /*+ no_merge*/ * from t2 where pk = t3.pk) v where n = pk and n < 10) select /*+ no_unnest */ * from cte);

explain with recursive cte(n) as (select 1 from dual union all select /*+ leading((cte v1) t3) use_nl(cte v1)*/ v1.pk + 1 from (select /*+no_merge*/ * from t2) v1, cte, (select /*+ no_merge */ * from t3) t3 where v1.pk = n and v1.pk = t3.pk) select * from cte;

with recursive cte(n) as (select 1 from dual union all select /*+ leading((cte v1) t3) use_nl(cte v1)*/ v1.pk + 1 from (select /*+no_merge*/ * from t2) v1, cte, (select /*+ no_merge */ * from t3) t3 where v1.pk = n and v1.pk = t3.pk) select * from cte;

explain with recursive cte(n) as (select 1 from dual union all select /*+ leading((cte v1) t3) use_hash(v1)*/ v1.pk + 1 from (select /*+no_merge*/ * from t2) v1, cte, (select /*+ no_merge */ * from t3) t3 where v1.pk = n and v1.pk = t3.pk) select * from cte;

with recursive cte(n) as (select 1 from dual union all select /*+ leading((cte v1) t3) use_hash(v1) */ v1.pk + 1 from (select /*+no_merge*/ * from t2) v1, cte, (select /*+ no_merge */ * from t3) t3 where v1.pk = n and v1.pk = t3.pk) select * from cte;

