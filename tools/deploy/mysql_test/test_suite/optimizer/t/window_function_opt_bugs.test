# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer
# description: window function generate plan bug

--result_format 4
--explain_protocol 2
--enable_sorted_result

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, index idx (c2)) partition by hash(c1) partitions 2;

--disable_query_log
--disable_result_log
insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 select * from t1;
insert into t1 select * from t1;
--enable_query_log
--enable_result_log


## 1. can only allcoate partition gi above partition wise window function
--sorted_result
select /*+parallel(5)*/ sum(c1) over (partition by(c1)) from t1;

## 2. can not allocate gi above window function which is not partition wise
--sorted_result
select /*+parallel(2) no_use_hash_aggregation no_rewrite*/ sum(distinct c1) from (select /*+index(t1 idx)*/ c1, c2, sum(c3) over() ws from t1) v group by c2;

## 3. allcoate gi above window function
select /*+parallel(2) no_use_hash_aggregation no_rewrite*/ sum(distinct c1) from (select /*+index(t1 idx)*/ c1, c2, sum(c3) over(partition by c1) ws from t1) v;
select /*+parallel(2) no_use_hash_aggregation no_rewrite*/ sum(distinct c2) from (select /*+index(t1 idx)*/ c1, c2, sum(c3) over(partition by c1) ws from t1) v;

select /*+parallel(2) no_use_hash_aggregation no_rewrite*/ distinct c1 from (select /*+index(t1 idx)*/ c1, c2, sum(c3) over(partition by c2,c1) ws from t1) v;
select /*+parallel(2) no_use_hash_aggregation no_rewrite*/ distinct c2 from (select /*+index(t1 idx)*/ c1, c2, sum(c3) over(partition by c2,c1) ws from t1) v;

drop table t1;
