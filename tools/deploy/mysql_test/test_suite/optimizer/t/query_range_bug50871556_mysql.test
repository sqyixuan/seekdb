--echo issue: 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, c4 int);
create index idx on t1(c1,c2,c3);
insert into t1 values(1,3,4,5),(2,3,4,5),(1,5,6,5),(1,5,7,5);
--result_format 4

--explain_protocol 2
select /*+index(t1 idx)*/* from t1 where (c1 in (1,2) and c2 = 3 and c3 = 4) or (c1 = 1 and c2 = 5 and c3 = 6);
select /*+full(t1)*/* from t1 where (c1 in (1,2) and c2 = 3 and c3 = 4) or (c1 = 1 and c2 = 5 and c3 = 6);
select /*+index(t1 idx)*/* from t1 where (c1 in (1,2) and c2 = 3 and c3 = 4) or (c1 = 1 and c2 = 5);
select /*+full(t1)*/* from t1 where (c1 in (1,2) and c2 = 3 and c3 = 4) or (c1 = 1 and c2 = 5);
--explain_protocol 0
--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
