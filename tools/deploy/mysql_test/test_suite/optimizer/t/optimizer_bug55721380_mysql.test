# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 1172, error_code =4001, frequency = 1;
--sleep 3

connection default;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
--disable_result_log
#select dbms_spm.drop_sql_plan_baseline('test', '4B6AAC3B7F6DA2AF0B2697A91EEE2535');
--enable_result_log

CREATE TABLE `t1` (
  `c1` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c2` bigint(127) DEFAULT NULL,
  `c3` decimal(64,20) DEFAULT NULL,
  `c4` datetime DEFAULT NULL,
  `c5` datetime DEFAULT NULL,
  `c6` decimal(64,13) DEFAULT NULL,
  `c7` datetime DEFAULT NULL,
  `c8` int(127) DEFAULT NULL,
  `c9` int(127) DEFAULT NULL,
  `c10` decimal(64,0) GENERATED ALWAYS AS ((`c6` + `c9`)) VIRTUAL
) partition by range (c2) (partition p0 values less than (100));
CREATE TABLE `t2` (
  `c1` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c2` bigint(127) DEFAULT NULL,
  `c3` decimal(64,20) DEFAULT NULL,
  `c4` datetime DEFAULT NULL,
  `c5` datetime DEFAULT NULL,
  `c6` decimal(64,13) DEFAULT NULL,
  `c7` datetime DEFAULT NULL,
  `c8` int(127) DEFAULT NULL,
  `c9` int(127) DEFAULT NULL,
  `c10` decimal(64,0) GENERATED ALWAYS AS ((`c6` + `c9`)) VIRTUAL
);
create index idx2 on t2(c1);

--result_format 4
--explain_protocol 2
set session optimizer_use_sql_plan_baselines = true;
set session optimizer_capture_sql_plan_baselines = true;
INSERT     INTO t1  (c1, c2, c3, c4, c5, c6, c7, c8, c9)
    SELECT t2.c1, t2.c2, t2.c3, t2.c4, t2.c5, t2.c6, t2.c7, t2.c8, t2.c9 FROM t2 ORDER BY 1, 2, 3, 4, 5, 6, 7, 8, 9 LIMIT 999
    ON DUPLICATE KEY UPDATE t1.c1 = 'YvSJCqOJNPulq63439833', t1.c2 = 63439833, t1.c3 = 63439833.00000000000000000000, t1.c4 = date'1987-2-4', t1.c5 = date'2065-5-19', t1.c6 = 63439833.0000000000000, t1.c7 = date'2066-10-8', t1.c8 = 63439833, t1.c9 = 63439833;
drop index idx2 on t2;
INSERT     INTO t1  (c1, c2, c3, c4, c5, c6, c7, c8, c9)
    SELECT t2.c1, t2.c2, t2.c3, t2.c4, t2.c5, t2.c6, t2.c7, t2.c8, t2.c9 FROM t2 ORDER BY 1, 2, 3, 4, 5, 6, 7, 8, 9 LIMIT 999
    ON DUPLICATE KEY UPDATE t1.c1 = 'YvSJCqOJNPulq63439833', t1.c2 = 63439833, t1.c3 = 63439833.00000000000000000000, t1.c4 = date'1987-2-4', t1.c5 = date'2065-5-19', t1.c6 = 63439833.0000000000000, t1.c7 = date'2066-10-8', t1.c8 = 63439833, t1.c9 = 63439833;

drop table t1,t2;
connection conn_admin;
alter system set_tp tp_no = 1172, error_code =0, frequency = 0;
