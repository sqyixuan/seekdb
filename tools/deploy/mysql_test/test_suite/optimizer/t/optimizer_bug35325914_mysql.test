--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
# tags: optimizer
#description: optimizer misc bug validation

--disable_warnings
drop table if exists t1, t2, f_t2;
--enable_warnings
create table t1 (c1 int, c2 int, c3 int, primary key(c1, c2));
create table t2 (d1 int, d2 int, d3 int) partition by hash(d1) partitions 3;
create table f_t2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;

--disable_query_log
--disable_result_log
insert into t1 values(1,1,1);
insert into t1 values(2,11,1);
insert into t1 values(3,21,1);
insert into t1 values(4,31,1);
insert into t1 values(5,41,1);
insert into t1 values(6,51,1);
insert into t1 values(7,61,1);
insert into t1 select c1 + 4, c2 + 100, c3 * c1 from t1;
insert into t2 select c1 + 2, c2 + 3, c3 + 1 from t1;
insert into f_t2 select * from t1;
select count(*) from t1;
select count(*) from t2;
select count(*) from f_t2;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select /*+NO_UNNEST, leading(A, VIEW1), USE_NL(VIEW1)*/* from t2 A where A.d1 in ( select c1 from f_t2 C , t2 D where d.d1 = c.c1 ) ;
select /*+NO_UNNEST, NO_REWRITE, leading(A, VIEW1), USE_NL(VIEW1)*/* from t2 A where A.d1 in ( select /*+NO_REWRITE*/ c1 from f_t2 C , t2 D where d.d1 = c.c1 ) ;
