--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer


## bug: 
## 测试pkey重分区的分区键中包含多列
--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10;
--enable_warnings
create table t1 (pk int primary key, c1 int, c2 int) partition by hash(pk) partitions 2;
create table t2 (pk int primary key, c1 int, c2 int) partition by hash(pk) partitions 2;
create table t3 (pk int primary key, c1 int, c2 int) partition by key(pk) partitions 2;
create table t4 (pk1 int, pk2 int, c2 int, primary key (pk1, pk2)) partition by key(pk1, pk2) partitions 3;
create table t5 (pk int primary key, c1 int, c2 int) partition by list (pk)
(
  partition p0 values in (1,3,5,7),
  partition p1 values in (2,4,6,8)
);
create table t6 (pk1 int, pk2 int, c2 int, primary key (pk1, pk2)) partition by list columns (pk1, pk2)
(
  partition p0 values in ((1,1), (3,3), (5,5), (7,7)),
  partition p1 values in ((2,2), (4,4), (6,6), (8,8))
);
create table t7 (pk int primary key, c1 int, c2 int) partition by range (pk)
(
  partition p0 values less than (9),
  partition p1 values less than (16)
);
create table t8 (pk1 int, pk2 int, c2 int, primary key (pk1, pk2)) partition by range columns (pk1, pk2)
(
  partition p0 values less than (9,9),
  partition p1 values less than (16,16)
);
create table t9(pk1 int, pk2 int, c2 int, primary key(pk1, pk2)) partition by hash(pk1) 
  subpartition by range (pk2) 
  subpartition template (
      subpartition sp0 values less than (5),  
      subpartition sp1 values less than (9)) partitions 2;
create table t10(pk1 int, pk2 int, c2 int, primary key(pk1, pk2)) partition by list(pk1) 
  subpartition by key (pk2) subpartitions 3
(
  partition p0 values in (1,3,5,7),  
  partition p1 values in (2,4,6,8));

insert into t1 values (1,1,1), (2,1,2), (3,2,3), (4,2,4), (5,3,1), (6,3,2), (7,4,3), (8,4,4);
insert into t2 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t3 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t4 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t5 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t6 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t7 values (2,1,1), (4,2,2), (6,3,3), (8,4,4), (9,5,5), (11,6,6), (13,7,7), (15,8,8);
insert into t8 values (1,1,1), (4,2,2), (6,3,3), (8,4,4), (9,5,5), (11,6,6), (13,7,7), (15,8,8);
insert into t9 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);
insert into t10 values (1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7), (8,8,8);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
select count(*) from t4;
select count(*) from t5;
select count(*) from t6;
select count(*) from t7;
select count(*) from t8;
select count(*) from t9;
select count(*) from t10;
--enable_result_log

--explain_protocol 2
--result_format 4

# repart on hash
select /*+ordered use_hash(t2) PQ_DISTRIBUTE(t2 PARTITION NONE)*/ * from t1, t2 where t1.c1 + t1.c1 = t2.pk;
select /*+no_use_px ordered use_hash(t2) PQ_DISTRIBUTE(t2 PARTITION NONE)*/ * from t1, t2 where t1.c1 + t1.c1 = t2.pk;
