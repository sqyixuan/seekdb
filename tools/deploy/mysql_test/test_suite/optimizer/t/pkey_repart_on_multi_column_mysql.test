select /*+ordered use_hash(t2) PQ_DISTRIBUTE(t2 PARTITION NONE)*/ * from t1, t2 where t1.c1 + case when t1.c2 is not null then 1 else 0 end = t2.pk;
select /*+no_use_px ordered use_hash(t2) PQ_DISTRIBUTE(t2 PARTITION NONE)*/ * from t1, t2 where t1.c1 + case when t1.c2 is not null then 1 else 0 end = t2.pk;

