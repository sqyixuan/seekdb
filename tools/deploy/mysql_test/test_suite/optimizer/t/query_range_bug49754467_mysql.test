CREATE TABLE `table100_range_pk_part_p1__50_part_p2__maxvalue_` (
  `col_smallint` smallint(6) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_float` float DEFAULT NULL,
  `pk` int(11) DEFAULT NULL,
  `col_double` double DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  KEY `idx46` (`col_bigint`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx48` (`col_double`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx49` (`col_float`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx50` (`col_smallint`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(pk)
(partition p1 values less than (50),
partition p2 values less than (MAXVALUE));

