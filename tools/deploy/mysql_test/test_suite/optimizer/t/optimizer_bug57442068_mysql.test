# owner: wuyuming.wym
# owner group: SQL1
# tags: optimizer

--result_format 4

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int, c2 int) partition by hash(c1) partitions 2;
create table t2(c1 int, c2 int) partition by hash(c1) partitions 2;
create table t3(c1 int, c2 int) partition by hash(c1) partitions 2;
insert into t1 values (1,1),(1,2),(1,3),(2,1),(2,2),(2,3),(3,1),(3,2),(3,3);
insert into t2 values (1,1),(2,2),(3,3);
insert into t3 values (1,1),(2,2),(3,3);
create index i1 on t1(c1) local;
create index i2 on t1(c2) local;
create index i1 on t3(c1) local;

set ob_enable_transformation = 0;

--explain_protocol 1

## issue:

## normal sort
select /*+ordered use_merge(t2) pq_distribute(t2 local local) no_use_hash_distinct*/ distinct v1.c2 from (select 1 as c0, c2 from t1) v1, t2 where v1.c0 = t2.c1 order by 1;
select /*+ordered parallel(2) use_merge(t2) pq_distribute(t2 hash hash) no_use_hash_distinct*/ distinct v1.c2 from (select 1 as c0, c2 from t1) v1, t2 where v1.c0 = t2.c1 order by 1;
select /*+ordered parallel(2) use_merge(t2) pq_distribute(t2 broadcast none) no_use_hash_distinct*/ distinct v1.c2 from (select 1 as c0, c2 from t1) v1, t2 where v1.c0 = t2.c1 order by 1;
## no sort
select /*+ordered use_merge(t2) pq_distribute(t2 none all) use_das(t2) no_use_hash_distinct*/ distinct v1.c2 from (select 1 as c0, c2 from t1) v1, t2 where v1.c0 = t2.c1 order by 1;
## local merge sort
select /*+ordered parallel(2) use_merge(t2) pq_distribute(t2 none broadcast) no_use_hash_distinct*/ distinct v1.c2 from (select 1 as c0, c2 from t1) v1, t2 where v1.c0 = t2.c1 order by 1;

## issue:

select /*+ordered use_das(t2) use_merge(t2) use_nl(t3) no_distinct_pushdown no_use_hash_distinct index(t1 i2)*/ distinct t1.c2 from t1, t2, t3 where t1.c2 = t2.c2 and t1.c1 = t3.c1 order by 1;
select /*+ordered use_das(t2) use_merge(t2) use_nl(t3) no_distinct_pushdown no_use_hash_distinct full(t1)*/ distinct t1.c2 from t1, t2, t3 where t1.c2 = t2.c2 and t1.c1 = t3.c1 order by 1;
select /*+ordered use_das(t2) use_merge(t2) no_distinct_pushdown no_use_hash_distinct*/ distinct t1.c2 from t1, t2 where t1.c2 = t2.c2 order by 1;

select /*+ordered use_merge(t2) use_das(t2) index(t1 i1)*/ distinct t1.c1 from t1, t2 where t1.c1 = t2.c2 order by 1;
select /*+ordered use_merge(t2) use_das(t2) index(t1 i1)*/ t1.c1 from t1, t2 where t1.c1 = t2.c2 order by 1;

drop table t1,t2,t3;

## test range order
--explain_protocol 0
create table t1(c1 int, c2 int) partition by range(c1) (partition p0 values less than(2), partition p1 values less than(4));
create table t2(c1 int, c2 int) partition by range(c1) (partition p0 values less than(2), partition p1 values less than(4));
create table t3(c1 int, c2 int) partition by range(c1) (partition p0 values less than(2), partition p1 values less than(4));
insert into t1 values (1,1),(1,2),(1,3),(2,1),(2,2),(2,3),(3,1),(3,2),(3,3);
insert into t2 values (1,1),(2,2),(3,3);
insert into t3 values (1,1),(2,2),(3,3);
create index i1 on t1(c1) local;
create index i2 on t1(c2) local;
create index i1 on t3(c1) local;
--explain_protocol 1

select distinct c1 from t1 order by 1 desc;
select c1, count(*) from t1 group by c1 order by 1 desc;
select distinct c1 from (select /*+index(t1 i1)*/ 1 as c0, c1 from t1) v1 order by c1;
select c1, row_number() over (partition by c1) from t1 order by c1;
select distinct c1, row_number() over (partition by c1) from t1 order by c1;
select /*+use_merge(t2) ordered*/ t1.c1 from t1,t2 where t1.c1 = t2.c1 order by 1 desc;
select /*+use_merge(t2) ordered use_das(t2)*/ t1.c1 from t1,t2 where t1.c1 = t2.c2 order by 1 desc;
select /*+use_merge(t2) ordered*/ distinct t1.c1 from t1,t2 where t1.c1 = t2.c1 order by 1 desc;
select /*+use_merge(t2) ordered use_das(t2)*/ distinct t1.c1 from t1,t2 where t1.c1 = t2.c2 order by 1 desc;
select /*+use_merge(t2) ordered full(t1)*/ distinct t1.c1 from t1,t2 where t1.c1 = t2.c1 order by 1 desc;
select /*+use_merge(t2) ordered use_das(t2) full(t1)*/ distinct t1.c1 from t1,t2 where t1.c1 = t2.c2 order by 1 desc;
select /*+use_merge(t2 t3) ordered use_das(t2)*/ t1.c1 from t1,t2,t3 where t1.c1 = t2.c2 and t1.c1 = t3.c1 order by 1 desc;
select /*+ordered use_merge(t2) pq_distribute(t2 local local) no_use_hash_distinct*/ distinct v1.c1 from (select 1 as c0, c1 from t1) v1, t2 where v1.c0 = t2.c1 order by 1 desc;
select /*+ordered use_merge(t2) use_das(t2) no_use_hash_distinct*/ distinct v1.c1 from (select 1 as c0, c1 from t1) v1, t2 where v1.c0 = t2.c1 order by 1 desc;
select /*+ordered use_merge(t2) use_das(t2) no_use_hash_distinct*/ distinct v1.c1 from (select 1 as c0, c1 from t1) v1, t2 where v1.c0 = t2.c1 order by 1 asc;

drop table t1,t2,t3;