# owner: zhanyue.zzy
# owner group: SQL1
# tags: optimizer

--result_format 4


##bug 


--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists tp1;
drop table if exists tp2;
--enable_warnings

create table t1 (c1 int, c2 int, unique idx (c2), index idx_c1(c1));
create table t2 (c1 int, c2 int, unique idx (c2), index idx_c1(c1));
create table tp1 (c1 int, c2 int, unique idx (c2) global, index idx_c1(c1)) partition by hash(c1) partitions 5;
create table tp2 (c1 int, c2 int, unique idx (c2) global, index idx_c1(c1)) partition by hash(c1) partitions 5;

--disable_query_log
--disable_result_log
insert into t1 values (1, 1), (1, 2), (1, 3), (4, 4), (5, 5);
insert into t2 values (1, null), (1, 2), (1, null), (4, null), (5, null);
insert into tp1 values (1, 1), (1, 2), (1, 3), (4, 4), (5, 5);
insert into tp2 values (1, null), (1, 2), (1, null), (4, null), (5, null);
select count(*) from t1;
select count(*) from t2;
select count(*) from tp1;
select count(*) from tp2;
--enable_query_log
--enable_result_log

--explain_protocol 2

select * from t1 where c2 is null;
select * from t2 where c2 is null;

select * from t1 where c2 is null and c1 = 1;
select * from t2 where c2 is null and c1 = 1;


## partition table
select * from tp1 where c2 is null;
select * from tp2 where c2 is null;

select * from tp1 where c2 is null and c1 = 1;
select * from tp2 where c2 is null and c1 = 1;

drop table t1;
drop table t2;
drop table tp1;
drop table tp2;
