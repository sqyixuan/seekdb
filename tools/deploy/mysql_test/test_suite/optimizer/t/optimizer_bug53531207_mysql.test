--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
 
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3));
create table t2(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3)) partition by hash(c1) partitions 10;
create index idx on t2(c2, c1) local;
 
--result_format 4
--explain_protocol 2
 
select /*+leading(t1) use_nl(t2) no_expand */ *
from t1
	left join (select /*+no_merge*/ * from t2) t2
	on (t2.c2 = t1.c2 or t2.c2 = 4) and t1.c1 < 10;
 
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
