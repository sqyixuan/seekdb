#owner: yibo.tyf
#owner group: sql1
#tags: optimizer
#description: 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--disable_result_log
create table t1(id int primary key, c1 int, c2 int);
create table t2(c1 int, c2 int, c3 int);
--disable_query_log
select count(*) from t1;
select count(*) from t2;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select t1.id from t1, (select c1 from t2 group by c1 having sum(t2.c1) = 0) view where t1.c1 = view.c1;

drop table t1,t2;
