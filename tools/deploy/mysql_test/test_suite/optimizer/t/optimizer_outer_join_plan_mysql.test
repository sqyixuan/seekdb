--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
# tags: optimizer
#description: outer join does not support subquery filter

# optimizer do not support generate plan for outer join whose on-conditions has subquery filter
--disable_warnings
drop table if exists t, s, r;
--enable_warnings
create table t (c1 int, c2 int);
create table s (c1 int, c2 int);
create table r (c1 int, c2 int);

--error 0,1235
explain select count(*) from t left join s on t.c1 = s.c1 and s.c2 in (select c1 from r);
--error 0,1235
explain select count(*) from t right join s on t.c1 = s.c1 and s.c2 in (select c1 from r);
explain select count(*) from t join s on t.c1 = s.c1 and s.c2 in (select c1 from r);

--error 0,1235
explain select count(*) from t left join (s join r on s.c2 = r.c2 and s.c2 in (select 1 union select 2))  on t.c1 = s.c1;
--error 0,1235
explain select count(*) from t right join (s join r on s.c2 = r.c2 and s.c2 in (select 1 union select 2))  on t.c1 = s.c1;
explain select count(*) from t join (s join r on s.c2 = r.c2 and s.c2 in (select 1 union select 2))  on t.c1 = s.c1;

drop table t, s, r;
