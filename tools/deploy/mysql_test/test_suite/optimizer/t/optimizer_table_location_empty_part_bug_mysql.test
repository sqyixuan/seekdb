--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
#tags: optimizer

--result_format 4

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
--enable_warnings

create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
create table t2(c1 int primary key, c2 int);

select /*+leading(t2 t1) use_nl(t1) use_das(t1) */ * from t1, t2 where t1.c1 = t2.c1;

drop table t1;
drop table t2;
