# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer, cross_validation

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, index idx1(c1,c2,c3,c4));
set @a = 0;
insert into t1 select level, level + 10, level + 20, level + 30
from (select @a := @a + 1 as level from table(generator(31)));

--result_format 4
--explain_protocol 2
## const [not] between col and col
select /*+full(t1)*/ * from t1 where 20 between c1 and c2;
select /*+index(t1 idx1)*/ * from t1 where 20 between c1 and c2;
select /*+full(t1)*/ * from t1 where 20 between c1 and c3;
select /*+index(t1 idx1)*/ * from t1 where 20 between c1 and c3;
select /*+full(t1)*/ * from t1 where c1 = 10 and 25 between c2 and c3;
select /*+index(t1 idx1)*/ * from t1 where c1 = 10 and 25 between c2 and c3;
select /*+full(t1)*/ * from t1 where 20 not between c1 and c2;
select /*+index(t1 idx1)*/ * from t1 where 20 not between c1 and c2;
select /*+full(t1)*/ * from t1 where 20 not between c1 and c3;
select /*+index(t1 idx1)*/ * from t1 where 20 not between c1 and c3;
select /*+full(t1)*/ * from t1 where c1 = 10 and 25 not between c2 and c3;
select /*+index(t1 idx1)*/ * from t1 where c1 = 10 and 25 not between c2 and c3;

## (const [not] between col and col) or other_cond
select /*+full(t1)*/* from t1 where (20 between c1 and c2) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (20 between c1 and c2) or c1 = 31;
select /*+full(t1)*/* from t1 where (20 between c1 and c3) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (20 between c1 and c3) or c1 = 31;
select /*+full(t1)*/* from t1 where (c1 = 10 and 25 between c2 and c3) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (c1 = 10 and 25 between c2 and c3) or c1 = 31;
select /*+full(t1)*/* from t1 where (20 not between c1 and c2) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (20 not between c1 and c2) or c1 = 31;
select /*+full(t1)*/* from t1 where (20 not between c1 and c3) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (20 not between c1 and c3) or c1 = 31;
select /*+full(t1)*/* from t1 where (c1 = 10 and 25 not between c2 and c3) or c1 = 31;
select /*+index(t1 idx1)*/* from t1 where (c1 = 10 and 25 not between c2 and c3) or c1 = 31;

drop table t1;