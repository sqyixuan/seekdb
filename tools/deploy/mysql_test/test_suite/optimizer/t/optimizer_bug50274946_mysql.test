--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer, cross_validation

connect (obsys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
let $saved_primary_zone=`select primary_zone from __all_tenant where tenant_name = 'sys'`;
alter tenant sys set primary_zone = 'RANDOM';
sleep 3;
connection default;

--disable_warnings
drop table if exists `gf_ar_dly_bill`;
drop table if exists `ob_causal_ordering2`;
drop table if exists `insertintot2`;
drop table if exists `upp_online_checktrans_92`;
--enable_warnings

CREATE TABLE `gf_ar_dly_bill` (                                         
  `tnt_inst_id` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT 'з§ҹжҲ·жңәжһ„id',                              
  `bill_no` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT 'иҙҰеҚ•еҸ·',
  `ip_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT 'з»“з®—еҜ№иұЎipid',                  
  `ip_role_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT 'з»“з®—еҜ№иұЎpid', 
  `inst_id` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT 'еҲҶж”Ҝжңәжһ„',       
  `pd_code` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT 'дә§е“Ғз Ғ',                                                              
  `ar_no` varchar(34) COLLATE utf8mb4_bin NOT NULL COMMENT 'еҗҲзәҰеҸ·',                   
  `bill_tp` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT 'иҙҰеҚ•зұ»еһӢ11пјҡжӯЈеёёж—ҘиҙҰеҚ•12пјҡжұҮжҖ»и°ғж•ҙж—ҘиҙҰеҚ•',
  `setl_tp` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT 'з»“з®—ж–№ејҸ01пјҡе®һж—¶иҙҰеҚ•02пјҡйў„ж”¶иҙҰеҚ•03пјҡеҗҺж”¶иҙҰеҚ•04пјҡе‘ЁжңҹжҖ§иҙҰеҚ•05пјҡж—Ҙз»“иҙҰеҚ•пјҲжҡӮж— пјү',
  `bill_st` varchar(2) COLLATE utf8mb4_bin NOT NULL COMMENT 'ж ёй”ҖзҠ¶жҖҒ01пјҡжңӘз»“з®—02пјҡйғЁеҲҶз»“з®—03пјҡе®Ңе…Ёз»“з®—',
  `bill_dt` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT 'иҙҰеҚ•ж—Ҙжңҹ',                            
  `actg_dt` varchar(8) COLLATE utf8mb4_bin NOT NULL COMMENT 'зҷ»иҙҰж—Ҙжңҹ',                              
  `acrd_dt` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еә”ж”¶ж—Ҙжңҹ',                     
  `gmt_pay` timestamp(6) NULL DEFAULT NULL COMMENT 'д»ҳж¬ҫж—¶й—ҙ',
  `payee_ac` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ж”¶ж¬ҫж–№иҙҰеҸ·',                    
  `payer_ac` varchar(34) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'д»ҳж¬ҫж–№иҙҰеҸ·пјҲжүЈж¬ҫиҙҰеҸ·пјҢйқһй“¶иЎҢеҚЎж—¶дёәз©әпјү',
  `pay_way` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ж”Ҝд»ҳж–№ејҸ 1:иө„йҮ‘2.еҢ…йҮҸ3пјҡеҢ…ж¬Ўж•°4пјҡеҢ…ж—¶й—ҙ5пјҡиө°йҮҸ',
  `pay_orig` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ж”Ҝд»ҳжқҘжәҗ1пјҡдё»иҙҰеҠЎ2пјҡеҢ…йҮҸ3пјҡйў„ж”¶4пјҡйў„еӯҳ5пјҡй“¶иЎҢ6пјҡз§ҜеҲҶ',   
  `clcn_bsc_amt` decimal(25,4) DEFAULT NULL COMMENT 'и®Ўиҙ№дәӨжҳ“йҮҸ',                                        
  `clcn_bsc_tp` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'и®Ўиҙ№дҫқжҚ®01пјҡдәӨжҳ“йҮ‘йўқ02пјҡдәӨжҳ“з¬”ж•°',    
  `clcn_mthd` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'и®Ўиҙ№ж–№жі•01пјҡе·®йўқзҙҜиҝӣ02пјҡе…ЁйўқзҙҜиҝӣ',                         
  `chrg_itm_code` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ж”¶иҙ№йЎ№зј–з Ғ',                                          
  `ccy` varchar(3) COLLATE utf8mb4_bin NOT NULL COMMENT 'еёҒз§Қ',                     
  `bill_amt` bigint(20) NOT NULL COMMENT 'иҙҰеҚ•йҮ‘йўқ',                                  
  `rcvd_amt` bigint(20) NOT NULL COMMENT 'е·Іж”¶йҮ‘йўқ',                                                                                                                                                                     
  `tax_tp` varchar(16) COLLATE utf8mb4_bin NOT NULL COMMENT 'зЁҺз§Қ01:еўһеҖјзЁҺ02пјҡиҗҘдёҡзЁҺ',
  `tax_rate` decimal(10,8) NOT NULL COMMENT 'зЁҺзҺҮ',
  `tax_amt` bigint(20) NOT NULL COMMENT 'зЁҺйўқ',
  `exn_inf` varchar(40960) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'жү©еұ•дҝЎжҒҜ',
  `orig_rcrd_id` varchar(128) COLLATE utf8mb4_bin NOT NULL COMMENT 'жәҗи®°еҪ•id',
  `mthly_bill_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'жңҲиҙҰеҚ•еҸ·',
  `wrtof_dtl_cnt` bigint(20) DEFAULT NULL COMMENT 'е·Іж ёй”ҖжҳҺз»Ҷж•°йҮҸ',
  `to_wrtof_dtl_cnt` bigint(20) DEFAULT NULL COMMENT 'еҫ…ж ёй”ҖжҳҺз»Ҷж•°йҮҸ',
  `anl_dmsn1` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҲҶжһҗз»ҙеәҰ1',
  `anl_dmsn2` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҲҶжһҗз»ҙеәҰ2',
  `anl_dmsn3` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҲҶжһҗз»ҙеәҰ3',
  `anl_dmsn4` varchar(1000) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҲҶжһҗз»ҙеәҰ4',
  `last_moder` varchar(32) COLLATE utf8mb4_bin NOT NULL COMMENT 'жңҖиҝ‘дҝ®ж”№дәә',
  `gmt_create` timestamp(6) NOT NULL COMMENT 'еҲӣе»әж—¶й—ҙ',
  `gmt_modified` timestamp(6) NOT NULL COMMENT 'дҝ®ж”№ж—¶й—ҙ',
  `charge_tp` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'и®Ўж”¶иҙ№зҺҜеўғзұ»еһӢ01  дё»з«ҷдә‘и®Ўж”¶иҙ№02  дё»з«ҷзҰ»зәҝи®Ўж”¶иҙ№03  дё»з«ҷиҖҒи®Ўж”¶иҙ№',
  `stl_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'з»“з®—еҜ№иұЎ(е·ІеәҹејғпјҢеҖјзӯүдәҺip_role_id)',
  `svc_amt` bigint(20) DEFAULT NULL COMMENT 'дәӨжҳ“йҮ‘йўқ',
  `chk_rcrd_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'е…іиҒ”зҡ„зЎ®и®Өи®°еҪ•idпјҢиӢҘдёәз©әпјҢиҜҙжҳҺиҜҘж—ҘиҙҰеҚ•е№¶жІЎжңүеҸ‘з”ҹиҝҮзЎ®и®Ө',
  `tp` varchar(2) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еә”ж”¶1иҝ”зӮ№2',
  `actg_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'NпјҡдёҚеҸ‘йҖҒж ёз®—ж¶ҲжҒҜYпјҡеҸ‘йҖҒж ёз®—ж¶ҲжҒҜ',
  `payer_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'жүЈж¬ҫеҜ№иұЎpid',
  `sgn_ip_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'зӯҫзәҰеҜ№иұЎipid',
  `sgn_ip_role_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'зӯҫзәҰеҜ№иұЎpid',
  `memo` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҺҹеӣ пјҲеҰӮжһңжҳҜи°ғж•ҙиҙҰеҚ•пјҢи°ғж•ҙеҺҹеӣ ж”ҫе…ҘжӯӨеҲ—пјү',
  `writingoff_amt` bigint(20) DEFAULT '0' COMMENT 'ж ёй”ҖдёӯйҮ‘йўқ',
  `svc_bill_amt` bigint(20) DEFAULT NULL COMMENT 'иҙҰеҚ•и®Ўиҙ№йҮ‘йўқпјҢи®Ўж”¶иҙ№и®Ўиҙ№ж—¶з”ҹжҲҗзҡ„дёӯй—ҙйҮ‘йўқ',
  `svc_ccy` varchar(3) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'иҙҰеҚ•и®Ўиҙ№еёҒз§Қ',
  `env_source` varchar(16) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'зҺҜеўғж ҮиҜҶ',
  `metadata_source` varchar(1024) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'е…ғж•°жҚ®жқҘжәҗж ҮиҜҶпјҢеҢ…жӢ¬(з”ЁжҲ·гҖҒе•ҶжҲ·гҖҒдә§е“ҒгҖҒеҗҲзәҰгҖҒи®Ўиҙ№)жқҘжәҗ',
  `setl_time_zone` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'иҙҰеҚ•з»“з®—ж—¶еҢә',
  `actg_time_zone` varchar(12) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'иҙҰеҚ•ж ёз®—ж—¶еҢә',
  `inter_trade_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'Y: жҳҜе…іиҒ”дәӨжҳ“ N: дёҚжҳҜе…іиҒ”дәӨжҳ“',
  `actg_bill_dt` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'ж ёз®—ж—¶еҢәиҙҰеҚ•ж—Ҙжңҹ',
  `auto_writeoff_group_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'иҮӘеҠЁж ёй”Җе…іиҒ”з»„еҸ·',
  `partition_id` char(4) COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`bill_no`,23,2)) VIRTUAL,
  `anl_dmsn_agg_sum` varchar(20480) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'еҲҶжһҗз»ҙеәҰжұҮжҖ»дҝЎжҒҜ',
  PRIMARY KEY (`tnt_inst_id`, `bill_no`),
  UNIQUE KEY `uk_tnt_inst_id_orig_rcrd_id` (`tnt_inst_id`, `orig_rcrd_id`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_tnt_inst_id_chk_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `chk_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_bill_no_ip_role_id` (`tnt_inst_id`, `bill_no`, `ip_role_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_mthly_bill_no_chk_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `mthly_bill_no`, `chk_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_ip_role_id_orig_rcrd_id` (`tnt_inst_id`, `ip_role_id`, `orig_rcrd_id`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_tnt_inst_id_ip_role_id_bill_dt` (`tnt_inst_id`, `ip_role_id`, `bill_dt`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_mthly_bill_no_ip_role_id_bill_st` (`tnt_inst_id`, `mthly_bill_no`, `ip_role_id`, `bill_st`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_mthly_bill_no_ip_role_id_bill_tp` (`tnt_inst_id`, `mthly_bill_no`, `ip_role_id`, `bill_tp`) BLOCK_SIZE 16384 LOCAL,
  CONSTRAINT `gf_ar_dly_bill1` CHECK ((`partition_id` = substr(`ip_role_id`,-3,2))),
  CONSTRAINT `gf_ar_dly_bill2` CHECK ((`partition_id` = substr(`mthly_bill_no`,23,2)))
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = 'еә”ж”¶ж—ҘиҙҰеҚ•иЎЁ'
