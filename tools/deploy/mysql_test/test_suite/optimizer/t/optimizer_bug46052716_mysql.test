--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
# link: 

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

--explain_protocol 3
--result_format 4
create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int, index idx_c1(c1));
create table t3(c1 int, c2 int, c3 int);
update t1 set c1 = 1, c2 = exists(select/*+index (t2 idx_c1)*/ 1 from (t2 inner join t3 on (t2.c1 != t1.c1 )));
update t1 set c1 = 1, c2 = exists(select/*+no_index (t2 idx_c1)*/ 1 from (t2 inner join t3 on (t2.c1 != t1.c1 )));

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
