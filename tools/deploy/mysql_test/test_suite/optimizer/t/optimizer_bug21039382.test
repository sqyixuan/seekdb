WITH x1 AS ( SELECT /*+materialize*/ x2 FROM ( SELECT 32130093.000000 AS x2 FROM v4 AS x3 NATURAL JOIN v0 WHERE v5 = ( ( SELECT v1 FROM v0 WHERE ( SELECT v6 = ( SELECT v1 FROM v0 WHERE v3 IS NULL AND v3 IS NULL ) FROM v4 ) AND v2 = 77 ) NOT IN ( 'x' , 'x' ) ) ) AS x4 , v0 AS x5 , v0 AS x6 , v4 AS x7 JOIN v0 , v0 AS x8 , v0 AS x9 JOIN v0 AS x10 ) SELECT DISTINCT 'x' FROM x1 AS x11 , v4 AS x12 , v0 AS x13 , v4 AS x14 , x1 AS x15 JOIN x1 AS x16 , v4 AS x17 , x1 NATURAL JOIN v4 AS x18 , x1 AS x19 , x1 AS x20 , x1 AS x21 , x1 AS x22 JOIN x1 AS x23 , v0 AS x24 , v0 WHERE -1 = 83 ;

