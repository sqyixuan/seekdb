SELECT 1  
FROM  
oceanbase.__all_tenant_time_zone_transition_type AS ref_0 
LEFT JOIN 
mysql.USER AS ref_1 
ON    ref_0.offset IN (                     
    ( SELECT   time_zone_id FROM     oceanbase.__all_tenant_time_zone_transition_type )                    
);
