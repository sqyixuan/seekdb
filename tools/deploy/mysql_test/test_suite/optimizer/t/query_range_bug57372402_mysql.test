# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer

--disable_warnings
DROP TABLE if exists t1,t2;
--enable_warnings

CREATE TABLE t1 (
  c1 datetime,
  KEY idx1 (c1)
);
insert into t1 values ('2024-01-02 12:00:00');

--result_format 4
--replace_regex /[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9] /CURRENT_DATE /
explain select /*+index(t1 idx1)*/ * from t1 where c1 < time '10:00:00';
select /*+index(t1 idx1)*/ * from t1 where c1 < time '10:00:00';
select /*+full(t1)*/ * from t1 where c1 < time '10:00:00';

--replace_regex /[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9] /CURRENT_DATE /
explain select /*+index(t1 idx1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');
select /*+index(t1 idx1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');
select /*+full(t1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');

SET TIMESTAMP=UNIX_TIMESTAMP('2024-01-02 10:14:35');

explain select /*+index(t1 idx1)*/ * from t1 where c1 < time '10:00:00';
select /*+index(t1 idx1)*/ * from t1 where c1 < time '10:00:00';
select /*+full(t1)*/ * from t1 where c1 < time '10:00:00';

explain select /*+index(t1 idx1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');
select /*+index(t1 idx1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');
select /*+full(t1)*/ * from t1 where c1 in (time '10:00:00', time '11:00:00', time '12:00:00');

DROP TABLE t1;