--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table t2;
--error 0,1305
drop procedure p1;
--error 0,1305
drop function f1;

--result_format 4

create table t1(c1 int);
create table t2(c1 int);
delimiter //;

create function f1() returns int        
begin
  insert into t2 values(2);
  return 1;
end//

create procedure p1()
begin
  declare i int  default 0;
  repeat
      set i = i+1;
      insert into t1 values (ceil(rand(3)*26*i));
    until i>50 end repeat;
end//

delimiter ;//

call p1();

explain select /*+parallel(1)*/ c1, f1() from t1 order by c1;

--echo ============ test global parallel hint ============
explain select /*+parallel(2)*/ c1, f1() from t1 order by c1;

--echo ============ test table parallel hint ============
explain select /*+parallel(t1 2)*/ c1, f1() from t1 order by c1;

--echo ============ test session force parallel ============
set _force_parallel_query_dop = 2;
explain select c1, f1() from t1 order by c1;
set _force_parallel_query_dop = 1;

--echo =====test bug 11914091 =======
explain select /*+parallel(t1, 2) leading(t1 t2) use_hash(t2) px_join_filter(t2)*/t1.c1, f1() from t1 join t2 on t1.c1=t2.c1 order by t2.c1;
drop table t1;
drop table t2;
drop procedure p1;
drop function f1;