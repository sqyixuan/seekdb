--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int,c2 int);
insert into t1 values(1,1);
create table t2(c1 int,c2 int);
insert into t2 values (1,1);
alter system flush plan cache global;

--error 1054
select c1 from t1 group by 2 with rollup;

select c1 from t1 group by 1 with rollup;

#static const
select 'abc' from t1 group by 'abc' with rollup;
select 'abc' from t1 group by 'abc' with rollup having 'abc' is null;
select 'abc' from t1 where 'abc' is null group by 'abc' with rollup;
select length('abc'), grouping('abc'), grouping('abc')+1 from t1 group by 'abc' with rollup;
select length('abc') from t1 group by length('abc') with rollup;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by 'abc' asc;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by 'abc' desc;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by length('abc') asc;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by length('abc') desc;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by grouping('abc') asc;
select 'abc',grouping('abc') from t1 group by 'abc' with rollup order by grouping('abc') desc;
select 1+1 from t1 group by 1+1 with rollup;
alter system flush plan cache global;
select 2+1+1 from t1 group by 1+1 with rollup;
alter system flush plan cache global;
select 1+1+2 from t1 group by 1+1 with rollup;

#exec params
select * from t1 where exists (select t1.c1 from t2 group by t1.c1 with rollup having t1.c1 is null);
select * from t1 where exists (select t1.c1 from t2 where t1.c1 is null group by t1.c1 with rollup);
select * from t1 where exists (select t1.c1+1 from t2 group by t1.c1 with rollup having t1.c1+1 is null);
select * from t1 where exists (select t1.c1+1 from t2 group by t1.c1+1 with rollup having t1.c1+1 is null);
select * from t1 where exists (select hex(t1.c1) from t2 group by t1.c1 with rollup having hex(t1.c1) is null);
select * from t1 where exists (select hex(t1.c1) from t2 group by hex(t1.c1) with rollup having hex(t1.c1) is null);
select * from t1 where exists (select hex(t1.c1+1) from t2 group by t1.c1+1 with rollup having hex(t1.c1+1) is null);
select * from t1 where exists (select hex(t1.c1+1) from t2 group by hex(t1.c1+1) with rollup having hex(t1.c1+1) is null);
select * from t1 where exists (select grouping(t1.c1) from t2 group by t1.c1 with rollup having grouping(t1.c1) = 0);
select * from t1 where exists (select grouping(t1.c1+1) from t2 group by t1.c1+1 with rollup having grouping(t1.c1+1) = 0);

select * from t1 where 1 in (select t1.c1 from t2 group by t1.c1 with rollup order by t1.c1 asc limit 1);
select * from t1 where 1 in (select t1.c1 from t2 group by t1.c1 with rollup order by t1.c1 desc limit 1);
select * from t1 where 2 in (select t1.c1+1 from t2 group by t1.c1+1 with rollup order by t1.c1+1 asc limit 1);
select * from t1 where 2 in (select t1.c1+1 from t2 group by t1.c1+1 with rollup order by t1.c1+1 desc limit 1);
select * from t1 where 2 in (select t1.c1+1 from t2 group by t1.c1+1 with rollup order by grouping(t1.c1+1) asc limit 1);
select * from t1 where 2 in (select t1.c1+1 from t2 group by t1.c1+1 with rollup order by grouping(t1.c1+1) desc limit 1);

##ob doesn't support. mysql 8.0 returns empty set
--error 1064 
select * from t1 where exists (select grouping(t1.c1, t1.c2) from t2 group by t1.c1, t1.c2 with rollup having grouping(t1.c1, t1.c2) = 0);

drop table t1,t2;

#BugFix:
--disable_warnings
drop table if exists v0;
--enable_warnings
create table v0 ( id integer , v2 integer not null unique primary key unique primary key unique unique not null unique , v1 integer ) ;
select v2,null is not null from v0 group by _binary 'x' , 'x' , null with rollup having v2 is not null;
select true, true is true, true is not true from dual group by true with rollup;
select null, null is null, null is not null from dual group by null with rollup;
select false, false is false, false is not false from dual group by false with rollup;
drop table v0;

#
--disable_warnings
drop table if exists v0;
--enable_warnings
CREATE TABLE t1 (id int, f1 INTEGER);
INSERT INTO t1 VALUES (1,0);
INSERT INTO t1 VALUES (2,1);
INSERT INTO t1 VALUES (3,2);

SELECT (SELECT sum(f1) AS sum FROM t1 ) AS field1,sum(id)
FROM t1 
GROUP BY field1 WITH ROLLUP;

SELECT (SELECT 1) AS field1,sum(id)
FROM t1 
GROUP BY field1 WITH ROLLUP;

SELECT (SELECT 1) AS field1,sum(id)
FROM t1 
GROUP BY field1 + 0 WITH ROLLUP;