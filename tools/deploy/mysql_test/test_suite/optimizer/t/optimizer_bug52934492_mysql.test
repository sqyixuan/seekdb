--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, constraint uk41 unique(c1,c2), constraint uk42 unique(c3), constraint t4_pk primary key(c4));
create table t2(c1 int, c2 int, c3 int, c4 int, primary key (c1, c2))  partition by hash(c2) partitions 4;

--result_format 4
--explain_protocol 1

select /*+ parallel(2) pq_map(t2) pq_distribute(t2 broadcast none) leading(t1 t2) use_merge(t2)*/ * from t1 join t2 on t1.c2 = t2.c1;
select /*+ parallel(2) pq_distribute(t2 broadcast none) leading(t1 t2) use_merge(t2)*/ * from t1 join t2 on t1.c2 = t2.c1;

drop table t1,t2;

