--disable_warnings
drop table if exists t1;
--enable_warnings

set ob_enable_transformation = 0;
create table t1(a int);
insert into t1 values (1),(5);
explain with recursive cte as (select min(a) x, max(a) y from t1), tmp(n) as (select x from cte union all select n+1 from tmp where n < (select y from cte)) select n from tmp ;
with recursive cte as (select min(a) x, max(a) y from t1), tmp(n) as (select x from cte union all select n+1 from tmp where n < (select y from cte)) select n from tmp ;

set ob_enable_transformation = 1;
drop table t1;