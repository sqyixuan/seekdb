#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer
#description: outer join startup filters bug

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int, c2 int, c3 int);
create table t3(c1 int, c2 int, c3 int);

--disable_result_log
--disable_query_log
insert into t1 values(1, 1, 1);
insert into t1 values(2, 2, 2);
insert into t2 values(1, 1, 1);
insert into t2 values(2, 2, 2);
insert into t3 values(1, 1, 1);
insert into t3 values(2, 2, 2);
select count(*) from t1;
select count(*) from t2;
select count(*) from t3;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

select * from t1 left join (t2 inner join t3 on false) on t1.c1 = t2.c1;
select /*+no_rewrite*/ * from t1 left join (t2 inner join t3 on false) on t1.c1 = t2.c1;

drop table t1, t2, t3;

##bug:
--disable_warnings
drop table if exists `cc`, `bb`;
--enable_warnings

CREATE TABLE `cc` (
  `pk` int(11) NOT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL
) ;

CREATE TABLE `bb` (
  `col_int` int(11) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 GLOBAL
) ;

--disable_query_log
--disable_result_log
