INSERT INTO `cc` VALUES (1,0,NULL,'z','l',2,'a','p',NULL),(2,NULL,NULL,'k','j',4,'b','c','l'),(3,9,'c','y',NULL,NULL,'i','j','m'),(4,0,'s',NULL,NULL,1,'v',NULL,'y'),(5,NULL,NULL,'g','m',3,'h','c','c'),(6,5,NULL,'e','i',2,'e','f','n'),(7,0,'m','q','f',5,'m','l',NULL),(8,9,'l',NULL,NULL,NULL,'i','w',NULL),(9,6,'a','j','k',8,'u','z','m'),(10,NULL,'u',NULL,NULL,1,'n','b','s'),(11,7,'d','t','v',9,'f',NULL,NULL),(12,5,'s','s','r',8,'k','n','a'),(13,9,NULL,'t',NULL,NULL,'w','b','q'),(14,2,NULL,'p','l',1,'n','j','d'),(15,0,'u','b',NULL,4,'d',NULL,NULL),(16,9,'x',NULL,'g',0,'i','g',NULL),(17,3,'h',NULL,NULL,5,NULL,'x',NULL),(18,5,'s','f','m',2,'f','u','a'),(19,NULL,'z',NULL,'d',1,NULL,'a','d'),(20,NULL,'y','m','e',2,NULL,'a','x'),(21,8,NULL,'l','h',9,NULL,'n','p'),(22,4,NULL,'n','e',9,'m','t','m'),(23,3,NULL,'d','e',6,'m','p','t'),(24,NULL,'h','f','h',7,'b','c',NULL),(25,5,'u',NULL,'p',5,'a','p','x'),(26,NULL,NULL,'t','s',7,NULL,'w','u'),(27,0,'t','p','q',1,'w','j','r'),(28,5,'y','v','m',5,'y',NULL,NULL),(29,NULL,NULL,NULL,NULL,5,'k',NULL,NULL);
select count(*) from `bb`;
select count(*) from `cc`;
--enable_query_log
--enable_result_log

SELECT table1 . `col_varchar` AS field1,
       table2 . col_varchar_10_key AS field2
FROM (CC AS table1
      LEFT  JOIN
        (SELECT SUBQUERY1_t1 . *
         FROM (CC AS SUBQUERY1_t1
               INNER JOIN BB AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
         WHERE SUBQUERY1_t1 . `col_int_key` > SUBQUERY1_t2 . `pk` ) AS table2 ON (table2 . `col_int_key` = table1 . `col_int_key`))
WHERE (table1 . `col_int` >=
         (SELECT 5
          FROM DUAL))
  OR (table2 . `col_varchar_20` <> table1 . `col_varchar`
      OR table1 . `col_varchar` != 'p')
ORDER BY field1,
         field2 ;

 
SELECT /*+no_rewrite*/ table1 . `col_varchar` AS field1,
       table2 . col_varchar_10_key AS field2
FROM (CC AS table1
      LEFT  JOIN
        (SELECT SUBQUERY1_t1 . *
         FROM (CC AS SUBQUERY1_t1
               INNER JOIN BB AS SUBQUERY1_t2 ON (SUBQUERY1_t2 . `pk` = SUBQUERY1_t1 . `col_int_key`))
         WHERE SUBQUERY1_t1 . `col_int_key` > SUBQUERY1_t2 . `pk` ) AS table2 ON (table2 . `col_int_key` = table1 . `col_int_key`))
WHERE (table1 . `col_int` >=
         (SELECT 5
          FROM DUAL))
  OR (table2 . `col_varchar_20` <> table1 . `col_varchar`
      OR table1 . `col_varchar` != 'p')
ORDER BY field1,
         field2 ;

##简化case
SELECT table1 . `col_varchar` AS field1 
FROM CC AS table1 LEFT  JOIN (CC AS SUBQUERY1_t1, BB AS SUBQUERY1_t2) 
      ON SUBQUERY1_t1 . `col_int_key` = table1 . `col_int_key` 
         and SUBQUERY1_t1 . `col_int_key` > SUBQUERY1_t2 . `pk` 
         and SUBQUERY1_t1 . `col_int_key` = SUBQUERY1_t2 . `pk`;

SELECT /*+no_rewrite*/ table1 . `col_varchar` AS field1 
FROM CC AS table1 LEFT  JOIN (CC AS SUBQUERY1_t1, BB AS SUBQUERY1_t2) 
      ON SUBQUERY1_t1 . `col_int_key` = table1 . `col_int_key` 
         and SUBQUERY1_t1 . `col_int_key` > SUBQUERY1_t2 . `pk` 
         and SUBQUERY1_t1 . `col_int_key` = SUBQUERY1_t2 . `pk`;

DROP TABLE  `cc`;
DROP TABLE  `bb`;

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create table t4(c1 int, c2 int);

explain select count(*)
from 
t1 left join
(t2 left join t3 on t2.c1 = t3.c1
inner join t4 on t2.c2 = t4.c2 and exists(select 1 from t1 where t1.c1 = t2.c2))
on t1.c1 = t2.c1;

explain select /*+parallel(2)*/ count(*)
from 
t1 left join
(t2 left join t3 on t2.c1 = t3.c1
inner join t4 on t2.c2 = t4.c2 and exists(select 1 from t1 where t1.c1 = t2.c2))
on t1.c1 = t2.c1;

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
