--disable_warnings
drop table if exists cool_device_apply_num     ;
drop table if exists cool_mcc_qq_detail        ;
drop table if exists cool_table_roles_fields   ;
drop table if exists int_bit_pk                ;
drop table if exists pk3                       ;
drop table if exists qian_index02              ;
drop table if exists sbjxoaai                  ;
drop table if exists sys_log_temp              ;
drop table if exists t17cngxy                  ;
drop table if exists t18eein7                  ;
drop table if exists t1x3lw8h                  ;
drop table if exists t1xelfsy                  ;
drop table if exists t2c6raex                  ;
drop table if exists t_mon_application_hsm_hour;
drop table if exists t_mon_info                ;
drop table if exists t_sys_role_cmd            ;
drop table if exists t_tinyuintw2l5qo          ;
drop table if exists utf8mb4_test              ;
drop table if exists varbinary_pk              ;
drop table if exists weiyi_index               ;
drop table if exists zuhe_index                ;
--enable_warnings

create table if not exists `sbjxoaai` (
	`a` int(11),
	`b` bigint(20) unsigned,
	`c` datetime,
	`d` year(4),
	`e` varchar(123),
	`f` date,
	`g` time,
	`h` double
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `sys_log_temp` (
  `sys_log_id` char(32) NOT NULL,
  `ip` char(32) DEFAULT NULL,
  `account` char(32) DEFAULT NULL,
  `method` char(8) DEFAULT NULL,
  `path` text,
  `gets` text,
  `posts` text,
  `created_at` int(11) DEFAULT NULL,
  PRIMARY KEY (`sys_log_id`),
  KEY `index_c` (`created_at`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `weiyi_index` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL,
  PRIMARY KEY (`name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

CREATE TABLE `cool_table_roles_fields` (
  `fields_id` int(11) NOT NULL AUTO_INCREMENT,
  `fields` varchar(100) DEFAULT NULL,
  `tableroles_id` int(10) DEFAULT NULL,
  PRIMARY KEY (`fields_id`)
) ENGINE=InnoDB AUTO_INCREMENT=250 DEFAULT CHARSET=utf8;

CREATE TABLE `t_sys_role_cmd` (
  `roleID` int(20) NOT NULL DEFAULT '0' COMMENT '角色标识',
  `cmdID` int(20) NOT NULL DEFAULT '0' COMMENT '命令ID',
  PRIMARY KEY (`roleID`,`cmdID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='命令角色关联表';

CREATE TABLE `cool_device_apply_num` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `apply_id` varchar(255) DEFAULT NULL ,
  `device_model` varchar(50) DEFAULT NULL ,
  `number` smallint(6) DEFAULT NULL ,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=248 DEFAULT CHARSET=utf8 ;

CREATE TABLE `t_mon_info` (
  `monitorID` int(20) NOT NULL AUTO_INCREMENT COMMENT '监控数据ID',
  `hsmUUID` varchar(50) DEFAULT NULL,
  `vsmUUID` varchar(50) DEFAULT NULL,
  `mode` int(11) DEFAULT NULL COMMENT '机器类型',
  `monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '监控时间',
  `memoryUsage` double DEFAULT NULL COMMENT '内存使用率',
  `cpuUsage` double DEFAULT NULL COMMENT 'CPU使用率',
  `inflowSum` double DEFAULT NULL COMMENT '网络流入总量',
  `outflowSum` double DEFAULT NULL COMMENT '网络流出总量',
  `diskTotal` bigint(20) DEFAULT NULL COMMENT '总存储空间',
  `diskUsed` bigint(20) DEFAULT NULL COMMENT '已使用的空间',
  `ioRsecSize` double(11,0) DEFAULT '0' COMMENT 'io读扇区大小',
  `ioWsecSize` double(11,0) DEFAULT '0' COMMENT 'io写扇区大小',
  `load1` double DEFAULT '0' COMMENT '1分钟的平均系统负载',
  `load5` double DEFAULT '0' COMMENT '5分钟的平均系统负载',
  `load15` double DEFAULT '0' COMMENT '15分钟的平均系统负载',
  `processRunning` int(11) DEFAULT '0' COMMENT '运行进程数',
  `tcpEstablished` int(11) DEFAULT '0' COMMENT '已经打开的tcp连接数',
  `encsCount` double DEFAULT NULL COMMENT '加密次数',
  `decsCount` double DEFAULT NULL COMMENT '解密次数',
  `taskcount` double DEFAULT NULL COMMENT '加解密平均次数',
  PRIMARY KEY (`monitorID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='主机监控表';

create table if not exists `t17cngxy` (
	`c1` int(11),
	`c2` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY LIST COLUMNS (c1)
(
	PARTITION `p0` VALUES IN (1,4,5,6,7,8,9,10),
	PARTITION `p1` VALUES IN (2,3),
	PARTITION `p2` VALUES IN (11,12,13,14,15,16,17,18),
	PARTITION `p3` VALUES IN (19,20)
);

create table `varbinary_pk` (
`c01` int(255),
`c02` numeric,
`c03` decimal(10,5),
`c04` bit(64),
`c05` tinyint(255),
`c06` smallint,
`c07` mediumint,
`c08` bigint,
`c09` float(20),
`c10` double,
`c11` varchar(255),
`c12` char(255),
`c13` tinytext,
`c14` mediumtext,
`c15` tinyblob,
`c16` longtext,
`c17` mediumblob,
`c18` longblob,
`c19` binary(255),
`c20` varbinary(255),
`c21` timestamp,
`c22` date,
`c23` time,
`c24` datetime,
`c25` year,
`c26` blob,
 primary key(`c20`));

 insert into varbinary_pk values (01,02,0.13,14,15,16,17,18,2.9,10,'张三','威抄','天文本','中问本','15','长文本','中不','长步','1','20','2017-08-30 11:34:21','2018-09-22','21:41:23','2020-05-14 21:41:24','1995','26');


CREATE TABLE `qian_index02` (
   `id` INT(11) UNSIGNED NOT NULL AUTO_INCREMENT COMMENT '主键',
   `name` VARCHAR(32) NOT NULL COMMENT '姓名',
   `gender` TINYINT(1) NOT NULL COMMENT '性别，0-男，1-女',
   `age` TINYINT(3) NOT NULL DEFAULT '0' COMMENT '年龄',
   `email` VARCHAR(32) NOT NULL DEFAULT '' COMMENT '邮箱',
   `homepage` VARCHAR(128) NOT NULL DEFAULT '' COMMENT '主页',
   `add_time` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '添加时间',
   `update_time` TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT '修改时间',
   PRIMARY KEY (`id`)
 ) ENGINE=INNODB AUTO_INCREMENT=1 DEFAULT CHARSET=utf8;
CREATE INDEX idx_author_email ON qian_index02(email(32));

CREATE TABLE `cool_mcc_qq_detail` (
  `mcc_qq_cate_detail_id` int(10) unsigned NOT NULL AUTO_INCREMENT,
  `mcc_name` varchar(255) DEFAULT NULL,
  `mcc_qq_cate_id` varchar(5) DEFAULT NULL,
  PRIMARY KEY (`mcc_qq_cate_detail_id`)
) ENGINE=InnoDB AUTO_INCREMENT=83 DEFAULT CHARSET=utf8;

create table if not exists `t_tinyuintw2l5qo` (
	`c1` tinyint(1) unsigned not null,
	primary key (`c1`)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY RANGE (c1)
(
	PARTITION `p1` VALUES LESS THAN (0),
	PARTITION `p2` VALUES LESS THAN (255),
	PARTITION `p3` VALUES LESS THAN (256),
	PARTITION `p4` VALUES LESS THAN (2500),
	PARTITION `p5` VALUES LESS THAN (MAXVALUE)
);

create table if not exists `t2c6raex` (
	`c1` int(11),
	`c2` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

create table `pk3` (
`c01` int(255),
`c02` numeric,
`c03` decimal(10,5),
`c04` bit(64),
`c05` tinyint(255),
`c06` smallint,
`c07` mediumint,
`c08` bigint,
`c09` float(20),
`c10` double,
`c11` varchar(255),
`c12` char(255),
`c13` tinytext,
`c14` mediumtext,
`c15` tinyblob,
`c16` longtext,
`c17` mediumblob,
`c18` longblob,
`c19` binary(255),
`c20` varbinary(255),
`c21` timestamp,
`c22` date,
`c23` time,
`c24` datetime,
`c25` year,
`c26` blob,
 primary key(`c01`,`c22`,`c11`));

 insert into pk3 values (01,02,0.13,14,15,16,17,18,2.9,10,'张三','威抄','天文本','中问本','15','长文本','中不','长步','1','20','2017-08-30 11:34:21','2018-09-22','21:41:23','2020-05-14 21:41:24','1995','26');


create table if not exists `t1x3lw8h` (
	`c1` enum('dog','cat'),
	`c2` set('book','notebook')
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `zuhe_index` (
  `name` varchar(20) NOT NULL,
  `age` int(10) NOT NULL,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(10) NOT NULL,
  PRIMARY KEY (`address`),
  KEY `hehe` (`name`,
`age`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ;

create table if not exists `t1xelfsy` (
	`c1` varchar(1),
	`c2` varchar(1),
	`c3` int(11)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;

CREATE TABLE `t_mon_application_hsm_hour` (
  `applicationID` int(11) NOT NULL AUTO_INCREMENT COMMENT 'applicationID',
  `monitorTime` timestamp NULL DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT '监控时间',
  `applicationName` varchar(20) DEFAULT NULL COMMENT '应用名称',
  `encsCount` double DEFAULT NULL COMMENT '加密次数',
  `decsCount` double DEFAULT NULL COMMENT '解密次数',
  `count` double DEFAULT NULL COMMENT '加解密总次数',
  `hsmUUID` varchar(50) DEFAULT NULL,
  `vsmUUID` varchar(50) DEFAULT NULL,
  PRIMARY KEY (`applicationID`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8;

CREATE TABLE `utf8mb4_test` (
  `name` varchar(20) NOT NULL,
  `age` int(11) NOT NULL AUTO_INCREMENT,
  `address` varchar(20) NOT NULL,
  `sex` float NOT NULL,
  `class` int(11) NOT NULL,
  PRIMARY KEY (`age`)
) DEFAULT CHARSET = utf8mb4 ;

create table `int_bit_pk` (
`c01` int(255),
`c02` numeric,
`c03` decimal(10,5),
`c04` bit(64),
`c05` tinyint(255),
`c06` smallint,
`c07` mediumint,
`c08` bigint,
`c09` float(20),
`c10` double,
`c11` varchar(255),
`c12` char(255),
`c13` tinytext,
`c14` mediumtext,
`c15` tinyblob,
`c16` longtext,
`c17` mediumblob,
`c18` longblob,
`c19` binary(255),
`c20` varbinary(255),
`c21` timestamp,
`c22` date,
`c23` time,
`c24` datetime,
`c25` year,
`c26` blob,
 primary key(`c01`,`c04`));

 insert into int_bit_pk values (01,02,0.13,14,15,16,17,18,2.9,10,'张三','威抄','天文本','中问本','15','长文本','中不','长步','1','20','2017-08-30 11:34:21','2018-09-22','21:41:23','2020-05-14 21:41:24','1995','26');

create table if not exists `t18eein7` (
	`num` int(11),
	`str` varchar(50)
)
default charset=utf8mb4
default collate=utf8mb4_general_ci;
--result_format 4
--explain_protocol 2

select 
  sum(
    cast(66 as DECIMAL)
  ) over (
    partition by ref_11.c10 
    order by 
      ref_12.c1
  ) as c1
from 
  (
    (
      (
        (
          (
            (
              test.weiyi_index as ref_1 
              right join test.cool_table_roles_fields as ref_2 on (
                ref_2.fields_id + ref_2.fields_id
              )
            )
          ) 
        ) 
        right join (
          (
            test.cool_mcc_qq_detail as ref_8
            inner join test.t_tinyuintw2l5qo as ref_9 on 1 = 1
          ) 
          right join test.pk3 as ref_11 on (0)
        ) on (ref_9.c1 >> ref_1.class)
      ) 
      left join (
        test.t1x3lw8h as ref_12 
        inner join test.zuhe_index as ref_13 on 1
      ) on (
        ref_8.mcc_qq_cate_detail_id = ref_13.age
      )
    ) 
    left join (
      (
        test.t1xelfsy as ref_14 
        inner join test.t_mon_application_hsm_hour as ref_15 on 1
      ) 
      left join test.utf8mb4_test as ref_16 on (
        ref_14.c3 
        AND ref_15.applicationID
      )
    ) on (
      EXISTS (
        select 
          1 
        from 
          test.int_bit_pk as ref_17 
        where 
          ref_11.c08 < ref_2.tableroles_id 
        limit 
          92
      )
    )
  );

--disable_warnings
