--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, index i1(c2));

--disable_query_log
--disable_result_log
insert into t1 values (1, 1, 1);
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select /*+index(t1 i1)*/ c2 from t1 where ora_rowscn > 0 order by c2;