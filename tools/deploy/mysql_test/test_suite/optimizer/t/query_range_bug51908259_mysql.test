create table t1 (c1 int, c2 int, c3 int, primary key(c1));
insert into t1 value (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10);

--explain_protocol 2
set ob_enable_plan_cache = false;
# 完整case
select * from table1000 where col_int in (5,9) or col_int in ('jthp',7,2,6,5,NULL) and col_int not in (7,8,5,4,6) order by 1,2,3,4,5,6;
#简化case
select * from t1 where (c1 in (5,6,7) and c1 < '7') or (c1 = '1' and c1 in (1,2,3));
select * from t1 where c1 in (5,6,7) or (c1 = '1' and c1 < 10);
select * from t1 where (c1 = '1' and c1 < 10) or c1 in (5,6,7);

set ob_enable_plan_cache = true;
# 完整case
select * from table1000 where col_int in (5,9) or col_int in ('jthp',7,2,6,5,NULL) and col_int not in (7,8,5,4,6) order by 1,2,3,4,5,6;
#简化case
select * from t1 where (c1 in (5,6,7) and c1 < '7') or (c1 = '1' and c1 in (1,2,3));
select * from t1 where c1 in (5,6,7) or (c1 = '1' and c1 < 10);
select * from t1 where (c1 = '1' and c1 < 10) or c1 in (5,6,7);

DROP TABLE table1000,t1;
