--disable_warnings
DROP TABLE if exists table1000,t1;
--enable_warnings
--result_format 4

CREATE TABLE table1000 (
pk int not null,
col_double double,
col_float float,
col_smallint smallint,
col_bigint bigint,
col_int int,
/*Indices*/
primary key (pk) )    ;
create index idx62 on table1000 (col_int);
