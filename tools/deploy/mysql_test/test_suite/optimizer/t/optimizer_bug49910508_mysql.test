#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(a int, b int) partition by hash(a) partitions 1;
create table t2(a int, b int) partition by hash(a) partitions 8;
insert into t1 values (1,1);
insert into t1 values (2,2);
insert into t2 values (1,1);
insert into t2 values (4,4);

--result_format 4
--explain_protocol 2

SELECT /*+ parallel(t2, 2) leading(t2 t1) */ * FROM t1 LEFT JOIN t2 ON t1.a=t2.a where t2.a < 3;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
