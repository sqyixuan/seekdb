# owner: yibo.tyf
# owner group: SQL1
# tags: optimizer
## test for row in query range

--disable_warnings
drop table if exists t1;
--enable_warnings
--explain_protocol 0
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key(c1, c2, c3, c4, c5, c6));
insert into t1 values (1, 1, 1, 4, 5, 6, 7);
insert into t1 values (1, 2, 1, 4, 5, 6, 7);
insert into t1 values (1, 3, 1, 4, 5, 6, 7);
insert into t1 values (2, 1, 1, 4, 5, 6, 7);
insert into t1 values (2, 2, 1, 4, 5, 6, 7);
insert into t1 values (2, 3, 1, 4, 5, 6, 7);
insert into t1 values (3, 1, 1, 4, 5, 6, 7);
insert into t1 values (3, 2, 1, 4, 5, 6, 7);
insert into t1 values (3, 3, 1, 4, 5, 6, 7);
--result_format 4
--explain_protocol 2
--echo cases that enable in optimization when contain row in
select * from t1 where (c1+1,c2+1) in ((1,2),(1,3),(3,4)) and c1 in (1,2,3);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c3 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c3 in (1,2,3,4);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c3 in (1,2,3,4) and c4 in (4,5,6);
select * from t1 where (c1,c2,c3) in ((1,2,1),(1,3,1),(3,4,4));
select * from t1 where (c1,c2,c3) in ((1,2,1),(1,3,1),(3,4,4)) and c4 >= 0;
select * from t1 where (c1,c2,c3) in ((1,2,1),(1,3,1),(3,4,4)) and c4 in (1,2,3,4);
select * from t1 where (c1,c2,c3,c4) in ((1,2,1,4),(1,3,1,5));

select * from t1 where c1 = 1 and (c2,c3) in ((2,1),(3,1),(3,4));
select * from t1 where c1 >= 0 and (c2,c3) in ((2,1),(3,1),(3,4));
select * from t1 where c1 in (1,2,3,4) and (c2,c3) in ((2,1),(3,1),(3,4));
select * from t1 where c1 = 1 and c2 = 1 and (c3,c4) in ((1,4),(1,5));
select * from t1 where c1 = 1 and c2 >= 0 and (c3,c4) in ((1,4),(1,5));
select * from t1 where c1 = 1 and c2 in (1,2,3) and (c3,c4) in ((1,4),(1,5));
select * from t1 where c1 in (1,2,3) and c2 in (1,2,3) and (c3,c4) in ((1,4),(1,5));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c3 = 1 or c3 in (2,3,4));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c3,c4) in ((1,4),(1,5));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c3,c4) in ((1,4),(1,5)) and c5 > 0;

select * from t1 where (c1 = 1 or c1 = 3) and (c2,c3) in ((2,1),(3,1),(3,4));
select * from t1 where (c1 = 1 or c1 = 3) and (c2,c3) in ((2,1),(3,1),(3,4)) and c4 >= 0;
select * from t1 where (c1 = 1 or c1 in (2,3)) and (c2,c3) in ((2,1),(3,1),(3,4));
select * from t1 where (c1 = 1 or c1 in (2,3)) and (c2,c3) in ((2,1),(3,1),(3,4)) and c4 >= 0;
select * from t1 where (c1 = 1 or c1 >= 2) and (c2,c3) in ((2,1),(3,1),(3,4)) and c4 >= 0;

--echo cases that disable in optimization when contain row in
select * from t1 where (c1,1) in ((1,1),(1,3),(3,4));
select * from t1 where (c1,c7) in ((1,7),(2,7),(3,8));
select * from t1 where (c1,c2+1) in ((1,1),(1,3),(3,4));
select * from t1 where (c1,c1) in ((1,1),(2,2),(3,4));
select * from t1 where (c1,c3) in ((1,1),(1,3),(3,4));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c1 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c2 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c1 in (1,2,3);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and c2 in (1,2,3);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c1,c3) in ((1,1),(1,3));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) or c1 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) or c2 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) or c3 > 0;
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) or c1 in (1,2,3);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) or c2 in (1,2,3);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c1 = 1 or c1 = 2);
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c1 = 1 or c1 in (2,3,4));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and (c2 = 1 or c2 in (2,3,4));
select * from t1 where (c1,c2) in ((1,2),(1,3),(3,4)) and ((c3,c4) in ((1,4),(1,5)) or c3 > 2);

--explain_protocol 0
--disable_warnings
drop table if exists t1;
--enable_warnings
