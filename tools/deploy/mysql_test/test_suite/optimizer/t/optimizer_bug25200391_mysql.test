--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
# tags: optimizer
alter system set ob_enable_batched_multi_statement = 'True';

--disable_warnings
--error 0, 942
drop table if exists t1;
--enable_warnings

create table t1(a int auto_increment, b int, c int) partition by hash(b) partitions 4;

--explain_protocol 2
--result_format 4
insert into t1 values (1,1,1),(2,2,2),(3,3,3);

alter system set ob_enable_batched_multi_statement = 'False';

--disable_warnings
--error 0, 942
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);
create table t3(c1 int, c2 int);
create table t4(c3 int);
create table t5(c1 int);
create table t6(c1 int);

explain SELECT /*+leading(ref_0 ((ref_2 (ref_4 ref_3)) ref_1))*/ 1
FROM  t1 AS ref_0
      LEFT JOIN 
      (t2 AS ref_1
        RIGHT JOIN (t3 AS ref_2
                    inner JOIN (t4 AS ref_3
                    RIGHT JOIN t5 AS ef_4
                            ON 1 =1 )
                            ON EXISTS (SELECT 1
                                         FROM   t6
                                         WHERE  ref_3.c3 IS NULL
                                         LIMIT  113))
                            ON 1=1)
      ON ref_2.c2 >= ref_2.c1;

SELECT /*+leading(ref_0 ((ref_2 (ref_4 ref_3)) ref_1))*/ 1
FROM  t1 AS ref_0
      LEFT JOIN 
      (t2 AS ref_1
        RIGHT JOIN (t3 AS ref_2
                    inner JOIN (t4 AS ref_3
                    RIGHT JOIN t5 AS ef_4
                            ON 1 =1 )
                            ON EXISTS (SELECT 1
                                         FROM   t6
                                         WHERE  ref_3.c3 IS NULL
                                         LIMIT  113))
                            ON 1=1)
      ON ref_2.c2 >= ref_2.c1;

--disable_warnings
--error 0, 942
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

create table t1(c1 int ,c2 int, c3 int);
create index t1_i1 on t1(c1,c2);
select /*+index(t1 t1_i1)*/ * from t1 order by c1,c2,c3 limit 10000000000;