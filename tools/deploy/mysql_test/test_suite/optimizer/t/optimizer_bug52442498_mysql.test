--disable_warnings
drop table if exists `v_rms_rsk_device_log`;
--enable_warnings

CREATE TABLE `v_rms_rsk_device_log` (
  `RSK_LOG_ID` char(19) NOT NULL,
  `MOBILE_NO` varchar(15) NOT NULL,
  `CUST_NO` char(20) DEFAULT NULL,
  `EVENT_TYPE` char(100) DEFAULT NULL,
  `SCENE_TYPE` char(100) DEFAULT NULL,
  `DEVICE_ID` varchar(100) DEFAULT NULL,
  `DEVICE_UNIQUE_ID` varchar(2000) NOT NULL,
  `MAC` varchar(48) DEFAULT NULL,
  `IMEI` varchar(50) DEFAULT NULL,
  `SUBSCRIBER_ID` varchar(200) DEFAULT NULL,
  `SERIAL_NO` varchar(200) DEFAULT NULL,
  `SIM_SERIAL` varchar(200) DEFAULT NULL,
  `PRODUCT` varchar(100) DEFAULT NULL,
  `CPU_TYPE` varchar(100) DEFAULT NULL,
  `CPU_SPEED` varchar(100) DEFAULT NULL,
  `CPU_HARDWARE` varchar(100) DEFAULT NULL,
  `CPU_SERIAL` varchar(100) DEFAULT NULL,
  `CPU_ABI` varchar(100) DEFAULT NULL,
  `TOTAL_STORAGE` varchar(100) DEFAULT NULL,
  `TOTAL_MEMORY` varchar(100) DEFAULT NULL,
  `HARDWARE` varchar(100) DEFAULT NULL,
  `HOST` varchar(100) DEFAULT NULL,
  `TAGS` varchar(100) DEFAULT NULL,
  `BRAND` varchar(100) DEFAULT NULL,
  `RO_DEVICE` varchar(100) DEFAULT NULL,
  `RO_MODEL` varchar(100) DEFAULT NULL,
  `RO_NAME` varchar(100) DEFAULT NULL,
  `BLACK_BOX` varchar(3000) NOT NULL,
  `INTRANEL_IP` varchar(32) DEFAULT NULL,
  `SMART_ID` varchar(20) DEFAULT NULL,
  `IP` varchar(32) DEFAULT NULL,
  `GPS_ADDRESS` varchar(300) DEFAULT NULL,
  `LONGI_TUDE` double DEFAULT NULL,
  `LATI_TUDE` double DEFAULT NULL,
  `USER_AGENT_CUST` varchar(2000) DEFAULT NULL,
  `REFER_CUST` varchar(1000) DEFAULT NULL,
  `PHONE_OPERATOR` varchar(100) DEFAULT NULL,
  `PHONE_MARKER` varchar(100) DEFAULT NULL,
  `PHONE_MODEL` varchar(100) DEFAULT NULL,
  `SIM_MOBILE_NO` varchar(20) DEFAULT NULL,
  `COMPUTER_HOST` varchar(100) DEFAULT NULL,
  `OPERATION_SYS` varchar(20) DEFAULT NULL,
  `OPERATION_SYS_VERSION` varchar(100) DEFAULT NULL,
  `RESOLUTION` varchar(20) DEFAULT NULL,
  `FONT` varchar(40) DEFAULT NULL,
  `FONT_SIZE` varchar(20) DEFAULT NULL,
  `BROWSER_TYPE` varchar(30) DEFAULT NULL,
  `BROWSER_VERSION` varchar(30) DEFAULT NULL,
  `IS_EMULATOR` char(10) DEFAULT NULL,
  `EQUIPMENT_CODE` varchar(2000) DEFAULT NULL,
  `MCC` varchar(50) DEFAULT NULL,
  `MNC` varchar(50) DEFAULT NULL,
  `CID` varchar(50) DEFAULT NULL,
  `LAC` varchar(50) DEFAULT NULL,
  `CREATE_DATE` decimal(8,0) DEFAULT NULL,
  `CREATE_TIME` char(6) DEFAULT NULL,
  `UPDATE_DATE` decimal(8,0) DEFAULT NULL,
  `UPDATE_TIME` char(6) DEFAULT NULL,
  `CREATE_DATETIME` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `UPDATE_DATETIME` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`MOBILE_NO`, `RSK_LOG_ID`),
  KEY `IDX_CUST_NO` (`CUST_NO`) BLOCK_SIZE 16384 GLOBAL
) partition by key(`mobile_no`)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7);

