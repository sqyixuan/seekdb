--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int primary key, b int, c int, d int, index k1(b) storing (c));
## all the data are in memory
--disable_query_log
--let $count = 0
while($count < 500)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, $count+1, $count+2, $count+3)
  eval $stmt;
  inc $count;
}
--enable_query_log
--disable_query_log
--let $count = 500
while($count < 1000)
{
  --let $stmt=insert into t1(a, b, c, d) values ($count, $count+1, $count+2, $count+3)
  eval $stmt;
  inc $count;
}
--enable_query_log

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 't1');

explain  select/*+index(t1 k1)*/ * from t1 where t1.b < 300 and t1.c > 200 and t1.d < 500 order by a;
select/*+index(t1 k1)*/ * from t1 where t1.b < 300 and t1.c > 200 and t1.d < 500 order by a;
select/*+index(t1 primary)*/ * from t1 where t1.b < 300 and t1.c > 200 and t1.d < 500 order by a;
explain  select/*+index(t1 k1)*/ * from t1 where t1.b + t1.c > 200 and t1.d < 300 order by a;
select/*+index(t1 k1)*/ * from t1 where t1.b + t1.c > 200 and t1.d < 300 order by a;
select/*+index(t1 primary)*/ * from t1 where t1.b + t1.c > 200 and t1.d < 300 order by a;
explain  select/*+index(t1 k1)*/ * from t1 where t1.b + t1.d > 200 and t1.d < 300 order by a;
select/*+index(t1 k1)*/ * from t1 where t1.b + t1.d > 200 and t1.d < 300 order by a;
select/*+index(t1 primary)*/ * from t1 where t1.b + t1.d > 200 and t1.d < 300 order by a;
explain  select/*+index(t1 k1)*/ * from t1 where t1.c + t1.d > 200 and t1.d < 300 order by a;
select/*+index(t1 k1)*/ * from t1 where t1.c + t1.d > 200 and t1.d < 300 order by a;
select/*+index(t1 primary)*/ * from t1 where t1.c + t1.d > 200 and t1.d < 300 order by a;
