--disable_warnings
drop table if exists tsc_stock, tsc_secfrozenitem, tdd_khxx;
drop sequence if exists sequence_5579;
drop function if exists SEQ_NEXTVAL;
--enable_warnings
# 查询初始值，case 结尾要还原
select name, value from oceanbase.V$OB_PARAMETERS where name like '%enable_var_assign_use_das';

CREATE TABLE `tsc_stock` (
  `client_id` varchar(12) COLLATE utf8mb4_bin NOT NULL,
  `wealth_account` char(5) COLLATE utf8mb4_bin NOT NULL DEFAULT '00000',
  `client_name` varchar(36) COLLATE utf8mb4_bin NOT NULL,
  `branch_no` varchar(4) COLLATE utf8mb4_bin NOT NULL,
  `market` char(2) COLLATE utf8mb4_bin NOT NULL,
  `stock_account` char(10) COLLATE utf8mb4_bin NOT NULL,
  `circulate_type` char(1) COLLATE utf8mb4_bin NOT NULL COMMENT 'TXTDM.FLDM=LTLX   0  非流通，1  流通',
  `stock_code` varchar(10) COLLATE utf8mb4_bin NOT NULL,
  `trust_seat` varchar(6) COLLATE utf8mb4_bin NOT NULL,
  `stock_attr` varchar(9) COLLATE utf8mb4_bin NOT NULL COMMENT 'TXTDM.FLDM=GFXZ 流通股为00，上海限售股为:  证券类别+流通类型+挂牌年份',
  `stock_name` varchar(36) COLLATE utf8mb4_bin NOT NULL,
  `stock_type` char(2) COLLATE utf8mb4_bin NOT NULL,
  `currency` char(3) COLLATE utf8mb4_bin NOT NULL COMMENT 'TXTDM.FLDM=BZ',
  `begin_qty` bigint(20) NOT NULL DEFAULT '0',
  `hold_qty` bigint(20) NOT NULL,
  `frozen_qty` bigint(20) NOT NULL,
  `other_frozen_qty` bigint(20) NOT NULL,
  `buy_unsett_qty` bigint(20) NOT NULL DEFAULT '0',
  `sell_unsett_qty` bigint(20) NOT NULL DEFAULT '0',
  `last_value` decimal(16,2) NOT NULL,
  `entrust_buy_qty` bigint(20) NOT NULL DEFAULT '0',
  `entrust_frozen_qty` bigint(20) NOT NULL DEFAULT '0',
  `buy_deal_qty` bigint(20) NOT NULL DEFAULT '0',
  `buy_deal_frozen_qty` bigint(20) NOT NULL DEFAULT '0',
  `purs_deal_qty` bigint(20) NOT NULL DEFAULT '0',
  `purs_deal_frozen_qty` bigint(20) NOT NULL DEFAULT '0' COMMENT '对ETF来说,指卖出委托数量可以被申购成交抵消的数量;\r\n            对股票来说，指卖出委托数量可以被赎回成交抵消的数量；',
  `sell_deal_qty` bigint(20) NOT NULL DEFAULT '0',
  `redp_deal_qty` bigint(20) NOT NULL DEFAULT '0',
  `redp_deal_frozen_qty` bigint(20) NOT NULL DEFAULT '0' COMMENT '对ETF来说,指赎回委托数量（记在卖出委托数量中）可以被买入成交抵消的数量;\r\n            对股票来说，指申购委托数量（记在卖出委托数量中）可以被买入成交抵消的数量；',
  `merge_split_deal_qty` bigint(20) NOT NULL DEFAULT '0',
  `merge_split_frozen_qty` bigint(20) NOT NULL DEFAULT '0',
   `other_deal_qty` bigint(20) NOT NULL DEFAULT '0' COMMENT '预留其他来源成交数量',
  `other_deal_frozen_qty` bigint(20) NOT NULL DEFAULT '0' COMMENT '预留其他来源成交冻结',
  `yest_purs_qty` bigint(20) NOT NULL COMMENT '分级基金T-1日申购未到账数量(不参与市值计算),仅用于盲拆',
  `yest_purs_frozen_qty` bigint(20) NOT NULL,
  `begin_pled_qty` bigint(20) NOT NULL COMMENT '日结时入库数量已经从ZQSL扣除,移到此字段方便市值计算',
  `buy_deal_amt` decimal(16,2) NOT NULL DEFAULT '0.00',
  `sell_deal_amt` decimal(16,2) NOT NULL DEFAULT '0.00',
  `open_date` int(11) NOT NULL,
  `modi_date` int(11) NOT NULL,
  `sum_buy_amt` decimal(16,2) NOT NULL COMMENT '包含手续费, 用来计算摊薄成本',
  `sum_buy_qty` bigint(20) NOT NULL,
  `sum_sell_amt` decimal(16,2) NOT NULL COMMENT '包含手续费, 用来计算摊薄成本',
  `sum_sell_qty` bigint(20) NOT NULL,
  `hold_cost` decimal(16,2) NOT NULL COMMENT '非摊薄成本，预留，暂不使用，系统只支持摊薄成本、买入均价',
  `sum_profit` decimal(16,2) NOT NULL,
  `fund_account` varchar(30) COLLATE utf8mb4_bin NOT NULL DEFAULT '',
  PRIMARY KEY (`client_id`, `wealth_account`, `market`, `stock_account`, `circulate_type`, `stock_code`, `trust_seat`, `stock_attr`),
  KEY `iZQGL_JYS_ZQDM` (`market`, `stock_code`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(client_id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`,
partition `p10`,
partition `p11`,
partition `p12`,
partition `p13`,
partition `p14`,
partition `p15`,
partition `p16`,
partition `p17`,
partition `p18`,
partition `p19`,
partition `p20`,
partition `p21`,
partition `p22`,
partition `p23`,
partition `p24`,
partition `p25`,
partition `p26`,
partition `p27`,
partition `p28`,
partition `p29`);


CREATE TABLE `tsc_secfrozenitem` (
  `branch_no` varchar(4) COLLATE utf8mb4_bin NOT NULL DEFAULT '',
  `serial_no` char(20) COLLATE utf8mb4_bin NOT NULL,
  `client_id` varchar(12) COLLATE utf8mb4_bin NOT NULL,
  `wealth_account` char(5) COLLATE utf8mb4_bin NOT NULL DEFAULT '00000',
  `market` char(2) COLLATE utf8mb4_bin NOT NULL,
  `stock_account` char(10) COLLATE utf8mb4_bin NOT NULL,
  `stock_code` varchar(10) COLLATE utf8mb4_bin NOT NULL,
  `circulate_type` char(1) COLLATE utf8mb4_bin NOT NULL COMMENT 'TXTDM.FLDM=LTLX   0  非流通，1  流通',
  `stock_attr` varchar(9) COLLATE utf8mb4_bin NOT NULL COMMENT 'TXTDM.FLDM=GFXZ 流通股为00，上海限售股为:  证券类别+流通类型+挂牌年份',
  `trust_seat` varchar(6) COLLATE utf8mb4_bin NOT NULL,
  `trade_date` int(11) NOT NULL,
  `occur_date` int(11) NOT NULL,
  `occur_time` varchar(12) COLLATE utf8mb4_bin NOT NULL,
  `frozen_type` int(11) NOT NULL COMMENT 'TXTDM.FLDM=GFDJLB',
  `occur_qty` bigint(20) NOT NULL,
  `withdraw_flag` int(11) NOT NULL COMMENT 'TXTDM.FLDM=CXBZ',
  `valid_date` int(11) NOT NULL COMMENT '0表示长期冻结',
  `buy_deal_frozen_qty` bigint(20) NOT NULL,
  `purs_deal_frozen_qty` bigint(20) NOT NULL,
  `redp_deal_frozen_qty` bigint(20) NOT NULL,
  `begin_frozen_qty` bigint(20) NOT NULL,
  `merge_split_frozen_qty` bigint(20) NOT NULL,
  `yest_purs_frozen_qty` bigint(20) NOT NULL,
  `other_deal_frozen_qty` bigint(20) NOT NULL,
  `busi_serial_no` varchar(40) COLLATE utf8mb4_bin DEFAULT NULL,
  `frozen_reason` char(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '冻结原因',
  `remark` varchar(80) COLLATE utf8mb4_bin DEFAULT NULL,
  PRIMARY KEY (`serial_no`, `client_id`, `market`, `stock_code`, `circulate_type`, `stock_attr`, `trust_seat`),
  KEY `IZQDJXMMX_KHH` (`client_id`, `withdraw_flag`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(client_id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`,
partition `p8`,
partition `p9`,
partition `p10`,
partition `p11`,
partition `p12`,
partition `p13`,
partition `p14`,
partition `p15`,
partition `p16`,
partition `p17`,
partition `p18`,
partition `p19`,
partition `p20`,
partition `p21`,
partition `p22`,
partition `p23`,
partition `p24`,
partition `p25`,
partition `p26`,
partition `p27`,
partition `p28`,
partition `p29`);

CREATE TABLE `tdd_khxx` (
  `khh` varchar(12) COLLATE utf8mb4_bin NOT NULL COMMENT '客户号',
  `XTLX` int(9) NOT NULL DEFAULT '0',
  `JDBH` int(11) DEFAULT NULL,
  PRIMARY KEY (`khh`, `XTLX`)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(`khh`)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`);


SELECT
  A .branch_no,
  concat(
    '20240321',
    curtime() + 0,
    lpad(@rownum := @rownum + 1, 6, '0')
  ) AS serial_no,
  A .client_id,
  '00000' wealth_account,
  A .market,
  A .stock_account,
  A .stock_code,
  A .circulate_type,
  A .stock_attr,
  A .trust_seat,
  '20240321' trade_date,
  '20240321' occur_date,
  '00:00:00' occur_time,
  3 frozen_type,
  0 AS occur_qty,
  0 withdraw_flag,
  30000101 valid_date,
  0 buy_deal_frozen_qty,
  0 purs_deal_frozen_qty,
  0 redp_deal_frozen_qty,
  0 begin_frozen_qty,
  0 merge_split_frozen_qty,
  0 yest_purs_frozen_qty,
  A .other_frozen_qty - ifnull(b.frozen_qty, 0) other_deal_frozen_qty,
  '' busi_serial_no,
  '0' frozen_reason,
  '迁移补冻结' remark
FROM
  tsc_stock A
  LEFT JOIN (
    SELECT
      /*+ merge no_PLACE_GROUP_BY */
      x.client_id,
      x.wealth_account,
      x.market,
      x.stock_account,
      x.trust_seat,
      x.circulate_type,
      x.stock_attr,
      x.stock_code,
      SUM(other_deal_frozen_qty) AS frozen_qty
    FROM
      tsc_secfrozenitem x,
      tdd_khxx y
    WHERE
      frozen_type = 3
      AND withdraw_flag < 2
      AND x.client_id = y.khh
      AND y.xtlx = 4
    GROUP BY
      x.client_id,
      x.wealth_account,
      x.market,
      x.stock_account,
      x.trust_seat,
      x.circulate_type,
      x.stock_attr,
      x.stock_code
  ) B ON A .client_id = B.client_id
  AND A .wealth_account = B.wealth_account
  AND A .market = B.market
  AND A .stock_account = B.stock_account
  AND A .trust_seat = B.trust_seat
  AND A .circulate_type = B.circulate_type
  AND A .stock_attr = B.stock_attr
  AND A .stock_code = B.stock_code,
  tdd_khxx C,
(
    SELECT
      @rownum := 0
  ) t
WHERE
  A .other_frozen_qty > 0
  AND A .client_id = C .khh
  AND C .xtlx = 4
  AND A .frozen_qty <> ifnull(b.frozen_qty, 0);

alter system flush plan cache global;
set @a:=0;
select @a:=@a+1;
set @a:=0;
select @a from (select @a:=@a+1) v;
set @a:=0;
select @a, (select @a:=@a+1);
set @a:=0;
set @b:=0;
select @a, @b from (select @a:=@b+1, @b:=@a+1) v;
set @a:=0;
set @b:=0;
select @a, @b from (select @a:=@b+1) v where 1=0;
select @a, @b;
explain basic select @a, @b from (select @a:=@b+1) v where 1=0;

alter system set _enable_var_assign_use_das = false;
sleep 5;
select name, value from oceanbase.V$OB_PARAMETERS where name like '%enable_var_assign_use_das';
alter system flush plan cache global;
set @a:=0;
select @a:=@a+1;
set @a:=0;
select @a from (select @a:=@a+1) v;
set @a:=0;
select @a, (select @a:=@a+1);
set @a:=0;
set @b:=0;
select @a, @b from (select @a:=@b+1, @b:=@a+1) v;
set @a:=0;
set @b:=0;
select @a, @b from (select @a:=@b+1) v where 1=0;
--echo 这个 case 结果跟 MySQL 是不兼容的，MySQL 的视图 V 会执行一次
select @a, @b;
explain basic select @a, @b from (select @a:=@b+1) v where 1=0;

alter system set _enable_var_assign_use_das = true;

# bug:2025010200106795478
create sequence sequence_5579 start with 1 increment by 1 minvalue 1 maxvalue 100000 cache 1000 nocycle;
delimiter //;
create function SEQ_NEXTVAL  (seq_name varchar(128)) returns int(11) BEGIN
DECLARE result INT DEFAULT 0;
IF seq_name = 'sequence_5579' THEN
SELECT sequence_5579.nextval INTO result;
END IF;
RETURN result;
END;
//

delimiter ;//

select @ret_seqno:=seq_nextval('sequence_5579');
select * from (select /*+no_merge*/ @ret_seqno:=seq_nextval('sequence_5579'));

drop table tsc_stock, tsc_secfrozenitem, tdd_khxx;