#owner: wuyuming.wym
#owner group: sql1
# tags: optimizer

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

create table t1(pk int, c1 int, c2 int, c3 int);
create table t2(pk int, c1 int, c2 int, c3 int);
create table t3(pk int, c1 int, c2 int, c3 int);
create table t4(pk int, c1 int, c2 int, c3 int, primary key(c1, c2));
create table t5(pk int, c1 int, c2 int, c3 int, foreign key(c1, c2) references t4(c1, c2));
create table t6(pk int, c1 int, c2 int, c3 int);


insert into t1 select v1.id, v1.n % 100, v2.n % 200, v3.n % 300 from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(1000)) order by rand(1))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(1000)) order by rand(2))) v2,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(1000)) order by rand(3))) v3
where v1.id=v2.id and v2.id=v3.id;

insert into t2 select v1.id, v1.n % 100, v2.n % 200, v3.n % 300 from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(2000)) order by rand(4))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(2000)) order by rand(5))) v2,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(2000)) order by rand(6))) v3
where v1.id=v2.id and v2.id=v3.id;

insert into t3 select v1.id, v1.n % 100, v2.n % 200, v3.n % 300 from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(3000)) order by rand(7))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(3000)) order by rand(8))) v2,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(3000)) order by rand(9))) v3
where v1.id=v2.id and v2.id=v3.id;

insert into t4 select v1.id, v1.n % 1000, v1.n % 1000, v2.n % 100 from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(1000)) order by rand(10))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(1000)) order by rand(11))) v2
where v1.id=v2.id;

insert into t5 select v1.id, v1.n % 1000, v1.n % 1000, v2.n % 100 from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(10000)) order by rand(12))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(10000)) order by rand(13))) v2
where v1.id=v2.id;

insert into t5 select n + 10000, null, n % 1000, n % 100 from (select row_number() over () as n from table(generator(10000)));

insert into t6 select v1.id, case when v1.n > 5000 then null else v1.n % 1000 end, case when v2.n > 5000 then null else v2.n % 1000 end, null from
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(10000)) order by rand(10))) v1,
(select row_number() over () as id, n from (select row_number() over () as n from table(generator(10000)) order by rand(11))) v2
where v1.id=v2.id;

set ob_query_timeout = 10000000000;

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1');
call dbms_stats.gather_table_stats(null, 't2');
call dbms_stats.gather_table_stats(null, 't3');
call dbms_stats.gather_table_stats(null, 't4');
call dbms_stats.gather_table_stats(null, 't5');
call dbms_stats.gather_table_stats(null, 't6');

--enable_query_log

--result_format 4
--explain_protocol 2

# test ambient cardinality for join between two tables
select count(*) from (select distinct t1.pk from t1, t2 where t1.c2 = t2.c1);
select count(*) from (select distinct t1.pk from t1, t2 where t1.c1 = t2.c2);
select count(*) from (select distinct t1.pk from t1, t2 where t1.c2 = t2.c1 and t2.c2 < 200);
select count(*) from (select distinct t1.pk from t1, t2 where t1.c1 = t2.c2 and t1.c2 < 200);
select count(*) from (select distinct t1.pk as c1, t2.pk as c2 from t1, t2 where t1.c1 = t2.c2);
select count(*) from (select distinct t1.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2);
select count(*) from (select distinct t1.pk from t1 where exists (select 1 from t2 where t2.c1 = t1.c2));
select count(*) from (select distinct t1.pk from t1 where not exists (select 1 from t2 where t2.c1 = t1.c2));
select count(*) from (select distinct t1.pk from t1 where exists (select 1 from t2 where t2.c2 = t1.c1));
select count(*) from (select distinct t1.pk from t1 where not exists (select 1 from t2 where t2.c2 = t1.c1));
select count(*) from (select distinct t1.pk from t1 left join t2 on t1.c1 = t2.c2);
select count(*) from (select distinct t1.pk from t1 left join t2 on t1.c1 = t2.c2 where t1.c2 <=> t2.c3);
select count(*) from (select distinct t1.pk from t1 left join t2 on t1.c1 = t2.c2 where t1.c3 <=> t2.c2);
select count(*) from (select distinct t1.pk from t1 right join t2 on t1.c1 = t2.c2);
select count(*) from (select distinct t1.pk from t1 right join t2 on t1.c1 = t2.c2 where t1.c2 <=> t2.c3);
select count(*) from (select distinct t1.pk from t1 right join t2 on t1.c1 = t2.c2 where t1.c3 <=> t2.c2);
select count(*) from (select distinct t1.pk from t1 full join t2 on t1.c1 = t2.c2);
select count(*) from (select distinct t1.pk from t1 full join t2 on t1.c1 = t2.c2 where t1.c2 <=> t2.c3);
select count(*) from (select distinct t1.pk from t1 full join t2 on t1.c1 = t2.c2 where t1.c3 <=> t2.c2);
select count(*) from (select distinct t1.pk from t1 where not exists (select 1 from t2 where t2.c1 = t1.c3));

# test ambient cardinality for join between three tables
select count(*) from (select /*+leading((t1 t2) t3)*/ distinct t3.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2);
select count(*) from (select /*+leading((t2 t3) t1)*/ distinct t3.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2);
explain select count(*) from (select /*+leading((t1 t3) t2)*/ distinct t3.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2);
select count(*) from (select /*+leading((t1 t2) t3)*/ distinct t2.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c3 = t3.c2);
select count(*) from (select /*+leading((t2 t3) t1)*/ distinct t2.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c3 = t3.c2);
select count(*) from (select /*+leading((t1 t3) t2)*/ distinct t2.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c3 = t3.c2);
select count(*) from (select /*+leading((t1 t2) t3)*/ distinct t2.pk from t1, t2, t3 where t1.c1 = t3.c1 and t2.c2 = t3.c2);
select count(*) from (select /*+leading((t1 t2) t3)*/ distinct t1.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2 and t3.c1 = t1.c2);
select count(*) from (select /*+leading((t2 t3) t1)*/ distinct t1.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2 and t3.c1 = t1.c2);
select count(*) from (select /*+leading((t1 t3) t2)*/ distinct t1.pk from t1, t2, t3 where t1.c1 = t2.c2 and t2.c1 = t3.c2 and t3.c1 = t1.c2);
select count(*) from (select distinct t3.pk from t1, t2, t3 where t1.c1=t2.c2 and t2.c2=t3.c3);
select count(*) from (select /*+leading((t1 t2) t3)*/ distinct t3.pk from t1, t2, t3 where t1.c1=t2.c2 and t2.c2=t3.c3);
select count(*) from (select /*+leading((t1 t3) t2)*/ distinct t3.pk from t1, t2, t3 where t1.c1=t2.c2 and t2.c2=t3.c3);
select count(*) from (select /*+leading((t2 t3) t1)*/ distinct t3.pk from t1, t2, t3 where t1.c1=t2.c2 and t2.c2=t3.c3);


# test ambient cardinality for join between pk and fk
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t4.pk from t4, t5 where t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4, t5 where t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t4.pk from t4, t5 where t4.c1 = t5.c1 and t4.c2 = t5.c2 and t4.c3 < 50);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4, t5 where t4.c1 = t5.c1 and t4.c2 = t5.c2 and t5.c3 < 50);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4, t5 where t4.c1 = t5.c1 and t4.c2 = t5.c2 and t4.c3 < 50 and t5.c3 < 50);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t4.pk from t4 left join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4 left join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t4.pk from t4 right join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4 right join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t4.pk from t4 left join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2 where t5.c3 is null);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ distinct t5.pk from t4 left join t5 on t4.c1 = t5.c1 and t4.c2 = t5.c2 where t5.c3 is null);
select count(*) from (select /*+NO_ELIMINATE_JOIN*/ 1 from t5 where not exists (select 1 from t4 where t4.c1 = t5.c1 and t4.c2 = t5.c2));

# test combined ndv
select count(*) from (select /*+no_rewrite*/ distinct t2.c1, t2.c2 from t1, t2 where t1.c1 = 1);
select count(*) from (select /*+no_rewrite*/ distinct t1.c1 as c3, t2.c1, t2.c2 from t1, t2 where t1.c1 = 1);
select count(*) from (select /*+no_rewrite*/ distinct t1.c1 as c3, t2.pk, t2.c1, t2.c2 from t1, t2 where t1.c1 = 1);
select count(*) from (select /*+no_rewrite*/ distinct t1.c1 as c3, t2.pk, t2.c1, t2.c2, row_number() over () from t1, t2 where t1.c1 = 1);

select count(*) from (select distinct c1 from t6 where c1 < 1000);
select count(*) from (select distinct c1 from t6 where c1 < 500);
select count(*) from (select distinct c1 from t6 where c1 < 500 and c2 < 500);
select count(*) from (select distinct c1 from t6 where c1 is null);
select count(*) from (select distinct c1 from t6 where c1 < 500 or c1 is null);
select count(*) from (select distinct c3 from t6 where c1 < 500);

drop table t1,t2,t3,t4,t5,t6;