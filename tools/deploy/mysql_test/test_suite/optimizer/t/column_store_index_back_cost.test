--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhenling.zzg
#owner group: sql1
# tags: optimizer cross validation 

--disable_warnings
drop table if exists t1, t2, t3;
drop sequence if exists seq;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int);
create index t1_i1 on t1(c1,c2,c3,c4);
create index t1_i2 on t1(c1,c2,c3,c4,c5)with column group(each column);
create index t1_i3 on t1(c1)storing(c2,c3,c4,c5,c6)with column group(each column, all columns);

create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int)with column group(each column);
create index t2_i1 on t2(c1,c2,c3,c4);
create index t2_i2 on t2(c1,c2,c3,c4,c5)with column group(each column);
create index t2_i3 on t2(c1)storing(c2,c3,c4,c5,c6)with column group(each column, all columns);
                
                
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int)with column group(each column, all columns);
create index t3_i1 on t3(c1,c2,c3,c4);
create index t3_i2 on t3(c1,c2,c3,c4,c5)with column group(each column);
create index t3_i3 on t3(c1)storing(c2,c3,c4,c5,c6)with column group(each column, all columns);

create sequence seq;

insert /*+query_timeout(100000000)*/ into t1
select seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000 from table(generator(100000));
insert /*+query_timeout(100000000)*/ into t2
select seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000 from table(generator(100000));
insert /*+query_timeout(100000000)*/ into t3
select seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000,seq.nextval % 1000 from table(generator(100000));

--source mysql_test/include/minorfreeze.inc
--real_sleep 10
--source mysql_test/include/wait_minor_merge.inc

call dbms_stats.gather_table_stats(NULL, 't1');
call dbms_stats.gather_table_stats(NULL, 't2');
call dbms_stats.gather_table_stats(NULL, 't3');

explain select count(*) from t1 where c1 = 1;
explain select * from t1 where c1 = 1;

explain select count(*) from t1 where c3 = 1;
explain select * from t1 where c3 = 1;

explain select count(*) from t1 where c6 = 1;
explain select * from t1 where c6 = 1;

explain select count(*) from t1 where c7 = 1;
explain select * from t1 where c7 = 1;

explain select count(*) from t1 where c1 = 1 and c3 = 1;
explain select * from t1 where c1 = 1 and c3 = 1;

explain select count(*) from t1 where c1 = 1 and c7 = 1;
explain select * from t1 where c1 = 1 and c7 = 1;

explain select count(*) from t1 where c3 = 1 and c7 = 1;
explain select * from t1 where c3 = 1 and c7 = 1;

explain select count(*) from t1 where c1 = 1 and c3 = 1 and c7 = 1;
explain select * from t1 where c1 = 1 and c3 = 1 and c7 = 1;


explain select count(*) from t2 where c1 = 1;
explain select * from t2 where c1 = 1;

explain select count(*) from t2 where c3 = 1;
explain select * from t2 where c3 = 1;

explain select count(*) from t2 where c6 = 1;
explain select * from t2 where c6 = 1;

explain select count(*) from t2 where c7 = 1;
explain select * from t2 where c7 = 1;

explain select count(*) from t2 where c1 = 1 and c3 = 1;
explain select * from t2 where c1 = 1 and c3 = 1;

explain select count(*) from t2 where c1 = 1 and c7 = 1;
explain select * from t2 where c1 = 1 and c7 = 1;

explain select count(*) from t2 where c3 = 1 and c7 = 1;
explain select * from t2 where c3 = 1 and c7 = 1;

explain select count(*) from t2 where c1 = 1 and c3 = 1 and c7 = 1;
explain select * from t2 where c1 = 1 and c3 = 1 and c7 = 1;


explain select count(*) from t3 where c1 = 1;
explain select * from t3 where c1 = 1;

explain select count(*) from t3 where c3 = 1;
explain select * from t3 where c3 = 1;

explain select count(*) from t3 where c6 = 1;
explain select * from t3 where c6 = 1;

explain select count(*) from t3 where c7 = 1;
explain select * from t3 where c7 = 1;

explain select count(*) from t3 where c1 = 1 and c3 = 1;
explain select * from t3 where c1 = 1 and c3 = 1;

explain select count(*) from t3 where c1 = 1 and c7 = 1;
explain select * from t3 where c1 = 1 and c7 = 1;

explain select count(*) from t3 where c3 = 1 and c7 = 1;
explain select * from t3 where c3 = 1 and c7 = 1;

explain select count(*) from t3 where c1 = 1 and c3 = 1 and c7 = 1;
explain select * from t3 where c1 = 1 and c3 = 1 and c7 = 1;

explain select count(*) from t3 where c4 = 1 and c4+c8=2;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 bigint, c2 bigint, c3 bigint, c4 bigint)with column group(each column);
create index i1 on t1(c1); 
insert into t1 select random(),random(),random(),random() from table(generator(10));

explain select /*+full(t1)*/ count(*) from t1;
explain select /*+index(t1 i1)*/ count(*) from t1;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 bigint, c2 bigint, c3 bigint, c4 bigint)partition by hash(c2) partitions 128 with column group(each column);
create index i1 on t1(c1)global; 
call dbms_stats.set_table_stats(NULL, 't1', numrows=>10000000);
call dbms_stats.set_column_stats(NULL, 't1', 'c1', distcnt=>100);
call dbms_stats.set_column_stats(NULL, 't1', 'c2', distcnt=>1000);
call dbms_stats.set_column_stats(NULL, 't1', 'c3', distcnt=>1000);


create table t2(c1 bigint, c2 bigint, c3 bigint, c4 bigint) with column group(each column);
create index i2 on t2(c1);
call dbms_stats.set_table_stats(NULL, 't2', numrows=>2586589);
call dbms_stats.set_column_stats(NULL, 't2', 'c1', distcnt=>100);
call dbms_stats.set_column_stats(NULL, 't2', 'c2', distcnt=>3);
call dbms_stats.set_column_stats(NULL, 't2', 'c3', distcnt=>1000);

explain select /*+index(t1 i1)*/ * from t1;

explain select /*+parallel(8) leading(A B) use_hash(B) px_join_filter(B) index(B i2) opt_param('_ENABLE_STORAGE_CARDINALITY_ESTIMATION', 'false')*/ count(B.c3) from t2 A, t2 B where A.c1 = B.c3 and B.c2 = 1;
explain select /*+parallel(2) leading(A B) use_hash(B) px_join_filter(B) index(B i2) opt_param('_ENABLE_STORAGE_CARDINALITY_ESTIMATION', 'false')*/ count(B.c2) from t1 A, t1 B where A.c1 = B.c3;