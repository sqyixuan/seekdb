# tags: optimizer

--disable_warnings
DROP TABLE if exists t1;
--enable_warnings

CREATE TABLE `t1` (
  `c1` int,
  `c2` int,
  `c3` int,
  `c4` int,
  PRIMARY KEY (c1,c2,c3,C4)
);
insert into t1 values (8, 10, 10, 11);

--result_format 4
--explain_protocol 2
select 1 from t1 where c1 = 8 and c2 > 3 and c2 > 4152881806389018624;
select 1 from t1 where c1 = 8 and c2 > 4152881806389018624 and c2 > 3;
select 1 from t1 where c1 = 8 and c2 > 3 and c2 > 4152881806389018624 and c3 > 3;
select 1 from t1 where c1 = 8 and c2 = 10 and c3 > 3 and c3 > 4152881806389018624;
select 1 from t1 where c1 = 8 and c3 > 3 and c3 > 4152881806389018624;
select 1 from t1 where c1 = 8 and c3 = 10 and c4 > 4152881806389018624;
select 1 from t1 where c1 = 8 and c3 = 10 and c4 = 10;

DROP TABLE t1;