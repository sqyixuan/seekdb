CREATE TABLE t1 (
col_number_20_0 int,
col_varchar2_20 varchar(20),
pk int not null,
col_decimal_20_5 decimal(20,5),
col_int int,
col_ts timestamp);
create index in_expr_idx7 on t1 (pk);

INSERT INTO t1 VALUES (6, 'get', 76, 4, 0, NULL);
INSERT INTO t1 VALUES (6, 'v', 58, 0, -7, NULL);
INSERT INTO t1 VALUES (9, 'qcuncvsvdvswhhdtprkx', 24, -22, 1252, NULL);
INSERT INTO t1 VALUES (6, 'l', 13, 8, -23, (Timestamp '2005-02-01 05:17:12.041643'));

--explain_protocol 3
SELECT /*+index(t1 in_expr_idx7)*/* FROM t1 WHERE PK IN (-1,-2) OR (COL_DECIMAL_20_5,PK) < (0,-2);  
SELECT /*+full(t1)*/* FROM t1 WHERE PK IN (-1,-2) OR (COL_DECIMAL_20_5,PK) < (0,-2);  

SELECT /*+index(t1 in_expr_idx7)*/* FROM t1 WHERE PK IN (-1,-2) OR (COL_DECIMAL_20_5,PK) != (0,-2);
SELECT /*+full(t1)*/* FROM t1 WHERE PK IN (-1,-2) OR (COL_DECIMAL_20_5,PK) != (0,-2);
