select /*+full(t1)*/* from t1 where (c1,c2) < (1.1,2);

select /*+index(t1 idx)*/* from t1 where (c1,c2) > (0.9,2);
select /*+full(t1)*/* from t1 where (c1,c2) > (0.9,2);

select /*+index(t1 idx)*/* from t1 where (c1,c2) >= (0.9,2);
select /*+full(t1)*/* from t1 where (c1,c2) >= (0.9,2);

select /*+index(t1 idx)*/* from t1 where (c1,c2,c3) > (1,0.9,2);
