# owner: link.zt
# owner group: SQL1
# tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 varchar(10) primary key);
insert into t1 values ('aaa1');
insert into t1 values ('aaa2');
insert into t1 values ('aaa3');
insert into t1 values ('aaaa');
insert into t1 values ('aaab');
insert into t1 values ('aaac');
insert into t1 values ('aaa_');
insert into t1 values ('aaa%');
insert into t1 values ('aaa\\');
insert into t1 values ('baa1');
insert into t1 values ('测试1');
insert into t1 values ('测试2');
insert into t1 values ('测试a');
insert into t1 values ('测试b');
insert into t1 values ('测试中');
insert into t1 values ('测试文');
insert into t1 values ('测试_');
insert into t1 values ('测试%');
insert into t1 values ('测试\\');
insert into t1 values ('中测试');
insert into t1 values ('文测试');

--disable_query_log
--disable_result_log
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4

explain extended_noaddr select * from t1 where c1 like 'aa';
select * from t1 where c1 like 'aa';

explain extended_noaddr select * from t1 where c1 like 'aa_';
select * from t1 where c1 like 'aa_';

explain extended_noaddr select * from t1 where c1 like 'aa%';
select * from t1 where c1 like 'aa%';

explain extended_noaddr select * from t1 where c1 like 'aa_1';
select * from t1 where c1 like 'aa_1';

explain extended_noaddr select * from t1 where c1 like 'aa%1';
select * from t1 where c1 like 'aa%1';

explain extended_noaddr select * from t1 where c1 like 'aa%1%';
select * from t1 where c1 like 'aa%1%';

explain extended_noaddr select * from t1 where c1 like 'aaa\_';
select * from t1 where c1 like 'aaa\_';

explain extended_noaddr select * from t1 where c1 like 'aaa\%';
select * from t1 where c1 like 'aaa\%';

explain extended_noaddr select * from t1 where c1 like 'aaa\\';
select * from t1 where c1 like 'aaa\\';

explain extended_noaddr select * from t1 where c1 like '_aa';
select * from t1 where c1 like '_aa';

explain extended_noaddr select * from t1 where c1 like '%aa';
select * from t1 where c1 like '%aa';

explain extended_noaddr select * from t1 where c1 like '测试';
select * from t1 where c1 like '测试';

explain extended_noaddr select * from t1 where c1 like '测试_';
select * from t1 where c1 like '测试_';

explain extended_noaddr select * from t1 where c1 like '测试%';
select * from t1 where c1 like '测试%';

explain extended_noaddr select * from t1 where c1 like '测试_1';
select * from t1 where c1 like '测试_1';

explain extended_noaddr select * from t1 where c1 like '测试%1';
select * from t1 where c1 like '测试%1';

explain extended_noaddr select * from t1 where c1 like '测试\_';
select * from t1 where c1 like '测试\_';

explain extended_noaddr select * from t1 where c1 like '测试\%';
select * from t1 where c1 like '测试\%';

explain extended_noaddr select * from t1 where c1 like '测试\\';
select * from t1 where c1 like '测试\\';

explain extended_noaddr select * from t1 where c1 like '_测试';
select * from t1 where c1 like '_测试';

explain extended_noaddr select * from t1 where c1 like '%测试';
select * from t1 where c1 like '%测试';

explain extended_noaddr select * from t1 where c1 like 'aaa%%' escape '%';
select * from t1 where c1 like 'aaa%%' escape '%';

explain extended_noaddr select * from t1 where c1 like 'aaa__' escape '_';
select * from t1 where c1 like 'aaa__' escape '_';

explain extended_noaddr select * from t1 where c1 like 'aa_a%';
select * from t1 where c1 like 'aa_a%';

## escape符后没有其他字符, 此时这个escape符按字符原意处理
explain extended_noaddr select * from t1 where c1 like 'aaa%' escape '%';
select * from t1 where c1 like 'aaa%' escape '%';

explain extended_noaddr select * from t1 where c1 like 'aaa_' escape '_';
select * from t1 where c1 like 'aaa_' escape '_';

drop table t1;
