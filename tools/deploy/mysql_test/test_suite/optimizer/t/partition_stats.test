--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: wuyuming.wym
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

set _enable_storage_cardinality_estimation = 0;
set cardinality_estimation_model = 0;
set optimizer_dynamic_sampling = 0;

create table t1(pid int, c1 int, c2 int) partition by hash(pid) partitions 4;
insert into t1 select row_number() over () % 4, abs(random(1)) % 4, abs(random(2)) % 100 from table(generator(10000));
insert into t1 select row_number() over () % 4, abs(random(3)) % 4, 0 from table(generator(10000));
create table t2(pid int, c1 int, c2 int) partition by hash(pid) partitions 4 subpartition by hash(c1) subpartitions 4;
insert into t2 select * from t1;

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats(null, 't1', method_opt=>'for columns c2 size 100 for columns pid size 1 for columns c1 size 1');
call dbms_stats.gather_table_stats(null, 't2', method_opt=>'for columns c2 size 100 for columns pid size 1 for columns c1 size 1');

--result_format 4
--explain_protocol 3
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where pid in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition (p0,p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition (p0,p1,p2) where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+dynamic_sampling(1)*/ count(*) from t1 where pid in (1,2) and c2 = 0;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2) where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c1 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c2 = 1;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c2 in (0, 1, 2);
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c2 not in (0, 1, 2);
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2,p3sp0) where c2 <= 2;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c1 in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c1 in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c1 in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c1 in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0sp1,p0sp2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0sp1,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition(p0) where c1 in (1,2) and c2 = 0;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 10)*/ count(*) from t2 partition(p0,p1,p2,p3sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 0)*/ count(*) from t2 partition(p0,p1,p2,p3sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 20)*/ count(*) from t2 partition(p0,p1,p2,p3sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 3)*/ count(*) from t2 partition(p0,p1sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 10)*/ count(*) from t2 partition(p0,p1sp0) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 10)*/ count(*) from t2 partition(p1sp0,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 1)*/ count(*) from t2 partition(p1sp0,p1sp1) where c2 = 0;

call dbms_stats.delete_table_stats(null, 't1', cascade_parts=>false);
call dbms_stats.delete_table_stats(null, 't2', cascade_parts=>false);

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where pid in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition (p0,p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition (p0,p1,p2) where pid in (1,2) and c2 = 0;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0,p1,p2) where pid in (1,2) and c2 = 0;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c1 in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1) and c1 in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c1 in (1) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 where pid in (1,2) and c1 in (1,2) and c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0sp1,p0sp2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition (p0sp1,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t2 partition(p0) where c1 in (1,2) and c2 = 0;

--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 10)*/ count(*) from t2 partition(p1sp0,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 1)*/ count(*) from t2 partition(p1sp0,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 2)*/ count(*) from t2 partition(p0,p1sp1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select /*+opt_param('partition_index_dive_limit', 1)*/ count(*) from t2 partition(p0,p1sp1) where c2 = 0;

call dbms_stats.gather_table_stats(null, 't1', 'p1', method_opt=>'for all columns size 1');
call dbms_stats.delete_table_stats(null, 't1', cascade_parts=>false);
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition(p1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition(p0,p1) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition(p0,p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 partition(p1,p2) where c2 = 0;
--replace_regex /version=\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2}\.\d{6}+/version=stat_version/
select count(*) from t1 where c2 = 0;

drop table t1,t2;