--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer
# link: 
--disable_warnings
drop table if exists T1,T1_1,T1_2;
--enable_warnings

CREATE TABLE T1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_1 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
CREATE TABLE T1_2 (C1 INT, C2 INT, C3 INT) PARTITION BY HASH(C1) PARTITIONS 3;
insert into T1 values (1,1,1),(2,2,2),(3,3,3);
insert into T1_1 values (1,1,1),(2,2,2),(3,3,3);
insert into T1_2 values (1,1,1),(2,2,2),(3,3,3);

--explain_protocol 2
--result_format 4

select * from t1_2 join (select /*+ no_rewrite */ * from t1 where exists (select 1 from t1_1 where t1.c1 = t1_1.c1)) t11 on t1_2.c1 = t11.c1;

select * from t1_2 join (select /*+ no_rewrite */ * from t1 where exists (select 1 from t1_1 where t1.c2 = t1_1.c1)) t11 on t1_2.c1 = t11.c2;

--disable_warnings
drop table T1,T1_1,T1_2;
--enable_warnings
