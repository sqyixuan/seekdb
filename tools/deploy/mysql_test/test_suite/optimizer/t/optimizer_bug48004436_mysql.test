--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1
# tags: optimizer,cross_validation
# link: 
--disable_warnings
drop table if exists `tbl_214`;
drop table if exists `tbl_436`;
--enable_warnings
CREATE TABLE `tbl_214` (
  `col_21057` tinyint(1) DEFAULT NULL,
  `col_21071` tinyint(1) DEFAULT '1',
  `col_21089` blob DEFAULT NULL,
  `col_21126` set('Alice','Bob','Charlie','David') NOT NULL
);

create table `tbl_436`  (`col_66090` varchar(179) NOT NULL);

--explain_protocol 2
--result_format 4
update
    tbl_214
set
    tbl_214.col_21071 = 1
where
    tbl_214.col_21057 in (
        select
            col_21071
        from
            tbl_214
        where
            tbl_214.col_21089 in (
                select
                    col_66090
                from
                    tbl_436
            )
    );

--disable_warnings
drop table `tbl_214`;
drop table `tbl_436`;
--enable_warnings
