--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhenling.zzg
#owner group: sql1
# tags: optimizer

connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
--disable_query_log
#--error 0,5157
#drop tenant column_store_route_test force;
#drop resource pool if exists column_store_route_test_pool;
#drop resource unit if exists column_store_route_test_box;

#eval create resource unit if not exists column_store_route_test_box max_cpu 2, memory_size='2G';
#eval create resource pool if not exists column_store_route_test_pool unit = 'column_store_route_test_box', unit_num = 1;
#eval create tenant if not exists column_store_route_test replica_num = 2, primary_zone='RANDOM', resource_pool_list=('column_store_route_test_pool'),LOCALITY = 'F@zone1,C@zone2' set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql', secure_file_priv = '/';
--enable_query_log
--enable_warnings

--source mysql_test/include/check_tenant_sync.inc

connect (con1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection con1;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int);
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int)with column group(each column);
alter system major freeze;
--sleep 10

explain select * from t1;
explain select * from t2;
explain select /*+use_das(t2)*/* from t2;

set ob_route_policy=COLUMN_STORE_ONLY;
--error 1235
explain select * from t1;
--error 1235
explain select * from t2;
--error 1235
explain select /*+use_das(t2)*/* from t2;

#set ob_read_consistency = WEAK;
#explain select * from t1;
#explain select * from t2;
#explain select /*+use_das(t2)*/* from t2;

set ob_route_policy=READONLY_ZONE_FIRST;
set ob_read_consistency = STRONG;

--disable_warnings
drop table if exists test_2x;
--enable_warnings

CREATE TABLE `test_2x` (
  `id` int(11) NOT NULL,
  `name` varchar(65536) DEFAULT NULL,
  `addr` varchar(65536) DEFAULT NULL,
  `birthday` timestamp NULL DEFAULT NULL,
  `money` int(11) DEFAULT NULL,
  `score` float DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `i2` (`money`) STORING (`name`) BLOCK_SIZE 16384 LOCAL
)  REPLICA_NUM = 1  ;
insert /*+append*/ into test_2x select 1,'1','1',null,0,1 from dual;
explain select * from test_2x where money = 0;
select * from test_2x where money = 0;

connection default;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int);
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int)with column group(each column);

explain select * from t1;
explain select * from t2;
explain select /*+use_das(t2)*/* from t2;

set ob_route_policy=COLUMN_STORE_ONLY;
--error 1235
explain select * from t1;
--error 1235
explain select * from t2;
--error 1235
explain select /*+use_das(t2)*/* from t2;

set ob_read_consistency = WEAK;
--error 4515
explain select * from t1;
--error 4515
explain select * from t2;
--error 4515
explain select /*+use_das(t2)*/* from t2;

set ob_route_policy=READONLY_ZONE_FIRST;
set ob_read_consistency = STRONG;

connection default;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
desc t1;
--error 4515
select * from t1;
set ob_route_policy=READONLY_ZONE_FIRST;
set ob_read_consistency = STRONG;
