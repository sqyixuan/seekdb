select/*+index(t1 idx3) */ * from t1 where JSON_CONTAINS( j->'$.zipcode',CAST('94507' AS JSON)) order by l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, j json, v vector(3), 
    primary key(c1), 
    INDEX idxj( (CAST(j->'$.zipcode' AS UNSIGNED ARRAY)) ),
    vector index idx3(v) with (distance=l2, type=ivf_flat));
