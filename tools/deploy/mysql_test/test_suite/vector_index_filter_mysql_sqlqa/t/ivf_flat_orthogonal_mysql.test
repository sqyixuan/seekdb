  (13, 24, '{"user":"Mary","user_id":72,"zipcode":[94536]}', '[0.442633,0.637534,0.633993]'),
  (14, 25, '{"user":"Ted","user_id":56,"zipcode":[94507,94582]}', '[0.190118,0.959676,0.796483]');
