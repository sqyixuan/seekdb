SELECT /*+ index(t1 idx1)*/* FROM t1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
##explain SELECT * FROM t1 where c2 >2 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

SELECT /*+ index(t1 idx1)*/* FROM t1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
SELECT l2_distance(c4,[1,2,-1]) FROM t1 where c1=c2 and c3>'Acsdfs' order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
SELECT /*+ index(t1 idx1)*/l2_distance(c4,[1,2,-1]) FROM t1 where c1=c2 and c3>'Acsdfs' order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
SELECT /*+ index(t1 idx2)*/l2_distance(c4,[1,2,-1]) FROM t1 where c1=c2 and c3>'Acsdfs' order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

SELECT /*+ index(t1 idx1)*/l2_distance(a.c4,[1,2,-1]) FROM t1 a,t1 b where a.c1=b.c2 and b.c3>'Acsdfs' order by l2_distance(a.c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
##explain SELECT /*+ index(t1 idx1)*/l2_distance(a.c4,[1,2,-1]) FROM t1 a,t1 b where a.c1=b.c2 and b.c3>'Acsdfs' order by l2_distance(a.c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

