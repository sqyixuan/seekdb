--enable_warnings
create materialized view mv1(primary key(c1))  as select /*+ index(t1 idx2)*/* from t1 where c1>1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1 and c2=c1  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
