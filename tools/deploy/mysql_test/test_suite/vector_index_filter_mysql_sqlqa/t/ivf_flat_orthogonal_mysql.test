--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, j json, v vector(3), 
    primary key(c1), 
    vector index idx3(v) with (distance=l2, type=ivf_flat));
INSERT INTO t1 VALUES 
  (10, 21, '{"user":"Jack","user_id":37,"zipcode":[94582,94536]}', '[0.203846,0.205289,0.880265]'),
  (11, 22, '{"user":"Jill","user_id":22,"zipcode":[94568,94507,94582]}', '[0.226980,0.579658,0.933939]'),
