select /*+ index(mv1 idx1)*/* from mv1   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

replace into t1 select /*+ index(t1 idx2)*/* from mv1 where c1>1 and c2=c1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
