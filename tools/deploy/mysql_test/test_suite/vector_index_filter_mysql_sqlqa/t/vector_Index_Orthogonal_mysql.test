select /*+index(t1 idx2) */* from t1 where  c2 =c3   order by l2_distance(c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx2) */* from t1 where  c3 =c4   order by l2_distance(c4, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx2) */* from t1 where  c4 =c5   order by l2_distance(c5, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx2) */* from t1 where  c5 =c6   order by l2_distance(c6, [0.712338,0.603321,0.133444]) approximate limit 1;
select * from t1 where  c6 <>c3 or c3 is null  order by l2_distance(c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select * from t1 where  c6 <>c3 or c4 is null  order by l2_distance(c4, [0.712338,0.603321,0.133444]) approximate limit 1;
select * from t1 where  c6 <>c3 or c5 is null  order by l2_distance(c5, [0.712338,0.603321,0.133444]) approximate limit 1;
select * from t1 where  c6 <>c3 or c6 is null  order by l2_distance(c6, [0.712338,0.603321,0.133444]) approximate limit 1;

select /*+index(t1 idx1) */* from t1 where  c6 <>c3 or c3 is null  order by l2_distance(c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx2) */* from t1 where  c6 <>c3 or c4 is null  order by l2_distance(c4, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx3) */* from t1 where  c6 <>c3 or c6 is null  order by l2_distance(c6, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx4) */* from t1 where  c6 <>c3 or c6 is null  order by l2_distance(c6, [0.712338,0.603321,0.133444]) approximate limit 1;


