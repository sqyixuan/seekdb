--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select  c1, ST_AsText(g) FROM t1 WHERE ST_Intersects(g, ST_GeomFromText('POINT(0 0)')) 
    ORDER BY l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 like t1;
insert into tt1 select /*+ ENABLE_PARALLEL_DML parallel(256) */ * FROM t1 WHERE ST_Intersects(g, ST_GeomFromText(@geo_py)) ORDER BY l2_distance(v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100;

--disable_warnings
drop materialized view if exists mv2;
--enable_warnings
create materialized view mv2(primary key(c1))  as select /*+ ENABLE_PARALLEL_DML parallel(256) */t1.c1, ST_AsText(tt1.g) from t1 ,tt1 where t1.g=tt1.g ORDER BY l2_distance(tt1.v, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select * from mv1,mv2 order by 1,2,3,4;

