##物化视图
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, c3 char(20) , c4 vector(3), primary key(c1), index idx1(c2) ,vector index idx2(c4) with (distance=l2, type=hnsw))partition by hash(c1) partitions 4;
insert into t1 values(1, 1, 'ans传记', '[0.203846,0.205289,0.880265]');
insert into t1 values(2, 2, '121asdasd', '[0.226980,0.579658,0.933939]');
insert into t1 values(3, 3, '123', '[0.181664,0.013905,0.628127]');
insert into t1 values(4, 4, null, '[0.442633,0.637534,0.633993]');
insert into t1 values(5, 5, 'Acsdfs', '[0.190118,0.959676,0.796483]');
insert into t1 values(6, 6, '中文ing123', '[0.710370,0.007130,0.710913]');
insert into t1 values(7, 7, '中文ing1231', '[0.238120,0.289662,0.970101]');
insert into t1 values(8, 8, '中文ing1232', '[0.168794,0.567442,0.062338]');
insert into t1 values(9, 9, '中文ing1233', '[0.901419,0.676738,0.122339]');
insert into t1 values(10, -1, '中文ing1234', null);
insert into t1 values(11, null, '中文ing123', null);
--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select /*+ index(t1 idx1)*/* from t1 where c1>1 and c2<>c1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
create materialized view mv1(primary key(c1))  as select /*+log_level(DEBUG) no_rewrite */* from t1 where c1>1 and c2=c1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
select /*+log_level(DEBUG) no_rewrite */* from mv1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

--disable_warnings
drop  view if exists v1;
--enable_warnings
create  view v1  as select /*+log_level(DEBUG) no_rewrite */* from t1 where c1>1 and c2=c1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
select /*+log_level(DEBUG) no_rewrite */* from v1;
select /*+log_level(DEBUG) no_rewrite */* from v1 order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;

select /*+log_level(DEBUG) no_rewrite */* from mv1,v1 where mv1.c4=v1.c4 order by l2_distance(v1.c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;
select * from mv1,v1 where mv1.c4=v1.c4 order by l2_distance(v1.c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100 ;



