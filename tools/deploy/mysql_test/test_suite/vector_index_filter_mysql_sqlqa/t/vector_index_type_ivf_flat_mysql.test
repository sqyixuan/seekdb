##MEDIUMBLOB
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 MEDIUMBLOB,c3 vector(3),vector index idx1(c3) with (distance=l2, type=ivf_flat));
insert into t1 values(1,'[1,1,2]','[2,2,3]');
insert into t1 values(2,'[2,2,3]','[3,2,3]');
insert into t1 values(3,'[29,2,2]','[3,2,3]');
insert into t1 values(4,null,'[3,2,3]');
insert into t1 values(5,null,null);
select * from t1 where c2>'[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select sum(c3) from t1 where c2='[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select c3 from t1 where c2='[1,1,2]' or c3 =[1,2,3] order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select c3 from t1 where c2 is null order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


