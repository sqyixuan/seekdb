#owner: luohongdi.lhd
#owner group: 多模
#description: vector index
#tags:vector index
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

###参数校验
##自定义参数结合过滤使用
alter system set ob_vector_memory_limit_percentage =44;
drop table if exists t1;
create table t1(c1 SERIAL , c2 BOOL, c3 TINYINT , c4 SMALLINT, c5 MEDIUMINT,c6 INT,c7 BIGINT,c8 vector(3),primary key(c1), vector index idx1(c8) with (distance=l2, type=ivf_flat));
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(1, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(2, TRUE, 0, -32768, -8388608, -2147483648, -9223372036854775808,'[0.226980,0.579658,0.933939]');
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(3, FALSE, 127, 32767, 8388607, 2147483647, 9223372036854775807,'[0.181664,0.013905,0.628127]');
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(4, TRUE, -128, -32768, -8388608, -2147483648, -9223372036854775808,'[0.442633,0.637534,0.633993]');
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(5, 0, 0, 0, 0, 0, 0,'[0.190118,0.959676,0.796483]');
insert into t1(c1,c2,c3,c4,c5,c6,c7,c8) values(6, FALSE, -1, -1, -1, -1, -1,'[0.710370,0.007130,0.710913]');
select * from t1  order by l2_distance(null, null) APPROXIMATE limit 10;

set @a=1;
select * from t1 where c1>@a order by l2_distance(c8, [1,2,3]) APPROXIMATE limit 10;
set @a='1';
select * from t1 where c1>@a order by l2_distance(c8, [1,2,3]) APPROXIMATE limit 10;
set @a='1';
--error 1064
select * from t1 where c1>@a order by l2_distance(c8, [1,2,3]) APPROXIMATE limit @a;
set @a='[0,0,0]';
select * from t1 where c1>1 and c7=-9223372036854775808 order by l2_distance(c8, @a) APPROXIMATE limit 10;
set @a=null;
--error 4152
select * from t1 where c1>1 and c7=-9223372036854775808 order by l2_distance(c8, @a) APPROXIMATE limit 10;
set @a='[0.442633,0.637534,0.633993]';
select * from t1 where c1>1 and c8='[0.442633,0.637534,0.633993]' order by l2_distance(c8, @a) APPROXIMATE limit 10;

##数据类型验证
##数值类型
--disable_warnings
drop table if exists example_table;
--enable_warnings

CREATE TABLE example_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    is_active BOOL,
    tiny_value TINYINT,
    small_value SMALLINT,
    medium_value MEDIUMINT,
    big_value BIGINT,
    decimal_value DECIMAL(10, 2) ,
    numeric_value NUMERIC(10, 2),
    float_value FLOAT,
    double_value DOUBLE,
    bit_value BIT(1),
    vector_value vector(3),vector index idx1(vector_value) with (distance=l2, type=ivf_flat));
INSERT INTO example_table (is_active, tiny_value, small_value, medium_value, big_value, decimal_value, numeric_value, float_value, double_value, bit_value,vector_value) 
VALUES 
    (TRUE, 10, 100, 1000, 10000, 1234.56, 78.90, 1.23, 4.567, b'1',null),
    (FALSE, -10, -100, -1000, -10000, 4567.89, 12.34, 5.67, 8.910, b'0','[0.226980,0.579658,0.933939]'),
    (TRUE, 127, 32767, 8388607, 9223372036854775807, 9876.54, 98.76, 9.12, 3.456, b'1','[0.181664,0.013905,0.628127]'),
    (FALSE, -128, -32768, -8388608, -9223372036854775808, 1357.24, 46.68, 2.34, 7.890, b'0','[0.442633,0.637534,0.633993]'),
    (TRUE, 0, 0, 0, 0, 2468.80, 13.14, 8.76, 5.432, b'1','[0.710370,0.007130,0.710913]');
select * from example_table where id >=0  order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
create index idx2 on example_table(id,is_active,tiny_value,small_value,medium_value,big_value,decimal_value,numeric_value,float_value,double_value,bit_value) global;
##使用不同列过滤
select l2_distance(vector_value, [1,2,3]) from example_table where id > 1 GROUP BY id  order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select /*+index(t1 idx2) */l2_distance(vector_value, [1,2,3]) from example_table where id > 1 GROUP BY id  order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(vector_value, [1,2,3]) from example_table where id > 1 GROUP BY id having id < 8 order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(vector_value, [1,2,3]) from example_table where id > 1 and tiny_value=0 order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(a.vector_value, [1,2,3]) from example_table a join example_table b on a.id=b.id order by l2_distance(a.vector_value, [1,2,3]) approximate limit 3;
select l2_distance(vector_value, [1,2,3]) from example_table where id >0 order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10 for update;
select l2_distance(vector_value, [1,2,3]) from example_table order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


##无符号定点类型
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 DECIMAL,c2 DECIMAL  unsigned,c3 NUMERIC,c4 FIXED unsigned,c5 FIXED,c6 NUMERIC unsigned,c7 vector(3),primary key(c3),vector index idx1(c7) with (distance=l2, type=ivf_flat));
insert into t1 values(1,2,1,4,5,6,[2,2,3]);
insert into t1 values(-1,2,2,4,5,6,'[5.1,2.2,3.4]');
insert into t1 values(10,2,3,4,5,6,null);
create index idx2 on t1(c3) global;
select /*+index(t1 idx2) */l2_distance(c7, [1,2,3]) from t1 order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c1 >1 and c2 >=2 order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select * from t1 where c1 >=1 and c2 >=2 order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select * from t1 where c1 >=1 and c2 >=2 order by l2_distance(c7, [0.712338,0.603321,0.133444])  limit 5;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c1=b.c1 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c2=b.c2 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c3=b.c3 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c4=b.c4 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c5=b.c5 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c6=b.c6 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;
select l2_distance(a.c7, [1,2,3]) from t1 a join t1 b on a.c7=b.c7 order by l2_distance(a.c7, [1,2,3]) approximate limit 3;


##无符号浮点类型
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 FLOAT unsigned,c2 double unsigned,c3 vector(3),primary key(c1),vector index idx1(c3) with (distance=l2, type=ivf_flat));
insert into t1 values(1.12,1.123,'[5.1,2.2,3.4]');
insert into t1 values(2.12,2.123,'[2,3,4]');
insert into t1 values(5.12,3.123,'[1,1,1]');
insert into t1 values(10.12,null,null);
select l2_distance(c3, [1,2,3]) from t1 order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c3, [1,2,3]) from t1 where c1 >1.12 and c2 >=1.123 order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;



##时间类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 DATE,c3 TIME,c4 DATETIME(6),c5 TIMESTAMP,c6 YEAR,c7 vector(3),vector index idx1(c7) with (distance=l2, type=ivf_flat));
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (1, '2023-04-01', '12:34:56', '2023-04-01 12:34:56', '2023-04-01 12:34:56', 2023,null);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (2, '2023-04-02', '13:45:00', NULL, '2023-04-02 13:45:00', 2023,'[0.226980,0.579658,0.933939]');
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (3, NULL, NULL, '2023-04-03 01:23:45', '2023-04-03 01:23:45', 2023,'[0.181664,0.013905,0.628127]');
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (4, NULL, NULL, NULL, '2023-04-04 00:00:00', NULL,[1,2,3]);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6,c7) VALUES (5, '2023-04-05', '02:30:00', '2023-04-05 02:30:00', '2023-04-05 02:30:00', NULL,[-1,2,3]);
create index idx2 on t1(c2) global;

select l2_distance(c7, [1,2,3]) from t1 order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select /*+index(t1 idx2) */l2_distance(c7, [1,2,3]) from t1 where c2 is null  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select /*+index(t1 idx1) */l2_distance(c7, [1,2,3]) from t1 where c2 is null  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c2 is null  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c3 ='13:45:00'  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c3 <'13:45:00'  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c4 <'2023-04-05 02:30:00'  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c5 <'2023-04-05 02:30:00'  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c6 <2025  order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select l2_distance(c7, [1,2,3]) from t1 where c2 is not null and c3 is not null order by l2_distance(c7, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


##char + vector
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3),c4 int[],vector index idx1(c3) with (distance=l2, type=ivf_flat));
insert into t1 values(1,'[1,1,2]',[2,2,3],[1,2,3]);
insert into t1 values(2,'[2,2,3]',[1,2,3],[1,2,3]);
insert into t1 values(3,'[29,2,2]',[-1,2,3],[1,2,3]);
insert into t1 values(4,null,[0,2,3],[1,2,3]);
insert into t1 values(5,null,null,null);
create index idx2 on t1(c2) global;

select * from t1 where c2>'[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select sum(c3) from t1 where c2='[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select c3 from t1 where c2='[1,1,2]' or c4 =[1,2,3] order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select /*+index(t1 idx2) */* from t1 where c2>'[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select /*+index(t1 idx2) */sum(c3) from t1 where c2='[1,1,2]' order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
select /*+index(t1 idx2) */c3 from t1 where c2='[1,1,2]' or c4 =[1,2,3] order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


