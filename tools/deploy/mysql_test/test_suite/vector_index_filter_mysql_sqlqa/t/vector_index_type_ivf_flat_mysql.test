##枚举类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 ENUM('A','[1]','W','12','999','NULL','中文'),c3 vector(1),vector index idx1(c3) with (distance=l2, type=ivf_flat));
INSERT INTO t1 (c1, c2, c3) VALUES (1, '999', '[1]');
INSERT INTO t1 (c1, c2, c3) VALUES (2, '[1]', '[4]');
INSERT INTO t1 (c1, c2, c3) VALUES (3, 'W', NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, '中文', '[9]');
INSERT INTO t1 (c1, c2, c3) VALUES (6, null, '[9]');

select * from t1 where c2>'999' order by l2_distance(c3, [0.712338]) APPROXIMATE limit 5;
select sum(c3) from t1 where c2='中文' order by l2_distance(c3, [0.712338]) APPROXIMATE limit 5;
select c3 from t1 where c2='[1]' or c3 =[9] order by l2_distance(c3, [0.712338]) APPROXIMATE limit 5;
select c3 from t1 where c2 is null and c3 is not null order by l2_distance(c3, [0.712338]) APPROXIMATE limit 5;


