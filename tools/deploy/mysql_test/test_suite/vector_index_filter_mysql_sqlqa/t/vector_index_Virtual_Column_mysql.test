#owner: gehao.wh
#owner group: 多模
#description: vector index
#tags:vector index
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;

##虚拟列为vector类型进行过滤
##hnsw
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, c3 BOOL , c4 vector(3), c5 vector(3) as (c4),primary key(c3), vector index idx1(c4) with (distance=l2, type=hnsw, lib=vsag));
insert into t1(c1,c2,c3,c4) values(1, 1, 1, '[0.203846,0.205289,0.880265]');
insert into t1(c1,c2,c3,c4) values(2, 2, 2, '[0.226980,0.579658,0.933939]');
insert into t1(c1,c2,c3,c4) values(3, 3, 3, '[0.181664,0.013905,0.628127]');
insert into t1(c1,c2,c3,c4) values(4, 4, 127, '[0.442633,0.637534,0.633993]');
insert into t1(c1,c2,c3,c4) values(5, 5, -127, '[0.190118,0.959676,0.796483]');
insert into t1(c1,c2,c3,c4) values(6, 6, -126, '[0.710370,0.007130,0.710913]');
insert into t1(c1,c2,c3,c4) values(7, 7, -128, '[0.238120,0.289662,0.970101]');
insert into t1(c1,c2,c3,c4) values(8, 8, 9, '[0.168794,0.567442,0.062338]');
insert into t1(c1,c2,c3,c4) values(9, 9, 0, '[0.901419,0.676738,0.122339]');
insert into t1(c1,c2,c3,c4) values(10, -1, -1, null);
insert into t1(c1,c2,c3,c4) values(11, null, 100, null);



##存在已知问题,《pre-filter场景，当选中的索引是主键时，不多余回主表的遗留问题》
#--error 4016
SELECT * FROM t1 where c5 = c4 and c1>1 and c1<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;
SELECT /*+index(t1 idx1) */* FROM t1 where c5 =c4 and c1>1 and c1<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;

##存在已知问题,《pre-filter场景，当选中的索引是主键时，不多余回主表的遗留问题》
#--error 4016
SELECT * FROM t1 where c5 =c4 and c2>1 and c2<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;
SELECT /*+index(t1 idx1) */* FROM t1 where c5 =c4 and c2>1 and c2<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;

#--error 4016
SELECT * FROM t1 where c5 =c4 and c3>1 and c3<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;
SELECT /*+index(t1 idx1) */* FROM t1 where c5 =c4 and c3>1 and c3<3   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;

#--error 4016
SELECT * FROM t1 where c5 =c4 and c3>1 and c3<3 and c4 <>c5   order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;
SELECT /*+index(t1 idx1) */* FROM t1 where c5 =c4 and c3>1 and c3<3 and c4 <>c5  order by l2_distance(c4, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1 ;


