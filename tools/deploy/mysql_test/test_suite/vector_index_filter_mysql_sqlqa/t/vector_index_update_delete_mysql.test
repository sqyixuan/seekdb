##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([2.5+1,2.5-1,-1.5*2],[-1000.5 % 1,1.5+1,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])-l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])*l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c2) select [2,3,4] from dual; 
insert into t1(c3) select [3,3,4] from dual; 
insert into t1(c3) select [l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])] from dual; 
