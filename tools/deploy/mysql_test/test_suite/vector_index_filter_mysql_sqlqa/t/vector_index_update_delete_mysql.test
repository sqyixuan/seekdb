CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings

CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 
##--error 1235  已修复
--error 5083
select /*+NO_USE_HASH_SET(@"SET$1")*/* from t1 union  select * from t2;

##select l2_distance(c2,c3) from t1 union  select l2_distance(a2,a3) from t2;

update t1 set c2 =[1,2,4] where c1 in (select l2_distance(c3,c3) from t1 inner join t2 on c2=a2);

update t1 join (t2) on c2 =a2 set c2 =[1,2,4] where a3 is null;

update t1 set c1 = l2_distance([1,2,4],[1,3,5]) where c1 in (select l2_distance(c3,c3) from t1 inner join t2 on c2=a2);

update t1 join t2 on c2 =a2 set c1 = l2_distance([1,2,4],[1,3,5]) where a3 is null;

