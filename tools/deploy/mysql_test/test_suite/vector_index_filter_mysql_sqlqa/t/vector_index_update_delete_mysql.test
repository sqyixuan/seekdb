drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),a5 vector(3) as (a2 * a3),
VECTOR INDEX vector_idx(a2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
replace into t2(a1,a2,a3,a4) select c1,c2,c3,c4 from t1; 

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select a2 from t1 a ,t2 b where a.c5=b.a5 order by l2_distance(a2,[1,1,8]) approximate limit 1;
select * from v1;


