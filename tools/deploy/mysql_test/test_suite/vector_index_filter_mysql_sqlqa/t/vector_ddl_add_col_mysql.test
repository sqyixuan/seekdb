##添加字符类型的数组
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
ALTER TABLE t1 ADD COLUMN c1 VARCHAR(100) NOT NULL DEFAULT '[]' COMMENT 'null';
--error 7600
select id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c1,'[0.9,1.0,0.9]') approximate limit 3;
--error 7600
select id,doc,l2_distance(c1,embedding) from t1 order by l2_distance(c1,'[0.9,1.0,0.9]') approximate limit 3;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
ALTER TABLE t1 ADD COLUMN c1 VARCHAR(100)  NULL DEFAULT '[1,2,-1]' COMMENT '图像向量（clip）,3维';

select id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c1,'[0.9,1.0,0.9]') approximate limit 3;
select id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c1,'[0.9,1.0,0.9]')  limit 3;
select id,doc,l2_distance(c1,embedding) from t1 where embedding<>c1 order by l2_distance(embedding,'[0.9,1.0,0.9]') approximate limit 3;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=ivf_pq,m=1));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
ALTER TABLE t1 ADD COLUMN c1 VARCHAR(100) NOT NULL DEFAULT '[1,2,0]' COMMENT 'null';
ALTER TABLE t1 ADD COLUMN note TEXT COMMENT '订单备注';
select /*+log_level(DEBUG) no_rewrite */id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c1,'[0.9,1.0,0.9]') approximate limit 3;
select /*+log_level(DEBUG) no_rewrite */id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c1,'[0.9,1.0,0.9]') approximate limit 3;
select /*+log_level(DEBUG) no_rewrite */id,doc,l2_distance(c1,embedding) from t1 where embedding<>c1 order by l2_distance(embedding,'[0.9,1.0,0.9]') approximate limit 3;

##添加指定列位置
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
ALTER TABLE t1 ADD COLUMN c1 vector(3)  null AFTER id;
ALTER TABLE t1 ADD COLUMN c2 vector(3)  null AFTER embedding;
ALTER TABLE t1 ADD COLUMN c3 vector(3)  null AFTER c1;
ALTER TABLE t1 ADD COLUMN c4 vector(3)  null AFTER c2;

create vector index idx2 on t1(c3) with (distance=l2,type=hnsw);
insert into t1(id,c3) values(10,'[1.2,0.7,1.1]'),(20,'[0.6,1.2,0.8]'),(30,'[1.1,1.1,0.9]'),(40,'[5.3,4.8,5.4]'),(50,'[4.9,5.3,4.8]'),(60,'[5.2,4.9,5.1]');
select /*+index(t1 idx2) */id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c3,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c2,'[0.9,1.0,0.9]') from t1 order by l2_distance(c3,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c3,'[0.9,1.0,0.9]') from t1 order by l2_distance(c3,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c4,'[0.9,1.0,0.9]') from t1 order by l2_distance(c3,'[0.9,1.0,0.9]') approximate limit 3;


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
ALTER TABLE t1 ADD COLUMN c1 vector(3)  null FIRST ;
ALTER TABLE t1 ADD COLUMN c2 vector(3)  null FIRST ;
ALTER TABLE t1 ADD COLUMN c3 vector(3)  null FIRST ;
ALTER TABLE t1 ADD COLUMN c4 vector(3)  null FIRST ;

create vector index idx2 on t1(c4) with (distance=l2,type=hnsw);
insert into t1(id,c4) values(10,'[1.2,0.7,1.1]'),(20,'[0.6,1.2,0.8]'),(30,'[1.1,1.1,0.9]'),(40,'[5.3,4.8,5.4]'),(50,'[4.9,5.3,4.8]'),(60,'[5.2,4.9,5.1]');
select /*+index(t1 idx2) */id,doc,l2_distance(c1,'[0.9,1.0,0.9]') from t1 order by l2_distance(c4,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c2,'[0.9,1.0,0.9]') from t1 order by l2_distance(c4,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c3,'[0.9,1.0,0.9]') from t1 order by l2_distance(c4,'[0.9,1.0,0.9]') approximate limit 3;
select /*+index(t1 idx2) */id,doc,l2_distance(c4,'[0.9,1.0,0.9]') from t1 order by l2_distance(c4,'[0.9,1.0,0.9]') approximate limit 3;


