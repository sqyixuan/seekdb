#owner: yangjiali.yjl
#owner group: 多模
#description: vector index
#tags:vector index
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;

##添加not null属性
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
--error 1138
alter table t1 add vec_1 vector(3) not null comment '图像向量（clip）,3维';

##添加null属性
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key,doc varchar(200),embedding vector(3),vector index idx1(embedding)with (distance=l2,type=hnsw));
insert into t1 values(1,'苹果','[1.2,0.7,1.1]'),(2,'香蕉','[0.6,1.2,0.8]'),(3,'橙子','[1.1,1.1,0.9]'),(4,'胡萝卜','[5.3,4.8,5.4]'),(5,'菠菜','[4.9,5.3,4.8]'),(6,'西红柿','[5.2,4.9,5.1]');
alter table t1 add vec_1 vector(3)  null comment '图像向量（clip）,3维';
select id,doc,l2_distance(vec_1,'[0.9,1.0,0.9]') from t1 order by l2_distance(vec_1,'[0.9,1.0,0.9]') approximate limit 3;

##添加普通列
