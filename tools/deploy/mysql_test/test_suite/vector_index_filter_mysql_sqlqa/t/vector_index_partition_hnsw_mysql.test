##分区键作为过滤条件
--disable_warnings
drop table if exists example_table;
--enable_warnings
CREATE TABLE example_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    is_active BOOL,
    tiny_value TINYINT,
    small_value SMALLINT,
    medium_value MEDIUMINT,
    big_value BIGINT,
    decimal_value DECIMAL(10, 2) ,
    numeric_value NUMERIC(10, 2),
    float_value FLOAT,
    double_value DOUBLE,
    bit_value BIT(1),
    vector_value vector(3),vector index idx1(vector_value) with (distance=l2,  type=ivf_sq8))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(10)
);
INSERT INTO example_table (is_active, tiny_value, small_value, medium_value, big_value, decimal_value, numeric_value, float_value, double_value, bit_value,vector_value) 
VALUES 
    (TRUE, 10, 100, 1000, 10000, 1234.56, 78.90, 1.23, 4.567, b'1',null),
    (FALSE, -10, -100, -1000, -10000, 4567.89, 12.34, 5.67, 8.910, b'0','[0.226980,0.579658,0.933939]'),
    (TRUE, 127, 32767, 8388607, 9223372036854775807, 9876.54, 98.76, 9.12, 3.456, b'1','[0.181664,0.013905,0.628127]'),
    (FALSE, -128, -32768, -8388608, -9223372036854775808, 1357.24, 46.68, 2.34, 7.890, b'0','[0.442633,0.637534,0.633993]'),
    (TRUE, 0, 0, 0, 0, 2468.80, 13.14, 8.76, 5.432, b'1','[0.710370,0.007130,0.710913]');
create index idx2 on example_table(id,is_active,tiny_value,small_value,medium_value,big_value,decimal_value,numeric_value,float_value,double_value,bit_value) ;
select * from example_table where id > 1   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;
##实际没有走ivf索引  已修复 ，bugfix引入
##explain select * from example_table where id > 1   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5; 


select *,/*+index(t1 idx1) */vector_value from example_table where id > 1 or is_active is true or tiny_value is true or  small_value is true or medium_value is true or big_value is true or decimal_value is true or numeric_value is true or float_value is true or double_value is true or bit_value is true or vector_value is not null   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select *,/*+index(t1 idx1) */vector_value from example_table where id > 1 and is_active is true and tiny_value is true and  small_value is true and medium_value is true and big_value is true and decimal_value is true and numeric_value is true and float_value is true and double_value is true and bit_value is true and vector_value is not null   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select *,/*+index(t1 idx1) */vector_value from example_table where id > 1 or is_active is true and tiny_value is false and  small_value is true and medium_value is true and big_value is true and decimal_value is true or numeric_value is true and float_value is true or double_value is true and bit_value is true and vector_value is not null   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;


##非分区键
select *,/*+index(t1 idx1) */vector_value from example_table where  is_active is true and tiny_value is false and  small_value is true and medium_value is true and big_value is true and decimal_value is true or numeric_value is true and float_value is true or double_value is true and bit_value is true and vector_value is not null   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select *,/*+index(t1 idx1) */vector_value from example_table where  is_active = is_active or vector_value <> vector_value   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select *,/*+index(t1 idx1) */vector_value from example_table where  is_active <> is_active or vector_value = vector_value   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;

select *,/*+index(t1 idx1) */vector_value from example_table where  is_active <> is_active or vector_value = vector_value   order by l2_distance(vector_value, [0.712338,0.603321,0.133444]) APPROXIMATE limit 5;






