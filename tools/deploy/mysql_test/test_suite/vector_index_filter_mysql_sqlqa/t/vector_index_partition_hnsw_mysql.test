#owner:wuxingying.wxy
#owner group: 多模
#description: vector index 
#tags:vector index
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
sleep 5;

--enable_sorted_result

##range分区
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  vector(3),c6 vector(3) ,c7 vector(3) as (c2), vector index idx1(c3) with (distance=l2, type=hnsw, lib=vsag), vector index idx2(c4) with (distance=l2, type=ivf_flat), vector index idx3(c5) with (distance=l2, type=ivf_sq8), vector index idx4(c6) with (distance=l2, type=ivf_pq,m=1))
PARTITION BY range COLUMNS(c1)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(10)
);
insert into t1(c1,c2,c3,c4,c5,c6) values(1,'[1,2,3]','[-1,2,3]','[1,-2,3]','[-1,2,-3]','[-1,2,-3]');
insert into t1(c1,c2,c3,c4,c5,c6) values(2,'[1,3,3]','[1,-2,3]','[1,-2,3]','[1,3,3]','[-1,-2,-3]');
insert into t1(c1,c2,c3,c4,c5,c6) values(3,'[1,4,3]','[1,5,3]','[1,6,3]','[1,7,3]','[-1,2,3]');
insert into t1(c1,c2,c3,c4,c5,c6) values(4,null,null,null,null,null);
create /*+enable_parallel_dml parallel(2)*/index idx5 on t1(c1,c2) global;

##call dbms_vector.rebuild_index('idx1','t1','c3');
##call dbms_vector.rebuild_index('idx2','t1','c4');
##call dbms_vector.rebuild_index('idx3','t1','c5');
##call dbms_vector.rebuild_index('idx4','t1','c6');


--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1 as select * from t1;

--disable_warnings
drop table if exists ttt1;
--enable_warnings
create table ttt1 like t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into ttt1(c1,c2,c3,c4,c5,c6) select /*+index(t1 idx3) */c1,c2,c3,c4,c5,c6 from t1 where c1>1 or c2 is not null or c3 =c2 order by l2_distance(c3, [0.712338,0.603321,0.133444])  limit 100;
select /*+index(t1 idx3) */* from ttt1 a,t1 b where a.c1<>b.c1 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx3) */* from ttt1 a,t1 b where a.c1<>b.c2 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx4) */* from ttt1 a,t1 b where a.c1<>b.c1 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx4) */* from ttt1 a,t1 b where a.c1<>b.c2 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;

select /*+index(t1 idx3) */* from t1 a,t1 b where a.c1<>b.c1 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx3) */* from t1 a,t1 b where a.c1<>b.c2 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx4) */* from t1 a,t1 b where a.c1<>b.c1 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;
select /*+index(t1 idx4) */* from t1 a,t1 b where a.c1<>b.c2 order by l2_distance(a.c3, [0.712338,0.603321,0.133444]) approximate limit 1;


