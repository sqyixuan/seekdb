SELECT * FROM t1 WHERE JSON_UNQUOTE(JSON_EXTRACT(c3, '$.name')) = 'Alice' order by l2_distance(c4, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
1	Alice	{"age": 30, "name": "Alice"}	[1,2,3]
SELECT * FROM t1 WHERE JSON_UNQUOTE(JSON_EXTRACT(c3, '$.name')) = 'Alice' and c2 = 'Alice' order by l2_distance(c4, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
1	Alice	{"age": 30, "name": "Alice"}	[1,2,3]
SELECT * FROM t1 WHERE ( JSON_UNQUOTE(JSON_EXTRACT(c3, '$.name')) = 'Alice'  OR JSON_EXTRACT(c3, '$.age') > 30  ) AND MATCH(c2) AGAINST('Alice' IN NATURAL LANGUAGE MODE)  order by c3;
c1	c2	c3	c4
1	Alice	{"age": 30, "name": "Alice"}	[1,2,3]
drop INDEX ft_index on t1;
drop  INDEX vector_idx on t1;
CREATE FULLTEXT INDEX ft_index ON t1 (c2);
create vector index idx1 on t1(c4)  with (distance=l2, type=hnsw);
