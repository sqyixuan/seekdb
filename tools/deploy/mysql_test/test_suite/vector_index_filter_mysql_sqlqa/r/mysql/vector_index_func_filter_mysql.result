CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 varchar(20)[] ,c4 vector(3),c5 vector(3),c6 vector(3),
VECTOR INDEX vector_idx1(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40),
VECTOR INDEX vector_idx2(c5) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40),
VECTOR INDEX vector_idx3(c6) 
WITH (distance=l2, type=ivf_pq, m=1));
