purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');
CREATE FULLTEXT INDEX ft_index ON t1 (c2);
REPLACE INTO t1 VALUES(5,'[-1,-3,-2]',null,'[2,3]');
update t1 set c2 ='[]' where c4 is null;
update t1 set c2 ='[]' where c3 is null;
delete from t1 where c3 = (select c3 from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) approximate limit 1) ;
select c1,c2,c4,LENGTH(c2) from t1 where LENGTH(c2) =10  or LENGTH(c2)= 7 order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c4	LENGTH(c2)
2	[1,0,3]	[2,3]	7
select c1,c2,c4,CONCAT(c2,c2) from t1 where CONCAT(c2,c2)='[1,1,2][1,1,2]' or c4 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c4	CONCAT(c2,c2)
2	[1,0,3]	[2,3]	[1,0,3][1,0,3]
3	[-1,2,2]	[4,3]	[-1,2,2][-1,2,2]
select c1,c2,c4,upper(c2) from t1 where upper(c2)='[1,1,2]' or c4 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c4	upper(c2)
2	[1,0,3]	[2,3]	[1,0,3]
3	[-1,2,2]	[4,3]	[-1,2,2]
select c1,c2,c4,lower(c2) from t1 where lower(c2)='[1,1,2]' or c4 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c4	lower(c2)
2	[1,0,3]	[2,3]	[1,0,3]
3	[-1,2,2]	[4,3]	[-1,2,2]
select c1,c2,c4,TO_BASE64(c2) from t1 where TO_BASE64(c2)='WzEsMSwyXQ==' or c4 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c4	TO_BASE64(c2)
2	[1,0,3]	[2,3]	WzEsMCwzXQ==
3	[-1,2,2]	[4,3]	Wy0xLDIsMl0=
SELECT c1, c2 FROM t1 WHERE MATCH(c2) AGAINST('[-1,2,2]' IN NATURAL LANGUAGE MODE) order by l2_distance(c3, [1,2,3]) approximate limit 10;
