drop table if exists t2;
CREATE TABLE t2 (a1 int primary key, a2 VARCHAR(30),a3 varchar(20)[] ,a4 vector(2),
VECTOR INDEX vector_idx(a4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
