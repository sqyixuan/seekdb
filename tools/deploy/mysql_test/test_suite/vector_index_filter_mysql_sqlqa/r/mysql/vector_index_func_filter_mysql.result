CREATE FULLTEXT INDEX ft_index ON t2 (a2);
ALTER TABLE t1 ADD CONSTRAINT fk_parent  FOREIGN KEY (c1) REFERENCES t2(a1) ON DELETE CASCADE ON UPDATE CASCADE;
