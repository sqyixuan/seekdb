purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
drop table if exists t1;
create table t1(c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  vector(3),c6 vector(3) ,c7 vector(3) as (c2), vector index idx1(c3) with (distance=l2, type=hnsw, lib=vsag), vector index idx2(c4) with (distance=l2, type=ivf_flat), vector index idx3(c5) with (distance=l2, type=ivf_sq8), vector index idx4(c6) with (distance=l2, type=ivf_pq,m=1))
PARTITION BY range COLUMNS(c1)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(10)
);
insert into t1(c1,c2,c3,c4,c5,c6) values(1,'[1,2,3]','[-1,2,3]','[1,-2,3]','[-1,2,-3]','[-1,2,-3]');
