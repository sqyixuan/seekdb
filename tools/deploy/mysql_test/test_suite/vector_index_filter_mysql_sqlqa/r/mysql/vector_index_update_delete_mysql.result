replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
select l2_distance(c2,c3) from t1 where c3 is not null order by c1 ;
l2_distance(c2,c3)
