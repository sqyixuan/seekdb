purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
alter system set ob_vector_memory_limit_percentage =44;
## update
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2,  type=ivf_pq, m=1));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
replace /*+log_level(DEBUG) no_rewrite */into t1 select * from t1 order by l2_distance(c3, [0.712338,0.603321,0.133444]) APPROXIMATE limit 100;
update t1 set c1 = 10 where c1 =5;
update t1 set c2 = (select [1,2,3] from dual  order by l2_distance([1,2,3], [0.712338,0.603321,0.133444]) limit 1);
select * from t1 order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1;
c1	c2	c3	c4
1	[1,2,3]	[2,2,3]	[1,3,2]
##where子句
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
update /*+log_level(DEBUG) no_rewrite */t1 set c2 ='[1,2,3]' where c1 =1 order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'APPROXIMATE limit 1' at line 1
update /*+log_level(DEBUG) no_rewrite */t1 set c2 ='[1,2,3]' where c1 =1 order by l2_distance(c2, [0.712338,0.603321,0.133444])  limit 1;
update t1 set c2 ='[1,2,3]' where c1 > (select c1 from t1 where c1 > 2 order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1);
update t1 set c2 ='[2,2,3]' where c1 > (select c1 from t1 where c4 is not null order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1);
update t1 set c4 =(select /*+ ENABLE_PARALLEL_DML parallel(256) */c4 from t1 where c4 is not null order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1) where c1 =5;
update t1 set c4 =(select /*+log_level(DEBUG) no_rewrite */c4 from t1 where c4 is not null order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 1) where c1 =2;
select * from t1 order by l2_distance(c2, [0.712338,0.603321,0.133444]) APPROXIMATE limit 10;
