select id,c1 from t1 where c1 <= 'abc&ABC' order by c1;
select id,c1 from t1 where c1 <> 'abc&ABC' order by c1;

select id,c2 from t1 where c2 = '' order by c2;
select id,c2 from t1 where c2 = 'null' order by c2;
