#窗口函数

select id,row_number() over(partition by c0 order by c0),c0 窗口 from t1 order by c0;
select id,row_number() over(partition by c1 order by c1),c1 窗口 from t1 order by c1;
select id,row_number() over(partition by c2 order by c2),c2 窗口 from t1 order by c2;
select id,row_number() over(partition by c3 order by c3),c3 窗口 from t1 order by c3;
select id,row_number() over(partition by c4 order by c4),c4 窗口 from t1 order by c4;
select id,row_number() over(partition by c5 order by c5),c5 窗口 from t1 order by c5;
select id,row_number() over(partition by c6 order by c6),c6 窗口 from t1 order by c6;

drop table t1;
set _enable_old_charset_aggregation = false;
--echo # Clean up users
connection default;
