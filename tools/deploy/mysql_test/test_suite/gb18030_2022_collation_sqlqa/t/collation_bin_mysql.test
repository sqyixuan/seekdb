--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user longpy@'%';
--enable_warnings
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,longpy,longpy,test,$OBMYSQL_PORT);

set names 'gb18030_2022';
set character_set_database = 'gb18030_2022';
set character_set_server = 'gb18030_2022';
show session variables like '%collation%';
show variables like 'character%';

--error 0,1051
drop table t1;
create table t1(c0 char(20) character set gb18030_2022 collate gb18030_2022_bin,c1 varchar(20) character set gb18030_2022 collate gb18030_2022_bin,c2 tinytext character set gb18030_2022 collate gb18030_2022_bin,c3 text character set gb18030_2022 collate gb18030_2022_bin,c4 mediumtext character set gb18030_2022 collate gb18030_2022_bin,c5 longtext character set gb18030_2022 collate gb18030_2022_bin,c6 set('×Ö','ˇû') character set gb18030_2022 collate gb18030_2022_bin,c7 enum('ÄĐ','ÅŽ') character set gb18030_2022 collate gb18030_2022_bin,id int auto_increment primary key);

--source mysql_test/test_suite/gb18030_2022_collation_sqlqa/t/collation_all_gb18030_1_mysql.inc

