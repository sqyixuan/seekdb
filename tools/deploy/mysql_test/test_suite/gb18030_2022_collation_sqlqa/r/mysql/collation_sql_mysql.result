#Environmental cleaning
drop user longpy@'%';
create user longpy identified by 'longpy';
grant all on *.* to longpy WITH GRANT OPTION;
set names 'gb18030_2022';
set character_set_database = 'gb18030_2022';
set character_set_server = 'gb18030_2022';
show session variables like '%collation%';
Variable_name	Value
collation_connection	gb18030_2022_chinese_ci
collation_database	gb18030_2022_chinese_ci
collation_server	gb18030_2022_chinese_ci
default_collation_for_utf8mb4	utf8mb4_general_ci
show variables like 'character%';
Variable_name	Value
character_sets_dir	
character_set_client	gb18030_2022
character_set_connection	gb18030_2022
character_set_database	gb18030_2022
character_set_filesystem	binary
character_set_results	gb18030_2022
character_set_server	gb18030_2022
character_set_system	utf8mb4
set _enable_old_charset_aggregation = true;
drop table t1;
create table t1(c0 varchar(100) collate gb18030_2022_bin,c1 varchar(100) collate gb18030_2022_chinese_ci,c2 varchar(100) collate gb18030_2022_chinese_cs,c3 varchar(100)collate gb18030_2022_radical_ci,c4 varchar(100) collate gb18030_2022_radical_cs,c5 varchar(100) collate gb18030_2022_stroke_ci,c6 varchar(100) collate gb18030_2022_stroke_cs,sal int,id int auto_increment primary key) character set gb18030_2022;
