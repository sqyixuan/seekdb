# owner: dachuan.sdc
# owner group: SQLQA
# tags: timeout
# description: ddl timeout
# author: wb-dhg594709
alter session set nls_date_format ='YYYY-MM-DD HH24:MI:SS';
set ob_query_timeout=100000000;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connection obsys;
alter system set _ob_ddl_timeout = '10s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';

--disable_warnings
--disable_query_log
call oceanbase.drop_tenant_force('tenant1');
call oceanbase.create_oracle_tenant_mini('tenant1');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings

connect(conn1, $OBMYSQL_MS0, sys@tenant1,,*NO-ONE*,$OBMYSQL_PORT);
connection conn1;

--enable_query_log
--echo create table
--disable_warnings
--error 0,00942
drop table ddlto_create11;
--error 0,00942
drop table ddlto_create12;
--enable_warnings
create table ddlto_create11(c1 int,c2 date,c3 varchar2(10));
delimiter /;
begin for i in reverse 0..20000 loop insert into ddlto_create11 select i,sysdate,i from dual; end loop;end;
/
delimiter ;/
select count(*) from ddlto_create11;
create table ddlto_create12 partition by hash(c2)subpartition by range(c1)subpartition template(subpartition p1 values less than (4),subpartition p2 values less than (maxvalue))partitions 10 as select * from ddlto_create11 union all select * from ddlto_create11 union all select * from ddlto_create11;
drop table ddlto_create11;
drop table ddlto_create12;


--echo create view
--disable_warnings
--error 0,01418
drop index ddlto_create_t2_idx;
--error 0,00942
drop view ddlto_create_v2;
--error 0,00942
drop table ddlto_create_t2;
--error 0,00600
drop synonym ddlto_create_s2;
--enable_warnings
create table ddlto_create_t2(c1 int primary key,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 100;
delimiter /;
begin for i in reverse 0..20000 loop insert into ddlto_create_t2 select i,sysdate+i,i from dual; end loop;end;
/
delimiter ;/
create index ddlto_create_t2_idx on ddlto_create_t2(c2);
select count(*) from ddlto_create_t2;
create or replace view ddlto_create_v2 as select * from ddlto_create_t2 where c1 in(select c3 from ddlto_create_t2 where c2 in (select c2 from ddlto_create_t2 where c2>sysdate));
create synonym ddlto_create_s2 for ddlto_create_t2;
drop synonym ddlto_create_s2;
drop view ddlto_create_v2;
drop table ddlto_create_t2;


--echo create trigger
--disable_warnings
--error 0,00942
drop table ddlto_create_t3;
--error 0,04080
drop trigger ddlto_create_tt3;
--enable_warnings
create table ddlto_create_t3(c1 int,c2 date,c3 nchar(5)) partition by hash(c1) partitions 100;
delimiter /;
create or replace trigger ddlto_create_tt3 
before insert on ddlto_create_t3 
for each row
begin 
if :new.c1 <=0 then
select :new.c1+100 into :new.c1 from dual;
else
select :new.c1+1 into :new.c1 from dual;
end if;
end;
/
delimiter ;/
insert into ddlto_create_t3(c1) values(1);
insert into ddlto_create_t3(c1) values(-1);
select * from ddlto_create_t3;

--echo create synonym
--disable_warnings
--error 0,00942
drop table ddlto_create_t4;
--error 0,00942
drop view ddlto_create_v4;
--error 0,00600
drop synonym ddlto_create_s4;
--enable_warnings
create table ddlto_create_t4(c1 int,c2 date);
delimiter /;
begin for i in reverse 0..2000 loop insert into ddlto_create_t4 select i,sysdate+i from dual; end loop;end;
/
delimiter ;/
create synonym ddlto_create_s4 for ddlto_create_t4;
create view ddlto_create_v4 as select * from ddlto_create_t4;
drop view ddlto_create_v4;
drop synonym ddlto_create_s4;
drop table ddlto_create_t4;

--echo create sequence

--echo create trigger/procedure/function/package
--disable_warnings
--error 0,00942
drop table ddlto_create_tb5;
--error 0,04080
drop trigger ddlto_create_tg5;
--error 0,00600
drop procedure ddlto_create_pc5;
--error 0,00600
drop function ddlto_create_ft5;
--enable_warnings
create table ddlto_create_tb5(c1 int,c2 date,c3 nchar(5));
delimiter /;
create or replace package ddlto_create_p6 is PROCEDURE P1(A VARCHAR2,I  OUT NUMBER); end;
/
create or replace trigger ddlto_create_tg5 before insert on ddlto_create_tb5 for each row begin if :new.c1 <=0 then select :new.c1+100 into :new.c1 from dual;end if;end;
/
create or replace procedure ddlto_create_pc5 as begin insert into ddlto_create_tb5 values(1,sysdate,'h'); end;
/
create or replace function ddlto_create_ft5 return varchar2 is r varchar2(4000); t int; r1 varchar2(4000); begin dbms_output.get_line(r, t); while t != 1 loop dbms_output.get_line(r1, t);r := r || chr(10) || r1;end loop;return r;end;
/
delimiter ;/
drop function ddlto_create_ft5;
drop procedure ddlto_create_pc5;
drop trigger ddlto_create_tg5;
drop table ddlto_create_tb5;


--echo batch create table
--echo create trigger/procedure/function/package
--disable_warnings
--error 0,00600
drop procedure ddlto_create_tbc;
--error 0,00600
drop procedure ddlto_delete_tbc;
--enable_warnings
delimiter /;
create or replace procedure ddlto_create_tbc(cnt_min in number,cnt_max in number,table_name_bf in VARCHAR2)
--echo oracle需在此处加上"Authid Current_User"，否则报错 insufficient privileges
Authid Current_User
is
begin
declare
cnt int := cnt_min;
p_n varchar2(100);
sqlstr varchar2(100);
begin
while cnt <=cnt_max loop
p_n := table_name_bf||cnt;
sqlstr := 'create table '||p_n||'(c1 int,c2 date) partition by hash(c1)';
execute immediate sqlstr;
cnt := cnt + 1;
end loop;
end;
end ddlto_create_tbc;
/
create or replace procedure ddlto_delete_tbc(cnt_min in number,cnt_max in number,table_name_bf in VARCHAR2) 
--echo oracle需在此处加上"Authid Current_User"，否则报错 insufficient privileges
Authid Current_User
is
begin
declare
cnt int := cnt_min;
p_n varchar2(100);
sqlstr varchar2(100);
begin
while cnt <=cnt_max loop
p_n := table_name_bf||cnt;
sqlstr := 'drop table '||p_n;
execute immediate sqlstr;
cnt := cnt + 1;
end loop;
end;
end ddlto_delete_tbc;
/
delimiter ;/
call ddlto_create_tbc(1,100,'ddlto_create_bc61');
call ddlto_delete_tbc(1,100,'ddlto_create_bc61');
--echo 确保创建的测试表都已删除
select table_name from all_Tables where lower(table_name) like 'ddlto_create_bc61%';

purge recyclebin;

connection obsys;
--disable_query_log
call oceanbase.drop_tenant_force('tenant1');
--enable_query_log
