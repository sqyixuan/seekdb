# owner: dachuan.sdc
# owner group: SQLQA
# tags: timeout
# description: ddl timeout alter
# author: wb-dhg594709

alter session set nls_date_format ='YYYY-MM-DD HH24:MI:SS';
alter session set nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
alter session set nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
set ob_query_timeout=100000000;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connect (test,$OBMYSQL_MS0,test@oracle,test,test,$OBMYSQL_PORT);
connection obsys;
alter system set _ob_ddl_timeout = '1S';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;

--echo constraint->not null
--disable_warnings
--error 0,00942
drop table ddlto_alter1;
--enable_warnings
#--error 00600
#create table ddlto_alter1(c1 int not null,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 200;
connection obsys; 
alter system set _ob_ddl_timeout = '10S';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
sleep 2;
create table ddlto_alter1(c1 int not null,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 200;
connection obsys;
alter system set _ob_ddl_timeout = '1s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;

purge recyclebin;

--echo constraint->primary key
--disable_warnings
--error 0,00942
drop table ddlto_alter2;
--enable_warnings
#--error 00600
#create table ddlto_alter2(c1 int primary key,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 200;
connection obsys;
alter system set _ob_ddl_timeout = '10s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
sleep 2;
create table ddlto_alter2(c1 int primary key,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 200;
connection obsys;
alter system set _ob_ddl_timeout = '1s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
drop table ddlto_alter2;
purge recyclebin;

--echo constraint->unique
--disable_warnings
--error 0,00942
drop table ddlto_alter3;
--enable_warnings
create table ddlto_alter3(c1 int primary key,c2 date,c3 varchar2(10)) partition by hash(c1) partitions 100;
--echo unique/index 不受限制
alter table ddlto_alter3 add constraint un_da_c1 unique(c3);
--echo alter table drop constraint 现在只支持删除 check 和 外键约束
drop index un_da_c1;
drop table ddlto_alter3;

--echo constraint->foreign key
--disable_warnings
--error 0,00942
drop table ddlto_alter42;
--error 0,00942
drop table ddlto_alter41;
--enable_warnings
create table ddlto_alter41(c1 int,c2 date,c3 nvarchar2(5),constraint t1_pk2 primary key(c1,c2));
#--error 00600
#create table ddlto_alter42(c1 int,c2 date,c3 nvarchar2(5),foreign key(c1,c2) references ddlto_alter41(c1,c2)) partition by hash(c1) partitions 200;
connection obsys;
alter system set _ob_ddl_timeout = '10s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
sleep 2;
create table ddlto_alter42(c1 int,c2 date,c3 nvarchar2(5),constraint fk_a_b foreign key(c1,c2) references ddlto_alter41(c1,c2)) partition by hash(c1) partitions 200;
--echo enable/disable 目前未实现
#alter table ddlto_alter42 disable novalidate constraint fk_a_b;
#alter table ddlto_alter42 enable novalidate constraint fk_a_b;
#alter table ddlto_alter41 disable novalidate primary key;
#alter table ddlto_alter41 enable novalidate primary key;
connection obsys;
alter system set _ob_ddl_timeout = '1s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
drop table ddlto_alter42;
drop table ddlto_alter41;
purge recyclebin;

--echo constraint->check
--disable_warnings
--error 0,00942
drop table ddlto_alter5;
--enable_warnings
#--error 00600
#create table ddlto_alter5(c1 int,c2 date,constraint dda_c1 check(c1 between 5000 and 50000)) partition by hash(c1) partitions 500;
connection obsys;
alter system set _ob_ddl_timeout = '10s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
sleep 2;
create table ddlto_alter5(c1 int,c2 date,constraint dda_c1 check(c1 between 5000 and 50000)) partition by hash(c1) partitions 200;
drop table ddlto_alter5;
purge recyclebin;

--echo table alter
--disable_warnings
--error 0,00942
drop table ddlto_alter6;
--enable_warnings
create table ddlto_alter6(c1 int,c2 int,c3 timestamp,c6 date,c7 char(5),c8 varchar2(10),c9 number(6,2),c10 int generated always as (c1+c2),constraint t1_pk1 primary key(c1, c2)) partition by hash(c1)subpartition by range(c2)subpartition template(subpartition p1 values less than (4),subpartition p2 values less than (maxvalue))partitions 100;
connection obsys;
alter system set _ob_ddl_timeout = '1s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
#delimiter //;
#begin for i in reverse 0..20000 loop insert into ddlto_alter6(c1,c2,c3,c6,c7,c8,c9) select i,i,sysdate+i,sysdate-i,i,i,i/3 from dual; end loop;end;
#//
#delimiter ;//
select c1,c2,c7,c8,c9,c10 from ddlto_alter6 where c1<5 order by c1;
alter table ddlto_alter6 rename column c3 to c3_new;
alter table ddlto_alter6 add c4 varchar(10) default 'new_colm';
comment on column ddlto_alter6.c4 is '测试表注释信息';
select c1,c2,c7,c8,c9,c10 from ddlto_alter6 where c1<5 order by c1;
alter table ddlto_alter6 drop column c4;
--error 00600
alter table ddlto_alter6 drop column c2;
alter table ddlto_alter6 enable row movement;
alter table ddlto_alter6 modify c1 int;
drop table ddlto_alter6;

--echo index alter
--disable_warnings
--error 0,01418
drop index ddlto_alter71_idx;
--error 0,00942
drop table ddlto_alter71;
--enable_warnings
create table ddlto_alter71(c1 int primary key,c2 date,c3 number(6,2)) partition by hash(c1) partitions 50;
#delimiter //;
#begin for i in reverse 0..20000 loop insert into ddlto_alter71 select i,sysdate+i,i/3 from dual; end loop;end;
#//
#delimiter ;//
create index ddlto_alter71_idx on ddlto_alter71(c1,c2);
--echo rename index not support
#alter index ddlto_alter71_idx rename to ddlto_alter71_idx1;
--echo merge index not support
#alter index ddlto_alter71_idx coalesce;
--echo create index again not support
#alter index ddlto_alter71_idx rebuild;
drop index ddlto_alter71_idx;
drop table ddlto_alter71;




