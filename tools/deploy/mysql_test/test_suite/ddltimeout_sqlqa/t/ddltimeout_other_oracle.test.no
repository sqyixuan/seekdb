# owner: dachuan.sdc
# owner group: SQLQA
# tags: timeout
# description: ddl timeout
# author: wb-dhg594709

connect (audit_tenant,$OBMYSQL_MS0,oraauditor@oracle,,TEST,$OBMYSQL_PORT);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connect (test,$OBMYSQL_MS0,test@oracle,test,test,$OBMYSQL_PORT);

alter session set nls_date_format ='YYYY-MM-DD HH24:MI:SS';
alter session set nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
alter session set nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
set ob_query_timeout=100000000; 

connection obsys;
alter system set _ob_ddl_timeout = '10S';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
--echo AUDIT
--echo dl audit_tenant obclient -h100.88.109.130 -P54911 -uoraauditor@oracle -Dtest
connection audit_tenant;
alter system set audit_sys_operations = 'true';
alter system set audit_trail = 'DB,EXTENDED';
audit all;
audit all statements;
--echo NOAUDIT
noaudit all;
noaudit all statements;
connection test;
--echo FLASHBACK
--disable_warnings
--error 0,00942
drop table ddlto_other1;
--enable_warnings
create table ddlto_other1(c1 int,c2 date,c3 varchar2(10));
delimiter /;
begin for i in reverse 0..2000 loop insert into ddlto_other1 select i,sysdate,i from dual; end loop;end;
/
delimiter ;/
commit;
select count(*) from ddlto_other1;
drop table ddlto_other1;
connection obsys;
let $drop_table_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where lower(original_name)='ddlto_other1' order by gmt_create desc, object_name, 1);
connection test;
--disable_query_log
eval flashback table $drop_table_name to before drop;
--enable_query_log
select count(*) from ddlto_other1;
drop table ddlto_other1;

--echo PURGE
connection obsys;
alter system set _ob_ddl_timeout = '1s';
select name,data_type,value from oceanbase.__all_sys_parameter where name = '_ob_ddl_timeout';
connection test;
purge recyclebin;
show recyclebin;


