result_format: 4
##控制 Hybrid Hash DM 是否开启的开关##
alter system set _px_join_skew_handling = 1;
##设置并行 join 中倾斜值必须满足的最低频率，出现比例小于该频率的值都不算倾斜值##
alter system set _px_join_skew_minfreq = 10;
##ADD_DATA##
drop procedure if exists insert_data;
create PROCEDURE insert_data(tab_nam varchar(100),var int)
begin
	set @i = 1;
	
	while @i <= var do
		SET @IN_VA_SQL = CONCAT(
		"INSERT INTO ",tab_nam," VALUES (",@i,",",@i,");");
		
		PREPARE STMT FROM @IN_VA_SQL;
		EXECUTE STMT;
		
		set @i = @i+1;
	end while;
	deallocate PREPARE STMT;
end;
//
drop procedure if exists insert_data_oneval;
create PROCEDURE insert_data_oneval(tab_nam varchar(20),var int)
begin
	set @i = 1;
	SET @IN_VA_SQL = CONCAT("INSERT INTO ",tab_nam," VALUES (1,1);");
	PREPARE STMT FROM @IN_VA_SQL;
	while @i <= var do
		EXECUTE STMT;
		set @i = @i+1;
	end while;
	deallocate PREPARE STMT;
end;
//
drop procedure if exists insert_data_onecol;
create PROCEDURE insert_data_onecol(tab_nam varchar(20),col varchar(20),var int)
begin
	set @i = 1;
	SET @IN_VA_SQL = CONCAT("INSERT INTO ",tab_nam,"(",col,") VALUES (1);");
	PREPARE STMT FROM @IN_VA_SQL;
	while @i <= var do
		EXECUTE STMT;
		set @i = @i+1;
	end while;
	deallocate PREPARE STMT;
end;
//
drop table if exists FF1;
drop table if exists FF2;
create table FF1 (A1 int , B1 int);
call insert_data('FF1',10);
create table FF2 (A2 INT , B2 INT);
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);
##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');
##except:hybrid hash##
##pq_distribute控制连接的分发方式##
