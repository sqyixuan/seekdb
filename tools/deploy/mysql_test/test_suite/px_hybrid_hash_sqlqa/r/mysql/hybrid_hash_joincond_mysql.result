| COUNT(*) |
+----------+
|        0 |
+----------+
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L RIGHT JOIN FF2 PARTITION(P0) R ON L.A2 = R.B2 WHERE L.A2 < L.A2 ORDER BY L.B2;
+----------+
| COUNT(*) |
+----------+
|        0 |
+----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L , FF2 PARTITION(P5) R WHERE L.B2 = R.B2 OR L.A2 IS NOT NULL ORDER BY L.B2;
