SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P4) L INNER JOIN FF2 PARTITION(P5) R ON L.B2 = R.B2 WHERE L.A2 IS NOT NULL ORDER BY L.A2;
