###SUBPARTITION###
drop table if exists FF2;
create table FF2 (A2 int , B2 int) PARTITION BY RANGE(A2)
SUBPARTITION BY HASH(B2)
(PARTITION P1 VALUES LESS THAN (10)
 (SUBPARTITION SP1,SUBPARTITION SP2),
 PARTITION P2 VALUES LESS THAN (20)
 (SUBPARTITION SP3,SUBPARTITION SP4),
 PARTITION P3 VALUES LESS THAN (30)
 (SUBPARTITION SP5,SUBPARTITION SP6),
 PARTITION P4 VALUES LESS THAN (40)
 (SUBPARTITION SP7,SUBPARTITION SP8),
 PARTITION P5 VALUES LESS THAN (50)
 (SUBPARTITION SP9,SUBPARTITION SP10),
 PARTITION P6 VALUES LESS THAN (MAXVALUE)
 (SUBPARTITION SP11,SUBPARTITION SP12));
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);
##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');
