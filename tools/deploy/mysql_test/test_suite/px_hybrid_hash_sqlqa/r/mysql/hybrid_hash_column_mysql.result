##FUNCTION##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ SUM(L.A1),MAX(L.A1),MIN(L.A1),AVG(L.A1) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = UPPER(L.A1);
+-----------+-----------+-----------+-----------+
| SUM(L.A1) | MAX(L.A1) | MIN(L.A1) | AVG(L.A1) |
+-----------+-----------+-----------+-----------+
|        65 |        10 |         1 |    3.2500 |
+-----------+-----------+-----------+-----------+
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MIN(L.B1) FROM FF1 L , FF2 R WHERE R.A2 = CEILING(L.B1) OR L.A1 NOT BETWEEN -10 AND 10 ORDER BY 1;
+-----------+
| MIN(L.B1) |
+-----------+
|         1 |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ SUM(L.A1) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = FLOOR(L.A1) WHERE L.A1 <> L.A1 ORDER BY 1;
+-----------+
| SUM(L.A1) |
+-----------+
|      NULL |
+-----------+
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ SUM(R.A2) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = CRC32(L.A1) WHERE R.B2 NOT LIKE '%1%' ORDER BY 1;
+-----------+
| SUM(R.A2) |
+-----------+
|      1860 |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MAX(L.B1) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = ROUND(L.B1) WHERE L.A1 NOT BETWEEN -10 AND 10 ORDER BY 1;
+-----------+
| MAX(L.B1) |
+-----------+
|      NULL |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MAX(L.A1) FROM FF1 L , FF2 R WHERE R.B2 = SIGN(L.A1) AND L.B1 NOT LIKE '%1%' ORDER BY 1;
+-----------+
| MAX(L.A1) |
+-----------+
|         9 |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MIN(L.B1) FROM FF1 L , FF2 R WHERE R.B2 = SIGN(L.B1) ORDER BY 1;
+-----------+
| MIN(L.B1) |
+-----------+
|         1 |
+-----------+
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MIN(R.A2) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = BIT_COUNT(L.A1) WHERE L.B1 NOT BETWEEN -10 AND 10 ORDER BY 1;
+-----------+
| MIN(R.A2) |
+-----------+
|      NULL |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ AVG(L.B1) FROM FF1 L INNER JOIN FF2 R ON R.A2 = CEILING(L.B1) WHERE L.B1 BETWEEN -10 AND 10 ORDER BY 1;
+-----------+
| AVG(L.B1) |
+-----------+
|    3.2500 |
+-----------+
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MAX(L.B1) FROM FF1 L , FF2 R WHERE R.A2 = CEIL(L.B1) ORDER BY 1;
+-----------+
| MAX(L.B1) |
+-----------+
|        10 |
+-----------+
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ MIN(L.A1) FROM FF1 L , FF2 R WHERE R.A2 = FLOOR(L.A1) AND R.A2 IS NOT NULL ORDER BY 1;
+-----------+
| MIN(L.A1) |
+-----------+
|         1 |
+-----------+
drop table if exists FF1;
drop table if exists FF2;
