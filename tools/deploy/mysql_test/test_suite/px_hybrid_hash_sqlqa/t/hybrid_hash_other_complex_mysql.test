SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.A3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.B2 AND Y.B2 = Z.A3 AND Y.A2 != Y.B2
UNION
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.A1) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.A2 AND Y.A2 = Z.A3 OR X.A1 LIKE 1;

