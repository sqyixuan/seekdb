UNION
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.B1) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.B2 = Z.A3 OR Y.B2 != Y.B2;

