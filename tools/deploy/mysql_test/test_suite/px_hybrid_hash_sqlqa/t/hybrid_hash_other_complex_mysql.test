#owner: peihan.dph
#owner group: sql2
#description: 一些其他得复杂场景使用hybrid hash（多表，union）
#tags:
#author: wb-zc01084078

--result_format 4

##控制 Hybrid Hash DM 是否开启的开关##
alter system set _px_join_skew_handling = 1;
##设置并行 join 中倾斜值必须满足的最低频率，出现比例小于该频率的值都不算倾斜值##
alter system set _px_join_skew_minfreq = 10;

--source insert_data_mysql.inc


###############OTHER SCENES##################
####多表连接####

--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
drop table if exists FF3;
--enable_warnings


CREATE TABLE FF1 (A1 INT, B1 INT,PRIMARY KEY (A1));
CREATE TABLE FF2 (A2 INT, B2 INT);
CREATE TABLE FF3 (A3 INT, B3 INT);

call insert_data('FF1',10);
call insert_data('FF2',66);
call insert_data('FF3',33);

call insert_data_oneval('FF2',10);
call insert_data_oneval('FF3',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');
call dbms_stats.gather_table_stats(NULL,'FF3',method_opt=>'for all columns size 100');
call dbms_stats.gather_table_stats(NULL,'FF1',method_opt=>'for all columns size 100');

##单个连接调hybrid##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3;

##USE HASH##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3;

##USE MERGE##
SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3;


##两个连接都调hybrid##
##USE HASH##
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3;

##USE MERGE##
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 INNER JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 INNER JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 RIGHT JOIN FF3 Z ON Y.B2 = Z.B3;


SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 , FF3 Z WHERE Y.B2 = Z.B3;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 , FF3 Z WHERE Y.B2 = Z.B3;



###GROUP BY###
##USE_HASH##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MAX(Y.A2) NOT LIKE '%1%' ORDER BY 1;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3 GROUP BY Z.B3 HAVING MIN(Z.B3) IS NOT NULL ORDER BY 1;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3 GROUP BY X.B1 HAVING COUNT(X.B1) LIKE 1 ORDER BY 1;



##USE_MERGE##
SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MAX(Y.A2) NOT LIKE '%1%' ORDER BY 1;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3 GROUP BY Z.B3 HAVING MIN(Z.B3) IS NOT NULL ORDER BY 1;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3 GROUP BY X.B1 HAVING COUNT(X.B1) LIKE 1 ORDER BY 1;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON X.A1 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;

##USE_HASH##
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MAX(Y.A2) IS NULL ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MAX(Y.A2) IS NOT NULL ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X, FF2 Y, FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;


##USE_MERGE##
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MIN(Y.A2) IS NOT NULL ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.A2 HAVING MAX(Y.A2) IS NOT NULL ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X, FF2 Y, FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3 GROUP BY Y.B2 HAVING MAX(Y.B2) = 1 ORDER BY 1;


SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/
COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.A2 = Z.A3
WHERE X.A1 = Y.A2 OR X.B1 = Y.B2 OR Z.B3 = Y.B2;

##三次hybrid##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE R.B2 = SOME (SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ Z.B3 FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.A2 AND X.A1 = Z.A3 AND X.A1 NOT LIKE '%1%' );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE R.A2 IN (SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ Y.B2 FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.A2 AND X.B1 = Z.A3 AND X.A1 BETWEEN -10 AND 10 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE R.A2 NOT IN (SELECT /*+ LEADING(X Y ) USE_HASH(Y)  PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ X.B1 FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.A2 WHERE Y.B2 IS NOT NULL );


##################UNION,EXCEPT,MINUS,INTERSECT###################
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1
UNION
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF3 R ON R.A3 = L.A1 ;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1
INTERSECT
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF3 R ON R.A3 = L.A1 ;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1
MINUS
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF3 R ON R.A3 = L.A1 ;


SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND Y.B2 = Z.A3 OR X.A1 < Y.B2
MINUS
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 RIGHT JOIN FF3 Z ON Y.B2 = Z.A3 WHERE Y.B2 BETWEEN -10 AND 10;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND Y.A2 = Z.A3 AND Y.A2 BETWEEN -10 AND 10
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.B2 AND X.B1 = Z.A3 OR Y.B2 < Y.A2;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.A2) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 INNER JOIN FF3 Z ON X.B1 = Z.A3 WHERE Y.A2 LIKE 1
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.B2 INNER JOIN FF3 Z ON Y.B2 = Z.A3 WHERE X.B1 NOT LIKE '%1%';

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.B1) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.B2 AND Y.B2 = Z.A3 AND Y.A2 BETWEEN -10 AND 10
UNION
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND X.A1 = Z.A3 OR X.B1 LIKE 1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.A2 AND X.B1 = Z.A3 OR X.B1 NOT LIKE '%1%'
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND Y.B2 = Z.A3 OR X.A1 NOT LIKE '%1%';

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND X.A1 = Z.A3 OR X.A1 NOT LIKE '%1%'
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.A3) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.A2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 WHERE X.A1 LIKE 1;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON X.A1 = Z.A3 WHERE Y.B2 LIKE 1
UNION
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.A2) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND X.B1 = Z.A3 OR X.A1 IS NOT NULL;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.A2) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.B2 INNER JOIN FF3 Z ON Y.A2 = Z.A3 WHERE Y.A2 LIKE 1
UNION
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.A3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND Y.A2 = Z.A3 AND X.B1 IS NOT NULL;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.A2 RIGHT JOIN FF3 Z ON X.A1 = Z.A3 WHERE Y.B2 IS NOT NULL
UNION
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.A3) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.A2 INNER JOIN FF3 Z ON X.B1 = Z.A3 WHERE X.B1 <= X.A1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.B3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.A2 AND X.B1 = Z.A3 OR X.A1 NOT BETWEEN -10 AND 10
UNION
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.A2) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.A2 INNER JOIN FF3 Z ON Y.B2 = Z.A3 WHERE X.B1 <> X.B1;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.A1) FROM FF1 X INNER JOIN FF2 Y ON X.A1 = Y.B2 RIGHT JOIN FF3 Z ON Y.B2 = Z.A3 WHERE X.B1 NOT BETWEEN -10 AND 10
UNION
SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.B2 AND X.B1 = Z.A3 AND Y.A2 NOT BETWEEN -10 AND 10;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.A2) FROM FF1 X RIGHT JOIN FF2 Y ON X.B1 = Y.A2 RIGHT JOIN FF3 Z ON X.B1 = Z.A3 WHERE X.A1 NOT LIKE '%1%'
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.B1) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND X.A1 = Z.A3 AND Y.B2 NOT BETWEEN -10 AND 10;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.B2 INNER JOIN FF3 Z ON X.B1 = Z.A3 WHERE X.A1 > X.B1
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Z.A3) FROM FF1 X , FF2 Y , FF3 Z WHERE X.B1 = Y.B2 AND X.B1 = Z.A3 AND Y.B2 IS NOT NULL;

SELECT /*+ LEADING(X Y Z) USE_MERGE(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(Y.B2) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.A2 INNER JOIN FF3 Z ON Y.B2 = Z.A3 WHERE X.A1 NOT LIKE '%1%'
INTERSECT
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.B1) FROM FF1 X RIGHT JOIN FF2 Y ON X.A1 = Y.B2 INNER JOIN FF3 Z ON Y.B2 = Z.A3 WHERE Y.B2 NOT BETWEEN -10 AND 10;

SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.A1) FROM FF1 X INNER JOIN FF2 Y ON X.B1 = Y.A2 RIGHT JOIN FF3 Z ON X.B1 = Z.A3 WHERE Y.A2 LIKE 1
UNION
SELECT /*+ LEADING(X Y Z) USE_HASH(Y Z) PQ_DISTRIBUTE(Z HASH HASH) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(X.B1) FROM FF1 X , FF2 Y , FF3 Z WHERE X.A1 = Y.B2 AND Y.A2 = Z.A3 AND Y.B2 <= Y.B2;

