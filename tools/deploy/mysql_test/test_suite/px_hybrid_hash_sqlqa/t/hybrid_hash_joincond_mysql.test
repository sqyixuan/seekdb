#owner: peihan.dph
#owner group: sql2
#description: 各种join条件下使用hybrid hash，以及分区表场景下使用hybrid hash
#tags:
#author: wb-zc01084078

--result_format 4

##控制 Hybrid Hash DM 是否开启的开关##
alter system set _px_join_skew_handling = 1;
##设置并行 join 中倾斜值必须满足的最低频率，出现比例小于该频率的值都不算倾斜值##
alter system set _px_join_skew_minfreq = 10;

--source insert_data_mysql.inc

--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
--enable_warnings

create table FF1 (A1 int , B1 int);
call insert_data('FF1',10);

create table FF2 (A2 INT , B2 INT);
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

##except:hybrid hash##
##pq_distribute控制连接的分发方式##
#explain select /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(2)*/ COUNT(*) from FF1 L RIGHT JOIN FF2 R ON L.A1 = R.A2;

#explain EXTENDED select /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(2)*/ COUNT(*) from FF1 L INNER JOIN FF2 R ON L.B1 = R.B2;

#explain EXTENDED select /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(2)*/ COUNT(*) from FF1 L , FF2 R WHERE L.B1 = R.B2 AND L.A1 = R.B2;


####SELF_JOIN####
##HASH JOIN##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L RIGHT JOIN FF2 R ON R.A2 = L.A2 AND R.A2 = L.B2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.A2 OR R.B2 = L.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L , FF2 R WHERE R.A2 = L.B2 OR L.B2 = R.A2 AND L.A2 = R.A2;

##MERGE JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L RIGHT JOIN FF2 R ON R.A2 = L.A2 AND R.A2 = L.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.A2 OR R.B2 = L.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L , FF2 R WHERE R.A2 = L.B2 OR L.B2 = R.A2 AND L.A2 = R.A2;

##AND join_condition##
##RIGHT JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND L.B1 IS NOT NULL;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = L.A1 AND R.A2 LIKE 1;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON L.B1 = R.A2 AND R.A2 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = L.B1 AND L.B1 > R.B2;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND L.A1 > R.A2;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON L.A1 = R.B2 AND R.B2 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON L.B1 = R.B2 AND L.A1 NOT BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND L.B1 IS NULL;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND L.A1 IS NULL;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 AND L.B1 NOT LIKE '%1%';

##INNER JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.B1 AND L.B1 IS NOT NULL;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.B2 = L.A1 AND R.A2 LIKE 1;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON L.B1 = R.A2 AND R.A2 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.B1 AND L.B1 > R.B2;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.A2 = L.B1 AND L.A1 > R.A2;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.A1 = R.B2 AND R.B2 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.B2 AND L.A1 NOT BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.A2 = L.B1 AND L.B1 IS NULL;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.B1 AND L.A1 IS NULL;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 AND L.B1 NOT LIKE '%1%';
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.B2 AND L.B1 IS NULL;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON L.B1 = R.B2 AND R.B2 <> L.A1;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.A1 = R.B2 AND R.A2 IS NOT NULL;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.A2 = L.B1 AND R.A2 NOT BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.A1 AND L.B1 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.A1 AND L.B1 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON L.A1 = R.A2 AND L.B1 BETWEEN -10 AND 10;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.A2 = L.A1 AND R.A2 LIKE 1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.B1 AND R.A2 LIKE 1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.B1 AND L.B1 NOT BETWEEN -10 AND 10;


##complex##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.B2 = L.A1
OR L.A1 IS NOT NULL
AND R.B2 != L.A1
AND R.A2 >= L.B1
OR R.A2 NOT LIKE '%1%'
AND R.B2 NOT BETWEEN -10
AND 10 ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.A2 OR R.B2 <> L.A1 AND R.B2 LIKE 1 AND R.A2 < L.B1 AND L.A1 IS NOT NULL OR R.B2 NOT BETWEEN -10 AND 10 ORDER BY R.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.B2 AND L.B1 NOT LIKE '%1%' OR L.A1 BETWEEN -10 AND 10 OR L.B1 > R.A2 OR R.A2 NOT LIKE '%1%' OR L.A1 NOT BETWEEN -10 AND 10 ORDER BY L.B1;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.A2 = L.B1 OR L.B1 BETWEEN -10 AND 10 OR R.B2 NOT BETWEEN -10 AND 10 OR L.B1 LIKE 1 AND L.B1 <> L.B1 OR R.B2 LIKE 1 ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON L.A1 = R.B2 OR L.B1 >= R.A2 AND R.B2 BETWEEN -10 AND 10 AND R.A2 BETWEEN -10 AND 10 OR R.A2 LIKE 1 OR L.A1 BETWEEN -10 AND 10 ORDER BY L.B1;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.A1 AND L.A1 LIKE 1 AND R.B2 LIKE 1 AND R.A2 BETWEEN -10 AND 10 OR R.B2 NOT LIKE '%1%' OR L.A1 BETWEEN -10 AND 10 ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON L.A1 = R.A2 OR R.A2 <> R.A2 OR R.A2 != R.B2 OR L.A1 BETWEEN -10 AND 10 OR L.B1 NOT LIKE '%1%' AND L.A1 NOT LIKE '%1%' ORDER BY L.A1;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.B1 OR L.B1 >= L.A1 AND L.A1 NOT BETWEEN -10 AND 10 OR L.B1 NOT BETWEEN -10 AND 10 AND R.B2 > L.A1 OR R.B2 <> R.A2 ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.A1 OR L.B1 NOT LIKE '%1%' OR L.A1 NOT LIKE '%1%' OR L.B1 NOT LIKE '%1%' AND R.B2 IS NOT NULL AND R.B2 BETWEEN -10 AND 10 ORDER BY L.B1;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 OR L.B1 BETWEEN -10 AND 10 AND R.B2 BETWEEN -10 AND 10 OR R.B2 BETWEEN -10 AND 10 OR L.A1 NOT LIKE '%1%' OR R.A2 LIKE 1 ORDER BY R.B2;


####group by####
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L RIGHT JOIN FF2 R ON R.A2 = L.B2 GROUP BY L.A2 HAVING MAX(L.A2) = 1;


####order by####
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.B2 = L.A1 WHERE R.B2 IS NOT NULL ORDER BY L.A1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 WHERE R.A2 = R.B2 ORDER BY L.A1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.B1 WHERE L.B1 IS NOT NULL ORDER BY L.B1;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.A1 = R.A2 AND R.B2 LIKE 1 ORDER BY L.A1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = L.A1 WHERE L.B1 NOT BETWEEN -10 AND 10 ORDER BY R.B2;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.B2 OR L.A1 NOT LIKE '%1%' ORDER BY L.B1;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = L.A1 WHERE R.B2 BETWEEN -10 AND 10 ORDER BY L.A1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE R.B2 = L.A1 OR L.A1 NOT LIKE '%1%' ORDER BY R.A2;
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 R WHERE L.B1 = R.B2 OR L.B1 NOT BETWEEN -10 AND 10 ORDER BY L.B1;
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L RIGHT JOIN FF2 R ON L.B1 = R.B2 WHERE R.A2 NOT BETWEEN -10 AND 10 ORDER BY L.A1;

####limit####
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L , FF2 R WHERE R.B2 = L.A2 LIMIT 1;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L , FF2 R WHERE R.B2 = L.B2 LIMIT 1;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.A2 LIMIT 1;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L RIGHT JOIN FF2 R ON R.A2 = L.B2 LIMIT 1;


####partition####
###RANGE PARTITION###
--disable_warnings
drop table if exists FF2;
--enable_warnings

create table FF2 (A2 int , B2 int) PARTITION BY RANGE(A2)
(PARTITION P0 VALUES LESS THAN (10),
 PARTITION P1 VALUES LESS THAN (20),
 PARTITION P2 VALUES LESS THAN (30),
 PARTITION P3 VALUES LESS THAN (40),
 PARTITION P4 VALUES LESS THAN (50),
 PARTITION P5 VALUES LESS THAN (60),
 PARTITION P6 VALUES LESS THAN (MAXVALUE));

call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

##HASH JOIN##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P0) L RIGHT JOIN FF2 PARTITION(P0) R ON R.A2 = L.B2 AND R.A2 = L.A2 ;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L INNER JOIN FF2 PARTITION(P0) R ON R.B2 = L.A1;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L , FF2 PARTITION(P0) R WHERE R.A2 = L.B2 AND L.A2 = R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 L , FF2 PARTITION(P1) R WHERE R.A2 = L.B1 AND L.A1 = R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P6) L RIGHT JOIN FF2 PARTITION(P0) R ON R.A2 = L.B2 ;

##MERGE JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L RIGHT JOIN FF2 R ON R.A2 = L.B2 AND R.A2 = L.B2;


SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.B2 AND L.A2 = R.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L , FF2 R WHERE R.A2 = L.B2 AND L.B2 = R.B2 OR R.A2 = L.A2;


###hash PRATITION###
--disable_warnings
drop table if exists FF2;
--enable_warnings

create table FF2 (A2 int , B2 int) PARTITION BY HASH(A2) PARTITIONS 6 ;

call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P4) L INNER JOIN FF2 PARTITION(P5) R ON L.B2 = R.B2 WHERE L.A2 IS NOT NULL ORDER BY L.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P4) L INNER JOIN FF2 PARTITION(P0) R ON L.B2 = R.B2 WHERE R.A2 NOT LIKE '%1%' ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P4) L , FF2 PARTITION(P1) R WHERE L.B2 = R.B2 AND L.A2 BETWEEN -10 AND 10 ORDER BY R.B2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L RIGHT JOIN FF2 PARTITION(P0) R ON L.A2 = R.B2 WHERE L.A2 < L.A2 ORDER BY L.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L , FF2 PARTITION(P5) R WHERE L.B2 = R.B2 OR L.A2 IS NOT NULL ORDER BY L.B2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L INNER JOIN FF2 PARTITION(P5) R ON L.A2 = R.B2 WHERE R.A2 NOT LIKE '%1%' ORDER BY L.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P0) L RIGHT JOIN FF2 PARTITION(P2) R ON R.A2 = L.B2 WHERE L.A2 BETWEEN -10 AND 10 ORDER BY L.B2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P5) L , FF2 PARTITION(P1) R WHERE L.A2 = R.A2 OR L.B2 NOT BETWEEN -10 AND 10 ORDER BY L.B2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P4) L , FF2 PARTITION(P4) R WHERE L.A2 = R.B2 AND R.B2 BETWEEN -10 AND 10 ORDER BY R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P0) L , FF2 PARTITION(P4) R WHERE R.A2 = L.A2 AND L.B2 NOT BETWEEN -10 AND 10 ORDER BY R.A2;


###SUBPARTITION###
#RANGE-HASH#
--disable_warnings
drop table if exists FF2;
--enable_warnings

create table FF2 (A2 int , B2 int) PARTITION BY RANGE(A2)
SUBPARTITION BY HASH(B2)
(PARTITION P1 VALUES LESS THAN (10)
 (SUBPARTITION SP1,SUBPARTITION SP2),
 PARTITION P2 VALUES LESS THAN (20)
 (SUBPARTITION SP3,SUBPARTITION SP4),
 PARTITION P3 VALUES LESS THAN (30)
 (SUBPARTITION SP5,SUBPARTITION SP6),
 PARTITION P4 VALUES LESS THAN (40)
 (SUBPARTITION SP7,SUBPARTITION SP8),
 PARTITION P5 VALUES LESS THAN (50)
 (SUBPARTITION SP9,SUBPARTITION SP10),
 PARTITION P6 VALUES LESS THAN (MAXVALUE)
 (SUBPARTITION SP11,SUBPARTITION SP12));

call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

##HASH JOIN##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP10) L RIGHT JOIN FF2 R ON R.A2 = L.B2 AND R.A2 = L.A2 ;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP7) L INNER JOIN FF2 PARTITION(P1) R ON L.B2 = R.B2 WHERE R.A2 IS NULL ORDER BY L.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP1) L , FF2 PARTITION(SP2) R WHERE R.A2 = L.B2 AND L.A2 = R.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L RIGHT JOIN FF2 PARTITION(SP1) R ON R.A2 = L.B2 ;

##MERGE JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP10) L RIGHT JOIN FF2 R ON R.A2 = L.B2 AND R.A2 = L.A2 ;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 L INNER JOIN FF2 R ON R.B2 = L.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP7) L INNER JOIN FF2 PARTITION(P1) R ON L.B2 = R.B2 WHERE R.A2 IS NULL ORDER BY L.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(SP1) L , FF2 PARTITION(SP2) R WHERE R.A2 = L.B2 AND L.A2 = R.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 PARTITION(P1) L RIGHT JOIN FF2 PARTITION(SP1) R ON R.A2 = L.B2 ;


####VIEW####
###VIEW不能统计信息，所以不能作为右表进行hybrid###
--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
--enable_warnings

create table FF1 (A1 int , B1 int);
call insert_data('FF1',10);

create table FF2 (A2 INT , B2 INT);
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

--disable_warnings
drop VIEW if exists VV01;
drop VIEW if exists VV02;
--enable_warnings

CREATE VIEW VV01 AS SELECT * FROM FF1;
CREATE VIEW VV02 AS SELECT * FROM FF2;

##HASH JOIN##
SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM VV01 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND R.A2 = L.A1 ;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM VV02 L INNER JOIN FF2 R ON R.B2 = L.A2;

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM VV02 L , FF2 R WHERE R.A2 = L.B2 AND L.A2 = R.A2;

##MERGE JOIN##
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM VV01 L RIGHT JOIN FF2 R ON R.A2 = L.B1 AND R.A2 = L.B1;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM  VV02 L INNER JOIN FF2 R ON R.B2 = L.B2 AND L.A2 = R.A2 WHERE L.B2 = R.A2;

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM VV02 L , FF2 R WHERE R.A2 = L.B2 AND R.A2 = L.A2;

--disable_warnings
drop VIEW if exists VV01;
drop VIEW if exists VV02;

drop table if exists FF1;
drop table if exists FF2;
--enable_warnings
