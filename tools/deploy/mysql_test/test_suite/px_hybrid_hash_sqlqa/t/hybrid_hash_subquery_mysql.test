###FROM###
SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM (SELECT /*+ LEADING(L1 R1) USE_HASH(R1) PQ_DISTRIBUTE(R1 HASH HASH) PARALLEL(4)*/ * FROM FF1 L1 RIGHT JOIN FF2 R1 ON R1.A2 = L1.A1) X,(SELECT /*+ LEADING(L2 R2) USE_HASH(R2) PQ_DISTRIBUTE(R2 HASH HASH) PARALLEL(4)*/ * FROM FF1 L2 RIGHT JOIN FF2 R2 ON R2.A2 = L2.A1) Y WHERE X.A1 = Y.A2;


SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM
(SELECT /*+ LEADING(L1 R1) USE_MERGE(R1) PQ_DISTRIBUTE(R1 HASH HASH) PARALLEL(4)*/ * FROM FF1 L1 INNER JOIN FF2 R1 ON R1.A2 = L1.A1) X INNER JOIN
(SELECT /*+ LEADING(L2 R2) USE_MERGE(R2) PQ_DISTRIBUTE(R2 HASH HASH) PARALLEL(4)*/ * FROM FF1 L2 INNER JOIN FF2 R2 ON R2.A2 = L2.A1) Y
ON X.A1 = Y.A2;

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L INNER JOIN FF2 R ON R.B2 = L.B1 WHERE L.B1 BETWEEN -10 AND 10 ORDER BY 1) X RIGHT JOIN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L , FF2 R WHERE L.A1 = R.B2 AND L.B1 IS NULL ORDER BY 1) Y ON X.A1 = Y.A2;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 WHERE L.B1 IS NULL ORDER BY 1) X RIGHT JOIN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L , FF2 R WHERE R.A2 = L.B1 OR R.B2 <= R.B2 ORDER BY 1) Y ON X.B1 = Y.A2;

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L , FF2 R WHERE R.A2 = L.B1 OR R.B2 NOT BETWEEN -10 AND 10 ORDER BY 1) X RIGHT JOIN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ * FROM FF1 L , FF2 R WHERE R.A2 = L.B1 AND L.A1 IS NULL ORDER BY 1) Y ON X.A1 = Y.B2;


