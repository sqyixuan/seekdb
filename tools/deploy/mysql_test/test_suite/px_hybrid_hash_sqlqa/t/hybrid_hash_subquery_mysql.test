SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ANY (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ALL (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =SOME (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE NOT EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);


####子查询外调hybrid####
##RIGHT JOIN 不会触发hybrid,=ALL也不会触发hybrid##
##USE HASH##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 =SOME (SELECT X.B1 FROM FF1,FF2 WHERE FF1.A1 = FF2.A2);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 IN (SELECT X.B1 FROM FF1,FF2 WHERE FF1.A1 = FF2.A2);

