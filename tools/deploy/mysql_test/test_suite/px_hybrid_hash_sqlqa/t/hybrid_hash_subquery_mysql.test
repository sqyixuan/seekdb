#owner: peihan.dph
#owner group: sql2
#description: 子查询使用hybrid hash场景
#tags:
#author: wb-zc01084078

--result_format 4

##控制 Hybrid Hash DM 是否开启的开关##
alter system set _px_join_skew_handling = 1;
##设置并行 join 中倾斜值必须满足的最低频率，出现比例小于该频率的值都不算倾斜值##
alter system set _px_join_skew_minfreq = 10;

--source insert_data_mysql.inc


###############SUBQUERY##################
--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
--enable_warnings

create table FF1 (A1 int , B1 int);
call insert_data('FF1',10);

create table FF2 (A2 INT , B2 INT);
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');


####right semi join\right anti join####
SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE A2 = SOME (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE NOT EXISTS (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE A2 = ANY (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE A2 = ALL (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE A2 IN (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE EXISTS (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );

SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE NOT EXISTS (SELECT L.A1 FROM FF1 L WHERE L.A1 = R.A2 );


SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE R.A2 = ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.A2 FROM FF1 L , FF2 R WHERE R.B2 = BIT_COUNT(L.A1) AND R.B2 LIKE 1 ORDER BY 1 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE NOT EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.B2 = BIT_COUNT(L.A1) WHERE R.A2 LIKE 1 ORDER BY 1 );

SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE NOT EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = SIGN(L.B1) WHERE L.B1 IS NOT NULL ORDER BY 1 );


####子查询内hybrid hash####
###RIGHT JOIN###
SELECT COUNT(*) FROM FF2 WHERE A2 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1 );

###inner join###
SELECT COUNT(*) FROM FF2 WHERE A2 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 NOT IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ALL (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =SOME (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ANY (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ALL (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=SOME (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ANY (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1 );


SELECT COUNT(*) FROM FF2 WHERE A2 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L ,  FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L ,  FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 =ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );

SELECT COUNT(*) FROM FF2 WHERE A2 !=ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1 );


SELECT /*+ LEADING(L R) hash_merge(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF2 R WHERE R.A2 = (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ COUNT(L.A1) FROM FF1 L , FF2 R WHERE R.A2 = L.A1);


####子查询作为连接条件####
####子查询内调hybrid####
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE NOT EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L INNER JOIN FF2 R ON L.B1 = R.A2 WHERE L.A1 <> L.A1 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = SOME (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.B2 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.B1 WHERE R.A2 IS NOT NULL ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.B2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.B2 FROM FF1 L , FF2 R WHERE R.B2 = L.A1 AND R.B2 IS NULL ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L INNER JOIN FF2 R ON L.A1 = R.B2 WHERE R.B2 BETWEEN -10 AND 10 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON NOT EXISTS (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L , FF2 R WHERE L.A1 = R.A2 OR R.A2 LIKE 1 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.A2 FROM FF1 L , FF2 R WHERE L.A1 = R.A2 OR L.A1 IS NULL ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.B2 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L RIGHT JOIN FF2 R ON R.B2 = L.B1 WHERE R.B2 BETWEEN -10 AND 10 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.B2 = ALL (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.B2 FROM FF1 L RIGHT JOIN FF2 R ON L.B1 = R.B2 WHERE L.A1 NOT BETWEEN -10 AND 10 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ R.B2 FROM FF1 L , FF2 R WHERE L.A1 = R.B2 OR L.A1 > R.B2 ORDER BY 1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.B1 FROM FF1 L , FF2 R WHERE R.A2 = L.B1 OR L.A1 IS NULL ORDER BY 1);


####子查询作为other condition####
####子查询内外都调hybrid####
##INNER JOIN##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X INNER JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.A2 = X.A1 AND Y.B2 =SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.A2 = X.A1 AND Y.B2 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.A2 = X.A1 AND Y.B2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.A2 = X.A1 AND EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X , FF2 Y WHERE Y.A2 = X.A1 AND NOT EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);


##RIGHT JOIN##
SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 NOT IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ANY (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =ALL (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 =SOME (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT /*+ LEADING(X Y) USE_HASH(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE NOT EXISTS (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

##USE MERGE##
SELECT /*+ LEADING(X Y) USE_MERGE(Y) PQ_DISTRIBUTE(Y HASH HASH) PARALLEL(4)*/ COUNT(*) FROM FF1 X RIGHT JOIN FF2 Y ON Y.A2 = X.A1 WHERE Y.B2 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ L.A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

