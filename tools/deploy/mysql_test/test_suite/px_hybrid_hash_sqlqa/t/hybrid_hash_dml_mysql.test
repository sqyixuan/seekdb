#owner: peihan.dph
#owner group: sql2
#description: dml使用hybrid hash场景
#tags:
#author: wb-zc01084078

--result_format 4

##控制 Hybrid Hash DM 是否开启的开关##
alter system set _px_join_skew_handling = 1;
##设置并行 join 中倾斜值必须满足的最低频率，出现比例小于该频率的值都不算倾斜值##
alter system set _px_join_skew_minfreq = 10;

--source insert_data_mysql.inc


--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
--enable_warnings

create table FF1 (A1 int , B1 int);
call insert_data('FF1',10);

create table FF2 (A2 INT , B2 INT);
call insert_data('FF2',66);
call insert_data_oneval('FF2',10);

##统计直方图##
call dbms_stats.gather_table_stats(NULL,'FF2',method_opt=>'for all columns size 100');

--disable_warnings
drop table if exists FF3;
--enable_warnings

CREATE TABLE FF3 (A3 INT, B3 INT);

INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;


##INNER JOIN##
INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

##,##
INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L , FF2 R WHERE R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_HASH(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;


###merge join###
##RIGHT JOIN##
INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L RIGHT JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

##INNER JOIN##
INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L INNER JOIN FF2 R ON R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;


##,##
INSERT INTO FF3 SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1,B2 FROM FF1 L , FF2 R WHERE R.A2 = L.A1;

SELECT COUNT(*) FROM FF3;

UPDATE FF3 SET B3 = 1 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;

DELETE FROM FF3 WHERE A3 IN (SELECT /*+ LEADING(L R) USE_MERGE(R) PQ_DISTRIBUTE(R HASH HASH) PARALLEL(4)*/ A1 FROM FF1 L , FF2 R WHERE R.A2 = L.A1);

SELECT COUNT(*) FROM FF3;


--disable_warnings
drop table if exists FF1;
drop table if exists FF2;
drop table if exists FF3;
--enable_warnings


