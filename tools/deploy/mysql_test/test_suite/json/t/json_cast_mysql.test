--disable_warnings
drop table if exists table_json;
--enable_warnings
create table table_json(k1 INT, v1 json);
insert /*+append*/ into table_json value 
(0,'{"Registered" : false}'),
(1,'[false]'),(1,'[false]'),
(5, '{"name": "Eve", "phone": null}'),
(6, '{"name": "Frank", "is_employed": true}'),
(2, '{"name": "Bob", "hobbies": ["reading", "gaming"]}'),
(3, '{"name": "Charlie", "address": {"city": "New York", "zip": "10001"}}'),
(4, '{"name": "Dana", "isStudent": true, "degree": null}'),
(5, '{\n       "name": "Eve",\n       "contacts": {\n           "email": "eve@example.com",\n           "phone": "123-456-7890"\n       },\n       "projects": [\n           {"name": "Project A", "status": "completed"},\n           {"name": "Project B", "status": "ongoing"}\n       ]\n   }'),
(1, '{"name": "Alice", "age": 30}'),
(8, '{"name": "Hank", "birthdate": "1990-01-01"}'),
(10, '{}'),(2,'[0]'),(3,'1'),(4,'0'),(4,'0'),
(5,'false'),(5,'false'),(6,'true'),
(7,null),(7,null),(17,null);

SELECT * FROM table_json where v1 not BETWEEN  '' and  '[false]' order by k1,v1;
SELECT * FROM table_json where v1 not BETWEEN  null and  '[false]' order by k1,v1;
SELECT /*+ MONITOR */ * FROM table_json where v1 not BETWEEN  '{"name": "Bob", "hobbies": ["reading", "gaming"]}' and  '{"name": "Bob", "hobbies": ["reading", "gaming"]}' order by k1,v1;

drop table table_json;

create table table_json (c1 json, c2 varchar(20));
insert into table_json values('"abc"', 'abc');
insert into table_json values(null, null);
select ifnull(c1, c2) a1, ifnull(c2, c1) a2 from table_json;
select ifnull(c1, '') a1, ifnull(c2, '') a2 from table_json;
select nvl(c1, c2) a1, nvl(c2, c1) a2 from table_json;
select nvl(c1, '') a1, nvl(c2, '') a2 from table_json;
select case c1 is null when true then cast('' as char(10)) else c1 end from table_json;

drop table table_json;