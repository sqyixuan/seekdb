drop table if exists t1;
CREATE TABLE `t1` (`a` JSON);
INSERT INTO `t1` VALUES ('{"key1": null}');
SELECT CASE JSON_EXTRACT(t1.a, '$.key1') WHEN 'null' THEN NULL WHEN true THEN true ELSE false END FROM t1;
drop table t1;

