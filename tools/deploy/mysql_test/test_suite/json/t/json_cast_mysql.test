--echo # bugfix: 
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 ( c1 enum('Alice','Bob','Charlie','David') DEFAULT NULL);
create table t2 (c1 json NOT NULL);
select t1.c1,t2.c1 from t1 join t2 where t1.c1 = t2.c1;
insert into t1 values('Alice');
insert into t2 values('"Alice"');
select t1.c1,t2.c1 from t1 join t2 where t1.c1 = t2.c1;
