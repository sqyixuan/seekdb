create table t1(j json);
insert into t1 values('{"key": "123"}');
select json_extract(j, '$.key') = '123' from t1;
select j from t1 where json_extract(j, '$.key') = '123';
drop table t1;

drop table if exists ttt;
create table ttt(c1 int, c2 json);
insert into ttt values(1, '{"page": "0"}');
insert into ttt values(1, '{"page": "1"}');
insert into ttt values(1, '{"page": "2"}');
select * from ttt where c2->'$.page' = '1';
select * from ttt where c2->'$.page' <> '1';
select * from ttt where c2->'$.page' in ('1');
select * from ttt where c2->'$.page' in ('1', '2');
select * from ttt where c2->'$.page' not in ('1');
select * from ttt where c2->'$.page' not in ('1', '2');
select * from ttt where (c1, c2->'$.page') in ((1, '1'));
select * from ttt where (c1, c2->'$.page') in ((1, '1'), (1,'2'));
select * from ttt where (c1, c2->'$.page') not in ((1, '1'));
select * from ttt where (c1, c2->'$.page') not in ((1, '1'), (1,'2'));
drop table if exists ttt;

drop table if exists t1;
CREATE TABLE t1 (c1 int primary key,c4 json)partition by hash(c1) partitions 8;
insert into t1 values(7,'{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4 = '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}';
select * from t1 where c4 <> '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}';
select * from t1 where c4 in ('{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4 not in ('{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
drop table if exists t1;

