create table t1 (c1 int primary key, c2 json);
insert into t1 values(1,'true');
insert into t1 values(2,'123');
insert into t1 values(3,'"asdf"');

select * from t1 where c2 = JSON_PRETTY('true');
select * from t1 where c2 = JSON_PRETTY('123');
select * from t1 where c2 = JSON_PRETTY('"asdf"');
drop table t1;

