  --echo #
  --echo # with ROLLUP + two/three groups
  --echo #

  CREATE TABLE tg (g1 int, g2 int, k int, b VARCHAR(10));
  INSERT INTO tg VALUES
  (1, 1, 1, "alfa"),
  (1, 2, 2, null),
  (2, 3, 3, "doi"),
  (1, 1, 4, "unu"),
  (3, 2, 5, "trei"),
  (4, 3, 6, null),
  (4, 1, 7, null),
  (1, 2, 8, "one");


  SELECT g1, g2, JSON_ARRAYAGG(g2) FROM tg GROUP BY g1, g2 with rollup;
  SELECT g1, g2, JSON_OBJECTAGG(k, g1) FROM tg GROUP BY g1, g2 with rollup;


  CREATE TABLE tg3 (g1 int, g2 int, g3 int, k int, b VARCHAR(10));
  INSERT INTO tg3 VALUES
  (1, 1, 1, 1, "1.1.1"),
  (1, 1, 2, 2, "1.1.2"),
  (1, 1, 3, 3, "1.1.3"),
  (1, 2, 1, 4, "1.2.1"),
  (1, 2, 2, 5, "1.2.2"),
  (1, 2, 3, 6, "1.2.3"),
  (1, 3, 1, 7, "1.3.1"),
  (1, 3, 2, 8, "1.3.2"),
  (1, 3, 3, 9, "1.3.3"),
  (2, 1, 1, 10, "2.1.1"),
  (2, 1, 2, 11, "2.1.2"),
  (2, 1, 3, 12, "2.1.3"),
  (2, 2, 1, 13, "2.2.1"),
  (2, 2, 2, 14, "2.2.2"),
  (2, 2, 3, 15, "2.2.3"),
  (2, 3, 1, 16, "2.3.1"),
  (2, 3, 2, 17, "2.3.2"),
  (2, 3, 3, 18, "2.3.3"),
  (3, 1, 1, 19, "3.1.1"),
  (3, 1, 2, 20, "3.1.2"),
  (3, 1, 3, 21, "3.1.3"),
  (3, 2, 1, 22, "3.2.1"),
  (3, 2, 2, 23, "3.2.2"),
  (3, 2, 3, 24, "3.2.3"),
  (3, 3, 1, 25, "3.3.1"),
  (3, 3, 2, 26, "3.3.2"),
  (3, 3, 3, 27, "3.3.3");


  SELECT g1, g2, g3, JSON_ARRAYAGG(b) FROM tg3 GROUP BY g1, g2, g3 with rollup;
  SELECT g1, g2, g3, JSON_OBJECTAGG(k, b) FROM tg3 GROUP BY g1, g2, g3 with rollup;


  DROP TABLE tg;
  DROP TABLE tg3;

  --echo #
  --echo # Tests duplicates for JSON_OBJECTAGG
  --echo #

  CREATE TABLE t1 (a int, k int, b VARCHAR(10));
  INSERT INTO t1 VALUES
  (1, 1, "1.1"),
  (1, 1, "1.2"),
  (1, 1, "1.3"),
  (2, 2, "2.1"),
  (2, 2, "2.2"),
  (2, 2, "2.3");

  SELECT a, JSON_OBJECTAGG(k, b) FROM t1 GROUP BY a;
  SELECT a, JSON_ARRAYAGG(b) FROM t1 GROUP BY a;

  DROP TABLE t1;

  --echo #
  --echo # Tests with ORDER BY, DISTINCT
  --echo #

  CREATE TABLE t1 (a int, k int, b VARCHAR(10));
  INSERT INTO t1 VALUES
  (2, 8, "2.3"),
  (1, 7, "1.1"),
  (3, 6, "3.2"),
  (2, 5, "2.2"),
  (3, 9, "3.1"),
  (1, 4, "1.2"),
  (3, 3, "3.3"),
  (2, 2, "2.1"),
  (1, 1, "1.3");

  SELECT a, JSON_ARRAYAGG(b) FROM t1 GROUP BY a ORDER BY a;
  SELECT DISTINCT a, JSON_ARRAYAGG(b) FROM t1 GROUP BY a ORDER BY a;
  SELECT DISTINCT a, JSON_ARRAYAGG(b) FROM t1 GROUP BY a ORDER BY a ASC;
  SELECT DISTINCT a, JSON_ARRAYAGG(b) FROM t1 GROUP BY a ORDER BY a DESC;

  SELECT a, JSON_OBJECTAGG(k, b) FROM t1 GROUP BY a ORDER BY a;
  SELECT DISTINCT a, JSON_OBJECTAGG(k, b) FROM t1 GROUP BY a ORDER BY a;
  SELECT DISTINCT a, JSON_OBJECTAGG(k, b) FROM t1 GROUP BY a ORDER BY a ASC;
  SELECT DISTINCT a, JSON_OBJECTAGG(k, b) FROM t1 GROUP BY a ORDER BY a DESC;

  DROP TABLE t1;

  --echo #
  --echo # Tests with joins
  --echo #

  CREATE TABLE t(id INT PRIMARY KEY AUTO_INCREMENT, t1 INT, t2 INT);
  CREATE TABLE p(id INT PRIMARY KEY AUTO_INCREMENT, p1 INT, p2 INT);

  INSERT INTO t(t1, t2) VALUES (1, 1), (2, 1), (3,3), (1, 4);
  INSERT INTO p(p1, p2) VALUES (2, 1), (1, 1), (3,3), (2, 4);


  #Since the JSON_*AGG does not have the ORDER BY clause order is not predictable
  SELECT t1, JSON_ARRAYAGG(t2) FROM t join p on t.t1=p.p1 group by t1;

  # Subquery in ORDER BY with outer reference
  #SELECT (SELECT 1 AS foo ORDER BY JSON_ARRAYAGG(t2)) AS x FROM t;
  #SELECT t1 FROM t ORDER BY (SELECT JSON_ARRAYAGG(t1) FROM t AS t2);
  #SELECT JSON_ARRAYAGG(t1) FROM t
  #ORDER BY (SELECT JSON_ARRAYAGG(t1) FROM t AS t2);

  SELECT (SELECT JSON_ARRAYAGG(t1_outer.t1) FROM t AS t1_inner LIMIT 1) as f
  FROM t AS t1_outer GROUP BY t1_outer.t2;

  DROP TABLE t;
  DROP TABLE p;

  --echo #
  --echo # Tests with JSON
  --echo #

  CREATE TABLE t(id INT PRIMARY KEY AUTO_INCREMENT, k INT, j JSON);
  INSERT INTO t(k, j) VALUES
  (1, '[1,2,3,4]'),
  (2, '{"prop1": 1}'),
  (1, '[3]'),
  (2, '{"prop2": 2, "prop10": 10}'),
  (1, '[99]');


  SELECT k, JSON_ARRAYAGG(j) FROM t GROUP BY k;
  SELECT k, JSON_OBJECTAGG(id, j) FROM t GROUP BY k;

  DROP TABLE t;

  --echo #
  --echo # Coverage tests for val_* functions
  --echo #

  CREATE TABLE t2(gid int, a int);
  INSERT INTO t2(gid, a) VALUES (1, 1), (1, 2), (2, 4), (2, 8);

  SELECT gid, 1.0 * JSON_ARRAYAGG(a) FROM t2 GROUP BY gid;
  SELECT gid, 0x30 << JSON_ARRAYAGG(a) FROM t2 GROUP BY gid;
  SELECT gid, DATE_ADD(JSON_ARRAYAGG(a), INTERVAL 31 DAY)
  FROM t2 GROUP BY gid;
  SELECT gid, SEC_TO_TIME(JSON_ARRAYAGG(a)) FROM t2 GROUP BY gid;

  TRUNCATE TABLE t2;

  SELECT 1.0 * JSON_ARRAYAGG(a) FROM t2;
  SELECT 0x30 << JSON_ARRAYAGG(a) FROM t2;
  SELECT DATE_ADD(JSON_ARRAYAGG(a), INTERVAL 31 DAY) FROM t2;
  SELECT SEC_TO_TIME(JSON_ARRAYAGG(a)) FROM t2;
  CREATE TABLE `nonp_wqh` (`col_auto_id` int(11) NOT NULL, `c_5_ShuF` json DEFAULT NULL);
  insert into nonp_wqh values(1, null);
  insert into nonp_wqh values(2, null);
  --error ER_JSON_DOCUMENT_NULL_KEY
  select json_objectagg(c_5_ShuF, c_5_ShuF) from nonp_wqh;
  select json_objectagg(col_auto_id, c_5_ShuF) from nonp_wqh;
  drop table nonp_wqh;
  DROP TABLE t2;

  CREATE TABLE t3 (a int, k int, b int DEFAULT NULL);
  INSERT INTO t3 VALUES
  (1, 1, null),
  (1, 2, 1),
  (1, 4, null),
  (2, 3, 3);

  SELECT JSON_OBJECTAGG(ISNULL(b), ISNULL(b)) from t3;
  SELECT JSON_ARRAYAGG(ISNULL(b)) from t3;

  select json_arrayagg(ISNULL(null+1)) from dual;
  select json_arrayagg(ISNULL('2021-11-03')) from dual;
  select json_arrayagg('112223333444444' REGEXP 1) from dual;
  select json_arrayagg('112223333444444' REGEXP 5) from dual;
  
  DROP TABLE t3;
  
  --disable_warnings
  drop table if exists test1;
  --enable_warnings
  CREATE TABLE test1(id int ,h1 json,h2 json,h3 json);
  INSERT INTO test1 VALUES (3, '{"name":"zhansan"}', '{"Height": 175}', '[1, {"a": "b"}]');
  INSERT INTO test1 VALUES (1, '{"url": "http://www.example.com"}', '{"abc": "xiaoxue"}', '["abc", 10, "null", true, false]');
  INSERT INTO test1 VALUES (2, '{"url": "http://www.example.com"}', '{"Height": 175}', '{"a": 1, "b": 2, "c": [3, 4, 5], "age":18}');
  SELECT avg(h2) FROM test1 order by h3 asc;
  DROP TABLE test1;

  --error ER_INVALID_JSON_CHARSET
  SELECT JSON_OBJECTAGG(b'1000011011',b'0');
  --error ER_INVALID_JSON_CHARSET
  SELECT JSON_OBJECT(b'1000011011',b'0');

  CREATE TABLE `deergbk` (
    `name` varchar(20) NOT NULL,
    PRIMARY KEY (`name`)
  ) DEFAULT CHARSET = gbk;
  insert into deergbk values('123');
  insert into deergbk values('56');
  insert into deergbk values('张三');
  insert into deergbk values('李四');
  insert into deergbk values('王五');


  SELECT name, JSON_ARRAYAGG(name) FROM deergbk;
  SELECT name, JSON_OBJECTAGG(name, name) FROM deergbk;

  --echo # bugfix: 
  --disable_warnings
  drop table if exists t1;
  --enable_warnings
  create table t1 ( c1 varchar ( 117 )   not null default '@濪TGN*缚y' ,c2 tinyint  unsigned not null ,c3 text ( 348 )   not null ,c4 enum ( 'Alice','Bob','Charlie','David' )   not null default 'David' ,c5 bigint   not null ,c6 datetime   not null ,c7 bit ( 32 )   not null default 2566395611 ,c8 decimal ( 48 , 23 )    default 0 ,c9 smallint  unsigned not null ,c10 date   not null default '1980-03-29' ,c11 decimal ( 21 , 4 )   not null ,c12 json ,c13 bigint   not null default -4556326997450633037 ) charset gbk collate gbk_bin partition by range ( c9 ) ( partition p0 values less than (21936), partition p1 values less than (22619), partition p2 values less than (29638), partition p3 values less than (32976), partition p4 values less than (41178), partition p5 values less than (46634), partition p6 values less than (56734), partition p7 values less than (57933) );
  replace into t1 set c1 = '(盻覲C卟黖kAMH*@_', c2 = 20, c3 = '~*@C80#Ja!a~x+8M0fx', c4 = 'Bob', c5 = -7252762196224462257, c6 = '1972-10-29', c7 = 1639103982, c8 = 170.4885, c9 = 18237, c10 = '2025-05-12', c11 = 935, c12 = "323232323.3232323232", c13 = -6728065068102163110;
  replace into t1 set c1 = '(盻覲C卟黖kAMH*@_', c2 = 20, c3 = '~*@C80#Ja!a~x+8M0fx', c4 = 'Alice', c5 = -7252762196224462257, c6 = '1972-10-29', c7 = 1639103982, c8 = 170.4885, c9 = 18237, c10 = '2025-05-12', c11 = 935, c12 = "323232323.3232323232", c13 = -6728065068102163110;
  select /*+ NO_REWRITE NO_USE_PX ,  PARALLEL( 9 ) */ t1.c3 as r0 , json_objectagg( t1.c4 , t1.c4 ) as r8 from t1;
  select /*+ NO_REWRITE NO_USE_PX ,  PARALLEL( 9 ) */ group_concat( t1.c4 ) as r1 from t1;
  select t1.c3 as r0 , json_objectagg( t1.c4 , t1.c4 ) as r8 from t1 order by r0,r8;
  select json_objectagg( t1.c4 , t1.c4 ) as r8 from t1;
  select json_arrayagg( t1.c4 ) as r8 from t1;
  drop table t1;

  --echo # bugfix: 
  --disable_warnings
  drop table if exists t1;
  drop table if exists t2;
  --enable_warnings
  create table t1 ( c1 enum ( 'Alice','Bob') collate utf8mb4_unicode_ci);
  create table t2 ( c2 bigint  unsigned, c3 int );
  (select t1.c1 from t1) union all (select json_objectagg( t2.c2 , t2.c3 ) from t2);
  insert into t1 values('Alice');
  insert into t2 values(0, 1);
  (select t1.c1 from t1) union all (select json_objectagg( t2.c2 , t2.c3 ) from t2);
  drop table t1;
  drop table t2;
drop table if exists v4;
CREATE TABLE v4 ( v5 INT, v6 INT , v7 INT) ;
INSERT INTO v4 VALUES (4, 5, 6);
--error 5798
SELECT DISTINCT JSON_ARRAYAGG ( DISTINCT v6 ) OVER ( PARTITION BY v7 ) FROM v4;
SELECT DISTINCT JSON_ARRAYAGG ( v6 ) OVER ( PARTITION BY v7 ) FROM v4;
SELECT DISTINCT JSON_ARRAYAGG ( ALL v6 ) OVER ( PARTITION BY v7 ) FROM v4;
--error 5798
SELECT DISTINCT JSON_ARRAYAGG ( DISTINCT v6 ) FROM v4;
SELECT DISTINCT JSON_ARRAYAGG ( v6 ) FROM v4;
SELECT DISTINCT JSON_ARRAYAGG ( ALL v6 ) FROM v4;
drop table v4;

# 64 bit
CREATE TABLE v4(c1 json DEFAULT NULL, c2 bit(64) NOT NULL);
insert into v4 values('{"qty": 100, "item": "canvas", "size": {"h": 28, "w": 35.5, "uom": "cm"}, "tags": ["cotton"]}', 1);
select json_objectagg(c1, c2) as js_object from v4 order by js_object;
drop table v4;
# 10 bit
CREATE TABLE v4(c1 json DEFAULT NULL, c2 bit(10) NOT NULL);
insert into v4 values('{"qty": 100, "item": "canvas", "size": {"h": 28, "w": 35.5, "uom": "cm"}, "tags": ["cotton"]}', 1);
select json_objectagg(c1, c2) as js_object from v4 order by js_object;
drop table v4;