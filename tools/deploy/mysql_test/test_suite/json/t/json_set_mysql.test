#owner: lb446709
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of JSON_SET function.
--echo # ----------------------------------------------------------------------

# NULLs
select json_set(NULL, '$.b', cast(1 as json));
select json_set('[1,2,3]', NULL, cast(1 as json));
select json_set('[1,2,3]', '$[3]', NULL);

# positive test cases

select json_set('[1,2,3]', '$[2]', 4);
select json_set('[1,2,3]', '$[3]', 4);
select json_set('[1,2,3]', '$[10]', 4);

select json_set('{"c":4}', '$.c', 5);
select json_set('{"c":4}', '$.a', 5);

select json_set('1', '$', 4);
select json_set('1', '$[0]', 4);
select json_set('1', '$[1]', 4);
select json_set('1', '$[10]', '4', '$[11]', 5);

select json_set('[1,2,3]', '$[2][0]', 4);
select json_set('[1,2,3]', '$[2][2]', 4);

select json_set('{"a": 3}', '$.a[0]', 4);
select json_set('{"a": 3}', '$.a[1]', 4, '$.a[2]', '5');

# Examples from the specification: Include when missing functions are
# available.

# returns { "a" : {}, "b" : [ 1, 2, 3 ] }
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
                '$.a',
                JSON_OBJECT());

# returns { "a" : "foo", "b" : [ 1, 2, 3 ], "c" : [ true, false ] }
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
              '$.c',
              JSON_ARRAY( true, false ));

# returns { "a" : "foo", "b" : [ 1, 2, 3 ], "c" : [ true, false ] }
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
              '$.c',
              JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) ));

# returns [ 1, null, null, 2 ]
SELECT JSON_SET('1', '$[3]', 2);

# should return { "a": { "b": false, "c": true } }
SELECT JSON_SET('{ "a" : "foo"}', '$.a',
                JSON_OBJECT( 'b', false ), '$.a.c', true);

# returns { "a" : {}, "b" : [ 1, 2, 3 ] }
select json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
              '$.a',
              cast('{}' as json));

# returns { "a" : "foo", "b" : [ 1, 2, 3 ], "c" : [ true, false ] }
select json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
              '$.c',
              cast('[true, false]' as json));

# returns [ 1, null, null, 2 ]
select json_set('1', '$[3]', 2);

# should return { "a": { "b": false, "c": true } }
select json_set('{ "a" : "foo"}', '$.a',
              cast('{"b": false}' as json), '$.a.c', true);

# examples from wl7909 spec
# returns {"a": {}, "b": [1, 2, 3]}
SELECT JSON_SET
(
  '{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
  '$.a',
  JSON_OBJECT()
);

# returns {"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET
(
  '{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
  '$.c',
  JSON_ARRAY( true, false )
);

# returns {"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET
(
  '{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
  '$.c',
  JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) )
);

# returns [1, 2]
SELECT JSON_SET
(
  '1',
  '$[3]',
  2
);

# returns {"a": {"b": false, "c": true}}
SELECT JSON_SET
(
  '{ "a" : "foo"}',
  '$.a', JSON_OBJECT( 'b', false ),
  '$.a.c', true
);

# return {"a": {"a1": [3]}, "b": {"b1": {"c": {"d": 8}}}}
select json_set
(
  '{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": 5}}}}',
  '$.b.b1.c.d', 8
);

# return {"qty": 100, "item": "paper", "size": {"h": 8.5, "w": 11, "uom": "cm"}, "status": "P", "lastModified": 1000}
select json_set
('{"qty": 100,
  "item": "paper",
  "size": {"h": 8.5, "w": 11, "uom": "in"}, "status": "D"
  }',
  '$.size.uom', 'cm',
  '$.status', 'P',
  '$.lastModified', 1000
);

# wrong # args
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_set(NULL);
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_set(NULL, NULL);
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_set(NULL, NULL, NULL, NULL);

# Detect errors in nested function calls.
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SET('{}', '$.name', JSON_EXTRACT('', '$'));

# auto-wrap plus ellipsis with nested hits should give: {"a": [{"b": [3, 6]}, 6]}
--error ER_INVALID_JSON_PATH_WILDCARD
select json_set(cast('{"a": {"b": [3]}}' as json), '$**[1]', 6);

# bug:
select JSON_SET(@j, '$[2][0]', JSON_ARRAY(10, 20, 30));

--error ER_INVALID_JSON_CHARSET
select json_set(UNHEX(""), '$[3]', 2);

SET @j = '{"a": 1, "b": [2, 3], "c": 4}';
select json_set(@j,'$','z','$[0].b[0]',10,'$[0].b[0]',10,'$',null);

SELECT JSON_ARRAYAGG(SPACE("n")) from dual;

--disable_warnings
drop table if exists jsonfunc;
--enable_warnings 
create table jsonfunc (
id int primary key,
json_info json,
c1 json generated always as (JSON_ARRAY(1, "abc", NULL, TRUE)),
c2 json generated always as (JSON_OBJECT('id', 87, 'name', 'carrot')),
c3 json generated always as (JSON_QUOTE('null')),
c4 json generated always as (JSON_UNQUOTE('null')),
c5 json generated always as (JSON_EXTRACT('[10, 20, [30, 40]]', '$[1]')),
c6 json generated always as (JSON_KEYS('{"a": 1, "b": {"c": 30}}')),
c7 json generated always as (JSON_SEARCH('["abc", [{"k": "10"}, "def"], {"x":"abc"}, {"y":"bcd"}]', 'one', 'abc')),
c8 json generated always as (JSON_ARRAY_APPEND('["a", ["b", "c"], "d"]', '$[1]', 1)),
c10 json generated always as (JSON_REMOVE('["a", ["b", "c"], "d"]', '$[1]')),
c11 json generated always as (JSON_DEPTH('true')),
c12 json generated always as (JSON_LENGTH('{"a": 1, "b": {"c": 30}}', '$.b')),
c13 json generated always as (JSON_REPLACE('{ "a": 1, "b": [2, 3]}', '$.a', 10, '$.c', '[true, false]')),
c14 json generated always as (json_info -> '$.id'),
c15 json generated always as (json_info ->> '$.id'),
c16 json generated always as (JSON_SET('{ "a": 1, "b": [2, 3]}', '$.a', 10, '$.c', '[true, false]')));

show  create table  jsonfunc ;
drop table jsonfunc;

# bugfix: 51998949
select json_set('{"a": 3}', '$.a[last-1]', 4, '$.a[last-2]', '5');
select json_set('[1,2,3]', '$[2][last-2]', 4);
select json_set('1', '$[last-1]', 4);

--disable_warnings
drop table if exists json_test;
create table json_test (id int primary key, data json);
insert into json_test values(1, '{ "a" : "foo", "b" : [ 1, 2, 3 ] }');
update json_test set data = json_set(data, '$.a', 'woo') where id = 1;
update json_test set data = json_set(data, '$.b[1]', '1.1') where id = 1;
update json_test set data = json_set(data, '$.b[10]', '10') where id = 1;
select * from json_test;

set log_row_value_options="partial_json"; 
update json_test set data = json_set(data, '$.a', 'xoo') where id = 1;
update json_test set data = json_set(data, '$.b[1]', '1.2') where id = 1;
update json_test set data = json_set(data, '$.b[10]', '101') where id = 1;
select * from json_test;

insert into json_test values(2, '{ "a" : "foo", "b" : [ 1, 2, 3 ] }');
update json_test set data = json_set(json_set(data, '$.b[10]', '101'), '$.b[1]', '1.2', '$.a', 'xoo') where id = 2;
select * from json_test where id=2;
update json_test set data = json_set(data, '$.b[0]', 2) where id = 2;
select * from json_test where id=2;
set log_row_value_options="";

drop table json_test;
