# # Order on stored and virtual generated columns with type JSON.

--disable_warnings
drop table if exists t, t1;
--enable_warnings

CREATE TABLE t(id INT, j JSON);
INSERT INTO t(id, j) VALUES (0, '"5"'), (1, '[]'), (2, '[1,2]'), (3, '5');
select * from t order by j;

insert into t(id,j) values (7, '{"a": 6}'), (8, '{"a": 7}');
select * from t order by j;

insert into t(id,j) values(9, '{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}');
insert into t(id,j) values(10, '{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}');
select * from t order by j;

insert into t(id,j) values(11, '[{"c" : null}, {"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}]');
insert into t(id,j) values(12, '[{"c" : 1}, {"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}]');
select * from t order by j;
insert into t(id,j) values (7, '[1,2]'), (8, '[{"a": null}, {"b": 8}]');
insert into t(id,j) values (7, '1'), (8, '{"a": null}');
select * from t order by j;

truncate table t;

insert into t(id,j) values (7, '1'), (8, '1'), (9, '{"a": null}'), (10, '{"a": null}'),
                           (11, '[{"a": 3}, {"b": 8}]'), (12, '[{"a": 3}, {"b": 8}]'),
                           (13, '{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}'),
                           (14, '{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}'),
						   (15, null), (16, null), (17, '"hello"'), (18, '"hello"');

insert into t(id,j) values (19, cast(cast('2014-11-25 18:00' as datetime) as json)),
                           (20, cast(cast('2014-11-25 18:00' as datetime) as json));

insert into t(id,j) values (21, cast(cast('2014-11-25' as date) as json)),
                           (22, cast(cast('2014-11-25' as date) as json));

insert into t(id,j) values (22, cast(cast('18:00:59' as time) as json)), (23, cast(cast('18:00:59' as time) as json));
insert into t(id,j) values (24, cast(cast(3.14 as decimal(5,2)) as json)), (25, cast(cast(3.14 as decimal(5,2)) as json));
insert into t(id,j) values (26, cast(3.14 as json)), (27, cast(3.14 as json)), (28, cast(3.14 as json));
insert into t(id,j) values (29, cast(3.1415 as json)), (30, cast(3.1415 as json)), (31, cast(3.1415 as json));
insert into t(id,j) values (31, cast(cast(3.141 as double) as json)), (32, cast(cast(3.141 as double) as json));
insert into t(id,j) values (33, cast(true as json)), (34, cast(true as json));
insert into t(id,j) values (35, cast(false as json)), (36, cast(false as json));
insert into t(id,j) values (37, cast(null as json));
insert into t(id,j) values (38, '{"name": "tom", "is_male": true, "age" : 25, "friends" : [{"name":"jim", "is_male": true, "age":21},
                                                                                           {"name":"jerry", "is_male": true, "age":22},
                                                                                           {"name":"Bob", "is_male": true, "age":26}],
                                  "addr": {"country" : "china", "province": "guangdong", "detail" : {"district": "nanshan", "street":"dengliang"}}
                                 }');

insert into t(id,j) values (39, '{"name": "tom", "is_male": true, "age" : 25, "friends" : [{"name":"jim", "is_male": true, "age":21},
                                                                                           {"name":"jerry", "is_male": true, "age":22},
                                                                                           {"name":"Bob", "is_male": true, "age":26}],
                                  "addr": {"country" : "china", "province": "guangdong", "detail" : {"district": "nanshan", "street":"dengliang"}}
                                 }');

insert into t(id,j) values (40, '{"name": "tom", "is_male": true, "age" : 25, "friends" : [{"name":"jim", "is_male": true, "age":21},
                                                                                           {"name":"jerry", "is_male": false, "age":22},
                                                                                           {"name":"Bob", "is_male": true, "age":26}],
                                  "addr": {"country" : "china", "province": "guangdong", "detail" : {"district": "nanshan", "street":"dengliang"}}
                                 }');

insert into t(id,j) values (41, '{"name": "tom", "is_male": true, "age" : 25, "friends" : [{"name":"jim", "is_male": true, "age":21},
                                                                                           {"name":"jerry", "is_male": true, "age":28},
                                                                                           {"name":"Bob", "is_male": true, "age":26}],
                                  "addr": {"country" : "china", "province": "guangdong", "detail" : {"district": "nanshan", "street":"dengliang"}}
                                 }');
select * from t order by j;
select /*+NO_USE_HASH_AGGREGATION*/ j, count(j) from t group by j;
select /*+USE_HASH_AGGREGATION*/ j, count(j) from t group by j;

drop table t;
