--disable_warnings
drop table if exists t1;
create table t1 (col_json json);
insert into t1 values ('["sfsdfasdfasdfasdfasdfasdfasdfasdf","sdfsdfsdfsdfsdfsdsdfsfsdfsdfsdfsd"]');
select json_array(col_json,col_json,217) from t1; 
drop table t1;
