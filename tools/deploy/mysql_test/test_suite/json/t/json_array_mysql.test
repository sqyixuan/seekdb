--echo # ----------------------------------------------------------------------
--echo # Test of JSON_ARRAY function.
--echo # ----------------------------------------------------------------------
select json_array(NULL, '$.b', cast(1 as json));
select json_array('[1,2,3]', NULL, cast(1 as json));
select json_array('[1,2,3]', '$[3]', NULL);
select json_array(38793);
select json_array(129);
select json_array(-8388607);
select json_array(65543);
SELECT JSON_ARRAY(CONCAT('"SQL "', '"汉字 "', '"Gooogle "', '"123456"')) from dual;
SELECT JSON_ARRAY(CONCAT_WS('"SQL "', '"汉字 "', '"Gooogle "', '"123456"')) from dual;
SELECT JSON_ARRAY(SUBSTR("zhangsan", 0, 3)) from dual;
SELECT JSON_ARRAY(SUBSTRING("zhangsan", 0, 3)) from dual;
SELECT JSON_ARRAY(REPEAT("1", -1)) from dual;
--disable_warnings
SELECT JSON_ARRAY(SPACE("n")) from dual;
--enable_warnings
SELECT JSON_ARRAY(LPAD("san",0,"zhang")) from dual;
SELECT JSON_ARRAY(SUBSTR("abcdefg",3,-2)) from dual;
SELECT JSON_ARRAY(POW(16,4.5)) from dual;
SELECT JSON_ARRAY(POWER(6,4.5)) from dual;

# positive test cases
select json_array();
select json_array(3.14);
select json_array('[1,2,3]');
select json_array(cast('[1,2,3]' as json));
select json_array(1,2,3);
select json_array(b'0', b'1', b'10');

