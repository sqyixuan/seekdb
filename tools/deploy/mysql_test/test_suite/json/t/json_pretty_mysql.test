--echo # ----------------------------------------------------------------------
--echo # Test of JSON_OBJECT function.
--echo # ----------------------------------------------------------------------
--error ER_INVALID_TYPE_FOR_JSON        
SELECT JSON_PRETTY(EXTRACT(MICROSECOND FROM 2021-11-11)) from dual;

--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_PRETTY(EXTRACT(WEEK FROM 2021-11-11)) from dual;

--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_PRETTY(EXTRACT(SECOND_MICROSECOND FROM 2021-11-11)) from dual;

--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_PRETTY(EXTRACT(HOUR_SECOND FROM NULL)) from dual;

DROP TABLE IF EXISTS pretty_tab;
CREATE TABLE pretty_tab(id INT PRIMARY KEY AUTO_INCREMENT,
		uc VARCHAR(128) CHARACTER SET utf8mb4,
		lc VARCHAR(128) CHARACTER SET utf8mb4,
		j JSON);

INSERT INTO pretty_tab(uc) VALUES
	(NULL),
	('{}'),
	('[]'),
	('[1,2,3]'),
	('{"a":1,"b":2}'),
	('{"a":[1,{}],"b":[]}'),
	('{"a":{"b":{"c":{"d":{"e":{"f":null}}}}}}'),
	('true'),
	('false'),
	('null'),
	('1'),
	('1.1'),
	('"hello"'),
	(JSON_ARRAY('abcdef', '"abc"'));

UPDATE pretty_tab SET lc = uc, j = uc;
SELECT JSON_PRETTY(uc) AS c1 FROM pretty_tab ORDER BY id;

SELECT JSON_PRETTY(lc) AS c1 FROM pretty_tab ORDER BY id;

SELECT JSON_PRETTY(j) AS c1 FROM pretty_tab ORDER BY id;

SELECT DISTINCT CHARSET(JSON_PRETTY(uc)) AS c1,
				CHARSET(JSON_PRETTY(lc)) AS c2,
				CHARSET(JSON_PRETTY(j)) AS c3 FROM pretty_tab;  

DROP TABLE pretty_tab;

SET @floating_points = '[0.0, -0.0, 1.0, -1.0, 3.14,
					999999999999999.0, -999999999999999.0,
					1000000000000000.0, -1000000000000000.0,
					1e200, -1e200]';
SELECT JSON_PRETTY(@floating_points);

--error ER_INVALID_JSON_CHARSET
select json_pretty(UNHEX(""));