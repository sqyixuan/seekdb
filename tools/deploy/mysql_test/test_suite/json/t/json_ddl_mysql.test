#owner: gehao.wh
#owner group: shenzhen
--echo Verify that JSON columns do not support indexes on create table
--error 3152
CREATE TABLE bad(i INT, j1bad JSON NOT NULL PRIMARY KEY);
--error 3152
CREATE TABLE bad(i INT, j1bad JSON NOT NULL, INDEX j1badindex (j1bad));
--error 3152
CREATE TABLE bad(i INT, j1bad JSON NOT NULL, UNIQUE INDEX j1badindex (j1bad));
--error 3152
CREATE TABLE bad(i INT, j1bad JSON NOT NULL, UNIQUE INDEX j1badindex (j1bad) USING HASH);

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, json, jt01, jt02, jt03, jt03_t2;
--enable_warnings
CREATE TABLE t1(i INT PRIMARY KEY);
ALTER TABLE t1 ADD COLUMN j1 JSON;
ALTER TABLE t1 ADD COLUMN j2 JSON NOT NULL;
# A JSON column cannot be used as a key.
--error ER_JSON_USED_AS_KEY
CREATE INDEX t1_idx_j ON t1(j1);
--error ER_JSON_USED_AS_KEY
CREATE INDEX t1_idx_i_j ON t1(i, j1);
--error ER_JSON_USED_AS_KEY
CREATE INDEX t1_idx_j_i ON t1(j1, i);
CREATE INDEX t1_idx_i ON t1(i);
DROP INDEX t1_idx_i ON t1;
DROP TABLE t1;

#--echo Verify that JSON columns do not support indexes on alter table
CREATE TABLE t2(i INT PRIMARY KEY, j1 JSON, j2 JSON NOT NULL);
--error 3152
ALTER TABLE t2 ADD INDEX j1badindex (j1);
--error 3152
ALTER TABLE t2 ADD UNIQUE INDEX j1badindex (j1);
--error 3152
ALTER TABLE t2 ADD UNIQUE INDEX j1badindex (j1) USING HASH;

--echo Verify that JSON columns can be dropped
ALTER TABLE t2 DROP COLUMN j1;
ALTER TABLE t2 DROP COLUMN j2;
DROP TABLE t2;

# JSON is a non-reserved keyword, so it should be possible to use it
# as an identifier.
CREATE TABLE json(json int);
INSERT INTO json(json) VALUES (1);
SELECT json FROM json;
DROP TABLE json;

# And it should be possible to use it as a label in a stored procedure.
DELIMITER |;
CREATE PROCEDURE p()
BEGIN
  json: LOOP
    LEAVE json;
  END LOOP json;
END|
DELIMITER ;|
CALL p();
DROP PROCEDURE p;

CREATE TABLE t1(txt TEXT CHARACTER SET utf8mb4 COLLATE utf8mb4_bin);
INSERT INTO t1 VALUES ('not JSON');
--replace_regex /#sql-[0-9a-f_]*/#sql-temporary/

--error ER_NOT_SUPPORTED_YET
ALTER TABLE t1 MODIFY COLUMN txt JSON;
SELECT * FROM t1;
CREATE TABLE t2(j JSON);
INSERT INTO t2 VALUES (JSON_OBJECT('a', 'b'));

--error ER_NOT_SUPPORTED_YET
ALTER TABLE t2 MODIFY COLUMN j TEXT CHARACTER SET utf8mb4 COLLATE utf8mb4_bin;
SELECT * FROM t2;

CREATE TABLE t3 (j JSON);
INSERT INTO t3 VALUES (JSON_OBJECT('a', 'b'));

CREATE TABLE t4 AS SELECT UPPER(j) AS jj FROM t3;
INSERT INTO t4 VALUES ('not JSON');

--error ER_NOT_SUPPORTED_YET
ALTER TABLE t4 MODIFY COLUMN jj JSON;
SELECT * FROM t4 order by jj;

create table t5(
  c1 int,
  c2 json,
  check(c2=1)
) charset=utf8;
DROP TABLE t5;

create table t5(
  c1 int,
  c2 json,
  check(c2>1)
) charset=utf8;

# --error 3813 as err-msg differnce everytime disable this case
# alter table t5 modify c2 json check(c1!=c2);

# --error 3813 as err-msg differnce everytime disable this case
# alter table t5 modify c2 json check(xyz);

# ER_BLOB_CANT_HAVE_DEFAULT
--error 1101
alter table t5 alter c2 set default null;

# ER_BLOB_CANT_HAVE_DEFAULT
--error 1101
alter table t5 alter c2 set default "abc";

create table jt01 (c1 int);
insert into jt01 values(1),(2);
alter table jt01 add column jt01_j1 json;
alter table jt01 add column jt01_j2 json not null;
alter table jt01 add column jt01_j3 json default null;
select * from jt01;
alter table jt01 change jt01_j2 jt01_j2 json not null;
select * from jt01;
alter table jt01 change jt01_j2 jt01_j2 json not null;
select * from jt01;

create table jt02 like jt01;
create table jt03 like jt02;

create table jt03_t2 select * from jt01;
select * from jt03_t2;

DROP TABLE t1, t2, t3, t4, t5, jt01, jt02, jt03, jt03_t2;

create table t1(a json,b json);
insert into t1 values('{"sal": 800, "empno": 7369, "ename": "clerk"}','{"sal": 1600, "empno": 7499, "ename": "allen"}'),('{"sal": 1250, "empno": 7521, "ename": "ward"}','{"sal": 2975, "empno": 7566, "ename": "jones"}'),
('{"sal": 2975, "empno": 7654, "ename": "martin"}','{"sal": 2850, "empno": 7698, "ename": "blake"}'),(null,null);
create table t2 select cast(a as char character set utf8mb4) a from t1 order by 1;
drop table t1, t2;

create table t1 (num int);
insert into t1 values(1);
create table t2 as select json_array(t1.num) from t1;
desc t2;
drop table t1,t2;

--disable_warnings
drop table if exists t1;
create table t1(c1 json not null);
insert ignore into t1 values(null);
select * from t1;
drop table t1;

create table t1(pk int primary key, j1 json, j2 json, j3 json, j4 json) json(j1) store as (chunk 1) json(j2) store as (chunk '1K') json(j3) store as (chunk '1');
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j1';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j2';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j3';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j4';
drop table t1;
create table t1(pk int primary key, j1 json, j2 json, j3 json, j4 json) json(j1) store as (chunk 10) json(j2) store as (chunk '2') json(j3) store as (chunk '256K');
alter table t1 add column (j5 json) json(j5) store as(chunk '1k');
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j1';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j2';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j3';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j4';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j5';
drop table t1;
create table t1(pk int primary key);
alter table t1 add column (j1 json) json(j1) store as (chunk '1k');
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j1';
drop table t1;
create table t1(pk int primary key, j1 json, j2 json) json(j1) store as (chunk 1) json(j2) store as (chunk '1');
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j1';
select lob_chunk_size from oceanbase.__all_table t join oceanbase.__all_column c on t.table_id=c.table_id where t.table_name='t1' and column_name='j2';
set _show_ddl_in_compat_mode = 1;
show create table t1;
set _show_ddl_in_compat_mode = 0;
show create table t1;
drop table t1;

create table t0(c1 longtext);
insert into t0 values('');
create table t1(pk int primary key, c1 json, c2 varchar(100), c3 varchar(100));
insert into t1 values(1, concat('{"name": "', repeat('test', 4211),'"}'), '123', '[1,2,3]');
select length(c1) from t1;
alter table t1 drop column c2;
update t1 set c1 = '{"sal": 800, "empno": 7369, "ename": "clerk"}';
drop table t1;
drop table t0;

create table t1(pk int primary key, j json chunk '1k');
insert into t1 values(1, concat('{"k1": 1, "k2":"', repeat('t', 4200), '", "k3": 2, "k4": 3}')); 
alter table t1 add `col_gen_1` varchar(1538) GENERATED ALWAYS AS (JSON_EXTRACT(j, '$.k4')) VIRTUAL;
alter table t1 add  index `gen_idx_1` (`col_gen_1`) LOCAL;
select /*+ index(gen_idx_1) */ col_gen_1 from t1;
# online ddl
let $before_count = query_get_value(select count(*) as cnt from oceanbase.__all_ddl_error_message, cnt, 1);
let $before_table_id = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='t1', cnt, 1);
alter table t1 modify j json chunk 2;
let $after_count = query_get_value(select count(*) as cnt from oceanbase.__all_ddl_error_message, cnt, 1);
let $after_table_id = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='t1', cnt, 1);
if($before_count != $after_count)
{
  --echo may run offline ddl , $before_count , $after_count
}
if($before_table_id != $after_table_id)
{
  --echo may run offline ddl , $before_table_id , $after_table_id
}
select /*+ index(gen_idx_1) */ col_gen_1 from t1;
drop table t1;
