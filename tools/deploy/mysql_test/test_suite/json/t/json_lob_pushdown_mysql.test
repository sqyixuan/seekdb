#owner: aozeliu.azl
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of Json Lob Storage Push Down Filter.
--echo # ----------------------------------------------------------------------

--result_format 4
--explain_protocol 0
--disable_query_log
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set ob_compaction_schedule_interval = '3s';
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 int auto_increment primary key, c2 bigint, c3 text, c4 json)  row_format = compressed block_size = 2048;
create table t2(pk int primary key, j json);
--let $loop=10
while($loop > 0)
{
  eval insert into t1 (c2, c3, c4) values ($loop, repeat('a', 500), '{"key" : "value"}');
  dec $loop;
}
insert into t1 (c2, c3, c4) values(5, NULL, NULL);
--let $loop=9
while($loop > 0)
{
  insert into t1 (c2, c3, c4) select c2 + 1, c3, c4 from t1;
  dec $loop;
}
insert into t1 (c2, c3, c4) values(NULL, NULL, NULL);
select count(1) from t1;

insert into t2 values(1, '{"K":1}');
insert into t2 values(2, '{"K":2}');
insert into t2 values(3, '{"K":3}');
insert into t2 values(4, '{"K":4}');
insert into t2 values(5, '{"K":5}');
insert into t2 values(6, '{"K":6}');

alter system major freeze;
connection syscon;
--source mysql_test/include/wait_daily_merge.inc
connection default;

--enable_query_log
select count(1) from t1;
select count(1) from t1 where c4 = '{"key" : "value"}';
select count(1) from t1 where c4 = json_object('key', 'value');
select count(1) from t1 where c4 != json_object('key', 'value');
select count(1) from t1 where c4 is NULL;
select pk from t2 where  nullif(cast(j as CHAR), cast('{"K": 6}' as json)) is null;
drop table t1;

--enable_warnings
--disable_query_log
connection syscon;
--enable_query_log
