--disable_warnings
drop table if exists t8, t9;
--enable_warnings
create table t8(c0 json, c1 float unsigned, c2 double, c3 int, c4 varchar(24));
create table t9(c0 json, c1 float unsigned, c2 double, c3 int, c4 varchar(24));
insert into t8 values('904557', 904557, 904557, 904557, 904557);
insert into t9 values('904557', 904557, 904557, 904557, 904557);
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c1, t9.c0    FROM t9 join t8 ON t8.c1 = t9.c0;
SELECT  t8.c1, t9.c0    FROM t9 join t8 ON t8.c1 = t9.c0;
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c2, t9.c0    FROM t9 join t8 ON t8.c2 = t9.c0;
SELECT  t8.c2, t9.c0    FROM t9 join t8 ON t8.c2 = t9.c0;
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c3, t9.c0    FROM t9 join t8 ON t8.c3 = t9.c0;
SELECT  t8.c3, t9.c0    FROM t9 join t8 ON t8.c3 = t9.c0;
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c4, t9.c0    FROM t9 join t8 ON t8.c4 = t9.c0;
SELECT  t8.c4, t9.c0    FROM t9 join t8 ON t8.c4 = t9.c0;
drop table t8;
