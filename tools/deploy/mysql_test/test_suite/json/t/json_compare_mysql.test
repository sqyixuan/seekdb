  select cast(1 as json) >= cast(1 as decimal);
  select cast(1 as json) <= cast(1 as decimal);
  select cast(1 as json) < cast(1 as decimal);
  select cast(1 as json) > cast(1 as decimal);

--echo # 6. json uint vs uint
  select cast(cast(1 as unsigned int) as json) = cast(1 as unsigned int);
  select cast(cast(1 as unsigned int) as json) != cast(1 as unsigned int);
  select cast(cast(1 as unsigned int) as json) >= cast(1 as unsigned int);
  select cast(cast(1 as unsigned int) as json) <= cast(1 as unsigned int);
  select cast(cast(1 as unsigned int) as json) < cast(1 as unsigned int);
  select cast(cast(1 as unsigned int) as json) > cast(1 as unsigned int);

--echo # 7. json uint vs int
  select cast(cast(1 as unsigned int) as json) = 1;
  select cast(cast(1 as unsigned int) as json) != 1;
  select cast(cast(1 as unsigned int) as json) >= 1;
  select cast(cast(1 as unsigned int) as json) <= 1;
