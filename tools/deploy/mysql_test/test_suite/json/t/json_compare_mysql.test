  select cast(cast(1 as double) as json) = cast(1 as double);
  select cast(cast(1 as double) as json) != cast(1 as double);
  select cast(cast(1 as double) as json) >= cast(1 as double);
  select cast(cast(1 as double) as json) <= cast(1 as double);
  select cast(cast(1 as double) as json) < cast(1 as double);
  select cast(cast(1 as double) as json) > cast(1 as double);

--echo # 11. json double vs int
  select cast(cast(1 as double) as json) = 1;
  select cast(cast(1 as double) as json) != 1;
  select cast(cast(1 as double) as json) >= 1;
  select cast(cast(1 as double) as json) <= 1;
  select cast(cast(1 as double) as json) < 1;
  select cast(cast(1 as double) as json) > 1;

--echo # 12. json double vs uint
  select cast(cast(1 as double) as json) = cast(1 as unsigned int);
  select cast(cast(1 as double) as json) != cast(1 as unsigned int);
  select cast(cast(1 as double) as json) >= cast(1 as unsigned int);
  select cast(cast(1 as double) as json) <= cast(1 as unsigned int);
