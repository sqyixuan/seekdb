--echo # Test JSON COMPARE
#--source mysql_test/test_suite/json/t/json_compare_mysql_include.in
--echo # ----------------------------------------------------------------------
--echo # Test of JSON COMPARE
--echo # ----------------------------------------------------------------------

#connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#connection conn_admin;
#alter system set _enable_static_typing_engine = false;
#connection default;
--echo # ---------------------------------- json vs json begin ------------------------------------
--echo # 1. json object vs json object (need json object function)
--echo # 2. json array vs json array (need json array function)
--echo # 3. json string vs json string
--error ER_INVALID_JSON_TEXT_IN_PARAM
  select cast("json" as json) = cast("json" as json);
--error ER_INVALID_JSON_TEXT_IN_PARAM
  select cast("json" as json) != cast("json" as json);
 --error ER_INVALID_JSON_TEXT_IN_PARAM
  select cast("json" as json) >= cast("json" as json);
--error ER_INVALID_JSON_TEXT_IN_PARAM
  select cast("json" as json) <= cast("json" as json);
--error ER_INVALID_JSON_TEXT_IN_PARAM  
  select cast("json" as json) > cast("json" as json);
--error ER_INVALID_JSON_TEXT_IN_PARAM
  select cast("json" as json) < cast("json" as json);

--echo # 4. json int vs json int
  select cast(1 as json) = cast(1 as json);
  select cast(1 as json) != cast(1 as json);
  select cast(1 as json) >= cast(1 as json);
  select cast(1 as json) <= cast(1 as json);
  select cast(1 as json) < cast(1 as json);
  select cast(1 as json) > cast(1 as json);

--echo # 5. json int vs json uint
  select cast(1 as json) = cast(cast(1 as unsigned int) as json);
  select cast(1 as json) != cast(cast(1 as unsigned int) as json);
  select cast(1 as json) >= cast(cast(1 as unsigned int) as json);
  select cast(1 as json) <= cast(cast(1 as unsigned int) as json);
  select cast(1 as json) < cast(cast(1 as unsigned int) as json);
  select cast(1 as json) > cast(cast(1 as unsigned int) as json);

--echo # 6. json int vs json double
  select cast(1 as json) = cast(cast(1.0 as double) as json);
  select cast(1 as json) != cast(cast(1.0 as double) as json);
  select cast(1 as json) >= cast(cast(1.0 as double) as json);
  select cast(1 as json) != cast(cast(1.0 as double) as json);
  select cast(1 as json) < cast(cast(1.0 as double) as json);
  select cast(1 as json) > cast(cast(1.0 as double) as json);

--echo # 7. json int vs json decimal
  select cast(1 as json) = cast(cast(1.0 as decimal) as json);
  select cast(1 as json) != cast(cast(1.0 as decimal) as json);
  select cast(1 as json) >= cast(cast(1.0 as decimal) as json);
  select cast(1 as json) <= cast(cast(1.0 as decimal) as json);
  select cast(1 as json) > cast(cast(1.0 as decimal) as json);
  select cast(1 as json) < cast(cast(1.0 as decimal) as json);

--echo # 8. json uint vs json uint
  select cast(cast(1 as unsigned int) as json) = cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as unsigned int) as json) != cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as unsigned int) as json) >= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as unsigned int) as json) <= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as unsigned int) as json) < cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as unsigned int) as json) > cast(cast(1 as unsigned int) as json);

--echo # 9. json uint vs json int
  select cast(cast(1 as unsigned int) as json) = cast(1 as json);
  select cast(cast(1 as unsigned int) as json) != cast(1 as json);
  select cast(cast(1 as unsigned int) as json) >= cast(1 as json);
  select cast(cast(1 as unsigned int) as json) <= cast(1 as json);
  select cast(cast(1 as unsigned int) as json) < cast(1 as json);
  select cast(cast(1 as unsigned int) as json) > cast(1 as json);

--echo # 10. json uint vs json double
  select cast(cast(1 as unsigned int) as json) = cast(cast(1 as double) as json);
  select cast(cast(1 as unsigned int) as json) != cast(cast(1 as double) as json);
  select cast(cast(1 as unsigned int) as json) >= cast(cast(1 as double) as json);
  select cast(cast(1 as unsigned int) as json) <= cast(cast(1 as double) as json);
  select cast(cast(1 as unsigned int) as json) < cast(cast(1 as double) as json);
  select cast(cast(1 as unsigned int) as json) > cast(cast(1 as double) as json);

--echo # 11. json uint vs json decimal
  select cast(cast(1 as unsigned int) as json) = cast(cast(1 as decimal) as json);
  select cast(cast(1 as unsigned int) as json) != cast(cast(1 as decimal) as json);
  select cast(cast(1 as unsigned int) as json) >= cast(cast(1 as decimal) as json);
  select cast(cast(1 as unsigned int) as json) <= cast(cast(1 as decimal) as json);
  select cast(cast(1 as unsigned int) as json) < cast(cast(1 as decimal) as json);
  select cast(cast(1 as unsigned int) as json) > cast(cast(1 as decimal) as json);

--echo # 12. json double vs json double
  select cast(cast(1 as double) as json) = cast(cast(1 as double) as json);
  select cast(cast(1 as double) as json) != cast(cast(1 as double) as json);
  select cast(cast(1 as double) as json) >= cast(cast(1 as double) as json);
  select cast(cast(1 as double) as json) <= cast(cast(1 as double) as json);
  select cast(cast(1 as double) as json) > cast(cast(1 as double) as json);
  select cast(cast(1 as double) as json) < cast(cast(1 as double) as json);

--echo # 13. json double vs json int
  select cast(cast(1 as double) as json) = cast(1 as json);
  select cast(cast(1 as double) as json) != cast(1 as json);
  select cast(cast(1 as double) as json) >= cast(1 as json);
  select cast(cast(1 as double) as json) <= cast(1 as json);
  select cast(cast(1 as double) as json) > cast(1 as json);
  select cast(cast(1 as double) as json) < cast(1 as json);

--echo # 14. json double vs json uint
  select cast(cast(1 as double) as json) = cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as double) as json) != cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as double) as json) >= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as double) as json) <= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as double) as json) > cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as double) as json) < cast(cast(1 as unsigned int) as json);

--echo # 15. json double vs json decimal
  select cast(cast(1 as double) as json) = cast(cast(1 as decimal) as json);
  select cast(cast(1 as double) as json) != cast(cast(1 as decimal) as json);
  select cast(cast(1 as double) as json) >= cast(cast(1 as decimal) as json);
  select cast(cast(1 as double) as json) <= cast(cast(1 as decimal) as json);
  select cast(cast(1 as double) as json) > cast(cast(1 as decimal) as json);
  select cast(cast(1 as double) as json) < cast(cast(1 as decimal) as json);

--echo # 16. json decimal vs json decimal
  select cast(cast(1 as decimal) as json) = cast(cast(1 as decimal) as json);
  select cast(cast(1 as decimal) as json) != cast(cast(1 as decimal) as json);
  select cast(cast(1 as decimal) as json) >= cast(cast(1 as decimal) as json);
  select cast(cast(1 as decimal) as json) <= cast(cast(1 as decimal) as json);
  select cast(cast(1 as decimal) as json) > cast(cast(1 as decimal) as json);
  select cast(cast(1 as decimal) as json) < cast(cast(1 as decimal) as json);

--echo # 17. json decimal vs json int
  select cast(cast(1 as decimal) as json) = cast(1 as json);
  select cast(cast(1 as decimal) as json) != cast(1 as json);
  select cast(cast(1 as decimal) as json) >= cast(1 as json);
  select cast(cast(1 as decimal) as json) <= cast(1 as json);
  select cast(cast(1 as decimal) as json) > cast(1 as json);
  select cast(cast(1 as decimal) as json) < cast(1 as json);

--echo # 18. json decimal vs json uint
  select cast(cast(1 as decimal) as json) = cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as decimal) as json) != cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as decimal) as json) >= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as decimal) as json) <= cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as decimal) as json) > cast(cast(1 as unsigned int) as json);
  select cast(cast(1 as decimal) as json) < cast(cast(1 as unsigned int) as json);

--echo # 19. json decimal vs json double
  select cast(cast(1 as decimal) as json) = cast(cast(1 as double) as json);
  select cast(cast(1 as decimal) as json) != cast(cast(1 as double) as json);
  select cast(cast(1 as decimal) as json) >= cast(cast(1 as double) as json);
  select cast(cast(1 as decimal) as json) <= cast(cast(1 as double) as json);
  select cast(cast(1 as decimal) as json) > cast(cast(1 as double) as json);
  select cast(cast(1 as decimal) as json) < cast(cast(1 as double) as json);

--echo # 20. json boolean vs json boolean
  select cast(true as json) = cast(true as json);
  select cast(true as json) != cast(true as json);
  select cast(true as json) >= cast(true as json);
  select cast(true as json) <= cast(true as json);
  select cast(true as json) > cast(true as json);
  select cast(true as json) < cast(true as json);

--echo # 21. json datetime vs json datetime
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < cast(cast('2015-4-15 09:22:07' as datetime) as json);

--echo # 22. json datetime vs json timestamp
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < cast(timestamp '2015-4-15 09:22:07' as json);

--echo # 23. json time vs json time
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = cast(time '09:22:07' as json); 
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != cast(time '09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= cast(time '09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= cast(time '09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > cast(time '09:22:07' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < cast(time '09:22:07' as json);

--echo # 24. json datetime vs json date
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = cast(date '2015-4-15' as json); 
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != cast(date '2015-4-15' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= cast(date '2015-4-15' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= cast(date '2015-4-15' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > cast(date '2015-4-15' as json);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < cast(date '2015-4-15' as json);

--echo # 25. json opaque vs json opaque

--echo # 26. json null vs json other
  select cast(null as json) = cast(null as json);
  select cast(null as json) = cast(1 as json);
  select cast(null as json) = cast(cast(1 as unsigned int) as json);
  select cast(null as json) = cast(cast(1 as double) as json);
  select cast(null as json) = cast(cast(1 as decimal) as json);
  select cast(null as json) = cast(true as json);
  select cast(null as json) = cast(cast('2015-4-15 09:22:07' as datetime) as json);
  select cast(null as json) = cast(timestamp '2015-4-15 09:22:07' as json);
  select cast(null as json) = cast(time '09:22:07' as json);
  select cast(null as json) = cast(date '2015-4-15 09:22:07' as json);

--echo # ---------------------------------- json vs json end --------------------------------------

--echo # ---------------------------------- json vs other begin -----------------------------------
--echo # 1. json string vs string (not support string cast to json)

--echo # 2. json int vs int
  select cast(1 as json) = 1;
  select cast(1 as json) != 1;
  select cast(1 as json) >= 1;
  select cast(1 as json) <= 1;
  select cast(1 as json) < 1;
  select cast(1 as json) > 1;

