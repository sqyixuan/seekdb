--echo # 19. json datetime vs datetime
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = cast('2015-4-15 09:22:07' as datetime);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != cast('2015-4-15 09:22:07' as datetime);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= cast('2015-4-15 09:22:07' as datetime);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= cast('2015-4-15 09:22:07' as datetime);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > cast('2015-4-15 09:22:07' as datetime);
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < cast('2015-4-15 09:22:07' as datetime);

--echo # 20. json datetime vs timestamp
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = timestamp '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != timestamp '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= timestamp '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= timestamp '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > timestamp '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < timestamp '2015-4-15 09:22:07';

--echo # 21. json time vs time
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = time '09:22:07'; 
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != time '09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= time '09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= time '09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > time '09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < time '09:22:07';

--echo # 22. json date vs date
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) = date '2015-4-15 09:22:07'; 
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) != date '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) >= date '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) <= date '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) > date '2015-4-15 09:22:07';
  select cast(cast('2015-4-15 09:22:07' as datetime) as json) < date '2015-4-15 09:22:07';

--echo # 23. json null vs other
  select cast(null as json) = null;
  select cast(null as json) = 1;
  select cast(null as json) = cast(1 as unsigned int);
  select cast(null as json) = cast(1 as double);
  select cast(null as json) = cast(1 as decimal);
  select cast(null as json) = true;
  select cast(null as json) = cast('2015-4-15 09:22:07' as datetime);
  select cast(null as json) = timestamp '2015-4-15 09:22:07';
  select cast(null as json) = time '09:22:07';
  select cast(null as json) = date '2015-4-15 09:22:07';

--echo # bug:
--disable_warnings
  drop table if exists jemp;
--enable_warnings
  create table jemp(c json, g int generated always as(c->"$.id"));
  insert into jemp(c) values ('{"id":"1","name":"Fred"}'),('{"id":"2","name":"Wilma"}'),('{"id":"3","name":"Barney"}'),('{"id":"4","name":"Betty"}');
  select c, json_extract(c,"$.id"), g from jemp where json_extract (c,"$.id") >1;
  drop table jemp;

-- echo # bug:
  create table jemp1(c json, g int generated always as(c->"$.id"));
  insert into jemp1(c) values ('{"id":"1","name":"Fred"}'),('{"id":"2","name":"Wilma"}'),('{"id":"3","name":"Barney"}'),('{"id":"4","name":"Betty"}');
  select c, c->"$.id" from jemp1 WHERE JSON_EXTRACT(c, "$.id") > 1 order by c->"$.name";
  drop table jemp1;

