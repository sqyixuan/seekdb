  select cast(cast(1 as unsigned int) as json) = cast(1 as double);
  select cast(cast(1 as unsigned int) as json) != cast(1 as double);
  select cast(cast(1 as unsigned int) as json) >= cast(1 as double);
  select cast(cast(1 as unsigned int) as json) <= cast(1 as double);
