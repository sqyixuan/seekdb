#owner: lb446709
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of JSON_KEYS function.
--echo # ----------------------------------------------------------------------

# should all give NULL:
select json_keys(NULL);
select json_keys(NULL, '$.b');
select json_keys(NULL, NULL);
select json_keys('{"a": 1, "b": {"e": "foo", "b": 3}}', '$.a');
select json_keys('{"a": 1, "b": {"e": "foo", "b": 3}}', NULL);

# non NULL results
select json_keys('{"a": 1, "b": {"e": "foo", "b": 3}}');
select json_keys('{"a": 1, "b": {"e": "foo", "b": 3}}', '$.b');

# Examples from the specification
--echo # returns [ "a", "b" ]
SELECT JSON_KEYS('{ "a" : "foo", "b" : [ true, { "c" : "123" } ] }');

--echo # returns []
SELECT JSON_KEYS('{ "a" : "foo", "b" : [ true, { "c" : {} } ] }',
                '$.b[1].c');

--echo # returns NULL
SELECT JSON_KEYS('{ "a" : "foo", "b" : [ true, { "c" : {} } ] }',
                '$.a.b[2]');

# examples from the wl7909 spec
# returns [ "a", "b" ]
SELECT JSON_KEYS
(
  '{ "a" : "foo", "b" : [ true, { "c" : "123" } ] }'
);

# returns []
SELECT JSON_KEYS
(
  '{ "a" : "foo", "b" : [ true, { "c" : {} } ] }',
  '$.b[1].c'
);

# returns NULL
SELECT JSON_KEYS
(
  '{ "a" : "foo", "b" : [ true, { "c" : {} } ] }',
  '$.a.b[2]'
);

--echo # ----------------------------------------------------------------------
--echo # CAST(<json> AS CHAR). See also 'json_conversions.test' for other
--echo # conversion tests.
--echo # ----------------------------------------------------------------------
select cast(json_keys('{"a": 1}') as char);
select cast(json_keys(NULL) as char);

--error ER_INVALID_JSON_PATH_WILDCARD
select json_keys('{"a": 1, "b": {"e": "foo", "b": 3}}', '$.*.b');
--error ER_INVALID_JSON_PATH
SELECT JSON_KEYS('{"a":1}', '1010');
--error ER_INVALID_JSON_PATH
SELECT JSON_KEYS('{"a":1}', '1010') IS NULL;
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
SELECT JSON_KEYS();
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
SELECT JSON_KEYS('{}', '$', '$');

--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(YEAR('2021-10-22')) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(UTC_TIMESTAMP() + 6) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(UNIX_TIMESTAMP('1997-10-04 22:23:00')) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(TO_DAYS('2015-11-04')) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(TIMESTAMPDIFF(SECOND, NOW(), '2011-01-01 11:11:11')) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(PERIOD_DIFF(202110, 202103)) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(MONTH('2021-02-03')) from dual;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_KEYS(DATEDIFF('2001-01-01','2001-02-02')) from dual;

--error ER_INVALID_JSON_CHARSET
select json_keys(UNHEX(""));