#owner: lb446709
#owner group: shenzhen
# ----------------------------------------------------------------------
# Test of JSON_QUOTE, JSON_UNQUOTE
# ----------------------------------------------------------------------

--error ER_INCORRECT_TYPE
select json_quote(from_unixtime(1218169800));

--error ER_INCORRECT_TYPE
select json_quote(cast(from_unixtime(1218169800) as json));

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_quote();

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_quote('abc', 'def');

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_quote(NULL, 'def');

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_quote('abc', NULL);

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_unquote();

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_unquote('"abc"', '"def"');

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_unquote(NULL, 'def');

--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
select json_unquote('"abc"', NULL);

select json_quote(NULL);

select json_unquote(NULL);

select json_quote('abc');
select json_quote(convert('abc' using utf8));
select json_quote(convert('abc' using utf8mb4));
SELECT JSON_UNQUOTE(SUBSTR("zhangsan", 0, 3)) from dual;
SELECT JSON_UNQUOTE(SUBSTRING("zhangsan", 0, 3)) from dual;
SELECT JSON_UNQUOTE(REPEAT("1", -1)) from dual;
SELECT JSON_UNQUOTE(SPACE("n")) from dual;
SELECT JSON_UNQUOTE(LPAD("san",0,"zhang")) from dual;
SELECT JSON_UNQUOTE(RPAD("zhang",0,"san")) from dual;
SELECT JSON_UNQUOTE(SUBSTR("abcdefg",3,-2)) from dual;
SELECT JSON_QUOTE(SUBSTR("zhangsan", 0, 3)) from dual;

SELECT JSON_QUOTE(SUBSTR("zhangsan", -3, -1)) from dual;
SELECT JSON_QUOTE(SUBSTRING("zhangsan", 0, 3)) from dual;
SELECT JSON_QUOTE(SUBSTRING("zhangsan", -3, -1)) from dual;
SELECT JSON_QUOTE(SPACE("n")) from dual;
--error ER_INVALID_JSON_CHARSET
SELECT JSON_QUOTE(QUOTE(null)) from dual;
SELECT JSON_QUOTE(SUBSTR("abcdefg",3,-2)) from dual;
SELECT JSON_QUOTE(SUBSTR("abcdefg",-1,-4)) from dual;

select json_unquote('abc');                      # should do nothing

select json_unquote('"abc"');
select json_unquote(convert('"abc"' using utf8));
select json_unquote(convert('"abc"' using utf8mb4));

select json_quote('"');
select json_unquote('"');                        # should do nothing

--error ER_INCORRECT_TYPE
select json_quote(CURDATE());

--error ER_INCORRECT_TYPE
select json_unquote(CURDATE());

--disable_warnings
drop table if exists json_test_quote_unquote;
--enable_warnings

CREATE TABLE json_test_quote_unquote (jdoc JSON);
INSERT INTO json_test_quote_unquote VALUES('{"key1": "value1", "key2": "value2"}');
INSERT INTO json_test_quote_unquote VALUES(JSON_OBJECT("mascot", "Our mascot is a dolphin named \"Sakila\"."));
SELECT jdoc->"$.mascot" FROM json_test_quote_unquote;
SELECT jdoc->>"$.mascot" FROM json_test_quote_unquote;
drop table json_test_quote_unquote;

--error ER_INCORRECT_TYPE
select json_quote(123);                          # integer not allowed

--error ER_INCORRECT_TYPE
select json_unquote(123);                        # integer not allowed

select json_unquote('""');                       # empty string
select char_length(json_unquote('""'));          # verify empty string
select json_unquote('"" ');                      # unchanged: no final "
select json_unquote(cast(json_quote('abc') as json)); # round trip

# No change in this JSON string: it is an object
select cast('{"abc": "foo"}' as json);
select json_unquote(cast('{"abc": "foo"}' as json));

# This is a JSON string, so it is actually unquoted
select json_extract(cast('{"abc": "foo"}' as json), '$.abc');
select json_unquote(json_extract(cast('{"abc": "foo"}' as json), '$.abc'));

# Bug fix: thse should be the same
select json_unquote('["a", "b", "c"]');
select json_unquote(cast('["a", "b", "c"]' as json));

select charset(json_unquote('"abc"'));

#select json_quote(convert(X'e68891' using utf8));    # chinese "I" (wo3)
#select json_quote(convert(X'e68891' using utf8mb4)); # chinese "I" (wo3)

#select cast(json_quote(convert(X'e68891' using utf8)) as json);

select  json_quote(json_quote(json_quote('abc')));     # deep quote
select  json_unquote(json_unquote(json_unquote(json_quote(json_quote(json_quote('abc'))))));

# DATE/TIME will lose their quotes, too:
select cast(cast('2015-01-15 23:24:25' as datetime) as json);
select json_unquote(cast(cast('2015-01-15 23:24:25' as datetime) as json));

# examples from the wl7909 spec
# returns the SQL string literal abc
SELECT JSON_UNQUOTE( '"abc"' );

# returns the SQL string literal "abc
SELECT JSON_UNQUOTE( '"abc' );

--error ER_INCORRECT_TYPE
SELECT JSON_UNQUOTE( 123 );

# returns the SQL string literal abc
SELECT JSON_UNQUOTE
( CAST( CAST( '"abc"' AS JSON ) AS CHAR ) );


# returns 1
SELECT JSON_UNQUOTE
(
CAST(
	JSON_EXTRACT( '{ "userName" : "fred" }', '$.userName' )
	AS CHAR
)
) = 'fred';

# returns 0
SELECT
CAST(
	JSON_EXTRACT( '{ "userName" : "fred" }', '$.userName' )
	AS CHAR
) = 'fred';

# returns "abc"
SELECT JSON_QUOTE( 'abc' );

--error ER_INCORRECT_TYPE
SELECT JSON_QUOTE( 123 );
# returns the JSON document consisting of the string scalar "123"
SELECT CAST( JSON_QUOTE( '123' ) AS JSON );

SELECT JSON_QUOTE(ACOS(null)) from dual;
SELECT JSON_QUOTE(ASIN(null)) from dual;
SELECT JSON_QUOTE(ATAN(null)) from dual;
SELECT JSON_QUOTE(COT(null)) from dual;
SELECT JSON_QUOTE(LN(-4)) from dual;
SELECT JSON_QUOTE(LOG(-4,-8)) from dual;
SELECT JSON_QUOTE(RADIANS(null)) from dual;
SELECT JSON_QUOTE(ROUND(null)) from dual;
SELECT JSON_QUOTE(CEIL(null)) from dual;
SELECT JSON_QUOTE(FLOOR(null)) from dual;
SELECT JSON_QUOTE(ABS(null)) from dual;
SELECT JSON_QUOTE(SIGN(null)) from dual;
SELECT JSON_QUOTE(MOD(80,null)) from dual;
SELECT JSON_QUOTE(POW(16,null)) from dual;
SELECT JSON_QUOTE(POWER(16,null)) from dual;
--error ER_INCORRECT_TYPE
SELECT JSON_QUOTE(POWER(16,4)) from dual;

SELECT JSON_UNQUOTE(ACOS(null)) from dual;
SELECT JSON_UNQUOTE(ASIN(null)) from dual;
SELECT JSON_UNQUOTE(ATAN(null)) from dual;
SELECT JSON_UNQUOTE(COT(null)) from dual;
SELECT JSON_UNQUOTE(LN(-4)) from dual;
SELECT JSON_UNQUOTE(LOG(-4,-8)) from dual;
SELECT JSON_UNQUOTE(RADIANS(null)) from dual;
SELECT JSON_UNQUOTE(ROUND(null)) from dual;
SELECT JSON_UNQUOTE(CEIL(null)) from dual;
SELECT JSON_UNQUOTE(FLOOR(null)) from dual;
SELECT JSON_UNQUOTE(ABS(null)) from dual;
SELECT JSON_UNQUOTE(SIGN(null)) from dual;
SELECT JSON_UNQUOTE(MOD(80,null)) from dual;
SELECT JSON_UNQUOTE(POW(16,null)) from dual;
SELECT JSON_UNQUOTE(POWER(16,null)) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1( 
c1 int primary key, 
c2 json);
insert into t1 values(1,'["\\b","\\f","\\n","\\r","\\t","\\u0032","\", "\\"",10, null, true, {"b": [1, 2]}, [3, 4]]');

select json_unquote(JSON_EXTRACT(c2,'$[0]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[1]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[2]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[3]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[4]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[5]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[6]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[7]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[8]')) from t1;
select json_unquote(JSON_EXTRACT(c2,'$[9]')) from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--error ER_INVALID_JSON_CHARSET
select JSON_UNQUOTE(UNHEX(""));

--error ER_INVALID_JSON_CHARSET
select JSON_QUOTE(UNHEX(""));
