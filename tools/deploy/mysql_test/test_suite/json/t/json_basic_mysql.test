--echo # Json basic test

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(i int, j1 json, j2 json NOT NULL);
insert into t1 values
(0, NULL, 'null'),
(1, '1', '1'),
(2, '[1,2,3]', '[4,5,6]'),
(3, '{"abc":"def"}', '{"a":"b","c":"d"}');

select j1, j2 from t1 order by i;
drop table t1;

delimiter //;
SET @p1=0;//
DROP PROCEDURE IF EXISTS `pro_2`//
CREATE PROCEDURE pro_2()
BEGIN
  SELECT JSON_ARRAY('a', 2) INTO @p1;
  SELECT @p1;
END//
CALL pro_2()//
--echo #预期运行结果：["a", 2]

## issue 
--echo # output result is json type not json string
--error 0, 1305
drop PROCEDURE proc1;//
CREATE PROCEDURE proc1()
    BEGIN
      DECLARE j json ;
      DECLARE a varchar(100) default '{"key":"value"}' ;
	  SELECT a into j from dual;
	  select j; 
    set a='[1,"test"]';
     SELECT a into j from dual;
      select j; 
      set a='1';
     SELECT a into j from dual;
      select j; 
    END 
//
call proc1();//

drop PROCEDURE proc1;//
CREATE PROCEDURE proc1()
    BEGIN
      DECLARE j json ;
      DECLARE a varchar(100) default '{"key":"value"}' ;
        set a='test';
     SELECT a into j from dual;
      select j;
    END 
//
--error 3141
call proc1();//

drop PROCEDURE proc1;//
CREATE PROCEDURE proc1()
    BEGIN
      DECLARE j json ;
      DECLARE j1 json ;
	   DECLARE curdo CURSOR FOR SELECT '{"key":"value"}' a, '[1,{"key":"valuse"}]' b FROM dual;
	  open curdo;
	  FETCH FROM curdo INTO j,j1;
	  select j,j1;
    END 
//
call proc1();//

drop PROCEDURE proc1;//
CREATE PROCEDURE proc1(j json)
    BEGIN
	  select j; 
    END 
//
call proc1('[1,2]');//
call proc1('{"key":"values"}');//

delimiter ;//
--disable_warnings
drop table if exists t_time;
--enable_warnings
create table t_time(c1 timestamp);
insert into t_time select cast('"7777-12-31 23:59:59"' as json) ;
select * from t_time;
drop table t_time;

SELECT CAST('"ab"' AS JSON) IS TRUE AS ist;
select CAST('"ab"' AS JSON) IS FALSE AS isf;
SELECT json_object( "a",FALSE) IS TRUE;
SELECT json_object( "a",FALSE) IS FALSE;

