# json table unadaptive datum trigger core dump issue 50688986
--disable_warnings
DROP TABLE if exists json_test1;
CREATE TABLE json_test1(
    c1 DECIMAL(38,0), 
  c2 VARCHAR(100) ,
  c3 json not null,
  c4 json,
  c5 VARCHAR(100));
  
insert into json_test1 values(1,12,'12','"2022-10-10"',null);
insert into json_test1 values(2,'{"a":[1,2]}','12','"2022-10-10"','123.12');
insert into json_test1 values(3,'"a"','"123"',null,'"sadf"');
insert into json_test1 values(4,'[1,"asdfasd1",{"a":12321564654},{"a":[1,2]},[]]','[1,2,{},{"a":[1,2]},[]]',null,'[1,"a",[],{}]');
insert into json_test1 values(5,'{"a":[1,2]}','[1,"asdfasd1",{"a":12321564654},{"a":[1,2]},[]]',null,'{"a":[1,2]}');
insert into json_test1 values(6,'true','true',null,'false');
insert into json_test1 values(7,'[]','{}',null,'false');

select t.* from json_test1 t1 INNER JOIN JSON_TABLE(t1.c2,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.b[1]" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) EXISTS PATH '$.b[1]')) as t  on t1.c1 = t.a;
select t.* from json_test1 t1 INNER JOIN JSON_TABLE(t1.c2,'$[*]' COLUMNS(a FOR ORDINALITY ,
 b VARCHAR(200) PATH "$.b[1]" default '0' ON EMPTY default '1' ON ERROR,
 c VARCHAR(200) EXISTS PATH '$.b[1]')) as t  on t1.c1 = t.a;

select t.a from JSON_TABLE('{"a": "2038-01-19 03:14:07", "b": [11,111]}','$.a' COLUMNS(a TIMESTAMP PATH "$[0]")) as t;
select 1 from JSON_TABLE('{"a": null, "b": [11,111]}','$.a' COLUMNS(a CHAR(100) PATH "$[0]" DEFAULT '1' ON EMPTY DEFAULT '2' ON ERROR)) as t where t.a is null;
select 1 from JSON_TABLE('{"a": null, "b": [11,111]}','$.a' COLUMNS(a CHAR(100) PATH "$[0]" DEFAULT '1' ON EMPTY DEFAULT '2' ON ERROR)) as t where t.a = 'null';
select length(t.a) from JSON_TABLE('{"a": null, "b": [11,111]}','$.a' COLUMNS(a CHAR(100) PATH "$[0]" DEFAULT '1' ON EMPTY DEFAULT '2' ON ERROR)) as t;
select t.a from JSON_TABLE('{"a": null, "b": [11,111]}','$.a' COLUMNS(a INT PATH "$[0]" error ON ERROR)) as t;
select t.a from JSON_TABLE('{"a": null, "b": [11,111]}','$.a' COLUMNS(a DATETIME PATH "$[0]" error ON ERROR)) as t;
