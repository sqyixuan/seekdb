) as test;
select * from json_table('{"key1":"1.211"}',
'$' columns
( a1 BIT path '$.key1') )as test;
select t.a1 from JSON_TABLE('77771231235959',"$" COLUMNS(a1 DATETIME PATH '$[0]')) as t;
select t.a1 from JSON_TABLE('[77771231235959]',"$" COLUMNS(a1 DATETIME PATH '$[0]')) as t;
select t.a1 from JSON_TABLE('{"a": "77771231235959"}',"$.a" COLUMNS(a1 DATETIME PATH '$[0]')) as t;
select t.* from JSON_TABLE('[1,"aaaa汉",true,null,[1,"aaaa汉",true,null],{"a": true, "b": [null,"汉字"]}]','$' COLUMNS(
 b int PATH "$.b[1]" default '0' ON EMPTY default '1' ON ERROR,c int EXISTS PATH '$.b[1]',
 NESTED PATH "$[4]" COLUMNS(bb varchar(100) PATH "$[2]" ),
 NESTED PATH "$[4]" COLUMNS( bb2 varchar(100) PATH "$[2]" ,
    NESTED PATH "$[1]" COLUMNS(bbb2 varchar(100) PATH "$[0]" )))) as t
    order by t.bb;
select * from json_table('{"key1":1}',
'$' columns
(id for ordinality, nested path '$' columns(id1 for ordinality)
,nested path '$' columns(id2 for ordinality,nested path '$' columns(id3 for ordinality,
nested path '$' columns(id4 for ordinality,nested path '$' columns(id5 for ordinality,
nested path '$' columns(id6 for ordinality,nested path '$' columns(id7 for ordinality))))))
)) as test;
select * from
  json_table(
    '[{"a": 1, "b": [9,8,5,26,4,null,"here"]},{},{},[],{},{}]',
    '$[*]' columns (
  a INT PATH '$.a' ,
  NESTED PATH '$.b[*]' COLUMNS (b1 varchar(200) PATH '$'))
  ) as tt ;
select sum(a) from json_table('[{"key":1},1,"test",false,true,null,"2010-12-12 05:05:05"]',
'$[*]' columns
(id for ordinality,a json path '$[0]',i int exists path '$.key')) as test;
select min(a) from json_table('[{"key":1},1,"test",false,true,null,"2010-12-12 05:05:05"]',
'$[*]' columns
(id for ordinality,a json path '$[0]',i int exists path '$.key')) as test;
select avg(a) from json_table('[{"key":1},1,"test",false,true,null,"2010-12-12 05:05:05"]',
'$[*]' columns
(id for ordinality,a json path '$[0]',i int exists path '$.key')) as test;
select * from json_table('{"key":"value"}',
'$' columns
(a0 varchar(50) path '$.key' default '"test"' on EMPTY DEFAULT '"TEST"' ON error)) as t;
select * from
json_table(
'[{"": 12, "a": 1, "b": "小瓦瓦"}]',
'$[*]' columns (id for ordinality ,a INT PATH '$.b' error on empty)
) as tt ;
drop table if exists test;
create table test as select * from json_table('{"key1":"values"}',
'$' columns
(a1 varchar(50) path '$.key1' default true on EMPTY default false on error)) as tt;
select * from test;
drop table test;
select * from json_table('[{"key":1},1,"test",false,true,null,"2010-12-12 05:05:05"]',
'$[*]' columns
(id for ordinality,a json path '$[0]',i int exists path '$.key')) as test order by a;
drop view if exists vtest;
create view vtest as select * from json_table('{"key1":1}',
'$' columns
(id for ordinality, a varchar(100) path '$.key1')) as test;
select * from vtest;
--error 1471
insert into vtest values(1,'test');
--error 1471
update vtest set id=3;
drop view vtest;
select t.a from JSON_TABLE('{"a": 1}','$.a' COLUMNS(a varchar(100) PATH "$[10]" default 'null' ON EMPTY)) as t;
--error 1690
select t.a from JSON_TABLE('11','$' COLUMNS(a BIT PATH "$" DEFAULT '2' ON EMPTY DEFAULT '9' ON ERROR)) as t;
drop table if exists orders;
CREATE TABLE orders (
  id INT PRIMARY KEY,
  order_date DATE,
  items JSON
);

INSERT INTO orders VALUES (1, '2021-01-01', '[{"product": "A", "quantity": 2}, {"product": "B", "quantity": 1}]');
INSERT INTO orders VALUES (2, '2021-01-02', '[{"product": "C", "quantity": 1}, {"product": "D", "quantity": 3}]');

SELECT oi.product, SUM(oi.quantity) AS total_quantity
FROM orders o
CROSS JOIN JSON_TABLE(o.items, '$[*]' COLUMNS (
  product VARCHAR(50) PATH '$.product',
  quantity INT PATH '$.quantity'
)) AS oi
GROUP BY oi.product;
drop table orders;

set names gbk;
select * from json_table('{"key":"value"}',
'$' columns
(a0 varchar(50) path '$.key' default '"test"' on EMPTY DEFAULT '"TEST"' ON error)) as t;
