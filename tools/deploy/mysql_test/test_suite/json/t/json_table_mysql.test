  (SELECT 1 UNION
   SELECT jt.id FROM t1 RIGHT JOIN JSON_TABLE(t1.jc, '$' COLUMNS
    (id FOR ORDINALITY)) as jt ON t1.jc=jt.id)
  SELECT * from qn;

