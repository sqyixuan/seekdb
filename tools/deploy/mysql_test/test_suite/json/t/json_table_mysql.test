select * from
json_table(
  '[
    {"a":"3", "n": { "l": 1}},
    {"a":2, "n": { "l": 1}},
    {"b":1, "n": { "l": 1}},
    {"a":0, "n": { "l": 1}}
  ]',
  '$[*]' columns (
    id for ordinality,
    jpath varchar(100) path '$.a',
    jexst int exists path '$.b',
    nested path '$.n' columns (
      id_n for ordinality,
      jpath_n varchar(50) path '$.l')
  )
) as tt;

explain format=json select * from
json_table(
  '[
    {"a":"3", "n": { "l": 1}},
    {"a":2, "n": { "l": 1}},
    {"b":1, "n": { "l": 1}},
    {"a":0, "n": { "l": 1}}
  ]',
  '$[*]' columns (
    id for ordinality,
    jpath varchar(100) path '$.a',
    jexst int exists path '$.b',
    nested path '$.n' columns (
      id_n for ordinality,
      jpath_n varchar(50) path '$.l')
  )
) as tt;

select * from
json_table(
  '[
    {"a":2, "n": [{ "l": 1}, {"l": 11}]},
    {"a":1, "n": [{ "l": 2}, {"l": 22}]}
  ]',
  '$[*]' columns (
    id for ordinality,
    jpath varchar(50) path '$.a',
    nested path '$.n[*]' columns (
      id_n for ordinality,
      jpath_n varchar(50) path '$.l'),
    nested path '$.n[*]' columns (
      id_m for ordinality,
      jpath_m varchar(50) path '$.l')
  )
) as tt;


