# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type": "array",
            "items": {"type": "array",
                "items": { "type": "array",
                    "items": {"type": "array",
                        "items": {"type": "number"}}}}}', 
              '[[[[1]], [[2],[3]]], [[[4], [5], [6]]]]');
# false
