# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"maximum": 30},{"minimum": 20}]}', '25');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"maximum": 30},{"minimum": 20}]}', '35');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{}]}', '1');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{},{}]}', '1');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{},{ "type": "number" }]}', '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{},{ "type": "number" }]}', '"foo"');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{ "type": "number" },{}]}', '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{ "type": "number" },{}]}', '"foo"');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"allOf": [{"type": "null"}]}]}', 'null');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"allOf": [{"type": "null"}]}]}', '123');

# allOf schema: true                        
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '30');
# allOf schema: false                         
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '5');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '3');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '15');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '2');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '10');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [ { "multipleOf": 2 } ],"anyOf": [ { "multipleOf": 3 }],"oneOf": [ { "multipleOf": 5 }]}', 
                        '6');
# add_pro: true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '{"foo": 1}');
# false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '{"foo" : 1, "bar" : 2, "quux" : "boom"}');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '[1, 2, 3]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '"foobarbaz"');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '12');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "patternProperties": { "^v": {} },
            "additionalProperties": false
        }', '{"foo":1, "vroom": 2}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "patternProperties": {"^á": {}},
            "additionalProperties": false
        }', '{"ármányos": 2}');
# false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "patternProperties": {"^á": {}},
            "additionalProperties": false
        }', '{"élmény": 2}');
# true, true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "additionalProperties": {"type": "boolean"}
        }', '{"foo": 1}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "additionalProperties": {"type": "boolean"}
        }', '{"foo" : 1, "bar" : 2, "quux" : true}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"foo": {}, "bar": {}},
            "additionalProperties": {"type": "boolean"}
        }', '{"foo" : 1, "bar" : 2, "quux" : 12}');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "additionalProperties": {"type": "boolean"}}', 
                        '{"foo" : true}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "additionalProperties": {"type": "boolean"}}', 
                        '{"foo" : 1}');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"properties": {"foo": {}, "bar": {}}}', 
                        '{"foo": 1, "bar": 2, "quux": true}');
# false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "allOf": [
                {"properties": {"foo": {}}}],
            "additionalProperties": {"type": "boolean"}}', 
                        '{"foo": 1, "bar": true}');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"additionalProperties": {"type": "null"}}', 
                        '{"foo": null}');

# additionalItems as schema
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}],"additionalItems": {"type": "integer"}}', 
                        '[ null, 2, 3, 4 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}],"additionalItems": {"type": "integer"}}', 
                        ' [ null, 2, 3, "foo" ]');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "items": {},"additionalItems": false}', 
                        ' [ 1, 2, 3, 4, 5 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}, {}, {}],"additionalItems": false}', 
                        ' [ ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}, {}, {}],"additionalItems": false}', 
                        ' [ 1 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}, {}, {}],"additionalItems": false}', 
                        ' [ 1, 2 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}, {}, {}],"additionalItems": false}', 
                        ' [ 1, 2, 3 ]');
# false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{}, {}, {}],"additionalItems": false}', 
                        ' [ 1, 2, 3, 4 ]');
# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"additionalItems": false}',  '[ 1, 2, 3, 4, 5 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"additionalItems": false}',  '{"foo" : "bar"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{"type": "integer"}]}',  '[1, "foo", false]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "allOf": [
                { "items": [ { "type": "integer" } ] }
            ],
            "additionalItems": { "type": "boolean" }
        }',  '[ 1, null ]');
# false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "allOf": [
                { "items": [ { "type": "integer" }, { "type": "string" } ] }
            ],
            "items": [ {"type": "integer" } ],
            "additionalItems": { "type": "boolean" }
        }',  '[ 1, "hello" ]');
# true, false, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "items": [ { "type": "string" } ],
            "additionalItems": { "type": "integer" }
        }',  '[ "x", 2, 3 ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "items": [ { "type": "string" } ],
            "additionalItems": { "type": "integer" }
        }',  '[ "x", "y" ]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "additionalItems": {
                "type": "null"
            }
        }',  '[ null ]');

# test var
SET @schema = '{"id": "htt/json-schema.org/geo",
                "$schema": "htt//json-schema.org/draft-04/schema#",
                "description": "A geographical coordinate",
                "type": "object",
                "properties": {
                "latitude": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                },
                "longitude": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                }
                },
                "required": ["latitude", "longitude"]}';

SET @document = '{"latitude": 63.444697, "longitude": 10.445118}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document);
SET @document = '{}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document);
SET @schema = '{
       "id": "httjson-schema.org/geo",
       "$schema": "httjson-schema.org/draft-04/schema#",
       "description": "A geographical coordinate",
       "type": "object",
       "properties": {
         "latitude": {
           "type": "number",
           "minimum": -90,
           "maximum": 90
         },
         "longitude": {
           "type": "number",
           "minimum": -180,
           "maximum": 180
         }
       }
      }';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document);
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, NULL);
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, @document);
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT('', @document);
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, '');
set @document = NULL;
set @schema = NULL;
--disable_warnings
drop table if exists t1;

--echo # Negative test for wrong number of arguments
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
SELECT JSON_SCHEMA_VALIDATION_REPORT();
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL);
--error ER_WRONG_PARAMCOUNT_TO_NATIVE_FCT
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL, NULL);

SELECT JSON_SCHEMA_VALIDATION_REPORT(@valid_json, @valid_json) AS should_be_true;

# test json_type as schema
--disable_warnings
drop table if exists schema_table;
CREATE TABLE schema_table(s json);
insert into schema_table values('{"id": "htt/json-schema.org/geo",
                "$schema": "htt//json-schema.org/draft-04/schema#",
                "description": "A geographical coordinate",
                "type": "object",
                "properties": {
                "latitude": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                },
                "longitude": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                }
                },
                "required": ["latitude", "longitude"]}');
insert into schema_table values('{"id": "htt/json-schema.org/geo",
                "$schema": "htt//json-schema.org/draft-04/schema#",
                "description": "A geographical coordinate",
                "type": "object"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT(s,'{}') from schema_table;
drop table schema_table;

# bugfix:53264347
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type": "object","required": ["street_name"],
                                      "properties": {"street_name": { "type": "string" }}}',
                                      '{"street_name":10,"street_name":"10"}') as should_be_false;
# bugfix: 53129719
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type": "string","maxLength": 20,"maxLength": 5}', '"This is a string"') AS should_be_true;
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type": "string","maxLength": 5,"maxLength": 20}', '"This is a string"') AS should_be_false;
select JSON_SCHEMA_VALIDATION_REPORT('{"type": "object", "properties": {"S_25": { "minLength": 5 }}, 
                           "patternProperties": { "^S_": { "type": "string" }, 
                           "^I_": { "type": "integer"}},"additionalProperties": false}',
                           '{ "S_25": "This is a string" ,"I_0": "test", "I_0": 42}') as should_be_false;
select JSON_SCHEMA_VALIDATION_REPORT('{"type": "object", "properties": {"S_25": { "minLength": 5 }}, 
                           "patternProperties": { "^S_": { "type": "string" }, 
                           "^I_": { "type": "integer"}},"additionalProperties": false}',
                           '{ "S_25": "This is a string" ,"I_0": 42, "I_0": "test"}') as should_be_false;
select JSON_SCHEMA_VALIDATION_REPORT('{"type": "object", "properties": {"S_25": { "minLength": 5 }}, 
                           "patternProperties": { "^S_": { "type": "string" }, 
                           "^I_": { "type": "integer"}},"additionalProperties": false}',
                           '{ "S_25": "This is a string" ,"I_0": 42, "I_0": 34}') as should_be_true;

# bugfix: 53161405
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type": "array","items": [{ "type": "number" },{ "enum": [ "Ab","a",14,true,null,[],{}] }],"additionalItems": false,"minItems": 2,"maxItems": 8,"uniqueItems": true,
"allOf": [{"type":"array"}],"not": {"$ref": "#/$defs/address" },
"$defs": {"address": { "type": "array", "allOf": [{"$ref": "#/$defs/address" }] }} }', '[1,{}]') ;