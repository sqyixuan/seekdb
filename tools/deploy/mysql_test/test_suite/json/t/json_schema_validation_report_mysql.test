#owner: wuxingying.wxy
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of JSON_SCHEMA_VALIDATION_REPORT
--echo # ----------------------------------------------------------------------

# --------------------------------test basic------------------------------
SET @schema = '{
  "type": "array",
  "items": [
    { "type": "number" },
    { "type": "string" },
    { "enum": ["Street", "Avenue", "Boulevard"] },
    { "enum": ["NW", "NE", "SW", "SE"] }
  ],
  "items":{ "type": "string" },
  "additionalItems": { "type": "string" }
}';
SET @document = '[1600, "Pennsylvania", "Avenue", "NW"]';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;

SET @schema = '{
      "type": "object",
      "properties": {
        "street_address": { "type": "object",
                              "properties": {
                              "k2":{"type": "string"}}
                          }
      }, 
      "patternProperties": {
    		"city": { "type": "string" }
   	  },
      "additionalProperties": { "type": "string" },     
      "required": ["street_address"],

  "allOf": [
    {"type":"object",
     "require":["state"]},
    {
      "properties": {
        "state": { "type": "string"} 
      },
      "additionalProperties": { "maxProperties": 6}
    },
    { "OneOf": [
        {
          "type": "number",
          "allOf":[{"required":["city"]}]
        }
      ]
    }],
  "anyOf": [
    {"type":"object"},
    {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "patternProperties": {
    	"^[cs]*": { "type": "string" }}
    },
    { "OneOf": [
        {"type": "number"},
        {"maxmum":10},
        {"type": "object",
          "properties": {"street_address":{"type": "string"}}
        }
      ]
    }
  ]
}';
SET @document = '{
   "street_address": {"k2": "Pennsylvania Avenue NW"},
   "city": "Washington",
   "state": "DC",
   "type": "business"
}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;

SET @schema = '{
      "type": "object",
      "properties": {
        "street_address": { "type": "object",
                              "properties": {
                              "k2":{"type": "string"}}
                          }
      }, 
      "patternProperties": {
    		"^[cs]*": { "type": "string" }
   	  },
      "additionalProperties": { "type": "string" },     
      "required": ["street_address"],

  "allOf": [
    {"type":"object",
     "require":["state"]},
    {
      "properties": {
        "state": { "type": "string"} 
      },
      "additionalProperties": { "maxProperties": 6}
    },
    { "OneOf": [
        {
          "type": "number",
          "allOf":[{"required":["city"]}]
        }
      ]
    }],
  "anyOf": [
    {"type":"object"},
    {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "patternProperties": {
    	"^[cs]*": { "type": "string" }}
    },
    { "OneOf": [
        {"type": "number"},
        {"maxmum":10},
        {"type": "object",
          "properties": {"street_address":{"type": "string"}}
        }
      ]
    }
  ]
}';
SET @document = '{
   "street_address": {"k2": "Pennsylvania Avenue NW"},
   "city": "Washington",
   "state": "DC",
   "type": "business"
}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_invalid;

SET @schema = '{
  "type": "string",
  "minLength": 2.9,
  "maxLength": 3
}';
SET @document = '"ab"';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;

SET @schema = '{
  "type": "object",
  "properties": {
    "builtin": { "type": "object",
                 "properties": {"b": {"type": "number"}},
                 "additionalProperties": {"type": "number"}
    }
  },
  "patternProperties": {"builtin": {"type": "object", 
                                "properties": {"c": {"type": "number"}},
                                "additionalProperties": {"type": "string"}
                                }
  }
}';
SET @document = '{ "builtin": {"b": 1, "c": 2} }';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_invalid;

SET @schema = '{"type": "object",
  "properties": {"street_address": 
  { "type": "object", 
  "properties": {"k2":{"type": "string"}}}},
  "patternProperties": {"^city*": { "type": "string" }},
  "additionalProperties": { "type": "string" },
  "required": ["street_address"],

  "allOf": [
  {"type":"object","require":["state"]},
  {"properties": {"state": { "type": "string"} }, "additionalProperties": { "maxProperties": 6}},
  { "oneOf": [
    {"required":["test_pro"]},
    {"allOf":[{"required":["state"]}]}
  ]}],
  
  "anyOf": [
  {"type":"object"},
  {"type": "object",
  "properties": {"city": { "type": "string" },"state": { "type": "string" }},
    "patternProperties": {"^[cs]*": { "type": "string" }}},
    { "oneOf": [{"type": "number"},{"maxmum":10},
    {"type": "object","properties": {"street_address":{"type": "string"}}}]}]
}';
SET @document = '{"street_address": {"k2": "Pennsylvania Avenue NW"}, "city": "Washington","state": "DC","type": "business"}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, @document);
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL);
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, NULL);
SET @document = NULL;
SET @schema = NULL;

SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL);
SELECT JSON_SCHEMA_VALIDATION_REPORT('{}', NULL);
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, '{}');

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "latitude": 63.444697,
  "longitude": 10.445118
}') AS should_be_valid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "longitude": 10.445118
}') AS should_be_invalid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "latitude": 62,
  "longitude": 10.445118
}') AS should_be_invalid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "8"
}') AS should_be_valid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "4"
}') AS should_be_invalid;

--error ER_NOT_SUPPORTED_YET
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": { "$ref": "htpexample.com" }
}','
{
  "latitude": 63.444697
}') AS invalid;

--error 3141
SELECT JSON_SCHEMA_VALIDATION_REPORT(repeat('[', 100000), json_object());
--error 3141
SELECT JSON_SCHEMA_VALIDATION_REPORT(json_object(), repeat('[', 100000));

--echo # Invalid JSON document in either argument
SET @invalid_json = '{"foo": "bar"'; # Missing closing '}'
SET @valid_json = '{}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@valid_json, @valid_json) AS should_be_true;
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(@invalid_json, @valid_json);
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(@valid_json, @invalid_json);
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(@invalid_json, @invalid_json);

--echo # Invalid regex patterns. rapidjson ignores invalid regex patterns, so
--echo # they are removed from the validation process.
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"string","pattern":"("}', '"abc"') AS should_be_true;
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"string","pattern":"[asdf@123"}', '"abc"') AS should_be_true;
--echo # Positive and negative tests for anchored regex patterns
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "a8"
}') AS should_be_valid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "^[5-9]"
    }
  }
}','{
  "a_string": "a8"
}') AS should_be_invalid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "8a"
}') AS should_be_valid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]$"
    }
  }
}','{
  "a_string": "8a"
}') AS should_be_invalid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "^[5-9]$"
    }
  }
}','{
  "a_string": "8"
}') AS should_be_valid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "^[5-9]$"
    }
  }
}','{
  "a_string": "a8"
}') AS should_be_invalid;

SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "^[5-9]$"
    }
  }
}','{
  "a_string": "8a"
}') AS should_be_invalid;

--echo # The JSON Schema must be an object, so see that we don't accept any
--echo # other type as the first argument.
--error 3853
SELECT JSON_SCHEMA_VALIDATION_REPORT('[]', '{}');

--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(CAST('test' AS JSON), '{}');
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', '{');

--echo # Test some various scenarios with cached JSON schema (first argument is const)
--disable_warnings
drop table if exists t1;
CREATE TABLE t1 (col1 JSON);
INSERT INTO t1 VALUES ('{"latitude": 0, "longitude": 0}');
INSERT INTO t1 VALUES ('{"latitude": -90, "longitude": -180}');
INSERT INTO t1 VALUES (NULL);
INSERT INTO t1 VALUES ('[]');
INSERT INTO t1 VALUES ('{"latitude": 90, "longitude": 180}');

--echo # All rows should return SQL NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, col1) FROM t1;

--echo # We should get true, true, null, false, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', col1) AS valid FROM t1;

--echo # Both arguments should be JSON
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(JSON_DEPTH(col1), col1) FROM t1;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', JSON_DEPTH(col1)) FROM t1;
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(123, col1) FROM t1;
DROP TABLE t1;

--echo # Test some scenarios with non-cached JSON schema (first argument is not const)
--disable_warnings
drop table if exists t1;
CREATE TABLE t1 (col1 JSON);
INSERT INTO t1 VALUES ('{"type":"object"}');
INSERT INTO t1 VALUES ('{"type":"array"}');
INSERT INTO t1 VALUES (NULL);
INSERT INTO t1 VALUES ('{"type":"string"}');

--echo # All rows should return SQL NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(col1, NULL) FROM t1;

--echo # We should get false, true, null, false
SELECT JSON_SCHEMA_VALIDATION_REPORT(col1, '[]') AS valid FROM t1;
DROP TABLE t1;

CREATE TABLE t1(s VARCHAR(100), d VARCHAR(100));
--echo # Invalid JSON document, non-const schema
INSERT INTO t1 VALUES('{"type":"object"}', '{');
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(s, d) FROM t1;
--echo # Invalid, non-const schema
UPDATE t1 SET s = '{', d = '{}';
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(s, d) FROM t1;
DROP TABLE t1;

--echo # Ensure that our item tree transformation doesn't get stuck forever when
--echo # using prepared statements.
PREPARE stmt FROM 'SELECT JSON_SCHEMA_VALIDATION_REPORT(?, ''{}'') FROM DUAL';
SET @json_schema = '{"type":"object"}';
SET @null = NULL;
EXECUTE stmt USING @json_schema;
EXECUTE stmt USING @null;
EXECUTE stmt USING @json_schema;
--error ER_INVALID_JSON_TEXT_IN_PARAM
SELECT JSON_SCHEMA_VALIDATION_REPORT(CAST('NULL' AS JSON), CAST('NULL' AS JSON));

--echo # See that we don't accept non-JSON types like geometry, bool, ints etc.
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(JSON_OBJECT(), 123);
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(JSON_OBJECT(), POINT(1, 1));
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(JSON_OBJECT(), true);

--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(123, JSON_OBJECT());
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(POINT(1, 1), JSON_OBJECT());
--error ER_INVALID_TYPE_FOR_JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(true, JSON_OBJECT());

