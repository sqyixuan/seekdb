# test uniqueItems
# uniqueItems schema1: true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '[1, 2]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '[0, false]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '[1, true]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '["foo", "bar", "baz"]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '[{"foo": "bar"}, {"foo": "baz"}]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"uniqueItems": true}', '[
                    {"foo": {"bar" : {"baz" : true}}},
                    {"foo": {"bar" : {"baz" : false}}}
