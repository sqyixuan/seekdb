                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        }', '{"bar": 2}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "anyOf": [
                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        }', '{"foo": "baz"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "anyOf": [
                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        }', '{"foo": "baz", "bar": 2}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "anyOf": [
                {
                    "properties": {
                        "bar": {"type": "integer"}
                    },
                    "required": ["bar"]
                },
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                }
            ]
        }', '{"foo": 2, "bar": "quux"}');

# true, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"anyOf": [{ "type": "number" },{}]}', '"foo"');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"anyOf": [{ "type": "number" },{}]}', '123');

# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"anyOf": [{"anyOf": [{"type": "null"}]}]}', 'null');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"anyOf": [{"anyOf": [{"type": "null"}]}]}', '123');

# allOf schema1: true                        
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"properties": {"bar": {"type": "integer"}},"required": ["bar"]},
                        {"properties": {"foo": {"type": "string"}},"required": ["foo"]}]}', 
                        '{"foo": "baz", "bar": 2}');
# allOf schema1: false                         
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"properties": {"bar": {"type": "integer"}},"required": ["bar"]},
                        {"properties": {"foo": {"type": "string"}},"required": ["foo"]}]}', 
                        '{"foo": "baz"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"properties": {"bar": {"type": "integer"}},"required": ["bar"]},
                        {"properties": {"foo": {"type": "string"}},"required": ["foo"]}]}', 
                        '{"bar": 2}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"allOf": [{"properties": {"bar": {"type": "integer"}},"required": ["bar"]},
                        {"properties": {"foo": {"type": "string"}},"required": ["foo"]}]}', 
                        '{"foo": "baz", "bar": "quux"}');

# true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "properties": {"bar": {"type": "integer"}},
            "required": ["bar"],
            "allOf" : [
                {
                    "properties": {
                        "foo": {"type": "string"}
                    },
                    "required": ["foo"]
                },
                {
                    "properties": {
                        "baz": {"type": "null"}
                    },
                    "required": ["baz"]
                }
            ]
        }', '{"foo": "quux", "bar": 2, "baz": null}');
