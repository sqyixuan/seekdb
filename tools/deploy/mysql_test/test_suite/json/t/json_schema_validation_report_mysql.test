SELECT JSON_SCHEMA_VALIDATION_REPORT('{"minimum": 1.1}', '0.6');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"minimum": 1.1, "exclusiveMinimum": false}', '0.6');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"minimum": 1.1, "exclusiveMinimum": true}', '1.1');
