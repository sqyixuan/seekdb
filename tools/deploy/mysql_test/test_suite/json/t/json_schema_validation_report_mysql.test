SELECT JSON_SCHEMA_VALIDATION_REPORT('{"items": [{"type": "null"}]}', '[ null ]');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "definitions": {
                "int": { "type": "integer" }
            },
            "allOf": [
                {
                    "properties": {
                        "foo": {
                            "$ref": "#/definitions/int"
                        }
                    }
                },
                {
                    "additionalProperties": {
                        "$ref": "#/definitions/int"
                    }
                }
            ]
        }', '{ "foo": 1 }');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
            "definitions": {
                "int": { "type": "integer" }
            },
            "allOf": [
                {
                    "properties": {
                        "foo": {
                            "$ref": "#/definitions/int"
                        }
                    }
                },
                {
                    "additionalProperties": {
                        "$ref": "#/definitions/int"
                    }
                }
            ]
        }', '{ "foo": "a string" }');
# enum schema1: true                         
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [1, 2, 3]}', '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [6, "foo", [], true, {"foo": 12}]}', '[]');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [6, "foo", [], true, {"foo": 12}]}', '{"foo": 12}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "enum": [6, null] }', 'null');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "enum": [6, null] }', '6');
# enum schema1: false                        
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [1, 2, 3]}', '4');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [6, "foo", [], true, {"foo": 12}]}', 'null');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [6, "foo", [], true, {"foo": 12}]}', '{"foo": false}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [6, "foo", [], true, {"foo": 12}]}', '{"foo": 12, "boo": 42}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "enum": [6, null] }', '"test"');
# enum schema2: true                         
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{"foo":"foo", "bar":"bar"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{"bar":"bar"}');
# enum schema2: false                        
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{"foo":"foot", "bar":"bar"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{"foo":"foo", "bar":"bart"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{"foo":"foo"}');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object",
                        "properties": {
                            "foo": {"enum":["foo"]},
                            "bar": {"enum":["bar"]}},
                        "required": ["bar"]}', '{}');
--error 3141
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": ["foo\nbar", "foo\rbar"]}', '"foo\nbar"');
# true, false, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [true]}', 'true');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [true]}', '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [true]}', '1.0');
# false, true, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [0]}', 'false');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [0]}', '0');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [0]}', '0.0');
# false, true, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [1]}', 'true');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [1]}', '1');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"enum": [1]}', '1.0');
# true, false
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "enum": [ "hello\u0000there" ] }', '"hello\u0000there"');
SELECT JSON_SCHEMA_VALIDATION_REPORT('{ "enum": [ "hello\u0000there" ] }', '"hellothere"');

