insert into json_test values(20, null, null);


create table json_test2(j json, j2 json) row_format=COMPRESSED SEMISTRUCT_ENCODING_TYPE='encoding' with column group(all columns, each column);
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;
insert  /*+ query_timeout(10000000000) append enable_parallel_dml parallel(2) */ into json_test2 select j, j2 from json_test2;

select md5(j), md5(j2) from json_test2 where json_value(j, '$.age' RETURNING SIGNED) = 35;

drop table json_test;
drop table json_test2;
