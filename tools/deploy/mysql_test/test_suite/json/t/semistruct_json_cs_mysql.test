#owner: aozeliu.azl
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of the json semistruct encoding column storage table
--echo # ----------------------------------------------------------------------
--disable_warnings
drop table if exists json_test;
drop table if exists json_test2;
drop table if exists json_patial;
--enable_warnings

set @@collation_server = 'utf8mb4_bin';
set @@collation_connection='utf8mb4_bin';

create table json_test(pk int primary key, j json, j2 json) row_format=COMPRESSED SEMISTRUCT_ENCODING_TYPE='encoding';
insert into json_test values(1,'{"age": 30, "like": [1, 2, 3], "name": "Mike", "score": 89.5, "int_dict": 51, "str_dict": "json"}', '{"c1": 11235733, "c2": "Bob", "c3": 58.3, "c4": 95.4}');
insert into json_test values(2,'{"age": 26, "like": [1, 10, 8], "name": "Jackson", "score": 79.5, "int_dict": 53, "str_dict": "gis"}', '{"c1": 11235734, "c2": "Sam", "c3": 58.3, "c4": 95.4}');
