drop table if exists t1;
create table t1 (pk bigint, col_char_20 char(20), col_json json, primary key (pk));
insert into t1 values (1,'zvv','{"width":"800","image":800,"thumbnail":{"url":"im481989943","width":100},"ids":[116,943,234,38793]}');
select JSON_EXTRACT(col_json,'$.ids[0]' ,'$[0].thumbnail.url' ,'$[0].width[0]' ,'$[0][0]') from t1;
JSON_EXTRACT(col_json,'$.ids[0]' ,'$[0].thumbnail.url' ,'$[0].width[0]' ,'$[0][0]')
[116, "im481989943", "800", {"ids": [116, 943, 234, 38793], "image": 800, "width": "800", "thumbnail": {"url": "im481989943", "width": 100}}]
select JSON_EXTRACT(JSON_LENGTH('23','$.name'),'$[0]');
