drop table if exists json_test1;
CREATE TABLE json_test1( 
c1 int, 
c2 JSON);
insert into json_test1(c2) values('["abc", 10, null, true, false]');
insert into json_test1(c2) values('{"Width":  "800","Image":  800,"Thumbnail": { "Url":    "12","Width":  100},"IDs": [116, 943, 234, 38793]}');
SELECT c1,JSON_EXTRACT(c2, "$.*") FROM json_test1;
c1	JSON_EXTRACT(c2, "$.*")
NULL	NULL
NULL	[[116, 943, 234, 38793], 800, "800", {"Url": "12", "Width": 100}]
SELECT JSON_EXTRACT('{"Width":  "800"}','$.Width','$.Width') from dual;
JSON_EXTRACT('{"Width":  "800"}','$.Width','$.Width')
["800", "800"]
drop table if exists json_test1;
drop table if exists json_test2;
create table json_test1 (id int primary key , r50 int , r49 int , r48 int , r47 int , r46 int , r45 int , r44 int , r43 int , r42 int , r41 int , r40 int , r39 int , r38 int , r37 int , r36 int , r35 int , r34 int , r33 int , r32 int , r31 int , r30 int , r29 int , r28 int , r27 int , r26 int , r25 int , r24 int , r23 int , r22 int , r21 int , r20 int , r19 int , r18 int , r17 int , r16 int , r15 int , r14 int , r13 int , r12 int , r11 int , r10 int , r9 int , r8 int , r7 int , r6 int , r5 int , r4 int , r3 int , r2 int , r1 int );
insert into json_test1 values(1 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 , 500 );
create table json_test2 (id int primary key, r_com json);
insert into json_test2 select id,json_object('id',json_array(1 , r50 , r49 , r48 , r47 , r46 , r45 , r44 , r43 , r42 , r41 , r40 , r39 , r38 , r37 , r36 , r35 , r34 , r33 , r32 , r31 , r30 , r29 , r28 , r27 , r26 , r25 , r24 , r23 , r22 , r21 , r20 , r19 , r18 , r17 , r16 , r15 , r14 , r13 , r12 , r11 , r10 , r9 , r8 , r7 , r6 , r5 , r4 , r3 , r2 , r1 )) from json_test1;
select count(*) from json_test2 where 500 member of(r_com->'$.id');
count(*)
1
select count(*) from json_test2 where 1 member of(r_com->'$.id');
count(*)
1
drop table if exists json_test1;
drop table if exists json_test2;
