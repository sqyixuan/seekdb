drop table if exists mayi_extract;
CREATE TABLE `mayi_extract` (
`id` varchar(64) NOT NULL,
`delete_time` bigint(20) NOT NULL DEFAULT '0',
`create_time` bigint(20) NOT NULL,
`doc_data` json NOT NULL,
PRIMARY KEY (`delete_time`, `id`),
KEY `idx_deletetime` (`id`, `delete_time`)
);
INSERT INTO `mayi_extract`(`id`,`create_time`,doc_data) VALUES('testUpdateOne id2',1646794252445730,'{"evnMap": "{}", "openTo": [], "deleted": true, "pvLimit": 0, "userName": "竹年", "repackUrl": "url", "depthLimit": 1000, "deviceInfo": ["abc", "123"], "needRepack": false, "taskStatus": "", "privateTask": false, "projectList": [], "caseExecTimes": 0, "selectActions": [], "workDeviceMap": {"num": "20", "name": "zhunian", "price": "1000L", "enable": "true"}, "containMorePages": false, "slmTaskResultList": []}');
