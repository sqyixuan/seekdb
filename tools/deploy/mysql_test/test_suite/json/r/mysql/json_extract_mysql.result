JSON_EXTRACT('[1,2,3,4]', '$**[last-1 to 3]')
[3, 4, 1, 2]
SELECT JSON_EXTRACT('[1,2,[3,4,[5,6,{"a":7}]]]', '$**[*]**[0]');
JSON_EXTRACT('[1,2,[3,4,[5,6,{"a":7}]]]', '$**[*]**[0]')
