drop table if exists chinese_char_test;
CREATE TABLE `chinese_char_test` (
`id` varchar(32) NOT NULL,
`delete_time` bigint(20) NOT NULL DEFAULT '0',
`doc_data` json NOT NULL,
PRIMARY KEY (`delete_time`, `id`),
KEY `idx_deletetime` (`id`, `delete_time`) 
);
insert into chinese_char_test values ('123', '0', '{"qty":45,"item":"中国", "name":null, "status":"A", "杭州": true}');
SELECT doc_data->'$.size' as 'size',doc_data->'$.size.h' as 'size.h' FROM chinese_char_test WHERE delete_time=0 AND doc_data->'$.杭州' = true ORDER BY id ASC LIMIT 10;
size	size.h
NULL	NULL
drop table chinese_char_test;
