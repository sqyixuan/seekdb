# ----------------------------------------------------------------------
# Test of JSON_DEPTH function.
# ----------------------------------------------------------------------
select json_depth(null);
json_depth(null)
NULL
select json_depth(cast(null as json));
json_depth(cast(null as json))
NULL
select json_depth(cast('[]' as json)),
json_depth(cast('{}' as json)),
json_depth(cast('null' as json));
json_depth(cast('[]' as json))	json_depth(cast('{}' as json))	json_depth(cast('null' as json))
1	1	1
select json_depth(cast('[[2], 3, [[[4]]]]' as json));
json_depth(cast('[[2], 3, [[[4]]]]' as json))
5
select json_depth(cast('{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}' as json));
json_depth(cast('{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": [5]}}}}' as json))
6
SELECT JSON_DEPTH
(
'{}'
);
JSON_DEPTH
(
'{}'
)
1
SELECT JSON_DEPTH
(
'[]'
);
JSON_DEPTH
(
'[]'
)
1
SELECT JSON_DEPTH( '"abc"' );
JSON_DEPTH( '"abc"' )
1
SELECT JSON_DEPTH( CAST( '"abc"' AS JSON ) );
JSON_DEPTH( CAST( '"abc"' AS JSON ) )
1
SELECT JSON_DEPTH( 1 );
ERROR 22032: Invalid data type for JSON data in argument 1 to function json_depth; a JSON string or JSON type is required.
SELECT JSON_DEPTH( 'abc' );
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_DEPTH( CAST( 1 AS JSON ) );
JSON_DEPTH( CAST( 1 AS JSON ) )
1
SELECT JSON_DEPTH
(
'{ "a" : true, "b" : false, "c" : null }'
);
JSON_DEPTH
(
'{ "a" : true, "b" : false, "c" : null }'
)
2
SELECT JSON_DEPTH
(
'[ "a", true, "b" , false, "c" , null ]'
);
JSON_DEPTH
(
'[ "a", true, "b" , false, "c" , null ]'
)
2
SELECT JSON_DEPTH
(
'{ "a" : true, "b" : {}, "c" : null }'
);
JSON_DEPTH
(
'{ "a" : true, "b" : {}, "c" : null }'
)
2
SELECT JSON_DEPTH
(
'[ "a", true, "b" , {}, "c" , null ]'
);
JSON_DEPTH
(
'[ "a", true, "b" , {}, "c" , null ]'
)
2
SELECT JSON_DEPTH
(
'{ "a" : true, "b" : { "e" : false }, "c" : null }'
);
JSON_DEPTH
(
'{ "a" : true, "b" : { "e" : false }, "c" : null }'
)
3
SELECT JSON_DEPTH
(
'[ "a", true, "b" , { "e" : false }, "c" , null ]'
);
JSON_DEPTH
(
'[ "a", true, "b" , { "e" : false }, "c" , null ]'
)
3
SELECT JSON_DEPTH
(
'[ "a", true, "b" , { "e" : false }, "c" , null'
);
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_DEPTH("");
ERROR 22032: Invalid JSON text in argument.
drop table if exists t;
create table if not exists t(a int, c varchar(20)) CHARACTER SET 'utf8';
insert into t values( 1, null );
select a, c, json_length( c ) from t where a = 1;
a	c	json_length( c )
1	NULL	NULL
drop table t;
SELECT JSON_DEPTH(UNHEX(""));
ERROR 22032: Cannot create a JSON value from a string.
