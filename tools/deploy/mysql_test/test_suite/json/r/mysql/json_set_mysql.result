# ----------------------------------------------------------------------
# Test of JSON_SET function.
# ----------------------------------------------------------------------
select json_set(NULL, '$.b', cast(1 as json));
json_set(NULL, '$.b', cast(1 as json))
NULL
select json_set('[1,2,3]', NULL, cast(1 as json));
json_set('[1,2,3]', NULL, cast(1 as json))
NULL
select json_set('[1,2,3]', '$[3]', NULL);
json_set('[1,2,3]', '$[3]', NULL)
[1, 2, 3, null]
select json_set('[1,2,3]', '$[2]', 4);
json_set('[1,2,3]', '$[2]', 4)
[1, 2, 4]
select json_set('[1,2,3]', '$[3]', 4);
json_set('[1,2,3]', '$[3]', 4)
[1, 2, 3, 4]
select json_set('[1,2,3]', '$[10]', 4);
json_set('[1,2,3]', '$[10]', 4)
[1, 2, 3, 4]
select json_set('{"c":4}', '$.c', 5);
json_set('{"c":4}', '$.c', 5)
{"c": 5}
select json_set('{"c":4}', '$.a', 5);
json_set('{"c":4}', '$.a', 5)
{"a": 5, "c": 4}
select json_set('1', '$', 4);
json_set('1', '$', 4)
4
select json_set('1', '$[0]', 4);
json_set('1', '$[0]', 4)
4
select json_set('1', '$[1]', 4);
json_set('1', '$[1]', 4)
[1, 4]
select json_set('1', '$[10]', '4', '$[11]', 5);
json_set('1', '$[10]', '4', '$[11]', 5)
[1, "4", 5]
select json_set('[1,2,3]', '$[2][0]', 4);
json_set('[1,2,3]', '$[2][0]', 4)
[1, 2, 4]
select json_set('[1,2,3]', '$[2][2]', 4);
json_set('[1,2,3]', '$[2][2]', 4)
[1, 2, [3, 4]]
select json_set('{"a": 3}', '$.a[0]', 4);
json_set('{"a": 3}', '$.a[0]', 4)
{"a": 4}
select json_set('{"a": 3}', '$.a[1]', 4, '$.a[2]', '5');
json_set('{"a": 3}', '$.a[1]', 4, '$.a[2]', '5')
{"a": [3, 4, "5"]}
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
JSON_OBJECT());
JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
JSON_OBJECT())
{"a": {}, "b": [1, 2, 3]}
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( true, false ));
JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( true, false ))
{"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) ));
JSON_SET('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) ))
{"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET('1', '$[3]', 2);
JSON_SET('1', '$[3]', 2)
[1, 2]
SELECT JSON_SET('{ "a" : "foo"}', '$.a',
JSON_OBJECT( 'b', false ), '$.a.c', true);
JSON_SET('{ "a" : "foo"}', '$.a',
JSON_OBJECT( 'b', false ), '$.a.c', true)
{"a": {"b": false, "c": true}}
select json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
cast('{}' as json));
json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
cast('{}' as json))
{"a": {}, "b": [1, 2, 3]}
select json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
cast('[true, false]' as json));
json_set('{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
cast('[true, false]' as json))
{"a": "foo", "b": [1, 2, 3], "c": [true, false]}
select json_set('1', '$[3]', 2);
json_set('1', '$[3]', 2)
[1, 2]
select json_set('{ "a" : "foo"}', '$.a',
cast('{"b": false}' as json), '$.a.c', true);
json_set('{ "a" : "foo"}', '$.a',
cast('{"b": false}' as json), '$.a.c', true)
{"a": {"b": false, "c": true}}
SELECT JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
JSON_OBJECT()
);
JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.a',
JSON_OBJECT()
)
{"a": {}, "b": [1, 2, 3]}
SELECT JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( true, false )
);
JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( true, false )
)
{"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) )
);
JSON_SET
(
'{ "a" : "foo", "b" : [ 1, 2, 3 ] }',
'$.c',
JSON_ARRAY( CAST( 'true' AS JSON ), CAST( 'false' AS JSON ) )
)
{"a": "foo", "b": [1, 2, 3], "c": [true, false]}
SELECT JSON_SET
(
'1',
'$[3]',
2
);
JSON_SET
(
'1',
'$[3]',
2
)
[1, 2]
SELECT JSON_SET
(
'{ "a" : "foo"}',
'$.a', JSON_OBJECT( 'b', false ),
'$.a.c', true
);
JSON_SET
(
'{ "a" : "foo"}',
'$.a', JSON_OBJECT( 'b', false ),
'$.a.c', true
)
{"a": {"b": false, "c": true}}
select json_set
(
'{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": 5}}}}',
'$.b.b1.c.d', 8
);
json_set
(
'{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": 5}}}}',
'$.b.b1.c.d', 8
)
{"a": {"a1": [3]}, "b": {"b1": {"c": {"d": 8}}}}
select json_set
('{"qty": 100,
  "item": "paper",
  "size": {"h": 8.5, "w": 11, "uom": "in"}, "status": "D"
  }',
'$.size.uom', 'cm',
'$.status', 'P',
'$.lastModified', 1000
);
json_set
('{"qty": 100,
  "item": "paper",
  "size": {"h": 8.5, "w": 11, "uom": "in"}, "status": "D"
  }',
'$.size.uom', 'cm',
'$.status', 'P',
'$.lastModified', 1000
)
{"qty": 100, "item": "paper", "size": {"h": 8.5, "w": 11, "uom": "cm"}, "status": "P", "lastModified": 1000}
select json_set(NULL);
ERROR 42000: Incorrect parameter count in the call to native function 'json_set'
select json_set(NULL, NULL);
ERROR 42000: Incorrect parameter count in the call to native function 'json_set'
select json_set(NULL, NULL, NULL, NULL);
ERROR 42000: Incorrect parameter count in the call to native function 'json_set'
SELECT JSON_SET('{}', '$.name', JSON_EXTRACT('', '$'));
ERROR 22032: Invalid JSON text in argument.
select json_set(cast('{"a": {"b": [3]}}' as json), '$**[1]', 6);
ERROR 42000: In this situation, path expressions may not contain the * and ** tokens.
select JSON_SET(@j, '$[2][0]', JSON_ARRAY(10, 20, 30));
JSON_SET(@j, '$[2][0]', JSON_ARRAY(10, 20, 30))
NULL
select json_set(UNHEX(""), '$[3]', 2);
ERROR 22032: Cannot create a JSON value from a string.
SET @j = '{"a": 1, "b": [2, 3], "c": 4}';
select json_set(@j,'$','z','$[0].b[0]',10,'$[0].b[0]',10,'$',null);
json_set(@j,'$','z','$[0].b[0]',10,'$[0].b[0]',10,'$',null)
null
SELECT JSON_ARRAYAGG(SPACE("n")) from dual;
JSON_ARRAYAGG(SPACE("n"))
[""]
Warnings:
Warning	1292	Truncated incorrect INTEGER value: 'n'
drop table if exists jsonfunc;
create table jsonfunc (
id int primary key,
json_info json,
c1 json generated always as (JSON_ARRAY(1, "abc", NULL, TRUE)),
c2 json generated always as (JSON_OBJECT('id', 87, 'name', 'carrot')),
c3 json generated always as (JSON_QUOTE('null')),
c4 json generated always as (JSON_UNQUOTE('null')),
c5 json generated always as (JSON_EXTRACT('[10, 20, [30, 40]]', '$[1]')),
c6 json generated always as (JSON_KEYS('{"a": 1, "b": {"c": 30}}')),
c7 json generated always as (JSON_SEARCH('["abc", [{"k": "10"}, "def"], {"x":"abc"}, {"y":"bcd"}]', 'one', 'abc')),
c8 json generated always as (JSON_ARRAY_APPEND('["a", ["b", "c"], "d"]', '$[1]', 1)),
c10 json generated always as (JSON_REMOVE('["a", ["b", "c"], "d"]', '$[1]')),
c11 json generated always as (JSON_DEPTH('true')),
c12 json generated always as (JSON_LENGTH('{"a": 1, "b": {"c": 30}}', '$.b')),
c13 json generated always as (JSON_REPLACE('{ "a": 1, "b": [2, 3]}', '$.a', 10, '$.c', '[true, false]')),
c14 json generated always as (json_info -> '$.id'),
c15 json generated always as (json_info ->> '$.id'),
c16 json generated always as (JSON_SET('{ "a": 1, "b": [2, 3]}', '$.a', 10, '$.c', '[true, false]')));
show  create table  jsonfunc ;
Table	Create Table
jsonfunc	CREATE TABLE `jsonfunc` (
  `id` int(11) NOT NULL,
  `json_info` json DEFAULT NULL,
  `c1` json GENERATED ALWAYS AS (JSON_ARRAY(1,'abc',NULL,(1 = 1))) VIRTUAL,
  `c2` json GENERATED ALWAYS AS (JSON_OBJECT('id',87,'name','carrot')) VIRTUAL,
  `c3` json GENERATED ALWAYS AS (JSON_QUOTE('null')) VIRTUAL,
  `c4` json GENERATED ALWAYS AS (JSON_UNQUOTE('null')) VIRTUAL,
  `c5` json GENERATED ALWAYS AS (JSON_EXTRACT('[10, 20, [30, 40]]','$[1]')) VIRTUAL,
  `c6` json GENERATED ALWAYS AS (JSON_KEYS('{\"a\": 1, \"b\": {\"c\": 30}}')) VIRTUAL,
  `c7` json GENERATED ALWAYS AS (JSON_SEARCH('[\"abc\", [{\"k\": \"10\"}, \"def\"], {\"x\":\"abc\"}, {\"y\":\"bcd\"}]','one','abc')) VIRTUAL,
  `c8` json GENERATED ALWAYS AS (JSON_ARRAY_APPEND('[\"a\", [\"b\", \"c\"], \"d\"]','$[1]',1)) VIRTUAL,
  `c10` json GENERATED ALWAYS AS (JSON_REMOVE('[\"a\", [\"b\", \"c\"], \"d\"]','$[1]')) VIRTUAL,
  `c11` json GENERATED ALWAYS AS (JSON_DEPTH('true')) VIRTUAL,
  `c12` json GENERATED ALWAYS AS (JSON_LENGTH('{\"a\": 1, \"b\": {\"c\": 30}}','$.b')) VIRTUAL,
  `c13` json GENERATED ALWAYS AS (JSON_REPLACE('{ \"a\": 1, \"b\": [2, 3]}','$.a',10,'$.c','[true, false]')) VIRTUAL,
  `c14` json GENERATED ALWAYS AS (JSON_EXTRACT(`json_info`,'$.id')) VIRTUAL,
  `c15` json GENERATED ALWAYS AS (JSON_UNQUOTE(JSON_EXTRACT(`json_info`,'$.id'))) VIRTUAL,
  `c16` json GENERATED ALWAYS AS (JSON_SET('{ \"a\": 1, \"b\": [2, 3]}','$.a',10,'$.c','[true, false]')) VIRTUAL,
  PRIMARY KEY (`id`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table jsonfunc;
select json_set('{"a": 3}', '$.a[last-1]', 4, '$.a[last-2]', '5');
json_set('{"a": 3}', '$.a[last-1]', 4, '$.a[last-2]', '5')
{"a": ["5", 4, 3]}
select json_set('[1,2,3]', '$[2][last-2]', 4);
json_set('[1,2,3]', '$[2][last-2]', 4)
[1, 2, [4, 3]]
select json_set('1', '$[last-1]', 4);
json_set('1', '$[last-1]', 4)
[4, 1]
drop table if exists json_test;
create table json_test (id int primary key, data json);
insert into json_test values(1, '{ "a" : "foo", "b" : [ 1, 2, 3 ] }');
update json_test set data = json_set(data, '$.a', 'woo') where id = 1;
update json_test set data = json_set(data, '$.b[1]', '1.1') where id = 1;
update json_test set data = json_set(data, '$.b[10]', '10') where id = 1;
select * from json_test;
id	data
1	{"a": "woo", "b": [1, "1.1", 3, "10"]}
set log_row_value_options="partial_json";
update json_test set data = json_set(data, '$.a', 'xoo') where id = 1;
update json_test set data = json_set(data, '$.b[1]', '1.2') where id = 1;
update json_test set data = json_set(data, '$.b[10]', '101') where id = 1;
select * from json_test;
id	data
1	{"a": "xoo", "b": [1, "1.2", 3, "10", "101"]}
insert into json_test values(2, '{ "a" : "foo", "b" : [ 1, 2, 3 ] }');
update json_test set data = json_set(json_set(data, '$.b[10]', '101'), '$.b[1]', '1.2', '$.a', 'xoo') where id = 2;
select * from json_test where id=2;
id	data
2	{"a": "xoo", "b": [1, "1.2", 3, "101"]}
update json_test set data = json_set(data, '$.b[0]', 2) where id = 2;
select * from json_test where id=2;
id	data
2	{"a": "xoo", "b": [2, "1.2", 3, "101"]}
set log_row_value_options="";
drop table json_test;
