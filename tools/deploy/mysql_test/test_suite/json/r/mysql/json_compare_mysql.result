drop table if exists obkv_mongo_test2;
CREATE TABLE `obkv_mongo_test2` (
`id` varchar(64) NOT NULL,
`delete_time` bigint(20) NOT NULL DEFAULT '0',
`create_time` bigint(20) NOT NULL,
`doc_data` json NOT NULL,
PRIMARY KEY (`delete_time`, `id`),
KEY `idx_deletetime` (`id`, `delete_time`) BLOCK_SIZE 16384 LOCAL
);
INSERT into obkv_mongo_test2(id, delete_time, create_time, doc_data) values('id_1', 0, 0, '{"testUpdateManyWithOptions key": "testUpdateManyWithOptions to value"}');
SELECT doc_data = JSON_SET(doc_data, '$."testUpdateManyWithOptions key"', 'testUpdateManyWithOptions to value') from obkv_mongo_test2 where delete_time=0;
doc_data = JSON_SET(doc_data, '$."testUpdateManyWithOptions key"', 'testUpdateManyWithOptions to value')
1
drop table obkv_mongo_test2;
# ---------------------------------- json vs json end --------------------------------------
drop table if exists t8, t9;
create table t8(c0 json, c1 float unsigned, c2 double, c3 int, c4 varchar(24));
create table t9(c0 json, c1 float unsigned, c2 double, c3 int, c4 varchar(24));
insert into t8 values('904557', 904557, 904557, 904557, 904557);
insert into t9 values('904557', 904557, 904557, 904557, 904557);
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c1, t9.c0    FROM t9 join t8 ON t8.c1 = t9.c0;
c1	c0
904557	904557
SELECT  t8.c1, t9.c0    FROM t9 join t8 ON t8.c1 = t9.c0;
c1	c0
904557	904557
SELECT /*+  LEADING (t9) USE_nl(t8) */  t8.c2, t9.c0    FROM t9 join t8 ON t8.c2 = t9.c0;
c2	c0
904557	904557
SELECT  t8.c2, t9.c0    FROM t9 join t8 ON t8.c2 = t9.c0;
