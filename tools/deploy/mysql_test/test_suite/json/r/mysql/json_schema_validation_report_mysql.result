  "type": "object",
  "properties": { "$ref": "htpexample.com" }
}','
{
  "latitude": 63.444697
}') AS invalid;
ERROR 42000: This version doesn't yet support 'references in JSON Schema.
SELECT JSON_SCHEMA_VALIDATION_REPORT(repeat('[', 100000), json_object());
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_SCHEMA_VALIDATION_REPORT(json_object(), repeat('[', 100000));
ERROR 22032: Invalid JSON text in argument.
# Invalid JSON document in either argument
SET @invalid_json = '{"foo": "bar"';
SET @valid_json = '{}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@valid_json, @valid_json) AS should_be_true;
should_be_true
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT(@invalid_json, @valid_json);
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_SCHEMA_VALIDATION_REPORT(@valid_json, @invalid_json);
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_SCHEMA_VALIDATION_REPORT(@invalid_json, @invalid_json);
ERROR 22032: Invalid JSON text in argument.
# Invalid regex patterns. rapidjson ignores invalid regex patterns, so
# they are removed from the validation process.
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"string","pattern":"("}', '"abc"') AS should_be_true;
should_be_true
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"string","pattern":"[asdf@123"}', '"abc"') AS should_be_true;
should_be_true
{"valid": true}
# Positive and negative tests for anchored regex patterns
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "a8"
}') AS should_be_valid;
should_be_valid
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "^[5-9]"
    }
  }
}','{
  "a_string": "a8"
}') AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#/a_string' failed requirement 'pattern' at JSON Schema location '#/properties/a_string", "schema-location": "#/properties/a_string", "document-location": "#/a_string", "schema-failed-keyword": "pattern"}
