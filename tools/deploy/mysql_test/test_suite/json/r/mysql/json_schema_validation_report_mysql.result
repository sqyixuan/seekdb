# The JSON Schema must be an object, so see that we don't accept any
# other type as the first argument.
SELECT JSON_SCHEMA_VALIDATION_REPORT('[]', '{}');
ERROR 22032: Invalid JSON type in argument, should be object.
SELECT JSON_SCHEMA_VALIDATION_REPORT(CAST('test' AS JSON), '{}');
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', '{');
ERROR 22032: Invalid JSON text in argument.
# Test some various scenarios with cached JSON schema (first argument is const)
drop table if exists t1;
CREATE TABLE t1 (col1 JSON);
INSERT INTO t1 VALUES ('{"latitude": 0, "longitude": 0}');
INSERT INTO t1 VALUES ('{"latitude": -90, "longitude": -180}');
INSERT INTO t1 VALUES (NULL);
INSERT INTO t1 VALUES ('[]');
INSERT INTO t1 VALUES ('{"latitude": 90, "longitude": 180}');
# All rows should return SQL NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, col1) FROM t1;
JSON_SCHEMA_VALIDATION_REPORT(NULL, col1)
NULL
NULL
NULL
NULL
NULL
# We should get true, true, null, false, true
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', col1) AS valid FROM t1;
valid
{"valid": true}
{"valid": true}
NULL
{"valid": false, "reason": "The JSON document location '#' failed requirement 'type' at JSON Schema location '#", "schema-location": "#", "document-location": "#", "schema-failed-keyword": "type"}
{"valid": true}
# Both arguments should be JSON
SELECT JSON_SCHEMA_VALIDATION_REPORT(JSON_DEPTH(col1), col1) FROM t1;
ERROR 22032: Invalid data type for JSON data in argument 1 to function json_schema_valid; a JSON string or JSON type is required.
SELECT JSON_SCHEMA_VALIDATION_REPORT('{"type":"object"}', JSON_DEPTH(col1)) FROM t1;
ERROR 22032: Invalid data type for JSON data in argument 2 to function json_schema_valid; a JSON string or JSON type is required.
SELECT JSON_SCHEMA_VALIDATION_REPORT(123, col1) FROM t1;
ERROR 22032: Invalid data type for JSON data in argument 1 to function json_schema_valid; a JSON string or JSON type is required.
DROP TABLE t1;
# Test some scenarios with non-cached JSON schema (first argument is not const)
drop table if exists t1;
CREATE TABLE t1 (col1 JSON);
INSERT INTO t1 VALUES ('{"type":"object"}');
INSERT INTO t1 VALUES ('{"type":"array"}');
INSERT INTO t1 VALUES (NULL);
INSERT INTO t1 VALUES ('{"type":"string"}');
# All rows should return SQL NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(col1, NULL) FROM t1;
JSON_SCHEMA_VALIDATION_REPORT(col1, NULL)
NULL
NULL
NULL
NULL
# We should get false, true, null, false
SELECT JSON_SCHEMA_VALIDATION_REPORT(col1, '[]') AS valid FROM t1;
valid
{"valid": false, "reason": "The JSON document location '#' failed requirement 'type' at JSON Schema location '#", "schema-location": "#", "document-location": "#", "schema-failed-keyword": "type"}
{"valid": true}
NULL
{"valid": false, "reason": "The JSON document location '#' failed requirement 'type' at JSON Schema location '#", "schema-location": "#", "document-location": "#", "schema-failed-keyword": "type"}
DROP TABLE t1;
CREATE TABLE t1(s VARCHAR(100), d VARCHAR(100));
# Invalid JSON document, non-const schema
INSERT INTO t1 VALUES('{"type":"object"}', '{');
SELECT JSON_SCHEMA_VALIDATION_REPORT(s, d) FROM t1;
ERROR 22032: Invalid JSON text in argument.
# Invalid, non-const schema
UPDATE t1 SET s = '{', d = '{}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(s, d) FROM t1;
ERROR 22032: Invalid JSON text in argument.
DROP TABLE t1;
# Ensure that our item tree transformation doesn't get stuck forever when
# using prepared statements.
PREPARE stmt FROM 'SELECT JSON_SCHEMA_VALIDATION_REPORT(?, ''{}'') FROM DUAL';
SET @json_schema = '{"type":"object"}';
SET @null = NULL;
EXECUTE stmt USING @json_schema;
JSON_SCHEMA_VALIDATION_REPORT(?, '{}')
{"valid": true}
EXECUTE stmt USING @null;
JSON_SCHEMA_VALIDATION_REPORT(?, '{}')
NULL
EXECUTE stmt USING @json_schema;
JSON_SCHEMA_VALIDATION_REPORT(?, '{}')
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT(CAST('NULL' AS JSON), CAST('NULL' AS JSON));
ERROR 22032: Invalid JSON text in argument.
# See that we don't accept non-JSON types like geometry, bool, ints etc.
