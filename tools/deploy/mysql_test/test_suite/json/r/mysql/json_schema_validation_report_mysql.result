# ----------------------------------------------------------------------
# Test of JSON_SCHEMA_VALIDATION_REPORT
# ----------------------------------------------------------------------
SET @schema = '{
  "type": "array",
  "items": [
    { "type": "number" },
    { "type": "string" },
    { "enum": ["Street", "Avenue", "Boulevard"] },
    { "enum": ["NW", "NE", "SW", "SE"] }
  ],
  "items":{ "type": "string" },
  "additionalItems": { "type": "string" }
}';
SET @document = '[1600, "Pennsylvania", "Avenue", "NW"]';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;
should_be_valid
{"valid": true}
SET @schema = '{
      "type": "object",
      "properties": {
        "street_address": { "type": "object",
                              "properties": {
                              "k2":{"type": "string"}}
                          }
      }, 
      "patternProperties": {
    		"city": { "type": "string" }
   	  },
      "additionalProperties": { "type": "string" },     
      "required": ["street_address"],

  "allOf": [
    {"type":"object",
     "require":["state"]},
    {
      "properties": {
        "state": { "type": "string"} 
      },
      "additionalProperties": { "maxProperties": 6}
    },
    { "OneOf": [
        {
          "type": "number",
          "allOf":[{"required":["city"]}]
        }
      ]
    }],
  "anyOf": [
    {"type":"object"},
    {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "patternProperties": {
    	"^[cs]*": { "type": "string" }}
    },
    { "OneOf": [
        {"type": "number"},
        {"maxmum":10},
        {"type": "object",
          "properties": {"street_address":{"type": "string"}}
        }
      ]
    }
  ]
}';
SET @document = '{
   "street_address": {"k2": "Pennsylvania Avenue NW"},
   "city": "Washington",
   "state": "DC",
   "type": "business"
}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;
should_be_valid
{"valid": true}
SET @schema = '{
      "type": "object",
      "properties": {
        "street_address": { "type": "object",
                              "properties": {
                              "k2":{"type": "string"}}
                          }
      }, 
      "patternProperties": {
    		"^[cs]*": { "type": "string" }
   	  },
      "additionalProperties": { "type": "string" },     
      "required": ["street_address"],

  "allOf": [
    {"type":"object",
     "require":["state"]},
    {
      "properties": {
        "state": { "type": "string"} 
      },
      "additionalProperties": { "maxProperties": 6}
    },
    { "OneOf": [
        {
          "type": "number",
          "allOf":[{"required":["city"]}]
        }
      ]
    }],
  "anyOf": [
    {"type":"object"},
    {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "state": { "type": "string" }
      },
      "patternProperties": {
    	"^[cs]*": { "type": "string" }}
    },
    { "OneOf": [
        {"type": "number"},
        {"maxmum":10},
        {"type": "object",
          "properties": {"street_address":{"type": "string"}}
        }
      ]
    }
  ]
}';
SET @document = '{
   "street_address": {"k2": "Pennsylvania Avenue NW"},
   "city": "Washington",
   "state": "DC",
   "type": "business"
}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#/street_address' failed requirement 'type' at JSON Schema location '#/properties/street_address", "schema-location": "#/properties/street_address", "document-location": "#/street_address", "schema-failed-keyword": "type"}
SET @schema = '{
  "type": "string",
  "minLength": 2.9,
  "maxLength": 3
}';
SET @document = '"ab"';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;
should_be_valid
{"valid": true}
SET @schema = '{
  "type": "object",
  "properties": {
    "builtin": { "type": "object",
                 "properties": {"b": {"type": "number"}},
                 "additionalProperties": {"type": "number"}
    }
  },
  "patternProperties": {"builtin": {"type": "object", 
                                "properties": {"c": {"type": "number"}},
                                "additionalProperties": {"type": "string"}
                                }
  }
}';
SET @document = '{ "builtin": {"b": 1, "c": 2} }';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#/builtin/b' failed requirement 'type' at JSON Schema location '#/properties/builtin/properties/b", "schema-location": "#/properties/builtin/properties/b", "document-location": "#/builtin/b", "schema-failed-keyword": "type"}
SET @schema = '{"type": "object",
  "properties": {"street_address": 
  { "type": "object", 
  "properties": {"k2":{"type": "string"}}}},
  "patternProperties": {"^city*": { "type": "string" }},
  "additionalProperties": { "type": "string" },
  "required": ["street_address"],

  "allOf": [
  {"type":"object","require":["state"]},
  {"properties": {"state": { "type": "string"} }, "additionalProperties": { "maxProperties": 6}},
  { "oneOf": [
    {"required":["test_pro"]},
    {"allOf":[{"required":["state"]}]}
  ]}],
  
  "anyOf": [
  {"type":"object"},
  {"type": "object",
  "properties": {"city": { "type": "string" },"state": { "type": "string" }},
    "patternProperties": {"^[cs]*": { "type": "string" }}},
    { "oneOf": [{"type": "number"},{"maxmum":10},
    {"type": "object","properties": {"street_address":{"type": "string"}}}]}]
}';
SET @document = '{"street_address": {"k2": "Pennsylvania Avenue NW"}, "city": "Washington","state": "DC","type": "business"}';
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, @document) AS should_be_valid;
should_be_valid
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, @document);
JSON_SCHEMA_VALIDATION_REPORT(NULL, @document)
NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL);
JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL)
NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(@schema, NULL);
JSON_SCHEMA_VALIDATION_REPORT(@schema, NULL)
NULL
SET @document = NULL;
SET @schema = NULL;
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL);
JSON_SCHEMA_VALIDATION_REPORT(NULL, NULL)
NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT('{}', NULL);
JSON_SCHEMA_VALIDATION_REPORT('{}', NULL)
NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT(NULL, '{}');
JSON_SCHEMA_VALIDATION_REPORT(NULL, '{}')
NULL
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "latitude": 63.444697,
  "longitude": 10.445118
}') AS should_be_valid;
should_be_valid
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "longitude": 10.445118
}') AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#' failed requirement 'required' at JSON Schema location '#", "schema-location": "#", "document-location": "#", "schema-failed-keyword": "required"}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "latitude": {
      "type": "number",
      "minimum": 63
    },
    "longitude": {
      "type": "number"
    }
  },
  "required": ["latitude", "longitude"]
}','{
  "latitude": 62,
  "longitude": 10.445118
}') AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#/latitude' failed requirement 'minimum' at JSON Schema location '#/properties/latitude", "schema-location": "#/properties/latitude", "document-location": "#/latitude", "schema-failed-keyword": "minimum"}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "8"
}') AS should_be_valid;
should_be_valid
{"valid": true}
SELECT JSON_SCHEMA_VALIDATION_REPORT('{
  "type": "object",
  "properties": {
    "a_string": {
      "type": "string",
      "pattern": "[5-9]"
    }
  }
}','{
  "a_string": "4"
}') AS should_be_invalid;
should_be_invalid
{"valid": false, "reason": "The JSON document location '#/a_string' failed requirement 'pattern' at JSON Schema location '#/properties/a_string", "schema-location": "#/properties/a_string", "document-location": "#/a_string", "schema-failed-keyword": "pattern"}
