# ----------------------------------------------------------------------
# Test of JSON_OBJECT function.
# ----------------------------------------------------------------------
select json_object( 'a' );
ERROR 42000: Incorrect parameter count in the call to native function 'json_object'
select json_object( 'a', 1, 'b' );
ERROR 42000: Incorrect parameter count in the call to native function 'json_object'
select json_object( null, 1 );
ERROR 22032: JSON documents may not contain NULL member names.
select json_object();
json_object()
{}
select json_object( 'a', null );
json_object( 'a', null )
{"a": null}
select json_object( 'a', 1 );
json_object( 'a', 1 )
{"a": 1}
select json_object( 'a', 1, 'b', 'foo' );
json_object( 'a', 1, 'b', 'foo' )
{"a": 1, "b": "foo"}
select json_object( 'a', 1, 'b', 'foo', 'c', cast( '{ "d": "wibble" }' as json ) );
json_object( 'a', 1, 'b', 'foo', 'c', cast( '{ "d": "wibble" }' as json ) )
{"a": 1, "b": "foo", "c": {"d": "wibble"}}
select json_object( 'a', true, 'b', false, 'c', cast( 'null' as json) );
json_object( 'a', true, 'b', false, 'c', cast( 'null' as json) )
{"a": true, "b": false, "c": null}
select json_valid( json_object( '"a"', 1 ) );
json_valid( json_object( '"a"', 1 ) )
1
select json_object( REPEAT('a', 64 * 1024), 1 );
json_object( REPEAT('a', 64 * 1024), 1 )
{"": 1}
select json_object(json_array(), json_array());
json_object(json_array(), json_array())
{"[]": []}
select json_object( cast(json_array() as char), json_array());
json_object( cast(json_array() as char), json_array())
{"[]": []}
select json_object( 1, json_array());
json_object( 1, json_array())
{"1": []}
select json_object( cast(1 as char), json_array());
json_object( cast(1 as char), json_array())
{"1": []}
SELECT JSON_OBJECT('a', 1, 'b', 2, 'a', 3);
JSON_OBJECT('a', 1, 'b', 2, 'a', 3)
{"a": 3, "b": 2}
SELECT JSON_OBJECT();
JSON_OBJECT()
{}
CREATE TABLE `nonp_wqh` (`col_auto_id` int(11) NOT NULL, `c_5_ShuF` json DEFAULT NULL);
insert into nonp_wqh values(1, null);
insert into nonp_wqh values(2, null);
select json_objectagg(c_5_ShuF, c_5_ShuF) from nonp_wqh where col_auto_id = 1;
ERROR 22032: JSON documents may not contain NULL member names.
drop table nonp_wqh;
#bug:
select json_object('id','87','name','[100,200]','{names:sam}' json_test) as object;
ERROR 42000: Incorrect parameter count in the call to native function 'json_object'
drop table if exists t1;
create table t1 (
pk bigint,
col_timestamp_6 timestamp(6),
col_json json,
primary key (pk) );
insert into t1 values (1, '2000-06-24 20:27:45.013867', 'false');
insert into t1 values (2, '2005-03-20 11:50:50.059548', '{"test": "abc"}');
insert into t1 values (3, '2000-01-05 23:38:26.009805', '[]');
insert into t1 values (4, '2007-12-26 19:58:06.056211', '"sadf"');
insert into t1 values (5, '2007-10-09 16:52:21.001669', '100000');
select json_object(pk,col_timestamp_6 ),col_timestamp_6 from t1 group by pk ;
json_object(pk,col_timestamp_6 )	col_timestamp_6
{"1": "2000-06-24 20:27:45.013867"}	2000-06-24 20:27:45.013867
{"2": "2005-03-20 11:50:50.059548"}	2005-03-20 11:50:50.059548
{"3": "2000-01-05 23:38:26.009805"}	2000-01-05 23:38:26.009805
{"4": "2007-12-26 19:58:06.056211"}	2007-12-26 19:58:06.056211
{"5": "2007-10-09 16:52:21.001669"}	2007-10-09 16:52:21.001669
drop table t1;
drop table if exists t_key_msp;
CREATE TABLE `t_key_msp` (
`c_1_j7sd` longtext DEFAULT NULL,
`c_0_jpG8` float NOT NULL DEFAULT '2',
`c_3_uyek` mediumint(8) unsigned NOT NULL DEFAULT '2',
`c_5_5AOd` json DEFAULT NULL,
`c_5_onVR` json DEFAULT NULL,
`col_auto_id` int(11) NOT NULL AUTO_INCREMENT,
`c_5_1ofk` json DEFAULT NULL,
`c_5_54Sl` json DEFAULT NULL,
`c_5_TCxF` json DEFAULT NULL,
`c_5_2Rnv` json DEFAULT NULL,
`c_2_8J4i` date DEFAULT '2018-09-22',
`c_4_FvdP` year(4) DEFAULT '2018',
`c_5_B2ou` json DEFAULT NULL,
`c_5_0vrL` json DEFAULT NULL
);
update t_key_MSP set  c_5_1ofk = '{ "item" : "canvas", "qty" : 100, "tags" : ["cotton"], "size" : { "h" : 28, "w" : 35.5, "uom" : "cm" }}' where col_auto_id < 1000;
insert t_key_MSP set c_5_5AOd = json_object('name',c_5_5AOd,'address', c_0_jpG8);
insert  t_key_MSP set c_5_5AOd = json_object('name',c_5_5AOd,'address', c_0_jpG8);
insert  t_key_MSP set c_5_5AOd = json_object('name',c_5_5AOd,'address', c_1_j7sd);
drop table t_key_msp;
drop table if exists test1;
drop table if exists test2;
create table test1(c1 year);
insert into test1 values(12);
select * from test1;
c1
2012
select json_object('year', c1) from test1;
json_object('year', c1)
{"year": 2012}
create table test2(c1 json);
insert into test2 select json_object('year', c1) from test1;
select * from test2;
c1
{"year": 2012}
drop table test1;
drop table test2;
drop table if exists test_time;
create table test_time(id int primary key, time DATETIME);
insert into test_time values(1, "2023-09-21 08:16:00.000000");
select * from test_time;
id	time
1	2023-09-21 08:16:00
SELECT json_object('id', `time`) AS json FROM test_time;
json
{"id": "2023-09-21 08:16:00.000000"}
set @@time_zone = '+12:00';
select @@time_zone;
@@time_zone
+12:00
select * from test_time;
id	time
1	2023-09-21 08:16:00
SELECT json_object('id', `time`) AS json FROM test_time;
json
{"id": "2023-09-21 08:16:00.000000"}
set @@time_zone = '+8:00';
drop table test_time;
drop table if exists test_time;
create table test_time(id int primary key, time TIMESTAMP);
insert into test_time values(1, "2023-09-21 08:16:00.000000");
select * from test_time;
id	time
1	2023-09-21 08:16:00
SELECT json_object('id', `time`) AS json FROM test_time;
json
{"id": "2023-09-21 08:16:00.000000"}
set @@time_zone = '+12:00';
select @@time_zone;
@@time_zone
+12:00
select * from test_time;
id	time
1	2023-09-21 12:16:00
SELECT json_object('id', `time`) AS json FROM test_time;
json
{"id": "2023-09-21 12:16:00.000000"}
set @@time_zone = '+8:00';
drop table test_time;
