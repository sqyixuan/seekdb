drop table if exists obkv_document;
CREATE TABLE obkv_document (coll_id int not null comment '集合id',doc_id varbinary(32) not null comment 'doc id', doc_data json not null comment 'doc的数据',last_modified bigint not null comment '最近修改时间', primary key(coll_id, doc_id),index idx_collid_lastmodified(coll_id, last_modified)) partition by key(coll_id) partitions 100;
INSERT INTO obkv_document(coll_id, doc_id, doc_data, last_modified) VALUES (1, '001', '{ "item" : "canvas", "qty" : 100, "tags" : ["cotton"], "size" : { "h" : 28, "w" : 35.5, "uom" : "cm" }}',1000);
INSERT INTO obkv_document(coll_id, doc_id, doc_data, last_modified) VALUES (1, '002', '{ "item": "journal", "qty": 25, "size": { "h": 14, "w": 21, "uom": "cm" }, "status": "A" }', 1000),(1, '003', '{ "item": "notebook", "qty": 50, "size": { "h": 8.5, "w": 11, "uom": "in" }, "status": "A" }', 1000), (1, '004', '{ "item": "paper", "qty": 100, "size": { "h": 8.5, "w": 11, "uom": "in" }, "status": "D" }', 1000),(1, '005', '{ "item": "planner", "qty": 75, "size": { "h": 22.85, "w": 30, "uom": "cm" }, "status": "D" }', 1000),(1, '006', '{ "item": "postcard", "qty": 45, "size": { "h": 10, "w": 15.25, "uom": "cm" }, "status": "A" }', 1000);
INSERT INTO obkv_document(coll_id, doc_id, doc_data, last_modified) VALUES (1, '007', '{ "datetime" : "2019-03-05 01:53:56", "qty" : 100, "tags" : ["cotton"], "size" : { "h" : 28, "w" : 35.5, "uom" : "cm" }}',1000);
INSERT INTO obkv_document(coll_id, doc_id, doc_data, last_modified) VALUES (1, '008', '{ "datetime" : "", "qty" : 100, "tags" : ["cotton"], "size" : { "h" : 28, "w" : 35.5, "uom" : "cm" }}',1000);
