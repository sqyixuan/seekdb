# ----------------------------------------------------------------------
# Tests json_query in gbk
# ----------------------------------------------------------------------
# prepare_environment
drop table t1;
CREATE TABLE t1( c1 json);
insert into t1 values('{"name":123}');
select json_query(c1,  '$.double()') from t1;
ERROR 42000: JSON path expression syntax error ('$.double()')
drop table t1;
drop table t_json;
create table t_json(c1 int, c2 json);
insert into t_json(c2) values('{"nested_level0":{"key_0":69,"key_1":null,"key_2":true,"nested_level1":{"key_0":[false,84,null],"key_1":"FMBowEJYtU","nested_level2":{"key_0":null,"nested_level3":{"key_0":{"key1":{"key1":{"key1":[{"key1":[true],"key2":true,"key3":"OE1y8ZIpeH"}]},"key2":{"key1":null,"key2":[false,[false,"N4lKqpcu9b",false]],"key3":null}},"key2":true,"key3":{"key1":[{"key1":"WDzimIex8T","key2":[13,null],"key3":false}],"key2":{"key1":"qIFpAZfjBU","key2":false}}},"key_1":74}}}}}');
select json_query(c2,'$.nested_level0') from t_json;
ERROR 42000: invalid data type for return value
drop table t_json;
