#
#
# Bug#21054516:QUERY HAVING SQL_BIG_RESULT ON JSON DATA GIVES EXTRA
#              ROWS IN OUTPUT
#
CREATE TABLE t1 (
pk integer auto_increment key,
col_varchar_255_utf8_key varchar(255)  CHARACTER SET utf8
);
INSERT INTO t1 VALUES (NULL, 'q') , (NULL, 'tgzvsj') ,
(NULL, 'b') , (NULL, 'q') , (NULL, 'up') , (NULL, 'up') ;
ALTER TABLE t1 ADD COLUMN json_varchar255_utf8_key json;
UPDATE t1 SET json_varchar255_utf8_key =
JSON_OBJECT('col_varchar_255_utf8_key', col_varchar_255_utf8_key);
DROP TABLE t1;
CREATE TABLE t1 ( `col_auto_id` int(11) NOT NULL AUTO_INCREMENT,
`c_5_ShuF` json DEFAULT NULL,
`col_gen_dr7` varchar(500) COLLATE gbk_bin GENERATED ALWAYS AS (JSON_EXTRACT(`c_5_ShuF`,'$.article0')) VIRTUAL
);
INSERT INTO t1(col_auto_id, c_5_ShuF) VALUES(1, null);
SELECT * FROM t1;
col_auto_id	c_5_ShuF	col_gen_dr7
1	NULL	NULL
DROP TABLE t1;
create table t_charset_test (pk int, info json, 
`col_gen_mzR` varchar(400) COLLATE gbk_bin GENERATED ALWAYS AS (json_extract(info, '$[0]'))
);
insert into t_charset_test(pk, info) values(2, '[{"title": "python基础"}]');
select * from t_charset_test;
pk	info	col_gen_mzR
2	[{"title": "python基础"}]	{"title": "python基础"}
drop table t_charset_test;
