# ----------------------------------------------------------------------
# Test of JSON_MERGE_PATCH function.
# ----------------------------------------------------------------------
select json_merge_patch('{"a":"b"}', '{"a":"c"}');
json_merge_patch('{"a":"b"}', '{"a":"c"}')
{"a": "c"}
select json_merge_patch('{"a":"b"}', '{"b":"c"}');
json_merge_patch('{"a":"b"}', '{"b":"c"}')
{"a": "b", "b": "c"}
select json_merge_patch('{"a":"b"}', '{"a":null}');
json_merge_patch('{"a":"b"}', '{"a":null}')
{}
select json_merge_patch('{"a":"b", "b":"c"}', '{"a":null}');
json_merge_patch('{"a":"b", "b":"c"}', '{"a":null}')
{"b": "c"}
select json_merge_patch('{"a":["b"]}', '{"a":"c"}');
json_merge_patch('{"a":["b"]}', '{"a":"c"}')
{"a": "c"}
select json_merge_patch('{"a":"c"}', '{"a":["b"]}');
json_merge_patch('{"a":"c"}', '{"a":["b"]}')
{"a": ["b"]}
select json_merge_patch('{"a": {"b":"c"}}', '{"a": {"b":"d", "c":null}}');
json_merge_patch('{"a": {"b":"c"}}', '{"a": {"b":"d", "c":null}}')
{"a": {"b": "d"}}
select json_merge_patch('{"a":[{"b":"c"}]}', '{"a": [1]}');
json_merge_patch('{"a":[{"b":"c"}]}', '{"a": [1]}')
{"a": [1]}
select json_merge_patch('["a","b"]', '["c","d"]');
json_merge_patch('["a","b"]', '["c","d"]')
["c", "d"]
select json_merge_patch('{"a":"b"}', '["c"]');
json_merge_patch('{"a":"b"}', '["c"]')
["c"]
select json_merge_patch('{"a":"foo"}', 'null');
json_merge_patch('{"a":"foo"}', 'null')
null
select json_merge_patch('{"a":"foo"}', '"bar"');
json_merge_patch('{"a":"foo"}', '"bar"')
"bar"
select json_merge_patch('{"e":null}', '{"a":1}');
json_merge_patch('{"e":null}', '{"a":1}')
{"a": 1, "e": null}
select json_merge_patch('[1,2]', '{"a":"b", "c":null}');
json_merge_patch('[1,2]', '{"a":"b", "c":null}')
{"a": "b"}
select json_merge_patch('{}', '{"a":{"bb":{"ccc":null}}}');
json_merge_patch('{}', '{"a":{"bb":{"ccc":null}}}')
{"a": {"bb": {}}}
select json_merge_patch(NULL, '{}');
json_merge_patch(NULL, '{}')
NULL
select json_merge_patch('{}', NULL);
json_merge_patch('{}', NULL)
NULL
SELECT JSON_MERGE_PATCH('{"a":"b"}', NULL, '{"c":"d"}');
JSON_MERGE_PATCH('{"a":"b"}', NULL, '{"c":"d"}')
NULL
SELECT JSON_MERGE_PATCH(NULL, '[1,2,3]');
JSON_MERGE_PATCH(NULL, '[1,2,3]')
[1, 2, 3]
SELECT JSON_MERGE_PATCH('{"a":"b"}', '{}', '[1,2,3]', '{"c":null,"d":"e"}');
JSON_MERGE_PATCH('{"a":"b"}', '{}', '[1,2,3]', '{"c":null,"d":"e"}')
{"d": "e"}
SELECT JSON_MERGE_PATCH();
ERROR 42000: Incorrect parameter count in the call to native function 'json_merge_patch'
SELECT JSON_MERGE_PATCH('{}');
ERROR 42000: Incorrect parameter count in the call to native function 'json_merge_patch'
SELECT JSON_MERGE_PATCH('{', '[1,2,3]');
ERROR 22032: Invalid JSON text in argument.
SELECT JSON_MERGE_PATCH('{"a":"b"}', '[1,');
ERROR 22032: Invalid JSON text in argument.
select json_merge_patch(UNHEX(""), '{"a":"c"}');
ERROR 22032: Cannot create a JSON value from a string.
select json_merge_patch('{"a":"c"}', UNHEX(""));
ERROR 22032: Cannot create a JSON value from a string.
