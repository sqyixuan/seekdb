ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(RPAD("zhang",0,"san")) from dual;
ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(SUBSTR("abcdefg",3,-2)) from dual;
ERROR 22032: Invalid JSON text.
