ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(SUBSTRING("zhangsan", 0, 3)) from dual;
ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(SUBSTRING("zhangsan", -3, -1)) from dual;
ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(REPEAT("1", -1)) from dual;
ERROR 22032: Invalid JSON text.
SELECT JSON_TYPE(SPACE("n")) from dual;
ERROR 22032: Invalid JSON text.
