select json_contains_path('{ "a": true }', 'all', '$[' );
ERROR 42000: Invalid JSON path expression.
select json_contains_path('{ "a": true }', 'all', '$a.***[3]' );
ERROR 42000: Invalid JSON path expression.
select json_contains_path('{ "a": true }', 'foo', '$.a' );
