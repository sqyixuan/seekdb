# ----------------------------------------------------------------------
# Test of JSON_ARRAY function.
# ----------------------------------------------------------------------
select json_array(NULL, '$.b', cast(1 as json));
json_array(NULL, '$.b', cast(1 as json))
[null, "$.b", 1]
select json_array('[1,2,3]', NULL, cast(1 as json));
json_array('[1,2,3]', NULL, cast(1 as json))
["[1,2,3]", null, 1]
select json_array('[1,2,3]', '$[3]', NULL);
json_array('[1,2,3]', '$[3]', NULL)
["[1,2,3]", "$[3]", null]
select json_array(38793);
json_array(38793)
[38793]
select json_array(129);
json_array(129)
[129]
select json_array(-8388607);
json_array(-8388607)
[-8388607]
select json_array(65543);
json_array(65543)
[65543]
SELECT JSON_ARRAY(CONCAT('"SQL "', '"汉字 "', '"Gooogle "', '"123456"')) from dual;
JSON_ARRAY(CONCAT('"SQL "', '"汉字 "', '"Gooogle "', '"123456"'))
["\"SQL \"\"汉字 \"\"Gooogle \"\"123456\""]
SELECT JSON_ARRAY(CONCAT_WS('"SQL "', '"汉字 "', '"Gooogle "', '"123456"')) from dual;
JSON_ARRAY(CONCAT_WS('"SQL "', '"汉字 "', '"Gooogle "', '"123456"'))
["\"汉字 \"\"SQL \"\"Gooogle \"\"SQL \"\"123456\""]
SELECT JSON_ARRAY(SUBSTR("zhangsan", 0, 3)) from dual;
JSON_ARRAY(SUBSTR("zhangsan", 0, 3))
[""]
SELECT JSON_ARRAY(SUBSTRING("zhangsan", 0, 3)) from dual;
JSON_ARRAY(SUBSTRING("zhangsan", 0, 3))
[""]
SELECT JSON_ARRAY(REPEAT("1", -1)) from dual;
JSON_ARRAY(REPEAT("1", -1))
[""]
SELECT JSON_ARRAY(SPACE("n")) from dual;
JSON_ARRAY(SPACE("n"))
[""]
SELECT JSON_ARRAY(LPAD("san",0,"zhang")) from dual;
JSON_ARRAY(LPAD("san",0,"zhang"))
[""]
SELECT JSON_ARRAY(SUBSTR("abcdefg",3,-2)) from dual;
JSON_ARRAY(SUBSTR("abcdefg",3,-2))
[""]
SELECT JSON_ARRAY(POW(16,4.5)) from dual;
JSON_ARRAY(POW(16,4.5))
[262144.0]
SELECT JSON_ARRAY(POWER(6,4.5)) from dual;
JSON_ARRAY(POWER(6,4.5))
[3174.538706646999]
select json_array();
json_array()
[]
select json_array(3.14);
json_array(3.14)
[3.14]
select json_array('[1,2,3]');
json_array('[1,2,3]')
["[1,2,3]"]
select json_array(cast('[1,2,3]' as json));
json_array(cast('[1,2,3]' as json))
[[1, 2, 3]]
select json_array(1,2,3);
json_array(1,2,3)
[1, 2, 3]
select json_array(b'0', b'1', b'10');
json_array(b'0', b'1', b'10')
["base64:type15:AA==", "base64:type15:AQ==", "base64:type15:Ag=="]
