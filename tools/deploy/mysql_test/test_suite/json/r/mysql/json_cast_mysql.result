create table table_json (c1 json, c2 varchar(20));
insert into table_json values('"abc"', 'abc');
insert into table_json values(null, null);
select ifnull(c1, c2) a1, ifnull(c2, c1) a2 from table_json;
a1	a2
"abc"	abc
NULL	NULL
select ifnull(c1, '') a1, ifnull(c2, '') a2 from table_json;
a1	a2
"abc"	abc
	
