drop table if exists obkv_document;
create table obkv_document (coll_id int not null comment '集合id',
doc_id varbinary(32) not null comment 'doc id',
doc_data json not null comment 'doc的数据',
last_modified bigint not null comment '最近修改时间',
primary key(coll_id, doc_id),
index idx_collid_lastmodified(coll_id, last_modified)
) partition by key(coll_id) partitions 100;
