# issue : 
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(c1 int);
create table t2(c1 int);
create table t3(c int);

--error 1060
with recursive cte as (
    select t1.c1, t2.c1, t3.c from t1,t2,t3
    union all 
    select cte.* from t1 join cte
) select * from cte;

drop table t1, t2, t3;

