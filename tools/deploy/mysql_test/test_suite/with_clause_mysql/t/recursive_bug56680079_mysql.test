# owner: wuyuming.wym
# owner group: sql1
# tags: optimizer

--result_format 4

create or replace view v as with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 4) select * from cte;
--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;
drop database db1;

with recursive cte(n) as (select 1 from dual union all select n+1 from cte v where v.n < 4) select * from cte;
--error 1046
select * from v;
select * from test.v;

use test;
drop view v;

explain with recursive cte(n) as (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select * from cte union all select n+1 from cte where n < 4) select * from cte;
explain with cte(n) as (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select * from cte union all select n+1 from cte where n < 4) select * from cte;
explain with recursive cte(n) as (select 1 from dual union all (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select n+1 from cte where n < 8)) select * from cte;
explain with recursive cte(n) as (with cte(n) as (select 1) select * from cte union all select n+1 from cte where n < 4) select * from cte;
explain with recursive cte1(n) as (select 1 from dual union all (with recursive cte2(m) as (select 2 from dual union all select m+1 from cte2 where m<3) select n*m from cte1,cte2 where n < 10)) select * from cte1;
explain with recursive cte(n) as (select 1 from dual union all (with cte2(m) as (select 2 from dual) select n + 1 from cte where n < 3)) select * from cte;
explain with recursive cte(n) as (select 1 from dual union all (with cte2 as (select 2 as m from dual) select n + 1 from cte where n < 3)) select * from cte;
explain with recursive cte as (select 1 as n from dual union all (with cte2 as (select 2 from dual) select n + 1 from cte where n < 3)) select * from cte;
explain with recursive cte as (select 1 as n from dual union all (with cte2 as (select 2 as m from dual) select n + 1 from cte where n < 3)) select * from cte;

with recursive cte(n) as (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select * from cte union all select n+1 from cte where n < 4) select * from cte;
with cte(n) as (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select * from cte union all select n+1 from cte where n < 4) select * from cte;
with recursive cte(n) as (select 1 from dual union all (with recursive cte(n) as (select 1 union all select n+1 from cte where n < 4) select n+1 from cte where n < 8)) select * from cte;
with recursive cte(n) as (with cte(n) as (select 1) select * from cte union all select n+1 from cte where n < 4) select * from cte;
with recursive cte1(n) as (select 1 from dual union all (with recursive cte2(m) as (select 2 from dual union all select m+1 from cte2 where m<3) select n*m from cte1,cte2 where n < 10)) select * from cte1;
with recursive cte1 as (select 1 as n from dual union all (with recursive cte2 as (select 2 as m from dual union all select m+1 from cte2 where m<3) select n*m from cte1,cte2 where n < 10)) select * from cte1;
with recursive cte(n) as (select 1 from dual union all (with cte2(m) as (select 2 from dual) select n + 1 from cte where n < 3)) select * from cte;
with recursive cte(n) as (select 1 from dual union all (with cte2 as (select 2 as m from dual) select n + 1 from cte where n < 3)) select * from cte;
with recursive cte as (select 1 as n from dual union all (with cte2 as (select 2 from dual) select n + 1 from cte where n < 3)) select * from cte;
with recursive cte as (select 1 as n from dual union all (with cte2 as (select 2 as m from dual) select n + 1 from cte where n < 3)) select * from cte;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
let $zone = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);

--disable_warnings
drop tenant if exists tenant_case_mode0 force;
--enable_warnings

--disable_warnings
#eval DROP RESOURCE POOL IF EXISTS case_mode_pool;
#eval DROP RESOURCE UNIT IF EXISTS case_mode_uint;
--enable_warnings

#eval CREATE RESOURCE UNIT case_mode_uint MAX_CPU=1, MEMORY_SIZE='2G';
#eval CREATE RESOURCE POOL case_mode_pool UNIT='case_mode_uint', UNIT_NUM=1, ZONE_LIST=('$zone');
--enable_query_log
--echo # ORIGIN_AND_SENSITIVE
#CREATE TENANT tenant_case_mode0 REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('case_mode_pool'), collate = utf8mb4_bin set ob_tcp_invited_nodes='%', lower_case_table_names=0;
--sleep 3
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn_case_mode_sys0,$TE_SERVER_IP, root, ,*NO-ONE*,$TE_SERVER_PORT);
connection conn_case_mode_sys0;
--disable_warnings
drop database if exists name_case;
--enable_warnings
create database name_case;
use name_case;

show variables like 'lower_case_table_names';

with cte(n) as (select 1 from dual) select * from cte;
with cte(n) as (select 1 from dual) select * from Cte;
with recursive cte(n) as (select 1 from dual) select * from cte;
with recursive cte(n) as (select 1 from dual) select * from Cte;
with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 5) select * from cte;
with recursive cte(n) as (select 1 from dual union all select n+1 from Cte where n < 5) select * from cte;
with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 5) select * from cte;
with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 5) select * from Cte;

connection sys;
#drop tenant tenant_case_mode0 force;
