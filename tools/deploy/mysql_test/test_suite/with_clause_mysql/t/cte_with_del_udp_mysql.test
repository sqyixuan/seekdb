##multi cte table
set cte_max_recursion_depth=0;
--error 3636
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 0),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 0)
select * from cte2;
set cte_max_recursion_depth=1;
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 0),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 0)
select * from cte2;
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 1),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 1)
select * from cte2;
--error 3636
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 2),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 2)
select * from cte2;
set cte_max_recursion_depth=10;
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 10),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 10),
  cte3 (a,b,c) as (select a,b,c from cte2 union all select a+1,b+1,c+1 from cte3 where cte3.a < 10)
select * from cte2;
--error 3636
with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 10),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 11),
  cte3 (a,b,c) as (select a,b,c from cte2 union all select a+1,b+1,c+1 from cte3 where cte3.a < 10)
select * from cte3;

with RECURSIVE 
  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 10),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 11),
  cte3 (a,b,c) as (select a,b,c from cte2 union all select a+1,b+1,c+1 from cte3 where cte3.a < 10)
select * from cte3, t1 where t1.c1 = cte3.a;

