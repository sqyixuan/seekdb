--echo #test with delete
insert into t1 values(4,4),(5,5);
##in from list
with cte AS (SELECT 1 AS col1) delete t1 from t1, cte where t1.c1=cte.col1;
select * from t1;
##join format
with cte AS (SELECT 2 AS col1) delete t1 from t1 join cte where t1.c1=cte.col1;
select * from t1;
##multi table delete
--error 1288
with cte AS (SELECT 3 AS col1) delete t1,cte from t1 join cte where t1.c1=cte.col1;
##delete data in cte
--error 1288
with cte AS (SELECT 1 AS col1 UNION ALL SELECT 3) delete from cte where cte.col1=1;
##with recursive
with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 3) delete t1 from t1,cte where t1.c1=cte.n;
select * from t1;
##nested
with cte2 as (with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) select * from cte where n > 4) delete t1 from t1,cte2 where t1.c1=cte2.n;
select * from t1;
--error 1064
with cte2 as (with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) delete t1 from t1,cte where t1.c1=cte.n) select * from cte2;
--error 1146
with cte2 as (with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) select * from cte) delete t1 from t1,cte where t1.c1=cte.n;
##duplicate table name
--error 1288
with t1 as (select 1) delete from t1;

##pl
delimiter //;
CREATE PROCEDURE cte_test(IN x INTEGER)
	BEGIN
		WITH RECURSIVE temp as 
		(
			select c1,c1+1 as c2 from t1
			UNION ALL
			select c1+1, c2+1 from temp where c1 < x
		) 
		delete t1 from t1,temp where t1.c1=temp.c1;
END//
delimiter ;//
call cte_test(5);
drop procedure cte_test;
select * from t1;

