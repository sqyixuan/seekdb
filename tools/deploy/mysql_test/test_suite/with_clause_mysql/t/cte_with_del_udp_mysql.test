#Bugfix46553550:
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(DEPTNO NUMERIC(2) PRIMARY KEY,DNAME VARCHAR(14),LOC VARCHAR(13)) ;
INSERT INTO t1 VALUES(1,'AccounTing','New York');
INSERT INTO t1 VALUES (2,'ReSeaRch','DallAs');
INSERT INTO t1 VALUES(3,'SaLeS','ChiCaGo');
INSERT INTO t1 VALUES(4,'OperaTions','BoSton');
SELECT * FROM t1;
WITH cte1 AS(SELECT DEPTNO,DNAME FROM t1 WHERE t1.DEPTNO = 1)
     UPDATE t1,cte1 SET t1.DNAME = 'Bruce' WHERE t1.DEPTNO IN (SELECT cte1.DEPTNO FROM cte1);
SELECT * FROM t1;

WITH cte1 AS(SELECT DEPTNO,DNAME FROM t1 WHERE t1.DEPTNO NOT IN (2,5,7) ORDER BY t1.DEPTNO),
     cte2 AS(SELECT * FROM cte1) UPDATE t1,cte1,cte2 SET t1.DNAME = 'Bruce' WHERE t1.DEPTNO IN (SELECT cte1.DEPTNO FROM cte1);
SELECT * FROM t1;
WITH cte1 AS(SELECT DEPTNO,DNAME FROM t1 WHERE t1.DEPTNO = 2)
     delete from t1 where t1.DNAME = 'ReSeaRch' and t1.DEPTNO IN (SELECT cte1.DEPTNO FROM cte1);
SELECT * FROM t1;
DROP TABLE IF EXISTS t1;
