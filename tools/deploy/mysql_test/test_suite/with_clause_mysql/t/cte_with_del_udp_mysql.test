# owner: yibo.tyf
--echo # owner group: sql1
--echo # tags: optimizer

--result_format 4
--disable_warnings
drop database if exists cte_st;
--enable_warnings
create database cte_st;
use cte_st;

--disable_warnings
drop table if exists t1,t1_part;
drop procedure if exists cte_test;
--enable_warnings

create table t1 (c1 int, c2 int);
insert into t1 values(1,1),(2,2),(3,3);

create table t1_part(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into t1_part values(1, 2);
insert into t1_part values(4, 5);
insert into t1_part values(5, 8);
insert into t1_part values(20, 11);
insert into t1_part values(40, 14);
insert into t1_part values(30, 17);


--echo #test with update
##multi table update
select * from t1;
with cte AS (SELECT 1 AS col1,2 AS col2 UNION ALL SELECT 3, 4) update t1,cte set t1.c2=cte.col2 where t1.c1=cte.col1;
select * from t1;
##join table update
with cte AS (SELECT 1 AS col1,1 AS col2 UNION ALL SELECT 3, 3) update t1 join cte set t1.c2=cte.col2 where t1.c1=cte.col1;
select * from t1;
##in subquery
with cte AS (SELECT 1 AS col1 UNION ALL SELECT 3) update t1 set t1.c2=5 where t1.c1 in (select col1 from cte);
--error 1288
with cte AS (SELECT 1 AS col1 UNION ALL SELECT 3) update (select col1 as c1 from cte) k set k.c1 = 1;
select * from t1;
##with recursive
with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) update t1,cte set t1.c2 = 1 where t1.c1=cte.n;
select * from t1;
##nested
with cte2 as (with cte AS (SELECT 2 AS col1 UNION ALL SELECT 3) (select * from cte)) update t1 join cte2 set t1.c2=cte2.col1 where t1.c1=cte2.col1;
select * from t1;
--error 1064
with cte2 as (with cte AS (SELECT 1 AS col1,2 AS col2 UNION ALL SELECT 3, 4) update t1 join cte set t1.c2=cte.col2 where t1.c1=cte.col1) update t1 join cte2 set t1.c2=cte2.col1 where t1.c1=cte2.col1;
--error 1064
with cte2 as (with cte AS (SELECT 1 AS col1,2 AS col2 UNION ALL SELECT 3, 4) update t1 join cte set t1.c2=cte.col2 where t1.c1=cte.col1) select * from cte2;
--error 1146
with cte2 as (with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) select * from cte) update t1,cte set t1.c1=1;
##duplicate table name
--error 1288
with t1 as (select 1) update t1 set t1.c1=1;
##duplicate column name
with cte as (select 1 as c1) update t1 set c1 = c1;
--error 1052
with cte as (select 1 as c1) update t1,cte set c1 = 1;
##pl
delimiter //;
CREATE PROCEDURE cte_test(IN x INTEGER)
	BEGIN
		WITH RECURSIVE temp as 
		(
			select c1,c1+1 as c2 from t1
			UNION ALL
			select c1+1, c2+1 from temp where c1 < x
		) 
		update t1,temp set t1.c2 = temp.c2 where t1.c1=temp.c1;
END//
delimiter ;//
call cte_test(3);
drop procedure cte_test;
select * from t1;

##discte
explain basic with cte0 as (select 1 as c1,1 as c2 union all select * from t1_part) update t1_part,cte0 set t1_part.c2 = t1_part.c1 where t1_part.c1 in (select c1 from cte0);
with cte0 as (select 1 as c1,1 as c2 union all select * from t1_part) update t1_part,cte0 set t1_part.c2 = t1_part.c1 where t1_part.c1 in (select c1 from cte0);
select * from t1_part;

explain basic with RECURSIVE cte0(a) as (select 1 union all select a+1 from cte0 where cte0.a < 50) update t1_part, cte0 set t1_part.c2 = cte0.a+1 where t1_part.c1 = cte0.a;
with RECURSIVE cte0(a) as (select 1 union all select a+1 from cte0 where cte0.a < 50) update t1_part, cte0 set t1_part.c2 = cte0.a+1 where t1_part.c1 = cte0.a;
select * from t1_part;

explain basic with RECURSIVE cte0(a,b) as (select * from t1_part union all select a+1,b+1 from cte0 where a < 10) update t1_part, cte0 set t1_part.c2 = 200 where t1_part.c1 = cte0.a;
with RECURSIVE cte0(a,b) as (select * from t1_part union all select a+1,b+1 from cte0 where a < 10) update t1_part, cte0 set t1_part.c2 = 200 where t1_part.c1 = cte0.a;
select * from t1_part;

explain basic with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_NL(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = 100 where t1_part.c1 in (select a from cte);

with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_NL(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = 100 where t1_part.c1 in (select a from cte);
select * from t1_part;

explain basic with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = 200 where t1_part.c1 in (select a from cte);

with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = 200 where t1_part.c1 in (select a from cte);
select * from t1_part;

explain basic with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_HASH(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = t1_part.c1 where t1_part.c1 in (select a from cte);

with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_HASH(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = t1_part.c1 where t1_part.c1 in (select a from cte);
select * from t1_part;

