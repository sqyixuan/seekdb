# owner group: sql1
# link: 

--disable_warnings
drop table if exists t1, t2;
drop view if exists view_cte_union_all;
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
--enable_warnings

--disable_query_log
--disable_result_log
insert into t1 VALUES (1, 2);
insert into t1 VALUES (3, 4);
insert into t2 VALUES (5, 6);
insert into t2 VALUES (7, 8);
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 0

create view view_cte_union_all as with cte1(n) as (select 1 from dual),
     cte2(n) as (with cte3(n) as (select 1 from dual) select n from cte3 union all (with cte1(n) as (select 2 from dual) select n from cte1) union all select 3 from dual union all select 4 from dual union all select 5 from dual)
     select  ta.n from cte2 ta left join cte1 tb on ta.n = tb.n;

show create view view_cte_union_all;

--explain_protocol 2

select * from view_cte_union_all;

explain basic with cte(n) as (select c1 from t1 union all select c1 from t2 union all select 1 from dual) select n from cte;

with cte(n) as (select c1 from t1 union all select c1 from t2 union all select 1 from dual) select n from cte;

SELECT 1 from dual
  UNION (
      WITH innermost(n) as (SELECT 2 from dual)
           SELECT * FROM innermost
            UNION 
            (with innermost(n) as (SELECT 3 from dual) 
                select n from innermost union select 4 from dual)
        );

--error 1066
with a(n) as (select 1 from dual), a(n) as (select 2 from dual) select n from a;

with a(n) as (select 1 from dual) select n from a union all select 2 from dual union all select 3 from dual;

SELECT 1 from dual
  UNION (WITH innermost(n) as (SELECT 2 from dual)
         SELECT * FROM innermost
         UNION select 3 from dual);

WITH innermost(n) as (SELECT 2 from dual)
           SELECT * FROM innermost
            UNION 
            (with innermost(n) as (SELECT 3 from dual) 
                select n from innermost union select 4 from dual);

drop table if exists t1, t2;
drop view if exists view_cte_union_all;