result_format: 4
WITH RECURSIVE cte AS
(
  SELECT 1 AS n, CAST('abc' AS CHAR(3)) AS str
  UNION ALL
  SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;
ERROR 22001: Data too long for column

set sql_mode = '';

WITH RECURSIVE cte AS
(
  SELECT 1 AS n, CAST('abc' AS CHAR(3)) AS str
  UNION ALL
  SELECT n + 1, CONCAT(str, str) FROM cte WHERE n < 3
)
SELECT * FROM cte;
+------+------+
| n    | str  |
+------+------+
|    1 | abc  |
|    2 | abc  |
|    3 | abc  |
+------+------+

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

drop table if exists colors;
CREATE TABLE colors (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(50),
  color ENUM('red', 'green', 'blue') DEFAULT 'red',
  color2 ENUM('orange', 'black') DEFAULT 'orange'
);
insert into colors(name) values ('A');
with recursive cte as (select 1 as n, color from colors union all select n+1, color from cte where n < 5 ) select * from cte;
+------+-------+
| n    | color |
+------+-------+
|    1 | red   |
|    2 | red   |
|    3 | red   |
|    4 | red   |
|    5 | red   |
+------+-------+
with recursive cte as (select 1 as n, color from colors union all select n+1, 'greene' from cte where n < 5 ) select * from cte;
ERROR 22001: Data too long for column
with recursive cte as (select 1 as n, color from colors union all select n+1, 'gree' from cte where n < 5 ) select * from cte;
+------+-------+
| n    | color |
+------+-------+
|    1 | red   |
|    2 | gree  |
|    3 | gree  |
|    4 | gree  |
|    5 | gree  |
+------+-------+
with recursive cte as ((select 1 as n, color from colors union all select 1 as n, color from colors) union all select n+1, color from cte where n < 5 ) select * from cte;
+------+-------+
| n    | color |
+------+-------+
|    1 | red   |
|    1 | red   |
|    2 | red   |
|    2 | red   |
|    3 | red   |
|    3 | red   |
|    4 | red   |
|    4 | red   |
|    5 | red   |
|    5 | red   |
+------+-------+
with recursive cte as ((select 1 as n, color from colors union all select 1 as n, color2 from colors) union all select n+1, color from cte where n < 5 ) select * from cte;
+------+--------+
| n    | color  |
+------+--------+
|    1 | red    |
|    1 | orange |
|    2 | red    |
|    2 | orange |
|    3 | red    |
|    3 | orange |
|    4 | red    |
|    4 | orange |
|    5 | red    |
|    5 | orange |
+------+--------+

drop table if exists A, BB;
CREATE TABLE A (
  pk int(11) NOT NULL AUTO_INCREMENT,
  col_int_key int(11) DEFAULT NULL,
  PRIMARY KEY (pk)
);

CREATE TABLE BB (
  pk int(11) NOT NULL AUTO_INCREMENT,
  col_blob_key blob,
  PRIMARY KEY (pk)
);

WITH RECURSIVE cte AS (
  SELECT col_blob_key AS field1 FROM  BB 
  UNION ALL
  SELECT t1.pk FROM cte AS t2 JOIN A AS t1) 
SELECT  * FROM cte;
+--------+
| field1 |
+--------+
+--------+

drop table A, BB;

with recursive cte(m, n) as (select null, 1 from dual union all select m+1, n+1 from cte where n < 5) select * from cte;
+------+------+
| m    | n    |
+------+------+
| NULL |    1 |
| NULL |    2 |
| NULL |    3 |
| NULL |    4 |
| NULL |    5 |
+------+------+
set sql_mode = '';
with recursive cte(m, n) as (select null, 1 from dual union all select ifnull(m,0)+1, n+1 from cte where n < 5) select * from cte;
+------+------+
| m    | n    |
+------+------+
| NULL |    1 |
|      |    2 |
|      |    3 |
|      |    4 |
|      |    5 |
+------+------+
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

drop table if exists cte;
create table cte(n int);
insert into cte values (4);
with recursive cte(n) as (with cte(n) as (select 1 from dual) select n from cte union all select n+1 from cte where n < 5) select * from cte;
+------+
| n    |
+------+
|    1 |
|    2 |
+------+
with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 5)  select * from cte;
+------+
| n    |
+------+
|    1 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+
with cte(n) as (with cte(n) as (select 1 from dual) select n from cte union all select n+1 from cte where n < 5) select * from cte;
+------+
| n    |
+------+
|    1 |
|    2 |
+------+
with cte(n) as (select n from cte union all select n+1 from cte where n < 5) select * from cte;
+------+
| n    |
+------+
|    4 |
|    5 |
+------+
with recursive cte(n) as (select n from cte) select * from cte;
ERROR HY000: Recursive Common Table Expression should contain a UNION ALL
with cte(n) as (select n from cte) select * from cte;
+------+
| n    |
+------+
|    4 |
+------+
with cte(n) as (select 3 from dual), cte2 as (select n from cte union all select n+1 from cte where n < 5) select * from cte2;
+------+
| n    |
+------+
|    3 |
|    4 |
+------+
with cte(n) as (select 3 from dual), cte2 as (with cte(n) as (select 1 from dual) select n from cte union all select n+1 from cte where n < 5) select * from cte2;
+------+
| n    |
+------+
|    1 |
|    2 |
+------+
with cte(n) as (select 3 from dual) select * from (with recursive cte(n) as (select 1 from dual union all select n+1 from cte where n < 5) select * from cte) v1;
+------+
| n    |
+------+
|    1 |
|    2 |
|    3 |
|    4 |
|    5 |
+------+
with cte(n) as (select 3 from dual) select * from (with recursive cte(n) as (select n from cte union all select n+1 from cte where n < 5) select * from cte) v1;
ERROR HY000: Recursive Common Table Expression should have one or more non-recursive query blocks followed by one or more recursive ones
