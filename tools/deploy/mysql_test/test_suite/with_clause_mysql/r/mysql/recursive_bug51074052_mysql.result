drop table cte;

with recursive cte(n) as (select 1 from dual union select n+1 from cte where n < 5) select * from cte;
ERROR 0A000: recursive UNION DISTINCT in Recursive Common Table Expression not supported

drop table if exists t1, t2, t3;
create table t1(c1 int);
create table t2(c1 int);
create table t3(c int);

with recursive cte as (
    select t1.c1, t2.c1, t3.c from t1,t2,t3
    union all 
    select cte.* from t1 join cte
) select * from cte;
ERROR 42S21: Duplicate column name 'c1'

drop table t1, t2, t3;

WITH RECURSIVE qn AS
(
  select 1 as n from dual
  union distinct
  select 2 as n from dual
  union ALL
  SELECT n * 2 FROM qn WHERE n < 5
)
select * from qn;
+------+
| n    |
+------+
|    1 |
|    2 |
|    2 |
|    4 |
|    4 |
|    8 |
|    8 |
+------+
