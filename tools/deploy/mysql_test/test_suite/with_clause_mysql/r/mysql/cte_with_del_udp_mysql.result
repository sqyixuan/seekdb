  cte1 (a,b,c) as (select 1,1,1 from dual union all select a+1,b+1,c+1 from cte1 where cte1.a < 10),
  cte2 (a,b,c) as (select a,b,c from cte1 union all select a+1,b+1,c+1 from cte2 where cte2.a < 11),
