# owner group: sql1
# tags: optimizer
result_format: 4
drop database if exists cte_st;
create database cte_st;
use cte_st;

drop table if exists t1,t1_part;
drop procedure if exists cte_test;
create table t1 (c1 int, c2 int);
insert into t1 values(1,1),(2,2),(3,3);

create table t1_part(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into t1_part values(1, 2);
insert into t1_part values(4, 5);
insert into t1_part values(5, 8);
insert into t1_part values(20, 11);
insert into t1_part values(40, 14);
insert into t1_part values(30, 17);

#test with update
##multi table update
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
|    3 |    3 |
+------+------+
with cte AS (SELECT 1 AS col1,2 AS col2 UNION ALL SELECT 3, 4) update t1,cte set t1.c2=cte.col2 where t1.c1=cte.col1;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    2 |    2 |
|    3 |    4 |
+------+------+
##join table update
with cte AS (SELECT 1 AS col1,1 AS col2 UNION ALL SELECT 3, 3) update t1 join cte set t1.c2=cte.col2 where t1.c1=cte.col1;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
|    3 |    3 |
+------+------+
##in subquery
with cte AS (SELECT 1 AS col1 UNION ALL SELECT 3) update t1 set t1.c2=5 where t1.c1 in (select col1 from cte);
with cte AS (SELECT 1 AS col1 UNION ALL SELECT 3) update (select col1 as c1 from cte) k set k.c1 = 1;
ERROR HY000: The target table k of the UPDATE is not updatable
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    5 |
|    2 |    2 |
|    3 |    5 |
+------+------+
##with recursive
with RECURSIVE cte(n) as (select 1 union all select n+1 from cte where n < 5) update t1,cte set t1.c2 = 1 where t1.c1=cte.n;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    1 |
|    2 |    1 |
|    3 |    1 |
+------+------+
##nested
with cte2 as (with cte AS (SELECT 2 AS col1 UNION ALL SELECT 3) (select * from cte)) update t1 join cte2 set t1.c2=cte2.col1 where t1.c1=cte2.col1;
select * from t1;
