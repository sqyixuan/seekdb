| c1   | c2   |
+------+------+
|    1 |    1 |
|    2 |    2 |
|    3 |    3 |
+------+------+
with cte2 as (with cte AS (SELECT 1 AS col1,2 AS col2 UNION ALL SELECT 3, 4) update t1 join cte set t1.c2=cte.col2 where t1.c1=cte.col1) update t1 join cte2 set t1.c2=cte2.col1 where t1.c1=cte2.col1;
