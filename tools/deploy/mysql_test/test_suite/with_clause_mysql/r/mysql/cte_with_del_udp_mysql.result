with RECURSIVE cte (a,b) AS
(
    SELECT c1,c2
    FROM t1_part e
    WHERE c1 < 20
    UNION ALL
    SELECT /*+ USE_NL(r e) */  e.c1+1, e.c2+1
    FROM cte r, t1_part e
    WHERE e.c1 = r.a
) update t1_part set t1_part.c2 = 100 where t1_part.c1 in (select a from cte);
