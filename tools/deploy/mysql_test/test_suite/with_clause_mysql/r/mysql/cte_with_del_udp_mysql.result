with cte as (select 1 as c1) update t1 set c1 = c1;
with cte as (select 1 as c1) update t1,cte set c1 = 1;
ERROR 23000: Column 'c1' in field list is ambiguous
##pl
CREATE PROCEDURE cte_test(IN x INTEGER)
	BEGIN
		WITH RECURSIVE temp as 
		(
			select c1,c1+1 as c2 from t1
			UNION ALL
			select c1+1, c2+1 from temp where c1 < x
		) 
		update t1,temp set t1.c2 = temp.c2 where t1.c1=temp.c1;
END//
call cte_test(3);
drop procedure cte_test;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    2 |    3 |
|    3 |    4 |
+------+------+

