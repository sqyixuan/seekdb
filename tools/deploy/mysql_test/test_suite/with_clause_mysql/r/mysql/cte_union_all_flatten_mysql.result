drop table if exists t1, t2;
drop view if exists view_cte_union_all;
create table t1 (c1 int, c2 int);
create table t2 (c1 int, c2 int);
result_format: 4
explain_protocol: 0
create view view_cte_union_all as with cte1(n) as (select 1 from dual),
     cte2(n) as (with cte3(n) as (select 1 from dual) select n from cte3 union all (with cte1(n) as (select 2 from dual) select n from cte1) union all select 3 from dual union all select 4 from dual union all select 5 from dual)
     select  ta.n from cte2 ta left join cte1 tb on ta.n = tb.n;

show create view view_cte_union_all;
View	Create View	character_set_client	collation_connection
view_cte_union_all	CREATE VIEW `view_cte_union_all` AS WITH RECURSIVE `cte1`(`n`) as (select 1 AS `n`), `cte2`(`n`) as (WITH RECURSIVE `cte3`(`n`) as (select 1 AS `n`) (select `cte3`.`n` AS `n` from `cte3`) union  all (WITH RECURSIVE `cte1`(`n`) as (select 2 AS `n`) select `cte1`.`n` AS `n` from `cte1`) union  all (select 3 AS `3`) union  all (select 4 AS `4`) union  all (select 5 AS `5`)) select `ta`.`n` AS `n` from (`cte2` `ta` left join `cte1` `tb` on (`ta`.`n` = `tb`.`n`))	utf8mb4	utf8mb4_general_ci

