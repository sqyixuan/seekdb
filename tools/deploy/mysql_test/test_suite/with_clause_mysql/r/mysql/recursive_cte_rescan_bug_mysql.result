create table f_rcte1 as 
    with recursive cte as (
      select 
        t1.pk as num1, 
        t1.col_bigint as num2, 
        t1.col_varchar_20_index as var1, 
        t1.col_varchar_20 as var2 
      from 
        table10_hash_pk_parts_10_int_not_null as t1 
      union all 
      select 
        
        /*+ use_nl(cte t2) leading(cte t2)*/
        cte.num1 + 1, 
        cte.num2 + 1, 
        cte.var1, 
        cte.var2 
      from 
        cte, 
        table10_int_not_null as t2 
      where 
        cte.num1 = t2.col_double_index 
        and NOT EXISTS (
          select 
            (
              (
                EXISTS (
                  select 
                    
                    /*+ use_nl(t2 t3) leading(t2 t3) */
                    t2.col_bigint_index 
                  from 
                    table10_key_pk_parts_10_int_not_null as t2, 
                    table10_int_not_null as t3 
                  where 
                    t3.col_varchar_20_unique_index > t2.col_varchar_20_unique_index 
                    and t3.col_decimal_20_0_unique_index > t2.col_bigint 
                    and t3.pk >= 7 
                  order by 
                    1 asc 
                  limit 
                    1
                )
              ) 
              or (
                EXISTS (
                  select 
                    
                    /*+ no_rewrite leading((t2 t3) t4) use_nl((t2 t3) t4) */
                    t2.col_bigint_index 
                  from 
                    table10_hash_pk_parts_10_int_not_null as t2, 
                    table10_key_pk_parts_10_int_not_null as t3, 
                    table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null as t4 
                  where 
                    t4.col_double_index > t3.col_bigint 
                    and t3.col_double_index >= t2.pk 
                  order by 
                    1 desc 
                  limit 
                    1
                )
              )
            ) 
            or (
              (
                t5.col_decimal_20_0 in (
                  select 
                    
                    /*+ use_nl(t2 t3) leading(t2 t3) */
                    t2.col_bigint_unique_index 
                  from 
                    table10_hash_pk_parts_10_int_not_null as t2, 
                    table10_int_not_null as t3 
                  where 
                    t3.col_varchar_20_index >= t2.col_varchar_20 
                  order by 
                    1 asc 
                  limit 
                    1
                )
              ) 
              or (
                EXISTS (
                  select 
                    
                    /*+ use_nl(t2 t3) leading(t2 t3) */
                    t2.pk 
                  from 
                    table10_key_pk_parts_10_int_not_null as t2, 
                    table10_int_not_null as t3 
                  where 
                    t3.pk = t2.col_decimal_20_0 
                  order by 
                    1 asc 
                  limit 
                    1
                )
              )
            ) 
          from 
            table10_hash_pk_parts_10_int_not_null as t5
        )
    ) 
    select 
      * 
    from 
      cte 
    order by 
      1, 
      2, 
      3, 
      4 asc;

create table nit as (
    select 
    /*+ no_rewrite leading((t2 t3) t4) use_nl((t2 t3) t4) */
    t2.col_bigint 
    from 
    table10_int_not_null as t2, 
    table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null as t3, 
    table10_key_pk_parts_10_int_not_null as t4 
    where 
    t4.pk > t3.col_decimal_20_0_index 
    and t3.col_varchar_20_index < t2.col_varchar_20
);

select ( NOT EXISTS ( select rcte2.num2 from ( with recursive cte2 as(select t1.col_double_index as num1, t1.col_bigint as num2, t1.col_varchar_20_index as var1, t1.col_varchar_20 as var2 from table10_hash_pk_parts_10_int_not_null as t1 union all  select /*+ use_nl(cte t2) leading(cte t2)no_rewrite*/ cte2.num1 + 1, cte2.num2 + 1, cte2.var1, cte2.var2 from cte2, table10_key_pk_parts_10_int_not_null as t2 where cte2.num1 = t2.col_decimal_20_0_unique_index and cte2.num2 NOT IN (select * from nit) ) select * from cte2 order by 1, 2, 3, 4 asc ) as rcte2 where rcte2.num2 = rcte1.num2 ) ) from (select * from f_rcte1) as rcte1;
+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
