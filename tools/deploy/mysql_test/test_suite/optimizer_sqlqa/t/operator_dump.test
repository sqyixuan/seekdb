connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#alter system set _max_trx_size='1G';


--disable_query_log
call oceanbase.drop_tenant_force('dump_tenant');
#call oceanbase.create_mysql_tenant_mini('dump_tenant');
--source mysql_test/include/check_tenant_sync.inc

let $t_id = query_get_value(select tenant_id as t_id from oceanbase.__all_tenant where tenant_name = 'sys' limit 1,t_id, 1);
--enable_result_log
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

set global parallel_servers_target=10;
alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';

sleep 2;

connection conn1;

--enable_query_log


--error 0,600

create table tt_dump(c1 int,c2 char(256),c3 varchar(4000));

insert into tt_dump values(1,repeat('sgt',20),repeat('abcde',80));

insert into tt_dump select c1+1,c2,c3 from tt_dump;

insert into tt_dump select c1+10,c2,c3 from tt_dump;

insert into tt_dump select c1+100,c2,c3 from tt_dump;

insert into tt_dump select c1+1000,c2,c3 from tt_dump;

insert into tt_dump select c1+10000,c2,c3 from tt_dump;

insert into tt_dump select c1+100000,c2,c3 from tt_dump;

insert into tt_dump select c1+1000000,c2,c3 from tt_dump;

insert into tt_dump select c1+10000000,c2,c3 from tt_dump;

insert into tt_dump select c1+100000000,c2,c3 from tt_dump;

insert into tt_dump select c1+1000000000,c2,c3 from tt_dump;

commit;

create table tt_dump1(c1 int,c2 char(256),c3 varchar(4000));

insert into tt_dump1 values(1,repeat('sgt',20),repeat('abcde',80));

