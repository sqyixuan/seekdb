select a.c0,sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)) from (select /*+ no_use_hash_aggregation*/ * from t_dump2 a union select /*+ no_use_hash_aggregation*/ * from t_dump1 a)a; 


