set  ob_query_timeout=200000000;

set  ob_trx_timeout=200000000;

create index idx_tt_dump1_01 on tt_dump1(c1);

create table tt_sgt(c1 int,c2 int);

insert into tt_sgt values(1,1);

insert into tt_sgt values(2,2);

commit;

