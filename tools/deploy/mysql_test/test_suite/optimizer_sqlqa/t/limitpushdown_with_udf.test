# owner: zhenling.zzg
# owner group: IMF
# description: udf limit pushdown
# author: xiyang.gjc

--disable_warnings
drop table IF EXISTS t1;
create table t1(stats int , s1 int , s2 int);
insert into t1 values(2,1,3),(1,0,0),(0,0,0),(0,0,0);

drop table IF EXISTS t2;
create table t2(id int ,s1 int, s2 int);

drop function IF EXISTS n_1;
delimiter /;
create function n_1() returns int not deterministic
begin
  insert into t2 values(1,0,1);
  return 0;
end/
delimiter ;/

select 1 from t1;
select 1 from t1 where s1=n_1() limit 1,3;
--enable_warnings
