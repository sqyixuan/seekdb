# test pl22
drop procedure if exists pf;
drop procedure if exists pf1;
create procedure pf(IN x float(20,10), OUT Z float(20,10))
begin 
declare y float;  
SELECT cf4 into z from nation limit 1;
end//
create procedure pf1(IN x decimal(20,10), OUT Z decimal(20,10))
begin
declare y float;
SELECT cf4 into z from nation limit 1;
end//
call pf(3.0, @f1_out);
call pf1(3.0, @f2_out);
drop procedure if exists pf1;
drop procedure if exists pf;
drop table if exists nation;
drop table if exists t1;
### turn off flag
alter system set _enable_convert_real_to_decimal = false;
create table nation (CountryCode varchar(100), cf1 float, cf2 float(10, 0), cf3 float(65, 10), cf4 float(10), cf5 float(53), cd1 double, cd2 double(10,0), cd3 double(65,10) );
drop table if exists nation;
