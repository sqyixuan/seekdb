# test pl
drop procedure if exists createnation;
CREATE PROCEDURE createnation ()
BEGIN
drop table if exists nation;
create table nation (CountryCode varchar(100), cf1 float, cf2 float(10, 0), cf3 float(65, 10), cf4 float(10), cf5 float(53), cd1 double, cd2 double(10,0), cd3 double(65,10) );
desc nation;
END//
call createnation();
Field	Type	Null	Key	Default	Extra
CountryCode	varchar(100)	YES		NULL	
cf1	float	YES		NULL	
cf2	decimal(10,0)	YES		NULL	
cf3	decimal(65,10)	YES		NULL	
cf4	float	YES		NULL	
cf5	double	YES		NULL	
cd1	double	YES		NULL	
cd2	decimal(10,0)	YES		NULL	
cd3	decimal(65,10)	YES		NULL	
