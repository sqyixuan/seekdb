########decimal-1及decimal-8-2测试点##########
##################同步测试环境及引入时区文件##################
# 此项需要根据运行环境选择使用
# ob中的开启外键功能
set foreign_key_checks=1;
##################基础功能测试##################
DROP TABLE stu;
DROP TABLE stu2;
DROP TABLE stu1;
# 指定位数的容量测试, 0及异常数字及非法值
create table stu(s1 decimal(2));
insert into stu(s1) values('测试');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu(s1) values('测试,');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('   ');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('测测试');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('  ');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values(null);
insert into stu values(好的);
ERROR 42S22: Unknown column '好的' in 'field list'
insert into stu values(,,,);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ',,)' at line 1
insert into stu values(',,,');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('\\\\');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('\\');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('**');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('$$');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('%%');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('''');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('''''');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values(123);
ERROR 22003: Out of range value for column 's1' at row 1
insert into stu values('abc');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values(''' ');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values(' '' ');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
insert into stu values('');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
create table stu1(s1 decimal(0));
create table stu1(s1 decimal(-10));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '-10))' at line 1
##################内置函数的嵌套使用##################
DROP TABLE stu;
DROP TABLE stu1;
# 测试check和默认值的冲突
create table stu1(s1 decimal(2) primary key, s2 decimal(6) not null, s3 decimal(6) default '123456', s4 decimal(6) default 123456, s5 decimal(6) default 45678);
insert into stu1(s1,s2,s5) values(1, 11, 111111);
insert into stu1(s1,s2,s5) values(1, 11, 1111111);
create table stu(s1 decimal(2) primary key, s2 decimal(6) not null, s3 decimal(6) default '123456', s4 decimal(6) default 123456, s5 decimal(6) default 45678, s6 decimal(1) default '1') ;
# insert中验证primary key, not null, check的约束作用
insert into stu(s1,s2) values(1, 11);
insert into stu(s1,s2,s5) values(1, 11, 111111);
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert into stu(s1,s2,s5) values(1, 11, 111111);
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert into stu(s1,s5) values(1, 111111);
ERROR HY000: Field 's2' doesn't have a default value
insert into stu(s1,s5) values(2, 222222);
ERROR HY000: Field 's2' doesn't have a default value
insert into stu(s1,s2,s5) values(2, 22, 2222222);
ERROR 22003: Out of range value for column 's5' at row 1
insert into stu(s2,s5) values(33, 333333);
ERROR HY000: Field 's1' doesn't have a default value
insert into stu(s1,s2,s5,s6) values(3, 33, 333333, 3);
# select中使用内置函数及算数运算
select length(s1) s1, nvl(s2, null) s2,substr(s3, 1, 4) s3, s4+654321 s4, s5*0 s5 from stu;
s1	s2	s3	s4	s5
1	11	1234	777777	0
1	33	1234	777777	0
# 以下nvl表达式的异常影响, bug: 22788257
# 
select upper(s1) s1, lower(s2) s2, nvl(s6,null) s6 from stu;
s1	s2	s6
1	11	1
3	33	3
select upper(s1) s1, lower(s2) s2, upper(nvl(s6,null)) s6 from stu;
s1	s2	s6
1	11	1
3	33	3
update set stu s6='' where s6=3;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'set stu s6='' where s6=3' at line 1
# select中函数转换
select cast(s1 as decimal) s1, cast(s2 as decimal) s2, cast(s3 as decimal) s3, cast(s4 as decimal) s4, cast(s5 as decimal) s5 from stu;
s1	s2	s3	s4	s5
1	11	123456	123456	45678
3	33	123456	123456	333333
delete from stu where 1=1;
# 修改字段类型, 测试函数及分组等
# 修改为比已有内容少
# 目前不支持alter操作 
# 设有默认值的decimal列, 修改类型时报默认值无效, bug:22797429 
# 
# 删表重新创建, 因不支持alter操作
DROP TABLE stu;
DROP TABLE stu1;
create table stu(s1 decimal(2) primary key, s2 decimal(20) not null, s3 decimal(20) default '123456', s4 decimal(20) default 123456, s5 decimal(20) default 45678, s6 decimal(1) default '1') ;
insert into stu(s1, s2, s3, s4, s5, s6) values(10, 20191001, 2009-10-01, 1999/10/01, 19891001, 2);
Warnings:
Warning	1265	Data truncated for column 's4' at row 1
# length表达式的结果写入decimal类型时报错, bug: 22797639
# 
insert into stu values(12, nvl('20191001', null), 2009-10-01, substr('1999/10/01',1,2), 19891001, length('aa'));
# where中使用函数, select中值转为时间类型
select * from stu where s1=13;
s1	s2	s3	s4	s5	s6
select * from stu where s6=2;
s1	s2	s3	s4	s5	s6
10	20191001	1998	200	19891001	2
12	20191001	1998	19	19891001	2
select * from stu where cast(s1 as decimal)=11;
s1	s2	s3	s4	s5	s6
# decimal类型列取出的值作为to_timestamp表达式参数时报错
# 
ALTER SESSION SET TIME_ZONE='+08:00';
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'SESSION SET TIME_ZONE='+08:00'' at line 1
# decimal类型列值作为to_date, next_day, to_timestamp_tz等表达式参数报错, bug: 22798050
# sql语法中的综合使用
select s6 from stu group by s6 having cast(s6 as decimal)=2;
s6
2
##################复制表操作, 约束, 分区##################
DROP TABLE stu;
DROP TABLE stu2;
DROP TABLE stu1;
DROP TABLE stu3;
# 创建两张关联表, 用上所有约束, 添加索引, 用来作为复制表的对象
create table stu1(s1 decimal(2) primary key, s2 decimal(20) default '12345');
insert into stu1(s1) values(1);
insert into stu1(s1) values(2);
insert into stu1(s1) values(3);
insert into stu1(s1) values(4);
insert into stu1(s1) values(2);
ERROR 23000: Duplicate entry '2' for key 'PRIMARY'
create table stu2(s1 decimal(2) unique not null, s2 decimal(20), s3 decimal(20) default 1, constraint stu2_all_pk primary key(s1,s2,s3) ,constraint stu2_fk foreign key(s3) references stu1(s1));
# 添加索引
create index s1_ind on stu2(s1);
create index s2_ind on stu2(s2);
create index s3_ind on stu2(s3);
# 添加并更新正常值
insert into stu2(s1,s2,s3) values(1,6,1);
update stu2 set s3=2 where s1=1;
# 更新为check限制外的值
# decimal类型列在和其它多列作为联合primary key时, check约束失效, bug: 22798363
# 
update stu2 set s3=3 where s1=1;
# 更新为不存在的关联值
update stu2 set s3=6 where s1=1;
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
insert into stu2(s1,s2) values(2,7);
# 检查unique是否有效
insert into stu2(s1,s2) values(2,8);
update stu2 set s1=1 where s1=2;
# 检查not null是否有效
insert into stu2(s2) values(8);
ERROR HY000: Field 's1' doesn't have a default value
update stu2 set s1='' where s1=2;
ERROR HY000: Incorrect decimal value for column 's1' at row 1
# insert 不存在的关联值
insert into stu2(s1,s2,s3) values(3,8,6);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
# s2字段的check是否有效,需大于5
# decimal类型列在和其它多列作为联合primary key时, check约束失效, bug: 22798363或者22741040
# 
# 
insert into stu2(s1,s2,s3) values(4,5,2);
# 受上面的check bug影响, 
update stu2 set s2=4 where s1=1;
# 插入些正常值供后续使用
insert into stu2 values(6, 8, 1);
insert into stu2 values(7, 9, 2);
insert into stu2 values(8, 10, 1);
select * from stu2;
s1	s2	s3
1	4	3
2	7	1
4	5	2
6	8	1
7	9	2
8	10	1
######复制表操作(create...as...)######
# 重新定义列名报语法错误, 
create table stu as select * from stu2;
select * from stu;
s1	s2	s3
1	4	3
2	7	1
4	5	2
6	8	1
7	9	2
8	10	1
# 依次测试unique, not null, check, foreign key, primary key是否有效
# 复制表后, oracle复制出的表中会保留基表的not null限制, ob不保留.
# 
# sql中验证函数的使用
# 不支持decode表达式 
# 复制表中s1的null限制还存在(insert), 验证update
# 复制表后, oracle复制出的表中会保留基表的not null限制, ob不保留.
# 
update stu set s1='' where s3=10;
update stu set s1=1 where s2=10;
update stu set s2=1 where s3=2;
update stu set s2='' where s3=2;
ERROR HY000: Incorrect decimal value for column 's2' at row 1
update stu set s3=100 where s1=1;
update stu set s3='' where s1=1;
ERROR HY000: Incorrect decimal value for column 's3' at row 1
# 复制表操作(insert...as...)
create table stu3(s1 decimal, s2 char(100), s3 char(100));
insert into stu3 select * from stu2;
# 验证复制来的表是否受限
insert into stu3 values(66666, '010203040506070809101', 15);
insert into stu3 values('','','');
ERROR HY000: Incorrect decimal value for column 's1' at row 1
# sql中验证函数的使用
select cast(s3 as decimal), count(*), sum(s2) from stu3 where 1=1 group by cast(s3 as decimal)  order by cast(s3 as decimal) desc;
cast(s3 as decimal)	count(*)	sum(s2)
15	1	1.0203040506070809e19
3	1	4
2	2	14
1	3	25
# 不支持decode表达式 
# 不支持禁用约束, 删除约束, 写入值测试
insert into stu2 values(1, 2, 2);
insert into stu2 values(10, 2, 2);
# 不提示约束了, foreign key的限制
insert into stu2 values(11, 2, 10);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
# 删除foreign key关联
insert into stu2 values(11, 2, 10);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
# 目前不支持修改约束名称及alter添加额外约束, 无法测试
# delete数据并查看stu2, stu, stu3
delete from stu2 where s3=2;
delete from stu where s3='';
ERROR HY000: Incorrect integer value
delete from stu3 where s3=1;
select * from stu2;
s1	s2	s3
1	4	3
2	7	1
6	8	1
8	10	1
# ob复制表中保留了联合primary key的非空限制bug: 
select * from stu;
s1	s2	s3
1	4	100
2	7	1
4	1	2
6	8	1
7	1	2
1	10	100
select s1,s3 from stu3;
s1	s3
1	3
4	2
7	2
66666	15
truncate table stu2;
insert into stu2(s1,s2,s3) values(1,6,1);
# 暂不支持range和list分区, 以下暂时测试不了
##################约束, 分区(range)##################
DROP TABLE stu;
DROP TABLE stu2;
DROP TABLE stu1;
DROP TABLE stu3;
