########decimal-8-1及decimal-8-11测试点##########
##################自定义类型create type...as...##################
drop table stu;
drop type my_type;
# 不支持create type语法, 不做具体测试. bug: 22775701
# 
##################type record测试##################
# 不支持type record语法, 不做具体测试
# 
##################procedure及匿名块中的使用##################
drop table stu;
drop table stu2;
drop table stu1;
drop type my_type;
create table stu(s1 decimal(6), s2 decimal(6));
insert into stu values('123', '456');
create table stu1(s1 varchar(5), s2 varchar(5));
# decimal作为声明的变量类型时报错, bug: 22777925
# 
# 读取decimal类型的值, 分别写入varchar和varchar2类型中
select * from stu1;
s1	s2
##################%type的使用##################
drop table stu;
drop table stu2;
drop table stu1;
drop type my_type;
create table stu(s0 decimal(2), s1 decimal(6), s2 decimal(6));
insert into stu values(1, '1212', '3434');
insert into stu values(2, '123', '456');
create table stu1(s0 decimal(2), s1 decimal(8), s2 decimal(6));
# decimal内容写入varchar和varchar2中
# bug: 
# varchar和varchar2内容写入decimal中
insert into stu1 values(3,'1234','3456');
# varchar和varchar2内容写入decimal中,超限情况测试
##################%rowtype的使用##################
drop table stu;
drop table stu2;
drop table stu1;
drop type my_type;
create table stu(s1 decimal(3), s2 decimal(3));
insert into stu values(12, 344);
create table stu1(s1 decimal(3), s2 decimal(4));
# 类型间的隐式转换
# 使用%rowtype时, put_line结果乱码, bug: 22781858
# 
# 以下验证预期的位数超限错误
# 块中写入decimal列汉字有乱码bug: 
select * from stu1;
s1	s2
##################中文, 日语, 韩语等的测试##################
drop table stu;
drop table stu2;
drop table stu1;
drop type my_type;
# 验证预期建表失败-生成列需大于依赖列字符数加拼接字符数
create table stu(s1 decimal(2), s2 decimal(2), s3 decimal(2), s4 decimal(4) generated always as(s3 || '123'));
insert into stu(s1, s2, s3) values(1, '6', '9');
insert into stu(s1, s2, s3) values(1, 2, 3);
drop table stu;
drop table stu2;
drop table stu1;
drop type my_type;
