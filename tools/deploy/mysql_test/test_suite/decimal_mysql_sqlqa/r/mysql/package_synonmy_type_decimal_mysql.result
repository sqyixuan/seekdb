########decimal-3测试点##########
##################打开外键约束##################
set foreign_key_checks=1;
##################package中的应用##################
drop table stu;
drop table stu2;
drop table stu1;
drop package my_pkg;
# 创建表stu1, stu2 foreign key stu1
create table stu1(s1 decimal(2) primary key, s2 decimal(4) unique, s3 decimal(20) generated always as(s2*0.001));
create index stu1_s3 on stu1(s3);
create index stu1_s2 on stu1(s2);
insert into stu1(s1,s2) values(2,2);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu1(s1,s2) values(3,3);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu1(s1,s2) values(4,4);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu1(s1,s2) values(20,20);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
# 创建表stu2, s2外键关联stu1的s1字段
create table stu2(s1 decimal(2), s2 decimal(5), s3 decimal(20) generated always as(s2/5), constraint stu2_pk primary key(s1,s2), constraint stu2_fk foreign key(s2) references stu1(s1));
create index stu2_s1 on stu2(s1);
create index stu2_s2 on stu2(s2);
create index stu2_s3 on stu2(s3);
# 验证预期失败, s1只能写入数字
insert into stu2(s1,s2) values('a',0);
ERROR HY000: Incorrect decimal value for column 's1' at row 1
# 验证预期失败, 外键不存在数字
insert into stu2(s1,s2) values(1,0);
ERROR 23000: Cannot add or update a child row: a foreign key constraint fails
# 验证预期失败, s1 check受限
insert into stu2(s1,s2) values(1,2);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
# 写入正常值
insert into stu2(s1,s2) values(3,2);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu2(s1,s2) values(6,3);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu2(s1,s2) values(9,4);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
insert into stu2(s1,s2) values(99,4);
Warnings:
Warning	1265	Data truncated for column 's3' at row 1
drop table stu;
create table stu(s1 decimal(2), s2 decimal(20) generated always as(s1/5) unique);
drop table stu;
drop table stu2;
drop table stu1;
drop package my_pkg;
