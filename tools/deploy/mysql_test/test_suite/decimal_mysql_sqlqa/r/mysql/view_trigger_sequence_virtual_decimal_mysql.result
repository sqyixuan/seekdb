########decimal-8-3及decimal-8-6测试点##########
##################同步测试环境及引入时区文件##################
# 此项需要根据运行环境选择使用
##################虚列,启用与禁用约束##################
DROP TABLE stu;
DROP TABLE stu1;
# 不支持alter添加约束, 不支持alter禁用和启用约束, 
# 不支持删除primary key , 不支持删除check时使用cascade 
# 验证虚拟列值和check的冲突, 虚拟列设置默认值
create table stu1(s1 decimal(2), s2 decimal(20) generated always as(s1+10));
insert into stu1(s1) values(1);
# 验证虚拟列值和check约束
insert into stu1(s1) values(2);
create table stu(s1 decimal(2) primary key, s2 decimal(20) generated always as (s1+10), s3 decimal(20) default 6);
# 验证异常情况,给虚列写值
insert into stu(s1,s2,s3) values(5, 10, 1);
ERROR HY000: The value specified for generated column 's2' in table 'stu' is not allowed
# 验证异常情况,check约束
insert into stu(s1,s3) values(5, 1);
# 验证缺省虚拟列名的写入
insert into stu values(6, 1);
ERROR 21S01: Column count doesn't match value count at row 1
insert into stu(s1) values(7);
# 删除约束,写入值测试
insert into stu(s1,s3) values(5, 1);
ERROR 23000: Duplicate entry '5' for key 'PRIMARY'
insert into stu(s1) values(10);
insert into stu(s1) values(10);
ERROR 23000: Duplicate entry '10' for key 'PRIMARY'
##################使用虚拟列作为外键和分区列, 创建索引##################
DROP TABLE stu;
DROP TABLE stu2;
DROP TABLE stu1;
# 虚拟列不支持作为foreign key字段. bug: 
# 当前外键有bug, 修复后测试
##################虚拟列的视图##################
DROP TABLE stu;
DROP TABLE stu1;
drop view view_stu;
drop view view_stu1;
# 创建基表
create table stu1(s1 decimal(2), s2 decimal(20) generated always as(s1+5));
insert into stu1(s1) values(1);
insert into stu1(s1) values('');
insert into stu1(s1) values(null);
insert into stu1(s1) values('0');
select s2 from stu1 order by s2 desc;
s2
6
5
NULL
select s2 from stu1 order by s2 asc;
s2
NULL
5
6
# 创建两个视图(一个使用原列名, 一个重命名)
create view view_stu as select * from stu1;
create view view_stu1(s1,s2) as select * from stu1;
# 视图中对decimal及其虚拟列的dml操作
insert into stu1(s1) values(3);
insert into view_stu(s1) values(3);
insert into view_stu1(s1) values(3);
insert into view_stu(s1) values(20);
insert into view_stu1(s1) values(20);
update view_stu set s2=5 where s1=3;
ERROR HY000: The value specified for generated column 's2' in table 'view_stu' is not allowed
update view_stu1 set s2=5 where s1=3;
ERROR HY000: The value specified for generated column 's2' in table 'view_stu1' is not allowed
# 此处update视图的bug, 修复后得更改
update view_stu set s1=18 where s2=8;
update view_stu1 set s1=15 where s2=8;
delete from view_stu;
select * from stu1;
s1	s2
select * from view_stu;
s1	s2
select * from view_stu1;
s1	s2
##################函数中的decimal应用##################
DROP TABLE stu;
DROP TABLE stu1;
drop view view_stu;
drop view view_stu1;
# 创建表
create table stu(s1 decimal(2), s2 decimal, s3 char(2), s4 varchar(2), s5 decimal(20) generated always as(s1*2));
insert into stu(s1,s2,s3,s4) values(1,1,1,1);
insert into stu(s1,s2,s3,s4) values(50,50,50,50);
# 函数中都decimal类型的增删改查
# 查看各类型的值, 统一返回decimal类型
# decimal类型不支持自定义函数, 已知bug: 22695959
##################trigger中的decimal应用1 ##################
DROP TABLE stu;
DROP TABLE stu1;
drop trigger stu_tg;
# 创建表
create table stu(s1 decimal(2) primary key, s2 decimal(2) not null, s3 decimal(2));
# 创建trigger, 验证insert和update超限字符
# 触发器的触发,验证预期异常, insert和update超过2个字符的内容
insert into stu values(1,2,3);
insert into stu values(2,2,2);
update stu set s3=4 where s1=1;
delete from stu;
##################trigger中的decimal应用2 ##################
DROP TABLE stu;
drop trigger stu_tg;
# 创建表
create table stu(s1 decimal(2) primary key, s2 decimal(2) not null, s3 decimal(2) unique);
# 创建trigger
# 触发器的触发,验证primary key,not null,unique及字符超限
insert into stu values(1,2,2);
insert into stu values(2,2,1);
insert into stu values(2,2,3);
ERROR 23000: Duplicate entry '2' for key 'PRIMARY'
insert into stu values(3,'',4);
ERROR HY000: Incorrect decimal value for column 's2' at row 1
insert into stu values(4,null,5);
ERROR 23000: Column 's2' cannot be null
insert into stu values(5,5,6);
insert into stu values(6,6,6);
insert into stu values(7,6,6);
insert into stu values(8,6,9);
# 创建trigger
insert into stu values(10,6,9);
insert into stu values(11,6,8);
##################sequence中的decimal应用1 ##################
DROP TABLE stu;
DROP TABLE stu1;
drop sequence seq;
# 创建表, 测试序列
create table stu(s1 decimal(1) unique, s2 decimal(1) not null, s3 decimal(1) primary key);
create table stu1(s1 decimal(1), s2 decimal(1), s3 decimal(1),s4 decimal(1));
insert into stu1 values(1,1,1,1);
# 创建序列
# 使用序列insert
# 添加虚拟列
# 虚拟列insert成功了, 已知bug: 
# 修改虚拟列依赖, 已知bug: 
select * from stu;
s1	s2	s3
DROP TABLE stu;
DROP TABLE stu1;
drop sequence seq;
