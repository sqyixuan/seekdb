--echo  # 删表重新创建, 因不支持alter操作
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--enable_warnings
create table stu(s1 decimal(2) primary key, s2 decimal(20) not null, s3 decimal(20) default '123456', s4 decimal(20) default 123456, s5 decimal(20) default 45678, s6 decimal(1) default '1') ;

insert into stu(s1, s2, s3, s4, s5, s6) values(10, 20191001, 2009-10-01, 1999/10/01, 19891001, 2);
#insert into stu values(11, to_number('18600618'), 1875-09-24, 1987/05/21, cast('19790321' as decimal), 2);
