--echo ########decimal-1及decimal-8-2测试点##########
--echo  ##################同步测试环境及引入时区文件##################
--echo  # 此项需要根据运行环境选择使用
#alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
#alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
#alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
#alter session set NLS_DATE_LANGUAGE = American;
--echo  # ob中的开启外键功能
set foreign_key_checks=1;



--echo  ##################基础功能测试##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu2;
--error 0,1051
DROP TABLE stu1;
--enable_warnings

--echo  # 指定位数的容量测试, 0及异常数字及非法值
create table stu(s1 decimal(2));
--error 1366
insert into stu(s1) values('测试');
--error 1366
insert into stu(s1) values('测试,');
--error 1366
insert into stu values('   ');
--error 1366
insert into stu values('测测试');
--error 1366
insert into stu values('  ');
insert into stu values(null);
--error 1054
insert into stu values(好的);
--error 1064
insert into stu values(,,,);
--error 1366
insert into stu values(',,,');
--error 1366
insert into stu values('\\\\');
--error 1366
insert into stu values('\\');
--error 1366
insert into stu values('**');
--error 1366
insert into stu values('$$');
--error 1366
insert into stu values('%%');
--error 1366
insert into stu values('''');
--error 1366
insert into stu values('''''');
--error 1264
insert into stu values(123);
--error 1366
insert into stu values('abc');
--error 1366
insert into stu values(''' ');
--error 1366
insert into stu values(' '' ');
--error 1366
insert into stu values('');
create table stu1(s1 decimal(0));
--error 1064
create table stu1(s1 decimal(-10));











--echo  ##################内置函数的嵌套使用##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--enable_warnings

--echo  # 测试check和默认值的冲突
create table stu1(s1 decimal(2) primary key, s2 decimal(6) not null, s3 decimal(6) default '123456', s4 decimal(6) default 123456, s5 decimal(6) default 45678);

insert into stu1(s1,s2,s5) values(1, 11, 111111);
--error 0,1264
insert into stu1(s1,s2,s5) values(1, 11, 1111111);

create table stu(s1 decimal(2) primary key, s2 decimal(6) not null, s3 decimal(6) default '123456', s4 decimal(6) default 123456, s5 decimal(6) default 45678, s6 decimal(1) default '1') ;

--echo  # insert中验证primary key, not null, check的约束作用

insert into stu(s1,s2) values(1, 11);
--error 1062
insert into stu(s1,s2,s5) values(1, 11, 111111);
--error 1062
insert into stu(s1,s2,s5) values(1, 11, 111111);
--error 1364
insert into stu(s1,s5) values(1, 111111);
--error 1364
insert into stu(s1,s5) values(2, 222222);
--error 1264
insert into stu(s1,s2,s5) values(2, 22, 2222222);
--error 1364
insert into stu(s2,s5) values(33, 333333);
insert into stu(s1,s2,s5,s6) values(3, 33, 333333, 3);

--echo  # select中使用内置函数及算数运算
select length(s1) s1, nvl(s2, null) s2,substr(s3, 1, 4) s3, s4+654321 s4, s5*0 s5 from stu;
--echo  # 以下nvl表达式的异常影响, bug: 22788257
--echo  # 
select upper(s1) s1, lower(s2) s2, nvl(s6,null) s6 from stu;
select upper(s1) s1, lower(s2) s2, upper(nvl(s6,null)) s6 from stu;
#select upper(s1) s1, lower(s2) s2, decode(s6, null, '空', 3, s6) s3, nvl(s6,null) s6 from stu;
#select upper(s1) s1, lower(s2) s2, decode(s6, null, '空', s6, s6) s3, nvl(s6,null) s6 from stu;
#select upper(s1) s1, lower(s2) s2, decode(s6, '', '空', s6, s6) s3, nvl(s6,null) s6 from stu;
# 目前不支持nval2表达式
#select upper(s1) s1, lower(s2) s2, decode(s6, '', '空', s6, s6) s3, nvl2(s6,null,'空值') s6 from stu;
--error 1064
update set stu s6='' where s6=3;
#select upper(s1) s1, lower(s2) s2, decode(s6, '', '空', s6, s6) s3, nvl2(s6,null,000) s6 from stu;

--echo  # select中函数转换
#select to_number(s1) s1, to_number(s2) s2, to_number(s3) s3, to_number(s4) s4, to_number(s5) s5 from stu;
#select to_char(s1) s1, to_char(s2) s2, to_char(s3) s3, to_char(s4) s4, to_char(s5) s5 from stu;
select cast(s1 as decimal) s1, cast(s2 as decimal) s2, cast(s3 as decimal) s3, cast(s4 as decimal) s4, cast(s5 as decimal) s5 from stu;
delete from stu where 1=1;

--echo  # 修改字段类型, 测试函数及分组等
