#--echo  # 更新为check限制外的值
#--error 02290
#update stu2 set s3=6 where s1=1;
#
#--echo  # 更新为不存在的关联值
#--error 02291
#update stu2 set s3=10 where s1=1;
#
#insert into stu2(s1,s2) values(2,7);
#
#--echo  # 检查unique是否有效
#--error 00001
#insert into stu2(s1,s2) values(2,8);
#--error 00001
#update stu2 set s1=1 where s1=2;
