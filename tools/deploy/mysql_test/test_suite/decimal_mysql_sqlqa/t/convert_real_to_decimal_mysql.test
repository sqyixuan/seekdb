#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: convert float(M,D)/Double(M,D) to Decimal(P,S)
#tags: decimal,ddl,dml
#author: zuojiao.hzj



--echo  # ### turn on converting flag
alter system set _enable_convert_real_to_decimal = false;

--disable_warnings
drop table if exists nation;
--enable_warnings
sleep 2;

--echo  # ### turn on converting flag
alter system set _enable_convert_real_to_decimal = true;
sleep 2;

--echo  # DDL
--disable_warnings
drop table if exists nation;
--enable_warnings

create table nation (CountryCode varchar(100), cf1 float, cf2 float(10, 0), cf3 float(65, 10), cf4 float(10), cf5 float(53), cd1 double, cd2 double(10,0), cd3 double(65,10) );

desc nation;

insert into nation values ('china', 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789);

select * from nation where cf1=1.12346;

select * from nation where cf3=1.123456789;

select * from nation where cd1=1.123456789;

alter table nation modify cf4 float(25, 10);

desc nation;

insert into nation values ('china', 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789);

select * from nation;

select * from nation where cf4=1.123456789;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 float(0,0));

desc t1;

insert into t1 values(1);
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (ia float (54,25) ZEROFILL );
desc t1;
insert into t1 values (10.10);
select * from t1;

--disable_warnings
drop table if exists  t1;
--enable_warnings
create table t1 (ia float (54,25) UNSIGNED );
desc t1;
insert into t1 values (10.10);
select * from t1;

--echo  # test pl

--disable_warnings
drop procedure if exists createnation;
--enable_warnings

delimiter //;

CREATE PROCEDURE createnation ()
       BEGIN
         drop table if exists nation;
         create table nation (CountryCode varchar(100), cf1 float, cf2 float(10, 0), cf3 float(65, 10), cf4 float(10), cf5 float(53), cd1 double, cd2 double(10,0), cd3 double(65,10) );
         desc nation;
       END//

delimiter ;//

call createnation();



insert into nation values ('china', 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789);

select * from nation where cf1=1.12346;

select * from nation where cf3=1.123456789;

select * from nation where cd1=1.123456789;


--disable_warnings
drop procedure if exists alternationtable;
--enable_warnings

delimiter //;

CREATE PROCEDURE alternationtable ()
       BEGIN
         alter table nation modify cf4 float(25, 10);
         desc nation;
       END//     

delimiter ;//

call alternationtable();         

insert into nation values ('china', 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789, 1.123456789);

select * from nation;

select * from nation where cf4=1.123456789;


--disable_warnings
drop procedure createnation;
drop procedure alternationtable;
--enable_warnings



--echo  # test pl22


--disable_warnings
drop procedure if exists pf;
drop procedure if exists pf1;
--enable_warnings

delimiter //;
create procedure pf(IN x float(20,10), OUT Z float(20,10))
    begin 
      declare y float;  
      SELECT cf4 into z from nation limit 1;
    end//

create procedure pf1(IN x decimal(20,10), OUT Z decimal(20,10))
    begin
      declare y float;
      SELECT cf4 into z from nation limit 1;
    end//

delimiter ;//

call pf(3.0, @f1_out);

call pf1(3.0, @f2_out);

--disable_warnings
drop procedure if exists pf1;
drop procedure if exists pf;
drop table if exists nation;
drop table if exists t1;
--enable_warnings

--echo ### turn off flag

alter system set _enable_convert_real_to_decimal = false;

sleep 2;

create table nation (CountryCode varchar(100), cf1 float, cf2 float(10, 0), cf3 float(65, 10), cf4 float(10), cf5 float(53), cd1 double, cd2 double(10,0), cd3 double(65,10) );

drop table if exists nation;


