--echo  ##################procedure及匿名块中的使用##################
--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,1064
drop type my_type;
--enable_warnings



create table stu(s1 decimal(6), s2 decimal(6));
insert into stu values('123', '456');
create table stu1(s1 varchar(5), s2 varchar(5));


delimiter //;
--echo  # decimal作为声明的变量类型时报错, bug: 22777925
--echo  # 
#--error 00900
#create or replace procedure pro is
#x decimal(6);
#y decimal(6);
#begin
#select s1 into x from stu;
#select s2 into y from stu;
#insert into stu1 values(x,y);
#end;
#//

#begin
#pro();
#end;
#//


--echo  # 读取decimal类型的值, 分别写入varchar和varchar2类型中
#declare
#x decimal(6);
#y decimal(6);
#begin
#select s1 into x from stu;
#select s2 into y from stu;
#insert into stu1 values(x,y);
#end;
#//


delimiter ;//
select * from stu1;


--echo  ##################%type的使用##################
--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,1064
drop type my_type;
--enable_warnings


create table stu(s0 decimal(2), s1 decimal(6), s2 decimal(6));
insert into stu values(1, '1212', '3434');
insert into stu values(2, '123', '456');
create table stu1(s0 decimal(2), s1 decimal(8), s2 decimal(6));


--echo  # decimal内容写入varchar和varchar2中
--echo  # bug: 
#delimiter //;
#declare
#x stu.s1%type;
#y stu.s2%type;
#begin
#select s1,s2 into x,y from stu where s0=1;
#insert into stu1 values(1,x||'中',y || 'a');
#end;
#//
#
#declare
#x stu.s1%type;
#y stu.s2%type;
#begin
#select s1,s2 into x,y from stu where s0=2;
#insert into stu1 values(2,x+10000000,y+100000);
#end;
#//

#delimiter ;//
--echo  # varchar和varchar2内容写入decimal中
insert into stu1 values(3,'1234','3456');
delimiter //;
#declare
#x stu.s1%type:=0;
#y stu.s2%type:=0;
#begin
#select s1,s2 into x,y from stu1 where s0=3;
#insert into stu values(3,x,y);
#end;
#//


--echo  # varchar和varchar2内容写入decimal中,超限情况测试
--error 00600
#declare
#x stu.s1%type:=1234567;
#y stu.s2%type:='abcdefg';
#begin
#insert into stu values(4,x,y);
#end;
#//

delimiter ;//
#select * from stu1;
#select * from stu;



--echo  ##################%rowtype的使用##################
--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,1064
drop type my_type;
--enable_warnings


create table stu(s1 decimal(3), s2 decimal(3));
insert into stu values(12, 344);
create table stu1(s1 decimal(3), s2 decimal(4));


delimiter //;
--echo  # 类型间的隐式转换
#--error 0,600
#declare
#x stu%rowtype;
#y decimal(3):=0;
#z decimal(12):=0;
#begin
#select s1,s2 into y,z from stu;
#insert into stu1 values(y+100, '3'||z);
#end;
#//

--echo  # 使用%rowtype时, put_line结果乱码, bug: 22781858
--echo  # 
#declare
#x stu%rowtype;
#begin
#x.s1:='123';
#DBMS_output.put_line('输出结果: ' || x.s1);
#end;
#//
# 正确结果如下:
# 输出结果: 123

--echo  # 以下验证预期的位数超限错误
--error 6502
#declare
#x stu%rowtype;
#begin
#x.s1:='1234';
#DBMS_output.put_line(x.s1);
#end;
#//

--error 1722
#declare
#x stu%rowtype;
#begin
#x.s1:='古之学者';
#DBMS_output.put_line(x.s1);
#end;
#//

--error 1722
#declare
#x stu%rowtype;
#begin
#x.s1:='古之1a0';
#DBMS_output.put_line(x.s1);
#end;
#//

delimiter ;//
--echo # 块中写入decimal列汉字有乱码bug: 
select * from stu1;




--echo  ##################中文, 日语, 韩语等的测试##################
--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,1064
drop type my_type;
--enable_warnings

--echo  # 验证预期建表失败-生成列需大于依赖列字符数加拼接字符数
--error 0,600
create table stu(s1 decimal(2), s2 decimal(2), s3 decimal(2), s4 decimal(4) generated always as(s3 || '123'));

#--echo  # decimal作为生成列依赖在特定条件下的insert异常, bug: 22782820
#--echo  # 
#create table stu(s1 decimal(2), s2 decimal(2), s3 decimal(2), s4 decimal(5) generated always as(s3 || '123'));

insert into stu(s1, s2, s3) values(1, '6', '9');

insert into stu(s1, s2, s3) values(1, 2, 3);

--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,1064
drop type my_type;
--enable_warnings

