--echo ########decimal-2测试点##########
--echo  ##################银行业务原sql测试##################
--echo  # 场景1
--disable_warnings
--error 0,1051
DROP TABLE AMT_POS_TRADE_COUN_AND_PRO;
--enable_warnings

CREATE TABLE AMT_POS_TRADE_COUN_AND_PRO (AREA_CODE decimal(20) NOT NULL, AREA_NAME decimal(30) NOT NULL, FLAG decimal(2) NOT NULL, STATUS decimal(2) NOT NULL, KIND decimal(2) NOT NULL, CONSTRAINT AREA_CODE_KEY PRIMARY KEY (AREA_CODE));

insert into AMT_POS_TRADE_COUN_AND_PRO values(1,2,3,4,5);
--error 1366
insert into AMT_POS_TRADE_COUN_AND_PRO values('a','1',000000,'b','c');
select * from AMT_POS_TRADE_COUN_AND_PRO;



