--disable_warnings
--error 0,1051
drop table stu;
--enable_warnings

create table stu(s1 decimal(2), s2 decimal(20) generated always as(s1/5) unique);



--disable_warnings
--error 0,1051
drop table stu;
--error 0,1051
drop table stu2;
--error 0,1051
drop table stu1;
--error 0,5559
drop package my_pkg;
--enable_warnings
