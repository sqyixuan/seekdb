--echo ########decimal-4测试点##########
###--echo ##精度,小数位数


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal NOT NULL);
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(3) NOT NULL);
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(3,2) NOT NULL);
--error 0,1264
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(4,2) NOT NULL);
--error 0,1264
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(5,2) NOT NULL);
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(6,1) NOT NULL);
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
CREATE TABLE t1  
(a1 decimal(6,2) NOT NULL);
insert INTO t1 values(123.89);
SELECT * FROM t1;


--disable_warnings
--error 0,1051
DROP TABLE t1;
--enable_warnings
--error 1427
CREATE TABLE t1  
(a1 decimal(4,5) NOT NULL);
