--echo  ##################trigger中的decimal应用1 ##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--error 0,1360
drop trigger stu_tg;
--enable_warnings

--echo  # 创建表
create table stu(s1 decimal(2) primary key, s2 decimal(2) not null, s3 decimal(2));

--echo  # 创建trigger, 验证insert和update超限字符
delimiter //;
#create or replace trigger stu_tg before insert or update on stu
#for each row
#begin
#if length(:new.s3)>=5 then
#select 'abcd' into :new.s3 from dual;
#else select :new.s3 into :new.s3 from dual;
#end if;
#end stu_tg;
#//
delimiter ;//

--echo  # 触发器的触发,验证预期异常, insert和update超过2个字符的内容
insert into stu values(1,2,3);
--error 0,600
insert into stu values(2,2,2);
--error 0,600
update stu set s3=4 where s1=1;
delete from stu;



--echo  ##################trigger中的decimal应用2 ##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1360
drop trigger stu_tg;
--enable_warnings

--echo  # 创建表
create table stu(s1 decimal(2) primary key, s2 decimal(2) not null, s3 decimal(2) unique);

--echo  # 创建trigger
delimiter //;
#create or replace trigger stu_tg before insert or update on stu
#for each row
#begin
#if length(:new.s3)>=5 then
#select 'abcd' into :new.s3 from dual;
#else select :new.s3 into :new.s3 from dual;
#end if;
#end stu_tg;
#//
delimiter ;//

--echo  # 触发器的触发,验证primary key,not null,unique及字符超限
insert into stu values(1,2,2);
insert into stu values(2,2,1);
--error 1062
insert into stu values(2,2,3);
--error 1366
insert into stu values(3,'',4);
--error 1048
insert into stu values(4,null,5);
insert into stu values(5,5,6);
--disable_result_log
--error 1062
insert into stu values(6,6,6);
--error 1062
insert into stu values(7,6,6);
--error 0,600
insert into stu values(8,6,9);

--echo  # 创建trigger
#delimiter //;
#create or replace trigger stu_tg before insert or update on stu
#for each row
#begin
#dbms_output.put_line('触发器的输出');
#if length(:new.s3)<2 then
#:new.s3:=5;
#else select :new.s3 into :new.s3 from dual;
#end if;
#end stu_tg;
#//
#delimiter ;//
--error 1062
insert into stu values(10,6,9);

insert into stu values(11,6,8);



--echo  ##################sequence中的decimal应用1 ##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--error 0,4298
drop sequence seq;
--enable_warnings

--echo  # 创建表, 测试序列
create table stu(s1 decimal(1) unique, s2 decimal(1) not null, s3 decimal(1) primary key);
create table stu1(s1 decimal(1), s2 decimal(1), s3 decimal(1),s4 decimal(1));
insert into stu1 values(1,1,1,1);

--echo  # 创建序列
#create sequence seq
#minvalue 1
#nomaxvalue
#start with 5
#increment by 1
#nocycle
#nocache;

--echo  # 使用序列insert
#insert into stu select seq.nextval, seq.nextval, seq.nextval from dual;
--error 01400
#insert into stu select seq.nextval, '', seq.nextval from dual;
#select seq.nextval from stu;
--disable_result_log
--error 00001
#insert into stu values(5,seq.nextval,seq.nextval);
--enable_result_log
--error 00001
#insert into stu values(seq.nextval,seq.nextval,5);
#select seq.nextval from stu;
--error 00600
#insert into stu select seq.nextval, seq.nextval, seq.nextval from dual;

--echo  # 添加虚拟列
#alter table stu add ss decimal(20) generated always as (s2+1);

--echo  # 虚拟列insert成功了, 已知bug: 
--error 00600
#insert into stu select seq.nextval-5, seq.nextval-5, seq.nextval-5, seq.nextval from dual;
--error 00600
#insert into stu select * from stu1;

--echo  # 修改虚拟列依赖, 已知bug: 
#--error 00600
#alter table stu modify ss as (s1+1);

select * from stu;
# 虚拟列insert成功了, 已知bug: 
#S1      S2      S3      SS
#5       5       5       6

--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--error 0,4298
drop sequence seq;
--enable_warnings

