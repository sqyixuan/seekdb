--echo  ##################虚列,启用与禁用约束##################
--disable_warnings
--error 0,1051
DROP TABLE stu;
--error 0,1051
DROP TABLE stu1;
--enable_warnings

--echo  # 不支持alter添加约束, 不支持alter禁用和启用约束, 
--echo  # 不支持删除primary key , 不支持删除check时使用cascade 

--echo  # 验证虚拟列值和check的冲突, 虚拟列设置默认值
create table stu1(s1 decimal(2), s2 decimal(20) generated always as(s1+10));
#comment on table stu1 is '被关联表';
insert into stu1(s1) values(1);
--echo  # 验证虚拟列值和check约束
--error 0,2290
insert into stu1(s1) values(2);


create table stu(s1 decimal(2) primary key, s2 decimal(20) generated always as (s1+10), s3 decimal(20) default 6);
#comment on table stu is '关联表';
#comment on column stu.s1 is '分区字段';

# 删除check
--echo  # 验证异常情况,给虚列写值
--error 3105
insert into stu(s1,s2,s3) values(5, 10, 1);
--echo  # 验证异常情况,check约束
--error 0,1062
insert into stu(s1,s3) values(5, 1);
--echo  # 验证缺省虚拟列名的写入
--error 1136
insert into stu values(6, 1);
insert into stu(s1) values(7);
--echo  # 删除约束,写入值测试
#alter table stu drop constraint s1_ch;
--error 1062
insert into stu(s1,s3) values(5, 1);
insert into stu(s1) values(10);
--error 1062
insert into stu(s1) values(10);



