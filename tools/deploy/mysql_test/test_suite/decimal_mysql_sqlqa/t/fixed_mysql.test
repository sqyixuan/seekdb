#owner:zuojiao.hzj
#owner group: SQL-SQL2
#description: test mysql fixed type
#tags: fixed,ddl,dml
#author:zuojiao.hzj

--disable_warnings
drop database if exists fixed1;
--enable_warnings

create database fixed1;
use fixed1;

--echo create table with fixed type
create table t1(f1 fixed, f2 fixed(5), f3 fixed(7, 2));
desc t1;

--echo explicit cast 
select cast(1 as fixed) f1, cast(2 as fixed(5)) f2, cast(3 as fixed(7, 2)) f3;
select cast('1' as fixed) f1, cast('2' as fixed(5)) f2, cast('3' as fixed(7, 2)) f3;
select cast(1.1 as fixed) f1, cast(2.2 as fixed(5)) f2, cast(3.3 as fixed(7, 2)) f3;

drop table t1;
drop database fixed1;
