# owner group: SQL2
# Test cast url_decode
# tags: url, decode, charset

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings

CREATE TABLE `t1` (
  `a` varchar(4) DEFAULT NULL,
  `b` varchar(4) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t2` (
  `a` varchar(4) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 ;
CREATE TABLE `t3` (
  `a` varchar(4) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t4` (
  `a` varchar(4) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t5` (
  `a` binary(10) DEFAULT NULL,
  `b` varbinary(255) DEFAULT NULL
) DEFAULT CHARSET = binary ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;


SELECT 
    IF(
        true, 
        subq_0.c0, 
        subq_0.c0
    ) AS c1
FROM 
    (SELECT 
        url_encode(CAST(CAST(NULL AS CHAR) AS CHAR) + 1) AS c0 
     FROM 
        t2 AS ref_0 
     WHERE 
        EXISTS (
            SELECT DISTINCT 
                2 AS c0 
            FROM 
                t5 AS ref_1 
            WHERE 
                95 NOT IN (77)
        )
    ) AS subq_0;


SELECT 
    IF(
        true, 
        subq_0.c0, 
        subq_0.c0
    ) AS c1
FROM 
    (SELECT 
        CAST(CAST(NULL AS CHAR) AS CHAR) + 1 AS c0 
     FROM 
        t2 AS ref_0 
     WHERE 
        EXISTS (
            SELECT DISTINCT 
                2 AS c0 
            FROM 
                t5 AS ref_1 
            WHERE 
                95 NOT IN (77)
        )
    ) AS subq_0;
