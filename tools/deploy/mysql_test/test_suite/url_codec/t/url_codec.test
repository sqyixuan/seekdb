--echo 参数为NULL值
select url_encode('');
select url_encode(NULL);
select url_decode('');
select url_decode(NULL);
select url_encode(url_decode(''));
select url_encode(url_decode(NULL));
select url_decode(url_encode(''));
select url_decode(url_encode(NULL));

--echo 参数为常量
select url_encode(17893);
select url_encode('17893');
select url_encode(0);
select url_encode(-1.9001);
select url_encode('testkxkk');
select url_encode('%0F');
select url_encode(' ');
select url_encode('*');
select url_encode('%……&&@！!>');
select url_encode('129we hih $^& 你好👋');
select url_decode(901);
select url_decode('%17191');
select url_decode(0);
select url_decode(-1.9001);
select url_decode(1.9001);
select url_decode('%0F');
select url_decode('%3C');
select url_decode('%33c');
select url_decode('%29u');
select url_decode('%ads');
select url_decode(url_encode('xdub12u NULL $点击即可 👋'));
select url_encode(url_decode('%901s xd&'));



--echo 参数为聚合函数
select url_encode(upper('ahhuAYU'));
select url_encode(ASCII('hbxs jiq1'));
select url_encode(BIN(12));
select url_encode(HEX('abc'));
select url_encode(CHARSET(char('' USING utf8mb4)));
select url_encode(BIT_LENGTH('oceanbase123'));
select url_encode(TIMESTAMP('2020-12-31 12:00:00','12:00:00'));
select url_encode(CONCAT('test','obclient', NULL));
select url_decode(ELT(3, 'abc1', 'abc2', 'abc', 'abc4', 'abc'));
select url_decode(LEFT('oceanbasebest',6 ));
select url_decode(LOWER('OBCLIENT您好！'));
select url_decode(LPAD('Base',1,'Ocean'));
select url_decode(TO_BASE64('OB'));
select url_decode(HEX(255));
select url_decode(LTRIM('    obclient    '));
select url_decode(CHARSET(char('' USING binary)));
select url_decode(MAKE_SET(1 | 4,'hello','ocean','base'));
select url_decode(url_encode(MAKE_SET(1 | 4,'hello','ocean','base')));
select url_decode(url_encode(LTRIM('    obclient    ')));
SELECT url_decode(DATE('2021-07-14 19:12:03'));
select url_encode(url_encode(url_decode(url_encode(12))));
select url_encode(url_decode(ELT(3, 'abc1', 'abc2', 'abc', 'abc4', 'abc')));

