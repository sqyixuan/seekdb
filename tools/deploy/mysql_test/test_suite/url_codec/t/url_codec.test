--disable_warnings
drop table if exists t4;
--enable_warnings

create table t4(a varchar(4));
insert into t4 values(null);
insert into t4 values(' ');
insert into t4 values('%20');
insert into t4 values(' ~');
insert into t4 values('%20~');

select url_decode('%0F');

--echo 异常参数
--error 1582 
select url_encode('Hello World', NULL);
--error 1583 
select url_encode(12.90O);
--error 1582 
select url_decode('Hello World', 123);
--error 1583
SELECT url_decode(E'\x48656c6c6f2c20576f726c6421');
--error 1064
select url_decode(%901);
--error 1210
select url_decode('%0G');
select url_decode('%FF');
--error 1210
select url_decode('%FG');
--error 1210
select url_decode('%G0');
--error 1210
select url_decode('%GF');
--error 1210
select url_decode('%0');
--error 1210
select url_decode('%G');
--error 1210
select url_decode('%F');
--error 1210
select url_decode('abc%0G');
--error 1210
select url_decode('abc%0');
--error 1210
select url_decode('abc%G');
select url_decode('abc%2F2');
select url_decode('abc%23');


--disable_warnings
drop table if exists t5;
--enable_warnings
--echo 使用binary字符集
CREATE TABLE t5 (a CHAR(10), b VARCHAR(255)) CHARACTER SET binary ;
insert into t5 values('%FE','%9c');
insert into t5 values('%FF','%9c');
insert into t5 values('%3c','%8bc');
insert into t5 values('%5D','%4A');
insert into t5 values('%7E','%2A');
select url_encode(url_encode(a)) from t5;
select url_decode(url_encode(b)) from t5;
select url_encode(url_decode(b)) from t5;
select url_decode(url_decode(a)) from t5;
select url_decode(a),url_decode(b) from t5;
select url_encode(a),url_encode(b) from t5;
insert into t5 values(NULL,'');
select url_decode(a),url_decode(b) from t5;
select url_encode(a),url_encode(b) from t5;



set _enable_rich_vector_format=true;

select url_encode(a) from t1;
select url_encode(url_encode(a)) from t1;

select url_decode(url_encode(a)) from t1;

--error 1210
select url_decode(a) from t2;

select url_decode(a) from t3;
select url_encode(url_decode(a)) from t3;

select *, url_encode(a),url_decode(a), url_decode(url_encode(a)) from t4;

set _enable_rich_vector_format=false;

select url_encode(a) from t1;
select url_encode(url_encode(a)) from t1;

select url_decode(url_encode(a)) from t1;

--error 1210
select url_decode(a) from t2;

select url_decode(a) from t3;
select url_encode(url_decode(a)) from t3;

select *, url_encode(a),url_decode(a), url_decode(url_encode(a)) from t4;
