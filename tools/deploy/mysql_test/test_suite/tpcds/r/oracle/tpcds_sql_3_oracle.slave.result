       [T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE)], [T_WIN_FUN_RANK()]), filter(nil), rowset=256
      win_expr(T_WIN_FUN_RANK()), partition_by([T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) 
      = cast(0, NUMBER(-1, -85)) THEN ITEM.I_CATEGORY ELSE NULL END]), order_by([T_FUN_SUM(STORE_SALES.SS_NET_PROFIT) / T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE),
       ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  4 - output([ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY)], [T_FUN_GROUPING(ITEM.I_CLASS)], [T_FUN_SUM(STORE_SALES.SS_NET_PROFIT)],
       [T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE)], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) 
      = cast(0, NUMBER(-1, -85)) THEN ITEM.I_CATEGORY ELSE NULL END], [T_FUN_SUM(STORE_SALES.SS_NET_PROFIT) / T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE)]), filter(nil), rowset=256
