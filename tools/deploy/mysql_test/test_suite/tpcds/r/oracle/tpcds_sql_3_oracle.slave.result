       [T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE)], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) 
