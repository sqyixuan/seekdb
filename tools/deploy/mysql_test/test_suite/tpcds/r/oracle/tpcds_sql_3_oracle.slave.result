      access([DATE_DIM.D_DATE_SK], [DATE_DIM.D_YEAR], [DATE_DIM.D_MOY]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX)always true
 15 - output([STORE_SALES.SS_CUSTOMER_SK], [STORE_SALES.SS_SOLD_DATE_SK]), filter(nil), rowset=256
