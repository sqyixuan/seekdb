      THEN ITEM.I_CATEGORY ELSE NULL END, ASC], [T_FUN_SUM(STORE_SALES.SS_NET_PROFIT) / T_FUN_SUM(STORE_SALES.SS_EXT_SALES_PRICE), ASC])
