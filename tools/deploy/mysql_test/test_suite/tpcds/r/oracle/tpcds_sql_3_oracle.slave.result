      access([VIEW4.CATALOG_SALES.CS_SHIP_CUSTOMER_SK])
 17 - output([CATALOG_SALES.CS_SHIP_CUSTOMER_SK]), filter(nil), rowset=256
      equal_conds([CATALOG_SALES.CS_SOLD_DATE_SK = DATE_DIM.D_DATE_SK]), other_conds(nil)
