      access([CUSTOMER.C_CUSTOMER_SK], [CUSTOMER.C_CURRENT_ADDR_SK], [CUSTOMER.C_LAST_NAME], [CUSTOMER.C_FIRST_NAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CUSTOMER.C_CUSTOMER_SK]), range(MIN ; MAX)always true
