 22 - output([DATE_DIM.D_DATE_SK]), filter([DATE_DIM.D_MOY <= cast(2 + 2, NUMBER(-1, -85))], [DATE_DIM.D_YEAR = cast(2002, NUMBER(-1, -85))], [DATE_DIM.D_MOY 
