      = cast(0, NUMBER(-1, -85)) THEN ITEM.I_CATEGORY ELSE NULL END, ASC], [T_WIN_FUN_RANK(), ASC]), topn(cast(FLOOR(cast(100, NUMBER(-1, -85))), BIGINT(-1, 0))),
       prefix_pos(1)
