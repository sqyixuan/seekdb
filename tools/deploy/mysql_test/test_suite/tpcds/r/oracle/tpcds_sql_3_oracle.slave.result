      access([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_NET_PROFIT], [STORE_SALES.SS_EXT_SALES_PRICE]), partitions(p0)
