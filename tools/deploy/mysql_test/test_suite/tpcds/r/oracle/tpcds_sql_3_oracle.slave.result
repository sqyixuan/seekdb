       [CUSTOMER_DEMOGRAPHICS.CD_CREDIT_RATING], [CUSTOMER_DEMOGRAPHICS.CD_DEP_COUNT], [CUSTOMER_DEMOGRAPHICS.CD_DEP_EMPLOYED_COUNT], [CUSTOMER_DEMOGRAPHICS.CD_DEP_COLLEGE_COUNT]), filter(nil), rowset=256
