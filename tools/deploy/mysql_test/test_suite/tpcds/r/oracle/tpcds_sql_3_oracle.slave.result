      win_expr(T_FUN_SUM(T_FUN_SUM(STORE_SALES.SS_SALES_PRICE))), partition_by([ITEM.I_MANAGER_ID]), order_by(nil), window_type(RANGE), upper(UNBOUNDED 
      PRECEDING), lower(UNBOUNDED FOLLOWING)
