  1 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE]), filter(nil)
  2 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE]), filter(nil), rowset=256
      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
  3 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE]), filter(nil), rowset=256
      distinct([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE])
  4 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE]), filter(nil), rowset=256
      sort_keys([ITEM.I_ITEM_ID, ASC], [ITEM.I_ITEM_DESC, ASC], [ITEM.I_CURRENT_PRICE, ASC])
  5 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE]), filter(nil), rowset=256
      conds(nil), nl_params_([ITEM.I_ITEM_SK(:2)]), use_batch=true
  6 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE], [ITEM.I_ITEM_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([INVENTORY.INV_ITEM_SK(:1)]), use_batch=true
  7 - output([INVENTORY.INV_ITEM_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([DATE_DIM.D_DATE_SK(:5)]), use_batch=true
  8 - output([DATE_DIM.D_DATE_SK]), filter([DATE_DIM.D_DATE >= cast('2001-06-09', DATE(0, 0))], [DATE_DIM.D_DATE <= cast('2001-08-08', DATE(0, 0))]), rowset=256
      access([DATE_DIM.D_DATE_SK], [DATE_DIM.D_DATE]), partitions(p0)
