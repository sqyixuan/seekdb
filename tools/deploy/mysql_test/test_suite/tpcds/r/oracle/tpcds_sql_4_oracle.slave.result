      access([GROUP_ID], [INVENTORY.INV_ITEM_SK], [INVENTORY.INV_QUANTITY_ON_HAND]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([INVENTORY.INV_DATE_SK], [INVENTORY.INV_ITEM_SK], [INVENTORY.INV_WAREHOUSE_SK]), range(MIN ; MAX), 
      range_cond([:5 = INVENTORY.INV_DATE_SK])
 10 - output([ITEM.I_ITEM_SK], [ITEM.I_CURRENT_PRICE], [ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC]), filter([ITEM.I_MANUFACT_ID IN (744, 884, 722, 693)], [ITEM.I_CURRENT_PRICE 
      <= 26 + 30], [ITEM.I_CURRENT_PRICE >= 26]), rowset=256
      access([GROUP_ID], [ITEM.I_ITEM_SK], [ITEM.I_CURRENT_PRICE], [ITEM.I_MANUFACT_ID], [ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
