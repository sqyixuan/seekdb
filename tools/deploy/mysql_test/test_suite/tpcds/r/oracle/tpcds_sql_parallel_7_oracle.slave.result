EXPLAIN select /*+parallel(2) TPC-DS Q67*/* from (select  i_item_id
,i_item_desc
,i_current_price
from item, inventory, date_dim, store_sales
where i_current_price between 22 and 22+30 and inv_item_sk = i_item_sk
and d_date_sk=inv_date_sk
and d_date between cast('1998-01-22' as date) and (cast('1998-03-22' as date))
and i_manufact_id in (211,338,181,209)
and inv_quantity_on_hand between 100 and 500 and ss_item_sk = i_item_sk
group by i_item_id,i_item_desc,i_current_price
order by i_item_id
) where rownum <= 100;
