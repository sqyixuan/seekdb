having count(*) > 10)A1)A2) V1
where ss_store_sk = s_store_sk
and ss_sold_date_sk = d_date_sk
and d_qoy = 2 and d_year = 1998  and (SUBSTR(s_zip,1,2) = SUBSTR(V1.ca_zip,1,2))
group by s_store_name
order by s_store_name
