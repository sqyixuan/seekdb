      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
  3 - output([CUSTOMER_ADDRESS.CA_ZIP], [T_FUN_SUM(CATALOG_SALES.CS_SALES_PRICE)]), filter(nil), rowset=256
      group([CUSTOMER_ADDRESS.CA_ZIP]), agg_func([T_FUN_SUM(CATALOG_SALES.CS_SALES_PRICE)])
  4 - output([CUSTOMER_ADDRESS.CA_ZIP], [CATALOG_SALES.CS_SALES_PRICE]), filter(nil), rowset=256
      sort_keys([CUSTOMER_ADDRESS.CA_ZIP, ASC])
  5 - output([CUSTOMER_ADDRESS.CA_ZIP], [CATALOG_SALES.CS_SALES_PRICE]), filter(nil), rowset=256
      equal_conds([CATALOG_SALES.CS_SOLD_DATE_SK = DATE_DIM.D_DATE_SK]), other_conds(nil)
  6 - output([DATE_DIM.D_DATE_SK]), filter([DATE_DIM.D_QOY = 1], [DATE_DIM.D_YEAR = 1998]), rowset=256
      access([DATE_DIM.D_DATE_SK], [DATE_DIM.D_QOY], [DATE_DIM.D_YEAR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX)always true
  7 - output([CUSTOMER_ADDRESS.CA_ZIP], [CATALOG_SALES.CS_SALES_PRICE], [CATALOG_SALES.CS_SOLD_DATE_SK]), filter(nil), rowset=256
      equal_conds([CATALOG_SALES.CS_BILL_CUSTOMER_SK = CUSTOMER.C_CUSTOMER_SK]), other_conds([(T_OP_OR, SUBSTR(cast(CUSTOMER_ADDRESS.CA_ZIP, VARCHAR2(10 
      BYTE)), 1, 5) IN (cast('85669', VARCHAR2(5 BYTE)), cast('86197', VARCHAR2(5 BYTE)), cast('88274', VARCHAR2(5 BYTE)), cast('83405', VARCHAR2(5 BYTE)), cast('86475',
       VARCHAR2(5 BYTE)), cast('85392', VARCHAR2(5 BYTE)), cast('85460', VARCHAR2(5 BYTE)), cast('80348', VARCHAR2(5 BYTE)), cast('81792', VARCHAR2(5 BYTE))),
       CUSTOMER_ADDRESS.CA_STATE IN ('CA', 'WA', 'GA'), CATALOG_SALES.CS_SALES_PRICE > 500)])
  8 - output([CUSTOMER_ADDRESS.CA_ZIP], [CUSTOMER_ADDRESS.CA_STATE], [CUSTOMER.C_CUSTOMER_SK]), filter(nil), rowset=256
      equal_conds([CUSTOMER.C_CURRENT_ADDR_SK = CUSTOMER_ADDRESS.CA_ADDRESS_SK]), other_conds(nil)
  9 - output([CUSTOMER_ADDRESS.CA_ADDRESS_SK], [CUSTOMER_ADDRESS.CA_ZIP], [CUSTOMER_ADDRESS.CA_STATE]), filter(nil), rowset=256
      access([CUSTOMER_ADDRESS.CA_ADDRESS_SK], [CUSTOMER_ADDRESS.CA_ZIP], [CUSTOMER_ADDRESS.CA_STATE]), partitions(p0)
      is_index_back=false, is_global_index=false, 
