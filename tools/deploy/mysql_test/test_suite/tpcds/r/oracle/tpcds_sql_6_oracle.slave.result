  6 - output([ITEM.I_CATEGORY], [ITEM.I_BRAND], [STORE.S_STORE_NAME], [STORE.S_COMPANY_NAME], [ITEM.I_CLASS], [DATE_DIM.D_MOY], [STORE_SALES.SS_SALES_PRICE]), filter(nil), rowset=256
      sort_keys([ITEM.I_CATEGORY, ASC], [ITEM.I_BRAND, ASC], [STORE.S_STORE_NAME, ASC], [STORE.S_COMPANY_NAME, ASC], [ITEM.I_CLASS, ASC], [DATE_DIM.D_MOY,
