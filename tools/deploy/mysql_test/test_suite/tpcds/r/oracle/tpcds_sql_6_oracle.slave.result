 10 - output([J.I_CATEGORY], [J.I_CURRENT_PRICE]), filter(nil), rowset=256
      access([J.I_CATEGORY], [J.I_CURRENT_PRICE]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([J.I_ITEM_SK]), range(MIN ; MAX)always true
 11 - output([S.SS_CUSTOMER_SK], [I.I_CATEGORY], [I.I_CURRENT_PRICE]), filter(nil), rowset=256
      equal_conds([S.SS_SOLD_DATE_SK = D.D_DATE_SK]), other_conds(nil)
