      access([STORE_RETURNS.SR_ITEM_SK], [STORE_RETURNS.SR_TICKET_NUMBER], [STORE_RETURNS.SR_CUSTOMER_SK], [STORE_RETURNS.SR_RETURNED_DATE_SK], [STORE_RETURNS.SR_RETURN_QUANTITY]), partitions(p0)
      is_index_back=false, is_global_index=false, 
