********************** TPC_DS Q53
EXPLAIN select /*TPC-DS Q53*/* from (select i_item_id
,i_item_desc
,s_store_id
,s_store_name
,max(ss_quantity)        as store_sales_quantity
,max(sr_return_quantity) as store_returns_quantity
,max(cs_quantity)        as catalog_sales_quantity
from    store_sales
,store_returns
,catalog_sales
,date_dim             d1
,date_dim             d2
,date_dim             d3
,store
,item
where     d1.d_moy               = 4
and d1.d_year              = 1998
and d1.d_date_sk           = ss_sold_date_sk
and i_item_sk              = ss_item_sk
and s_store_sk             = ss_store_sk
and ss_customer_sk         = sr_customer_sk
and ss_item_sk             = sr_item_sk
and ss_ticket_number       = sr_ticket_number
and sr_returned_date_sk    = d2.d_date_sk
and d2.d_moy               between 4 and  4 + 3
and d2.d_year              = 1998
and sr_customer_sk         = cs_bill_customer_sk
and sr_item_sk             = cs_item_sk
and cs_sold_date_sk        = d3.d_date_sk
and d3.d_year              in (1998,1998+1,1998+2)
group by    i_item_id
,i_item_desc
,s_store_id
,s_store_name
order by    i_item_id
,i_item_desc
,s_store_id
,s_store_name
) where rownum <= 100;
Query Plan
===================================================================================
|ID|OPERATOR                                  |NAME         |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                        |             |1       |894         |
|1 |└─EXCHANGE OUT REMOTE                     |             |1       |893         |
|2 |  └─LIMIT                                 |             |1       |890         |
|3 |    └─MERGE GROUP BY                      |             |1       |890         |
|4 |      └─SORT                              |             |1       |890         |
|5 |        └─NESTED-LOOP JOIN                |             |1       |890         |
|6 |          ├─NESTED-LOOP JOIN              |             |1       |875         |
|7 |          │ ├─HASH JOIN                   |             |2       |854         |
|8 |          │ │ ├─HASH JOIN                 |             |2       |850         |
|9 |          │ │ │ ├─TABLE FULL SCAN         |D1           |30      |48          |
|10|          │ │ │ └─NESTED-LOOP JOIN        |             |17      |791         |
|11|          │ │ │   ├─HASH JOIN             |             |19      |493         |
|12|          │ │ │   │ ├─TABLE FULL SCAN     |D2           |125     |53          |
|13|          │ │ │   │ └─MERGE JOIN          |             |211     |380         |
|14|          │ │ │   │   ├─TABLE FULL SCAN   |ITEM         |200     |14          |
|15|          │ │ │   │   └─TABLE FULL SCAN   |STORE_RETURNS|3000    |299         |
|16|          │ │ │   └─DISTRIBUTED TABLE GET |STORE_SALES  |1       |16          |
|17|          │ │ └─TABLE FULL SCAN           |STORE        |12      |3           |
|18|          │ └─DISTRIBUTED TABLE RANGE SCAN|CATALOG_SALES|1       |16          |
|19|          └─DISTRIBUTED TABLE GET         |D3           |1       |16          |
===================================================================================
Outputs & filters:
-------------------------------------
  0 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [T_FUN_MAX(STORE_SALES.SS_QUANTITY)], [T_FUN_MAX(STORE_RETURNS.SR_RETURN_QUANTITY)],
       [T_FUN_MAX(CATALOG_SALES.CS_QUANTITY)]), filter(nil)
  1 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [T_FUN_MAX(STORE_SALES.SS_QUANTITY)], [T_FUN_MAX(STORE_RETURNS.SR_RETURN_QUANTITY)],
       [T_FUN_MAX(CATALOG_SALES.CS_QUANTITY)]), filter(nil)
  2 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [T_FUN_MAX(STORE_SALES.SS_QUANTITY)], [T_FUN_MAX(STORE_RETURNS.SR_RETURN_QUANTITY)],
       [T_FUN_MAX(CATALOG_SALES.CS_QUANTITY)]), filter(nil), rowset=256
      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
  3 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [T_FUN_MAX(STORE_SALES.SS_QUANTITY)], [T_FUN_MAX(STORE_RETURNS.SR_RETURN_QUANTITY)],
       [T_FUN_MAX(CATALOG_SALES.CS_QUANTITY)]), filter(nil), rowset=256
      group([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME]), agg_func([T_FUN_MAX(STORE_SALES.SS_QUANTITY)], [T_FUN_MAX(STORE_RETURNS.SR_RETURN_QUANTITY)],
       [T_FUN_MAX(CATALOG_SALES.CS_QUANTITY)])
  4 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [STORE_RETURNS.SR_RETURN_QUANTITY], [STORE_SALES.SS_QUANTITY],
       [CATALOG_SALES.CS_QUANTITY]), filter(nil), rowset=256
      sort_keys([ITEM.I_ITEM_ID, ASC], [ITEM.I_ITEM_DESC, ASC], [STORE.S_STORE_ID, ASC], [STORE.S_STORE_NAME, ASC])
  5 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [STORE_RETURNS.SR_RETURN_QUANTITY], [STORE_SALES.SS_QUANTITY],
       [CATALOG_SALES.CS_QUANTITY]), filter(nil), rowset=256
      conds(nil), nl_params_([CATALOG_SALES.CS_SOLD_DATE_SK(:24)]), use_batch=true
  6 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [CATALOG_SALES.CS_SOLD_DATE_SK], [STORE_RETURNS.SR_RETURN_QUANTITY],
       [STORE_SALES.SS_QUANTITY], [CATALOG_SALES.CS_QUANTITY]), filter(nil), rowset=256
      conds(nil), nl_params_([STORE_SALES.SS_ITEM_SK(:6)], [STORE_SALES.SS_CUSTOMER_SK(:7)]), use_batch=true
  7 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE.S_STORE_ID], [STORE.S_STORE_NAME], [STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_CUSTOMER_SK], [STORE_RETURNS.SR_RETURN_QUANTITY],
       [STORE_SALES.SS_QUANTITY]), filter(nil), rowset=256
      equal_conds([STORE.S_STORE_SK = STORE_SALES.SS_STORE_SK]), other_conds(nil)
  8 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_CUSTOMER_SK], [STORE_RETURNS.SR_RETURN_QUANTITY], [STORE_SALES.SS_STORE_SK],
       [STORE_SALES.SS_QUANTITY]), filter(nil), rowset=256
      equal_conds([D1.D_DATE_SK = STORE_SALES.SS_SOLD_DATE_SK]), other_conds(nil)
  9 - output([D1.D_DATE_SK]), filter([D1.D_MOY = 4], [D1.D_YEAR = 1998]), rowset=256
      access([D1.D_DATE_SK], [D1.D_MOY], [D1.D_YEAR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([D1.D_DATE_SK]), range(MIN ; MAX)always true
 10 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_CUSTOMER_SK], [STORE_RETURNS.SR_RETURN_QUANTITY], [STORE_SALES.SS_SOLD_DATE_SK],
       [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_QUANTITY]), filter(nil), rowset=256
      conds(nil), nl_params_([STORE_RETURNS.SR_CUSTOMER_SK(:3)], [STORE_RETURNS.SR_ITEM_SK(:4)], [STORE_RETURNS.SR_TICKET_NUMBER(:5)]), use_batch=true
 11 - output([ITEM.I_ITEM_ID], [ITEM.I_ITEM_DESC], [STORE_RETURNS.SR_CUSTOMER_SK], [STORE_RETURNS.SR_ITEM_SK], [STORE_RETURNS.SR_TICKET_NUMBER], [STORE_RETURNS.SR_RETURN_QUANTITY]), filter(nil), rowset=256
      equal_conds([STORE_RETURNS.SR_RETURNED_DATE_SK = D2.D_DATE_SK]), other_conds(nil)
 12 - output([D2.D_DATE_SK]), filter([D2.D_YEAR = 1998], [D2.D_MOY <= 4 + 3], [D2.D_MOY >= 4]), rowset=256
      access([D2.D_DATE_SK], [D2.D_MOY], [D2.D_YEAR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([D2.D_DATE_SK]), range(MIN ; MAX)always true
