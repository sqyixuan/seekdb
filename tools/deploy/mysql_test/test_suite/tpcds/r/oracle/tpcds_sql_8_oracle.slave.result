      / HOUSEHOLD_DEMOGRAPHICS.HD_VEHICLE_COUNT ELSE NULL END > 1], [HOUSEHOLD_DEMOGRAPHICS.HD_BUY_POTENTIAL = '>10000' OR HOUSEHOLD_DEMOGRAPHICS.HD_BUY_POTENTIAL 
      = '5001-10000'], [HOUSEHOLD_DEMOGRAPHICS.HD_VEHICLE_COUNT > 0]), rowset=256
      access([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK], [HOUSEHOLD_DEMOGRAPHICS.HD_BUY_POTENTIAL], [HOUSEHOLD_DEMOGRAPHICS.HD_VEHICLE_COUNT], [HOUSEHOLD_DEMOGRAPHICS.HD_DEP_COUNT]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK]), range(MIN ; MAX)always true
 12 - output([STORE_SALES.SS_TICKET_NUMBER], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_HDEMO_SK], [STORE_SALES.SS_CUSTOMER_SK]), filter(nil), rowset=256
      access([STORE_SALES.SS_TICKET_NUMBER], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_HDEMO_SK], [STORE_SALES.SS_CUSTOMER_SK]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_TICKET_NUMBER]), range(MIN,MIN ; MAX,MAX)always true
 13 - output([CUSTOMER.C_LAST_NAME], [CUSTOMER.C_FIRST_NAME], [CUSTOMER.C_SALUTATION], [CUSTOMER.C_PREFERRED_CUST_FLAG]), filter(nil), rowset=256
      access([GROUP_ID], [CUSTOMER.C_LAST_NAME], [CUSTOMER.C_FIRST_NAME], [CUSTOMER.C_SALUTATION], [CUSTOMER.C_PREFERRED_CUST_FLAG]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CUSTOMER.C_CUSTOMER_SK]), range(MIN ; MAX), 
      range_cond([:6 = CUSTOMER.C_CUSTOMER_SK])
select /*TPC-DS Q79*/c_last_name
,c_first_name
,c_salutation
,c_preferred_cust_flag
,ss_ticket_number
,cnt from   (select ss_ticket_number
,ss_customer_sk
,count(*) cnt
from store_sales,date_dim,store,household_demographics
where store_sales.ss_sold_date_sk = date_dim.d_date_sk
and store_sales.ss_store_sk = store.s_store_sk
and store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk
and date_dim.d_dom between 1 and 2    and (household_demographics.hd_buy_potential = '>10000' or         household_demographics.hd_buy_potential = '5001-10000')
and household_demographics.hd_vehicle_count > 0    and case when household_demographics.hd_vehicle_count > 0 then             household_demographics.hd_dep_count/ household_demographics.hd_vehicle_count else null end > 1    and date_dim.d_year in (1999,1999+1,1999+2)
and store.s_county in ('Williamson County','Williamson County','Williamson County','Williamson County')
group by ss_ticket_number,ss_customer_sk) dj,customer
where ss_customer_sk = c_customer_sk
and cnt between 1 and 5    order by cnt desc, c_last_name asc;
