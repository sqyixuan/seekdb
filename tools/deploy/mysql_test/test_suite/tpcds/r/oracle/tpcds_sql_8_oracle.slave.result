 16 - output([STORE_SALES.SS_EXT_SALES_PRICE], [STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SOLD_TIME_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([STORE_SALES.SS_SOLD_DATE_SK(:11)]), use_batch=true
 17 - output([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_EXT_SALES_PRICE], [STORE_SALES.SS_SOLD_TIME_SK]), filter(nil), rowset=256
