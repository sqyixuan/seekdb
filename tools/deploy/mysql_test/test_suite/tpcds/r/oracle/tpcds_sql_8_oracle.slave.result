result_format: 4
explain_protocol: 2
set global ob_sql_work_area_percentage=100;

set ob_query_timeout = 1000000000;
set ob_trx_timeout=1000000000;
********************** TPC_DS Q70

with v1 as(
select i_category, i_brand,
cc_name,
d_year, d_moy,
sum(cs_sales_price) sum_sales,
avg(sum(cs_sales_price)) over
(partition by i_category, i_brand,
cc_name, d_year)
avg_monthly_sales,
rank() over
(partition by i_category, i_brand,
cc_name
order by d_year, d_moy) rn
from item, catalog_sales, date_dim, call_center
where cs_item_sk = i_item_sk
and cs_sold_date_sk = d_date_sk
and cc_call_center_sk= cs_call_center_sk
and (
d_year = 2000 or
( d_year = 2000-1 and d_moy =12) or
( d_year = 2000+1 and d_moy =1)
)
group by i_category, i_brand,
cc_name , d_year, d_moy),
v2 as(
select v1.i_brand
,v1.d_year, v1.d_moy
,v1.avg_monthly_sales
,v1.sum_sales, v1_lag.sum_sales psum, v1_lead.sum_sales nsum
from v1, v1 v1_lag, v1 v1_lead
where v1.i_category = v1_lag.i_category
and v1.i_category = v1_lead.i_category
and v1.i_brand = v1_lag.i_brand
and v1.i_brand = v1_lead.i_brand
and v1. cc_name = v1_lag. cc_name
and v1. cc_name = v1_lead. cc_name
and v1.rn = v1_lag.rn + 1
and v1.rn = v1_lead.rn - 1)
select /*TPC-DS Q70*/ * from ( select  *
from v2
where  d_year = 2000
and avg_monthly_sales > 0
and case when avg_monthly_sales > 0 then abs(sum_sales - avg_monthly_sales) / avg_monthly_sales else null end > 0.1 order by sum_sales - avg_monthly_sales, 3  ) where rownum <= 100;
+---------+--------+-------+-------------------+-----------+------+------+
| I_BRAND | D_YEAR | D_MOY | AVG_MONTHLY_SALES | SUM_SALES | PSUM | NSUM |
+---------+--------+-------+-------------------+-----------+------+------+
+---------+--------+-------+-------------------+-----------+------+------+


********************** TPC_DS Q71
EXPLAIN select /*TPC-DS Q71*/* from (select   s_store_name,
i_item_desc,
sc.revenue,
i_current_price,
i_wholesale_cost,
i_brand
from store, item,
(select ss_store_sk, avg(revenue) as ave
from       (select  ss_store_sk, ss_item_sk,
sum(ss_sales_price) as revenue
from store_sales, date_dim
where ss_sold_date_sk = d_date_sk and d_month_seq between 1177 and 1177+11      group by ss_store_sk, ss_item_sk) sa
group by ss_store_sk) sb,
(select  ss_store_sk, ss_item_sk, sum(ss_sales_price) as revenue
from store_sales, date_dim
where ss_sold_date_sk = d_date_sk and d_month_seq between 1177 and 1177+11   group by ss_store_sk, ss_item_sk) sc
where sb.ss_store_sk = sc.ss_store_sk
and sc.revenue <= 0.1 * sb.ave
and s_store_sk = sc.ss_store_sk
and i_item_sk = sc.ss_item_sk
order by s_store_name, i_item_desc
) where rownum <= 100;
Query Plan
===========================================================================
|ID|OPERATOR                           |NAME        |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                 |            |0       |911         |
|1 |└─EXCHANGE OUT REMOTE              |            |0       |911         |
|2 |  └─TEMP TABLE TRANSFORMATION      |            |0       |911         |
|3 |    ├─TEMP TABLE INSERT            |TEMP1       |0       |911         |
|4 |    │ └─HASH GROUP BY              |            |0       |911         |
|5 |    │   └─HASH JOIN                |            |0       |911         |
|6 |    │     ├─TABLE FULL SCAN        |DATE_DIM    |0       |36          |
|7 |    │     └─TABLE FULL SCAN        |STORE_SALES |5000    |420         |
|8 |    └─TOP-N SORT                   |            |0       |0           |
|9 |      └─NESTED-LOOP JOIN           |            |0       |0           |
|10|        ├─HASH JOIN                |            |0       |0           |
|11|        │ ├─NESTED-LOOP JOIN       |            |0       |0           |
|12|        │ │ ├─SUBPLAN SCAN         |SB          |0       |0           |
|13|        │ │ │ └─HASH GROUP BY      |            |0       |0           |
|14|        │ │ │   └─TEMP TABLE ACCESS|VIEW3(TEMP1)|0       |0           |
|15|        │ │ └─DISTRIBUTED TABLE GET|STORE       |1       |16          |
|16|        │ └─TEMP TABLE ACCESS      |VIEW2(TEMP1)|0       |0           |
|17|        └─DISTRIBUTED TABLE GET    |ITEM        |1       |16          |
===========================================================================
Outputs & filters:
-------------------------------------
  0 - output([STORE.S_STORE_NAME], [ITEM.I_ITEM_DESC], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil)
  1 - output([STORE.S_STORE_NAME], [ITEM.I_ITEM_DESC], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil)
  2 - output([STORE.S_STORE_NAME], [ITEM.I_ITEM_DESC], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil), rowset=256
  3 - output(nil), filter(nil), rowset=256
  4 - output([T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_ITEM_SK]), filter(nil), rowset=256
      group([STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_ITEM_SK]), agg_func([T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)])
  5 - output([STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SALES_PRICE]), filter(nil), rowset=256
      equal_conds([STORE_SALES.SS_SOLD_DATE_SK = DATE_DIM.D_DATE_SK]), other_conds(nil)
  6 - output([DATE_DIM.D_DATE_SK]), filter([DATE_DIM.D_MONTH_SEQ >= 1177], [DATE_DIM.D_MONTH_SEQ <= 1177 + 11]), rowset=256
      access([DATE_DIM.D_DATE_SK], [DATE_DIM.D_MONTH_SEQ]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX)always true
  7 - output([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_SALES_PRICE]), filter(nil), rowset=256
      access([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_SOLD_DATE_SK], [STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_SALES_PRICE]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([STORE_SALES.SS_ITEM_SK], [STORE_SALES.SS_TICKET_NUMBER]), range(MIN,MIN ; MAX,MAX)always true
  8 - output([STORE.S_STORE_NAME], [ITEM.I_ITEM_DESC], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil), rowset=256
      sort_keys([STORE.S_STORE_NAME, ASC], [ITEM.I_ITEM_DESC, ASC]), topn(cast(FLOOR(100), BIGINT(-1, 0)))
  9 - output([STORE.S_STORE_NAME], [ITEM.I_ITEM_DESC], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil), rowset=256
      conds(nil), nl_params_([VIEW2.STORE_SALES.SS_ITEM_SK(:5)]), use_batch=true
 10 - output([STORE.S_STORE_NAME], [VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [VIEW2.STORE_SALES.SS_ITEM_SK]), filter(nil), rowset=256
      equal_conds([STORE.S_STORE_SK = VIEW2.STORE_SALES.SS_STORE_SK]), other_conds([VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE) <= .1 * SB.AVE])
 11 - output([STORE.S_STORE_NAME], [SB.AVE], [STORE.S_STORE_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([SB.SS_STORE_SK(:3)]), use_batch=true
 12 - output([SB.SS_STORE_SK], [SB.AVE]), filter(nil), rowset=256
      access([SB.SS_STORE_SK], [SB.AVE])
 13 - output([VIEW3.STORE_SALES.SS_STORE_SK], [T_FUN_SUM(VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)) / T_FUN_COUNT(VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE))]), filter(nil), rowset=256
      group([VIEW3.STORE_SALES.SS_STORE_SK]), agg_func([T_FUN_SUM(VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE))], [T_FUN_COUNT(VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE))])
 14 - output([VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [VIEW3.STORE_SALES.SS_STORE_SK]), filter(nil), rowset=256
      access([VIEW3.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [VIEW3.STORE_SALES.SS_STORE_SK])
 15 - output([STORE.S_STORE_SK], [STORE.S_STORE_NAME]), filter(nil), rowset=256
      access([GROUP_ID], [STORE.S_STORE_SK], [STORE.S_STORE_NAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([STORE.S_STORE_SK]), range(MIN ; MAX), 
      range_cond([:3 = STORE.S_STORE_SK])
 16 - output([VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [VIEW2.STORE_SALES.SS_STORE_SK], [VIEW2.STORE_SALES.SS_ITEM_SK]), filter(nil), rowset=256
      access([VIEW2.T_FUN_SUM(STORE_SALES.SS_SALES_PRICE)], [VIEW2.STORE_SALES.SS_STORE_SK], [VIEW2.STORE_SALES.SS_ITEM_SK])
 17 - output([ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), filter(nil), rowset=256
      access([GROUP_ID], [ITEM.I_ITEM_DESC], [ITEM.I_CURRENT_PRICE], [ITEM.I_WHOLESALE_COST], [ITEM.I_BRAND]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([ITEM.I_ITEM_SK]), range(MIN ; MAX), 
      range_cond([ITEM.I_ITEM_SK = :5])
select /*TPC-DS Q71*/* from (select   s_store_name,
i_item_desc,
sc.revenue,
i_current_price,
i_wholesale_cost,
i_brand
from store, item,
(select ss_store_sk, avg(revenue) as ave
from       (select  ss_store_sk, ss_item_sk,
sum(ss_sales_price) as revenue
from store_sales, date_dim
where ss_sold_date_sk = d_date_sk and d_month_seq between 1177 and 1177+11      group by ss_store_sk, ss_item_sk) sa
group by ss_store_sk) sb,
(select  ss_store_sk, ss_item_sk, sum(ss_sales_price) as revenue
from store_sales, date_dim
where ss_sold_date_sk = d_date_sk and d_month_seq between 1177 and 1177+11   group by ss_store_sk, ss_item_sk) sc
where sb.ss_store_sk = sc.ss_store_sk
and sc.revenue <= 0.1 * sb.ave
and s_store_sk = sc.ss_store_sk
and i_item_sk = sc.ss_item_sk
order by s_store_name, i_item_desc
) where rownum <= 100;
+--------------+-------------+---------+-----------------+------------------+---------+
| S_STORE_NAME | I_ITEM_DESC | REVENUE | I_CURRENT_PRICE | I_WHOLESALE_COST | I_BRAND |
+--------------+-------------+---------+-----------------+------------------+---------+
+--------------+-------------+---------+-----------------+------------------+---------+


********************** TPC_DS Q72
EXPLAIN select /*TPC-DS Q72*/ i_brand_id brand_id, i_brand brand,t_hour,t_minute,
sum(ext_price) ext_price
from item, (select ws_ext_sales_price as ext_price,
ws_sold_date_sk as sold_date_sk,
ws_item_sk as sold_item_sk,
ws_sold_time_sk as time_sk
from web_sales,date_dim
where d_date_sk = ws_sold_date_sk
and d_moy=11 and d_year=1998 union all  select cs_ext_sales_price as ext_price,
cs_sold_date_sk as sold_date_sk,
cs_item_sk as sold_item_sk,
cs_sold_time_sk as time_sk
from catalog_sales,date_dim
where d_date_sk = cs_sold_date_sk
and d_moy=11 and d_year=1998 union all select ss_ext_sales_price as ext_price,
ss_sold_date_sk as sold_date_sk,
ss_item_sk as sold_item_sk,
ss_sold_time_sk as time_sk
from store_sales,date_dim
where d_date_sk = ss_sold_date_sk
and d_moy=11 and d_year=1998) tmp,time_dim
where   sold_item_sk = i_item_sk
and i_manager_id=1   and time_sk = t_time_sk
and (t_meal_time = 'breakfast' or t_meal_time = 'dinner')
group by i_brand, i_brand_id,t_hour,t_minute
order by ext_price desc, i_brand_id;
Query Plan
=======================================================================================
|ID|OPERATOR                                      |NAME         |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                            |             |1       |333         |
|1 |└─EXCHANGE OUT REMOTE                         |             |1       |333         |
|2 |  └─SORT                                      |             |1       |333         |
|3 |    └─HASH GROUP BY                           |             |1       |333         |
|4 |      └─HASH JOIN                             |             |1       |333         |
|5 |        ├─TABLE FULL SCAN                     |TIME_DIM     |2       |25          |
|6 |        └─NESTED-LOOP JOIN                    |             |4       |308         |
|7 |          ├─TABLE FULL SCAN                   |ITEM         |3       |13          |
|8 |          └─SUBPLAN SCAN                      |TMP          |4       |155         |
|9 |            └─UNION ALL                       |             |4       |155         |
|10|              ├─NESTED-LOOP JOIN              |             |2       |51          |
|11|              │ ├─DISTRIBUTED TABLE RANGE SCAN|WEB_SALES    |2       |18          |
|12|              │ └─DISTRIBUTED TABLE GET       |DATE_DIM     |1       |16          |
|13|              ├─NESTED-LOOP JOIN              |             |2       |53          |
|14|              │ ├─DISTRIBUTED TABLE RANGE SCAN|CATALOG_SALES|2       |19          |
|15|              │ └─DISTRIBUTED TABLE GET       |DATE_DIM     |1       |16          |
|16|              └─NESTED-LOOP JOIN              |             |2       |52          |
|17|                ├─DISTRIBUTED TABLE RANGE SCAN|STORE_SALES  |2       |19          |
|18|                └─DISTRIBUTED TABLE GET       |DATE_DIM     |1       |16          |
=======================================================================================
Outputs & filters:
-------------------------------------
  0 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE], [T_FUN_SUM(TMP.EXT_PRICE)]), filter(nil)
  1 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE], [T_FUN_SUM(TMP.EXT_PRICE)]), filter(nil)
  2 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE], [T_FUN_SUM(TMP.EXT_PRICE)]), filter(nil), rowset=256
      sort_keys([T_FUN_SUM(TMP.EXT_PRICE), DESC], [ITEM.I_BRAND_ID, ASC])
  3 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE], [T_FUN_SUM(TMP.EXT_PRICE)]), filter(nil), rowset=256
      group([ITEM.I_BRAND], [ITEM.I_BRAND_ID], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE]), agg_func([T_FUN_SUM(TMP.EXT_PRICE)])
  4 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE], [TMP.EXT_PRICE]), filter(nil), rowset=256
      equal_conds([TMP.TIME_SK = TIME_DIM.T_TIME_SK]), other_conds(nil)
  5 - output([TIME_DIM.T_TIME_SK], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE]), filter([TIME_DIM.T_MEAL_TIME = 'breakfast' OR TIME_DIM.T_MEAL_TIME = 'dinner']), rowset=256
      access([TIME_DIM.T_TIME_SK], [TIME_DIM.T_MEAL_TIME], [TIME_DIM.T_HOUR], [TIME_DIM.T_MINUTE]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([TIME_DIM.T_TIME_SK]), range(MIN ; MAX)always true
  6 - output([ITEM.I_BRAND_ID], [ITEM.I_BRAND], [TMP.EXT_PRICE], [TMP.TIME_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([ITEM.I_ITEM_SK(:6)]), use_batch=true
  7 - output([ITEM.I_ITEM_SK], [ITEM.I_BRAND], [ITEM.I_BRAND_ID]), filter([ITEM.I_MANAGER_ID = 1]), rowset=256
      access([ITEM.I_ITEM_SK], [ITEM.I_MANAGER_ID], [ITEM.I_BRAND], [ITEM.I_BRAND_ID]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([ITEM.I_ITEM_SK]), range(MIN ; MAX)always true
  8 - output([TMP.EXT_PRICE], [TMP.TIME_SK]), filter(nil), rowset=256
      access([TMP.EXT_PRICE], [TMP.TIME_SK])
  9 - output([UNION([1])], [UNION([2])], [UNION([3])]), filter(nil), rowset=256
 10 - output([WEB_SALES.WS_EXT_SALES_PRICE], [WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_SOLD_TIME_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([WEB_SALES.WS_SOLD_DATE_SK(:7)]), use_batch=true
 11 - output([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_SOLD_DATE_SK], [WEB_SALES.WS_EXT_SALES_PRICE], [WEB_SALES.WS_SOLD_TIME_SK]), filter(nil), rowset=256
      access([GROUP_ID], [WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_SOLD_DATE_SK], [WEB_SALES.WS_EXT_SALES_PRICE], [WEB_SALES.WS_SOLD_TIME_SK]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_ORDER_NUMBER]), range(MIN,MIN ; MAX,MAX)always true, 
      range_cond([WEB_SALES.WS_ITEM_SK = :6])
 12 - output(nil), filter([DATE_DIM.D_MOY = 11], [DATE_DIM.D_YEAR = 1998]), rowset=256
      access([GROUP_ID], [DATE_DIM.D_MOY], [DATE_DIM.D_YEAR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX), 
      range_cond([DATE_DIM.D_DATE_SK = :7])
 13 - output([CATALOG_SALES.CS_EXT_SALES_PRICE], [CATALOG_SALES.CS_ITEM_SK], [CATALOG_SALES.CS_SOLD_TIME_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([CATALOG_SALES.CS_SOLD_DATE_SK(:9)]), use_batch=true
 14 - output([CATALOG_SALES.CS_ITEM_SK], [CATALOG_SALES.CS_SOLD_DATE_SK], [CATALOG_SALES.CS_EXT_SALES_PRICE], [CATALOG_SALES.CS_SOLD_TIME_SK]), filter(nil), rowset=256
      access([GROUP_ID], [CATALOG_SALES.CS_ITEM_SK], [CATALOG_SALES.CS_SOLD_DATE_SK], [CATALOG_SALES.CS_EXT_SALES_PRICE], [CATALOG_SALES.CS_SOLD_TIME_SK]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CATALOG_SALES.CS_ITEM_SK], [CATALOG_SALES.CS_ORDER_NUMBER]), range(MIN,MIN ; MAX,MAX)always true, 
      range_cond([CATALOG_SALES.CS_ITEM_SK = :6])
 15 - output(nil), filter([DATE_DIM.D_MOY = 11], [DATE_DIM.D_YEAR = 1998]), rowset=256
      access([GROUP_ID], [DATE_DIM.D_MOY], [DATE_DIM.D_YEAR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
