       [T_FUN_SUM(STORE_SALES.SS_LIST_PRICE) / T_FUN_COUNT(STORE_SALES.SS_LIST_PRICE)], [T_FUN_SUM(STORE_SALES.SS_COUPON_AMT) / T_FUN_COUNT(STORE_SALES.SS_COUPON_AMT)],
