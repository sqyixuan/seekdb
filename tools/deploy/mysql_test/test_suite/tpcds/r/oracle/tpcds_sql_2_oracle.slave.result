result_format: 4
explain_protocol: 2
set global ob_sql_work_area_percentage=100;

set ob_query_timeout = 1000000000;
set ob_trx_timeout=1000000000;
********************** TPC_DS Q10
with ws as  (select d_year AS ws_sold_year, ws_item_sk,
ws_bill_customer_sk ws_customer_sk,
sum(ws_quantity) ws_qty,
sum(ws_wholesale_cost) ws_wc,
sum(ws_sales_price) ws_sp
from web_sales
left join web_returns on wr_order_number=ws_order_number and ws_item_sk=wr_item_sk
join date_dim on ws_sold_date_sk = d_date_sk
where wr_order_number is null   group by d_year, ws_item_sk, ws_bill_customer_sk
),
cs as  (select d_year AS cs_sold_year, cs_item_sk,
cs_bill_customer_sk cs_customer_sk,
sum(cs_quantity) cs_qty,
sum(cs_wholesale_cost) cs_wc,
sum(cs_sales_price) cs_sp
from catalog_sales
left join catalog_returns on cr_order_number=cs_order_number and cs_item_sk=cr_item_sk
join date_dim on cs_sold_date_sk = d_date_sk
where cr_order_number is null   group by d_year, cs_item_sk, cs_bill_customer_sk
),
ss as  (select d_year AS ss_sold_year, ss_item_sk,
ss_customer_sk,
sum(ss_quantity) ss_qty,
sum(ss_wholesale_cost) ss_wc,
sum(ss_sales_price) ss_sp
from store_sales
left join store_returns on sr_ticket_number=ss_ticket_number and ss_item_sk=sr_item_sk
join date_dim on ss_sold_date_sk = d_date_sk
where sr_ticket_number is null   group by d_year, ss_item_sk, ss_customer_sk
)
select /*TPC-DS Q10*/* from ( select ss_customer_sk,
round(ss_qty/(coalesce(ws_qty,0)+coalesce(cs_qty,0)),2) ratio,
ss_qty store_qty, ss_wc store_wholesale_cost, ss_sp store_sales_price,
coalesce(ws_qty,0)+coalesce(cs_qty,0) other_chan_qty,
coalesce(ws_wc,0)+coalesce(cs_wc,0) other_chan_wholesale_cost,
coalesce(ws_sp,0)+coalesce(cs_sp,0) other_chan_sales_price
from ss
left join ws on (ws_sold_year=ss_sold_year and ws_item_sk=ss_item_sk and ws_customer_sk=ss_customer_sk)
left join cs on (cs_sold_year=ss_sold_year and cs_item_sk=ss_item_sk and cs_customer_sk=ss_customer_sk)
where (coalesce(ws_qty,0)>0 or coalesce(cs_qty, 0)>0) and ss_sold_year=2001order by  ss_customer_sk,
ss_qty desc, ss_wc desc, ss_sp desc,
other_chan_qty,
other_chan_wholesale_cost,
other_chan_sales_price,
ratio
) where rownum <= 100;
+----------------+-------+-----------+----------------------+-------------------+----------------+---------------------------+------------------------+
| SS_CUSTOMER_SK | RATIO | STORE_QTY | STORE_WHOLESALE_COST | STORE_SALES_PRICE | OTHER_CHAN_QTY | OTHER_CHAN_WHOLESALE_COST | OTHER_CHAN_SALES_PRICE |
+----------------+-------+-----------+----------------------+-------------------+----------------+---------------------------+------------------------+
+----------------+-------+-----------+----------------------+-------------------+----------------+---------------------------+------------------------+


********************** TPC_DS Q11
EXPLAIN select /*TPC-DS Q11*/* from (select sum(ws_net_paid) as total_sum
,i_category
,i_class
,grouping(i_category)+grouping(i_class) as lochierarchy
,rank() over (
partition by grouping(i_category)+grouping(i_class),
case when grouping(i_class) = 0 then i_category end order by sum(ws_net_paid) desc) as rank_within_parent
from web_sales
,date_dim d1
,item
where d1.d_month_seq between 1205 and 1205+11 and d1.d_date_sk = ws_sold_date_sk
and i_item_sk  = ws_item_sk
group by rollup(i_category,i_class)
order by lochierarchy desc,
case when lochierarchy = 0 then i_category end,
rank_within_parent
) where rownum <= 100;
Query Plan
======================================================================
|ID|OPERATOR                         |NAME     |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE               |         |0       |382         |
|1 |└─EXCHANGE OUT REMOTE            |         |0       |382         |
|2 |  └─TOP-N SORT                   |         |0       |382         |
|3 |    └─WINDOW FUNCTION            |         |0       |382         |
|4 |      └─SORT                     |         |0       |382         |
|5 |        └─MERGE GROUP BY         |         |0       |382         |
|6 |          └─SORT                 |         |0       |382         |
|7 |            └─HASH JOIN          |         |0       |382         |
|8 |              ├─TABLE FULL SCAN  |D1       |0       |36          |
|9 |              └─MERGE JOIN       |         |212     |328         |
|10|                ├─TABLE FULL SCAN|ITEM     |200     |16          |
|11|                └─TABLE FULL SCAN|WEB_SALES|3500    |253         |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [T_WIN_FUN_RANK()]), filter(nil)
  1 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [T_WIN_FUN_RANK()]), filter(nil)
  2 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [T_WIN_FUN_RANK()]), filter(nil), rowset=256
      sort_keys([T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS), DESC], [CASE WHEN T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS) 
      = 0 THEN ITEM.I_CATEGORY ELSE NULL END, ASC], [T_WIN_FUN_RANK(), ASC]), topn(cast(FLOOR(100), BIGINT(-1, 0))), prefix_pos(1)
  3 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [T_WIN_FUN_RANK()],
       [CASE WHEN T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS) = 0 THEN ITEM.I_CATEGORY ELSE NULL END]), filter(nil), rowset=256
      win_expr(T_WIN_FUN_RANK()), partition_by([T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) 
      = 0 THEN ITEM.I_CATEGORY ELSE NULL END]), order_by([T_FUN_SUM(WEB_SALES.WS_NET_PAID), DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  4 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY)], [T_FUN_GROUPING(ITEM.I_CLASS)], [T_FUN_GROUPING(ITEM.I_CATEGORY) 
      + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) = 0 THEN ITEM.I_CATEGORY ELSE NULL END]), filter(nil), rowset=256
      sort_keys([T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS), DESC], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) = 0 THEN ITEM.I_CATEGORY 
      ELSE NULL END, ASC], [T_FUN_SUM(WEB_SALES.WS_NET_PAID), DESC])
  5 - output([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [ITEM.I_CATEGORY], [ITEM.I_CLASS], [T_FUN_GROUPING(ITEM.I_CATEGORY)], [T_FUN_GROUPING(ITEM.I_CLASS)], [T_FUN_GROUPING(ITEM.I_CATEGORY) 
      + T_FUN_GROUPING(ITEM.I_CLASS)], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) = 0 THEN ITEM.I_CATEGORY ELSE NULL END]), filter(nil), rowset=256
      group(nil), rollup([ITEM.I_CATEGORY], [ITEM.I_CLASS]), agg_func([T_FUN_SUM(WEB_SALES.WS_NET_PAID)], [T_FUN_GROUPING(ITEM.I_CATEGORY)], [T_FUN_GROUPING(ITEM.I_CLASS)])
  6 - output([ITEM.I_CATEGORY], [ITEM.I_CLASS], [WEB_SALES.WS_NET_PAID]), filter(nil), rowset=256
      sort_keys([ITEM.I_CATEGORY, ASC], [ITEM.I_CLASS, ASC])
  7 - output([ITEM.I_CATEGORY], [ITEM.I_CLASS], [WEB_SALES.WS_NET_PAID]), filter(nil), rowset=256
      equal_conds([D1.D_DATE_SK = WEB_SALES.WS_SOLD_DATE_SK]), other_conds(nil)
  8 - output([D1.D_DATE_SK]), filter([D1.D_MONTH_SEQ >= 1205], [D1.D_MONTH_SEQ <= 1205 + 11]), rowset=256
      access([D1.D_DATE_SK], [D1.D_MONTH_SEQ]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([D1.D_DATE_SK]), range(MIN ; MAX)always true
  9 - output([ITEM.I_CATEGORY], [ITEM.I_CLASS], [WEB_SALES.WS_SOLD_DATE_SK], [WEB_SALES.WS_NET_PAID]), filter(nil), rowset=256
      equal_conds([ITEM.I_ITEM_SK = WEB_SALES.WS_ITEM_SK]), other_conds(nil)
      merge_directions([ASC])
 10 - output([ITEM.I_ITEM_SK], [ITEM.I_CATEGORY], [ITEM.I_CLASS]), filter(nil), rowset=256
      access([ITEM.I_ITEM_SK], [ITEM.I_CATEGORY], [ITEM.I_CLASS]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([ITEM.I_ITEM_SK]), range(MIN ; MAX)always true
 11 - output([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_SOLD_DATE_SK], [WEB_SALES.WS_NET_PAID]), filter(nil), rowset=256
      access([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_SOLD_DATE_SK], [WEB_SALES.WS_NET_PAID]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_ORDER_NUMBER]), range(MIN,MIN ; MAX,MAX)always true
select /*TPC-DS Q11*/* from (select sum(ws_net_paid) as total_sum
,i_category
,i_class
,grouping(i_category)+grouping(i_class) as lochierarchy
,rank() over (
partition by grouping(i_category)+grouping(i_class),
case when grouping(i_class) = 0 then i_category end order by sum(ws_net_paid) desc) as rank_within_parent
from web_sales
,date_dim d1
,item
where d1.d_month_seq between 1205 and 1205+11 and d1.d_date_sk = ws_sold_date_sk
and i_item_sk  = ws_item_sk
group by rollup(i_category,i_class)
order by lochierarchy desc,
case when lochierarchy = 0 then i_category end,
rank_within_parent
) where rownum <= 100;
+-----------+------------+---------+--------------+--------------------+
| TOTAL_SUM | I_CATEGORY | I_CLASS | LOCHIERARCHY | RANK_WITHIN_PARENT |
+-----------+------------+---------+--------------+--------------------+
+-----------+------------+---------+--------------+--------------------+


********************** TPC_DS Q12

with customer_total_return as(select sr_customer_sk as ctr_customer_sk
,sr_store_sk as ctr_store_sk
,sum(SR_RETURN_AMT_INC_TAX) as ctr_total_return
from store_returns
,date_dim
where sr_returned_date_sk = d_date_sk
and d_year =1999 group by sr_customer_sk
,sr_store_sk)
select /*TPC-DS Q12*/* from ( select  c_customer_id
from customer_total_return ctr1
,store
,customer
where ctr1.ctr_total_return > (select avg(ctr_total_return)*1.2 from customer_total_return ctr2
where ctr1.ctr_store_sk = ctr2.ctr_store_sk)
and s_store_sk = ctr1.ctr_store_sk
and s_state = 'TN' and ctr1.ctr_customer_sk = c_customer_sk
order by c_customer_id
) where rownum <= 100;
+---------------+
| C_CUSTOMER_ID |
+---------------+
+---------------+


********************** TPC_DS Q13
EXPLAIN select /*TPC-DS Q13*/ cc_call_center_id Call_Center,
cc_name Call_Center_Name,
cc_manager Manager,
sum(cr_net_loss) Returns_Loss
from        call_center,
catalog_returns,
date_dim,
customer,
customer_address,
customer_demographics,
household_demographics
where   cr_call_center_sk       = cc_call_center_sk
and     cr_returned_date_sk     = d_date_sk
and     cr_returning_customer_sk= c_customer_sk
and     cd_demo_sk              = c_current_cdemo_sk
and     hd_demo_sk              = c_current_hdemo_sk
and     ca_address_sk           = c_current_addr_sk
and     d_year                  = 2002
and     d_moy                   = 11
and     ( (cd_marital_status       = 'M' and cd_education_status     = 'Unknown')
or(cd_marital_status       = 'W' and cd_education_status     = 'Advanced Degree'))
and     hd_buy_potential like 'Unknown%'and     ca_gmt_offset           = -6 group by cc_call_center_id,cc_name,cc_manager,cd_marital_status,cd_education_status
order by sum(cr_net_loss) desc;
Query Plan
=======================================================================================
|ID|OPERATOR                             |NAME                  |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                   |                      |1       |562         |
|1 |└─EXCHANGE OUT REMOTE                |                      |1       |562         |
|2 |  └─SORT                             |                      |1       |561         |
|3 |    └─HASH GROUP BY                  |                      |1       |561         |
|4 |      └─NESTED-LOOP JOIN             |                      |1       |561         |
|5 |        ├─NESTED-LOOP JOIN           |                      |1       |556         |
|6 |        │ ├─HASH JOIN                |                      |3       |510         |
|7 |        │ │ ├─HASH JOIN              |                      |3       |507         |
|8 |        │ │ │ ├─MERGE JOIN           |                      |3       |239         |
|9 |        │ │ │ │ ├─TABLE FULL SCAN    |CUSTOMER_ADDRESS      |82      |28          |
|10|        │ │ │ │ └─SORT               |                      |37      |204         |
|11|        │ │ │ │   └─HASH JOIN        |                      |37      |196         |
|12|        │ │ │ │     ├─TABLE FULL SCAN|HOUSEHOLD_DEMOGRAPHICS|34      |13          |
|13|        │ │ │ │     └─TABLE FULL SCAN|CUSTOMER              |1000    |84          |
|14|        │ │ │ └─TABLE FULL SCAN      |CATALOG_RETURNS       |1500    |130         |
|15|        │ │ └─TABLE FULL SCAN        |CALL_CENTER           |6       |3           |
|16|        │ └─DISTRIBUTED TABLE GET    |DATE_DIM              |1       |16          |
|17|        └─DISTRIBUTED TABLE GET      |CUSTOMER_DEMOGRAPHICS |1       |16          |
=======================================================================================
Outputs & filters:
-------------------------------------
  0 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS)]), filter(nil)
  1 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS)]), filter(nil)
  2 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS)]), filter(nil), rowset=256
      sort_keys([T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS), DESC])
  3 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS)]), filter(nil), rowset=256
      group([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS], [CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS]),
       agg_func([T_FUN_SUM(CATALOG_RETURNS.CR_NET_LOSS)])
  4 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS], [CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS],
       [CATALOG_RETURNS.CR_NET_LOSS]), filter(nil), rowset=256
      conds(nil), nl_params_([CUSTOMER.C_CURRENT_CDEMO_SK(:8)]), use_batch=true
  5 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [CUSTOMER.C_CURRENT_CDEMO_SK], [CATALOG_RETURNS.CR_NET_LOSS]), filter(nil), rowset=256
      conds(nil), nl_params_([CATALOG_RETURNS.CR_RETURNED_DATE_SK(:2)]), use_batch=true
  6 - output([CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER], [CUSTOMER.C_CURRENT_CDEMO_SK], [CATALOG_RETURNS.CR_RETURNED_DATE_SK],
       [CATALOG_RETURNS.CR_NET_LOSS]), filter(nil), rowset=256
      equal_conds([CATALOG_RETURNS.CR_CALL_CENTER_SK = CALL_CENTER.CC_CALL_CENTER_SK]), other_conds(nil)
  7 - output([CUSTOMER.C_CURRENT_CDEMO_SK], [CATALOG_RETURNS.CR_RETURNED_DATE_SK], [CATALOG_RETURNS.CR_CALL_CENTER_SK], [CATALOG_RETURNS.CR_NET_LOSS]), filter(nil), rowset=256
      equal_conds([CATALOG_RETURNS.CR_RETURNING_CUSTOMER_SK = CUSTOMER.C_CUSTOMER_SK]), other_conds(nil)
  8 - output([CUSTOMER.C_CURRENT_CDEMO_SK], [CUSTOMER.C_CUSTOMER_SK]), filter(nil), rowset=256
      equal_conds([CUSTOMER_ADDRESS.CA_ADDRESS_SK = CUSTOMER.C_CURRENT_ADDR_SK]), other_conds(nil)
      merge_directions([ASC])
  9 - output([CUSTOMER_ADDRESS.CA_ADDRESS_SK]), filter([CUSTOMER_ADDRESS.CA_GMT_OFFSET = (T_OP_NEG, 6)]), rowset=256
      access([CUSTOMER_ADDRESS.CA_ADDRESS_SK], [CUSTOMER_ADDRESS.CA_GMT_OFFSET]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([CUSTOMER_ADDRESS.CA_ADDRESS_SK]), range(MIN ; MAX)always true
 10 - output([CUSTOMER.C_CURRENT_CDEMO_SK], [CUSTOMER.C_CURRENT_ADDR_SK], [CUSTOMER.C_CUSTOMER_SK]), filter(nil), rowset=256
      sort_keys([CUSTOMER.C_CURRENT_ADDR_SK, ASC])
 11 - output([CUSTOMER.C_CURRENT_CDEMO_SK], [CUSTOMER.C_CURRENT_ADDR_SK], [CUSTOMER.C_CUSTOMER_SK]), filter(nil), rowset=256
      equal_conds([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK = CUSTOMER.C_CURRENT_HDEMO_SK]), other_conds(nil)
 12 - output([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK]), filter([(T_OP_LIKE, HOUSEHOLD_DEMOGRAPHICS.HD_BUY_POTENTIAL, cast(replace(cast('Unknown%', VARCHAR2(8 
      BYTE)), '\', '\\'), CHAR(16 BYTE)), '\')]), rowset=256
      access([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK], [HOUSEHOLD_DEMOGRAPHICS.HD_BUY_POTENTIAL]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK]), range(MIN ; MAX)always true
 13 - output([CUSTOMER.C_CUSTOMER_SK], [CUSTOMER.C_CURRENT_CDEMO_SK], [CUSTOMER.C_CURRENT_HDEMO_SK], [CUSTOMER.C_CURRENT_ADDR_SK]), filter(nil), rowset=256
      access([CUSTOMER.C_CUSTOMER_SK], [CUSTOMER.C_CURRENT_CDEMO_SK], [CUSTOMER.C_CURRENT_HDEMO_SK], [CUSTOMER.C_CURRENT_ADDR_SK]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CUSTOMER.C_CUSTOMER_SK]), range(MIN ; MAX)always true
 14 - output([CATALOG_RETURNS.CR_CALL_CENTER_SK], [CATALOG_RETURNS.CR_RETURNED_DATE_SK], [CATALOG_RETURNS.CR_RETURNING_CUSTOMER_SK], [CATALOG_RETURNS.CR_NET_LOSS]), filter(nil), rowset=256
      access([CATALOG_RETURNS.CR_CALL_CENTER_SK], [CATALOG_RETURNS.CR_RETURNED_DATE_SK], [CATALOG_RETURNS.CR_RETURNING_CUSTOMER_SK], [CATALOG_RETURNS.CR_NET_LOSS]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CATALOG_RETURNS.CR_ITEM_SK], [CATALOG_RETURNS.CR_ORDER_NUMBER]), range(MIN,MIN ; MAX,MAX)always true
 15 - output([CALL_CENTER.CC_CALL_CENTER_SK], [CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER]), filter(nil), rowset=256
      access([CALL_CENTER.CC_CALL_CENTER_SK], [CALL_CENTER.CC_CALL_CENTER_ID], [CALL_CENTER.CC_NAME], [CALL_CENTER.CC_MANAGER]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([CALL_CENTER.CC_CALL_CENTER_SK]), range(MIN ; MAX)always true
 16 - output(nil), filter([DATE_DIM.D_MOY = 11], [DATE_DIM.D_YEAR = 2002]), rowset=256
      access([GROUP_ID], [DATE_DIM.D_YEAR], [DATE_DIM.D_MOY]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX), 
      range_cond([:2 = DATE_DIM.D_DATE_SK])
 17 - output([CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS], [CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS]), filter([CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS = 
      'M' AND CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS = 'Unknown' OR CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS = 'W' AND CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS 
      = 'Advanced Degree']), rowset=256
      access([GROUP_ID], [CUSTOMER_DEMOGRAPHICS.CD_MARITAL_STATUS], [CUSTOMER_DEMOGRAPHICS.CD_EDUCATION_STATUS]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([CUSTOMER_DEMOGRAPHICS.CD_DEMO_SK]), range(MIN ; MAX), 
      range_cond([CUSTOMER_DEMOGRAPHICS.CD_DEMO_SK = :8])
select /*TPC-DS Q13*/ cc_call_center_id Call_Center,
cc_name Call_Center_Name,
cc_manager Manager,
sum(cr_net_loss) Returns_Loss
from        call_center,
catalog_returns,
date_dim,
customer,
customer_address,
customer_demographics,
household_demographics
where   cr_call_center_sk       = cc_call_center_sk
and     cr_returned_date_sk     = d_date_sk
and     cr_returning_customer_sk= c_customer_sk
and     cd_demo_sk              = c_current_cdemo_sk
and     hd_demo_sk              = c_current_hdemo_sk
and     ca_address_sk           = c_current_addr_sk
and     d_year                  = 2002
and     d_moy                   = 11
and     ( (cd_marital_status       = 'M' and cd_education_status     = 'Unknown')
or(cd_marital_status       = 'W' and cd_education_status     = 'Advanced Degree'))
and     hd_buy_potential like 'Unknown%'and     ca_gmt_offset           = -6 group by cc_call_center_id,cc_name,cc_manager,cd_marital_status,cd_education_status
order by sum(cr_net_loss) desc;
+-------------+------------------+---------+--------------+
| CALL_CENTER | CALL_CENTER_NAME | MANAGER | RETURNS_LOSS |
+-------------+------------------+---------+--------------+
+-------------+------------------+---------+--------------+


********************** TPC_DS Q14
EXPLAIN select /*TPC-DS Q14*/* from (select  *
from(select w_warehouse_name
,i_item_id
,sum(case when (cast(d_date as date) < cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_before
,sum(case when (cast(d_date as date) >= cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_after
from inventory
,warehouse
,item
,date_dim
where i_current_price between 0.99 and 1.49
and i_item_sk          = inv_item_sk
and inv_warehouse_sk   = w_warehouse_sk
and inv_date_sk    = d_date_sk
and d_date between (cast ('2000-04-19' as date))
and (cast ('2000-06-18' as date))
group by w_warehouse_name, i_item_id) x
where (case when inv_before > 0  then inv_after / inv_before
else null end) between 2.0/3.0 and 3.0/2.0 order by w_warehouse_name
,i_item_id
) where rownum <= 100;
Query Plan
=================================================================================
|ID|OPERATOR                                    |NAME     |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                          |         |0       |689         |
|1 |└─EXCHANGE OUT REMOTE                       |         |0       |689         |
|2 |  └─LIMIT                                   |         |0       |689         |
|3 |    └─MERGE GROUP BY                        |         |0       |689         |
|4 |      └─SORT                                |         |0       |689         |
|5 |        └─NESTED-LOOP JOIN                  |         |0       |689         |
|6 |          ├─NESTED-LOOP JOIN                |         |0       |673         |
|7 |          │ ├─NESTED-LOOP JOIN              |         |0       |658         |
|8 |          │ │ ├─TABLE FULL SCAN             |DATE_DIM |0       |31          |
|9 |          │ │ └─DISTRIBUTED TABLE RANGE SCAN|INVENTORY|8000    |627         |
|10|          │ └─DISTRIBUTED TABLE GET         |WAREHOUSE|1       |16          |
|11|          └─DISTRIBUTED TABLE GET           |ITEM     |1       |16          |
=================================================================================
Outputs & filters:
-------------------------------------
  0 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND 
      ELSE 0 END)]), filter(nil)
  1 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND 
      ELSE 0 END)]), filter(nil)
  2 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND 
      ELSE 0 END)]), filter(nil), rowset=256
      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
  3 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND 
      ELSE 0 END)]), f
      ilter([CASE WHEN T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) 
      > 0 THEN T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) / T_FUN_SUM(CASE 
      WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) ELSE NULL END >= 2 / 3], [CASE WHEN 
      T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) > 0 THEN T_FUN_SUM(CASE 
      WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) / T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE,
       DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END) ELSE NULL END <= 3 / 2]), rowset=256
      group([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID]), agg_func([T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) < cast('2000-05-19', DATE(0,
       0)) THEN INVENTORY.INV_QUANTITY_ON_HAND ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(DATE_DIM.D_DATE, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN INVENTORY.INV_QUANTITY_ON_HAND 
      ELSE 0 END)])
  4 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [DATE_DIM.D_DATE], [INVENTORY.INV_QUANTITY_ON_HAND]), filter(nil), rowset=256
      sort_keys([WAREHOUSE.W_WAREHOUSE_NAME, ASC], [ITEM.I_ITEM_ID, ASC])
  5 - output([WAREHOUSE.W_WAREHOUSE_NAME], [ITEM.I_ITEM_ID], [DATE_DIM.D_DATE], [INVENTORY.INV_QUANTITY_ON_HAND]), filter(nil), rowset=256
      conds(nil), nl_params_([INVENTORY.INV_ITEM_SK(:2)]), use_batch=true
  6 - output([WAREHOUSE.W_WAREHOUSE_NAME], [DATE_DIM.D_DATE], [INVENTORY.INV_QUANTITY_ON_HAND], [INVENTORY.INV_ITEM_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([INVENTORY.INV_WAREHOUSE_SK(:0)]), use_batch=true
  7 - output([DATE_DIM.D_DATE], [INVENTORY.INV_QUANTITY_ON_HAND], [INVENTORY.INV_ITEM_SK], [INVENTORY.INV_WAREHOUSE_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([DATE_DIM.D_DATE_SK(:5)]), use_batch=true
  8 - output([DATE_DIM.D_DATE_SK], [DATE_DIM.D_DATE]), filter([DATE_DIM.D_DATE >= cast('2000-04-19', DATE(0, 0))], [DATE_DIM.D_DATE <= cast('2000-06-18',
       DATE(0, 0))]), rowset=256
      access([DATE_DIM.D_DATE_SK], [DATE_DIM.D_DATE]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([DATE_DIM.D_DATE_SK]), range(MIN ; MAX)always true
  9 - output([INVENTORY.INV_ITEM_SK], [INVENTORY.INV_WAREHOUSE_SK], [INVENTORY.INV_QUANTITY_ON_HAND]), filter(nil), rowset=256
      access([GROUP_ID], [INVENTORY.INV_ITEM_SK], [INVENTORY.INV_WAREHOUSE_SK], [INVENTORY.INV_QUANTITY_ON_HAND]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([INVENTORY.INV_DATE_SK], [INVENTORY.INV_ITEM_SK], [INVENTORY.INV_WAREHOUSE_SK]), range(MIN ; MAX), 
      range_cond([INVENTORY.INV_DATE_SK = :5])
 10 - output([WAREHOUSE.W_WAREHOUSE_NAME]), filter(nil), rowset=256
      access([GROUP_ID], [WAREHOUSE.W_WAREHOUSE_NAME]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([WAREHOUSE.W_WAREHOUSE_SK]), range(MIN ; MAX), 
      range_cond([:0 = WAREHOUSE.W_WAREHOUSE_SK])
 11 - output([ITEM.I_ITEM_ID]), filter([ITEM.I_CURRENT_PRICE <= 1.49], [ITEM.I_CURRENT_PRICE >= .99]), rowset=256
      access([GROUP_ID], [ITEM.I_CURRENT_PRICE], [ITEM.I_ITEM_ID]), partitions(p0)
