select /*+parallel(2) TPC-DS Q53*/* from (select i_item_id
,i_item_desc
,s_store_id
,s_store_name
,max(ss_quantity)        as store_sales_quantity
,max(sr_return_quantity) as store_returns_quantity
,max(cs_quantity)        as catalog_sales_quantity
from    store_sales
,store_returns
,catalog_sales
,date_dim             d1
,date_dim             d2
,date_dim             d3
,store
,item
where     d1.d_moy               = 4
and d1.d_year              = 1998
and d1.d_date_sk           = ss_sold_date_sk
and i_item_sk              = ss_item_sk
and s_store_sk             = ss_store_sk
and ss_customer_sk         = sr_customer_sk
and ss_item_sk             = sr_item_sk
and ss_ticket_number       = sr_ticket_number
and sr_returned_date_sk    = d2.d_date_sk
and d2.d_moy               between 4 and  4 + 3
and d2.d_year              = 1998
and sr_customer_sk         = cs_bill_customer_sk
and sr_item_sk             = cs_item_sk
and cs_sold_date_sk        = d3.d_date_sk
and d3.d_year              in (1998,1998+1,1998+2)
group by    i_item_id
,i_item_desc
,s_store_id
,s_store_name
order by    i_item_id
,i_item_desc
,s_store_id
,s_store_name
) where rownum <= 100;
+-----------+-------------+------------+--------------+----------------------+------------------------+------------------------+
| I_ITEM_ID | I_ITEM_DESC | S_STORE_ID | S_STORE_NAME | STORE_SALES_QUANTITY | STORE_RETURNS_QUANTITY | CATALOG_SALES_QUANTITY |
+-----------+-------------+------------+--------------+----------------------+------------------------+------------------------+
+-----------+-------------+------------+--------------+----------------------+------------------------+------------------------+


********************** TPC_DS Q54
EXPLAIN select /*+parallel(2) TPC-DS Q54*/* from (select  count(*) from (
select distinct c_last_name, c_first_name, d_date
from store_sales, date_dim, customer
where store_sales.ss_sold_date_sk = date_dim.d_date_sk
and store_sales.ss_customer_sk = customer.c_customer_sk
and d_month_seq between 1178 and 1178 + 11  intersect    select distinct c_last_name, c_first_name, d_date
from catalog_sales, date_dim, customer
where catalog_sales.cs_sold_date_sk = date_dim.d_date_sk
and catalog_sales.cs_bill_customer_sk = customer.c_customer_sk
and d_month_seq between 1178 and 1178 + 11  intersect    select distinct c_last_name, c_first_name, d_date
from web_sales, date_dim, customer
where web_sales.ws_sold_date_sk = date_dim.d_date_sk
and web_sales.ws_bill_customer_sk = customer.c_customer_sk
and d_month_seq between 1178 and 1178 + 11) hot_cust
) where rownum <= 100;
