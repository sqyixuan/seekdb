  3 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      dop=2
  4 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
  5 - output(nil), filter(nil), rowset=256
      conds(nil), nl_params_([STORE_SALES.SS_STORE_SK(:4)]), use_batch=true
  6 - output([STORE_SALES.SS_STORE_SK]), filter(nil), rowset=256
      conds(nil), nl_params_([STORE_SALES.SS_HDEMO_SK(:0)]), use_batch=true
  7 - output([STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_HDEMO_SK]), filter(nil), rowset=256
      equal_conds([STORE_SALES.SS_SOLD_TIME_SK = TIME_DIM.T_TIME_SK]), other_conds(nil)
