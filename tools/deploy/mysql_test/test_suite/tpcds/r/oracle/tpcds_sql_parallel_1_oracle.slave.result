      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([TIME_DIM.T_TIME_SK]), range(MIN ; MAX)always true
 13 - output([STORE_SALES.SS_STORE_SK], [STORE_SALES.SS_HDEMO_SK], [STORE_SALES.SS_SOLD_TIME_SK]), filter(nil), rowset=256
 14 - output([STORE_SALES.SS_SOLD_TIME_SK], [STORE_SALES.SS_HDEMO_SK], [STORE_SALES.SS_STORE_SK]), filter(nil), rowset=256
 15 - output([STORE_SALES.SS_SOLD_TIME_SK], [STORE_SALES.SS_HDEMO_SK], [STORE_SALES.SS_STORE_SK]), filter([RF_IN_FILTER(STORE_SALES.SS_SOLD_TIME_SK)], [RF_RANGE_FILTER(STORE_SALES.SS_SOLD_TIME_SK)],
