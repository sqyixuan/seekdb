result_format: 4
explain_protocol: 2
set global ob_sql_work_area_percentage=100;

set ob_query_timeout = 1000000000;
set ob_trx_timeout=1000000000;
********************** TPC_DS Q1
EXPLAIN select /*+parallel(2) TPC-DS Q1*/* from (select  count(*)
from store_sales
,household_demographics
,time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 8
and time_dim.t_minute >= 30
and household_demographics.hd_dep_count = 5
and store.s_store_name = 'ese' order by count(*)
) where rownum <= 100;
Query Plan
==================================================================================================
|ID|OPERATOR                                        |NAME                  |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------------------------------------
|0 |LIMIT                                           |                      |1       |77          |
|1 |└─SCALAR GROUP BY                               |                      |1       |77          |
|2 |  └─PX COORDINATOR                              |                      |2       |77          |
|3 |    └─EXCHANGE OUT DISTR                        |:EX10001              |2       |76          |
|4 |      └─MERGE GROUP BY                          |                      |2       |76          |
|5 |        └─NESTED-LOOP JOIN                      |                      |0       |76          |
|6 |          ├─NESTED-LOOP JOIN                    |                      |0       |76          |
|7 |          │ ├─SHARED HASH JOIN                  |                      |0       |76          |
|8 |          │ │ ├─JOIN FILTER CREATE              |:RF0000               |0       |26          |
|9 |          │ │ │ └─EXCHANGE IN DISTR             |                      |0       |26          |
|10|          │ │ │   └─EXCHANGE OUT DISTR (BC2HOST)|:EX10000              |0       |26          |
|11|          │ │ │     └─PX BLOCK ITERATOR         |                      |0       |26          |
|12|          │ │ │       └─TABLE FULL SCAN         |TIME_DIM              |0       |26          |
|13|          │ │ └─JOIN FILTER USE                 |:RF0000               |13      |50          |
|14|          │ │   └─PX BLOCK ITERATOR             |                      |13      |50          |
|15|          │ │     └─TABLE FULL SCAN             |STORE_SALES           |13      |50          |
|16|          │ └─DISTRIBUTED TABLE GET             |HOUSEHOLD_DEMOGRAPHICS|1       |16          |
|17|          └─DISTRIBUTED TABLE GET               |STORE                 |1       |16          |
==================================================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))]), filter(nil), rowset=256
      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
  1 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
