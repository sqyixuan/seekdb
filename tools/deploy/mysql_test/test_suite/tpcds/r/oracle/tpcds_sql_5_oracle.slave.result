result_format: 4
explain_protocol: 2
set global ob_sql_work_area_percentage=100;

set ob_query_timeout = 1000000000;
set ob_trx_timeout=1000000000;
********************** TPC_DS Q40
EXPLAIN select /*TPC-DS Q40*/* from (select  cast(amc as decimal(15,4))*cast(pmc as decimal(15,4)) am_pm_ratio
from ( select count(*) amc
from web_sales, household_demographics , time_dim, web_page
where ws_sold_time_sk = time_dim.t_time_sk
and ws_ship_hdemo_sk = household_demographics.hd_demo_sk
and ws_web_page_sk = web_page.wp_web_page_sk
and time_dim.t_hour between 9 and 9+1
and household_demographics.hd_dep_count = 2
and web_page.wp_char_count between 5000 and 5200) at,
( select count(*) pmc
from web_sales, household_demographics , time_dim, web_page
where ws_sold_time_sk = time_dim.t_time_sk
and ws_ship_hdemo_sk = household_demographics.hd_demo_sk
and ws_web_page_sk = web_page.wp_web_page_sk
and time_dim.t_hour between 15 and 15+1
and household_demographics.hd_dep_count = 2
and web_page.wp_char_count between 5000 and 5200) pt
order by am_pm_ratio
) where rownum <= 100;
Query Plan
=====================================================================================
|ID|OPERATOR                           |NAME                  |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                 |                      |1       |607         |
|1 |└─EXCHANGE OUT REMOTE              |                      |1       |606         |
|2 |  └─TEMP TABLE TRANSFORMATION      |                      |1       |605         |
|3 |    ├─TEMP TABLE INSERT            |TEMP1                 |0       |604         |
|4 |    │ └─NESTED-LOOP JOIN           |                      |0       |604         |
|5 |    │   ├─NESTED-LOOP JOIN         |                      |0       |604         |
|6 |    │   │ ├─HASH JOIN              |                      |0       |604         |
|7 |    │   │ │ ├─TABLE FULL SCAN      |TIME_DIM              |0       |33          |
|8 |    │   │ │ └─TABLE FULL SCAN      |WEB_SALES             |3500    |253         |
|9 |    │   │ └─DISTRIBUTED TABLE GET  |HOUSEHOLD_DEMOGRAPHICS|1       |16          |
|10|    │   └─DISTRIBUTED TABLE GET    |WEB_PAGE              |1       |16          |
|11|    └─LIMIT                        |                      |1       |1           |
|12|      └─NESTED-LOOP JOIN CARTESIAN |                      |1       |1           |
|13|        ├─SUBPLAN SCAN             |AT                    |1       |1           |
|14|        │ └─SCALAR GROUP BY        |                      |1       |0           |
|15|        │   └─TEMP TABLE ACCESS    |VIEW2(TEMP1)          |0       |0           |
|16|        └─SUBPLAN SCAN             |PT                    |1       |1           |
|17|          └─SCALAR GROUP BY        |                      |1       |0           |
|18|            └─TEMP TABLE ACCESS    |VIEW3(TEMP1)          |0       |0           |
=====================================================================================
Outputs & filters:
-------------------------------------
  0 - output([cast(AT.AMC, NUMBER(15, 4)) * cast(PT.PMC, NUMBER(15, 4))]), filter(nil)
  1 - output([cast(AT.AMC, NUMBER(15, 4)) * cast(PT.PMC, NUMBER(15, 4))]), filter(nil)
  2 - output([cast(AT.AMC, NUMBER(15, 4)) * cast(PT.PMC, NUMBER(15, 4))]), filter(nil), rowset=256
  3 - output(nil), filter(nil), rowset=256
  4 - output([TIME_DIM.T_HOUR]), filter(nil), rowset=256
      conds(nil), nl_params_([WEB_SALES.WS_WEB_PAGE_SK(:4)]), use_batch=true
  5 - output([WEB_SALES.WS_WEB_PAGE_SK], [TIME_DIM.T_HOUR]), filter(nil), rowset=256
      conds(nil), nl_params_([WEB_SALES.WS_SHIP_HDEMO_SK(:0)]), use_batch=true
  6 - output([WEB_SALES.WS_WEB_PAGE_SK], [TIME_DIM.T_HOUR], [WEB_SALES.WS_SHIP_HDEMO_SK]), filter(nil), rowset=256
      equal_conds([WEB_SALES.WS_SOLD_TIME_SK = TIME_DIM.T_TIME_SK]), other_conds(nil)
  7 - output([TIME_DIM.T_TIME_SK], [TIME_DIM.T_HOUR]), filter([TIME_DIM.T_HOUR >= 9 AND TIME_DIM.T_HOUR <= 9 + 1 OR TIME_DIM.T_HOUR >= 15 AND TIME_DIM.T_HOUR 
      <= 15 + 1]), rowset=256
      access([TIME_DIM.T_TIME_SK], [TIME_DIM.T_HOUR]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([TIME_DIM.T_TIME_SK]), range(MIN ; MAX)always true
  8 - output([WEB_SALES.WS_SOLD_TIME_SK], [WEB_SALES.WS_SHIP_HDEMO_SK], [WEB_SALES.WS_WEB_PAGE_SK]), filter(nil), rowset=256
      access([WEB_SALES.WS_SOLD_TIME_SK], [WEB_SALES.WS_SHIP_HDEMO_SK], [WEB_SALES.WS_WEB_PAGE_SK]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([WEB_SALES.WS_ITEM_SK], [WEB_SALES.WS_ORDER_NUMBER]), range(MIN,MIN ; MAX,MAX)always true
  9 - output(nil), filter([HOUSEHOLD_DEMOGRAPHICS.HD_DEP_COUNT = 2]), rowset=256
      access([GROUP_ID], [HOUSEHOLD_DEMOGRAPHICS.HD_DEP_COUNT]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK]), range(MIN ; MAX), 
      range_cond([:0 = HOUSEHOLD_DEMOGRAPHICS.HD_DEMO_SK])
 10 - output(nil), filter([WEB_PAGE.WP_CHAR_COUNT >= 5000], [WEB_PAGE.WP_CHAR_COUNT <= 5200]), rowset=256
      access([GROUP_ID], [WEB_PAGE.WP_CHAR_COUNT]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([WEB_PAGE.WP_WEB_PAGE_SK]), range(MIN ; MAX), 
      range_cond([:4 = WEB_PAGE.WP_WEB_PAGE_SK])
 11 - output([AT.AMC], [PT.PMC]), filter(nil), rowset=256
      limit(cast(FLOOR(100), BIGINT(-1, 0))), offset(nil)
 12 - output([AT.AMC], [PT.PMC]), filter(nil), rowset=256
      conds(nil), nl_params_(nil), use_batch=false
 13 - output([AT.AMC]), filter(nil), rowset=256
      access([AT.AMC])
 14 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
 15 - output(nil), filter([VIEW2.TIME_DIM.T_HOUR >= 9], [VIEW2.TIME_DIM.T_HOUR <= 9 + 1]), rowset=256
      access([VIEW2.TIME_DIM.T_HOUR])
 16 - output([PT.PMC]), filter(nil), rowset=256
      access([PT.PMC])
 17 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
 18 - output(nil), filter([VIEW3.TIME_DIM.T_HOUR >= 15], [VIEW3.TIME_DIM.T_HOUR <= 15 + 1]), rowset=256
      access([VIEW3.TIME_DIM.T_HOUR])
select /*TPC-DS Q40*/* from (select  cast(amc as decimal(15,4))*cast(pmc as decimal(15,4)) am_pm_ratio
from ( select count(*) amc
from web_sales, household_demographics , time_dim, web_page
where ws_sold_time_sk = time_dim.t_time_sk
and ws_ship_hdemo_sk = household_demographics.hd_demo_sk
and ws_web_page_sk = web_page.wp_web_page_sk
and time_dim.t_hour between 9 and 9+1
and household_demographics.hd_dep_count = 2
and web_page.wp_char_count between 5000 and 5200) at,
( select count(*) pmc
from web_sales, household_demographics , time_dim, web_page
where ws_sold_time_sk = time_dim.t_time_sk
and ws_ship_hdemo_sk = household_demographics.hd_demo_sk
and ws_web_page_sk = web_page.wp_web_page_sk
and time_dim.t_hour between 15 and 15+1
and household_demographics.hd_dep_count = 2
and web_page.wp_char_count between 5000 and 5200) pt
order by am_pm_ratio
) where rownum <= 100;
+-------------+
| AM_PM_RATIO |
+-------------+
|           0 |
+-------------+


********************** TPC_DS Q41
EXPLAIN select /*TPC-DS Q41*/* from (select  i_item_id
,i_item_desc
,s_state
,count(ss_quantity) as store_sales_quantitycount
,avg(ss_quantity) as store_sales_quantityave
,stddev_samp(ss_quantity) as store_sales_quantitystdev
,stddev_samp(ss_quantity)/avg(ss_quantity) as store_sales_quantitycov
,count(sr_return_quantity) as store_returns_quantitycount
,avg(sr_return_quantity) as store_returns_quantityave
,stddev_samp(sr_return_quantity) as store_returns_quantitystdev
,stddev_samp(sr_return_quantity)/avg(sr_return_quantity) as store_returns_quantitycov
,count(cs_quantity) as catalog_sales_quantitycount ,avg(cs_quantity) as catalog_sales_quantityave
,stddev_samp(cs_quantity) as catalog_sales_quantitystdev
,stddev_samp(cs_quantity)/avg(cs_quantity) as catalog_sales_quantitycov
from store_sales
,store_returns
,catalog_sales
,date_dim d1
,date_dim d2
,date_dim d3
,store
,item
where d1.d_quarter_name = '1999Q1'   and d1.d_date_sk = ss_sold_date_sk
and i_item_sk = ss_item_sk
and s_store_sk = ss_store_sk
and ss_customer_sk = sr_customer_sk
and ss_item_sk = sr_item_sk
and ss_ticket_number = sr_ticket_number
and sr_returned_date_sk = d2.d_date_sk
and d2.d_quarter_name in ('1999Q1','1999Q2','1999Q3')
and sr_customer_sk = cs_bill_customer_sk
and sr_item_sk = cs_item_sk
and cs_sold_date_sk = d3.d_date_sk
and d3.d_quarter_name in ('1999Q1','1999Q2','1999Q3')
group by i_item_id
,i_item_desc
,s_state
order by i_item_id
,i_item_desc
,s_state
) where rownum <= 100;
