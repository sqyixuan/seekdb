      sort_keys([T_FUN_GROUPING(ITEM.I_CATEGORY) + T_FUN_GROUPING(ITEM.I_CLASS), DESC], [CASE WHEN T_FUN_GROUPING(ITEM.I_CLASS) = 0 THEN ITEM.I_CATEGORY 
      ELSE NULL END, ASC], [T_FUN_SUM(T_FUN_SUM(WEB_SALES.WS_NET_PAID)), DESC])
