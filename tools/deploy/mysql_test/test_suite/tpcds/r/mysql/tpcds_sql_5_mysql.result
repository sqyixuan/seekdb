  9 - output([item.i_item_sk]), filter([item.i_manufact_id = 651]), rowset=16
      access([item.i_item_sk], [item.i_manufact_id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 10 - output([web_sales.ws_item_sk], [web_sales.ws_sold_date_sk], [web_sales.ws_ext_discount_amt]), filter(nil), rowset=16
      access([GROUP_ID], [web_sales.ws_item_sk], [web_sales.ws_sold_date_sk], [web_sales.ws_ext_discount_amt]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([web_sales.ws_item_sk], [web_sales.ws_order_number]), range(MIN ; MAX), 
      range_cond([web_sales.ws_item_sk = :0])
select  /*TPC-DS Q44*/ sum(ws_ext_discount_amt) as "Excess Discount Amount" from web_sales
,item
,date_dim
where i_manufact_id = 651 and i_item_sk = ws_item_sk
and d_date between '1998-01-29' and  (cast('1998-03-29' as date))
and d_date_sk = ws_sold_date_sk
and ws_ext_discount_amt
>( SELECT 1.3 * avg(ws_ext_discount_amt)
FROM  web_sales ,date_dim
WHERE ws_item_sk = i_item_sk
and d_date between '1998-01-29' and  (cast('1998-03-29' as date))
and d_date_sk = ws_sold_date_sk
)
order by sum(ws_ext_discount_amt)
limit 100;
