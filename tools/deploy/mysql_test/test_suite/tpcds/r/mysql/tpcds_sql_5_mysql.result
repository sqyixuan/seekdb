      access([at.amc])
 13 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
 14 - output(nil), filter([VIEW1.time_dim.t_hour >= 9], [VIEW1.time_dim.t_hour <= 9 + 1]), rowset=256
      access([VIEW1.time_dim.t_hour])
 15 - output([pt.pmc]), filter(nil), rowset=256
