      equal_conds([web_sales.ws_web_page_sk = web_page.wp_web_page_sk]), other_conds(nil)
  8 - output([web_page.wp_web_page_sk]), filter([web_page.wp_char_count >= 5000], [web_page.wp_char_count <= 5200]), rowset=256
      access([web_page.wp_web_page_sk], [web_page.wp_char_count]), partitions(p0)
