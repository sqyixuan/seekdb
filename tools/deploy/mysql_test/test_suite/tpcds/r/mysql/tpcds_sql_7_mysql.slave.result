      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 10 - output([inventory.inv_date_sk], [inventory.inv_item_sk]), filter([inventory.inv_quantity_on_hand <= 500], [inventory.inv_quantity_on_hand >= 100]), rowset=256
      access([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_quantity_on_hand]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
