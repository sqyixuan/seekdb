| s_store_name | s_company_id | s_street_number | s_street_name | s_street_type | s_suite_number | s_city | s_county | s_state | s_zip | 30 days | 31-60 days | 61-90 days | 91-120 days | >120 days |
+--------------+--------------+-----------------+---------------+---------------+----------------+--------+----------+---------+-------+---------+------------+------------+-------------+-----------+
+--------------+--------------+-----------------+---------------+---------------+----------------+--------+----------+---------+-------+---------+------------+------------+-------------+-----------+



********************** TPC_DS Q61
EXPLAIN select /*TPC-DS Q61*/ dt.d_year
,item.i_category_id
,item.i_category
,sum(ss_ext_sales_price)
from date_dim dt
,store_sales
,item
where dt.d_date_sk = store_sales.ss_sold_date_sk
and store_sales.ss_item_sk = item.i_item_sk
and item.i_manager_id = 1
and dt.d_moy=12
and dt.d_year=2002
group by  dt.d_year
,item.i_category_id
,item.i_category
order by sum(ss_ext_sales_price) desc,dt.d_year
,item.i_category_id
,item.i_category
limit 100 ;
Query Plan
===================================================================
|ID|OPERATOR                    |NAME       |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE          |           |1       |103         |
|1 |└─EXCHANGE OUT REMOTE       |           |1       |103         |
|2 |  └─TOP-N SORT              |           |1       |102         |
|3 |    └─HASH GROUP BY         |           |1       |102         |
|4 |      └─NESTED-LOOP JOIN    |           |1       |102         |
|5 |        ├─NESTED-LOOP JOIN  |           |4       |53          |
|6 |        │ ├─TABLE FULL SCAN |item       |3       |11          |
|7 |        │ └─TABLE RANGE SCAN|store_sales|2       |16          |
|8 |        └─TABLE GET         |dt         |1       |16          |
===================================================================
Outputs & filters:
-------------------------------------
  0 - output([dt.d_year], [item.i_category_id], [item.i_category], [T_FUN_SUM(store_sales.ss_ext_sales_price)]), filter(nil)
  1 - output([dt.d_year], [item.i_category_id], [item.i_category], [T_FUN_SUM(store_sales.ss_ext_sales_price)]), filter(nil)
  2 - output([dt.d_year], [item.i_category_id], [item.i_category], [T_FUN_SUM(store_sales.ss_ext_sales_price)]), filter(nil), rowset=16
      sort_keys([T_FUN_SUM(store_sales.ss_ext_sales_price), DESC], [item.i_category_id, ASC], [item.i_category, ASC]), topn(100)
  3 - output([dt.d_year], [item.i_category_id], [item.i_category], [T_FUN_SUM(store_sales.ss_ext_sales_price)]), filter(nil), rowset=16
      group([item.i_category_id], [item.i_category]), agg_func([T_FUN_SUM(store_sales.ss_ext_sales_price)])
  4 - output([dt.d_year], [item.i_category_id], [item.i_category], [store_sales.ss_ext_sales_price]), filter(nil), rowset=16
      conds(nil), nl_params_([store_sales.ss_sold_date_sk(:1)]), use_batch=true
  5 - output([item.i_category_id], [item.i_category], [store_sales.ss_sold_date_sk], [store_sales.ss_ext_sales_price]), filter(nil), rowset=16
      conds(nil), nl_params_([item.i_item_sk(:0)]), use_batch=true
  6 - output([item.i_item_sk], [item.i_category_id], [item.i_category]), filter([item.i_manager_id = 1]), rowset=16
      access([item.i_item_sk], [item.i_manager_id], [item.i_category_id], [item.i_category]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
  7 - output([store_sales.ss_sold_date_sk], [store_sales.ss_ext_sales_price]), filter(nil), rowset=16
      access([GROUP_ID], [store_sales.ss_sold_date_sk], [store_sales.ss_ext_sales_price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN ; MAX), 
      range_cond([store_sales.ss_item_sk = :0])
  8 - output([dt.d_year]), filter([dt.d_moy = 12], [dt.d_year = 2002]), rowset=16
      access([GROUP_ID], [dt.d_moy], [dt.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([dt.d_date_sk]), range(MIN ; MAX), 
      range_cond([dt.d_date_sk = :1])
select /*TPC-DS Q61*/ dt.d_year
,item.i_category_id
,item.i_category
,sum(ss_ext_sales_price)
from date_dim dt
,store_sales
,item
where dt.d_date_sk = store_sales.ss_sold_date_sk
and store_sales.ss_item_sk = item.i_item_sk
and item.i_manager_id = 1
and dt.d_moy=12
and dt.d_year=2002
group by  dt.d_year
,item.i_category_id
,item.i_category
order by sum(ss_ext_sales_price) desc,dt.d_year
,item.i_category_id
,item.i_category
limit 100 ;
