      distinct([i1.i_product_name])
  4 - output([i1.i_product_name]), filter(nil), rowset=16
      sort_keys([i1.i_product_name, ASC])
  5 - output([i1.i_product_name]), filter(nil), rowset=16
      equal_conds([VIEW1.item.i_manufact = i1.i_manufact]), other_conds(nil)
  6 - output([VIEW1.item.i_manufact]), filter(nil), rowset=16
      access([VIEW1.item.i_manufact])
  7 - output([item.i_manufact]), filter([(T_OP_OR, (T_OP_AND, item.i_category = 'Women', item.i_color = 'midnight' OR item.i_color = 'gainsboro', item.i_units 
      = 'Box' OR item.i_units = 'Carton', item.i_size = 'small' OR item.i_size = 'large'), (T_OP_AND, item.i_category = 'Women', item.i_color = 'magenta' OR item.i_color 
      = 'chocolate', item.i_units = 'Lb' OR item.i_units = 'Bunch', item.i_size = 'petite' OR item.i_size = 'medium'), (T_OP_AND, item.i_category = 'Men', item.i_color 
      = 'chartreuse' OR item.i_color = 'chiffon', item.i_units = 'Tbl' OR item.i_units = 'Dozen', item.i_size = 'economy' OR item.i_size = 'extra large'), (T_OP_AND,
       item.i_category = 'Men', item.i_color = 'coral' OR item.i_color = 'pale', item.i_units = 'Ton' OR item.i_units = 'Bundle', item.i_size = 'small' OR item.i_size 
      = 'large'), (T_OP_AND, item.i_category = 'Women', item.i_color = 'burnished' OR item.i_color = 'plum', item.i_units = 'Oz' OR item.i_units = 'Each', item.i_size 
      = 'small' OR item.i_size = 'large'), (T_OP_AND, item.i_category = 'Women', item.i_color = 'misty' OR item.i_color = 'mint', item.i_units = 'Ounce' OR item.i_units 
      = 'Tsp', item.i_size = 'petite' OR item.i_size = 'medium'), (T_OP_AND, item.i_category = 'Men', item.i_color = 'dark' OR item.i_color = 'olive', item.i_units 
      = 'Dram' OR item.i_units = 'Gross', item.i_size = 'economy' OR item.i_size = 'extra large'), (T_OP_AND, item.i_category = 'Men', item.i_color = 'cornflower' 
      OR item.i_color = 'hot', item.i_units = 'Gram' OR item.i_units = 'N/A', item.i_size = 'small' OR item.i_size = 'large'))]), rowset=16
      access([item.i_manufact], [item.i_category], [item.i_color], [item.i_units], [item.i_size]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
  8 - output([i1.i_manufact], [i1.i_product_name]), filter([i1.i_manufact_id >= 761], [i1.i_manufact_id <= 761 + 40]), rowset=16
      access([i1.i_manufact_id], [i1.i_manufact], [i1.i_product_name]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([i1.i_item_sk]), range(MIN ; MAX)always true
select /*TPC-DS Q62*/ distinct(i_product_name)
from item i1
where i_manufact_id between 761 and 761+40   and (select count(*) as item_cnt
from item
where (i_manufact = i1.i_manufact
and ((i_category = 'Women' and (i_color = 'midnight' or i_color = 'gainsboro') and (i_units = 'Box' or i_units = 'Carton') and (i_size = 'small' or i_size = 'large')
) or (i_category = 'Women' and (i_color = 'magenta' or i_color = 'chocolate') and (i_units = 'Lb' or i_units = 'Bunch') and (i_size = 'petite' or i_size = 'medium')
) or (i_category = 'Men' and (i_color = 'chartreuse' or i_color = 'chiffon') and (i_units = 'Tbl' or i_units = 'Dozen') and (i_size = 'economy' or i_size = 'extra large')
) or (i_category = 'Men' and (i_color = 'coral' or i_color = 'pale') and (i_units = 'Ton' or i_units = 'Bundle') and (i_size = 'small' or i_size = 'large')
))) or (i_manufact = i1.i_manufact and ((i_category = 'Women' and (i_color = 'burnished' or i_color = 'plum') and (i_units = 'Oz' or i_units = 'Each') and (i_size = 'small' or i_size = 'large')
) or (i_category = 'Women' and (i_color = 'misty' or i_color = 'mint') and (i_units = 'Ounce' or i_units = 'Tsp') and (i_size = 'petite' or i_size = 'medium')
) or (i_category = 'Men' and (i_color = 'dark' or i_color = 'olive') and (i_units = 'Dram' or i_units = 'Gross') and (i_size = 'economy' or i_size = 'extra large')
) or (i_category = 'Men' and (i_color = 'cornflower' or i_color = 'hot') and (i_units = 'Gram' or i_units = 'N/A') and (i_size = 'small' or i_size = 'large')
)))) > 0 order by i_product_name
limit 100;
+----------------+
| i_product_name |
+----------------+
+----------------+



