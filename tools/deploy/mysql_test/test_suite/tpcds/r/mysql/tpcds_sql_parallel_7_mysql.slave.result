where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 10
and time_dim.t_minute >= 30
and ((household_demographics.hd_dep_count = 3
and household_demographics.hd_vehicle_count<=3+2)
or (household_demographics.hd_dep_count = 1 and household_demographics.hd_vehicle_count<=1+2)
or (household_demographics.hd_dep_count = 4 and household_demographics.hd_vehicle_count<=4+2))
and store.s_store_name = 'ese') s5,
(select count(*) h11_to_11_30
from store_sales, household_demographics , time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 11
and time_dim.t_minute < 30
and ((household_demographics.hd_dep_count = 3 and household_demographics.hd_vehicle_count<=3+2)
or (household_demographics.hd_dep_count = 1 and household_demographics.hd_vehicle_count<=1+2)
or (household_demographics.hd_dep_count = 4 and household_demographics.hd_vehicle_count<=4+2))
and store.s_store_name = 'ese') s6,
(select count(*) h11_30_to_12
from store_sales, household_demographics , time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 11
and time_dim.t_minute >= 30
and ((household_demographics.hd_dep_count = 3 and household_demographics.hd_vehicle_count<=3+2)
or (household_demographics.hd_dep_count = 1 and household_demographics.hd_vehicle_count<=1+2)
or (household_demographics.hd_dep_count = 4 and household_demographics.hd_vehicle_count<=4+2))
and store.s_store_name = 'ese') s7,
(select count(*) h12_to_12_30
from store_sales, household_demographics , time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 12
and time_dim.t_minute < 30
and ((household_demographics.hd_dep_count = 3 and household_demographics.hd_vehicle_count<=3+2)
or (household_demographics.hd_dep_count = 1 and household_demographics.hd_vehicle_count<=1+2)
or (household_demographics.hd_dep_count = 4 and household_demographics.hd_vehicle_count<=4+2))
and store.s_store_name = 'ese') s8;
