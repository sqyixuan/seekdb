      is_index_back=false, is_global_index=false, 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 10 - output([catalog_sales.cs_item_sk], [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_call_center_sk], [catalog_sales.cs_sales_price]), filter(nil), rowset=256
      access([catalog_sales.cs_item_sk], [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_call_center_sk], [catalog_sales.cs_sales_price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([catalog_sales.cs_item_sk], [catalog_sales.cs_order_number]), range(MIN,MIN ; MAX,MAX)always true
 11 - output([v1.i_brand], [v1.d_year], [v1.d_moy], [v1.avg_monthly_sales], [v1.sum_sales], [v1_lag.sum_sales], [v1_lead.sum_sales]), filter(nil), rowset=256
      sort_keys([v1.sum_sales - v1.avg_monthly_sales, ASC], [v1.d_moy, ASC]), topn(100)
