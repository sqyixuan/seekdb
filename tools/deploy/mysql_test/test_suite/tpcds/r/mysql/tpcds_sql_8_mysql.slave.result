      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
  8 - output([store.s_store_name], [item.i_item_desc], [VIEW1.T_FUN_SUM(store_sales.ss_sales_price)], [item.i_current_price], [item.i_wholesale_cost], [item.i_brand]), filter(nil), rowset=256
      sort_keys([store.s_store_name, ASC], [item.i_item_desc, ASC]), topn(100)
