  1 - output([store.s_store_name], [item.i_item_desc], [VIEW1.T_FUN_SUM(store_sales.ss_sales_price)], [item.i_current_price], [item.i_wholesale_cost], [item.i_brand]), filter(nil)
  2 - output([store.s_store_name], [item.i_item_desc], [VIEW1.T_FUN_SUM(store_sales.ss_sales_price)], [item.i_current_price], [item.i_wholesale_cost], [item.i_brand]), filter(nil), rowset=256
  3 - output(nil), filter(nil), rowset=256
