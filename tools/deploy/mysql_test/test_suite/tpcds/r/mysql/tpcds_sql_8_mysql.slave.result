      sort_keys([customer.c_last_name, ASC], [customer.c_first_name, ASC], [customer.c_salutation, ASC], [customer.c_preferred_cust_flag, DESC], [dn.ss_ticket_number,
       ASC])
  3 - output([customer.c_last_name], [customer.c_first_name], [customer.c_salutation], [customer.c_preferred_cust_flag], [dn.ss_ticket_number], [dn.cnt]), filter(nil), rowset=256
      conds(nil), nl_params_([dn.ss_customer_sk(:6)]), use_batch=true
  4 - output([dn.ss_customer_sk], [dn.cnt], [dn.ss_ticket_number]), filter(nil), rowset=256
      access([dn.ss_customer_sk], [dn.cnt], [dn.ss_ticket_number])
  5 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [T_FUN_COUNT(*)]), filter([T_FUN_COUNT(*) >= 15], [T_FUN_COUNT(*) <= 20]), rowset=256
      group([store_sales.ss_ticket_number], [store_sales.ss_customer_sk]), agg_func([T_FUN_COUNT(*)])
