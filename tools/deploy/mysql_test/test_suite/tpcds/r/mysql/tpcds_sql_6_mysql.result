********************** TPC_DS Q56
EXPLAIN select /*TPC-DS Q56*/ *
from(
select i_category, i_class, i_brand,
s_store_name, s_company_name,
d_moy,
sum(ss_sales_price) sum_sales,
avg(sum(ss_sales_price)) over
(partition by i_category, i_brand, s_store_name, s_company_name)
avg_monthly_sales
from item, store_sales, date_dim, store
where ss_item_sk = i_item_sk and
ss_sold_date_sk = d_date_sk and
ss_store_sk = s_store_sk and
d_year in (1998) and
((i_category in ('Electronics','Men','Books') and
i_class in ('cameras','shirts','entertainments')
)
or (i_category in ('Music','Women','Jewelry') and
i_class in ('classical','dresses','estate')
))
group by i_category, i_class, i_brand,
s_store_name, s_company_name, d_moy) tmp1
where case when (avg_monthly_sales <> 0) then (abs(sum_sales - avg_monthly_sales) / avg_monthly_sales) else null end > 0.1order by sum_sales - avg_monthly_sales, s_store_name
limit 100;
Query Plan
=========================================================================
|ID|OPERATOR                          |NAME       |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------------
|0 |TOP-N SORT                        |           |3       |233         |
|1 |└─SUBPLAN SCAN                    |tmp1       |3       |231         |
|2 |  └─WINDOW FUNCTION               |           |8       |231         |
|3 |    └─MERGE GROUP BY              |           |8       |220         |
|4 |      └─SORT                      |           |8       |218         |
|5 |        └─MERGE JOIN              |           |8       |215         |
|6 |          ├─TABLE FULL SCAN       |store      |12      |3           |
|7 |          └─SORT                  |           |8       |210         |
|8 |            └─HASH JOIN           |           |8       |208         |
|9 |              ├─NESTED-LOOP JOIN  |           |8       |121         |
|10|              │ ├─TABLE FULL SCAN |item       |7       |11          |
|11|              │ └─TABLE RANGE SCAN|store_sales|2       |16          |
|12|              └─TABLE FULL SCAN   |date_dim   |350     |55          |
=========================================================================
Outputs & filters:
-------------------------------------
  0 - output([tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], [tmp1.d_moy], [tmp1.sum_sales], [tmp1.avg_monthly_sales]), filter(nil), rowset=256
      sort_keys([cast(tmp1.sum_sales, DECIMAL(29, 2)) - tmp1.avg_monthly_sales, ASC], [tmp1.s_store_name, ASC]), topn(100)
  1 - output([tmp1.avg_monthly_sales], [tmp1.sum_sales], [tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], 
      [tmp1.d_moy]), filter([CASE WHEN tmp1.avg_monthly_sales != cast(0, DECIMAL(20, 0)) THEN abs(cast(tmp1.sum_sales, DECIMAL(29, 2)) - tmp1.avg_monthly_sales) 
      / tmp1.avg_monthly_sales ELSE NULL END > cast(0.1, DECIMAL(2, 1))]), rowset=256
      access([tmp1.avg_monthly_sales], [tmp1.sum_sales], [tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], 
      [tmp1.d_moy])
  2 - output([item.i_category], [item.i_class], [item.i_brand], [store.s_store_name], [store.s_company_name], [date_dim.d_moy], [T_FUN_SUM(store_sales.ss_sales_price)],
       [cast(T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price)), DECIMAL_INT(61, 34)) / cast(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price)), DECIMAL_INT(20,
       0))]), filter(nil), rowset=256
      win_expr(T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name]),
       order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name]),
       order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([T_FUN_SUM(store_sales.ss_sales_price)], [item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy]), filter(nil), rowset=256
      group([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy]), agg_func([T_FUN_SUM(store_sales.ss_sales_price)])
  4 - output([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy], [store_sales.ss_sales_price]), filter(nil), rowset=256
      sort_keys([item.i_category, ASC], [item.i_brand, ASC], [store.s_store_name, ASC], [store.s_company_name, ASC], [item.i_class, ASC], [date_dim.d_moy,
       ASC])
  5 - output([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy], [store_sales.ss_sales_price]), filter(nil), rowset=256
      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
      merge_directions([ASC])
  6 - output([store.s_store_sk], [store.s_store_name], [store.s_company_name]), filter(nil), rowset=256
      access([store.s_store_sk], [store.s_store_name], [store.s_company_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
  7 - output([item.i_category], [item.i_brand], [item.i_class], [date_dim.d_moy], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      sort_keys([store_sales.ss_store_sk, ASC])
  8 - output([item.i_category], [item.i_brand], [item.i_class], [date_dim.d_moy], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      equal_conds([store_sales.ss_sold_date_sk = date_dim.d_date_sk]), other_conds(nil)
  9 - output([item.i_category], [item.i_brand], [item.i_class], [store_sales.ss_store_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      conds(nil), nl_params_([item.i_item_sk(:0)]), use_batch=true
 10 - output([item.i_item_sk], [item.i_category], [item.i_class], [item.i_brand]), filter([item.i_category IN ('Electronics', 'Men', 'Books') AND item.i_class 
      IN ('cameras', 'shirts', 'entertainments') OR item.i_category IN ('Music', 'Women', 'Jewelry') AND item.i_class IN ('classical', 'dresses', 'estate')]), rowset=256
      access([item.i_item_sk], [item.i_category], [item.i_class], [item.i_brand]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 11 - output([store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      access([GROUP_ID], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN ; MAX), 
      range_cond([store_sales.ss_item_sk = :0])
 12 - output([date_dim.d_date_sk], [date_dim.d_moy]), filter([date_dim.d_year = 1998]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_year], [date_dim.d_moy]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
select /*TPC-DS Q56*/ *
from(
select i_category, i_class, i_brand,
s_store_name, s_company_name,
d_moy,
sum(ss_sales_price) sum_sales,
avg(sum(ss_sales_price)) over
(partition by i_category, i_brand, s_store_name, s_company_name)
avg_monthly_sales
from item, store_sales, date_dim, store
where ss_item_sk = i_item_sk and
ss_sold_date_sk = d_date_sk and
ss_store_sk = s_store_sk and
d_year in (1998) and
((i_category in ('Electronics','Men','Books') and
i_class in ('cameras','shirts','entertainments')
)
or (i_category in ('Music','Women','Jewelry') and
i_class in ('classical','dresses','estate')
))
group by i_category, i_class, i_brand,
s_store_name, s_company_name, d_moy) tmp1
where case when (avg_monthly_sales <> 0) then (abs(sum_sales - avg_monthly_sales) / avg_monthly_sales) else null end > 0.1order by sum_sales - avg_monthly_sales, s_store_name
