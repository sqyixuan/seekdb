      group([customer_address.ca_zip]), agg_func([T_FUN_SUM(catalog_sales.cs_sales_price)])
  2 - output([customer_address.ca_zip], [catalog_sales.cs_sales_price]), filter(nil), rowset=256
      equal_conds([catalog_sales.cs_sold_date_sk = date_dim.d_date_sk]), other_conds(nil)
  3 - output([date_dim.d_date_sk]), filter([date_dim.d_qoy = 1], [date_dim.d_year = 1998]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_qoy], [date_dim.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
  4 - output([customer_address.ca_zip], [catalog_sales.cs_sales_price], [catalog_sales.cs_sold_date_sk]), filter(nil), rowset=256
      equal_conds([catalog_sales.cs_bill_customer_sk = customer.c_customer_sk]), other_conds([(T_OP_OR, substr(cast(customer_address.ca_zip, VARCHAR(1048576)),
       1, 5) IN ('85669', '86197', '88274', '83405', '86475', '85392', '85460', '80348', '81792'), customer_address.ca_state IN ('CA', 'WA', 'GA'), catalog_sales.cs_sales_price 
      > cast(500, DECIMAL_INT(7, 2)))])
