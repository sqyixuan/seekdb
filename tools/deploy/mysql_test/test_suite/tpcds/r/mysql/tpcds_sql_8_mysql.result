      range_key([store.s_store_sk]), range(MIN ; MAX)always true
  6 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      sort_keys([store_sales.ss_store_sk, ASC])
  7 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      equal_conds([store_sales.ss_sold_date_sk = date_dim.d_date_sk]), other_conds(nil)
