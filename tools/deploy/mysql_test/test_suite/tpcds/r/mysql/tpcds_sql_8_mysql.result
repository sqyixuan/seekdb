| c_customer_id | c_salutation | c_first_name | c_last_name | c_preferred_cust_flag | c_birth_day | c_birth_month | c_birth_year | c_birth_country | c_login | c_email_address | ctr_total_return |
+---------------+--------------+--------------+-------------+-----------------------+-------------+---------------+--------------+-----------------+---------+-----------------+------------------+
+---------------+--------------+--------------+-------------+-----------------------+-------------+---------------+--------------+-----------------+---------+-----------------+------------------+


********************** TPC_DS Q76
EXPLAIN select /*TPC-DS Q76*/ t_s_secyear.customer_id, t_s_secyear.customer_first_name, t_s_secyear.customer_last_name
from (
