  0 - output([customer.c_last_name], [customer.c_first_name], [customer.c_salutation], [customer.c_preferred_cust_flag], [dn.ss_ticket_number], [dn.cnt]), filter(nil), rowset=256
      sort_keys([customer.c_last_name, ASC], [customer.c_first_name, ASC], [customer.c_salutation, ASC], [customer.c_preferred_cust_flag, DESC], [dn.ss_ticket_number,
       ASC])
