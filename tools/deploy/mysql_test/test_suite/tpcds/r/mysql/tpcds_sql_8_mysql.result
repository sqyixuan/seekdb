      access([dn.ss_customer_sk], [dn.cnt], [dn.ss_ticket_number])
  3 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [T_FUN_COUNT(*)]), filter([T_FUN_COUNT(*) >= 15], [T_FUN_COUNT(*) <= 20]), rowset=256
      group([store_sales.ss_ticket_number], [store_sales.ss_customer_sk]), agg_func([T_FUN_COUNT(*)])
  4 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk]), filter(nil), rowset=256
      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
