      access([catalog_sales.cs_item_sk], [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_ext_sales_price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([catalog_sales.cs_item_sk], [catalog_sales.cs_order_number]), range(MIN,MIN ; MAX,MAX)always true
select /*+parallel(2) TPC-DS Q65*/ i_item_id
,i_item_desc
,i_category
,i_class
,i_current_price
,sum(cs_ext_sales_price) as itemrevenue
,sum(cs_ext_sales_price)*100/sum(sum(cs_ext_sales_price)) over
(partition by i_class) as revenueratio
from  catalog_sales
,item
,date_dim
where cs_item_sk = i_item_sk
and i_category in ('Books', 'Children', 'Sports')
and cs_sold_date_sk = d_date_sk
and d_date between cast('2000-04-25' as date)
and (cast('2000-05-25' as date))
group by i_item_id
,i_item_desc
,i_category
,i_class
,i_current_price
order by i_category
,i_class
,i_item_id
,i_item_desc
,revenueratio
limit 100;
