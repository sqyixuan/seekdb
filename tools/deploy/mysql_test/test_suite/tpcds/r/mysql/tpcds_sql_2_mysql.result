      access([catalog_returns.cr_call_center_sk], [catalog_returns.cr_returned_date_sk], [catalog_returns.cr_returning_customer_sk], [catalog_returns.cr_net_loss]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([catalog_returns.cr_item_sk], [catalog_returns.cr_order_number]), range(MIN,MIN ; MAX,MAX)always true
 13 - output([call_center.cc_call_center_sk], [call_center.cc_call_center_id], [call_center.cc_name], [call_center.cc_manager]), filter(nil), rowset=256
      access([call_center.cc_call_center_sk], [call_center.cc_call_center_id], [call_center.cc_name], [call_center.cc_manager]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([call_center.cc_call_center_sk]), range(MIN ; MAX)always true
