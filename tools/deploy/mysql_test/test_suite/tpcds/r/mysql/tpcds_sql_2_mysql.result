********************** TPC_DS Q14
EXPLAIN select  /*TPC-DS Q14*/*
from(select w_warehouse_name
,i_item_id
,sum(case when (cast(d_date as date) < cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_before
,sum(case when (cast(d_date as date) >= cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_after
from inventory
,warehouse
,item
,date_dim
where i_current_price between 0.99 and 1.49
and i_item_sk          = inv_item_sk
and inv_warehouse_sk   = w_warehouse_sk
and inv_date_sk    = d_date_sk
and d_date between (cast ('2000-04-19' as date))
and (cast ('2000-06-18' as date))
group by w_warehouse_name, i_item_id) x
where (case when inv_before > 0 then inv_after / inv_before
else null end) between 2.0/3.0 and 3.0/2.0 order by w_warehouse_name
,i_item_id
limit 100;
Query Plan
================================================================
|ID|OPERATOR                   |NAME     |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |TOP-N SORT                 |         |1       |1470        |
|1 |└─HASH GROUP BY            |         |1       |1470        |
|2 |  └─MERGE JOIN             |         |3       |1469        |
|3 |    ├─TABLE FULL SCAN      |warehouse|5       |3           |
|4 |    └─SORT                 |         |3       |1466        |
|5 |      └─HASH JOIN          |         |3       |1466        |
|6 |        ├─TABLE FULL SCAN  |date_dim |2       |22          |
|7 |        └─HASH JOIN        |         |3       |1444        |
|8 |          ├─TABLE FULL SCAN|item     |3       |10          |
|9 |          └─TABLE FULL SCAN|inventory|8000    |764         |
================================================================
Outputs & filters:
-------------------------------------
  0 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), filter(nil), rowset=256
      sort_keys([warehouse.w_warehouse_name, ASC], [item.i_item_id, ASC]), topn(100)
  1 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), filter([CASE WHEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END) > cast(0, DECIMAL_INT(42, 0)) THEN cast(T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END), DECIMAL(42, 0)) / cast(T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END), DECIMAL(42, 0)) ELSE NULL END >= cast(2.0, DECIMAL_INT(16, 15)) / 3.0], [CASE WHEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < 
      cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END) > cast(0, DECIMAL_INT(42, 0)) THEN cast(T_FUN_SUM(CASE WHEN cast(date_dim.d_date,
       DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END), DECIMAL(42, 0)) / cast(T_FUN_SUM(CASE WHEN cast(date_dim.d_date,
       DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END), DECIMAL(42, 0)) ELSE NULL END <= cast(3.0, DECIMAL_INT(16,
       15)) / 2.0]), rowset=256
      group([warehouse.w_warehouse_name], [item.i_item_id]), agg_func([T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0,
       0)) THEN inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)])
  2 - output([warehouse.w_warehouse_name], [item.i_item_id], [date_dim.d_date], [inventory.inv_quantity_on_hand]), filter(nil), rowset=256
      equal_conds([inventory.inv_warehouse_sk = warehouse.w_warehouse_sk]), other_conds(nil)
      merge_directions([ASC])
  3 - output([warehouse.w_warehouse_sk], [warehouse.w_warehouse_name]), filter(nil), rowset=256
      access([warehouse.w_warehouse_sk], [warehouse.w_warehouse_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([warehouse.w_warehouse_sk]), range(MIN ; MAX)always true
  4 - output([item.i_item_id], [date_dim.d_date], [inventory.inv_quantity_on_hand], [inventory.inv_warehouse_sk]), filter(nil), rowset=256
      sort_keys([inventory.inv_warehouse_sk, ASC])
  5 - output([item.i_item_id], [date_dim.d_date], [inventory.inv_quantity_on_hand], [inventory.inv_warehouse_sk]), filter(nil), rowset=256
      equal_conds([inventory.inv_date_sk = date_dim.d_date_sk]), other_conds(nil)
  6 - output([date_dim.d_date_sk], [date_dim.d_date]), filter([date_dim.d_date >= cast('2000-04-19', DATE(0, 0))], [date_dim.d_date <= cast('2000-06-18',
       DATE(0, 0))]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_date]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
  7 - output([item.i_item_id], [inventory.inv_quantity_on_hand], [inventory.inv_warehouse_sk], [inventory.inv_date_sk]), filter(nil), rowset=256
      equal_conds([item.i_item_sk = inventory.inv_item_sk]), other_conds(nil)
  8 - output([item.i_item_sk], [item.i_item_id]), filter([item.i_current_price <= 1.49], [item.i_current_price >= 0.99]), rowset=256
      access([item.i_item_sk], [item.i_current_price], [item.i_item_id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
  9 - output([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_warehouse_sk], [inventory.inv_quantity_on_hand]), filter(nil), rowset=256
      access([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_warehouse_sk], [inventory.inv_quantity_on_hand]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_warehouse_sk]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select  /*TPC-DS Q14*/*
from(select w_warehouse_name
,i_item_id
,sum(case when (cast(d_date as date) < cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_before
,sum(case when (cast(d_date as date) >= cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_after
from inventory
,warehouse
,item
,date_dim
where i_current_price between 0.99 and 1.49
and i_item_sk          = inv_item_sk
and inv_warehouse_sk   = w_warehouse_sk
and inv_date_sk    = d_date_sk
and d_date between (cast ('2000-04-19' as date))
and (cast ('2000-06-18' as date))
group by w_warehouse_name, i_item_id) x
where (case when inv_before > 0 then inv_after / inv_before
else null end) between 2.0/3.0 and 3.0/2.0 order by w_warehouse_name
,i_item_id
limit 100;
+------------------+-----------+------------+-----------+
| w_warehouse_name | i_item_id | inv_before | inv_after |
+------------------+-----------+------------+-----------+
+------------------+-----------+------------+-----------+


