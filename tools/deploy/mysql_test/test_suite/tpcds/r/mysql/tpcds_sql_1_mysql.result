-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil)
      limit(100), offset(nil)
  1 - output([T_FUN_COUNT(*)]), filter(nil)
      group(nil), agg_func([T_FUN_COUNT(*)])
  2 - output(nil), filter(nil)
      equal_conds([store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk]), other_conds(nil)
  3 - output([household_demographics.hd_demo_sk]), filter([household_demographics.hd_dep_count = 5])
      access([household_demographics.hd_demo_sk], [household_demographics.hd_dep_count]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([household_demographics.hd_demo_sk]), range(MIN ; MAX)always true
  4 - output([store_sales.ss_hdemo_sk]), filter(nil)
      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
  5 - output([store.s_store_sk]), filter([store.s_store_name = 'ese'])
      access([store.s_store_sk], [store.s_store_name]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
  6 - output([store_sales.ss_hdemo_sk], [store_sales.ss_store_sk]), filter(nil)
      equal_conds([store_sales.ss_sold_time_sk = time_dim.t_time_sk]), other_conds(nil)
  7 - output([time_dim.t_time_sk]), filter([time_dim.t_minute >= 30], [time_dim.t_hour = 8])
      access([time_dim.t_time_sk], [time_dim.t_hour], [time_dim.t_minute]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([time_dim.t_time_sk]), range(MIN ; MAX)always true
  8 - output([store_sales.ss_sold_time_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_store_sk]), filter(nil)
      access([store_sales.ss_sold_time_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_store_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
select /*TPC-DS Q1*/ count(*)
from store_sales
,household_demographics
,time_dim, store
