      sort_keys([item.i_item_id, ASC], [item.i_item_desc, ASC], [store.s_store_id, ASC], [store.s_store_name, ASC])
  3 - output([item.i_item_id], [item.i_item_desc], [store.s_store_id], [store.s_store_name], [store_returns.sr_net_loss], [store_sales.ss_net_profit], [catalog_sales.cs_net_profit]), filter(nil)
      conds(nil), nl_params_([catalog_sales.cs_sold_date_sk(:5)]), use_batch=true
  4 - output([item.i_item_id], [item.i_item_desc], [store.s_store_id], [store.s_store_name], [catalog_sales.cs_sold_date_sk], [store_returns.sr_net_loss],
       [store_sales.ss_net_profit], [catalog_sales.cs_net_profit]), filter(nil)
      conds(nil), nl_params_([store_sales.ss_item_sk(:3)], [store_returns.sr_customer_sk(:4)]), use_batch=true
  5 - output([item.i_item_id], [item.i_item_desc], [store.s_store_id], [store.s_store_name], [store_sales.ss_item_sk], [store_returns.sr_customer_sk], [store_returns.sr_net_loss],
       [store_sales.ss_net_profit]), filter(nil)
      equal_conds([store.s_store_sk = store_sales.ss_store_sk]), other_conds(nil)
      merge_directions([ASC])
  6 - output([store.s_store_sk], [store.s_store_id], [store.s_store_name]), filter(nil)
      access([store.s_store_sk], [store.s_store_id], [store.s_store_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
  7 - output([item.i_item_id], [item.i_item_desc], [store_sales.ss_item_sk], [store_returns.sr_customer_sk], [store_sales.ss_store_sk], [store_returns.sr_net_loss],
       [store_sales.ss_net_profit]), filter(nil)
      sort_keys([store_sales.ss_store_sk, ASC])
  8 - output([item.i_item_id], [item.i_item_desc], [store_sales.ss_item_sk], [store_returns.sr_customer_sk], [store_sales.ss_store_sk], [store_returns.sr_net_loss],
       [store_sales.ss_net_profit]), filter(nil)
      equal_conds([d1.d_date_sk = store_sales.ss_sold_date_sk]), other_conds(nil)
  9 - output([d1.d_date_sk]), filter([d1.d_moy = 4], [d1.d_year = 2001])
      access([d1.d_date_sk], [d1.d_moy], [d1.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([d1.d_date_sk]), range(MIN ; MAX)always true
 10 - output([item.i_item_id], [item.i_item_desc], [store_sales.ss_item_sk], [store_returns.sr_customer_sk], [store_sales.ss_store_sk], [store_returns.sr_net_loss],
       [store_sales.ss_sold_date_sk], [store_sales.ss_net_profit]), filter(nil)
      conds(nil), nl_params_([store_returns.sr_customer_sk(:0)], [store_returns.sr_item_sk(:1)], [store_returns.sr_ticket_number(:2)]), use_batch=true
 11 - output([item.i_item_id], [item.i_item_desc], [store_returns.sr_customer_sk], [store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_net_loss]), filter(nil)
      equal_conds([store_returns.sr_returned_date_sk = d2.d_date_sk]), other_conds(nil)
 12 - output([d2.d_date_sk]), filter([d2.d_year = 2001], [d2.d_moy >= 4], [d2.d_moy <= 10])
      access([d2.d_date_sk], [d2.d_moy], [d2.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([d2.d_date_sk]), range(MIN ; MAX)always true
 13 - output([item.i_item_id], [item.i_item_desc], [store_returns.sr_customer_sk], [store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_returned_date_sk],
       [store_returns.sr_net_loss]), filter(nil)
      equal_conds([item.i_item_sk = store_returns.sr_item_sk]), other_conds(nil)
      merge_directions([ASC])
 14 - output([item.i_item_sk], [item.i_item_id], [item.i_item_desc]), filter(nil)
      access([item.i_item_sk], [item.i_item_id], [item.i_item_desc]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 15 - output([store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_customer_sk], [store_returns.sr_returned_date_sk], [store_returns.sr_net_loss]), filter(nil)
      access([store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_customer_sk], [store_returns.sr_returned_date_sk], [store_returns.sr_net_loss]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_returns.sr_item_sk], [store_returns.sr_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
 16 - output([store_sales.ss_item_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_net_profit]), filter([store_sales.ss_customer_sk 
      = :0])
      access([GROUP_ID], [store_sales.ss_item_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_customer_sk], [store_sales.ss_net_profit]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN ; MAX), 
      range_cond([store_sales.ss_item_sk = :1], [store_sales.ss_ticket_number = :2])
 17 - output([catalog_sales.cs_sold_date_sk], [catalog_sales.cs_net_profit]), filter([:4 = catalog_sales.cs_bill_customer_sk])
      access([GROUP_ID], [catalog_sales.cs_bill_customer_sk], [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_net_profit]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([catalog_sales.cs_item_sk], [catalog_sales.cs_order_number]), range(MIN ; MAX), 
      range_cond([:3 = catalog_sales.cs_item_sk])
 18 - output(nil), filter([d3.d_year = 2001], [d3.d_moy >= 4], [d3.d_moy <= 10])
      access([GROUP_ID], [d3.d_moy], [d3.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([d3.d_date_sk]), range(MIN ; MAX), 
      range_cond([:5 = d3.d_date_sk])
select  /*TPC-DS Q9*/ i_item_id
,i_item_desc
,s_store_id
,s_store_name
,min(ss_net_profit) as store_sales_profit
,min(sr_net_loss) as store_returns_loss
,min(cs_net_profit) as catalog_sales_profit
from store_sales
,store_returns
,catalog_sales
,date_dim d1
,date_dim d2
,date_dim d3
,store
,item
where d1.d_moy = 4 and d1.d_year = 2001 and d1.d_date_sk = ss_sold_date_sk
and i_item_sk = ss_item_sk
and s_store_sk = ss_store_sk
and ss_customer_sk = sr_customer_sk
and ss_item_sk = sr_item_sk
and ss_ticket_number = sr_ticket_number
and sr_returned_date_sk = d2.d_date_sk
and d2.d_moy between 4 and  10 and d2.d_year = 2001 and sr_customer_sk = cs_bill_customer_sk
and sr_item_sk = cs_item_sk
and cs_sold_date_sk = d3.d_date_sk
and d3.d_moy between 4 and  10 and d3.d_year = 2001 group by i_item_id
,i_item_desc
,s_store_id
,s_store_name
order by i_item_id
,i_item_desc
,s_store_id
,s_store_name
limit 100;
