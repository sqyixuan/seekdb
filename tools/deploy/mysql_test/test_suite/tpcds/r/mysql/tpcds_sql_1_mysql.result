       0)) / cast(CASE WHEN VIEW2.T_FUN_COUNT(inventory.inv_quantity_on_hand) - 1 != 0 THEN VIEW2.T_FUN_COUNT(inventory.inv_quantity_on_hand) - 1 ELSE NULL END,
