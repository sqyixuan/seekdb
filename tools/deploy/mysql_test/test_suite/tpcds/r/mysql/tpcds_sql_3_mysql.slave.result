and 2+2)
and not exists (select * from catalog_sales,date_dim
where c.c_customer_sk = cs_ship_customer_sk
and cs_sold_date_sk = d_date_sk
and d_year = 2002
and d_moy between 2 and 2+2))
group by cd_gender,
cd_marital_status,
cd_education_status,
cd_purchase_estimate,
cd_credit_rating
order by cd_gender,
cd_marital_status,
cd_education_status,
cd_purchase_estimate,
cd_credit_rating
limit 100;
