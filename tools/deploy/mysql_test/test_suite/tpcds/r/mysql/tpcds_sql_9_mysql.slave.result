      range_key([d1.d_date_sk]), range(MIN ; MAX)always true
 19 - output([d2.d_date_sk], [d2.d_week_seq]), filter(nil), rowset=256
      access([d2.d_date_sk], [d2.d_week_seq]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([d2.d_date_sk]), range(MIN ; MAX)always true
 20 - output([inventory.inv_warehouse_sk]), filter([inventory.inv_quantity_on_hand < :35]), rowset=256
      access([GROUP_ID], [inventory.inv_warehouse_sk], [inventory.inv_quantity_on_hand]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_warehouse_sk]), range(MIN ; MAX), 
      range_cond([:36 = inventory.inv_item_sk], [inventory.inv_date_sk = :37])
 21 - output(nil), filter([customer_demographics.cd_marital_status = 'U']), rowset=256
      access([GROUP_ID], [customer_demographics.cd_marital_status]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([customer_demographics.cd_demo_sk]), range(MIN ; MAX), 
      range_cond([:6 = customer_demographics.cd_demo_sk])
 22 - output([warehouse.w_warehouse_name]), filter(nil), rowset=256
      access([GROUP_ID], [warehouse.w_warehouse_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([warehouse.w_warehouse_sk]), range(MIN ; MAX), 
      range_cond([warehouse.w_warehouse_sk = :15])
 23 - output([promotion.p_promo_sk]), filter(nil), rowset=256
      access([GROUP_ID], [promotion.p_promo_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([promotion.p_promo_sk]), range(MIN ; MAX), 
      range_cond([:14 = promotion.p_promo_sk])
select /*TPC-DS Q87*/ i_item_desc
,w_warehouse_name
,d1.d_week_seq
,sum(case when p_promo_sk is null then 1 else 0 end) no_promo
,sum(case when p_promo_sk is not null then 1 else 0 end) promo
,count(*) total_cnt
from catalog_sales
join inventory on (cs_item_sk = inv_item_sk)
join warehouse on (w_warehouse_sk=inv_warehouse_sk)
join item on (i_item_sk = cs_item_sk)
join customer_demographics on (cs_bill_cdemo_sk = cd_demo_sk)
join household_demographics on (cs_bill_hdemo_sk = hd_demo_sk)
join date_dim d1 on (cs_sold_date_sk = d1.d_date_sk)
join date_dim d2 on (inv_date_sk = d2.d_date_sk)
join date_dim d3 on (cs_ship_date_sk = d3.d_date_sk)
left outer join promotion on (cs_promo_sk=p_promo_sk)
left outer join catalog_returns on (cr_item_sk = cs_item_sk and cr_order_number = cs_order_number)
where d1.d_week_seq = d2.d_week_seq
and inv_quantity_on_hand < cs_quantity
and d3.d_date > d1.d_date + 5  and hd_buy_potential = '>10000'  and d1.d_year = 1999  and cd_marital_status = 'U'group by i_item_desc,w_warehouse_name,d1.d_week_seq
order by total_cnt desc, i_item_desc, w_warehouse_name, d1.d_week_seq
limit 100;
+-------------+------------------+------------+----------+-------+-----------+
| i_item_desc | w_warehouse_name | d_week_seq | no_promo | promo | total_cnt |
+-------------+------------------+------------+----------+-------+-----------+
+-------------+------------------+------------+----------+-------+-----------+


********************** TPC_DS Q88
EXPLAIN select /*TPC-DS Q88*/ * from (select i_manufact_id,
sum(ss_sales_price) sum_sales,
avg(sum(ss_sales_price)) over (partition by i_manufact_id) avg_quarterly_sales
from item, store_sales, date_dim, store
where ss_item_sk = i_item_sk and ss_sold_date_sk = d_date_sk and ss_store_sk = s_store_sk and d_month_seq in (1183,1183+1,1183+2,1183+3,1183+4,1183+5,1183+6,1183+7,1183+8,1183+9,1183+10,1183+11) and((i_category in ('Books','Children','Electronics') and i_class in ('personal','portable','reference','self-help') and i_brand in ('scholaramalgamalg #14','scholaramalgamalg #7',
'exportiunivamalg #9','scholaramalgamalg #9'))
or(i_category in ('Women','Music','Men') and i_class in ('accessories','classical','fragrances','pants') and i_brand in ('amalgimporto #1','edu packscholar #1','exportiimporto #1',
'importoamalg #1')))
group by i_manufact_id, d_qoy ) tmp1
where case when avg_quarterly_sales > 0 then abs (sum_sales - avg_quarterly_sales)/ avg_quarterly_sales
else null end > 0.1order by avg_quarterly_sales,
sum_sales,
i_manufact_id
limit 100;
Query Plan
=========================================================================================
|ID|OPERATOR                                          |NAME       |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                                |           |1       |27          |
|1 |└─EXCHANGE OUT REMOTE                             |           |1       |27          |
|2 |  └─TOP-N SORT                                    |           |1       |27          |
|3 |    └─SUBPLAN SCAN                                |tmp1       |1       |27          |
|4 |      └─WINDOW FUNCTION                           |           |1       |27          |
|5 |        └─MERGE GROUP BY                          |           |1       |27          |
|6 |          └─SORT                                  |           |1       |27          |
|7 |            └─NESTED-LOOP JOIN                    |           |1       |27          |
|8 |              ├─MERGE JOIN                        |           |1       |23          |
|9 |              │ ├─TABLE FULL SCAN                 |store      |12      |3           |
|10|              │ └─SORT                            |           |1       |20          |
|11|              │   └─NESTED-LOOP JOIN              |           |1       |20          |
|12|              │     ├─TABLE FULL SCAN             |item       |1       |17          |
|13|              │     └─DISTRIBUTED TABLE RANGE SCAN|store_sales|2       |16          |
|14|              └─DISTRIBUTED TABLE GET             |date_dim   |1       |16          |
=========================================================================================
Outputs & filters:
-------------------------------------
  0 - output([tmp1.i_manufact_id], [tmp1.sum_sales], [tmp1.avg_quarterly_sales]), filter(nil)
  1 - output([tmp1.i_manufact_id], [tmp1.sum_sales], [tmp1.avg_quarterly_sales]), filter(nil)
  2 - output([tmp1.i_manufact_id], [tmp1.sum_sales], [tmp1.avg_quarterly_sales]), filter(nil), rowset=256
      sort_keys([tmp1.avg_quarterly_sales, ASC], [tmp1.sum_sales, ASC], [tmp1.i_manufact_id, ASC]), topn(100)
  3 - output([tmp1.avg_quarterly_sales], [tmp1.sum_sales], [tmp1.i_manufact_id]), filter([CASE WHEN tmp1.avg_quarterly_sales > cast(0, DECIMAL(1, 0)) THEN 
      abs(tmp1.sum_sales - tmp1.avg_quarterly_sales) / tmp1.avg_quarterly_sales ELSE NULL END > 0.1]), rowset=256
      access([tmp1.avg_quarterly_sales], [tmp1.sum_sales], [tmp1.i_manufact_id])
  4 - output([item.i_manufact_id], [T_FUN_SUM(store_sales.ss_sales_price)], [T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price)) / cast(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price)),
       DECIMAL(20, 0))]), filter(nil), rowset=256
      win_expr(T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_manufact_id]), order_by(nil), window_type(RANGE), upper(UNBOUNDED 
      PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_manufact_id]), order_by(nil), window_type(RANGE), upper(UNBOUNDED 
      PRECEDING), lower(UNBOUNDED FOLLOWING)
  5 - output([T_FUN_SUM(store_sales.ss_sales_price)], [item.i_manufact_id]), filter(nil), rowset=256
      group([item.i_manufact_id], [date_dim.d_qoy]), agg_func([T_FUN_SUM(store_sales.ss_sales_price)])
  6 - output([item.i_manufact_id], [date_dim.d_qoy], [store_sales.ss_sales_price]), filter(nil), rowset=256
      sort_keys([item.i_manufact_id, ASC], [date_dim.d_qoy, ASC])
  7 - output([item.i_manufact_id], [date_dim.d_qoy], [store_sales.ss_sales_price]), filter(nil), rowset=256
      conds(nil), nl_params_([store_sales.ss_sold_date_sk(:2)]), use_batch=true
  8 - output([item.i_manufact_id], [store_sales.ss_sold_date_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
      merge_directions([ASC])
  9 - output([store.s_store_sk]), filter(nil), rowset=256
      access([store.s_store_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
 10 - output([item.i_manufact_id], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      sort_keys([store_sales.ss_store_sk, ASC])
 11 - output([item.i_manufact_id], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      conds(nil), nl_params_([item.i_item_sk(:0)]), use_batch=true
 12 - output([item.i_item_sk], [item.i_manufact_id]), filter([(T_OP_AND, item.i_category IN ('Books', 'Children', 'Electronics'), item.i_class IN ('personal',
       'portable', 'reference', 'self-help'), item.i_brand IN ('scholaramalgamalg #14', 'scholaramalgamalg #7', 'exportiunivamalg #9', 'scholaramalgamalg #9')) 
      OR (T_OP_AND, item.i_category IN ('Women', 'Music', 'Men'), item.i_class IN ('accessories', 'classical', 'fragrances', 'pants'), item.i_brand IN ('amalgimporto 
      #1', 'edu packscholar #1', 'exportiimporto #1', 'importoamalg #1'))]), rowset=256
      access([item.i_item_sk], [item.i_category], [item.i_class], [item.i_brand], [item.i_manufact_id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 13 - output([store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), filter(nil), rowset=256
      access([GROUP_ID], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_sales_price]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN ; MAX), 
      range_cond([store_sales.ss_item_sk = :0])
 14 - output([date_dim.d_qoy]), filter([date_dim.d_month_seq IN (1183, 1183 + 1, 1183 + 2, 1183 + 3, 1183 + 4, 1183 + 5, 1183 + 6, 1183 + 7, 1183 + 8, 1183 
      + 9, 1183 + 10, 1183 + 11)]), rowset=256
      access([GROUP_ID], [date_dim.d_month_seq], [date_dim.d_qoy]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX), 
      range_cond([:2 = date_dim.d_date_sk])
