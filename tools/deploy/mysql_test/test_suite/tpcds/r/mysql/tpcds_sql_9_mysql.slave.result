       [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_promo_sk], [catalog_sales.cs_bill_cdemo_sk]), filter(nil), rowset=256
      equal_conds([catalog_sales.cs_item_sk = item.i_item_sk]), other_conds(nil)
      merge_directions([ASC])
