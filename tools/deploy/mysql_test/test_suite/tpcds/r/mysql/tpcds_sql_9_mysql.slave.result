|ID|OPERATOR                       |NAME                  |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE             |                      |100     |2949        |
|1 |└─EXCHANGE OUT REMOTE          |                      |100     |2849        |
|2 |  └─TOP-N SORT                 |                      |100     |2625        |
|3 |    └─HASH GROUP BY            |                      |596     |2438        |
|4 |      └─HASH JOIN              |                      |596     |2074        |
|5 |        ├─HASH JOIN            |                      |625     |1702        |
|6 |        │ ├─TABLE FULL SCAN    |store                 |12      |4           |
|7 |        │ └─HASH JOIN          |                      |656     |1641        |
|8 |        │   ├─TABLE FULL SCAN  |household_demographics|200     |29          |
|9 |        │   └─HASH JOIN        |                      |1363    |1452        |
|10|        │     ├─TABLE FULL SCAN|date_dim              |100     |62          |
|11|        │     └─TABLE FULL SCAN|store_sales           |5000    |949         |
|12|        └─TABLE FULL SCAN      |customer              |1000    |56          |
=================================================================================
Outputs & filters:
-------------------------------------
  0 - output([customer.c_last_name], [customer.c_first_name], [substr(store.s_city, 1, 30)], [store_sales.ss_ticket_number], [T_FUN_SUM(store_sales.ss_coupon_amt)],
       [T_FUN_SUM(store_sales.ss_net_profit)]), filter(nil)
  1 - output([customer.c_last_name], [customer.c_first_name], [substr(store.s_city, 1, 30)], [store_sales.ss_ticket_number], [T_FUN_SUM(store_sales.ss_coupon_amt)],
       [T_FUN_SUM(store_sales.ss_net_profit)]), filter(nil)
  2 - output([customer.c_last_name], [customer.c_first_name], [substr(store.s_city, 1, 30)], [store_sales.ss_ticket_number], [T_FUN_SUM(store_sales.ss_coupon_amt)],
       [T_FUN_SUM(store_sales.ss_net_profit)]), filter(nil), rowset=256
      sort_keys([customer.c_last_name, ASC], [customer.c_first_name, ASC], [substr(store.s_city, 1, 30), ASC], [T_FUN_SUM(store_sales.ss_net_profit), ASC]),
       topn(100)
  3 - output([customer.c_last_name], [customer.c_first_name], [substr(store.s_city, 1, 30)], [store_sales.ss_ticket_number], [T_FUN_SUM(store_sales.ss_coupon_amt)],
       [T_FUN_SUM(store_sales.ss_net_profit)]), filter(nil), rowset=256
      group([customer.c_customer_sk], [store_sales.ss_ticket_number], [store_sales.ss_addr_sk], [store.s_city]), agg_func([T_FUN_SUM(store_sales.ss_coupon_amt)],
       [T_FUN_SUM(store_sales.ss_net_profit)])
  4 - output([customer.c_last_name], [customer.c_first_name], [store_sales.ss_ticket_number], [customer.c_customer_sk], [store_sales.ss_addr_sk], [store.s_city],
       [store_sales.ss_coupon_amt], [store_sales.ss_net_profit]), filter(nil), rowset=256
      equal_conds([store_sales.ss_customer_sk = customer.c_customer_sk]), other_conds(nil)
  5 - output([store_sales.ss_ticket_number], [store_sales.ss_addr_sk], [store.s_city], [store_sales.ss_customer_sk], [store_sales.ss_coupon_amt], [store_sales.ss_net_profit]), filter(nil), rowset=256
      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
  6 - output([store.s_store_sk], [store.s_city]), filter([store.s_number_employees >= 200], [store.s_number_employees <= 295]), rowset=256
      access([store.s_store_sk], [store.s_number_employees], [store.s_city]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
  7 - output([store_sales.ss_ticket_number], [store_sales.ss_addr_sk], [store_sales.ss_store_sk], [store_sales.ss_customer_sk], [store_sales.ss_coupon_amt],
       [store_sales.ss_net_profit]), filter(nil), rowset=256
      equal_conds([store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk]), other_conds(nil)
  8 - output([household_demographics.hd_demo_sk]), filter([household_demographics.hd_dep_count = 1 OR household_demographics.hd_vehicle_count > -1]), rowset=256
      access([household_demographics.hd_demo_sk], [household_demographics.hd_dep_count], [household_demographics.hd_vehicle_count]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([household_demographics.hd_demo_sk]), range(MIN ; MAX)always true
  9 - output([store_sales.ss_ticket_number], [store_sales.ss_addr_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk],
       [store_sales.ss_coupon_amt], [store_sales.ss_net_profit]), filter(nil), rowset=256
      equal_conds([store_sales.ss_sold_date_sk = date_dim.d_date_sk]), other_conds(nil)
 10 - output([date_dim.d_date_sk]), filter([date_dim.d_dow = 1], [date_dim.d_year IN (2000, 2000 + 1, 2000 + 2)]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_dow], [date_dim.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
 11 - output([store_sales.ss_ticket_number], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk],
       [store_sales.ss_coupon_amt], [store_sales.ss_net_profit], [store_sales.ss_addr_sk]), filter(nil), rowset=256
      access([store_sales.ss_ticket_number], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk],
       [store_sales.ss_coupon_amt], [store_sales.ss_net_profit], [store_sales.ss_addr_sk]), p
      artitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
 12 - output([customer.c_customer_sk], [customer.c_last_name], [customer.c_first_name]), filter(nil), rowset=256
      access([customer.c_customer_sk], [customer.c_last_name], [customer.c_first_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([customer.c_customer_sk]), range(MIN ; MAX)always true
select /*TPC-DS Q89*/ c_last_name,c_first_name,substr(s_city,1,30),ss_ticket_number,amt,profit
from (select ss_ticket_number
,ss_customer_sk
,store.s_city
,sum(ss_coupon_amt) amt
,sum(ss_net_profit) profit
from store_sales,date_dim,store,household_demographics
where store_sales.ss_sold_date_sk = date_dim.d_date_sk
and store_sales.ss_store_sk = store.s_store_sk
and store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk
and (household_demographics.hd_dep_count = 1 or household_demographics.hd_vehicle_count > -1)
and date_dim.d_dow = 1 and date_dim.d_year in (2000,2000+1,2000+2)
and store.s_number_employees between 200 and 295 group by ss_ticket_number,ss_customer_sk,ss_addr_sk,store.s_city) ms,customer
where ss_customer_sk = c_customer_sk
order by c_last_name,c_first_name,substr(s_city,1,30), profit
limit 100;
