      equal_conds([store_sales.ss_store_sk = store.s_store_sk]), other_conds(nil)
  9 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
 10 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      dop=2
 11 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      equal_conds([store_sales.ss_sold_date_sk = date_dim.d_date_sk]), other_conds(nil)
 12 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
 13 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      dop=2
 14 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      equal_conds([store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk]), other_conds(nil)
 15 - output([household_demographics.hd_demo_sk]), filter(nil), rowset=256
 16 - output([household_demographics.hd_demo_sk]), filter(nil), rowset=256
      dop=2
 17 - output([household_demographics.hd_demo_sk]), filter(nil), rowset=256
 18 - output([household_demographics.hd_demo_sk]), filter([household_demographics.hd_buy_potential = '>10000' OR household_demographics.hd_buy_potential 
      = '5001-10000'], [CASE WHEN household_demographics.hd_vehicle_count > 0 THEN cast(household_demographics.hd_dep_count, DECIMAL_INT(34, 23)) / cast(household_demographics.hd_vehicle_count,
       DECIMAL_INT(11, 0)) ELSE NULL END > cast(1, DECIMAL(20, 0))], [household_demographics.hd_vehicle_count > 0]), rowset=256
      access([household_demographics.hd_demo_sk], [household_demographics.hd_buy_potential], [household_demographics.hd_vehicle_count], [household_demographics.hd_dep_count]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([household_demographics.hd_demo_sk]), range(MIN ; MAX)always true
 19 - output([store_sales.ss_ticket_number], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk]), filter(nil), rowset=256
 20 - output([store_sales.ss_ticket_number], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk]), filter(nil), rowset=256
      access([store_sales.ss_ticket_number], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_customer_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
 21 - output([date_dim.d_date_sk]), filter(nil), rowset=256
 22 - output([date_dim.d_date_sk]), filter([date_dim.d_dom <= 2], [date_dim.d_dom >= 1], [date_dim.d_year IN (1999, 1999 + 1, 1999 + 2)]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_dom], [date_dim.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
 23 - output([store.s_store_sk]), filter(nil), rowset=256
 24 - output([store.s_store_sk]), filter([store.s_county IN ('Williamson County', 'Williamson County', 'Williamson County', 'Williamson County')]), rowset=256
      access([store.s_store_sk], [store.s_county]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
 25 - output([customer.c_customer_sk], [customer.c_last_name], [customer.c_first_name], [customer.c_salutation], [customer.c_preferred_cust_flag]), filter(nil), rowset=256
      access([GROUP_ID], [customer.c_customer_sk], [customer.c_last_name], [customer.c_first_name], [customer.c_salutation], [customer.c_preferred_cust_flag]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([customer.c_customer_sk]), range(MIN ; MAX), 
      range_cond([:0 = customer.c_customer_sk])
select /*+parallel(2) TPC-DS Q79*/ c_last_name
,c_first_name
,c_salutation
,c_preferred_cust_flag
,ss_ticket_number
,cnt from (select ss_ticket_number
,ss_customer_sk
,count(*) cnt
from store_sales,date_dim,store,household_demographics
where store_sales.ss_sold_date_sk = date_dim.d_date_sk
and store_sales.ss_store_sk = store.s_store_sk
and store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk
and date_dim.d_dom between 1 and 2 and (household_demographics.hd_buy_potential = '>10000' or household_demographics.hd_buy_potential = '5001-10000')
and household_demographics.hd_vehicle_count > 0 and case when household_demographics.hd_vehicle_count > 0 then household_demographics.hd_dep_count/ household_demographics.hd_vehicle_count else null end > 1 and date_dim.d_year in (1999,1999+1,1999+2)
and store.s_county in ('Williamson County','Williamson County','Williamson County','Williamson County')
group by ss_ticket_number,ss_customer_sk) dj,customer
where ss_customer_sk = c_customer_sk
and cnt between 1 and 5
order by cnt desc, c_last_name asc;
