 36 - output([VIEW1.T_FUN_SUM(store_sales.ss_sales_price)], [VIEW1.store_sales.ss_store_sk], [VIEW1.store_sales.ss_item_sk]), filter(nil), rowset=256
      access([VIEW1.T_FUN_SUM(store_sales.ss_sales_price)], [VIEW1.store_sales.ss_store_sk], [VIEW1.store_sales.ss_item_sk])
