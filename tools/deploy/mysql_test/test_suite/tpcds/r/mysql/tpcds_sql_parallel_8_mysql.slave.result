********************** TPC_DS Q76
EXPLAIN select /*+parallel(2) TPC-DS Q76*/ t_s_secyear.customer_id, t_s_secyear.customer_first_name, t_s_secyear.customer_last_name
from (
select c_customer_id customer_id
,c_first_name customer_first_name
,c_last_name customer_last_name
,d_year as year
,sum(ss_net_paid) year_total
,'s' sale_type
from customer
,store_sales
,date_dim
where c_customer_sk = ss_customer_sk
and ss_sold_date_sk = d_date_sk
and d_year in (2000,2000+1)
group by c_customer_id
,c_first_name
,c_last_name
,d_year
union all select c_customer_id customer_id
,c_first_name customer_first_name
,c_last_name customer_last_name
,d_year as year
,sum(ws_net_paid) year_total
,'w' sale_type
from customer
,web_sales
,date_dim
where c_customer_sk = ws_bill_customer_sk
and ws_sold_date_sk = d_date_sk
and d_year in (2000,2000+1)
group by c_customer_id
,c_first_name
,c_last_name
,d_year
)
as  t_s_firstyear
,(
select c_customer_id customer_id
,c_first_name customer_first_name
,c_last_name customer_last_name
,d_year as year
,sum(ss_net_paid) year_total
,'s' sale_type
from customer
,store_sales
,date_dim
where c_customer_sk = ss_customer_sk
and ss_sold_date_sk = d_date_sk
and d_year in (2000,2000+1)
group by c_customer_id
,c_first_name
,c_last_name
,d_year
union all select c_customer_id customer_id
,c_first_name customer_first_name
,c_last_name customer_last_name
