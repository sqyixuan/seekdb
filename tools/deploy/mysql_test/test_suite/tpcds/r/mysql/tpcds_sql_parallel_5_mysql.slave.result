select /*+parallel(2) TPC-DS Q46*/* from (select item_sk
,d_date
,web_sales
,store_sales
,max(web_sales)
over (partition by item_sk order by d_date rows between unbounded preceding and current row) web_cumulative
,max(store_sales)
over (partition by item_sk order by d_date rows between unbounded preceding and current row) store_cumulative
from (select case when web.item_sk is not null then web.item_sk else store.item_sk end item_sk
,case when web.d_date is not null then web.d_date else store.d_date end d_date
,web.cume_sales web_sales
,store.cume_sales store_sales
from (
select ws_item_sk item_sk, d_date,
sum(sum(ws_sales_price))
over (partition by ws_item_sk order by d_date rows between unbounded preceding and current row) cume_sales
from web_sales
,date_dim
where ws_sold_date_sk=d_date_sk
and d_month_seq between 1201 and 1201+11 and ws_item_sk is not NULL group by ws_item_sk, d_date) as web full outer join (
select ss_item_sk item_sk, d_date,
sum(sum(ss_sales_price))
over (partition by ss_item_sk order by d_date rows between unbounded preceding and current row) cume_sales
from store_sales
,date_dim
where ss_sold_date_sk=d_date_sk
and d_month_seq between 1201 and 1201+11  and ss_item_sk is not NULL group by ss_item_sk, d_date) as store on (web.item_sk = store.item_sk
and web.d_date = store.d_date)
)x )y
where web_cumulative > store_cumulative
order by item_sk
,d_date
limit 100;
+---------+--------+-----------+-------------+----------------+------------------+
| item_sk | d_date | web_sales | store_sales | web_cumulative | store_cumulative |
+---------+--------+-----------+-------------+----------------+------------------+
+---------+--------+-----------+-------------+----------------+------------------+


********************** TPC_DS Q47
EXPLAIN select /*+parallel(2) TPC-DS Q47*/ ca_state,
cd_gender,
cd_marital_status,
cd_dep_count,
count(*) cnt1,
stddev_samp(cd_dep_count),
min(cd_dep_count),
cd_dep_employed_count,
count(*) cnt2,
stddev_samp(cd_dep_employed_count),
min(cd_dep_employed_count),
cd_dep_college_count,
count(*) cnt3,
stddev_samp(cd_dep_college_count),
min(cd_dep_college_count)
from  customer c,customer_address ca,customer_demographics
where  c.c_current_addr_sk = ca.ca_address_sk and  cd_demo_sk = c.c_current_cdemo_sk and  exists (select *
from store_sales,date_dim
where c.c_customer_sk = ss_customer_sk and
ss_sold_date_sk = d_date_sk and
d_year = 1999 and
d_qoy < 4) and (exists (select *
from web_sales,date_dim
where c.c_customer_sk = ws_bill_customer_sk and
ws_sold_date_sk = d_date_sk and
d_year = 1999 and
d_qoy < 4) or
exists (select *
from catalog_sales,date_dim
where c.c_customer_sk = cs_ship_customer_sk and
cs_sold_date_sk = d_date_sk and
d_year = 1999 and
d_qoy < 4))
group by ca_state,
cd_gender,
cd_marital_status,
cd_dep_count,
cd_dep_employed_count,
cd_dep_college_count
order by ca_state,
cd_gender,
cd_marital_status,
cd_dep_count,
cd_dep_employed_count,
cd_dep_college_count
limit 100;
