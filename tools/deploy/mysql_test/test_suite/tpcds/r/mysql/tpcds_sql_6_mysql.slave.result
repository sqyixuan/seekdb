       DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price END)]), filter(nil)
  1 - output([store_sales.ss_customer_sk], [T_FUN_SUM(CASE WHEN store_returns.sr_return_quantity IS NOT NULL THEN cast(store_sales.ss_quantity - store_returns.sr_return_quantity,
       DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price END)]), filter(nil)
  2 - output([store_sales.ss_customer_sk], [T_FUN_SUM(CASE WHEN store_returns.sr_return_quantity IS NOT NULL THEN cast(store_sales.ss_quantity - store_returns.sr_return_quantity,
       DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price END)]), filter(nil), rowset=256
      sort_keys([T_FUN_SUM(CASE WHEN store_returns.sr_return_quantity IS NOT NULL THEN cast(store_sales.ss_quantity - store_returns.sr_return_quantity, 
      DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price END), ASC], [store_sales.ss_customer_sk,
       ASC]), topn(100)
  3 - output([store_sales.ss_customer_sk], [T_FUN_SUM(CASE WHEN store_returns.sr_return_quantity IS NOT NULL THEN cast(store_sales.ss_quantity - store_returns.sr_return_quantity,
       DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price END)]), filter(nil), rowset=256
      group([store_sales.ss_customer_sk]), agg_func([T_FUN_SUM(CASE WHEN store_returns.sr_return_quantity IS NOT NULL THEN cast(store_sales.ss_quantity 
      - store_returns.sr_return_quantity, DECIMAL(12, 0)) * store_sales.ss_sales_price ELSE cast(store_sales.ss_quantity, DECIMAL(11, 0)) * store_sales.ss_sales_price 
      END)])
  4 - output([store_sales.ss_customer_sk], [store_returns.sr_return_quantity], [store_sales.ss_quantity], [store_sales.ss_sales_price]), filter(nil), rowset=256
      equal_conds([store_returns.sr_item_sk = store_sales.ss_item_sk], [store_returns.sr_ticket_number = store_sales.ss_ticket_number]), other_conds(nil)
  5 - output([store_returns.sr_return_quantity], [store_returns.sr_item_sk], [store_returns.sr_ticket_number]), filter(nil), rowset=256
