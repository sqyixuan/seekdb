---------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                              |           |2       |205         |
|1 |└─EXCHANGE OUT REMOTE                           |           |2       |201         |
|2 |  └─TOP-N SORT                                  |           |2       |193         |
|3 |    └─SUBPLAN SCAN                              |tmp1       |2       |192         |
|4 |      └─WINDOW FUNCTION                         |           |5       |192         |
|5 |        └─MERGE GROUP BY                        |           |5       |184         |
|6 |          └─SORT                                |           |5       |183         |
|7 |            └─NESTED-LOOP JOIN                  |           |5       |181         |
|8 |              ├─HASH JOIN                       |           |6       |97          |
|9 |              │ ├─NESTED-LOOP JOIN              |           |6       |91          |
|10|              │ │ ├─TABLE FULL SCAN             |item       |5       |14          |
|11|              │ │ └─DISTRIBUTED TABLE RANGE SCAN|store_sales|2       |16          |
|12|              │ └─TABLE FULL SCAN               |store      |12      |3           |
|13|              └─DISTRIBUTED TABLE GET           |date_dim   |1       |16          |
=======================================================================================
Outputs & filters:
-------------------------------------
  0 - output([tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], [tmp1.d_moy], [tmp1.sum_sales], [tmp1.avg_monthly_sales]), filter(nil)
  1 - output([tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], [tmp1.d_moy], [tmp1.sum_sales], [tmp1.avg_monthly_sales]), filter(nil)
  2 - output([tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], [tmp1.d_moy], [tmp1.sum_sales], [tmp1.avg_monthly_sales]), filter(nil), rowset=256
      sort_keys([tmp1.sum_sales - tmp1.avg_monthly_sales, ASC], [tmp1.s_store_name, ASC]), topn(100)
  3 - output([tmp1.avg_monthly_sales], [tmp1.sum_sales], [tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], 
      [tmp1.d_moy], [tmp1.sum_sales - tmp1.avg_monthly_sales]), f
      ilter([CASE WHEN tmp1.avg_monthly_sales != cast(0, DECIMAL(1, 0)) THEN abs(tmp1.sum_sales - tmp1.avg_monthly_sales) / tmp1.avg_monthly_sales ELSE NULL END 
      > 0.1]), rowset=256
      access([tmp1.avg_monthly_sales], [tmp1.sum_sales], [tmp1.i_category], [tmp1.i_class], [tmp1.i_brand], [tmp1.s_store_name], [tmp1.s_company_name], 
      [tmp1.d_moy])
  4 - output([item.i_category], [item.i_class], [item.i_brand], [store.s_store_name], [store.s_company_name], [date_dim.d_moy], [T_FUN_SUM(store_sales.ss_sales_price)],
       [T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price)) / cast(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price)), DECIMAL(20, 0))]), filter(nil), rowset=256
      win_expr(T_FUN_SUM(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name]),
       order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(T_FUN_SUM(store_sales.ss_sales_price))), partition_by([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name]),
       order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  5 - output([T_FUN_SUM(store_sales.ss_sales_price)], [item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy]), filter(nil), rowset=256
      group([item.i_category], [item.i_brand], [store.s_store_name], [store.s_company_name], [item.i_class], [date_dim.d_moy]), agg_func([T_FUN_SUM(store_sales.ss_sales_price)])
