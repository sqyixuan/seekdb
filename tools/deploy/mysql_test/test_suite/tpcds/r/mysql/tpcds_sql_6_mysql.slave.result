  6 - output([reason.r_reason_sk]), filter([reason.r_reason_desc = 'Did not like the warranty']), rowset=256
      access([reason.r_reason_sk], [reason.r_reason_desc]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([reason.r_reason_sk]), range(MIN ; MAX)always true
  7 - output([store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_reason_sk], [store_returns.sr_return_quantity]), filter(nil), rowset=256
      access([store_returns.sr_item_sk], [store_returns.sr_ticket_number], [store_returns.sr_reason_sk], [store_returns.sr_return_quantity]), partitions(p0)
