      access([store.s_store_sk], [store.s_store_id], [store.s_store_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store.s_store_sk]), range(MIN ; MAX)always true
 36 - output([catalog_sales.cs_sold_date_sk], [catalog_sales.cs_quantity]), filter([:4 = catalog_sales.cs_bill_customer_sk]), rowset=256
      access([GROUP_ID], [catalog_sales.cs_bill_customer_sk], [catalog_sales.cs_sold_date_sk], [catalog_sales.cs_quantity]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([catalog_sales.cs_item_sk], [catalog_sales.cs_order_number]), range(MIN ; MAX), 
      range_cond([:3 = catalog_sales.cs_item_sk])
 37 - output(nil), filter([d3.d_year IN (1998, 1998 + 1, 1998 + 2)]), rowset=256
      access([GROUP_ID], [d3.d_year]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([d3.d_date_sk]), range(MIN ; MAX), 
      range_cond([:5 = d3.d_date_sk])
select /*+parallel(2) TPC-DS Q53*/ i_item_id
,i_item_desc
,s_store_id
,s_store_name
,max(ss_quantity) as store_sales_quantity
,max(sr_return_quantity) as store_returns_quantity
,max(cs_quantity) as catalog_sales_quantity
from store_sales
,store_returns
,catalog_sales
,date_dim d1
,date_dim d2
,date_dim d3
,store
,item
where d1.d_moy = 4
and d1.d_year = 1998
and d1.d_date_sk = ss_sold_date_sk
and i_item_sk = ss_item_sk
and s_store_sk = ss_store_sk
and ss_customer_sk = sr_customer_sk
and ss_item_sk = sr_item_sk
and ss_ticket_number = sr_ticket_number
and sr_returned_date_sk = d2.d_date_sk
and d2.d_moy between 4 and  4 + 3
and d2.d_year = 1998
and sr_customer_sk = cs_bill_customer_sk
and sr_item_sk = cs_item_sk
and cs_sold_date_sk = d3.d_date_sk
and d3.d_year in (1998,1998+1,1998+2)
group by  i_item_id
,i_item_desc
,s_store_id
,s_store_name
order by i_item_id
,i_item_desc
,s_store_id
,s_store_name
limit 100;
