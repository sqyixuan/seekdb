      = :0]), rowset=256
      access([GROUP_ID], [store_sales.ss_item_sk], [store_sales.ss_sold_date_sk], [store_sales.ss_store_sk], [store_sales.ss_customer_sk], [store_sales.ss_quantity]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
