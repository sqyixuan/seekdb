      group([call_center.cc_call_center_id], [call_center.cc_name], [call_center.cc_manager], [customer_demographics.cd_marital_status], [customer_demographics.cd_education_status]),
       agg_func([T_FUN_SUM(catalog_returns.cr_net_loss)])
