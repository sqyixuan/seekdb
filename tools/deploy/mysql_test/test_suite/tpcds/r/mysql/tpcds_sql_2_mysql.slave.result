      access([customer.c_customer_sk], [customer.c_current_cdemo_sk], [customer.c_current_hdemo_sk], [customer.c_current_addr_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([customer.c_customer_sk]), range(MIN ; MAX)always true
 14 - output([catalog_returns.cr_call_center_sk], [catalog_returns.cr_returned_date_sk], [catalog_returns.cr_returning_customer_sk], [catalog_returns.cr_net_loss]), filter(nil), rowset=256
      access([catalog_returns.cr_call_center_sk], [catalog_returns.cr_returned_date_sk], [catalog_returns.cr_returning_customer_sk], [catalog_returns.cr_net_loss]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([catalog_returns.cr_item_sk], [catalog_returns.cr_order_number]), range(MIN,MIN ; MAX,MAX)always true
