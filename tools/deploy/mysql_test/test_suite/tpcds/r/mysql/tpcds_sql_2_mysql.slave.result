select /*TPC-DS Q13*/ cc_call_center_id Call_Center,
cc_name Call_Center_Name,
cc_manager Manager,
sum(cr_net_loss) Returns_Loss
from    call_center,
catalog_returns,
date_dim,
customer,
customer_address,
customer_demographics,
