********************** TPC_DS Q14
EXPLAIN select  /*TPC-DS Q14*/*
from(select w_warehouse_name
,i_item_id
,sum(case when (cast(d_date as date) < cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_before
,sum(case when (cast(d_date as date) >= cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_after
from inventory
,warehouse
,item
,date_dim
where i_current_price between 0.99 and 1.49
and i_item_sk          = inv_item_sk
and inv_warehouse_sk   = w_warehouse_sk
and inv_date_sk    = d_date_sk
and d_date between (cast ('2000-04-19' as date))
and (cast ('2000-06-18' as date))
group by w_warehouse_name, i_item_id) x
where (case when inv_before > 0 then inv_after / inv_before
else null end) between 2.0/3.0 and 3.0/2.0 order by w_warehouse_name
,i_item_id
limit 100;
Query Plan
=================================================================================
|ID|OPERATOR                                    |NAME     |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                          |         |0       |914         |
|1 |└─EXCHANGE OUT REMOTE                       |         |0       |914         |
|2 |  └─LIMIT                                   |         |0       |914         |
|3 |    └─MERGE GROUP BY                        |         |0       |914         |
|4 |      └─SORT                                |         |0       |914         |
|5 |        └─NESTED-LOOP JOIN                  |         |0       |914         |
|6 |          ├─NESTED-LOOP JOIN                |         |0       |898         |
|7 |          │ ├─NESTED-LOOP JOIN              |         |0       |883         |
|8 |          │ │ ├─TABLE FULL SCAN             |date_dim |0       |30          |
|9 |          │ │ └─DISTRIBUTED TABLE RANGE SCAN|inventory|8000    |854         |
|10|          │ └─DISTRIBUTED TABLE GET         |warehouse|1       |16          |
|11|          └─DISTRIBUTED TABLE GET           |item     |1       |16          |
=================================================================================
Outputs & filters:
-------------------------------------
  0 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), filter(nil)
  1 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), filter(nil)
  2 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), filter(nil), rowset=256
      limit(100), offset(nil)
  3 - output([warehouse.w_warehouse_name], [item.i_item_id], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN 
      inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)]), f
      ilter([CASE WHEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END) 
      > cast(0, DECIMAL(1, 0)) THEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END) / T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END) ELSE 
      NULL END >= 2.0 / 3.0], [CASE WHEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END) > cast(0, DECIMAL(1, 0)) THEN T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END) / T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand ELSE 0 END) ELSE 
      NULL END <= 3.0 / 2.0]), rowset=256
      group([warehouse.w_warehouse_name], [item.i_item_id]), agg_func([T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) < cast('2000-05-19', DATE(0,
       0)) THEN inventory.inv_quantity_on_hand ELSE 0 END)], [T_FUN_SUM(CASE WHEN cast(date_dim.d_date, DATE(0, 0)) >= cast('2000-05-19', DATE(0, 0)) THEN inventory.inv_quantity_on_hand 
      ELSE 0 END)])
  4 - output([warehouse.w_warehouse_name], [item.i_item_id], [date_dim.d_date], [inventory.inv_quantity_on_hand]), filter(nil), rowset=256
      sort_keys([warehouse.w_warehouse_name, ASC], [item.i_item_id, ASC])
  5 - output([warehouse.w_warehouse_name], [item.i_item_id], [date_dim.d_date], [inventory.inv_quantity_on_hand]), filter(nil), rowset=256
      conds(nil), nl_params_([inventory.inv_item_sk(:2)]), use_batch=true
  6 - output([warehouse.w_warehouse_name], [date_dim.d_date], [inventory.inv_quantity_on_hand], [inventory.inv_item_sk]), filter(nil), rowset=256
      conds(nil), nl_params_([inventory.inv_warehouse_sk(:0)]), use_batch=true
  7 - output([date_dim.d_date], [inventory.inv_quantity_on_hand], [inventory.inv_item_sk], [inventory.inv_warehouse_sk]), filter(nil), rowset=256
      conds(nil), nl_params_([date_dim.d_date_sk(:5)]), use_batch=true
  8 - output([date_dim.d_date_sk], [date_dim.d_date]), filter([date_dim.d_date >= cast('2000-04-19', DATE(0, 0))], [date_dim.d_date <= cast('2000-06-18',
       DATE(0, 0))]), rowset=256
      access([date_dim.d_date_sk], [date_dim.d_date]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX)always true
  9 - output([inventory.inv_item_sk], [inventory.inv_warehouse_sk], [inventory.inv_quantity_on_hand]), filter(nil), rowset=256
      access([GROUP_ID], [inventory.inv_item_sk], [inventory.inv_warehouse_sk], [inventory.inv_quantity_on_hand]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([inventory.inv_date_sk], [inventory.inv_item_sk], [inventory.inv_warehouse_sk]), range(MIN ; MAX), 
      range_cond([inventory.inv_date_sk = :5])
 10 - output([warehouse.w_warehouse_name]), filter(nil), rowset=256
      access([GROUP_ID], [warehouse.w_warehouse_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([warehouse.w_warehouse_sk]), range(MIN ; MAX), 
      range_cond([:0 = warehouse.w_warehouse_sk])
 11 - output([item.i_item_id]), filter([item.i_current_price <= 1.49], [item.i_current_price >= 0.99]), rowset=256
      access([GROUP_ID], [item.i_current_price], [item.i_item_id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([item.i_item_sk]), range(MIN ; MAX), 
      range_cond([item.i_item_sk = :2])
select  /*TPC-DS Q14*/*
from(select w_warehouse_name
,i_item_id
,sum(case when (cast(d_date as date) < cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_before
,sum(case when (cast(d_date as date) >= cast ('2000-05-19' as date))
then inv_quantity_on_hand
else 0 end) as inv_after
from inventory
,warehouse
,item
,date_dim
where i_current_price between 0.99 and 1.49
and i_item_sk          = inv_item_sk
and inv_warehouse_sk   = w_warehouse_sk
and inv_date_sk    = d_date_sk
and d_date between (cast ('2000-04-19' as date))
and (cast ('2000-06-18' as date))
group by w_warehouse_name, i_item_id) x
where (case when inv_before > 0 then inv_after / inv_before
else null end) between 2.0/3.0 and 3.0/2.0 order by w_warehouse_name
,i_item_id
limit 100;
