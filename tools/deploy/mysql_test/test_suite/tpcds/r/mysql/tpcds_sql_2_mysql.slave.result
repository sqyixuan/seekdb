      access([GROUP_ID], [date_dim.d_year], [date_dim.d_moy]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([date_dim.d_date_sk]), range(MIN ; MAX), 
      range_cond([:2 = date_dim.d_date_sk])
 16 - output([customer_demographics.cd_marital_status], [customer_demographics.cd_education_status]), filter([customer_demographics.cd_marital_status = 
      'M' AND customer_demographics.cd_education_status = 'Unknown' OR customer_demographics.cd_marital_status = 'W' AND customer_demographics.cd_education_status 
      = 'Advanced Degree']), rowset=256
      access([GROUP_ID], [customer_demographics.cd_marital_status], [customer_demographics.cd_education_status]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([customer_demographics.cd_demo_sk]), range(MIN ; MAX), 
      range_cond([customer_demographics.cd_demo_sk = :8])
 17 - output([call_center.cc_call_center_id], [call_center.cc_name], [call_center.cc_manager]), filter(nil), rowset=256
      access([GROUP_ID], [call_center.cc_call_center_id], [call_center.cc_name], [call_center.cc_manager]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([call_center.cc_call_center_sk]), range(MIN ; MAX), 
