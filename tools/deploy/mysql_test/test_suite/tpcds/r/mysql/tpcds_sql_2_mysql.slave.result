      DECIMAL(20, 0)) * 1.2], [VIEW2.store_returns.sr_store_sk]), filter(nil), rowset=256
      group([VIEW2.store_returns.sr_store_sk]), agg_func([T_FUN_SUM(VIEW2.T_FUN_SUM(store_returns.sr_return_amt_inc_tax))], [T_FUN_COUNT(VIEW2.T_FUN_SUM(store_returns.sr_return_amt_inc_tax))])
