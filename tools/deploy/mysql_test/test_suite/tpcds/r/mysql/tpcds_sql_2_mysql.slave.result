  2 - output([T_FUN_SUM(web_sales.ws_net_paid)], [item.i_category], [item.i_class], [T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class)], [T_WIN_FUN_RANK()]), filter(nil), rowset=256
      sort_keys([T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class), DESC], [CASE WHEN T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class) 
      = 0 THEN item.i_category ELSE NULL END, ASC], [T_WIN_FUN_RANK(), ASC]), topn(100), prefix_pos(1)
  3 - output([T_FUN_SUM(web_sales.ws_net_paid)], [item.i_category], [item.i_class], [T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class)], [T_WIN_FUN_RANK()],
       [CASE WHEN T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class) = 0 THEN item.i_category ELSE NULL END]), filter(nil), rowset=256
      win_expr(T_WIN_FUN_RANK()), partition_by([T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class)], [CASE WHEN T_FUN_GROUPING(item.i_class) 
      = 0 THEN item.i_category ELSE NULL END]), order_by([T_FUN_SUM(web_sales.ws_net_paid), DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  4 - output([T_FUN_SUM(web_sales.ws_net_paid)], [item.i_category], [item.i_class], [T_FUN_GROUPING(item.i_category)], [T_FUN_GROUPING(item.i_class)], [T_FUN_GROUPING(item.i_category) 
      + T_FUN_GROUPING(item.i_class)], [CASE WHEN T_FUN_GROUPING(item.i_class) = 0 THEN item.i_category ELSE NULL END]), filter(nil), rowset=256
      sort_keys([T_FUN_GROUPING(item.i_category) + T_FUN_GROUPING(item.i_class), DESC], [CASE WHEN T_FUN_GROUPING(item.i_class) = 0 THEN item.i_category 
      ELSE NULL END, ASC], [T_FUN_SUM(web_sales.ws_net_paid), DESC])
  5 - output([T_FUN_SUM(web_sales.ws_net_paid)], [item.i_category], [item.i_class], [T_FUN_GROUPING(item.i_category)], [T_FUN_GROUPING(item.i_class)], [T_FUN_GROUPING(item.i_category) 
      + T_FUN_GROUPING(item.i_class)], [CASE WHEN T_FUN_GROUPING(item.i_class) = 0 THEN item.i_category ELSE NULL END]), filter(nil), rowset=256
      group(nil), rollup([item.i_category], [item.i_class]), agg_func([T_FUN_SUM(web_sales.ws_net_paid)], [T_FUN_GROUPING(item.i_category)], [T_FUN_GROUPING(item.i_class)])
  6 - output([item.i_category], [item.i_class], [web_sales.ws_net_paid]), filter(nil), rowset=256
      sort_keys([item.i_category, ASC], [item.i_class, ASC])
  7 - output([item.i_category], [item.i_class], [web_sales.ws_net_paid]), filter(nil), rowset=256
      equal_conds([d1.d_date_sk = web_sales.ws_sold_date_sk]), other_conds(nil)
  8 - output([d1.d_date_sk]), filter([d1.d_month_seq >= 1205], [d1.d_month_seq <= 1205 + 11]), rowset=256
      access([d1.d_date_sk], [d1.d_month_seq]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([d1.d_date_sk]), range(MIN ; MAX)always true
  9 - output([item.i_category], [item.i_class], [web_sales.ws_sold_date_sk], [web_sales.ws_net_paid]), filter(nil), rowset=256
      equal_conds([item.i_item_sk = web_sales.ws_item_sk]), other_conds(nil)
      merge_directions([ASC])
 10 - output([item.i_item_sk], [item.i_category], [item.i_class]), filter(nil), rowset=256
      access([item.i_item_sk], [item.i_category], [item.i_class]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([item.i_item_sk]), range(MIN ; MAX)always true
 11 - output([web_sales.ws_item_sk], [web_sales.ws_sold_date_sk], [web_sales.ws_net_paid]), filter(nil), rowset=256
      access([web_sales.ws_item_sk], [web_sales.ws_sold_date_sk], [web_sales.ws_net_paid]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([web_sales.ws_item_sk], [web_sales.ws_order_number]), range(MIN,MIN ; MAX,MAX)always true
select /*TPC-DS Q11*/ sum(ws_net_paid) as total_sum
,i_category
,i_class
,grouping(i_category)+grouping(i_class) as lochierarchy
,rank() over (
partition by grouping(i_category)+grouping(i_class),
case when grouping(i_class) = 0 then i_category end order by sum(ws_net_paid) desc) as rank_within_parent
from web_sales
,date_dim  d1
,item
where d1.d_month_seq between 1205 and 1205+11 and d1.d_date_sk = ws_sold_date_sk
and i_item_sk  = ws_item_sk
group by i_category,i_class with rollup
order by lochierarchy desc,
case when lochierarchy = 0 then i_category end,
rank_within_parent
limit 100;
+-----------+------------+---------+--------------+--------------------+
| total_sum | i_category | i_class | lochierarchy | rank_within_parent |
+-----------+------------+---------+--------------+--------------------+
+-----------+------------+---------+--------------+--------------------+


********************** TPC_DS Q12
EXPLAIN select /*TPC-DS Q12*/ c_customer_id
from (select sr_customer_sk as ctr_customer_sk
,sr_store_sk as ctr_store_sk
,sum(SR_RETURN_AMT_INC_TAX) as ctr_total_return
from store_returns
,date_dim
where sr_returned_date_sk = d_date_sk
and d_year =1999 group by sr_customer_sk
,sr_store_sk) as ctr1
,store
,customer
where ctr1.ctr_total_return > (select avg(ctr_total_return)*1.2 from (select sr_customer_sk as ctr_customer_sk
,sr_store_sk as ctr_store_sk
,sum(SR_RETURN_AMT_INC_TAX) as ctr_total_return
from store_returns
,date_dim
where sr_returned_date_sk = d_date_sk
and d_year =1999 group by sr_customer_sk
,sr_store_sk) as ctr2
where ctr1.ctr_store_sk = ctr2.ctr_store_sk)
and s_store_sk = ctr1.ctr_store_sk
and s_state = 'TN' and ctr1.ctr_customer_sk = c_customer_sk
order by c_customer_id
limit 100;
