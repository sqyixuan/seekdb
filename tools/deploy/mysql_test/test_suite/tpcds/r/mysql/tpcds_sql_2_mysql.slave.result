      conds(nil), nl_params_([customer.c_current_cdemo_sk(:8)]), use_batch=true
  6 - output([catalog_returns.cr_call_center_sk], [customer.c_current_cdemo_sk], [catalog_returns.cr_net_loss]), filter(nil), rowset=256
