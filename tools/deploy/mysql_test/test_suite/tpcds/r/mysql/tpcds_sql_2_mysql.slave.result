       DECIMAL(20, 0))], [T_FUN_SUM(store_sales.ss_list_price) / cast(T_FUN_COUNT(store_sales.ss_list_price), DECIMAL(20, 0))], [T_FUN_SUM(store_sales.ss_coupon_amt) 
