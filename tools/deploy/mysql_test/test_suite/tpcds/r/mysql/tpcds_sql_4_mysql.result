,sum(case when d_moy = 10 then cs_net_paid * cs_quantity else 0 end) as oct_net
,sum(case when d_moy = 11 then cs_net_paid * cs_quantity else 0 end) as nov_net
,sum(case when d_moy = 12 then cs_net_paid * cs_quantity else 0 end) as dec_net
from  catalog_sales
,warehouse
,date_dim
,time_dim
,ship_mode
where cs_warehouse_sk =  w_warehouse_sk
and cs_sold_date_sk = d_date_sk
and cs_sold_time_sk = t_time_sk
and cs_ship_mode_sk = sm_ship_mode_sk
and d_year = 2001
and t_time between 19072 AND 19072+28800
and sm_carrier in ('FEDEX','GERMA')
group by w_warehouse_name
,w_warehouse_sq_ft
,w_city
,w_county
,w_state
,w_country
,d_year
) x
group by w_warehouse_name
,w_warehouse_sq_ft
,w_city
,w_county
,w_state
,w_country
,ship_carriers
,year order by w_warehouse_name
limit 100;
