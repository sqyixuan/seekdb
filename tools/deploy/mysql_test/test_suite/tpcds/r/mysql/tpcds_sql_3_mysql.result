from customer c,customer_address ca,customer_demographics
where c.c_current_addr_sk = ca.ca_address_sk and ca_county in ('Clinton County','Platte County','Franklin County','Louisa County','Harmon County') and cd_demo_sk = c.c_current_cdemo_sk and exists (select *
from store_sales,date_dim
where c.c_customer_sk = ss_customer_sk
and ss_sold_date_sk = d_date_sk
and d_year = 2002
and d_moy between 3
and 3+3)
and (exists (select *
from web_sales,date_dim
where c.c_customer_sk = ws_bill_customer_sk
