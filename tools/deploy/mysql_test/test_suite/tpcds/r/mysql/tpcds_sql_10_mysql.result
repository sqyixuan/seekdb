      access([dn.ss_customer_sk], [dn.bought_city], [dn.ss_ticket_number], [dn.extended_price], [dn.extended_tax], [dn.list_price])
  5 - output([store_sales.ss_ticket_number], [store_sales.ss_customer_sk], [customer_address.ca_city], [T_FUN_SUM(store_sales.ss_ext_sales_price)], [T_FUN_SUM(store_sales.ss_ext_list_price)],
       [T_FUN_SUM(store_sales.ss_ext_tax)]), filter(nil), rowset=256
