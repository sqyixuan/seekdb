       [store_sales.ss_ext_list_price], [store_sales.ss_ext_tax]), filter(nil), rowset=256
      equal_conds([store_sales.ss_hdemo_sk = household_demographics.hd_demo_sk]), other_conds(nil)
 12 - output([household_demographics.hd_demo_sk]), filter([household_demographics.hd_dep_count = 0 OR household_demographics.hd_vehicle_count = 1]), rowset=256
