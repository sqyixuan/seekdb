result_format: 4
explain_protocol: 2
set global ob_sql_work_area_percentage=100;

use opt_tpcds;
set ob_query_timeout = 1000000000;
set ob_trx_timeout=1000000000;
********************** TPC_DS Q1
EXPLAIN select /*TPC-DS Q1*/ count(*)
from store_sales
,household_demographics
,time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 8 and time_dim.t_minute >= 30
and household_demographics.hd_dep_count = 5
and store.s_store_name = 'ese'order by count(*)
limit 100;
Query Plan
===================================================================================
|ID|OPERATOR                         |NAME                  |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE               |                      |1       |953         |
|1 |└─EXCHANGE OUT REMOTE            |                      |1       |953         |
|2 |  └─LIMIT                        |                      |1       |952         |
|3 |    └─SCALAR GROUP BY            |                      |1       |952         |
|4 |      └─NESTED-LOOP JOIN         |                      |0       |952         |
|5 |        ├─NESTED-LOOP JOIN       |                      |0       |937         |
|6 |        │ ├─HASH JOIN            |                      |0       |921         |
|7 |        │ │ ├─TABLE FULL SCAN    |time_dim              |0       |62          |
|8 |        │ │ └─TABLE FULL SCAN    |store_sales           |5000    |442         |
|9 |        │ └─DISTRIBUTED TABLE GET|household_demographics|1       |16          |
|10|        └─DISTRIBUTED TABLE GET  |store                 |1       |16          |
===================================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil)
  1 - output([T_FUN_COUNT(*)]), filter(nil)
  2 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      limit(100), offset(nil)
  3 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
  4 - output(nil), filter(nil), rowset=256
      conds(nil), nl_params_([store_sales.ss_store_sk(:4)]), use_batch=true
  5 - output([store_sales.ss_store_sk]), filter(nil), rowset=256
      conds(nil), nl_params_([store_sales.ss_hdemo_sk(:0)]), use_batch=true
  6 - output([store_sales.ss_store_sk], [store_sales.ss_hdemo_sk]), filter(nil), rowset=256
      equal_conds([store_sales.ss_sold_time_sk = time_dim.t_time_sk]), other_conds(nil)
  7 - output([time_dim.t_time_sk]), filter([time_dim.t_minute >= 30], [time_dim.t_hour = 8]), rowset=256
      access([time_dim.t_time_sk], [time_dim.t_hour], [time_dim.t_minute]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([time_dim.t_time_sk]), range(MIN ; MAX)always true
  8 - output([store_sales.ss_sold_time_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_store_sk]), filter(nil), rowset=256
      access([store_sales.ss_sold_time_sk], [store_sales.ss_hdemo_sk], [store_sales.ss_store_sk]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([store_sales.ss_item_sk], [store_sales.ss_ticket_number]), range(MIN,MIN ; MAX,MAX)always true
  9 - output(nil), filter([household_demographics.hd_dep_count = 5]), rowset=256
      access([GROUP_ID], [household_demographics.hd_dep_count]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([household_demographics.hd_demo_sk]), range(MIN ; MAX), 
      range_cond([:0 = household_demographics.hd_demo_sk])
 10 - output(nil), filter([store.s_store_name = 'ese']), rowset=256
      access([GROUP_ID], [store.s_store_name]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([store.s_store_sk]), range(MIN ; MAX), 
      range_cond([:4 = store.s_store_sk])
select /*TPC-DS Q1*/ count(*)
from store_sales
,household_demographics
,time_dim, store
where ss_sold_time_sk = time_dim.t_time_sk
and ss_hdemo_sk = household_demographics.hd_demo_sk
and ss_store_sk = s_store_sk
and time_dim.t_hour = 8 and time_dim.t_minute >= 30
and household_demographics.hd_dep_count = 5
and store.s_store_name = 'ese'order by count(*)
limit 100;
