#owner:dachuan.sbc
#owner group:sql2
#description:可更新视图的数据类型：数值类型、字符串类型、时间日期类型
--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);




--disable_result_log




--error 0,1007
create database hz;
use hz;
--error 0,1051
drop table test1;
--error 0,1051
drop view v1;
--error 0,1051
drop view v2;
--error 0,1051
drop view v3;

--echo  #view-1-1-1  数值类型
--echo  #TINYINT、SMALLINT、MEDIUMINT、int、INTEGER
create table test1(b1 TINYINT(20),b2 SMALLINT(20),b3 MEDIUMINT(30),b4 int,b5 INTEGER(30));
create view v1 as SELECT * from test1 where b1<10 and b2>200 and b3=90 and b4<200 and b5 <150 WITH CHECK OPTION;
insert into v1 values(1,201,90,150,149);
--error 0,1369
insert into v1 values(11,201,90,150,151);
insert into v1 values(9,189+12,90,150,149);
insert into v1 values(81/9,189+12,30*3,170-20,30*5-1);
SELECT * from v1 order by b1 asc;
DELETE from test1;
--error 0,1051
drop view v1;

create view v2 as SELECT * from test1 where b1=1 and b2=b1+1 and b3=b1+b2 and b4=8 and b5=b4-b1 WITH CHECK OPTION;
insert into v2 values(1,2,3,8,7);
insert into v2 values(1,4/2,3*1,4+4,10-3);
--error 0,1369
insert into v2 values(1,6/2,3*1,4+4,10-3);
SELECT * from v2 order by b1 asc;
DELETE from test1;
--error 0,1051
drop view v2;

create view v3 as SELECT * from test1 where b1>b3 and b3=b2 and b4>b1 and b2<b5 and b5<b1 WITH CHECK OPTION;
insert into v3 values(10,3,3,12,6);
SELECT * from v3 order by b1 asc;
--error 0,1369
insert into v3 values(10,4,3,12,6);
insert into v3 values(50+50,20-4,2*8,300/2,9*9);
SELECT * from v3 order by b1 asc;
--error 0,1369
replace into v3 values(50+50,((SELECT b2 from v3 LIMIT 1)),2*8,300/2,9*9);
drop view v3;
drop table test1;


--echo  #TINYINT、SMALLINT、MEDIUMINT、int、INTEGER
create table test1(b1 BIGINT(20),b2 FLOAT(20),b3 DOUBLE,b4 DECIMAL,b5 bit(30));
create view v1 as SELECT * from test1 where b1<10 and b2>200 and b3=90 and b4<200 and b5 <150 WITH CHECK OPTION;
insert into v1 values(1,201,90,150,149);
insert into v1 values((SELECT b1 from v1),189+12,30*3,170-20,30*5-1);
--error 0,1064
insert into v1 values(2,(UPDATE v1 set b2=260 where b2=201),30*3,70-20,30*5-1);
--error 0,1369
insert into v1 values(11,201,90,150,151);
insert into v1 values(9,189+12,90,150,149);
insert into v1 values(81/9,189+12,30*3,170-20,30*5-1);
SELECT * from v1 order by b1 asc;
DELETE from test1;
drop view v1;

create view v2 as SELECT * from test1 where b1=1 and b2=b1+1 and b3=b1+b2 and b4=8 and b5=b4-b1 WITH CHECK OPTION;
insert into v2 values(1,2,3,8,7);
insert into v2 values(1,4/2,3*1,4+4,10-3);
--error 0,1369
insert into v2 values(1,6/2,3*1,4+4,10-3);
SELECT * from v2 order by b1 asc;
DELETE from test1;
drop view v2;



create view v3 as SELECT * from test1 where b1>b3 and b3<b2 and b4>b1 and b2<b5 and b5<b1 WITH CHECK OPTION;
insert into v3 values(10,3,2,12,6);
SELECT * from v3 order by b1 asc;
--error 0,1369
insert into v3 values(10,4,3,12,6);
insert into v3 values(50+50,20-3,2*8,300/2,9*9);
SELECT * from v3 order by b1 asc;
DELETE from test1;
drop view v3;
drop table test1;



create table test1 (a1 int, a2 int);
insert into test1 values(1,98);
insert into test1 values(2,78);
create or REPLACE view v1 as SELECT * from test1 WITH CHECK OPTION;
SELECT * from v1;
SELECT * from test1;
insert into v1 values(null,null);
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select a2 from v1 where a2=78));
SELECT * from v1;
SELECT * from test1;
--error 0,1064
insert into v1(a1) values(select a2 from v1 where a2=78);
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select distinct a2 from test1 where a2 is null));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select distinct a1 from test1 where a2 is null LIMIT 1));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select max(a2) from test1 where a2 is null));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select min(a2) from test1 where a2 is null));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select count(a2) from test1 where a2 is null));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select avg(a2) from test1 where a2 is null));
SELECT * from v1;
SELECT * from test1;
insert into v1(a1) values((select sum(a1) from test1));
SELECT * from v1;
SELECT * from test1;
update v1 set a1=(select a1 from v1 LIMIT 1) ;
SELECT * from v1;
SELECT * from test1;
drop table test1;
drop view v1;


--echo  #view-1-1-2  字符串类型
create table test1(b1 CHAR(20),b2 VARCHAR(20),b3 varbinary(20),b4 TINYBLOB,b5 TINYTEXT);
create view v1 as SELECT * from test1 WITH CHECK OPTION;
insert into v1 values('张三','李四','李白','赵云','鲁班');
insert into v1 values('凯','妲己','韩信','后裔','诸葛');
SELECT * from v1 order by b1 asc;
SELECT * from test1 order by b1 asc;
drop view v1;
drop table test1;


create table test1(b1 BLOB(20),b2 TEXT(20),b3 MEDIUMBLOB,b4 LONGBLOB,b5 LONGTEXT);
create view v2 as SELECT * from test1 WITH CHECK OPTION;
insert into v2 values('张三','李四','李白','赵云','鲁班');
insert into v2 values('凯','妲己','韩信','后裔','诸葛');
SELECT * from v2 order by b1 asc;
SELECT * from test1 order by b1 asc;
drop view v2;
drop table test1;



--echo  #view-1-1-3  时间日期
create table test1(b1 DATE,b2 TIME,b3 YEAR,b4 DATETIME,b5 TIMESTAMP);
create view v1 as SELECT * from test1 WITH CHECK OPTION;
insert into v1 values('2021-09-13','16:04:33','1986','2021-12-31 23:59:59','2021-12-31 23:59:59');
insert into v1 values('1000-01-01','12:00:00','2155','3599-12-31 23:59:59','2038-12-31 23:59:59');
SELECT * from v1 order by b1 asc;
SELECT * from test1 order by b1 asc;
drop view v1;
drop table test1;

--enable_result_log





--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user hjw@'%' ;
--enable_warnings
