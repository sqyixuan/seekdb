--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);

--disable_result_log

--echo   #view-2-1  create view
--echo   #view-2-2  insert

--error 0,1007
create database hz;
use hz;
--error 0,1051
drop table test2;
--error 0,1051
drop table test3;
--error 0,1051
drop view v1;
--error 0,1051
drop view v2;
--error 0,1051
