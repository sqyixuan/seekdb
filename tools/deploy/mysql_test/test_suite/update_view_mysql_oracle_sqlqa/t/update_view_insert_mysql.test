--echo   #view-2-1  create view
--echo   #and
create table test2(b1 int,b2 bigint,b3 bit(10),b4 DOUBLE,b5 FLOAT,b6 SMALLINT);
insert into test2 values(1,35,55,75,95,105);
--error 0,4179
create or REPLACE view v1 as SELECT * from test2 where b1<(select b5 from test2 limit 1) WITH CHECK OPTION;
create or REPLACE view v1 as SELECT * from test2 where b1<100 and b2<100 and b3<100 and b4>100 and b5>100 and b6>100 WITH CHECK OPTION;
insert into v1 values(1,35,55,705,950,1005);
SELECT * from test2 order by b1 asc;
SELECT * from v1 order by b1 asc;
drop view v1;
DELETE from test2;

--echo   #or
create or REPLACE view v2 as SELECT * from test2 where b1>100 or b2<300 or b3<260 or b4>520 or b5<480 or b6<320 WITH CHECK OPTION;
insert into v2 values(149,299,255,521,470,318);
insert into v2 values(99,299,255,521,470,318);
insert into v2 values(99,301,270,519,481,318);
--error 0,1369
insert into v2 values(99,301,270,519,481,321);
SELECT * from test2 order by b1 asc;
SELECT * from v2 order by b1 asc;
drop view v2;
drop table test2;



--echo   #like
create table test2(b1 int,b2 char(20),b3 varchar(20),b4 TINYTEXT,b5 TINYTEXT,b6 TINYTEXT);
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
create or REPLACE view v2 as SELECT * from test2 where b2 like '李%' and b3 like '后%' and b4 like '%姬' and b5 like '鲁%' WITH CHECK OPTION;
insert into v2 values(2,'李三','后四','五姬','鲁六','小刘');
insert into v2 values(3,'李1','后2','3姬','鲁4','小武');
--error 0,1369
insert into v2 values(4,'三1','四2','3姬','鲁4','小武');
SELECT * from test2 order by b1 asc;
SELECT * from v2 order by b1 asc;
drop view v2;
DELETE from test2;


--echo   #exists
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
--error 0,4179
create or REPLACE view v2 as SELECT * from test2 where EXISTS(SELECT b2 from test2)WITH CHECK OPTION;
DELETE from test2;


--echo   #all
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
--error 0,4179
create or REPLACE view v2 as SELECT * from test2 where b2=ALL(SELECT b2 from test2) WITH CHECK OPTION;
DELETE from test2;

--echo   #any
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
--error 0,4179
create or REPLACE view v2 as SELECT * from test2 where b2=any(SELECT b2 from test2) WITH CHECK OPTION;
DELETE from test2;

--echo   #some
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
--error 0,4179
create or REPLACE view v2 as SELECT * from test2 where b2=some(SELECT b2 from test2) WITH CHECK OPTION;
DELETE from test2;

--echo   #in
insert into test2 values(1,'李白','后裔','虞姬','鲁班','韩信');
--error 0,4179
create or REPLACE view v2 as SELECT * from test2 where b2 in(SELECT b2 from test2) WITH CHECK OPTION;
DELETE from test2;
drop table test2;



--echo   #view-2-2  insert
--echo   #view-2-2-1  新增字段
create table test3(id int,name varchar(20),chinese int,math int,english int);
create or REPLACE view v3 as SELECT * from test3 where chinese<150 and math<150 and english<150 WITH CHECK OPTION;
insert into v3 values(1,'小李',79,149,130);
insert into v3 values(2,'小王',109,145,140);
SELECT * from v3 order by id asc;
SELECT * from test3 order by id asc;
alter table test3 add chem int;
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
create or REPLACE view v3 as SELECT * from test3 where chinese<150 and math<150 and english<150 WITH CHECK OPTION;
update v3 set chem=95;
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
update v3 set chem=chem+5 limit 1;
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
--error 0,1064
update v3 set chem=(REPLACE into v3(chem) values(140));
alter table test3 modify column chem bigint;
desc test3;
desc v3;
drop view v3;
drop table test3;



--echo   #view-2-2  insert
--echo   #view-2-2-2  设置replace 
create table test3(id int,name varchar(20),chinese int,math int,english int);
insert into test3 values(1,'小李',79,149,130);
insert into test3 values(2,'小王',109,145,140);
create or REPLACE view v3 as SELECT * from test3 where chinese<=150 and math<=150 and english<=150 WITH CHECK OPTION;
REPLACE into v3 values(3,'小李',79,149,130);
--error 0,1146
REPLACE into v2 values(4,'小王',151,151,140);
--error 0,1369
REPLACE into v3 values(5,'小王',151,151,140);
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
drop table test3;



--echo   #view-2-2  insert
--echo   #view-2-2-3  插入函数
create table test3(id int,chinese BIGINT,math BIGINT,english INTEGER);
insert into test3 values(1,79,149,130);
create or REPLACE view v3 as SELECT * from test3 where chinese<=LOG(500,500) and math<=log10(9999) and english<=abs(2000) WITH CHECK OPTION;
replace into v3 values(2,log(52,250),log10(999),abs(200));
--error 0,1369
replace into v3 values(3,bin(250),exp(9),ln(200));
replace into v3 values(3,log(501,250),log10(999),abs(200));
--error 0,1369
replace into v3 values(4,log(501,501),log10(99999),abs(200));
--error 0,1369
replace into v3 values(5,log(501,501),log10(99999),abs(2000));
--error 0,1369
replace into v3 values(6,log(499,499),log10(abs(99999)),abs(2000));
--error 0,1369
replace into v3 values(7,log(501,501),log10(abs(99999)),abs(2001));
--error 0,1064
replace into v3 values(8,log(log10(499),abs(499)),log10(abs(log(499,499))),abs(log10(log(499,499)));
drop view v3;
drop table test3;

--echo  #插入函数:exp、ln、mod
create table test3(id int,chinese BIGINT,math BIGINT,english INTEGER);
create or REPLACE view v3 as SELECT * from test3 where chinese<=exp(500) and math<=ln(9999) and english<=mod(500,700) WITH CHECK OPTION;
replace into v3 values(1,exp(0.005),ln(998),mod(499,699));
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
--error 0,1369
replace into v3 values(2,exp(5),ln(99998),mod(501,701));
--error 0,1369
replace into v3 values(2,exp(5),ln(99998),mod(51,71));
replace into v3 values(2,exp(0.005),ln(mod(499,699)),mod(ln(9999),exp(5)));
replace into v3 values(3,exp(mod(0.25,0.35)),ln(mod(499,699)),mod(ln(9999),exp(5)));
replace into v3 values(4,exp(mod(ln(2),ln(2))),ln(mod(exp(5),ln(9999))),mod(ln(9999),exp(5)));
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;


--echo  #插入函数:FLOOR、ROUND(x,y)、TRUNCATE(x,y)
create or REPLACE view v3 as SELECT * from test3 where chinese<=FLOOR(500) and math<=ROUND(300,200) and english<=TRUNCATE(500,700) WITH CHECK OPTION;
replace into v3 values(1,FLOOR(500),ROUND(299,199),TRUNCATE(499,699));
--error 0,1369
replace into v3 values(2,FLOOR(501),ROUND(299,199),TRUNCATE(499,699));
--error 0,1369
replace into v3 values(2,FLOOR(501),ROUND(301,201),TRUNCATE(501,701));
replace into v3 values(2,FLOOR(ROUND(TRUNCATE(499,499),TRUNCATE(499,499))),ROUND(TRUNCATE(299,199),FLOOR(199)),TRUNCATE(ROUND(299,199),FLOOR(199)));

SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;

--echo  #插入函数:POW、SIN、ASIN
create or REPLACE view v3 as SELECT * from test3 where chinese<=pow(5,4) and math<=sin(RADIANS(90)) and english<=asin(0.5) WITH CHECK OPTION;
replace into v3 values(1,pow(3,3),sin(RADIANS(60)),asin(0.2));
--error 0,1369
replace into v3 values(2,pow(9,3),sin(RADIANS(60)),asin(0.2));
replace into v3 values(2,pow(3,3),sin(RADIANS(70)),asin(0.4));
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;

--echo  #插入函数:cos、ACOS、TAN(x)、ATAN(x)
create or REPLACE view v3 as SELECT * from test3 where chinese<=ACOS(0.5) and math<=TAN(180) and english<=ATAN(90) WITH CHECK OPTION;
replace into v3 values(1,ACOS(0.8),TAN(90),ATAN(10));
replace into v3 values(2,COS(0.8),TAN(90),ATAN(10));
replace into v3 values(3,COS(0.6),TAN(90),ATAN(10));
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
--error 0,1369
replace into v3 values(4,COS(0.5),TAN(90),ATAN(15));
replace into v3 values(5,ACOS(0.5),TAN(90),ATAN(10));
replace into v3 values(6,ACOS(0.4),TAN(90),ATAN(10));

SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;
drop table test3;


--echo   #view-2-2  insert
--echo   #view-2-2-4  函数运算    加
create table test3(id int,chinese BIGINT,math BIGINT,english INTEGER);
create or REPLACE view v3 as SELECT * from test3 where chinese<=10 and math>=15 and english<30 WITH CHECK OPTION;
replace into v3 values(1,log(10)+ln(20),15,29);
--error 0,1369
replace into v3 values(2,log(10)+ln(20),log10(5)+abs(20),bin(5)+exp(3));
replace into v3 values(3,log(10,15)+mod(20,2),floor(25)+ROUND(20,8),TRUNCATE(1,1)+POW(2,2));
--error 0,1369
replace into v3 values(4,SIN(60)+cos(25),ASIN(30)+ACOS(20),TAN(1)+ATAN(2));
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;


--echo   #函数运算    减
create or REPLACE view v3 as SELECT * from test3 where chinese<=10 and math>=5 and english<30 WITH CHECK OPTION;
replace into v3 values(1,log(30)-ln(10),15,29);
replace into v3 values(2,log(30)-ln(5),abs(10)-log10(90),bin(6)-exp(5));
replace into v3 values(3,log(10,15)-mod(20,2),floor(25)-ROUND(20,8),TRUNCATE(1,1)-POW(2,2));
--error 0,1369
replace into v3 values(4,SIN(60)-cos(25),ASIN(30)-ACOS(20),TAN(1)-ATAN(2));
--error 0,1369
replace into v3 values(4,SIN(60)-cos(25),TAN(80)-ATAN(3),25);
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;


--echo   #函数运算   乘
create or REPLACE view v3 as SELECT * from test3 where chinese<=20 and math>=10 and english<50 WITH CHECK OPTION;
replace into v3 values(1,log(30)*ln(10),15,29);
replace into v3 values(2,log(1)*ln(1),abs(10)*log10(30),bin(1)*exp(1));
replace into v3 values(3,log(10,15)*mod(20,2),floor(25)*ROUND(20,8),TRUNCATE(1,1)*POW(2,2));
replace into v3 values(4,SIN(60)*cos(25),11,TAN(1)*ATAN(2));
replace into v3 values(5,SIN(60)*cos(25),TAN(80)*ATAN(3),25);
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;


--echo   #函数运算   除
create or REPLACE view v3 as SELECT * from test3 where chinese<=20 and math<=10 and english>10 WITH CHECK OPTION;
replace into v3 values(1,log(30)/ln(10),9,29);
replace into v3 values(2,log(9)/ln(0.5),abs(10)/log10(30),bin(9)/exp(1));
replace into v3 values(3,log(100,150)/mod(20,0.55),floor(25)/ROUND(20,8),TRUNCATE(91,1)/POW(2,2));
replace into v3 values(4,SIN(60)/cos(25),9,TAN(1)/ATAN(0.14));
replace into v3 values(5,SIN(60)/cos(25),TAN(80)/ATAN(3),25);
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop view v3;
DELETE from test3;
drop table test3;


--echo   #view-2-2-5  update
create table test2(id int,chinese BIGINT,math BIGINT,english INTEGER);
insert into test2 values(1,130,121,109);
create table test3(id int,chinese BIGINT,math BIGINT,english INTEGER);
insert into test3 values(1,130,121,109);
create or REPLACE view v3 as SELECT * from test3 where chinese<=150 and math<=150 and english<150 WITH CHECK OPTION;
--error 0,1064
replace into v3 values(2,update test2 set chinese=145,9,29);
--error 0,1064
insert into v3 values(2,update v3 set chinese=145,9,29);
SELECT * from test3 order by id asc;
SELECT * from v3 order by id asc;
drop table test2;
drop table test3;
drop view v3;


--echo   #view-2-2-6  插入特殊符号值
create table test2(id int,chinese BIGINT,math BIGINT,english INTEGER);
create or REPLACE view v2 as SELECT * from test2 where chinese<=150 or math<=null or english<null WITH CHECK OPTION;
insert into v2 values(1,145,99,129);
--error 0,1064
insert into v2 values(2,2@,99,129);
--error 0,1054
insert into v2 values(2,99$,99,129);
--error 0,1064
insert into v2 values(2,130%,99,129);
--error 0,1064
insert into v2 values(2,*130,99,129);
--error 0,1064
insert into v2 values(2,100&,99,129);
insert into v2 values(2,150,149,null);
insert into v2 values(3,123,null,null);
--error 0,1054
insert into v2 values(4,123,12yh,null);
insert into v2 values(4,123,12*@yh,null);
SELECT * from test2 order by id asc;
SELECT * from v2 order by id asc;
drop view v2;
drop table test2;

--enable_result_log








