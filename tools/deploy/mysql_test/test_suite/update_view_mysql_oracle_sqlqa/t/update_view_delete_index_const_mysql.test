--echo   #view-2-3  update
create table test1(a1 int primary key AUTO_INCREMENT,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1(name,chinese,math,english) values('小明',101,115,113);
insert into test1(name,chinese,math,english) values('小王',103,125,115);
insert into test1(name,chinese,math,english) values('小超',107,135,108);
insert into test1(name,chinese,math,english) values('小李',119,145,100);
create or REPLACE view v1 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=chinese+2;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=chinese-1,math=math+1,english=english+3;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1288
update ((SELECT * from v1)) set chinese=chinese-1 ;
update v1 set chinese=(select chinese from test1 LIMIT 1);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
update v1 set chinese=(select math from test1 where math=126 );
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=(select math from test1 where math<=116 LIMIT 1 );
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=(select math from test1 where math=(select math from test1 where math=116));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=chinese-1 and math=math+1 and english=english+3;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=chinese-1 or math=math+1 or english=english+3;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;


create table test1(a1 int primary key AUTO_INCREMENT,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1(name,chinese,math,english) values('小明',101,115,113);
insert into test1(name,chinese,math,english) values('小王',103,125,115);
insert into test1(name,chinese,math,english) values('小超',107,135,108);
insert into test1(name,chinese,math,english) values('小李',119,145,100);
create or REPLACE view v1 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
update v1 set chinese=log(81);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set chinese=log(81)+log10(81);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1288
update (SELECT chinese from v1 ) set chinese=log(81)+log10(81);
update v1 set chinese=log(log10(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english-log(log10(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english*log(log10(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english-abs(bin(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english-abs(bin(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english*exp(ln(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;


create table test1(a1 int primary key AUTO_INCREMENT,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1(name,chinese,math,english) values('小明',101,115,113);
insert into test1(name,chinese,math,english) values('小王',103,125,115);
insert into test1(name,chinese,math,english) values('小超',107,135,108);
insert into test1(name,chinese,math,english) values('小李',119,145,100);
create or REPLACE view v1 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english*sin(tan(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=english*sin(cos(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
update v1 set english=log(8100)+log10(8100)-ln(6400) ;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
update v1 set english=(select chinese from test1 where chinese=log(log10(81)) LIMIT 1) ;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1064
update v1 set english=(update v1 set english=log(log10(81)) LIMIT 1) ;
--error 0,1369
update v1 set english=english*sin(asin(81));
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;


--echo   #view-2-4  delete删除内容
--echo   #view-2-4-1-1  嵌套语句
create table test1(a1 int ,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
insert into test1 values(2,'小王',103,135,88);
insert into test1 values(3,'小超',107,145,48);
insert into test1 values(4,'小李',119,155,18);
create or REPLACE view v1 as SELECT * from test1 where chinese<=150 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english=(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where EXISTS(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english=all(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
insert into test1 values(1,'小明',101,125,98);
insert into test1 values(2,'小王',103,135,88);
insert into test1 values(3,'小超',107,145,48);
insert into test1 values(4,'小李',119,155,18);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english>all(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english<all(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
DELETE from test1;
drop view v1;
insert into test1 values(1,'小明',101,125,98);
insert into test1 values(2,'小王',103,135,88);
insert into test1 values(3,'小超',107,145,48);
insert into test1 values(4,'小李',119,155,18);
create or REPLACE view v1 as SELECT * from test1 where chinese<=150 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english=any(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english=some(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english in(SELECT english from v1 where english=98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;


--echo   #view-2-4-1-2  单列字段数据
create table test1(a1 int ,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
insert into test1 values(2,'小王',103,135,88);
insert into test1 values(3,'小超',107,145,48);
insert into test1 values(4,'小李',119,155,18);
create or REPLACE view v1 as SELECT * from test1 where chinese<=150 and math>=120 and english<100 WITH CHECK OPTION;
create or REPLACE view v2 as SELECT * from test1 where chinese<=150 and math>=120 and english<100 WITH CHECK OPTION;
create or REPLACE view v3 as SELECT * from test1 where chinese<=150 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
delete from v1 where english=18;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
UPDATE v1 set english=null;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
DELETE from v1;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--echo   #view-2-4-1-3
DELETE from v2 v3;
drop view v2,v3;
drop view v1;
drop table test1;





--echo   #view-2-5  约束
--echo   #NOT NULL 非空
create table test1(a1 int ,name varchar(20),chinese BIGINT not null,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese<=null and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1048
replace into v1 values(1,'小明',null,125,98);
--error 0,1369
replace into v1 values(1,'小明',0,125,98);
--error 0,1369
replace into v1 values(2,'小明',-1,125,98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;

--echo   #UNIQUE Key 唯一
create table test1(a1 int,name varchar(20),chinese BIGINT UNIQUE Key,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
replace into v1 values(2,'小明',101,125,98);
replace into v1 values(3,'小明',101,125,98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;


--echo   # FOREIGN KEY 外键
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create table test2(a1 int,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER,constraint fk_test1_test2_a1 FOREIGN key(a1) REFERENCES test1(a1));
insert into test1 values(5,'小张',91,121,80);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
insert into v1 values(2,'小明',99,124,78);
replace into v1 values(2,'小明',103,124,78);
insert into v1 values(3,'小王',103,124,78);
insert into v1 values(4,'小草',110,130,70);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test2;
drop table test1;




--echo   # PRIMARY KEY 主键
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
replace into v1 values(2,'小明',100,125,98);
replace into v1 values(3,'小明',102,125,98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
drop view v1;
drop table test1;

--echo   #view-2-6  索引
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER,index suoyin(chinese));
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
insert into v1 values(2,'小明',103,125,98);
replace into v1 values(3,'小明',102,125,98);
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
--error 0,1369
UPDATE v1 set chinese=chinese-1;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
UPDATE v1 set chinese=chinese+21;
SELECT * from test1 order by a1 asc;
SELECT * from v1 order by a1 asc;
DELETE from v1;
drop view v1;
drop table test1;



--echo   #view-3  多表
create table test1(a1 int,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,115,113);
insert into test1 values(2,'小王',103,110,115);
insert into test1 values(3,'小超',107,116,108);
insert into test1 values(4,'小李',119,119,100);
create table test2(b1 int,xuexiao varchar(20),beiyong BIGINT,fenshu BIGINT,banji BIGINT);
insert into test2 values(1,'中国科学院',99,120,1);
insert into test2 values(2,'中国社会科学院',102,130,2);
insert into test2 values(3,'清华大学',130,140,2);
insert into test2 values(4,'北京大学',30,150,1);
--echo   #多表连接
--error 0,4179     #基本连接   mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v1 as SELECT * from test1,test2 where test1.a1 = test2.b1 WITH CHECK OPTION;
--error 0,4179     #基本连接   mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v2 as SELECT test1.a1,test2.b1 from test1,test2 where a1 = b1 WITH CHECK OPTION;
--error 0,4179     #交叉连接    mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v3 as SELECT * from test1,test2 WITH CHECK OPTION;
--error 0,4179     #右连接   mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v4 as SELECT * from test1 RIGHT JOIN test2 on test1.a1 = test2.b1 WITH CHECK OPTION;
--error 0,1368     #硬连接   mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v5 as SELECT * from test1 union SELECT * from test2 WITH CHECK OPTION;
--error 0,4179     #左连接   mysql多表连接行为诡异 obmysql报错，不符合WITH CHECK OPTION
create view v6 as SELECT * from test1 LEFT JOIN test2 on test1.a1 = test2.b1 WITH CHECK OPTION;

drop table test1;
drop table test2;












