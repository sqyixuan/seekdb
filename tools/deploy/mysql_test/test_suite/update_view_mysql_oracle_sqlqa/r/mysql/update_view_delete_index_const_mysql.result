#view-2-5  约束
#NOT NULL 非空
create table test1(a1 int ,name varchar(20),chinese BIGINT not null,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese<=null and math>=120 and english<100 WITH CHECK OPTION;
SELECT * from test1 order by a1 asc;
a1	name	chinese	math	english
1	小明	101	125	98
SELECT * from v1 order by a1 asc;
a1	name	chinese	math	english
replace into v1 values(1,'小明',null,125,98);
replace into v1 values(1,'小明',0,125,98);
replace into v1 values(2,'小明',-1,125,98);
SELECT * from test1 order by a1 asc;
a1	name	chinese	math	english
1	小明	101	125	98
SELECT * from v1 order by a1 asc;
a1	name	chinese	math	english
drop view v1;
drop table test1;
#UNIQUE Key 唯一
create table test1(a1 int,name varchar(20),chinese BIGINT UNIQUE Key,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
replace into v1 values(2,'小明',101,125,98);
replace into v1 values(3,'小明',101,125,98);
SELECT * from test1 order by a1 asc;
a1	name	chinese	math	english
3	小明	101	125	98
SELECT * from v1 order by a1 asc;
