#view-3  多表
create table test1(a1 int,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,115,113);
insert into test1 values(2,'小王',103,110,115);
insert into test1 values(3,'小超',107,116,108);
insert into test1 values(4,'小李',119,119,100);
create table test2(b1 int,xuexiao varchar(20),beiyong BIGINT,fenshu BIGINT,banji BIGINT);
insert into test2 values(1,'中国科学院',99,120,1);
insert into test2 values(2,'中国社会科学院',102,130,2);
insert into test2 values(3,'清华大学',130,140,2);
insert into test2 values(4,'北京大学',30,150,1);
#多表连接
create view v1 as SELECT * from test1,test2 where test1.a1 = test2.b1 WITH CHECK OPTION;
create view v2 as SELECT test1.a1,test2.b1 from test1,test2 where a1 = b1 WITH CHECK OPTION;
create view v3 as SELECT * from test1,test2 WITH CHECK OPTION;
create view v4 as SELECT * from test1 RIGHT JOIN test2 on test1.a1 = test2.b1 WITH CHECK OPTION;
create view v5 as SELECT * from test1 union SELECT * from test2 WITH CHECK OPTION;
create view v6 as SELECT * from test1 LEFT JOIN test2 on test1.a1 = test2.b1 WITH CHECK OPTION;
drop table test1;
drop table test2;
