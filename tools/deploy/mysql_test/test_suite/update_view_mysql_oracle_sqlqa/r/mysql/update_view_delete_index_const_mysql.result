drop view v1;
drop table test1;
# FOREIGN KEY 外键
create table test1(a1 int PRIMARY KEY,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,125,98);
create table test2(a1 int,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER,constraint fk_test1_test2_a1 FOREIGN key(a1) REFERENCES test1(a1));
insert into test1 values(5,'小张',91,121,80);
create or REPLACE view v1 as SELECT * from test1 where chinese>=101 and math>=120 and english<100 WITH CHECK OPTION;
