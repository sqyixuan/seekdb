3	118	140	115
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	110	101	119
3	118	140	115
delete from v1 partition(p0) where english<(SELECT english from v1 where english=(SELECT english from v1 where english=115));
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	110	101	119
3	118	140	115
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	110	101	119
3	118	140	115
update v1 partition(p0) set english=120 where english=115;
update v1 partition(p0) set english=119 where english=115;
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	110	101	119
3	118	140	119
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	110	101	119
3	118	140	119
update v1  partition(p0) set english=101 LIMIT 1;
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	110	101	101
3	118	140	119
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	110	101	101
3	118	140	119
drop view v1;
drop table test1;
