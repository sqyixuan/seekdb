#view-5   视图嵌套
#view-5-1  WITH CHECK OPTION嵌套
create table test1(a1 int ,name varchar(20),chinese BIGINT,math BIGINT,english INTEGER);
insert into test1 values(1,'小明',101,115,113);
create or REPLACE view v2 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
create or REPLACE view v3 as SELECT * from test1 where chinese>=30 and math<160 and english>=60 WITH CHECK OPTION;
create or REPLACE view v4 as SELECT * from v3 where chinese<=(select chinese from v2 LIMIT 1 ) WITH CHECK OPTION;
create or REPLACE view v4 as SELECT * from v3 where chinese<=110 and math<155 and english>=59.5 WITH CHECK OPTION;
replace into v4 values(2,'小王',29,110,115);
replace into v4 values(2,'小超',107,154,108);
replace into v4 values(3,'小李',100,129,59.51);
replace into v4 values(4,'小李',100,129,59.59);
replace into v4 values(5,'小李',100,129,60.1);
update v4 set english=75 where english=(SELECT english from v3 where a1=5);
SELECT * from test1 order by a1 asc;
a1	name	chinese	math	english
