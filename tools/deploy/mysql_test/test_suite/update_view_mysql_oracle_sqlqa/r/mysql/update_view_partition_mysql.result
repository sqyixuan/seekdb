#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#view-4   分区
#view-5   视图嵌套
create database hz;
use hz;
drop table test1;
drop TABLE test2;
drop view v1;
drop view v2;
drop view v3;
drop view v4;
#分区-4
#分区-4-1  list分区
create table test1(a1 int,chinese int,math int,english int)partition by list(a1)(partition p2 values in(1,2));
create or REPLACE view v1 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
replace INTO v1 partition(p0) VALUES(0,110,101,119);
replace INTO v1 partition(p0) VALUES(1,112,150,100);
replace INTO v1 partition(p0) VALUES(2,110,101,119);
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	100
2	110	101	119
SELECT * from v1 order by a1 asc;
a1	chinese	math	english
1	112	150	100
2	110	101	119
replace INTO v1 partition(p0) VALUES(3,110,101,119);
replace INTO v1 partition(p1) VALUES(0,110,101,119);
replace INTO v1 partition(p1) VALUES(1,110,101,119);
replace INTO v1 partition(p1) VALUES(2,110,101,119);
replace INTO v1 partition(p1) VALUES(3,110,101,119);
INSERT INTO v1 partition(p2) VALUES(0,110,101,119);
INSERT INTO v1 partition(p2) VALUES(1,110,101,119);
INSERT INTO v1 partition(p2) VALUES(2,110,101,119);
INSERT INTO v1 partition(p2) VALUES(3,110,101,119);
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	100
1	110	101	119
1	110	101	119
2	110	101	119
2	110	101	119
2	110	101	119
