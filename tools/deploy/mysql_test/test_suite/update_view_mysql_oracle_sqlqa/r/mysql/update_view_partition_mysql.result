a1	chinese	math	english
1	112	150	100
1	110	101	119
1	110	101	119
2	110	101	119
2	110	101	119
2	110	101	119
UPDATE v1 partition(p0) set english=math-1;
UPDATE v1 partition(p0) set english=english-20;
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	80
1	110	101	99
1	110	101	99
2	110	101	99
2	110	101	99
2	110	101	99
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	112	150	80
1	110	101	99
1	110	101	99
2	110	101	99
2	110	101	99
2	110	101	99
delete from v1 partition(p0) where math=some(SELECT math from v1 where math=101);
delete from v1 partition(p0) where math>(SELECT math from v1 where math=101);
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	80
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	112	150	80
UPDATE v1 partition(p0) set english=null;
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	80
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	112	150	80
UPDATE v1 partition(p0) set english=119;
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	112	150	119
SELECT * from v1 partition(p0) order by a1 asc;
a1	chinese	math	english
1	112	150	119
UPDATE v1 partition(p1) set english=english+119;
drop view v1;
drop table test1;
#分区-4-2    hash 分区
create table test1(a1 int,chinese int,math int,english int)partition by hash(a1);
create or REPLACE view v1 as SELECT * from test1 where chinese<=121 and math>=100 and english<120 WITH CHECK OPTION;
replace INTO v1 partition(p0) VALUES(1,110,101,119);
insert  INTO v1 partition(p0) VALUES(2,112,150,100);
insert  INTO v1 partition(p0) VALUES(3,118,140,115);
SELECT * from test1 order by a1 asc;
a1	chinese	math	english
1	110	101	119
2	112	150	100
3	118	140	115
