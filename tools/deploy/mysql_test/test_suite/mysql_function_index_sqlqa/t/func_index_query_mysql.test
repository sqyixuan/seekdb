select id,c1 from table1 where date(c1) >= date'2023-02-26' order by 1,2;
select id,c1 from table1 where date(c1) < timestamp'2023-02-26 12:00:00' order by 1,2;
select id,c1 from table1 where date(c1) <= date('2023-02-26') order by 1,2;
select id,c1 from table1 where date(c1) = timestamp('2023-02-26') order by 1,2;
select id,c1 from table1 where date(c1) > cast('2023-02-26' as date) order by 1,2;
