purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo -------------------------------------------------------------------------------------
--echo ######################## 标签：func_index-7 函数索引抽取强化 ########################
--echo ################ mysql_func_index-7-1 表达式的匹配 
--echo ###### date CHAR/VARCHAR/DATE/DATETIME/TIMESTAMP->DATE
--error 0,1051
drop table table1;
create table table1(
  id int, 
  c1 char(100), 
  c2 varchar(100),
  c3 date,
  c4 datetime,
  c5 timestamp,
  index idx1 ((date(c1))),
  index idx2 ((date(c2))),
  index idx3 ((date(c3))),
  index idx4 ((date(c4))));

INSERT INTO table1 VALUES (1,NULL,NULL,NULL,NULL,NULL);
