purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
--disable_warnings
--echo ------------------------------------------------------------------------------------
--echo ######################## 标签：func_index-1 函数索引的创建  ########################
--echo ######################## 标签：func_index-3 函数            ########################
--echo ################ 系统函数的结果是否受到系统变量的影响
--error 0,1051
drop table table1;
create table table1 ( 
  id int,
  c1 char(50), 
  c2 varchar(50), 
  c3 binary(50),
  c4 varbinary(50), 
  c5 enum('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c6 set('a', 'b', 'c', 'd', 'e'),
  c7 tinyint, 
  c8 smallint,
  c9 mediumint, 
  c10 int, 
  c11 bigint, 
  c12 float, 
  c13 double, 
  c14 decimal(5,2), 
  c15 bit(20),
  c16 bool,
  c17 point,
  c18 date, 
  c19 time, 
  c20 year, 
  c21 datetime, 
  c22 timestamp,
  c23 geometry);

