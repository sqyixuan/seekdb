  name VARCHAR(50),
  type VARCHAR(50));

CREATE TABLE table6_const (
  id INT PRIMARY KEY,
  name VARCHAR(50) UNIQUE,
  age INT NOT NULL,
  salary DECIMAL(10,2) DEFAULT 0.00,
  email VARCHAR(50) CHECK (email LIKE '%@%.%'),
  department_id int,
  gender ENUM('M', 'F'),
  birthdate DATE,
  CONSTRAINT fk_department FOREIGN KEY (department_id) REFERENCES table6(id)
);

