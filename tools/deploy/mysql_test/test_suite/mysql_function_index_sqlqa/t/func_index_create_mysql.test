# owner: sean.yyj
# owner group: sql-优化器
# description: mysql 函数索引的创建
# tags: ddl,dml
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo ------------------------------------------------------------------------------------
--echo ######################## 标签：func_index-1 函数索引的创建  ########################
--echo ######################## 标签：func_index-4 数据类型        ########################
--echo ######################## 标签：func_index-5 表 - 分区表     ########################
--echo ################ create 语句
--echo ###### create table 语句
--error 0,1051
drop table table1_range;
CREATE TABLE table1_range (
  id int,
  c1 char(10),
  c2 varchar(100),
  c3 binary(100),
  c4 varbinary(100),
  c5 enum('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'),
  c6 set('a', 'b', 'c', 'd', 'e'),
  index index1 ((SUBSTRING_INDEX(c1, ' ', -1)))
) PARTITION BY RANGE (id) (
 PARTITION p0 VALUES LESS THAN (5),
 PARTITION p1 VALUES LESS THAN (10),
 PARTITION p2 VALUES LESS THAN MAXVALUE);
#explain select * from table1_range where SUBSTRING_INDEX(c1, ' ', -1) ='A';
#explain select /*+index(table1_range index1)*/ * from table1_range where SUBSTRING_INDEX(c1, ' ', -1) ='A';

--error 0,1051
drop table table2_list;
CREATE TABLE table2_list (
  id INT NOT NULL,
  c1 tinyint,
  c2 smallint,
  c3 mediumint,
  c4 int,
  c5 bigint,
  c6 float,
  c7 double,
  c8 decimal(5,2),
  c9 bit(10),
  c10 bool,
  index index2 ((c1+c2-1*2/3))
)PARTITION BY LIST(c1)(
 PARTITION p0 VALUES IN (1,2,3,4,5),
 PARTITION p1 VALUES IN (6,7,8,9,10),
 PARTITION p2 VALUES IN (11,12,13,14,15));
#explain select * from table2_list where c1+c2-1*2/3 > 0;

--error 0,1051
drop table table3_hash;
CREATE TABLE table3_hash (
  id INT NOT NULL,
  c1 date,
  c2 time,
  c3 year,
  c4 datetime,
  c5 timestamp,
 index index3 ((date(c4)) ASC)
)PARTITION BY HASH(id) PARTITIONS 3;
#explain select * from table3_hash where date(c4) = '2023-01-01';

--error 0,1051
drop table table4_key;
CREATE TABLE table4_key (
  id INT NOT NULL PRIMARY KEY,
  c1 int,
  c2 char(10),
  index index4 ((c1>1))
)PARTITION BY KEY() PARTITIONS 3;
#explain select * from table4_key where c1 > 1;

--error 0,1051
drop table table_order;
CREATE TABLE table_order (
  id INT NOT NULL PRIMARY KEY,
  c1 int,
  c2 char(10),
  index index4 ((c1>1) DESC)
);


--echo ###### create table... like 语句
--error 0,1051
drop table like_table_range;
create table like_table_range like table1_range;
show create table like_table_range;

--error 0,1051
drop table like_table2_list;
create table like_table2_list like table2_list;
show create table like_table2_list;

--error 0,1051
drop table like_table3_hash;
create table like_table3_hash like table3_hash;
show create table like_table3_hash;

--error 0,1051
drop table like_table4_key;
create table like_table4_key like table4_key;
show create table like_table4_key;


--echo ###### create table... #explain select 语句
--error 0,1051
drop table select_table_range;
create table select_table_range select* from table2_list;
show create table select_table_range;


--echo ###### create index 语句
--error 0,1051
drop table table6_const;
--error 0,1051
drop table table5;
CREATE TABLE table5 (
  id INT NOT NULL PRIMARY KEY,
  c1 int,
  c2 float,
  c3 char(10));

--error 0,1091
drop index index50 on table5;
create index index50 on table5 ((c1+c2));
create index index51 on table5 ((floor(c2)) DESC) ;
create index index52 on table5 ((floor(c2)) ASC) ;

--error 0,1091
drop index index51 on table5;
create unique index index51 on table5 ((c1+c2));

--error 1072
create fulltext index index52 on table5 ((c1+c2 < 1));

--error 1064
create spatial index index53 on table5 (abs(c1+c2));


--echo ################ alter 语句
alter table table5 add index index54 ((concat(c3,'abc')));
alter table table5 add index index55 ((c1+1) ASC);
alter table table5 add index index56 ((c1*2) DESC);
alter table table5 add index ((c1+2));


show create table table5;

alter table table5 drop index index54;
show create table table5;

--echo ################ drop 语句
drop index index51 on table5;
show create table table5;


