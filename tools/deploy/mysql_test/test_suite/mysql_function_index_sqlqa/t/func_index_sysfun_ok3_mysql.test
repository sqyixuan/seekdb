--echo #### STR_TO_DATE()
create index index29_18_1 on table1 ((STR_TO_DATE(c18, '%Y-%m-%d')));
create index index29_20_1 on table1 ((STR_TO_DATE(c20, '%Y-%m-%d')));
create index index29_21_1 on table1 ((STR_TO_DATE(c21, '%Y-%m-%d')));
create index index29_22_1 on table1 ((STR_TO_DATE(c22, '%Y-%m-%d')));
select id,c18,STR_TO_DATE(c18,'%Y-%m-%d') from table1 where STR_TO_DATE(c18,'%Y-%m-%d') = '2021-08-27' order by id;
select id,c20,STR_TO_DATE(c20,'%Y-%m-%d') from table1 where STR_TO_DATE(c20,'%Y-%m-%d') = '2022-00-00' order by id;
select id,c21,STR_TO_DATE(c21,'%Y-%m-%d') from table1 where STR_TO_DATE(c21,'%Y-%m-%d') = '2020-08-27' order by id;
select id,c22,STR_TO_DATE(c22,'%Y-%m-%d') from table1 where STR_TO_DATE(c22,'%Y-%m-%d') = '2020-08-27' order by id;

