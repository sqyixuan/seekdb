select id,c22,TO_DAYS(c22) from table1 where TO_DAYS(c22) = 738029 order by id;

SET sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';
create index index219_2 on table1 ((TO_DAYS(c18)));
create index index222_2 on table1 ((TO_DAYS(c21)));
create index index223_2 on table1 ((TO_DAYS(c22)));
select id,c18,TO_DAYS(c18) from table1 where TO_DAYS(c18) = 738394 order by id;
select id,c21,TO_DAYS(c21) from table1 where TO_DAYS(c21) = 738029 order by id;
select id,c22,TO_DAYS(c22) from table1 where TO_DAYS(c22) = 738029 order by id;

--echo ######## 系统变量 time_zone
SET @@session.time_zone = '+8:00';
create index index219_3 on table1 ((TO_DAYS(c18)));
create index index222_3 on table1 ((TO_DAYS(c21)));
create index index223_3 on table1 ((TO_DAYS(c22)));
select id,c18,TO_DAYS(c18) from table1 where TO_DAYS(c18) = 738394 order by id;
select id,c21,TO_DAYS(c21) from table1 where TO_DAYS(c21) = 738029 order by id;
select id,c22,TO_DAYS(c22) from table1 where TO_DAYS(c22) = 738029 order by id;

SET @@session.time_zone = '+10:00';
create index index219_4 on table1 ((TO_DAYS(c18)));
create index index222_4 on table1 ((TO_DAYS(c21)));
create index index223_4 on table1 ((TO_DAYS(c22)));
select id,c18,TO_DAYS(c18) from table1 where TO_DAYS(c18) = 738394 order by id;
select id,c21,TO_DAYS(c21) from table1 where TO_DAYS(c21) = 738029 order by id;
