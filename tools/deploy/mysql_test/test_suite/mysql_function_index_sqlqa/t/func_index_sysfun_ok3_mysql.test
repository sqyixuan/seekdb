  c11 bigint, 
  c12 float, 
  c13 double, 
  c14 decimal(5,2), 
  c15 bit(20),
  c16 bool,
  c17 point,
  c18 date, 
  c19 time, 
  c20 year, 
  c21 datetime, 
  c22 timestamp,
  c23 geometry);

