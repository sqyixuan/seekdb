######## дёҖдёӘиЎЁжңҖеӨҡе…Ғи®ёеҲӣе»ә128дёӘзҙўеј•пјҢзҙўеј•жӯӨеӨ„йҮҚж–°еҲ йҷӨеҲӣе»әиЎЁ
drop table table1;
create table table1 ( 
  id int,
  c1 char(50), 
  c2 varchar(50), 
  c3 binary(50),
  c4 varbinary(50), 
  c5 enum('жҳҹжңҹдёҖ', 'жҳҹжңҹдәҢ', 'жҳҹжңҹдёү', 'жҳҹжңҹеӣӣ', 'жҳҹжңҹдә”', 'жҳҹжңҹе…ӯ'), 
  c6 set('a', 'b', 'c', 'd', 'e'),
  c7 tinyint, 
  c8 smallint,
  c9 mediumint, 
  c10 int, 
  c11 bigint, 
  c12 float, 
  c13 double, 
  c14 decimal(5,2), 
  c15 bit(20),
  c16 bool,
  c17 point,
  c18 date, 
  c19 time, 
  c20 year, 
  c21 datetime, 
  c22 timestamp,
  c23 geometry);
