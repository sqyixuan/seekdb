#### time -》time/timestamp/datetime
drop table table1;
create table table1(
  id int, 
  c1 time,
  c11 time as (c1+1),
  c12 timestamp as (c1+2),
  c13 datetime as (c1+3));
drop index idx1 on table1;
drop index idx2 on table1;
drop index idx3 on table1;
create index idx1 on table1(c11);
create index idx2 on table1(c12);
create index idx3 on table1(c13);
