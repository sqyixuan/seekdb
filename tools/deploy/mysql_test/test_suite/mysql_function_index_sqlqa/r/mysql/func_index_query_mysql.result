#### float -》float/double
drop table table1;
create table table1(
  id int, 
  c1 float,
  c11 float as (c1+1),
  c12 double as (c1*2));
drop index idx1 on table1;
create index idx1 on table1(c11);
INSERT INTO table1(id,c1) VALUES (1,NULL),(2,0),(3,11.123),(4,12.345),(5,13.567),(6,14.789),(7,15.987);
select * from table1 where cast(c1+1 as float) > 3.5 order by 1,2;
