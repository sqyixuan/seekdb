#### timestamp/datetime -》timestamp/datetime
drop table table1;
create table table1(
  id int, 
  c1 timestamp,
  c2 datetime,
  c12 timestamp as (c2+1),
  c22 datetime as (c2+5));
drop index idx1 on table1;
drop index idx2 on table1;
drop index idx3 on table1;
drop index idx4 on table1;
create index idx2 on table1(c12);
create index idx4 on table1(c22);
