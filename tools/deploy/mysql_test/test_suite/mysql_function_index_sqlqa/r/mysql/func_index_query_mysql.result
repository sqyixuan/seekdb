################ mysql_func_index-7-2 like表达式前缀索引抽取
drop table table1;
create table table1 (
  id int,
  col_char char(20),
  col_varchar varchar(20),
  col_tinytext tinytext,
  col_text text,
  col_mediumtext mediumtext,
  col_longtext longtext,
  col_binary binary(20),
  col_varbinary varbinary(20),
  col_tinyblob tinyblob,
  col_blob blob,
  col_mediumblob mediumblob,
  col_longblob longblob,
  index idx1 (col_char(3)),
  index idx2 (col_varchar(3)),
  index idx3 (col_tinytext(3)),
  index idx4 (col_text(3)),
  index idx5 (col_mediumtext(3)),
  index idx6 (col_longtext(3)),
  index idx7 (col_binary(3)),
  index idx8 (col_varbinary(3)),
  index idx9 (col_tinyblob(3)),
  index idx10 (col_blob(3)),
  index idx11 (col_mediumblob(3)),
  index idx12 (col_longblob(3))
);
