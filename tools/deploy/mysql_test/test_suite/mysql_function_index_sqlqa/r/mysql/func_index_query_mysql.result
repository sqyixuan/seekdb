###### timestamp CHAR/VARCHAR/DATE/DATETIME/TIMESTAMP->TIMESTAMP
drop table table1;
create table table1(
  id int, 
  c1 char(100), 
  c2 varchar(100),
  c3 date,
  c4 datetime,
  c5 timestamp,
  index idx1 ((timestamp(c1))),
  index idx2 ((timestamp(c2))),
  index idx3 ((timestamp(c3))),
  index idx4 ((timestamp(c4))));
