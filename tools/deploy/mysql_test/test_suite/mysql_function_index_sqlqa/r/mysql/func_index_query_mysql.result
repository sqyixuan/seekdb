######################## 标签：func_index-7 函数索引抽取强化 ########################
################ mysql_func_index-7-1 表达式的匹配 
###### date CHAR/VARCHAR/DATE/DATETIME/TIMESTAMP->DATE
drop table table1;
create table table1(
  id int, 
  c1 char(100), 
  c2 varchar(100),
  c3 date,
  c4 datetime,
  c5 timestamp,
  index idx1 ((date(c1))),
  index idx2 ((date(c2))),
  index idx3 ((date(c3))),
  index idx4 ((date(c4))));
INSERT INTO table1 VALUES (1,NULL,NULL,NULL,NULL,NULL);
