################ mysql_func_index-7-3 显示复合表达式的场景
######## 数据类型转换 
#### int -》int
drop table table1;
create table table1(
  id int, 
  c1 int, 
  c11 int as (c1+1));
drop index idx1 on table1;
create index idx1 on table1(c11);
INSERT INTO table1(id,c1) VALUES (1,NULL),(2,0),(3,1),(4,2.1),(5,3.5),(6,4.0),(7,5.9);
select * from table1 where cast(c1+1 as SIGNED) >  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where cast(c1+1 as SIGNED) >= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    4 |    2 |    3 |
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where cast(c1+1 as SIGNED) <  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
+------+------+------+
select * from table1 where cast(c1+1 as SIGNED) <= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
|    4 |    2 |    3 |
+------+------+------+
select * from table1 where cast(c1+1 as UNSIGNED) >  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where cast(c1+1 as UNSIGNED) >= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    4 |    2 |    3 |
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where cast(c1+1 as UNSIGNED) <  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
+------+------+------+
select * from table1 where cast(c1+1 as UNSIGNED) <= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
|    4 |    2 |    3 |
+------+------+------+
select * from table1 where c1+1 >  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where c1+1 >= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    4 |    2 |    3 |
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
