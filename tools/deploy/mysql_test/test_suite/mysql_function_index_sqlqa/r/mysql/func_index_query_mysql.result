+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
+------+------+------+
select * from table1 where c1+1 <= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    2 |    0 |    1 |
|    3 |    1 |    2 |
|    4 |    2 |    3 |
+------+------+------+
select * from table1 where c11 >  3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
+------+------+------+
select * from table1 where c11 >= 3 order by 1,2;
+------+------+------+
| id   | c1   | c11  |
+------+------+------+
|    4 |    2 |    3 |
|    5 |    4 |    5 |
|    6 |    4 |    5 |
|    7 |    6 |    7 |
