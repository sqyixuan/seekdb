######################## 标签：func_index-8 其他场景    ########################
drop table table10;
CREATE TABLE table10 (
  id int,
  c1 char(10),
  c2 varchar(100),
  c3 int,
  c4 float,
  c5 double);
###### 创建相同的函数索引
create index index1 on table10 ((concat(c1,c2)));
create index index2 on table10 ((concat(c1,c2)));
###### 函数索引的索引键是字段前缀
create index index3 on table10 (c1(5));
###### 函数索引的索引键是一个单独的列名
create index index4 on table10 ((c1));
ERROR HY000: Functional index on a column is not supported. Consider using a regular index instead.
###### 函数索引的表达式没有位于括号之中
create index index4 on table10 (c3+c4);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '+c4)' at line 1
###### 函数索引的索引键是表达式以外的场景
### 子查询
create index index4 on table10 ((select 1+1 from dual));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'select 1+1 from dual))' at line 1
### 参数
drop procedure p0;/
create procedure p0(a varchar(10))
begin
  declare var varchar(10);
  set var  = 'c4+2';
  create index index4 on table10 (a);
  create index index5 on table10 (var);
end;
/
call p0('c3+1');
ERROR 42000: Key column 'a' doesn't exist in table
### 变量
create index index4 on table10 ((@@hostname));
ERROR 0A000: use variables in generated column not supported
set @var = 'c5+1';
create index index4 on table10 ((@var));
ERROR 0A000: use variables in generated column not supported
### 存储过程
create index index4 on table10 (p0('c3+1'));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ''c3+1'))' at line 1
### 用户定义的函数
drop function fun1;/
create function fun1() returns int NO SQL
begin
  return 1;
end;
/
create index index4 on table10 ((c3+fun1()));
ERROR 0A000: using udf as generated column not supported
###### 一个字段被用于函数索引，删除该字段会报错
create index index5 on table10 ((c3+c4));
alter table table10 drop COLUMN c3;
ERROR HY000: Column 'c3' has a functional index dependency and cannot be dropped or renamed.
###### 一个字段被用于函数索引，先删除该函数索引，再删除该字段不会报错
drop index index5 on table10;
alter table table10 drop COLUMN c3;
# Clean up users
drop user whh@'%';
