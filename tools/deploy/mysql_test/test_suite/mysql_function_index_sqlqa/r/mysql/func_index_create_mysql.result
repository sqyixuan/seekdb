purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
------------------------------------------------------------------------------------
######################## 标签：func_index-1 函数索引的创建  ########################
######################## 标签：func_index-4 数据类型        ########################
######################## 标签：func_index-5 表 - 分区表     ########################
################ create 语句
###### create table 语句
drop table table1_range;
CREATE TABLE table1_range (
  id int,
  c1 char(10),
  c2 varchar(100),
  c3 binary(100),
  c4 varbinary(100),
  c5 enum('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'),
  c6 set('a', 'b', 'c', 'd', 'e'),
  index index1 ((SUBSTRING_INDEX(c1, ' ', -1)))
) PARTITION BY RANGE (id) (
 PARTITION p0 VALUES LESS THAN (5),
 PARTITION p1 VALUES LESS THAN (10),
 PARTITION p2 VALUES LESS THAN MAXVALUE);
drop table table2_list;
CREATE TABLE table2_list (
  id INT NOT NULL,
  c1 tinyint,
  c2 smallint,
  c3 mediumint,
  c4 int,
  c5 bigint,
  c6 float,
  c7 double,
  c8 decimal(5,2),
  c9 bit(10),
  c10 bool,
  index index2 ((c1+c2-1*2/3))
)PARTITION BY LIST(c1)(
 PARTITION p0 VALUES IN (1,2,3,4,5),
 PARTITION p1 VALUES IN (6,7,8,9,10),
 PARTITION p2 VALUES IN (11,12,13,14,15));
drop table table3_hash;
CREATE TABLE table3_hash (
  id INT NOT NULL,
  c1 date,
  c2 time,
  c3 year,
  c4 datetime,
  c5 timestamp,
 index index3 ((date(c4)) ASC)
)PARTITION BY HASH(id) PARTITIONS 3;
drop table table4_key;
CREATE TABLE table4_key (
  id INT NOT NULL PRIMARY KEY,
  c1 int,
  c2 char(10),
  index index4 ((c1>1))
)PARTITION BY KEY() PARTITIONS 3;
drop table table_order;
CREATE TABLE table_order (
  id INT NOT NULL PRIMARY KEY,
  c1 int,
  c2 char(10),
  index index4 ((c1>1) DESC)
);
###### create table... like 语句
drop table like_table_range;
create table like_table_range like table1_range;
show create table like_table_range;
Table	Create Table
like_table_range	CREATE TABLE `like_table_range` (
  `id` int(11) DEFAULT NULL,
  `c1` char(10) DEFAULT NULL,
  `c2` varchar(100) DEFAULT NULL,
  `c3` binary(100) DEFAULT NULL,
  `c4` varbinary(100) DEFAULT NULL,
  `c5` enum('星期一','星期二','星期三','星期四','星期五','星期六') DEFAULT NULL,
  `c6` set('a','b','c','d','e') DEFAULT NULL,
  KEY `index1` ((SUBSTRING_INDEX(`c1`,' ',-1))) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (5),
partition `p1` values less than (10),
partition `p2` values less than (MAXVALUE))
drop table like_table2_list;
create table like_table2_list like table2_list;
show create table like_table2_list;
Table	Create Table
like_table2_list	CREATE TABLE `like_table2_list` (
  `id` int(11) NOT NULL,
  `c1` tinyint(4) DEFAULT NULL,
  `c2` smallint(6) DEFAULT NULL,
  `c3` mediumint(9) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` bigint(20) DEFAULT NULL,
  `c6` float DEFAULT NULL,
  `c7` double DEFAULT NULL,
  `c8` decimal(5,2) DEFAULT NULL,
  `c9` bit(10) DEFAULT NULL,
  `c10` tinyint(1) DEFAULT NULL,
  KEY `index2` (((`c1` + `c2`) - ((1 * 2) / 3))) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by list(c1)
(partition `p0` values in (1,2,3,4,5),
partition `p1` values in (6,7,8,9,10),
partition `p2` values in (11,12,13,14,15))
drop table like_table3_hash;
create table like_table3_hash like table3_hash;
show create table like_table3_hash;
Table	Create Table
like_table3_hash	CREATE TABLE `like_table3_hash` (
  `id` int(11) NOT NULL,
  `c1` date DEFAULT NULL,
  `c2` time DEFAULT NULL,
  `c3` year(4) DEFAULT NULL,
  `c4` datetime DEFAULT NULL,
  `c5` timestamp NULL DEFAULT NULL,
  KEY `index3` ((date(`c4`))) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(id)
(partition `p0`,
partition `p1`,
partition `p2`)
drop table like_table4_key;
create table like_table4_key like table4_key;
show create table like_table4_key;
Table	Create Table
like_table4_key	CREATE TABLE `like_table4_key` (
  `id` int(11) NOT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` char(10) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `index4` ((`c1` > 1)) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key()
(partition `p0`,
partition `p1`,
partition `p2`)
