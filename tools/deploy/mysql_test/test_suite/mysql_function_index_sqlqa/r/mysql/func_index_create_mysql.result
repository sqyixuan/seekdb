###### 约    束
drop table pk_table;
create table pk_table (
  c1 int,
  c2 int,
  index i1 ((c1+1)),
  primary key ((c1+c2)));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(c1+c2)))' at line 5
drop table table6_const;
drop table table6;
CREATE TABLE table6 (
  id INT PRIMARY KEY,
  name VARCHAR(50),
  type VARCHAR(50));
CREATE TABLE table6_const (
  id INT PRIMARY KEY,
  name VARCHAR(50) UNIQUE,
  age INT NOT NULL,
  salary DECIMAL(10,2) DEFAULT 0.00,
  email VARCHAR(50) CHECK (email LIKE '%@%.%'),
  department_id int,
  gender ENUM('M', 'F'),
  birthdate DATE,
  CONSTRAINT fk_department FOREIGN KEY (department_id) REFERENCES table6(id)
);
create index index61 on table6_const ((id+1));
create index index62 on table6_const ((upper(name)));
create index index63 on table6_const ((floor(salary)));
create index index64 on table6_const ((lower(email)));
create index index65 on table6_const ((trim(gender)));
create index index66 on table6_const ((department_id+2));
