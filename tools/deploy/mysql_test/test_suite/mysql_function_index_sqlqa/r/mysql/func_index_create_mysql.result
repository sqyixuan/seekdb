  UNIQUE KEY `index51` ((`c1` + `c2`)) BLOCK_SIZE 16384 LOCAL,
  KEY `index50` ((`c1` + `c2`)) BLOCK_SIZE 16384 LOCAL,
  KEY `index52` ((floor(`c2`))) BLOCK_SIZE 16384 LOCAL,
