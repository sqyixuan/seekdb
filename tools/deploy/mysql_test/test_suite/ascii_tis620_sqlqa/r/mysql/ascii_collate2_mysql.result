drop table test_ascii_bak;

CREATE TABLE test_ascii_bak (
    c0 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE ascii_general_ci,
    c1 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE ascii_bin,
    c2 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE tis620_thai_ci,
    c3 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE tis620_bin,
    c4 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE utf8mb4_0900_ai_ci,
    c5 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE ascii_general_ci,
    c6 ENUM('$', 'Y', '123', '123.1', 'abc ABC', 'abc&ABC', '2010-11-11', 'A', 'B') COLLATE ascii_bin,
    sal INT,
    id INT
) CHARACTER SET ascii;

