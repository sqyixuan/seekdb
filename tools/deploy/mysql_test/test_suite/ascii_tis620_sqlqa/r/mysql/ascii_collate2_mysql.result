drop table test_ascii_bak;

CREATE TABLE test_ascii_bak(
    c0 SET('$', 'A', 'B') COLLATE ascii_general_ci,
    c1 SET('$', 'A', 'B') COLLATE ascii_bin,
    c2 SET('$', 'A', 'B') COLLATE tis620_thai_ci,
    c3 SET('$', 'A', 'B') COLLATE tis620_bin,
    c4 SET('$', 'A', 'B') COLLATE utf8mb4_0900_ai_ci,
    c5 SET('$', 'A', 'B') COLLATE ascii_general_ci,
    c6 SET('$', 'A', 'B') COLLATE ascii_bin,
    sal INT,
    id INT
) CHARACTER SET ascii;

INSERT INTO test_ascii_bak (c0,c1,c2,c3,c4,c5,c6,sal) VALUES 
('A', 'A', 'A', 'A', 'A', 'A', 'A', 2300),
('B', 'B', 'B', 'B', 'B', 'B', 'B', 1800),
('$', '$', '$', '$', '$', '$', '$', 2000),
('A', 'A', 'A', 'A', 'A', 'A', 'A', 1800),
('B','B','B','B','B','B','B',1650),
('B','B','B','B','B','B','B',1500),
('B','B','B','B','B','B','B',1450);

