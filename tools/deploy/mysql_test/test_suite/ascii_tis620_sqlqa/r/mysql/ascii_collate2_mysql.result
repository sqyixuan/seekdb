#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'ascii';
set character_set_database = 'ascii';
set character_set_server = 'ascii';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ascii';
Charset	Description	Default collation	Maxlen
ascii	US ASCII	ascii_general_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	ascii
character_set_connection	ascii
character_set_database	ascii
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	ascii
character_set_system	utf8mb4

DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ASCII;
use db1;

===================================================test basic code ==================================================
drop table ascii_table;
drop procedure build_ascii_table;
drop table ascii_bin_table;
drop procedure build_ascii_bin_table;
create table ascii_table(c1 char(3) charset ascii collate ascii_general_ci);
create table ascii_bin_table(c1 char(3) charset ascii collate ascii_bin);

create procedure build_ascii_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into ascii_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ascii_table();
/
