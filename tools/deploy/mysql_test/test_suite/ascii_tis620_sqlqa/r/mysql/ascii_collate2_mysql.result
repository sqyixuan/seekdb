drop table test_ascii_bak;
create table test_ascii_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate ascii_bin generated always as(concat(c0,c1)) ) character set ascii;

drop procedure build_ascii_table2;

create procedure build_ascii_table2()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into test_ascii_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_ascii_table2();
/
SELECT c0,c1,
  hex(c1),
  hex(@u:=convert(c1 using utf8))
  FROM test_ascii_bak order by c1;
