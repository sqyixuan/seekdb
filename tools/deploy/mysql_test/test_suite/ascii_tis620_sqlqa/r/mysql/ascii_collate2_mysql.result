drop table test_ascii_bak;
create table test_ascii_bak(c0 varchar(100) collate ascii_general_ci,c1 varchar(100) collate ascii_bin,c2 varchar(100) collate tis620_thai_ci,c3 varchar(100) collate tis620_bin,c4 varchar(100) collate utf8mb4_0900_ai_ci,c5 varchar(100) collate ascii_general_ci,c6 varchar(100) collate ascii_bin,sal int,id int) character set ascii;

drop procedure test_ascii_bak_ascii_pro;

create procedure test_ascii_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<128
  DO
      insert into test_ascii_bak values(unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),unhex(hex(i)),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call test_ascii_bak_ascii_pro();
/
