drop table test_ascii_bak;

CREATE TABLE test_ascii_bak(
c0 TEXT COLLATE ascii_general_ci,
c1 TEXT COLLATE ascii_bin,
c2 TEXT COLLATE tis620_thai_ci,
c3 TEXT COLLATE tis620_bin,
c4 TEXT COLLATE utf8mb4_0900_ai_ci,
c5 TEXT COLLATE ascii_general_ci,
c6 TEXT COLLATE ascii_bin,
sal INT,
id INT
) CHARACTER SET ascii;

drop procedure test_ascii_bak_ascii_pro3;

CREATE PROCEDURE test_ascii_bak_ascii_pro3()
BEGIN
  DECLARE i INT DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO test_ascii_bak(c0, c1, c2, c3, c4, c5, c6, sal, id)
    VALUES(CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), CONVERT(CHAR(i) USING ascii), i, i);
    SET i = i + 1;
  END WHILE;
  COMMIT;
END /

CALL test_ascii_bak_ascii_pro3();
