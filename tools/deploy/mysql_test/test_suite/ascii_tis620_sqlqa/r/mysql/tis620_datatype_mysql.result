TRUNCATE TABLE t2;
DROP PROCEDURE create_TIS6204;
CREATE PROCEDURE create_TIS6204()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 255;

  WHILE i <= max_value DO
    IF i BETWEEN 48 AND 58 THEN
      INSERT INTO t2 (numeric_column, float_column, double_column)
      VALUES (CHAR(i), CHAR(i), CHAR(i));
    END IF;

    SET i = i + 1;
  END WHILE;
END;
//
call create_TIS6204();
