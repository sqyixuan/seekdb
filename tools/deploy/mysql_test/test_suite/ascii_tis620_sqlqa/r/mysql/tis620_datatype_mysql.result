DROP PROCEDURE create_TIS6205;
CREATE PROCEDURE create_TIS6205()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 256;

  WHILE i <= max_value DO
    select char(i);
    SET i = i + 1;
  END WHILE;
END;
//

call create_TIS6205();
