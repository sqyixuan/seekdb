############################# жХ∞е≠Чз±їеЮЛ #############################
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numeric_column DECIMAL(10, 2) NOT NULL,
    float_column FLOAT,
    double_column DOUBLE
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS6203;
CREATE PROCEDURE create_TIS6203()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (float_column,double_column)
    VALUES (char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//

call create_TIS6203();
