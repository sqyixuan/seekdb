    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = ASCII;
DROP PROCEDURE create_ascii8;
CREATE PROCEDURE create_ascii8()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

