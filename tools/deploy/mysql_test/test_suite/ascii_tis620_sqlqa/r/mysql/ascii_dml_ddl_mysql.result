DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ASCII;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = ASCII;
DROP PROCEDURE create_ascii2;
CREATE PROCEDURE create_ascii2()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

### --error 1366
