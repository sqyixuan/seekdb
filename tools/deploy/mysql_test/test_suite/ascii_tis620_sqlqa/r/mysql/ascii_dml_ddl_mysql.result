#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'ascii';
set character_set_database = 'ascii';
set character_set_server = 'ascii';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ascii';
Charset	Description	Default collation	Maxlen
ascii	US ASCII	ascii_general_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	ascii
character_set_connection	ascii
character_set_database	ascii
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	ascii
character_set_system	utf8mb4

########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ASCII;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = ASCII;
DROP PROCEDURE create_ascii;

CREATE PROCEDURE create_ascii()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

### --error 1366
call create_ascii();
select * from t2 order by id,a;
