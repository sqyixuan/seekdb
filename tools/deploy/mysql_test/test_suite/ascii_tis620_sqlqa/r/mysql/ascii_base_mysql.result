DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ascii;

use db1;

drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

DROP PROCEDURE create_ascii;
CREATE PROCEDURE create_ascii()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t1 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_ascii();

