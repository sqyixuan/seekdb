不同字符集联合查询（hex、convert）
select count(*) from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;
+----------+
| count(*) |
+----------+
|        1 |
+----------+
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using ASCII))=hex(convert(db2.t1.a using ASCII));
+----------+
| count(*) |
+----------+
|       19 |
+----------+
select count(*) from db1.t1,db2.t1 where db1.t1.a=convert(db2.t1.a using ASCII);
+----------+
| count(*) |
+----------+
|       19 |
+----------+
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using gb18030)=db2.t1.a;
+----------+
| count(*) |
+----------+
|        1 |
+----------+
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using ASCII)=db2.t1.a;
+----------+
| count(*) |
+----------+
|        1 |
+----------+
select count(*) from db1.t1,db2.t1 where convert(db2.t1.a using ASCII)=db1.t1.a;
+----------+
| count(*) |
+----------+
|       19 |
+----------+
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using ASCII))=hex(convert(db2.t1.a using _gb18030));
