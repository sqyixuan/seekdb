drop table test_tis620_bak;

CREATE TABLE test_tis620_bak(
    c0 SET('$', 'A', 'B') COLLATE ascii_general_ci,
    c1 SET('$', 'A', 'B') COLLATE ascii_bin,
    c2 SET('$', 'A', 'B') COLLATE tis620_thai_ci,
    c3 SET('$', 'A', 'B') COLLATE tis620_bin,
    c4 SET('$', 'A', 'B') COLLATE utf8mb4_0900_ai_ci,
    c5 SET('$', 'A', 'B') COLLATE ascii_general_ci,
    c6 SET('$', 'A', 'B') COLLATE ascii_bin,
    sal INT,
    id INT
) CHARACTER SET tis620;

