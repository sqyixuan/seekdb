#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'tis620';
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
Charset	Description	Default collation	Maxlen
tis620	TIS620 Thai	tis620_thai_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	tis620
character_set_connection	tis620
character_set_database	tis620
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	tis620
character_set_system	utf8mb4

===================================================test basic code ==================================================
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;
drop table tis620_table;
drop procedure build_tis620_table;
drop table tis620_bin_table;
drop procedure build_tis620_bin_table;

create table tis620_table(c1 char(3) charset tis620 collate tis620_thai_ci);
create table tis620_bin_table(c1 char(3) charset tis620 collate tis620_bin);

create procedure build_tis620_table()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into tis620_table values(unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_tis620_table();
/
