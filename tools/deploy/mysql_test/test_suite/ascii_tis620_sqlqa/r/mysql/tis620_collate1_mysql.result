drop table test_tis620_bak;
create table test_tis620_bak(c0 varchar(100),c1 varchar(100),full varchar(100) collate tis620_bin generated always as(concat(c0,c1)) ) character set tis620;

drop procedure build_tis620_table2;

create procedure build_tis620_table2()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_tis620_bak(c0,c1) values(unhex(hex(i)),unhex(hex(i)));
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /

call build_tis620_table2();
/
