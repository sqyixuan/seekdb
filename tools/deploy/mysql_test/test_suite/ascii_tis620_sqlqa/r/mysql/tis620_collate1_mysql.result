show create table test_tis620_bak;
Table	Create Table
test_tis620_bak	CREATE TABLE `test_tis620_bak` (
  `c0` varchar(100) CHARACTER SET tis620 DEFAULT NULL,
  `c1` varchar(100) CHARACTER SET tis620 DEFAULT NULL,
  `full` varchar(100) CHARACTER SET tis620 COLLATE tis620_bin GENERATED ALWAYS AS (concat(`c0`,`c1`)) VIRTUAL
) ORGANIZATION INDEX DEFAULT CHARSET = gbk ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
