Table	Create Table
test_tis620_bak	CREATE TABLE `test_tis620_bak` (
  `c0` varchar(100) CHARACTER SET tis620 COLLATE tis620_bin DEFAULT 'ไธญๆ',
  `c1` varchar(100) DEFAULT 'ๅญ็ฌฆ',
  `c2` varchar(100) DEFAULT NULL,
  `c3` varchar(100) CHARACTER SET tis620 COLLATE tis620_bin DEFAULT NULL,
  `c4` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `c5` varchar(100) CHARACTER SET ascii DEFAULT NULL,
  `c6` varchar(100) CHARACTER SET ascii COLLATE ascii_bin DEFAULT NULL,
  `sal` int(11) DEFAULT NULL,
  `id` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = tis620 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0

