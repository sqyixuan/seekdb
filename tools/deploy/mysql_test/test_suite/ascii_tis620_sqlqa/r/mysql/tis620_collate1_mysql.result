drop table test_tis620_bak;
create table test_tis620_bak(c0 varchar(100) collate ascii_general_ci,c1 varchar(100) collate ascii_bin,c2 varchar(100) collate tis620_thai_ci,c3 varchar(100) collate tis620_bin,c4 varchar(100) collate utf8mb4_0900_ai_ci,c5 varchar(100) collate ascii_general_ci,c6 varchar(100) collate ascii_bin,sal int,id int) character set tis620;

drop procedure test_tis620_bak_ascii_pro;

create procedure test_tis620_bak_ascii_pro()
  begin
	DECLARE i int;
  set i=0;
  WHILE i<256
  DO
      insert into test_tis620_bak values(char(i),char(i),char(i),char(i),char(i),char(i),char(i),i,i);
  SET i=i+1;
  END WHILE;
  commit;
  end ;
  /
call test_tis620_bak_ascii_pro();
/

