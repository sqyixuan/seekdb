DROP PROCEDURE create_ascii4;
CREATE PROCEDURE create_ascii4()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 127;

  WHILE i <= max_value DO
    IF i BETWEEN 48 AND 58 THEN
      INSERT INTO t2 (numeric_column, float_column, double_column)
      VALUES (CHAR(i), CHAR(i), CHAR(i));
    END IF;

    SET i = i + 1;
  END WHILE;
END;
//

