############################# µĢ░ÕŁŚń▒╗Õ×ŗ #############################
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numeric_column DECIMAL(10, 2) NOT NULL,
    float_column FLOAT NOT NULL,
    double_column DOUBLE NOT NULL
)DEFAULT CHARACTER SET = ASCII;
DROP PROCEDURE create_ascii3;

CREATE PROCEDURE create_ascii3()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t2 (numeric_column,float_column,double_column)
    VALUES (char(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//

call create_ascii3();
