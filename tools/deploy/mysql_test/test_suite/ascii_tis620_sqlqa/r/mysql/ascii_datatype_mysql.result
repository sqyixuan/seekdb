use db1;
drop table t11;
ERROR 42S02: Unknown table 'db1.t11'
CREATE TABLE t11 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = utf8mb4;
DROP PROCEDURE create_ascii2;
CREATE PROCEDURE create_ascii2()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t11 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
    VALUES (char(i),char(i),char(i),char(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_ascii2();
select * from t1 order by id;
