DROP PROCEDURE create_tis6202;
CREATE PROCEDURE create_tis6202()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t3 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

call create_tis6202();
