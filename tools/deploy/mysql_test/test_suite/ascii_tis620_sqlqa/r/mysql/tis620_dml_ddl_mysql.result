########################## 字符转换为其他字符集 ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS62010;
CREATE PROCEDURE create_TIS62010()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_TIS62010();
select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by 1,2;
SELECT CONVERT(a USING utf8mb4) COLLATE utf8mb4_unicode_ci FROM db1.t2 order by 1;
SELECT CONVERT(a USING gb18030_2022) FROM db1.t2 order by 1;
SELECT CONVERT(a USING tis620) FROM db1.t2 order by 1;
SELECT CONVERT(a USING TIS620) FROM db1.t2 order by 1;
