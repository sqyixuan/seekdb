select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

select t2222.* from t2 t2222 order by id;
DROP DATABASE db2;
CREATE DATABASE db2 CHARACTER SET TIS620;
DROP table db2.t2;
CREATE TABLE db2.t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS6203;
CREATE PROCEDURE create_TIS6203()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO db2.t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

call create_TIS6203();
select * from db2.t2 order by id;
select * from db1.t2 order by id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 order by t1.id and t1.a;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id order by t1.id;

select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id = 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id > 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id < 100 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id between 100 and 200 order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id = 100 or t1.id = 10 order by t1.id;

select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a = 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a > 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a < 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a between 'a' and 'y' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a = 'w' or t1.id = 'p' order by t1.id;

select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like 'a' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like '%}%' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.id like 100 or t1.a like '% } %' order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a like ascii(44) order by t1.id;
select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a like char(44) order by t1.id;

select id,sum(a) from db1.t2 order by db1.t2.a;
select sum(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select count(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select count(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
select max(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select max(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
select min(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select min(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;
select avg(a) from db1.t2 group by db1.t2.a order by db1.t2.a;
select avg(a) from db1.t2 where db1.t2.id=100 group by db1.t2.a order by db1.t2.a;

select * from db1.t2 union select * from db2.t2;
select * from db1.t2 union all select * from db2.t2;
select * from (select * from db1.t2 union select * from db2.t2) t order by t.a;
select * from (select * from db1.t2 union all select * from db2.t2) t order by t.a;

DROP PROCEDURE create_TIS6204;
CREATE PROCEDURE create_TIS6204()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    select t2.*,t1.* from db2.t2 as t2 join db1.t2 as t1 on t1.id = t2.id where t1.a like char(i) order by t1.id;
    set i = i + 1;
  END WHILE;
END;
//

call create_TIS6204();

SELECT
    CASE
        WHEN db1.t2.a='p' THEN 'p'
        ELSE 'result_value_if_false'
    END
FROM db1.t2 order by db1.t2.a;

SELECT REPLACE('Aa', 'a', 'TIS620');
SELECT REPLACE('a', 'a', 'TIS620');
SELECT REPLACE('A', 'a', 'TIS620');
SELECT REPLACE('!@#$%^', '@', 'TIS620');
SELECT REPLACE('aaa!@#$%^', 'a', 'TIS620');
SELECT REPLACE('AAAA!@#$%^', 'a', 'TIS620');
SELECT ABS(ascii(a)) FROM db1.t2 order by db1.t2.a;
SELECT ABS(-989.77);
SELECT MOD(10, 3);
SELECT MOD(a, 3) from db1.t2 where a = 9 order by a;
SELECT MOD(a, 3) from db1.t2 where a = 8 order by a;
SELECT ROUND(3.14159, 2), ROUND(-123.456, 1);

SELECT
    id,
    IF(a >= 85, '优秀', '待提高') AS grade
FROM db1.t2 ORDER BY 1;

SELECT
    id,
    IF(a >= 8, '优秀', '待提高') AS grade
FROM db1.t2 ORDER BY 1;

SELECT
    id,
    IFNULL(a, '无记录') AS contact_info
FROM db1.t2 ORDER BY 1;

SELECT
    id,
    a,
    NULLIF(a, 0) AS adjusted_salary
FROM db1.t2 ORDER BY 1,2;

SELECT
    id,
    a,
    GREATEST(id, a) AS max_price
FROM db1.t2 ORDER BY 1,2;

SELECT
    id,
    a,
    LEAST(id, a) AS min_date
FROM db1.t2 ORDER BY 1,2;

SELECT
    id,
    a,
    ISNULL(a) AS is_inactive
FROM db1.t2 ORDER BY 1,2;

SELECT
    id,
    a,
    rowid,
    rownum
FROM db1.t2;

########################## insert ########################
DROP table db2.t2;
CREATE TABLE db2.t2 (
    a char(1)
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS6205;
CREATE PROCEDURE create_TIS6205()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO db2.t2 VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//

call create_TIS6205();
select * from db2.t2 order by a;

INSERT INTO db2.t2  (select a from db2.t2 order by a);
select * from db2.t2 order by a;

########################## update ########################
update db2.t2 set a = 'a' where a='a';
select * from db2.t2 where a='a' order by a;

update db2.t2 set a = 'A' where a='a';
select * from db2.t2 where a='A' order by a;

update db2.t2 set a = ']' where a='{';
select * from db2.t2 where a=']' order by a;

