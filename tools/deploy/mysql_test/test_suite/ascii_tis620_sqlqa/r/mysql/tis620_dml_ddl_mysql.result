#Environmental cleaning
purge recyclebin;
result_format: 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'tis620';
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
Charset	Description	Default collation	Maxlen
tis620	TIS620 Thai	tis620_thai_ci	1
show variables like 'character_set%';
Variable_name	Value
character_sets_dir	
character_set_client	tis620
character_set_connection	tis620
character_set_database	tis620
character_set_filesystem	binary
character_set_results	utf8mb4
character_set_server	tis620
character_set_system	utf8mb4

########################## select ########################
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS620;
CREATE PROCEDURE create_TIS620()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_TIS620();

select * from t2 order by id;
select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by id;

##with as
with with_as_name as(
    select id,a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2
)
select * from with_as_name order by with_as_name.id;

SELECT CONCAT('Hello, ', 'World!')as 'hw';
select CAST('balance' AS CHAR);
select DISTINCT a from db1.t2 order by 1;
select DISTINCT a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t2 order by 1,2;

DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    a char(1)
)DEFAULT CHARACTER SET = TIS620;
DROP PROCEDURE create_TIS6202;
CREATE PROCEDURE create_TIS6202()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (a) VALUES (char(i));
    set i = i + 1;
