#owner: sanquan.qz
#owner group:SQL-优化器
#tags: charset
#description:tis620 charset case
#author:wb-zcp01469308

connection default;
--echo #Environmental cleaning
purge recyclebin;
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'tis620';
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
show variables like 'character_set%';

--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET tis620;
use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

--error 0,1305
DROP PROCEDURE create_tis620;
delimiter //;
CREATE PROCEDURE create_tis620()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t1 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_tis620();
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;

--error 0,1051
drop table db1.t2;
CREATE TABLE db1.t2 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
--echo 码表大小写不影响对应的字符
INSERT INTO db1.t2(a) VALUES (_tis620 0x6D);
INSERT INTO db1.t2(a) VALUES (_tis620 0x6d);
select * from db1.t2 order by id asc;
--echo 码表写法 错误的格式
--error 1064
INSERT INTO db1.t2(a) VALUES (_tis620 0X6d);
select * from db1.t2 order by id asc;

--echo 不指定字符集，采用默认db字符集
--error 0,1051
drop table db1.t3;
CREATE TABLE db1.t3 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
INSERT INTO db1.t3(a)VALUES (0x7A),( 0x7B),( 0x7C),( 0x7D),( 0x7E),( 0x7F);
INSERT INTO db1.t3(a)VALUES (char(245)),(char(246));
select * from db1.t3 order by id asc;

--error 0,1305
DROP PROCEDURE create_tis6202;
delimiter //;
CREATE PROCEDURE create_tis6202()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t3 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_tis6202();
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t3;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t3 order by a;
select a,ascii(a),HEX(a),lower(a),upper(a) from db1.t1 order by a;

--echo ### DB不指定字符集，采用系统默认字符集
--error 0,1008
DROP DATABASE db2;
CREATE DATABASE db2;
use db2;
--error 0,1051
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
--error 0,1305
DROP PROCEDURE create_tis6203;
delimiter //;
CREATE PROCEDURE create_tis6203()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t1 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_tis6203();
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db2.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db2.t1 order by a;

--echo 指定其他类型字符集
--error 0,1051
drop table db2.t2;
CREATE TABLE db2.t2 (id int AUTO_INCREMENT PRIMARY KEY, a varchar(255));

INSERT INTO db2.t2(a) VALUES (_gb18030 0x84318236),(_gb18030 0x84318238),(_gb18030 0x84318237),(_gb18030 0x84318239);
INSERT INTO db2.t2(a) VALUES (_gb18030 0x82359133),(_gb18030 0x82359134);
INSERT INTO db2.t2(a) VALUES (_gb18030 'nihao'),(_gb18030 '你好');
INSERT INTO db2.t2(a) VALUES (9);
select * from db2.t2 order by id asc;

select count(*) from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;
select * from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;

select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using tis620)=db2.t1.a;
select * from db1.t1,db2.t1 where convert(db1.t1.a using tis620)=db2.t1.a;
select * from db1.t1,db2.t2 where convert(db2.t2.a using tis620)=db1.t1.a;
select * from db1.t1,db2.t2 where convert(db2.t2.id using tis620)=db1.t1.id;

--echo ### 查看使用的默认字符序
SELECT * FROM INFORMATION_SCHEMA.SCHEMATA WHERE SCHEMA_NAME in ('db1','db2');
SHOW CREATE TABLE db1.t1;
SHOW CREATE TABLE db2.t1;

--error 0,1051
drop table db1.t2;
CREATE TABLE db1.t2 (id int AUTO_INCREMENT PRIMARY KEY, a char(2));
INSERT INTO db1.t2(a) VALUES (9);
### --error 1406
INSERT INTO db1.t2(a) VALUES (99);
#tis620：0x37是w，0x377是.，mysql不报错
INSERT INTO db1.t2(a) VALUES (0x37),(0x377);
INSERT INTO db1.t2(a) VALUES (0x38);
select * from db1.t2 order by id asc;
truncate db1.t2;
#tis620：0x58是X，0x588是.，mysql不报错
INSERT INTO db1.t2(a) VALUES (_tis620 0x58);
INSERT INTO db1.t2(a) VALUES (0x58);
INSERT INTO db1.t2(a) VALUES (0x588);
select * from db1.t2 order by id asc;
truncate db1.t2;

--echo  ### 字符转换
#tis620转换成gb18030显示
--error 0,1051
drop table db2.t1;
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(20));
INSERT INTO db2.t1(a) VALUES (9);
INSERT INTO db2.t1(a) VALUES ('H');
INSERT INTO db2.t1(a) VALUES (_gb18030 'nihao'),(_gb18030 '你好');
select * from db2.t1 order by id;
select id,a,convert(a, char(20) CHARACTER SET gb18030) from db2.t1 order by id;
select id,a,convert(a, char(20) CHARACTER SET tis620) from db2.t1 order by id;
SELECT id,a,hex(a),hex(weight_string(a)),length(a) FROM db2.t1 order by id;

--disable_warnings
--error 0,1008
DROP DATABASE IF EXISTS db1;
--error 0,1008
DROP DATABASE IF EXISTS db2;
--enable_warnings

--echo #########清空回收站,删除测试数据库,表等 ##########
purge recyclebin;