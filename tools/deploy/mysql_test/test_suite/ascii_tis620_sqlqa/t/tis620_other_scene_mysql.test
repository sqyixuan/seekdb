create table biaoming表;
--error 1064
create table 'biaoming表';

#增加XML数据类型测试
--error 0,1008
DROP DATABASE db3;
CREATE DATABASE db3 CHARACTER SET TIS620;
use db3;
--error 1051
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    xml_col varchar(4000)
)DEFAULT CHARACTER SET = TIS620;

insert into t1(xml_col) values('
    <?xml version="1.0" encoding="TIS620" ?>
    <!DOCTYPE ldml SYSTEM "../../common/dtd/ldml.dtd">
    <!--
    CLDR data files are interpreted according to the LDML specification
    For terms of use, see
    -->
    <student>
        <name>李四</name>
        <age>33</age>
        <sex>不知道</sex>
    </student>
');
--sorted_result
select * from db3.t1;

insert into t1(xml_col) values('
    <?xml version="1.0" encoding="TIS620" ?>
    <!DOCTYPE ldml SYSTEM "../../common/dtd/ldml.dtd">
    <!--
    CLDR data files are interpreted according to the LDML specification
    For terms of use, see
    -->
');
--sorted_result
select * from db3.t1;

