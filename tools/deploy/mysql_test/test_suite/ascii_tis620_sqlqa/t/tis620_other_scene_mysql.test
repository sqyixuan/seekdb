#author:wb-zcp01469308

connection default;
--echo #Environmental cleaning
purge recyclebin;
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'tis620';
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
show variables like 'character_set%';

--echo ############################# 字符类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;

--error 1051
drop table t1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = TIS620;

--error 0,1305
DROP PROCEDURE create_TIS620;
delimiter //;
CREATE PROCEDURE create_TIS620()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t1 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
    VALUES (char(i),hex(i),char(i),hex(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_TIS620();
select * from t1 order by id;

--error 1051
drop table db1.t2;
CREATE TABLE t2 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(10),
    nchar_column NATIONAL CHAR(10),
    varchar_column VARCHAR(10),
    nvarchar_column NATIONAL VARCHAR(10),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = tis620;

--echo 单条插入
INSERT INTO t2 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
VALUES ('a','a','a','a','a','a');
--sorted_result
select * from db1.t2;

INSERT INTO t2 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
VALUES ('ๆ','ๆ','ๆ','ๆ','ๆ','ๆ');
--sorted_result
select * from db1.t2;

INSERT INTO t2 (char_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

INSERT INTO t2 (nchar_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

INSERT INTO t2 (varchar_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

INSERT INTO t2 (nvarchar_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

INSERT INTO t2 (text_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

INSERT INTO t2 (blob_column)
VALUES (char(192));
--sorted_result
select * from db1.t2;

TRUNCATE TABLE t2;
select * from db1.t2;

--echo PL插入

--error 0,1305
DROP PROCEDURE create_tis6202;
delimiter //;
CREATE PROCEDURE create_tis6202()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (char_column,varchar_column,text_column,blob_column)
    VALUES (char(i),char(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_tis6202();
--sorted_result
select * from db1.t2;
--sorted_result
select * from db1.t1;

--echo 多表查询
select t1.*,t2.* from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t1.id;
select t1.*,t2.* from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t2.id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.id=t2.id order by t1.id;

#aoneid：56259187
select
    t1.id,hex(t1.char_column),t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.char_column=t2.char_column order by id;

select
    t1.id,hex(t1.char_column),t1.char_column,ascii(t1.char_column)
from db1.t1 t1 ,db1.t2 t2 where t1.char_column=t2.char_column
and ascii(t1.char_column)='00'
order by id;

#aoneid：56259187
select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.varchar_column=t2.varchar_column order by id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.text_column=t2.text_column order by id;

select
    t1.id,t1.char_column,t1.nchar_column,t1.varchar_column,t1.nvarchar_column,t1.text_column,t1.blob_column,
    t2.char_column,t2.varchar_column,t2.text_column,t2.blob_column
from db1.t1 t1 ,db1.t2 t2 where t1.blob_column=t2.blob_column order by id;

select
    t1.id,t1.char_column,t2.char_column
from db1.t1 t1 ,db1.t2 t2 where t1.varchar_column=t2.varchar_column order by id;

