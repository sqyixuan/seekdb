--error 0,1305
DROP PROCEDURE create_TIS6205;
DELIMITER //;
CREATE PROCEDURE create_TIS6205()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 256;

  WHILE i <= max_value DO
    select char(i);
    SET i = i + 1;
  END WHILE;
END;
//
DELIMITER ;//

call create_TIS6205();

# 数据类型转换
# 隐式转换：数字到字符
SELECT 'The number is: ' || 42;

# 隐式转换：日期到字符
SELECT 'Today is: ' || 2024-01;
SELECT '123' + 45;

# 隐式转换：数字到时间戳
SELECT TIMESTAMP '1970-01-01 00:00:00';

# 隐式转换：字符串到日期（格式需符合数据库默认或指定格式）
