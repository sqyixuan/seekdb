connection default;
--echo #Environmental cleaning
purge recyclebin;
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'tis620';
set character_set_database = 'tis620';
set character_set_server = 'tis620';
set character_set_results = 'utf8mb4';
show character set where Charset = 'tis620';
show variables like 'character_set%';

--echo ############################# 字符类型 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET TIS620;
use db1;
CREATE TABLE t1 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = TIS620;
--error 0,1305
DROP PROCEDURE create_TIS620;
delimiter //;
CREATE PROCEDURE create_TIS620()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t1 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
    VALUES (char(i),char(i),char(i),char(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_TIS620();
select * from t1 order by id;

--sorted_result
SELECT CONVERT(blob_column USING TIS620) AS char_value FROM t1;
--sorted_result
SELECT CAST(blob_column AS CHAR CHARSET TIS620) AS string_value FROM t1;
--sorted_result
SELECT CAST(blob_column AS CHAR CHARSET UTF8) AS string_value FROM t1;

--echo ### 其他字符集转TIS620
--error 0,1051
drop table t11;
CREATE TABLE t11 (
    id int AUTO_INCREMENT PRIMARY KEY,
    char_column CHAR(1),
    nchar_column NATIONAL CHAR(1),
    varchar_column VARCHAR(1),
    nvarchar_column NATIONAL VARCHAR(1),
    text_column TEXT,
    blob_column BLOB
)DEFAULT CHARACTER SET = utf8mb4;

--error 0,1305
DROP PROCEDURE create_TIS6202;
delimiter //;
CREATE PROCEDURE create_TIS6202()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t11 (char_column,nchar_column,varchar_column,nvarchar_column,text_column,blob_column)
    VALUES (char(i),char(i),char(i),char(i),char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_TIS6202();
select * from t1 order by id;
--sorted_result
SELECT CONVERT(blob_column USING TIS620) AS char_value FROM t1;
--sorted_result
SELECT CAST(blob_column AS CHAR CHARSET TIS620) AS string_value FROM t1;
--sorted_result
SELECT CAST(blob_column AS CHAR CHARSET UTF8) AS string_value FROM t1;
--sorted_result
SELECT concat(t1.char_column,_TIS620 '【@】') FROM t1;
--sorted_result
SELECT ascii(t1.char_column) FROM t1;

--echo ############################# 数字类型 #############################
--error 0,1051
DROP table t2;
CREATE TABLE t2 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    numeric_column DECIMAL(10, 2) NOT NULL,
    float_column FLOAT,
    double_column DOUBLE
)DEFAULT CHARACTER SET = TIS620;
sleep 2;
--error 0,1305
DROP PROCEDURE create_TIS6203;
sleep 2;
delimiter //;
CREATE PROCEDURE create_TIS6203()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO t2 (float_column,double_column)
    VALUES (char(i),char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//

call create_TIS6203();
select * from t2 order by id;

TRUNCATE TABLE t2;
sleep 2;
--error 0,1305
DROP PROCEDURE create_TIS6204;
sleep 2;
DELIMITER //;
CREATE PROCEDURE create_TIS6204()
BEGIN
  DECLARE i INT DEFAULT 0;
  DECLARE max_value INT DEFAULT 255;

  WHILE i <= max_value DO
    IF i BETWEEN 48 AND 58 THEN
      INSERT INTO t2 (numeric_column, float_column, double_column)
      VALUES (CHAR(i), CHAR(i), CHAR(i));
    END IF;

    SET i = i + 1;
  END WHILE;
END;
//
DELIMITER ;//
call create_TIS6204();
select t2.* from t2 order by id;
select t2.*,ascii(t2.float_column),char(ascii(t2.float_column)) from t2 order by id;

--echo ############################# 时间类型 #############################
--error 0,1051
DROP table t3;
CREATE TABLE t3 (
    id INT AUTO_INCREMENT PRIMARY KEY,
    date_column DATE,
    timestamp_column TIMESTAMP,
    interval_value VARCHAR(255),
    interval_unit ENUM('seconds', 'minutes', 'hours', 'days', 'weeks', 'months', 'years')
) DEFAULT CHARACTER SET = TIS620;
select * from t3 order by id;
insert into t3(date_column,timestamp_column,interval_value,interval_unit)
    values('2023-06-07', '2023-06-07 14:30:00', 15, 'days');
insert into t3(date_column,timestamp_column,interval_value,interval_unit)
    values('2023-06-07', '2023-06-07 14:30:00', 15, 'days');
select * from t3 order by id;

--echo ############################# 其他类型 #############################
#const 表达式
SELECT DATE('2012-12-12') + INTERVAL 123 DAY;
--sorted_result
SELECT date_column,(date_column + INTERVAL 123 DAY)as "new_date_column" from t3;
select * from t3 order by id;
select length(id),length(date_column),length(timestamp_column),length(interval_value),length(12) from t3 order by id;

