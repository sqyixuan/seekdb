SELECT '2024-0¼-15' + INTERVAL '1 day';
--error 0,1064
select CAST(42 AS VARCHAR(10);

SELECT NOW() -NOW() + 3600;
SELECT CAST(TIMESTAMP '2024-04-15 12:34:56' AS DATE);
SELECT ASCII('A');
SELECT SUBSTR('Hello, World!', 7, 5);
SELECT TRIM('   Hello, World!   ');
SELECT LTRIM('   Hello, World!');
SELECT RTRIM('Hello, World!   ');
select '你好' ;
SELECT CONVERT('你好' USING TIS620) AS char_value FROM dual;
