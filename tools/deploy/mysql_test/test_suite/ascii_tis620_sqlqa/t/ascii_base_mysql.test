INSERT INTO db1.t1(a)VALUES (_ASCII 0x50),(_ASCII 0x51),(_ASCII 0x52),(_ASCII 0x53),(_ASCII 0x54),(_ASCII 0x55),(_ASCII 0x56),(_ASCII 0x57),(_ASCII 0x58),(_ASCII 0x59);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x5A),(_ASCII 0x5B),(_ASCII 0x5C),(_ASCII 0x5D),(_ASCII 0x5E),(_ASCII 0x5F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x60),(_ASCII 0x61),(_ASCII 0x62),(_ASCII 0x63),(_ASCII 0x64),(_ASCII 0x65),(_ASCII 0x66),(_ASCII 0x67),(_ASCII 0x68),(_ASCII 0x69);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x6A),(_ASCII 0x6B),(_ASCII 0x6C),(_ASCII 0x6D),(_ASCII 0x6E),(_ASCII 0x6F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x70),(_ASCII 0x71),(_ASCII 0x72),(_ASCII 0x73),(_ASCII 0x74),(_ASCII 0x75),(_ASCII 0x76),(_ASCII 0x77),(_ASCII 0x78),(_ASCII 0x79);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x7A),(_ASCII 0x7B),(_ASCII 0x7C),(_ASCII 0x7D),(_ASCII 0x7E),(_ASCII 0x7F);

--echo 码表大小写不影响对应的字符
INSERT INTO db1.t1(a) VALUES (_ASCII 0x6D);
INSERT INTO db1.t1(a) VALUES (_ASCII 0x6d);
--echo 码表写法 错误的格式
--error 1064
INSERT INTO db1.t1(a) VALUES (_ASCII 0X6d);

select * from db1.t1 order by id asc;
select t1.a,ascii(t1.a) from db1.t1 order by id asc;

--echo 不指定字符集，采用默认db字符集
INSERT INTO db1.t1(a)VALUES (0x7A),( 0x7B),( 0x7C),( 0x7D),( 0x7E),( 0x7F);
select * from db1.t1 order by id asc;

--echo 指定其他类行字符集 预期正常
INSERT INTO db2.t1(a) VALUES (_gb18030 0x84318236),(_gb18030 0x84318238),(_gb18030 0x84318237),(_gb18030 0x84318239);
INSERT INTO db2.t1(a) VALUES (_gb18030 0x84318330),(_gb18030 0x84318331),(_gb18030 0x84318332),(_gb18030 0x84318333);
INSERT INTO db2.t1(a) VALUES (_gb18030 0x84318334),(_gb18030 0x84318335),(_gb18030 0x82359037),(_gb18030 0x82359038);
INSERT INTO db2.t1(a) VALUES (_gb18030 0x82359039),(_gb18030 0x82359130),(_gb18030 0x82359131),(_gb18030 0x82359132);
INSERT INTO db2.t1(a) VALUES (_gb18030 0x82359133),(_gb18030 0x82359134);
INSERT INTO db2.t1(a) VALUES (9);
select * from db2.t1 order by id asc;

--echo 不同字符集联合查询（hex、convert）
select count(*) from db1.t1,db2.t1 where db1.t1.a=db2.t1.a;
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using ASCII))=hex(convert(db2.t1.a using ASCII));
select count(*) from db1.t1,db2.t1 where db1.t1.a=convert(db2.t1.a using ASCII);
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using gb18030)=db2.t1.a;
select count(*) from db1.t1,db2.t1 where convert(db1.t1.a using ASCII)=db2.t1.a;
select count(*) from db1.t1,db2.t1 where convert(db2.t1.a using ASCII)=db1.t1.a;
--error 1064
select count(*) from db1.t1,db2.t1 where hex(convert(db1.t1.a using ASCII))=hex(convert(db2.t1.a using _gb18030));
select * from db1.t1 order by a asc;
select * from db2.t1 order by a asc;
# --查看使用的默认字符序
SELECT * FROM INFORMATION_SCHEMA.SCHEMATA WHERE SCHEMA_NAME in ('db1','db2');
SHOW CREATE TABLE db1.t1;
#use db1;
#SHOW TABLE STATUS LIKE 't2' SELECT 'Collation'\G;
#use db2;
#SHOW TABLE STATUS LIKE 't2' SELECT 'Collation'\G;

truncate db1.t1;
truncate db2.t1;

--error 0,1051
drop table db1.t2;
CREATE TABLE db1.t2 (id int AUTO_INCREMENT PRIMARY KEY, a char(2));
INSERT INTO db1.t2(a) VALUES (9);
INSERT INTO db1.t2(a) VALUES (99);
INSERT INTO db1.t2(a) VALUES (999);
INSERT INTO db1.t2(a) VALUES (91);
#ascii：0x37是w，0x377也是w，mysql不报错
INSERT INTO db1.t2(a) VALUES (0x377);
INSERT INTO db1.t2(a) VALUES (0x84318236);
select * from db1.t2 order by id asc;

--echo 1.3.gb18030 insert into ascii
--error 0,1051
drop table db1.t3;
CREATE TABLE db1.t3 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
--error 0,1051
drop table db2.t3;
CREATE TABLE db2.t3 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
INSERT INTO db2.t3(a) VALUES ('你'),('好'),('1'),('2'),('3'),('4'),('a'),('b'),('E'),('H');
INSERT INTO db2.t3(a) VALUES (_gb18030 0xB6FB);
INSERT INTO db2.t3(a) VALUES (_gb18030 0x4D);
select * from db2.t3 order by id asc;

insert into db1.t3(a) select a from db2.t3 where id between 3 and 10 order by id asc;
insert into db1.t3(a) select t3.a from db2.t3 where a = hex(convert(('e') using gb18030));
select * from db1.t3 order by id asc;

--error 1136
INSERT INTO db1.t3 SELECT a FROM db2.t3;

select a,hex(a),hex(weight_string(a)) from db1.t3 order by a;

--echo 1.4.字符转换
#utf8下三字节插入显示
#国，在utf8下是3个字节，gb18030_2022下2个字节
--error 1136
INSERT INTO db1.t2 VALUES (_utf8 0xE59BBD);
#?7?5，在utf8下是3个字节，gb18030_2022下4个字节
#aone:49210591# INSERT INTO db1.t2 VALUES (_utf8 0xEAB080);

SELECT a,hex(a),hex(weight_string(a)),length(a) FROM db1.t3 order by a;
select a,convert(a, char(1) CHARACTER SET ascii) from db1.t3 order by 1;
#ascii转换成utf显示
select a,convert(a, char(1) CHARACTER SET utf8) from db1.t3 order by 1;

#补充：通过ascii码表位置插入数据到表中
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET ascii;

use db1;

--error 0,1051
drop table db1.t1;
CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

--error 0,1305
DROP PROCEDURE create_ascii;
delimiter //;
CREATE PROCEDURE create_ascii()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 128 DO
    INSERT INTO t1 (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
call create_ascii();

#select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1;
select a,ascii(a),HEX(a),LEFT(HEX(a), 2),UNHEX(HEX(a)) from db1.t1 order by a;
select a,ascii(a),HEX(a),lower(a),upper(a) from db1.t1 order by a;

--echo #########清空回收站,删除测试数据库,表等 ##########
--disable_warnings
DROP DATABASE IF EXISTS db1;
DROP DATABASE IF EXISTS db2;
--enable_warnings
--source mysql_test/test_suite/ascii_tis620_sqlqa/include/drop_tenant.inc
purge recyclebin;