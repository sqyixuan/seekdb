#owner: sanquan.qz
#owner group:SQL-优化器
#tags: charset
#description:ascii charset case (check insert 0～127 charset)
#author:wb-zcp01469308

connection default;
--echo #Environmental cleaning
purge recyclebin;
--result_format 4
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
SET sql_mode = '';

###设置并查看当前字符集设置
set names 'ascii';
set character_set_database = 'ascii';
set character_set_server = 'ascii';
set character_set_results = 'utf8mb4';
show character set where Charset = 'ascii';
show variables like 'character_set%';

--disable_warnings
DROP DATABASE IF EXISTS db1;
DROP DATABASE IF EXISTS db2;
--enable_warnings

CREATE DATABASE db1 CHARACTER SET ASCII;
CREATE DATABASE db2 CHARACTER SET gb18030;

CREATE TABLE db1.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));
CREATE TABLE db2.t1 (id int AUTO_INCREMENT PRIMARY KEY, a char(1));

--echo 1.1.映射关系改变的18个字符,转换为 utf8mb4 之类的其他字符集会有变化
INSERT INTO db1.t1(a)VALUES (_ASCII 0x00),(_ASCII 0x01),(_ASCII 0x02),(_ASCII 0x03),(_ASCII 0x04),(_ASCII 0x05),(_ASCII 0x06),(_ASCII 0x07),(_ASCII 0x08),(_ASCII 0x09);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x0A),(_ASCII 0x0B),(_ASCII 0x0C),(_ASCII 0x0D),(_ASCII 0x0E),(_ASCII 0x0F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x10),(_ASCII 0x11),(_ASCII 0x12),(_ASCII 0x13),(_ASCII 0x14),(_ASCII 0x15),(_ASCII 0x16),(_ASCII 0x17),(_ASCII 0x18),(_ASCII 0x19);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x1A),(_ASCII 0x1B),(_ASCII 0x1C),(_ASCII 0x1D),(_ASCII 0x1E),(_ASCII 0x1F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x20),(_ASCII 0x21),(_ASCII 0x22),(_ASCII 0x23),(_ASCII 0x24),(_ASCII 0x25),(_ASCII 0x26),(_ASCII 0x27),(_ASCII 0x28),(_ASCII 0x29);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x2A),(_ASCII 0x2B),(_ASCII 0x2C),(_ASCII 0x2D),(_ASCII 0x2E),(_ASCII 0x2F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x30),(_ASCII 0x31),(_ASCII 0x32),(_ASCII 0x33),(_ASCII 0x34),(_ASCII 0x35),(_ASCII 0x36),(_ASCII 0x37),(_ASCII 0x38),(_ASCII 0x39);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x3A),(_ASCII 0x3B),(_ASCII 0x3C),(_ASCII 0x3D),(_ASCII 0x3E),(_ASCII 0x3F);
INSERT INTO db1.t1(a)VALUES (_ASCII 0x40),(_ASCII 0x41),(_ASCII 0x42),(_ASCII 0x43),(_ASCII 0x44),(_ASCII 0x45),(_ASCII 0x46),(_ASCII 0x47),(_ASCII 0x48),(_ASCII 0x49);
