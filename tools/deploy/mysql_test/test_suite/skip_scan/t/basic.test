# owner: yht146439
# tags: storage
# description: skip scan basic

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
connection default;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2,t3,t4,pt1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, c1 int, c2 int, primary key(pk1));
create table t2(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2));
create table t3(pk1 int, pk2 int, pk3 int, c1 int, c2 int, c3 int, c4 int, c5 int, primary key(pk1, pk2, pk3));
create table t4(pk1 varchar(10), pk2 varchar(10), c1 varchar(10), c2 varchar(10), c3 varchar(10), primary key(pk1, pk2));

create table pt1(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2)) partition by hash(pk1) partitions 4;

--disable_query_log
alter system set _optimizer_skip_scan_enabled = true;
alter system flush plan cache;
--let $loop=1
while($loop < 5001)
{
  eval insert into t1 (pk1,c1,c2) values ($loop, $loop % 3, $loop);
  eval insert into t2 (pk1,pk2,c1,c2,c3) values ($loop % 10, $loop, $loop % 3, $loop, $loop);
  eval insert into t3 (pk1,pk2,pk3,c1,c2,c3,c4,c5) values ($loop % 4, $loop % 2, $loop, $loop % 3, $loop % 2, 1, $loop, $loop);
  eval insert into t4 (pk1,pk2,c1,c2,c3) select concat("a", $loop % 3),concat("abc", $loop), concat("a", $loop % 3), concat("abc", $loop), concat("abc", $loop);
  eval insert into pt1(pk1,pk2,c1,c2,c3) values ($loop % 10, $loop, $loop % 3, $loop, $loop);
  inc $loop;
}

call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'FALSE');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T3', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T4', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'PT1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'TRUE');

--enable_query_log
create index t1_idx1 on t1(c1,c2);
create index t2_idx1 on t2(c1,c2);
create index t2_idx2 on t2(c1,c2,c3);
create index t3_idx1 on t3(c1,c2,c3,c4);
create index t3_idx2 on t3(c1,c2,c3,c4,c5);
create index t4_idx1 on t4(c1,c2,c3);
create index pt1_idx1 on pt1(c1,c2);
create index pt1_idx2 on pt1(c1,c3) global;

select count(distinct c1),count(distinct c2) from t1;
explain select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234;
select /*+ index(t1 primary) */ * from t1 where c2 = 1234;

explain select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234;
select /*+ index(t1 primary) */ * from t1 where c1 < 4000 and c2 = 2234;

explain select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234;
select /*+ index(t1 primary) */ count(*),count(pk1) from t1 where c2 = 1234;

explain select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234;
select /*+ index(t1 primary) */ count(*),count(c1) from t1 where c2 = 1234;

explain select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234;
select /*+ index(t1 primary) */ count(*),count(c1),pk1 from t1 where c2 = 1234;

explain select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 > 2234 and c2 < 2236;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 > 2234 and c2 < 2236;
select /*+ index(t1 primary) */ * from t1 where c2 > 2234 and c2 < 2236;

select count(distinct pk1),count(distinct pk2) from t2;
select count(distinct c1),count(distinct c2) from t2;

explain select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234;
select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234;
select /*+ index(t2 primary) */ * from t2 where pk2 = 1234;

explain select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234;
select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234;
select /*+ index(t2 primary) */ * from t2 where pk1 < 4000 and c2 = 2234;

