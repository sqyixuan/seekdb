# owner: yht146439
# tags: storage
# description: reverse skip scan

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
connection default;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(pk1 int, c1 int, c2 int, primary key(pk1)) BLOCK_SIZE = 2048 ROW_FORMAT = COMPACT;
create table t2(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2)) BLOCK_SIZE = 2048 ROW_FORMAT = COMPACT;

--disable_query_log
alter system set _optimizer_skip_scan_enabled = true;
alter system flush plan cache;
--let $loop=1
while($loop < 5001)
{
  eval insert into t1 (pk1,c1,c2) values ($loop, $loop % 3, $loop);
  eval insert into t2 (pk1,pk2,c1,c2,c3) values ($loop % 10, $loop, $loop % 3, $loop, $loop);
  inc $loop;
}
call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'FALSE');
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.gather_table_stats('TEST', 'T2', method_opt=>'for all columns size 64', estimate_percent=>100);
call dbms_stats.set_global_prefs('ESTIMATE_BLOCK', 'TRUE');
--enable_query_log
create index t1_idx1 on t1(c1,c2);
create index t2_idx1 on t2(c1,c2);
create index t2_idx2 on t2(c1,c2,c3);

select count(distinct c1),count(distinct c2) from t1;
explain  select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234 order by c1 desc;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234 order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c2 = 1234 order by c1 desc;

explain  select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234 order by c1 desc;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234 order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c1 < 4000 and c2 = 2234 order by c1 desc;

explain  select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234 order by c1 desc;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234 order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(pk1) from t1 where c2 = 1234 order by c1 desc;

explain  select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234 order by c1 desc;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234 order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1) from t1 where c2 = 1234 order by c1 desc;

explain  select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234 order by c1 desc;
select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234 order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1),pk1 from t1 where c2 = 1234 order by c1 desc;

select count(distinct pk1),count(distinct pk2) from t2;
select count(distinct c1),count(distinct c2) from t2;

explain  select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;
select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;
select /*+ index(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;

explain  select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234 order by c1 desc;
select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234 order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where pk1 < 4000 and c2 = 2234 order by c1 desc;

explain  select /*+ index_ss(t2 t2_idx1) */ * from t2 where c2 = 3434 order by c1 desc;
select /*+ index_ss(t2 t2_idx1) */ * from t2 where c2 = 3434 order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 3434 order by c1 desc;

explain  select /*+ index_ss(t2 t2_idx1) */ c3 from t2 where c2 = 3434 order by c1 desc;
select /*+ index_ss(t2 t2_idx1) */ c3 from t2 where c2 = 3434 order by c1 desc;
select /*+ index(t2 primary) */ c3 from t2 where c2 = 3434 order by c1 desc;

explain  select /*+ index_ss(t2 t2_idx2) */ * from t2 where c2 = 4545 order by c1 desc;
select /*+ index_ss(t2 t2_idx2) */ * from t2 where c2 = 4545 order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 4545 order by c1 desc;

explain  select /*+ index_ss(t2 t2_idx2) */ pk2,c3 from t2 where c2 = 3434 order by c1 desc;
select /*+ index_ss(t2 t2_idx2) */ pk2,c3 from t2 where c2 = 3434 order by c1 desc;
select /*+ index(t2 primary) */ pk2,c3 from t2 where c2 = 3434 order by c1 desc;

# minor freeze
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234  order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c1 < 4000 and c2 = 2234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(pk1) from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1) from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1),pk1 from t1 where c2 = 1234  order by c1 desc;

select count(distinct pk1),count(distinct pk2) from t2;
select count(distinct c1),count(distinct c2) from t2;

select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;
select /*+ index(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;

select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where pk1 < 4000 and c2 = 2234  order by c1 desc;

select /*+ index_ss(t2 t2_idx1) */ * from t2 where c2 = 3434  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 3434  order by c1 desc;

select /*+ index_ss(t2 t2_idx1) */ c3 from t2 where c2 = 3434  order by c1 desc;
select /*+ index(t2 primary) */ c3 from t2 where c2 = 3434  order by c1 desc;

select /*+ index_ss(t2 t2_idx2) */ * from t2 where c2 = 4545  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 4545  order by c1 desc;

select /*+ index_ss(t2 t2_idx2) */ pk2,c3 from t2 where c2 = 3434  order by c1 desc;
select /*+ index(t2 primary) */ pk2,c3 from t2 where c2 = 3434 order by c1 desc;

# major freeze
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234  order by c1 desc;
select /*+ index(t1 primary) */ * from t1 where c1 < 4000 and c2 = 2234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(pk1) from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(pk1) from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1) from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1) from t1 where c2 = 1234  order by c1 desc;

select /*+ index_ss(t1 t1_idx1) */ count(*),count(c1),pk1 from t1 where c2 = 1234  order by c1 desc;
select /*+ index(t1 primary) */ count(*),count(c1),pk1 from t1 where c2 = 1234  order by c1 desc;

select count(distinct pk1),count(distinct pk2) from t2;
select count(distinct c1),count(distinct c2) from t2;

select /*+ index_ss(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;
select /*+ index(t2 primary) */ * from t2 where pk2 = 1234 order by pk1 desc;

select /*+ index_ss(t2 t2_idx1) */ * from t2 where pk1 < 4000 and c2 = 2234  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where pk1 < 4000 and c2 = 2234  order by c1 desc;

select /*+ index_ss(t2 t2_idx1) */ * from t2 where c2 = 3434  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 3434  order by c1 desc;

select /*+ index_ss(t2 t2_idx1) */ c3 from t2 where c2 = 3434  order by c1 desc;
select /*+ index(t2 primary) */ c3 from t2 where c2 = 3434  order by c1 desc;

select /*+ index_ss(t2 t2_idx2) */ * from t2 where c2 = 4545  order by c1 desc;
select /*+ index(t2 primary) */ * from t2 where c2 = 4545  order by c1 desc;

