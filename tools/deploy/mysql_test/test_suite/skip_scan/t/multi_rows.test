# owner: yht146439
# tags: storage
# description: skip scan get multi row

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
connection default;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1,t2,t3,t4,pt1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, c1 int, c2 int, primary key(pk1)) BLOCK_SIZE = 1024 ROW_FORMAT = COMPACT;
create table pt1(pk1 int, c1 int, c2 int, c3 int, primary key(pk1)) partition by hash(pk1) partitions 4;

--disable_query_log
alter system set _optimizer_skip_scan_enabled = true;
alter system flush plan cache;
--let $loop=1
while($loop < 201)
{
  eval insert into t1 (pk1,c1,c2) values ($loop, 1, 1);
  eval insert into pt1(pk1,c1,c2,c3) values ($loop, 1, 1, $loop);
  inc $loop;
}

--enable_query_log
create index t1_idx1 on t1(c1,c2);
create index pt1_idx1 on pt1(c1,c2,c3);
create index pt1_idx2 on pt1(c1,c2,c3) global;

select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1;
select * from t1 where c2 = 1;

select count(distinct c1),count(distinct c2),count(distinct c3) from pt1; 
select /*+ index_ss(pt1 pt1_idx1) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1  order by pk1;
select /*+ index(pt1 pt1_idx1) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

select /*+ index_ss(pt1 pt1_idx2) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1 order by pk1;
select /*+ index(pt1 pt1_idx2) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

# minor freeze
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1;
select * from t1 where c2 = 1;

select count(distinct c1),count(distinct c2),count(distinct c3) from pt1; 
select /*+ index_ss(pt1 pt1_idx1) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1 order by pk1;
select /*+ index(pt1 pt1_idx1) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

select /*+ index_ss(pt1 pt1_idx2) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1 order by pk1;
select /*+ index(pt1 pt1_idx2) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

# major freeze
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(distinct c1),count(distinct c2) from t1;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1;
select * from t1 where c2 = 1;

select count(distinct c1),count(distinct c2),count(distinct c3) from pt1; 
select /*+ index_ss(pt1 pt1_idx1) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1 order by pk1;
select /*+ index(pt1 pt1_idx1) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

select /*+ index_ss(pt1 pt1_idx2) */ * from pt1 where c2 = 1 order by pk1;
select * from pt1 where c2 = 1 order by pk1;
select /*+ index(pt1 pt1_idx2) */ * from pt1 where c3 = 1;
select * from pt1 where c3 = 1;

# clean
drop table if exists t1,t2,t3,t4,pt1;