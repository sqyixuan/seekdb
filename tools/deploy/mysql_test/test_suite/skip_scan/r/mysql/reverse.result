create table t1(pk1 int, c1 int, c2 int, primary key(pk1)) BLOCK_SIZE = 2048 ROW_FORMAT = COMPACT;
create table t2(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2)) BLOCK_SIZE = 2048 ROW_FORMAT = COMPACT;
create index t1_idx1 on t1(c1,c2);
create index t2_idx1 on t2(c1,c2);
create index t2_idx2 on t2(c1,c2,c3);
select count(distinct c1),count(distinct c2) from t1;
count(distinct c1)	count(distinct c2)
3	5000
explain  select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234 order by c1 desc;
