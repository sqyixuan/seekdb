# owner: xiaoyi.xy
# owner group: SQL2
#tags: optimizer
# description: 新引擎下面加了隐式cast和bool表达式，create xxx as select时候不能打印bool expr/cast expr

--result_format 4
--explain_protocol 0

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
alter system flush plan cache global;
set ob_enable_plan_cache = 0;
sleep 2;

--disable_warnings
drop table if exists t0, t1;
drop view if exists v1;
--enable_warnings

create table t0 (c1 int, c2 varchar(10), c3 char(10));
insert into t0 values(1, 'ab', '12');

--echo // got implicit cast in c1+c3
create view v1 as select c1 from t0 where c1+c3 = 13;
show create view v1;
select * from v1;
drop view v1;

--echo // got implicit cast recursively
create view v1 as select substr(c1, substr(c1, substr(c1, 1))) from t0 where c1+c3 = 13;
show create view v1;
select * from v1;
drop view v1;

--echo // got bool expr in where clause
create view v1 as select c1 from t0 where c1;
show create view v1;
select * from v1;
drop view v1;

--echo // same test, but create table
--echo // got implicit cast in c1+c3
create table t1 as select c1 from t0 where c1+c3 = 13;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;
drop table t1;

--echo // got implicit cast recursively
create table t1 as select substr(c1, substr(c1, substr(c1, 1))) from t0 where c1+c3 = 13;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;
drop table t1;

--echo // got bool expr in where clause
create table t1 as select c1 from t0 where c1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
select * from t1;
drop table t1;

sleep 2;
