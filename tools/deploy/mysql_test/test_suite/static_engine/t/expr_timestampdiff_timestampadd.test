#owner: dachuan.sdc
#owner group: SQL2

--result_format 4

## Test TIMESTAMPDIFF & TIMESTAMPADD WHEN EXPORT TIME ZONE
## 1. HAS STATIC ENGINE
## 1.1 HAS TIME ZONE POS
## 1.2 NO TIME ZONE POS
## 2. HAS STATIC ENGINE
## 2.1 HAS TIME ZONE POS
## 2.2 NO TIME ZONE POS

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone_mysql.inc
connection default;

set @@time_zone='+8:00';
select TIMESTAMPDIFF(YEAR,str_to_date('19890416','%Y%m%d'),str_to_date('20230224','%Y%m%d'));
select TIMESTAMPADD(MONTH, 1 ,str_to_date('19870412','%Y%m%d')) ;
set @@time_zone='Asia/Shanghai';
select TIMESTAMPDIFF(YEAR,str_to_date('19890416','%Y%m%d'),str_to_date('20230224','%Y%m%d'));
select TIMESTAMPADD(MONTH, 1 ,str_to_date('19870412','%Y%m%d')) ;

