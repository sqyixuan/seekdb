#owner: wenkai.cwk

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#
# BUG 2025040800108087634
#
connection default;
--disable_query_log
--disable_result_log
drop table if exists shujie_t1;
drop table if exists shujie_t2;
drop table if exists shujie_t3;
drop table if exists shujie_t4;
drop table if exists shujie_t5;
CREATE TABLE shujie_t1(a TIMESTAMP, b TIMESTAMP);
CREATE TABLE shujie_t2(a TIMESTAMP, b TIMESTAMP);
CREATE TABLE shujie_t3(a TIMESTAMP, b TIMESTAMP);
CREATE TABLE shujie_t4(a TIMESTAMP, b TIMESTAMP);
CREATE TABLE shujie_t5(a TIMESTAMP, b TIMESTAMP);
connection syscon;
alter system set_tp tp_no = 2211, error_code = 4019, frequency = 1;
--sleep 1

connection default;
--enable_query_log
--enable_result_log
SELECT /*+ NO_REWRITE DBMS_STATS OPT_PARAM('ROWSETS_MAX_ROWS', 256) FULL(`__all_table`)  USE_PLAN_CACHE(NONE) QUERY_TIMEOUT(599840956)*/  COUNT(*),  MAX(`table_type`),  MIN(`load_type`) FROM `oceanbase`.`__all_table` where table_name like '%shujie_%';


--disable_query_log
--disable_result_log
drop table if exists shujie_t1;
drop table if exists shujie_t2;
drop table if exists shujie_t3;
drop table if exists shujie_t4;
drop table if exists shujie_t5;

connection syscon;
alter system set_tp tp_no = 2211, error_code = 4019, frequency = 0;
