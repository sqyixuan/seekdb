# owner: xiaoyi.xy
#tags: optimizer
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;

connection default;
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 int primary key) partition by hash(c1) partitions 3;
create table t2(c1 int primary key);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(6);
explain select /*+ parallel(2) pq_distribute(t1 partition none) */ * from t1, t2 where t1.c1= t2.c1;
--sorted_result
select /*+ parallel(2) pq_distribute(t1 partition none) */ * from t1, t2 where t1.c1= t2.c1;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

##bugfix: 
CREATE TABLE t1(pk int PRIMARY KEY, c1 int, c2 int, c3 int) PARTITION by RANGE(PK) subpartition by hash(PK) subpartitions 2
(PARTITION p0 values less THAN (10),
 PARTITION p1 values less THAN (50),
 PARTITION p2 values less THAN (MAXVALUE));

INSERT INTO t1 VALUES (0,NULL,NULL,NULL);
INSERT INTO t1 VALUES (1,NULL,3,4);
INSERT INTO t1 VALUES (10,20,NULL,40);
INSERT INTO t1 VALUES (50,50,50,NULL);
INSERT INTO t1 VALUES (99,-2,-3,-4);
INSERT INTO t1 VALUES (-99,-99,-99,-99);

create table t2 as select * from t1;

select /*+leading(t1 view2) semi_to_inner pq_distribute(view2 none partition)*/ * from t1
where pk in  (999999999,-99999999,-99999999) and exists (select 1 from t2 where t1.pk = t2.pk);
drop table t1;
drop table t2;

connection conn_admin;
