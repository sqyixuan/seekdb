#owner: dachuan.sdc
#owner group: sql2
#tags: optimizer

--disable_abort_on_error
--result_format 4
--explain_protocol 0

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
--sleep 2
alter system set enable_async_syslog = false;

connection default;
set @@ob_enable_plan_cache = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(text varchar(30), intval int);
insert into t1 values(null, null);
insert into t1 values('', -15);
insert into t1 values('abc', -1.5);
insert into t1 values('0.0.0.-1', -1);
insert into t1 values('0.0.0.256', 256);
insert into t1 values('0.0.0.0', 0);
insert into t1 values('0.0.0.10', 10);
insert into t1 values('10.11.12.13', 168496141);
insert into t1 values('100.111.122.133', 1685027461);
insert into t1 values('255.255.255.255', 4294967295);
insert into t1 values('255.255.255.256', 4294967296);

sele * from t1;
    

--explain_protocol 2
connection conn_admin;
--sleep 2
connection default;
select text, ip2int(text), intval, int2ip(intval) from t1;

connection conn_admin;
--sleep 2
