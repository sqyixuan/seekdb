#owner: dachuan.sdc
#owner group: sql2
--result_format 4
--disable_warnings
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
--sleep 1
connection default;
set @@ob_enable_plan_cache = 0;

drop table if exists t1;
create table t1 (c1 int);
let $cnt = 0;

--disable_query_log
--disable_result_log
while($cnt < 5000)
{
  eval insert into t1 values($cnt); 
  inc $cnt;
}
--enable_query_log
--enable_result_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
--disable_result_log
while($cnt < 10000)
{
  eval insert into t1 values($cnt); 
  inc $cnt;
}
--enable_query_log
--enable_result_log

connection conn_admin;
--sleep 1
connection default;

--error 5730
select * from t1 sample(100);
--error 5730
select * FROM t1 sample(0.0000002);
select count(*), avg(c1) from t1 sample(0.1) seed(23333);
select count(*), avg(c1) from t1 sample(1) seed(23333);
select count(*), avg(c1) from t1 sample(10) seed(23333);
select count(*), avg(c1) from t1 sample(30) seed(23333);
select count(*), avg(c1) from t1 sample(40) seed(23333);
select count(*), avg(c1) from t1 sample(90) seed(23333);
select count(*), avg(c1) from t1 sample(99) seed(23333);

select count(*), avg(c1) from t1 sample block(0.1) seed(23333);
select count(*), avg(c1) from t1 sample block(1) seed(23333);
select count(*), avg(c1) from t1 sample block(10) seed(23333);
select count(*), avg(c1) from t1 sample block(30) seed(23333);
select count(*), avg(c1) from t1 sample block(40) seed(23333);
select count(*) > 0, avg(c1) is not null from t1 sample block(90) seed(23333);
select count(*) > 0, avg(c1) is not null from t1 sample block(99) seed(23333);

drop table t1;

connection conn_admin;
