drop table if exists t1;
create table t1 (pk int primary key, c1 char(20)) charset=gb18030;
insert into t1 values (1, ''),(2,  X'1CEFBFA1EFBFA5E280'),(3, '1'),(4,'d');
select * from t1 order by 2;

drop table if exists t1;
create table t1 (pk int primary key, c1 char(20)) charset=gbk;
insert into t1 values (1, ''),(2,  X'1CEFBFA1EFBFA5E280'),(3, '1'),(4,'d');
select * from t1 order by 2;

drop table if exists t1;
create table t1 (pk int primary key, c1 char(20)) charset=utf16;
insert into t1 values (1, ''),(2,  X'1CEFBFA1EFBFA5E280'),(3, '1'),(4,'d');
select * from t1 order by 2;
