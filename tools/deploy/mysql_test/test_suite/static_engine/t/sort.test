create table t111_var(c0 bigint primary key,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into t111_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t111_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
commit;

create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var values(null,null,null,null,null,null,null,null);
commit;

create index t333_idx on t333_var(c0);

--result_format 4
--explain_protocol 1
#set  @@ob_enable_trace_log=1;
#set  @@ob_log_level='trace';
explain select * from t1,t2;
select * from t1,t2;
explain select * from t1 order by c1;
select * from t1 order by c1;
explain select * from t1 order by c1 limit 10;
select * from t1 order by c1 limit 10;
select * from t1 order by c1,'abc' limit 10;

##test sort dump
select /*+ use_merge(a b) index(t111_var PRIMARY) index(b PRIMARY)*/SQL_CALC_FOUND_ROWS sum(a.c0),sum(length(a.c1)),count(a.c2),count(a.c3),count(a.c4),count(a.c5),count(a.c6),count(a.c7),
sum(b.c0),sum(length(b.c1)),count(b.c2),count(b.c3),count(b.c4),count(b.c5),count(b.c6),count(b.c7) from t111_var a,t333_var b where a.c0=b.c0 limit 1;

##topn sort
select sum(a.c0),sum(length(a.c1)),count(a.c2),count(a.c3),count(a.c4),count(a.c5),count(a.c6),count(a.c7) from (select /*+ index(a PRIMARY)*/ * from t333_var a order by c0 desc limit 10)a;

##topn sort prefix
select sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7) from (select /*+ NO_USE_LATE_MATERIALIZATION INDEX(a t333_idx)*/* from t333_var a order by c0,c1 limit 100);

##prefix sort
select c0,length(c1),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7) from (select /*+ INDEX(a t333_idx)*/* from t333_var a order by c0,c1 limit 100000);

##prefix sort dump
select sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7) from
(select * from
  (select /*+ use_merge(a b) index(t111_var PRIMARY) index(b PRIMARY)*/ a.*,b.c0 d0,b.c1 d1,b.c2 d2,b.c3 d3,b.c4 d4,b.c5 d5,b.c6 d6,b.c7 d7 from t111_var a,t333_var b where a.c0=b.c0)
order by c0, d1 limit 100000);


##prefix core case

set ob_query_timeout=30000000;
set ob_trx_timeout=30000000;
--sorted_result
select /*+ use_px parallel(2)*/min(a.c0)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ index(a idx_t333_01) no_use_hash_aggregation no_use_hash_distinct opt_param('rowsets_max_rows', 64)*/* from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7)a group by a.c1;

--sorted_result
select /*+ no_use_px */min(a.c0)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ index(a idx_t333_01) no_use_hash_aggregation no_use_hash_distinct opt_param('rowsets_max_rows', 64)*/* from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7)a group by a.c1;

--sorted_result
select min(a.c0)+sum(length(a.c1))+sum(length(a.c2))+sum(length(a.c3))+sum(length(a.c4))+sum(length(a.c5))+sum(length(a.c6))+sum(length(a.c7))
from (select /*+ index(a primary) no_use_hash_aggregation no_use_hash_distinct opt_param('rowsets_max_rows', 64)*/* from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7)a group by a.c1;


##null first
select /*+ index(a PRIMARY)*/* from t333_var a order by c0 limit 1;
select sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7) from (select /*+ index(a PRIMARY)*/ * from t333_var a order by c0 desc limit 1);

