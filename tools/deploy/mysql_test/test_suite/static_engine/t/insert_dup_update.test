# owner: bin.lb
# owner group: sql2
# tags: optimizer

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int);
drop table if exists t2;
create table t2 (c1 int, c2 int auto_increment, c3 int, primary key(c1, c2));
drop table if exists t3;
create table t3 (c1 int primary key, c2 int unsigned);
--enable_warnings

connection syscon;

sleep 2;

connection default;
set @@ob_enable_plan_cache = 0;

insert into t1 (c1, c2, c3) values (1, 1, 1), (2, 2, 2) on duplicate key update c2 = 3, c3 = 4;
select * from t1;
insert into t1 (c1, c2, c3) values (1, 1, 1), (2, 2, 2) on duplicate key update c2 = 3, c3 = 4;
select * from t1;
insert into t1 (c1, c2, c3) values (1, 10, 1), (2, 20, 2) on duplicate key update c2 = c3, c3 = c3 + values (c2);
## check values return NULL for non insert on dup update.
select c1, c2, c3, values(c3) from t1;

insert into t1 (c3, c2, c1) values (4, 3, 3), (4, 20, 2) on duplicate key update c2 = c3, c3 = c3 + values (c2);
select * from t1;
insert into t1 (c3, c2, c1) values (4, 3, 4), (4, 20, 4) on duplicate key update c2 = c3, c3 = c3 + values (c2);
select * from t1;

## auto increment
insert into t2 (c1, c2, c3) values (1, NULL, 1), (1, NULL, 1) on duplicate key update c2 = 3, c3 = 4;
select * from t2;
insert into t2 (c1, c2, c3) values (1, 1, 1), (1, 2, 3) on duplicate key  update c2 = 10 + values(c3), c3 = 5;
select * from t2;
insert into t2 (c1, c2, c3) values (1, NULL, 1), (1, NULL, 1) on duplicate key update c2 = 3, c3 = 4;
select * from t2;

insert into t3 (c1, c2) values (1, -1) on duplicate key update c2 = 1;
insert into t3 (c1, c2) values (1, 1) on duplicate key update c2 = 2;
select * from t3;
explain insert into t3 (c1, c2) values (1, 1) on duplicate key update c2 = -1;
insert into t3 (c1, c2) values (1, 1) on duplicate key update c2 = -1;
select * from t3;

connection syscon;
