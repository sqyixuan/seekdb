# owner: xiaoyi.xy
# owner group: SQL2
# tags: optimizer
# description: 

--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
sleep 2;
set ob_enable_plan_cache = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 char(10) primary key, c2 int);
insert into t1 values('a', 1);

set @ori_sql_mode = @@sql_mode;
set @@sql_mode = concat(@ori_sql_mode, ',PAD_CHAR_TO_FULL_LENGTH');
--echo // column conv -> cast -> padding -> cast -> c2;
explain update t1 set c1 = c2;
update t1 set c1 = c2;
select * from t1;

set @@sql_mode = @ori_sql_mode;
--echo // test values() func
delete from t1;
insert into t1 values('a', 1);
explain insert into t1 values('a', 2) on duplicate key update c1 = values(c2)+1;
insert into t1 values('a', 2) on duplicate key update c1 = values(c2)+1;
select * from t1;
select length(c1) from t1;

sleep 2;
