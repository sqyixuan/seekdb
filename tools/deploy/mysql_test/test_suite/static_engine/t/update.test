# owner: bin.lb
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int);
drop table if exists t2;
create table t2 (c1 int primary key, c2 int, c3 int, c4 int, index i1(c2), unique index i2(c3));
drop table if exists t3;
create table t3 (c1 int, c2 int, c3 int, primary key(c2, c3));
drop table if exists t4;
create table t4 (c1 int, c2 int, c3 int);

insert into t1 (c1, c2, c3) values (1, 1, 1);
insert into t1 (c1, c2, c3) values (2, 2, 2);

insert into t2 (c1, c2, c3, c4) values (1, 1, 1, 1);
insert into t2 (c1, c2, c3, c4) values (2, 2, 2, 2);

insert into t3 (c1, c2, c3) values (1, 1, 1);
insert into t3 (c1, c2, c3) values (2, 2, 2);

insert into t4 (c1, c2, c3) values (1, 1, 1);
insert into t4 (c1, c2, c3) values (1, 1, 1);
--enable_warnings

connection syscon;

sleep 2;

connection default;
set @@ob_enable_plan_cache = 0;

update t1 set c3 = 3;
select * from t1;
update t1 set c3 = 3;

update t1 set c1 = 3;


update t2 set c2 = 3;
select * from t2 where c2 = 3;
update t2 set c3 = 1;
update t2 set c3 = NULL;
select * from t2 where c3 is null;

update t3 set c1 = 3;
select * from t3;
update t3 set c2 = 3;
select * from t3;
update t3 set c3 = 3;

update t4 set c2 = 3;
select * from t4;

update t1 set c1 = NULL;
update t1, t2 set t1.c2 = 11 where t1.c3 = t2.c2;
select * from t1;

--echo // test shadow key
drop table t1;
CREATE TABLE t1(c0 FLOAT NULL, c1 int)  PARTITION BY hash (c1) partitions 2;
CREATE UNIQUE INDEX idx_c0 on t1(c0) GLOBAL;
insert into t1 values(1, 2), (3, 4), (5, 6);
update t1 set c0 = c1, c1 = c0;
select * from t1;
--disable_warnings
drop table t1, t2, t3, t4;
DROP TABLE IF EXISTS tbl_t1;
DROP VIEW IF EXISTS info_year;
--echo // test update view
--echo // test range partition
CREATE TABLE tbl_t1 (
	id INT NOT NULL,
	year INT,
	month INT
)
PARTITION BY RANGE COLUMNS (year) (
	PARTITION Dec2020 VALUES LESS THAN (2021),
	PARTITION Dec2021 VALUES LESS THAN (2022),
	PARTITION Dec2024 VALUES LESS THAN (2025)
);
INSERT INTO tbl_t1 VALUES (1, 2019, 2);
INSERT INTO tbl_t1 VALUES (2, 2020, 5);
INSERT INTO tbl_t1 VALUES (3, 2020, 10);
INSERT INTO tbl_t1 VALUES (4, 2021, 2);
INSERT INTO tbl_t1 VALUES (5, 2021, 5);
INSERT INTO tbl_t1 VALUES (6, 2022, 1);
CREATE OR REPLACE VIEW info_year AS SELECT * FROM tbl_t1 PARTITION (Dec2020);
SELECT * FROM info_year;
INSERT INTO info_year VALUES (7, 2020, 11);
--error 1748
UPDATE info_year SET year = 2022 WHERE id = 7;
UPDATE info_year SET year = 2000 WHERE id = 7;
SELECT * FROM info_year;
--echo // test single partition
UPDATE info_year SET id = 100 WHERE year = 2019;
UPDATE info_year SET id = 200 WHERE year = 2022;
SELECT * FROM info_year;
SELECT * FROM tbl_t1;
DROP TABLE tbl_t1;
DROP VIEW info_year;
--echo // test hash partition
--disable_warnings
DROP TABLE IF EXISTS TEST_HASH;
DROP VIEW IF EXISTS INFO_YEAR_HASH;
CREATE TABLE TEST_HASH (C1 INT, YEAR INT, C4 INT, PRIMARY KEY(C1,C4)) PARTITION BY HASH(C4) PARTITIONS 4;
CREATE OR REPLACE VIEW INFO_YEAR_HASH AS SELECT * FROM TEST_HASH PARTITION(P1);
INSERT INTO TEST_HASH VALUES(1, 2021, 1);
INSERT INTO TEST_HASH VALUES(2, 2022, 2);
INSERT INTO TEST_HASH VALUES(3, 2023, 3);
INSERT INTO TEST_HASH VALUES(4, 2024, 4);
INSERT INTO TEST_HASH VALUES(5, 2025, 5);
SELECT * FROM TEST_HASH;
SELECT * FROM INFO_YEAR_HASH;
UPDATE INFO_YEAR_HASH SET C4 = 9 WHERE YEAR = 2021;
--error 1748
UPDATE INFO_YEAR_HASH SET C4 = 8 WHERE YEAR = 2021;
--echo // test single partition
UPDATE INFO_YEAR_HASH SET YEAR = 2048 WHERE C4 = 3;
UPDATE INFO_YEAR_HASH SET YEAR = 2048 WHERE C4 = 1;
SELECT * FROM INFO_YEAR_HASH;
SELECT * FROM TEST_HASH;
DROP TABLE TEST_HASH;
DROP VIEW INFO_YEAR_HASH;
--echo // test list partition
--disable_warnings
DROP TABLE IF EXISTS TEST_LIST;
DROP VIEW IF EXISTS INFO_YEAR_LIST;
CREATE TABLE TEST_LIST (
	C1 INT,
	YEAR INT,
	C3 INT,
	PRIMARY KEY(C1,C3)
)
PARTITION BY LIST (C1) (
	PARTITION P0 VALUES IN (1, 2, 3, 4, 5, 6, 7, 10),
	PARTITION P1 VALUES IN (11, 20, 30, 40, 50, 100),
	PARTITION P2 VALUES IN (102, 203, 8, 9, 1000)
);
CREATE OR REPLACE VIEW INFO_YEAR_LIST AS SELECT * FROM TEST_LIST PARTITION(P1);
INSERT INTO TEST_LIST VALUES(1, 2021, 1);
INSERT INTO TEST_LIST VALUES(2, 2022, 2);
INSERT INTO TEST_LIST VALUES(11, 20211, 11);
INSERT INTO TEST_LIST VALUES(20, 20220, 20);
INSERT INTO TEST_LIST VALUES(102, 202102, 102);
INSERT INTO TEST_LIST VALUES(203, 202203, 203);
SELECT * FROM TEST_LIST;
SELECT * FROM INFO_YEAR_LIST;
UPDATE INFO_YEAR_LIST SET C1 = 100 WHERE YEAR = 20211;
--error 1748
UPDATE INFO_YEAR_LIST SET C1 = 1 WHERE YEAR = 20220;
--echo // test single partition
UPDATE INFO_YEAR_LIST SET YEAR = 2048 WHERE C1 = 203;
UPDATE INFO_YEAR_LIST SET YEAR = 2048 WHERE C1 = 20;
SELECT * FROM TEST_LIST;
SELECT * FROM INFO_YEAR_LIST;
DROP TABLE TEST_LIST;
DROP VIEW INFO_YEAR_LIST;
--enable_warnings
connection syscon;
