select c1, date_add(c1, interval 1 HOUR_MINUTE), date_sub(c1, interval 1 HOUR_MINUTE) from t2;
select c1, date_add(c1, interval 1 DAY_MICROSECOND), date_sub(c1, interval 1 DAY_MICROSECOND) from t2;
select c1, date_add(c1, interval 1 DAY_SECOND), date_sub(c1, interval 1 DAY_SECOND) from t2;
select c1, date_add(c1, interval 1 DAY_MINUTE), date_sub(c1, interval 1 DAY_MINUTE) from t2;
select c1, date_add(c1, interval 1 DAY_HOUR), date_sub(c1, interval 1 DAY_HOUR) from t2;
select c1, date_add(c1, interval 1 YEAR_MONTH), date_sub(c1, interval 1 YEAR_MONTH) from t2;
select c1, date_add(c1, interval 10.5 MICROSECOND), date_sub(c1, interval 10.5 MICROSECOND) from t2;
select c1, date_add(c1, interval 10.5 SECOND), date_sub(c1, interval 10.5 SECOND) from t2;
select c1, date_add(c1, interval 10.5 MINUTE), date_sub(c1, interval 10.5 MINUTE) from t2;
select c1, date_add(c1, interval 10.5 HOUR), date_sub(c1, interval 10.5 HOUR) from t2;
select c1, date_add(c1, interval 10.5 DAY), date_sub(c1, interval 10.5 DAY) from t2;
select c1, date_add(c1, interval 10.5 WEEK), date_sub(c1, interval 10.5 WEEK) from t2;
select c1, date_add(c1, interval 10.5 MONTH), date_sub(c1, interval 10.5 MONTH) from t2;
select c1, date_add(c1, interval 10.5 QUARTER), date_sub(c1, interval 10.5 QUARTER) from t2;
select c1, date_add(c1, interval 10.5 YEAR), date_sub(c1, interval 10.5 YEAR) from t2;
select c1, date_add(c1, interval 10.5 SECOND_MICROSECOND), date_sub(c1, interval 10.5 SECOND_MICROSECOND) from t2;
select c1, date_add(c1, interval 10.5 MINUTE_MICROSECOND), date_sub(c1, interval 10.5 MINUTE_MICROSECOND) from t2;
select c1, date_add(c1, interval 10.5 MINUTE_SECOND), date_sub(c1, interval 10.5 MINUTE_SECOND) from t2;
