connection conn_admin;
connection default;
let $cnt1 = 4;
let $idx1 = 1;
while ($idx1 <= $cnt1)
{ 
  eval select c$idx1, date_add(c$idx1, interval 1 MICROSECOND), date_sub(c$idx1, interval 1 MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 SECOND), date_sub(c$idx1, interval 1 SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 MINUTE), date_sub(c$idx1, interval 1 MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 HOUR), date_sub(c$idx1, interval 1 HOUR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 DAY), date_sub(c$idx1, interval 1 DAY) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 WEEK), date_sub(c$idx1, interval 1 WEEK) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 MONTH), date_sub(c$idx1, interval 1 MONTH) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 QUARTER), date_sub(c$idx1, interval 1 QUARTER) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 YEAR), date_sub(c$idx1, interval 1 YEAR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 SECOND_MICROSECOND), date_sub(c$idx1, interval 1 SECOND_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 MINUTE_MICROSECOND), date_sub(c$idx1, interval 1 MINUTE_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 MINUTE_SECOND), date_sub(c$idx1, interval 1 MINUTE_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 HOUR_MICROSECOND), date_sub(c$idx1, interval 1 HOUR_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 HOUR_SECOND), date_sub(c$idx1, interval 1 HOUR_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 HOUR_MINUTE), date_sub(c$idx1, interval 1 HOUR_MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 DAY_MICROSECOND), date_sub(c$idx1, interval 1 DAY_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 DAY_SECOND), date_sub(c$idx1, interval 1 DAY_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 DAY_MINUTE), date_sub(c$idx1, interval 1 DAY_MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 DAY_HOUR), date_sub(c$idx1, interval 1 DAY_HOUR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 1 YEAR_MONTH), date_sub(c$idx1, interval 1 YEAR_MONTH) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 MICROSECOND), date_sub(c$idx1, interval 10.5 MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 SECOND), date_sub(c$idx1, interval 10.5 SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 MINUTE), date_sub(c$idx1, interval 10.5 MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 HOUR), date_sub(c$idx1, interval 10.5 HOUR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 DAY), date_sub(c$idx1, interval 10.5 DAY) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 WEEK), date_sub(c$idx1, interval 10.5 WEEK) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 MONTH), date_sub(c$idx1, interval 10.5 MONTH) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 QUARTER), date_sub(c$idx1, interval 10.5 QUARTER) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 YEAR), date_sub(c$idx1, interval 10.5 YEAR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 SECOND_MICROSECOND), date_sub(c$idx1, interval 10.5 SECOND_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 MINUTE_MICROSECOND), date_sub(c$idx1, interval 10.5 MINUTE_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 MINUTE_SECOND), date_sub(c$idx1, interval 10.5 MINUTE_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 HOUR_MICROSECOND), date_sub(c$idx1, interval 10.5 HOUR_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 HOUR_SECOND), date_sub(c$idx1, interval 10.5 HOUR_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 HOUR_MINUTE), date_sub(c$idx1, interval 10.5 HOUR_MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 DAY_MICROSECOND), date_sub(c$idx1, interval 10.5 DAY_MICROSECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 DAY_SECOND), date_sub(c$idx1, interval 10.5 DAY_SECOND) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 DAY_MINUTE), date_sub(c$idx1, interval 10.5 DAY_MINUTE) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 DAY_HOUR), date_sub(c$idx1, interval 10.5 DAY_HOUR) from t1;
  eval select c$idx1, date_add(c$idx1, interval 10.5 YEAR_MONTH), date_sub(c$idx1, interval 10.5 YEAR_MONTH) from t1;
  inc $idx1;
}

select c1, date_add(c1, interval 1 MICROSECOND), date_sub(c1, interval 1 MICROSECOND) from t2;
select c1, date_add(c1, interval 1 SECOND), date_sub(c1, interval 1 SECOND) from t2;
select c1, date_add(c1, interval 1 MINUTE), date_sub(c1, interval 1 MINUTE) from t2;
select c1, date_add(c1, interval 1 HOUR), date_sub(c1, interval 1 HOUR) from t2;
