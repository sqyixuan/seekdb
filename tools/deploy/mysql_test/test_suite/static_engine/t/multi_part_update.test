drop table if exists t1;
--enable_warnings
CREATE TABLE `t1` (
  `c0` float DEFAULT NULL COMMENT 'asdf',
  `c1` float DEFAULT NULL,
  UNIQUE KEY `c0` (`c0`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY i450(c0) global,
  key i950(c1, c0)
) partition by key(c1, c0) partitions 2;
insert into t1 values(1,1);
--sleep 1
UPDATE t1 SET c0= EXISTS (SELECT 1 from dual wHERE FALSE), c1=1.165811464E9;
--echo #验证结果
select/*trace*/ * from t1;
drop table t1;


connection conn_admin;
