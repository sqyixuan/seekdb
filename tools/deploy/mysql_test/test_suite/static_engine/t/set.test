#owner: zuojiao.hzj
#owner group: sql2
# tags: optimizer

--disable_abort_on_error
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
alter system set enable_async_syslog = false;

connection default;
set @@ob_enable_plan_cache = 0;

--disable_warnings
drop table if exists imc_use_dict_has_null;
--enable_warnings


CREATE TABLE imc_use_dict_has_null 
( 
 c_tiny_int  TINYINT, 
 c_small_int SMALLINT, 
 c_medium_int MEDIUMINT, 
 c_int         INTEGER, 
 c_big_int     BIGINT, 
 c_tiny_int_u  TINYINT unsigned, 
 c_small_int_u smallint unsigned, 
 c_medium_int_u mediumint unsigned, 
 c_int_u     integer unsigned, 
 c_big_int_u bigint unsigned, 
 c_decimal   decimal(10,5), 
 c_decimal_u decimal(10,5) unsigned, 
 c_number    number(10,2), 
 c_number_u  number(10,2) unsigned, 
 c_float float, 
 c_float_u float unsigned, 
 c_double DOUBLE, 
 c_double_u DOUBLE unsigned, 
 c_bit      bit(6), 
 c_time     time, 
 c_datetime datetime, 
 c_timestamp timestamp, 
 c_year year, 
 c_date    date, 
 c_char    char(5), 
 c_varchar varchar(5), 
 c_binary  binary(5), 
 c_varbinary varbinary(5), 
 c_enum enum('value1','value2', 'value3'), 
 c_set SET('v1', 'v2', 'v3') 
);

--source mysql_test/include/use_dict_has_null.inc


select * from imc_use_dict_has_null;

--sleep 2

# select again to detect is observer is still active
select * from imc_use_dict_has_null limit 5;

--disable_warnings
drop table if exists imc_use_dict_has_null;
--enable_warnings

connection conn_admin;
--sleep 2
