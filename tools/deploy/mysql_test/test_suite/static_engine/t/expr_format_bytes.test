--disable_abort_on_error
--result_format 4

connection default;
--disable_warnings

--echo Test format_bytes

SELECT format_bytes('1000000') AS a;
SELECT format_bytes(1000000) AS a;
SELECT format_bytes(NULL) AS a;
SELECT format_bytes('1000000a') AS a;
SELECT format_bytes(1071050000) AS a;


-- echo # Bad arguments
--error 1582
SELECT format_bytes() AS a;
--error 1582
SELECT format_bytes(1,2) AS a;

