#owner: yibo.tyf
#owner group: sql1
#tags: optimizer

--disable_abort_on_error
--result_format 4
--explain_protocol 0

--disable_warnings
drop table if exists test, t1;
--enable_warnings


--echo #test encrypt()

select length(encrypt('test'));
select encrypt('test','aa');
select encrypt('test','a a');
select length(encrypt(''));
select encrypt('','aa');
select encrypt('test','a\a');
select encrypt('test','a/');
select encrypt('test','a.');
select encrypt('test','123');
select encrypt('test','a');
select encrypt('test','a\n');
select encrypt('1234','_.');

select encrypt(NULL,'aa');
select encrypt('aa',NULL);

create table test as select encrypt('test','aa');
desc test;
drop table test;

create table t1 (c1 varchar(20), c2 int, c3 varchar(20));
insert into t1 values('test',111,'aaa'),('tAst',222,'bbb'),('ABC',333,'ccc');
select c1,c2,encrypt(c1,c2) from t1;
select c1,c3,encrypt(c1,c3) from t1;
select encrypt('test',c2) from t1;
select encrypt(c1,'aaa') from t1;
drop table t1;

--error 1582
select encrypt();
--error 1582
select encrypt(1,1,1);

--echo #test des_encrypt() & des_decrypt()
select hex(des_encrypt('hello'));
select hex(des_encrypt('test', 'akeystr'));
select hex(des_encrypt('test', 1));
select hex(des_encrypt('test', 9));
select hex(des_encrypt('test', 100));
select hex(des_encrypt('test', ''));
select des_encrypt('', 'key');
select des_encrypt('test', NULL);
select des_encrypt(NULL, 'test');

select des_decrypt('test','');
select des_decrypt('','key');
select length(des_decrypt('', 'key'));
select des_decrypt(1, 1);
select des_decrypt(des_encrypt("test", 'thekey'), 'thekey');
select hex(des_encrypt("hello")),des_decrypt(des_encrypt("hello"));
select des_decrypt(des_encrypt("hello",4));
select des_decrypt(des_encrypt("hello"),'default_password');
select des_decrypt(des_encrypt("hello",4),'password');
select hex(des_decrypt(des_encrypt("hello","hidden")));

create table test as select des_encrypt('testtest','password');
desc test;
drop table test;

select des_decrypt('12345','');
create table test as select des_decrypt('tt','');
desc test;
drop table test;
select des_decrypt(111,'');
create table test as select des_decrypt(111,'');
desc test;
drop table test;

create table test as select des_decrypt(des_encrypt('testtest','password'),'password');
desc test;
drop table test;

create table t1(c1 varchar(20), c2 int, c3 varchar(20));
insert into t1 values('aaa',1, 'pass1'),('bbb',2,'pass2'),('ccc',10,NULL);
select des_decrypt(des_encrypt(c1)) from t1;
select des_decrypt(des_encrypt(c1,c2)) from t1;
select des_decrypt(des_encrypt(c1,0)) from t1;
select des_decrypt(des_encrypt(c1,c3),c3) from t1;
select des_decrypt(des_encrypt(c1,'pass'),'pass') from t1;

--error 1582
select des_encrypt('aaa','1','2');
--error 1582
select des_encrypt();
--error 1582
select des_decrypt('aaa','1','2');
--error 1582
select des_decrypt();

--echo #test decode() & encode()
select hex(encode('test', 'akeystr'));
select hex(encode('test', ''));
select encode('', 'key');
select encode('test', NULL);
select encode(NULL, 'test');
select hex(decode('test',''));
select decode('','key');

create table test as select encode('testtest','password');
desc test;
drop table test;
create table test as select decode(encode('testtest','password'),'password');
desc test;
drop table test;

select decode(encode(c1,c2),c2) from t1;
select decode(encode(c1,'password'),'password') from t1;
select decode(encode('test',c2),c2) from t1;

--error 1582
select encode('aaa','1','2');
--error 1582
select encode();
--error 1582
select decode('aaa','1','2');
--error 1582
select decode();

#BugFix:
drop table t1;
create table t1(
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 bigint,
c6 bit(64),
c7 year,
c8 number(10,2),
c9 float
) default charset = utf8mb4;
insert into t1 values(1,2,3,4,5,6,null,null,null);
insert into t1 values(11,22,33,44,55,66,2022,100.3,123.123);
select des_encrypt('str1',c1) as c1,
des_encrypt('str2',c2) as c2,
des_encrypt('str3',c3) as c3,
des_encrypt('str4',c4) as c4,
des_encrypt('str5',c5) as c5,
des_encrypt('str6',c6) as c6,
des_encrypt('str7',c7) as c7,
des_encrypt('str8',c8) as c8,
des_encrypt('str9',c9) as c9
from t1;

select des_decrypt(des_encrypt('str1',c1),c1) as c1,
des_decrypt(des_encrypt('str2',c2),c2) as c2,
des_decrypt(des_encrypt('str3',c3),c3) as c3,
des_decrypt(des_encrypt('str4',c4),c4) as c4,
des_decrypt(des_encrypt('str5',c5),c5) as c5,
des_decrypt(des_encrypt('str6',c6),c6) as c6,
des_decrypt(des_encrypt('str7',c7),c7) as c7,
des_decrypt(des_encrypt('str8',c8),c8) as c8,
des_decrypt(des_encrypt('str9',c9),c9) as c9
from t1;

drop table t1;
