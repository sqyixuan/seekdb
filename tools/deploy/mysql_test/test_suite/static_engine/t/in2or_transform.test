#owner: peihan.dph
#tags: optimizer

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

alter system flush plan cache global;

connection default;

set ob_enable_plan_cache=false;
--echo ### Case 1
select 1 in (1, 2, 3) from dual;
explain select 1 in (1, 2, 3) from dual;

select 1 not in (1, 2, 3) from dual;
explain select 1 not in (1, 2, 3) from dual;

select 1 in (1.0, '1.0', 2) from dual;
explain select 1 in (1.0, '1.0', 2) from dual;

select 1 not in (1.0, '1.0', 2) from dual;
explain select 1 not in (1.0, '1.0', 2) from dual;

select (1, 2) in ((1, 2), (2, 3), (3, 4)) from dual;
explain select (1, 2) in ((1, 2), (2, 3), (3, 4)) from dual;

select (1, 2) not in ((1, 2), (2, 3), (3, 4)) from dual;
explain select (1, 2) not in ((1, 2), (2, 3), (3, 4)) from dual;

select (1, '2') in ((1.0, '2'), (1, 2.0), (1, 2)) from dual;
explain select (1, '2') in ((1.0, '2'), (1, 2.0), (1, 2)) from dual;

select (1, '2') not in ((1.0, '2'), (1, 2.0), (1, 2)) from dual;
explain select (1, '2') not in ((1.0, '2'), (1, 2.0), (1, 2)) from dual;

--echo ### Case 2
select 1 in (1, NULL) from dual;
explain select 1 in (1, NULL) from dual;

select 1 in (2, NULL) from dual;
explain select 1 in (1, NULL) from dual;

select 1 in ('1', 2, NULL) from dual;
explain select 1 in ('1', 2, NULL) from dual;

select NULL in (NULL, 1, 2) from dual;
explain select NULL in (NULL, 1, 2) from dual;

select NULL in (1, 2) from dual;
explain select NULL in (1, 2) from dual;

select (1, 2) in ((1, 2), (NULL, NULL), (2, 3)) from dual;
explain select (1, 2) in ((1, 2), (NULL, NULL), (2, 3)) from dual;

select (1, 2) in (('1', 2), (NULL, NULL), (2, 3)) from dual;
explain select (1, 2) in (('1', 2), (NULL, NULL), (2, 3)) from dual;

select (1, 2) in (('2', 3), (NULL, NULL), (3, 4)) from dual;
explain select (1, 2) in (('2', 3), (NULL, NULL), (3, 4)) from dual;

select (1, null) in ((1, null), ('1', null), ('1', '2')) from dual;
explain select (1, null) in ((1, null), ('1', null), ('1', '2')) from dual;

select (1, null) in (('1', null), ('1', '2')) from dual;
explain select (1, null) in (('1', null), ('1', '2')) from dual;

--echo not ins
select 1 not in (1, NULL) from dual;
explain select 1 not in (1, NULL) from dual;

select 1 not in (2, NULL) from dual;
explain select 1 not in (1, NULL) from dual;

select 1 not in ('1', 2, NULL) from dual;
explain select 1 not in ('1', 2, NULL) from dual;

select NULL not in (NULL, 1, 2) from dual;
explain select NULL not in (NULL, 1, 2) from dual;

select NULL not in (1, 2) from dual;
explain select NULL not in (1, 2) from dual;

select (1, 2) not in ((1, 2), (NULL, NULL), (2, 3)) from dual;
explain select (1, 2) not in ((1, 2), (NULL, NULL), (2, 3)) from dual;

select (1, 2) not in (('1', 2), (NULL, NULL), (2, 3)) from dual;
explain select (1, 2) not in (('1', 2), (NULL, NULL), (2, 3)) from dual;

select (1, 2) not in (('2', 3), (NULL, NULL), (3, 4)) from dual;
explain select (1, 2) not in (('2', 3), (NULL, NULL), (3, 4)) from dual;

select (1, null) not in ((1, null), ('1', null), ('1', '2')) from dual;
explain select (1, null) not in ((1, null), ('1', null), ('1', '2')) from dual;

select (1, null) not in (('1', null), ('1', '2')) from dual;
explain select (1, null) not in (('1', null), ('1', '2')) from dual;

--echo ### Case 3
--disable_warnings
drop table if exists t1;
--enable_warnings

connection conn_admin;

connection default;

create table t1 (a int, b varchar(100) collate utf8mb4_general_ci,
                 c varchar(100) collate utf8mb4_bin,
                 d varchar(100) collate gbk_chinese_ci);
insert into t1 values (1, "hello", "test", "你好test");
insert into t1 values (2, "test", "test", "你好test");
insert into t1 values (3, "你好test", "test", "你好test");

connection conn_admin;
connection default;

select b in (c, d) from t1;
explain select b in (c, d) from t1;

select b not in (c, d) from t1;
explain select b not in (c, d) from t1;

select (b, c) in ((b, c), (c, d), (d, null)) from t1;
explain select (b, c) in ((b, c), (c, d), (d, null)) from t1;

select (b, c) not in ((b, c), (c, d), (d, null)) from t1;
explain select (b, c) not in ((b, c), (c, d), (d, null)) from t1;

select /*+no_rewrite()*/(b, c) not in ((b, c), (c, d), (d, null)) from t1;
explain select /*+no_rewrite()*/(b, c) not in ((b, c), (c, d), (d, null)) from t1;

select case when (b, c) in ((b, c), (c, d), (d, null)) then "YES" else "NO" end from t1;
explain select case when (b, c) in ((b, c), (c, d), (d, null)) then "YES" else "NO" end from t1;
