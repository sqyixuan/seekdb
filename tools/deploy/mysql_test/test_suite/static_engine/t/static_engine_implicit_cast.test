--echo // Case2: test zerofill
--explain_protocol 0
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int(3) zerofill);
insert into t1 values(1);

set ob_enable_plan_cache = 0;
select concat(c1, 'a') from t1 limit 1;

delete from t1;
insert into t1 values(1234);
select concat(c1, 'a') from t1 limit 1;

drop table t1;
--error 1439
create table t1(c1 int(256) zerofill);
--error 1064
create table t1(c1 int(-1) zerofill);

create table t1(c1 int(255) zerofill);
insert into t1 values(1);
select length(c1) from t1;

drop table t1;
create table t1(c1 int(0) zerofill);
insert into t1 values(1);
select length(c1) from t1;
--explain_protocol 2

--echo // Case3: 测试collation不同，添加两次cast的情况
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (col_int int, 
                 col_string_utf8 varchar(100) charset utf8mb4 collate utf8mb4_general_ci,
                 col_string_gbk varchar(100) charset gbk collate gbk_chinese_ci
);
insert into t1 values(1, '12', '13');

alter system flush plan cache global;
set ob_enable_plan_cache = 0;
--echo // col_int和col_string_utf8都会被转为double
select col_int + col_string_utf8 from t1 limit 1;
--echo // col_int前面增加cast，将其转为double
--echo // col_string_gbk前面有两个cast,第一个将其转为utf8,第二个将其转为double
select col_int + col_string_gbk from t1 limit 1;
--echo // col_utf8前面没有cast
--echo // col_string_gbk前面有一个cast,将其转为utf8
select concat(col_string_utf8, col_string_gbk) from t1 limit 1;

--echo // Case5: 测试bool expr cast_mode的设置
--explain_protocol 0
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (col_bigint bigint primary key);
insert into t1 values(9223372036854775800);
select * from t1;

alter system flush plan cache global;
set ob_enable_plan_cache = 0;
--explain_protocol 2
--echo // 测试bool expr下面的cast expr是否加上了WARN_ON_FAIL,结果应该为1
select col_bigint and 1 from t1;
--echo // insert语句中，WARN_ON_FAIL会被去掉，所以这里测试NO_RANGE_CHECK是否加上
insert into t1 (col_bigint) select col_bigint and 1 from t1;
--echo // 上面insert的结果应该是1
select * from t1;

--echo // Case6: 测试column_conv cast_mode的设置
--explain_protocol 0
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 tinyint primary key);

alter system flush plan cache global;
set ob_enable_plan_cache = 0;
set sql_mode = default;
--explain_protocol 2
--echo // 会报错, out of range
insert into t1 values(10000);
set sql_mode = '';
--echo // 不会报错, 非strict mode, column_conv进行cast时会加上WARN_ON_FAIL
insert into t1 values(10000);
--echo // 结果是127
select * from t1;
set sql_mode = default;

--echo // Case7: 测试是否有过多的cast出现
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c_utf8_ci varchar(100) collate utf8mb4_general_ci,
                c_utf8_bin varchar(100) collate utf8mb4_bin,
                c_utf16 varchar(100) collate utf16_bin, 
                c_double double);
insert into t1 values('1', '1', '1', 1);

--sleep 1
--echo // utf8转double，只有一个cast
select c_utf8_ci + c_double from t1;
--echo // utf8转double，只有一个cast
select c_utf8_bin + c_double from t1;
--echo // utf16转double，现将utf16转为utf8，在转为double
select c_utf16 + c_double from t1;

--echo // 只有一个cast，将c_utf8_ci转为c_utf8_bin
select trim(leading c_utf8_ci from c_utf8_bin) from t1;
--echo // 只有一个cast，将c_utf8_bin转为c_utf16
select trim(leading c_utf16 from c_utf8_bin) from t1;
--echo // 都是utf8 ci，所以没有cast
select trim(leading c_utf8_ci from c_utf8_ci) from t1;
--echo // 都是utf8 bin，所以没有cast
select trim(leading c_utf8_bin from c_utf8_bin) from t1;
--echo // 都是utf16，所以没有cast
select trim(leading c_utf16 from c_utf16) from t1;

--echo // Case8: test null
select null union all select 1;
select null union select null;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 binary);
insert into t1 values(1);
--echo // one cast, cast binary to double
explain select c1 + 1 from t1;
select c1 + 1 from t1;

--echo // Case9: scale test
--explain_protocol 0
--echo // float_range_check
drop table t1;
create table t1(c1 float(10, 0), c2 float, c3 float);
insert into t1(c3) values(1.138);
update t1 set c1 = c3, c2 = c3;
select * from t1;

--echo // number_range_check
drop table t1;
create table t1(c1 number(10, 1), c2 number(10, 2), c3 number(10, 3));
insert into t1(c3) values(1.138);
update t1 set c1 = c3, c2 = c3;
select * from t1;
delete from t1;
insert into t1(c2) values(1.13);
update t1 set c1 = c2, c3 = c2;
select * from t1;

--echo // time_scale_check
drop table t1;
create table t1(c1 time, c2 time(3), c3 time(6));
insert into t1(c3) values('11:22:33.123456');
update t1 set c1 = c3, c2 = c3;
select * from t1;
delete from t1;
insert into t1(c1) values('11:22:33');
update t1 set c2 = c1, c3 = c1;
select * from t1;

--echo // enumset
drop table t1;
create table t1(c1 enum('a', 'b', 'c'), c2 int);
insert into t1(c1) values('a');
select * from t1;
update t1 set c1 = 'b', c2 = c1;
select * from t1;

--echo // string->year error check
drop table t1;
create table t1(c1 year);
--error 1264
insert into t1 values('201a');
select * from t1;

--echo // datetime precision check
drop table t1;
create table t1 (`col_timestamp` timestamp NULL DEFAULT NULL, col_varchar varchar(100));
insert into t1 values ('2002-01-20 17:16:05', '2002-01-20 17:16:05');
select col_timestamp c1 ,IFNULL( col_timestamp, STR_TO_DATE( DATE_FORMAT( col_timestamp , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ) ) c2, trim(IFNULL( col_timestamp, STR_TO_DATE( DATE_FORMAT( col_timestamp , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ) )) c3 from t1;
select col_varchar c1 ,IFNULL( col_varchar, STR_TO_DATE( DATE_FORMAT( col_timestamp , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ) ) c2, trim(IFNULL( col_varchar, STR_TO_DATE( DATE_FORMAT( col_timestamp , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ) )) c3 from t1;

--echo // in res type check
--echo // bug: 
drop table t1;
create table t1(c1 float);
select * from t1 where least(null, c1 IN ((NOT (1)), c1),  EXISTS (SELECT 1));

drop table t1;
