# owner: luofan.zp
#tags: optimizer
# owner group: SQL2

--result_format 4
--explain_protocol 0

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--echo // Case1: normal test，通过交叉各种类型进行测试
--echo // Case2: test zerofill
--echo // Case3: 测试collation不同，添加两次cast的情况
--echo // Case4: 测试char/varchar的转换是trivial cast,不需要deep copy

--echo // Case1: normal test，通过交叉各种类型进行测试
set ob_enable_plan_cache = 0;
alter system flush plan cache global;
--disable_warnings
drop table if exists t1;
--enable_warnings
# TODO: binary varbinary enum set
# TODO: 测试rawtohex(raw->string), hextoraw; 测试数字类型超过值域, unsigned range check
create table t1 (
  col_tinyint tinyint,
  col_smallint smallint,
  col_mediumint tinyint,
  col_int int,
  col_bigint bigint,
  col_float float,
  col_double double,
  col_decimal decimal,

  col_utinyint tinyint unsigned,
  col_usmallint smallint unsigned,
  col_umediumint tinyint unsigned,
  col_uint int unsigned,
  col_ubigint bigint unsigned,
  col_ufloat float unsigned,
  col_udouble double unsigned,
  col_udecimal decimal unsigned,

  col_char char(100),
  col_varchar varchar(100),
  col_blob blob,
  col_text text,

  col_date date,
  col_datetime datetime,
  col_timestamp timestamp,
  col_year year,
  col_time time,

  col_bit bit
  );

insert into t1 values(
  -1,
  -2,
  -3,
  -4,
  -5,
  -1.0,
  -2.0,
  -111.11,

  1,
  2,
  3,
  4,
  5,
  1.0,
  2.0,
  111.11,

  'char type',
  'varchar type',
  'blob type', 
  'text type',

  '2019-01-01',
  '2019-01-01 00:00:00',
  '2019-01-01 00:00:00',
  '1997',
  '00:12:12',

  b'001'
);

