# owner: bin.lb
#tags: optimizer
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int);
insert into t1 (c1, c2, c3) values (1, 1, 1);
insert into t1 (c1, c2, c3) values (2, 2, 2);
insert into t1 (c1, c2, c3) values (3, 3, 3);

drop table if exists t2;
create table t2 (c1 int primary key, c2 int, c3 int);
insert into t2 (c1, c2, c3) values (1, 2, 3);
insert into t2 (c1, c2, c3) values (3, 4, 5);

connection syscon;

sleep 2;

connection default;
set @@ob_enable_plan_cache = 0;


explain select c1, (select 1, t1.c2 from t2 where t2.c1 < t1.c1 limit 1) < (select 1, t1.c2 from t2 where t2.c1 > t1.c1 limit 1) from t1;
select c1, (select 1, t1.c2 from t2 where t2.c1 < t1.c1 limit 1) < (select 1, t1.c2 from t2 where t2.c1 > t1.c1 limit 1) from t1;

select c1, (select 1, t1.c2 from t2 where t2.c1 < t1.c1 limit 1) <=> (select null, null from t2 where t2.c1 > t1.c1 limit 1) from t1;


connection syscon;
