CREATE table t1(c1 LONGBLOB,c2 LONGTEXT);
insert into t1(c1) values(bin_to_uuid(uuid_to_bin('13d29c12-493f-11ed-9307-7cd30abc95d8')));
insert into t1(c2) values(bin_to_uuid(uuid_to_bin('13d29c12-493f-11ed-9307-7cd30abc95d8')));
