insert into t1(c2) values(bin_to_uuid(uuid_to_bin('13d29c12-493f-11ed-9307-7cd30abc95d8'),127));
insert into t1(c1) values(bin_to_uuid(uuid_to_bin('13d29c12-493f-11ed-9307-7cd30abc95d8'),128));
insert into t1(c2) values(bin_to_uuid(uuid_to_bin('13d29c12-493f-11ed-9307-7cd30abc95d8'),128));
select * from t1;
