drop table obright_part;

#fix bug:
# 《小规格 - [SQL.DAS] ~ObLocalIndexLookupOp rowkey_iter_ iter is not released, maybe some bug occured》
--explain_protocol 0
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (c1 int, c2 int ,c3 int, c4 int);
create index aaa_t2 on t2(c1,c2);
insert into t2 values (1,1,1,1);
insert into t2 values (2,2,2,2);
insert into t2 values (2,2,2,2);
select * from t2 where c1 =2;
alter system set_tp tp_no=306, error_code=4016, frequency=1;
--error 4016
select * from t2 where c1 =2;
alter system set_tp tp_no=306, error_code=0, frequency=1;
select * from t2 where c1 =2;
drop table t2;
