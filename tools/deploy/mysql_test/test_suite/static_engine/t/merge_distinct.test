# owner: peihan.dph
# owner group: sql2
# tags: optimizer

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

sleep 2;

connection default;

--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2(c1 int,c2 int,c3 int);
insert into t2 values(2,2,3);
insert into t2 values(2,0,3);
insert into t2 values(0,2,3);
insert into t2 values(1,2,3);
insert into t2 values(null,2,3);
insert into t2 values(1,2,3);
insert into t2 values(0,2,3);
insert into t2 values(2,2,3);
commit;

create index idx_t1 on t2(c1,c2);

connection syscon;
sleep 2;


connection default;
set @@ob_enable_plan_cache = 0;

###--result_format 4
--explain_protocol 2
select /*+ NO_USE_HASH_AGGREGATION */distinct c1,c2 from t2;
select /*+ NO_USE_HASH_AGGREGATION */distinct c2,c1 from t2;
select /*+ NO_USE_HASH_AGGREGATION */distinct c2,c1,c1+c2 from t2;
select /*+ NO_USE_HASH_AGGREGATION */distinct 1,c2,2,3,c1,5,'ab' from t2;
##24219498  当前codegen失败，暂时ignore
#select /*+ NO_USE_HASH_AGGREGATION */distinct 2 from t2;

connection syscon;
sleep 2;

connection default;
drop table t2;
