#owner: peihan.dph
#owner group: sql2
#tags: optimizer

--disable_abort_on_error
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
alter system set enable_async_syslog = false;
alter system flush plan cache global;

connection default;
#set @@ob_enable_plan_cache = 0;
#set @@ob_log_level='debug';

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 year, c22 date, c23 time, 
    c24 varchar(30), c25 char(30),
    c26 varbinary(30), c27 binary(30),
    c28 enum("","0","1","2","3","5","6","7","8","9"), 
    c29 set("","0","1","2","3","5","6","7","8","9")
    );
    
select * from t1;
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.1, 4.1, 
    5.1, 6.1,
    7.1, 8.1,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00', 
    2020,'2020-01-01','12:34:56',
    '9.1', '10.1',
    '9.1', '10.1',
    0, 0);
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.6, 4.6, 
    -5.6, 6.6,
    -7.6, 8.6,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00', 
    2021,'2020-01-11','12:35:56',
    '-9.6', '10.6',
    '-9.6', '10.6',
    3, 3);

connection conn_admin;
--explain_protocol 2
--sleep 1

connection default;
--echo #### test add expr and limit operator in new engine

--enable_metadata

let $cnt=29;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select c$left, c$right, c$left + c$right from t1;
    eval select c$left, c$right, c$left - c$right from t1;
    eval select c$left, c$right, c$left * c$right, c$left / c$right, c$left % c$right from t1;
    eval select c$left, c$right, c$left DIV c$right from t1;

    inc $right;
  }
  inc $left;
}

let $right=1;
while ($right <= $cnt)
{
  eval select NULL, c$right, NULL + c$right, c$right + NULL from t1;
  eval select NULL, c$right, NULL - c$right, c$right - NULL from t1;
  eval select NULL, c$right, NULL * c$right, c$right * NULL from t1;
  eval select NULL, c$right, NULL / c$right, c$right / NULL from t1;
  eval select NULL, c$right, NULL DIV c$right, c$right DIV NULL from t1;    
  eval select NULL, c$right, NULL % c$right, c$right % NULL from t1;
    
  inc $right;
}

#bug not support const value now
eval select NULL, NULL, NULL + NULL, c1 from t1;
eval select NULL, NULL, NULL - NULL, c1 from t1;
eval select NULL, NULL, NULL * NULL, c1 from t1;
eval select NULL, NULL, NULL / NULL, c1 from t1;
eval select NULL, NULL, NULL DIV NULL, c1 from t1;    
eval select NULL, NULL, NULL % NULL, c1 from t1;

--disable_metadata

connection conn_admin; 
--sleep 2
