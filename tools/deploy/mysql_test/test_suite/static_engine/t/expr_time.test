select subtime(c1, c1), subtime(c1, c2), subtime(c1, c3), subtime(c1, c4), subtime(c2, c1), subtime(c2, c2), subtime(c2, c3), subtime(c2, c4),
subtime(c3, c1), subtime(c3, c2), subtime(c3, c3), subtime(c3, c4), subtime(c4, c1), subtime(c4, c2), subtime(c4, c3), subtime(c4, c4) from t1;
let $cnt2 = 6;
let $idx2 = 1;
while ($idx2 <= $cnt2)
{
  let $cnt3 = 4;
  let $idx3 = 1;
  while ($idx3 <= $cnt3)
  {
    eval select a.c$idx2, b.c$idx3, subtime(a.c$idx2, b.c$idx3) from t2 a, t3 b;
    inc $idx3;
  }
  inc $idx2;
}

select extract(MICROSECOND from null) from t1;
select extract(SECOND from null) from t1;
select extract(MINUTE from null) from t1;
select extract(HOUR from null) from t1;
select extract(DAY from null) from t1;
select extract(WEEK from null) from t1;
select extract(MONTH from null) from t1;
select extract(QUARTER from null) from t1;
select extract(YEAR from null) from t1;
select extract(SECOND_MICROSECOND from null) from t1;
select extract(MINUTE_MICROSECOND from null) from t1;
select extract(MINUTE_SECOND from null) from t1;
select extract(HOUR_MICROSECOND from null) from t1;
select extract(HOUR_SECOND from null) from t1;
select extract(HOUR_MINUTE from null) from t1;
select extract(DAY_MICROSECOND from null) from t1;
select extract(DAY_SECOND from null) from t1;
select extract(DAY_MINUTE from null) from t1;
select extract(DAY_HOUR from null) from t1;
select extract(YEAR_MONTH from null) from t1;


let $cnt = 3;
let $idx = 1;
while ($idx <= $cnt)
{
  eval select c$idx, extract(MICROSECOND from c$idx) from t1;
  eval select c$idx, extract(SECOND from c$idx) from t1;
  eval select c$idx, extract(MINUTE from c$idx) from t1;
  eval select c$idx, extract(HOUR from c$idx) from t1;
  eval select c$idx, extract(DAY from c$idx) from t1;
  eval select c$idx, extract(WEEK from c$idx) from t1;
  eval select c$idx, extract(MONTH from c$idx) from t1;
  eval select c$idx, extract(QUARTER from c$idx) from t1;
  eval select c$idx, extract(YEAR from c$idx) from t1;
  eval select c$idx, extract(SECOND_MICROSECOND from c$idx) from t1;
  eval select c$idx, extract(MINUTE_MICROSECOND from c$idx) from t1;
  eval select c$idx, extract(MINUTE_SECOND from c$idx) from t1;
  eval select c$idx, extract(HOUR_MICROSECOND from c$idx) from t1;
  eval select c$idx, extract(HOUR_SECOND from c$idx) from t1;
  eval select c$idx, extract(HOUR_MINUTE from c$idx) from t1;
  eval select c$idx, extract(DAY_MICROSECOND from c$idx) from t1;
  eval select c$idx, extract(DAY_SECOND from c$idx) from t1;
  eval select c$idx, extract(DAY_MINUTE from c$idx) from t1;
  eval select c$idx, extract(DAY_HOUR from c$idx) from t1;
  eval select c$idx, extract(YEAR_MONTH from c$idx) from t1;
  inc $idx;
}

let $cnt = 6;
let $idx = 1;
while ($idx <= $cnt)
{
  eval select c$idx, extract(MICROSECOND from c$idx) from t2;
  eval select c$idx, extract(SECOND from c$idx) from t2;
  eval select c$idx, extract(MINUTE from c$idx) from t2;
  eval select c$idx, extract(HOUR from c$idx) from t2;
  eval select c$idx, extract(DAY from c$idx) from t2;
  eval select c$idx, extract(WEEK from c$idx) from t2;
  eval select c$idx, extract(MONTH from c$idx) from t2;
  eval select c$idx, extract(QUARTER from c$idx) from t2;
  eval select c$idx, extract(YEAR from c$idx) from t2;
  eval select c$idx, extract(SECOND_MICROSECOND from c$idx) from t2;
  eval select c$idx, extract(MINUTE_MICROSECOND from c$idx) from t2;
  eval select c$idx, extract(MINUTE_SECOND from c$idx) from t2;
  eval select c$idx, extract(HOUR_MICROSECOND from c$idx) from t2;
  eval select c$idx, extract(HOUR_SECOND from c$idx) from t2;
  eval select c$idx, extract(HOUR_MINUTE from c$idx) from t2;
  eval select c$idx, extract(DAY_MICROSECOND from c$idx) from t2;
  eval select c$idx, extract(DAY_SECOND from c$idx) from t2;
  eval select c$idx, extract(DAY_MINUTE from c$idx) from t2;
  eval select c$idx, extract(DAY_HOUR from c$idx) from t2;
  eval select c$idx, extract(YEAR_MONTH from c$idx) from t2;
  inc $idx;
}

drop table t1;
drop table t2;
drop table t3;

connection conn_admin;
