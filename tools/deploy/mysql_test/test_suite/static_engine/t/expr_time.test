connection conn_admin;
#alter system set _enable_static_typing_engine = false;
alter system set enable_async_syslog = false;

connection default;
set @@ob_enable_plan_cache = 0;
set timestamp =  1609837573;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;

create table t1(c1 datetime, c2 timestamp, c3 date, c4 time);
create table t2(c1 bigint, c2 float, c3 double, c4 varchar(30), c5 varchar(30), c6 varchar(30));
create table t3(c1 bigint, c2 float, c3 varchar(30), c4 time);
