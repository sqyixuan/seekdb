#owner: xiaoyi.xy
#tags: optimizer

--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;


connection default;
set ob_enable_plan_cache = false;

--echo >>>>>>>> TEST BASIC
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (a varchar(100), b int as (a + 1) virtual);

--error 3105
insert into t1 values (1, 2);

insert into t1 values (1, default);
explain insert into t1 values (1, default);

insert into t1(a) values (10000);
explain insert into t1(a) values (10000);

--error 1265
insert into t1(a) values ('he');
explain insert into t1(a) values ('he');

--echo // data from memory table
select * from t1;

connection conn_admin;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection default;

--echo // data from sstable, and virtual column is calculated
select * from t1;

drop table t1;

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;

create table t1 (a varchar(16), k varchar(16),
                                b char(32) as (substr(a, 1)) virtual,
                                c int as (a / 2) virtual,
                                d int as (a * 2) virtual,
                                e int as (a + 2) virtual,
                                f int as (a - 2) virtual,
                                g char(64) as (concat(a, k)) virtual);

let $cnt = 1;

while ($cnt <= 10)
{
  eval insert into t1(a, k) values ($cnt, $cnt);
  inc $cnt;
}

select a, b, length(b), c, d, e, f, g from t1;

update t1 set a = '11' where a < 5;

replace into t1(a) values ('11');

select a, b, length(b) c, d, e, f, g from t1;

drop table t1;

create table t1 (a int primary key, b int, c int as (a + b) virtual);

replace into t1(a, b) values (1, 2);
replace into t1(a, b) values (1, 2);
replace into t1(a, b) values (2, 3);
select * from t1;

connection conn_admin;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection default;

update t1 set a = 11 where b = 2;

select a, c from t1;

delete from t1;

select * from t1;

drop table t1;

create table t1 (a varchar(16), b char(32) as (substr(a, 1)) stored,
                                c int as (a / 2) stored,
                                d int as (a * 2) stored,
                                e int as (a + 2) stored,
                                f int as (a - 2) stored);


let $cnt = 1;

while ($cnt <= 10)
{
  eval insert into t1(a) values ($cnt);
  inc $cnt;
}

select a, b, length(b), c, d, e, f from t1;

connection conn_admin;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection default;

select a, b, length(b), c, d, e, f from t1;

drop table t1;

# generated column on new added column
create table t1 (c1 int, c2 int);
insert into t1 (c1, c2) values (1, 1);
alter table t1 add column c3 int default 2;
alter table t1 add column c4 int as (c3 + 1) virtual;
select * from t1;
drop table t1;

# padding.
create table t1 (c1 char(10), c2 char(10));
insert into t1 (c1, c2) values ('a', 'b');
alter table t1 add column c3 char(30) as (concat(c1, c2)) virtual;
set sql_mode=STRICT_ALL_TABLES;
select c1, c2, c3, length(c1), length(c2), length(c3)  from t1;
set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
select c1, c2, c3, length(c1), length(c2), length(c3)  from t1;
drop table t1;

# insert into
create table t1(a int, b varchar(25), c datetime, d varchar(100) default null, v_column varchar(20)
                generated always as (substr(b, 3)) virtual, primary key(a,b,c)) partition by key(v_column)
                subpartition by range columns(c) subpartition template (
                subpartition p20170101 values less than('2017-01-01 00:00:00'),
                subpartition p20170701 values less than('2017-07-01 00:00:00'),
                subpartition p20180101 values less than('2018-01-01 00:00:00')) partitions 3;

insert into t1(a,b,c) values(1, 'asdfadsfasdfdsa', '2016-09-28 00:00:00');

select * from t1;

drop table t1;
connection conn_admin;

