
#owner: bin.lb
#owner group: sql2


--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
alter system set enable_async_syslog = false;

connection default;
alter system set _force_hash_groupby_dump = true;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
    c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 year, c22 date, c23 time, 
    c24 varchar(4000), c25 char(256),
    c26 varbinary(4000), c27 binary(256));
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00', 
    2020,'2020-01-01','12:34:56',
    repeat('0',4000), repeat('0',250),
    repeat('0',4000), repeat('0',250));
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00', 
    2021,'2020-01-11','12:35:56',
    repeat('1',4000), repeat('1',250),
    repeat('1',4000), repeat('1',250));

insert into t1 (c1) values(4);
insert into t1 (c1) values(5);

insert into t1 values(3, 3,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -3.5, 4.5,
    -3.5, 6.5,
    -3.5, 8.5,
    '2019-02-11 12:00:00', '2019-12-03 16:00:00',
    2001,'2000-01-11','10:35:56',
    repeat('2',4000), repeat('2',250),
    repeat('2',4000), repeat('2',250));

select * from t1;
    

--disable_query_log

let $cnt=1000;
let $left=1;
while ($left <= $cnt)
{
  let $val = ($left % 100);
  eval insert into t1 values(($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    date_add('2019-02-11 12:00:00', interval ($left % 100) hour),
    date_add('2019-12-03 16:00:00', interval ($left % 100) hour),
    2001 + ($left % 100),
    date_add('2019-12-03 16:00:00', interval ($left % 100) day),
    date_add('2019-12-03 16:00:00', interval ($left % 100) minute),
    repeat('3',120), repeat('3',130),
    repeat('3',120), repeat('3',130));
    
    inc $left;
}

--enable_query_log

connection conn_admin;
--sleep 1

connection default;
--echo #### test add expr and limit operator in new engine

set @@ob_query_timeout=10*@@ob_query_timeout;
#set @@ob_enable_plan_cache = 0;
#set @@ob_log_level='debug';

--disable_abort_on_error

let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select /*+use_hash_aggregation*/ c$left, c$right, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
    eval select /*+use_hash_aggregation*/ c$left, c$right, length(c24), max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
      
    inc $right;
    inc $right;
    inc $right;
  }

  inc $left;
}

eval select /*+use_hash_aggregation*/ max(NULL), min(NULL), sum(NULL), avg(NULL), count(*), count(NULL) from t1 group by c1 order by 1,2,3 limit 10;


--enable_metadata

let $left=1;
let $right=1;

eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;

eval select /*+use_px parallel(2) no_use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;

eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;


delete from t1;

let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select /*+use_hash_aggregation*/ c$left, c$right, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
    eval select /*+use_hash_aggregation*/ c$left, c$right, length(c24), max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
    inc $right;
    inc $right;
    inc $right;
  }

  inc $left;
}

--disable_metadata

alter system set _force_hash_groupby_dump = false;
connection conn_admin; 
