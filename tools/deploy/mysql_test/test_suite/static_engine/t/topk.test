# owner: xiaoyi.xy
# tags: optimizer
# owner group: sql2

--disable_warnings
drop table if exists t_hash_group, t_material, t_parallel;
--enable_warnings


######################################### case hash group by ##################################################

create table t_hash_group (c1 int, c2 int, c3 varchar(32)) partition by hash(c1) partitions 2;
insert into t_hash_group values(1,1,1),(3,3,3),(5,5,5),(7,7,7),(9,9,9),(11,11,11),(13,13,13),(15,15,15),(17,17,17),(19,19,19);

--echo // sleep 2
--sleep 2
set @@ob_enable_plan_cache = 0;

--explain_protocol 2
select /*+topk(1 2)*/ c2 from t_hash_group group by c2 order by 'a' limit 1;
--explain_protocol 0


########################################## case material #####################################################

CREATE TABLE `t_material` (`c0` double,`c1` smallint(14)) partition by key(c1, c0) partitions 10;
insert into t_material values('-1916917789', null), ('724800132', null);

--echo // sleep 2
--sleep 2
set @@ob_enable_plan_cache = 0;

--explain_protocol 2
select /*+ topk (50 50) */ c0, c1 from t_material where c1 is unknown group by c0, c1 order by c1 desc limit 2147483647 offset 0;
--explain_protocol 0


########################################## case material #####################################################
 
create table t_parallel(c1 int);
insert into t_parallel values(1),(2),(3),(4),(5);
 
--echo // sleep 2
--sleep 2
set @@ob_enable_plan_cache = 0;
 
--explain_protocol 2
select  /*+ TOPK(50 50) no_rewrite parallel(2)*/ 1 from t_parallel where c1 = 1 group by c1 order by c1 limit 1;
--explain_protocol 0
 
 
drop table t_hash_group, t_material, t_parallel;