# owner: xiaoqiu.wy
# owner group: sql2

connect (obmysql, $OBMYSQL_MS0, root@sys, , test, $OBMYSQL_PORT);
connection obmysql;
alter system set _enable_pseudo_partition_id = true;
alter system set _rowsets_enabled = true;
alter system flush plan cache;

--result_format 4
--disable_warnings
drop database if exists test_partition_pseudo;
--enable_warnings
create database test_partition_pseudo;
use test_partition_pseudo;

# bug-2025032100107684456, delete union子查询正交问题
