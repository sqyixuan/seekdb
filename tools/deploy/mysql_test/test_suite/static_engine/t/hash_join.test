# owner: peihan.dph
# owner group: sql2
# tags: optimizer

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_query_log
#eval create resource unit new_box1 max_cpu 1, memory_size '2G';
#eval create resource pool new_pool1 unit = 'new_box1', unit_num = $obs_num;
#eval create tenant dump_tenant primary_zone='$zone_name', resource_pool_list('new_pool1') set ob_tcp_invited_nodes='%';

--enable_result_log
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

set global parallel_servers_target=10;
alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';

--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t111_var;
--error 0,1051
drop table t333_var;
--error 0,1051
drop table t1_set;
--error 0,1051
drop table t2_set;
--enable_warnings

create table t1(c1 int,c2 int,c3 int);
create table t2(c1 int,c2 int,c3 int);

insert into t1 values(1,2,3);
insert into t1 values(1,2,3);
insert into t1 values(0,2,3);
insert into t1 values(2,2,3);
insert into t1 values(3,2,3);

insert into t2 values(2,2,3);
insert into t2 values(2,0,3);
insert into t2 values(0,2,3);
insert into t2 values(1,2,3);
insert into t2 values(null,2,3);
insert into t2 values(1,2,3);
insert into t2 values(0,2,3);
insert into t2 values(2,2,3);
commit;


create table t111_var(c0 bigint, c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into t111_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t111_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert into t111_var select c0,c1,c2,c3,c4,c5,c6,c7 from t111_var;
commit;

create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var values(null,null,null,null,null,null,null,null);
commit;

create table t1_set(c1 tinyint, c2 tinyint unsigned);
create table t2_set(c1 tinyint, c2 tinyint unsigned);

insert into t1_set values(-128, 0);
insert into t1_set values(127, 255);
insert into t1_set values(-128, 255);
insert into t1_set values(-1, 255);
#insert into t1_set values(200, 255);

insert into t2_set values(-128, 0);
insert into t2_set values(127, 255);
insert into t2_set values(-128, 255);
commit;

--result_format 4
--explain_protocol 1
#set  @@ob_enable_trace_log=1;
#set  @@ob_log_level='trace';

select /*+ use_hash(a b)*/ * from t1 a , t2 b where a.c1=b.c1;
select /*+ use_hash(a b)*/ * from t1 a left outer join t2 b on a.c1=b.c1;
select /*+ use_hash(a b)*/ * from t1 a right outer join t2 b on a.c1=b.c1;
select /*+ use_hash(a b)*/ * from t1 a full outer join t2 b on a.c1=b.c1;

select /*+ use_hash(a b)*/ * from t1 a where c1 in (select c2 from  t2 b );
select /*+ use_hash(a b)*/ * from t1 a where c1 in (select c2 from  t2 b where a.c2=b.c2);

select /*+ use_hash(a b)*/ * from t1 a , t2 b where a.c3=b.c3;

# tinyint = unsigned tinyint
select /*+ leading(a b) use_hash(a b)*/ * from t1_set a join t2_set b where a.c1=b.c1;
select /*+ leading(a b) use_hash(a b)*/ * from t1_set a join t2_set b where a.c1=b.c2;
select /*+ leading(a b) use_hash(a b)*/ * from t1_set a join t2_set b where a.c2=b.c1;
select /*+ leading(a b) use_hash(a b)*/ * from t1_set a left outer join t2_set b on a.c1=b.c1;

##test hash join dump
#alter system set _force_hash_join_spill=true;
select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7),sum(d0),sum(length(d1)),count(d2),count(d3),count(d4),count(d5),count(d6),count(d7)
from (select a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7,b.c0 d0,b.c1 d1,b.c2 d2,b.c3 d3,b.c4 d4,b.c5 d5,b.c6 d6,b.c7 d7 from t111_var a join t333_var b on a.c0=b.c0) order by c1 limit 1;

select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7),sum(d0),sum(length(d1)),count(d2),count(d3),count(d4),count(d5),count(d6),count(d7)
from (select a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7,b.c0 d0,b.c1 d1,b.c2 d2,b.c3 d3,b.c4 d4,b.c5 d5,b.c6 d6,b.c7 d7 from t111_var a left outer join t333_var b on a.c0=b.c0) order by c1 limit 1;

select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7),sum(d0),sum(length(d1)),count(d2),count(d3),count(d4),count(d5),count(d6),count(d7)
from (select a.c0,a.c1,a.c2,a.c3,a.c4,a.c5,a.c6,a.c7,b.c0 d0,b.c1 d1,b.c2 d2,b.c3 d3,b.c4 d4,b.c5 d5,b.c6 d6,b.c7 d7 from t111_var a right outer join t333_var b on a.c0=b.c0) order by c1 limit 1;

#select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7)
#from t111_var a where a.c0 in (select b.c0 from t333_var b) order by c1 limit 1;

select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7)
from t111_var a where a.c0 not in (select b.c0 from t333_var b where b.c1 is null) order by c1 limit 1;

set ob_query_timeout = 60000000;
select /*+ leading(a b) use_hash(a b) */SQL_CALC_FOUND_ROWS sum(c0),sum(length(c1)),count(c2),count(c3),count(c4),count(c5),count(c6),count(c7)
from t111_var a where a.c0 not in (select b.c0 from t333_var b where b.c1 is not null) order by c1 limit 1;



connection syscon;
#drop tenant dump_tenant force;
#drop resource pool new_pool1;
#drop resource unit new_box1;
