# owner: luofan.zp
# owner group: SQL2

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 varchar(100));
insert into t1 values('a');

--echo // Case1: normal test
set ob_enable_plan_cache = 0;
--echo // 0, 应该有两个cast expr
--echo // TODO: 这里有bug,
--echo // 目前是保证结果跟不开新引擎的结果一致,bug后面再修复
select convert(c1 using binary) = 'A' from t1;
--echo // 下面四个都是1
select convert(c1 using utf8mb4) = 'A' from t1;
select convert(c1 using gbk) = 'A' from t1;
--echo // 这里也有bug，虽然结果是对的，但是仍然有上述的bug存在
select convert(c1 using utf16) = 'A' from t1;
select convert(c1 using gb18030) = 'A' from t1;

--echo // Case2: 进行各种类型的convert
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 varchar(30), c22 char(30), c23 blob, c24 text,
    c25 binary(29), c26 varbinary(30));
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-03 06:00:00', 
    '9.5', '10.5', 'blob type', 'text type', X'FE', X'FE');

set ob_enable_plan_cache = 0;
let $cnt=24;
let $idx=1;
while ($idx <= $cnt)
{
  eval select convert(c$idx using utf8mb4) from t1;
  eval select convert(c$idx using gbk) from t1;
  eval select convert(c$idx using utf16) from t1;
  eval select convert(c$idx using gb18030) from t1;

  inc $idx;
}
let $cnt=26;
while ($idx <= $cnt)
{
  eval select hex(convert(c$idx using utf8mb4)) from t1;
  eval select hex(convert(c$idx using gbk)) from t1;
  eval select hex(convert(c$idx using utf16)) from t1;
  eval select hex(convert(c$idx using gb18030)) from t1;

  inc $idx;
}

--echo // Case3: 测试转换为其他类型
--echo // 1.000
select convert(c1, decimal(10, 3)) from t1;

drop table t1;

--echo issue 40652361
select convert('☺' using gbk);
create table t1(c1 varchar(100));
insert into t1 values('☺');
select convert(c1 using gbk) from t1;
drop table t1;

--echo issue 43090283
select convert(x'e68891' using utf8);

