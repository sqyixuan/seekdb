#owner: xiaoyi.xy
#tag: optimizer

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;

--sleep 2
alter system flush plan cache global;
--sleep 3
connection default;
--disable_query_log
--disable_warnings
drop table if exists t;
--enable_warnings
--enable_query_log

create table t (pk int primary key, a int); 

insert into t values (1, 1), (2, 2), (3, 3), (4, 4);

--echo >>>>>>>> Simple Case
select 1 + 1 from t;
--echo // hit plan ans pre calculated
select 1 + 1 from t;
explain select 1 + 1 from t;
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select ? + ? from t';

select * from t where pk = 1 + 1;
select * from t where pk = 2 + 1;
explain select * from t where pk = 2 + 1;
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where pk = ? + ?';

--echo // BUG, need fix [zongmei.zzm]

explain select * from t where pk = '1' + 1;

--echo >>>>>>>> Test Always True or False
select * from t where 1 + 1 = 2;
select * from t where 1 + 0 = 2;
select * from t where 1 + 2 = 3;
select * from t where 1 + 2 = 4;

explain select * from t where 1 + 1 = 2;
explain select * from t where 1 + 0 = 2;
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where ? + ? = ?';


--echo >>>>>>>> Pre Calc exprs generate by rewrite

select * from t where pk = 1 + 0 + (select 2 from dual);
select * from t where pk = 1 + 1 + (select 1 from dual);

explain select * from t where pk = 1 + 1 + (select 1 from dual);

select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where pk = ? + ? + (select ? from dual)';

select * from t where pk = (1 * 1) + (select 2 + 1 from dual);
select * from t where pk = (1 * 1) + (select 1 + 2 from dual);
explain select * from t where pk = (1 * 1) + (select 1 + 2 from dual);
select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select * from t where pk = (? * ?) + (select ? + ? from dual)';


select case when 1 then 1 else 1 / 0 end from t;
select case when 1 then 1 else 1 / 0 end from t;
explain select case when 1 then 1 else 1 / 0 end from t;

select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select case when ? then ? else ? / ? end from t';
drop table t;

--echo >>>>>>>> // Pre Calc Expr generated by Cost rewrite
create table t (pk int primary key, c1 int, c2 int);
create index idx_c1 on t(c1) local;
create index idx_c2 on t(c2) local;

insert into t values (1001, 1001, 1);
insert into t values (1002, 1, 1001);

--disable_query_log
let $cnt = 1;
while ($cnt <= 1000)
{
  eval insert into t values ($cnt, 1, 1);
  inc $cnt;
}
--enable_query_log

select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 1) + (select 999 from dual);
select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 0) + (select 1000 from dual);
explain select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 0) + (select 1000 from dual);

select hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select /*+use_concat*/* from t where c1 = (select ? from dual) or c2 = (? + ?) + (select ? from dual)';
drop table t;

--echo >>>>>>>> // like expr
create table t (a varchar (255));
insert into t values ('hello'), ('hi'), ("what's up");

select * from t where a like '%h%';
explain select * from t where a like '%h%';

--echo >>>>>>>> // greatest/least expr
drop table t;
create table t(c1 decimal);
select c1 from t where least(c1, !1);
select c1 from t where greatest(c1, !1);
drop table t;

--echo >>>>>>>> // bug:
--disable_warnings
source mysql_test/test_suite/static_engine/t/pre_calc.sql;
EXPLAIN SELECT DISTINCT GRANDPARENT1 . col_int_key AS G1 FROM p AS GRANDPARENT1 WHERE GRANDPARENT1 . `pk` IN ( SELECT  PARENT1 . `col_int_key` AS P1 FROM hh AS PARENT1 LEFT JOIN c AS PARENT2 ON ( PARENT1 . `col_varchar_10_key` >= PARENT2 . `col_varchar_20` ) WHERE ( PARENT1 . `pk` , PARENT1 . `pk` ) IN ( SELECT  CHILD1 . `col_int_key` AS C1 , CHILD1 . `col_int_key` AS C2 FROM q AS CHILD1 LEFT JOIN s AS CHILD2 ON ( CHILD1 . `col_varchar_10_key` <> CHILD2 . `col_varchar_10` ) WHERE ( ( CHILD1 . `col_varchar_20_key` <> CHILD1 . `col_varchar_20` ) OR NOT ( ( CHILD1 . `col_date_key` <= PARENT1 . `col_date` ) OR ( GRANDPARENT1 . `col_date` <> '2006-03-14' ) ) ) ORDER BY CHILD1 . col_int_key ) AND ( ( PARENT1 . `col_datetime` >= GRANDPARENT1 . `col_datetime` ) OR ( GRANDPARENT1 . `col_date_key` BETWEEN '2007-11-14' AND '2000-11-16' OR GRANDPARENT1 . `col_int` = 4 ) )  ) AND ( GRANDPARENT1 . col_int_key IS UNKNOWN OR NOT GRANDPARENT1 . `col_datetime_key` <= '2006-03-25' )  ORDER BY GRANDPARENT1 . col_int_key LIMIT 7;
SELECT DISTINCT GRANDPARENT1 . col_int_key AS G1 FROM p AS GRANDPARENT1 WHERE GRANDPARENT1 . `pk` IN ( SELECT  PARENT1 . `col_int_key` AS P1 FROM hh AS PARENT1 LEFT JOIN c AS PARENT2 ON ( PARENT1 . `col_varchar_10_key` >= PARENT2 . `col_varchar_20` ) WHERE ( PARENT1 . `pk` , PARENT1 . `pk` ) IN ( SELECT  CHILD1 . `col_int_key` AS C1 , CHILD1 . `col_int_key` AS C2 FROM q AS CHILD1 LEFT JOIN s AS CHILD2 ON ( CHILD1 . `col_varchar_10_key` <> CHILD2 . `col_varchar_10` ) WHERE ( ( CHILD1 . `col_varchar_20_key` <> CHILD1 . `col_varchar_20` ) OR NOT ( ( CHILD1 . `col_date_key` <= PARENT1 . `col_date` ) OR ( GRANDPARENT1 . `col_date` <> '2006-03-14' ) ) ) ORDER BY CHILD1 . col_int_key ) AND ( ( PARENT1 . `col_datetime` >= GRANDPARENT1 . `col_datetime` ) OR ( GRANDPARENT1 . `col_date_key` BETWEEN '2007-11-14' AND '2000-11-16' OR GRANDPARENT1 . `col_int` = 4 ) )  ) AND ( GRANDPARENT1 . col_int_key IS UNKNOWN OR NOT GRANDPARENT1 . `col_datetime_key` <= '2006-03-25' )  ORDER BY GRANDPARENT1 . col_int_key LIMIT 7;
DROP TABLE P;
DROP TABLE Q;
DROP TABLE HH;
DROP TABLE S;
DROP TABLE C;
