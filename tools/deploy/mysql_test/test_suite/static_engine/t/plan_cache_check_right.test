#owner: xiaoyi.xy
#owner group: sql1

connect (conn_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;

--disable_info
--disable_metadata
--disable_query_log
--disable_result_log

alter system flush plan cache;
--sleep 1
connection default;
select effective_tenant();


--disable_query_log
--disable_result_log
SET NAMES 'utf8mb4' COLLATE 'utf8mb4_general_ci';
set @@ob_enable_plan_cache = 1;
#set ob_read_consistency = 'weak';
--sleep 1
source mysql_test/test_suite/static_engine/t/plan_cache_table_init.sql;

connection conn_admin;
--sleep 2

connection default;
source mysql_test/test_suite/static_engine/t/plan_cache.sql;
--enable_query_log
--enable_result_log
source mysql_test/test_suite/static_engine/t/plan_cache_change_param.sql;

--echo # test insert hit plan
alter system flush plan cache global;
create table insert_t(c1 int primary key, c2 int);
set autocommit = 0;
insert into insert_t values(1, null);
insert into insert_t values(2, '1');
select hit_count from oceanbase.V$OB_PLAN_CACHE_PLAN_STAT where STATEMENT = "insert into insert_t values(?, ?)";
select * from insert_t;
commit;
set autocommit = 1;

--echo
--disable_query_log
--disable_result_log
--disable_warnings
drop table type_t;
drop table t1;
drop table t2;
drop table t3;
drop table dist_t;
drop table emp;
drop table acs_test;
drop table insert_t;
drop tablegroup xy_group;
--enable_warnings

connection conn_admin;
--sleep 2
