#owner: peihan.dph
#owner group: sql2
#tags: optimizer
#description: 测试新引擎下bit and, bit or, bit count, bit xor, bit leftshift, bit right shift

--disable_abort_on_error
--result_format 4
--explain_protocol 0
--disable_warnings
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
set @@ob_enable_plan_cache = 0;
sleep 2;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 varchar(30), c22 char(30));
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-03 06:00:00', 
    '9.5', '10.5');
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-03 06:00:00', 
    '-9.5', '10.5');

let $cnt=22;
let $left=1;
while ($left <= $cnt)
{
  eval select bit_count(c$left) from t1;
  eval select ~c$left from t1;

  let $right=1;
  while ($right <= $cnt)
  {
    eval select c$left, c$right, c$left & c$right from t1;
    eval select c$right, null & c$right from t1;
    eval select c$left, c$left & null from t1;

    eval select c$left, c$right, c$left | c$right from t1;
    eval select c$right, null | c$right from t1;
    eval select c$left, c$left | null from t1;

    eval select c$left, c$right, c$left << c$right from t1;
    eval select c$right, null << c$right from t1;
    eval select c$left, c$left << null from t1;

    eval select c$left, c$right, c$left >> c$right from t1;
    eval select c$right, null >> c$right from t1;
    eval select c$left, c$left >> null from t1;

    eval select c$left, c$right, c$left ^ c$right from t1;
    eval select c$right, null ^ c$right from t1;
    eval select c$left, c$left ^ null from t1;

    inc $right;
  }
  inc $left;
}

--echo // big number, res is 0
select 11111111111111111111111111111 & 0;
select 11111111111111111111111111111 | 0;
select 11111111111111111111111111111 << 0;
select 11111111111111111111111111111 >> 0;
select 11111111111111111111111111111 ^ 0;
select ~11111111111111111111111111111;
select bitcount(11111111111111111111111111111);

--echo // in create table as, cast_mode has no WARN_ON_FAIL, so got out of range error
create table t1 as select 11111111111111111111111111111 & 0;

select 1 & 0;
select 1 & 1;
select 1 & -1;
select 1 & -2;

select 1 | 0;
select 1 | 1;
select 1 | -1;
select 1 | -2;

select 1 >> 0;
select 1 >> 1;
select 1 >> -1;
select 1 >> -2;

sleep 2;


--disable_warnings
drop table if exists t;
--enable_warnings
create table t ( c1 float );
insert into t values (-9.183);
(SELECT 1 FROM t WHERE COT(0.2)=0) UNION ALL (SELECT (BINARY c1 | 0) FROM t);
