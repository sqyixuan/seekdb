# owner: peihan.dph
# owner group: sql2

--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;
sleep 2;

set ob_enable_plan_cache = 0;
#basic test
set block_encryption_mode = 0;
show variables like 'block_encryption_mode';
--error 1235
select hex(sm4_encrypt('abcd', 'asd')) from dual; 
--error 1235
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
--error 1235
select hex(sm4_decrypt('abc', 'dbc')) from dual;

set block_encryption_mode = 17;
show variables like 'block_encryption_mode';
--error 1235
select hex(sm4_encrypt('abcd', 'asd')) from dual; 
--error 1235
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
--error 1235
select hex(sm4_decrypt('abc', 'dbc')) from dual;


--error 0,1231
set block_encryption_mode = 18;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc
--source mysql_test/test_suite/security/include/sm4_two_param.inc

--error 0,1231
set block_encryption_mode = 19;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

--error 0,1231
set block_encryption_mode = 20;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

--error 0,1231
set block_encryption_mode = 21;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

sleep 2;
