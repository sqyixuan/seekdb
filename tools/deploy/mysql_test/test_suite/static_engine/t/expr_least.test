set @@ob_enable_plan_cache = 0;



let $cnt=18;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select least(c$left, c$right), greatest(c$left, c$right) from t;
    inc $right;
  }
  inc $left;
}

let $first=1;
while ($first <= $cnt)
{
  let $second=1;
  while ($second <= $cnt)
  {
    let $third=1;
    while ($third <= $cnt)
    {
      eval select least(c$first, c$second, c$third), greatest(c$first, c$second, c$third) from t;
      inc $third;
    }
    inc $second;
  }
  inc $first;
}
-- error 1690
select least(pow(10000, 10000), c18) from t;
-- error 1690
select greatest(pow(10000, 10000), c18) from t;
select least(c18, pow(10000, 10000)), greatest(c18, pow(10000, 10000)) from t;

let $cnt=10;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select a.c1, b.c1, least(a.c1, b.c1), greatest(a.c1, b.c1) from t$left a, t$right b;
    inc $right;
  }
  inc $left;
}

