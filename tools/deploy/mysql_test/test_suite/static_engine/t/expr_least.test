col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_char_20 char(20),
col_decimal_20_0 decimal(20,0),
pk bigint,
col_bigint bigint,
/*Indices*/
primary key (pk) )  ;
UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ table0_bigint SET pk = ( ROUND( GREATEST( 4 , ( ROUND( COALESCE( 8 , 6 , 1 ) ) * 2 - 1 ) , ( ROUND( -49 / ( -23 * 2 - 1 ) ) * 2 - 1 ) ) ) * 2 - 1 )  ORDER BY col_char_20 ASC , col_char_20 ASC , col_char_20 ASC , pk DESC LIMIT 1;
