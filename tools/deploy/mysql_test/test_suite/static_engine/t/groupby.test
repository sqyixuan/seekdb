#owner: bin.lb
#owner group: sql2

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
alter system set enable_async_syslog = false;

connection default;
#set @@ob_enable_plan_cache = 0;
#set @@ob_log_level='debug';

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (
    c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 year, c22 date, c23 time, 
    c24 varchar(30), c25 char(30),
    c26 varbinary(30), c27 binary(30));
    
select * from t1;
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00', 
    2020,'2020-01-01','12:34:56',
    '9.5', '10.5',
    '9.5', '10.5');
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00', 
    2021,'2020-01-11','12:35:56',
    '-9.5', '10.5',
    '-9.5', '10.5');

insert into t1 (c1) values(4);
insert into t1 (c1) values(5);

insert into t1 values(3, 3,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -3.5, 4.5,
    -3.5, 6.5,
    -3.5, 8.5,
    '2019-02-11 12:00:00', '2019-12-03 16:00:00',
    2001,'2000-01-11','10:35:56',
    '-9.5', '10.5',
    '-9.5', '10.5');

connection conn_admin;
--sleep 1

connection default;
--echo #### test add expr and limit operator in new engine

--disable_abort_on_error

--disable_warnings
let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  eval select max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 order by 1,2,3 limit 10;
  eval select c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), group_concat(c$left, c$left order by c1 separator '----') from t1 order by 1,2,3 limit 10;

  inc $left;
}

let $left=1;
eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2)*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;


let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select /*+no_use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
    eval select /*+no_use_hash_aggregation*/ c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), 1.23*1.23 from t1 group by c$left, c$right order by 1,2,3 limit 10;

    eval select  max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left), grouping(c$left) as g1, grouping(c$right)  from t1 group by c$left, c$right with rollup order by 1,2,3 limit 10;
    eval select  c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), 1.23*1.23 from t1 group by c$left, c$right with rollup order by 1,2,3 limit 10;
    inc $right;
  }

  inc $left;
}

eval select max(NULL), min(NULL), sum(NULL), avg(NULL), count(*), count(NULL), group_concat(NULL order by c1), approx_count_distinct(NULL) from t1 order by 1,2,3 limit 10;
eval select /*+no_use_hash_aggregation*/ max(NULL), min(NULL), sum(NULL), avg(NULL), count(*), count(NULL), group_concat(NULL order by c1), approx_count_distinct(NULL) from t1 group by c1 order by 1,2,3 limit 10;
eval select /*+no_use_hash_aggregation*/ max(NULL), min(NULL), sum(NULL), avg(NULL), count(*), count(NULL), group_concat(NULL order by c1), approx_count_distinct(NULL), grouping(c1) from t1 group by c1 with rollup order by 1,2,3 limit 10;


let $left=1;
let $right=1;

eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;

eval select /*+use_px parallel(2) no_use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right order by 1,2,3 limit 10;

eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+no_use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left)  from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_HASH(t12,t11)*/* from (select c$left from t1) t11 join (select /*+use_hash_aggregation*/ c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;


eval select /*+USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left), grouping(c$left) as g1, grouping(c$right) from t1 group by c$left, c$right with rollup) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;
eval select /*+use_px parallel(2)*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left), grouping(c$left) as g1, grouping(c$right) from t1 group by c$left, c$right with rollup order by 1,2,3 limit 10;
eval select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* from (select c$left from t1) t11 join (select c$left, max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left), grouping(c$left) as g1, grouping(c$right) from t1 group by c$left, c$right with rollup) t12 on t11.c$left = t12.c$left order by 1,2,3 limit 10;

delete from t1;

let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  eval select max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left)  from t1 order by 1,2,3 limit 10;
  eval select c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), group_concat(c$left, c$left order by c1 separator '----') from t1 order by 1,2,3 limit 10;
 
  inc $left;
}


let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {
    eval select /*+no_use_hash_aggregation*/ max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left)  from t1 group by c$left, c$right order by 1,2,3 limit 10;
    eval select /*+no_use_hash_aggregation*/ c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), 1.23*1.23 from t1 group by c$left, c$right order by 1,2,3 limit 10;

    eval select  max(c$left), min(c$left), sum(c$left), avg(c$left), count(*), count(c$left), group_concat(c$left order by c1), approx_count_distinct(c$left) from t1 group by c$left, c$right with rollup order by 1,2,3 limit 10;
    eval select  c1, c1 + c1, max(distinct c$left + c$left) + c$left + min(distinct c$left + c$left) + sum(distinct c$left + c$left) + avg(distinct c$left + c$left) + count(distinct c$left + c$left), 1.23*1.23 from t1 group by c$left, c$right with rollup order by 1,2,3 limit 10;
 
    inc $right;
  }

  inc $left;
}


#test null

create table t2 (c1 int, c2 int, c3 varchar(20));
insert into t2 values(0, 1, '');
insert into t2 values(0, 2, '');
insert into t2 values(1, 3, NULL);
insert into t2 values(1, 4, NULL);
insert into t2 values(2, 5, NULL);
insert into t2 values(2, 6, '');
insert into t2 values(3, 5, '');
insert into t2 values(3, 6, NULL);
insert into t2 values(4, 6, '2');
insert into t2 values(4, 7, NULL);
insert into t2 values(4, 8, '2');
insert into t2 values(5, 7, '2');
insert into t2 values(5, 9, '');
insert into t2 values(5, 10, '2');

select * from t2 order by c1, c2;

select /*+no_use_hash_aggregation*/c1, group_concat(c2 order by c2) from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2 order by c2) from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2) from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2) from t2 group by c1 with rollup;

select /*+no_use_hash_aggregation*/c1, group_concat(c2 order by c2 separator '-') from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2 order by c2 separator '-') from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2 separator '-') from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2 separator '-') from t2 group by c1 with rollup;

select /*+use_hash_aggregation*/c1, group_concat(c2 order by c2 separator '-') from t2 group by c1;
select /*+use_hash_aggregation*/c1, group_concat(c1, c2 order by c2 separator '-') from t2 group by c1;
select /*+use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2 separator '-') from t2 group by c1;
select /*+use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2 separator '-') from t2 group by c1 with rollup;

select /*+use_hash_aggregation*/c1, group_concat(c2 order by c2 separator '-') from t2;
select /*+use_hash_aggregation*/c1, group_concat(c1, c2 order by c2 separator '-') from t2;
select /*+use_hash_aggregation*/c1, group_concat(c1, c2, c3 order by c2 separator '-') from t2;

select /*+no_use_hash_aggregation*/c1, group_concat(distinct c2 order by c2 separator '-') from t2 group by c1;
select /*+no_use_hash_aggregation*/c1, group_concat(distinct c2 order by c2 separator '-') from t2 group by c1 with rollup;
select /*+use_hash_aggregation*/c1, group_concat(distinct c2 order by c2 separator '-') from t2 group by c1;
select /*+use_hash_aggregation*/c1, group_concat(distinct c2 order by c2 separator '-') from t2 group by c1 with rollup;
select c1, group_concat(distinct c2 order by c2 separator '-') from t2;

select c1, grouping(c1)  from t2 group by c1 with rollup;
select c1, grouping(c1)  from t2 group by c1,c1 with rollup;
select c1, grouping(c1)  from t2 group by c1,c1,c1 with rollup;

select approx_count_distinct(c1), approx_count_distinct_synopsis(c1) from t2 group by c2;
select approx_count_distinct(c1), approx_count_distinct_synopsis(c1) from t2 group by c2 with rollup;
--enable_warnings

connection conn_admin; 

