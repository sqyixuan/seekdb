# owner: bin.lb
# owner group: sql2

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

# fitler before indexback bug: 
create table t1 (c1 int primary key, c2 int, c3 int, index i1 (c2)); 
insert into t1 (c1, c2, c3) values (1, 1, 1), (2, null, 2);
select * from (select /*+ index(t1 i1) */ c2 is null as x, c3 from t1) a where x;

