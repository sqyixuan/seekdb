#owner: bin.lb
#owner group: sql2

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
#alter system set enable_async_syslog = false;
#alter system set syslog_io_bandwidth_limit='1G';

connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
    c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 year, c22 date, c23 time, 
    c24 varchar(4000), c25 char(256),
    c26 varbinary(4000), c27 binary(256));
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00', 
    2020,'2020-01-01','12:34:56',
    repeat('0',4000), repeat('0',250),
    repeat('0',4000), repeat('0',250));
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00', 
    2021,'2020-01-11','12:35:56',
    repeat(1,4000), repeat(1,250),
    repeat(1,4000), repeat(1,250));

insert into t1 (c1) values(4);
insert into t1 (c1) values(5);

insert into t1 values(3, 3,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -3.5, 4.5,
    -3.5, 6.5,
    -3.5, 8.5,
    '2019-02-11 12:00:00', '2019-12-03 16:00:00',
    2001,'2000-01-11','10:35:56',
    repeat(2,4000), repeat(2,250),
    repeat(2,4000), repeat(2,250));

select * from t1;
    

--disable_query_log

let $cnt=100;
let $left=1;
while ($left <= $cnt)
{
  let $val = ($left % 10);
  eval insert into t1 values(($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    date_add('2019-02-11 12:00:00', interval ($left % 100) hour),
    date_add('2019-12-03 16:00:00', interval ($left % 100) hour),
    2001 + ($left % 100),
    date_add('2019-12-03 16:00:00', interval ($left % 100) day),
    date_add('2019-12-03 16:00:00', interval ($left % 100) minute),
    repeat('3',4000), repeat('3',250),
    repeat('3',4000), repeat('3',250));
    
    inc $left;
}

--enable_query_log

connection conn_admin;
--sleep 1

connection default;
--echo #### test add expr and limit operator in new engine

#set @@ob_enable_plan_cache = 0;
#set @@ob_log_level='debug';

--disable_abort_on_error

--disable_warnings
let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {

    eval select c$left,  c$left + c$right 
                ,rank() over (partition by c$right) as 'c01'
                ,rank() over (partition by c$right order by c$right) as 'c02'
                ,rank() over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,rank() over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,rank() over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,rank() over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,rank() over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,rank() over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,rank() over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,rank() over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,rank() over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,rank() over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,rank() over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,rank() over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,rank() over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,rank() over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,rank() over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,rank() over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
    eval select c$left,  c$left + c$right 
                ,row_number() over (partition by c$right) as 'c01'
                ,row_number() over (partition by c$right order by c$right) as 'c02'
                ,row_number() over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,row_number() over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,row_number() over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,row_number() over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,row_number() over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,row_number() over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,row_number() over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,row_number() over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,row_number() over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,row_number() over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,row_number() over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,row_number() over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,row_number() over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,row_number() over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,row_number() over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,row_number() over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
    eval select c$left,  c$left + c$right 
                ,ntile(123) over (partition by c$right) as 'c01'
                ,ntile(123) over (partition by c$right order by c$right) as 'c02'
                ,ntile(123) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,ntile(123) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,ntile(123) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,ntile(123) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,ntile(123) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,ntile(123) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,ntile(123) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,ntile(123) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,ntile(123) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,ntile(123) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
    eval select c$left,  c$left + c$right 
                ,cume_dist() over (partition by c$right) as 'c01'
                ,cume_dist() over (partition by c$right order by c$right) as 'c02'
                ,cume_dist() over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,cume_dist() over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,cume_dist() over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,cume_dist() over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,cume_dist() over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,cume_dist() over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,cume_dist() over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,cume_dist() over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,cume_dist() over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,cume_dist() over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
     eval select c$left,  c$left + c$right 
                ,first_value(c$left) ignore nulls over (partition by c$right) as 'c01'
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right) as 'c02'
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,first_value(c$left) ignore nulls over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,first_value(c$left) ignore nulls over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
     
	inc $right;
    eval select c$left,  c$left + c$right 
                ,last_value(c$left) respect nulls over (partition by c$right) as 'c01'
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right) as 'c02'
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,last_value(c$left) respect nulls over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,last_value(c$left) respect nulls over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
     eval select c$left,  c$left + c$right 
                ,LEAD(c$left) ignore nulls over (partition by c$right) as 'c01'
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right) as 'c02'
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,LEAD(c$left) ignore nulls over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,LEAD(c$left) ignore nulls over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;


	inc $right;
    eval select c$left,  c$left + c$right 
                ,LAG(c$left) respect nulls over (partition by c$right) as 'c01'
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right) as 'c02'
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,LAG(c$left) respect nulls over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,LAG(c$left) respect nulls over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

	inc $right;
    eval select c$left,  c$left + c$right 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right) as 'c01'
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right) as 'c02'
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,nth_value(c$left, $right) from first  ignore nulls over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,nth_value(c$left, $right) from last  respect nulls over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;

    inc $right;
  }
  inc $left;
}
--enable_warnings

connection conn_admin; 
