#owner: zuojiao.hzj
#owner group: sql2
--disable_abort_on_error
--result_format 4
--disable_warnings
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set enable_async_syslog = false;
--sleep 2
connection default;

drop table if exists t;

create table t(a int);

select 1/0 from t;
select case when a = 1 then 1 else 1 / 0 end from t;
select cast('aaa' as signed) from t;


insert into t values (1);
select 1/0 from t;
select case when a = 1 then 1 else 1 / 0 end from t;
select cast('aaa' as signed) from t;

connection conn_admin;
--sleep 2
connection default;

connection conn_admin;
connection default;
drop table t;
