# owner: bin.lb
# owner group: sql2
# tags: optimizer

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
--sleep 2
connection default;


--disable_warnings
drop table if exists t1;
drop view if exists v;
create table t1 (c1 int, c2 int);
insert into t1 (c1 , c2) values (1, 1);

--enable_warnings

connection syscon;

sleep 2;

connection default;
set @@ob_enable_plan_cache = 0;

explain select (select c1 from ((select a.c1, c2 from t1) union (select c1, a.c2 from t1))u ) as x from t1 a;
select (select c1 from ((select a.c1, c2 from t1) union (select c1, a.c2 from t1))u ) as x from t1 a;

create view v as select (select c1 from ((select a.c1, c2 from t1) union (select c1, a.c2 from t1))u ) as x from t1 a;
show create view v;

explain select c1 = (select 1 from dual) from t1;
select c1 = (select 1 from dual) from t1;

drop table t1;
create table t1 (c1 int primary key, c2 int, c3 int) partition by hash (c1) partitions 3;
insert into t1 (c1) values (1),(2),(3),(4); 
select /*+NO_REWRITE*/ count(*) from t1 group by 1 + (select 1 > all (select 0));

connection syscon;
--sleep 2
