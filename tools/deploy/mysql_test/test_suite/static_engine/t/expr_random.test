# owner: dachuan.sdc
# owner gorup: SQL2
# tags: optimizer

--disable_abort_on_error
--result_format 4
--explain_protocol 0

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
set @@ob_enable_plan_cache = 0;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);
insert into t1 values(1),(2), (-1), (-2), (0);

--sleep 1

select rand(c1) from t1;
select rand(1), rand(2), rand(-1), rand(-2), rand(0);

drop table t1;
