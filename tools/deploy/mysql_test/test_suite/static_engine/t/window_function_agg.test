#owner: bin.lb
#owner group: sql2

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
#alter system set enable_async_syslog = false;
#alter system set syslog_io_bandwidth_limit='1G';

connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (
    c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 year, c22 date, c23 time, 
    c24 varchar(4000), c25 char(256),
    c26 varbinary(4000), c27 binary(256));
    
insert into t1 values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00', 
    2020,'2020-01-01','12:34:56',
    repeat('0',4000), repeat('0',250),
    repeat('0',4000), repeat('0',250));
insert into t1 values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00', 
    2021,'2020-01-11','12:35:56',
    repeat(1,4000), repeat(1,250),
    repeat(1,4000), repeat(1,250));

insert into t1 (c1) values(4);
insert into t1 (c1) values(5);

insert into t1 values(3, 3,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -3.5, 4.5,
    -3.5, 6.5,
    -3.5, 8.5,
    '2019-02-11 12:00:00', '2019-12-03 16:00:00',
    2001,'2000-01-11','10:35:56',
    repeat(2,4000), repeat(2,250),
    repeat(2,4000), repeat(2,250));

select * from t1;
    

--disable_query_log

let $cnt=100;
let $left=1;
while ($left <= $cnt)
{
  let $val = ($left % 10);
  eval insert into t1 values(($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    -($left % 100), ($left % 100),
    date_add('2019-02-11 12:00:00', interval ($left % 100) hour),
    date_add('2019-12-03 16:00:00', interval ($left % 100) hour),
    2001 + ($left % 100),
    date_add('2019-12-03 16:00:00', interval ($left % 100) day),
    date_add('2019-12-03 16:00:00', interval ($left % 100) minute),
    repeat('3',120), repeat('3',150),
    repeat('3',120), repeat('3',150));
    
    inc $left;
}

--enable_query_log

connection conn_admin;
--sleep 1

connection default;
--echo #### test add expr and limit operator in new engine

#set @@ob_enable_plan_cache = 0;
#set @@ob_log_level='debug';

--disable_abort_on_error

--enable_metadata

let $cnt=27;
let $left=1;
while ($left <= $cnt)
{
  let $right=1;
  while ($right <= $cnt)
  {

    eval select c$left,  c$left + c$right 
                ,max(c$left) over (partition by c$right) as 'c01'
                ,max(c$left) over (partition by c$right order by c$right) as 'c02'
                ,max(c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,max(c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,max(c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)  as 'c05' 
                ,max(c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,max(c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,max(c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,max(c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,max(c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,max(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,max(c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;

    eval select c$left,  c$left + c$right 
                ,min(DISTINCT c$left) over (partition by c$right) as 'c01'
                ,min(DISTINCT c$left) over (partition by c$right order by c$right) as 'c02'
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,min(DISTINCT c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,min(DISTINCT c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;

    eval select c$left,  c$left + c$right 
                ,sum(c$left) over (partition by c$right) as 'c01'
                ,sum(c$left) over (partition by c$right order by c$right) as 'c02'
                ,sum(c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,sum(c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,sum(c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,sum(c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,sum(c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,sum(c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,sum(c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,sum(c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,sum(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,sum(c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;

    eval select c$left,  c$left + c$right 
                ,avg(c$left) over (partition by c$right) as 'c01'
                ,avg(c$left) over (partition by c$right order by c$right) as 'c02'
                ,avg(c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,avg(c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,avg(c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,avg(c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,avg(c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,avg(c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,avg(c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,avg(c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,avg(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,avg(c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;

     eval select c$left,  c$left + c$right 
                ,count(*) over (partition by c$right) as 'c01'
                ,count(*) over (partition by c$right order by c$right) as 'c02'
                ,count(*) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,count(*) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,count(*) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,count(*) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,count(*) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,count(*) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,count(*) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,count(*) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 

                ,count(*) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,count(*) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,count(*) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,count(*) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,count(*) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,count(*) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,count(*) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,count(*) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;
     
    eval select c$left,  c$left + c$right 
                ,stddev(c$left) over (partition by c$right) as 'c01'
                ,stddev(c$left) over (partition by c$right order by c$right) as 'c02'
                ,stddev(c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,stddev(c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,stddev(c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,stddev(c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,stddev(c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,stddev(c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,stddev(c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,stddev(c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 
    from t1 order by 1,2,3 limit 10;

    eval select c$left,  c$left + c$right 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,stddev(c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;


    eval select c$left,  c$left + c$right 
                ,variance(c$left) over (partition by c$right) as 'c01'
                ,variance(c$left) over (partition by c$right order by c$right) as 'c02'
                ,variance(c$left) over (partition by c$right order by c$right rows between 1 preceding and 1 following)  as 'c03'
                ,variance(c$left) over (partition by c$right order by c$right rows between 2 preceding and 1 preceding)  as 'c04' 
                ,variance(c$left) over (partition by c$right order by c$right rows between 1 following and 2 following)   as 'c05' 
                ,variance(c$left) over (partition by c$right order by c$right rows between CURRENT ROW  and 1 following)  as 'c06' 
                ,variance(c$left) over (partition by c$right order by c$right rows between 1 preceding  and CURRENT ROW)   as 'c07' 
                ,variance(c$left) over (partition by c$right order by c$right rows between UNBOUNDED preceding and CURRENT ROW)   as 'c08' 
                ,variance(c$left) over (partition by c$right order by c$right rows between CURRENT ROW and UNBOUNDED following)   as 'c09' 
                ,variance(c$left) over (partition by c$right order by c$right rows CURRENT ROW)  as 'c10' 
    from t1 order by 1,2,3 limit 10;

    eval select c$left,  c$left + c$right 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding and 1 following)  as 'c11' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between 2 preceding and 1 preceding)  as 'c12' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between 1 following and 2 following)  as 'c13' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW  and 1 following)   as 'c14' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between 1 preceding  and CURRENT ROW)   as 'c15' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between UNBOUNDED preceding and CURRENT ROW)   as 'c16' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range between CURRENT ROW and UNBOUNDED following)   as 'c17' 
                ,variance(c$left) over (partition by c$left, c$right order by c$right range CURRENT ROW)   as 'c18' 
    from t1 order by 1,2,3 limit 10;
    inc $right;
  }
  inc $left;
}

select /*+no_use_px USE_MERGE(t12,t11)*/* 
from (
    select distinct c1  from t1
) t11 
join (select /*+use_px parallel(2) */ c1,  c2, c3, c1 + c2 + c3 
            ,sum(c1) over (partition by c2 order by c3,c1 rows between 2 preceding and 1 preceding)  as 'c04' 
            ,sum(c1) over (partition by c1, c2 order by c3 range between 1 preceding and 1 following)  as 'c11' 
      from t1
) t12 on t11.c1 = t12.c1 order by 1,2,3,4 limit 10;

select /*+no_use_px USE_HASH(t12,t11)*/* 
from (
    select distinct c1  from t1
) t11 
join (select /*+use_px parallel(2) */ c1,  c2, c3, c1 + c2 + c3 
            ,sum(c1) over (partition by c2 order by c3,c1 rows between 2 preceding and 1 preceding)  as 'c04' 
            ,sum(c1) over (partition by c1, c2 order by c3 range between 1 preceding and 1 following)  as 'c11' 
      from t1
) t12 on t11.c1 = t12.c1 order by 1,2,3,4 limit 10;


select /*+use_px parallel(2) */ c1,  c2, c3, c1 + c2 + c3 
            ,sum(c1) over (partition by c2 order by c3,c1 rows between 2 preceding and 1 preceding)  as 'c04' 
            ,sum(c1) over (partition by c1, c2 order by c3 range between 1 preceding and 1 following)  as 'c11' 
from t1 order by 1,2,3 limit 10;

select /*+use_px parallel(2) USE_MERGE(t12,t11)*/* 
from (
    select distinct c1  from t1
) t11 
join (select /*+use_px parallel(2) */ c1,  c2, c3, c1 + c2 + c3 
            ,sum(c1) over (partition by c2 order by c3,c1 rows between 2 preceding and 1 preceding)  as 'c04' 
            ,sum(c1) over (partition by c1, c2 order by c3 range between 1 preceding and 1 following)  as 'c11' 
      from t1
) t12 on t11.c1 = t12.c1 order by 1,2,3,4 limit 10;

select /*+use_px parallel(2) USE_HASH(t12,t11)*/* 
from (
    select distinct c1  from t1
) t11 
join (select /*+use_px parallel(2) */ c1,  c2, c3, c1 + c2 + c3 
            ,sum(c1) over (partition by c2 order by c3,c1 rows between 2 preceding and 1 preceding)  as 'c04' 
            ,sum(c1) over (partition by c1, c2 order by c3 range between 1 preceding and 1 following)  as 'c11' 
      from t1
) t12 on t11.c1 = t12.c1 order by 1,2,3,4 limit 10;


--disable_metadata

connection conn_admin; 
