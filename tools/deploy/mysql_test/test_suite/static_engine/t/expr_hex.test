# owner: bin.lb
# owner group: sql2

--result_format 4

set @@ob_enable_plan_cache = 0;

select hex(1);
select hex(110);
select hex(110.1);
select hex(110.9);
select hex(-1);
select hex(-110.9);

select hex(null);
select hex('abcdef');
select hex(timestamp'2019-11-11 11:11:11');

##bugfix: 
--disable_warnings
drop table if exists table0_bigint;
--enable_warnings

create table table0_bigint(pk int, col_char_20 char(20), col_bigint bigint);
SELECT pk FROM table0_bigint WHERE 
( col_char_20 NOT IN (TRIM( SUBSTR( SUBSTR( 'r' , 1, 20) , 1 , 20 ) ) ,
  TRIM( SUBSTR( CONCAT( TRIM( BOTH TRIM( SUBSTR( SUBSTR( CAST( ( 0 ) AS CHAR(100) ) , 1 , 20 ) , 1 , 20 ) ) FROM TRIM( SUBSTR( HEX( TRIM( SUBSTR( REPEAT( TRIM( SUBSTR( CONCAT(SUBSTR( COALESCE( SUBSTR( 'yrawm' , 1, 20) , SUBSTR( 'm' , 1, 20) , SUBSTR( 'umyrawm' , 1, 20) ) FROM 3 ) , SUBSTR( 'yumyr' , 1, 20) ) , 1 , 20 ) ) , 1 + 1 ) , 1 , 20 ) ) ) , 1 , 20 ) ) ) , CONCAT(CONCAT( SUBSTR( HEX( SUBSTR( 'py' , 1, 20) ) , 1, 20) , SUBSTR( 'ip' , 1, 20) ) , 'tail' ) ) , 1 , 20 ) ) ,
  TRIM( SUBSTR( HEX( SUBSTR( 'vi' , 1, 20) ) , 1 , 20 ) )) )
AND ( ( (  -100 = col_bigint )  AND  ( UPPER( SUBSTR( 'pvipyu' , 1, 20) ) NOT LIKE UPPER( SUBSTR( 'zp' , 1, 20) ) ESCAPE 'c' ) ) AND col_char_20 IS NOT NULL AND ( 0 ) IS NOT NULL )
ORDER BY col_char_20 ASC , col_char_20 ASC , col_char_20 DESC , pk DESC;
drop table table0_bigint;