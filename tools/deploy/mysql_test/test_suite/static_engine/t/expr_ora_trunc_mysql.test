#owner: lijinmao.ljm
#owner group: sql1
#tags: optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

--result_format 4
--explain_protocol 0

create table t1 (c1 int, c2 int unsigned,
    c3 float, c4 float unsigned,
    c5 double, c6 double unsigned,
    c7 decimal(10,2), c8 decimal(10,2) unsigned,
    c9 date, c10 timestamp,
    c11 varchar(20)
    );

insert into t1 values(1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.7, 8.8,
    Date '2012-12-01', Timestamp '2019-12-01 12:00:00.124',
    '11.2');

insert into t1 values(-1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.7, 8.8,
    '2019-12-01', '2017-12-11 11:00:00.124',
    '-11.5');

select ora_trunc(c1) from t1;
select ora_trunc(c2) from t1;
select ora_trunc(c3) from t1;
select ora_trunc(c4) from t1;
select ora_trunc(c5) from t1;
select ora_trunc(c6) from t1;
select ora_trunc(c7) from t1;
--error 1210
select ora_trunc(c8) from t1;
select ora_trunc(c9) from t1;
select ora_trunc(c10) from t1;
select ora_trunc(c11) from t1;

drop table t1;