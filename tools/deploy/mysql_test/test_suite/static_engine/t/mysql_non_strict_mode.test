--echo #分区表测试
--error 0,942,1051
drop table test_int;
create table test_int(c1 TINYINT not null, c2 SMALLINT not null, c3 MEDIUMINT not null, c4 INT not null, c5 BIGINT not null, c6 FLOAT not null, c7 DOUBLE not null, c8 decimal not null ) partition by hash(c1) partitions 4 ;
insert into test_int values (1,1,1,1,1,1,1,1);
set sql_mode = 'STRICT_ALL_TABLES';
--error 1048
insert into test_int values (null,null,null,null,null,null,null,null);
--error 1048
insert into test_int values (null,null,null,null,null,null,null,null),(null,null,null,null,null,null,null,null);
--error 1048
update test_int set c1=null, c2=null, c3=null, c4=null, c5=null, c6=null, c7=null, c8=null;
set sql_mode='';
--error 1048
insert into test_int values (null,null,null,null,null,null,null,null);
insert into test_int values (null,null,null,null,null,null,null,null),(null,null,null,null,null,null,null,null);
select c1,ascii(c1),c2,ascii(c2),c3,ascii(c3),c4,ascii(c4),c5,ascii(c5),c6,ascii(c6),c7,ascii(c7),c8,ascii(c8) from test_int;
update test_int set c1=null, c2=null, c3=null, c4=null, c5=null, c6=null, c7=null, c8=null where c1=1;
select c1,ascii(c1),c2,ascii(c2),c3,ascii(c3),c4,ascii(c4),c5,ascii(c5),c6,ascii(c6),c7,ascii(c7),c8,ascii(c8) from test_int;

--echo #pdml测试
--error 0,942,1051
drop table test_int;
create table test_int(c1 TINYINT not null, c2 SMALLINT not null, c3 MEDIUMINT not null, c4 INT not null, c5 BIGINT not null, c6 FLOAT not null, c7 DOUBLE not null, c8 decimal not null ) partition by hash(c1) partitions 4 ;
explain insert into test_int values (1,1,1,1,1,1,1,1);
explain insert /*parallel(2) enable_parallel_dml*/into test_int values (null,null,null,null,null,null,null,null);
insert into test_int values (1,1,1,1,1,1,1,1);
set sql_mode = 'STRICT_ALL_TABLES';
--error 1048
insert /*parallel(2) enable_parallel_dml*/into test_int values (null,null,null,null,null,null,null,null);
--error 1048
insert /*parallel(2) enable_parallel_dml*/ into test_int values (null,null,null,null,null,null,null,null),(null,null,null,null,null,null,null,null);
--error 1048
update /*parallel(2) enable_parallel_dml*/ test_int set c1=null, c2=null, c3=null, c4=null, c5=null, c6=null, c7=null, c8=null;
set sql_mode='';
--error 1048
insert /*parallel(2) enable_parallel_dml*/ into test_int values (null,null,null,null,null,null,null,null);
insert /*parallel(2) enable_parallel_dml*/ into test_int values (null,null,null,null,null,null,null,null),(null,null,null,null,null,null,null,null);
select c1,ascii(c1),c2,ascii(c2),c3,ascii(c3),c4,ascii(c4),c5,ascii(c5),c6,ascii(c6),c7,ascii(c7),c8,ascii(c8) from test_int;
update /*parallel(2) enable_parallel_dml*/test_int set c1=null, c2=null, c3=null, c4=null, c5=null, c6=null, c7=null, c8=null where c1=1;
select c1,ascii(c1),c2,ascii(c2),c3,ascii(c3),c4,ascii(c4),c5,ascii(c5),c6,ascii(c6),c7,ascii(c7),c8,ascii(c8) from test_int;
--error 0,942,1051
drop table t1;
CREATE TABLE t1 ( a VARCHAR(600), b VARCHAR(600), PRIMARY KEY (a), INDEX (b)) PARTITION BY KEY(a) PARTITIONS 3;
set sql_mode = '';
explain basic insert INTO t1  values (null,0),(null,1);
--error 1062
insert INTO t1  values (null,0),(null,1);
explain basic insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
--error 1062
insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);

set sql_mode = 'STRICT_ALL_TABLES';
explain basic insert INTO t1  values (null,0),(null,1);
--error 1048
insert INTO t1  values (null,0),(null,1);
explain basic insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
--error 1048
insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);

--echo #测试非严格insert兼容性
set sql_mode = '';
--error 0,942,1051
DROP TABLE t1;
--error 0,942,1051
DROP TABLE t2;
--error 0,942,1051
DROP TABLE t3;
--error 0,942,1051
DROP TABLE t4;
 
CREATE TABLE t1(c1 INT not null);
CREATE TABLE t2(c1 INT not null, c2 INT not null);
CREATE TABLE t3(c1 INT);
CREATE TABLE t4(c1 INT , c2 INT);
INSERT INTO t3 values (1),(2),(NULL),(3),(NULL);
INSERT INTO t4 values (1,NULL),(2,NULL),(NULL,NULL),(NULL,3),(NULL,NULL);

--error 1048
INSERT INTO t1 values(NULL);
INSERT INTO t1 values(NULL),(NULL);
--error 1048
INSERT INTO t1 values(NULL);
INSERT INTO t1 values(NULL),(NULL);
INSERT INTO t1 values (default);
INSERT INTO t1 select * from t3;
--error 1048
INSERT INTO t1 set c1=null;
--error 1048
INSERT INTO t2 values(NULL, NULL);
INSERT INTO t2 values(NULL, 1),(NULL, NULL);
INSERT INTO t2 values(default, default);
INSERT INTO T2 select * from t4;
--error 1048
INSERT INTO t2 set c1=null,c2=null;


--error 0,942,1051
drop table t1;
--error 0,942,1051
drop table t2;
create table t1(c1 int not null, c2 int);
create table t2(c1 int not null, c2 int);
set sql_mode = '';
--error 5868
update t1,t2 set t1.c2=t2.c2 order by t1.c2;

--error 0,942,1051
drop table t1;
CREATE TABLE t1 (
  c1 INT NOT NULL,
  cnt INT DEFAULT 1
);
set sql_mode='';
--error 1048
INSERT INTO t1 (c1,cnt) values (NULL,NULL) ON DUPLICATE KEY UPDATE c1=NULL;
INSERT INTO t1 (c1,cnt) values (NULL,NULL),(NULL,1) ON DUPLICATE KEY UPDATE c1=NULL;
INSERT INTO t1 (c1,cnt) SELECT NULL,NULL ON DUPLICATE KEY UPDATE c1=NULL;

--echo ============== 测试常见报错忽略 ===============

## test ERR_DATA_TOO_LONG
set sql_mode = 'STRICT_ALL_TABLES';
--error 0,942,1051
drop table test;
create table test(c1 varchar(5)); 
--error 1406
insert into test(c1) values('你你你你你你你');
set sql_mode = '';
insert into test(c1) values('你你你你你你你');
select * from test;

## test ERR_DIVISION_BY_ZERO
set sql_mode = 'STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO';
--error 0,942
drop table test;
create table test(c1 int); 
--error 1365
insert into test values (1/0);
set sql_mode = '';
insert into test values (1/0);

## test ERR_NO_DEFAULT_FOR_FIELD
set sql_mode = 'STRICT_ALL_TABLES';
--error 0,942,1051
drop table test;
create table test(c1 int not null); 
--error 1364
insert into test values (default);
set sql_mode = '';
insert into test values (default);

## ERR_TRUNCATED_WRONG_VALUE
set sql_mode = 'STRICT_ALL_TABLES';
--error 0,942,1051
drop table test;
create table test(c1 int); 
--error 1366
insert into test(c1) values('𐐀');
set sql_mode = '';
insert into test(c1) values('𐐀');
select * from test;

## ERR_WARN_DATA_OUT_OF_RANGE
set sql_mode = 'STRICT_ALL_TABLES';
--error 0,942,1051
drop table test;
create table test(c1 double); 
--error 1265
insert into test(c1) values('你你你你你你');
set sql_mode = '';
insert into test(c1) values('𐐀');
select * from test;

--echo ============== 测试duplicate冲突, 非严格模式不能忽略冲突报错 ===============
set sql_mode = '';
-- echo #单行操作
--error 0,942,1051
drop table test;
create table test(c1 int primary key, c2 int unique key, c3 int);
insert into test values(1,2,3);
#插入重复主键冲突
--error 1062
insert into test values(1,5,4);
#插入重复索引列冲突
--error 1062
insert into test values(1,2,4);
#更新后产生索引列冲突
insert into test values(2,3,4);
--error 1062
insert into test values(1,3,4) on duplicate key update c1 = 2;
#更新后产生主键冲突；
insert into test values(10,12,14);
insert into test values(11,14,15);
--error 1062
insert into test values(19,14,22) on duplicate key update c1 = c1 - 1;

-- echo #多行操作
delete from test;
insert into test values(100,101,102), (101, 102, 103), (102,103,105);
#表内数据主键冲突
--error 1062
insert into test values(103, 104, 105), (102, 105, 104);
#表内数据索引冲突
--error 1062
insert into test values(103, 104, 105), (104, 103, 105), (103,106, 107);


--echo #测试insert update重复键冲突报错

delete from test;
insert into test values(1, 2, 3), (2,3,4), (3,4,5);
--error 1062
insert into test values(3,5,5) on duplicate key update c2 = c2 - 1;
--error 1062 
insert into test values(4,5,6),(5,6,7),(3,0,0),(2,0,0) on duplicate key update c2 = c2 - 1;
--error 1062 
insert into test values(4,5,6),(5,6,7),(2,0,0),(1,0,0) on duplicate key update c1 = c1 + 1;
--error 1062 
insert into test values(4,5,6),(5,6,7), (6,7,3),(7,10, 0),(4,8,5), (5,9,0) on duplicate key update c1 = c1 + 1;
--error 1062 
insert into test values(4,5,6),(5,6,7), (6,7,3),(7,8, 0),(4,10,5), (5,9,0) on duplicate key update c2 = c2 + 1;
drop table test;

--echo non_strict_mode use multi part dml
drop table if exists t1;
CREATE TABLE t1 ( a VARCHAR(600), b VARCHAR(600), PRIMARY KEY (a), INDEX (b)) PARTITION BY KEY(a) PARTITIONS 3;
drop table if exists t2;
CREATE TABLE t2 ( a VARCHAR(600), b VARCHAR(600));
set sql_mode = '';
explain basic insert INTO t1  values (null,0),(null,1);
--error 1062
insert INTO t1  values (null,0),(null,1);
insert INTO t2  values (null,0),(null,1);
explain basic insert into t1 select * from t2;
explain basic insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
--error 1062
insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
 
set sql_mode = 'STRICT_ALL_TABLES';
explain basic insert INTO t1  values (null,0),(null,1);
--error 1048
insert INTO t1  values (null,0),(null,1);
explain basic insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
--error 1048
insert INTO t1  values (null,0),(null,1),(0,0),(0,1),(1,0),(1,1);
--error 1048
insert into t1 select * from t2;


--error 0,942,1051
drop table table30_key_pk_parts_16_int;
CREATE TABLE `table30_key_pk_parts_16_int` (
  `pk` int(11) NOT NULL,  PRIMARY KEY (`pk`)
) partition by key(pk)
(partition p0,
partition p1,
partition p2,
partition p3);
set sql_mode='';

insert into table30_key_pk_parts_16_int values (10);
UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ table30_key_pk_parts_16_int SET pk = NULL ;
explain basic UPDATE /*+ ENABLE_PARALLEL_DML PARALLEL(3) */ table30_key_pk_parts_16_int SET pk = NULL ;
