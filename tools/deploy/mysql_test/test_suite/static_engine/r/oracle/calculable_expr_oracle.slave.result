result_format: 4

alter system flush plan cache global;


drop table t;

create table t (pk int primary key, a int) partition by hash(pk) partitions 2;

insert into t values (1, 1), (2, 2), (3, 3), (4, 4);

>>>>>>>> Simple Case
select 1 + 1 from t;
+-----+
| 1+1 |
+-----+
|   2 |
|   2 |
|   2 |
|   2 |
+-----+
// hit plan ans pre calculated
select 1 + 1 from t;
+-----+
| 1+1 |
+-----+
|   2 |
|   2 |
|   2 |
|   2 |
+-----+
explain select 1 + 1 from t;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |4       |5           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|4       |5           |
|2 |  └─PX PARTITION ITERATOR|        |4       |5           |
|3 |    └─TABLE FULL SCAN    |T       |4       |5           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(1 + 1)]), filter(nil), rowset=16
  1 - output(nil), filter(nil), rowset=16
      dop=1
  2 - output(nil), filter(nil), rowset=16
      force partition granule
  3 - output(nil), filter(nil), rowset=16
      access(nil), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([T.PK]), range(MIN ; MAX)always true
select hit_count from sys.GV$OB_PLAN_CACHE_PLAN_STAT where to_char(statement) = 'select ? + ? from t';
