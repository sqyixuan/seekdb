set @@ob_enable_plan_cache = 0;
drop table t1;
drop table t2;
drop table t1_null;
drop table t2_null;
drop table t1_constraint;
drop table t2_constraint;
create table t1 (c1 int, c2 int, b3 int);
create table t2 (c1 int, c2 int, c3 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 1, 2);
insert into t1 values (3, 4, 3);
insert into t1 values (4, 6, 4);
insert into t1 values (5, 7, 5);
insert into t2 values (1, 1, 1);
insert into t2 values (3, 4, 4);
insert into t2 values (4, 2, 2);
insert into t2 values (6, 2, 2);
commit;
select * from t1;
C1	C2	B3
1	1	1
2	1	2
3	4	3
4	6	4
5	7	5
create table t1_null (c1 int, c2 int not null, b3 int);
create table t2_null (c1 int, c2 int, c3 int);
insert into t1_null values (1, 1, 1);
insert into t1_null values (2, 1, 2);
insert into t1_null values (3, 4, 3);
insert into t1_null values (4, 6, 4);
insert into t1_null values (5, 7, 5);
insert into t2_null values (1, 1, 1);
insert into t2_null values (3, 4, 4);
insert into t2_null values (4, 2, 2);
commit;
create table t1_constraint (c1 int , c2 int not null, b3 int,constraint uk31 unique(c2,b3));
create table t2_constraint (c1 int, c2 int, c3 int);
insert into t1_constraint values (1, 1, 1);
insert into t1_constraint values (2, 1, 2);
insert into t1_constraint values (3, 4, 3);
insert into t1_constraint values (4, 6, 4);
insert into t1_constraint values (5, 7, 5);
insert into t2_constraint values (1, 1, 1);
insert into t2_constraint values (3, 4, 4);
insert into t2_constraint values (4, 2, 2);
commit;
result_format: 4
explain_protocol: 1
set "autocommit"=0;
##old cg fail
##merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t1.c2 * 2 where t1.c2 < 5 delete where t1.c2 > 5 when not matched then insert values (t2.c1, t2.c2, t2.c3);
##normal
explain merge into t1 using t2 on (t1.c1 = t2.c1) when matched then update set t1.c2 = t1.c2 * 2 where t1.c1 < 5 delete where t1.b3 > 3 when not matched then insert values (t2.c1, t2.c2, t2.c3);
