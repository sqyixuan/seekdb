-------------------------------------
  0 - output(nil), filter(nil)
      columns([{T1: ({T1: (T1.__pk_increment, T1.C1, T1.C2, T1.B3)})}]), partitions(p0), 
      column_values([T_HIDDEN_PK], [column_conv(NUMBER,PS:(-1,0),NULL,T2.C1)], [column_conv(NUMBER,PS:(-1,0),NULL,T2.C2)], [column_conv(NUMBER,PS:(-1,0),
      NULL,T2.C3)]),
      update([T1.C2=column_conv(NUMBER,PS:(-1,0),NULL,T1.C2 * 2)]), 
      insert_conds(nil), update_conds([T1.C1 < 5]), delete_conds([T1.B3 > 3])
  1 - output([T1.__pk_increment], [T1.C1], [T1.C2], [T1.B3], [T2.C1], [T2.C2], [T2.C3]), filter(nil), rowset=16
      equal_conds([T1.C1 = T2.C1]), other_conds(nil)
  2 - output([T2.C1], [T2.C2], [T2.C3]), filter(nil), rowset=16
      access([T2.C1], [T2.C2], [T2.C3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T2.__pk_increment]), range(MIN ; MAX)always true
  3 - output([T1.__pk_increment], [T1.C1], [T1.C2], [T1.B3]), filter(nil), rowset=16
      access([T1.__pk_increment], [T1.C1], [T1.C2], [T1.B3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([T1.__pk_increment]), range(MIN ; MAX)always true
