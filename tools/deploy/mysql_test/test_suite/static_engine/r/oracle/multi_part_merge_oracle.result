      column_values([column_conv(NUMBER,PS:(-1,0),NOT NULL,T2.C1)], [column_conv(NUMBER,PS:(-1,0),NOT NULL,T2.C2)], [column_conv(NUMBER,PS:(-1,0),NULL,T2.C3)]),
      
      update([T1.C2=column_conv(NUMBER,PS:(-1,0),NOT NULL,T1.C2 * 2)]), 
