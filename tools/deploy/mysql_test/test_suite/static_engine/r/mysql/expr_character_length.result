result_format: 4
alter system flush plan cache global;

set ob_enable_plan_cache = 0;
select char_length(1234),character_length(1234);
+-------------------+------------------------+
| char_length(1234) | character_length(1234) |
+-------------------+------------------------+
|                 4 |                      4 |
+-------------------+------------------------+
select char_length(1),character_length(1);
+----------------+---------------------+
| char_length(1) | character_length(1) |
+----------------+---------------------+
|              1 |                   1 |
+----------------+---------------------+
select char_length(null),character_length(null);
+-------------------+------------------------+
| char_length(null) | character_length(null) |
+-------------------+------------------------+
|              NULL |                   NULL |
+-------------------+------------------------+
select char_length(''),character_length('');
+-----------------+----------------------+
| char_length('') | character_length('') |
+-----------------+----------------------+
|               0 |                    0 |
+-----------------+----------------------+
select char_length('a'),character_length('a');
+------------------+-----------------------+
| char_length('a') | character_length('a') |
+------------------+-----------------------+
|                1 |                     1 |
+------------------+-----------------------+
select char_length(' a '),character_length(' a ');
+--------------------+-------------------------+
| char_length(' a ') | character_length(' a ') |
+--------------------+-------------------------+
|                  3 |                       3 |
+--------------------+-------------------------+
select char_length(' a b'),character_length(' a b');
+---------------------+--------------------------+
| char_length(' a b') | character_length(' a b') |
+---------------------+--------------------------+
|                   4 |                        4 |
+---------------------+--------------------------+

drop table if exists t1;
create table t1 (c1 int, c2 char(10), c3 varchar(10), c4 timestamp, c5 decimal);
insert into t1 values(1, 'a ', 'a ', '2010-01-01 11:11:11', 10.1);
Warnings:
Warning	1265	Data truncated for column 'c5' at row 1
select char_length(c1),character_length(c1) from t1;
+-----------------+----------------------+
| char_length(c1) | character_length(c1) |
+-----------------+----------------------+
|               1 |                    1 |
+-----------------+----------------------+
select char_length(c2),character_length(c1) from t1;
+-----------------+----------------------+
| char_length(c2) | character_length(c1) |
+-----------------+----------------------+
|               1 |                    1 |
+-----------------+----------------------+
select char_length(c3),character_length(c2) from t1;
+-----------------+----------------------+
| char_length(c3) | character_length(c2) |
+-----------------+----------------------+
|               2 |                    1 |
+-----------------+----------------------+
select char_length(c4),character_length(c4) from t1;
+-----------------+----------------------+
| char_length(c4) | character_length(c4) |
+-----------------+----------------------+
|              19 |                   19 |
+-----------------+----------------------+
select char_length(c5),character_length(c5) from t1;
+-----------------+----------------------+
| char_length(c5) | character_length(c5) |
+-----------------+----------------------+
|               2 |                    2 |
+-----------------+----------------------+


