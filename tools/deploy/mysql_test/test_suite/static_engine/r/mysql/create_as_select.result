result_format: 4
explain_protocol: 0
alter system flush plan cache global;
set ob_enable_plan_cache = 0;

drop table if exists t0, t1;
drop view if exists v1;
create table t0 (c1 int, c2 varchar(10), c3 char(10));
insert into t0 values(1, 'ab', '12');

// got implicit cast in c1+c3
create view v1 as select c1 from t0 where c1+c3 = 13;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `test`.`t0`.`c1` AS `c1` from `test`.`t0` where ((`test`.`t0`.`c1` + `test`.`t0`.`c3`) = 13)	utf8mb4	utf8mb4_general_ci
select * from v1;
+------+
| c1   |
+------+
|    1 |
+------+
drop view v1;

// got implicit cast recursively
create view v1 as select substr(c1, substr(c1, substr(c1, 1))) from t0 where c1+c3 = 13;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select substr(`test`.`t0`.`c1`,substr(`test`.`t0`.`c1`,substr(`test`.`t0`.`c1`,1))) AS `substr(c1, substr(c1, substr(c1, 1)))` from `test`.`t0` where ((`test`.`t0`.`c1` + `test`.`t0`.`c3`) = 13)	utf8mb4	utf8mb4_general_ci
select * from v1;
+---------------------------------------+
| substr(c1, substr(c1, substr(c1, 1))) |
+---------------------------------------+
| 1                                     |
+---------------------------------------+
drop view v1;

// got bool expr in where clause
create view v1 as select c1 from t0 where c1;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `test`.`t0`.`c1` AS `c1` from `test`.`t0` where `test`.`t0`.`c1`	utf8mb4	utf8mb4_general_ci
select * from v1;
+------+
| c1   |
+------+
|    1 |
+------+
drop view v1;

// same test, but create table
// got implicit cast in c1+c3
create table t1 as select c1 from t0 where c1+c3 = 13;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
select * from t1;
+------+
| c1   |
+------+
|    1 |
+------+
drop table t1;

// got implicit cast recursively
create table t1 as select substr(c1, substr(c1, substr(c1, 1))) from t0 where c1+c3 = 13;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `substr(c1, substr(c1, substr(c1, 1)))` varchar(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
select * from t1;
+---------------------------------------+
| substr(c1, substr(c1, substr(c1, 1))) |
+---------------------------------------+
| 1                                     |
+---------------------------------------+
drop table t1;

// got bool expr in where clause
create table t1 as select c1 from t0 where c1;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
