SELECT table1 . col_bigint,
       table1 . col_char_20
FROM table0_bigint AS table1
INNER JOIN table100_hash_pk_parts_1_bigint AS table2 USING (pk)
WHERE table1 . pk < 189
  AND table1 . pk >=
    (SELECT coalesce(
                       (SELECT *
                        FROM
                          (SELECT SUM(LENGTH(SUBSTR('j', 1, 20)))
                           FROM table0_bigint
                           WHERE TRIM(SUBSTR(SUBSTR(HEX(SUBSTR('y', 1, 20)), 1, 20), 1, 20)) <=> COALESCE(col_char_20_index, col_char_20, col_char_20_index)
                           ORDER BY col_bigint, col_bigint_index, col_char_20, col_char_20_index, col_decimal_20_0, col_decimal_20_0_index, col_timestamp_6, col_timestamp_6_index, pk , pk DESC) TC1),
                       (SELECT *
                        FROM
                          (SELECT MAX(col_decimal_20_0)
                           FROM table100_key_pk_parts_1_bigint
                           WHERE col_timestamp_6_index <=> (COALESCE('2015-06-19 10:00:00.000001', CONCAT(CAST(2015 + 3 + 3 AS CHAR(20)), '-06-19 01:00:00.000003'), '2015-06-15 10:00:00.000001'))
                           ORDER BY col_char_5_index , pk) TC2), -12276))
ORDER BY table1 . pk ASC,
         table1 . col_bigint ,
         table1 . col_char_20_index DESC,
         table2 . pk DESC,
         table2 . col_bigint ASC,
         table2 . col_char_20_index DESC,
         table1 . pk
LIMIT 6;
