result_format: 4

drop table if exists t1;
alter system flush plan cache global;
SELECT NAME_CONST(123, 'abc');
+-----+
| 123 |
+-----+
| abc |
+-----+
SELECT NAME_CONST(123, 1234567890123456789012345678901234567890123456789012345678901234567890);
+------------------------------------------------------------------------+
| 123                                                                    |
+------------------------------------------------------------------------+
| 1234567890123456789012345678901234567890123456789012345678901234567890 |
+------------------------------------------------------------------------+
SELECT NAME_CONST(123, 1.23456);
+---------+
| 123     |
+---------+
| 1.23456 |
+---------+
SELECT NAME_CONST(123, -1.23456);
+----------+
| 123      |
+----------+
| -1.23456 |
+----------+
SELECT NAME_CONST(123, 123);
+------+
| 123  |
+------+
|  123 |
+------+
SELECT NAME_CONST(123, -123);
+------+
| 123  |
+------+
| -123 |
+------+
SELECT NAME_CONST(123, NULL);
+------+
| 123  |
+------+
| NULL |
+------+
SELECT NAME_CONST(123, a);
ERROR HY000: Incorrect arguments to name_const

SELECT NAME_CONST('abc', 'abc');
+-----+
| abc |
+-----+
| abc |
+-----+
SELECT NAME_CONST(1234567890123456789012345678901234567890123456789012345678901234567890, 'abc');
+------------------------------------------------------------------------+
| 1234567890123456789012345678901234567890123456789012345678901234567890 |
+------------------------------------------------------------------------+
| abc                                                                    |
+------------------------------------------------------------------------+
SELECT NAME_CONST(1.23456, 'abc');
+---------+
| 1.23456 |
+---------+
| abc     |
+---------+
SELECT NAME_CONST(123, 'abc');
+-----+
| 123 |
+-----+
| abc |
+-----+
SELECT NAME_CONST(-1.23456, 'abc');
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(-123, 'abc');
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(NULL, 123);
ERROR HY000: The 'name_const' syntax is reserved for purposes internal to the OceanBase Server
SELECT NAME_CONST(a, 123);
ERROR HY000: Incorrect arguments to name_const

SELECT NAME_CONST(TIME'1', 1);
+----------+
| 00:00:01 |
+----------+
|        1 |
+----------+
SELECT NAME_CONST(DATE'2001-1-1', 1);
+------------+
| 2001-01-01 |
+------------+
|          1 |
+------------+
SELECT NAME_CONST(TIMESTAMP'2001-1-1 1:1:1', 1);
+---------------------+
| 2001-01-01 01:01:01 |
+---------------------+
|                   1 |
+---------------------+
SELECT NAME_CONST('abc', TIME'1');
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST('abc', DATE'2001-1-1');
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST('abc', TIMESTAMP'2001-1-1 1:1:1');
ERROR HY000: Incorrect arguments to name_const

SELECT NAME_CONST('s1', _utf8'test' COLLATE utf8_unicode_ci);
+------+
| s1   |
+------+
| test |
+------+
SELECT NAME_CONST(_utf8'test' COLLATE utf8_unicode_ci, 's1');
ERROR HY000: Incorrect arguments to name_const

SELECT COLLATION(NAME_CONST('s1', _utf8'test' COLLATE utf8_unicode_ci));
+------------------------------------------------------------------+
| COLLATION(NAME_CONST('s1', _utf8'test' COLLATE utf8_unicode_ci)) |
+------------------------------------------------------------------+
| utf8mb4_unicode_ci                                               |
+------------------------------------------------------------------+
SELECT COLLATION(_utf8'test' COLLATE utf8_unicode_ci);
+------------------------------------------------+
| COLLATION(_utf8'test' COLLATE utf8_unicode_ci) |
+------------------------------------------------+
| utf8mb4_unicode_ci                             |
+------------------------------------------------+

SELECT TIME(NAME_CONST('a', 0));
+--------------------------+
| TIME(NAME_CONST('a', 0)) |
+--------------------------+
| 00:00:00                 |
+--------------------------+
SELECT DATE(NAME_CONST('a', 0));
+--------------------------+
| DATE(NAME_CONST('a', 0)) |
+--------------------------+
| 0000-00-00               |
+--------------------------+

SELECT NAME_CONST(1+1,1);
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(1,1+1);
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(1,NOW());
ERROR HY000: Incorrect arguments to name_const

create table t1(c1 int);
insert into t1 values(1), (2), (3);
SELECT NAME_CONST('test',2), c1 from t1;
+------+------+
| test | c1   |
+------+------+
|    2 |    1 |
|    2 |    2 |
|    2 |    3 |
+------+------+
SELECT NAME_CONST('test',2) * max(c1) from t1;
+--------------------------------+
| NAME_CONST('test',2) * max(c1) |
+--------------------------------+
|                              6 |
+--------------------------------+
insert into t1 values(name_const('abc',10));
select * from t1;
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
|   10 |
+------+
SELECT c1 from t1 HAVING NAME_CONST('', 1);
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
|   10 |
+------+
SELECT NAME_CONST(c1, 1) from t1;
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(1, c1) from t1;
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(1, c1+1) from t1;
ERROR HY000: Incorrect arguments to name_const
SELECT NAME_CONST(x,2) FROM (SELECT c1 x FROM t1) t;
ERROR HY000: Incorrect arguments to name_const
SELECT c1 from t1 HAVING NAME_CONST('', c1);
ERROR HY000: Incorrect arguments to name_const

drop table t1;

create table t1 as SELECT NAME_CONST(123, 'abc');
desc t1;
+-------+------------+------+-----+---------+-------+
| Field | Type       | Null | Key | Default | Extra |
+-------+------------+------+-----+---------+-------+
| 123   | varchar(3) | YES  |     | NULL    |       |
+-------+------------+------+-----+---------+-------+
drop table t1;

create table t1 as SELECT NAME_CONST('abc', _utf8'test' COLLATE utf8_unicode_ci);
desc t1;
+-------+------------+------+-----+---------+-------+
| Field | Type       | Null | Key | Default | Extra |
+-------+------------+------+-----+---------+-------+
| abc   | varchar(4) | YES  |     | NULL    |       |
+-------+------------+------+-----+---------+-------+
drop table t1;

create table t1 as (SELECT _utf8'test' COLLATE utf8_unicode_ci as 'abc');
desc t1;
+-------+------------+------+-----+---------+-------+
| Field | Type       | Null | Key | Default | Extra |
+-------+------------+------+-----+---------+-------+
| abc   | varchar(4) | YES  |     | NULL    |       |
+-------+------------+------+-----+---------+-------+
drop table t1;

##with bool
select name_const(true,true);
+------+
| 1    |
+------+
|    1 |
+------+
select name_const(false,false);
+------+
| 0    |
+------+
|    0 |
+------+

##with number
select name_const(0,1);
+------+
| 0    |
+------+
|    1 |
+------+
select name_const(-0,1);
ERROR HY000: Incorrect arguments to name_const

##with timestamp
select name_const(timestamp '2022-9-15 00:00:00.000000','新的一天');
+----------------------------+
| 2022-09-15 00:00:00.000000 |
+----------------------------+
| 新的一天                   |
+----------------------------+
select name_const(timestamp '2022-09-15 00:00:00.00000','新的一天');
+---------------------------+
| 2022-09-15 00:00:00.00000 |
+---------------------------+
| 新的一天                  |
+---------------------------+
select name_const(timestamp '2022-9-15 00:00:00.000000000','新的一天');
+----------------------------+
| 2022-09-15 00:00:00.000000 |
+----------------------------+
| 新的一天                   |
+----------------------------+
select name_const(timestamp '2022-09-15 00:00:00.00','新的一天');
+------------------------+
| 2022-09-15 00:00:00.00 |
+------------------------+
| 新的一天               |
+------------------------+
##with escape character
select name_const('\n\n\n','1');
+---+
|   |
+---+
| 1 |
+---+
select name_const('\t','1');
+---+
|   |
+---+
| 1 |
+---+
select name_const('\r',1);
+------+
|      |
+------+
|    1 |
+------+

##with scientific format
select name_const(1.234E8,'科学计数');
+--------------+
| 123400000    |
+--------------+
| 科学计数     |
+--------------+
select name_const(1.234E+8,'科学计数');
+--------------+
| 123400000    |
+--------------+
| 科学计数     |
+--------------+
select name_const('科学计数',1.234E8);
+--------------+
| 科学计数     |
+--------------+
|    123400000 |
+--------------+

##with procedure
drop procedure if exists p1;
create procedure p1(aa int) select name_const(aa,1);
call p1(21);
ERROR HY000: Incorrect arguments to name_const
drop procedure p1;
create procedure p1(aa int) select name_const(1,aa);
call p1(21);
+------------------+
| name_const(1,aa) |
+------------------+
|               21 |
+------------------+
drop procedure p1;
