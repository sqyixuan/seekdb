explain_protocol: 0
drop table if exists t1;
create table t1(col_1 datetime, col_2 date, col_3 timestamp, col_4 year, col_5 time);
set time_zone='-2:00';
insert into t1 values("2021-01-01 12:34:56","2021-01-01","2021-01-01 12:34:56",2021,"12:34:56");

