result_format: 4

explain_protocol: 0
drop table if exists t1;
set timestamp = 1600000000;
create table t1 (col_pos_int int,
                 col_neg_int int,
                 col_zero_int int,
                 col_pos_varchar varchar(10),
                 col_neg_varchar varchar(10),
                 col_zero_varchar varchar(10));
insert into t1 values(1, -1, 0, '01', '-02', '00');
select * from t1;
+-------------+-------------+--------------+-----------------+-----------------+------------------+
| col_pos_int | col_neg_int | col_zero_int | col_pos_varchar | col_neg_varchar | col_zero_varchar |
+-------------+-------------+--------------+-----------------+-----------------+------------------+
|           1 |          -1 |            0 | 01              | -02             | 00               |
+-------------+-------------+--------------+-----------------+-----------------+------------------+

// Case1: normal test
alter system flush plan cache global;
explain_protocol: 2
set @@ob_enable_plan_cache = 0;
