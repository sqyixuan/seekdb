| is_uuid('12345678123456781234567812345678') |
+---------------------------------------------+
|                                           1 |
+---------------------------------------------+
SELECT is_uuid('12345678-1234-5678-1234-567812345678');
+-------------------------------------------------+
| is_uuid('12345678-1234-5678-1234-567812345678') |
+-------------------------------------------------+
|                                               1 |
+-------------------------------------------------+

