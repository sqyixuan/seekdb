+------------------------------------------------------------------+-----------------------------------------------------------------------------------------------------------+
| bin_to_uuid(uuid_to_bin('12345678-1234-5678-1234-567812345678')) | bin_to_uuid(uuid_to_bin('12345678-1234-5678-1234-567812345678')) = '12345678-1234-5678-1234-567812345678' |
