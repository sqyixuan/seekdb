result_format: 4
set ob_enable_plan_cache = 0;

drop table if exists t1;
create table t1 (c1 char(10) primary key, c2 int);
insert into t1 values('a', 1);

set @ori_sql_mode = @@sql_mode;
set @@sql_mode = concat(@ori_sql_mode, ',PAD_CHAR_TO_FULL_LENGTH');
// column conv -> cast -> padding -> cast -> c2;
explain update t1 set c1 = c2;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |UPDATE           |    |1       |34          |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.c1, t1.c2)})}]),
      update([t1.c1=column_conv(CHAR,utf8mb4_general_ci,length:10,NOT NULL,cast(pad(cast(t1.c2, VARCHAR(1048576)), ' ', 10), CHAR(1048576)))])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
update t1 set c1 = c2;
select * from t1;
+------------+------+
| c1         | c2   |
+------------+------+
| 1          |    1 |
+------------+------+

set @@sql_mode = @ori_sql_mode;
// test values() func
delete from t1;
insert into t1 values('a', 1);
explain insert into t1 values('a', 2) on duplicate key update c1 = values(c2)+1;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |DISTRIBUTED INSERT_UP|    |1       |13          |
|1 |└─EXPRESSION         |    |1       |1           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.c1, t1.c2)})}]), 
      column_values([column_conv(CHAR,utf8mb4_general_ci,length:10,NOT NULL,__values.c1)], [column_conv(INT,PS:(11,0),NULL,__values.c2)]),
      update([t1.c1=column_conv(CHAR,utf8mb4_general_ci,length:10,NOT NULL,cast(inner_trim(2, cast(' ', VARCHAR(1048576)), cast(values(column_conv(INT,PS:(11,
      0),NULL,__values.c2)) + 1, VARCHAR(1048576))), CHAR(1048576)))])
  1 - output([__values.c1], [__values.c2]), filter(nil)
      values({'a', 2})
insert into t1 values('a', 2) on duplicate key update c1 = values(c2)+1;
select * from t1;
+----+------+
| c1 | c2   |
+----+------+
| 3  |    1 |
+----+------+
select length(c1) from t1;
+------------+
| length(c1) |
+------------+
|          1 |
+------------+

