drop table if exists t1;
result_format: 4
explain_protocol: 0
create table t1 (c1 int, c2 int unsigned,
    c3 float, c4 float unsigned,
    c5 double, c6 double unsigned,
    c7 decimal(10,2), c8 decimal(10,2) unsigned,
    c9 date, c10 timestamp,
    c11 varchar(20)
    );

insert into t1 values(1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.7, 8.8,
    Date '2012-12-01', Timestamp '2019-12-01 12:00:00.124',
    '11.2');

insert into t1 values(-1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.7, 8.8,
    '2019-12-01', '2017-12-11 11:00:00.124',
    '-11.5');

