result_format: 4
set @@ob_enable_plan_cache = 0;

drop table if exists t_basic, t_rowkey, t_null;
create table t_basic (c1 int);
insert into t_basic values(1);
insert into t_basic values(2);

create table t_rowkey (c1 int, c2 int, key(c1, c2));
insert into t_rowkey values(1, 2);
insert into t_rowkey values(1, 2);
insert into t_rowkey values(2, 2);
insert into t_rowkey values(2, 2);
insert into t_rowkey values(3, 3);
insert into t_rowkey values(4, 4);

create table t_null(c1 int, c2 int, primary key(c1));
insert into t_null values(1, null);
insert into t_null values(2, null);
insert into t_null values(3, 3);
insert into t_null values(4, 4);

// basic test
select * from t_basic;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+
delete from t_basic where c1 = 1;
select * from t_basic;
+------+
| c1   |
+------+
|    2 |
+------+
delete from t_basic;
select * from t_basic;
+------+
| c1   |
+------+
+------+

// test with dup rowkey
select * from t_rowkey;
+------+------+
| c1   | c2   |
+------+------+
|    1 |    2 |
|    1 |    2 |
|    2 |    2 |
|    2 |    2 |
|    3 |    3 |
|    4 |    4 |
+------+------+
delete from t_rowkey where c1 = 1;
select * from t_rowkey;
+------+------+
| c1   | c2   |
+------+------+
|    2 |    2 |
|    2 |    2 |
|    3 |    3 |
|    4 |    4 |
+------+------+
delete from t_rowkey where c1 = 2 and c2 = 2;
select * from t_rowkey;
+------+------+
| c1   | c2   |
+------+------+
|    3 |    3 |
|    4 |    4 |
+------+------+

// test with null value
select * from t_null;
+----+------+
| c1 | c2   |
+----+------+
|  1 | NULL |
|  2 | NULL |
|  3 |    3 |
|  4 |    4 |
+----+------+
delete from t_null where c2 is not null;
select * from t_null;
+----+------+
| c1 | c2   |
+----+------+
|  1 | NULL |
|  2 | NULL |
+----+------+
delete from t_null where c2 is null;
select * from t_null;
+----+------+
| c1 | c2   |
+----+------+
+----+------+

