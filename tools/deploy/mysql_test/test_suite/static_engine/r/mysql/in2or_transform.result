### Case 3
drop table if exists t1;


create table t1 (a int, b varchar(100) collate utf8mb4_general_ci,
                 c varchar(100) collate utf8mb4_bin,
                 d varchar(100) collate gbk_chinese_ci);
insert into t1 values (1, "hello", "test", "你好test");
insert into t1 values (2, "test", "test", "你好test");
insert into t1 values (3, "你好test", "test", "你好test");


select b in (c, d) from t1;
+-------------+
| b in (c, d) |
+-------------+
|           0 |
|           1 |
|           1 |
+-------------+
explain select b in (c, d) from t1;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |3       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([cast(t1.b, VARCHAR(1048576)) = t1.c OR t1.b = cast(t1.d, VARCHAR(1048576))]), filter(nil), rowset=16
      access([t1.b], [t1.c], [t1.d]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true

