       MYSQL_DATETIME(-1, -1)) >= cast('2007-11-14', MYSQL_DATETIME(-1, -1)) AND cast(GRANDPARENT1.col_date_key, MYSQL_DATETIME(-1, -1)) <= cast('2000-11-16',
       MYSQL_DATETIME(-1, -1)), GRANDPARENT1.col_int = 4)], [VIEW2.CHILD1.col_varchar_20_key != VIEW2.CHILD1.col_varchar_20 OR VIEW2.CHILD1.col_date_key > VIEW2.PARENT1.col_date 
      AND cast(GRANDPARENT1.col_date, MYSQL_DATETIME(-1, -1)) = cast('2006-03-14', MYSQL_DATETIME(-1, -1))])
