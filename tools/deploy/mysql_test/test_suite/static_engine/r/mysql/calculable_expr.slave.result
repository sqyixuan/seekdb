>>>>>>>> // Pre Calc Expr generated by Cost rewrite
create table t (pk int primary key, c1 int, c2 int);
create index idx_c1 on t(c1) local;
create index idx_c2 on t(c2) local;

insert into t values (1001, 1001, 1);
insert into t values (1002, 1, 1001);

select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 1) + (select 999 from dual);
+------+------+------+
| pk   | c1   | c2   |
+------+------+------+
| 1001 | 1001 |    1 |
| 1002 |    1 | 1001 |
+------+------+------+
select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 0) + (select 1000 from dual);
+------+------+------+
| pk   | c1   | c2   |
+------+------+------+
| 1001 | 1001 |    1 |
| 1002 |    1 | 1001 |
+------+------+------+
explain select /*+use_concat*/* from t where c1 = (select 1001 from dual) or c2 = (1 + 0) + (select 1000 from dual);
Query Plan
===========================================================
|ID|OPERATOR              |NAME     |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------
|0 |EXCHANGE IN REMOTE    |         |2       |17          |
|1 |└─EXCHANGE OUT REMOTE |         |2       |16          |
|2 |  └─UNION ALL         |         |2       |14          |
|3 |    ├─TABLE RANGE SCAN|t(idx_c1)|1       |7           |
|4 |    └─TABLE RANGE SCAN|t(idx_c2)|1       |7           |
===========================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])], [UNION([2])], [UNION([3])]), filter(nil)
  1 - output([UNION([1])], [UNION([2])], [UNION([3])]), filter(nil)
  2 - output([UNION([1])], [UNION([2])], [UNION([3])]), filter(nil), rowset=16
  3 - output([t.pk], [t.c1], [t.c2]), filter(nil), rowset=16
      access([t.pk], [t.c1], [t.c2]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t.c1], [t.pk]), range(1001,MIN ; 1001,MAX), 
      range_cond([t.c1 = 1001])
  4 - output([t.pk], [t.c1], [t.c2]), filter([lnnvl(cast(t.c1 = 1001, TINYINT(-1, 0)))]), rowset=16
      access([t.pk], [t.c1], [t.c2]), partitions(p0)
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t.c2], [t.pk]), range(1001,MIN ; 1001,MAX), 
      range_cond([t.c2 = 1 + 0 + 1000])

