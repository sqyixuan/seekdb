drop table t1;

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;

create table t1 (a varchar(16), k varchar(16),
                                b char(32) as (substr(a, 1)) virtual,
                                c int as (a / 2) virtual,
                                d int as (a * 2) virtual,
                                e int as (a + 2) virtual,
                                f int as (a - 2) virtual,
                                g char(64) as (concat(a, k)) virtual);


