result_format: 4
alter system flush plan cache global;

drop table if exists t1, t2;
create table t1(c1 int primary key) partition by hash(c1) partitions 3;
create table t2(c1 int primary key);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(6);
explain select /*+ parallel(2) pq_distribute(t1 partition none) */ * from t1, t2 where t1.c1= t2.c1;
Query Plan
=====================================================================
|ID|OPERATOR                         |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |PX COORDINATOR                   |        |3       |8           |
|1 |└─EXCHANGE OUT DISTR             |:EX10001|3       |7           |
|2 |  └─HASH JOIN                    |        |3       |6           |
|3 |    ├─PX PARTITION ITERATOR      |        |3       |4           |
|4 |    │ └─TABLE FULL SCAN          |t1      |3       |4           |
|5 |    └─EXCHANGE IN DISTR          |        |3       |2           |
|6 |      └─EXCHANGE OUT DISTR (PKEY)|:EX10000|3       |2           |
|7 |        └─PX BLOCK ITERATOR      |        |3       |2           |
|8 |          └─TABLE FULL SCAN      |t2      |3       |2           |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t2.c1)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t2.c1)]), filter(nil), rowset=16
      dop=2
  2 - output([t1.c1], [t2.c1]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
  3 - output([t1.c1]), filter(nil), rowset=16
      affinitize
  4 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true
  5 - output([t2.c1]), filter(nil), rowset=16
  6 - output([t2.c1]), filter(nil), rowset=16
      (#keys=1, [t2.c1]), dop=2
  7 - output([t2.c1]), filter(nil), rowset=16
  8 - output([t2.c1]), filter(nil), rowset=16
      access([t2.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1]), range(MIN ; MAX)always true
select /*+ parallel(2) pq_distribute(t1 partition none) */ * from t1, t2 where t1.c1= t2.c1;
