drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
insert into t1 (c1, c2, c3) values (1, 0, 1);
insert into t1 (c1, c2, c3) values (2, 2, 2);
insert into t2 (c1, c2, c3) values (1, 1, 1);
select * from t1 where t1.c2 > (select lnnvl(sum(c2)/count(c2)) from t2 where t2.c1 = t1.c1);
c1	c2	c3
2	2	2
select * from t1 where t1.c2 > (select 0.5 * min(c2) from t2 where t2.c1 = t1.c1);
c1	c2	c3
