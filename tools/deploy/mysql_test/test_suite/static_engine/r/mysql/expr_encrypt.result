#test encrypt()
select length(encrypt('test'));
+-------------------------+
| length(encrypt('test')) |
+-------------------------+
|                      13 |
+-------------------------+
select encrypt('test','aa');
+----------------------+
| encrypt('test','aa') |
+----------------------+
| aaqPiZY5xR5l.        |
+----------------------+
select encrypt('test','a a');
+-----------------------+
| encrypt('test','a a') |
+-----------------------+
| NULL                  |
+-----------------------+
select length(encrypt(''));
+---------------------+
| length(encrypt('')) |
+---------------------+
|                   0 |
+---------------------+
select encrypt('','aa');
+------------------+
| encrypt('','aa') |
+------------------+
|                  |
+------------------+
select encrypt('test','a\a');
+-----------------------+
| encrypt('test','a\a') |
+-----------------------+
| aaqPiZY5xR5l.         |
+-----------------------+
select encrypt('test','a/');
+----------------------+
| encrypt('test','a/') |
+----------------------+
| a/Y0IQTEWVqHY        |
+----------------------+
select encrypt('test','a.');
+----------------------+
| encrypt('test','a.') |
+----------------------+
| a.JudaJzXH8D2        |
+----------------------+
select encrypt('test','123');
+-----------------------+
| encrypt('test','123') |
+-----------------------+
| 126D8rSh5sjUE         |
+-----------------------+
select encrypt('test','a');
+---------------------+
| encrypt('test','a') |
+---------------------+
| NULL                |
+---------------------+
select encrypt('test','a\n');
+-----------------------+
| encrypt('test','a\n') |
+-----------------------+
| NULL                  |
+-----------------------+
select encrypt('1234','_.');
+----------------------+
| encrypt('1234','_.') |
+----------------------+
| NULL                 |
+----------------------+

select encrypt(NULL,'aa');
+--------------------+
| encrypt(NULL,'aa') |
+--------------------+
| NULL               |
+--------------------+
select encrypt('aa',NULL);
+--------------------+
| encrypt('aa',NULL) |
+--------------------+
| NULL               |
+--------------------+

create table test as select encrypt('test','aa');
desc test;
+----------------------+---------------+------+-----+---------+-------+
| Field                | Type          | Null | Key | Default | Extra |
+----------------------+---------------+------+-----+---------+-------+
| encrypt('test','aa') | varbinary(13) | YES  |     | NULL    |       |
+----------------------+---------------+------+-----+---------+-------+
drop table test;

create table t1 (c1 varchar(20), c2 int, c3 varchar(20));
insert into t1 values('test',111,'aaa'),('tAst',222,'bbb'),('ABC',333,'ccc');
select c1,c2,encrypt(c1,c2) from t1;
+------+------+----------------+
| c1   | c2   | encrypt(c1,c2) |
+------+------+----------------+
| test |  111 | 11qUL4NWjGdI2  |
| tAst |  222 | 22GoE17uIrBW.  |
| ABC  |  333 | 33VzMAMJs8.rk  |
+------+------+----------------+
select c1,c3,encrypt(c1,c3) from t1;
+------+------+----------------+
| c1   | c3   | encrypt(c1,c3) |
+------+------+----------------+
| test | aaa  | aaqPiZY5xR5l.  |
| tAst | bbb  | bbG2fdo47mNIA  |
| ABC  | ccc  | cc3MB/cQR7eaY  |
+------+------+----------------+
select encrypt('test',c2) from t1;
+--------------------+
| encrypt('test',c2) |
+--------------------+
| 11qUL4NWjGdI2      |
| 22g0LE.ThdPFo      |
| 331fAiIWHS9aM      |
+--------------------+
select encrypt(c1,'aaa') from t1;
+-------------------+
| encrypt(c1,'aaa') |
+-------------------+
| aaqPiZY5xR5l.     |
| aaV0zk4ntChzo     |
| aaiobidSpC6hQ     |
+-------------------+
drop table t1;

select encrypt();
