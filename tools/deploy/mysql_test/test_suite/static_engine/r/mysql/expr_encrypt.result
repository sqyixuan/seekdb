#test decode() & encode()
select hex(encode('test', 'akeystr'));
+--------------------------------+
| hex(encode('test', 'akeystr')) |
+--------------------------------+
| D214346F                       |
+--------------------------------+
select hex(encode('test', ''));
+-------------------------+
| hex(encode('test', '')) |
+-------------------------+
| 9306D8E1                |
+-------------------------+
select encode('', 'key');
+-------------------+
| encode('', 'key') |
+-------------------+
|                   |
+-------------------+
select encode('test', NULL);
+----------------------+
| encode('test', NULL) |
+----------------------+
| NULL                 |
+----------------------+
select encode(NULL, 'test');
+----------------------+
| encode(NULL, 'test') |
+----------------------+
| NULL                 |
+----------------------+
select hex(decode('test',''));
+------------------------+
| hex(decode('test','')) |
+------------------------+
| BB70C91B               |
+------------------------+
select decode('','key');
+------------------+
| decode('','key') |
+------------------+
|                  |
+------------------+

create table test as select encode('testtest','password');
desc test;
+-------------------------------+---------------+------+-----+---------+-------+
| Field                         | Type          | Null | Key | Default | Extra |
+-------------------------------+---------------+------+-----+---------+-------+
| encode('testtest','password') | varbinary(32) | YES  |     | NULL    |       |
+-------------------------------+---------------+------+-----+---------+-------+
drop table test;
create table test as select decode(encode('testtest','password'),'password');
desc test;
