// Case5: big integer test
drop table if exists t1;
create table t1(c1 bigint unsigned, c2 bigint);
insert into t1 values(18446744073709551615, 9223372036854775807);
select c1, round(c1, -19), c2, round(c2, -18) from t1;
+----------------------+---------------------+---------------------+---------------------+
| c1                   | round(c1, -19)      | c2                  | round(c2, -18)      |
+----------------------+---------------------+---------------------+---------------------+
| 18446744073709551615 | 1553255926290448384 | 9223372036854775807 | 9000000000000000000 |
+----------------------+---------------------+---------------------+---------------------+
select c1, round(c1, -20), c2, round(c2, -19) from t1;
+----------------------+----------------+---------------------+----------------------+
| c1                   | round(c1, -20) | c2                  | round(c2, -19)       |
+----------------------+----------------+---------------------+----------------------+
| 18446744073709551615 |              0 | 9223372036854775807 | -8446744073709551616 |
+----------------------+----------------+---------------------+----------------------+
select c1, round(c1, -21), c2, round(c2, -20) from t1;
+----------------------+----------------+---------------------+----------------+
| c1                   | round(c1, -21) | c2                  | round(c2, -20) |
+----------------------+----------------+---------------------+----------------+
| 18446744073709551615 |              0 | 9223372036854775807 |              0 |
+----------------------+----------------+---------------------+----------------+
select c1, round(c1, -100), c2, round(c2, -100) from t1;
+----------------------+-----------------+---------------------+-----------------+
| c1                   | round(c1, -100) | c2                  | round(c2, -100) |
+----------------------+-----------------+---------------------+-----------------+
| 18446744073709551615 |               0 | 9223372036854775807 |               0 |
+----------------------+-----------------+---------------------+-----------------+
drop table t1;

create table t1(c1 decimal(10, 2), c2 int);
insert into t1 values(11.1, 1), (-0.1, 2), (12232334.1234, 3);
Warnings:
Warning	1265	Data truncated for column 'c1' at row 3
select avg(c1), round(avg(round(c1))), round(avg(round(c1, -1)), -1), round(avg(round(c1, 1)), 1) from t1;
+----------------+-----------------------+-------------------------------+-----------------------------+
| avg(c1)        | round(avg(round(c1))) | round(avg(round(c1, -1)), -1) | round(avg(round(c1, 1)), 1) |
+----------------+-----------------------+-------------------------------+-----------------------------+
| 4077448.373333 |               4077448 |                       4077450 |                   4077448.4 |
+----------------+-----------------------+-------------------------------+-----------------------------+
select avg(c2), round(avg(round(c2))), round(avg(round(c2, -1)), -1), round(avg(round(c2, 1)), 1) from t1;
+---------+-----------------------+-------------------------------+-----------------------------+
| avg(c2) | round(avg(round(c2))) | round(avg(round(c2, -1)), -1) | round(avg(round(c2, 1)), 1) |
+---------+-----------------------+-------------------------------+-----------------------------+
|  2.0000 |                     2 |                             0 |                         2.0 |
+---------+-----------------------+-------------------------------+-----------------------------+
select sum(c1), round(sum(round(c1))), round(sum(round(c1, -1)), -1), round(sum(round(c1, 1)), 1) from t1;
+-------------+-----------------------+-------------------------------+-----------------------------+
| sum(c1)     | round(sum(round(c1))) | round(sum(round(c1, -1)), -1) | round(sum(round(c1, 1)), 1) |
+-------------+-----------------------+-------------------------------+-----------------------------+
| 12232345.12 |              12232345 |                      12232340 |                  12232345.1 |
+-------------+-----------------------+-------------------------------+-----------------------------+
select sum(c2), round(sum(round(c2))), round(sum(round(c2, -1)), -1), round(sum(round(c2, 1)), 1) from t1;
+---------+-----------------------+-------------------------------+-----------------------------+
| sum(c2) | round(sum(round(c2))) | round(sum(round(c2, -1)), -1) | round(sum(round(c2, 1)), 1) |
+---------+-----------------------+-------------------------------+-----------------------------+
|       6 |                     6 |                             0 |                           6 |
+---------+-----------------------+-------------------------------+-----------------------------+
drop table t1;

drop table tbl_check_result;
drop table tbl_check_type;


// round integer scale test(30306488)
// expect scale is 0
select LEAST( ROUND( 0 , 8 ) , ROUND( 1 / 2 ) * 2 - 1 );
+--------------------------------------------------+
| LEAST( ROUND( 0 , 8 ) , ROUND( 1 / 2 ) * 2 - 1 ) |
+--------------------------------------------------+
|                                                0 |
+--------------------------------------------------+
// same test, but more exprs
select TRIM( SUBSTR( SUBSTR( CAST( ( LEAST( ROUND( 0 , 8 ) , ABS( ( ROUND( EXTRACT( MINUTE FROM '2015-06-15 10:00:00.000001' ) + 1 / ( ROUND( LENGTH( SUBSTR( CAST( ( ( ROUND( LENGTH( 'OGKDL' ) ) * 2 - 1 ) ) AS CHAR(100) ) , 1 , 20 ) ) ) * 2 - 1 ) ) * 2 - 1 ) ) ) ) AS CHAR(100) ) , 1 , 20 ) , 1 , 20 ) ) as tri_str;
+---------+
| tri_str |
+---------+
| 0       |
+---------+

