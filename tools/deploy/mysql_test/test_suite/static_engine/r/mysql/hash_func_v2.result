drop table t;
## varchar,basic
create table t(a varchar(2));
insert into t values(null);
explain select  * from t v1, t v2 where v2.a <=> case when v1.a  is null then null else null end;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH JOIN        |    |1       |5           |
|1 |├─TABLE FULL SCAN|v1  |1       |3           |
|2 |└─TABLE FULL SCAN|v2  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([v1.a], [v2.a]), filter(nil), rowset=16
      equal_conds([v2.a <=> cast(CASE WHEN v1.a IS NULL THEN NULL ELSE NULL END, VARCHAR(1048576))]), other_conds(nil)
  1 - output([v1.a]), filter(nil), rowset=16
      access([v1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([v1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([v2.a]), filter(nil), rowset=16
      access([v2.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([v2.__pk_increment]), range(MIN ; MAX)always true
select  * from t v1, t v2 where v2.a <=> case when v1.a  is null then null else null end;
a	a
NULL	NULL
drop table t;
