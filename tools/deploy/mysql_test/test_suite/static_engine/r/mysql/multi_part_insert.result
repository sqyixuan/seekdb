# 验证全局索引结果正确
EXPLAIN select /*+ index(xy_t primary)*/ * from xy_t;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |6       |20          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|6       |16          |
|2 |  └─PX PARTITION ITERATOR|        |6       |5           |
|3 |    └─TABLE FULL SCAN    |xy_t    |6       |5           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(xy_t.a, xy_t.b, xy_t.c, xy_t.d, xy_t.e)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(xy_t.a, xy_t.b, xy_t.c, xy_t.d, xy_t.e)]), filter(nil), rowset=16
      dop=1
  2 - output([xy_t.a], [xy_t.b], [xy_t.c], [xy_t.e], [xy_t.d]), filter(nil), rowset=16
      force partition granule
  3 - output([xy_t.a], [xy_t.b], [xy_t.c], [xy_t.e], [xy_t.d]), filter(nil), rowset=16
      access([xy_t.a], [xy_t.b], [xy_t.c], [xy_t.e], [xy_t.d]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([xy_t.a], [xy_t.b], [xy_t.c]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select /*+ index(xy_t primary)*/ * from xy_t;
+---+---+---+------+------+
| a | b | c | d    | e    |
+---+---+---+------+------+
| 2 | 2 | 2 |    2 |    2 |
| 4 | 4 | 4 |    4 |    4 |
| 6 | 6 | 6 |    6 |    6 |
| 1 | 1 | 1 |    1 |    1 |
| 3 | 3 | 3 |    3 |    3 |
| 5 | 5 | 5 |    5 |    5 |
+---+---+---+------+------+
EXPLAIN select /*+ index(xy_t g_idx_bc)*/ b, c from xy_t;
Query Plan
===================================================================
|ID|OPERATOR                 |NAME          |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |PX COORDINATOR           |              |6       |11          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000      |6       |9           |
|2 |  └─PX PARTITION ITERATOR|              |6       |5           |
|3 |    └─TABLE FULL SCAN    |xy_t(g_idx_bc)|6       |5           |
===================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(xy_t.b, xy_t.c)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(xy_t.b, xy_t.c)]), filter(nil), rowset=16
      dop=1
  2 - output([xy_t.b], [xy_t.c]), filter(nil), rowset=16
      force partition granule
  3 - output([xy_t.b], [xy_t.c]), filter(nil), rowset=16
      access([xy_t.b], [xy_t.c]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([xy_t.b], [xy_t.c], [xy_t.a]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select /*+ index(xy_t g_idx_bc)*/ b, c from xy_t;
