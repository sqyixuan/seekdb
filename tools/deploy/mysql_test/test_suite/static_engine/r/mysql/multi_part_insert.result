EXPLAIN select /*+ index(xy_t g_idx_cde)*/ c, d, e from xy_t;
Query Plan
====================================================================
|ID|OPERATOR                 |NAME           |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------------------
|0 |PX COORDINATOR           |               |6       |16          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000       |6       |13          |
|2 |  └─PX PARTITION ITERATOR|               |6       |7           |
|3 |    └─TABLE FULL SCAN    |xy_t(g_idx_cde)|6       |7           |
====================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(xy_t.c, xy_t.d, xy_t.e)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(xy_t.c, xy_t.d, xy_t.e)]), filter(nil), rowset=16
      dop=1
  2 - output([xy_t.c], [xy_t.e], [xy_t.d]), filter(nil), rowset=16
      force partition granule
  3 - output([xy_t.c], [xy_t.e], [xy_t.d]), filter(nil), rowset=16
      access([xy_t.c], [xy_t.e], [xy_t.d]), partitions(p[0-2])
      is_index_back=false, is_global_index=true, 
      range_key([xy_t.c], [xy_t.d], [xy_t.e], [xy_t.a], [xy_t.b]), range(MIN,MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX,MAX)always true
select /*+ index(xy_t g_idx_cde)*/ c, d, e from xy_t;
