explain_protocol: 2
result_format: 4
alter system set enable_async_syslog = false;


drop table if exists xy_t;
create table xy_t(a int, b int, c int, d int, e int, primary key(a,b,c), index g_idx_bc(b,c)) partition by hash(b) partitions 2;
create index g_idx_cde on xy_t(c, d, e) global partition by hash(e) partitions 3;

EXPLAIN insert into xy_t values(5,5,5,5,5);
Query Plan
==================================================
|ID|OPERATOR          |NAME|EST.ROWS|EST.TIME(us)|
--------------------------------------------------
|0 |DISTRIBUTED INSERT|    |1       |20          |
|1 |└─EXPRESSION      |    |1       |1           |
==================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{xy_t: ({xy_t: (xy_t.a, xy_t.b, xy_t.c, xy_t.d, xy_t.e)}, {g_idx_cde: (xy_t.c, xy_t.d, xy_t.e, xy_t.a, xy_t.b)})}]), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,__values.a)], [column_conv(INT,PS:(11,0),NOT NULL,__values.b)], [column_conv(INT,PS:(11,0),NOT NULL,
      __values.c)], [column_conv(INT,PS:(11,0),NULL,__values.d)], [column_conv(INT,PS:(11,0),NULL,__values.e)])
  1 - output([__values.a], [__values.b], [__values.c], [__values.d], [__values.e]), filter(nil)
      values({5, 5, 5, 5, 5})
insert into xy_t values(5,5,5,5,5);
