drop table t1, t2;
drop table if exists z0case, z1case;
explain_protocol: 0
create table z0case(z0_test0 enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-10'),z0_test1 char(100) );
insert into z0case values('中文字符','中文字符');
insert into z0case values('123456','123456');
insert into z0case values('ABCabc','ABC abc');
insert into z0case values('!@#$%^&*','!@#$%^&*');

create table z1case(z1_test5 DECIMAL);
insert into z1case values('123456');

update z0case set z0_test0=(select z1_test5 from z1case where z1_test5='1234156') limit 1;

update z0case set z0_test0=null limit 1;
update z0case set z0_test0=cast(null as decimal) limit 1;
update z0case set z0_test0=cast(null as number) limit 1;

drop table z0case;

