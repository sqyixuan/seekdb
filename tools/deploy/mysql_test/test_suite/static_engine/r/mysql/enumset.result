drop table if exists tbl_19;
CREATE TABLE `tbl_19` (
  `col_111` int(11) NOT NULL,
  `col_112` float NOT NULL,
  `col_113` set('Alice','Bob','Charlie','David') NOT NULL,
  `col_114` enum('Alice','Bob','Charlie','David') NOT NULL,
  `col_115` mediumint(8) unsigned NOT NULL DEFAULT '10109932',
  `col_116` tinyint(3) unsigned NOT NULL DEFAULT '118',
  `col_117` json DEFAULT NULL,
  `col_118` varbinary(488) NOT NULL DEFAULT 'v@',
  `col_119` bigint(20) NOT NULL DEFAULT '5717840293670355732',
  `col_120` json DEFAULT NULL,
  `col_121` varbinary(88) NOT NULL,
  `col_122` decimal(28,1) NOT NULL,
  `col_123` bigint(20) NOT NULL DEFAULT '6623545682150549061',
  `col_124` double DEFAULT NULL,
  `col_125` date DEFAULT '2007-10-23',
  `col_126` date DEFAULT NULL,
  `col_127` varbinary(348) DEFAULT NULL,
  `col_128` text NOT NULL,
  `col_129` blob NOT NULL,
  `col_130` double DEFAULT '1992.2454747031088',
  `col_131` bigint(20) unsigned NOT NULL,
  `col_132` enum('Alice','Bob','Charlie','David') NOT NULL,
  `col_133` datetime NOT NULL,
  `col_134` set('Alice','Bob','Charlie','David') DEFAULT 'Alice',
  PRIMARY KEY (`col_116`, `col_123`, `col_114`, `col_132`, `col_115`),
  UNIQUE KEY `idx_15` (`col_116`, `col_111`, `col_133`) BLOCK_SIZE 16384 GLOBAL,
  UNIQUE KEY `idx_2196` (`col_116`, `col_124`, `col_126`) BLOCK_SIZE 16384 GLOBAL,
  KEY `idx_14` (`col_126`) BLOCK_SIZE 16384 GLOBAL
);
