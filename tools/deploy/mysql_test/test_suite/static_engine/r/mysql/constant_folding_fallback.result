result_format: 4
alter system set enable_async_syslog = false;

drop table if exists t;

create table t(a int);

select 1/0 from t;
+------+
| 1/0  |
+------+
+------+
select case when a = 1 then 1 else 1 / 0 end from t;
+---------------------------------------+
| case when a = 1 then 1 else 1 / 0 end |
+---------------------------------------+
+---------------------------------------+
select cast('aaa' as signed) from t;
+-----------------------+
| cast('aaa' as signed) |
+-----------------------+
+-----------------------+

insert into t values (1);
select 1/0 from t;
+------+
| 1/0  |
+------+
| NULL |
+------+
select case when a = 1 then 1 else 1 / 0 end from t;
+---------------------------------------+
| case when a = 1 then 1 else 1 / 0 end |
+---------------------------------------+
|                                1.0000 |
+---------------------------------------+
select cast('aaa' as signed) from t;
+-----------------------+
| cast('aaa' as signed) |
+-----------------------+
|                     0 |
+-----------------------+


drop table t;
