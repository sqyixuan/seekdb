insert into t values(100, -123, 12, 24325645, 0);
create table t1 as select least(c1, c2), least(c1, c3), least(c1, c4), least(c1, c5), least(c2, c3), least(c2, c4), least(c2, c5), least(c3, c4), least(c3, c5), least(c4, c5) from t;
