      range_cond([:0 <= Y.pk])
SELECT Y.*,Y.__ob_partition_id,MAX(distinct Y.__ob_partition_index) FROM table_2 AS X LEFT JOIN table_3 AS Y ON X . col_bigint <= Y . pk;
