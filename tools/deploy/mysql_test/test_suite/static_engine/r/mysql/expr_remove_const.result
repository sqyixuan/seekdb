drop table t1;
create table t1 (c1 int primary key, c2 int, c3 int) partition by hash (c1) partitions 3;
insert into t1 (c1) values (1),(2),(3),(4);
select /*+NO_REWRITE*/ count(*) from t1 group by 1 + (select 1 > all (select 0));
