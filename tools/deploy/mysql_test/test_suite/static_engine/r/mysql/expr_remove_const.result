create view v as select (select c1 from ((select a.c1, c2 from t1) union (select c1, a.c2 from t1))u ) as x from t1 a;
show create view v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select (select `u`.`c1` from ((select `a`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1`) union (select `test`.`t1`.`c1` AS `c1`,`a`.`c2` AS `c2` from `test`.`t1`)) `u`) AS `x` from `test`.`t1` `a`	utf8mb4	utf8mb4_general_ci

