create table t1(c1 int,c2 int, c3 date);
insert into t1 values(1,2,date'2019-10-10');
insert into t1 values(2,1,date'2019-09-10');
insert into t1 values(0,3,date'2019-12-10');
insert into t1 values(4,2,date'2019-11-10');
commit;
select * from t1 where c1 >1;
c1	c2	c3
2	1	2019-09-10
4	2	2019-11-10
select * from t1 where c1 >1 and c1<3;
c1	c2	c3
2	1	2019-09-10
select * from t1 where c1 >1 and c2>1;
c1	c2	c3
4	2	2019-11-10
select * from t1 where c1 >1 and c2>1 and c1+c2>3;
c1	c2	c3
4	2	2019-11-10
select * from t1 where c1 >1 and c2>1 and c1+c2>3 and c1<5;
c1	c2	c3
4	2	2019-11-10
select * from t1 where (c1 >1 and c2>1 and c1+c2>3 and c1<5) or c1 <3;
c1	c2	c3
1	2	2019-10-10
2	1	2019-09-10
0	3	2019-12-10
4	2	2019-11-10
select /*+ parallel(2)*/ * from t1 where c1 >1;
c1	c2	c3
2	1	2019-09-10
4	2	2019-11-10
select /*+ parallel(2)*/* from t1 where c1 >1 and c2>1;
c1	c2	c3
4	2	2019-11-10
select /*+ parallel(2)*/* from t1 where c1 >1 and c2>1 and c1+c2>3;
c1	c2	c3
4	2	2019-11-10
select /*+ parallel(2)*/* from t1 where c1 >1 and c2>1 and c1+c2>3 and c1<5;
c1	c2	c3
4	2	2019-11-10
select /*+ parallel(2)*/* from t1 where (c1 >1 and c2>1 and c1+c2>3 and c1<5) or c1 <3;
c1	c2	c3
1	2	2019-10-10
2	1	2019-09-10
0	3	2019-12-10
4	2	2019-11-10
create index idx_t1_01 on t1(c2);
select /*+ index(t1 idx_t1_01)*/ * from t1 where c1 >1 and c2=1;
c1	c2	c3
2	1	2019-09-10
select /*+ index(t1 primay)*/ * from t1 where c1 >1 and c2=1;
c1	c2	c3
2	1	2019-09-10
select /*+ parallel(2) index(t1 idx_t1_01)*/ * from t1 where c1 >1 and c2=1;
c1	c2	c3
2	1	2019-09-10
select /*+ parallel(2) index(t1 primay)*/ * from t1 where c1 >1 and c2=1;
c1	c2	c3
2	1	2019-09-10
select /*+ parallel(2) index(t1 primay)*/ * from t1 where c2=1;
c1	c2	c3
2	1	2019-09-10
select /*+ parallel(2) index(t1 idx_t1_01)*/ * from t1 where c1 >1 and c2>1 and c2<3 and c1<3;
c1	c2	c3
select /*+ parallel(2) index(t1 idx_t1_01)*/ * from t1 where c1 >1 and c2>1 and c2+1<4 and c1<5 and c2+2>-10;
c1	c2	c3
4	2	2019-11-10
select /*+ parallel(2) index(t1 idx_t1_01)*/ * from t1 where c1 >1 and c2>1 and c2+1<4;
c1	c2	c3
4	2	2019-11-10
drop table t1;
