result_format: 4
alter system flush plan cache global;

set ob_enable_plan_cache = 0;
set block_encryption_mode = 0;
show variables like 'block_encryption_mode';
Variable_name	Value
block_encryption_mode	aes-128-ecb
select hex(sm4_encrypt('abcd', 'asd')) from dual;
ERROR 0A000: Function sm4_encrypt not supported
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
ERROR 0A000: Function sm4_encrypt not supported
select hex(sm4_decrypt('abc', 'dbc')) from dual;
ERROR 0A000: Function sm4_decrypt not supported

set block_encryption_mode = 17;
show variables like 'block_encryption_mode';
Variable_name	Value
block_encryption_mode	aes-256-ofb
select hex(sm4_encrypt('abcd', 'asd')) from dual;
ERROR 0A000: Function sm4_encrypt not supported
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
ERROR 0A000: Function sm4_encrypt not supported
select hex(sm4_decrypt('abc', 'dbc')) from dual;
ERROR 0A000: Function sm4_decrypt not supported

set block_encryption_mode = 18;
show variables like 'block_encryption_mode';
Variable_name	Value
block_encryption_mode	aes-256-ofb
select 1 as flag from dual where sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj') = sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj');
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select hex(sm4_encrypt('asdas123123dasdasd', '12312313123', '$$&$(*&(%*&(*%&($&*%&(dkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select hex(sm4_encrypt('asdasdasdasd', '', '1290380129038129038012938'))  from dual;
select hex(sm4_encrypt('', 'abc', '121903810293801289301298301982301928'))  from dual;
select hex(sm4_encrypt('asdasdasdasd', 'asdasdas', '1230121231230381209380913820912830'))  from dual;
select sm4_decrypt(sm4_encrypt('asdasdasdasd', '', '1290380129038129038012938'), '','1290380129038129038012938')  from dual;
select sm4_decrypt(sm4_encrypt('', 'abc', '121903810293801289301298301982301928'), 'abc', '121903810293801289301298301982301928')  from dual;
select sm4_decrypt(sm4_encrypt('asdasdasdasd', 'asdasdas', '1230121231230381209380913820912830'),'asdasdas', '1230121231230381209380913820912830') from dual;
select hex(sm4_encrypt('中文字符加一点', '你好', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select hex(sm4_encrypt('测试', '是不是', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select hex(sm4_encrypt('意义', '周三', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select hex(sm4_encrypt('午后的天气还不错', '莎士比亚', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'))  from dual;
select sm4_decrypt(sm4_encrypt('中文字符加一点', '你好', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'), '你好', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj') from dual;
select sm4_decrypt(sm4_encrypt('测试', '是不是', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'),'是不是','asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj') from dual;
select sm4_decrypt(sm4_encrypt('意义', '周三', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'),'周三','asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj') from dual;
select sm4_decrypt(sm4_encrypt('午后的天气还不错', '莎士比亚', 'asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj'),'莎士比亚','asdasdkljasdkljalskdjaklsdjaklsjdaklsdjlaksdj') from dual;
select 1 as flag from dual where sm4_encrypt('abc', '&*!') = sm4_encrypt('abc', '&*!');
select hex(sm4_encrypt('abcd', 'asd')) from dual;
select hex(sm4_encrypt('asdiajsldkjasldjaljaskldjalskdjalskj', '123123jasldkjlkj1')) from dual;
select hex(sm4_encrypt('lalalla', 'daskldalsdkaldk')) from dual;
select hex(sm4_encrypt(12564765764343423423473,5754343243243243123)) from dual;
select hex(sm4_encrypt('asdasd', '!%@#$')) from dual;
select hex(sm4_encrypt('hahahaa', 'aklsjdlkajsdklajsdkllkjalsjdlakjsl')) from dual;
select hex(sm4_encrypt('aklsdjalkjsdlkajsdklajsdlajsdlkajsdljkasldjkalsdjalskdjalksdjaklsjdlaksjdlaksjdlalskdjalsjkdalsjkdaklsdj', 'asdl;ajksdlaksdlasdlasdkl;asd;aklsd;alskd;aksd;aks;alsdkas;ldka;lksda;kls;')) from dual;
select sm4_decrypt(sm4_encrypt('abcd', 'asd'), 'asd') from dual;
select sm4_decrypt(sm4_encrypt('asdiajsldkjasldjaljaskldjalskdjalskj', '123123jasldkjlkj1'), '123123jasldkjlkj1') from dual;
select sm4_decrypt(sm4_encrypt('lalalla', 'daskldalsdkaldk'),'daskldalsdkaldk') from dual;
select sm4_decrypt(sm4_encrypt(12564765764343423423473,5754343243243243123), 5754343243243243123) from dual;
select sm4_decrypt(sm4_encrypt('asdasd', '!%@#$'), '!%@#$') from dual;
select sm4_decrypt(sm4_encrypt('hahahaa', 'aklsjdlkajsdklajsdkllkjalsjdlakjsl'), 'aklsjdlkajsdklajsdkllkjalsjdlakjsl') from dual;
select hex(sm4_decrypt(sm4_encrypt('aklsdjalkjsdlkajsdklajsdlajsdlkajsdljkasldjkalsdjalskdjalksdjaklsjdlaksjdlaksjdlalskdjalsjkdalsjkdaklsdj', 'asdl;ajksdlaksdl'), 'asdl;ajksdlaksdl')) from dual;
select hex(sm4_decrypt(1, 2)) from dual;
select hex(sm4_decrypt(1.2, 3.6)) from dual;
select hex(sm4_decrypt('abc', 'dbc')) from dual;
select hex(sm4_encrypt('断剑重铸之时，英雄归来之日', 'asd')) from dual;
select hex(sm4_encrypt('我用双手成就你的梦想', 'asd')) from dual;
select hex(sm4_encrypt('没有什么好恐惧的，除了恐惧本身', 'asd')) from dual;
select sm4_decrypt(sm4_encrypt('断剑重铸之时，英雄归来之日', 'asd'), 'asd') from dual;
select sm4_decrypt(sm4_encrypt('我用双手成就你的梦想', 'asd'), 'asd') from dual;
select sm4_decrypt(sm4_encrypt('没有什么好恐惧的, 除了恐惧本身', 'asd'), 'asd') from dual;

set block_encryption_mode = 19;
show variables like 'block_encryption_mode';
Variable_name	Value
block_encryption_mode	aes-256-ofb
