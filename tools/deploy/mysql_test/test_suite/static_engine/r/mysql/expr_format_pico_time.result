result_format: 4
Test format_pico_time
SELECT format_pico_time('1230000') AS a;
+---------+
| a       |
+---------+
| 1.23 us |
+---------+
SELECT format_pico_time(1230000) AS a;
+---------+
| a       |
+---------+
| 1.23 us |
+---------+
SELECT format_pico_time(NULL) AS a;
+------+
| a    |
+------+
| NULL |
+------+
SELECT format_pico_time('1230000a') AS a;
+---------+
| a       |
+---------+
| 1.23 us |
+---------+

# Bad arguments
SELECT format_pico_time() AS a;
ERROR 42000: Incorrect parameter count in the call to native function 'format_pico_time'
SELECT format_pico_time(1,2) AS a;
ERROR 42000: Incorrect parameter count in the call to native function 'format_pico_time'
