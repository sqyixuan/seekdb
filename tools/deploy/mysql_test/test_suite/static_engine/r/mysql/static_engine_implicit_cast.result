-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.__pk_increment, t1.col_int, t1.col_string_utf8, t1.col_string_gbk)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,__values.col_int)], [column_conv(VARCHAR,utf8mb4_general_ci,length:100,NULL,__values.col_string_utf8)],
       [column_conv(VARCHAR,gbk_chinese_ci,length:100,NULL,__values.col_string_gbk)])
  1 - output([__values.col_int], [__values.col_string_utf8], [__values.col_string_gbk]), filter(nil)
      values({1, '12', '13'})
