// Case2: test zerofill
explain_protocol: 0
drop table if exists t1;
create table t1(c1 int(3) zerofill);
insert into t1 values(1);

set ob_enable_plan_cache = 0;
select concat(c1, 'a') from t1 limit 1;
+-----------------+
| concat(c1, 'a') |
+-----------------+
| 001a            |
+-----------------+

delete from t1;
insert into t1 values(1234);
select concat(c1, 'a') from t1 limit 1;
+-----------------+
| concat(c1, 'a') |
+-----------------+
| 1234a           |
+-----------------+

drop table t1;
create table t1(c1 int(256) zerofill);
ERROR 42000: Display width out of range for column 'c1' (max = 255)
create table t1(c1 int(-1) zerofill);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '-1) zerofill)' at line 1

create table t1(c1 int(255) zerofill);
insert into t1 values(1);
select length(c1) from t1;
+------------+
| length(c1) |
+------------+
|        255 |
+------------+

drop table t1;
create table t1(c1 int(0) zerofill);
insert into t1 values(1);
select length(c1) from t1;
+------------+
| length(c1) |
+------------+
|         10 |
+------------+
explain_protocol: 2
// Case3: 测试collation不同，添加两次cast的情况
drop table if exists t1;
create table t1 (col_int int, 
                 col_string_utf8 varchar(100) charset utf8mb4 collate utf8mb4_general_ci,
                 col_string_gbk varchar(100) charset gbk collate gbk_chinese_ci
);
EXPLAIN insert into t1 values(1, '12', '13');
Query Plan
==================================================
|ID|OPERATOR          |NAME|EST.ROWS|EST.TIME(us)|
--------------------------------------------------
|0 |DISTRIBUTED INSERT|    |1       |13          |
|1 |└─EXPRESSION      |    |1       |1           |
==================================================
