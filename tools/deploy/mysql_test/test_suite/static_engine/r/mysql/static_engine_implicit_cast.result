// Case9: scale test
explain_protocol: 0
// float_range_check
drop table t1;
create table t1(c1 float(10, 0), c2 float, c3 float);
insert into t1(c3) values(1.138);
update t1 set c1 = c3, c2 = c3;
select * from t1;
+------+-------+-------+
| c1   | c2    | c3    |
+------+-------+-------+
|    1 | 1.138 | 1.138 |
+------+-------+-------+

// number_range_check
drop table t1;
create table t1(c1 number(10, 1), c2 number(10, 2), c3 number(10, 3));
insert into t1(c3) values(1.138);
update t1 set c1 = c3, c2 = c3;
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1
Warning	1265	Data truncated for column 'c2' at row 1
select * from t1;
+------+------+-------+
| c1   | c2   | c3    |
+------+------+-------+
|  1.1 | 1.14 | 1.138 |
+------+------+-------+
delete from t1;
insert into t1(c2) values(1.13);
update t1 set c1 = c2, c3 = c2;
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1
select * from t1;
+------+------+-------+
| c1   | c2   | c3    |
+------+------+-------+
|  1.1 | 1.13 | 1.130 |
+------+------+-------+

// time_scale_check
drop table t1;
create table t1(c1 time, c2 time(3), c3 time(6));
insert into t1(c3) values('11:22:33.123456');
update t1 set c1 = c3, c2 = c3;
select * from t1;
+----------+--------------+-----------------+
| c1       | c2           | c3              |
+----------+--------------+-----------------+
| 11:22:33 | 11:22:33.123 | 11:22:33.123456 |
+----------+--------------+-----------------+
delete from t1;
insert into t1(c1) values('11:22:33');
update t1 set c2 = c1, c3 = c1;
select * from t1;
+----------+--------------+-----------------+
| c1       | c2           | c3              |
+----------+--------------+-----------------+
| 11:22:33 | 11:22:33.000 | 11:22:33.000000 |
+----------+--------------+-----------------+

// enumset
drop table t1;
create table t1(c1 enum('a', 'b', 'c'), c2 int);
insert into t1(c1) values('a');
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
| a    | NULL |
+------+------+
update t1 set c1 = 'b', c2 = c1;
select * from t1;
+------+------+
| c1   | c2   |
+------+------+
| b    |    2 |
+------+------+

// string->year error check
drop table t1;
create table t1(c1 year);
insert into t1 values('201a');
ERROR 22003: Out of range value for column 'c1' at row 1
select * from t1;
