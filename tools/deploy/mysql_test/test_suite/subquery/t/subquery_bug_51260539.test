--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;

CREATE TABLE t1 (a INT, b INT);
INSERT INTO t1 VALUES (1,1),(1,2),(2,3),(3,4);
CREATE TABLE t2 (a INT);
INSERT INTO t2 values (1);

SELECT 
(SELECT COUNT(DISTINCT t1.b) FROM t2 
union 
SELECT 1 FROM t2 WHERE 12 < 3) 
FROM t1 GROUP BY t1.a ORDER BY t1.a;

SELECT 
(SELECT COUNT(t1.b) FROM dual
union 
SELECT 1 FROM dual WHERE 2<1) 
FROM t1 GROUP BY t1.a;

SELECT 
(SELECT COUNT(t1.b) FROM dual) 
FROM t1 GROUP BY t1.a;


# aggfunc in having
SELECT 1 FROM t1 HAVING 1 in (SELECT MAX(t1.a) FROM dual);

SELECT 1 FROM t1 HAVING 4 in (SELECT COUNT(t1.a) FROM dual);

SELECT 1 FROM t1 HAVING MIN(t1.a) in (SELECT a FROM t2 WHERE COUNT(t1.a) > t2.a);


# aggfunc in order
SELECT (SELECT MAX(t1.a) FROM dual) FROM t1 ORDER BY (SELECT MAX(t1.a) FROM dual);

SELECT (SELECT 1 FROM dual WHERE MAX(t1.a) < 3) FROM t1 ORDER BY (SELECT 1 FROM dual WHERE MAX(t1.a) < 3);


drop table t1;
drop table t2;