--disable_warnings
drop table if exists agent_department;
drop table if exists agent_employee;
--enable_warnings

create table agent_department(id int primary key, leader_id int);
create table agent_employee(id int primary key, nick_name varchar(10) default 'hhh', department_id int);
insert into agent_department values (1, 1);
insert into agent_employee values (11756, 'hhh', 1);

explain SELECT id, nick_name, department_id, (SELECT d.leader_id FROM agent_department d WHERE d.id = a.department_id) AS leader, (SELECT aa.nick_name FROM agent_employee aa WHERE aa.id = leader) FROM agent_employee a WHERE id IN (11756, 23078, 8954, 23934, 27833, 35022, 40856, 43660, 46893, 45931) LIMIT 0, 1000;

SELECT id, nick_name, department_id, (SELECT d.leader_id FROM agent_department d WHERE d.id = a.department_id) AS leader, (SELECT aa.nick_name FROM agent_employee aa WHERE aa.id = leader) FROM agent_employee a WHERE id IN (11756, 23078, 8954, 23934, 27833, 35022, 40856, 43660, 46893, 45931) LIMIT 0, 1000;

drop table agent_department;
drop table agent_employee;