# owner: qiaolinjun.qlj
# owner group: IMF
# description: das,batch rescan
# tags: das,join

--disable_abort_on_error
--disable_warnings
drop table if exists t3;
drop table if exists t2;
drop table if exists t1;
--enable_warnings

create table t1(a int, b int);
insert into t1 values(1, 1), (2, 2), (3, 3);
create table t2(a int, b int);
insert into t2 select 1, 1 from table(generator(1005));
insert into t2 select 2, 2 from table(generator(1005));
insert into t2 select 3, 3 from table(generator(1005));
create table t3(a int, b int, index i3(a));
insert into t3 select 1, 1 from table(generator(1005));
insert into t3 select 2, 2 from table(generator(1005));
insert into t3 select 3, 3 from table(generator(1005));

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set _rowsets_enabled = 1 tenant=sys;
alter system set _rowsets_enabled = 1 tenant=all_user;
alter system set _rowsets_enabled = 1 tenant=all_meta;

alter system set _rowsets_max_rows=1 tenant=sys;
alter system set _rowsets_max_rows=1 tenant=all_user;
alter system set _rowsets_max_rows=1 tenant=all_meta;

alter system set_tp tp_no=367, error_code=4016, frequency=1;
sleep 5;
connection default;

explain select * from t1 where exists(select /*+no_rewrite, use_nl(t2, t3)*/ t2.a from t2, t3 where t2.a=t3.a and t2.b=t1.a and exists(select 1 from t3 where t3.a=t2.a));
select * from t1 where exists(select /*+no_rewrite, use_nl(t2, t3)*/ t2.a from t2, t3 where t2.a=t3.a and t2.b=t1.a and exists(select 1 from t3 where t3.a=t2.a));

connection conn_admin;
alter system set_tp tp_no=367, error_code=0, frequency=0;
alter system set _rowsets_max_rows=256 tenant=sys;
alter system set _rowsets_max_rows=256 tenant=all_user;
alter system set _rowsets_max_rows=256 tenant=all_meta;
sleep 5;
connection default;

drop table t3;
drop table t2;
drop table t1;

CREATE TABLE t1 (
  a int(11) NOT NULL,
  b int(11) DEFAULT NULL,
  PRIMARY KEY (a)
);

CREATE TABLE t2 (
  a int(11) DEFAULT NULL,
  b int(11) DEFAULT NULL,
  c int(11) DEFAULT NULL,
  KEY i1 (a) BLOCK_SIZE 16384 GLOBAL
) partition by hash(a) partitions 2;

insert into t1 values (1,1),(2,1),(3,1),(4,1),(5,5),(6,6);
insert into t2 values (1,1,1),(1,2,2),(1,3,3),(1,4,4);
insert into t2 values (1,1,1),(1,2,2),(1,3,3),(1,4,4);
insert into t2 values (1,1,1),(1,2,2),(1,3,3),(1,4,4);
insert into t2 values (1,1,1),(1,2,2),(1,3,3),(1,4,4);
insert into t2 values (1,5,5);

select * from t1;
select * from t2;
alter system set _enable_spf_batch_rescan=false;
--sleep 3
explain select /*+log_level(DEBUG), no_rewrite*/ * from t1 where exists (select * from t2 where t1.b=t2.a);
select /*+log_level(DEBUG), no_rewrite*/ * from t1 where exists (select * from t2 where t1.b=t2.a);
alter system set _enable_spf_batch_rescan=true;

drop table t2;
drop table t1;