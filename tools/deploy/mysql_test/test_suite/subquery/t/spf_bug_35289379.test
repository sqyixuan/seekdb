# owner group: sql2
# description:
#

--explain_protocol 2
--result_format 4

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c11 varchar(100), c12 varchar(100) primary key, c13 varchar(100));
create table t2(c21 varchar(100) primary key, c22 varchar(100), c23 varchar(100));
create table t3(c31 int, c32 varchar(100), c33 varchar(100)) partition by hash(c31) partitions 3;

insert/*trace*/ into t1 values('abc', 'abc', 'abc'), ('xxx', 'xxx', 'xxx');
insert/*trace*/ into t2 values('abc', 'abc', 'abc');

select /*+no_rewrite*/ * from ((select/*+leading(t1, t2) use_nl(t1, t2)*/ t2.c22 as c32 from t1, t2 where t1.c12 = t2.c21 ) union all select c32 from t3) v where exists (select 1 from t1 where t1.c12 = v.c32);

drop table t1,t2,t3;
