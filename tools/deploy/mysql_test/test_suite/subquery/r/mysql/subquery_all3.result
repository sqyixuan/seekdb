  1 - output([t1.t1_id]), filter(nil), rowset=16
      access([t1.t1_id]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.t1_id]), range(MIN ; MAX)always true
  2 - output([T_FUN_SUM(t3.amount)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(t3.amount)])
  3 - output([t3.amount]), filter(nil), rowset=16
      access([t3.t3_id], [t3.amount]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t3.t1_id], [t3.t3_id]), range(MIN,MIN ; MAX,MAX)always true, 
