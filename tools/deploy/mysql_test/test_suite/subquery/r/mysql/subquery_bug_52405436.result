drop table if exists t1;
drop table if exists t2;
drop table if exists tt1;
drop table if exists tt2;
create table t1 (id int);
create table t2 (id int);
create table tt1 (id int primary key, name varchar(20), age int);
create table tt2 (id int primary key, name2 varchar(20), age int);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t2 values(1);
insert into t2 values(2);
insert into t2 values(3);
insert into tt1 values(1, 'aaa', 10);
insert into tt1 values(2, 'bbb', 10);
insert into tt2 values(1, 'aaa', 10);
insert into tt2 values(2, 'bbb', 10);
select * from t1 join t2 on t1.id = t2.id union select * from t1 join t2 on t1.id = t2.id;
id	id
1	1
2	2
3	3
select * from (select * from t1 join t2 on t1.id = t2.id union select * from t1 join t2 on t1.id = t2.id);
ERROR 42S21: Duplicate column name 'id'
select id from (select * from t1 join t2 on t1.id = t2.id union select * from t1 join t2 on t1.id = t2.id);
ERROR 42S21: Duplicate column name 'id'
select * from tt1 left join tt2 on tt1.name = tt2.name2 where tt1.age = 10 union select * from tt1 left join tt2 on tt1.name = tt2.name2 where tt1.age = 20;
id	name	age	id	name2	age
1	aaa	10	1	aaa	10
2	bbb	10	2	bbb	10
select * from (select * from tt1 left join tt2 on tt1.name = tt2.name2 where tt1.age = 10 union select * from tt1 left join tt2 on tt1.name = tt2.name2 where tt1.age = 20);
ERROR 42S21: Duplicate column name 'id'
drop table t1;
drop table t2;
