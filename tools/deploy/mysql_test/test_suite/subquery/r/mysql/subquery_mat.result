drop table if exists t1, t2, t3, t4, t1i, t2i, t3i, columns;
drop view if exists v1, v2, v1m, v2m;
create table t1 (a1 char(8), a2 char(8));
create table t2 (b1 char(8), b2 char(8));
create table t3 (c1 char(8), c2 char(8));
insert into t1 values ('1 - 00', '2 - 00');
insert into t1 values ('1 - 01', '2 - 01');
insert into t1 values ('1 - 02', '2 - 02');
insert into t2 values ('1 - 01', '2 - 01');
insert into t2 values ('1 - 01', '2 - 01');
insert into t2 values ('1 - 02', '2 - 02');
insert into t2 values ('1 - 02', '2 - 02');
insert into t2 values ('1 - 03', '2 - 03');
insert into t3 values ('1 - 01', '2 - 01');
insert into t3 values ('1 - 02', '2 - 02');
insert into t3 values ('1 - 03', '2 - 03');
insert into t3 values ('1 - 04', '2 - 04');
create table t1i (a1 char(8), a2 char(8), index it1i1(a1), index it1i2(a2), index it1i3(a1, a2));
create table t2i (b1 char(8), b2 char(8), index it2i1(b1), index it2i2(b2), index it2i3(b1, b2));
create table t3i (c1 char(8), c2 char(8), index it3i1(c1), index it3i2(c2), index it3i3(c1, c2));
insert into t1i values ('1 - 00', '2 - 00');
insert into t1i values ('1 - 01', '2 - 01');
insert into t1i values ('1 - 02', '2 - 02');
insert into t2i values ('1 - 01', '2 - 01');
insert into t2i values ('1 - 01', '2 - 01');
insert into t2i values ('1 - 02', '2 - 02');
insert into t2i values ('1 - 02', '2 - 02');
insert into t2i values ('1 - 03', '2 - 03');
insert into t3i values ('1 - 01', '2 - 01');
insert into t3i values ('1 - 02', '2 - 02');
insert into t3i values ('1 - 03', '2 - 03');
insert into t3i values ('1 - 04', '2 - 04');
insert into t1i select * from t1;
insert into t2i select * from t2;
insert into t3i select * from t3;
EXPLAIN 
select * from t1 where a1 in (select b1 from t2 where b1 > '0');
