# bug 54027490


--disable_warnings
--error 0,1305
DROP PROCEDURE zc_prole;
--enable_warnings

delimiter //;
CREATE PROCEDURE zc_prole()
BEGIN
	SET ROLE NONE;
end;
//
delimiter ;//

call zc_prole();

DROP PROCEDURE zc_prole;


# bug 54038536
connection default;
--disable_warnings
--error 0, 1396
drop user U1;
--error 0, 1396
drop role r1;
drop table if exists t1;
--enable_warnings

create user U1;
create role r1;

create table t1(c1 int);
grant update(c1) on t1 to r1;
grant select(c1) on t1 to U1;
grant r1 to U1;


connect (conn54038536,$OBMYSQL_MS0,U1,,*NO-ONE*,$OBMYSQL_PORT);
connection conn54038536;
show full columns in test.t1;
set role r1;
show full columns in test.t1;

connection default;
drop user U1;
drop role r1;
drop table t1;


#bug 54027490
--disable_query_log
--disable_warnings
--error 0, 1396
drop role role_procedure1;
DROP PROCEDURE IF EXISTS create_role;
--enable_warnings
--enable_query_log

create role role_procedure1;

DELIMITER //;
CREATE PROCEDURE create_role()
BEGIN
    drop role role_procedure1;
    create role role_procedure1;
    select user from mysql.user where user='role_procedure1';
END //
DELIMITER ;//

CALL create_role;

drop role role_procedure1;

