--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:jim.wjh
#owner group: sql2
#tags: dcl
#description: 
# create / drop role
# grant priv_list to role # grant role_list to user
# revole priv_list from role # revoke role_list from user

--result_format 4

connection default;
--disable_warnings
--error 0, 1396
drop role r3;
--error 0, 1396
drop role r4;
--error 0, 1396
drop role r5;
--error 0, 1396
drop role r6;
--error 0, 1396
drop user u1;
--error 0, 1396
drop user u2;
--error 0, 1396
drop role u9;
--enable_warnings

create user u1 identified by '123';
create user u2 identified by '123';

# create / drop role
create role r3;
--sorted_result
select user, host from mysql.user where user like 'r_';
--error 1396
create role r3;
create role r4;
--error 1396
create role r3,r4;
drop role r3,r4;
--sorted_result
select user, host from mysql.user where user like 'r_';
--error 1396
drop role r3;


########################################
# grant/revoke role to role/user
########################################

--source mysql_test/include/check_schema_fast_sync.inc
connection default;

create role r3;
create role r4;
create role r5;

# grant test

grant select on *.* to r5;
grant select on mysql.* to r4;
grant select on mysql.user to r3;
show grants for r4;
show grants for r3;

grant r4 to r3;
show grants for r3;
show grants for r3 using r4;

grant r3 to u2;
show grants for u2;
show grants for u2 using r3;
grant u2 to u1;
show grants for u1;
--error 3530
show grants for u1 using r4;

--error 4027
grant u1 to r4;


--sorted_result
select * from mysql.role_edges;

# revoke test

revoke r4 from r3;
show grants for r3;
--error 3530
show grants for r3 using r4;
revoke r3 from u2;
show grants for u2;
--error 3530
show grants for u2 using r3;
revoke u2 from u1;
show grants for u1;
revoke u2 from u1;
show grants for u1;

--error 3523
grant r100 to u1;

--error 3523
grant r3 to u100;

grant r3,r4 to u1,u2;
grant r5 to r3;
grant r5 to r4;

set default role r3 to u1;
set default role r3,r4 to u2;
set default role r5 to r3;


--sorted_result
select * from mysql.role_edges;
--sorted_result
select * from mysql.default_roles;

# login role, the role is locked
--disable_query_log
--error 3118
connect (failed_conn3,$OBMYSQL_MS0,r3,,*NO-ONE*,$OBMYSQL_PORT);
--error 3118
connect (failed_conn4,$OBMYSQL_MS0,r4,,*NO-ONE*,$OBMYSQL_PORT);
--enable_query_log

alter user r3 account unlock;
alter user r4 account unlock;

connect (succ_conn3,$OBMYSQL_MS0,r3,,*NO-ONE*,$OBMYSQL_PORT);
connection succ_conn3;
show grants;
show grants for r3 using r5;
select current_role();
select * from information_schema.enabled_roles;


connect (succ_conn4,$OBMYSQL_MS0,r4,,*NO-ONE*,$OBMYSQL_PORT);
connection succ_conn4;
show grants;
show grants for r4 using r5;
select current_role();
select * from information_schema.enabled_roles;


connect (succ_conn1,$OBMYSQL_MS0,u1,123,*NO-ONE*,$OBMYSQL_PORT);
connection succ_conn1;
show grants;
show grants for u1 using r3,r4;
select current_role();
select * from information_schema.enabled_roles;
set role r3,r4;
select current_role();
select * from information_schema.enabled_roles;
--error 3530
set role r5;
set role NONE;
select current_role();
select * from information_schema.enabled_roles;
set role ALL;
select current_role();
select * from information_schema.enabled_roles;
set role ALL except r4;
select current_role();

# bug 53979503
set role ALL except r5;
select current_role();
set role ALL except r99;
select current_role();

select * from information_schema.enabled_roles;
SET role DEFAULT;
select current_role();
select * from information_schema.enabled_roles;


connect (succ_conn2,$OBMYSQL_MS0,u2,123,*NO-ONE*,$OBMYSQL_PORT);
connection succ_conn2;
show grants;
show grants for u2 using r3,r4;
select current_role();

connection default;

--disable_warnings
drop table if exists t1;
drop procedure if exists my_proc1;
--enable_warnings

create user u9;

create table t1(c1 int);
insert into t1 values(1);

create role r6;
grant select on test.t1 to r6;
grant r6 to u9;
grant execute on *.* to u9;

delimiter //;
CREATE definer = 'u9' PROCEDURE my_proc1 (OUT count_all INT)
BEGIN
 SELECT COUNT(*) INTO count_all FROM test.t1;
END
//
delimiter ;//

--error 1142
call my_proc1(@a);

set default role r6 to u9;

call my_proc1(@a);


drop table t1;
drop user u9;
drop role r6;


drop role r3;
drop role r4;
drop user u1;
drop user u2;


