#owner: lichangqing
#owner group: SQL2
#description: 验证ssl support 
##tags: dcl

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set ssl_client_authentication = false;
sleep 20;
connection default;
alter system set ob_ssl_invited_common_names = 'NONE';

--disable_warnings
--error 0, 942, 1051, 600
drop table t_user_name;
--error 0, 942, 1051, 600
drop table t_require_info;
--error 0, 600
drop user jianhua_error cascade;
--error 0, 600
drop user jianhua cascade;
--error 0, 600
drop user jianhua_none cascade;
--error 0, 600
drop user jianhua_ssl cascade;
--error 0, 600
drop user jianhua_x509 cascade;
--error 0, 600
drop user jianhua_cipher cascade;
--error 0, 600
drop user jianhua_cipher2 cascade;
--error 0, 600
drop user jianhua_issuer cascade;
--error 0, 600
drop user jianhua_subject cascade;
--error 0, 600
drop user jianhua_ci cascade;
--error 0, 600
drop user jianhua_cs cascade;
--error 0, 600
drop user jianhua_is cascade;
--error 0, 600
drop user jianhua_cis cascade;
--error 0, 600
drop user jianhua_cipher_other cascade;
--enable_warnings

let $user_cnt=11;
create table t_user_name(id int, c1 varchar2(20));
insert into t_user_name values (1, 'JIANHUA');
insert into t_user_name values (2, 'JIANHUA_NONE');
insert into t_user_name values (3, 'JIANHUA_SSL');
insert into t_user_name values (4, 'JIANHUA_X509');
insert into t_user_name values (5, 'JIANHUA_CIPHER');
insert into t_user_name values (6, 'JIANHUA_ISSUER');
insert into t_user_name values (7, 'JIANHUA_SUBJECT');
insert into t_user_name values (8, 'JIANHUA_CI');
insert into t_user_name values (9, 'JIANHUA_CS');
insert into t_user_name values (10, 'JIANHUA_IS');
insert into t_user_name values (11, 'JIANHUA_CIS');

let $require_cnt=11;
create table t_require_info(id int, c1 varchar2(300));
insert into t_require_info values (1, '');
insert into t_require_info values (2, 'require none');
insert into t_require_info values (3, 'require ssl');
insert into t_require_info values (4, 'require x509');
insert into t_require_info values (5, 'require CIPHER ''DHE-RSA-AES128-GCM-SHA256''');
insert into t_require_info values (6, 'require ISSUER ''/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate''');
insert into t_require_info values (7, 'require SUBJECT ''/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate''');
insert into t_require_info values (8, 'require CIPHER ''DHE-RSA-AES128-GCM-SHA256'' and ISSUER ''/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate''');
insert into t_require_info values (9, 'require CIPHER ''DHE-RSA-AES128-GCM-SHA256''  SUBJECT ''/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate''');
insert into t_require_info values (10, 'require ISSUER ''/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate'' and SUBJECT ''/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate''');
insert into t_require_info values (11, 'require CIPHER ''DHE-RSA-AES128-GCM-SHA256'' ISSUER ''/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate'' and SUBJECT ''/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate''');

let $ssl_ca = --ssl-ca=wallet/ca.pem;
let $ssl_cert = --ssl-cert=wallet/client-cert.pem;
let $ssl_key = --ssl-key=wallet/client-key.pem;

let $ssl_ca_error = --ssl-ca=wallet/ca_error.pem;
let $ssl_cert_error = --ssl-cert=wallet/client-cert_error.pem;
let $ssl_key_error = --ssl-key=wallet/client-key_error.pem;

let $mysql_login_cmd = ./obclient --host=$OBMYSQL_MS0 --port=$OBMYSQL_PORT -p'123456' ;

########################  test for create column ###########################################

let $idx=1;
while ($idx <= $user_cnt)
{
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  let $require_info = query_get_value(select c1 AS C1 from t_require_info where id=$idx, C1, 1);
  --echo $user_name, $require_info;
  
  --disable_warnings
  --error 0, 600
  eval drop user '$user_name' cascade;
  sleep 2;
  --enable_warnings
  
  if ($idx==1)
  {
    eval create user '$user_name' IDENTIFIED BY 123456;
  }
  if ($idx > 1)
  {
    eval create user '$user_name' IDENTIFIED BY 123456 $require_info;
  }  
  eval grant select on *.* to '$user_name' with grant option;
  #select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_type), lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from mysql.user where user='$user_name';
  select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from SYS.ALL_VIRTUAL_USER_AGENT where user_name='$user_name';
  
  inc $idx;
}

--disable_warnings
--error 0, 600
eval drop user 'JIANHUA_ERROR' cascade;
sleep 2;
--enable_warnings

--error 900
create user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 require;
--error 900
create user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 require x5091;
--error 900
create user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 require x509 1;
--error 900
create user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 REQUIRE SUBJECT '/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate' , ISSUER '/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate';

########################  test for alter column ###########################################

let $idx=1;
while ($idx <= $user_cnt)
{
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  
  let $idxn=2;
  while ($idxn <= $user_cnt)
  {
    let $require_info = query_get_value(select c1 AS C1 from t_require_info where id=$idxn, C1, 1);
    
    eval alter user '$user_name' $require_info;

    #select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_type), lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from mysql.user where user='$user_name';
    select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from SYS.ALL_VIRTUAL_USER_AGENT where user_name='$user_name';
    
    inc $idxn;
  }  
  inc $idx;
}

--error 600,1918
alter user 'JIANHUA_ERROR'@'%' require ssl;
--error 600,1918
alter user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456;

--disable_warnings
--error 0, 600
drop user 'JIANHUA_ERROR' cascade;
sleep 2;
--enable_warnings

create user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 require none;
--error 900
alter user 'JIANHUA_ERROR'@'%' IDENTIFIED BY 123456 require ssl;
drop user 'JIANHUA_ERROR' cascade;



let $idx=2;
while ($idx <= $user_cnt)
{
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  let $require_info = query_get_value(select c1 AS C1 from t_require_info where id=$idx, C1, 1);
    
  eval alter user '$user_name' $require_info;

  #select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_type), lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from mysql.user where user='$user_name';
  select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from SYS.ALL_VIRTUAL_USER_AGENT where user_name='$user_name';

  inc $idx;
}

drop user 'JIANHUA' cascade;
create user 'JIANHUA' IDENTIFIED BY 123456;
eval grant select on *.* to 'JIANHUA' with grant option;

########################  test for check column ###########################################

connection obsys;
alter system set ssl_client_authentication = false;
sleep 20;
connection default;

--echo =====allow non-ssl user for non-ssl server

let $idx=1;
while ($idx <= 2)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  
  connect (con1,$OBMYSQL_MS0,$user_name@oracle,123456,,$OBMYSQL_PORT);
  select 'Con1 is alive' from dual;
  disconnect con1;
  
  inc $idx;
}

let $idx=3;
while ($idx <= $user_cnt)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);

  --disable_query_log
  --error ER_ACCESS_DENIED_ERROR
  connect (con1,$OBMYSQL_MS0,$user_name@oracle,123456,,$OBMYSQL_PORT);
  --enable_query_log
 
  inc $idx; 
}

alter system set ob_ssl_invited_common_names = 'MySQL_Server_5.7.24_Auto_Generated_Client_Certificate';
connection obsys;
alter system set ssl_client_authentication = True;
sleep 30;
connection default;

--echo ===== allow non-ssl user and user(ssl) for ssl server

let $idx=1;
while ($idx <= 3)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);

  --disable_query_log
  connect (con1,$OBMYSQL_MS0,$user_name@oracle,123456,,$OBMYSQL_PORT);
  select 'Con1 is alive' from dual;
  disconnect con1;
  --enable_query_log

  inc $idx;
}

let $idx=4;
while ($idx <= $user_cnt)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);

  --disable_query_log
  --error ER_ACCESS_DENIED_ERROR
  connect (con1,$OBMYSQL_MS0,$user_name@oracle,123456,,$OBMYSQL_PORT);
  --enable_query_log
 
  inc $idx; 
}


let $idx=1;
while ($idx <= $user_cnt)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  
  --exec $mysql_login_cmd -u$user_name@oracle $ssl_ca $ssl_cert $ssl_key -e "select 'Con1 is alive' from dual;" 
  
  inc $idx;
}


let $idx=1;
while ($idx <= $user_cnt)
{
  connection default;
  let $user_name = query_get_value(select c1 AS C1 from t_user_name where id=$idx, C1, 1);
  
  --error 1
  --exec $mysql_login_cmd -u$user_name@oracle $ssl_ca_error $ssl_cert $ssl_key -e "select 'Con1 is alive' from dual;" 
  --error 1
  --exec $mysql_login_cmd -u$user_name@oracle $ssl_ca $ssl_error $ssl_key -e "select 'Con1 is alive' from dual;" 
  --error 1
  --exec $mysql_login_cmd -u$user_name@oracle $ssl_ca $ssl $ssl_key_error -e "select 'Con1 is alive' from dual;" 
  
  inc $idx;
}

--echo check cipher

connection default;
--disable_warnings
--error 0, 600
eval drop user 'JIANHUA_CIPHER_OTHER' cascade;
--error 0, 600
eval drop user 'JIANHUA_CIPHER2' cascade;
sleep 2;
--enable_warnings

create user 'JIANHUA_CIPHER_OTHER' IDENTIFIED BY 123456 require CIPHER  'AES128-SHA';
grant select on *.* to JIANHUA_CIPHER_OTHER with grant option;
#select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_type), lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from mysql.user where user='JIANHUA_CIPHER_OTHER';
select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from SYS.ALL_VIRTUAL_USER_AGENT where user_name='JIANHUA_CIPHER_OTHER';

--error 1
--exec $mysql_login_cmd -uJIANHUA_CIPHER_OTHER@oracle $ssl_ca $ssl_cert $ssl_key -e "select 'Con1 is alive' from dual;" 
--error 1
--exec $mysql_login_cmd -uJIANHUA_CIPHER_OTHER@oracle $ssl_ca $ssl_cert $ssl_key --ssl-cipher=DHE-RSA-AES128-GCM-SHA256 -e "select 'Con1 is alive' from dual;" 

--exec $mysql_login_cmd -uJIANHUA_CIPHER_OTHER@oracle $ssl_ca $ssl_cert $ssl_key --ssl-cipher=AES128-SHA -e "select 'Con1 is alive' from dual;" 


create user 'JIANHUA_CIPHER2' IDENTIFIED BY 123456 require CIPHER  'DHE-RSA-AES128-GCM-SHA256:AES128-SHA';
grant select on *.* to JIANHUA_CIPHER2 with grant option;
#select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_type), lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from mysql.user where user='JIANHUA_CIPHER2';
select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, lengthb(ssl_cipher), lengthb(x509_issuer), lengthb(x509_subject) from SYS.ALL_VIRTUAL_USER_AGENT where user_name='JIANHUA_CIPHER2';

--error 1
--exec $mysql_login_cmd -uJIANHUA_CIPHER2@oracle $ssl_ca $ssl_cert $ssl_key -e "select 'Con1 is alive' from dual;" 


alter system set ob_ssl_invited_common_names = 'NONE';
connection obsys;
alter system set ssl_client_authentication = False;
connection default;


