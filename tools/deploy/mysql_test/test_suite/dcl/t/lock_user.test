--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:sean.yyj
#owner group: sql2

--disable_warnings
create user if not exists lock_user_1 identified by 'pass1';
--enable_warnings
grant create, drop, select, insert, update, delete on test.* to lock_user_1;
alter user lock_user_1 account lock;

--disable_query_log
--source mysql_test/include/check_schema_sync.inc
--error 3118 
connect (conn2,$OBMYSQL_MS0,lock_user_1,pass1,test,$OBMYSQL_PORT);
--enable_query_log
connection default;
alter user lock_user_1 account unlock;

--disable_query_log
--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,lock_user_1,pass1,test,$OBMYSQL_PORT);
--enable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1 values(1);
insert into t1 values(1);
insert into t1 values(1);
delete from t1;
drop table t1;

connection default;
drop user lock_user_1;

