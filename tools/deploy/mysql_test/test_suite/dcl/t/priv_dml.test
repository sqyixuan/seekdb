#owner:sean.yyj
#owner group: sql2
#tags : privilege
#用于DML语句权限测试
#INSERT SQL: PRIV_INSERT
#SELECT SQL: PRIV_SELECT
#UPDATRE SQL: PRIV_UDPATE | PRIV_SELECT
#DELETE SQL: PRIV_DELETE | PRIV_SELECT
#INSERT SQL: PRIV_INSERT
#REPLACE SQL: PRIV_INSERT | PRIV_DELETE
#INSERT ON DUPLICATE SQL: PRIV_INSERT | PRIV_UPDATE | PRIV_SELECT

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
--error 0,1396
drop user yzdml;
create user yzdml identified by '123';
drop table if exists t, t1;
--enable_warnings
create table t(c1 int primary key, c2 int);
create table t1(c1 int primary key, c2 int);
grant insert on t1 to yzdml;
--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,yzdml,123,test,$OBMYSQL_PORT);
connection conn2;
#no privilege on t, all dml denied.
--error 1142
select * from t;
--error 1142
select * from t for update;
--error 1142
insert into t values(1, 2);
--error 1142
replace into t values(1, 2);
--error 1142
update t set c1 = 2 where c1 = 1;
--error 1142
insert into t values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t where c1 = 1;

#has insert privilege on t1, can only do insert. replace need delete privlege.
--error 1142
select * from t1;
--error 1142
select * from t1 for update;
#accessful
insert into t1 values(1, 2);
--error 1142
replace into t1 values(1, 2);
--error 1142
update t1 set c1 = 2 where c1 = 1;
--error 1142
insert into t1 values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t1 where c1 = 1;


connection conn1;
#yzdml can do no dml to t;
grant update on t to yzdml;
#yzdml can do insert/replace on t1
grant insert, delete on t1 to yzdml;

connection conn2;
--error 1142
select * from t;
--error 1142
select * from t for update;
--error 1142
insert into t values(1, 2);
--error 1142
replace into t values(1, 2);
--error 1142
update t set c1 = 2 where c1 = 1;
--error 1142
insert into t values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t where c1 = 1;

--error 1142
select * from t1;
#accessful
insert into t1 values(2, 2);
replace into t1 values(1, 3);
--error 1142
update t1 set c1 = 2 where c1 = 1;
--error 1142
insert into t1 values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t1 where c1 = 1;

#insert into select, need select priv in sub-query
--error 1142
insert into t1 select * from t;


connection conn1;
#yzdml can do update,select to t;
grant update, select on t to yzdml;
#yzdml can do insert/replace on t1.
grant insert, delete,update on t1 to yzdml;

connection conn2;
select * from t;
--error 1142
insert into t values(1, 2);
--error 1142
replace into t values(1, 2);
update t set c1 = 2 where c1 = 1;
--error 1142
insert into t values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t where c1 = 1;

--error 1142
select * from t1;
#accessful
insert into t1 values(3, 4);
replace into t1 values(3, 5);
--error 1142
update t1 set c1 = 2 where c1 = 1;
--error 1062 #do not need select privilege
insert into t1 values(1, 2) on duplicate key update c1 = 2;
--error 1142
delete from t1 where c1 = 1;
#can do this now
insert into t1 select * from t;

connection conn1;
#yzdml has update,select,delete privs, can do update,select,delete to t;
grant delete on t to yzdml;
#yzdml has update,insert,delete,select privs, can do all dml on t1.
grant select on t1 to yzdml;

connection conn2;
select * from t;
--error 1142
insert into t values(1, 2);
--error 1142
replace into t values(1, 2);
update t set c1 = 2 where c1 = 1;
--error 1142
insert into t values(1, 2) on duplicate key update c1 = 2;
delete from t where c1 = 1;

select * from t1;
insert into t1 values(4, 5);
replace into t1 values(4, 6);
update t1 set c1 = 11 where c1 = 1;
insert into t1 values(1, 2) on duplicate key update c1 = 2;
delete from t1 where c1 = 1;

connection conn1;
#yzdml has update,delete privs, can do no things to t;
revoke select on t from yzdml;
#yzdml has update,insert,delete,select privs, can do all dml on t1.
grant select on t1 to yzdml;

--sleep 2
connection conn2;
--error 1142
update t1 set c1 = 2 where c1 in (select c1 from t);
--error 1142
delete from t1 where c1 in (select c1 from t);
--error 1142
insert into t1 select * from t;

connection conn1;
#yzdml has update,delete,select privs, can do update/delete to t;
grant select on t to yzdml;
#yzdml has update,insert,delete,select privs, can do all dml on t1.
grant select on t1 to yzdml;

connection conn2;
update t1 set c1 = 2 where c1 in (select c1 from t);
delete from t1 where c1 in (select c1 from t);
insert into t1 select * from t;

connection conn1;
revoke delete, update on t from yzdml;
connection conn2;
select * from t;
--error 1142
select * from t for update;

connection conn1;
grant delete on t to yzdml;
connection conn2;
select * from t;
select * from t for update;

connection conn1;
revoke delete on t from yzdml;
grant update on t to yzdml;
connection conn2;
select * from t;
select * from t for update;

connection conn1;
grant delete on t to yzdml;
connection conn2;
select * from t;
select * from t for update;

connection conn1;
drop table t,t1;
drop user yzdml;
