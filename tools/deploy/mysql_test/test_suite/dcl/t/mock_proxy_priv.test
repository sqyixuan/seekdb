# owner:zhuangyifeng.zyf
# owner group: sql1
# tags : privilege
# description: 测试 mock proxy 权限

--disable_warnings
drop user if exists u_proxied, u_proxy_1, u_proxy_2;
--enable_warnings

create user u_proxy_1 identified by '';
create user u_proxy_2 identified by '';
create user u_proxied identified by '';

# grant to/revoke from one user
grant proxy on u_proxied to u_proxy_1;
revoke proxy on u_proxied from u_proxy_1;

# grant to/revoke from multiple users
grant proxy on u_proxied to u_proxy_1, u_proxy_2;
revoke proxy on u_proxied from u_proxy_1, u_proxy_2;

# grant to/revoke from user with host
grant proxy on u_proxied@host0 to u_proxy_1@host0;
revoke proxy on u_proxied@host0 from u_proxy1@host0;
grant proxy on u_proxied to u_proxy_2@host1;
revoke proxy on u_proxied from u_proxy2@host1;
grant proxy on u_proxied@host0 to u_proxy1, u_proxy2@host1;
revoke proxy on u_proxied@host0 from u_proxy@host1, u_proxy1;

# grant/revoke proxy on user, not on db/table
--error 1064
grant proxy on *.* to u_proxy_1;
--error 1064
revoke proxy on *.* from u_proxy_1;

# no validation check for user(s) or grant privilege for now
# so the following queries would succeed because they are grammatically correct.
grant proxy on non_exist_object to non_exist_proxy_user;
revoke proxy on non_exist_object from non_exist_proxy_user;

drop user u_proxied, u_proxy_1, u_proxy_2;