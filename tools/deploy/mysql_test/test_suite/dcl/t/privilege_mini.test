--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:sean.yyj
#owner group: sql1
#tags: privilege

#test create grant revoke
#用于minitest所以没有复杂的测试,否则占用时间太长

#create user
--disable_abort_on_error
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn1;
--error 0,1396
drop user yangze;
--error 0,1396
drop user mianren;
--error 0,1396
drop user zhan1;
--error 0,1396
drop user zhan;
create user yangze identified by '123';
create user mianren identified by 'pass1';
create user zhan1 identified by password '*23AE809DDACAF96AF0FD78ED04B6A265E05AA257';
--error 1827
create user zhan identified by password '123';
#--error 1470
create user 'user_name_longer_than_16' identified by 'pass1', 'u12' identified by 'pass2';
drop user user_name_longer_than_16, u12;

#set password
set password for zhan1 = password('123');
set password for zhan1 = '123';
set password for zhan1 = '*23AE809DDACAF96AF0FD78ED04B6A265E05AA257';

#grant
grant all on *.* to mianren with grant option;
grant all on mysql.* to mianren with grant option;
grant select on mysql.user to mianren;
grant select on noexistdb.* to mianren;
--error 1146
grant select on mysql.noexisttable to mianren;
grant select, create on mysql.noexisttable to mianren;
--real_sleep 1
--sorted_result
show grants for mianren;
grant usage on *.* to zhan2 identified by password '*23AE809DDACAF96AF0FD78ED04B6A265E05AA257';
--error 1827
grant usage on *.* to zhan3 identified by password '123';

#revoke
revoke select on mysql.user from mianren;
revoke all on mysql.* from mianren;
--real_sleep 1
--sorted_result
show grants for mianren;
revoke all, grant option from mianren;
--real_sleep 1
--sorted_result
show grants for mianren;

#syntax error
--error 1064
revoke all privilege, from mianren;
--error 1064
revoke all , grant option on mysql.* from mianren;
--error 1064
grant all, select on *.* to mianren;

#privilege check
use test;
--disable_warnings
drop table if exists t_priv;
--enable_warnings
--disable_warnings
drop table if exists privilege_mini_table;
--enable_warnings
create table t_priv(c1 int primary key, c2 int);
create view t_view as select user from mysql.user where user = 'yangze';
grant select on t_view to yangze;
grant select on test.t_priv to yangze;
grant drop on test.t_priv to yangze;
grant create on `test%`.* to yangze;


--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,yangze,123,test,$OBMYSQL_PORT);
connection conn2;
select * from test.t_priv;
drop table test.t_priv;
--error 1142
select user from mysql.user;
select * from test.t_view;
--error 1044
use mysql;
use test;
--sorted_result
show grants;
--error 1142
show grants for admin;
show databases;
create table if not exists privilege_mini_table(c1 int primary key, c2 int);
connection conn2; 
create database test_1;
set password = password('');

connection conn1;
drop user yangze, mianren, zhan1, zhan2;
drop table test.privilege_mini_table;
drop view test.t_view;
drop database test_1;

--enable_abort_on_error
