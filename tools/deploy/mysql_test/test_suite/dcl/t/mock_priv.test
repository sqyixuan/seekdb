--error 0,1396
drop user linyi1;

create user linyi1;
show grants for linyi1;
select user, shutdown_priv, reload_priv from mysql.user where user = 'linyi1';
grant shutdown on *.* to linyi1;
grant reload on *.* to linyi1;

--error 1221
grant shutdown on test.* to linyi1;
--error 1221
grant reload on test.* to linyi1;

--error 1144
grant shutdown on test.t1 to linyi1;
--error 1144
grant reload on test.t1 to linyi1;

show grants for linyi1;
select user, shutdown_priv, reload_priv from mysql.user where user = 'linyi1';

--error 1221
revoke shutdown on test.* from linyi1;
--error 1221
revoke reload on test.* from linyi1;
--error 1144
revoke shutdown on test.t1 from linyi1;
--error 1144
revoke reload on test.t1 from linyi1;

revoke shutdown on *.* from linyi1;
show grants for linyi1;
select user, shutdown_priv, reload_priv from mysql.user where user = 'linyi1';

revoke reload on *.* from linyi1;
