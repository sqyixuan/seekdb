#owner:sean.yyj
#owner group: sql2
#tags : privilege
#用于VIEW相关权限测试
#CREATE VIEW SQL: PRIV CREATE VIEW,PRIV SELECT ON object.
#SHOW CREATE VIEW SQL: PRIV SHOW VIEW, PRIV SELECT ON VIEW

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
drop view if exists v;
drop database if exists test;
--enable_warnings
create database test;
create table test.t1(c1 int);
set sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
grant create view on test.* to yzview;

--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,yzview,,test,$OBMYSQL_PORT);
connection conn2;

--error 1142
create view test.v as select * from t1;

connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
grant select on test.t1 to yzview;

--sleep 2
connection conn2;
create view test.v as select * from t1;
--error 1142
show create view v;
--error 1142
show create table v;

connection conn1;
grant show view on test.v to yzview;

connection conn2;
--error 1142
show create view v;
--error 1142
show create table v;

connection conn1;
grant select on test.v to yzview;

connection conn2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create view v;
show create table v;

show grants for yzview;

connection conn1;
drop user yzview;
drop table test.t1;
drop view test.v;
