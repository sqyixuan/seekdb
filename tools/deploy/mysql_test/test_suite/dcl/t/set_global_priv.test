--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql2
#tags: privilege
#test 
#将SET GLOBAL权限从原来的SUPER缩小为Alter System，用户在mysql模式下，在拥有ALTER SYSTEM或SUPER权限时，
#可以执行SET GLOBAL.

connect(conn_root, $OBMYSQL_MS0, root,,,$OBMYSQL_PORT);
connection conn_root;

--error 0, 1396
drop user usr_test;

--echo #
--echo # Create user
--echo #
create user usr_test;
grant usage, select on *.* to usr_test;

disconnect conn_root;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_usr, $OBMYSQL_MS0, usr_test,,,$OBMYSQL_PORT);
connection conn_usr;

--echo #
--echo # set global without any privilege
--echo #
--error 1227
set global max_connections=200;

disconnect conn_usr;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_root, $OBMYSQL_MS0, root,,,$OBMYSQL_PORT);
connection conn_root;

grant alter system on *.* to usr_test;

disconnect conn_root;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_usr, $OBMYSQL_MS0, usr_test,,,$OBMYSQL_PORT);
connection conn_usr;

--echo #
--echo # set global with alter system
--echo #
set global max_connections=200;

disconnect conn_usr;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_root, $OBMYSQL_MS0, root,,,$OBMYSQL_PORT);
connection conn_root;

grant super on *.* to usr_test;

disconnect conn_root;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_usr, $OBMYSQL_MS0, usr_test,,,$OBMYSQL_PORT);
connection conn_usr;

--echo #
--echo # set global with alter system and super
--echo #
set global max_connections=200;

disconnect conn_usr;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_root, $OBMYSQL_MS0, root,,,$OBMYSQL_PORT);
connection conn_root;

revoke alter system on *.* from usr_test;

disconnect conn_root;
--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_usr, $OBMYSQL_MS0, usr_test,,,$OBMYSQL_PORT);
connection conn_usr;

--echo #
--echo # set global with super
--echo #
set global max_connections=200;

disconnect conn_usr;