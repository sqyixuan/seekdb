# owner: sean.yyj
# owner group: sql3
# tags: resolver
# test user privileges in mysql mode

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_warnings
connect(grantuser,$OBMYSQL_MS0,admin,admin,*NO-ONE*,$OBMYSQL_PORT);

--let $usernum=10
--let $dbnum=5
--let $tablenum=5

################create user#################
--let $count = 0
while($count < $usernum)
{
  --let $stmt=drop user u$count
  --error 0, 1396
  eval $stmt;
  --let $stmt=create user "u$count" identified by "passu$count"
  eval $stmt;
  inc $count;
}

################create db and table#################
--let $countdb = 0
while($countdb < $dbnum)
{
  --let $stmt=drop database if exists d$countdb
  eval $stmt;
  --let $stmt=create database d$countdb
  eval $stmt;
  --let $stmt=use d$countdb
  eval $stmt;

  --let $counttable=0
  while($counttable < $tablenum)
  {
    --let $stmt=create table t$counttable(c1 int, c2 int)
    eval $stmt;
    inc $counttable;
  }
  inc $countdb;
}

--enable_query_log
--enable_warnings

################grant privileges#################
##### u0 具有部分权限， u1 具有部分权限， u2 只有mysql的部分权限， u3 有mysql的select权限，u4具有user level所有权限，u9做特殊场景测试

--echo grant privileges
grant alter, create, create user, delete, drop, insert, update, select, index, create view, show view, show databases on *.* to u0 with grant option;

grant super, process, file, alter tenant, alter system, create resource pool, create resource unit, replication slave, replication client on *.* to u1;

grant insert, update on mysql.* to u2;

grant select on mysql.* to u3;

grant all privileges on *.* to u4;

connect(u0,$OBMYSQL_MS0,u0,passu0,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
connect(u1,$OBMYSQL_MS0,u1,passu1,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
connect(u2,$OBMYSQL_MS0,u2,passu2,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
connect(u3,$OBMYSQL_MS0,u3,passu3,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
connect(u4,$OBMYSQL_MS0,u4,passu4,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

################user privileges column check####################
show columns from information_schema.user_privileges;

################test user privileges#################
--echo user no privilege, output nothing
connect(u9,$OBMYSQL_MS0,u9,passu9,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

--echo user has 'mysql' other privileges, output nothing
connection grantuser;
grant insert, alter, update on mysql.* to u9;
connection u9;
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

--echo user has 'mysql' select privilege, output all table privilege, 并且立即生效
connection grantuser;
grant select on mysql.* to u9;
connection u9;
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

################ 断连接重连的原因是，session中user_level权限暂时不支持异步更新 ##########################

--echo user has user level other privilege, output nothing

connection grantuser;
revoke select on mysql.* from u9;
grant insert, alter, update on *.* to u9;
connection u9;

--echo !!! 此时 u9 的权限检查条件为false, 此时应该生成一个plan cache 1
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
disconnect u9;
connect(u9,$OBMYSQL_MS0,u9,passu9,*NO-ONE*,$OBMYSQL_PORT);

--echo !!! 此时 u9 的权限检查条件为false, 此时应该复用一个plan cache 1？？

--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

--echo user has user level select privilege, output all table privilege
connection grantuser;
grant select on *.* to u9;
connection u9;

--echo !!! 此时 u9 的权限没有更新，理论上检查条件为false, 此时应该复用plan cache 1

--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
disconnect u9;
connect(u9,$OBMYSQL_MS0,u9,passu9,*NO-ONE*,$OBMYSQL_PORT);

--echo !!! 此时 u9 的权限更新，理论上检查条件为true, 此时应该生成plan cache 2
--sorted_result
select * from information_schema.user_privileges WHERE GRANTEE IN (
  "'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
  "'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;

--disable_query_log
--disable_warnings

connection grantuser;

--let $countdb = 0
while($countdb < $dbnum)
{
  --let $stmt=drop database if exists d$countdb
  eval $stmt;
  inc $countdb;
}

--let $count = 0
while($count < $usernum)
{
  --let $stmt=drop user u$count
  eval $stmt;
  inc $count;
}
