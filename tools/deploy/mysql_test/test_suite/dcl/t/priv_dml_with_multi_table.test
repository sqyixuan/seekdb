#owner:sean.yyj
#owner group: sql1
#tags : privilege

--disable_warnings
--error 0, 1396
drop user u1;
--error 0, 1396
drop user u2;
--error 0, 1396
drop user u3;
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);

create user u1 identified by '123';
create user u2 identified by '123';
create user u3 identified by '123';
grant all on t1 to u1;
grant select on t2 to u1;
grant all on t1 to u2;
grant select on test.* to u3;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,u1,123,test,$OBMYSQL_PORT);
connection conn1;

--echo # u1 has enough privilege
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
delete t1 from t1 join t2 on t1.c1 = t2.c1;

connect (conn2,$OBMYSQL_MS0,u2,123,test,$OBMYSQL_PORT);
connection conn2;

--echo # u2 lack select privilege on t2
--error 1142
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
--error 1142
delete t1 from t1 join t2 on t1.c1 = t2.c1;

connect (conn3,$OBMYSQL_MS0,u3,123,test,$OBMYSQL_PORT);
connection conn3;

--echo # u3 lack dml privilege on t1
--error 1142
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
--error 1142
delete t1 from t1 join t2 on t1.c1 = t2.c1;

connection default;
drop table t1,t2;
drop user u1;
drop user u2;
drop user u3;
