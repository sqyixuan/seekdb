--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: sql3
# tags : privilege
# description: test case insensitive compare for db_name when connect
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--disable_query_log
--disable_warnings
--enable_warnings
#eval CREATE RESOURCE UNIT case_mode_uint MAX_CPU=1, MEMORY_SIZE='2G', LOG_DISK_SIZE='3G';
#eval CREATE RESOURCE POOL case_mode_pool UNIT='case_mode_uint', UNIT_NUM=1, ZONE_LIST=('$zone');
#CREATE TENANT tenant_case_mode0 REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('case_mode_pool'), collate = utf8mb4_bin set ob_tcp_invited_nodes='%', lower_case_table_names=0;i
--enable_query_log

--echo # ORIGIN_AND_SENSITIVE
let $__tenant_name__ = 'sys';
--sleep 3
--source mysql_test/include/get_tenant_server.inc
connect (conn_case_mode_sys0, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);
connection conn_case_mode_sys0;

show variables like 'lower_case_table_names';
--disable_warnings
create database if not exists Db_Test;
--enable_warnings
--error 0,1396
drop user u1;
create user u1 identified by '123';
grant select on Db_Test.* to u1;
show grants for u1;

--source mysql_test/include/check_schema_fast_sync.inc

--disable_query_log
--error 1045
connect (conn_u1_upper0,$TE_SERVER_IP,u1@tenant_case_mode0,123,DB_TEST,$TE_SERVER_PORT);
--error 1045
connect (conn_u1_lower0,$TE_SERVER_IP,u1@tenant_case_mode0,123,db_test,$TE_SERVER_PORT);
connect (conn_u1_mixed0,$TE_SERVER_IP,u1,123,Db_Test,$TE_SERVER_PORT);
--enable_query_log

--echo
--echo # LOWERCASE_AND_INSENSITIVE
connection sys;
#drop tenant tenant_case_mode0 force;
#CREATE TENANT tenant_case_mode1 REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('case_mode_pool'), collate = utf8mb4_bin set ob_tcp_invited_nodes='%', lower_case_table_names=1;
let $__tenant_name__ = 'sys';
--sleep 3
--source mysql_test/include/get_tenant_server.inc
connect (conn_case_mode_sys1, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);
connection conn_case_mode_sys1;

show variables like 'lower_case_table_names';
create database if not exists Db_Test;
--error 0,1396
drop user u1;
create user u1 identified by '123';
grant select on Db_Test.* to u1;
show grants for u1;

--source mysql_test/include/check_schema_fast_sync.inc

connect (conn_u1_upper1,$TE_SERVER_IP,u1,123,DB_TEST,$TE_SERVER_PORT);
connect (conn_u1_lower1,$TE_SERVER_IP,u1,123,db_test,$TE_SERVER_PORT);
connect (conn_u1_mixed1,$TE_SERVER_IP,u1,123,Db_Test,$TE_SERVER_PORT);

--echo
--echo # ORIGIN_AND_INSENSITIVE
connection sys;
#drop tenant tenant_case_mode1 force;
#CREATE TENANT tenant_case_mode2 REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('case_mode_pool'), collate = utf8mb4_bin set ob_tcp_invited_nodes='%', lower_case_table_names=2;
let $__tenant_name__ = 'sys';
--sleep 3
--source mysql_test/include/get_tenant_server.inc
connect (conn_case_mode_sys2, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);
connection conn_case_mode_sys2;

show variables like 'lower_case_table_names';
create database if not exists Db_Test;
--error 0,1396
drop user u1;
create user u1 identified by '123';
grant select on Db_Test.* to u1;

--source mysql_test/include/check_schema_fast_sync.inc
connection conn_case_mode_sys2;
show grants for u1;

connect (conn_u1_upper2,$TE_SERVER_IP,u1,123,DB_TEST,$TE_SERVER_PORT);
connect (conn_u1_lower2,$TE_SERVER_IP,u1,123,db_test,$TE_SERVER_PORT);
connect (conn_u1_mixed2,$TE_SERVER_IP,u1,123,Db_Test,$TE_SERVER_PORT);

--echo
--echo # clean up
connection sys;
#drop tenant tenant_case_mode2 force;
#drop resource pool case_mode_pool;
#drop resource unit case_mode_uint;
