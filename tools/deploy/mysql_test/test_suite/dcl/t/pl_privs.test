#owner:sean.yyj
#owner group: sql3
#tags : privilege
#desc : some test for pl priv

purge recyclebin;
--enable_sorted_result
--result_format 4
--disable_warnings
drop user if exists u1,u2,u3,u4;
--enable_warnings
--error 0, 1008
drop database routine_priv;
drop procedure if exists p1;
drop procedure if exists p2;
drop function if exists f1;
drop function if exists f2;
--enable_warnings

set ob_log_level='DEBUG';
SET ob_enable_show_trace='ON';

create database routine_priv;
use routine_priv;
create user u1 identified by '123';
create user u2 identified by '123';
create user u3 identified by '123';



delimiter //;
create procedure p1() begin select 1; end;//
create procedure p2() begin select 1; end;//
delimiter ;//
grant execute on procedure routine_priv.p1 to u1;
show grants for u1;
grant alter routine on procedure routine_priv.p1 to u2 with grant option;
show grants for u2;

call p1();

connect (u1_con,$OBMYSQL_MS0, u1, 123, routine_priv,$OBMYSQL_PORT);
connection u1_con;
call p1();

--error 1370
drop procedure p1;


connect (u2_con,$OBMYSQL_MS0, u2, 123, routine_priv,$OBMYSQL_PORT);
connection u2_con;
--error 1370
call p1();
drop procedure p1;

delimiter //;
--error 1370
create procedure p1() begin select 1; end;//
delimiter ;//

--error 1044
grant create routine on Routine_priv.* to u1;

--error 1370
grant alter routine on procedure routine_priv.P2 to u1;

connect (root_con,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,routine_priv,$OBMYSQL_PORT);
connection root_con;
delimiter //;
create procedure p1() begin select 1; end;//
delimiter ;//

grant create routine on routine_priv.* to u1;
grant alter routine on procedure P1 to u2;
select database_name, routine_name, routine_type, all_priv from oceanbase.__all_routine_privilege;
show grants for u1;
show grants for u2;

connection u2_con;
grant alter routine on procedure routine_Priv.p1 to u1;
--error 1370
grant execute on procedure p1 to u1;

#reconnect and reload db priv
disconnect u1_con;
connect (u1_con,$OBMYSQL_MS0, u1, 123, routine_priv,$OBMYSQL_PORT);
connection u1_con;
show grants for u1;
drop procedure p1;
delimiter //;
create procedure p1() begin select 1; end;//
delimiter ;//
call p1();
show grants for u1;

--error 1227
set global automatic_sp_privileges=0;

connection root_con;
set global automatic_sp_privileges=0;
drop procedure p2;
drop user u1;
create user u1 identified by '123';
grant create routine on routine_priv.* to u1;

disconnect u1_con;
connect (u1_con,$OBMYSQL_MS0, u1, 123, routine_priv,$OBMYSQL_PORT);
connection u1_con;
delimiter //;
create procedure p2() begin select 1; end;//
delimiter ;//
show grants for u1;

--error 1370
call p2();


#### TEST SECURITY: DEFINER AND ROVKER

disconnect root_con;
connect (root_con,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,routine_priv,$OBMYSQL_PORT);
connection root_con;
set global automatic_sp_privileges=1;
--disable_warnings
drop procedure if exists P1;
drop procedure if exists p2;
drop function if exists f1;
drop function if exists f2;
--enable_warnings
drop user u1;
drop user u2;
create user u1 identified by '123';
create user u2 identified by '123';

--disable_warnings
--error 0, 1051
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1 values(1), (2), (3);

delimiter //;
create definer='u1' procedure p1() begin select f1(); end; //
create definer='u2' function f1() returns int return (select max(c1) from t1); //
delimiter ;//

--error 1370
call p1();

grant execute on procedure p1 to u1;

--error 1370
call p1();

grant execute on function f1 to u1;
--error 1370
call p1();

grant execute on function f1 to u2;
--error 0,1142
call p1();

grant select on t1 to u2;
call p1();

grant create user on *.* to u2;
disconnect u2_con;
connect (u2_con,$OBMYSQL_MS0, u2, 123, routine_priv,$OBMYSQL_PORT);
connection u2_con;
--error 4006
drop user u1;

disconnect root_con;
connect (root_con,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,routine_priv,$OBMYSQL_PORT);
connection root_con;
show grants for u1;
show grants for u2;
drop user u1;
show warnings;
drop user u2;
show warnings;

drop procedure p1;
drop function f1;
drop database routine_priv;

create database routine_priv;
use routine_priv;
create user u1 identified by '123';
delimiter //;
create procedure p1() begin select 1; end;//
delimiter ;//
--error 1144
grant create routine on procedure p1 to u1;
--error 1144
revoke create routine on procedure p1 from u1;

grant all on procedure p1 to u1;
show grants for u1;
select database_name, table_name as routine_name, ddl_stmt_str from oceanbase.__all_ddl_operation  where ddl_stmt_str like 'GRANT%' order by gmt_create desc limit 1;
revoke all on procedure p1 from u1;
show grants for u1;
select database_name, table_name as routine_name, ddl_stmt_str from oceanbase.__all_ddl_operation  where ddl_stmt_str like 'REVOKE%' order by gmt_create desc limit 1;

grant all on procedure p1 to u1 with grant option;
show grants for u1;
select database_name, table_name as routine_name, ddl_stmt_str from oceanbase.__all_ddl_operation  where ddl_stmt_str like 'GRANT%' order by gmt_create desc limit 1;

revoke all on procedure p1 from u1;
show grants for u1;
select database_name, table_name as routine_name, ddl_stmt_str from oceanbase.__all_ddl_operation  where ddl_stmt_str like 'REVOKE%' order by gmt_create desc limit 1;

revoke grant option on procedure p1 from u1;

drop procedure p1;
delimiter //;
create procedure p1() begin select 1; end;//
delimiter ;//
show grants for admin;
revoke execute on procedure p1 from admin;
ALTER PROCEDURE  p1 SQL SECURITY DEFINER;
show grants for admin;

drop database routine_priv;
drop user u1;




set global _enable_mysql_pl_priv_check=on;
set global _enable_mysql_pl_priv_check=1;
set global _enable_mysql_pl_priv_check='on';

--error 1235
set global _enable_mysql_pl_priv_check=off;
--error 1235
set global _enable_mysql_pl_priv_check='off';
--error 1235
set global _enable_mysql_pl_priv_check=false;
--error 1235
set global _enable_mysql_pl_priv_check=true;
--error 1235
set global _enable_mysql_pl_priv_check=0;
--error 1231
set global _enable_mysql_pl_priv_check='1';
--error 1235
set global _enable_mysql_pl_priv_check=1-1;
--error 1235
set global _enable_mysql_pl_priv_check=0+1;
