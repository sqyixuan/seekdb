################## 4. sys租户下的其他用户没有super，也没有alter system 权限，可以执行alter system
connection conn1;
--error 0, 1396
drop user alter_u3;
create user alter_u3;
grant select on *.* to alter_u3;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_alter_u3,$OBMYSQL_MS0,alter_u3@sys,'',*NO-ONE*,$OBMYSQL_PORT);
--error 1227
alter system flush plan cache;
--error 1227
alter system flush sql plan;
--error 1227
alter system flush kvcache;

--error 1227
alter system report replica;

--error 1227
alter system recycle replica;

--error 1227
alter system clear merge error;

--error 1227
alter system cancel task '1';

--error 1227
alter system major freeze tenant = sys;
--error 1227
alter system major freeze tenant = all_user;
--error 1227
alter system major freeze tenant = all_meta;

--error 1227
alter system checkpoint;

--error 1227
alter system minor freeze tenant = sys;
--error 1227
alter system minor freeze tenant = all_user;
--error 1227
alter system minor freeze tenant = all_meta;

--error 1227
eval alter system start server '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 1227
eval alter system add zone 'zone2' region '$curr_region';

--error 1227
alter system start zone 'zone2';

--error 1227
eval alter system alter zone 'zone2' set region='$curr_region';

--error 1227
alter system refresh schema;

--error 1227
alter system set_tp tp_no = 53;

--error 1227
alter system clear location cache;

--error 1227
alter system remove balance task zone ='zone1';


--error 1227
alter system reload unit;

--error 1227
alter system reload server;

--error 1227
alter system reload zone;

--error 1227
eval alter system migrate unit 1 destination '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 1227
alter system cancel migrate unit 1;

--error 1227
alter system upgrade virtual schema;

--error 1227
alter system run job 'adsf';

--error 1227
alter system end upgrade;


--error 1227
eval alter system set disk valid server '$OBMYSQL_MS0:$OBMYSQL_PORT';

ALTER SYSTEM CHANGE TENANT sys;

--error 1227
alter system archivelog;

--error 1227
alter system noarchivelog;

--error 1227
alter system backup database;

--error 1227
alter system backup incremental database;

--error 1227
alter system validate database;

--error 1227, 9046
alter system validate backupset 34;

################## 5. alter tenant ###################################
####### 5.1 sys租户下的root用户可以执行alter tenant
connection conn1;
--error 0, 4179
alter tenant sys primary_zone = 'zone1';

####### 5.2 sys租户下的其他用户，有super权限可以执行alter tenant
connection conn_alter_u1;

--error 0, 4179
alter tenant sys primary_zone = 'zone1';

####### 5.3 sys租户下的其他用户，有alter tenant权限可以执行alter tenant
connection conn1;
grant alter tenant on *.* to alter_u2;

--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_alter_u2;
connect (conn_alter_u2,$OBMYSQL_MS0,alter_u2@sys,'',*NO-ONE*,$OBMYSQL_PORT);
--error 0, 4179
alter tenant sys primary_zone = 'zone1';

####### 5.4 sys租户下的其他用户，没有super，也没有alter tenant权限，不可以执行alter tenant
connection conn_alter_u3;
--error 1227
alter tenant sys primary_zone = 'zone1';

################## 6. create/alter/drop resource unit ###################################

####### 6.1. sys租户下的root用户可以执行create/alter/drop resource unit
connection conn1;
--error 0, 4650
drop resource pool alter_pool1;
--error 0, 4648
drop resource unit unit1;
create resource unit unit1 max_cpu 1, memory_size '1G';
alter resource unit unit1 max_cpu 2;
drop resource unit unit1;

######## 6.2 sys租户下的其他用户，有super权限可以执行create/alter/drop resource unit

connection conn_alter_u1;
create resource unit unit1 max_cpu 1, memory_size '1G';
alter resource unit unit1 max_cpu 2;
drop resource unit unit1;

######## 6.3 sys租户下的其他用户，有alter tenant权限可以执行create/alter/drop resource unit
connection conn1;
grant create resource unit on *.* to alter_u2;

--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_alter_u2;
connect (conn_alter_u2,$OBMYSQL_MS0,alter_u2@sys,'',*NO-ONE*,$OBMYSQL_PORT);

create resource unit unit1 max_cpu 1, memory_size '1G';
alter resource unit unit1 max_cpu 2;
drop resource unit unit1;

######## 6.4 sys租户下的其他用户，没有super，也没有alter tenant权限，不可以执行create/alter/drop resource unit
connection conn1;
create resource unit unit1 max_cpu 1, memory_size '1G';

connection conn_alter_u3;
--error 1227
create resource unit unit2 max_cpu 1, memory_size '1G';
--error 1227
alter resource unit unit1 max_cpu 2;
--error 1227
drop resource unit unit1;

################## 7. create/alter/drop resource pool ###################################

######## 7.1 sys租户下的root用户可以执行create/alter/drop resource pool
connection conn1;

--error 0, 4648
drop resource unit unit2;

create resource unit unit2 max_cpu 1, memory_size '1G';

--error 0, 4624
create resource pool alter_pool1 unit = 'unit1', unit_num = 1, zone_list=('zone1'); 

--error 0, 4650
alter resource pool alter_pool1 unit = 'unit2';

--error 0, 4650
drop resource pool alter_pool1;

######## 7.2 sys租户下的其他用户，有super权限可以执行create/alter/drop resource pool
connection conn_alter_u1;

--error 0, 4624
create resource pool alter_pool1 unit = 'unit1', unit_num = 1, zone_list=('zone1'); 

--error 0, 4650
alter resource pool alter_pool1 unit = 'unit2';

--error 0, 4650
drop resource pool alter_pool1;

######## 7.3 sys租户下的其他用户，有alter tenant权限可以执行create/alter/drop resource pool
connection conn1;
grant create resource pool on *.* to alter_u2;

--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_alter_u2;
connect (conn_alter_u2,$OBMYSQL_MS0,alter_u2@sys,'',*NO-ONE*,$OBMYSQL_PORT);

--error 0, 4624
create resource pool alter_pool1 unit = 'unit1', unit_num = 1, zone_list=('zone1'); 

--error 0, 4650
alter resource pool alter_pool1 unit = 'unit2';

--error 0, 4650
drop resource pool alter_pool1;

######## 7.4 sys租户下的其他用户，没有super，也没有alter tenant权限，不可以执行create/alter/drop resource pool
connection conn1;
--error 0, 4624
create resource pool alter_pool1 unit = 'unit1', unit_num = 1, zone_list=('zone1'); 

connection conn_alter_u3;

--error 1227
create resource pool alter_pool2 unit = 'unit1', unit_num = 1, zone_list=('zone1'); 
--error 1227
alter resource pool alter_pool1 unit = 'unit2';
--error 1227
drop resource pool alter_pool1;



################## 8. purge recyclebin ###################################

######## 8.1 sys租户下的，有drop的权限，可以执行purge recyclebin
connection conn1;

purge recyclebin;

######## 8.2 sys租户下的，无drop的权限，不能执行purge recyclebin
connection conn_alter_u1;
--error 1227
purge recyclebin;

######## 8.3 sys租户下的，授予drop用户级权限，能执行purge recyclebin
connection conn1;
grant drop on *.* to alter_u1;

--source mysql_test/include/check_schema_fast_sync.inc
disconnect conn_alter_u1;
connect (conn_alter_u1,$OBMYSQL_MS0,alter_u1@sys,'',*NO-ONE*,$OBMYSQL_PORT);

purge recyclebin;

connection conn1;
--error 0, 4650
drop resource pool alter_pool1;
drop resource unit unit1;
drop resource unit unit2;

use test;
drop table alter_system_table1;
drop user alter_u1;
drop user alter_u2;
drop user alter_u3;
--enable_warnings


