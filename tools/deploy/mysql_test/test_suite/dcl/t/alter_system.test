--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:sean.yyj
#owner group: sql
#tags: privilege

connect (conn1,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

################## 1. sys租户下的root用户可以执行alter system
use test;
--disable_warnings
drop table if exists alter_system_table1;
create table alter_system_table1(c1 int);
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='alter_system_table1', table_id, 1);
alter system flush plan cache;
alter system flush sql plan;
alter system flush kvcache;

let $inner_port = $OBMYSQL_PORT;
dec $inner_port;
let $curr_region = query_get_value(select region from oceanbase.dba_ob_zones, region, 1);

--disable_query_log

alter system report replica;

alter system recycle replica;

alter system clear merge error;

--error 0, 1210
alter system cancel task '1';

--error 0, 4217
alter system major freeze tenant = sys;
--error 0, 4217
alter system major freeze tenant = all_user;
--error 0, 4217
alter system major freeze tenant = all_meta;

--error 0, 4217, 4014, 4012
alter system checkpoint;

--error 0, 4263
alter system minor freeze tenant = sys;
--error 0, 4263
alter system minor freeze tenant = all_user;
--error 0, 4263
alter system minor freeze tenant = all_meta;

--error 0, 1210, 4630
eval alter system start server '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 4017
eval alter system add zone 'zone2' region '$curr_region';

--error 0, 4633
alter system start zone 'zone2';

eval alter system alter zone 'zone2' set region='$curr_region';

--error 0, 4023
alter system refresh schema;

alter system set_tp tp_no = 53;

--error 0, 4077
alter system clear location cache;

alter system remove balance task zone ='zone1';

alter system reload unit;

alter system reload server;

alter system reload zone;

--error 0, 1210, 4018, 1235
eval alter system migrate unit 1 destination '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 4016
alter system cancel migrate unit 1;

--error 0, 4012
alter system upgrade virtual schema;

--error 0, 1210
alter system run job 'adsf';

alter system end upgrade;


--error 0, 1210, 4012, 4018
eval alter system set disk valid server '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 5160
ALTER SYSTEM CHANGE TENANT sys;

--error 0, 9026
alter system archivelog;

--error 0, 9026, 9024
alter system noarchivelog;

--error 0, 9032, 4023, 9040
alter system backup database;

--error 0, 9032, 4023, 9040
alter system backup incremental database;

--error 0, 1235, 9026
alter system validate database;

--error 0, 1235, 9026, 9046
alter system validate backupset 34;

################## 2. sys租户下的其他用户有super权限，可以执行alter system
--error 0, 1396
drop user alter_u1;
create user alter_u1;
grant super on *.* to alter_u1;

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_alter_u1,$OBMYSQL_MS0,alter_u1@sys,'',*NO-ONE*,$OBMYSQL_PORT);
alter system flush plan cache;
alter system flush sql plan;
alter system flush kvcache;

alter system report replica;

