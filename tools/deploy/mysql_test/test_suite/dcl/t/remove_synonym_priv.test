# owner: sean.yyj
# owner group: SQL1
# description: remove the create synonym priv in mysql mode

--disable_warnings
drop user if exists u1,u2;
--enable_warnings


create user u1 identified by '123';
grant alter, create, create user, delete, drop, insert, update, select, index, create view, show view, show databases, super, process on *.* to 'u1' with grant option;
create user u2 identified by '123';

--source mysql_test/include/check_schema_fast_sync.inc
connect (conn_u1,$OBMYSQL_MS0,u1,123,*NO-ONE*,$OBMYSQL_PORT);
--error 1227
grant all privileges on *.* to u2;

connection default;
drop user u1,u2;