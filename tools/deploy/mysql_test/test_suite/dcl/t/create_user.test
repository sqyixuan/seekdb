--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql2
#description: todo
#tags: dcl

--disable_warnings
#--error 0,1396

drop user if exists u1,u2,u3,u4;
--enable_warnings
--disable_warnings
connect (jx_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection jx_obsys;

--disable_query_log
#call oceanbase.drop_tenant_force('tenant');
#call oceanbase.create_mysql_tenant_1c2g('tenant');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

connection default;
drop table if exists t1,t2,t3,t4;
--enable_warnings

connection jx_obsys;
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc

connect (conn1,$TE_SERVER_IP,root,,test,$TE_SERVER_PORT);
connection conn1;

create user 'u1' identified by 'pass1', 'u2' identified by 'pass2', 'u3' identified by 'pass3', 'u4' identified by 'pass4';
# wait ms to get newest privilege information
grant select on *.* to u1 with grant option;
--source mysql_test/include/check_schema_sync.inc
connect (conn2,$TE_SERVER_IP,u1,pass1,test,$TE_SERVER_PORT);

connection conn2;
--echo no privilege
--error 1227
create user 'u11' identified by 'pass1', 'u12' identified by 'pass2', 'u13' identified by 'pass3', 'u14' identified by 'pass4';
--error 1227
create user 'u15' identified by 'pass1', 'u12' identified by 'pass2';

--error 1227
drop user 'u3','u4';

connection conn1;

drop user 'u1';
--echo drop user failed
--error 1396
drop user 'u1';


--echo  user exists
--error 1396
create user 'u1' identified by 'pass1', 'u2' identified by 'pass2', 'u3' identified by 'pass3', 'u4' identified by 'pass4';
drop user 'u1', 'u2', 'u3', 'u4';

create user 'create' identified by 'pass1';
create user 'password' identified by 'pass1';
create user 'username' identified by 'pass1';
create user 'status' identified by 'pass1';
drop user 'create', 'password', 'username', 'status';


--echo password must not be empty
#--error 5051
create user 'u21' identified by '';
drop user 'u21';

###verify user with hostname from syntax level
connection conn1;
--disable_warnings
drop user if exists 'user1'@'localhost','user1'@'%';
drop user if exists 'user2'@'localhost','user2'@'%';
drop user if exists 'u1'@'h1','u2'@'h2','u2'@h22,'create'@h_create,'password'@'h_passwd','username'@'h_userName','status' @'h_status',`create`,'destroy';
--enable_warnings

create user 'u1'@'h1' identified by 'pass1', 'u2'@'h2' identified by 'pass2';
# wait ms to get newest privilege information
grant select on *.* to u1@'h1' with grant option;
 
connection conn2;
--echo no privilege
--error 1133
create user 'u11'@h11 identified by 'pass1';
 
connection conn1;
 
drop user 'u1'@h1;
--echo drop user failed
--error 1396
drop user 'u1'@h2; # Ignore hostname
 
--echo user exists even different hostnames
create user 'u2'@h22 identified by 'pass2';
--error 1396
drop user 'u2'@h33;
 
create user 'create'@h_create identified by 'pass1';
create user 'password'@'h_passwd' identified by 'pass1';
create user 'username'@'h_userName' identified by 'pass1';
create user 'status' @'h_status' identified by 'pass1';
--error 1396
drop user 'create'@h1, 'password' @h2, 'username'@h3, 'status' @h4;

--echo test if user not exists
create user if not exists 'create' identified by 'pass1';
create user if not exists 'create' identified by 'pass1';
--error 1396
create user 'create' identified by 'pass1';
create user if not exists 'create' identified by 'pass1', 'destroy' identified by 'pass1';
create user if not exists 'create' identified by 'pass1', 'destroy' identified by 'pass1';
drop user 'create';

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
--enable_query_log

connection default;
--error 0,1396
drop user u1,u2;
--error 1064
create user u1 identified with by 'test';
--error 1524
create user u1 identified with 'aaa' by 'test';
--error 1524
create user u1 identified with aaa by 'test';
create user u1 identified with 'mysql_native_password' by 'test';
create user u2 identified with mysql_native_password by 'test';

--error 1064
alter user u1 identified with by 'test';
--error 1524
alter user u1 identified with aaa by 'test';
--error 1524
alter user u1 identified with 'aaa' by 'test';
alter user u1 identified with 'mysql_native_password' by 'test';
alter user u2 identified with mysql_native_password by 'test';

--error 1064
grant select on *.* to u1 identified with by 'test';
--error 1524
grant select on *.* to u1 identified with aaa by 'test';
--error 1524
grant select on *.* to u1 identified with 'aaa' by 'test';
grant select on *.* to u1 identified with 'mysql_native_password' by 'test';
grant select on *.* to u2 identified with mysql_native_password by 'test';

drop user u1,u2;
--echo drop user failed
--error 1396
drop user u1;
--echo drop user failed
--error 1396
drop user u1,u2;

# not report error
drop user if exists u1;
# not report error
drop user if exists u1,u2;

create user u1 identified with 'mysql_native_password' by 'test';
drop user if exists u1,u2;

# delete correct
create user u1 identified with 'mysql_native_password' by 'test';
drop user if exists u1;

--result_format 4

--disable_warnings
drop user if exists 'user1'@'localhost','user1'@'%';
--enable_warnings
CREATE USER 'user1'@'localhost' IDENTIFIED WITH mysql_native_password AS '*AABBCCDDEEFF00112233445566778899AABBCCDD';
SELECT HOST,USER,PLUGIN,PASSWORD FROM MYSQL.USER WHERE USER = 'USER1';

--disable_warnings
drop user if exists 'user2'@'localhost','user2'@'%';
--enable_warnings
CREATE USER 'user2'@'localhost' IDENTIFIED WITH mysql_native_password AS '*AABBCCDDEEFF00112233445566778899AABBCCDD';
SELECT HOST,USER,PLUGIN,PASSWORD FROM MYSQL.USER WHERE USER = 'user2';

