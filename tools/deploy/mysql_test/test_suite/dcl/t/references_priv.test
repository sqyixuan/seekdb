#owner: linyi.cl
#owner group: sql3
#description: mock shutdown and reload priv
#tags: dcl

--disable_warnings
drop user if exists linyi;
--enable_warnings

create user linyi;
grant create, drop, alter on *.* to linyi;
show grants for linyi;
select user, references_priv from mysql.user where user = 'linyi';

connect(conn_linyi1, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi1;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(c1 int primary key);
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));

--result_format 4

--echo ## user level
connection default;
grant references on *.* to 'linyi'@'%';
show grants for 'linyi'@'%';
select user, references_priv from mysql.user where user = 'linyi';

connect(conn_linyi2, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi2;
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
alter table t2 add foreign key f1 (c1) references t1(c1);

connection default;
revoke references on *.* from 'linyi'@'%';
show grants for 'linyi'@'%';
select user, references_priv from mysql.user where user = 'linyi';

connect(conn_linyi3, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi3;
--error 1142
alter table t2 add foreign key f1 (c1) references t1(c1);
drop table t2;
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));


--echo ## db level
connection default;
grant references on test.* to 'linyi'@'%';
show grants for 'linyi'@'%';
select user, db, references_priv from mysql.db where user = 'linyi' and db = 'test';

connect(conn_linyi4, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi4;
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
alter table t2 add foreign key f1 (c1) references t1(c1);

connection default;
revoke references on test.* from 'linyi'@'%';
show grants for 'linyi'@'%';
select user, db, references_priv from mysql.db where user = 'linyi' and db = 'test';

connect(conn_linyi5, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi5;
--error 1142
alter table t2 add foreign key f1 (c1) references t1(c1);
drop table t2;
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));


--echo ## table level
connection default;
grant references on test.t1 to 'linyi'@'%';
show grants for 'linyi'@'%';

connect(conn_linyi6, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi6;
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
alter table t2 add foreign key f1 (c1) references t1(c1);

connection default;
revoke references on test.t1 from 'linyi'@'%';
show grants for 'linyi'@'%';

connect(conn_linyi7, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi7;
--error 1142
alter table t2 add foreign key f1 (c1) references t1(c1);
drop table t2;
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));


--echo ## column level
connection default;
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
grant references(c1) on test.t1 to 'linyi'@'%';
show grants for 'linyi'@'%';
select table_name, column_name, column_priv from mysql.columns_priv where user = 'linyi' and db = 'test' and table_name = 't1';

connect(conn_linyi8, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi8;
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
--error 1142
alter table t2 add foreign key f1 (c1) references t1(c1);

connection default;
revoke references(c1) on test.t1 from 'linyi'@'%';
show grants for 'linyi'@'%';
select table_name, column_name, column_priv from mysql.columns_priv where user = 'linyi' and db = 'test' and table_name = 't1';

connect(conn_linyi9, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi9;
--error 1142
create table t2(c1 int primary key, c2 int, foreign key (c2) references t1 (c1));
--error 1142
alter table t2 add foreign key f1 (c1) references t1(c1);


connection default;
grant references on test.t1 to 'linyi'@'%';
grant references(c1) on test.t1 to 'linyi'@'%';
show grants for 'linyi'@'%';

revoke references on test.t1 from 'linyi'@'%';
show grants for 'linyi'@'%';

drop table t2,t1;
drop user linyi;