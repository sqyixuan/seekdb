# owner: sean.yyj
# owner group: SQL3
# tags: privilege
# description: test database read only

--result_format 4
--disable_warnings

--error 0,1051
drop table t1;
--error 0,1008
drop database db1;
--error 0,1396
drop user u1;

--enable_warnings

create table t1 (c1 int, c2 int);
insert into t1 values(1,1);
select * from t1;

create database db1;

sleep 5;

connect (admin_db1,$OBMYSQL_MS0,admin,admin,db1,$OBMYSQL_PORT);
create table t1 (c1 int, c2 int);
insert into t1 values(2,2);
select * from t1;

connection default;
create user u1 identified by '123';
grant select, insert, update on test.t1 to u1;
grant select, insert, update on db1.t1 to u1;

alter database test read only;
select * from test.t1;
# admin has super privilege, allow to insert read only database
insert into test.t1 values(3,3);
insert into db1.t1 (c1, c2) select c1, c2 from test.t1;

connect (u1_db1,$OBMYSQL_MS0,u1,123,db1,$OBMYSQL_PORT);
select * from test.t1;

--disable_warnings
--error 5234
insert into test.t1 values(4,4);
--enable_warnings

insert into db1.t1 (c1, c2) select c1, c2 from test.t1;
select * from db1.t1;

connection default;
drop table t1;
drop database db1;
drop user u1;
