# owner: sean.yyj
# owner group: SQL3
# description: test privilege of show database, show create database, show tables, show create table, show index, show columns

--disable_abort_on_error
--disable_query_log
--disable_warnings

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
drop database if exists db1;
drop database if exists db2;
--error 0, 1396
drop user db1_u1;
--error 0, 1396
drop user db1_u2;
--error 0, 1396
drop user db1_u3;
--error 0, 1396
drop user db1_u4;
--enable_warnings
--enable_query_log

## create table in db1, db2;
create database db1;
create database db2;
create table db1.db1_t1(c1 varchar(10) primary key, c2 varchar(10), c3 int);
create table db1.db1_t2(c1 varchar(10) primary key, c2 varchar(10), c3 int);
create table db2.db2_t1(c1 varchar(10) primary key, c2 varchar(10), c3 int);

## create user
## db1_u1, single table privilege
create user db1_u1 identified by '123';
## db1_u2, db privilege
create user db1_u2 identified by '123';
## db1_u3, global privilege
create user db1_u3 identified by '123';
create user db1_u4 identified by '123';

## select
grant select on db1.db1_t1 to db1_u1;
grant select on db1.* to db1_u2;
grant select on *.* to db1_u3;
grant show databases on *.* to db1_u4;

connect (db1_u1,$OBMYSQL_MS0,db1_u1,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u2,$OBMYSQL_MS0,db1_u2,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u3,$OBMYSQL_MS0,db1_u3,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

## insert
connection sys;
revoke select on db1.db1_t1 from db1_u1;
revoke select on db1.* from db1_u2;
revoke select on *.* from db1_u3;
grant insert on db1.db1_t1 to db1_u1;
grant insert on db1.* to db1_u2;
grant insert on *.* to db1_u3;

disconnect db1_u1;
disconnect db1_u2;
disconnect db1_u3;

connect (db1_u1,$OBMYSQL_MS0,db1_u1,123,*NO-ONE*,$OBMYSQL_PORT);
show grants;
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u2,$OBMYSQL_MS0,db1_u2,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u3,$OBMYSQL_MS0,db1_u3,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

## create
connection sys;
revoke insert on db1.db1_t1 from db1_u1;
revoke insert on db1.* from db1_u2;
revoke insert on *.* from db1_u3;
grant create on db1.db1_t1 to db1_u1;
grant create on db1.* to db1_u2;
grant create on *.* to db1_u3;

disconnect db1_u1;
disconnect db1_u2;
disconnect db1_u3;

connect (db1_u1,$OBMYSQL_MS0,db1_u1,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u2,$OBMYSQL_MS0,db1_u2,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u3,$OBMYSQL_MS0,db1_u3,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

## alter
connection sys;
revoke create on db1.db1_t1 from db1_u1;
revoke create on db1.* from db1_u2;
revoke create on *.* from db1_u3;
grant alter on db1.db1_t1 to db1_u1;
grant alter on db1.* to db1_u2;
grant alter on *.* to db1_u3;

disconnect db1_u1;
disconnect db1_u2;
disconnect db1_u3;

connect (db1_u1,$OBMYSQL_MS0,db1_u1,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u2,$OBMYSQL_MS0,db1_u2,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u3,$OBMYSQL_MS0,db1_u3,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
show create database db1;
show create database db2;
show tables from db1;
show tables from db2;
show create table db1.db1_t1;
show create table db1.db1_t2;
show create table db2.db2_t1;
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;
show columns from db1.db1_t1;
show columns from db1.db1_t2;
show columns from db2.db2_t1;

connect (db1_u4,$OBMYSQL_MS0,db1_u4,123,*NO-ONE*,$OBMYSQL_PORT);
--sorted_result
show databases;
use oceanbase;
--enable_warnings
## index
connection sys;
revoke alter on db1.db1_t1 from db1_u1;
revoke alter on db1.* from db1_u2;
revoke alter on *.* from db1_u3;
grant index on db1.db1_t1 to db1_u1;
grant index on db1.* to db1_u2;
grant index on *.* to db1_u3;

disconnect db1_u1;
disconnect db1_u2;
disconnect db1_u3;
disconnect db1_u4;

connect (db1_u1,$OBMYSQL_MS0,db1_u1,123,*NO-ONE*,$OBMYSQL_PORT);
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;

connect (db1_u2,$OBMYSQL_MS0,db1_u2,123,*NO-ONE*,$OBMYSQL_PORT);
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;

connect (db1_u3,$OBMYSQL_MS0,db1_u3,123,*NO-ONE*,$OBMYSQL_PORT);
show index from db1.db1_t1;
show index from db1.db1_t2;
show index from db2.db2_t1;

--disable_query_log
--disable_warnings
connection sys;
drop user db1_u1,db1_u2,db1_u3,db1_u4;
drop database if exists db1;
drop database if exists db2;