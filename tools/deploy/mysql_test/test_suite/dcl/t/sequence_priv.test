#description: sequence priv
#tags: dcl

--error 0,1396
drop user linyi1;
--disable_warnings
drop sequence if exists s1;
drop database if exists db1;
--enable_warnings

create user linyi1;
grant select on *.* to linyi1;
connect(conn_linyi1, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi1;

--error 1044
create sequence s1;
--error 1044
alter sequence s1 maxvalue 10;
--error 1044
drop sequence s1;

connection default;
grant create on test.* to linyi1;

create database db1;
connect(conn_linyi2, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi2;

create sequence s1;
--error 1044
alter sequence s1 maxvalue 10;
--error 1044
drop sequence s1;

use db1;
--error 1044
create sequence s1;

connection default;
grant alter on test.* to linyi1;
grant drop on test.* to linyi1;

connect(conn_linyi3, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi3;

use db1;
--error 1044
alter sequence s1 maxvalue 10;
--error 1044
drop sequence s1;

use test;
alter sequence s1 maxvalue 10;
drop sequence s1;

connection default;
grant create on *.* to linyi1;
grant alter on *.* to linyi1;
grant drop on *.* to linyi1;

connect(conn_linyi4, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi4;

use db1;
create sequence s1;
alter sequence s1 maxvalue 10;
drop sequence s1;

connection default;
drop user linyi1;
