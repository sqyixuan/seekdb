#issue 54202194
--disable_warnings
--error 0, 1396
drop user U1;
--error 0, 1396
drop user U2;
--enable_warnings

create user U1;
create user U2;

--source mysql_test/include/check_schema_fast_sync.inc
connection default;
connect(conn1,$OBMYSQL_MS0,U1,,*NO-ONE*,$OBMYSQL_PORT);
show grants;
show grants for U1;

connection default;
grant select on mysql.user to U1;

connection conn1;
show grants;
#show grants for admin;

connection default;
drop user U1,U2;

#issue 54295946

connection default;
create user U1,U2;

--source mysql_test/include/check_schema_fast_sync.inc

connect (conn2,$OBMYSQL_MS0,U1,,*NO-ONE*,$OBMYSQL_PORT);
--error 1227
revoke all, grant option from U2;
connection default;
grant create user on *.* to U1;

connect (conn3,$OBMYSQL_MS0,U1,,*NO-ONE*,$OBMYSQL_PORT);
revoke all, grant option from U2;

connection default;
revoke create user on *.* from U1;
grant update on mysql.* to U1;

connect (conn4,$OBMYSQL_MS0,U1,,*NO-ONE*,$OBMYSQL_PORT);
revoke all, grant option from U2;

connection default;
drop user U1,U2;


