connect (sys,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection default;
create user u1 identified by 123;
create user u2 identified by 123;
create user u3 identified by 123;
create user u4 identified by 123;
create role r1;
create role r2;
create table t1(c1 int);
alter user u1 grant connect through u2;
select * from sys.proxy_users;
connection sys;
select user_name, flags from oceanbase.__all_virtual_user where user_name in ('U1', 'U2', 'U3', 'U4');
connection default;

--error 1924
alter user u1 grant connect through u2 with role r1;

grant r1, r2 to u1;

alter user u1 grant connect through u2 with role r1;
select * from sys.proxy_users;
connection sys;
select user_name, flags from oceanbase.__all_virtual_user where user_name in ('U1', 'U2', 'U3', 'U4');
connection default;

alter user u1 grant connect through u2 with no role;
select * from sys.proxy_users;


alter user u1 grant connect through u2 with role all except r1,r2;
select * from sys.proxy_users;


alter user u1 revoke connect through u2;
select * from sys.proxy_users;
connection sys;
select user_name, flags from oceanbase.__all_virtual_user where user_name in ('U1', 'U2', 'U3', 'U4');
connection default;


alter user u1 grant connect through u1;
select * from sys.proxy_users;


alter user u1, u2 grant connect through u3, u4;
select * from sys.proxy_users;


--error 1924
alter user u1, u2 grant connect through u3, u4 with role r1;

alter user u1 grant connect through u3, u4 with role r1, r2;
select * from sys.proxy_users;


alter user u1, u2 grant connect through u3, u4;
select * from sys.proxy_users;
connection sys;
select user_name, flags from oceanbase.__all_virtual_user where user_name in ('U1', 'U2', 'U3', 'U4');
connection default;

drop role r1;


revoke r2 from u1;


