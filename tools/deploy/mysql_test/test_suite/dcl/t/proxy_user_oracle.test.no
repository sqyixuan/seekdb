CREATE USER zc_user1 IDENTIFIED BY 123;
CREATE USER zc_user2 IDENTIFIED BY 321;
CREATE ROLE zc_role1 NOT IDENTIFIED;
GRANT zc_role1 to zc_user2;

ALTER USER zc_user2 GRANT CONNECT THROUGH zc_user1 WITH ROLE ALL EXCEPT zc_role1;

SELECT * from sys.proxy_users;

REVOKE zc_role1 FROM zc_user2;

SELECT * from sys.proxy_users;
drop user zc_user1 cascade;
drop user zc_user2 cascade;
drop role zc_role1;

