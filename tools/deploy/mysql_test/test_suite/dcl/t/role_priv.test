#owner: linyi.cl
#owner group: sql3
#description: mock shutdown and reload priv
#tags: dcl

--disable_warnings
drop user if exists linyi;
drop table if exists t1;
--enable_warnings

--error 0,1396
drop role r1;
--error 0,1396
drop role r2;

--result_format 4

create user linyi;
grant create, drop, alter on *.* to linyi;
show grants for linyi;
select user, create_role_priv, drop_role_priv from mysql.user where user = 'linyi';

connect(conn_linyi1, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi1;
--error 1227
create role r1;
--error 1227
drop role r1;

connection default;
--error 1221
grant create role on test.* to linyi;
--error 1144
grant create role on test.t1 to linyi;
grant create role on *.* to linyi;
show grants for linyi;
select user, create_role_priv, drop_role_priv from mysql.user where user = 'linyi';

connect(conn_linyi2, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi2;
create role r1;
--error 1227
drop role r1;

connection default;
grant drop role on *.* to linyi;
revoke create role on *.* from linyi;
show grants for linyi;
select user, create_role_priv, drop_role_priv from mysql.user where user = 'linyi';

connect(conn_linyi3, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi3;
drop role r1;
--error 1227
create role r1;

connection default;
revoke drop role on *.* from linyi;
show grants for linyi;
select user, create_role_priv, drop_role_priv from mysql.user where user = 'linyi';

connect(conn_linyi4, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi4;
--error 1227
drop role r1;

connection default;
grant create user on *.* to linyi;
show grants for linyi;

connect(conn_linyi5, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi5;
create role r1;
drop role r1;

connection default;
create role r1;
create role r2;
grant r2 to r1;
grant r1 to admin;
set role r1;
create table t1(c1 int);
grant select on test.t1 to r2;
select * from information_schema.role_table_grants;
grant create,insert on test.t1 to r1 with grant option;
select * from information_schema.role_table_grants;
grant select(c1) on test.t1 to r2;
select * from information_schema.role_column_grants;
grant insert(c1),update(c1) on test.t1 to r1 with grant option;
select * from information_schema.role_column_grants;

--error 0,1305
drop procedure p1;
delimiter /;
create procedure p1() begin select 1 from dual; end; /
delimiter ;/
grant execute on procedure test.p1 to r2;
select * from information_schema.role_routine_grants;
grant alter routine, execute on procedure test.p1 to r1 with grant option;
select * from information_schema.role_routine_grants;
grant all privileges on *.* to linyi with grant option;

connect(conn_linyi6, $OBMYSQL_MS0, linyi, '', test, $OBMYSQL_PORT);
connection conn_linyi6;
revoke insert on test.t1 from r1;
revoke execute on procedure test.p1 from r1;

connection default;
select * from information_schema.role_table_grants;
grant insert on test.t1 to r1;
select * from information_schema.role_table_grants;

select * from information_schema.role_routine_grants;
grant execute on procedure test.p1 to r1;
select * from information_schema.role_routine_grants;

drop procedure p1;
drop table t1;
drop role r1;
drop role r2;
drop user linyi;