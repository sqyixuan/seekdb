#owner: linyi.cl
#owner group: sql3
#description: outline priv
#tags: dcl

--error 0,1396
drop user linyi1;
--disable_warnings
drop database if exists db1;
--enable_warnings

--error 0,5265
drop outline o1;

create user linyi1;
grant select on *.* to linyi1;
connect(conn_linyi1, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi1;

--error 1044
create outline o1 on select 1 from dual;
--error 1044
alter outline o1 add select 1 from dual;
--error 1044
drop outline o1;

connection default;
grant create on test.* to linyi1;

create database db1;
connect(conn_linyi2, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi2;

create outline o1 on select 1 from dual;
--error 1044
alter outline o1 add select 1 from dual;
--error 1044
drop outline o1;

use db1;
--error 1044
create outline o1 on select 1 from dual;

connection default;
grant alter on test.* to linyi1;
grant drop on test.* to linyi1;

connect(conn_linyi3, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi3;

use db1;
--error 1044
alter outline o1 add select 1 from dual;
--error 1044
drop outline o1;

use test;
--error 5272
alter outline o1 add select 1 from dual;
drop outline o1;

connection default;
grant create on *.* to linyi1;
grant alter on *.* to linyi1;
grant drop on *.* to linyi1;

connect(conn_linyi4, $OBMYSQL_MS0, linyi1, '', test, $OBMYSQL_PORT);
connection conn_linyi4;

use db1;
create outline o1 on select 1 from dual;
--error 5272
alter outline o1 add select 1 from dual;
drop outline o1;

connection default;
drop user linyi1;
