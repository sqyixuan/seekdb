--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql4
#description: todo
#tags: dcl

--disable_warnings
--error 0,942,1051
drop table test;

drop database if exists db_t;

--error 0,1396
drop user u1;

--error 0,1396
drop user u2;

--enable_warnings

create user u1 identified by '123';
create database db_t;
create table db_t.t1(c1 int);
#grant all  on db_t.t1 to current_user;
#grant all  on db_t.t1 to current_user();

grant all privileges on db_t.t1 to u1;
drop database db_t;
revoke select on db_t.t1 from u1;
revoke select on db_t.t1 from u1;

create user u2 identified by '123';

grant create user on *.* to u1;
grant select on test.* to u1;
connect (conn_u1,$OBMYSQL_MS0, u1,123,test,$OBMYSQL_PORT);
connection conn_u1;

revoke all on *.* from u2;

connection default;
grant super on *.* to u2;

connection conn_u1;
--error 1227
revoke all on *.* from u2;

connection default;
grant super on *.* to u1;

disconnect conn_u1;
connect (conn_u1,$OBMYSQL_MS0, u1,123,test,$OBMYSQL_PORT);
connection conn_u1;
revoke all on *.* from u2;

connection default;
grant select on mysql.user to u1;
#grant select on mysql.user to u1 with grant option;

revoke select on mysql.user from u1;
select user_name from oceanbase.__all_user where user_name='u1';
connection conn_u1;
--error 1142
set @var=(SELECT password FROM mysql.user WHERE user='ROOT'); 

connection conn_u1;
show grants;
#revoke all on *.* from current_user;
show grants;
--error 1044
revoke select on test.* from current_user;


connection default;
select user_name from oceanbase.__all_user where user_name='u1';
drop user u1;
drop user u2;
