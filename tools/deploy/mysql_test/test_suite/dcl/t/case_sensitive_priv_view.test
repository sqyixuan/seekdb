# owner: sean.yyj
# owner group: sql3
# tags: resolver
# test schema privileges in mysql mode
--result_format 4

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;

--disable_warnings
#drop tenant if exists tt1 force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit1;
--enable_warnings

--disable_query_log
#eval create resource unit test_resource_unit1 max_cpu 1, memory_size '2G';
--enable_query_log

--disable_query_log
#eval create resource pool test_resource_pool1 unit = 'test_resource_unit1', unit_num = 1, zone_list = ('$zone_name');
--enable_query_log

--disable_query_log
#eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set lower_case_table_names = 0, ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

##time to sync schema
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
connection conn1;

--disable_warnings
drop database if exists db1;
#drop database if exists DB1;
--error 0, 1396
drop user u1;
--enable_warnings

create database db1;
#create database DB1;
show databases;
create table db1.t1(c1 int);
#create table db1.T1(c1 int);

create user u1 identified by '123';

#grant select on DB1.* to u1;
show grants for u1;
select database_name, priv_select from oceanbase.__all_database_privilege;
select database_name, priv_select, is_deleted from oceanbase.__all_database_privilege_history;
select * from information_schema.SCHEMA_PRIVILEGES where grantee like '%u1%';

grant select on db1.* to u1;
show grants for u1;
select database_name, priv_select from oceanbase.__all_database_privilege;
select database_name, priv_select, is_deleted from oceanbase.__all_database_privilege_history;
select * from information_schema.SCHEMA_PRIVILEGES where grantee like '%u1%';

grant select on db1.t1 to u1;
show grants for u1;
select database_name, table_name, priv_select from oceanbase.__all_table_privilege;
select database_name, table_name, priv_select, is_deleted from oceanbase.__all_table_privilege_history;
select * from information_schema.TABLE_PRIVILEGES where grantee like '%u1%';

#grant select on db1.T1 to u1;
show grants for u1;
select database_name, table_name, priv_select from oceanbase.__all_table_privilege;
select database_name, table_name, priv_select, is_deleted from oceanbase.__all_table_privilege_history;
select * from information_schema.TABLE_PRIVILEGES where grantee like '%u1%';

#revoke select on db1.T1 from u1;
show grants for u1;
select database_name, table_name, priv_select from oceanbase.__all_table_privilege;
select database_name, table_name, priv_select, is_deleted from oceanbase.__all_table_privilege_history;
select * from information_schema.TABLE_PRIVILEGES where grantee like '%u1%';

#grant select on db1.T1 to u1;
show grants for u1;
select database_name, table_name, priv_select from oceanbase.__all_table_privilege;
select database_name, table_name, priv_select, is_deleted from oceanbase.__all_table_privilege_history;
select * from information_schema.TABLE_PRIVILEGES where grantee like '%u1%';

drop user u1;

select database_name, priv_select from oceanbase.__all_database_privilege;
select database_name, priv_select, is_deleted from oceanbase.__all_database_privilege_history;
select database_name, table_name, priv_select from oceanbase.__all_table_privilege;
select database_name, table_name, priv_select, is_deleted from oceanbase.__all_table_privilege_history;
select * from information_schema.SCHEMA_PRIVILEGES where grantee like '%u1%';
select * from information_schema.TABLE_PRIVILEGES where grantee like '%u1%';

drop database if exists db1;
#drop database if exists DB1;
connection conn0;
#drop tenant tt1 force;
