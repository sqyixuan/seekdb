#owner:sean.yyj
#owner group: sql1
#tags : privilege

purge recyclebin;
--disable_warnings
drop user if exists u1,u2;
drop function if exists f1;
--enable_warnings

create user u1;
create user u2;

--echo # cascade revoke priv
set global automatic_sp_privileges = 1;
delimiter //;
create function f1() returns int deterministic return 1; //
delimiter ;//
grant execute on function f1 to u1;
show grants;
show grants for u1;
show grants for u2;

drop function f1;
show grants;
show grants for u1;
show grants for u2;

--echo # not to cascade revoke priv
set global automatic_sp_privileges = 0;
delimiter //;
create function f1() returns int deterministic return 1; //
delimiter ;//
grant execute on function f1 to admin;
grant execute on function f1 to u1;
show grants;
show grants for u1;
show grants for u2;

drop function f1;
show grants;
show grants for u1;
show grants for u2;

revoke execute on function f1 from admin;
revoke execute on function f1 from u1;
show grants;
show grants for u1;
show grants for u2;

# cleanup
set global automatic_sp_privileges = 1;
drop user u1,u2;
