#privilege check
use test;
--disable_warnings
drop table if exists t_priv;
drop view if exists t_view;
--enable_warnings
--disable_warnings
drop table if exists privilege_table;
--enable_warnings
create table t_priv(c1 int primary key, c2 int);
connection conn1;
create view t_view as select user from mysql.user where user = 'yangze';
grant select on t_view to yangze;
grant select on test.t_priv to yangze with grant option;
grant drop on test.t_priv to yangze;
grant create on `jianhua_pdb%`.* to yangze;
grant create on `test%`.* to yangze;


--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,yangze,123,test,$OBMYSQL_PORT);
connection conn2;
set sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
--error 1410
grant select on test.t_priv to priv_user_not_exist;
--error 1410
grant select on test.t_priv to priv_user_not_exist identified by '123';
select * from test.t_priv;
show databases like 'jianhua_pdb%';
--error 1142
select user from mysql.user;
--error 1142
show create table mysql.user;
--error 1142
explain select user from mysql.user;
select * from test.t_view;
--error 1044
