--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#tags: privilege

--disable_warnings
drop view if exists v1,v2;
drop table if exists t1;
drop database if exists db_1;
--error 0,1396
drop user u1;
--enable_warnings

--echo #prepare
create user u1 identified by '123';
grant all on test.* to u1;
create table t1(c1 int);
create view v1 as select * from t1;
create database db_1;
create table db_1.t1(c1 int);
create view db_1.v1 as select * from db_1.t1;

--source mysql_test/include/check_schema_fast_sync.inc
connect(conn_u1, $OBMYSQL_MS0, u1, 123, test, $OBMYSQL_PORT);
connection conn_u1;

--echo #test
--error 1142
select * from mysql.time_zone;
--error 1142
create view v1 as select * from mysql.time_zone;

--error 1142
select * from db_1.t1;
--error 1142
create view v1 as select * from db_1.v1;

select * from v1;
create view v2 as select * from v1;

--echo #cleanup
connection default;
drop view v1,v2;
drop table t1;
drop database db_1;
drop user u1;
