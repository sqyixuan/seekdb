--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
#owner: sean.yyj
#owner group: sql3
#tags: privilege,dcl

--enable_query_log
connect (obsys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
alter system set _enable_reserved_user_dcl_restriction=true;
sleep 5;

connection default;

--error 0,1051
drop table t1;
create table t1 (c1 int, c2 int);

--error 1235
alter user root identified by 'new_root';
--error 1235
set password for root = 'new_root';
--error 1235
alter user root account lock;
--error 1235
alter user root account unlock;
--error 1235
alter user root require SSL;
--error 1227
drop user root;
--error 1235
grant select on test.t1 to root;
--error 1235
revoke all privileges on test.* from root;

--error 1235,1133
alter user ORAAUDITOR identified by 'new_root';
--error 1235,1827,1133
set password for ORAAUDITOR = 'new_root';
--error 1235,1396
alter user ORAAUDITOR account lock;
--error 1235,1396
alter user ORAAUDITOR account unlock;
--error 1235,1133
alter user ORAAUDITOR require SSL;
--error 1227,1396
drop user ORAAUDITOR;
--error 1235,1045
grant select on test.t1 to ORAAUDITOR;
--error 1235,1133
revoke all privileges on test.* from ORAAUDITOR;

drop table t1;

connection obsys;
alter system set _enable_reserved_user_dcl_restriction=false;
disconnect obsys;

connection default;
