user has user level select privilege, output all table privilege
grant select on *.* to u9;
!!! 此时 u9 的权限没有更新，理论上检查条件为false, 此时应该复用plan cache 1
select * from information_schema.user_privileges;
GRANTEE	TABLE_CATALOG	PRIVILEGE_TYPE	IS_GRANTABLE
'u9'@'%'	def	ALTER	NO
'u9'@'%'	def	INSERT	NO
'u9'@'%'	def	SELECT	NO
'u9'@'%'	def	UPDATE	NO
