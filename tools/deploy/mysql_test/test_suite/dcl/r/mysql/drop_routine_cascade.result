purge recyclebin;
drop user if exists u1,u2;
drop function if exists f1;
create user u1;
create user u2;
# cascade revoke priv
set global automatic_sp_privileges = 1;
create function f1() returns int deterministic return 1; //
grant execute on function f1 to u1;
show grants;
Grants for admin@%
GRANT ALL PRIVILEGES ON *.* TO 'admin' WITH GRANT OPTION
GRANT EXECUTE, ALTER ROUTINE ON FUNCTION `test`.`f1` TO 'admin'
show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
GRANT EXECUTE ON FUNCTION `test`.`f1` TO 'u1'
show grants for u2;
Grants for u2@%
GRANT USAGE ON *.* TO 'u2'
drop function f1;
show grants;
Grants for admin@%
GRANT ALL PRIVILEGES ON *.* TO 'admin' WITH GRANT OPTION
show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
show grants for u2;
Grants for u2@%
GRANT USAGE ON *.* TO 'u2'
# not to cascade revoke priv
set global automatic_sp_privileges = 0;
create function f1() returns int deterministic return 1; //
grant execute on function f1 to admin;
grant execute on function f1 to u1;
show grants;
Grants for admin@%
GRANT ALL PRIVILEGES ON *.* TO 'admin' WITH GRANT OPTION
GRANT EXECUTE ON FUNCTION `test`.`f1` TO 'admin'
show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
GRANT EXECUTE ON FUNCTION `test`.`f1` TO 'u1'
show grants for u2;
Grants for u2@%
GRANT USAGE ON *.* TO 'u2'
drop function f1;
show grants;
Grants for admin@%
GRANT ALL PRIVILEGES ON *.* TO 'admin' WITH GRANT OPTION
GRANT EXECUTE ON FUNCTION `test`.`f1` TO 'admin'
show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
GRANT EXECUTE ON FUNCTION `test`.`f1` TO 'u1'
show grants for u2;
Grants for u2@%
GRANT USAGE ON *.* TO 'u2'
revoke execute on function f1 from admin;
revoke execute on function f1 from u1;
show grants;
Grants for admin@%
GRANT ALL PRIVILEGES ON *.* TO 'admin' WITH GRANT OPTION
show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
show grants for u2;
Grants for u2@%
GRANT USAGE ON *.* TO 'u2'
set global automatic_sp_privileges = 1;
drop user u1,u2;
