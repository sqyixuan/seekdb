purge recyclebin;
result_format: 4
drop user if exists u1,u2,u3,u4;
drop database routine_priv;
drop procedure if exists p1;
drop procedure if exists p2;
drop function if exists f1;
drop function if exists f2;
set ob_log_level='DEBUG';
SET ob_enable_show_trace='ON';

create database routine_priv;
use routine_priv;
create user u1 identified by '123';
create user u2 identified by '123';
create user u3 identified by '123';


create procedure p1() begin select 1; end;//
create procedure p2() begin select 1; end;//
grant execute on procedure routine_priv.p1 to u1;
show grants for u1;
Grants for u1@%
GRANT EXECUTE ON PROCEDURE `routine_priv`.`p1` TO 'u1'
GRANT USAGE ON *.* TO 'u1'
grant alter routine on procedure routine_priv.p1 to u2 with grant option;
show grants for u2;
Grants for u2@%
GRANT ALTER ROUTINE ON PROCEDURE `routine_priv`.`p1` TO 'u2' WITH GRANT OPTION
GRANT USAGE ON *.* TO 'u2'

call p1();
+---+
| 1 |
+---+
| 1 |
+---+

call p1();
+---+
| 1 |
+---+
| 1 |
+---+

