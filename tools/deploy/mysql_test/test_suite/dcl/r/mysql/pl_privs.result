#### TEST SECURITY: DEFINER AND ROVKER
set global automatic_sp_privileges=1;
drop procedure if exists P1;
drop procedure if exists p2;
drop function if exists f1;
drop function if exists f2;
drop user u1;
drop user u2;
create user u1 identified by '123';
create user u2 identified by '123';

drop table if exists t1;
create table t1(c1 int);
insert into t1 values(1), (2), (3);

create definer='u1' procedure p1() begin select f1(); end; //
create definer='u2' function f1() returns int return (select max(c1) from t1); //

call p1();
ERROR 42000: EXECUTE command denied to user 'u1'@'%' for routine 'p1'

grant execute on procedure p1 to u1;

call p1();
ERROR 42000: EXECUTE command denied to user 'u1'@'%' for routine 'f1'

grant execute on function f1 to u1;
call p1();
ERROR 42000: EXECUTE command denied to user 'u2'@'%' for routine 'f1'

grant execute on function f1 to u2;
call p1();
+------+
| f1() |
+------+
|    3 |
+------+

grant select on t1 to u2;
call p1();
+------+
| f1() |
+------+
|    3 |
+------+

grant create user on *.* to u2;
drop user u1;
ERROR HY000: Operation DROP USER failed for 'u1'@'%' as it is referenced as a definer account in a stored routine.

show grants for u1;
Grants for u1@%
