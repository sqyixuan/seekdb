result_format: 4

##time to sync schema


drop database if exists db1;
drop user u1;
create database db1;
show databases;
Database
db1
information_schema
mysql
obproxy
oceanbase
sys_external_tbs
test
create table db1.t1(c1 int);
create user u1 identified by '123';

show grants for u1;
Grants for u1@%
GRANT USAGE ON *.* TO 'u1'
select database_name, priv_select from oceanbase.__all_database_privilege;
+--------------------+-------------+
| database_name      | priv_select |
+--------------------+-------------+
| information_schema |           1 |
| mysql              |           1 |
| oceanbase          |           1 |
| test               |           1 |
| __public           |           1 |
| __recyclebin       |           1 |
| oceanbase          |           1 |
+--------------------+-------------+
select database_name, priv_select, is_deleted from oceanbase.__all_database_privilege_history;
+--------------------+-------------+------------+
| database_name      | priv_select | is_deleted |
+--------------------+-------------+------------+
| information_schema |           1 |          0 |
| mysql              |           1 |          0 |
| oceanbase          |           1 |          0 |
| test               |           1 |          0 |
| __public           |           1 |          0 |
| __recyclebin       |           1 |          0 |
| oceanbase          |           1 |          0 |
+--------------------+-------------+------------+
select * from information_schema.SCHEMA_PRIVILEGES where grantee like '%u1%';
+---------+---------------+--------------+----------------+--------------+
| GRANTEE | TABLE_CATALOG | TABLE_SCHEMA | PRIVILEGE_TYPE | IS_GRANTABLE |
+---------+---------------+--------------+----------------+--------------+
+---------+---------------+--------------+----------------+--------------+

