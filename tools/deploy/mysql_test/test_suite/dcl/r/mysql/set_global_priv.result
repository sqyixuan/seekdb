drop user usr_test;
#
# Create user
#
create user usr_test;
grant usage, select on *.* to usr_test;
#
# set global without any privilege
#
set global max_connections=200;
ERROR 42501: Access denied; you need (at least one of) the SUPER or ALTER SYSTEM privilege(s) for this operation
grant alter system on *.* to usr_test;
#
# set global with alter system
#
set global max_connections=200;
grant super on *.* to usr_test;
#
# set global with alter system and super
#
set global max_connections=200;
revoke alter system on *.* from usr_test;
#
# set global with super
#
set global max_connections=200;
