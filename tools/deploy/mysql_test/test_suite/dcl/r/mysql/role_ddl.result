drop table if exists t1;
drop procedure if exists my_proc1;
create user u9;

create table t1(c1 int);
insert into t1 values(1);

create role r6;
grant select on test.t1 to r6;
grant r6 to u9;
grant execute on *.* to u9;

CREATE definer = 'u9' PROCEDURE my_proc1 (OUT count_all INT)
BEGIN
 SELECT COUNT(*) INTO count_all FROM test.t1;
END
//

call my_proc1(@a);
ERROR 42000: SELECT command denied to user 'u9'@'%' for table 't1'

set default role r6 to u9;

call my_proc1(@a);

drop table t1;
drop user u9;
Warnings:
Warning	4005	User 'u9'@'%' is referenced as a definer account in a stored routine.
