show columns from information_schema.user_privileges;
Field	Type	Null	Key	Default	Extra
GRANTEE	varchar(81)	NO			
TABLE_CATALOG	varchar(512)	NO			
PRIVILEGE_TYPE	varchar(64)	NO			
IS_GRANTABLE	varchar(3)	NO			
user no privilege, output nothing
select * from information_schema.user_privileges WHERE GRANTEE IN (
"'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
"'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
GRANTEE	TABLE_CATALOG	PRIVILEGE_TYPE	IS_GRANTABLE
'u9'@'%'	def	USAGE	NO
user has 'mysql' other privileges, output nothing
grant insert, alter, update on mysql.* to u9;
