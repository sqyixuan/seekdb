grant privileges
grant alter, create, create user, delete, drop, insert, update, select, index, create view, show view, show databases on *.* to u0 with grant option;
grant super, process, file, alter tenant, alter system, create resource pool, create resource unit, replication slave, replication client on *.* to u1;
grant insert, update on mysql.* to u2;
grant select on mysql.* to u3;
grant all privileges on *.* to u4;
select * from information_schema.user_privileges WHERE GRANTEE IN (
"'u1'@'%'", "'u2'@'%'", "'u3'@'%'", "'u4'@'%'", "'u5'@'%'",
"'u6'@'%'", "'u7'@'%'", "'u8'@'%'", "'u9'@'%'", "'u10'@'%'"
)
ORDER BY GRANTEE, PRIVILEGE_TYPE;
GRANTEE	TABLE_CATALOG	PRIVILEGE_TYPE	IS_GRANTABLE
