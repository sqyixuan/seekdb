alter system set ssl_client_authentication = false;
alter system set ob_ssl_invited_common_names = "NONE";
drop user jianhua_error,jianhua,jianhua_none,jianhua_ssl,jianhua_x509,jianhua_cipher,jianhua_cipher2,jianhua_issuer,jianhua_subject,jianhua_ci,jianhua_cs,jianhua_is,jianhua_cis,jianhua_cipher_other;
drop table t_user_name, t_require_info;
create table t_user_name(id int, c1 varchar(20));
insert into t_user_name values (1, 'jianhua');
insert into t_user_name values (2, 'jianhua_none');
insert into t_user_name values (3, 'jianhua_ssl');
insert into t_user_name values (4, 'jianhua_x509');
insert into t_user_name values (5, 'jianhua_cipher');
insert into t_user_name values (6, 'jianhua_issuer');
insert into t_user_name values (7, 'jianhua_subject');
insert into t_user_name values (8, 'jianhua_ci');
insert into t_user_name values (9, 'jianhua_cs');
insert into t_user_name values (10, 'jianhua_is');
insert into t_user_name values (11, 'jianhua_cis');
create table t_require_info(id int, c1 varchar(300));
insert into t_require_info values (1, '');
insert into t_require_info values (2, 'require none');
insert into t_require_info values (3, 'require ssl');
insert into t_require_info values (4, 'require x509');
insert into t_require_info values (5, 'require CIPHER "DHE-RSA-AES128-GCM-SHA256"');
insert into t_require_info values (6, 'require ISSUER "/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate"');
insert into t_require_info values (7, 'require SUBJECT "/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate"');
insert into t_require_info values (8, 'require CIPHER "DHE-RSA-AES128-GCM-SHA256" and ISSUER "/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate"');
insert into t_require_info values (9, 'require CIPHER "DHE-RSA-AES128-GCM-SHA256"  SUBJECT "/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate"');
insert into t_require_info values (10, 'require ISSUER "/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate" and SUBJECT "/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate"');
insert into t_require_info values (11, 'require CIPHER "DHE-RSA-AES128-GCM-SHA256" ISSUER "/CN=MySQL_Server_5.7.24_Auto_Generated_CA_Certificate" and SUBJECT "/CN=MySQL_Server_5.7.24_Auto_Generated_Client_Certificate"');
create user 'jianhua' IDENTIFIED BY '123456' ;
grant select on *.* to jianhua with grant option;
select user,ssl_type,ssl_cipher, x509_issuer, x509_subject, length(ssl_type), length(ssl_cipher), length(x509_issuer), length(x509_subject) from mysql.user where user='$user_name';
user	ssl_type	ssl_cipher	x509_issuer	x509_subject	length(ssl_type)	length(ssl_cipher)	length(x509_issuer)	length(x509_subject)
select user_name,ssl_type,ssl_cipher, x509_issuer, x509_subject, length(ssl_cipher), length(x509_issuer), length(x509_subject) from oceanbase.__all_user where user_name='$user_name';
user_name	ssl_type	ssl_cipher	x509_issuer	x509_subject	length(ssl_cipher)	length(x509_issuer)	length(x509_subject)
