drop user u1;
drop user u2;
drop user u3;
drop table if exists t1;
create user u1 identified by '123';
create user u2 identified by '123';
create user u3 identified by '123';
create table t1(c1 int);
grant replication slave on test.* to u1;
ERROR HY000: Incorrect usage of DB GRANT and GLOBAL PRIVILEGES
grant replication slave on test.t1 to u1;
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
grant replication client on test.* to u1;
ERROR HY000: Incorrect usage of DB GRANT and GLOBAL PRIVILEGES
grant replication client on test.t1 to u1;
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
revoke replication slave on test.* from u1;
ERROR HY000: Incorrect usage of DB GRANT and GLOBAL PRIVILEGES
revoke replication slave on test.t1 from u1;
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
revoke replication client on test.* from u1;
ERROR HY000: Incorrect usage of DB GRANT and GLOBAL PRIVILEGES
revoke replication client on test.t1 from u1;
ERROR 42000: Illegal GRANT/REVOKE command; please consult the manual to see which privileges can be used
grant replication slave on *.* to u1;
grant replication client on *.* to u2;
grant all on *.* to u3;
show grants for u1;
Grants for u1@%
GRANT REPLICATION SLAVE ON *.* TO 'u1'
show grants for u2;
Grants for u2@%
GRANT REPLICATION CLIENT ON *.* TO 'u2'
show grants for u3;
Grants for u3@%
GRANT ALL PRIVILEGES ON *.* TO 'u3'
select user,repl_slave_priv, repl_client_priv from mysql.user where user in ('u1','u2','u3') order by user;
user	repl_slave_priv	repl_client_priv
u1	Y	N
u2	N	Y
u3	Y	Y
grant replication client on *.* to u1;
grant replication slave on *.* to u2;
revoke replication client on *.* from u2;
revoke replication client on *.* from u3;
show grants for u1;
Grants for u1@%
GRANT REPLICATION SLAVE, REPLICATION CLIENT ON *.* TO 'u1'
show grants for u2;
Grants for u2@%
GRANT REPLICATION SLAVE ON *.* TO 'u2'
show grants for u3;
Grants for u3@%
GRANT ALTER, CREATE, CREATE USER, DELETE, DROP, INSERT, UPDATE, SELECT, INDEX, CREATE VIEW, SHOW VIEW, SHOW DATABASES, SUPER, PROCESS, REFERENCES, FILE, ALTER TENANT, ALTER SYSTEM, CREATE RESOURCE POOL, CREATE RESOURCE UNIT, REPLICATION SLAVE, DROP DATABASE LINK, CREATE DATABASE LINK, EXECUTE, ALTER ROUTINE, CREATE ROUTINE, CREATE TABLESPACE, SHUTDOWN, RELOAD, LOCK TABLES, CREATE ROLE, DROP ROLE, TRIGGER, EVENT, CREATE CATALOG, USE CATALOG ON *.* TO 'u3'
select user,repl_slave_priv, repl_client_priv from mysql.user where user in ('u1','u2','u3') order by user;
user	repl_slave_priv	repl_client_priv
u1	Y	Y
u2	Y	N
u3	Y	N
drop table t1;
drop user u1;
drop user u2;
drop user u3;
