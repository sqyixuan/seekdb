user has user level other privilege, output nothing
revoke select on mysql.* from u9;
grant insert, alter, update on *.* to u9;
!!! 此时 u9 的权限检查条件为false, 此时应该生成一个plan cache 1
select * from information_schema.table_privileges;
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
!!! 此时 u9 的权限检查条件为false, 此时应该复用一个plan cache 1？？
select * from information_schema.table_privileges;
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
user has user level select privilege, output all table privilege
grant select on *.* to u9;
!!! 此时 u9 的权限没有更新，理论上检查条件为false, 此时应该复用plan cache 1
select * from information_schema.table_privileges;
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
