grant privileges
u0 有d0.t0的所有权限，并且priv_grant_option = 1
grant all privileges on d0.t0 to u0 with grant option;
u1 有d1.*的所有权限，并且priv_grant_option = 1
grant all privileges on d1.* to u1 with grant option;
u2 有*.*的所有权限，并且priv_grant_option = 1
grant all privileges on *.* to u2 with grant option;
u3 有d3.t3的部分权限，并且priv_grant_option = 1
grant alter, create, delete, drop on d3.t3 to u3 with grant option;
u4 有d4.t4的部分权限，并且priv_grant_option = 0
grant insert, update, select, index, create view, show view on d4.t4 to u4;
select * from information_schema.table_privileges;
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
'u0'@'%'	def	d0	t0	ALTER	YES
'u0'@'%'	def	d0	t0	CREATE	YES
'u0'@'%'	def	d0	t0	CREATE VIEW	YES
'u0'@'%'	def	d0	t0	DELETE	YES
'u0'@'%'	def	d0	t0	DROP	YES
'u0'@'%'	def	d0	t0	INDEX	YES
'u0'@'%'	def	d0	t0	INSERT	YES
'u0'@'%'	def	d0	t0	REFERENCES	YES
'u0'@'%'	def	d0	t0	SELECT	YES
'u0'@'%'	def	d0	t0	SHOW VIEW	YES
'u0'@'%'	def	d0	t0	TRIGGER	YES
'u0'@'%'	def	d0	t0	UPDATE	YES
