drop user u1;
drop user u2;
drop user u3;
drop table if exists t1, t2;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create user u1 identified by '123';
create user u2 identified by '123';
create user u3 identified by '123';
grant all on t1 to u1;
grant select on t2 to u1;
grant all on t1 to u2;
grant select on test.* to u3;
# u1 has enough privilege
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
delete t1 from t1 join t2 on t1.c1 = t2.c1;
# u2 lack select privilege on t2
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
ERROR 42000: SELECT command denied to user 'u2'@'%' for table 't2'
delete t1 from t1 join t2 on t1.c1 = t2.c1;
ERROR 42000: SELECT command denied to user 'u2'@'%' for table 't2'
# u3 lack dml privilege on t1
update t1 join t2 on t1.c1 = t2.c1 set t1.c2 = t2.c2;
ERROR 42000: UPDATE command denied to user 'u3'@'%' for table 't1'
delete t1 from t1 join t2 on t1.c1 = t2.c1;
ERROR 42000: DELETE command denied to user 'u3'@'%' for table 't1'
drop table t1,t2;
drop user u1;
drop user u2;
drop user u3;
