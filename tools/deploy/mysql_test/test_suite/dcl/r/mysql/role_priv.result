create role r1;
create role r2;
grant r2 to r1;
grant r1 to admin;
set role r1;
create table t1(c1 int);
grant select on test.t1 to r2;
select * from information_schema.role_table_grants;
+---------+--------------+---------+--------------+---------------+--------------+------------+----------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | PRIVILEGE_TYPE | IS_GRANTABLE |
+---------+--------------+---------+--------------+---------------+--------------+------------+----------------+--------------+
| admin   | %            | r2      | %            | def           | test         | t1         | Select         | NO           |
+---------+--------------+---------+--------------+---------------+--------------+------------+----------------+--------------+
grant create,insert on test.t1 to r1 with grant option;
select * from information_schema.role_table_grants;
+---------+--------------+---------+--------------+---------------+--------------+------------+---------------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | PRIVILEGE_TYPE      | IS_GRANTABLE |
+---------+--------------+---------+--------------+---------------+--------------+------------+---------------------+--------------+
| admin   | %            | r1      | %            | def           | test         | t1         | Create,Grant,Insert | YES          |
| admin   | %            | r2      | %            | def           | test         | t1         | Select              | NO           |
+---------+--------------+---------+--------------+---------------+--------------+------------+---------------------+--------------+
grant select(c1) on test.t1 to r2;
select * from information_schema.role_column_grants;
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | PRIVILEGE_TYPE | IS_GRANTABLE |
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+
|    NULL |         NULL | r2      | %            | def           | test         | t1         | c1          | Select         | NO           |
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+
grant insert(c1),update(c1) on test.t1 to r1 with grant option;
select * from information_schema.role_column_grants;
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | PRIVILEGE_TYPE | IS_GRANTABLE |
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+
|    NULL |         NULL | r1      | %            | def           | test         | t1         | c1          | Insert,Update  | YES          |
|    NULL |         NULL | r2      | %            | def           | test         | t1         | c1          | Select         | NO           |
+---------+--------------+---------+--------------+---------------+--------------+------------+-------------+----------------+--------------+

drop procedure p1;
create procedure p1() begin select 1 from dual; end; /
grant execute on procedure test.p1 to r2;
select * from information_schema.role_routine_grants;
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+----------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | SPECIFIC_CATALOG | SPECIFIC_SCHEMA | SPECIFIC_NAME | ROUTINE_CATALOG | ROUTINE_SCHEMA | ROUTINE_NAME | PRIVILEGE_TYPE | IS_GRANTABLE |
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+----------------+--------------+
| admin   | %            | r2      | %            | def              | test            | p1            | def             | test           | p1           | Execute        | NO           |
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+----------------+--------------+
grant alter routine, execute on procedure test.p1 to r1 with grant option;
select * from information_schema.role_routine_grants;
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+-----------------------------+--------------+
| GRANTOR | GRANTOR_HOST | GRANTEE | GRANTEE_HOST | SPECIFIC_CATALOG | SPECIFIC_SCHEMA | SPECIFIC_NAME | ROUTINE_CATALOG | ROUTINE_SCHEMA | ROUTINE_NAME | PRIVILEGE_TYPE              | IS_GRANTABLE |
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+-----------------------------+--------------+
| admin   | %            | r1      | %            | def              | test            | p1            | def             | test           | p1           | Execute,Alter Routine,Grant | YES          |
| admin   | %            | r2      | %            | def              | test            | p1            | def             | test           | p1           | Execute                     | NO           |
+---------+--------------+---------+--------------+------------------+-----------------+---------------+-----------------+----------------+--------------+-----------------------------+--------------+
grant all privileges on *.* to linyi with grant option;

revoke insert on test.t1 from r1;
revoke execute on procedure test.p1 from r1;

select * from information_schema.role_table_grants;
