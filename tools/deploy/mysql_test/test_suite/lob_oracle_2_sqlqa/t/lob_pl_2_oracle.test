--echo  #INSTR
--error 0,600
DROP PROCEDURE PROCEDURE_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1 IS
	v_blob BLOB := utl_raw.cast_to_raw('qwerfdsbgsfgstyui');
	v_clob CLOB := TO_CLOB('231332113131');
	i NUMBER    := 1;
	v_int1 NUMBER;
	v_int2 NUMBER;
BEGIN
	LOOP
		EXIT WHEN i > 4 ;
		v_int1 := DBMS_LOB.INSTR(v_blob,utl_raw.cast_to_raw('s'));
		v_int2 := DBMS_LOB.INSTR(v_clob,'1');
		DBMS_OUTPUT.PUT_LINE('OUTPUT:' || v_int1);
		DBMS_OUTPUT.PUT_LINE(v_int2);
		i := i + 1;
	END LOOP;
END;
