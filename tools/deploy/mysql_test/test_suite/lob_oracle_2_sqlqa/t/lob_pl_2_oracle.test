--echo  #ISOPEN
--error 0,600
DROP PROCEDURE PROCEDURE_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1 IS
	v_blob BLOB := utl_raw.cast_to_raw('qwerfdsbgsfgstyui');
	v_clob CLOB := TO_CLOB('231332113131');
	i NUMBER    := 1;
	v_int1 NUMBER;
	v_int2 NUMBER;
BEGIN
	LOOP
		EXIT WHEN i > 4 ;
		DBMS_LOB.OPEN(v_blob, DBMS_LOB.LOB_READONLY);
		DBMS_LOB.OPEN(v_clob, DBMS_LOB.LOB_READONLY);
		v_int1 := DBMS_LOB.ISOPEN(v_blob);
		v_int2 := DBMS_LOB.ISOPEN(v_clob);
		DBMS_OUTPUT.PUT_LINE('OUTPUT:' || v_int1);
		DBMS_OUTPUT.PUT_LINE('OUTPUT:' || v_int2);
		DBMS_LOB.CLOSE(v_blob);
		DBMS_LOB.CLOSE(v_clob);
		i := i + 1;
	END LOOP;
END;
/
delimiter ;/
