--echo   #dbms_lob-11   pl/sql语句



--echo  #dbms_lob-11-1  存储过程======>loop循环
--echo  #CREATETEMPORARY
--error 0,600
DROP PROCEDURE PROCEDURE_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1 IS
   v_blob BLOB := utl_raw.cast_to_raw('qwerfdsbgsfgstyui');
   v_clob CLOB := TO_CLOB('231332113131');
   i NUMBER    := 1;
BEGIN
	LOOP
		EXIT WHEN i > 5;
		DBMS_LOB.CREATETEMPORARY(v_blob, TRUE);
		DBMS_LOB.CREATETEMPORARY(v_clob, TRUE);
		DBMS_OUTPUT.PUT_LINE('OUTPUT:' || utl_raw.cast_to_varchar2(v_blob));
		DBMS_OUTPUT.PUT_LINE(v_clob);
		i := i + 1;
	END LOOP;
END;
/
delimiter ;/
CALL PROCEDURE_1();
DROP PROCEDURE PROCEDURE_1;
delimiter /;
CREATE PROCEDURE PROCEDURE_1 IS
   v_blob BLOB := utl_raw.cast_to_raw('qwerfdsbgsfgstyui');
   v_clob CLOB := TO_CLOB('231332113131');
   i NUMBER    := 1;
BEGIN
	LOOP
		EXIT WHEN i > v_blob;
		DBMS_LOB.CREATETEMPORARY(v_blob, TRUE);
		DBMS_LOB.CREATETEMPORARY(v_clob, TRUE);
		DBMS_OUTPUT.PUT_LINE('OUTPUT:' || utl_raw.cast_to_varchar2(v_blob));
		DBMS_OUTPUT.PUT_LINE(v_clob);
		i := i + 1;
	END LOOP;
END;
/
