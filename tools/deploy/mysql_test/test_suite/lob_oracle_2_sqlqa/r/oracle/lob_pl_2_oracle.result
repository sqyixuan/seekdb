| ID | C1     | C2                                 |
+----+--------+------------------------------------+
|  1 | CLOB 1 | 445346555939382D5355594649455752   |
|  2 | CLOB 2 | 647366646673732D736466736766736664 |
+----+--------+------------------------------------+
DROP PROCEDURE PROCEDURE_1;
CREATE PROCEDURE PROCEDURE_1 (
  in_id IN NUMBER,
  out_clob OUT CLOB,
  out_blob OUT BLOB
)
IS
BEGIN
  SELECT c1 INTO out_clob FROM DBMS_LOB_0329 WHERE id = in_id;
  SELECT c2 INTO out_blob FROM DBMS_LOB_0329 WHERE id = in_id;
END;
/
DECLARE
	v_clob CLOB;
	v_blob BLOB;
BEGIN
	PROCEDURE_1(1, v_clob, v_blob);
	DBMS_OUTPUT.PUT_LINE('clob output:' || TO_CLOB(v_clob));
	DBMS_OUTPUT.PUT_LINE('blob output::' || utl_raw.cast_to_varchar2(v_blob));
END;
/
SELECT TO_CLOB(c1),utl_raw.cast_to_varchar2(c2) FROM DBMS_LOB_0329 WHERE id=1;
+-------------+------------------------------+
| TO_CLOB(C1) | UTL_RAW.CAST_TO_VARCHAR2(C2) |
+-------------+------------------------------+
| CLOB 1      | DSFUY98-SUYFIEWR             |
+-------------+------------------------------+
DECLARE
	v_clob CLOB;
	v_blob BLOB;
BEGIN
	PROCEDURE_1(2, v_clob, v_blob);
	DBMS_OUTPUT.PUT_LINE('clob output:' || TO_CLOB(v_clob));
	DBMS_OUTPUT.PUT_LINE('blob output::' || utl_raw.cast_to_varchar2(v_blob));
END;
/
SELECT TO_CLOB(c1),utl_raw.cast_to_varchar2(c2) FROM DBMS_LOB_0329 WHERE id=2;
+-------------+------------------------------+
| TO_CLOB(C1) | UTL_RAW.CAST_TO_VARCHAR2(C2) |
+-------------+------------------------------+
| CLOB 2      | dsfdfss-sdfsgfsfd            |
+-------------+------------------------------+
DECLARE
	v_clob CLOB;
	v_blob BLOB;
BEGIN
	PROCEDURE_1(2, CREATETEMPORARY(v_clob, TRUE);, CREATETEMPORARY(v_lob, TRUE););
	DBMS_OUTPUT.PUT_LINE('clob output:' || TO_CLOB(v_clob));
	DBMS_OUTPUT.PUT_LINE('blob output::' || utl_raw.cast_to_varchar2(v_blob));
END;
/
