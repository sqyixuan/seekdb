alter database db1 charset binary;
#相同字符集表修改成不同字符集字段进行join
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter table t1 modify c2 varchar(50) character set utf8mb4 ;
alter table t2 modify a2 varchar(50) character set gbk;
select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
count(*)
3
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
count(*)
3
drop table t1;
drop table t2;
