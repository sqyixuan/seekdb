#环境清理
drop database if exists db1;
create database db1;
use db1;
字符集
#不同字符集的表进行join
#binary,utf8mb4
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter  table  t1  character  set  'binary';
alter  table  t2  character  set  'utf8mb4';
select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
count(*)
3
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
count(*)
3
drop table t1;
drop table t2;
#binary,gbk
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
