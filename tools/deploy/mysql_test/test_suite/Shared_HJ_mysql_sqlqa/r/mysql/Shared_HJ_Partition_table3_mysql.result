#环境清理
drop database if exists db1;
create database db1;
use db1;
#key 分区
create table t1(c1 int primary key , c2 int)
partition by key(c1)
partitions 4;
create table t2(a1 int not null,a2 int,unique key(a1))
partition by key(a1)
partitions 4;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i,i+1);
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t2(a1,a2) values(i,i-1);
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#创建key分区使用分区键作为连接条件，ob与MySQL8.0结果不一致；
drop table t1 ;
drop procedure pro1;
drop table t2 ;
drop procedure pro2;
drop database db1;
