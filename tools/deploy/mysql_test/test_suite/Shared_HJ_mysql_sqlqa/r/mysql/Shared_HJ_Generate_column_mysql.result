#环境清理
drop database if exists db1;
create database db1;
use db1;
#虚拟列作为join连接列
CREATE TABLE t1(  
c1 int,  
c2 int GENERATED ALWAYS AS (5 * c1) VIRTUAL
);
CREATE TABLE t2(  
a1 int ,  
a2 int GENERATED ALWAYS AS (10 * a1) VIRTUAL
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1) values(i);
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1) values(i);
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c2=t2.a2;
count(*)
999
#左连接和右连接时mysql夯住不动，ob正常
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 left join t2 on t1.c2=t2.a2;
count(*)
2000
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 right join t2 on t1.c2=t2.a2;
count(*)
2999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
drop database db1;
