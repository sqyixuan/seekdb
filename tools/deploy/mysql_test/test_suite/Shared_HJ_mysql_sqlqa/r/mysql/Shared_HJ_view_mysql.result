insert into view_t1 select /*+parallel(6) use_hash(view_t1,view_t2)*/ * from view_t1  where c1 in(select a1 from view_t2) limit 1;
select count(*) from view_t1 ;
count(*)
2001
select count(*) from view_t2 ;
count(*)
3002
insert into view_t1 select /*+parallel(6) use_hash(view_t1,view_t2)*/ * from view_t1  where c1 not in(select a1 from view_t2) limit 1;
select count(*) from view_t1 ;
count(*)
2002
select count(*) from view_t2 ;
count(*)
3002
#delete
delete from t1 where c1= (select /*+parallel(6) use_hash(t1,t2)*/c1 from (select * from t1 inner join t2 on t1.c1=t2.a1 order by c1 limit 1) as tt) ;
