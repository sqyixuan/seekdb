count(*)
3001
insert into view_t2 select /*+parallel(6) use_hash(view_t1,view_t2)*/a1,a2,a3  from view_t1 right join view_t2 on view_t1.c1=view_t2.a1 order by c1 limit 1;
select count(*) from view_t1 ;
count(*)
2000
