#环境清理
drop database if exists db1;
create database db1;
use db1;
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop procedure if exists pro1;
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop procedure if exists pro2;
CREATE TABLE t1(  
c1 int primary key,  
c2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int primary key,  
a2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#primary key
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
count(*)
1999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int unique,  
c2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int unique,  
a2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#unique
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
count(*)
1999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int check(c1>0),  
c2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int check(a1>0),  
a2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#check
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
count(*)
1999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int default 1 ,  
c2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int default 1,  
a2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#default
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
count(*)
1999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int not null,  
c2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int not null,  
a2 VARCHAR(100) unique
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
#not null
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
count(*)
1999
drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int primary key,  
c2 VARCHAR(100) unique
);
CREATE TABLE t2(  
a1 int primary key,  
a2 VARCHAR(100) unique,
foreign key(a1) references t1(c1)
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2) values(i, concat("李",i/2));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t2(a1,a2) values(i, concat("黄",i*2));
set i = i + 1;
end WHILE;
end;
//
call pro2(1000);
#foreign key
