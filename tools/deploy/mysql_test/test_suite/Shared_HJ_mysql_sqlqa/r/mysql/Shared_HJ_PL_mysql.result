#环境清理
drop database if exists db1;
create database db1;
use db1;
# if条件语句
drop  table  if  exists  t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
drop  table  if  exists  t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop  procedure if  exists  pro1;
drop  procedure if  exists  pro2;
drop  procedure if  exists  pro3;
CREATE TABLE t1(  
c1 int ,  
c2 DECIMAL(5,2) DEFAULT null, 
c3 VARCHAR(100)
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2,c3) values(i,null, concat("李",i));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int ,  
a2 DECIMAL(5,2) DEFAULT null, 
a3 VARCHAR(100)
);
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
while i <= j DO
insert into t2(a1,a2,a3) values(i,null, concat("黄",i));
set i = i + 1;
end WHILE;
end;
//
call pro2(3000);
create procedure pro3(a int,b int)
begin
if  a < b  then
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
else
select /*+parallel(6) use_hash(t1,t2)*/ sum(c1) from t1 inner join t2 on t1.c1=t2.a1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ sum(c1) from t1 inner join t2 on t1.c1=t2.a1 ;
end if;
end//
call pro3(1,2);
count(*)
1999
call pro3(2,1);
sum(c1)
2000999
#循环语句
drop  procedure if  exists  pro3;
create procedure pro3()
begin
Declare c1 int default 1;
repeat
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ sum(c1) from t1 inner join t2 on t1.c1=t2.a1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ sum(c1) from t1 inner join t2 on t1.c1=t2.a1 ;    
set c1 = c1+1;
until c1>=2
end repeat;
end//
call pro3();
count(*)
sum(c1)
1999
1999
drop  procedure if  exists  pro3;
create procedure pro3()
begin
Declare c1 int default 1;
repeat
insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t1 inner join t2 on t1.c1=t2.a1 order by c1,a1 limit 1; 
#explain insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t1 inner join t2 on t1.c1=t2.a1 order by c1,a1 limit 1; 
insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t2 left join t1 on t1.c1=t2.a1 order by c1,a1 limit 1; 
#explain insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t2 left join t1 on t1.c1=t2.a1 order by c1,a1 limit 1;
insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t1 right join t2 on t1.c1=t2.a1 order by c1,a1 limit 1; 
#explain insert into t2 select /*+parallel(6) use_hash(t1,t2)*/a1,a2,a3  from t1 right join t2 on t1.c1=t2.a1 order by c1,a1 limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
#explain  insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
#explain  insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
set c1 = c1+1;
until c1>=2
end repeat;
end//
call pro3();
drop  table  if  exists  t1;
drop  table  if  exists  t2;
drop  procedure if  exists  pro1;
drop  procedure if  exists  pro2;
drop  procedure if  exists  pro3;
#while
create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);
create procedure pro1(a int)
begin
declare i int;
set i = 1;
while i<a
do
select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1 order by c1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
set i = i+1;
end while;
end//
drop   procedure if   exists   pro1;
create procedure pro1(a int)
begin
declare i int;
set i = 1;
while i<a
do
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
set i = i+1;
end while;
end//
call pro1(20);
#loop
drop  table  if  exists  t1;
drop  table  if  exists  t2;
drop  procedure if  exists  pro1;
create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);
create procedure pro1()
begin
declare i int default 10;
label:loop
select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 inner join t2 on t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.a1 order by c1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
set i = i+1;
if i>10 then leave label;
end if;
end loop label;
select * from t1;
end//
call pro1();
