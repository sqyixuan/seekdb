#loop循环
drop   table     if   exists   t1;
drop   table     if   exists   t2;
drop function if exists func1;
create table t1(c1 int, c2 int);
create table t2(a1 int, a2 int);
insert into t1 values (1,1),(2,2),(3,3),(5,5),(6,6),(7,null);
insert into t2 values (2,1),(3,3),(5,5),(6,6),(7,7),(8,8);
create function func1() returns int
begin
Declare tem int default 1;
label:loop
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1,t2 where t1.c1 = t2.a1 limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 inner join t2 on t1.c1 =  t2.a1 order by t1.c1 limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 left join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ a1,a2 from t1 right join t2 on t1.c1 = t2.a1 order by t1.c1 desc limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2) limit 1;
insert into t1 select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2) limit 1;
set tem = tem + 1;
if tem>3 then leave label;
end if;
end loop label;
return 1;
end//
