#环境清理
drop database if exists db1;
create database db1;
use db1;
#join类型
# 不加任何条件进行join
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);
#无条件连接 
select /*+use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
count(*)
12
select /*+parallel(6) use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
count(*)
12
select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
count(*)
5
select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
count(*)
5
select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
count(*)
5
select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
count(*)
5
select count(*)  from (select * from t1,t2)a,(select * from t2,t3)b order by c1 asc,b1 desc;
count(*)
192
select /*+parallel(2) */ count(*)  from (select /*+parallel(2) use_hash(t1,t2)*/ * from t1,t2)a ,(select /*+parallel(2) use_hash(t2,t3)*/ * from t2,t3)b order by c1 asc,b1 desc;
count(*)
192
select count(*)  from (select * from t1 natural join t2)a natural join (select * from t2 natural join t3)b order by c1 asc,b1 desc;
count(*)
48
select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;
count(*)
48
select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;
count(*)
48
# 总结得出,针对于无条件连接即使指定了hint也还是会走nested loop join ;
