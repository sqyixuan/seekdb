drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;
CREATE TABLE t1(  
c1 int primary key,  
c2 DECIMAL(5,2) DEFAULT null, 
c3 VARCHAR(100)
);
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
while i <= j DO
insert into t1(c1,c2,c3) values(i,null, concat("李",i));
set i = i + 1;
end WHILE;
end;
//
call pro1(2000);
CREATE TABLE t2(  
a1 int primary key,  
a2 DECIMAL(5,2) DEFAULT null, 
a3 VARCHAR(100)
);
