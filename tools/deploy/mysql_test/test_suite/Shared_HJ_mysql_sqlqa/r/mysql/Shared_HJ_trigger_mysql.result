#环境清理
drop database if exists db1;
create database db1;
use db1;
#insert型触发器
DROP TABLE IF EXISTS t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
CREATE TABLE t1(c0 TINYINT ZEROFILL AUTO_INCREMENT,
c1 FLOAT NOT NULL,
c2 DOUBLE(5,0) ,
c4 VARCHAR(10),
c7 VARBINARY(20) ,
c8 ENUM('a','b','c','d','e','f','g','h'),
c9 SET('i','j','k','l','m','n','o','p'),
c12 TIME ,
c16 YEAR ,
CONSTRAINT chk_ind CHECK(c16>=2000),
PRIMARY KEY(c0,c1));
INSERT INTO t1 VALUES(1,1.5,1,'','SHUZI!1234567','a','i','20:12:12','2000'),
(2,2.5,2,'中文—汉化','SHUZI!1234567','b','j','21:12:12','2001'),					 
(3,3.5,3,'删除时使用情景','SHUZI!134567','c','k','22:12:12','2002'), 
(4,4.5,4,'删除中——汉化','SHUZI!1234567','d','l','23:12:12','2003'),
(5,5.5,5,'删除中文*汉化删除','SHUZI!134567','e','m','20:22:12','2004'),
(6,6.5,6,'除列时使用情景','SHUZI!123457','f','n','20:32:12','2005'),
(7,7.5,7,'时使用情','SHUZI!123456','a','i','20:12:12','2006'),
(8,8.5,8,'中文—0汉化','SHUZI!234567','b','j','11:12:12','2007'),
(9,9.5,9,'删除使1用情景','SHUZ!1234567','c','k','02:12:12','2008'),
(13,10.5,10,'删除中—2汉化','SHUI!1234567','d','l','03:12:12','2009'),
(14,11.5,11,'删除中文*汉除','SHZI!14567','e','m','00:22:12','2010'),
(17,12.5,12,'列时使3用情','SHZI!12567','f','n','00:32:12','2011');
CREATE INDEX ind_1 ON t1(c12);
CREATE INDEX ind_2 ON t1(c7);
DROP TABLE IF EXISTS t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
CREATE TABLE t2(c0 INT,c1 VARCHAR(10));
INSERT INTO t2 VALUES(1,'A'),(2,'B'),(3,'C'),(4,'D'),(5,'E'),(6,'F'),(10,'G'),(13,'H'),(14,'I'),(15,'G'),(19,'H'),(22,'I');
create trigger t1 after insert on  t2
for each row
begin 
update t1 set c4="中文—汉化" where c4="";
end //
#ob成功添加，但mysql8.0和5.7均不能更新触发器中的表;
