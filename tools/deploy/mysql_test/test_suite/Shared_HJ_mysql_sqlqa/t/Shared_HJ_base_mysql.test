# c2和a2是不同字符集 不同字符集之间不能直接比较;
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter table t1 modify c2 varchar(50) character set gbk ;
alter table t2 modify a2 varchar(50) character set gb18030;

#select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
#explain select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
#select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
drop table t1;drop table t2;

create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter table t1 modify c2 varchar(50) character set utf16 ;
alter table t2 modify a2 varchar(50) character set gb18030;

select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
#explain select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c2=t2.a2 order by t1.c1;
drop table t1;drop table t2;

drop database db1;