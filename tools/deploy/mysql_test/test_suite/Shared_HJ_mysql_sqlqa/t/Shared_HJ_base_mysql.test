#owner:wenkai.cwk
#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:测试不同字符集建表连接以及字段
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo 字符集
--echo #不同字符集的表进行join
--echo #binary,utf8mb4
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter  table  t1  character  set  'binary';
alter  table  t2  character  set  'utf8mb4';


select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
drop table t1;drop table t2;


--echo #binary,gbk
create table t1(c1 int primary key,c2 varchar(50) not null);
insert into t1 values(1,1),(2,2),(3,3);
create table t2(a1 int primary key,a2 varchar(50));
insert into t2 values(1,1),(2,2),(3,3),(4,4);
alter  table  t1  character  set  'binary';
alter  table  t2  character  set  'gbk';

select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain select /*+use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1,t2 where t1.c1=t2.a1 order by t1.c1;
drop table t1;drop table t2;

