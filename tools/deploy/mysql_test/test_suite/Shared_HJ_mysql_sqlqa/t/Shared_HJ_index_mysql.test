#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:index
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

CREATE TABLE t1(  
c1 int ,  
c2 VARCHAR(100) 
);

DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1,c2) values(i, concat("李",i/2));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);

CREATE TABLE t2(  
a1 int ,  
a2 VARCHAR(100) 
);

DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
    while i <= j DO
		insert into t2(a1,a2) values(i, concat("黄",i*2));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(3000);

--echo #普通索引列作为join连接列
create index t1_c1 on t1(c1);
create index t2_a1 on t2(a1);

select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;


drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;