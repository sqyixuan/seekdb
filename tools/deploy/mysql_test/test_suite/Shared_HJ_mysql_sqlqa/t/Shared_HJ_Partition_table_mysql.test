#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:Partition table
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo	#hash 分区
create table t1(c1 int primary key ,c2 int) partition by hash(c1)
(
partition p1 ,
partition p2 ,
partition p3 
);
create table t2(a1 int ,a2 int) partition by hash(a1)
(
partition p1 ,
partition p2 ,
partition p3 
);

DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1,c2) values(i,i+1);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);

DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t2(a1,a2) values(i,i-1);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(3000);

select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;


drop table t1 ;
drop procedure pro1;
drop table t2 ;
drop procedure pro2;

drop database db1;

