--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

CREATE TABLE t1(c0 TINYINT ZEROFILL AUTO_INCREMENT,
                c1 FLOAT NOT NULL,
                c2 DOUBLE(5,0) ,
                c3 BIT(20) DEFAULT 0,
                c4 BLOB,
                c5 TEXT,
                c6 VARCHAR(50),
                c7 CHAR(50),
                c8 BINARY(50) ,
                c9 VARBINARY(50) ,
                c10 ENUM('a','b','c','d','e','f','g','h'),
                c11 SET('i','j','k','l','m','n','o','p'),
                c12 TIME ,
                c13 DATE ,
                c14 DATETIME ,
                c15 TIMESTAMP DEFAULT '2000-01-01 00:00:00',
                c16 YEAR ,
                CONSTRAINT chk_ind CHECK(c16>=2000),
                PRIMARY KEY(c0,c1,c2),
                UNIQUE KEY uni_key(c6,c10));
