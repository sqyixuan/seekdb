#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:Partition table
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;



--echo  #range - key复合分区
create table t1(c1 int,c2 int)
partition by range(c1)
subpartition by key(c2)
subpartitions 3
(
partition p1 values less than (200),
partition p2 values less than maxvalue
);
create table t2(a1 int,a2 int)
partition by range(a1)
subpartition by key(a2)
subpartitions 3
(
partition p1 values less than (400),
partition p2 values less than maxvalue
);
DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1,c2) values(i,i+1);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);

DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t2(a1,a2) values(i,i-1);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(3000);

 

select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c2=t2.a2;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c2=t2.a2;

select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 left join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 left join t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 right join t2 on t1.c1=t2.a1;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 right join t2 on t1.c1=t2.a1;


drop table t1 ;
drop procedure pro1;
drop table t2 ;
drop procedure pro2;


drop database db1;

