#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:Generate column
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo	#虚拟列 为not null作为连接列
CREATE TABLE t1(  
c1 int,  
c2 int GENERATED ALWAYS AS (5 * c1) VIRTUAL not null 
);
CREATE TABLE t2(  
a1 int ,  
a2 int GENERATED ALWAYS AS (5 * a1) VIRTUAL not null  
);

DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1) values(i);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);


DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
    while i <= j DO
		insert into t2(a1) values(i);
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(3000);

select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c2=t2.a2;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 inner join t2 on t1.c2=t2.a2;

--echo #左连接和右连接时mysql夯住不动，ob正常
#select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 left join t2 on t1.c2=t2.a2;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 left join t2 on t1.c2=t2.a2;
#select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 right join t2 on t1.c2=t2.a2;
#explain select /*+parallel(6) use_hash(t1,t2)*/count(*) from t1 right join t2 on t1.c2=t2.a2;

drop table t1;
drop procedure pro1;
drop table t2;
drop procedure pro2;


drop database db1;