drop table t1 ;
drop procedure pro1;
drop table t2 ;
drop procedure pro2;
drop table tt1;
drop table tt2;


CREATE TABLE t1(  
c1 int ,  
c2 DECIMAL(5,2) DEFAULT null, 
c3 VARCHAR(100)
);
DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1,c2,c3) values(i,null, concat("李",i));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);

CREATE TABLE t2(  
a1 int ,  
a2 DECIMAL(5,2) DEFAULT null, 
a3 VARCHAR(100)
);
DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
    while i <= j DO
		insert into t2(a1,a2,a3) values(i,null, concat("黄",i));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(3000);
create table tt1 as select * from t1;
create table tt2 as select * from t2;


--echo #update

update /*+parallel(6) use_hash(tt1,tt2)*/tt1 inner join tt2 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );
#explain update /*+parallel(6) use_hash(tt1,tt2)*/tt1 inner join tt2 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );

update /*+parallel(6) use_hash(tt1,tt2)*/tt2 left join tt1 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );
#explain update /*+parallel(6) use_hash(tt1,tt2)*/tt2 left join tt1 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );

update /*+parallel(6) use_hash(tt1,tt2)*/tt1 right join tt2 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );
#explain update /*+parallel(6) use_hash(tt1,tt2)*/tt1 right join tt2 on tt1.c1=tt2.a1 set tt1.c2=6,tt2.a2=7  where tt1.c1 =(select c1 from(select c1 from tt1 order by c1 limit 6,1)as tt );

update /*+parallel(6) use_hash(tt1,tt2)*/tt1 inner join tt2 on tt1.c1=tt2.a1 set tt1.c1=2,tt2.a1=3 where tt1.c3="李6";
#explain update /*+parallel(6) use_hash(tt1,tt2)*/tt1 inner join tt2 on tt1.c1=tt2.a1 set tt1.c1=2,tt2.a1=3 where tt1.c3="李6";

update /*+parallel(6) use_hash(tt1,tt2)*/tt2 left join tt1 on tt1.c1=tt2.a1 set tt1.c1=2,tt2.a1=3 where tt1.c3="李6";
select * from tt1 limit 10;select * from tt2 limit 10;
