#owner group:技术部_sql_sql2
#description:Shared_Hash_Join
#tags:测试各种join
#author:wb-ljh01399065
--echo #环境清理
--disable_warnings

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo #join类型

--echo # 不加任何条件进行join
create table t1(c1 int,c2 int);
create table t2(a1 int,a2 int);
create table t3(b1 int,b2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,6);
insert into t2 values(1,2);
insert into t2 values(2,2);
insert into t2 values(3,4);
insert into t2 values(5,7);
insert into t3 values(1,null);
insert into t3 values(null,1);
insert into t3 values(null,null);

--echo  #无条件连接 
select /*+use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
#explain basic select /*+use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
select /*+parallel(6) use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;
#explain basic select /*+parallel(6) use_hash(t2,t3)*/ count(*)  from t2 natural join t3 order by t2.a1;

select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
#explain basic select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2;

select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
#explain basic select /*+use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*)  from t1,t2 where t1.c2> t2.a2 order by t1.c1 desc;

select count(*)  from (select * from t1,t2)a,(select * from t2,t3)b order by c1 asc,b1 desc;
#explain basic select count(*)  from (select * from t1,t2)a,(select * from t2,t3)b order by c1 asc,b1 desc;
select /*+parallel(2) */ count(*)  from (select /*+parallel(2) use_hash(t1,t2)*/ * from t1,t2)a ,(select /*+parallel(2) use_hash(t2,t3)*/ * from t2,t3)b order by c1 asc,b1 desc;
#explain basic select /*+parallel(2) */ count(*)  from (select /*+parallel(2) use_hash(t1,t2)*/ * from t1,t2)a ,(select /*+parallel(2) use_hash(t2,t3)*/ * from t2,t3)b order by c1 asc,b1 desc;

select count(*)  from (select * from t1 natural join t2)a natural join (select * from t2 natural join t3)b order by c1 asc,b1 desc;
#explain basic select count(*)  from (select * from t1 natural join t2)a natural join (select * from t2 natural join t3)b order by c1 asc,b1 desc;
select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;
#explain basic select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;
select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;
#explain basic select /*+parallel(2) */ count(*) from (select /*+parallel(2)*/ * from t1 natural join t2)a natural join (select /*+parallel(2)*/ * from t2 natural join t3)b order by c1 asc,b1 desc;

--echo # 总结得出,针对于无条件连接即使指定了hint也还是会走nested loop join ;

--echo # 内连接
select /*+use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1;

select /*+use_hash(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
#explain basic select /*+use_hash(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
select /*+parallel(6) use_hash(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;
#explain basic select /*+parallel(6) use_hash(t2,t3)*/ * from t2,t3 where t2.a1=t3.b1 order by t2.a1;

select /*+use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
#explain basic select /*+use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1,t2 where t1.c1=t2.a1 order by t1.c1 desc;

select /*+use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t1.c1;

select /*+use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
select /*+parallel(6) use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ distinct t2.a2 from t1,t2 where t1.c1=t2.a1 order by t2.a2 desc;


--echo  #left join
select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1;

select /*+use_hash(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
#explain basic select /*+use_hash(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
select /*+parallel(6) use_hash(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;
#explain basic select /*+parallel(6) use_hash(t2,t3)*/ * from t2 left join t3 on t2.a1=t3.b1;

select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;

select /*+use_hash(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+use_hash(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1 left join  t2 on t1.c1=t2.a1 order by t1.c2 desc;

--echo  #right join
select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1;

select /*+use_hash(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
#explain basic select /*+use_hash(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
select /*+parallel(6) use_hash(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;
#explain basic select /*+parallel(6) use_hash(t2,t3)*/ * from t2 right join  t3 on t2.a1=t3.b1;

select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 order by t2.a2 desc;

select /*+use_hash(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
#explain basic select /*+use_hash(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ count(*) from t1 right join  t2 on t1.c1=t2.a1 ;

--echo  #full join
select /*+use_hash(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full join  t2 on t1.c1=t2.a1 order by t1.c1;

select /*+use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 order by t1.c1;

select /*+use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 full outer join  t2 on t1.c1=t2.a1 where t1.c1 is null or t2.a1 is null order by t1.c1;

--echo  #半连接
--echo  #semi join

select /*+use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
#explain basic select /*+use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 in(select a1 from t2);

select /*+use_hash(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
#explain basic select /*+use_hash(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 = any(select a1 from t2);

--echo  #反链接
--echo  #anti join

select /*+use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
#explain basic select /*+use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 not in(select a1 from t2);

select /*+use_hash(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
#explain basic select /*+use_hash(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1  where c1 != all(select a1 from t2);

select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 left join  t2 on t1.c1=t2.a1 where t2.a1 is null;

select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
#explain basic select /*+use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;
#explain basic select /*+parallel(6) use_hash(t1,t2)*/ * from t1 right join  t2 on t1.c1=t2.a1 where t1.c1 is null;

drop table t1;
drop table t2;
drop table t3;


--echo  #case when
create table t1(sid int(1),sname char(20),age int(1),sex int(1));
create table t2(sid int(1),cid char(5),grade char(20)) ;
create table t3(cid char(5),cname char(20),teacher char(20));
insert into t1(sid,sname,age,sex)values
(1111,'david',28,1),
(1112,'dany',23,0),
(1113,'tom',38,1),
(1114,'lily',20,0);
insert into t2(sid,cid,grade)values
(1113,'c1','38'),
(1112,'c2','80'),
(1112,'c3','67'),
(1111,'c4','88'),
(1114,'c4','66');
insert into t3(cid,cname,teacher)values
('c4','maths','zhangsan'),
('c3','english','lisi'),
('c2','chinese','wangwu'),
('c1','computer','zhaoliu');

select /*+parallel(6) use_hash(t1,t2)*/ distinct t1.sid,sname,(case sex when '0' then '女' when '1' then '男' else '其他' end) from t1 inner join t2 on t1.sid=t2.sid inner join t3 on t3.cid=t2.cid order by t1.sid limit 2; 
#explain select /*+parallel(6) use_hash(t1,t2)*/ distinct t1.sid,sname,(case sex when '0' then '女' when '1' then '男' else '其他' end) from t1 inner join t2 on t1.sid=t2.sid inner join t3 on t3.cid=t2.cid order by t1.sid limit 2; 
 
select /*+parallel(6) use_hash(t1,t2)*/ sname,(case when grade between 60 and 80  then '良好' when grade >80  then '优秀' else '不及格' end) from t1 inner join t2 on t1.sid=t2.sid inner join t3 on t3.cid=t2.cid  order by t2.grade desc limit 2;
#explain select /*+parallel(6) use_hash(t1,t2)*/ sname,(case when grade between 60 and 80  then '良好' when grade >80  then '优秀' else '不及格' end) from t1 inner join t2 on t1.sid=t2.sid inner join t3 on t3.cid=t2.cid  order by t2.grade desc limit 2;



 
--echo # 聚合函数
--echo # count，avg，min，max，sum


drop table if exists t1;
drop procedure if exists pro1;
drop table if exists t2;
drop procedure if exists pro2;

CREATE TABLE t1(  
c1 int primary key,  
c2 DECIMAL(5,2) DEFAULT null, 
c3 VARCHAR(100)
);

DELIMITER //;
CREATE  PROCEDURE pro1(in j int)
begin
DECLARE i int;
set i = 1;
    while i <= j DO
		insert into t1(c1,c2,c3) values(i,null, concat("李",i));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro1(2000);

CREATE TABLE t2(  
a1 int primary key,  
a2 DECIMAL(5,2) DEFAULT null, 
a3 VARCHAR(100)
);
DELIMITER //;
CREATE  PROCEDURE pro2(in j int)
begin
DECLARE i int;
set i = 2;
    while i <= j DO
		insert into t2(a1,a2,a3) values(i,null, concat("黄",i));
	set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//
call pro2(2000);

select /*+parallel(6) use_hash(t1,t2)*/min(c1)  from t1,t2 where t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ min(c1) from t1,t2 where t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/min(c1)  from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ min(c1) from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/min(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ min(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;

select /*+parallel(6) use_hash(t1,t2)*/count(c1)  from t1,t2 where t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ count(c1) from t1,t2 where t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/count(c1)  from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ count(c1) from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/count(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ count(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;

select /*+parallel(6) use_hash(t1,t2)*/max(c1)  from t1,t2 where t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ max(c1) from t1,t2 where t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/max(c1)  from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ max(c1) from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/max(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ max(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;

select /*+parallel(6) use_hash(t1,t2)*/avg(c1)  from t1,t2 where t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ avg(c1) from t1,t2 where t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/avg(c1)  from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ avg(c1) from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/avg(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ avg(c1) from t1,(select * from t2)a where t1.c1=a.a1 order by c1 ;

select /*+parallel(6) use_hash(t1,t2)*/sum(c1)  from t1,t2 where t1.c1=t2.a1 order by c1 ;
#explain select /*+parallel(6) use_hash(t1,t2)*/ sum(c1) from t1,t2 where t1.c1=t2.a1 order by c1 ;
select /*+parallel(6) use_hash(t1,t2)*/sum(c1)  from t1 inner join t2 on t1.c1=t2.a1 order by c1 ;
