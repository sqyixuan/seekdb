##more than stale percent(default value:10)
update GENERAL_TAB_UNIFORM set F1 = 10000 where F1 >=10;
update PARTITIONED_HASH_TAB_UNIFORM partition(p0) set F3 = 10000 where F1 < 100;
update PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp0) set F3 = 10000 where F1 <= 100;
update PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp1) set F3 = 10000 where F1 <= 100;
