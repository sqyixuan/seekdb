delete from GENERAL_TAB_FRE where f1 <= 30;
delete from GENERAL_TAB_GAUSSIAN where f1 <= 1000;
delete from PARTITIONED_HASH_TAB_UNIFORM where f1 <= 80;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
use yyl;

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

