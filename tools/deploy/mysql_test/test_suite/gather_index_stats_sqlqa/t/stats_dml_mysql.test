update I_GENERAL_TAB_UNIFORM set f3 = 100 where f1 <= 5;
update I_GENERAL_TAB_UNIFORM set f3 = 100 where f1 <= 20;
update I_GENERAL_TAB_GAUSSIAN set f3 = 100 where f1 <= 100;
