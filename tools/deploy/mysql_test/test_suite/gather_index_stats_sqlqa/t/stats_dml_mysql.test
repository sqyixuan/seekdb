#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connection default;

--disable_query_log
--error 0,1396
drop user yyl;
sleep 3;
create user 'yyl' identified by '123';
GRANT all privileges ON *.* TO 'yyl'@'%' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
--enable_query_log
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connect(conn,$OBMYSQL_MS0,yyl,123,test,$OBMYSQL_PORT);
connection conn;

set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_result_log
--disable_warnings
drop database IF EXISTS yyl;
--enable_warnings
--enable_result_log

create database yyl  character set utf8;
use yyl;
--source mysql_test/test_suite/gather_index_stats_sqlqa/include/prepare_table_mysql.inc
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
use yyl;

SELECT COUNT(*) FROM GENERAL_TAB_UNIFORM;
SELECT COUNT(*) FROM GENERAL_TAB_GAUSSIAN;
SELECT COUNT(*) FROM PARTITIONED_HASH_TAB_UNIFORM;
SELECT COUNT(*) FROM PARTITIONED_LISTRANGE_TAB_UNIFORM;
SELECT COUNT(*) FROM PARTITIONED_LISTHASH_TAB_GAUSSIAN;
SELECT COUNT(*) FROM I_GENERAL_TAB_UNIFORM;
SELECT COUNT(*) FROM I_GENERAL_TAB_GAUSSIAN;
SELECT COUNT(*) FROM I_PARTITIONED_LIST_TAB_GAUSSIAN;
SELECT COUNT(*) FROM GENERAL_TAB_FRE;
SELECT COUNT(*) FROM GENERAL_TAB_TOPK;

--result_format 4
--echo ## 测分 gather_index_stats-01-02 ###
--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

insert into GENERAL_TAB_UNIFORM select * from GENERAL_TAB_UNIFORM;
insert into GENERAL_TAB_GAUSSIAN select * from GENERAL_TAB_GAUSSIAN;
insert into PARTITIONED_HASH_TAB_UNIFORM select * from PARTITIONED_HASH_TAB_UNIFORM;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
use yyl;

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

##replace
replace into PARTITIONED_LISTRANGE_TAB_UNIFORM select * from PARTITIONED_LISTRANGE_TAB_UNIFORM;
replace into PARTITIONED_LISTHASH_TAB_GAUSSIAN select * from PARTITIONED_LISTHASH_TAB_GAUSSIAN order by f1 desc limit 100;
replace into PARTITIONED_LISTHASH_TAB_GAUSSIAN select * from PARTITIONED_LISTHASH_TAB_GAUSSIAN;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
use yyl;

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

call dbms_stats.FLUSH_DATABASE_MONITORING_INFO();

--sorted_result
select TABLE_OWNER,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,INSERTS,UPDATES,DELETES from oceanbase.dba_tab_modifications where TABLE_OWNER='YYL' and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK');

