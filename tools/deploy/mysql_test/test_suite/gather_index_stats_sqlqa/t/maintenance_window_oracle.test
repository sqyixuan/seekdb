#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--source mysql_test/include/check_schema_sync.inc
--source mysql_test/test_suite/histogram/include/create_oracle_tenant.inc
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
--source mysql_test/test_suite/histogram/include/conn_oracle_sys_tenant.inc
--disable_query_log
call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_ALL_TABLE');
call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_COLUMN_TABLE');
--enable_query_log
--source mysql_test/test_suite/gather_index_stats_sqlqa/include/prepare_table.inc
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
connection conn_stat_test_sys;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
purge recyclebin;

--echo ###设置自动化收集任务，30s之后开始###
purge recyclebin;
--disable_query_log
--disable_result_log
let $point = query_get_value("select substr(sysdate + 30*1/24/60/60, 0, 26) as X from dual;", X, 1);
let $day = query_get_value("SELECT MOD(TO_NUMBER(TO_CHAR(sysdate, 'D')) + 5, 7) as X FROM dual;", X, 1);
if ($day == 0) {
  eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 1) {
  eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 2) {
  eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 3) {
  eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 4) {
  eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 5) {
  eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 6) {
  eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
}
--enable_result_log
--enable_query_log

--disable_query_log
select count(*) as CNT from DBA_TAB_STATISTICS where LAST_ANALYZED is not null and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'SYS';
##wait auto gather table stats finish
let $__i__= 180;
while($__i__ > 0)
{
  sleep 1;
  dec $__i__;
  let $__memstore_cnt__ = query_get_value("select count(*) as CNT from DBA_TAB_STATISTICS where LAST_ANALYZED is not null and table_name in (
'GENERAL_TAB_UNIFORM'
,'GENERAL_TAB_GAUSSIAN'
,'PARTITIONED_RANGE_TAB_UNIFORM'
,'PARTITIONED_RANGE_TAB_GAUSSIAN'
,'PARTITIONED_HASH_TAB_UNIFORM'
,'PARTITIONED_HASH_TAB_GAUSSIAN'
,'PARTITIONED_LIST_TAB_UNIFORM'
,'PARTITIONED_LIST_TAB_GAUSSIAN'
,'PARTITIONED_RANGEHASH_TAB_UNIFORM'
,'PARTITIONED_RANGEHASH_TAB_GAUSSIAN'
,'PARTITIONED_RANGELIST_TAB_UNIFORM'
,'PARTITIONED_RANGELIST_TAB_GAUSSIAN'
,'PARTITIONED_LISTRANGE_TAB_UNIFORM'
,'PARTITIONED_LISTRANGE_TAB_GAUSSIAN'
,'PARTITIONED_LISTRANGE_TAB_GAUSSIAN2'
,'PARTITIONED_LISTRANGE_TAB_UNIFORM2'
,'PARTITIONED_LISTHASH_TAB_UNIFORM'
,'PARTITIONED_LISTHASH_TAB_GAUSSIAN'
,'COMPOSITE_PARTITIONED_TAB'
,'TMP_COMPOSITE_PARTITIONED_TAB'
,'PARTITIONED_TAB'
,'GENERAL_TAB'
,'I_GENERAL_TAB_UNIFORM'
,'I_GENERAL_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGE_TAB_UNIFORM'
,'I_PARTITIONED_RANGE_TAB_GAUSSIAN'
,'I_PARTITIONED_HASH_TAB_UNIFORM'
,'I_PARTITIONED_HASH_TAB_GAUSSIAN'
,'I_PARTITIONED_LIST_TAB_UNIFORM'
,'I_PARTITIONED_LIST_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGEHASH_TAB_UNIFORM'
,'I_PARTITIONED_RANGEHASH_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGELIST_TAB_UNIFORM'
,'I_PARTITIONED_RANGELIST_TAB_GAUSSIAN'
,'I_PARTITIONED_LISTRANGE_TAB_UNIFORM'
,'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN'
,'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN2'
,'I_PARTITIONED_LISTRANGE_TAB_UNIFORM2'
,'I_PARTITIONED_LISTHASH_TAB_UNIFORM'
,'I_PARTITIONED_LISTHASH_TAB_GAUSSIAN'
,'I_COMPOSITE_PARTITIONED_TAB'
,'I_TMP_COMPOSITE_PARTITIONED_TAB'
,'I_PARTITIONED_TAB'
,'I_GENERAL_TAB'
,'GENERAL_TAB_FRE'
,'GENERAL_TAB_TOPK'
) and OWNER = 'SYS';", CNT, 1);
  if ($__memstore_cnt__ == 578)
  {
    let $__i__ = -1;
  }
}
if ($__i__ != -1)
{
  --echo auto gather table sats failed $__memstore_cnt__
}
--enable_query_log
--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from DBA_TAB_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'SYS';

--echo ###自动收集任务完成后，root用户登录查看任务状态,gather_index_stats-01-01-02###
connection conn_root;
purge recyclebin;
--disable_result_log
select * from __all_virtual_scheduler_job_run_detail_v2 ORDER BY TIME;
--enable_result_log

--echo ###自动收集任务完成后，普通用户登录查看信息收集结果,对应测分全量表类型覆盖,gather_index_stats-01-01-01-01###
connection conn_stat_test_sys;
purge recyclebin;
--disable_result_log
select * from DBA_SCHEDULER_JOBS;
select count(*) from sys.all_virtual_tenant_scheduler_job_real_agent where this_date is not null or last_date is not null;
--enable_result_log

--echo  ###GENERAL_TAB_UNIFORM###
--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position, object_type, num_rows, avg_row_len/*, last_analyzed*/ FROM USER_TAB_STATISTICS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY subpartition_name,partition_name;
--disable_result_log
--sorted_result
SELECT table_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets/*, last_analyzed*/, sample_size, avg_col_len, histogram FROM USER_TAB_COL_STATISTICS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY column_name;
--sorted_result
SELECT table_name, partition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size/*, last_analyzed*/, avg_col_len, histogram FROM USER_PART_COL_STATISTICS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY partition_name,column_name;
--sorted_result
SELECT table_name, subpartition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size/*, last_analyzed*/, avg_col_len, histogram FROM USER_SUBPART_COL_STATISTICS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY subpartition_name,column_name;
--sorted_result
SELECT table_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_TAB_HISTOGRAMS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY column_name,endpoint_number;
--sorted_result
SELECT table_name, partition_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_PART_HISTOGRAMS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY partition_name,column_name,endpoint_number;
--sorted_result
SELECT table_name, subpartition_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_SUBPART_HISTOGRAMS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY subpartition_name,column_name,endpoint_number;
