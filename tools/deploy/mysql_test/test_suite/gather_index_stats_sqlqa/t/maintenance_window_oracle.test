SELECT table_name, partition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size/*, last_analyzed*/, avg_col_len, histogram FROM USER_PART_COL_STATISTICS WHERE table_name='GENERAL_TAB_TOPK' ORDER BY partition_name,column_name;
--sorted_result
SELECT table_name, subpartition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size/*, last_analyzed*/, avg_col_len, histogram FROM USER_SUBPART_COL_STATISTICS WHERE table_name='GENERAL_TAB_TOPK' ORDER BY subpartition_name,column_name;
--sorted_result
SELECT table_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_TAB_HISTOGRAMS WHERE table_name='GENERAL_TAB_TOPK' ORDER BY column_name,endpoint_number;
--sorted_result
SELECT table_name, partition_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_PART_HISTOGRAMS WHERE table_name='GENERAL_TAB_TOPK' ORDER BY partition_name,column_name,endpoint_number;
--sorted_result
SELECT table_name, subpartition_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_SUBPART_HISTOGRAMS WHERE table_name='GENERAL_TAB_TOPK' ORDER BY subpartition_name,column_name,endpoint_number;
--enable_result_log

--source mysql_test/test_suite/histogram/include/drop_oracle_tenant.inc
connection default;

purge recyclebin;

connection conn_admin;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
