#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connection default;

--disable_query_log
--error 0,1396
drop user yyl;
sleep 3;
create user 'yyl' identified by '123';
GRANT all privileges ON *.* TO 'yyl'@'%' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
--enable_query_log
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connect(conn,$OBMYSQL_MS0,yyl,123,test,$OBMYSQL_PORT);
connection conn;

set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS yyl;
--enable_warnings

create database yyl character set utf8;
use yyl;

--echo #数据类型,兼容性验证gather_index_stats-02-02-01、gather_index_stats-02-02-01-02-03#
###整数类型：BOOL/BOOLEAN/TINYINT、SMALLINT、MEDIUMINT、INT/INTEGER 和 BIGINT。
###定点类型：DECIMAL 和 NUMERIC。
###浮点类型：FLOAT 和 DOUBLE。
###Bit-Value 类型：BIT。
--error 0,1051
DROP TABLE TEST_DTYPE;
CREATE TABLE TEST_DTYPE (F1 TINYINT, f2 SMALLINT, f3 MEDIUMINT, f4 INT, f5 INTEGER, f6 BIGINT);

INSERT INTO TEST_DTYPE VALUES(1 ,1 ,1 ,1 ,1 ,1 );
INSERT INTO TEST_DTYPE VALUES(2 ,2 ,2 ,2 ,2 ,2 );
INSERT INTO TEST_DTYPE VALUES(3 ,3 ,3 ,3 ,3 ,3 );
INSERT INTO TEST_DTYPE VALUES(4 ,4 ,4 ,4 ,4 ,4 );
INSERT INTO TEST_DTYPE VALUES(5 ,5 ,5 ,5 ,5 ,5 );
INSERT INTO TEST_DTYPE VALUES(6 ,6 ,6 ,6 ,6 ,6 );
INSERT INTO TEST_DTYPE VALUES(7 ,7 ,7 ,7 ,7 ,7 );
INSERT INTO TEST_DTYPE VALUES(8 ,8 ,8 ,8 ,8 ,8 );
INSERT INTO TEST_DTYPE VALUES(9 ,9 ,9 ,9 ,9 ,9 );
INSERT INTO TEST_DTYPE VALUES(10,10,10,10,10,10);

CALL dbms_stats.gather_table_stats(NULL,'TEST_DTYPE',NULL,method_opt=>'FOR ALL COLUMNS SIZE 20',degree=>4,granularity=>'ALL');
--disable_result_log
--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position, object_type, num_rows, avg_row_len/*, last_analyzed*/ FROM OceanBase.DBA_TAB_STATISTICS WHERE table_name='TEST_DTYPE' ORDER BY subpartition_name,partition_name;
--sorted_result
SELECT table_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets/*, last_analyzed*/, sample_size, avg_col_len, histogram FROM OceanBase.DBA_TAB_COL_STATISTICS WHERE table_name='TEST_DTYPE' ORDER BY column_name;
--sorted_result
SELECT table_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM OceanBase.DBA_TAB_HISTOGRAMS WHERE table_name='TEST_DTYPE' ORDER BY column_name,endpoint_number;

--error 0,1051
DROP TABLE TEST_DTYPE;
CREATE TABLE TEST_DTYPE (F1 DECIMAL(10,3), f2 NUMERIC, f3 DOUBLE, f4 BOOL, f5 BOOLEAN, f6 BIT(10));

INSERT INTO TEST_DTYPE VALUES(1 ,1 ,1 ,0,1,b'111' );
INSERT INTO TEST_DTYPE VALUES(2 ,2 ,2 ,0,1,b'10000000');
INSERT INTO TEST_DTYPE VALUES(3 ,3 ,3 ,0,1,b'111');
INSERT INTO TEST_DTYPE VALUES(4 ,4 ,4 ,0,1,b'110');
INSERT INTO TEST_DTYPE VALUES(5 ,5 ,5 ,0,1,b'111');
INSERT INTO TEST_DTYPE VALUES(6 ,6 ,6 ,0,1,b'111');
INSERT INTO TEST_DTYPE VALUES(7 ,7 ,7 ,0,1,b'011');
INSERT INTO TEST_DTYPE VALUES(8 ,8 ,8 ,0,1,b'111');
INSERT INTO TEST_DTYPE VALUES(9 ,9 ,9 ,0,1,b'101');
INSERT INTO TEST_DTYPE VALUES(10,10,10,0,1,b'111');

CALL dbms_stats.gather_table_stats(NULL,'TEST_DTYPE',NULL,method_opt=>'FOR ALL COLUMNS SIZE 20',degree=>4,granularity=>'ALL');
--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position, object_type, num_rows, avg_row_len/*, last_analyzed*/ FROM OceanBase.DBA_TAB_STATISTICS WHERE table_name='TEST_DTYPE' ORDER BY subpartition_name,partition_name;
--sorted_result
SELECT table_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets/*, last_analyzed*/, sample_size, avg_col_len, histogram FROM OceanBase.DBA_TAB_COL_STATISTICS WHERE table_name='TEST_DTYPE' ORDER BY column_name;
--sorted_result
SELECT table_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM OceanBase.DBA_TAB_HISTOGRAMS WHERE table_name='TEST_DTYPE' ORDER BY column_name,endpoint_number;


--echo ###数值类型
--error 0,1051
DROP TABLE IF EXISTS TEST_DTYPE;
CREATE TABLE TEST_DTYPE(c0  BOOL, c1 BOOLEAN,c2 TINYINT(20),c3 SMALLINT,c4 MEDIUMINT,c5 INT(100) ZEROFILL,c6 INTEGER,c7 BIGINT,c8 DECIMAL(10, 5) ZEROFILL,c9 NUMERIC(10, 5),c10 FLOAT,c11 DOUBLE,c12 BIT(64));
INSERT INTO TEST_DTYPE VALUES (1,true,45,11,11,11,11,9223372036854775807,10.2,10.2,-10.25,-13.45,b'10000000');
INSERT INTO TEST_DTYPE VALUES (2,true,45,11,11,11,11,9223372036854775807,10.2,10.2,-10.25,-13.45,b'10000000');
