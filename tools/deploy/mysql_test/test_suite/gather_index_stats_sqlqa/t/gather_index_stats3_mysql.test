create database yyl  character set utf8;
use yyl;
--echo ###无主键、唯一键、索引表,普通表、均匀分布###

##由于oracle兼容的视图没有平均行长、宏块、微块字段，这里提前创建一个视图用于查询
create view index_stats_view as SELECT
    CAST(DB.DATABASE_NAME AS CHAR(128)) AS OWNER,
    CAST(V.INDEX_NAME AS     CHAR(128)) AS INDEX_NAME,
    CAST(DB.DATABASE_NAME AS     CHAR(128)) AS TABLE_OWNER,
    CAST(T.TABLE_NAME       AS  CHAR(128)) AS TABLE_NAME,
    CAST(V.PARTITION_NAME   AS  CHAR(128)) AS PARTITION_NAME,
    CAST(V.SUBPARTITION_NAME  AS    CHAR(128)) AS SUBPARTITION_NAME,
    CAST(V.OBJECT_TYPE AS CHAR(12)) AS OBJECT_TYPE,
    CAST(STAT.ROW_CNT AS    DECIMAL) AS NUM_ROWS,
    CAST(STAT.AVG_ROW_LEN AS    DECIMAL) AS AVG_ROW_LEN,
    CAST(STAT.macro_blk_cnt AS    DECIMAL) AS MACRO_BLK_CNT,
    CAST(STAT.micro_blk_cnt AS    DECIMAL) AS MICRO_BLK_CNT
    FROM
    (SELECT TENANT_ID,
            DATABASE_ID,
            TABLE_ID,
            DATA_TABLE_ID,
            CASE WHEN PART_LEVEL = 0 THEN -2 ELSE -1 END AS PARTITION_ID,
            SUBSTR(TABLE_NAME, 7 + INSTR(SUBSTR(TABLE_NAME, 7), '_')) AS INDEX_NAME,
            NULL AS PARTITION_NAME,
            NULL AS SUBPARTITION_NAME,
            NULL AS PARTITION_POSITION,
            NULL AS SUBPARTITION_POSITION,
            'INDEX' AS OBJECT_TYPE
        FROM
            oceanbase.__all_table T
        WHERE T.TABLE_TYPE = 5
    UNION ALL
        SELECT T.TENANT_ID,
                T.DATABASE_ID,
                T.TABLE_ID,
                T.DATA_TABLE_ID,
                P.PART_ID,
                SUBSTR(T.TABLE_NAME, 7 + INSTR(SUBSTR(T.TABLE_NAME, 7), '_')) AS INDEX_NAME,
                P.PART_NAME,
                NULL,
                P.PART_ID + 1,
                NULL,
                'PARTITION'
        FROM
            oceanbase.__all_table T
          JOIN
            oceanbase.__all_part P
            ON T.TENANT_ID = P.TENANT_ID
            AND T.TABLE_ID = P.TABLE_ID
        WHERE T.TABLE_TYPE = 5
    UNION ALL
        SELECT T.TENANT_ID,
               T.DATABASE_ID,
               T.TABLE_ID,
               T.DATA_TABLE_ID,
               SP.SUB_PART_ID AS PARTITION_ID,
               SUBSTR(T.TABLE_NAME, 7 + INSTR(SUBSTR(T.TABLE_NAME, 7), '_')) AS INDEX_NAME,
               P.PART_NAME,
               SP.SUB_PART_NAME,
               P.PART_ID + 1,
               SP.SUB_PART_ID + 1,
              'SUBPARTITION'
        FROM
            oceanbase.__all_table T
        JOIN
            oceanbase.__all_part P
            ON T.TENANT_ID = P.TENANT_ID
            AND T.TABLE_ID = P.TABLE_ID
        JOIN
            oceanbase.__all_sub_part SP
            ON T.TENANT_ID = SP.TENANT_ID
            AND T.TABLE_ID = SP.TABLE_ID
            AND P.PART_ID = SP.PART_ID
        WHERE T.TABLE_TYPE = 5
    ) V
    JOIN oceanbase.__all_table T
         ON T.TABLE_ID = V.DATA_TABLE_ID
         AND T.TENANT_ID = V.TENANT_ID
         AND T.DATABASE_ID = V.DATABASE_ID
         AND V.TENANT_ID in (0, 1)
    JOIN
        oceanbase.__all_database DB
        ON DB.TENANT_ID = V.TENANT_ID
        AND DB.DATABASE_ID = V.DATABASE_ID
        AND DB.DATABASE_NAME !=  '__recyclebin'
    LEFT JOIN
        oceanbase.__all_table_stat STAT
        ON V.TENANT_ID = STAT.TENANT_ID
        AND V.TABLE_ID = STAT.TABLE_ID
        AND (V.PARTITION_ID = STAT.PARTITION_ID OR V.PARTITION_ID = -2)
        AND STAT.INDEX_TYPE = 1;
		
		

--echo ###————————————————————————————————————————————————————————————————————————————————————###

set ob_query_timeout=30000000;

drop table if exists table111;

CREATE TABLE table111 (
    id int(11) NOT NULL AUTO_INCREMENT ,
    title char(255) NOT NULL ,
    content text NULL ,
    time int(10) NULL DEFAULT NULL ,
    PRIMARY KEY (id),
    INDEX index_111 (title)
);

insert into table111 values(1,'abc','abc','20220630');
insert into table111 values(2,'abc','abc','20220630');
insert into table111 values(3,'abc','abc','20220630');
insert into table111 values(4,'abc','abc','20220630');
insert into table111 values(5,'abc','abc','20220630');

--echo 收集统计信息
call dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111');
--echo ### OB关注的内容
--sorted_result
SELECT TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN,MACRO_BLK_CNT,MICRO_BLK_CNT FROM index_stats_view where INDEX_NAME = 'INDEX_111' ;
--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position FROM oceanbase.dba_ind_statistics WHERE INDEX_NAME='INDEX_111' ORDER BY subpartition_name,partition_name;
--sorted_result
SELECT object_type,BLEVEL,LEAF_BLOCKS,DISTINCT_KEYS,CLUSTERING_FACTOR, num_rows FROM oceanbase.dba_ind_statistics WHERE INDEX_NAME='INDEX_111' ORDER BY subpartition_name,partition_name;
--sorted_result
SELECT GLOBAL_STATS,USER_STATS,STATTYPE_LOCKED,STALE_STATS FROM oceanbase.dba_ind_statistics WHERE INDEX_NAME='INDEX_111' ORDER BY subpartition_name,partition_name;
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',estimate_percent=>100);
--sorted_result
SELECT object_type,BLEVEL,LEAF_BLOCKS,DISTINCT_KEYS,CLUSTERING_FACTOR, num_rows FROM oceanbase.dba_ind_statistics WHERE INDEX_NAME='INDEX_111' ORDER BY subpartition_name,partition_name;
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'AUTO');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'DEFAULT');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'GLOBAL AND PARTITION');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'APPROX_GLOBAL AND PARTITION');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'GLOBAL');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'PARTITION');
CALL dbms_stats.gather_index_stats('YYL', 'INDEX_111', tabname=>'table111',granularity=>'SUBPARTITION');

