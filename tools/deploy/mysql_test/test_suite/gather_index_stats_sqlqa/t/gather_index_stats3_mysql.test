--disable_warnings
drop table if exists triangle;
--enable_warnings

CREATE TABLE triangle (
  sidea DOUBLE,
  sideb DOUBLE,
  sidec DOUBLE AS (SQRT(sidea * sidea + sideb * sideb))
)DEFAULT CHARACTER SET = utf8;
INSERT INTO triangle (sidea, sideb) VALUES(1,1),(3,4),(6,8);

CREATE INDEX INDEX_222 ON triangle(sidec);

--echo 收集统计信息
call dbms_stats.gather_index_stats('YYL', 'INDEX_222', tabname=>'triangle');
--echo ### OB关注的内容
--sorted_result
SELECT TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME,OBJECT_TYPE,NUM_ROWS,AVG_ROW_LEN,MACRO_BLK_CNT,MICRO_BLK_CNT FROM index_stats_view where INDEX_NAME = 'INDEX_222' ;
--sorted_result
SELECT table_name, partition_name, partition_position, subpartition_name, subpartition_position,object_type,num_rows FROM oceanbase.dba_ind_statistics WHERE INDEX_NAME='INDEX_222' ORDER BY subpartition_name,partition_name;

