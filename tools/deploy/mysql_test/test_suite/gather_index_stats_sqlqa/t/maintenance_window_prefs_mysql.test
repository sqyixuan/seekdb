#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
purge recyclebin;
--disable_query_log
--source mysql_test/include/check_schema_sync.inc
--source mysql_test/test_suite/histogram/include/create_mysql_tenant.inc
--enable_query_log
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
--source mysql_test/test_suite/histogram/include/conn_mysql_tenant.inc
--source mysql_test/test_suite/gather_index_stats_sqlqa/include/prepare_table_mysql.inc
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
connection conn_stat_test_sys_mysql;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
##show relation system table
desc oceanbase.__all_optstat_global_prefs;
desc oceanbase.__all_optstat_user_prefs;
--echo ## 测分 gather_index_stats-01-02 ###
##test query global prefs
select SNAME, SVAL1, SPARE4 from oceanbase.__all_optstat_global_prefs;

##test set prefs
call dbms_stats.set_global_prefs('APPROXIMATE_NDV', 'FALSE');
select dbms_stats.get_prefs('APPROXIMATE_NDV') from dual;

call dbms_stats.set_param('CASCADE', 'true');
select dbms_stats.get_param('CASCADE') from dual;

call dbms_stats.set_global_prefs('degree', '5');
select dbms_stats.get_prefs('DEGREE') from dual;

call dbms_stats.set_param('ESTIMATE_PERCENT', '60');
select dbms_stats.get_param('ESTIMATE_PERCENT') from dual;

call dbms_stats.set_global_prefs('GRANULARITY', 'ALL');
select dbms_stats.get_param('GRANULARITY') from dual;

call dbms_stats.set_param('INCREMENTAL', 'TRUE');
select dbms_stats.get_prefs('INCREMENTAL') from dual;

call dbms_stats.set_param('INCREMENTAL_LEVEL', NULL);
select dbms_stats.get_prefs('INCREMENTAL_LEVEL') from dual;

call dbms_stats.set_global_prefs('method_OPT', 'FOR ALL COLUMNS SIZE 10');
select dbms_stats.get_prefs('METHOD_OPT') from dual;

call dbms_stats.set_param('NO_INVALIDATE', 'TRUE');
select dbms_stats.get_prefs('NO_INVALIDATE') from dual;

call dbms_stats.set_global_prefs('OPTIONS', 'GATHER AUTO');
select dbms_stats.get_prefs('OPTIONS') from dual;

call dbms_stats.set_global_prefs('STALE_PERCENT', '50');
select dbms_stats.get_prefs('STALE_PERCENT') from dual;

call dbms_stats.set_table_prefs('TEST', 'GENERAL_TAB_UNIFORM', 'degree', '3');
select dbms_stats.get_prefs('degree', 'TEST', 'GENERAL_TAB_UNIFORM') from dual;

call dbms_stats.set_table_prefs('TEST', 'GENERAL_TAB_GAUSSIAN', 'ESTIMATE_PERCENT', '30');
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'GENERAL_TAB_GAUSSIAN') from dual;

call dbms_stats.set_table_prefs('TEST', 'PARTITIONED_RANGE_TAB_UNIFORM', 'GRANULARITY', 'global');
select dbms_stats.get_prefs('GRANULARITY', 'TEST', 'PARTITIONED_RANGE_TAB_UNIFORM') from dual;

call dbms_stats.set_table_prefs('TEST', 'PARTITIONED_HASH_TAB_UNIFORM', 'method_OPT', 'FOR ALL COLUMNS SIZE 10');
select dbms_stats.get_prefs('method_OPT', 'TEST', 'PARTITIONED_HASH_TAB_UNIFORM') from dual;

call dbms_stats.set_table_prefs('TEST', 'I_PARTITIONED_RANGE_TAB_GAUSSIAN', 'method_OPT', NULL);
select dbms_stats.get_prefs('method_OPT', 'TEST', 'I_PARTITIONED_RANGE_TAB_GAUSSIAN') from dual;

call dbms_stats.set_schema_prefs('TEST', 'degree', '4');
select dbms_stats.get_prefs('degree', 'TEST', 'GENERAL_TAB_TOPK') from dual;
select dbms_stats.get_prefs('degree', 'TEST', 'GENERAL_TAB_FRE') from dual;
select dbms_stats.get_prefs('degree', 'TEST', 'I_PARTITIONED_TAB') from dual;

call dbms_stats.set_schema_prefs('TEST', 'ESTIMATE_PERCENT', '60');
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'GENERAL_TAB_TOPK') from dual;
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN2') from dual;
select dbms_stats.get_prefs('ESTIMATE_PERCENT', 'TEST', 'PARTITIONED_LISTHASH_TAB_GAUSSIAN') from dual;

call dbms_stats.set_schema_prefs('TEST', 'method_OPT', 'FOR ALL COLUMNS size 100');
select dbms_stats.get_prefs('method_OPT', 'TEST', 'GENERAL_TAB_TOPK') from dual;
select dbms_stats.get_prefs('method_OPT', 'TEST', 'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN2') from dual;
select dbms_stats.get_prefs('method_OPT', 'TEST', 'PARTITIONED_LISTHASH_TAB_GAUSSIAN') from dual;

--echo ###设置自动化收集任务，10s之后开始###
--disable_query_log
--disable_result_log
let $point = query_get_value("select substr(date_add(now(),interval 10 second), 1, 26) as X from dual;", X, 1);
let $day = query_get_value("select WEEKDAY(now()) as X from dual;", X, 1);
if ($day == 0) {
  eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 1) {
  eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 2) {
  eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 3) {
  eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 4) {
  eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 5) {
  eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 6) {
  eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
}
--enable_result_log
--enable_query_log

--disable_query_log
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'TEST';

##wait auto gather table stats finish

let $__i__= 120;
while($__i__ > 0)
{
  sleep 1;
  dec $__i__;
  let $__memstore_cnt__ = query_get_value("select count(*) as CNT from oceanbase.DBA_TAB_STATISTICS where LAST_ANALYZED > 0 and table_name in (
'GENERAL_TAB_UNIFORM'
,'GENERAL_TAB_GAUSSIAN'
,'PARTITIONED_RANGE_TAB_UNIFORM'
,'PARTITIONED_RANGE_TAB_GAUSSIAN'
,'PARTITIONED_HASH_TAB_UNIFORM'
,'PARTITIONED_HASH_TAB_GAUSSIAN'
,'PARTITIONED_LIST_TAB_UNIFORM'
,'PARTITIONED_LIST_TAB_GAUSSIAN'
,'PARTITIONED_RANGEHASH_TAB_UNIFORM'
,'PARTITIONED_RANGEHASH_TAB_GAUSSIAN'
,'PARTITIONED_RANGELIST_TAB_UNIFORM'
,'PARTITIONED_RANGELIST_TAB_GAUSSIAN'
,'PARTITIONED_LISTRANGE_TAB_UNIFORM'
,'PARTITIONED_LISTRANGE_TAB_GAUSSIAN'
,'PARTITIONED_LISTRANGE_TAB_GAUSSIAN2'
,'PARTITIONED_LISTRANGE_TAB_UNIFORM2'
,'PARTITIONED_LISTHASH_TAB_UNIFORM'
,'PARTITIONED_LISTHASH_TAB_GAUSSIAN'
,'COMPOSITE_PARTITIONED_TAB'
,'TMP_COMPOSITE_PARTITIONED_TAB'
,'PARTITIONED_TAB'
,'GENERAL_TAB'
,'I_GENERAL_TAB_UNIFORM'
,'I_GENERAL_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGE_TAB_UNIFORM'
,'I_PARTITIONED_RANGE_TAB_GAUSSIAN'
,'I_PARTITIONED_HASH_TAB_UNIFORM'
,'I_PARTITIONED_HASH_TAB_GAUSSIAN'
,'I_PARTITIONED_LIST_TAB_UNIFORM'
,'I_PARTITIONED_LIST_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGEHASH_TAB_UNIFORM'
,'I_PARTITIONED_RANGEHASH_TAB_GAUSSIAN'
,'I_PARTITIONED_RANGELIST_TAB_UNIFORM'
,'I_PARTITIONED_RANGELIST_TAB_GAUSSIAN'
,'I_PARTITIONED_LISTRANGE_TAB_UNIFORM'
,'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN'
,'I_PARTITIONED_LISTRANGE_TAB_GAUSSIAN2'
,'I_PARTITIONED_LISTRANGE_TAB_UNIFORM2'
,'I_PARTITIONED_LISTHASH_TAB_UNIFORM'
,'I_PARTITIONED_LISTHASH_TAB_GAUSSIAN'
,'I_COMPOSITE_PARTITIONED_TAB'
,'I_TMP_COMPOSITE_PARTITIONED_TAB'
,'I_PARTITIONED_TAB'
,'I_GENERAL_TAB'
,'GENERAL_TAB_FRE'
,'GENERAL_TAB_TOPK'
) and OWNER = 'TEST';", CNT, 1);
  if ($__memstore_cnt__ == 578)
  {
    let $__i__ = -1;
  }
}
if ($__i__ != -1)
{
  --echo auto gather table sats failed $__memstore_cnt__
}

--enable_query_log
--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'TEST';
select count(*) from oceanbase.__all_tenant_scheduler_job where this_date is not null or last_date is not null;

--echo ###自动收集任务完成后，root用户登录查看任务状态###
connection conn_root;
--disable_result_log
select * from __all_virtual_scheduler_job_run_detail_v2 ORDER BY TIME;
--enable_result_log

--echo ###自动收集任务完成后，普通用户登录查看信息收集结果###
connection conn_stat_test_sys_mysql;
use test;
--disable_result_log
select * from oceanbase.DBA_SCHEDULER_JOBS;
--enable_result_log
purge recyclebin;
--disable_result_log
--source mysql_test/test_suite/gather_index_stats_sqlqa/include/select_table_mysql.inc
--enable_result_log

--source mysql_test/test_suite/histogram/include/drop_mysql_tenant.inc
connection default;

purge recyclebin;
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 4016, frequency = 1;
connection default;
