#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connection default;

--disable_query_log
--error 0,1396
drop user yyl;
sleep 3;
create user 'yyl' identified by '123';
GRANT all privileges ON *.* TO 'yyl'@'%' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
--enable_query_log
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
connect(conn,$OBMYSQL_MS0,yyl,123,test,$OBMYSQL_PORT);
connection conn;

set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS yyl;
--enable_warnings

create database yyl  character set utf8;
use yyl;

