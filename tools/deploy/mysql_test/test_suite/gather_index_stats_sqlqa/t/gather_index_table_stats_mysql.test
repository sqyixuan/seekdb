--error 0,1091
DROP INDEX idx_4 on i_general_tab_Gaussian;

create index idx_3 on i_general_tab_Gaussian(f1);
create index idx_4 on i_general_tab_Gaussian(F1,f5) global;


--echo ###有主键、唯一键、索引表,range分区表、均匀分布###
--error 0,1051
DROP TABLE i_partitioned_range_tab_uniform ;
CREATE TABLE i_partitioned_range_tab_uniform (f1 int,f2 float, f3 DECIMAL(10,5),f4 DOUBLE, f5 char(10), f6 VARBINARY(10), f7 VARCHAR(20), f8 text)
PARTITION BY RANGE(f1) (PARTITION p1 VALUES less than(6),PARTITION p2 VALUES less than(81),PARTITION p3 VALUES less than(MAXVALUE));
INSERT INTO i_partitioned_range_tab_uniform SELECT * FROM i_general_tab_uniform;

--echo 全局范围分区索引
--error 0,1091
DROP INDEX idx_5 on I_PARTITIONED_RANGE_TAB_UNIFORM;
CREATE INDEX idx_5 ON i_partitioned_range_tab_uniform(f1)
   GLOBAL PARTITION BY RANGE (f1)(
	PARTITION p1 VALUES LESS THAN (30),
    PARTITION p2 VALUES LESS THAN (60),
    PARTITION p3 VALUES LESS THAN (MAXVALUE)
	);


--echo ###有主键、唯一键、索引表,range-hash、高斯分布###

--error 0,1051
DROP TABLE i_partitioned_rangehash_tab_Gaussian ;
CREATE TABLE i_partitioned_rangehash_tab_Gaussian (f1 int,f2 float, f3 DECIMAL(10,5),f4 DOUBLE, f5 char(10), f6 VARBINARY(10), f7 VARCHAR(20), f8 text)
partition by range(f1)
subpartition by hash(f1) subpartitions 4
(PARTITION p1 VALUES less than(6),PARTITION p2 VALUES less than(81),PARTITION p3 VALUES less than(MAXVALUE));

INSERT INTO i_partitioned_rangehash_tab_Gaussian SELECT * FROM i_general_tab_Gaussian;


--echo 全局范围分区索引
CREATE INDEX IDX_12 ON i_partitioned_rangehash_tab_Gaussian(f1)
   GLOBAL PARTITION BY RANGE (f1)(
	PARTITION p1 VALUES LESS THAN (30),
    PARTITION p2 VALUES LESS THAN (60),
    PARTITION p3 VALUES LESS THAN (MAXVALUE)
	);
	


--echo ###设置自动化收集任务，10s之后开始，gather_index_stats-03-02-01-02###
--disable_query_log
--disable_result_log
let $point = query_get_value("select substr(date_add(now(),interval 10 second), 1, 26) as X from dual;", X, 1);
let $day = query_get_value("select WEEKDAY(now()) as X from dual;", X, 1);
if ($day == 0) {
  eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 1) {
  eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 2) {
  eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 3) {
  eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 4) {
  eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 5) {
  eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 6) {
  eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
}
--enable_result_log
--enable_query_log

--disable_query_log
--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name in ('i_general_tab_uniform','i_general_tab_Gaussian','i_partitioned_rangehash_tab_Gaussian','i_partitioned_rangehash_tab_Gaussian') and OWNER = 'TEST';

##wait auto gather table stats finish
let $__i__= 180;
while($__i__ > 0)
{
  sleep 1;
  dec $__i__;
  let $__memstore_cnt__ = query_get_value("select count(*) as CNT from oceanbase.DBA_TAB_STATISTICS where LAST_ANALYZED is not null and table_name in (
'i_general_tab_uniform','i_general_tab_Gaussian','i_partitioned_rangehash_tab_Gaussian','i_partitioned_rangehash_tab_Gaussian'
) and OWNER = 'TEST';", CNT, 1);
  if ($__memstore_cnt__ == 578)
  {
    let $__i__ = -1;
  }
}
if ($__i__ != -1)
{
  --echo auto gather table sats failed
}
--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from oceanbase.DBA_TAB_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'TEST';
select count(*) from oceanbase.__all_tenant_scheduler_job where this_date is not null or last_date is not null;

