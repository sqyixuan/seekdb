--sorted_result
SELECT table_name, column_name, endpoint_number, endpoint_actual_value, endpoint_repeat_count FROM USER_TAB_HISTOGRAMS WHERE table_name='GENERAL_TAB_UNIFORM' ORDER BY column_name,endpoint_number;
--sorted_result
