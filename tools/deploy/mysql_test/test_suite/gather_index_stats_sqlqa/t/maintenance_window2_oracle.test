#owner: dingjincheng.djc
#owner group: sql1
#description: dbms_stats.gather_table_stats
#tags: pl, opt_stats, optimizer
#author:wb-sl672505

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 368, error_code = 0, frequency = 1;
connection default;
--source mysql_test/test_suite/histogram/include/create_oracle_tenant.inc
connect (conn_root,$OBMYSQL_MS0,root@sys,,Oceanbase,$OBMYSQL_PORT);
--source mysql_test/test_suite/histogram/include/conn_oracle_sys_tenant.inc
--disable_query_log
call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_ALL_TABLE');
call dbms_stats.gather_table_stats('SYS','ALL_VIRTUAL_CORE_COLUMN_TABLE');
--enable_query_log
--source mysql_test/test_suite/gather_index_stats_sqlqa/include/prepare_table.inc
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
connection conn_stat_test_sys;
purge recyclebin;
--echo ###设置自动化收集任务，10s之前,gather_index_stats-01-01-02-01 及之下所有。###
--disable_query_log
--disable_result_log
let $point = query_get_value("select substr(sysdate + 10*1/24/60/60, 0, 26) as X from dual;", X, 1);
let $day = query_get_value("SELECT MOD(TO_NUMBER(TO_CHAR(sysdate, 'D')) + 5, 7) as X FROM dual;", X, 1);
if ($day == 0) {
  eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 1) {
  eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 2) {
  eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 3) {
  eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 4) {
  eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 5) {
  eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
}
if ($day == 6) {
  eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
}
--enable_result_log
--enable_query_log

sleep 12;

###select * from sys.all_virtual_tenant_scheduler_job_real_agent;
###select JOB_NAME,JOB,LOWNER,POWNER,COWNER,LAST_DATE,THIS_DATE,NEXT_DATE,FAILURES,ENABLED,STATE from sys.all_virtual_tenant_scheduler_job_real_agent;

--disable_query_log
--error 0,20001
call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '2022-06-23 00:00:00');
--error 0,20001
call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '2022-06-23 -00:00:00');
--error 0,20001
call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '2022-06-23 12:00:00');
--error 1850
call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '2022-06-23 24:00:00');
--error 1850
call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '2022-06-23 25:00:00');
--error 1850
call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '2022-06-23 48:00:00');
--error 1850
call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '2022-06-23 49:00:00');
--error 1850
call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '2022-06-23 -49:00:00');
--enable_query_log


--echo ###设置自动化收集任务，设置整点边界值,前一个整点###
--disable_query_log
--disable_result_log
let $point = query_get_value("select to_date(to_char(sysdate -(rownum - 1) / 24,'yyyy-mm-dd hh24') || ':00:00','yyyy-mm-dd hh24:mi:ss') as X
from dual
connect by rownum <= 1 order by 1;", X, 1);
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--enable_result_log
--enable_query_log

sleep 2;

--echo ###设置自动化收集任务，设置整点边界值，后两个整点###
--disable_query_log
--disable_result_log
let $point = query_get_value("select to_date(to_char(sysdate +(rownum + 1) / 24,'yyyy-mm-dd hh24') || ':00:00','yyyy-mm-dd hh24:mi:ss') as X
from dual
connect by rownum <= 1 order by 1;", X, 1);
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--enable_result_log
--enable_query_log

sleep 2;


--echo ###设置自动化收集任务，设置10s后执行，先disable，再enable查看结果，gather_index_stats-01-01-02-01-03###
--disable_query_log
--disable_result_log
let $point = query_get_value("select substr(sysdate + 10*1/24/60/60, 0, 26) as X from dual;", X, 1);
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('TUESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('WEDNESDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('THURSDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('FRIDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SATURDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '$point');
--error 0,20001
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point');
--enable_result_log
--enable_query_log

##see the maintenance window
--sorted_result
select OWNER,JOB_NAME,ENABLED from dba_scheduler_jobs where JOB_NAME in ('FRIDAY_WINDOW','MONDAY_WINDOW','OPT_STATS_HISTORY_MANAGER','SATURDAY_WINDOW','SUNDAY_WINDOW','THURSDAY_WINDOW','TUESDAY_WINDOW','WEDNESDAY_WINDOW');

##connect sys tenant to set maintenance window

call dbms_scheduler.disable('MONDAY_WINDOW');
call dbms_scheduler.disable('TUESDAY_WINDOW');
call dbms_scheduler.disable('WEDNESDAY_WINDOW');
call dbms_scheduler.disable('THURSDAY_WINDOW');
call dbms_scheduler.disable('FRIDAY_WINDOW');
call dbms_scheduler.disable('SATURDAY_WINDOW');
call dbms_scheduler.disable('SUNDAY_WINDOW');
call dbms_scheduler.disable('MONDAY_WINDOW');
--sorted_result
select OWNER,JOB_NAME,ENABLED from dba_scheduler_jobs where JOB_NAME in ('FRIDAY_WINDOW','MONDAY_WINDOW','OPT_STATS_HISTORY_MANAGER','SATURDAY_WINDOW','SUNDAY_WINDOW','THURSDAY_WINDOW','TUESDAY_WINDOW','WEDNESDAY_WINDOW');


sleep 12;
--sorted_result
select OWNER,JOB_NAME,ENABLED from dba_scheduler_jobs where JOB_NAME in ('FRIDAY_WINDOW','MONDAY_WINDOW','OPT_STATS_HISTORY_MANAGER','SATURDAY_WINDOW','SUNDAY_WINDOW','THURSDAY_WINDOW','TUESDAY_WINDOW','WEDNESDAY_WINDOW');

call dbms_scheduler.enable('MONDAY_WINDOW');
call dbms_scheduler.enable('TUESDAY_WINDOW');
call dbms_scheduler.enable('WEDNESDAY_WINDOW');
call dbms_scheduler.enable('THURSDAY_WINDOW');
call dbms_scheduler.enable('FRIDAY_WINDOW');
call dbms_scheduler.enable('SATURDAY_WINDOW');
call dbms_scheduler.enable('SUNDAY_WINDOW');
call dbms_scheduler.enable('MONDAY_WINDOW');
--sorted_result
select OWNER,JOB_NAME,ENABLED from dba_scheduler_jobs where JOB_NAME in ('FRIDAY_WINDOW','MONDAY_WINDOW','OPT_STATS_HISTORY_MANAGER','SATURDAY_WINDOW','SUNDAY_WINDOW','THURSDAY_WINDOW','TUESDAY_WINDOW','WEDNESDAY_WINDOW');

--disable_result_log
select count(*) as CNT from DBA_TAB_STATISTICS where LAST_ANALYZED is not null and table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'SYS';
--sorted_result
select TABLE_NAME, partition_name, subpartition_name, OBJECT_TYPE, NUM_ROWS, AVG_ROW_LEN, SAMPLE_SIZE from DBA_TAB_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'SYS';
--enable_result_log

--echo ###设置名称不对时，预期失败。###
--disable_query_log
let $point = query_get_value("select substr(sysdate + 10*1/24/60/60, 0, 26) as X from dual;", X, 1);
--error 20000
eval call dbms_scheduler.set_attribute('MONDAY_WINDOWS', 'NEXT_DATE', '$point');
--error 20000
eval call dbms_scheduler.set_attribute('TUESDAYWINDOW', 'NEXT_DATE', '$point');
--error 20000
