--error 0,20001
eval call dbms_scheduler.set_attribute('SUNDAY_WINDOW', 'NEXT_DATE', '2022-06-20 -01:01:01');
--error 600
eval call dbms_scheduler.set_attribute('MONDAY_WINDOW', 'NEXT_DATE', '$point','$point');
--enable_query_log


--echo ###设置自动化收集任务，设置5s后执行###
