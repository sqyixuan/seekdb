DROP TABLE o_partitioned_rangehash_tab_Gaussian ;
CREATE TABLE o_partitioned_rangehash_tab_Gaussian (f1 int,f2 float, f3 DECIMAL(10,5),f4 DOUBLE, f5 char(10), f6 VARBINARY(10), f7 VARCHAR(20), f8 text)
partition by range(f1)
subpartition by hash(f1) subpartitions 4
(PARTITION p1 VALUES less than(6),PARTITION p2 VALUES less than(81),PARTITION p3 VALUES less than(MAXVALUE));
INSERT INTO o_partitioned_rangehash_tab_Gaussian SELECT * FROM i_general_tab_Gaussian;
全局范围分区索引
CREATE INDEX IDX_1234 ON o_partitioned_rangehash_tab_Gaussian(f1)
GLOBAL PARTITION BY RANGE (f1)(
PARTITION p1 VALUES LESS THAN (30),
PARTITION p2 VALUES LESS THAN (60),
PARTITION p3 VALUES LESS THAN (MAXVALUE)
);
