set ob_query_timeout=30000000;
drop table if exists table111;
Warnings:
Note	1051	Unknown table 'yyl.table111'
CREATE TABLE table111 (
id int(11) NOT NULL AUTO_INCREMENT ,
title char(255) NOT NULL ,
content text NULL ,
time int(10) NULL DEFAULT NULL ,
PRIMARY KEY (id),
INDEX index_111 (title)
);
