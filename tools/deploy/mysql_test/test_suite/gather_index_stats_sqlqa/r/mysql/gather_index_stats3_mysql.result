drop table if exists triangle23;
CREATE TABLE triangle23 (
sidea VARCHAR(100),
sideb VARCHAR(100),
sidec VARCHAR(200) AS (CONV(HEX(255),16,10)),
sided VARCHAR(200) AS (HEX(255)),
sidee VARCHAR(200) AS (X'616263'),
sidef VARCHAR(200) AS (UNHEX(HEX(sidea))),
sideg VARCHAR(200) AS (INSERT('Quadratic', 3, 4, 'What')),
sideh VARCHAR(200) AS (0 IS FALSE),
sidei VARCHAR(200) AS (LEAST(sidea,sideb)),
sidej VARCHAR(200) AS (LEAST(2,0)),
sidek VARCHAR(200) AS (LENGTH(sidea)),
sidel VARCHAR(200) AS ('David!' LIKE '%D%v%'),
sidem VARCHAR(200) AS (LOWER('QUADRATICALLY')),
siden VARCHAR(200) AS (sidea LIKE '%D%v%')
)
DEFAULT CHARACTER SET = GBK;
INSERT INTO triangle23 (sidea, sideb) VALUES('chaerre','chaerr');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文测试','中文测试1');
INSERT INTO triangle23 (sidea, sideb) VALUES('中文混合adfso441','中文混合adfso442');
INSERT INTO triangle23 (sidea, sideb) VALUES('20000101','19920202');
CREATE INDEX idx_c23 ON triangle23(sidec);
CREATE INDEX idx_c24 ON triangle23(sided);
CREATE INDEX idx_c25 ON triangle23(sidee);
CREATE INDEX idx_c26 ON triangle23(sidef);
CREATE INDEX idx_c27 ON triangle23(sideg);
CREATE INDEX idx_c28 ON triangle23(sideh);
CREATE INDEX idx_c29 ON triangle23(sidei);
CREATE INDEX idx_c30 ON triangle23(sidej);
CREATE INDEX idx_c31 ON triangle23(sidek);
CREATE INDEX idx_c32 ON triangle23(sidel);
CREATE INDEX idx_c33 ON triangle23(sidem);
CREATE INDEX idx_c34 ON triangle23(siden);
