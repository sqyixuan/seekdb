select TABLE_NAME, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from OCEANBASE.DBA_TAB_COL_STATISTICS where table_name in ('GENERAL_TAB_UNIFORM','GENERAL_TAB_GAUSSIAN','PARTITIONED_HASH_TAB_UNIFORM','PARTITIONED_LISTRANGE_TAB_UNIFORM','PARTITIONED_LISTHASH_TAB_GAUSSIAN','I_GENERAL_TAB_UNIFORM','I_GENERAL_TAB_GAUSSIAN','I_PARTITIONED_LIST_TAB_GAUSSIAN','GENERAL_TAB_FRE','GENERAL_TAB_TOPK') and OWNER = 'YYL';
select TABLE_NAME, partition_name, COLUMN_NAME, NUM_DISTINCT, LOW_VALUE, HIGH_VALUE, DENSITY, NUM_NULLS, NUM_BUCKETS, SAMPLE_SIZE, AVG_COL_LEN, HISTOGRAM from OCEANBASE.DBA_PART_COL_STATISTICS where table_name in ('T_PART','PARTITIONED_LISTHASH_TAB_GAUSSIAN') and OWNER = 'YYL';
SELECT table_name, subpartition_name, column_name, num_distinct, low_value, high_value, density, num_nulls, num_buckets, sample_size, avg_col_len, histogram FROM OCEANBASE.DBA_SUBPART_COL_STATISTICS WHERE table_name = 'PARTITIONED_LISTHASH_TAB_GAUSSIAN' and owner='YYL';

##not arrive stale percent(default value:10)
delete from GENERAL_TAB_UNIFORM where F1 >=95;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p0) where F1 <= 10;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p1) where F1 <= 10;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp0) where F1 <= 10;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp1) where F1 <= 10;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part4sp0) where F1 <= 15;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
