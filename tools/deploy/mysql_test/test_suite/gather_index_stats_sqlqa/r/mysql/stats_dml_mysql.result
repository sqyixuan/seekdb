##delete   大于百分之十
delete from GENERAL_TAB_UNIFORM where F1 >=75;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p0) where F1 <= 40;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p1) where F1 <= 30;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
use yyl;

