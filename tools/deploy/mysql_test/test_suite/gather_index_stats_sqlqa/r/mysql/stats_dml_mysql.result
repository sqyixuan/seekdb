update GENERAL_TAB_UNIFORM set F1 = 10000 where F1 >=10;
update PARTITIONED_HASH_TAB_UNIFORM partition(p0) set F3 = 10000 where F1 < 100;
update PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp0) set F3 = 10000 where F1 <= 100;
update PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp1) set F3 = 10000 where F1 <= 100;
delete from GENERAL_TAB_UNIFORM where F1 >=95;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p0) where F1 <= 50;
delete from PARTITIONED_HASH_TAB_UNIFORM partition(p1) where F1 <= 50;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp0) where F1 <= 1500;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part1sp1) where F1 <= 50;
delete from PARTITIONED_LISTHASH_TAB_GAUSSIAN partition(part4sp0) where F1 <= 50;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
