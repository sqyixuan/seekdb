##################约束
#####给double列创建not null约束
drop procedure if exists pro1//
create procedure pro1()
BEGIN
drop table if exists t1;
CREATE TABLE t1 (
a   double(53,2) not null,
b   varchar(10)
);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试非空约束')//
insert into t1 (a,b) values(2,'测试非空约束')//
insert into t1 (a,b) values(null,'测试非空约束')//
ERROR 23000: Column 'a' cannot be null
select * from t1//
a	b
1.00	测试非空约束
2.00	测试非空约束
#####给double列创建not null约束double(M,D)  M的值>255      
drop procedure if exists pro1//
create procedure pro1()
BEGIN
drop table if exists t1;
CREATE TABLE t1 (
a   double(256,2) not null,
b   varchar(10)
);
END//
call pro1()//
ERROR 42000: Display width out of range for column 'a' (max = 255)
#####给double列创建unique约束     ob 1 warning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
drop table if exists t1;
CREATE TABLE t1 (
a   double(53,2) unique,
b   varchar(10)
);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试非空约束')//
insert into t1 (a,b) values(2,'测试非空约束')//
insert into t1 (a,b) values(2,'测试非空约束')//
ERROR 23000: Duplicate entry '2' for key 'a'
select * from t1//
a	b
1.00	测试非空约束
2.00	测试非空约束
#####给double列创建unique约束double(M,D)  M的值>255        
