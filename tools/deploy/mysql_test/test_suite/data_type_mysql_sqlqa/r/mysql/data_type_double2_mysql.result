call pro1()//
ERROR 42000: Display width out of range for column 'a' (max = 255)
#####给double列创建primary key约束     ob 1 warning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
drop table if exists t1;
CREATE TABLE t1 (
a   double(53,3) primary key,
b   varchar(10)
);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试主键约束')//
insert into t1 (a,b) values(2,'测试主键约束')//
insert into t1 (a,b) values(2,'测试主键约束')//
ERROR 23000: Duplicate entry '2' for key 'PRIMARY'
select * from t1//
a	b
1.000	测试主键约束
2.000	测试主键约束
#####给double列创建primary key约束 double(M,D) M的值>255 ，且传入D的值 
drop procedure if exists pro1//
create procedure pro1()
BEGIN
drop table if exists t1;
CREATE TABLE t1 (
a   double(256,2) primary key,
b   varchar(10)
);
END//
call pro1()//
ERROR 42000: Display width out of range for column 'a' (max = 255)
#####给double列创建foreign key约束  主表和从表关联字段数据类型一样,范围一致   
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) not null primary key,
b   varchar(10)
);
CREATE TABLE t2 (
c   double(53,2) primary key,
d   varchar(10),
e   double(20,3) not null,
foreign key(e)references t1(a)
);
END//
call pro1()//
#####给double列创建foreign key约束  主表和从表关联字段数据类型一样,子表double列范围小于父表double范围列 
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) not null primary key,
b   varchar(10)
);
CREATE TABLE t2 (
c   double(53,2) primary key,
d   varchar(10),
e   double(11,3) not null,
foreign key(e)references t1(a)
);
END//
call pro1()//
#####给double列创建foreign key约束  主表和从表关联字段数据类型一致,子表double列范围大于父表double范围列
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) not null primary key,
b   varchar(10)
);
CREATE TABLE t2 (
c   double(53,2) primary key,
d   varchar(10),
e   double(21,3) not null,
foreign key(e)references t1(a)
);
END//
call pro1()//
#####给double列创建foreign key约束  主表关联字段为double类型和从表关联字段为double类型,范围一致
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) not null primary key,
b   varchar(10)
);
CREATE TABLE t2 (
c   double(53,2) primary key,
d   varchar(10),
e   double(20,3) not null,
foreign key(e)references t1(a)
);
END//
call pro1()//
#####给double列创建foreign key约束  主表关联字段为double类型和从表关联字段为double类型,范围一致
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) not null primary key,
b   varchar(10)
);
CREATE TABLE t2 (
c   double(53,2) primary key,
d   varchar(10),
e   double(20,3) not null,
foreign key(e)references t1(a)
);
END//
call pro1()//
#####给double列创建default约束
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) default 5,
b   varchar(20)
);
END//
call pro1()//
insert into t1 values(1,'测试default约束')//
insert into t1 (b) values('测试default约束')//
insert into t1 values(3,'测试default约束')//
select * from t1//
a	b
1.000	测试default约束
5.000	测试default约束
3.000	测试default约束
#####给double列创建default约束 默认值为字符  
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3) default 'sss',
b   varchar(20)
);
END//
call pro1()//
ERROR 42000: Invalid default value for 'a'
select * from t1//
ERROR 42S02: Table 'zh_db.t1' doesn't exist
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (
a   double(20,3),
b   varchar(20),
check(a > 20 AND a < 50)
);
END//
call pro1()//
drop table t1;//
#####创建索引        标签float/double 1-2-2-1-2
###创建普通索引
drop table if exists t1//
Warnings:
Note	1051	Unknown table 'zh_db.t1'
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (a double(20,3) primary key, b DATE);
alter table t1 add index a_index(a);
END//
CALL pro1()//
###创建唯一索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1 (a double(20,3) primary key, b char(20));
alter table t1 add UNIQUE(a);
END//
CALL pro1()//
insert into t1 values(1,'测试唯一索引')//
insert into t1 values(1,'测试唯一索引')//
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert into t1 values(2,'测试唯一索引')//
insert into t1 values(3,'测试唯一索引')//
select * from t1//
a	b
1.000	测试唯一索引
2.000	测试唯一索引
3.000	测试唯一索引
#########创建主键索引     
#####在使用procedure创建主键索引时，ob调用时报错，创建主键索引失败。mysql创建主键索引成功。直接建表创建主键索引的话，ob创建成功。
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1(a double(20,3),b char(20));
alter table t1 add primary key(a);
END//
CALL pro1()//
insert into t1 values(1,'测试主键索引')//
insert into t1 values(1,'测试主键索引')//
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert into t1 values(3,'测试主键索引')//
insert into t1 values(4,'测试主键索引')//
select * from t1//
a	b
1.000	测试主键索引
3.000	测试主键索引
4.000	测试主键索引
###创建组合索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1(a double(20,3),b char(20),c INT);
alter table t1 add INDEX m_index(a,b,c);
END//
CALL pro1()//
###创建全文索引        ob创建失败，MySQL创建成功 bugid:37648842  功能被移除
#####ERROR 1235 (0A000): Not supported feature or function
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
CREATE TABLE t1(a double(20,3),b char(20),c INT,d text);
alter table t1 add FULLTEXT(d);
END//
CALL pro1()//
#########创建视图           标签float/double 1-2-2-1-3
#####create or replace
drop table if exists t1//
CREATE TABLE t1 (
a   double(20,2),
b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
create or replace view v1 as select * from t1;
END//
call pro1()//
select * from v1//
a	b
1.00	测试创建视图1
2.00	测试创建视图2
3.00	测试创建视图3
4.00	测试创建视图4
#####create or replace 查询一个double列
drop table if exists t1//
CREATE TABLE t1 (
a   double(20,2),
b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
create or replace view v1 as select a from t1;
END//
call pro1()//
select * from v1//
a
1.00
2.00
3.00
4.00
#####as 给double列取别名
drop table if exists t1//
CREATE TABLE t1 (
a   double(20,2),
b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
create or replace view test_v1 as select a as test_double_a from t1;
END//
call pro1()//
select * from test_v1//
test_double_a
1.00
2.00
3.00
4.00
########查看建表结果desc    标签 float/double 1-2-2-1-4
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
desc t1;
END//
CALL pro1()//
Field	Type	Null	Key	Default	Extra
a	double(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
