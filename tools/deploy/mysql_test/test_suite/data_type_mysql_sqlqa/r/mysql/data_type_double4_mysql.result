#####条件表达式 case
drop table if exists t1//
CREATE TABLE t1(a double(20,2),b char(25),class INT,score double(20,1))//
insert into t1 values(1,'测试运算符语句',1101,97)//
insert into t1 values(2,'测试运算符语句',1101,80.5)//
insert into t1 values(3,'测试运算符语句',1102,70.5)//
insert into t1 values(4,'测试运算符语句',1102,85.5)//
insert into t1 values(5,'测试运算符语句',1102,90.5)//
insert into t1 values(6,'测试运算符语句',1103,90.5)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select a,class 班级,case score when 80.5 then 80 end as 成绩 from t1;
END//
CALL pro1()//
a	班级	成绩
1.00	1101	NULL
2.00	1101	80
3.00	1102	NULL
4.00	1102	NULL
5.00	1102	NULL
6.00	1103	NULL
#####条件表达式 between
drop table if exists t1//
CREATE TABLE t1(a double(20,2),b char(25),class INT,score double(20,1))//
insert into t1 values(1,'测试运算符语句',1101,97)//
insert into t1 values(2,'测试运算符语句',1101,80.5)//
insert into t1 values(3,'测试运算符语句',1102,70.5)//
insert into t1 values(4,'测试运算符语句',1102,85.5)//
insert into t1 values(5,'测试运算符语句',1102,90)//
insert into t1 values(6,'测试运算符语句',1103,90.5)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select a,class 班级,score 成绩 from t1 where score between 80  and 90;
END//
CALL pro1()//
a	班级	成绩
2.00	1101	80.5
4.00	1102	85.5
5.00	1102	90.0
#####条件表达式 between   包含条件的数据
