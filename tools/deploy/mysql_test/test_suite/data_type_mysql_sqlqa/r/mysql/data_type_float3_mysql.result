drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 drop primary key;
END//
CALL pro1()//
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	NO		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
