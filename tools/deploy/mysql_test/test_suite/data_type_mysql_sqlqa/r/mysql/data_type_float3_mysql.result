########## 处理测试环境 ##########
drop database if exists zh_db;
create database if not exists zh_db;
use zh_db;
drop user 'funkzz';
# 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;
set autocommit=1;
################alter table  标签  float/double 1-2-2-2-1
##########列           标签  float/double 1-2-2-2-1-1
######修改float列成varchar类型
drop table if exists t2//
drop table if exists t1//
Warnings:
Note	1051	Unknown table 'zh_db.t1'
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column a varchar(10);
END//
CALL pro1()//
desc t1//
Field	Type	Null	Key	Default	Extra
a	varchar(10)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######修改float列成varchar类型   并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column a varchar(10);
END//
CALL pro1()//
select * from t1//
a	b	c
1.000	32.22	30
desc t1//
Field	Type	Null	Key	Default	Extra
a	varchar(10)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######修改float列成double类型
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column a double(10,2);
END//
CALL pro1()//
desc t1//
Field	Type	Null	Key	Default	Extra
a	double(10,2)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######修改char列成float类型  并且包含字符类型的数据
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
insert into t1 values(1,'www',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column b float(10,2);
END//
CALL pro1()//
ERROR 01000: Truncated incorrect DOUBLE value
select * from t1//
a	b	c
1.000	www	30
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######修改char列成float类型  并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column b float(10,2);
END//
CALL pro1()//
select * from t1//
a	b	c
1.000	32.22	30
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES		NULL	
b	float(10,2)	YES		NULL	
c	int(11)	YES		NULL	
######修改char列成float类型 且M>53  并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column b float(54,2);
END//
CALL pro1()//
select * from t1//
