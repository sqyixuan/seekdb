######range分区INT类型的列 测试range分区  float类型不支持分区
drop table if exists t1//
CREATE TABLE t1 (
s_s_no INT,
s_r_r  char(10),
s_c_no float(20,3),
s_score INT,
PRIMARY key(s_s_no,s_score)
) 
PARTITION BY range(s_score)(
partition p0 values less than (75),
partition p1 values less than (80),
partition p2 values less than (91),
partition p3 values less than (MAXVALUE)
)//
