a	float(20,3)	YES		NULL	
b	float(54,2)	YES		NULL	
c	int(11)	YES		NULL	
######添加float类型 列
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add column d float(22,2);
END//
CALL pro1()//
select * from t1//
a	b	c	d
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
d	float(22,2)	YES		NULL	
######添加列与已有的列名相同 范围不同
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add column a float(22,2);
END//
CALL pro1()//
ERROR 42S21: Duplicate column name 'a'
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######添加列   使用first添加列
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add column d float(22,2) first;
END//
CALL pro1()//
select * from t1//
d	a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
d	float(22,2)	YES		NULL	
a	float(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######添加列   使用after添加列
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add column d float(22,2) after a;
END//
CALL pro1()//
select * from t1//
a	d	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES		NULL	
d	float(22,2)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######删除列 
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 drop column a;
END//
CALL pro1()//
select * from t1//
b	c
desc t1//
Field	Type	Null	Key	Default	Extra
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######删除多列
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 drop column a,drop column b;
END//
CALL pro1()//
select * from t1//
c
desc t1//
Field	Type	Null	Key	Default	Extra
c	int(11)	YES		NULL	
##############修改列名不修改列的数据类型
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 change a d float(20,3);
END//
CALL pro1()//
select * from t1//
d	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
d	float(20,3)	YES		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
