b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
################约束            标签     float/double 1-2-2-2-1-2
######给float列添加主键约束
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add primary key(a);
END//
CALL pro1()//
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	NO	PRI	NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######给float列添加唯一约束
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 add unique(a);
END//
CALL pro1()//
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	YES	UNI	NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######给float列添加非空约束 bugid:37455132
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 MODIFY a float(20,3) not null;
END//
CALL pro1()//
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	NO		NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
######给float列添加外键约束
drop table if exists t2//
Warnings:
Note	1051	Unknown table 'zh_db.t2'
drop table if exists t1//
CREATE TABLE t1(a float(20,3) primary key,b char(20),c INT)//
CREATE TABLE t2(d float(20,3),e char(20),f INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t2 ADD CONSTRAINT FK_ID FOREIGN KEY(d) REFERENCES t1(a);
END//
CALL pro1()//
select * from t1//
a	b	c
desc t1//
Field	Type	Null	Key	Default	Extra
a	float(20,3)	NO	PRI	NULL	
b	char(20)	YES		NULL	
c	int(11)	YES		NULL	
desc t2//
Field	Type	Null	Key	Default	Extra
d	float(20,3)	YES		NULL	
e	char(20)	YES		NULL	
f	int(11)	YES		NULL	
######给float列添加默认default约束
drop table if exists t2//
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 modify column a float(20,3) default 2;
END//
CALL pro1()//
insert into t1 values(1,'测试添加默认约束',10)//
insert into t1 (b,c) values('测试添加默认约束',20)//
insert into t1 values(3,'测试添加默认约束',30)//
select * from t1//
a	b	c
1.000	测试添加默认约束	10
2.000	测试添加默认约束	20
3.000	测试添加默认约束	30
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
alter table t1 ADD CONSTRAINT check_id CHECK(a > 2);
END//
CALL pro1()//
insert into t1 values(1,'测试添加默认约束',10)//
ERROR HY000: check constraint violated
insert into t1 values(2,'测试添加默认约束',20)//
ERROR HY000: check constraint violated
insert into t1 values(3,'测试添加默认约束',30)//
select * from t1//
a	b	c
3.000	测试添加默认约束	30
######给float列删除主键约束  bugid:37463109
