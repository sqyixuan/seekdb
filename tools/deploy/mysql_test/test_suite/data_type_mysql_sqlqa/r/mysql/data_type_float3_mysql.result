###########分区 
######modify       
######KEY分区float类型的列
drop table if exists t1//
CREATE TABLE t1 (
s_s_no INT,
s_r_r  char(10),
s_c_no float(20,3),
s_score INT,
PRIMARY key(s_s_no,s_c_no)
) 
PARTITION BY key(s_c_no)
PARTITIONS 4//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'list分区',6,72)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'list分区',12,73)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'list分区',19,77)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'list分区',30,90)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'list分区',35,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1006,'list分区',45,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1007,'list分区',50,93)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
ALTER TABLE t1 DROP PARTITION p3;
END//
CALL pro1()//
ERROR 0A000: Drop hash partition not supported
##############ERROR 1235 (0A000): drop hash partition not supported
select * from t1//
s_s_no	s_r_r	s_c_no	s_score
1001	list分区	6.000	72
1007	list分区	50.000	93
1002	list分区	12.000	73
1004	list分区	30.000	90
1005	list分区	35.000	93
1003	list分区	19.000	77
1006	list分区	45.000	93
SELECT
PARTITION_NAME,
TABLE_ROWS
FROM
INFORMATION_SCHEMA. PARTITIONS
WHERE
TABLE_NAME = 't1' and table_schema = 'zh_db'//
PARTITION_NAME	TABLE_ROWS
p0	NULL
p1	NULL
p2	NULL
p3	NULL
