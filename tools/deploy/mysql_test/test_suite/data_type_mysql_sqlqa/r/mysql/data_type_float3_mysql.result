insert into t1 values(2,'测试TRUNCATE TABLE的rollback',20)//
insert into t1 values(3,'测试TRUNCATE TABLE的rollback',30)//
TRUNCATE TABLE t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
rollback;
END//
CALL pro1()//
