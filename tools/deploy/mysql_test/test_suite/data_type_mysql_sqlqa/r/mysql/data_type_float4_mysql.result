#########select操作，与字符串类型比较
drop table if exists t1//
CREATE TABLE t1(id INT,a_float float(20))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a char(20);
set a = 20;
select  * from t1 where a_float < a;
END//
CALL pro1()//
id	a_float
2	19.53
3	10.53
4	15.53
######调用方法时与定义的变量不同类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_float float(20))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare p_float char(20);
set p_float = 20;
select  * from t1 where a_float < p_float;
END//
CALL pro1()//
id	a_float
2	19.53
3	10.53
4	15.53
######直接赋值   数字
drop table if exists t1//
CREATE TABLE t1(id INT,a_float float(20))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a_float float(20);
declare p_char char(20);
set a_float = 20;
set p_char = 50;
insert into t1 values(1,a_float);
set a_float = p_char;
insert into t1 values(2,a_float);
END//
CALL pro1()//
select * from t1//
id	a_float
1	20
2	50
######直接赋值   字符串         ob传入null值，mysql创建存储成功，调用失败
drop table if exists t1//
CREATE TABLE t1(id INT,a_float float(20))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a_float float(20);
declare p_char char(20);
set a_float = 20;
set p_char = 'aa';
insert into t1 values(1,a_float);
set a_float = p_char;
insert into t1 values(2,a_float);
END//
CALL pro1()//
select * from t1//
id	a_float
1	20
2	NULL
######算术运算 
drop table if exists t1//
CREATE TABLE t1(id INT,a_float float(20))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare p_char char(20);
set p_char = 20;
insert into t1 values(1,1+p_char);
END//
CALL pro1()//
select * from t1//
id	a_float
1	21
