######group by   having on
drop table if exists t1//
CREATE TABLE t1(a float(20),b char(25),class INT,score float(20,1))//
insert into t1 values(1,'测试group by语句',1101,97)//
insert into t1 values(2,'测试group by语句',1101,80.5)//
insert into t1 values(3,'测试group by语句',1103,70)//
insert into t1 values(4,'测试group by语句',1102,90)//
insert into t1 values(5,'测试group by语句',1102,60)//
insert into t1 values(6,'测试group by语句',1104,57)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select class,max(score) from t1 group by class having max(score);
END//
CALL pro1()//
class	max(score)
1101	97.0
1103	70.0
1102	90.0
1104	57.0
######order by             标签     float/double 1-2-3-4
