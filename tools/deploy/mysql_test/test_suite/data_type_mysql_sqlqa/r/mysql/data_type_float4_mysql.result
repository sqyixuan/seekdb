4	测试with as语句	1102	90.0
5	测试with as语句	1102	60.0
6	测试with as语句	1104	57.0
##############where        标签     float/double 1-2-3-8
#######in的使用
drop table if exists t1//
CREATE TABLE t1(a float(20),b char(25),class INT,score float(20,1))//
insert into t1 values(1,'测试in语句',1101,97)//
insert into t1 values(2,'测试in语句',1101,80.5)//
insert into t1 values(3,'测试in语句',1103,70)//
insert into t1 values(4,'测试in语句',1102,90)//
insert into t1 values(5,'测试in语句',1102,60)//
insert into t1 values(6,'测试in语句',1104,57)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select * from t1 where score in(select score from t1 where a = 2);
END//
CALL pro1()//
a	b	class	score
2	测试in语句	1101	80.5
#######not in的使用
drop table if exists t1//
CREATE TABLE t1(a float(20),b char(25),class INT,score float(20,1))//
insert into t1 values(1,'测试not in语句',1101,97)//
insert into t1 values(2,'测试not in语句',1101,80.5)//
insert into t1 values(3,'测试not in语句',1103,70)//
insert into t1 values(4,'测试not in语句',1102,90)//
insert into t1 values(5,'测试not in语句',1102,60)//
insert into t1 values(6,'测试not in语句',1104,57)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select * from t1 where score not in(select score from t1 where a = 2);
END//
CALL pro1()//
a	b	class	score
1	测试not in语句	1101	97.0
3	测试not in语句	1103	70.0
4	测试not in语句	1102	90.0
5	测试not in语句	1102	60.0
6	测试not in语句	1104	57.0
#######all >的使用
drop table if exists t1//
CREATE TABLE t1(a float(20),b char(25),class INT,score float(20,1))//
insert into t1 values(1,'测试all语句',1101,97)//
insert into t1 values(2,'测试all语句',1101,80.5)//
insert into t1 values(3,'测试all语句',1103,70)//
insert into t1 values(4,'测试all语句',1102,90)//
insert into t1 values(5,'测试all语句',1102,60)//
insert into t1 values(6,'测试all语句',1104,57)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select class,score from t1 where score > ALL(select score from t1 where a = 5) order by score;
END//
CALL pro1()//
class	score
1103	70.0
1101	80.5
1102	90.0
1101	97.0
