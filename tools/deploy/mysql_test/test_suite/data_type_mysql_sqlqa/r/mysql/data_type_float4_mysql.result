create procedure pro1()
BEGIN
declare e float(20);
declare f char(25);
declare g INT;
declare h float(20,1);
select a,b,class,score into e,f,g,h from t1 where a = 2;
select e,f,g,h;
END//
CALL pro1()//
e	f	g	h
2	select into(变量)	1101	80.5
