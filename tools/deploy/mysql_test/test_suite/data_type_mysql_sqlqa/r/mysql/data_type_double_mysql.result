########## 处理测试环境 ##########
drop database if exists zh_db;
create database if not exists zh_db;
use zh_db;
drop user 'funkzz';
# 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;
set autocommit=1;
####################################类型验证  ##标签float/double 1-1
##########精度传入  ##标签  float/double 1-1-1
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(7,2);
set a = 20;
END;//
call pro1();//
##无精度传入 ##标签  float/double 1-1-1
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double();
set a = 10;
END;//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ')' at line 3
call pro1();//
ERROR 42000: procedure zh_db.pro1 does not exist
浮点数类型DOUBLE[(M,D)] M是总位数，D是小数点后的位数，当只传入总位数M，不传入小数点后位数D，ob成功，mysql失败。bugid:37188921  bug已修复
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(7);
set a = 10;
END;//
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(7)' at line 3
call pro1();//
ERROR 42000: procedure zh_db.pro1 does not exist
