######关键字   
#####     select … from 查找
#####查询全部信息
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into t1 VALUES(1,"测试查询语句",a);
select * from t1;
END//
call pro1()//
id	result	a
1	测试查询语句	30.000000
#####查询单个字段信息信息
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into t1 VALUES(1,"测试查询语句",a);
select result,a from t1;
END//
call pro1()//
result	a
测试查询语句	30.000000
##### distinct 合并相同的项
##### 在PL语句声明double类型变量插入表中，使用distinct去重double类型的列。ob查询出来的语句列名显示:0，mysql查询出来的语句列明正常。
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   double(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into t1 VALUES(1,"插入测试去重语句1",100,a);
insert into t1 VALUES(2,"插入测试去重语句2",97,45);
insert into t1 VALUES(3,"插入测试去重语句3",100,33);
insert into t1 VALUES(4,"插入测试去重语句4",22,a);
select distinct a  from t1;
END//
call pro1()//
a
30.000000
##### limit 读取行数limit 2
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   double(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into t1 VALUES(1,"插入读取行数语句1",100,a);
insert into t1 VALUES(2,"插入读取行数语句2",97,45);
insert into t1 VALUES(3,"插入读取行数语句3",100,33);
insert into t1 VALUES(4,"插入读取行数语句4",22,a);
insert into t1 VALUES(5,"插入读取行数语句5",100,a);
insert into t1 VALUES(6,"插入读取行数语句6",97,46);
insert into t1 VALUES(7,"插入读取行数语句7",100,44);
insert into t1 VALUES(8,"插入读取行数语句8",22,a);
select * from t1 limit 2;
END//
call pro1()//
id	result	score	a
1	插入读取行数语句1	100	30.000000
2	插入读取行数语句2	97	45.000000
