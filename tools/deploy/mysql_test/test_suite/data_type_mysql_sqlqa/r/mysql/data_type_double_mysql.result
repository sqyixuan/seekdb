#######drop column
#######删除列
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
alter table t1 drop column a;
insert into t1 VALUES(1,'删除列的结果');
END//
call pro1()//
select * from t1//
id	result
1	删除列的结果
########################拷贝表 insert into select      ##标签 float/double 1-2-1-1-4
########拷贝表
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop table if exists t2//
Warnings:
Note	1051	Unknown table 'zh_db.t2'
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2 select * from t1;
END//
call pro1()//
select * from t2//
id	result	a
1	复制的数据	20.00
########拷贝表  部分数据
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2(id,a) select id,a from t1;
END//
call pro1()//
select * from t2//
id	result	a
1	NULL	20.00
########拷贝表  不包含主键数据
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2(result,a) select result,a from t1;
END//
call pro1()//
ERROR HY000: Field 'id' doesn't have a default value
select * from t2//
id	result	a
########拷贝表  两表不同浮点型列
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a float(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2(id,result,a) select id,result,a from t1;
END//
call pro1()//
select * from t2//
id	result	a
1	复制的数据	20.00
#################update更新         ##标签    float/double 1-2-1-2
#################update set where   ##标签    float/double 1-2-1-2-1
#################对象               ##标签     float/double 1-2-1-2-1-1
##update table
#######修改double字段表 数字
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'插入的数据',a); 
update t1 set a = 10 where a = 20;
END//
call pro1()//
select * from t1//
id	result	a
1	插入的数据	10.00
#######修改double字段 字符
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'插入的数据',a); 
update t1 set a = 'ss' where a = 20;
END//
call pro1()//
ERROR 01000: Data truncated for column 'a' at row 1
select * from t1//
id	result	a
1	插入的数据	20.00
#######修改double字段 符号
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 20;
insert into t1 VALUES(1,'插入的数据',a); 
update t1 set a = '￥%#￥' where a = 20;
END//
call pro1()//
ERROR 01000: Data truncated for column 'a' at row 1
select * from t1//
id	result	a
1	插入的数据	20.00
###########分区
#####hash分区double类型的列   ERROR 1659 (HY000): Field 's_c_no' is of a not allowed type for this type of partitioning
drop table if exists t1//
CREATE TABLE t1 (
s_s_no INT,
s_r_r  char(10),
s_c_no double(20,3),
s_score INT,
PRIMARY key(s_s_no,s_c_no)
) PARTITION BY hash(s_c_no) PARTITIONS 4//
ERROR HY000: Field 's_c_no' is of a not allowed type for this type of partitioning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE s_c_no double(20,3);
set s_c_no = 4;
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'hash分区',1,72);
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'hash分区',2,73);
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'hash分区',3,77);
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'hash分区',s_c_no,90);
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'hash分区',2,93);
END//
CALL pro1()//
ERROR 42S02: Table 'zh_db.t1' doesn't exist
SELECT
PARTITION_NAME,
TABLE_ROWS
FROM
INFORMATION_SCHEMA. PARTITIONS
WHERE
TABLE_NAME = 't1'//
