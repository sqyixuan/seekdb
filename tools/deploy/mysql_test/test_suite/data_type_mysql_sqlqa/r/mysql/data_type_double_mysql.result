########Match Against 搜索，match字段，against内容
#####全文索引不支持double类型
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   double(53,6),
FULLTEXT(a)
)//
ERROR 42000: A FTS index may only contain a text type column.
########Match Against 搜索，match字段，against内容
#####使用字符时ob不支持该功能
drop table if exists t1//
Warnings:
Note	1051	Unknown table 'zh_db.t1'
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   double(53,6),
FULLTEXT(result)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into t1 VALUES(1,"查询条件判断语句1",100,a);
insert into t1 VALUES(2,"查询条件判断语句2",97,45);
insert into t1 VALUES(3,"查询条件判断语句3",100,33);
insert into t1 VALUES(4,"查询条件判断语句4",22,a);
insert into t1 VALUES(5,"查询条件判断语句5",100,a);
insert into t1 VALUES(6,"查询条件判断语句6",97,46);
insert into t1 VALUES(7,"查询条件判断语句7",100,44);
insert into t1 VALUES(8,"查询条件判断语句8",22,a);
END//
call pro1()//
select * from t1 where match(result) against('查询条件判断语句8')//
id	result	score	a
8	查询条件判断语句8	22	30.000000
#########子查询    ##标签  float/double 1-2-1-2-1-2
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   double(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
insert into t1 VALUES(2,"插入读取行数语句2",97,45)//
insert into t1 VALUES(3,"插入读取行数语句3",100,33)//
insert into t1 VALUES(4,"插入读取行数语句4",22,20)//
insert into t1 VALUES(5,"插入读取行数语句5",100,77)//
insert into t1 VALUES(6,"插入读取行数语句6",97,46)//
insert into t1 VALUES(7,"插入读取行数语句7",100,44)//
insert into t1 VALUES(8,"插入读取行数语句8",22,5)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select * from t1 where a in (select a from t1 where score = 100);
END//
call pro1()//
id	result	score	a
1	插入读取行数语句1	100	20.000000
3	插入读取行数语句3	100	33.000000
