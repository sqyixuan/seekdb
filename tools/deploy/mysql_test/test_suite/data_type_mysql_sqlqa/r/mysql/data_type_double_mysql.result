######################dml语句                			   ##标签 float/double 1-2-1
########验证数据类型的insert语句						   ##标签 float/double 1-2-1-1
#####插入表											   ##标签 float/double 1-2-1-1-1
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(255,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(255,6);
set a = 20;
insert into t1 VALUES(1,"插入的double值",a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	20.000000
#####插入视图											##标签 float/double 1-2-1-1-1
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(255,6)
)//
drop view if exists v1//
create view v1 as select * from t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(255,6);
set a = 30;
insert into v1 VALUES(1,"插入的double值",a);
END//
call pro1()//
select * from v1//
id	result	a
1	插入的double值	30.000000
###############插入数据验证      ##标签 float/double 1-2-1-1-2
#######插入数字
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 50;
insert into t1 VALUES(1,"插入的double值",a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	50.000000
#######插入时间
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 2021-12-11;
insert into t1 VALUES(1,"插入的double值",a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	1998.00
#######插入字符   ob创建成功，调用成功。插入的数据为NULL值。mysql创建成功，调用失败
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 'sss';
insert into t1 VALUES(1,'插入的double值',a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	NULL
#######插入特殊字符    ob创建成功，调用成功。插入的数据为NULL值。mysql创建成功，调用失败
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = '！@#';
insert into t1 VALUES(1,'插入的double值',a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	NULL
#######插入边界值
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,2);
set a = 1222222222123333333333333333356456454444;
insert into t1 VALUES(1,'插入的double值',a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	1222222222123333300000000000000000000000.00
#######alter table with data      ##标签 float/double 1-2-1-1-3
#######add column
########添加正常范围double列
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(52,2);
set a = 30;
alter table t1 add a double(52,2);
insert into t1 VALUES(1,'插入的double值',a);
END//
call pro1()//
select * from t1//
id	result	a
1	插入的double值	30.00
