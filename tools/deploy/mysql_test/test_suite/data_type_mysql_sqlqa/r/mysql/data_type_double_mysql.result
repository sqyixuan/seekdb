######视图
###修改视图数据   数字
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(53,6)
)//
drop view if exists v1//
create view v1 as select * from t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a double(53,6);
set a = 30;
insert into v1 VALUES(1,'修改的数据',a);
update v1 set a = 20 where id = 1;
END//
call pro1()//
select * from v1//
id	result	a
1	修改的数据	20.000000
###修改视图数据    字符
