######精度值范围     ##标签 float/double 1-1-2-3
##浮点数类型(double[(M,D)]M是总位数，D是小数点后的位数，取值范围为 M（1～255）和 D（0～30，且M>=D)
##定义长度M等于255
drop table if exists t1;//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   double(255,2)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(255,2);
set a = 20;
insert into t1 VALUES(1,"插入的double值",a);
END;//
call pro1();//
select * from t1;//
id	result	a
1	插入的double值	20.00
##测试double的宽度范围
##定义长度M大于255
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(256,2);
set a = 20;
END;//
ERROR 42000: Display width out of range for column '(null)' (max = 255)
call pro1();//
ERROR 42000: procedure zh_db.pro1 does not exist
####定义小数D大于0，大于30时。
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(255,31);
set a = 20;
END;//
ERROR 42000: Too big scale 31 specified for column '(null)'. Maximum is 30.
call pro1();//
ERROR 42000: procedure zh_db.pro1 does not exist
##测试D>M时的结果         ob创建存储成功，调用失败。MySQL创建存储失败
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(0,1);
set a = 10.22;
END;//
Warnings:
Warning	5002	Resolve error
call pro1();//
ERROR 42000: For float(M,D), double(M,D) or decimal(M,D), M must be >= D (column '').
##测试D>M时的结果          ob创建存储成功，调用失败。MySQL创建存储失败
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a double(3,6);
set a = 1045.22;
END;//
Warnings:
Warning	5002	Resolve error
call pro1();//
ERROR 42000: For float(M,D), double(M,D) or decimal(M,D), M must be >= D (column '').
