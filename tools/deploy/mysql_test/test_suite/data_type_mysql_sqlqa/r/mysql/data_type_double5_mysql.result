########select操作，与字符串类型比较
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a char(20);
set a = 20;
select  * from t1 where a_double < a;
END//
CALL pro1()//
id	a_double
2	19.53
3	10.53
4	15.53
#####调用方法时与定义的变量不同类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare p_double char(20);
set p_double = 20;
select  * from t1 where a_double < p_double;
END//
CALL pro1()//
id	a_double
2	19.53
3	10.53
4	15.53
#####直接赋值   数字
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a_double double(20,2);
declare p_char char(20);
set a_double = 20;
set p_char = 50;
insert into t1 values(1,a_double);
set a_double = p_char;
insert into t1 values(2,a_double);
END//
CALL pro1()//
select * from t1//
id	a_double
1	20.00
2	50.00
#####直接赋值   字符串         ob传入null值，mysql创建存储成功，调用失败
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare a_double double(20,2);
declare p_char char(20);
set a_double = 20;
set p_char = 'aa';
insert into t1 values(1,a_double);
set a_double = p_char;
insert into t1 values(2,a_double);
END//
CALL pro1()//
select * from t1//
id	a_double
1	20.00
2	NULL
#####算术运算 
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare p_char char(20);
set p_char = 20;
insert into t1 values(1,1+p_char);
END//
CALL pro1()//
select * from t1//
id	a_double
1	21.00
