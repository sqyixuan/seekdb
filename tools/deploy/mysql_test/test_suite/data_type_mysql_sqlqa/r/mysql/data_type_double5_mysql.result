#####double变量的使用
drop table if exists t1//
CREATE TABLE t1(a double(20,2),b char(25),class INT,score double(20,1))//
insert into t1 values(1,'double变量',1101,97)//
insert into t1 values(2,'double变量',1101,80.5)//
insert into t1 values(3,'double变量',1102,70.5)//
insert into t1 values(4,'double变量',1102,85.5)//
insert into t1 values(5,'double变量',1102,90)//
insert into t1 values(6,'double变量',1103,90.5)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
declare e double(20,2);
declare f char(25);
declare g INT;
declare h double(20,1);
select a,b,class,score into e,f,g,h from t1 where a = 2;
select e,f,g,h;
END//
CALL pro1()//
e	f	g	h
2.00	double变量	1101	80.5
#####递归
drop procedure if exists factorial//
set @@session.max_sp_recursion_depth=99//
create procedure factorial (in n double(20,3), out b double(20,3))  
begin  
declare c_in double(20,3);
declare c_out double(20,3);
if n!=1 then 
set c_in := n-1;  
call factorial(c_in,c_out);  
set b:=n*c_out;  
else  
set b:=1;  
end if;  
end//
call factorial(6,@r)//
select @r//
@r
720.000
