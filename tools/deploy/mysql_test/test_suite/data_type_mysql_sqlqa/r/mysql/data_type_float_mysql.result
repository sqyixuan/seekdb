########## 处理测试环境 ##########
drop database if exists zh_db;
create database if not exists zh_db;
use zh_db;
drop user 'funkzz';
# 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;
set autocommit=1;
#####################################类型验证  ##标签float/double 1-1
###########单精度传入  ##标签  float/double 1-1-1
drop table if exists t1;//
CREATE TABLE t1(
id int(10) primary key,
result varchar(10),
a float(7,2)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a float(7,2);
set a = 20;
insert into t1 VALUES(1,'插入的float值',a);
END;//
call pro1();//
select * from t1;//
id	result	a
1	插入的float值	20.00
###无精度传入 ##标签  float/double 1-1-1
