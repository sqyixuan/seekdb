###############group by ... having 分组后筛选
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   float(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
insert into t1 VALUES(2,"插入读取行数语句2",97,45)//
insert into t1 VALUES(3,"插入读取行数语句3",100,33)//
insert into t1 VALUES(4,"插入读取行数语句4",22,15)//
insert into t1 VALUES(5,"插入读取行数语句5",100,10)//
insert into t1 VALUES(6,"插入读取行数语句6",97,46)//
insert into t1 VALUES(7,"插入读取行数语句7",100,44)//
insert into t1 VALUES(8,"插入读取行数语句8",22,30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select a,sum(score) from t1 group by a having sum(score) >= 100;
END//
call pro1()//
a	sum(score)
20.000000	100
33.000000	100
10.000000	100
44.000000	100
###############where … group by … having 先筛选再分组再筛选
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   float(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
insert into t1 VALUES(2,"插入读取行数语句2",97,45)//
insert into t1 VALUES(3,"插入读取行数语句3",100,33)//
insert into t1 VALUES(4,"插入读取行数语句4",22,15)//
insert into t1 VALUES(5,"插入读取行数语句5",100,10)//
insert into t1 VALUES(6,"插入读取行数语句6",97,46)//
insert into t1 VALUES(7,"插入读取行数语句7",100,44)//
insert into t1 VALUES(8,"插入读取行数语句8",22,30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select score,sum(a),id from t1 where id = 1 group by score having sum(a) >= 20;
END//
call pro1()//
score	sum(a)	id
100	20.000000	1
#########union 组合查询，多个select
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   float(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
insert into t1 VALUES(2,"插入读取行数语句2",97,45)//
insert into t1 VALUES(3,"插入读取行数语句3",100,33)//
insert into t1 VALUES(4,"插入读取行数语句4",22,15)//
insert into t1 VALUES(5,"插入读取行数语句5",100,10)//
insert into t1 VALUES(6,"插入读取行数语句6",97,46)//
insert into t1 VALUES(7,"插入读取行数语句7",100,44)//
insert into t1 VALUES(8,"插入读取行数语句8",22,30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select * from t1 where a < 30
union
select * from t1 where a > 40;
END//
call pro1()//
id	result	score	a
1	插入读取行数语句1	100	20.000000
2	插入读取行数语句2	97	45.000000
4	插入读取行数语句4	22	15.000000
5	插入读取行数语句5	100	10.000000
6	插入读取行数语句6	97	46.000000
7	插入读取行数语句7	100	44.000000
#########union all 组合查询，不合并相同信息
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
score int(10),
a   float(53,6)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
score int(10),
a   float(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
insert into t1 VALUES(2,"插入读取行数语句2",97,45)//
insert into t1 VALUES(3,"插入读取行数语句3",100,33)//
insert into t1 VALUES(4,"插入读取行数语句4",22,15)//
insert into t1 VALUES(5,"插入读取行数语句5",100,10)//
insert into t1 VALUES(6,"插入读取行数语句6",97,46)//
insert into t1 VALUES(7,"插入读取行数语句7",100,44)//
insert into t1 VALUES(8,"插入读取行数语句8",22,30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
select a from t1
union all
select a from t2;
END//
call pro1()//
a
