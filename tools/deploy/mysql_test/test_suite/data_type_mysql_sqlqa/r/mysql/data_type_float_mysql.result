############精度值范围     ##标签 float/double 1-1-2-3
###浮点数类型(FLOAT[(M,D)]M是总位数，D是小数点后的位数，取值范围为 M（1～255）和 D（0～30，且M>=D）
###定义长度M等于53 
drop table if exists t1;//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(53)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a float(53);
set a = 20;
insert into t1 VALUES(1,"插入的float值",a);
END;//
call pro1();//
select * from t1;//
id	result	a
1	插入的float值	20
###测试float的宽度范围
#定义长度大于53的浮点数类型列对象，mysql成功，ob失败。（mysql中 M范围（1～255），ob中M范围（1～53）
###定义长度M大于53   bugid:37211144   bug已修复
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a float(54);
set a = 20;
END;//
ERROR 42000: Incorrect column specifier for column ''
call pro1();//
ERROR 42000: procedure zh_db.pro1 does not exist
#####定义总位数M大于53,小于等于255时，定义小数D大于0，小于等于30时。ob建表失败，ob创建存储成功，调用失败。MySQL创建成功，调用成功。bugid:37218121   bug已修复
drop table if exists t1;//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(54,2)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a float(54,2);
set a = 20;
insert into t1 VALUES(1,"插入的float值",a);
END;//
call pro1();//
select * from t1;//
id	result	a
1	插入的float值	20.00
###测试D>M时的结果
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
DECLARE a float(0,1);
set a = 10.22;
insert into t1 VALUES(a);
END;//
Warnings:
Warning	5002	Resolve error
call pro1();//
ERROR 42000: For float(M,D), double(M,D) or decimal(M,D), M must be >= D (column '').
