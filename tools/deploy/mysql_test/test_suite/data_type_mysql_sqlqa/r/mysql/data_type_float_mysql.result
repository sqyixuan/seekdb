#########拷贝表
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop table if exists t2//
Warnings:
Note	1051	Unknown table 'zh_db.t2'
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop procedure if exists pro1//
