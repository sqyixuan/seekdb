1	复制的数据	20.00
#########拷贝表  部分数据
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a float(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2(id,a) select id,a from t1;
END//
call pro1()//
select * from t2//
id	result	a
1	NULL	20.00
#########拷贝表  不包含主键数据
drop table if exists t1//
CREATE TABLE t1 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop table if exists t2//
CREATE TABLE t2 (
id  int(10) primary key,
result char(10),
a   float(53,2)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
DECLARE a float(53,2);
set a = 20;
insert into t1 VALUES(1,'复制的数据',a);
insert into t2(result,a) select result,a from t1;
END//
call pro1()//
ERROR HY000: Field 'id' doesn't have a default value
select * from t2//
id	result	a
