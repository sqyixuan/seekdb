--echo ########## 处理测试环境 ##########
--disable_warnings
drop database if exists zh_db;
--enable_warnings
create database if not exists zh_db;
use zh_db;
--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

--echo # 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc

connect (con_zh,$OBMYSQL_MS0,funkzz,funkzz,zh_db,$OBMYSQL_PORT);
connection con_zh;
set autocommit=1;
#--source output_print_enable.inc
#--source mysql_test/include/check_tenant_sync.inc
delimiter //;

--echo ##########子查询    ##标签  float/double 1-2-1-2-1-2
--disable_warnings
drop table if exists t2//
--enable_warnings
--disable_warnings
drop table if exists t1//
--enable_warnings
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	score int(10),
	a   float(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(53,6);
	set a = 30;
	insert into t1 VALUES(1,"查询条件判断语句1",100,a);
	insert into t1 VALUES(2,"查询条件判断语句2",97,45);
	insert into t1 VALUES(3,"查询条件判断语句3",100,33);
	insert into t1 VALUES(4,"查询条件判断语句4",22,a);
	insert into t1 VALUES(5,"查询条件判断语句5",100,a);
	insert into t1 VALUES(6,"查询条件判断语句6",97,46);
	insert into t1 VALUES(7,"查询条件判断语句7",100,44);
	insert into t1 VALUES(8,"查询条件判断语句8",22,a);
END//
call pro1()//
select * from t1 where a in (select a from t1 where score = 100)//




--echo ##########快速游标    ##标签   float/double 1-2-1-2-2
--disable_warnings
drop table if exists student//
--enable_warnings
create table student(
    stuId int primary key auto_increment,
    stuName varchar(20),
    stuSex varchar(2),
    stuAge float(53,2)
)default charset=utf8//
insert into student(stuName,stuSex,stuAge) values('小明','男',20)//
insert into student(stuName,stuSex,stuAge) values('小花','女',19)//
insert into student(stuName,stuSex,stuAge) values('大赤','男',20)//
insert into student(stuName,stuSex,stuAge) values('可乐','男',19)//
insert into student(stuName,stuSex,stuAge) values('莹莹','女',19)//
drop procedure if exists p1//
create procedure p1()
begin
    declare id int;
    declare name varchar(100) character set utf8;
    declare done int default 0;

    declare mc cursor for select stuId,stuName from student where stuAge >19;
    declare continue handler for not found set done = 1;

    open mc;

    fetch mc into id,name;

    select id,name;
	
    close mc;
end //

call p1()//


--echo ########delete  commit rollback    标签 float/double 1-2-1-3
set autocommit =0//
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	score int(10),
	a   float(53,6)
)//
ALTER TABLE t1 ENGINE=Innodb//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	insert into t1 VALUES(1,"查询条件判断语句1",100,30);
	insert into t1 VALUES(2,"查询条件判断语句2",97,45);
	insert into t1 VALUES(3,"查询条件判断语句3",100,33);
	insert into t1 VALUES(4,"查询条件判断语句4",22,30);
	commit;
	delete from t1 where a = 30;
	rollback;
END//
call pro1()//
select * from t1//


--echo ########拷贝表  create table as   标签  float/double 1-2-1-4

drop table if exists t1//
drop table if exists t2//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	score int(10),
	a   float(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(53,6);
	set a = 30;
	insert into t1 VALUES(1,"查询条件判断语句1",100,a);
	insert into t1 VALUES(2,"查询条件判断语句2",97,45);
	insert into t1 VALUES(3,"查询条件判断语句3",100,33);
	insert into t1 VALUES(4,"查询条件判断语句4",22,a);
	create table t2 as select * from t1; 
END//
call pro1()//
select * from t2//


