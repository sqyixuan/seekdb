--echo ######创建索引        标签float/double 1-2-2-1-2
--echo ####创建普通索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (a float(20,3) primary key, b DATE);
	alter table t1 add index a_index(a);
END//

CALL pro1()//


--echo ####创建唯一索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (a float(20,3) primary key, b char(20));
	alter table t1 add UNIQUE(a);
END//

CALL pro1()//
insert into t1 values(1,'测试唯一索引')//
--error 1062
insert into t1 values(1,'测试唯一索引')//
insert into t1 values(2,'测试唯一索引')//
insert into t1 values(3,'测试唯一索引')//
select * from t1//


--echo ##########创建主键索引     
--echo ######在使用procedure创建主键索引时，ob调用时报错，创建主键索引失败。mysql创建主键索引成功。直接建表创建主键索引的话，ob创建成功。bugid:37396924
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a float(20,3),b char(20));
	alter table t1 add primary key(a);
END//
CALL pro1()//
insert into t1 values(1,'测试主键索引')//
--error 1062
insert into t1 values(1,'测试主键索引')//
insert into t1 values(3,'测试主键索引')//
insert into t1 values(4,'测试主键索引')//
select * from t1//

--echo ####创建组合索引

drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a float(20,3),b char(20),c INT);
	alter table t1 add INDEX m_index(a,b,c);
END//

CALL pro1()//


--echo ####创建全文索引        ob创建失败，MySQL创建成功
--echo ######ERROR 1235 (0A000): Not supported feature or function
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a float(20,3),b char(20),c INT,d text);
	alter table t1 add FULLTEXT(d);
END//

CALL pro1()//



--echo ##########创建视图           标签float/double 1-2-2-1-3
--echo ######create or replace
--disable_warnings
drop table if exists t1//
--enable_warnings
	CREATE TABLE t1 (
	a   float(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view v1 as select * from t1;
END//
call pro1()//

select * from v1//


--echo ######create or replace 查询一个float列
drop table if exists t1//
	CREATE TABLE t1 (
	a   float(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view v1 as select a from t1;
END//
call pro1()//

select * from v1//

--echo ######as 给float列取别名
drop table if exists t1//
	CREATE TABLE t1 (
	a   float(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view test_v1 as select a as test_float_a from t1;
END//
call pro1()//

