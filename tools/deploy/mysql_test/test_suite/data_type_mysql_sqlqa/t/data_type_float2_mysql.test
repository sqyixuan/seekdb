--echo ######给float列创建foreign key约束  主表和从表关联字段数据类型一样,范围一致  
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   float(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   float(53) primary key,
	d   varchar(10),
	e   float(20,3) not null,
	foreign key(e)references t1(a)
	);
	
END//
call pro1()//

--echo ######给float列创建foreign key约束  主表和从表关联字段数据类型一样,子表float列范围小于父表float范围列 
--echo #####在创建表时，给主表创建外键时，子表外键的float类型范围小于父表，ob会创建失败，mysql创建成功。bugid:37383276    限制没有意义，已关闭
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   float(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   float(53) primary key,
	d   varchar(10),
	e   float(11,3) not null,
	foreign key(e)references t1(a)
	);
	
END//
call pro1()//

--echo ######给float列创建foreign key约束  主表和从表关联字段数据类型一致,子表float列范围大于父表float范围列
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   float(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   float(53) primary key,
	d   varchar(10),
	e   float(21,3) not null,
	foreign key(e)references t1(a)
	);
	
END//

call pro1()//


--echo ######给float列创建foreign key约束  主表关联字段为double类型和从表关联字段为float类型,范围一致   ob 1 warning
drop table if exists t2//
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   float(53) primary key,
	d   varchar(10),
	e   float(20,3) not null,
	foreign key(e)references t1(a)
	);
	
END//
--error 1215
call pro1()//

--echo ######给float列创建foreign key约束  主表关联字段为float类型和从表关联字段为double类型,范围一致   ob 1 warning
