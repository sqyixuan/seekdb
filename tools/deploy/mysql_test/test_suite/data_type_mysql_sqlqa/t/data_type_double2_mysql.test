--echo ########## 处理测试环境 ##########
--disable_warnings
drop database if exists zh_db;
--enable_warnings
create database if not exists zh_db;
use zh_db;
--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

--echo # 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc

connect (con_zh,$OBMYSQL_MS0,funkzz,funkzz,zh_db,$OBMYSQL_PORT);
connection con_zh;
set autocommit=1;
#--source output_print_enable.inc
#--source mysql_test/include/check_tenant_sync.inc
delimiter //;

--echo #########ddl					标签  float/double 1-2-2
--echo #########create       			
--echo #####create table            标签  float/double 1-2-2-1-1
--echo #####定义double的总位数M超过255，ob创建存储成功，调用失败。MySQL创建存储失败
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a  double(256,6)
	);
END//
--error 1439
call pro1()//

--echo #####定义字符数据类型double的列时，当传入的长度为小数时，ob创建存储失败，MySQL创建存储成功。
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(3.6)
	);
END//
--error 1305
call pro1()//


--echo #####定义字符数据类型double的列时，当传入的长度为字符时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(zzz)
	);
END//
--error 1305
call pro1()//



--echo #####定义字符数据类型double的列时，当传入的长度为特殊字符时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(^^)
	);
END//
--error 1305
call pro1()//


--echo #####定义字符数据类型double的列时，当传入的长度为0时 ob 1 warning
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(0)
	);
END//
--error 1305
call pro1()//

--echo #####定义字符数据类型double的列时，当传入的长度为空时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double()
	);
END//
--error 1305
call pro1()//

--echo #####定义字符数据类型double的列时，当传入超大值时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(4651616156444444444444444444444444444445315466431213215645646556,2)
	);
END//
--error 1305
call pro1()//

--echo #####定义字符数据类型double的列时，当传入负数时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(-3)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型 列
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(6,2),
	b   double(5,4)
	);
END//
call pro1()//

--echo #####定义多个double类型总位数M>53,且带小数位D 列    ob创建存储成功，调用失败。MySQL创建存储成功，调用成功。
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(256,3),
	b   double(256,3)
	);
END//
--error 1439
call pro1()//

--echo #####定义多个double类型传入小数时  ob创建存储失败，MySQL创建存储成功。
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(5.6,2),
	b   double(5.6,2)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型传入字符时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(zzz),
	b   double(zzz)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型传入超大值时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(45645616123132123156456156162132132132123123156415656456415641,2),
	b   double(45645615163213216545645616156456453212316545656653213256456565,3)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型传入负数时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(-5),
	b   double(-6)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型传入0时 ob 1 warning
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(0),
	b   double(0)
	);
END//
--error 1305
call pro1()//

--echo #####定义多个double类型传入空值时
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(),
	b   double()
	);
END//
--error 1305
call pro1()//

--echo #####定义double列+多个其他列
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(20,2),
	b   varchar(10)
	);
END//
call pro1()//

--echo #####定义double列+多个其他列 double的总位数M>53    ob创建存储成功，调用失败。MySQL创建存储失败.
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(256,2),
	b   varchar(10)
	);
END//
--error 1439
call pro1()//

--echo ##################约束
--echo #####给double列创建not null约束
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(53,2) not null,
	b   varchar(10)
	);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试非空约束')//
insert into t1 (a,b) values(2,'测试非空约束')//
--error 1048
insert into t1 (a,b) values(null,'测试非空约束')//
select * from t1//



--echo #####给double列创建not null约束double(M,D)  M的值>255      
drop procedure if exists pro1// 
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(256,2) not null,
	b   varchar(10)
	);
END//
--error 1439
call pro1()//


--echo #####给double列创建unique约束     ob 1 warning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(53,2) unique,
	b   varchar(10)
	);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试非空约束')//
insert into t1 (a,b) values(2,'测试非空约束')//
--error 1062
insert into t1 (a,b) values(2,'测试非空约束')//
select * from t1//

--echo #####给double列创建unique约束double(M,D)  M的值>255        
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(256,2) unique,
	b   varchar(10)
	);
END//
--error 1439
call pro1()//


--echo #####给double列创建primary key约束     ob 1 warning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(53,3) primary key,
	b   varchar(10)
	);
END//
call pro1()//
insert into t1 (a,b) values(1,'测试主键约束')//
insert into t1 (a,b) values(2,'测试主键约束')//
--error 1062
insert into t1 (a,b) values(2,'测试主键约束')//
select * from t1//


--echo #####给double列创建primary key约束 double(M,D) M的值>255 ，且传入D的值 
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table if exists t1;
	CREATE TABLE t1 (
	a   double(256,2) primary key,
	b   varchar(10)
	);
END//
--error 1439
call pro1()//

--echo #####给double列创建foreign key约束  主表和从表关联字段数据类型一样,范围一致   
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   double(53,2) primary key,
	d   varchar(10),
	e   double(20,3) not null,
	foreign key(e)references t1(a)
	);
END//
call pro1()//

--echo #####给double列创建foreign key约束  主表和从表关联字段数据类型一样,子表double列范围小于父表double范围列 
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   double(53,2) primary key,
	d   varchar(10),
	e   double(11,3) not null,
	foreign key(e)references t1(a)
	);
END//
call pro1()//

--echo #####给double列创建foreign key约束  主表和从表关联字段数据类型一致,子表double列范围大于父表double范围列
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   double(53,2) primary key,
	d   varchar(10),
	e   double(21,3) not null,
	foreign key(e)references t1(a)
	);
END//
call pro1()//

--echo #####给double列创建foreign key约束  主表关联字段为double类型和从表关联字段为double类型,范围一致
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   double(53,2) primary key,
	d   varchar(10),
	e   double(20,3) not null,
	foreign key(e)references t1(a)
	);
END//
call pro1()//

--echo #####给double列创建foreign key约束  主表关联字段为double类型和从表关联字段为double类型,范围一致
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings

drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) not null primary key,
	b   varchar(10)
	);
	CREATE TABLE t2 (
	c   double(53,2) primary key,
	d   varchar(10),
	e   double(20,3) not null,
	foreign key(e)references t1(a)
	);
END//
call pro1()//

--echo #####给double列创建default约束
drop table if exists t2//  
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) default 5,
	b   varchar(20)
	);
END//
call pro1()//
insert into t1 values(1,'测试default约束')//
insert into t1 (b) values('测试default约束')//
insert into t1 values(3,'测试default约束')//
select * from t1//

--echo #####给double列创建default约束 默认值为字符  
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3) default 'sss',
	b   varchar(20)
	);
END//
--error 1067
call pro1()//
--error 1146
select * from t1//

--disable_warnings 
drop table if exists t1//
--enable_warnings
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (
	a   double(20,3),
	b   varchar(20),
	check(a > 20 AND a < 50)
	);
END//
call pro1()//
drop table t1;//

--echo #####创建索引        标签float/double 1-2-2-1-2
--echo ###创建普通索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (a double(20,3) primary key, b DATE);
	alter table t1 add index a_index(a);
END//
CALL pro1()//

--echo ###创建唯一索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1 (a double(20,3) primary key, b char(20));
	alter table t1 add UNIQUE(a);
END//

CALL pro1()//
insert into t1 values(1,'测试唯一索引')//
--error 1062
insert into t1 values(1,'测试唯一索引')//
insert into t1 values(2,'测试唯一索引')//
insert into t1 values(3,'测试唯一索引')//
select * from t1//


--echo #########创建主键索引     
--echo #####在使用procedure创建主键索引时，ob调用时报错，创建主键索引失败。mysql创建主键索引成功。直接建表创建主键索引的话，ob创建成功。
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a double(20,3),b char(20));
	alter table t1 add primary key(a);
END//
CALL pro1()//
insert into t1 values(1,'测试主键索引')//
--error 1062
insert into t1 values(1,'测试主键索引')//
insert into t1 values(3,'测试主键索引')//
insert into t1 values(4,'测试主键索引')//
select * from t1//

--echo ###创建组合索引
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a double(20,3),b char(20),c INT);
	alter table t1 add INDEX m_index(a,b,c);
END//
CALL pro1()//


--echo ###创建全文索引        ob创建失败，MySQL创建成功 bugid:37648842  功能被移除
--echo #####ERROR 1235 (0A000): Not supported feature or function
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a double(20,3),b char(20),c INT,d text);
	alter table t1 add FULLTEXT(d);
END//

CALL pro1()//



--echo #########创建视图           标签float/double 1-2-2-1-3
--echo #####create or replace
drop table if exists t1//
	CREATE TABLE t1 (
	a   double(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view v1 as select * from t1;
END//
call pro1()//
select * from v1//

--echo #####create or replace 查询一个double列
drop table if exists t1//
	CREATE TABLE t1 (
	a   double(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view v1 as select a from t1;
END//
call pro1()//
select * from v1//

--echo #####as 给double列取别名
drop table if exists t1//
	CREATE TABLE t1 (
	a   double(20,2),
	b   varchar(10)
)//
insert into t1 values(1,'测试创建视图1')//
insert into t1 values(2,'测试创建视图2')//
insert into t1 values(3,'测试创建视图3')//
insert into t1 values(4,'测试创建视图4')//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	create or replace view test_v1 as select a as test_double_a from t1;
END//
call pro1()//
select * from test_v1//

--echo ########查看建表结果desc    标签 float/double 1-2-2-1-4
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	desc t1;
END//
CALL pro1()//




delimiter ;//
--echo # 清理测试用户
#--source output_print_disable.inc
disconnect con_zh;
connection default;

--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings
