--echo ########数据类型转换        标签 float/double 1-5
--echo #######隐式数据类型转换     标签float/double 1-5-1
--echo #######insert      double类型转换char类型
drop table if exists t1//
CREATE TABLE t1(a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a char(20);
	set a = 'aa';
	insert into t1 values(a);
END//
--error 1265
CALL pro1()//
select * from t1//

--echo #######insert      double类型转换INT类型
drop table if exists t1//
CREATE TABLE t1(a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a INT(20);
	set a = 22;
	insert into t1 values(a);
END//
CALL pro1()//
select * from t1//

--echo #######insert      double类型转换double类型
drop table if exists t1//
CREATE TABLE t1(a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a double(20,3);
	set a = 22.222;
	insert into t1 values(a);
END//
CALL pro1()//
select * from t1//

--echo ########update     转换char类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a char(20);
	set a = 'aaaa';
	update t1 set a_double = a where id = 1;	
END//
--error 1265
CALL pro1()//
select * from t1//

--echo ########update    转换int类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a INT;
	set a = 20;
	update t1 set a_double = a where id = 1;
END//
CALL pro1()//
select * from t1//

--echo ########update    转换double类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a double(10,3);
	set a = 20.222;
	update t1 set a_double = a where id = 1;
END//
CALL pro1()//
select * from t1//

--echo ########select操作，与字符串类型比较
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a char(20);
	set a = 20;
	select  * from t1 where a_double < a;
END//
CALL pro1()//

--echo #####调用方法时与定义的变量不同类型
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
insert into t1 values(1,22.53)//
insert into t1 values(2,19.53)//
insert into t1 values(3,10.53)//
insert into t1 values(4,15.53)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare p_double char(20);
	set p_double = 20;
	select  * from t1 where a_double < p_double;
END//
CALL pro1()//

--echo #####直接赋值   数字
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a_double double(20,2);
	declare p_char char(20);
	set a_double = 20;
	set p_char = 50;
	insert into t1 values(1,a_double);
	set a_double = p_char;
	insert into t1 values(2,a_double);
END//
CALL pro1()//
select * from t1//

--echo #####直接赋值   字符串         ob传入null值，mysql创建存储成功，调用失败
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a_double double(20,2);
	declare p_char char(20);
	set a_double = 20;
	set p_char = 'aa';
	insert into t1 values(1,a_double);
	set a_double = p_char;
	insert into t1 values(2,a_double);
END//
CALL pro1()//
select * from t1//

--echo #####算术运算 
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare p_char char(20);
	set p_char = 20;
	insert into t1 values(1,1+p_char);
END//
CALL pro1()//
select * from t1//


--echo #####显式数据类型转换to_char       标签 float/double 1-5-2
drop table if exists t1//
CREATE TABLE t1(id INT,a_double double(20,2))//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare p_char double(20,3);
	set p_char = 20.22;
	select to_char(p_char) from dual;
END//
CALL pro1()//

--echo #####显式数据类型转换cast    char类型转double类型
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	declare p_char char(20);
	set p_char = 20.22;
	select cast(p_char as double(10,1));
END//
--error 1305
CALL pro1()//


--echo #####显式数据类型转换cast    double类型转char类型
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare p_double double(20,2);
	set p_double = 20.22;
	select cast(p_double as char(20));
END//
CALL pro1()//

--echo #####显式数据类型转换cast    double类型转char类型
drop procedure if exists pro1//
--error 1064
create procedure pro1()
BEGIN
	declare p_double double(20,2);
	set p_double = 20.22;
	select cast(p_double as INT);
END//
--error 1305
CALL pro1()//




