--echo ###########存储过程         标签   float/double 1-3
--echo ###########变量             标签   float/double 1-3-1
--echo #####@a设置变量  设置数字
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	declare a double(20,3) default 0;
	set @a = 30.00;
END//
CALL pro1()//
select @a//

