--echo ########## 处理测试环境 ##########
--disable_warnings
drop database if exists zh_db;
--enable_warnings
create database if not exists zh_db;
use zh_db;
--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

--echo # 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc

connect (con_zh,$OBMYSQL_MS0,funkzz,funkzz,zh_db,$OBMYSQL_PORT);
connection con_zh;
set autocommit=1;
#--source output_print_enable.inc
#--source mysql_test/include/check_tenant_sync.inc
delimiter //;


--echo ###############alter table  标签  float/double 1-2-2-2-1
--echo #########列           标签  float/double 1-2-2-2-1-1
--echo #####修改double列成varchar类型

--disable_warnings
drop table if exists t1//
--enable_warnings
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a varchar(10);
END//
CALL pro1()//
desc t1//

--echo #####修改double列成varchar类型   并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a varchar(10);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####修改double列成float类型
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a float(10,2);
END//
CALL pro1()//
desc t1//

--echo #####修改char列成double类型  并且包含字符类型的数据
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'www',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column b double(10,2);
END//
--error 1292
CALL pro1()//
select * from t1//
desc t1//

--echo #####修改char列成double类型  并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column b double(10,2);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####修改char列成double类型 且M>255  并且包含浮点型的数据
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'32.22',30)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column b double(256,2);
END//
--error 1439
CALL pro1()//
select * from t1//
desc t1//

--echo #####添加double类型 列
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add column d double(22,2);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####添加列与已有的列名相同 范围不同
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add column a double(22,2);
END//
--error 1060
CALL pro1()//
select * from t1//
desc t1//

--echo #####添加列   使用first添加列
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add column d double(22,2) first;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####添加列   使用after添加列
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add column d double(22,2) after a;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####删除列 
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 drop column a;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####删除多列
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 drop column a,drop column b;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #############修改列名不修改列的数据类型
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 change a d double(20,3);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #############修改列名修改列的数据类型
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 change a d float(20,3);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo ###############约束            标签     float/double 1-2-2-2-1-2
--echo #####给double列添加主键约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add primary key(a);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列添加唯一约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 add unique(a);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列添加非空约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 MODIFY a double(20,3) not null;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列添加外键约束
--disable_warnings
drop table if exists t2//
drop table if exists t1//
--enable_warnings
CREATE TABLE t1(a double(20,3) primary key,b char(20),c INT)//
CREATE TABLE t2(d double(20,3),e char(20),f INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t2 ADD CONSTRAINT FK_ID FOREIGN KEY(d) REFERENCES t1(a);
END//
CALL pro1()//
select * from t1//
desc t1//
desc t2//

--echo #####给double列添加默认default约束
drop table if exists t2//
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a double(20,3) default 2;
END//
CALL pro1()//
insert into t1 values(1,'测试添加默认约束',10)//
insert into t1 (b,c) values('测试添加默认约束',20)//
insert into t1 values(3,'测试添加默认约束',30)//
select * from t1//


drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 ADD CONSTRAINT check_id CHECK(a > 2);
END//
CALL pro1()//
--error 3819
insert into t1 values(1,'测试添加默认约束',10)//
--error 3819
insert into t1 values(2,'测试添加默认约束',20)//
insert into t1 values(3,'测试添加默认约束',30)//
select * from t1//

--echo #####给double列删除主键约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3) primary key,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 drop primary key;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列删除非空约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3) not null,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify a double(20,3);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列删除非空约束  修改double数据类型
drop table if exists t1//
CREATE TABLE t1(a double(20,3) not null,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify a double(20,3);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列删除非空约束  修改char数据类型
drop table if exists t1//
CREATE TABLE t1(a double(20,3) not null,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify a char(20);
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列删除唯一约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3) unique,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 drop index a;
END//
CALL pro1()//
select * from t1//
desc t1//

--echo #####给double列删除外键约束
drop table if exists t2//
drop table if exists t1//
CREATE TABLE t1(a double(20,3) primary key,b char(20),c INT)//
CREATE TABLE t2(d double(20,3),e char(20),f INT)//
alter table t2 ADD CONSTRAINT FK_ID FOREIGN KEY(d) REFERENCES t1(a)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t2 drop foreign key FK_ID;
END//
CALL pro1()//
select * from t1//
desc t1//
desc t2//

--echo #####给double列删除外键默认约束
drop table if exists t1//
CREATE TABLE t1(a double(20,3) default 2,b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a double(20,3);
END//
CALL pro1()//
insert into t1 values(1,'删除外键约束测试1',10)//
insert into t1 (b,c) values('删除外键约束测试2',20)//
insert into t1 values(3,'删除外键约束测试3',30)//
select * from t1//
desc t1//
desc t2//


--echo ##########分区 
--echo #####modify       
--echo #####KEY分区double类型的列
drop table if exists t1//
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no double(20,3),
       s_score INT,
       PRIMARY key(s_s_no,s_c_no)
       ) 
PARTITION BY key(s_c_no)
PARTITIONS 4//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'list分区',6,72)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'list分区',12,73)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'list分区',19,77)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'list分区',30,90)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'list分区',35,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1006,'list分区',45,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1007,'list分区',50,93)//

drop procedure if exists pro1//
create procedure pro1()
BEGIN
     ALTER TABLE t1 DROP PARTITION p3;
END//
--error 1235
CALL pro1()//
--echo #############ERROR 1235 (0A000): drop hash partition not supported
select * from t1//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1' and table_schema = 'zh_db'//
	
 
--echo #####KEY分区double类型的列	
drop table if exists t1//
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no double(20,3),
       s_score INT,
       PRIMARY key(s_s_no,s_c_no)
       ) 
PARTITION BY key(s_c_no)
PARTITIONS 4//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'list分区',6,72)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'list分区',12,73)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'list分区',19,77)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'list分区',30,90)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'list分区',35,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1006,'list分区',45,93)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1007,'list分区',50,93)//

drop procedure if exists pro1//
create procedure pro1()
BEGIN
     ALTER TABLE t1 DROP PARTITION p3;
END//
--error 1235
CALL pro1()//
--echo #############ERROR 1235 (0A000): drop hash partition not supported
select * from t1//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1' and table_schema = 'zh_db'//


--echo #####range分区INT类型的列 测试range分区  double类型不支持分区
drop table if exists t1//
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no double(20,3),
       s_score INT,
       PRIMARY key(s_s_no,s_score)
       ) 
PARTITION BY range(s_score)(
	partition p0 values less than (75),
	partition p1 values less than (80),
	partition p2 values less than (91),
	partition p3 values less than (MAXVALUE)
)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'range分区',6,72)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'range分区',12,73)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'range分区',19,77)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'range分区',25,90)//
INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'range分区',35,93)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	ALTER TABLE t1 DROP PARTITION p3;	
END//
CALL pro1()//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1' and table_schema = 'zh_db'//
	
	
--echo ##########drop             ####标签      float/double 1-2-2-3
--echo #####drop视图
drop table if exists t1//
--disable_warnings
drop view if exists v1//
--enable_warnings
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'测试删除视图',10)//
create view v1 as select * from t1//
select * from v1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop view v1;
END//

CALL pro1()//
--error 1146
select * from v1//

--echo #################drop索引
--echo #####删除普通索引
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT,key a(a))//
insert into t1 values(1,'测试删除普通索引',10)//
desc t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop index a on t1;
END//
CALL pro1()//
desc t1//

--echo #####删除唯一索引
drop table if exists t1//
CREATE TABLE t1(a double(20,3) unique,b char(20),c INT)//
insert into t1 values(1,'测试删除普通索引',10)//
desc t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop index a on t1;
END//
CALL pro1()//
desc t1//

--echo #####删除主键索引
drop table if exists t1//
CREATE TABLE t1(a double(20,3) primary key,b char(20),c INT)//
insert into t1 values(1,'测试删除普通索引',10)//
desc t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 drop primary key;
END//
CALL pro1()//
desc t1//

--echo #####删除组合索引
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
alter table t1 add index(a,b,c)//
insert into t1 values(1,'测试删除普通索引',10)//
desc t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop index a on t1;
END//
CALL pro1()//
desc t1//

--echo #####drop 表      
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
insert into t1 values(1,'测试删除普通索引',10)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	drop table t1;
END//
CALL pro1()//
--error 1146
select * from t1//

--echo ###########comment      标签float/double 1-2-2-4
--echo #####创建表给double列加注释
drop table if exists t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	CREATE TABLE t1(a double(20,3) comment '测试建表加注释',b char(20),c INT);
END//
CALL pro1()//
show full columns from t1//

--echo #####已经建好的表给double列加注释
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a double(20,3) comment '测试已建好的表加注释';
END//
CALL pro1()//
show full columns from t1//

--echo #####创建表给double列加注释，并修改注释
drop table if exists t1//
CREATE TABLE t1(a double(20,3) comment '测试建表加注释',b char(20),c INT)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	alter table t1 modify column a double(20,3) comment '修改后字段的注释';
END//
CALL pro1()//
show full columns from t1//

--echo ###########TRUNCATE TABLE      标签    float/double 1-2-2-5
--echo #####rollback   不能回滚
set autocommit = 0//
drop table if exists t1//
CREATE TABLE t1(a double(20,3),b char(25),c INT)//
insert into t1 values(1,'测试TRUNCATE TABLE的rollback',10)//
insert into t1 values(2,'测试TRUNCATE TABLE的rollback',20)//
insert into t1 values(3,'测试TRUNCATE TABLE的rollback',30)//
TRUNCATE TABLE t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	rollback;
END//
CALL pro1()//
select * from t1//
set autocommit = 1//



delimiter ;//
--echo # 清理测试用户
#--source output_print_disable.inc
disconnect con_zh;
connection default;


--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

