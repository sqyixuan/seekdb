--echo ########alter table with data      ##标签 float/double 1-2-1-1-3
--echo ########add column
--echo #########添加正常范围float列
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(52,2);
	set a = 30;
	alter table t1 add a float(52,2);
	insert into t1 VALUES(1,'插入的float值',a);
END//
call pro1()//
select * from t1//

--echo ######## 添加总位数M大于53的列
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(52,2);
	set a = 30;
	alter table t1 add a float(55,2);
	insert into t1 VALUES(1,'插入的float值',a);
END//
call pro1()//
select * from t1//

--echo ######## 添加传入精度为字符的列
