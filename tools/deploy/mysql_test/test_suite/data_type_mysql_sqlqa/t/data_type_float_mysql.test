--echo #########union 组合查询，多个select
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	score int(10),
	a   float(53,6)
)//
insert into t1 VALUES(1,"插入读取行数语句1",100,20)//
