    TABLE_NAME = 't1'//

--echo ######range分区float类型的列
drop table if exists t1//
--error 1659
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no float(20,3),
       s_score INT,
       PRIMARY key(s_s_no,s_c_no)
       ) 
PARTITION BY range(s_c_no)(
	partition p0 values less than (10),
	partition p1 values less than (20),
	partition p2 values less than (30),
	partition p3 values less than (MAXVALUE)
)//
--echo ######ERROR 1659 (HY000): Field 's_c_no' is of a not allowed type for this type of partitioning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE s_c_no INT;
	set s_c_no = 29;
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'range分区',6,72);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'range分区',12,73);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'range分区',19,77);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'range分区',s_c_no,90);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'range分区',35,93);
END//
--error 1146
CALL pro1()//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1'//
	
--echo ######range分区INT类型的列
drop table if exists t1//
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no INT,
       s_score INT,
       PRIMARY key(s_s_no,s_c_no)
       ) 
PARTITION BY range(s_c_no)(
	partition p0 values less than (10),
	partition p1 values less than (20),
	partition p2 values less than (30),
	partition p3 values less than (MAXVALUE)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE s_c_no INT;
	set s_c_no = 29;
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'range分区',6,72);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'range分区',12,73);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'range分区',19,77);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'range分区',s_c_no,90);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'range分区',35,93);
END//

CALL pro1()//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1'//

--echo ######list分区float类型的列
drop table if exists t1//
--error 1659
CREATE TABLE t1 (
       s_s_no INT,
	   s_r_r  char(10),
       s_c_no float(20,3),
       s_score INT,
       PRIMARY key(s_s_no,s_c_no)
       ) 
PARTITION BY list(s_c_no)(
	partition p0 values IN (6,45,50),
	partition p1 values IN (19),
	partition p2 values IN (29),
	partition p3 values IN (12,35)
)//
--echo ######ERROR 1659 (HY000): Field 's_c_no' is of a not allowed type for this type of partitioning
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE s_c_no float;
	set s_c_no = 29;
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1001,'list分区',6,72);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) VALUES(1002,'list分区',12,73);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1003,'list分区',19,77);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1004,'list分区',s_c_no,90);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1005,'list分区',35,93);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1006,'list分区',45,93);
	INSERT INTO t1(s_s_no,s_r_r,s_c_no,s_score) values(1007,'list分区',50,93);
END//

--error 1146
CALL pro1()//

SELECT
    PARTITION_NAME,
    TABLE_ROWS
FROM
    INFORMATION_SCHEMA. PARTITIONS
WHERE
    TABLE_NAME = 't1'//


