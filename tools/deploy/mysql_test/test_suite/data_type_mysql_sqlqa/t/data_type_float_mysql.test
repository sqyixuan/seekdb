BEGIN
	DECLARE a float(53,2);
	set a = 2021-12-11;
	insert into t1 VALUES(1,"插入的float值",a);
END//
call pro1()//
select * from t1//


--echo ########插入字符   插表的值为NULL   mysql创建成功，调用失败。ob创建成功，调用成功。bugid:37249309   bug状态:reopen
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	a   float(53,2)
)//
