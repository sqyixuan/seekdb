--echo ########## 处理测试环境 ##########
--disable_warnings
drop database if exists zh_db;
--enable_warnings
create database if not exists zh_db;
use zh_db;
--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

--echo # 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc

connect (con_zh,$OBMYSQL_MS0,funkzz,funkzz,zh_db,$OBMYSQL_PORT);
connection con_zh;
set autocommit=1;
#--source output_print_enable.inc
#--source mysql_test/include/check_tenant_sync.inc
delimiter //;

--echo #####################################类型验证  ##标签float/double 1-1
--echo ###########单精度传入  ##标签  float/double 1-1-1

--disable_warnings
drop table if exists t1;//
--enable_warnings
CREATE TABLE t1(
	id int(10) primary key,
	result varchar(10),
 	a float(7,2)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(7,2);
	set a = 20;
	insert into t1 VALUES(1,'插入的float值',a);
END;//
call pro1();//
select * from t1;//

--echo ###无精度传入 ##标签  float/double 1-1-1
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float();
	set a = 10;
END;//
--error 1305
call pro1();//

--echo #########边界值验证  ##标签 float/double 1-1-2
--echo ###传入超大值       ##标签 float/double 1-1-2-1
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(1564561615616516161561616156151216556456456151651561564546545641561561561561564564564566212);
	set a = 10;
END;//

--echo ###传入负数   ##标签 float/double 1-1-2-1
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(-3);
	set a = 10;
END;//

--echo ###传入精度0   ##标签 float/double 1-1-2-1
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(0);
	set a = 10;
END;//

--echo #####传入小数  ##标签 float/double 1-1-2-1
--echo ###传入小数的float类型，MySQL创建成功，ob创建失败。bugid:37177317   bug已修复
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(3.6);
	set a = 20;
END;//
call pro1();//

--echo ##########精度值验证  ##标签 float/double 1-1-2-2
--echo #####传入boolean类型  
--echo ###传入值为true
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(true);
	set a = 20;
END;//
--error 1305
call pro1();//


--echo ###传入值为false
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(false);
	set a = 20;
END;//
--error 1305
call pro1();//

--echo #####传入char类型
--echo ###传入文字
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(好好);
	set a = 20;
END;//
--error 1305
call pro1();//

--echo ###传入字母
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(ss);
	set a = 20;
END;//
--error 1305
call pro1();//

--echo ###传入特殊字符
drop procedure if exists pro1;//
--error 1064
create procedure pro1()
BEGIN
	DECLARE a float(,);
	set a = 20;
END;//
--error 1305
call pro1();//




--echo ############精度值范围     ##标签 float/double 1-1-2-3
--echo ###浮点数类型(FLOAT[(M,D)]M是总位数，D是小数点后的位数，取值范围为 M（1～255）和 D（0～30，且M>=D）
--echo ###定义长度M等于53 
drop table if exists t1;//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	a   float(53)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(53);
	set a = 20;
	insert into t1 VALUES(1,"插入的float值",a);
END;//
call pro1();//
select * from t1;//

--echo ###测试float的宽度范围
--echo #定义长度大于53的浮点数类型列对象，mysql成功，ob失败。（mysql中 M范围（1～255），ob中M范围（1～53）
--echo ###定义长度M大于53   bugid:37211144   bug已修复
drop procedure if exists pro1;//
--error 1063
create procedure pro1()
BEGIN
	DECLARE a float(54);
	set a = 20;
END;//
--error 1305
call pro1();//

--echo #####定义总位数M大于53,小于等于255时，定义小数D大于0，小于等于30时。ob建表失败，ob创建存储成功，调用失败。MySQL创建成功，调用成功。bugid:37218121   bug已修复
drop table if exists t1;//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	a   float(54,2)
);//
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(54,2);
	set a = 20;
	insert into t1 VALUES(1,"插入的float值",a);
END;//
call pro1();//
select * from t1;//

--echo ###测试D>M时的结果
drop procedure if exists pro1;//
create procedure pro1()
BEGIN
	DECLARE a float(0,1);
	set a = 10.22;
	insert into t1 VALUES(a);
END;//
--error 1427
call pro1();//

--echo ################################################场景验证  ##标签 float/double 1-2
--echo #######################dml语句                			   ##标签 float/double 1-2-1
--echo #########验证数据类型的insert语句						   ##标签 float/double 1-2-1-1
--echo ######插入表											   ##标签 float/double 1-2-1-1-1
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	a   float(53,6)
)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(53,6);
	set a = 20;
	insert into t1 VALUES(1,"插入的float值",a);
END//
call pro1()//
select * from t1//

--echo ######插入数据到视图											##标签 float/double 1-2-1-1-1
drop table if exists t1//
CREATE TABLE t1 (
	id  int(10) primary key,
	result char(10),
	a   float(53,6)
)//
drop view if exists v1//
create view v1 as select * from t1//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	DECLARE a float(53,6);
	set a = 30;
	insert into v1 VALUES(1,"插入的float值",a);
END//
call pro1()//
select * from v1//	

--echo ################插入数据验证      ##标签 float/double 1-2-1-1-2
--echo ########插入数字
