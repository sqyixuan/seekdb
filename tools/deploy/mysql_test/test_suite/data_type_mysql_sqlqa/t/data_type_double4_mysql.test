insert into t1 values(2,'测试OVER函数语句',1101,80.5)//
insert into t1 values(3,'测试OVER函数语句',1103,70)//
insert into t1 values(4,'测试OVER函数语句',1102,90)//
insert into t1 values(5,'测试OVER函数语句',1102,60)//
