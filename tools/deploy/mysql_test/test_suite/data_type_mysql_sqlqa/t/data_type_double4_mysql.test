insert into t1 values(4,'测试order by语句',1102,90)//
insert into t1 values(5,'测试order by语句',1102,60)//
insert into t1 values(6,'测试order by语句',1104,57)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
