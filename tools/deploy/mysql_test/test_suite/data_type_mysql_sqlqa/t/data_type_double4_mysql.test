CREATE TABLE t1(a double(20,2),b char(25),class INT,score double(20,1))//
insert into t1 values(1,'测试运算符语句',1101,97)//
insert into t1 values(2,'测试运算符语句',1101,80.5)//
insert into t1 values(3,'测试运算符语句',1102,70.5)//
insert into t1 values(4,'测试运算符语句',1102,85.5)//
insert into t1 values(5,'测试运算符语句',1102,90.5)//
insert into t1 values(6,'测试运算符语句',1103,90.5)//
