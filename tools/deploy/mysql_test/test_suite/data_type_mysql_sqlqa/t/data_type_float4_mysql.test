--echo ########## 处理测试环境 ##########
--disable_warnings
drop database if exists zh_db;
--enable_warnings
create database if not exists zh_db;
use zh_db;
--disable_warnings
--error 0,1396
drop user 'funkzz';
--enable_warnings

--echo # 创建用户并使用
create user 'funkzz' IDENTIFIED BY 'funkzz';
grant all on *.* to 'funkzz' WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc

connect (con_zh,$OBMYSQL_MS0,funkzz,funkzz,zh_db,$OBMYSQL_PORT);
connection con_zh;
set autocommit=1;
#--source output_print_enable.inc
#--source mysql_test/include/check_tenant_sync.inc
delimiter //;

--echo #############dql        标签    float/double 1-2-3
--echo #########集合           标签    float/double 1-2-3-1
--echo ######union
--disable_warnings
drop table if exists t1//
--enable_warnings
CREATE TABLE t1(a float(20,3),b char(25),c INT)//
insert into t1 values(1,'测试union语句',10)//
insert into t1 values(2,'测试union语句',20)//
insert into t1 values(3,'测试union语句',30)//
insert into t1 values(4,'测试union语句',40)//
insert into t1 values(5,'测试union语句',50)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	select * from t1 where a < 3
	union
	select * from t1 where a > 4;
END//
CALL pro1()//

--echo ######union all
drop table if exists t1//
CREATE TABLE t1(a float(20,3),b char(25),c INT)//
insert into t1 values(1,'测试union语句',10)//
insert into t1 values(2,'测试union语句',20)//
insert into t1 values(2,'测试union语句',20)//
insert into t1 values(3,'测试union语句',30)//
insert into t1 values(4,'测试union语句',40)//
insert into t1 values(5,'测试union语句',50)//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	select * from t1 where a < 3
	union all
	select * from t1 where a > 4;
END//
CALL pro1()//



--echo ##########join          标签        float/double 1-2-3-2
--echo ######隐式内连接
--disable_warnings
drop table if exists dept//
--enable_warnings
CREATE TABLE dept (
id INT ( 11 ) NOT NULL PRIMARY KEY,
name VARCHAR ( 50 )
)//
INSERT INTO dept ( id, name )
VALUES
	( 1, '销售部' ),
	( 2, '研发部' ),
	( 3, '运营部' ),
	( 4, '人力资源部' ),
	( 5, '产品部' )//
--disable_warnings
drop table if exists emp//
--enable_warnings
CREATE TABLE emp (
id INT ( 11 ) NOT NULL PRIMARY KEY,
name VARCHAR ( 50 ),
entryTime TIMESTAMP,
dept_id INT,
salary float(20,2)
)//
INSERT INTO emp ( id, name, entryTime, dept_id, salary )
VALUES
	( 1, '张飞', '2016-08-16 14:32:08', 1, '8000' ),
	( 2, '关羽', '2016-08-16 14:32:08', 3, '9000' ),
	( 3, '赵云', '2016-08-16 14:32:08', 4, '1000' ),
	( 4, '吕布', '2016-08-16 14:32:08', 2, '2000' ),
	( 5, '曹操', '2016-08-16 14:32:08', 3, '3000' )//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	select emp.salary from dept,emp WHERE emp.dept_id=dept.id;
END//
CALL pro1()//

--echo ######显示内连接
drop table if exists dept//
CREATE TABLE dept (
id INT ( 11 ) NOT NULL PRIMARY KEY,
name VARCHAR ( 50 )
)//
INSERT INTO dept ( id, name )
VALUES
	( 1, '销售部' ),
	( 2, '研发部' ),
	( 3, '运营部' ),
	( 4, '人力资源部' ),
	( 5, '产品部' )//
drop table if exists emp//
CREATE TABLE emp (
id INT ( 11 ) NOT NULL PRIMARY KEY,
name VARCHAR ( 50 ),
entryTime TIMESTAMP,
dept_id INT,
salary float(20,2)
)//
INSERT INTO emp ( id, name, entryTime, dept_id, salary )
VALUES
	( 1, '张飞', '2016-08-16 14:32:08', 1, '8000' ),
	( 2, '关羽', '2016-08-16 14:32:08', 3, '9000' ),
	( 3, '赵云', '2016-08-16 14:32:08', 4, '1000' ),
	( 4, '吕布', '2016-08-16 14:32:08', 2, '2000' ),
	( 5, '曹操', '2016-08-16 14:32:08', 3, '3000' )//
drop procedure if exists pro1//
create procedure pro1()
BEGIN
	select * from dept inner join emp on emp.dept_id=dept.id;
END//
CALL pro1()//

