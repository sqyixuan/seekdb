--echo ########递归            标签     float/double 1-3-7
drop procedure if exists factorial//
set @@session.max_sp_recursion_depth=99// 
create procedure factorial (in n float(20,3), out b float(20,3))  
begin  
    declare c_in float(20,3);
    declare c_out float(20,3);
    if n!=1 then 
        set c_in := n-1;  
        call factorial(c_in,c_out);  
        set b:=n*c_out;  
    else  
        set b:=1;  
    end if;  
end//    
call factorial(6,@r)//
select @r//

