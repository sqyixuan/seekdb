###################  replace into  #######################
#主键重复+唯一主键索引不重复
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}'),
(3,'ma',12,'{"score":[55,66]}'),
(4,'li',12,'{"score":[77,88]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
replace into t36 values (4,'ma',15,'{"score":100}');
select * from t36;

