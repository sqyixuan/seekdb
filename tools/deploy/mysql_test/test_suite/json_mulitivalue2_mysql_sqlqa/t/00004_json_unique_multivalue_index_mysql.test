show create table t40;

#添加虚拟列
alter table t40 add column (j2 json GENERATED ALWAYS AS (js->>'$.score') VIRTUAL);
show create table t40;

#删除虚拟列
#BUG
#mysql删除成功
#ob删除报错ERROR 1235 (0A000): Run this DDL operation on table with fulltext search index or multivalue index. not supported
#2024082700104279509
--error 1235
alter table t40 drop column j2;
show create table t40;

#被上面bug阻塞无法测试
#添加stored列和虚拟列之后，插入数据
--error 1235
alter table t40 add column (j json GENERATED ALWAYS AS (js->>'$.score') STORED);
alter table t40 add column (j3 json GENERATED ALWAYS AS (js->>'$.score') VIRTUAL);
insert into t40(id,name,age,js) values (6,'lili',12,'{"score":[1,2]}');
insert into t40(id,name,age,js) values (7,'ma',12,'{"tags":[1,2]}');

select * from t40;

#修改行各式
ALTER TABLE t40 ROW_FORMAT = DYNAMIC;
select * from t40;
show create table t40;

ALTER TABLE t40 ROW_FORMAT = REDUNDANT;
select * from t40;
show create table t40;

ALTER TABLE t40 ROW_FORMAT = COMPACT;
select * from t40;
show create table t40;

ALTER TABLE t40 ROW_FORMAT = DEFAULT;
select * from t40;
show create table t40;

#修改块大小
#ALTER TABLE t1 BLOCK_SIZE = 1024;

insert into t40(id,name,age,js) values (9,'mana',12,'{"tags":[1,2],"数学":"语文"}');
#转换字符集
SHOW CHARACTER SET;
SET NAMES gbk;
select * from t40;
SET NAMES utf8mb4;
select * from t40;

#truncate
truncate table t40;
insert into t40(id,name,age,js) values (6,'lili',12,'{"score":[1,2]}');
insert into t40(id,name,age,js) values (7,'ma',12,'{"tags":[1,2]}');
select * from t40;

#添加唯一索引
--error 1062
alter table t39 add unique index idx1(age);



