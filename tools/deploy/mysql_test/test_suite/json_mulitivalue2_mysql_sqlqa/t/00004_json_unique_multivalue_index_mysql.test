alter table t381 rename column js to js2;
--error 1064
alter table t381 change column js js2;

#添加重名索引
--error 1072
create index score2 on t381(phone,address);
--error 1072
alter table t381 add index score2(phone,address);

#添加同条件索引
create index score3 on t381((cast(js->'$.score' as unsigned array)));
alter table t381 add index score4((cast(js->'$.score' as unsigned array)));
create unique index scores5 on t381((cast(js->'$.score' as char(100) array)));


