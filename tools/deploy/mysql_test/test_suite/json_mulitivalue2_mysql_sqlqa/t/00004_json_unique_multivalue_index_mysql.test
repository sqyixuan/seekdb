###################  后建唯一多值索引 #######################
#无数据+后建唯一多值索引
--disable_warnings
drop table if exists t31;
create table t31(id int primary key,name varchar(50),age int ,js json);
#create index scores on t31 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
#drop index scores on t31;
create unique index scores on t31 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
show create table t31;
show index from t31;

