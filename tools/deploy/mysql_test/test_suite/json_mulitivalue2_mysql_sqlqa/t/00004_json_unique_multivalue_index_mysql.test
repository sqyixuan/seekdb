###################  inset into ... on duplicate key update #######################
#普通insert插入重复数据
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
--error 1062
insert into t36 values(6,'ss',12,'{"score":[22,456,678]}');
select * from t36;

#主键重复+多值索引不重复+update不重复
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
insert into t36 values (1,'ma',15,'{"score":[1,2,3]}') on duplicate key update js = '{"score":[1,2,3]}';
select * from t36;

#主键重复+多值索引不重复+update重复1
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'lili',12,'{"score":[55,66]}'),
(3,'mali',12,'{"score":[33,44]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
insert into t36 values (1,'ma',15,'{"score":[1,2,3]}') on duplicate key update js = '{"score":[11,22]}';
insert into t36 values (1,'ma',15,'{"score":[1,2,3]}') on duplicate key update js = values(js);
select * from t36;

