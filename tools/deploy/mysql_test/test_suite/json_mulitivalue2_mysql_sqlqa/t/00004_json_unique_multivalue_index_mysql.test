update t36 set js = '{"score":100}' where id = 2;


##################### delete +  member of /json_contains/json_v #######################
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}'),
(3,'ma',12,'{"score":[55,66]}'),
(4,'li',12,'{"score":[77,88]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));
--replace_regex /table_columns.*/123/g   /output.*/123/g /access.*/123/g
explain delete from t36 where 33 member of(js->>'$.score');
#预期报错
#没有报错
delete from t36 where 33 member of(js->>'$.score');
--replace_regex /table_columns.*/123/g   /output.*/123/g /access.*/123/g
explain delete from t36 where json_contains(js->'$.score',CAST('[11]' AS JSON));
#预期报错
#没有报错
delete from t36 where json_contains(js->'$.score',CAST('[11]' AS JSON));
--replace_regex /table_columns.*/123/g   /output.*/123/g /access.*/123/g
explain delete from t36 where JSON_OVERLAPS(js->>'$.score', '[55]');
#预期报错
#没有报错
delete from t36 where JSON_OVERLAPS(js->>'$.score', '[55]');

select * from t36;

##################### explain select  order by/group by/union/join/别名/弱读 + json函数  #####################
--disable_warnings
drop table if exists t36;
create table t36(id int primary key,name varchar(50),age int ,js json);
insert into t36 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}'),
(3,'ma',12,'{"score":[55,66]}'),
(4,'li',12,'{"score":[77,88]}');
create unique index scores on t36 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));

#member of
select * from t36 where 11 member of (js->'$.score');
explain select * from t36 where 11 member of (js->'$.score');

#json_contains
select * from t36 where json_contains(js->'$.score', CAST('[11]' AS JSON));
explain select * from t36 where json_contains(js->'$.score', CAST('[11]' AS JSON));

#json_overlaps
select * from t36 where JSON_OVERLAPS(js->>'$.score', '[55]');
explain select * from t36 where JSON_OVERLAPS(js->>'$.score', '[55]');

#弱读
sleep 1;
select /*+read_consistency(weak) */ * from t36;
select /*+read_consistency(weak) */* from t36 where 11 member of (js->'$.score');
select /*+read_consistency(weak) */* from t36 where json_contains(js->'$.score', CAST('[11]' AS JSON));
select /*+read_consistency(weak) */* from t36 where JSON_OVERLAPS(js->>'$.score', '[55]');

delete t36 from t36 join t31 on t36.id = t31.id;

