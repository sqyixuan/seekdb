#owner: lb446709
#owner group: shenzhen
#description:json多值索引+分区
#tags:json多值索引
#author: miaozhuanghua.mzh

connect (conadmin,$OBMYSQL_MS0,admin@sys,admin,,$OBMYSQL_PORT);
connection conadmin;
alter system set _enable_add_fulltext_index_to_existing_table = true;
connection default;

############ 一级分区  ############
--disable_warnings
drop table if exists  t100;
create table t100
    (id int not null AUTO_INCREMENT,
    age int,
    name varchar(50),
    date1 date,
    js json,
    primary key (id, date1)
     )partition by range columns(date1)
     (partition p202401 values less than('2024-01-01'),
     partition p202402 values less than('2024-02-01'),
     partition p202403 values less than('2024-03-01'),
     partition p202404 values less than('2024-04-01'),
     partition p202405 values less than('2024-05-01'),
     partition p202406 values less than('2024-06-01'),
     partition p202407 values less than('2024-07-01'),
     partition p202408 values less than('2024-08-01'),
     partition p202409 values less than('2024-09-01'),
     partition p202410 values less than('2024-10-01'),
     partition p202411 values less than('2024-11-01'),
     partition p202412 values less than('2024-12-01')
     );

drop procedure if exists json_insert;
delimiter //;
create procedure json_insert()
    begin
    DECLARE i INT DEFAULT 1;

    WHILE i<100 DO

       insert into t100 (age, name, date1, js) values
       (FLOOR(RAND() * 100)+1,
       CONCAT('name', FLOOR(RAND() * 100)+1),
       CONCAT('2024-',FLOOR(RAND() * 11)+1, '-',FLOOR(RAND() * 26)+1),
       CONCAT('[',FLOOR(RAND() * 10000)+1 ,',',FLOOR(RAND() * 10000)+1 , ']')
       );
       SET i = i + 1;
    END WHILE;
    end //

delimiter ;//
call json_insert;
create index scores on t100 ((CAST(js->'$[*]' as UNSIGNED ARRAY)));
#alter table t100 add index

#删除分区
alter table t100 drop partition p202401;
alter table t100 drop partition p202403;
alter table t100 drop partition p202405;
alter table t100 drop partition p202407;

#清空分区
alter table t100 truncate partition p202402;
alter table t100 truncate partition p202404;
alter table t100 truncate partition p202406;
alter table t100 truncate partition p202408;

#添加分区
--echo 2024090600104404102
#BUG 2024090600104404102
#mysql执行成功
#OB报错  ERROR 1235 (0A000): alter partition operation on table with fulltext or multivalue index not supported
###--error 1235
alter table t100 add partition
    (partition p202501 values less than('2025-01-01'),
     partition p202502 values less than('2025-02-01'),
     partition p202503 values less than('2025-03-01'));


show create table t100;

call json_insert;

#重分区
#BUG
#mysql执行成功
#OB报错 ERROR 1235 (0A000): Run this DDL operation on table with fulltext search index or multivalue index. not supported
###--error 1235
alter table t100 partition by key(id) partitions 10;

#select * from t100 where
truncate table t100;
--disable_warnings
drop table if exists t100;



############ 二级分区  ############
create table t100
    (id int not null AUTO_INCREMENT,
    age int,
    name varchar(50),
    date1 date,
    js json,
    primary key (id, date1)
     )partition by range columns(date1)
     SUBPARTITION BY HASH(id) SUBPARTITIONS 5
     (partition p202401 values less than('2024-01-01'),
     partition p202402 values less than('2024-02-01'),
     partition p202403 values less than('2024-03-01'),
     partition p202404 values less than('2024-04-01'),
     partition p202405 values less than('2024-05-01'),
     partition p202406 values less than('2024-06-01'),
     partition p202407 values less than('2024-07-01'),
     partition p202408 values less than('2024-08-01'),
     partition p202409 values less than('2024-09-01'),
     partition p202410 values less than('2024-10-01'),
     partition p202411 values less than('2024-11-01'),
     partition p202412 values less than('2024-12-01')
     );

call json_insert;
create index scores on t100 ((CAST(js->'$[*]' as UNSIGNED ARRAY)));

#删除分区
alter table t100 drop partition p202401;
alter table t100 drop partition p202403;
alter table t100 drop partition p202405;
alter table t100 drop partition p202407;

#清空分区
alter table t100 truncate partition p202402;
alter table t100 truncate partition p202404;
alter table t100 truncate partition p202406;
alter table t100 truncate partition p202408;

#添加分区
--echo 2024090600104404102
#BUG 2024090600104404102
#mysql执行成功
#OB报错  ERROR 1235 (0A000): alter partition operation on table with fulltext or multivalue index not supported
###--error 1235
alter table t100 add partition
    (partition p202501 values less than('2025-01-01'),
     partition p202502 values less than('2025-02-01'),
     partition p202503 values less than('2025-03-01'));

show create table t100;

call json_insert;

#重分区
#BUG
#mysql执行成功
#OB报错 ERROR 1235 (0A000): Run this DDL operation on table with fulltext search index or multivalue index. not supported
###--error 1235
alter table t100 partition by key(id) partitions 10;

#select * from t100 where
truncate table t100;
--disable_warnings
drop table if exists t100;
