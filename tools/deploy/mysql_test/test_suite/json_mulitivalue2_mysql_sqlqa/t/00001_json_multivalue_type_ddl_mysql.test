--error 1062
insert into t1 (id,name,js1,js2) values (5,'祭城超市','[2634,5142312]','["橙汁","可乐"]') on duplicate key update js1 = '[5412342,54213412]';
--error 1062
insert into t1 (id,name,js1,js2) values (5,'祭城超市','[2634,5142312]','["橙汁","可乐"]') on duplicate key update js1 = '[5412342,54213412]';


#### 主键 + 后建唯一复合多值索引
--disable_warnings
drop table if exists t1;
create table t1 (id int primary key, name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[2634,2743353]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["泡面","卤蛋"]');
create unique index idx1 on t1 (name, (cast(js1->'$' as unsigned array)));
--error 1062
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]');
#BUG mysql 成功执行 ob 报错4016
#--error 4016 #ERROR 4016 (HY000): Internal error
replace into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]');
#BUG mysql 成功执行 ob 报错4016
#--error 4016 #ERROR 4016 (HY000): Internal error
replace into t1 (id,name,js1,js2) values (1,'祭城超市','[4125312,4123612]','["橙汁","可乐"]');
