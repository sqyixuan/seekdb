### 字符集
--disable_warnings
drop table if exists t1;
create table t1 (id int, name char(10), date1 date, js json, index idx1 (date1), unique index idx2(name));
alter table t1 CONVERT TO CHARACTER SET gbk;
insert into t1 (id, name , date1, js) values (1,"祭城超市", "2024-01-01", '["火锅丸子","酸奶"]'),(2,"金庄超市", "2025-01-01", '["火锅丸子","饼干"]'),(3,"庙张超市", "2026-01-01", '["辣条","水果"]');
create index idx3 on t1((cast(js->'$' as char(10) array)));
insert into t1 (id, name , date1, js) values (4,"文化产业大厦",'2024-03-01', '["可乐","雪碧"]'), (5,"绿地新都会",'2024-03-01', '["可乐","雪碧"]');
replace into t1 (id, name , date1, js) values (5,"绿地新都会",'2024-03-01', '["果冻","馍片"]') ;
update t1 set js = '["橙汁","茶"]' where JSON_CONTAINS(js->'$',CAST('["酸奶"]' AS JSON));
delete from t1 where JSON_CONTAINS(js->'$',CAST('["果冻"]' AS JSON));
sleep 1;
select /*+read_consistency(weak) */ * from t1;


#### id 的长度长于48... 自夏

--disable_warnings
drop table if exists t1;
create table t1 (c1 char(50), c2 json, primary key(c1), index zips((cast(c2->'$.key' as unsigned array))));
insert into t1 (c1,c2)values ('aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa', '{"key":[1,2,3,4,5,6]}');
