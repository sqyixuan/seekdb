#### 无其他索引 + 后建唯一复合多值索引
--disable_warnings
drop table if exists t1;
create table t1 (id int , name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[2634,2743353]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["泡面","卤蛋"]');
alter table t1 add unique idx1 (name,(cast(js2->'$' as char(10) array)));
#BUG mysql 报错 ERROR 1062 (23000): Duplicate entry '祭城超市-["可乐", "橙汁"]' for key 't1.idx1'  ob插入成功
--error 1062
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]');
#BUG mysql 将id=1记录的js2替换  ob插入新记录
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]') on duplicate key update js2 = '["跑车"]';
#BUG mysql 这块的处理逻辑也是蛮奇怪的  mysql插入新数据  ob插入新数据
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,437237]','["薯片","超市"]') on duplicate key update js2 = '["绵羊"]';
#BUG mysql 这块的处理逻辑也是蛮奇怪的 mysql 将其中一条记录的js2替换   ob
--error 1062 #BUG
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,437237]','["黑马","薯片"]') on duplicate key update js2 = '["绵羊"]';


##### 主键 + 后建多值索引 + 后建复合多值索引
--disable_warnings
drop table if exists t1;
create table t1 (id int primary key, name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[2634,2743353]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["泡面","卤蛋"]');
#多值索引
create index idx1 on t1 ((cast(js1->'$' as unsigned array)));
#复合多值索引
alter table t1 add index idx2(name,(cast(js2->'$[*]' as char(10) array)));

insert into t1 (id,name,js1,js2) values (4,'郑州东站','[4263,48263712]','["锅盔","炸鸡"]');
insert into t1 (id,name,js1,js2) values (5,'洛阳东站','[512732,5123]','["蚂蚱","笔记"]') on duplicate key update name = '鹤壁东站', js1 = '[112732,1123]',js2 = '["锅盔","炸鸡"]';
insert into t1 (id,name,js1,js2) values (1,'开封东站','[512731232,51223]','["蚂蚱","笔记"]') on duplicate key update name = values(name),js1 = values(js1),js2 = values(js2);

replace into t1 (id,name,js1,js2) values (6,'西安东站','[621543512,621534512]','["蚂蚱","笔记"]');
replace into t1 (id,name,js1,js2) values (2,'东蚂蚱站','[7125312,7263521]','["蚂蚱","笔记"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;

update t1 set name = '洛阳东站', js1 = '[512732,5123]', js2 = '["锅盔","炸鸡"]' where name = ''  and JSON_CONTAINS(js1->'$[*]',CAST('["42343112"]' AS JSON));
update t1 set name = '西安东站', js1 = '[621543512,621534512]', js2 = '["蚂蚱","笔记"]' where json_overlaps(js2->'$', '["加湿器"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;

delete from t1 where name = '洛阳东站'  and JSON_CONTAINS(js2->'$[*]',CAST('["锅盔"]' AS JSON));
delete from t1 where json_overlaps(js1->'$', '[621543512]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;


#### 主键 + 后建唯一多值索引
--disable_warnings
drop table if exists t1;
create table t1 (id int primary key, name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[2634,2743353]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["泡面","卤蛋"]');
alter table t1 add unique index idx1 ((cast(js1->'$' as unsigned array)));

--error 1062 #ERROR 1062 (23000): Duplicate entry '1' for key 'PRIMARY'
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]');
--error 1062 #ERROR 1062 (23000): Duplicate entry '173467623' for key 'idx1'
insert into t1 (id,name,js1,js2) values (4,'祭城超市','[1232332,173467623]','["橙汁","可乐"]');

insert into t1 (id,name,js1,js2) values (4,'祭城超市','[1232332,173467623]','["橙汁","可乐"]') on duplicate key update js1 = '[4231,45656756]';
