#owner: lb446709
#owner group: shenzhen
#description:json多值索引-测试后建各种类型的多值索引（UNSIGNED、DECIMAL、FLOAT、DATE、CHAR、BINARY）其中UNSIGNED和CHAR最为常用
#tags:json多值索引
#author: miaozhuanghua.mzh

connect (conadmin,$OBMYSQL_MS0,admin@sys,admin,,$OBMYSQL_PORT);
connection conadmin;
alter system set _enable_add_fulltext_index_to_existing_table = true;
connection default;

#### 后建多个索引类型(预期数据)
#1. UNSIGNED
#1.1 无数据后建
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,name varchar(10),js json);
create index scores on t1((CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add index scores2((CAST(js->'$.score' AS UNSIGNED ARRAY)));

create unique index score3 on t1((CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add unique index score4 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));

create  index score5 on t1(name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add  index score6 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));

create unique index score7 on t1(name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add unique index score8 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));

insert into t1(id,name,js) values (1,'li','{"score":[123,345]}'),(2,'mi','{"score":[88,99]}'),(3,'lc','{"score":[73467,0]}'),(4,'z','{"score":[273463,888]}');
show create table t1;

#1.2 有数据后建
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,name varchar(10),js json);
insert into t1(id,name,js) values (1,'li','{"score":[123,345]}'),(2,'mi','{"score":[88,99]}'),(3,'lc','{"score":[73467,0]}'),(4,'z','{"score":[273463,888]}');
create index scores on t1((CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add index scores2((CAST(js->'$.score' AS UNSIGNED ARRAY)));

create unique index score3 on t1((CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add unique index score4 ((CAST(js->'$.score' AS UNSIGNED ARRAY)));

create  index score5 on t1(name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add  index score6 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));

create unique index score7 on t1(name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
alter table t1 add unique index score8 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));

select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123]' AS JSON));
select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123,678]' AS JSON));
--replace_regex /range_key.*range/123/g
explain select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123,678]' AS JSON));



#2.DECIMAL
#2.1 无数据后建
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,js json);
alter table t1 add index scores2((CAST(js->'$.score' AS DECIMAL ARRAY)));
create index scores on t1((CAST(js->'$.score' AS DECIMAL ARRAY)));
insert into t1(id,js) values (1,'{"score":[123.45,345]}'),(2,'{"score":[88,99]}'),(3,'{"score":[73467,0]}'),(4,'{"score":[273463,888]}');
show create table t1;


#2.2 有数据后建
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,js json);
insert into t1(id,js) values (1,'{"score":[123.45,345]}'),(2,'{"score":[88,99]}'),(3,'{"score":[73467,0]}'),(4,'{"score":[273463,888]}');
create index scores on t1((CAST(js->'$.score' AS DECIMAL ARRAY)));
alter table t1 add index scores2((CAST(js->'$.score' AS DECIMAL ARRAY)));

select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[345]' AS JSON));
select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123.45]' AS JSON));
select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123,345]' AS JSON));
--replace_regex /range_key.*range/123/g
explain select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[345,678]' AS JSON));



#3.FLOAT/DOUBLE
#3.1
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,js json);
#不兼容mysql
#mysql 报错 ERROR 1235 (42000): This version of MySQL doesn't yet support 'CAST-ing data to array of DOUBLE'
#ob成功
create index scores on t1((CAST(js->'$.score' AS DOUBLE ARRAY)));
alter table t1 add index scores2 ((CAST(js->'$.score' AS DOUBLE ARRAY)));
insert into t1(js) values ('{"score":[123,345.12]}');
show create table t1;

#3.2
--disable_warnings
drop table if exists t1;
create table t1(id int AUTO_INCREMENT primary key ,js json);
insert into t1(js) values ('{"score":[123,345.12]}');
#不兼容mysql
#mysql报错 ERROR 1235 (42000): This version of MySQL doesn't yet support 'CAST-ing data to array of DOUBLE'
#ob成功
alter table t1 add index scores2 ((CAST(js->'$.score' AS DOUBLE ARRAY)));
create index scores on t1((CAST(js->'$.score' AS DOUBLE ARRAY)));

select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123]' AS JSON));
select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[345.12]' AS JSON));
select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123,678]' AS JSON));
--replace_regex /range_key.*range/123/g
explain select id,js from t1 where JSON_CONTAINS(js->'$.score',CAST('[123,678]' AS JSON));



#4.DATE/DATETIME/TIME/YEAR
#4.1
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
alter table t2 add index scores2((CAST(js->'$.score' AS DATE ARRAY)));
create index scores on t2((CAST(js->'$.score' AS DATE ARRAY)));
insert into t2(js) values ('{"score":["2024-01-01"]}'),('{"score":["2024-02-01"]}'), ('{"score":["2024-03-01"]}'), ('{"score":["2024-04-01"]}');

show create table t2;
#4.2
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
insert into t2(js) values ('{"score":["2024-01-01"]}'),('{"score":["2024-02-01"]}'), ('{"score":["2024-03-01"]}'), ('{"score":["2024-04-01"]}');

create index scores on t2((CAST(js->'$.score' AS DATE ARRAY)));
alter table t2 add index scores2((CAST(js->'$.score' AS DATE ARRAY)));

select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["2024-01-01"]' AS JSON));


#5.CHAR
#5.1
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
create index scores on t2((CAST(js->'$.score' AS char(50) ARRAY)));
alter table t2 add index scores2((CAST(js->'$.score' AS char(50) ARRAY)));
show create table t2;

#5.2
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
insert into t2(js) values ('{"score":["miao","zhuang"]}'),('{"score":["liu","xue"]}'),('{"score":["wen","zshy"]}');
alter table t2 add index scores2((CAST(js->'$.score' AS char(50) ARRAY)));
create index scores on t2((CAST(js->'$.score' AS char(50) ARRAY)));

select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao"]' AS JSON));
select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["zhuang","liu"]' AS JSON));
select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao","zhuang"]' AS JSON));
--replace_regex /range_key.*range/123/g
explain select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao","zhuang"]' AS JSON));


#6.BINARY
#6.1
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
alter table t2 add index scores2((CAST(js->'$.score' AS BINARY(500) ARRAY)));
create index scores on t2((CAST(js->'$.score' AS BINARY(500) ARRAY)));
show create table t2;

#6.2
--disable_warnings
drop table if exists t2;
create table t2(id int AUTO_INCREMENT primary key ,js json);
insert into t2(js) values ('{"score":["miao","zhuang"]}'),('{"score":["zu","liu"]}'),('{"score":[12312,true]}');
create index scores on t2((CAST(js->'$.score' AS BINARY(500) ARRAY)));
alter table t2 add index scores2((CAST(js->'$.score' AS BINARY(500) ARRAY)));


select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao"]' AS JSON));
select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["zhuang","liu"]' AS JSON));
select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao","zhuang"]' AS JSON));
--replace_regex /range_key.*range/123/g
explain select id,js from t2 where JSON_CONTAINS(js->'$.score',CAST('["miao","zhuang"]' AS JSON));




####创建多值索引前的各种类型数据
#1.UNSIGNED
#1.1
--disable_warnings
drop table if exists t4;
create table t4(id int AUTO_INCREMENT primary key ,js json);
insert into t4(js) values ('{"socre":[1,2,3,4,5]}');
create index scores on t4((CAST(js->'$.score' AS UNSIGNED ARRAY)));
#删除之后，验证是否真正删除
alter table t4 drop index scores;
insert into t4(js) values ('{"score":{"miao":123}}');

#1.2
--disable_warnings
drop table if exists t5;
create table t5(id int AUTO_INCREMENT primary key ,js json);
insert into t5(js) values ('{"socre":[]}');
create index scores on t5((CAST(js->'$.score' AS UNSIGNED ARRAY)));
 show create table t5;

#1.3
--disable_warnings
drop table if exists t6;
create table t6(id int AUTO_INCREMENT primary key ,js json);
insert into t6(js) values ('{"score":{}}');
--echo BUG 提示不明显
#BUG
#mysql 报错 ERROR 1235 (42000): This version of MySQL doesn't yet support 'CAST-ing JSON OBJECT type to array'
#ob 报错 ERROR 5703 (HY000): Add index failed
--error 5703,1235
create index scores on t6((CAST(js->'$.score' AS UNSIGNED ARRAY)));

#1.4
--disable_warnings
drop table if exists t7;
create table t7(id int AUTO_INCREMENT primary key ,js json);
insert into t7(js) values ('{"score":{"miao":123}}');
--echo BUG 提示不明显
#BUG 提示不明显，
#mysql 报错 ERROR 1235 (42000): This version of MySQL doesn't yet support 'CAST-ing JSON OBJECT type to array'
#ob 报错 ERROR 5703 (HY000): Add index failed
--error 5703,1235
create index scores on t7((CAST(js->'$.score' AS UNSIGNED ARRAY)));

#1.5

--disable_warnings
drop table if exists t8;
create table t8(id int AUTO_INCREMENT primary key ,js json);
insert into t8(js) values ('{"score":true}');
--echo 不兼容mysql
#mysql 报错 ERROR 1235 (42000): This version of MySQL doesn't yet support 'CAST-ing JSON BOOLEAN type to array'
#ob 执行成功
create index scores on t8((CAST(js->'$.score' AS UNSIGNED ARRAY)));

--disable_warnings
drop table if exists t9;
create table t9(id int AUTO_INCREMENT primary key ,js json);
insert into t9(js) values ('123');
create index scores on t9((CAST(js->'$.score' AS UNSIGNED ARRAY)));

--disable_warnings
drop table if exists t9;
create table t9(id int AUTO_INCREMENT primary key ,js json);
insert into t9(js) values ('"miao"');
create index scores on t9((CAST(js->'$.score' AS UNSIGNED ARRAY)));


#2 char
--disable_warnings
drop table if exists t10;
create table t10 (id int AUTO_INCREMENT primary key , js json);

insert into t10(js) values ('"miao"');
create index scores on t10((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;

insert into t10(js) values ('1234');
alter table t10 add index scores((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;

insert into t10(js) values ('{}');
create index scores on t10((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
alter table t10 drop index scores;

insert into t10(js) values ( '{"score":123}');
alter table t10 add index scores((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;

insert into t10(js) values ( '{"score":"maio"}');
--echo BUG 提示不明显
#BUG
#mysql 报错 ERROR 3903 (22018): Invalid JSON value for CAST for functional index 'scores'.
#ob 报错 ERROR 5703 (HY000): Add index failed
--error 5703,3903
create index scores on t10((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
#alter table t10 drop index scores;

insert into t10(js) values ( '{"key":123}');
alter table t10 add index scores((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;

insert into t10(js) values ( '[]');
create index scores on t10((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
alter table t10 drop index scores;

insert into t10(js) values ( '[123,234]');
alter table t10 add index scores((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;

insert into t10(js) values ('true');
create index scores on t10((CAST(js->'$.score' AS UNSIGNED ARRAY)));
truncate table t10;
drop index scores on t10;


#### 各种json path作为索引
#'$.*'
--disable_warnings
drop table if exists t11;
create table t11(id int AUTO_INCREMENT primary key , js json);
create index scores1 on t11((CAST(js->'$.*' AS UNSIGNED ARRAY)));
--error 3140 #ERROR 3140 (22032): Invalid JSON text.
insert into t11(js) values ('{1,344}');
insert into t11(js) values ('{}');
insert into t11(js) values ('[]');
--error 3140 #ERROR 3140 (22032): Invalid JSON text.
insert into t11(js) values ('{"miao"}');
insert into t11(js) values ('[123]');
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t11(js) values ('{"miao":"miao"}');
insert into t11(js) values ('{"miao":1111,"zhuang":234,"hua":238}');
#index t11(scores1)
--replace_regex /range_key.*range/123/g
explain select * from t11 where 1111 member of(js->'$.*');
--error 3908 #ERROR 3908 (42000): Cannot store an array or an object in a scalar key part of the index.
insert into t11(js) values ('{"score":[]}');
--error 3908 #ERROR 3908 (42000): Cannot store an array or an object in a scalar key part of the index.
insert into t11(js) values ('{"score":[1111,2222]}');

#'$.score'
--disable_warnings
drop table if exists t11;
create table t11(id int AUTO_INCREMENT primary key , js json);
create index scores2 on t11((CAST(js->'$.score' AS UNSIGNED ARRAY)));
insert into t11(js) values (null);
insert into t11(js) values ('{}');
insert into t11(js) values ('[]');
insert into t11(js) values ('[1234,344]');
insert into t11(js) values ('{"tags":123}');
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t11(js) values ('{"score":"miao"}');
--error 1235 #ERROR 1235 (42000): This version of MySQL doesn't yet support CAST-ing JSON OBJECT type to array
insert into t11(js) values ('{"score":{}}');
insert into t11(js) values ('{"score":[]}');
--error 1235 #ERROR 1235 (42000): This version of MySQL doesn't yet support CAST-ing JSON OBJECT type to array
insert into t11(js) values ('{"score":{"zheng":123}}');
insert into t11(js) values ('{"score":[1111,2222]}');
#t11(scores2)
--replace_regex /range_key.*range/123/g
explain select * from t11 where 1111 member of(js->'$.score');


#'$[*]'
--disable_warnings
drop table if exists t11;
create table t11(id int AUTO_INCREMENT primary key , js json);
create index scores2 on t11((CAST(js->'$[*]' AS UNSIGNED ARRAY)));
insert into t11(js) values (null);
insert into t11(js) values ('{}');
insert into t11(js) values ('[]');
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t11(js) values ('["miao", true,12312]');
insert into t11(js) values ('[ true,12312]');
insert into t11(js) values ('[ 23432,12312]');
insert into t11(js) values ('123123');
insert into t11(js) values ('"miao"');
insert into t11(js) values ('123123');
insert into t11(js) values ('true');
#t11(scores2)
--replace_regex /range_key.*range/123/g
explain select * from t11 where 23432 member of(js->'$[*]');

#'$[*][*]'
--disable_warnings
drop table if exists t11;
create table t11(id int AUTO_INCREMENT primary key , js json);
create index scores3 on t11((CAST(js->'$[*][*]' AS UNSIGNED ARRAY)));
insert into t11(js) values ('null');
insert into t11(js) values ('{}');
insert into t11(js) values ('[]');
insert into t11(js) values ('true');
insert into t11(js) values ('12321');
insert into t11(js) values ('"miao"');
insert into t11(js) values ('{"miao":12312}');
insert into t11(js) values ('[12312,"miao", true]');
insert into t11(js) values ('[12312,[21312,32121], true]');
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t11(js) values ('[12312,["miao","zheng"], true]');
#t11
--replace_regex /range_key.*range/123/g
explain select * from t11 where 23432 member of(js->'$[*]');
#t11(scores3)
--replace_regex /range_key.*range/123/g
explain select * from t11 where 23432 member of(js->'$[*][*]');

#''$[1]'
--disable_warnings
drop table if exists t11;
create table t11(id int AUTO_INCREMENT primary key , js json);
create index scores2 on t11((CAST(js->'$[1]' AS UNSIGNED ARRAY)));
insert into t11(js) values ('null');
insert into t11(js) values ('{}');
insert into t11(js) values ('[]');
insert into t11(js) values ('[[12312],[123123,12312], [1212]]');
insert into t11(js) values ('[122212]');
#t11
explain select * from t11 where 23432 member of(js->'$[0]');
#t11(scores2)
--replace_regex /range_key.*range/123/g
explain select * from t11 where 23432 member of(js->'$[1]');
#t11
explain select * from t11 where 23432 member of(js->'$[*]');



### 数据重复 创建唯一索引
--disable_warnings
drop table if exists t1;
create table t1 (id int primary key, name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[1232332,173467623]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["橙汁","可乐"]');
--error 1062 #ERROR 1062 (23000): Duplicate entry '1232332' for key 'idx1'
create unique index idx1 on t1 ((cast(js1->'$[*]' as unsigned array)));
--error 1062 #ERROR 1062 (23000): Duplicate entry '可乐' for key 'idx2'
alter table t1 add unique index idx2 ((cast(js2->'$[*]' as char(10) array)));


#### 多值索引与主键等其他索引一起
#### 后建多值索引 + 主键索引
--disable_warnings
drop table if exists t1;
create table t1 (id int primary key, name char(10), date1 date, js1 json,js2 json,js3 json,js4 json);
insert into t1 (id,name ,date1,js1,js2,js3,js4) values (1,'祭城超市',"2021-04-04", '[12312,12342343]','["橙汁","可乐"]','{"score":["2024-04-04"]}','[[-10,10]]');
insert into t1 (id,name ,date1,js1,js2,js3,js4) values (2,'金庄超市',"2022-04-04", '[2127362,271263]','["薯片","饼干"]','{"score":["2025-05-05"]}','[[-20,20]]');
insert into t1 (id,name ,date1,js1,js2,js3,js4) values (3,'庙张超市',"2023-04-04", '[312,3723622323]','["茶叶","咖啡"]','{"score":["2026-06-06"]}','[[-30,30]]');
#多值索引
create index idx1 on t1 ((cast(js1->'$' as unsigned array)));
#复合多值索引
alter table t1 add index idx2(date1,(cast(js2->'$[*]' as char(10) array)));
#唯一多值索引
create unique index idx3 on t1 ((cast(js3->'$.score' as date array)));
#唯一复合多值索引
alter table t1 add unique index idx4(name , (cast(js4->'$[*][*]' as signed array)));

insert into t1 (id,name ,date1,js1,js2,js3,js4) values (4,'郑州东站',"2024-04-04", '[42343112,43]','["汽车","客车"]','{"score":["2027-05-05"]}','[[-50,50]]');
insert into t1 (id,name ,date1,js1,js2,js3,js4) values (5,'火车站',"2025-04-04", '[5123412,54]','["挂车","大挂"]','{"score":["2028-06-06"]}','[[-60,60]]') on duplicate key update js1 = '[5123412,54]',js2 = '["挂车","大挂"]',js3 = '{"score":["2026-06-06"]}',js4 = '[[-60,60]]';
#BUG mysql正常执行 ob报错 ERROR 4016 (HY000): Internal error
insert into t1 (id,name ,date1,js1,js2,js3,js4) values (1,'折扣牛',"2026-04-04", '[6123412,64]','["挂车","大挂"]','{"score":["2029-06-06"]}','[[-60,60]]') on duplicate key update js1 = '[5374673,54]',js2 = '["加湿器","苹果"]',js3 = values(js3),js4 = js4;
#BUG mysql正常执行 ob报错 ERROR 4016 (HY000): Internal error
replace into t1 (id,name ,date1,js1,js2,js3,js4) values (6,'折扣牛',"2027-04-04", '[6123412,64]','["挂车","大挂"]','{"score":["2026-06-06"]}','[[-60,60]]');
#BUG mysql正常执行 ob报错 ERROR 4200 (HY000): hash map/set entry exist
#--error 4200
replace into t1 (id,name ,date1,js1,js2,js3,js4) values (2,'折扣牛',"2028-04-04", '[6123412,64]','["挂车","大挂"]','{"score":["2026-06-06"]}','[[-60,60]]');
sleep 2;
select /*+read_consistency(weak) */ * from t1;

update t1 set js1 = values(js1),js2 = js1,js3 = values(js2),js4 = '[[-100],[100]]' where id = 3;
update t1 set js1 = values(js1),js2 = js1,js3 = values(js2),js4 = '[[-100],[100]]' where JSON_CONTAINS(js1->'$[*]',CAST('["6123412"]' AS JSON));
update t1 set js1 = '[26153512,12763612]',js2 = js2,js3 = values(js3),js4 = '[[-100],[100]]' where json_overlaps(js2->'$', '["挂车"]');
update t1 set js1 = '[26153512,12763612]',js2 = js2,js3 = values(js3),js4 = '[[-100],[100]]' where "2026-06-06" member of (js3->'$.score');
sleep 2;
select /*+read_consistency(weak) */ * from t1;

delete  from t1 where JSON_CONTAINS(js1->'$[*]',CAST('["42343112"]' AS JSON));
delete  from t1 where json_overlaps(js2->'$', '["加湿器"]');
sleep 2;
select /*+read_consistency(weak) */ * from t1;


#### 无其他索引 + 后建多值索引 + 后建复合多值索引
--disable_warnings
drop table if exists t1;
create table t1 (id int , name char(10), js1 json,js2 json);
insert into t1 (id,name,js1,js2) values (1,'祭城超市','[1232332,173467623]','["橙汁","可乐"]'),(2,'金庄超市','[2634,2743353]','["薯片","饼干"]'),(3,'庙张超市','[32736,31823672]','["泡面","卤蛋"]');
#多值索引
create index idx1 on t1 ((cast(js1->'$' as unsigned array)));
#复合多值索引
alter table t1 add index idx2(name,(cast(js2->'$[*]' as char(10) array)));

insert into t1 (id,name,js1,js2) values (4,'郑州东站','[4263,48263712]','["锅盔","炸鸡"]');
insert into t1 (id,name,js1,js2) values (5,'洛阳东站','[512732,5123]','["蚂蚱","笔记"]') on duplicate key update name = '鹤壁东站', js1 = '[112732,1123]',js2 = '["锅盔","炸鸡"]';
insert into t1 (id,name,js1,js2) values (1,'开封东站','[512731232,51223]','["蚂蚱","笔记"]') on duplicate key update name = values(name),js1 = values(js1),js2 = values(js2);
sleep 1;
select /*+read_consistency(weak) */ * from t1;

replace into t1 (id,name,js1,js2) values (6,'西安东站','[621543512,621534512]','["蚂蚱","笔记"]');
replace into t1 (id,name,js1,js2) values (2,'东蚂蚱站','[7125312,7263521]','["蚂蚱","笔记"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;

#BUG 此处有争议 和 mysql现象不一致
select * from t1  where json_overlaps(js1->'$', '["173467623"]');
select * from t1  where json_overlaps(js1->'$', cast('["173467623"]' as json));
select * from t1  where json_overlaps(js1->'$[*]', cast('["173467623"]' as json));

select * from t1  where json_overlaps(js1->'$', '[173467623]');
select * from t1  where json_overlaps(js1->'$', cast('[173467623]' as json));
select * from t1  where json_overlaps(js1->'$[*]', cast('[173467623]' as json));

select * from t1 where json_contains(js1->'$', '["173467623"]');
select * from t1  where json_contains(js1->'$', cast('["173467623"]' as json));
select * from t1  where json_contains(js1->'$[*]', cast('["173467623"]' as json));

select * from t1 where json_contains(js1->'$', '[173467623]');
select * from t1  where json_contains(js1->'$', cast('[173467623]' as json));
select * from t1  where json_contains(js1->'$[*]', cast('[173467623]' as json));

select * from t1 where "173467623" member of (js1->'$');
select * from t1 where '["173467623"]' member of (js1->'$');
select * from t1 where cast('["173467623"]' as json) member of (js1->'$');

select * from t1 where 173467623 member of (js1->'$');
select * from t1 where '[173467623]' member of (js1->'$');
select * from t1 where cast('[173467623]' as json) member of (js1->'$');

update t1 set name = '洛阳东站', js1 = '[512732,5123]', js2 = '["锅盔","炸鸡"]' where name = '金庄超市'  and JSON_CONTAINS(js2->'$[*]',CAST('["薯片"]' AS JSON));
#非BUG 此处与mysql不一致  ob更加合理所以不认为是bug
update t1 set name = '西安东站', js1 = '[621543512,621534512]', js2 = '["蚂蚱","笔记"]' where json_overlaps(js1->'$', '["173467623"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;
sleep 1;
update t1 set name = '西安东站', js1 = '[621543512,621534512]', js2 = '["蚂蚱","笔记"]' where json_overlaps(js1->'$', '[173467623]');
select /*+read_consistency(weak) */ * from t1;

delete from t1 where name = '郑州东站'  and JSON_CONTAINS(js2->'$[*]',CAST('["锅盔"]' AS JSON));
#非BUG 此处与mysql不一致  ob更加合理所以不认为是bug
delete from t1 where json_overlaps(js1->'$', '[621543512]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;



