#################### insert into ... on duplicate key update ############################
#添加不重复数据
--disable_warnings
drop table if exists t52;
create table t52(id int primary key,name varchar(50),age int ,js json);
insert into t52 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[44,33]}');
create unique index scores on t52 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));

#主键不重复+唯一复合多值索引不重复
insert into t52 values (3,'shuxue',12,'{"score":[55,66]}') on duplicate key update name = 'ma',js = '{"score":[77,88]}';
delete from t52 where id = 3;
select * from t52;

#主键重复+唯一复合多值索引不重复
--disable_warnings
