########################   20240829   ############################

#主键不重复+唯一复合多值索引重复
--disable_warnings
drop table if exists t52;
create table t52(id int primary key,name varchar(50),age int ,js json);
insert into t52 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[44,33]}');
create unique index scores on t52 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
insert into t52 values (3,'lili',12,'{"score":[11,22]}') on duplicate key update id = values(id), name = 'ssss';
select * from t52;

#主键重复+唯一复合多值索引和另一条记录重复
--disable_warnings
drop table if exists t52;
create table t52(id int primary key,name varchar(50),age int ,js json);
insert into t52 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[44,33]}');
create unique index scores on t52 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
#BUG
#mysql 执行成功'
#+----+------+------+---------------------+
#| id | name | age  | js                  |
#+----+------+------+---------------------+
#|  1 | lili |   12 | {"score": [11, 22]} |
#|  2 | ssss |   12 | {"score": [44, 33]} |
#+----+------+------+---------------------+
#ob 执行失败 ERROR 4016 (HY000): Internal error
#--error 4016
insert into t52 values (2,'lili',12,'{"score":[11,22]}') on duplicate key update name = 'ssss';
select * from t52;



######################## replace into ########################
#主键不重复+唯一多值索引不重复
--disable_warnings
drop table if exists t52;
create table t52(id int primary key,name varchar(50),age int ,js json);
insert into t52 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[44,33]}');
create unique index scores on t52 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
#+----+------+------+---------------------+
#| id | name | age  | js                  |
#+----+------+------+---------------------+
#|  1 | lili |   12 | {"score": [11, 22]} |
#|  2 | mali |   12 | {"score": [44, 33]} |
#|  3 | ma   |   13 | {"score": [55, 66]} |
#+----+------+------+---------------------+
replace into t52(id, name, age, js) values (3,'ma', 13, '{"score":[55,66]}');
select * from t52;

