#|  2 | mali |   12 | {"score": [44, 33]} |
#+----+------+------+---------------------+
#ob报错ERROR 4016 (HY000): Internal error
#--error 4016
insert into t52 values (1,'yuwen',12,'{"score":[55,66]}') on duplicate key update name = 'ma',js = '{"score":[77,88]}';
select * from t52;

