connect (conadmin,$OBMYSQL_MS0,admin@sys,admin,,$OBMYSQL_PORT);
connection conadmin;
alter system set _enable_add_fulltext_index_to_existing_table = true;
connection default;

###############  后建唯一复合多值索引  ###############
#无数据,后建唯一复合多值索引
drop table if exists t50;
create table t50(id int primary key,name varchar(50),age int ,js json);
create unique index scores on t50 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
insert into t50 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}'),
(3,'daici',12,'{"score":[55,66]}'),
(4,'chujin',12,'{"score":[77,88]}'),
(5,'nani',12,'{"score":[10]}');
show create table t50;
select * from t50;
explain select * from t50 where name = 'lili' and  11 member of(js->>'$.score');
drop index scores on t50;
--disable_warnings
drop table if exists t50;


#有数据+后建唯一复合多值索引
--disable_warnings
drop table if exists t51;
create table t51(id int primary key,name varchar(50),age int ,js json);
insert into t51 values
(1,'lili',12,'{"score":[11,22]}'),
(2,'mali',12,'{"score":[33,44]}'),
(3,'daici',12,'{"score":[55,66]}'),
(4,'chujin',12,'{"score":[77,88]}'),
(5,'nani',12,'{"score":[10]}');
create unique index scores on t51 (name,(CAST(js->'$.score' AS UNSIGNED ARRAY)));
show create table t51;
select * from t51;
explain select * from t51 where name = 'lili' and  11 member of(js->>'$.score');


