connect (conadmin,$OBMYSQL_MS0,admin@sys,admin,,$OBMYSQL_PORT);
connection conadmin;
alter system set _enable_add_fulltext_index_to_existing_table = true;
connection default;

#分区
--disable_warnings
drop table if exists t200;
create table t200(id int, age int, name varchar(50), js json, primary key(id));
insert into t200 values
(1,12,'mali', '{"score":[11,22]}'),
(2,12,'yang', '{"score":[44,33]}'),
(3,15,'chang', '{"score":[66,55]}');
create index scores on t200((CAST(js->'$.score' as unsigned array)));

--disable_warnings
drop view if exists t200_v1;
--disable_warnings
drop view if exists t200_v2;
--disable_warnings
drop view if exists t200_v3;
create view t200_v1 as select * from t200;
create view t200_v2 as select id,js from t200;
create view t200_v3 as select id,js->'$.score' as js from t200;

select * from t200_v1 order by id;
select * from t200_v2 order by id;
select * from t200_v3 order by id;

#插入源表
insert into t200 values (4,19,'meng', '{"score":[100]}');
#更新源表
update t200 set js = '{"score":[77,88]}' where id = 3;
select * from t200_v1 order by id;
select * from t200_v2 order by id;
select * from t200_v3 order by id;


#更新视图
update t200_v1 set js = '{"score":[11,22]}';
update t200_v2 set js = '{"score":[500]}' where id = 2;
--error 1348
update t200_v3 set js = '[1000]' where id = 3;


select * from t200 order by id;
select * from t200_v1 order by id;
select * from t200_v2 order by id;
select * from t200_v3 order by id;


#删除
#delete from t200_v1 where json_value(js,'$.score') = '[11,22]';
delete from t200_v1 where id = 1;
delete from t200_v2 where id = 2;
delete from t200_v3 where id = 3;

select * from t200 order by id;
select * from t200_v1 order by id;
select * from t200_v2 order by id;
select * from t200_v3 order by id;
--disable_warnings
drop view if exists t200_v1;
--disable_warnings
drop view if exists t200_v2;
--disable_warnings
drop view if exists t200_v3;

--disable_warnings
drop table if exists t200;

#视图+分区
--disable_warnings
drop table if exists t202;
create table t202(id int, age int, name varchar(50),date1 date, js json, primary key(id, date1))
partition by range columns (date1)
subpartition by hash(id) SUBPARTITIONS 5
(partition p202401 values less than('20240101'),
partition p202402 values less than('20240201'),
partition p202403 values less than('20240301'),
partition p202404 values less than('20240401'),
partition p202405 values less than('20240501')
);
insert into t202 values
(1,12,'mali','20240115', '{"score":[11]}'),
(2,12,'yang','20240215', '{"score":[22]}'),
(3,15,'chang','20240315', '{"score":[33]}'),
(4,16,'zheng','20240415', '{"score":[44]}');

#BUG hung住了 2024082100104212541
create index scores on t202((CAST(js->'$.score' as unsigned array)));

--disable_warnings
drop view if exists t202_v1;
--disable_warnings
drop view if exists t202_v2;
--disable_warnings
drop view if exists t202_v3;
create view t202_v1 as select * from t202;
create view t202_v2 as select id,js from t202;
create view t202_v3 as select id,js->'$.score' as js from t202;

#更新
update t202_v1 set js = '{"score":[11,22]}';
update t202_v2 set js = '{"score":[500]}' where id = 2;
#ERROR 1348 (HY000): Column 'js' is not updatable
--error 1348
update t202_v3 set js = '[1000]' where id = 3;

select * from t202 order by id;
select * from t202_v1 order by id;
select * from t202_v2 order by id;
select * from t202_v3 order by id;

#删除
delete from t202_v1 where id = 1;
delete from t202_v2 where id = 2;
delete from t202_v3 where id = 3;

select * from t202 order by id;
select * from t202_v1 order by id;
select * from t202_v2 order by id;
select * from t202_v3 order by id;

--disable_warnings
drop view if exists t202_v1;
--disable_warnings
drop view if exists t202_v2;
--disable_warnings
drop view if exists t202_v3;

--disable_warnings
drop table if exists t202;

####################### 物化视图 ##############################
--disable_warnings
drop table if exists t203;
create table t203(id int, age int, name varchar(50),date1 date, js json, primary key(id, date1))
partition by range columns (date1)
subpartition by hash(id) SUBPARTITIONS 5
(partition p202401 values less than('20240101'),
partition p202402 values less than('20240201'),
partition p202403 values less than('20240301'),
partition p202404 values less than('20240401'),
partition p202405 values less than('20240501')
);

#BUG hung住了 2024082100104212541
create index scores on t203((CAST(js->'$.score' as unsigned array)));

insert into t203 values
(1,12,'mali','20240115', '{"score":[11]}'),
(2,12,'yang','20240215', '{"score":[22]}'),
(3,15,'chang','20240315', '{"score":[33]}'),
(4,16,'zheng','20240415', '{"score":[44]}');

--disable_warnings
drop MATERIALIZED VIEW if exists t203_mv1;
#普通物化视图
#mysql 报错 ERROR 1064 (42000): You have an error in your SQL syntax; check the manual that corresponds to your MySQL server version for the right syntax to use near 'MATERIALIZED VIEW t203_mv1(id,name,js) as select id,name,js from t203' at line 1
create MATERIALIZED VIEW t203_mv1(id,name,js) as select id,name,js from t203;

--disable_warnings
drop MATERIALIZED VIEW if exists t203_mv2;
#物化视图+主键
#mysql 报错 ERROR 1064 (42000): You have an error in your SQL syntax; check the manual that corresponds to your MySQL server version for the right syntax to use near 'MATERIALIZED VIEW t203_mv2(id,name,js,primary key(id)) as select id,name,js from' at line 1
create MATERIALIZED VIEW t203_mv2(id,name,js,primary key(id)) as select id,name,js from t203;

--disable_warnings
drop MATERIALIZED VIEW if exists t203_mv3;
#物化视图+主键+后建唯一索引+后建多值索引
#mysql 报错 ERROR 1064 (42000): You have an error in your SQL syntax; check the manual that corresponds to your MySQL server version for the right syntax to use near 'MATERIALIZED VIEW t203_mv3(id,name,js,primary key(id))
create MATERIALIZED VIEW t203_mv3(id,name,js,primary key(id))
    PARALLEL 5
    PARTITION BY HASH(id) PARTITIONS 8
    as select id,name,js
    from t203;

#ERROR 1503 (HY000): A UNIQUE INDEX must include all columns in the table's partitioning function
--error 1503
create unique index index_mv3_1 on t203_mv3 (name);
#ERROR 1235 (0A000): use functional index on materialized view not supported
--error 1235
create index index_mv3_2 on t203_mv3 ((cast(js->'$.score' as unsigned array)));

--disable_warnings
drop MATERIALIZED VIEW if exists LOG;
#实时物化视图
#ERROR 1060 (42S21): Duplicate column name 'id'
--error 1060
CREATE MATERIALIZED VIEW LOG ON t203 WITH PRIMARY KEY, ROWID, SEQUENCE (id,js) INCLUDING NEW VALUES;

--disable_warnings
drop MATERIALIZED VIEW if exists t203_mv4;
#ERROR 9783 (HY000): cannot ENABLE ON QUERY COMPUTATION for the materialized view
--error 9783
create MATERIALIZED VIEW t203_mv4
    ENABLE ON QUERY COMPUTATION
    as select id,js from t203;

SELECT MVIEW_NAME, ON_QUERY_COMPUTATION FROM oceanbase.DBA_MVIEWS WHERE MVIEW_NAME = 't203_mv4';
#ERROR 1146 (42S02): Table 'test.t203_mv4' doesn't exist
#EXPLAIN BASIC SELECT * FROM t203_mv4;


