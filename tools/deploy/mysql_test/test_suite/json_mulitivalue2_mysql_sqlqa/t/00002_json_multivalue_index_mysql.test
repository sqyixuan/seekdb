create index idx1 on t1 ((cast(js->'$[*][*]' as unsigned array)));
truncate table t1;
drop index idx1 on t1;

insert into t1 (id ,js) values (2,'null');
create index idx1 on t1 ((cast(js->'$[*][*]' as unsigned array)));
truncate table t1;
drop index idx1 on t1;

