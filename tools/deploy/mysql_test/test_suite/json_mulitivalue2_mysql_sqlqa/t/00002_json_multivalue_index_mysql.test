####$[1] | unsigned | alter table ｜无其他索引 | 有数据后建 | 数据符合｜ 非hint
--disable_warnings
drop table if exists t1;
create table t1 (id int , js json);
insert into t1 (id, js) values (1,'[[111],[222,333]]') ,(2,'[[444],[555,666]]'),(3,'[[777],[888,999]]'),(4,'[[1234]]');
alter table t1 add index idx1((cast(js->'$[1]' as unsigned array)));
insert into t1 values (5,'[[123]]'),(6,'[[222],[32423]]');
insert into t1 values (7,'[[3453],[263]]') on duplicate key update js = values(js);
replace into t1 values (8,'[[111],[222]]');

select * from t1;
select * from t1 where JSON_OVERLAPS(js->>'$[1]', '[333]');
select * from t1 where JSON_OVERLAPS(js->>'$[1]', '[444]');

update t1 set js = '[[111]]' where id = 1;
update t1 set js = '[[111],[222,333]]' where id = 1;

delete from t1 limit 1;
delete from t1 where id = 2;
delete from t1 where JSON_OVERLAPS(js->>'$[1]', '[]');

#### $.score | date | create index | 有主键索引 ｜ 有数据后建 ｜ 数据符合  ｜ hint
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, js json);
insert into t1 (id,js) values (1,'{"score":["2023-01-01","2024-01-01"]}'),(2,'{"score":["2023-02-01","2024-02-01"]}'),(3,'{"score":["2023-03-01","2024-03-01"]}'),(4,'{"score":["2023-04-01","2024-04-01"]}');
#BUG mysql成功执行 ob报错 ERROR 1146 (42S02): Table doesn't exist  问题链接 ：2024092400104554530
create /*+ ENABLE_PARALLEL_DML parallel(8) */index idx1 on t1((cast(js->'$.score' as date array)));
insert into t1(id,js) values (5,'{"score":["2025-01-01","2025-01-01"]}'),(6,'{"score":["2026-06-06","2026-06-07"]}');
insert into t1(id,js) values (5,'{"score":["2025-07-07"]}') on duplicate key update js = values(js);
insert into t1(id,js) values (7,'{"score":["2027-07-07","2027-06-07"]}') on duplicate key update js = values(js);
replace into t1 (id,js) values (6,'{"score":["2027-07-07"]}');
replace into t1 (id,js) values (8,'{"score":["2028-08-08","2028-08-09"]}');
select * from t1;
update t1 set js = '{"score":["2011-11-11"]}' where id = 1;
update t1 set js = json_set(js,'$.score[0]',"2011-11-11") where id = 2;
update t1 set js = json_set(js,'$.score[0]',"2011-11-11") where JSON_OVERLAPS(js->>'$.score', '["2023-03-01"]');
delete  from t1 where JSON_OVERLAPS(js->>'$.score', '["2023-04-01"]');
delete from t1 where id = 5;
select * from t1;

#### $.[n to m] | char | alter table  | 有主键索引 ｜ 有数据后建 ｜ 数据符合  ｜ hint
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, js json);
insert into t1 (id, js) values (1,'[["11"],["12"],["13"]]'), (2,'[["21"],["22"],["23"]]'),(3,'[["31"],["32"],["33"]]');
#BUG mysql 报错 ERROR 3908 (HY000): Cannot store an array or an object in a scalar key part of the index 'idx1'. ob报错 ERROR 5703 (HY000): Add index failed
--error 5703,3908
alter /*+ ENABLE_PARALLEL_DML parallel(8) */ table t1 add index idx1((cast(js->'$[1 to 2]' as char(5) array)));
#BUG mysql 报错 ERROR 3908 (HY000): Cannot store an array or an object in a scalar key part of the index 'idx1'. ob报错 ERROR 5703 (HY000): Add index failed
--error 5703,3908
alter table t1 add index idx1((cast(js->'$[1 to 2]' as char(5) array)));


#### $.score | char | alter table  | 有主键索引 ｜ 有数据后建 ｜ 数据符合  ｜ hint
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, js json);
insert into t1 (id, js) values (1,'{"score":["11"]}'), (2,'{"score":["22"]}'),(3,'{"score":["33"]}');
#BUG mysql成功 ob ERROR 1146 (42S02): Table doesn't exist
alter /*+ ENABLE_PARALLEL_DML parallel(8) */ table t1 add index idx1((cast(js->'$.score' as char(5) array)));
insert into t1 (id,js) values (4,'{"score":["44"]}'), (5,'{"score":["55"]}');
insert into t1 (id,js) values (4,'{"score":["66"]}') on duplicate key update js = values(js);
insert into t1 (id,js) values (6,'{"score":["66"]}') on duplicate key update js = values(js);
replace into t1 (id,js) values (5,'{"score":["77"]}');
replace into t1 (id,js) values (7,'{"score":["77"]}');
update t1 set js = '{"score":["100"]}' where JSON_CONTAINS(js->'$.score',CAST('["11"]' AS JSON));
update t1 set js = '{"score":["100"]}' where json_overlaps(js->'$.score', '["22"]');
update t1 set js = '{"score":["100"]}' where 33 member of(js->'$.score');
sleep 1;
select /*+read_consistency(weak) */ * from t1;
delete from t1 where JSON_CONTAINS(js->'$.score',CAST('["100"]' AS JSON));
delete from t1 where json_overlaps(js->'$.score', '["66"]');
delete from t1 where 77 member of(js->'$.score');
sleep 1;
select /*+read_consistency(weak) */ * from t1;


#### $ | char | create index  | 普通索引&唯一索引 ｜ 有数据后建 ｜ 数据符合  ｜ 非hint | 弱读
--disable_warnings
drop table if exists t1;
create table t1 (id int, name char(10), date1 date, js json, index idx1 (date1), unique index idx2(name));
insert into t1 (id, name , date1, js) values (1,"祭城超市", "2024-01-01", '["火锅丸子","酸奶"]'),(2,"金庄超市", "2025-01-01", '["火锅丸子","饼干"]'),(3,"庙张超市", "2026-01-01", '["辣条","水果"]');
create index idx3 on t1((cast(js->'$' as char(10) array)));
insert into t1 (id, name , date1, js) values (4,"文化产业大厦",'2024-03-01', '["可乐","雪碧"]'), (5,"绿地新都会",'2024-03-01', '["可乐","雪碧"]');
insert into t1 (id, name , date1, js) values (4,"文化产业大厦",'2024-03-01', '["果冻","馍片"]') on duplicate key update js = values(js);
insert into t1 (id, name , date1, js) values (6,"回忆银河里",'2024-03-01', '["果冻","馍片"]') on duplicate key update js = values(js);
replace into t1 (id, name , date1, js) values (5,"绿地新都会",'2024-03-01', '["果冻","馍片"]') ;
replace into t1 (id, name , date1, js) values (7,"郑州东站",'2024-03-01', '["果冻","馍片"]') ;
sleep 1;
select /*+read_consistency(weak) */ * from t1;

update t1 set js = '["橙汁","茶"]' where JSON_CONTAINS(js->'$',CAST('["酸奶"]' AS JSON));
update t1 set js = '["橙汁","茶"]' where json_overlaps(js->'$', '["火锅丸子"]');
update t1 set js = '["橙汁","茶"]' where json_overlaps(js, '["辣条"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;

delete from t1 where JSON_CONTAINS(js->'$',CAST('["果冻"]' AS JSON));
delete from t1 where json_overlaps(js->'$', '["橙汁","饮料"]');
sleep 1;
select /*+read_consistency(weak) */ * from t1;

#### $ | unsigned | alter table  | 主键索引&唯一索引 ｜ 有数据后建 ｜ 数据符合  ｜ 非hint | insert on duplicate 主键重复
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, name char(10),js json, unique index idx2(name));
insert into t1 (id,name,js) values (1,'祭城超市','[11,12]'),(2,'文化产业大厦','[21,2888888]'),(3,'回忆银河里','[31,39999999]'),(4,'郑州东站','[4263526362,41]');
alter table t1 add index idx1((cast(js->'$' as unsigned array)));
insert into t1 (id,name,js) values (5,'绿地新都会','[51,55]'),(6,'七里河站','[66,676766]'),(7,'八里沟','[76,76666666]'),(8,'省骨科医院','[87,800000]');
#不重复
insert into t1 (id, name,js) values (9,'石林', '[913213]') on duplicate key update js = values(js);
#主键重复
insert into t1 (id, name ,js) values (5,'安阳', '[51253512]')  on duplicate key update js = values(js);
insert into t1 (id, name ,js) values (6,'驻马店', '[62354623456]')  on duplicate key update js = (js);
insert into t1 (id, name ,js) values (7,'滑县', '[62354623456]')  on duplicate key update js = '[62354623456]';
#BUG mysql报错 ERROR 3903 (22018): Invalid JSON value for CAST for functional index 'idx1'.
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t1 (id, name ,js) values (1,'橙汁', '[121312312]')  on duplicate key update js = '["miao"]';
#BUG mysql 报错 ERROR 3903 (22018): Invalid JSON value for CAST for functional index 'idx1'.
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
update t1 set js = '["miao"]' where name = '文化产业大厦';

--replace_regex /range_key.*/123/g
explain select * from t1 where JSON_CONTAINS(js->'$',CAST('[39999999]' AS JSON));
--replace_regex /range_key.*/123/g
explain select * from t1 where json_overlaps(js->'$', '[4263526362]');
explain select * from t1 where json_overlaps(js, '["辣条"]');



#### $ | unsigned | alter table  | 主键索引&唯一索引 ｜ 有数据后建 ｜ 数据符合  ｜ 非hint |  insert on duplicate 唯一键重复
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, name char(10),js json, unique index idx2(name));
insert into t1 (id,name,js) values (1,'祭城超市','[11,12]'),(2,'文化产业大厦','[21,2888888]'),(3,'回忆银河里','[31,39999999]'),(4,'郑州东站','[4263526362,41]');
alter table t1 add index idx1((cast(js->'$' as unsigned array)));
insert into t1 (id,name,js) values (5,'绿地新都会','[51,55]'),(6,'七里河站','[66,676766]'),(7,'八里沟','[76,76666666]'),(8,'省骨科医院','[87,800000]');
#唯一键重复
insert into t1 (id, name ,js) values (9,'绿地新都会', '[51253512]')  on duplicate key update js = values(js);
insert into t1 (id, name ,js) values (10,'七里河站', '[62354623456]')  on duplicate key update js = (js);
insert into t1 (id, name ,js) values (11,'八里沟', '[112312312321]')  on duplicate key update js = '[34423423]';
#BUG mysql报错 ERROR 3903 (22018): Invalid JSON value for CAST for functional index 'idx1'.
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t1 (id, name ,js) values (12,'省骨科医院', '[62354623456]')  on duplicate key update js = '["maio"]';

#BUG mysql 用到了多值索引 ob没用到
--replace_regex /table_columns.*/123/g   /output.*/123/g /access.*/123/g /range_key.*/123/g
explain delete from t1 where JSON_CONTAINS(js->'$',CAST('[62354623456]' AS JSON));
delete from t1 where JSON_CONTAINS(js->'$',CAST('[62354623456]' AS JSON));
#BUG mysql用到了多值索引 ob没用
--replace_regex /table_columns.*/123/g   /output.*/123/g /access.*/123/g /range_key.*/123/g /range_key.*/123/g
explain delete /*+ index(t1 idx1)*/ from t1 where JSON_CONTAINS(js->'$',CAST('[2888888]' AS JSON));
delete /*+ index(t1 idx1)*/ from t1 where JSON_CONTAINS(js->'$',CAST('[2888888]' AS JSON));

sleep 1;
select /*+read_consistency(weak) */ * from t1;


#### $ | unsigned | alter table  | 主键索引&唯一索引 ｜ 有数据后建 ｜ 数据符合  ｜ 非hint |  insert on duplicate 主键重复&唯一键重复
--disable_warnings
drop table if exists t1;
create table t1 (id int AUTO_INCREMENT primary key, name char(10),js json, unique index idx2(name));
insert into t1 (id,name,js) values (1,'祭城超市','[11,12]'),(2,'文化产业大厦','[21,2888888]'),(3,'回忆银河里','[31,39999999]'),(4,'郑州东站','[4263526362,41]');
alter table t1 add index idx1((cast(js->'$' as unsigned array)));
insert into t1 (id,name,js) values (5,'绿地新都会','[51,55]'),(6,'七里河站','[66,676766]'),(7,'八里沟','[76,76666666]'),(8,'省骨科医院','[87,800000]');

insert into t1 (id, name ,js) values (1,'祭城超市', '[21312312]')  on duplicate key update js = values(js);
insert into t1 (id, name ,js) values (2,'回忆银河里', '[1231313]')  on duplicate key update js = values(js);
#BUG mysql 报错 ERROR 3903 (22018): Invalid JSON value for CAST for functional index 'idx1'.
--error 3903 #ERROR 3903 (42000): Invalid JSON value for CAST for functional index.
insert into t1 (id, name ,js) values (4,'郑州东站', '[1231313]')  on duplicate key update js = '["miao"]';
sleep 1;
select /*+read_consistency(weak) */ * from t1;
