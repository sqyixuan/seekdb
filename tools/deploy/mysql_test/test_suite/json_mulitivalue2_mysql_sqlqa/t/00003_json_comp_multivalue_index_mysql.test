(11,'mary',12,'{"score":[1234,3452,5671,909]}'),
(12,'lili',13,'{"score":[1001,234,4563,6786]}'),
(13,'mali',11,'{"score":[67,894,930,7389]}'),
(14,'defu',14,'{"score":[1223,920,415,919]}');

#insert into on duplicate
insert into t20 (id, js) values (14,'{"score":[1,2,34]}') on duplicate key update js = values(js);
select * from t20;

insert into t20 (id, js) values (15,'{"score":[1,2,34]}') on duplicate key update js = values(js);
select * from t20;

--echo replace into
#重复
replace into t20 set id=14,js='{"score": [555, 999]}';
select * from t20;

#不重复
replace into t20 set id=17,js='{"score": [555, 999]}';
select * from t20;

#查看索引
show create table t20;
#show index from t20;

#explain
select * from t20 where name='mary' and age =12 and 909 member of(js->>'$.score');
--replace_regex /range_key.*/123/g
explain select * from t20 where name='mary' and age =12 and 909 member of(js->>'$.score');

--disable_warnings
drop table if exists t20;

