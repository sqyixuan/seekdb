drop MATERIALIZED VIEW if exists t203_mv1;
create MATERIALIZED VIEW t203_mv1(id,name,js) as select id,name,js from t203;
drop MATERIALIZED VIEW if exists t203_mv2;
create MATERIALIZED VIEW t203_mv2(id,name,js,primary key(id)) as select id,name,js from t203;
drop MATERIALIZED VIEW if exists t203_mv3;
create MATERIALIZED VIEW t203_mv3(id,name,js,primary key(id))
PARALLEL 5
PARTITION BY HASH(id) PARTITIONS 8
as select id,name,js
from t203;
create unique index index_mv3_1 on t203_mv3 (name);
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
create index index_mv3_2 on t203_mv3 ((cast(js->'$.score' as unsigned array)));
ERROR 0A000: use functional index on materialized view not supported
drop MATERIALIZED VIEW if exists LOG;
CREATE MATERIALIZED VIEW LOG ON t203 WITH PRIMARY KEY, ROWID, SEQUENCE (id,js) INCLUDING NEW VALUES;
ERROR 42S21: Duplicate column name 'id'
drop MATERIALIZED VIEW if exists t203_mv4;
create MATERIALIZED VIEW t203_mv4
ENABLE ON QUERY COMPUTATION
as select id,js from t203;
