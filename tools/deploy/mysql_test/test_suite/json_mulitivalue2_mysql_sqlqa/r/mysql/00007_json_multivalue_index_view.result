drop table if exists t202;
create table t202(id int, age int, name varchar(50),date1 date, js json, primary key(id, date1))
partition by range columns (date1)
subpartition by hash(id) SUBPARTITIONS 5
(partition p202401 values less than('20240101'),
partition p202402 values less than('20240201'),
partition p202403 values less than('20240301'),
partition p202404 values less than('20240401'),
partition p202405 values less than('20240501')
);
