############################## TEST CASES  ##############################
## 普通表 + 分区表 + 约束
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

--ERROR 0,1067
CREATE TABLE t1 (  
    id BIGINT UNSIGNED DEFAULT 0,  
    AGE INT DEFAULT '2/0'
);

--ERROR 0,1067
CREATE TABLE t1 (  
    id BIGINT UNSIGNED DEFAULT 0,  
    AGE tinyint DEFAULT '2/0'
);

--ERROR 0,1566
CREATE TABLE t1(
    a bigint,
	b INT
)partition by range columns(b) 
( 
	partition part_1 values less than (1),
	partition part_2 values less than (MOD(3,0)),
	partition part_3 values less than (4)
);


CREATE TABLE t1(
    a bigint,
	b INT
)partition by range columns(b) 
( 
	partition part_1 values less than (5),
	partition part_2 values less than (10),
	partition part_3 values less than (20)
);
INSERT IGNORE INTO t1 VALUES(1, MOD(3,0));
--error 0,1365
INSERT INTO t1 VALUES(2, IFNULL(NULL, 2/0));
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1 (
    id INT,
    data date
) PARTITION BY LIST(id) (
    PARTITION p0 VALUES IN (5, MOD(3,0), 15),
    PARTITION p1 VALUES IN (6, 12, 18)
);
INSERT IGNORE INTO t1 VALUES(MOD(3,0),'2020-01-23 21:29:31');
--error 0,1365
INSERT INTO t1 VALUES(IFNULL(NULL, 2/0), '2020-01-23 21:29:31');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1 (
    id INT,
    signed DATETIME
) PARTITION BY HASH( MOD(id,0) )
PARTITIONS 2;
INSERT IGNORE INTO t1 VALUES(1,'0000-00-00 21:29:31');
--error 1365
INSERT  INTO t1 VALUES(2,'0000-00-00 21:29:31');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
    a INT,
	c_time DATE,
    d_a int GENERATED ALWAYS AS (mod(a,0)) 
);
INSERT IGNORE INTO t1(a, c_time) VALUES(1,'2022-01-03');
INSERT IGNORE INTO t1(a, c_time) VALUES(2,'2023-03-11');
UPDATE IGNORE t1 SET a=56/0;
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
	a INT,
	c_time DATE,
	d_a varchar(30) GENERATED ALWAYS AS (mod(a,0)) 
);
INSERT IGNORE INTO t1(a, c_time) VALUES(1,'2022-01-03');
INSERT IGNORE INTO t1(a, c_time) VALUES(2,'2023-03-11');
UPDATE IGNORE t1 SET a=56/0;
SELECT * FROM t1;
DROP TABLE t1;

create table t1(c1 tinyint);
SET sql_mode='STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO';
--error 1365
INSERT INTO t1 SET c1 = 1/0;
drop table t1;

