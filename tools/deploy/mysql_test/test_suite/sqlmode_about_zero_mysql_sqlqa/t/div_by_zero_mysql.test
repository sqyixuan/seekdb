############################## TEST CASES  ##############################
## SELECT 语句
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

SELECT 10/0;
SELECT 0/0;
SELECT 1.0/0;
SELECT -3.0/0;
SELECT -3.0/0.1;
SELECT 1.175494351E-38/0;
SELECT -3.402823466E+38/0;
SELECT -1.7976931348623157E+308/0;
SELECT 1100111011110101111010000000111000111/0;
SELECT 0000-12-25/0;
SELECT cast(20.3456 as decimal(10, 2))/0;
SELECT cast('2019-03-08 15:31:26' as datetime )/0;
SELECT cast('2019-03-08 15:31:26' as date )/0;
SELECT cast('2015-11-03 15:31:26' as signed)/0;
SELECT sign(1.175494351E-38)/0 From dual;
SELECT sign(1.175494351E-38/0 )From dual;
SELECT sign(-3.402823466E+38)/0 From dual;
SELECT sign(-3.402823466E+38/0) From dual;
SELECT sign(-1.7976931348623157E+308/0) From dual;


############################## TEST CASES  ##############################
## 函数
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

SELECT ASCII(10/0) A, ASCII(0/10) a, ASCII(0) space FROM DUAL;
SELECT LENGTH(10/0) FROM DUAL;
SELECT concat(10/0,'XXXX') FROM DUAL;
SELECT concat(10/0,'XXXX') FROM DUAL;
SELECT ABS(5/0) FROM DUAL;
SELECT ABS(0/0) FROM DUAL;
SELECT ABS(0/1) FROM DUAL;
SELECT ACOS(-10/0) FROM DUAL;
SELECT ACOS(-0/0) FROM DUAL;
SELECT ASIN(-1/0) FROM DUAL;
SELECT BIT_COUNT(42/0) FROM DUAL;
SELECT BIT_COUNT(b'1010')/0 FROM DUAL;
SELECT CEIL(1.2) FROM DUAL;
SELECT CEILING(1.23)/0 FROM DUAL;
SELECT CONV(9223372036854775807,10,2)/0 FROM DUAL;
SELECT COS(PI())/0 FROM DUAL;
SELECT COS(0)/0 FROM DUAL;
SELECT COT(-10/0) FROM DUAL;
SELECT EXP(2/0) FROM DUAL;
SELECT FLOOR(1.2/0) FROM DUAL;
SELECT LN(-10/0) FROM DUAL;
SELECT LOG(-10/0) FROM DUAL;
SELECT LOG10(-10/0) FROM DUAL;
SELECT LOG2(-10/0) FROM DUAL;
SELECT MOD(29,0) FROM DUAL;
SELECT MOD(cast('0000-00-00 15:31:26' as datetime ),0) FROM DUAL;
SELECT 29 MOD 0 FROM DUAL;
SELECT 29 % 0 FROM DUAL;
SELECT NEG(1)/0 FROM DUAL;
SELECT NEG(1/0) FROM DUAL;
SELECT POW(4,0) FROM DUAL;
SELECT POW(1,NULL) FROM DUAL;
SELECT RADIANS(-10/0) FROM DUAL;
SELECT RAND(2/0) FROM DUAL;
SELECT ROUND(2.15/0,0) FROM DUAL;
SELECT SIGN(-32/0) FROM DUAL;
SELECT TRUNCATE(3.27/0,1) FROM DUAL;
SELECT IF (5>6, 1, 1/0) FROM DUAL;
SELECT IF (5>6, 1/0, 0) FROM DUAL;
SELECT IF (5/6>0, 1/0, 0) FROM DUAL;
SELECT CASE 2/1 WHEN 2 THEN 2 WHEN 1/0 THEN 0 END FROM DUAL;
SELECT CASE 2/1 WHEN 1 THEN 2 WHEN 1/0 THEN 0 END FROM DUAL;
SELECT CASE 2/1 WHEN 1 THEN 2 WHEN 1/0 THEN 0 ELSE 2/0 END FROM DUAL;
SELECT IFNULL(2/0, 'ABC') FROM DUAL; 
SELECT IFNULL(NULL, 2/0) FROM DUAL; 
SELECT NULLIF(null, 123/0) FROM DUAL; 
SELECT NULLIF(2/0, 123/0) FROM DUAL; 
SELECT NULLIF(2/0, 123) FROM DUAL; 
SELECT ORA_DECODE(1,1,'lala',2/0,'mua') FROM DUAL; 
SELECT ORA_DECODE(1,1/0,'lala',2/0,'mua') FROM DUAL; 


############################## TEST CASES  ##############################
## 启用模式 + 严格模式 INSERT
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

CREATE TABLE t1 (id1 int ,age1 varchar(20));
--ERROR 0,1365
INSERT INTO t1 values (56/0,-451);
--ERROR 0,1365
INSERT INTO t1 values (56,-451/0);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t2 (id2 tinyint ,age2 smallint);
--ERROR 0,1365
INSERT INTO t2 values (56/0,-451);
--ERROR 0,1365
INSERT INTO t2 values (56,-451/0);
SELECT * FROM t2;
DROP TABLE t2;

CREATE TABLE t3 (id3 mediumint, age3 bigint);
--ERROR 0,1365
INSERT INTO t3 values (56/0,-451);
--ERROR 0,1365
INSERT INTO t3 values (56,-451/0);
SELECT * FROM t3;
DROP TABLE t3;

CREATE TABLE t4 (id4 float, age4 double);
--ERROR 0,1365
INSERT INTO t4 values (56/0,-451);
--ERROR 0,1365
INSERT INTO t4 values (56,-451/0);
SELECT * FROM t4;
DROP TABLE t4;


############################## TEST CASES  ##############################
## 启用模式 + 严格模式 INSERT IGNORE 
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

CREATE TABLE t1 (id1 int ,age1 varchar(20));
INSERT IGNORE INTO t1 values (56/0,-451);
INSERT IGNORE INTO t1 values (56,-451/0);
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t2 (id2 tinyint ,age2 smallint);
INSERT IGNORE INTO t2 values (56/0,-451);
INSERT IGNORE INTO t2 values (56,-451/0);
SELECT * FROM t2;
DROP TABLE t2;

CREATE TABLE t3 (id3 mediumint, age3 bigint);
INSERT IGNORE INTO t3 values (56/0,-451);
INSERT IGNORE INTO t3 values (56,-451/0);
SELECT * FROM t3;
DROP TABLE t3;
--disable_warnings
CREATE TABLE t4 (id4 float, age4 double);
INSERT IGNORE INTO t4 values (56/0,-451);
INSERT IGNORE INTO t4 values (56,-451/0);
SELECT * FROM t4;
DROP TABLE t4;

CREATE TABLE t5(c date);
INSERT INTO t5 VALUES('2020-01-12');
INSERT IGNORE INTO t5 VALUES(0000-00-00/0);
INSERT IGNORE INTO t5 VALUES('00-00-00'/0);
INSERT IGNORE INTO t5 VALUES('0000:00:00'/0);
SELECT * FROM t5;
DROP TABLE t5;

CREATE TABLE t6(c1 time);
INSERT IGNORE INTO t6 VALUES('00-00-00'/0);
INSERT IGNORE INTO t6 VALUES('0000.00.00'/0);
INSERT IGNORE INTO t6 VALUES('0000:00:00'/0);
INSERT IGNORE INTO t6 VALUES('00:00:00'/0);
INSERT IGNORE INTO t6 VALUES('00.00.00'/0);
SELECT * FROM t6;
DROP TABLE t6;

CREATE TABLE t7(c2 datetime);
INSERT IGNORE INTO t7 VALUES('2020-01-23 21:29:31'/0);
INSERT IGNORE INTO t7 VALUES('00-00-00 21:29:31'/0);
INSERT IGNORE INTO t7 VALUES('0000-00-00 21:29:31'/0);
INSERT IGNORE INTO t7 VALUES('59-00-00 21:29:31'/0);
SELECT * FROM t7;
DROP TABLE t7;

CREATE TABLE t8(c3 timestamp);
INSERT IGNORE INTO t8 VALUES('2020-01-13 21:29:31'/0);
INSERT IGNORE INTO t8 VALUES('00-00-00 21:29:31'/0);
INSERT IGNORE INTO t8 VALUES('00.00.00 21:29:31'/0);
SELECT * FROM t8;
DROP TABLE t8;
--enable_warnings

############################## TEST CASES  ##############################
## 启用模式 + 严格模式 UPDATE  
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

CREATE TABLE t1 (id1 int ,age1 varchar(20));
INSERT INTO t1 values (56,-451);
--ERROR 0,1365
UPDATE t1 SET id1=56/0;
INSERT INTO t1 values (56,-452);
--ERROR 0,1365
UPDATE t1 SET age1=56/0;
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t2 (id2 tinyint ,age2 smallint);
INSERT  INTO t2 values (56,-451);
--ERROR 0,1365
UPDATE t2 SET id2=56/0;
INSERT IGNORE INTO t2 values (56,-451);
--ERROR 0,1365
UPDATE t2 SET age2=56/0;
SELECT * FROM t2;
DROP TABLE t2;


CREATE TABLE t3 (id3 mediumint, age3 bigint);
INSERT  INTO t3 values (56,-451);
--ERROR 0,1365
UPDATE t3 SET id3=56/0;
INSERT  INTO t3 values (56,-451);
--ERROR 0,1365
UPDATE t3 SET age3=56/0;
SELECT * FROM t3;
DROP TABLE t3;


CREATE TABLE t4 (id4 float, age4 double);
INSERT  INTO t4 values (56,-451);
--ERROR 0,1365
UPDATE t4 SET id4=56/0;
INSERT  INTO t4 values (56,-452);
--ERROR 0,1365
UPDATE t4 SET age4=56/0;
SELECT * FROM t4;
DROP TABLE t4;



