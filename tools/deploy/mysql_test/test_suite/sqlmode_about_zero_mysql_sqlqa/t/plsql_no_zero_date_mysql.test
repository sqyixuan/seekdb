GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############
--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;
--error 0,1051
DROP TABLE t3;
--error 0,1051
DROP TABLE t4;

--error 0,1305
DROP FUNCTION f_test ;
--error 0,1305
drop procedure p_test;

CREATE TABLE t1(c2 datetime);
INSERT INTO t1 VALUES('2020-01-23 21:29:31');
SELECT * FROM t1;

CREATE TABLE t2(c date);
INSERT INTO t2 VALUES('2020-01-12');
SELECT * FROM t2;

CREATE TABLE t3(c3 timestamp);
INSERT INTO t3 VALUES('2020-01-13 21:29:31');
SELECT * FROM t3;


############################## TEST CASES  ##############################
## NO_ZERO_DATE
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES'; 

### 存储函数

DELIMITER //;
CREATE FUNCTION f_test()
returns DATE
begin
	declare a DATE;
	SELECT DATE('0000-00-00') FROM DUAL INTO a;
	return a;
END;
//
DELIMITER ;//
SELECT  f_test();
DROP FUNCTION f_test;


DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT  ADDDATE(samplename, INTERVAL 31 DAY) FROM dual INTO a ;
	return a;
END;
//
DELIMITER ;//
SELECT f_test('0000-00-00');
SELECT f_test('0');
drop function f_test ;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT INTO t1 VALUES('00-00-00');
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1292
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT ignore INTO t1 VALUES('00-00-00');
	return a;
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	UPDATE  t1 SET c2='0000-00-00';
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1292
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	UPDATE IGNORE t1 SET c2='0000-00-00';
	return a;
END;
//
DELIMITER ;//
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT ignore INTO t2 VALUES('0000-00-00');
	return a;
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;
select * from t2;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
RETURNS varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT INTO t2 VALUES('0000-00-00');
	return a;
END;
//
DELIMITER ;//
--ERROR 0,1292
SELECT f_test() FROM dual;
select * from t2;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	UPDATE IGNORE t1 SET c2='0000-00-00';
	return a;
END;
//
DELIMITER ;//
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


### 存储过程

DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	INSERT INTO t2 VALUES('0000-00-00');
END;
//
DELIMITER ;//
--ERROR 0,1292
CALL p_test();
SELECT * FROM t2;
drop procedure p_test;


DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	INSERT ignore INTO t2 VALUES('0000-00-00');
END;
//
DELIMITER ;//
CALL p_test();
SELECT * FROM t2;
drop procedure p_test;


DELIMITER //;
CREATE  PROCEDURE p_test(in samplename  varchar(200))
begin
	INSERT ignore INTO t2 VALUES(samplename);
END;
//
DELIMITER ;//
CALL p_test('0000-00-00');
CALL p_test('0');
SELECT * FROM t2;
drop procedure p_test;


DELIMITER //;
CREATE PROCEDURE p_test()
begin
	UPDATE IGNORE t2 SET c='0000-00-00';
END;
//
DELIMITER ;//
CALL p_test();
SELECT * FROM t2;
drop procedure p_test;

DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user wmj456@'%' ;
--enable_warnings

