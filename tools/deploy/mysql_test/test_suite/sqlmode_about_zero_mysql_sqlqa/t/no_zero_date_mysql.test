############################## TEST CASES  ##############################
## 启用此模式 + 严格模式
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

CREATE TABLE t2(c date,c1 time);
INSERT INTO t2 VALUES('2020-01-12','23:59:59');
--ERROR 0,1292
INSERT INTO t2 VALUES('0000-00-00','21:01:01');
--ERROR 0,1292
INSERT INTO t2 VALUES('0000:00:00','21:01:01');
--ERROR 0,1292
INSERT INTO t2 VALUES('00:00:00','21:01:01');
--ERROR 0,1292
INSERT INTO t2 VALUES('00.00.00','21:01:01');
--ERROR 0,1292
INSERT INTO t2 VALUES('00/00/00','21:01:01');
SELECT * FROM t2;
DROP TABLE t2;


CREATE TABLE t4(c1 time);
--ERROR 0,1292
INSERT INTO t4 VALUES('00-00-00');
--ERROR 0,1292
INSERT INTO t4 VALUES('0000.00.00');
INSERT INTO t4 VALUES('0000:00:00');
INSERT INTO t4 VALUES('00:00:00');
--ERROR 0,1292
INSERT INTO t4 VALUES('00.00.00');
SELECT * FROM t4;
DROP TABLE t4;




############################## TEST CASES  ##############################
## 启用此模式 + 严格模式，使用 INSERT IGNORE
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

CREATE TABLE t2(c date);
INSERT INTO t2 VALUES('2020-01-12');
INSERT IGNORE INTO t2 VALUES('0000-00-00');
INSERT IGNORE INTO t2 VALUES('00-00-00');
INSERT IGNORE INTO t2 VALUES('0000:00:00');
INSERT IGNORE INTO t2 VALUES('00:00:00');
INSERT IGNORE INTO t2 VALUES('00.00.00');
INSERT IGNORE INTO t2 VALUES('00/00/00');
SELECT * FROM t2;
DROP TABLE t2;

CREATE TABLE t4(c1 time);
INSERT IGNORE INTO t4 VALUES('00-00-00');
INSERT IGNORE INTO t4 VALUES('0000.00.00');
INSERT INTO t4 VALUES('0000:00:00');
INSERT INTO t4 VALUES('00:00:00');
INSERT IGNORE INTO t4 VALUES('00.00.00');
SELECT * FROM t4;
DROP TABLE t4;




############################## TEST CASES  ##############################
## 启用此模式 + 严格模式，使用 UPDATE
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

CREATE TABLE t2(b int, c date);
INSERT INTO t2 VALUES(1, '2020-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='0000-00-00';
INSERT INTO t2 VALUES(2, '2021-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='00-00-00';
INSERT INTO t2 VALUES(3, '2022-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='00:00:00';
INSERT INTO t2 VALUES(4, '2023-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='0000:00:00';
INSERT INTO t2 VALUES(5, '2024-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='00.00.00';
INSERT INTO t2 VALUES(5, '2024-01-12');
--ERROR 0,1292
UPDATE  t2 SET c='00/00/00';
SELECT * FROM t2;
DROP TABLE t2;

CREATE TABLE t4(c1 time);
INSERT  INTO t4 VALUES('20:01:12');
UPDATE  t4 SET c1='00-00-00';
INSERT INTO t4 VALUES('2020-01-12');
INSERT  INTO t4 VALUES('00.00.00');
INSERT INTO t4 VALUES('2020-01-12');
UPDATE  t4 SET c1='00:00:00';
INSERT  INTO t4 VALUES('2020-01-12');
UPDATE  t4 SET c1='0000:00:00';
INSERT INTO t4 VALUES('2020-01-12');
UPDATE  t4 SET c1='0000.00.00';
SELECT * FROM t4;
DROP TABLE t4;


############################## TEST CASES  ##############################
## 启用此模式 + 严格模式，使用 UPDATE IGNORE
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

CREATE TABLE t2(b int, c date);
INSERT INTO t2 VALUES(1, '2020-01-12');
UPDATE IGNORE t2 SET c='0000-00-00';
INSERT INTO t2 VALUES(2, '2021-01-12');
UPDATE IGNORE t2 SET c='00-00-00';
INSERT INTO t2 VALUES(3, '2022-01-12');
UPDATE IGNORE t2 SET c='00:00:00';
INSERT INTO t2 VALUES(4, '2023-01-12');
UPDATE IGNORE t2 SET c='0000:00:00';
INSERT INTO t2 VALUES(5, '2024-01-12');
UPDATE IGNORE t2 SET c='00.00.00';
INSERT INTO t2 VALUES(5, '2024-01-12');
UPDATE IGNORE t2 SET c='00/00/00';
SELECT * FROM t2;
DROP TABLE t2;

CREATE TABLE t4(c1 time);
INSERT  INTO t4 VALUES('20:01:12');
UPDATE IGNORE t4 SET c1='00-00-00';
INSERT INTO t4 VALUES('2020-01-12');
INSERT IGNORE INTO t4 VALUES('00.00.00');
INSERT INTO t4 VALUES('2020-01-12');
UPDATE IGNORE t4 SET c1='00:00:00';
INSERT  INTO t4 VALUES('2020-01-12');
UPDATE IGNORE t4 SET c1='0000:00:00';
INSERT INTO t4 VALUES('2020-01-12');
UPDATE IGNORE t4 SET c1='0000.00.00';
SELECT * FROM t4;
DROP TABLE t4;


############################## TEST CASES  ##############################
## 普通表 + 分区表 + 约束
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

--ERROR 0,1067
CREATE TABLE t1 (
    id BIGINT UNSIGNED DEFAULT 0,
    date_1 date DEFAULT '0000-00-00 '
);


CREATE TABLE t1 (
    id BIGINT UNSIGNED DEFAULT 0,
    date_1 varchar(255) DEFAULT '0000-00-00'
);
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1(id) VALUES(2);
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
    a bigint,
        b date
)partition by range columns(b)
(
        partition part_1 values less than ('0000-00-00'),
        partition part_2 values less than ('2020-09-01'),
        partition part_3 values less than ('2021-09-01')
);
INSERT IGNORE INTO t1 VALUES(1, '0000-00-00');
INSERT INTO t1 VALUES(2, '1100-02-12');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
    a bigint,
        b date
)partition by range columns(b)
(
        partition part_1 values less than ('2019-09-01'),
        partition part_2 values less than ('2020-09-01'),
        partition part_3 values less than ('2021-09-01')
);
INSERT IGNORE INTO t1 VALUES(1, '0000-00-00');
INSERT INTO t1 VALUES(2, '1100-02-12');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1 (
    id INT,
    data date
) PARTITION BY LIST(id) (
    PARTITION p0 VALUES IN (5, year('0000-00-00'), 15),
    PARTITION p1 VALUES IN (6, 12, 18)
);
DROP TABLE T1;


CREATE TABLE t1 (
    id INT,
    signed DATETIME
) PARTITION BY HASH( MONTH(signed) )
PARTITIONS 2;
INSERT IGNORE INTO t1 VALUES(1,'0000-00-00');
SELECT * FROM t1;
DROP TABLE t1;


CREATE TABLE t1(
    a INT AUTO_INCREMENT PRIMARY KEY,
        c_time DATE,
    d_time varchar(101) GENERATED ALWAYS AS (DAYOFMONTH(c_time))
);
INSERT IGNORE INTO t1(a, c_time) VALUES(1,'0000-00-00');
SELECT * FROM t1;
DROP TABLE t1;



