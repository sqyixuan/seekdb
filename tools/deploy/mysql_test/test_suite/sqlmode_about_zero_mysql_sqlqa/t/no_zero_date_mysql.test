############################## TEST CASES  ##############################
## SELECT / 函数
SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';

SELECT ADDDATE('0000-00-00',INTERVAL 31 DAY) FROM DUAL;
SELECT ADDDATE('2021-08-01','0000-00-00') FROM DUAL;
SELECT ADDDATE('2021-08-01','0000-00-00') FROM DUAL;
SELECT DATE('0000-00-00');
SELECT DATE('00.00.00');
SELECT DATE('00-00-00');
SELECT DATE_ADD('0000-00-00', INTERVAL 5 MICROSECOND);
SELECT DATE_ADD('0000-00-00', INTERVAL 5 MINUTE);
SELECT DATE_ADD('0000-00-00', INTERVAL 5 HOUR);
SELECT DATE_ADD('0000-00-00', INTERVAL 5 DAY);
SELECT DATE_FORMAT('0000-00-00', '%Y-%M-%d');
SELECT DATE_FORMAT('00.00.00', '%Y-%M-%d');
SELECT DATE_FORMAT('00.00.00', '%X');
SELECT DATE_FORMAT('00.00.00', '%X');
SELECT DATE_SUB('0000-00-00', INTERVAL 5 MICROSECOND);
SELECT DATE_SUB('0000-00-00', INTERVAL 5 HOUR);
SELECT DATE_SUB('0000-00-00', INTERVAL '5.000005' SECOND_MICROSECOND);
SELECT DATEDIFF('0000-00-00','1994-12-17');
SELECT DATEDIFF('1994-12-17','1994-12-17');
SELECT DATEDIFF('1994-12-17','0000-00-00');
SELECT DATEDIFF('0000-00-00','00.00.00');
SELECT DAYOFMONTH('2008-12-31');
# SELECT DAYOFMONTH('0000-00-00');
# SELECT DAYOFWEEK('0000-00-00');
# SELECT DAYOFWEEK('0000.00.00');
# SELECT DAYOFYEAR('0000-00-00');
SELECT EXTRACT(WEEK FROM '0000-00-00');
SELECT EXTRACT(YEAR_MONTH  FROM '0000-00-00');
SELECT EXTRACT(DAY   FROM '0000-00-00');
SELECT DATE_FORMAT('0000-00-00',GET_FORMAT(DATE,'EUR'));
# SELECT STR_TO_DATE('00.00.0000',GET_FORMAT(DATE,'USA'));
SELECT HOUR('00:00:00');
SELECT LAST_DAY('0000-00-00');
SELECT LAST_DAY('0000.00.00');
SELECT MAKEDATE(0000,1);
SELECT MAKEDATE(0000,0);
# SELECT MONTH('0000.00.00');
# SELECT MONTH('0000-00-00');
# SELECT MONTHNAME('0000-00-00');
SELECT PERIOD_ADD(000001,2);
SELECT PERIOD_ADD(000000,2);
SELECT PERIOD_DIFF(000001, 200703);
SELECT PERIOD_DIFF(200000, 200703);
SELECT QUARTER('0000-00-00');
SELECT QUARTER('00-00-00');
SELECT TO_DAYS('0000-00-00');
SELECT WEEKOFYEAR('0000-00-00');
SELECT YEARWEEK('0000-00-00');
SELECT YEARWEEK('0000.00.00');
# SELECT YEAR('0000-00-00');
SELECT CAST('0000' as date) FROM DUAL;
SELECT CAST('0000-00-00' as date) FROM DUAL;
SELECT CONVERT('0000-00-00', datetime) FROM DUAL;


## LIKE / WHERE
CREATE TABLE t1 (id int not null,name varchar(20));
INSERT INTO t1 values (1,'t1a');
INSERT INTO t1 values (2,'t2a');
INSERT INTO t1 values (3,'0000-00-00');
SELECT * FROM t1 WHERE name LIKE CAST('0000-00-00' AS DATE);
SELECT * FROM t1 WHERE name LIKE NULL;
SELECT * FROM t1 WHERE  NULL <=> CAST('0000-00-00' AS DATE);
DROP TABLE t1;

CREATE TABLE t2(c date);
INSERT INTO t2 VALUES('2020-01-12');
SELECT * FROM t2 WHERE c LIKE '%0000-00-00%';
DROP TABLE t2;


############################## TEST CASES  ##############################
## 未启用此模式
SET sql_mode = '';
CREATE TABLE t1 (id int not null,name varchar(20));
INSERT INTO t1 values (1,'t1a');
INSERT INTO t1 values (2,'0000-00-00');
SELECT * FROM t1;
DROP TABLE t1;

CREATE TABLE t2(c date,c1 time);
INSERT INTO t2 VALUES('2020-01-12','23:59:59');
INSERT INTO t2 VALUES('0000-00-00','21:01:01');
SELECT * FROM t2;
DROP TABLE t2;




############################## TEST CASES  ##############################
## 启用该模式
SET sql_mode='NO_ZERO_DATE';

CREATE TABLE t1 (id int not null,name varchar(20));
INSERT INTO t1 values (1,'t1a');
INSERT INTO t1 values (2,'0001-00-00');
SELECT * FROM t1;
DROP TABLE t1;

