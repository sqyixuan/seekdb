# description:  在 ERROR_FOR_DIVISION_BY_ZERO 模式下，测试存储过程、存储函数


--echo #Environmental cleaning
--disable_warnings
--error 0,1396
DROP USER wmj456@'%';
--error 0,1008
DROP DATABASE obwmjtest;
--error 0,1008
DROP DATABASE obwmjtest2;
CREATE DATABASE obwmjtest;
--enable_warnings
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;

--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,wmj456,wmj456,obwmjtest,$OBMYSQL_PORT);
connection conn;


############### Initialize_Environment ###############
--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;
--error 0,1051
DROP TABLE t3;
--error 0,1051
DROP TABLE t4;

--error 0,1305
DROP FUNCTION f_test ;
--error 0,1305
drop procedure p_test;


############################## TEST CASES  ##############################
## DIV_BY_ZERO
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES'; 

CREATE TABLE t1 (id1 int ,age1 varchar(20));
INSERT INTO t1 values (56,-451);
INSERT INTO t1 values (66,32);
SELECT * FROM t1;

### 存储函数

DELIMITER //;
CREATE FUNCTION f_test()
returns DATE
begin
	declare a DATE;
	SELECT LOG(-10/0) FROM DUAL INTO a;
	return a;
END;
//
DELIMITER ;//
SELECT  f_test();
DROP FUNCTION f_test;


DELIMITER //;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
	declare a varchar(200);
	SELECT MOD(samplename,0) FROM DUAL INTO a ;
	return a;
END;
//
DELIMITER ;//
SELECT f_test(13);
SELECT f_test(3);
drop function f_test ;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT INTO t1 VALUES(88,-451/0);
	return a;
END;
//
DELIMITER ;//

--ERROR 0,1365
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	INSERT IGNORE INTO t1 VALUES(88,-451/0);
	return a;
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	UPDATE  t1 SET age1=-451/0;
	return a;
END;
//
DELIMITER ;//
--error 0,1365
SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


DELIMITER //;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
	DECLARE a varchar(200) DEFAULT '2';
	UPDATE IGNORE t1 SET age1=-451/0;
	return a;
END;
//
DELIMITER ;//

SELECT f_test() FROM dual;
select * from t1;
drop function f_test;


### 存储过程

DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	INSERT INTO t1 VALUES(90,MOD(10,0));
END;
//
DELIMITER ;//
--ERROR 0,1365
CALL p_test();
SELECT * FROM t1;
drop procedure p_test;


DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	INSERT IGNORE INTO t1 VALUES(90,MOD(10,0));
END;
//
DELIMITER ;//

CALL p_test();
SELECT * FROM t1;
drop procedure p_test;


DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	UPDATE t1 SET age1=-451/0;
END;
//
DELIMITER ;//
--ERROR 0,1365
CALL p_test();
SELECT * FROM t1;
drop procedure p_test;


DELIMITER //;
CREATE  PROCEDURE p_test()
begin
	UPDATE IGNORE t1 SET age1=-451/0;
END;
//
DELIMITER ;//

CALL p_test();
SELECT * FROM t1;
drop procedure p_test;



--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user wmj456@'%' ;
--enable_warnings



