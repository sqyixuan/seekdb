#Environmental cleaning
DROP USER wmj456@'%';
DROP DATABASE obwmjtest;
DROP DATABASE obwmjtest2;
CREATE DATABASE obwmjtest;
CREATE USER wmj456 IDENTIFIED BY 'wmj456';
GRANT ALL ON *.* TO wmj456 WITH GRANT OPTION;
DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;
DROP TABLE t4;
DROP FUNCTION f_test ;
drop procedure p_test;
SET sql_mode='ERROR_FOR_DIVISION_BY_ZERO,STRICT_ALL_TABLES';
CREATE TABLE t1 (id1 int ,age1 varchar(20));
INSERT INTO t1 values (56,-451);
INSERT INTO t1 values (66,32);
SELECT * FROM t1;
id1	age1
56	-451
66	32
CREATE FUNCTION f_test()
returns DATE
begin
declare a DATE;
SELECT LOG(-10/0) FROM DUAL INTO a;
return a;
END;
//
SELECT  f_test();
f_test()
NULL
DROP FUNCTION f_test;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT MOD(samplename,0) FROM DUAL INTO a ;
return a;
END;
//
SELECT f_test(13);
f_test(13)
NULL
SELECT f_test(3);
f_test(3)
NULL
drop function f_test ;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
DECLARE a varchar(200) DEFAULT '2';
INSERT INTO t1 VALUES(88,-451/0);
return a;
END;
//
SELECT f_test() FROM dual;
select * from t1;
id1	age1
56	-451
66	32
drop function f_test;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
DECLARE a varchar(200) DEFAULT '2';
INSERT IGNORE INTO t1 VALUES(88,-451/0);
return a;
END;
//
SELECT f_test() FROM dual;
f_test()
2
select * from t1;
id1	age1
56	-451
66	32
88	NULL
drop function f_test;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
DECLARE a varchar(200) DEFAULT '2';
UPDATE  t1 SET age1=-451/0;
return a;
END;
//
SELECT f_test() FROM dual;
select * from t1;
id1	age1
56	-451
66	32
88	NULL
drop function f_test;
CREATE FUNCTION f_test()
returns  varchar(200)
begin
DECLARE a varchar(200) DEFAULT '2';
UPDATE IGNORE t1 SET age1=-451/0;
return a;
END;
//
SELECT f_test() FROM dual;
f_test()
2
select * from t1;
id1	age1
56	NULL
66	NULL
88	NULL
drop function f_test;
CREATE  PROCEDURE p_test()
begin
INSERT INTO t1 VALUES(90,MOD(10,0));
END;
//
CALL p_test();
SELECT * FROM t1;
id1	age1
56	NULL
66	NULL
88	NULL
drop procedure p_test;
CREATE  PROCEDURE p_test()
begin
INSERT IGNORE INTO t1 VALUES(90,MOD(10,0));
END;
//
CALL p_test();
SELECT * FROM t1;
id1	age1
56	NULL
66	NULL
88	NULL
90	NULL
drop procedure p_test;
CREATE  PROCEDURE p_test()
begin
UPDATE t1 SET age1=-451/0;
END;
//
CALL p_test();
SELECT * FROM t1;
id1	age1
56	NULL
66	NULL
88	NULL
90	NULL
drop procedure p_test;
CREATE  PROCEDURE p_test()
begin
UPDATE IGNORE t1 SET age1=-451/0;
END;
//
CALL p_test();
SELECT * FROM t1;
id1	age1
56	NULL
66	NULL
88	NULL
90	NULL
drop procedure p_test;
# Clean up users
drop user wmj456@'%' ;
