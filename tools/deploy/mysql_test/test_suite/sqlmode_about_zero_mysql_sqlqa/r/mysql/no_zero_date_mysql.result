SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';
CREATE TABLE t1 (
id BIGINT UNSIGNED DEFAULT 0,
date_1 date DEFAULT '0000-00-00 '
);
CREATE TABLE t1 (
id BIGINT UNSIGNED DEFAULT 0,
date_1 varchar(255) DEFAULT '0000-00-00'
);
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1(id) VALUES(2);
SELECT * FROM t1;
id	date_1
1	0000-00-00
2	0000-00-00
DROP TABLE t1;
CREATE TABLE t1(
a bigint,
b date
)partition by range columns(b)
(
partition part_1 values less than ('0000-00-00'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
INSERT IGNORE INTO t1 VALUES(1, '0000-00-00');
INSERT INTO t1 VALUES(2, '1100-02-12');
SELECT * FROM t1;
a	b
1	0000-00-00
2	1100-02-12
DROP TABLE t1;
CREATE TABLE t1(
a bigint,
b date
)partition by range columns(b)
(
partition part_1 values less than ('2019-09-01'),
partition part_2 values less than ('2020-09-01'),
partition part_3 values less than ('2021-09-01')
);
INSERT IGNORE INTO t1 VALUES(1, '0000-00-00');
INSERT INTO t1 VALUES(2, '1100-02-12');
SELECT * FROM t1;
a	b
1	0000-00-00
2	1100-02-12
DROP TABLE t1;
CREATE TABLE t1 (
id INT,
data date
) PARTITION BY LIST(id) (
PARTITION p0 VALUES IN (5, year('0000-00-00'), 15),
PARTITION p1 VALUES IN (6, 12, 18)
);
