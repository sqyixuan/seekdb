SET sql_mode='NO_ZERO_DATE,STRICT_ALL_TABLES';
CREATE FUNCTION f_test()
returns DATE
begin
declare a DATE;
SELECT DATE('0000-00-00') FROM DUAL INTO a;
return a;
END;
//
SELECT  f_test();
f_test()
NULL
DROP FUNCTION f_test;
CREATE FUNCTION f_test(samplename varchar(200))
returns varchar(200)
begin
declare a varchar(200);
SELECT  ADDDATE(samplename, INTERVAL 31 DAY) FROM dual INTO a ;
return a;
END;
//
SELECT f_test('0000-00-00');
f_test('0000-00-00')
NULL
SELECT f_test('0');
f_test('0')
NULL
drop function f_test ;
