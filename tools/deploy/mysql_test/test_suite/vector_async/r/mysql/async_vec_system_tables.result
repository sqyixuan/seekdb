alter system set ob_vector_memory_limit_percentage = 30;
========== setup ==========
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;

========== 6.1 System Table Queries ==========

=== 6.1.1 __all_vector_index_task - query async index task status ===
create table t1 (
id int primary key,
vec vector(3)
) organization heap;
--- Create async index and generate task ---
create vector index idx1 on t1(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data to trigger async task ---
insert into t1 values (1, '[1.0, 1.0, 1.0]');
insert into t1 values (2, '[2.0, 2.0, 2.0]');
insert into t1 values (3, '[3.0, 3.0, 3.0]');
--- Get table and index IDs ---
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Query __all_vector_index_task (task should be completed or moved to history) ---
active_tasks
0
--- Verify task fields (trigger_type, task_type, status, ret_code) ---
trigger_type	task_type	status	ret_code
drop table t1;

=== 6.1.2 __all_vector_index_task_history - verify completed task history ===
create table t2 (
id int primary key,
vec vector(3)
) organization heap;
create vector index idx2 on t2(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data ---
insert into t2 values (1, '[1.0, 1.0, 1.0]');
insert into t2 values (2, '[2.0, 2.0, 2.0]');
--- Get table IDs ---
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Wait 12 seconds for task to transfer to history table ---
--- Query __all_vector_index_task_history ---
trigger_type	task_type	status	ret_code
history_count
0
drop table t2;

=== 6.1.4 __all_virtual_change_stream_refresh_stat - change stream info ===
create table t4 (
id int primary key,
vec vector(3)
) organization heap;
create vector index idx4 on t4(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data ---
insert into t4 values (1, '[1.0, 1.0, 1.0]');
insert into t4 values (2, '[2.0, 2.0, 2.0]');
insert into t4 values (3, '[3.0, 3.0, 3.0]');
call dbms_index_manager.refresh();
--- Query __all_virtual_change_stream_refresh_stat ---
--- Note: This table contains change stream framework statistics ---
select count(*) as cs_count from oceanbase.__all_virtual_change_stream_refresh_stat;
cs_count
1
drop table t4;

=== 6.1.5 DBA and CDB views ===
create table t5 (
id int primary key,
vec vector(3)
) organization heap;
create vector index idx5 on t5(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data ---
insert into t5 values (1, '[1.0, 1.0, 1.0]');
insert into t5 values (2, '[2.0, 2.0, 2.0]');
call dbms_index_manager.refresh();
--- Query DBA_OB_VECTOR_INDEX_TASKS ---
trigger_type	task_type	status	ret_code
--- Wait for task to move to history ---
--- Query DBA_OB_VECTOR_INDEX_TASK_HISTORY ---
trigger_type	task_type	status	ret_code
--- Query DBA_OB_CHANGE_STREAM_REFRESH_STAT ---
select count(*) as cs_refresh_count from oceanbase.DBA_OB_CHANGE_STREAM_REFRESH_STAT;
cs_refresh_count
1
--- Create sys connection for CDB views ---
drop table t5;

========== 6.2 Internal Table Verification ==========

=== 6.2.1 Verify internal table structure ===
create table t6 (
id int primary key,
vec vector(3),
name varchar(50)
) organization heap;
create vector index idx6 on t6(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert test data ---
insert into t6 values (1, '[1.0, 1.0, 1.0]', 'item1');
insert into t6 values (2, '[2.0, 2.0, 2.0]', 'item2');
insert into t6 values (3, '[3.0, 3.0, 3.0]', 'item3');
call dbms_index_manager.refresh();
--- Verify data in base table ---
select id, name from t6 order by id;
id	name
1	item1
2	item2
3	item3
--- Verify vector search works ---
select id, name from t6 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id	name
1	item1
2	item2
3	item3
--- Query __all_table to find internal index tables ---
select 
table_name,
table_type
from oceanbase.__all_table 
where table_name like '%idx6%' 
order by table_name;
table_name	table_type
__idx_XXXXXX_idx6	5
__idx_XXXXXX_idx6_index_id_table	5
__idx_XXXXXX_idx6_index_snapshot_data_table	5
drop table t6;

=== 6.2.2 Verify internal tables for partitioned table ===
create table t7 (
id int primary key,
vec vector(3)
) organization heap
partition by hash(id) partitions 4;
create vector index idx7 on t7(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data across partitions ---
insert into t7 values (1, '[1.0, 1.0, 1.0]');
insert into t7 values (101, '[2.0, 2.0, 2.0]');
insert into t7 values (201, '[3.0, 3.0, 3.0]');
insert into t7 values (301, '[4.0, 4.0, 4.0]');
call dbms_index_manager.refresh();
--- Verify data across partitions ---
select count(*) from t7;
count(*)
4
select id from t7 order by id;
id
1
101
201
301
--- Verify vector search across partitions ---
select id from t7 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 4;
id
1
101
201
301
--- Query internal tables for partitioned index ---
select 
table_name,
table_type
from oceanbase.__all_table 
where table_name like '%idx7%' 
order by table_name;
table_name	table_type
__idx_XXXXXX_idx7	5
__idx_XXXXXX_idx7_index_id_table	5
__idx_XXXXXX_idx7_index_snapshot_data_table	5
drop table t7;

=== 6.2.5 Multiple async indexes - verify independent sync_info ===
create table t10 (
id int primary key,
vec1 vector(3),
vec2 vector(3)
) organization heap;
create vector index idx10_1 on t10(vec1) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
create vector index idx10_2 on t10(vec2) with (distance=cosine, type=hnsw, lib=vsag, sync_mode=async);
--- Insert data ---
insert into t10 values (1, '[1.0, 1.0, 1.0]', '[10.0, 10.0, 10.0]');
insert into t10 values (2, '[2.0, 2.0, 2.0]', '[20.0, 20.0, 20.0]');
call dbms_index_manager.refresh();
--- Verify both indexes work ---
select id from t10 order by l2_distance(vec1, '[1.0, 1.0, 1.0]') approximate limit 2;
id
1
2
select id from t10 order by cosine_distance(vec2, '[10.0, 10.0, 10.0]') approximate limit 2;
id
1
2
drop table t10;

========== cleanup ==========
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
