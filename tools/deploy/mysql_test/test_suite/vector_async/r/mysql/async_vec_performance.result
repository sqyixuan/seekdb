========== 7. Execute retrieval on all tables ==========
--- 7.1 Retrieval on 128-dim ---
select id from t_perf_128 order by l2_distance(vec, concat('[', repeat('5000.0,', 127), '5000.0]')) approximate limit 5;
--- 7.2 Retrieval on 512-dim ---
select id from t_perf_512 order by l2_distance(vec, concat('[', repeat('1000.0,', 511), '1000.0]')) approximate limit 5;
--- 7.3 Retrieval on 1000-dim ---
select id from t_perf_1000 order by l2_distance(vec, concat('[', repeat('500.0,', 999), '500.0]')) approximate limit 5;
--- 7.4 Retrieval on 2000-dim ---
select id from t_perf_2000 order by l2_distance(vec, concat('[', repeat('250.0,', 1999), '250.0]')) approximate limit 5;
--- 7.5 Retrieval on 4000-dim ---
select id from t_perf_4000 order by l2_distance(vec, concat('[', repeat('250.0,', 3999), '250.0]')) approximate limit 5;
--- 7.6 Retrieval on 4096-dim ---
select id from t_perf_4096 order by l2_distance(vec, concat('[', repeat('250.0,', 4095), '250.0]')) approximate limit 5;

========== Performance Test Cleanup ==========
drop table t_perf_128;
drop table t_perf_512;
drop table t_perf_1000;
drop table t_perf_2000;
drop table t_perf_4000;
drop table t_perf_4096;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
