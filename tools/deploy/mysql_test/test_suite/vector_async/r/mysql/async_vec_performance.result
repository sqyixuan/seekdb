alter system set ob_vector_memory_limit_percentage = 30;
========== Performance Test Setup ==========
drop table if exists t_perf_128;
drop table if exists t_perf_512;
drop table if exists t_perf_1000;
drop table if exists t_perf_2000;
drop table if exists t_perf_4000;
drop table if exists t_perf_4096;

========== 1. Low-dim: 128 dimensions (large data volume) ==========
--- 1.1 Create table with 128-dim vector ---
create table t_perf_128 (
id int primary key,
vec vector(128),
category int,
VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;
--- 1.2 Insert 50000 vectors (128-dim, low-dim large volume) ---
call dbms_index_manager.refresh();
select count(*) as total_rows_128 from t_perf_128;
total_rows_128
50000
--- 1.3 Verify index usage (EXPLAIN) ---
explain basic select id from t_perf_128 order by l2_distance(vec, concat('[', repeat('5000.0,', 127), '5000.0]')) approximate limit 10;
Query Plan
==========================================
|ID|OPERATOR         |NAME               |
------------------------------------------
|0 |VECTOR INDEX SCAN|t_perf_128(idx_vec)|
==========================================
Outputs & filters:
-------------------------------------
  0 - output([t_perf_128.id]), filter(nil), rowset=16
      access([t_perf_128.__pk_increment], [t_perf_128.id]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t_perf_128.__pk_increment], [t_perf_128.__type_0_0]), range(MIN,MIN ; MAX,MAX)always true

