alter system set ob_vector_memory_limit_percentage = 30;
========== setup ==========
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
drop table if exists t8;
drop table if exists t9;
drop table if exists t10;
drop table if exists t11;
drop table if exists t12;

========== 1. Modify table structure ==========

=== 1.1 Add regular column (should not affect async index) ===
create table t1 (
id int primary key,
vec vector(3)
) organization heap;
--- Insert test data ---
insert into t1 values (1, '[1.0, 1.0, 1.0]');
insert into t1 values (2, '[2.0, 2.0, 2.0]');
--- Create async index ---
create vector index idx1 on t1(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify index works ---
select id from t1 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 2;
id
1
2
--- Add regular column ---
alter table t1 add column name varchar(50);
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  `name` varchar(50) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx1` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
--- Update new column ---
update t1 set name = 'item1' where id = 1;
update t1 set name = 'item2' where id = 2;
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify async index still works ---
select id, name from t1 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 2;
id	name
1	item1
2	item2
--- Insert new data with new column ---
insert into t1 values (3, '[3.0, 3.0, 3.0]', 'item3');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify all data is searchable ---
select id, name from t1 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id	name
1	item1
2	item2
3	item3
drop table t1;

=== 1.2 Drop regular column (should not affect async index) ===
create table t2 (
id int primary key,
vec vector(3),
name varchar(50),
score int
) organization heap;
--- Insert test data ---
insert into t2 values (1, '[1.0, 1.0, 1.0]', 'item1', 100);
insert into t2 values (2, '[2.0, 2.0, 2.0]', 'item2', 200);
--- Create async index ---
create vector index idx2 on t2(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify index works ---
select id, name, score from t2 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 2;
id	name	score
1	item1	100
2	item2	200
--- Drop regular column ---
alter table t2 drop column score;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  `name` varchar(50) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx2` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify async index still works ---
select id, name from t2 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 2;
id	name
1	item1
2	item2
drop table t2;

