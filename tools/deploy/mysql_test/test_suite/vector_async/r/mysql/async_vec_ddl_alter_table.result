=== 1.4 Add second vector column with async index ===
create table t4 (
id int primary key,
vec1 vector(3)
) organization heap;
--- Insert test data ---
insert into t4 values (1, '[1.0, 1.0, 1.0]');
insert into t4 values (2, '[2.0, 2.0, 2.0]');
--- Create async index on first vector column ---
create vector index idx4_1 on t4(vec1) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify first index works ---
select id from t4 order by l2_distance(vec1, '[1.0, 1.0, 1.0]') approximate limit 2;
id
1
2
--- Add second vector column ---
alter table t4 add column vec2 vector(3);
show create table t4;
Table	Create Table
t4	CREATE TABLE `t4` (
  `id` int(11) NOT NULL,
  `vec1` VECTOR(3) DEFAULT NULL,
  `vec2` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx4_1` (`vec1`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
--- Update second vector column ---
update t4 set vec2 = '[10.0, 10.0, 10.0]' where id = 1;
update t4 set vec2 = '[20.0, 20.0, 20.0]' where id = 2;
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Create async index on second vector column ---
create vector index idx4_2 on t4(vec2) with (distance=cosine, type=hnsw, lib=vsag, sync_mode=async);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify both indexes work ---
select id from t4 order by l2_distance(vec1, '[1.0, 1.0, 1.0]') approximate limit 2;
id
1
2
select id from t4 order by cosine_distance(vec2, '[10.0, 10.0, 10.0]') approximate limit 2;
id
1
2
drop table t4;

========== 2. Partition operations ==========

=== 2.1 Add partition to RANGE partitioned table ===
create table t6 (
id int primary key,
vec vector(3)
) organization heap
partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200)
);
--- Insert test data ---
insert into t6 values (10, '[1.0, 1.0, 1.0]');
insert into t6 values (110, '[2.0, 2.0, 2.0]');
--- Create async index ---
create vector index idx6 on t6(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify index works ---
select id from t6 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 2;
id
10
110
--- Add new partition ---
alter table t6 add partition (partition p2 values less than (300));
show create table t6;
Table	Create Table
t6	CREATE TABLE `t6` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx6` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p2` values less than (300))
--- Insert data into new partition ---
insert into t6 values (210, '[3.0, 3.0, 3.0]');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify index works across all partitions ---
select count(*) from t6;
count(*)
3
select id from t6 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id
10
110
210
drop table t6;

