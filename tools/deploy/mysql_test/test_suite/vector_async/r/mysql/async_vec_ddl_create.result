========== 3. Partitioned tables ==========

=== 3.1 HASH partition ===
create table t16 (
id int primary key,
vec vector(3),
VECTOR INDEX idx16(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 4;
show create table t16;
Table	Create Table
t16	CREATE TABLE `t16` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx16` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(id)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
drop table t16;

=== 3.2 RANGE partition ===
create table t17 (
id int primary key,
vec vector(3),
VECTOR INDEX idx17(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by range(id) (
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300),
partition p3 values less than maxvalue
);
show create table t17;
Table	Create Table
t17	CREATE TABLE `t17` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx17` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(id)
(partition `p0` values less than (100),
partition `p1` values less than (200),
partition `p2` values less than (300),
partition `p3` values less than (MAXVALUE))
drop table t17;

=== 3.3 Multiple partitions (2 partitions) ===
