  VECTOR KEY `idx22_2` (`vec2`) WITH (DISTANCE=COSINE, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
