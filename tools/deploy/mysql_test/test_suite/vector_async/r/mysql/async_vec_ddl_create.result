=== 2.4 Multiple regular indexes ===
create table t14 (
id int primary key,
vec vector(3),
col1 int,
col2 varchar(100),
INDEX idx_col1(col1),
INDEX idx_col2(col2),
VECTOR INDEX idx14(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t14;
Table	Create Table
t14	CREATE TABLE `t14` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  `col1` int(11) DEFAULT NULL,
  `col2` varchar(100) DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `idx_col1` (`col1`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_col2` (`col2`) BLOCK_SIZE 16384 LOCAL,
  VECTOR KEY `idx14` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
