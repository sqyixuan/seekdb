========== 1. Basic CREATE TABLE with async index ==========

=== 1.1 Different distance functions ===
--- L2 distance ---
create table t1 (
id int primary key,
vec vector(3),
VECTOR INDEX idx1(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx1` (`vec`) WITH (DISTANCE=L2, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t1;
--- Cosine distance ---
create table t2 (
id int primary key,
vec vector(3),
VECTOR INDEX idx2(vec) WITH (distance=cosine, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx2` (`vec`) WITH (DISTANCE=COSINE, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t2;
--- Inner product distance ---
create table t3 (
id int primary key,
vec vector(3),
VECTOR INDEX idx3(vec) WITH (distance=inner_product, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `id` int(11) NOT NULL,
  `vec` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`),
  VECTOR KEY `idx3` (`vec`) WITH (DISTANCE=INNER_PRODUCT, TYPE=HNSW, LIB=VSAG, SYNC_MODE=ASYNC, M=16, EF_CONSTRUCTION=200, EF_SEARCH=64) BLOCK_SIZE 16384
) ORGANIZATION HEAP DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t3;

