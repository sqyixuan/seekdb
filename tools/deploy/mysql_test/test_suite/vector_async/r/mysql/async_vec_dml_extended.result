========== 2.4 REPLACE and ON DUPLICATE KEY UPDATE ==========

=== 2.4.1 REPLACE INTO with primary key conflict ===
create table t15 (
id int primary key,
vec vector(3),
name varchar(50)
) organization heap;
create vector index idx15 on t15(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert initial data ---
insert into t15 values (1, '[1.0, 1.0, 1.0]', 'item1');
insert into t15 values (2, '[2.0, 2.0, 2.0]', 'item2');
insert into t15 values (3, '[3.0, 3.0, 3.0]', 'item3');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify initial state ---
select id, name, vec from t15 order by id;
id	name	vec
1	item1	[1,1,1]
2	item2	[2,2,2]
3	item3	[3,3,3]
select id, name from t15 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id	name
1	item1
2	item2
3	item3
--- REPLACE with primary key conflict (id=1) ---
replace into t15 values (1, '[10.0, 10.0, 10.0]', 'replaced1');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify REPLACE behavior (old vector deleted, new vector inserted) ---
select id, name, vec from t15 order by id;
id	name	vec
1	replaced1	[10,10,10]
2	item2	[2,2,2]
3	item3	[3,3,3]
select id, name from t15 order by l2_distance(vec, '[10.0, 10.0, 10.0]') approximate limit 1;
id	name
1	replaced1
select id, name from t15 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id	name
2	item2
3	item3
1	replaced1
--- REPLACE without conflict (new row) ---
replace into t15 values (4, '[4.0, 4.0, 4.0]', 'item4');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify new row added ---
select count(*) from t15;
count(*)
4
select id, name from t15 order by l2_distance(vec, '[4.0, 4.0, 4.0]') approximate limit 1;
id	name
4	item4
drop table t15;

=== 2.4.2 INSERT ... ON DUPLICATE KEY UPDATE ===
create table t16 (
id int primary key,
vec vector(3),
name varchar(50)
) organization heap;
create vector index idx16 on t16(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert initial data ---
insert into t16 values (1, '[1.0, 1.0, 1.0]', 'item1');
insert into t16 values (2, '[2.0, 2.0, 2.0]', 'item2');
insert into t16 values (3, '[3.0, 3.0, 3.0]', 'item3');
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify initial state ---
select id, name, vec from t16 order by id;
id	name	vec
1	item1	[1,1,1]
2	item2	[2,2,2]
3	item3	[3,3,3]
select id, name from t16 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
id	name
1	item1
2	item2
3	item3
--- INSERT with ON DUPLICATE KEY UPDATE (update vector column) ---
insert into t16 values (1, '[11.0, 11.0, 11.0]', 'new1') 
on duplicate key update vec = '[10.0, 10.0, 10.0]', name = 'updated1';
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify vector updated ---
select id, name, vec from t16 order by id;
id	name	vec
1	updated1	[10,10,10]
2	item2	[2,2,2]
3	item3	[3,3,3]
select id, name from t16 order by l2_distance(vec, '[10.0, 10.0, 10.0]') approximate limit 1;
id	name
1	updated1
--- INSERT with ON DUPLICATE KEY UPDATE (update non-vector column only) ---
insert into t16 values (2, '[22.0, 22.0, 22.0]', 'new2') 
on duplicate key update name = 'updated2';
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify only name updated, vector unchanged ---
select id, name, vec from t16 order by id;
id	name	vec
1	updated1	[10,10,10]
2	updated2	[2,2,2]
3	item3	[3,3,3]
select id, name from t16 order by l2_distance(vec, '[2.0, 2.0, 2.0]') approximate limit 3;
id	name
2	updated2
3	item3
1	updated1
--- INSERT with ON DUPLICATE KEY UPDATE (no conflict, new row) ---
insert into t16 values (4, '[4.0, 4.0, 4.0]', 'item4') 
on duplicate key update vec = '[44.0, 44.0, 44.0]';
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify new row inserted ---
select count(*) from t16;
count(*)
4
select id, name from t16 order by l2_distance(vec, '[4.0, 4.0, 4.0]') approximate limit 1;
id	name
4	item4
drop table t16;

=== 2.4.3 ON DUPLICATE KEY UPDATE with VALUES() function ===
create table t17 (
id int primary key,
vec vector(3),
counter int default 0
) organization heap;
create vector index idx17 on t17(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
--- Insert initial data ---
insert into t17 values (1, '[1.0, 1.0, 1.0]', 1);
insert into t17 values (2, '[2.0, 2.0, 2.0]', 1);
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify initial state ---
select id, vec, counter from t17 order by id;
id	vec	counter
1	[1,1,1]	1
2	[2,2,2]	1
--- INSERT with ON DUPLICATE KEY UPDATE using VALUES() ---
insert into t17 values (1, '[10.0, 10.0, 10.0]', 1) 
on duplicate key update vec = values(vec), counter = counter + 1;
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify vector updated and counter incremented ---
select id, vec, counter from t17 order by id;
id	vec	counter
1	[10,10,10]	2
2	[2,2,2]	1
select id from t17 order by l2_distance(vec, '[10.0, 10.0, 10.0]') approximate limit 2;
id
1
2
--- Repeat ON DUPLICATE KEY UPDATE ---
insert into t17 values (1, '[11.0, 11.0, 11.0]', 1) 
on duplicate key update vec = values(vec), counter = counter + 1;
--- Wait for CDC sync ---
call dbms_index_manager.refresh();
--- Verify vector updated again ---
select id, vec, counter from t17 order by id;
id	vec	counter
1	[11,11,11]	3
2	[2,2,2]	1
select id from t17 order by l2_distance(vec, '[11.0, 11.0, 11.0]') approximate limit 2;
id
1
2
drop table t17;

========== cleanup ==========
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
