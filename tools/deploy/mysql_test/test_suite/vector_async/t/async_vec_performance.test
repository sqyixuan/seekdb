--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: Performance tests for async vector index
#  Strategy: Low-dim (128) inserts large volume; high-dim (512~4096) insert small volume
#  Covers: 128, 512, 1000, 2000, 4000, 4096 dimensions, index build, retrieval
#  Note: Query results omitted due to non-deterministic behavior with large datasets

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== Performance Test Setup ==========
--disable_warnings
drop table if exists t_perf_128;
drop table if exists t_perf_512;
drop table if exists t_perf_1000;
drop table if exists t_perf_2000;
drop table if exists t_perf_4000;
drop table if exists t_perf_4096;
--enable_warnings

--echo
--echo ========== 1. Low-dim: 128 dimensions (large data volume) ==========

--echo --- 1.1 Create table with 128-dim vector ---
create table t_perf_128 (
  id int primary key,
  vec vector(128),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 1.2 Insert 50000 vectors (128-dim, low-dim large volume) ---
--disable_query_log
let $i = 1;
while ($i <= 50000) {
  let $val = $i;
  eval insert into t_perf_128 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 127), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_128 from t_perf_128;

--echo --- 1.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_128 order by l2_distance(vec, concat('[', repeat('5000.0,', 127), '5000.0]')) approximate limit 10;

--echo
--echo ========== 2. Mid-dim: 512 dimensions (medium data volume) ==========

--echo --- 2.1 Create table with 512-dim vector ---
create table t_perf_512 (
  id int primary key,
  vec vector(512),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 2.2 Insert 5000 vectors (512-dim) ---
--disable_query_log
let $i = 1;
while ($i <= 5000) {
  let $val = $i;
  eval insert into t_perf_512 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 511), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_512 from t_perf_512;

--echo --- 2.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_512 order by l2_distance(vec, concat('[', repeat('1000.0,', 511), '1000.0]')) approximate limit 10;

--echo
--echo ========== 3. High-dim: 1000 dimensions (small data volume) ==========

--echo --- 3.1 Create table with 1000-dim vector ---
create table t_perf_1000 (
  id int primary key,
  vec vector(1000),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 3.2 Insert 1000 vectors (1000-dim, high-dim small volume) ---
--disable_query_log
let $i = 1;
while ($i <= 1000) {
  let $val = $i;
  eval insert into t_perf_1000 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 999), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_1000 from t_perf_1000;

--echo --- 3.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_1000 order by l2_distance(vec, concat('[', repeat('500.0,', 999), '500.0]')) approximate limit 10;

--echo
--echo ========== 4. High-dim: 2000 dimensions (small data volume) ==========

--echo --- 4.1 Create table with 2000-dim vector ---
create table t_perf_2000 (
  id int primary key,
  vec vector(2000),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 4.2 Insert 500 vectors (2000-dim) ---
--disable_query_log
let $i = 1;
while ($i <= 500) {
  let $val = $i;
  eval insert into t_perf_2000 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 1999), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_2000 from t_perf_2000;

--echo --- 4.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_2000 order by l2_distance(vec, concat('[', repeat('250.0,', 1999), '250.0]')) approximate limit 10;

--echo
--echo ========== 5. High-dim: 4000 dimensions (small data volume) ==========

--echo --- 5.1 Create table with 4000-dim vector ---
create table t_perf_4000 (
  id int primary key,
  vec vector(4000),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 5.2 Insert 500 vectors (4000-dim) ---
--disable_query_log
let $i = 1;
while ($i <= 500) {
  let $val = $i;
  eval insert into t_perf_4000 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 3999), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_4000 from t_perf_4000;

--echo --- 5.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_4000 order by l2_distance(vec, concat('[', repeat('250.0,', 3999), '250.0]')) approximate limit 10;

--echo
--echo ========== 6. Max-dim: 4096 dimensions (small data volume) ==========

--echo --- 6.1 Create table with 4096-dim vector ---
create table t_perf_4096 (
  id int primary key,
  vec vector(4096),
  category int,
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, M=16)
) organization heap;

--echo --- 6.2 Insert 100 vectors (4096-dim) ---
--disable_query_log
let $i = 1;
while ($i <= 100) {
  let $val = $i;
  eval insert into t_perf_4096 (id, vec, category) values ($i, concat('[', repeat(concat($val, '.0,'), 4095), $val, '.0]'), $i % 10);
  inc $i;
}
--enable_query_log

call dbms_index_manager.refresh();
select count(*) as total_rows_4096 from t_perf_4096;

--echo --- 6.3 Verify index usage (EXPLAIN) ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id from t_perf_4096 order by l2_distance(vec, concat('[', repeat('250.0,', 4095), '250.0]')) approximate limit 10;

--echo
--echo ========== 7. Execute retrieval on all tables ==========

--echo --- 7.1 Retrieval on 128-dim ---
--disable_result_log
select id from t_perf_128 order by l2_distance(vec, concat('[', repeat('5000.0,', 127), '5000.0]')) approximate limit 5;
--enable_result_log

--echo --- 7.2 Retrieval on 512-dim ---
--disable_result_log
select id from t_perf_512 order by l2_distance(vec, concat('[', repeat('1000.0,', 511), '1000.0]')) approximate limit 5;
--enable_result_log

--echo --- 7.3 Retrieval on 1000-dim ---
--disable_result_log
select id from t_perf_1000 order by l2_distance(vec, concat('[', repeat('500.0,', 999), '500.0]')) approximate limit 5;
--enable_result_log

--echo --- 7.4 Retrieval on 2000-dim ---
--disable_result_log
select id from t_perf_2000 order by l2_distance(vec, concat('[', repeat('250.0,', 1999), '250.0]')) approximate limit 5;
--enable_result_log

--echo --- 7.5 Retrieval on 4000-dim ---
--disable_result_log
select id from t_perf_4000 order by l2_distance(vec, concat('[', repeat('250.0,', 3999), '250.0]')) approximate limit 5;
--enable_result_log

--echo --- 7.6 Retrieval on 4096-dim ---
--disable_result_log
select id from t_perf_4096 order by l2_distance(vec, concat('[', repeat('250.0,', 4095), '250.0]')) approximate limit 5;
--enable_result_log

--echo
--echo ========== Performance Test Cleanup ==========
drop table t_perf_128;
drop table t_perf_512;
drop table t_perf_1000;
drop table t_perf_2000;
drop table t_perf_4000;
drop table t_perf_4096;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
