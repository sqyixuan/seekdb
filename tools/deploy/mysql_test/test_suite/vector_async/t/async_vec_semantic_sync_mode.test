--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: verify semantic index supports sync_mode options

--disable_warnings
drop database if exists vec_async_semantic;
create database vec_async_semantic;
use vec_async_semantic;
--enable_warnings

alter system set ob_vector_memory_limit_percentage = 30;

--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');

call DBMS_AI_SERVICE.CREATE_AI_MODEL(
'ob_embed', '{
    "type": "dense_embedding",
    "model_name": "bge-M3"
  }');

call DBMS_AI_SERVICE.CREATE_AI_MODEL_ENDPOINT (
'ob_embed_endpoint', '{
    "ai_model_name": "ob_embed",
    "scope": "all",
    "url": "https://www.baidu.com/",
    "access_key": "sk-xxxxxxxxxxxx",
    "request_model_name": "bge-M3",
    "provider": "openai"
  }');

--echo
--echo "--------------------------------- sync_mode=immediate ---------------------------------"
drop table if exists t_vec;
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=immediate)
) organization heap;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo "--------------------------------- sync_mode=manual ---------------------------------"
drop table if exists t_vec;
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=manual)
) organization heap;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo "--------------------------------- sync_mode=async ---------------------------------"
drop table if exists t_vec;
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=async, sync_interval=5s)
) organization heap;
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo "--------------------------------- post-create index with sync_mode ---------------------------------"
drop table if exists t_vec;
create table t_vec(
  id int primary key,
  doc varchar(100)
) organization heap;
create vector index vec_idx1 on t_vec(doc)
  with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=async, sync_interval=5s);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t_vec;
show index from t_vec;
drop table t_vec;

--echo
--echo "--------------------------------- invalid sync_mode ---------------------------------"
drop table if exists t_vec;
--error 1210
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=abc)
) organization heap;

--error 1210
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=0)
) organization heap;

--error 1210
create table t_vec(
  id int primary key,
  doc varchar(100),
  vector index vec_idx1(doc) with (distance=l2, type=hnsw, model=ob_embed, dim=1024, sync_mode=async, sync_interval=0s)
) organization heap;

--echo
--echo "--------------------------------- cleanup ---------------------------------"
--error 0,11112
call DBMS_AI_SERVICE.DROP_AI_MODEL_ENDPOINT ('ob_embed_endpoint');
--error 0,11118
call DBMS_AI_SERVICE.DROP_AI_MODEL ('ob_embed');
drop database vec_async_semantic;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
