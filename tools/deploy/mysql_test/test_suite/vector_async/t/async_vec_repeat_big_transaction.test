--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: Repeat big-transaction-like async vector index scenario

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== setup ==========
--disable_warnings
drop table if exists t_big_txn_4096d;
--enable_warnings

--echo
--echo ========== repeat 50 times ==========
--disable_query_log
let $i = 1;
while ($i <= 50) {
  --echo --- iteration $i ---
  drop table if exists t_big_txn_4096d;
  create table t_big_txn_4096d (
    id int primary key,
    vec vector(4096),
    name varchar(64),
    VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, m=16)
  ) organization heap;

  insert into t_big_txn_4096d values (1, concat('[', repeat(concat(1, '.0,'), 4095), 1, '.0]'), concat('item_', 1));
  insert into t_big_txn_4096d values (2, concat('[', repeat(concat(2, '.0,'), 4095), 2, '.0]'), concat('item_', 1));
  insert into t_big_txn_4096d values (3, concat('[', repeat(concat(3, '.0,'), 4095), 3, '.0]'), concat('item_', 1));

  call dbms_index_manager.refresh();

  select id, name from t_big_txn_4096d order by l2_distance(vec, concat('[', repeat('1.0,', 4095), '3.0]')) limit 3;
  inc $i;
}
--enable_query_log

--echo
--echo ========== cleanup ==========
drop table if exists t_big_txn_4096d;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
