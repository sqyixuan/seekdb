--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: Async vector index dimension boundary and over-limit tests

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== setup ==========
--disable_warnings
drop table if exists t_async_dim_4096;
drop table if exists t_async_dim_4097;
drop table if exists t_async_dim_5000;
drop table if exists t_async_dim_10000;
--enable_warnings

--echo
--echo ========== 1. 4096 dimension (max supported) ==========
create table t_async_dim_4096 (
  id int primary key,
  vec vector(4096),
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200, m=16)
) organization heap;

--echo --- insert small amount of data ---
insert into t_async_dim_4096 values (1, concat('[', repeat('1.0,', 4095), '1.0]'));
insert into t_async_dim_4096 values (2, concat('[', repeat('2.0,', 4095), '2.0]'));
insert into t_async_dim_4096 values (3, concat('[', repeat('3.0,', 4095), '3.0]'));

call dbms_index_manager.refresh();

--echo --- explain retrieval with async index ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g /, $/,/g
explain basic select id
  from t_async_dim_4096
  order by l2_distance(vec, concat('[', repeat('1.5,', 4095), '1.5]'))
  approximate limit 2;

--echo
--echo ========== 2. 4097 dimension (should fail) ==========
--error 1235
create table t_async_dim_4097 (
  id int primary key,
  vec vector(4097),
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo
--echo ========== 3. 5000 dimension (should fail) ==========
--error 1235
create table t_async_dim_5000 (
  id int primary key,
  vec vector(5000),
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo
--echo ========== 4. 10000 dimension (should fail) ==========
--error 1235
create table t_async_dim_10000 (
  id int primary key,
  vec vector(10000),
  VECTOR INDEX idx_vec(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo
--echo ========== cleanup ==========
drop table if exists t_async_dim_4096;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
