--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: Regression test for async vector index with PDML APPEND insert-select

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== setup ==========
--disable_warnings
drop table if exists test3;
drop table if exists test4;
--enable_warnings

create table test3 (
  id int primary key,
  vec vector(3),
  name varchar(64)
) organization heap;

insert into test3 values (1, '[1.0, 1.0, 1.0]', 'item_1');
insert into test3 values (2, '[2.0, 2.0, 2.0]', 'item_2');
insert into test3 values (3, '[3.0, 3.0, 3.0]', 'item_3');
insert into test3 values (4, '[4.0, 4.0, 4.0]', 'item_4');

create table test4 (
  id int primary key,
  vec vector(3),
  name varchar(64),
  vector index idx_vec(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo
--echo ========== PDML APPEND insert-select ==========
begin;
INSERT /*+ enable_parallel_dml parallel(2) APPEND*/ INTO test4 SELECT * FROM test3;
commit;

select count(*) from test4;
select id, name from test4 order by id;

call dbms_index_manager.refresh();
select id, name from test4 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;

--echo
--echo ========== cleanup ==========
drop table test3;
drop table test4;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
