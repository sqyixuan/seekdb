--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: Repeat drop/create table + async vector index scenario

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== setup ==========
--disable_warnings
drop table if exists t8;
--enable_warnings

--echo
--echo ========== repeat 20 times ==========
--disable_query_log
let $i = 1;
while ($i <= 20) {
  drop table if exists t8;
  create table t8 (
      id int primary key,
      vec vector(3),
      name varchar(50)
    ) organization heap
    partition by range(id) (
      partition p0 values less than (100),
      partition p1 values less than (200)
    );
  insert into t8 values (10, '[1.0, 1.0, 1.0]', 'item1');
  insert into t8 values (20, '[1.5, 1.5, 1.5]', 'item2');
  insert into t8 values (110, '[2.0, 2.0, 2.0]', 'item3');
  create vector index idx8 on t8(vec) with (distance=l2, type=hnsw, lib=vsag, sync_mode=async);
  call dbms_index_manager.refresh();
  select id, name from t8 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
  inc $i;
}
--enable_query_log

--echo
--echo ========== cleanup ==========
drop table if exists t8;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
