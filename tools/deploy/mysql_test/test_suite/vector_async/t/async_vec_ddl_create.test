--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: lana.lgx
#owner group: seekdb
#description: DDL tests for creating async vector index at table creation time
#  Covers: basic CREATE TABLE with async index, constraints, partitions, multiple vectors, error cases

connection default;
alter system set ob_vector_memory_limit_percentage = 30;

--echo ========== setup ==========
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t7;
drop table if exists t8;
drop table if exists t9;
drop table if exists t10;
drop table if exists t11;
drop table if exists t12;
drop table if exists t13;
drop table if exists t14;
drop table if exists t15;
drop table if exists t16;
drop table if exists t17;
drop table if exists t18;
drop table if exists t19;
drop table if exists t20;
--enable_warnings

--echo
--echo ========== 1. Basic CREATE TABLE with async index ==========
--echo
--echo === 1.1 Different distance functions ===

--echo --- L2 distance ---
create table t1 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx1(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t1;
drop table t1;

--echo --- Cosine distance ---
create table t2 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx2(vec) WITH (distance=cosine, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t2;
drop table t2;

--echo --- Inner product distance ---
create table t3 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx3(vec) WITH (distance=inner_product, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t3;
drop table t3;

--echo
--echo === 1.2 Different dimensions ===

--echo --- Dimension 3 ---
create table t4 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx4(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t4;
drop table t4;

--echo --- Dimension 10 ---
create table t5 (
  id int primary key,
  vec vector(10),
  VECTOR INDEX idx5(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t5;
drop table t5;

--echo --- Dimension 128 ---
create table t6 (
  id int primary key,
  vec vector(128),
  VECTOR INDEX idx6(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t6;
drop table t6;

--echo
--echo === 1.3 HNSW parameters ===

--echo --- With m parameter ---
create table t7 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx7(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, m=16)
) organization heap;
show create table t7;
drop table t7;

--echo --- With ef_construction parameter ---
create table t8 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx8(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_construction=200)
) organization heap;
show create table t8;
drop table t8;

--echo --- With ef_search parameter ---
create table t9 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx9(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, ef_search=100)
) organization heap;
show create table t9;
drop table t9;

--echo --- With all HNSW parameters ---
create table t10 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx10(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async, m=16, ef_construction=200, ef_search=100)
) organization heap;
show create table t10;
drop table t10;

--echo
--echo ========== 2. CREATE TABLE with constraints ==========
--echo
--echo === 2.1 Vector column with NOT NULL constraint ===
create table t11 (
  id int primary key,
  vec vector(3) not null,
  VECTOR INDEX idx11(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t11;
drop table t11;

--echo
--echo === 2.2 Other columns with DEFAULT constraint ===
create table t12 (
  id int primary key,
  vec vector(3),
  name varchar(100) default 'unknown',
  score int default 0,
  VECTOR INDEX idx12(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t12;
drop table t12;

--echo
--echo === 2.3 Column with UNIQUE index ===
create table t13 (
  id int primary key,
  vec vector(3),
  code varchar(50) unique,
  VECTOR INDEX idx13(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t13;
drop table t13;

--echo
--echo === 2.4 Multiple regular indexes ===
create table t14 (
  id int primary key,
  vec vector(3),
  col1 int,
  col2 varchar(100),
  INDEX idx_col1(col1),
  INDEX idx_col2(col2),
  VECTOR INDEX idx14(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t14;
drop table t14;

--echo
--echo === 2.5 Combined constraints ===
create table t15 (
  id int primary key,
  vec vector(3) not null,
  name varchar(100) default 'test',
  code varchar(50) unique,
  col1 int,
  INDEX idx_col1(col1),
  VECTOR INDEX idx15(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t15;
drop table t15;

--echo
--echo ========== 3. Partitioned tables ==========
--echo
--echo === 3.1 HASH partition ===
create table t16 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx16(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 4;
show create table t16;
drop table t16;

--echo
--echo === 3.2 RANGE partition ===
create table t17 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx17(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by range(id) (
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than maxvalue
);
show create table t17;
drop table t17;

--echo
--echo === 3.3 Multiple partitions (2 partitions) ===
create table t18 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx18(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 2;
show create table t18;
drop table t18;

--echo
--echo === 3.4 Multiple partitions (3+ partitions) ===
create table t19 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx19(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 8;
show create table t19;
drop table t19;

--echo
--echo === 3.5 Partition key is primary key ===
create table t20 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx20(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 4;
show create table t20;
drop table t20;

--echo
--echo ========== 4. Multiple vector columns and indexes ==========
--echo
--echo === 4.1 Multiple vector columns with async indexes ===
create table t22 (
  id int primary key,
  vec1 vector(3),
  vec2 vector(3),
  VECTOR INDEX idx22_1(vec1) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async),
  VECTOR INDEX idx22_2(vec2) WITH (distance=cosine, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t22;
drop table t22;

--echo
--echo === 4.2 Mixed async and immediate indexes ===
create table t23 (
  id int primary key,
  vec1 vector(3),
  vec2 vector(3),
  VECTOR INDEX idx23_1(vec1) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async),
  VECTOR INDEX idx23_2(vec2) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=immediate)
) organization heap;
show create table t23;
drop table t23;

--echo
--echo ========== 5. Error scenarios ==========
--echo
--echo === 5.1 Non-heap table with async index (should error) ===
--error ER_NOT_SUPPORTED_YET
create table t24 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx24(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
);

--echo
--echo === 5.2 Heap table without primary key with async index ===
--echo --- Test behavior: should this work or error? ---
create table t25 (
  id int,
  vec vector(3),
  VECTOR INDEX idx25(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;
show create table t25;
drop table t25;

--echo
--echo ========== 6. Functional test: Create table and insert data ==========
--echo
create table t28 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx28(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo --- Insert test data ---
insert into t28 values (1, '[1.0, 1.0, 1.0]');
insert into t28 values (2, '[2.0, 2.0, 2.0]');
insert into t28 values (3, '[3.0, 3.0, 3.0]');

--echo --- Wait for CDC sync ---
call dbms_index_manager.refresh();

--echo --- Verify vector search works ---
--replace_regex /__type_[0-9]+_[0-9]+/__type_0_0/g
explain basic select id, vec from t28 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;
select id, vec from t28 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 3;

--echo
--echo ========== 7. Functional test: Partition table with data ==========
--echo
create table t29 (
  id int primary key,
  vec vector(3),
  VECTOR INDEX idx29(vec) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async)
) organization heap
partition by hash(id) partitions 4;

--echo --- Insert data into different partitions ---
insert into t29 values (1, '[1.0, 1.0, 1.0]');
insert into t29 values (101, '[2.0, 2.0, 2.0]');
insert into t29 values (201, '[3.0, 3.0, 3.0]');
insert into t29 values (301, '[4.0, 4.0, 4.0]');

--echo --- Wait for CDC sync ---
call dbms_index_manager.refresh();

--echo --- Verify vector search works across partitions ---
select id, vec from t29 order by l2_distance(vec, '[1.0, 1.0, 1.0]') approximate limit 4;

--echo
--echo ========== 8. Functional test: Multiple vector columns ==========
--echo
create table t30 (
  id int primary key,
  vec1 vector(3),
  vec2 vector(3),
  VECTOR INDEX idx30_1(vec1) WITH (distance=l2, type=hnsw, lib=vsag, sync_mode=async),
  VECTOR INDEX idx30_2(vec2) WITH (distance=cosine, type=hnsw, lib=vsag, sync_mode=async)
) organization heap;

--echo --- Insert test data ---
insert into t30 values (1, '[1.0, 1.0, 1.0]', '[2.0, 2.0, 2.0]');
insert into t30 values (2, '[3.0, 3.0, 3.0]', '[4.0, 4.0, 4.0]');

--echo --- Wait for CDC sync ---
call dbms_index_manager.refresh();

--echo --- Verify both indexes work ---
select id, vec1 from t30 order by l2_distance(vec1, '[1.0, 1.0, 1.0]') approximate limit 2;
select id, vec2 from t30 order by cosine_distance(vec2, '[2.0, 2.0, 2.0]') approximate limit 2;


--echo
--echo ========== cleanup ==========
drop table if exists t28;
drop table if exists t29;
drop table if exists t30;
alter system set ob_vector_memory_limit_percentage = 0;
PURGE RECYCLEBIN;
