##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete 单表
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int primary key,c2 varchar(60));
insert into t1 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;

--echo  #delete...order by...limit ?,?/limit ? 没有进行batch 优化
delimiter //;
delete from t1 order by c1 limit 1;delete from t1 order by c1 limit 1;delete from t1 order by c1 limit 1;//
delete from t1 order by c1 limit 1;delete from t1 order by c1 limit 1;delete from t1 order by c1 limit 1;//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 order by c1 limit %' order by hit_count;
rollback;

drop table t1;



--echo  #delete ..where
create table t2(c1 decimal(5,3) not null,c2 double);
insert into t2 values(10.222,1.123),(20.222,2.234),(30.333,3.456),(1.1234,5.2);
commit;

--echo  #where条件精度不同场景回退
delimiter //;
delete from t2 where c1 = 10.222;delete from t2 where c1 = 20.222;delete from t2 where c1 = 30.333;//
delete from t2 where c1 = 10.222;delete from t2 where c1 = 1.1234;delete from t2 where c1 = 30.333;//
delimiter ;//
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
rollback;
drop table t2;


create table t3(c1 decimal(5,3) not null,c2 double);
insert into t3 values(10.222,1.123),(20.222,2.234),(30.333,3.456),(1.1234,5.2);
commit;

--echo  #delete ...where c1 = ?+?
alter system flush plan cache global;
delimiter //;
delete from t3 where c2 = 1+0.123;delete from t3 where c2 = 2+0.234;delete from t3 where c2 = 3+0.456;//
delete from t3 where c2 = 1+0.123;delete from t3 where c2 = 5+0.2;delete from t3 where c2 = 3+0.456;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c2 = %' order by hit_count;
rollback;
drop table t3;


create table t4(c1 int not null default '8',c2 char(20));
insert into t4 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
insert into t4(c2) values('2020-02-02'),('2021');
commit;

--echo  #delete ...where c1 = ?*?*? or ?/?/? or ?%?%?
delimiter //;
delete from t4 where c1 = 6-1-1;delete from t4 where c1 = 10-2-1;delete from t4 where c1 = 8-3-0;//
delete from t4 where c1 = 1*2*3;delete from t4 where c1 = 2*2*2;delete from t4 where c1 = 3*1*3;//
delete from t4 where c1 = 9/3/3;delete from t4 where c1 = 8/2/2;delete from t4 where c1 = 12/2/2;//
delete from t4 where c1 = 9%6%2;delete from t4 where c1 = 11%6%3;delete from t4 where c1 = 25%9%4;//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = %' order by hit_count;
rollback;
drop table t4;



create table t5(c1 int primary key auto_increment,c2 varchar(60))partition by hash(c1)
(partition p1,
partition p2,
partition p3
);
insert into t5 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;

--echo  #delete ...where ..and....
delimiter //;
delete from t5 where c1 = 4 and c2 = 'DD';delete from t5 where c1 = 2 and c2 = 'AA';delete from t5 where c1 = 3 and c2 = 'CC';//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % and c2 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t5 where c1 = 4 and c2 = 'DD';delete from t5 where c1 = 2 and c2 = 'AD';delete from t5 where c1 = 3 and c2 = 'CC';//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % and c2 = %' order by hit_count;
rollback;


#--echo  #delete ...where ..or....
#delimiter //;
#delete from t5 where c1 = 1 or c1 = 3;delete from t5 where c1 = 2 or c1 = 5;delete from t5 where c1 = 7 or c1 = 9;//
#delete from t5 where c1 = 1 or c1 = 3 and c2 = 'CC';delete from t5 where c1 = 2 or c1 = 5 and c2 = '杭州';delete from t5 where c1 = 7 or c1 = 9 and c2 = 'JJJ';//
#delimiter ;//
#select * from t5;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % or c1 = %' order by hit_count;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % or c1 = % and c2 = %' order by hit_count;
#rollback;

--echo  #delete 重复行(batch场景回退)
alter system flush plan cache global;
delimiter //;
delete from t5 where c1 = 1 or c1 = 3;delete from t5 where c1 = 2 or c1 = 3;delete from t5 where c1 = 7 or c1 = 9;//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % or c1 = %' order by hit_count;
rollback;
drop table t5;


create table t6(c1 float not null,c2 datetime not null);
insert into t6 values(2.222,'2022-06-09'),(3.333,'2022-07-09'),(5.555,'2022-08-08'),(6.678,'1998-09-09'),(7.221,'2000-10-10'),(8.666,'2001-01-01'),(9.678,'2002-02-02'),(10.001,'2010-10-10'),(11.645,'2016-06-06'),(12.111,'2018-08-08');
commit;

--echo  #delete...where...and...order by...limit  没有进行batch优化
delimiter //;
delete from t6 where c1 > 3 and c1 < 5 order by c1 desc limit 1;delete from t6 where c1 > 6 and c1 < 8 order by c1 desc limit 1;delete from t6 where c1 > 10 and c1 < 12 order by c1 desc limit 1;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c1 > % and c1 < % order by c1 desc limit %' order by hit_count;
select * from t6;
rollback;
drop table t6;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;





