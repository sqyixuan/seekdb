##owner: laibingzheng.lbz
##owner group: SQL2
##description: 不同数据类型
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;



drop table if exists t1;
--echo	#float、double、decimal
create table t1 (c1 float primary key,c2 double not null,c3 decimal(5,3),key index_c1_c2(c1,c2));
create index index_c3 on t1(c3);
insert into t1 values(1.111,1.111,1.111),(2.111,2.222,2.333),(3.111,3.222,3.333),(4.111,4.222,4.333),(5.111,5.222,5.333),(6.111,6.222,6.333),(7.1,7.2,7.3);
insert into t1 values(11.111,11.111,11.111),(12.111,12.222,12.333),(13.111,13.222,13.333),(14.111,14.222,14.333),(15.111,15.222,15.333),(16.111,16.222,16.333),(17.1,17.2,17.3);
commit;

alter system flush plan cache global;
--echo  #delete where条件精度不同 batch场景回退,where 条件后 +计算 batch场景回退。
delimiter //;
delete from t1 where c1 = 1.111;delete from t1 where c1 = 2.111;delete from t1 where c1 = 3.111;//
delete from t1 where c1 = 4.111;delete from t1 where c1 = 5.111;delete from t1 where c1 = 7.1;//
delete from t1 where c1 = 10+1.111;delete from t1 where c1 = 11+1.111;delete from t1 where c1 = 12+1.111;//
delimiter ;//
select c1 from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
rollback;


--echo  #double类型,where条件后精度不同回退
delimiter //;
delete from t1 where c2 = 1.111;delete from t1 where c2 = 2.222;delete from t1 where c2 = 3.222;//
delete from t1 where c2 = 4.222;delete from t1 where c2 = 5.222;delete from t1 where c2 = 7.20000;//
delete from t1 where c2 = 10+1.111;delete from t1 where c2 = 11+1.222;delete from t1 where c2 = 12+1.222;//
delimiter ;//
select c2 from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c2 = %' order by hit_count;
rollback;


--echo  #decimal,where条件后精度不同回退
delimiter //;
delete from t1 where c3 = 1.111;delete from t1 where c3 = 2.333;delete from t1 where c3 = 3.333;//
delete from t1 where c3 = 5.333;delete from t1 where c3 = 6.333;delete from t1 where c3 = 7.30;//
delete from t1 where c3 = 13+1.333;delete from t1 where c3 = 14+1.333;delete from t1 where c3 = 15+1.333;//
delimiter ;//
select c3 from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c3 = %' order by hit_count;
rollback;

drop table t1;


--echo	#datetime、year、timestamp
create table t2 (c1 datetime not null,c2 year ,c3 timestamp not null,primary key(c1,c2))
partition by key(c1)
partitions 3;
insert into t2 values('2000-01-01','2000','2000-01-01'),('2001-01-01','2001','2001-01-01'),('2002-01-01','2002','2002-01-01'),('2003-01-01','2003','2003-01-01'),('2004-01-01','2004','2004-01-01'),('2005-01-01','2005','2005-01-01');
commit;
insert into t2 values('2006-01-01','2006','2006-01-01'),('2007-01-01','2007','2007-01-01'),('2008-01-01','2008','2008-01-01'),('2009-01-01 10:10:00','2009','2009-01-01'),('2010-01-01','2010','2010-01-01 01:01:01'),('2011-01-01','2011','2011-01-01');
commit;


delimiter //;
delete from t2 where c1 = '2000-01-01';delete from t2 where c1 = '2001-01-01';delete from t2 where c1 = '2002-01-01';//
delete from t2 where c1 = '2006-01-01';delete from t2 where c1 = '2009-01-01 10:10:00';delete from t2 where c1 = '2010-01-01';//
delimiter ;//
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
rollback;

drop table t2;



create table t3 (c1 datetime not null,c2 year,c3 timestamp not null,primary key(c1,c2),index index_c2(c2))
partition by hash(c2)
partitions 3;
insert into t3 values('2000-01-01','2000','2000-01-01'),('2001-01-01','2001','2001-01-01'),('2002-01-01','2002','2002-01-01'),('2003-01-01','2003','2003-01-01'),('2004-01-01','2004','2004-01-01'),('2005-01-01','2005','2005-01-01');
commit;
insert into t3 values('2006-01-01','2006','2006-01-01'),('2007-01-01','2007','2007-01-01'),('2008-01-01','2008','2008-01-01'),('2009-01-01 10:10:00','2009','2009-01-01'),('2010-01-01','2010','2010-01-01 01:01:01'),('2011-01-01','2011','2011-01-01');
commit;


alter system flush plan cache global;
delimiter //;
delete from t3 where c2 = '2001';delete from t3 where c2 = '2002';delete from t3 where c2 = '2003';//
delete from t3 where c2 = '2001'+9;delete from t3 where c2 = '2002'+5;delete from t3 where c2 = '2003'+6;//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c2 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t3 where c2 = 2004;delete from t3 where c2 = 2005;delete from t3 where c2 = 2006;//
delete from t3 where c2 = '2001'+'7';delete from t3 where c2 = '2002'+'9';delete from t3 where c2 = '1999'+'1';//
delimiter ;//
select * from t3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c2 = %' order by hit_count;
rollback;
drop table t3;




create table t4 (c1 datetime not null,c2 year ,c3 timestamp not null,primary key(c3))
partition by key(c3)
partitions 3;
create index index_c3 on t4(c3);
insert into t4 values('2000-01-01','2000','2000-01-01'),('2001-01-01','2001','2001-01-01'),('2002-01-01','2002','2002-01-01'),('2003-01-01','2003','2003-01-01'),('2004-01-01','2004','2004-01-01'),('2005-01-01','2005','2005-01-01');
commit;
insert into t4 values('2006-01-01','2006','2006-01-01'),('2007-01-01','2007','2007-01-01'),('2008-01-01','2008','2008-01-01'),('2009-01-01 10:10:00','2009','2009-01-01'),('2010-01-01','2010','2010-01-01 01:01:01'),('2011-01-01','2011','2011-01-01');
commit;


delimiter //;
delete from t4 where c1 = '2000-01-01';delete from t4 where c1 = '2001-01-01';delete from t4 where c1 = '2002-01-01';//
delete from t4 where c1 = '2006-01-01';delete from t4 where c1 = '2010-01-01 01:01:01';delete from t4 where c1 = '2010-01-01';//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = %' order by hit_count;
rollback;

drop table t4;




alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


