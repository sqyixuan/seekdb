##owner: laibingzheng.lbz
##owner group: SQL2
##description: 复制表中测试
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int primary key,c2 varchar(60));
create table tt1 as select * from t1;
insert into tt1 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table tt2 (a1 int primary key auto_increment,a2 varchar(60) not null);
insert into tt2(a2) values('AA'),('BB'),('正在'),('单独'),('方法'),('算数'),('##$$'),(';;l'),('3121/+651'),('mgsg《'),('asd123'),('王w@'),('ACD啊#￥');
commit;

--echo  #delete+关联子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt2 as a where a.a1 = (select c1 from tt1 where tt1.c1 = a.a1 and a.a1 = 1);delete a from tt2 as a where a.a1 = (select c1 from tt1 where tt1.c1 = a.a1 and a.a1 = 2);delete a from tt2 as a where a.a1 = (select c1 from tt1 where tt1.c1 = a.a1 and a.a1 = 3);//
delete a from tt2 as a where a.a1 > (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 6);delete a from tt2 as a where a.a1 > (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 8);delete a from tt2 as a where a.a1 > (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 10);//
delete a from tt2 as a where a.a1 >= (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 6);delete a from tt2 as a where a.a1 >= (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 8);delete a from tt2 as a where a.a1 >= (select min(c1) from tt1 where tt1.c1 = a.a1 and c1 > 10);//
delete a from tt2 as a where a.a1 < any(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 5);delete a from tt2 as a where a.a1 < any(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 6);delete a from tt2 as a where a.a1 < any(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 7);//
delete a from tt2 as a where a.a1 <= all(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 5 and c1 > 3);delete a from tt2 as a where a.a1 <= all(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 6 and c1 >1);delete a from tt2 as a where a.a1 <= all(select max(c1) from tt1 where tt1.c1 = a.a1 and c1 < 7 and c1 > 4);//
delimiter ;//
select * from tt2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt2 as a where %' order by hit_count;
rollback;
drop table tt1;
drop table tt2;




create table t3(c1 char(10) not null,c2 varchar(10));
create table tt3 as select * from t3;
create table t4(a1 char(10) not null,a2 varchar(10));
create table tt4 as select * from t4;
insert into tt3 values('aa','张三'),('bb','李四'),('cc','王五'),('dd','马六'),('ee','田七');
insert into tt4 values('aa','张三'),('bb','四'),('cc','王五'),('dd','六'),('ee','田七');
commit;

--echo  #delete + in关键字子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt4 as a where a.a1 in (select c1 from tt3 where tt3.c1 = a.a1 and tt3.c1 = 'aa');delete a from tt4 as a where a.a1 in (select c1 from tt3 where tt3.c1 = a.a1 and tt3.c1 = 'bb');delete a from tt4 as a where a.a1 in (select c1 from tt3 where tt3.c1 = a.a1 and tt3.c1 = 'cc');//
delete a from tt4 as a where a.a1 not in (select c1 from tt3 where tt3.c1 = a.a1 and tt3.c1 = 'aa');delete a from tt4 as a where a.a1 not in (select c1 from tt3 where tt3.c1 = a.a1 and tt3.c1 = 'dd');//
delimiter ;//
select * from tt4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt4 as a where a.a1 in %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt4 as a where a.a1 not in %' order by hit_count;
rollback;
drop table tt3;
drop table tt4;


create table t5(c1 varbinary(30) primary key,c2 binary(30));
create table tt5 as select * from t5;
create table t6(a1 varbinary(30) not null ,a2 binary(30));
create table tt6 as select * from t6;
insert into tt5 values(101,101),(202,202),(303,303),(404,404),(505,505),(606,606);
insert into tt6 values(101,101),(202,202),(303,303),(505,505),(606,606);
commit;

--echo  #delete+any子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt6 as a where a.a1 = any (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 101);delete a from tt6 as a where a.a1 = any (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 202);delete a from tt6 as a where a.a1 = any (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 303);//
delete a from tt6 as a where a.a1 = all (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 202);delete a from tt6 as a where a.a1 = all (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 303);delete a from tt6 as a where a.a1 = all (select c1 from tt5 where tt5.c1 = a.a1 and tt5.c1 = 404);//
delimiter ;//
select * from tt6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt6 as a where a.a1 = %' order by hit_count;
rollback;
drop table tt5;
drop table tt6;



create table t7(c1 year not null primary key , c2 date not null,index index_c1(c1));
create table t8(a1 year not null primary key , a2 date not null,index index_a1(a1));
create table tt7 as select * from t7;
create table tt8 as select * from t8;
insert into tt7 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into tt8 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');
commit;

--echo  #delete+some子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt8 as a where a.a1 = some (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2017);delete a from tt8 as a where a.a1 = some (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2019);delete a from tt8 as a where a.a1 = some (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2020);//
delimiter ;//
select * from tt8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt8 as a where a.a1 = %' order by hit_count;
rollback;


--echo  #delete+exists子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt8 as a where a.a1 = exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2017);delete a from tt8 as a where a.a1 = exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2020);delete a from tt8 as a where a.a1 = exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c1 = 2019);//
delete a from tt8 as a where  not exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c2 = '2017-08-08');delete a from tt8 as a where  not exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c2 = '2019-08-08');delete a from tt8 as a where  not exists (select c1 from tt7 where tt7.c1 = a.a1 and tt7.c2 = '2020-08-08');//
delimiter ;//
select * from tt8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt8 as a where a.a1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt8 as a where  %' order by hit_count;
rollback;
drop table tt7;
drop table tt8;


create table t9(c1 int not null primary key,c2 double not null,index index_c1(c1));
create table tt9 as select * from t9;
insert into tt9 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);
create table t10(a1 int not null primary key,a2 double not null,index index_c1(a1));
create table tt10 as select * from t10;
insert into tt10 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);

--echo  #delete 单表使用using(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete from tt9 using tt9 where c1 = 1;delete from tt9 using tt9 where c1 = 2;delete from tt9  using tt9 where c1 = 3;//
delimiter ;//
select * from tt9;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt9 using tt9 where c1 = %' order by hit_count;
rollback;

--echo  #多表
--echo  #无条件连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete tt9,tt10 from tt9,tt10 where tt9.c1 = 1 and tt10.a1 = 1;delete tt9,tt10 from tt9,tt10 where tt9.c1 = 2 and tt10.a1 = 2;delete tt9,tt10 from tt9,tt10 where tt9.c1 = 3 and tt10.a1 = 3;//
delimiter ;//
select * from tt9;
select * from tt10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt9,tt10 from tt9,tt10 where tt9.c1 = % and tt10.a1 = %' order by hit_count;
rollback;


--echo  #cross join(没有进行batch 优化)
delimiter //;
delete tt9,tt10 from tt9 cross join tt10 where tt9.c1 = 1 and tt10.a1 = 1;delete tt9,tt10 from tt9 cross join tt10 where tt9.c1 = 2 and tt10.a1 = 2;delete tt9,tt10 from tt9 cross join tt10 where tt9.c1 = 3 and tt10.a1 = 3;//
delimiter ;//
select * from tt9;
select * from tt10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt9,tt10 from tt9 cross join tt10 where tt9.c1 = % and tt10.a1 = %' order by hit_count;
rollback;

drop table tt9;
drop table tt10;


create table t11 (c1 varchar(30) not null,c2 char(15));
create table tt11 as select * from t11;
insert into tt11 values('A','aa'),('B','bb'),('C','cc'),('D','dd'),('王','ww');
commit;
create table t12 (a1 varchar(30),a2 char(10),a3 int);
create table tt12 as select * from t12;
insert into tt12 values('A','aa',1),('B','bb',2),('C','cc',3),('D','dd',4),('E','ee',5);
commit;

--echo  #natural join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete tt11,tt12 from tt11 natural join tt12 where tt11.c1 = 'A' and tt12.a1 = 'A';delete tt11,tt12 from tt11 natural join tt12 where tt11.c1 = 'B' and tt12.a1 = 'B';delete tt11,tt12 from tt11 natural join tt12 where tt11.c1 = 'C' and tt12.a1 = 'C';//
delimiter ;//
select * from tt11;
select * from tt12;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt11,tt12 from tt11 natural join tt12 where tt11.c1 = % and tt12.a1 = %' order by hit_count;
rollback;


--echo  #基本连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete tt11,tt12 from tt11,tt12 where tt11.c1 = tt12.a1 and tt11.c1 = 'A';delete tt11,tt12 from tt11,tt12 where tt11.c1 = tt12.a1 and tt11.c1 = 'B';delete tt11,tt12 from tt11,tt12 where tt11.c1 = tt12.a1 and tt11.c1 = 'C';//
delimiter ;//
select * from tt11;
select * from tt12;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt11,tt12 from tt11,tt12 where tt11.c1 = tt12.a1 and tt11.c1 = %;' order by hit_count;
rollback;
drop table tt11;
drop table tt12;


create table t13(c1 year not null,c2 datetime default '2020-02-02');
create table tt13 as select * from t13;
create table t14(a1 year primary key,a2 varchar(20));
create table tt14 as select * from t14;
insert into tt13 values('2005','2005-05-05'),('2006','2006-06-06'),('2007','2007-07-07'),('2008','2008-08-08'),('2009','2009-09-09');
commit;
insert into tt14 values('2005','AAA'),('2006','BBB'),('2007','CCC'),('2008','DDD'),('2009','EEE');
commit;
--echo  #delete + inner join(没有进行batch 优化)
delimiter //;
delete tt13,tt14 from tt13 inner join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2005;delete tt13,tt14 from tt13 inner join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2007;delete tt13,tt14 from tt13 inner join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2009;//
delimiter ;//
select * from tt13;
select * from tt14;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt13,tt14 from tt13 inner join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = %' order by hit_count;
rollback;


--echo  #delete +  join(没有进行batch 优化)
delimiter //;
delete tt13,tt14 from tt13  join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2005;delete tt13,tt14 from tt13  join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2007;delete tt13,tt14 from tt13  join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = 2009;//
delimiter ;//
select * from tt13;
select * from tt14;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt13,tt14 from tt13  join tt14 on tt13.c1 = tt14.a1 where tt14.a1 = %' order by hit_count;
rollback;
drop table tt13;
drop table tt14;



create table t15(c1 int primary key,c2 varchar(60));
create table tt15 as select * from t15;
insert into tt15 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t16(a1 int primary key,a2 char(60));
create table tt16 as select * from t16;
insert into tt16 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;


--echo  #delete + left join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete tt15,tt16 from tt15 left join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 5;delete tt15,tt16 from tt15 left join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 7;delete tt15,tt16 from tt15 left join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 9;//
delimiter ;//
select * from tt15;
select * from tt16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt15,tt16 from tt15 left join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = %' order by hit_count;
rollback;



--echo  #delete + right join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete tt15,tt16 from tt15 right join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 5;delete tt15,tt16 from tt15 right join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 7;delete tt15,tt16 from tt15 right join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = 9;//
delimiter ;//
select * from tt15;
select * from tt16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete tt15,tt16 from tt15 right join tt16 on tt15.c1 = tt16.a1 where tt16.a1 = %' order by hit_count;
rollback;



--echo  #delete from ..using...table...
alter system flush plan cache global;
delimiter //;
delete from tt15,tt16 using tt15 left join tt16 on tt15.c1 = tt16.a1 where tt15.c1 = 1;delete from tt15,tt16 using tt15 left join tt16 on tt15.c1 = tt16.a1 where tt15.c1 = 2;delete from tt15,tt16 using tt15 left join tt16 on tt15.c1 = tt16.a1 where tt15.c1 = 3;//
delimiter ;//
select * from tt15;
select * from tt16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt15,tt16 using tt15 left join tt16 on tt15.c1 = tt16.a1 where tt15.c1 = %' order by hit_count;
rollback;

drop table tt15;
drop table tt16;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

