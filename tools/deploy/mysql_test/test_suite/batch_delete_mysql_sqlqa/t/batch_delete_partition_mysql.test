##owner: laibingzheng.lbz
##owner group: SQL2
##description: 分区表中测试batch delete
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;





--echo  #range分区
drop table if exists t1,t2,t3;
create table t1(c1 int not null,c2 int default '6',index index_c1(c1)) partition by range(c1)
(
partition p1 values less than(5),
partition p2 values less than(10),
partition p3 values less than(maxvalue)
);
insert into t1 values(1,1),(3,3),(6,6),(9,9),(11,11),(17,17);
commit;
insert into t1 values(1,1),(2,3),(3,6),(6,9),(11,5),(17,9);
commit;

create table t2(a1 int,a2 int);
insert into t2 values(1,1),(2,5),(3,3),(6,6),(9,9),(11,11),(17,17);
commit;
create table t3(b1 int,b2 int);
insert into t3 values(1,1),(2,6),(3,3),(6,6),(9,9),(11,11),(15,15);
commit;

--echo	#obs1模式下报错
#alter system flush plan cache global;
#delimiter //;
#delete from t1 where c1 = 1;delete from t1 where c1 = 2;delete from t1 where c1 = 3;//
#delimiter ;//
#select * from t1;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
#rollback;


#delimiter //;
#delete from t1 partition(p1) where c1 = 1;delete from t1 partition(p1) where c1 = 2;delete from t1 partition(p1) where c1 = 3;//
#delimiter ;//
#select * from t1;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 partition(p1) where c1 = %' order by hit_count;
#rollback;


--echo  #delete where +子查询(无batch优化)
alter system flush plan cache global;
delimiter //;
delete from t1 where c1 = (select a1 from t2 where a2 =5);delete from t1 where c1 = (select a1 from t2 where a2 =1);delete from t1 where c1 = (select a1 from t2 where a2 =3);//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
rollback;


--echo #delete join(无batch优化)
delimiter //;
delete t1,t2 from t1 inner join t2 on t1.c1 = t2.a1 where t1.c1 = 1;delete t1,t2 from t1 inner join t2 on t1.c1 = t2.a1 where t1.c1 = 6;delete t1,t2 from t1 inner join t2 on t1.c1 = t2.a1 where t1.c1 = 11;//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t1,t2 from t1 inner join t2 on t1.c1 = t2.a1 where t1.c1 = %' order by hit_count;
rollback;


delimiter //;
delete t1,t2,t3 from t1 inner join t2 on t1.c1 = t2.a1 inner join t3 on t1.c1 = t3.b1 where t1.c1 = 1;delete t1,t2,t3 from t1 inner join t2 on t1.c1 = t2.a1 inner join t3 on t1.c1 = t3.b1 where t1.c1 = 6;delete t1,t2,t3 from t1 inner join t2 on t1.c1 = t2.a1 inner join t3 on t1.c1 = t3.b1 where t1.c1 = 11;//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t1,t2,t3 from t1 inner join t2 on t1.c1 = t2.a1 inner join t3 on t1.c1 = t3.b1 where t1.c1 = %' order by hit_count;
rollback;

drop table t1;
drop table t2;
drop table t3;




--echo  #hash分区
create table t4(c1 int primary key auto_increment,c2 datetime not null,c3 timestamp not null default '2022-01-01',key index_c1_c2(c1,c2)) partition by hash(c1)
(partition p1,
partition p2,
partition p3
);

insert into t4(c1,c2) values('2000','2000-01-02'),('2001','2001-01-03'),('2002','2002-01-05'),('2003','2003-01-06'),('2004','2004-01-07'),('2005','2005-01-08');
commit;
insert into t4(c1,c2) values('2006','2006-01-09'),('2007','2007-01-10'),('2008','2008-01-11'),('2009','2009-01-12'),('2010','2010-01-01 01:01:13'),('2011','2011-01-15');
commit;

create table t5(a1 int,a2 varchar(60));
insert into t5 values(2000,'A'),(2001,'BB'),(2002,'张三'),(2003,'哦哦哦'),(2005,'李四'),(2006,'#$%#%'),(2007,'晴天@@@'),(2008,'王五'),(2009,'AA'),(2011,'马六'),(2013,'田七'),(2012,'tiankkkk');
commit;

create table t6(b1 year,b2 varchar(60));
insert into t6 values(2002,'旅业'),(2003,'张三'),(2004,'哦哦哦'),(2005,'李四'),(2006,'#$%#%'),(2007,'晴天@@@'),(2008,'王五'),(2009,'AA'),(2010,'马六'),(2013,'田七'),(2003,'卡卡卡卡');
commit;


alter system flush plan cache global;
delimiter //;
delete from t4 where c1 = 2001;delete from t4 where c1 = 2005;delete from t4 where c1 = 2009;delete from t4 where c1 = 2013;//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = %' order by hit_count;
rollback;


delimiter //;
delete from t4 partition(p1) where c1 = '2001';delete from t4 partition(p1) where c1 = '2002';delete from t4 partition(p1) where c1 = '2003';//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 partition(p1) where c1 = %' order by hit_count;
rollback;



--echo  #delete where +子查询
alter system flush plan cache global;
delimiter //;
delete from t4 where c1 = (select a1 from t5 where a1 =2005);delete from t4 where c1 = (select a1 from t5 where a1 =2001);delete from t4 where c1 = (select a1 from t5 where a1 =2011);//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = %' order by hit_count;
rollback;


--echo #delete join
delimiter //;
delete t4,t5 from t4 right join t5 on t4.c1 = t5.a1 where t4.c1 = 2001;delete t4,t5 from t4 right join t5 on t4.c1 = t5.a1 where t4.c1 = 2006;delete t4,t5 from t4 right join t5 on t4.c1 = t5.a1 where t4.c1 = 2011;//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t4,t5 from t4 right join t5 on t4.c1 = t5.a1 where t4.c1 = %' order by hit_count;
rollback;


delimiter //;
delete t4,t5,t6 from t4 right join t5 on t4.c1 = t5.a1 right join t6 on t4.c1 = t6.b1 where t4.c1 = 2001;delete t4,t5,t6 from t4 right join t5 on t4.c1 = t5.a1 right join t6 on t4.c1 = t6.b1 where t4.c1 = 2006;delete t4,t5,t6 from t4 right join t5 on t4.c1 = t5.a1 right join t6 on t4.c1 = t6.b1 where t4.c1 = 2011;//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t4,t5,t6 from t4 right join t5 on t4.c1 = t5.a1 right join t6 on t4.c1 = t6.b1 where t4.c1 = %' order by hit_count;
rollback;

drop table t4;
drop table t5;
drop table t6;


--echo  #list分区
create table t7(c1 int not null auto_increment,c2 double not null,key index_c1_c2(c1,c2))
partition by list (c1)
(
partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9),
partition p3 values in(10,11,12)
);
insert into t7 values(1,1.111),(1,2.213),(1,3.333),(2,2.222),(2,3.3332),(3,4.444),(3,5.555),(3,6.666),(3,7.777),(4,4.1234),(5,5.55),(6,6.6641),(7,7.77),(8,8.88),(9,9.99),(10,10.1010),(11,11.4444),(12,12.121212);
commit;

create table t8(a1 int,a2 int);
insert into t8 values(1,1),(2,2),(3,4),(4,4),(5,5),(6,6),(7,7),(8,8),(9,9),(10,10),(11,11),(12,12);
commit;

create table t9(b1 int,b2 int);
insert into t9 values(1,1),(2,2),(3,4),(4,4),(5,5),(6,6),(7,7),(8,8),(9,9),(10,10),(11,11),(12,12);
commit;


delimiter //;
delete from t7 where c1 = 1;delete from t7 where c1 = 5;delete from t7 where c1 = 8;delete from t7 where c1 = 15;//
delimiter ;//
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 where c1 = %' order by hit_count;
rollback;



delimiter //;
delete from t7 partition(p0) where c1 = 1;delete from t7 partition(p0) where c1 = 2;delete from t7 partition(p0) where c1 = 3;//
delimiter ;//
select * from t7 partition(p0);
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 partition(p0) where c1 = %' order by hit_count;
rollback;


--echo  #delete where +子查询
alter system flush plan cache global;
delimiter //;
delete from t7 where c1 = (select a1 from t8 where a2 =2);delete from t7 where c1 = (select a1 from t8 where a2 =5);delete from t7 where c1 = (select a1 from t8 where a2 =8);delete from t7 where c1 = (select a1 from t8 where a2 =11);//
delimiter ;//
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 where c1 = %' order by hit_count;
rollback;


--echo #delete join
delimiter //;
delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 1;delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 6;delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 8;delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 11;//
delimiter ;//
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = %' order by hit_count;
rollback;

delimiter //;
delete t7,t8,t9 from t7 left join t8 on t7.c1 = t8.a1 left join t9 on t7.c1 = t9.b1 where t7.c1 = 1;delete t7,t8,t9 from t7 left join t8 on t7.c1 = t8.a1 left join t9 on t7.c1 = t9.b1 where t7.c1 = 6;delete t7,t8,t9 from t7 left join t8 on t7.c1 = t8.a1 left join t9 on t7.c1 = t9.b1 where t7.c1 = 8;delete t7,t8,t9 from t7 left join t8 on t7.c1 = t8.a1 left join t9 on t7.c1 = t9.b1 where t7.c1 = 11;//
delimiter ;//
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t7,t8,t9 from t7 left join t8 on t7.c1 = t8.a1 left join t9 on t7.c1 = t9.b1 where t7.c1 = %' order by hit_count;
rollback;

drop table t7;
drop table t8;
drop table t9;



alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
