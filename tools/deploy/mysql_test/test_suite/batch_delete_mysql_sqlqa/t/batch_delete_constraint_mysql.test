--echo  #没有进行batch优化
alter system flush plan cache global;
delimiter //;
delete from t3 where c1 =(select 1+1+1);delete from t3 where c1 =(select 2+2+2);delete from t3 where c1 =(select 3+3+3);//
delimiter ;//
select * from t3 order by c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c1 =%'order by hit_count;
rollback;


--echo  #delete ..inner join..没有进行batch优化
delimiter //;
delete t3,t4 from t3 inner join t4 on t3.c1 = t4.c1 where t3.c1 = 1;delete t3,t4 from t3 inner join t4 on t3.c1 = t4.c1 where t3.c1 = 2;delete t3,t4 from t3 inner join t4 on t3.c1 = t4.c1 where t3.c1 = 3;//
delimiter ;//
select * from t3 inner join t4 on t3.c1 = t4.c1 order by t3.c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t3,t4 from t3 inner join t4 on t3.c1 = t4.c1 where t3.c1 = %' order by hit_count;
rollback;
drop table t3;
drop table t4;



--echo  #not null
create table t5(c1 int not null,c2 varchar(30));
insert into t5 values(1,'NULL'),(2,'AA'),(3,'AA'),(4,'CC'),(6,'6A'),(7,'端午'),(8,'￥%…………'),(9,'123'),(10,'【AA】'),(11,'ash#2'),(12,'cc');
commit;

create table t6(c1 char(20) not null,c2 int not null);
insert into t6 values(1,1),(2,2),(3,3),(5,5),(6,6),(7,7),(8,8),(9,9),(10,10),(12,12);
commit;


alter system flush plan cache global;
delimiter //;
delete from t5 where c1 =1*2*2;delete from t5 where c1 =2*2*2;delete from t5 where c1 =3*2*1;//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 =%'order by hit_count;
rollback;


--echo  #delete 重复行   batch场景回退
alter system flush plan cache global;
delimiter //;
delete from t5 where c1 =6;delete from t5 where c1 =7;delete from t5 where c1 =6;//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 =%'order by hit_count;
rollback;

--echo  #delete ..left join...
alter system flush plan cache global;
delimiter //;
delete t5,t6 from t5 left join t6 on t5.c1 = t6.c1 where t5.c1 = 1;delete t5,t6 from t5 left join t6 on t5.c1 = t6.c1 where t5.c1 = 2;delete t5,t6 from t5 left join t6 on t5.c1 = t6.c1 where t5.c1 = 3;//
delimiter ;//
select *  from t5 left join t6 on t5.c1 = t6.c1 order by t5.c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t5,t6 from t5 left join t6 on t5.c1 = t6.c1 where t5.c1 = %'order by hit_count;
rollback;
drop table t5;
drop table t6;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


