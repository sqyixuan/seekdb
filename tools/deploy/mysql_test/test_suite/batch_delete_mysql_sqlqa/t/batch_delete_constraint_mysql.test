##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete在不同约束中测试
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo  #primary key
drop table if exists t1;
create table t1(c1 int primary key,c2 varchar(30) not null);
insert into t1 values(2000,'NULL'),(2001,'AA'),(2002,'AA'),(2003,'CC'),(2004,'6A'),(2005,'端午'),(2006,'￥%…………'),(2007,'123'),(2008,'【AA】'),(2009,'ash#2'),(2010,'cc');
commit;
drop table if exists t2;
create table t2(c1 year primary key,c2 double not null);
insert into t2 values(2001,1.1),(2002,2.11),(2003,3.111),(2005,5.11111),(2006,6.111111),(2007,7.1111111),(2008,8.11111111),(2009,9.111111111),(2010,10.1111111111),(2012,12.111111111111);
commit;

--echo  #没有进行batch 优化
alter system flush plan cache global;
delimiter //;
delete from t1 where c1 = 2000;delete from t1 where c1 = 2001;delete from t1 where c1 = 2002;//
delete from t2 where c1 = 2000+1+1;delete from t2 where c1 = 2001+1+1;delete from t2 where c1 = 2002+1+1;//
delimiter ;//
select * from t1;
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
rollback;


--echo  #delete join(没有batch 优化)
delimiter //;
delete t1,t2 from t1,t2 where t1.c1 = t2.c1 and t1.c1 = 2005;delete t1,t2 from t1,t2 where t1.c1 = t2.c1 and t1.c1 = 2006;delete t1,t2 from t1,t2 where t1.c1 = t2.c1 and t1.c1 = 2007;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t1,t2 from t1,t2 where t1.c1 = t2.c1 and t1.c1 = %' order by hit_count;
rollback;

drop table t1;




--echo  #unique key
create table t3(c1 int unique key,c2 varchar(30) not null) partition by hash(c1)
(partition p1,
partition p2,
partition p3
);
insert into t3 values(1,'NULL'),(2,'AA'),(3,'AA'),(4,'CC'),(6,'6A'),(7,'端午'),(8,'￥%…………'),(9,'123'),(10,'【AA】'),(11,'ash#2'),(12,'cc');
commit;

create table t4(c1 int primary key auto_increment,c2 datetime not null);
insert into t4 values(1,'2022-01-01'),(2,'2022-01-02'),(3,'2022-01-03'),(4,'2022-01-04'),(5,'2022-01-05'),(6,'2022-01-06'),(7,'2022-01-07'),(8,'2022-01-08'),(9,'2022-01-09');
commit;

