##owner: laibingzheng.lbz
##owner group: SQL2
##description: 视图中测试 delete + select join
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int not null primary key,c2 double not null,index index_c1(c1));
insert into t1 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);
commit;
create table t2(a1 int not null primary key,a2 double not null,index index_c1(a1));
insert into t2 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);
commit;
create view v_t1 as select * from t1;
create view v_t2 as select * from t2;

--echo  #delete 单表使用using(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete from v_t1 using v_t1 where c1 = 1;delete from v_t1 using v_t1 where c1 = 2;delete from v_t1  using v_t1 where c1 = 3;//
delimiter ;//
select * from v_t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from v_t1 using v_t1 where c1 = %' order by hit_count;
rollback;

--echo  #多表
--echo  #无条件连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete v_t1,v_t2 from v_t1,v_t2 where v_t1.c1 = 1 and v_t2.a1 = 1;delete v_t1,v_t2 from v_t1,v_t2 where v_t1.c1 = 2 and v_t2.a1 = 2;delete v_t1,v_t2 from v_t1,v_t2 where v_t1.c1 = 3 and v_t2.a1 = 3;//
delimiter ;//
select * from v_t1;
select * from v_t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t1,v_t2 from v_t1,v_t2 where v_t1.c1 = % and v_t2.a1 = %' order by hit_count;
rollback;


--echo  #cross join(没有进行batch 优化)
delimiter //;
delete v_t1,v_t2 from v_t1 cross join v_t2 where v_t1.c1 = 1 and v_t2.a1 = 1;delete v_t1,v_t2 from v_t1 cross join v_t2 where v_t1.c1 = 2 and v_t2.a1 = 2;delete v_t1,v_t2 from v_t1 cross join v_t2 where v_t1.c1 = 3 and v_t2.a1 = 3;//
delimiter ;//
select * from v_t1;
select * from v_t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t1,v_t2 from v_t1 cross join v_t2 where v_t1.c1 = % and v_t2.a1 = %' order by hit_count;
rollback;

drop view v_t1;
drop view v_t2;


create table t3 (c1 varchar(30) not null,c2 char(15));
insert into t3 values('A','aa'),('B','bb'),('C','cc'),('D','dd'),('王','ww');
commit;
create table t4 (a1 varchar(30),a2 char(10),a3 int);
insert into t4 values('A','aa',1),('B','bb',2),('C','cc',3),('D','dd',4),('E','ee',5);
commit;
create view v_t3 as select * from t3;
create view v_t4 as select * from t4;


--echo  #natural join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete v_t3,v_t4 from v_t3 natural join v_t4 where v_t3.c1 = 'A' and v_t4.a1 = 'A';delete v_t3,v_t4 from v_t3 natural join v_t4 where v_t3.c1 = 'B' and v_t4.a1 = 'B';delete v_t3,v_t4 from v_t3 natural join v_t4 where v_t3.c1 = 'C' and v_t4.a1 = 'C';//
delimiter ;//
select * from v_t3;
select * from v_t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t3,v_t4 from v_t3 natural join v_t4 where v_t3.c1 = % and v_t4.a1 = %' order by hit_count;
rollback;


--echo  #基本连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete v_t3,v_t4 from v_t3,v_t4 where v_t3.c1 = v_t4.a1 and v_t3.c1 = 'A';delete v_t3,v_t4 from v_t3,v_t4 where v_t3.c1 = v_t4.a1 and v_t3.c1 = 'B';delete v_t3,v_t4 from v_t3,v_t4 where v_t3.c1 = v_t4.a1 and v_t3.c1 = 'C';//
delimiter ;//
select * from v_t3;
select * from v_t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t3,v_t4 from v_t3,v_t4 where v_t3.c1 = v_t4.a1 and v_t3.c1 = %;' order by hit_count;
rollback;
drop view v_t3;
drop view v_t4;


create table t5(c1 year not null,c2 datetime default '2020-02-02');
create table t6(a1 year primary key,a2 varchar(20));
insert into t5 values('2005','2005-05-05'),('2006','2006-06-06'),('2007','2007-07-07'),('2008','2008-08-08'),('2009','2009-09-09');
commit;
insert into t6 values('2005','AAA'),('2006','BBB'),('2007','CCC'),('2008','DDD'),('2009','EEE');
commit;
create view v_t5 as select * from t5;
create view v_t6 as select * from t6;


--echo  #delete + inner join(没有进行batch 优化)
delimiter //;
delete v_t5,v_t6 from v_t5 inner join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2005;delete v_t5,v_t6 from v_t5 inner join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2007;delete v_t5,v_t6 from v_t5 inner join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2009;//
delimiter ;//
select * from v_t5;
select * from v_t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t5,v_t6 from v_t5 inner join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = %' order by hit_count;
rollback;


--echo  #delete +  join(没有进行batch 优化)
delimiter //;
delete v_t5,v_t6 from v_t5  join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2005;delete v_t5,v_t6 from v_t5  join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2007;delete v_t5,v_t6 from v_t5  join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = 2009;//
delimiter ;//
select * from v_t5;
select * from v_t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t5,v_t6 from v_t5  join v_t6 on v_t5.c1 = v_t6.a1 where v_t6.a1 = %' order by hit_count;
rollback;
drop view v_t5;
drop view v_t6;



create table t7(c1 int primary key,c2 varchar(60));
insert into t7 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t8(a1 int primary key,a2 char(60));
insert into t8 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create view v_t7 as select * from t7;
create view v_t8 as select * from t8;

--echo  #delete + left join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete v_t7,v_t8 from v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 5;delete v_t7,v_t8 from v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 7;delete v_t7,v_t8 from v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 9;//
delimiter ;//
select * from v_t7;
select * from v_t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t7,v_t8 from v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = %' order by hit_count;
rollback;



--echo  #delete + right join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete v_t7,v_t8 from v_t7 right join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 5;delete v_t7,v_t8 from v_t7 right join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 7;delete v_t7,v_t8 from v_t7 right join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = 9;//
delimiter ;//
select * from v_t7;
select * from v_t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete v_t7,v_t8 from v_t7 right join v_t8 on v_t7.c1 = v_t8.a1 where v_t8.a1 = %' order by hit_count;
rollback;



--echo  #delete from ..using...table...
alter system flush plan cache global;
delimiter //;
delete from v_t7,v_t8 using v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t7.c1 = 1;delete from v_t7,v_t8 using v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t7.c1 = 2;delete from v_t7,v_t8 using v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t7.c1 = 3;//
delimiter ;//
select * from v_t7;
select * from v_t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from v_t7,v_t8 using v_t7 left join v_t8 on v_t7.c1 = v_t8.a1 where v_t7.c1 = %' order by hit_count;
rollback;

drop view v_t7;
drop view v_t8;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


