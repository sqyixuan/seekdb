--echo  #bit
create table t8(c1 bit(64),c2 bit(64));
insert into t8 values(10,10),(11,11),(12,12),(13,13),(14,14),(15,15),(16,16),(17,17),(18,18);
commit;
select bin(c1),bin(c2) from t8;


delimiter //;
delete from t8 where c1 = b'1101';delete from t8 where c1 = b'1110';delete from t8 where c1 = b'1111';//
delimiter ;//
select bin(c1),bin(c2) from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t8 where c1 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t8 where c1 = b'1101';delete from t8 where c1 = b'1110';delete from t8 where c1 = b'1111';//
delimiter ;//
select bin(c1),bin(c2) from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t8 where c1 = %' order by hit_count;
rollback;



alter system flush plan cache global;
delimiter //;
delete from t8 where c1 = 16;delete from t8 where c1 = b'10001';delete from t8 where c1 = b'10010';//
delimiter ;//
select bin(c1),bin(c2) from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t8 where c1 = %' order by hit_count;
rollback;

drop table t8;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
