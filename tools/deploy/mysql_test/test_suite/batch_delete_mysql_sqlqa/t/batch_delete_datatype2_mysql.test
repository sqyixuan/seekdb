##owner: laibingzheng.lbz
##owner group: SQL2
##description: 不同数据类型
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;



--echo	#varchar、char
create table t5(c1 varchar(60),c2 char(30));
insert into t5 values('张','1A'),('王@','bbb'),('李','adasd#%$'),('赵G','null'),('---','NNsa阿瑟东'),('@仰卧','453123'),('舆论￥%……','CC'),(' ','dfe'),('cccc','ddddd');
commit;
select * from t5;


delimiter //;
delete from t5 where c1 = '张';delete from t5 where c1 = '王@';delete from t5 where c1 = '赵G';//
delete from t5 where c2 = 'adasd#%$';delete from t5 where c2 = 'NNsa阿瑟东';delete from t5 where c2 = 'CC';//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c2 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t5 where c1 = '张';delete from t5 where c1 = ' ';delete from t5 where c1 = '赵G';//
delete from t5 where c2 = 'adasd#%$';delete from t5 where c2 = 'null';delete from t5 where c2 = 'CC';//
delimiter ;//
select * from t5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c2 = %' order by hit_count;
rollback;
drop table t5;



--echo  #varbinary,binary
--echo	#varbinary、binary
create table t6(c1 varbinary(30),c2 binary(30));
insert into t6 values('aaa','一一一');
insert into t6 values('bbb','二二二');
insert into t6 values('ccc','三三三');
insert into t6 values('abc/20','1000/66.6');
insert into t6 values('b/2','2000/128.8');
insert into t6 values('c/3','3000/256.6');
insert into t6 values(' ','ABC');
insert into t6 values(' a',null);
commit;
select * from t6;


delimiter //;
delete from t6 where c1 = 'aaa';delete from t6 where c1 = 'bbb';delete from t6 where c1 = 'ccc';//
delete from t6 where c2 = '1000/66.6';delete from t6 where c2 = '2000/128.8';delete from t6 where c2 = '3000/256.6';//
delimiter ;//
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c2 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t6 where c1 = 'aaa';delete from t6 where c1 = 'bbb';delete from t6 where c1 = ' ';//
delete from t6 where c2 = '1000/66.6';delete from t6 where c2 = '2000/128.8';delete from t6 where c2 = 'null';//
delimiter ;//
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t6 where c2 = %' order by hit_count;
rollback;
drop table t6;




