##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete+join
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int not null primary key,c2 double not null,index index_c1(c1));
insert into t1 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);
create table t2(a1 int not null primary key,a2 double not null,index index_c1(a1));
insert into t2 values(1,1.11),(2,2.22),(3,3.33),(4,4.444);

--echo  #delete 单表使用using(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete from t1 using t1 where c1 = 1;delete from t1 using t1 where c1 = 2;delete from t1  using t1 where c1 = 3;//
delimiter ;//
select * from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 using t1 where c1 = %' order by hit_count;
rollback;

--echo  #多表
--echo  #无条件连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete t1,t2 from t1,t2 where t1.c1 = 1 and t2.a1 = 1;delete t1,t2 from t1,t2 where t1.c1 = 2 and t2.a1 = 2;delete t1,t2 from t1,t2 where t1.c1 = 3 and t2.a1 = 3;//
delimiter ;//
select * from t1;
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t1,t2 from t1,t2 where t1.c1 = % and t2.a1 = %' order by hit_count;
rollback;


--echo  #cross join(没有进行batch 优化)
delimiter //;
delete t1,t2 from t1 cross join t2 where t1.c1 = 1 and t2.a1 = 1;delete t1,t2 from t1 cross join t2 where t1.c1 = 2 and t2.a1 = 2;delete t1,t2 from t1 cross join t2 where t1.c1 = 3 and t2.a1 = 3;//
delimiter ;//
select * from t1;
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t1,t2 from t1 cross join t2 where t1.c1 = % and t2.a1 = %' order by hit_count;
rollback;

drop table t1;
drop table t2;


create table t3 (c1 varchar(30) not null,c2 char(15));
insert into t3 values('A','aa'),('B','bb'),('C','cc'),('D','dd'),('王','ww');
commit;
create table t4 (a1 varchar(30),a2 char(10),a3 int);
insert into t4 values('A','aa',1),('B','bb',2),('C','cc',3),('D','dd',4),('E','ee',5);
commit;

--echo  #natural join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete t3,t4 from t3 natural join t4 where t3.c1 = 'A' and t4.a1 = 'A';delete t3,t4 from t3 natural join t4 where t3.c1 = 'B' and t4.a1 = 'B';delete t3,t4 from t3 natural join t4 where t3.c1 = 'C' and t4.a1 = 'C';//
delimiter ;//
select * from t3;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t3,t4 from t3 natural join t4 where t3.c1 = % and t4.a1 = %' order by hit_count;
rollback;


--echo  #基本连接(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete t3,t4 from t3,t4 where t3.c1 = t4.a1 and t3.c1 = 'A';delete t3,t4 from t3,t4 where t3.c1 = t4.a1 and t3.c1 = 'B';delete t3,t4 from t3,t4 where t3.c1 = t4.a1 and t3.c1 = 'C';//
delimiter ;//
select * from t3;
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t3,t4 from t3,t4 where t3.c1 = t4.a1 and t3.c1 = %;' order by hit_count;
rollback;
drop table t3;
drop table t4;


create table t5(c1 year not null,c2 datetime default '2020-02-02');
create table t6(a1 year primary key,a2 varchar(20));
insert into t5 values('2005','2005-05-05'),('2006','2006-06-06'),('2007','2007-07-07'),('2008','2008-08-08'),('2009','2009-09-09');
commit;
insert into t6 values('2005','AAA'),('2006','BBB'),('2007','CCC'),('2008','DDD'),('2009','EEE');
commit;
--echo  #delete + inner join(没有进行batch 优化)
delimiter //;
delete t5,t6 from t5 inner join t6 on t5.c1 = t6.a1 where t6.a1 = 2005;delete t5,t6 from t5 inner join t6 on t5.c1 = t6.a1 where t6.a1 = 2007;delete t5,t6 from t5 inner join t6 on t5.c1 = t6.a1 where t6.a1 = 2009;//
delimiter ;//
select * from t5;
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t5,t6 from t5 inner join t6 on t5.c1 = t6.a1 where t6.a1 = %' order by hit_count;
rollback;


--echo  #delete +  join(没有进行batch 优化)
delimiter //;
delete t5,t6 from t5  join t6 on t5.c1 = t6.a1 where t6.a1 = 2005;delete t5,t6 from t5  join t6 on t5.c1 = t6.a1 where t6.a1 = 2007;delete t5,t6 from t5  join t6 on t5.c1 = t6.a1 where t6.a1 = 2009;//
delimiter ;//
select * from t5;
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t5,t6 from t5  join t6 on t5.c1 = t6.a1 where t6.a1 = %' order by hit_count;
rollback;
drop table t5;
drop table t6;



create table t7(c1 int primary key,c2 varchar(60));
insert into t7 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t8(a1 int primary key,a2 char(60));
insert into t8 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;


--echo  #delete + left join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t8.a1 = 5;delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t8.a1 = 7;delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t8.a1 = 9;//
delimiter ;//
select * from t7;
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t7,t8 from t7 left join t8 on t7.c1 = t8.a1 where t8.a1 = %' order by hit_count;
rollback;



--echo  #delete + right join(没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete t7,t8 from t7 right join t8 on t7.c1 = t8.a1 where t8.a1 = 5;delete t7,t8 from t7 right join t8 on t7.c1 = t8.a1 where t8.a1 = 7;delete t7,t8 from t7 right join t8 on t7.c1 = t8.a1 where t8.a1 = 9;//
delimiter ;//
select * from t7;
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t7,t8 from t7 right join t8 on t7.c1 = t8.a1 where t8.a1 = %' order by hit_count;
rollback;



--echo  #delete from ..using...table...
alter system flush plan cache global;
delimiter //;
delete from t7,t8 using t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 1;delete from t7,t8 using t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 2;delete from t7,t8 using t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = 3;//
delimiter ;//
select * from t7;
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7,t8 using t7 left join t8 on t7.c1 = t8.a1 where t7.c1 = %' order by hit_count;
rollback;

drop table t7;
drop table t8;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

