##owner: laibingzheng.lbz
##owner group: SQL2
##description: delete + subquery in view
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int primary key,c2 varchar(60));
insert into t1 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t2 (a1 int primary key auto_increment,a2 varchar(60) not null);
insert into t2(a2) values('AA'),('BB'),('正在'),('单独'),('方法'),('算数'),('##$$'),(';;l'),('3121/+651'),('mgsg《'),('asd123'),('王w@'),('ACD啊#￥');
commit;
create view v_t1 as select * from t1;
create view v_t2 as select * from t2;


--echo  #delete+(比较运算符)子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from v_t2 as a where a.a1 = (select c1 from v_t1 where c1 = 1);delete a from v_t2 as a where a.a1 = (select c1 from v_t1 where c1 = 2);delete a from v_t2 as a where a.a1 = (select c1 from v_t1 where c1 = 3);//
delete a from v_t2 as a where a.a1 > (select min(c1) from v_t1 where c1 > 6);delete a from v_t2 as a where a.a1 > (select min(c1) from v_t1 where c1 > 8);delete a from v_t2 as a where a.a1 > (select min(c1) from v_t1 where c1 > 10);//
delete a from v_t2 as a where a.a1 >= (select min(c1) from v_t1 where c1 > 6);delete a from v_t2 as a where a.a1 >= (select min(c1) from v_t1 where c1 > 8);delete a from v_t2 as a where a.a1 >= (select min(c1) from v_t1 where c1 > 10);//
delete a from v_t2 as a where a.a1 < any(select max(c1) from v_t1 where c1 < 5);delete a from v_t2 as a where a.a1 < any(select max(c1) from v_t1 where c1 < 6);delete a from v_t2 as a where a.a1 < any(select max(c1) from v_t1 where c1 < 7);//
delete a from v_t2 as a where a.a1 <= all(select max(c1) from v_t1 where c1 < 5 and c1 > 3);delete a from v_t2 as a where a.a1 <= all(select max(c1) from v_t1 where c1 < 6 and c1 >1);delete a from v_t2 as a where a.a1 <= all(select max(c1) from v_t1 where c1 < 7 and c1 > 4);//
delimiter ;//
select * from v_t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t2 as a where %' order by hit_count;
rollback;
drop view v_t1;
drop view v_t2;




create table t3(c1 char(10) not null,c2 varchar(10));
create table t4(a1 char(10) not null,a2 varchar(10));
insert into t3 values('aa','张三'),('bb','李四'),('cc','王五'),('dd','马六'),('ee','田七');
insert into t4 values('aa','张三'),('bb','四'),('cc','王五'),('dd','六'),('ee','田七');
commit;
create view v_t3 as select * from t3;
create view v_t4 as select * from t4;

--echo  #delete + in关键字子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from v_t4 as a where a.a1 in (select c1 from v_t3 where c1 = 'aa');delete a from v_t4 as a where a.a1 in (select c1 from v_t3 where c1 = 'bb');delete a from v_t4 as a where a.a1 in (select c1 from v_t3 where c1 = 'cc');//
delete a from v_t4 as a where a.a1 not in (select c1 from v_t3 where c1 = 'aa');delete a from v_t4 as a where a.a1 not in (select c1 from v_t3 where c1 = 'dd');//
delimiter ;//
select * from v_t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t4 as a where a.a1 in %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t4 as a where a.a1 not in %' order by hit_count;
rollback;
drop view v_t3;
drop view v_t4;


create table t5(c1 varbinary(30) primary key,c2 binary(30));
create table t6(a1 varbinary(30) not null ,a2 binary(30));
insert into t5 values(101,101),(202,202),(303,303),(404,404),(505,505),(606,606);
insert into t6 values(101,101),(202,202),(303,303),(505,505),(606,606);
commit;
create view v_t5 as select * from t5;
create view v_t6 as select * from t6;

--echo  #delete+any子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from v_t6 as a where a.a1 = any (select c1 from v_t5 where c1 = 101);delete a from v_t6 as a where a.a1 = any (select c1 from v_t5 where c1 = 202);delete a from v_t6 as a where a.a1 = any (select c1 from v_t5 where c1 = 303);//
delete a from v_t6 as a where a.a1 = all (select c1 from v_t5 where c1 = 202);delete a from v_t6 as a where a.a1 = all (select c1 from v_t5 where c1 = 303);delete a from v_t6 as a where a.a1 = all (select c1 from v_t5 where c1 = 404);//
delimiter ;//
select * from v_t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t6 as a where a.a1 = %' order by hit_count;
rollback;
drop view v_t5;
drop view v_t6;



create table t7(c1 year not null primary key , c2 date not null,index index_c1(c1));
create table t8(a1 year not null primary key , a2 date not null,index index_a1(a1));
insert into t7 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into t8 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');
commit;
create view v_t7 as select * from t7;
create view v_t8 as select * from t8;

--echo  #delete+some子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from v_t8 as a where a.a1 = some (select c1 from v_t7 where c1 = 2017);delete a from v_t8 as a where a.a1 = some (select c1 from v_t7 where c1 = 2019);delete a from v_t8 as a where a.a1 = some (select c1 from v_t7 where c1 = 2020);//
delimiter ;//
select * from v_t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t8 as a where a.a1 = %' order by hit_count;
rollback;


--echo  #delete+exists子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from v_t8 as a where a.a1 = exists (select c1 from v_t7 where c1 = 2018);delete a from v_t8 as a where a.a1 = exists (select c1 from v_t7 where c1 = 2020);delete a from v_t8 as a where a.a1 = exists (select c1 from v_t7 where c1 = 2019);//
delete a from v_t8 as a where  not exists (select c1 from v_t7 where c2 = '2017-08-08');delete a from v_t8 as a where  not exists (select c1 from v_t7 where c2 = '2019-08-08');delete a from v_t8 as a where  not exists (select c1 from v_t7 where c2 = '2020-08-08');//

delimiter ;//
select * from v_t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t8 as a where a.a1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from v_t8 as a where  %' order by hit_count;
rollback;
drop view v_t7;
drop view v_t8;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

