##owner: laibingzheng.lbz
##owner group: SQL2
##description: time type
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


drop table if exists t1;
create table t1 (c1 timestamp not null,c2 timestamp unique key,index index_c1(c1));
insert into t1 values('2020-08-08','2020-09-09 09:09:00');
insert into t1 values('2020-10-10 10:10:00','2020-11-11');
insert into t1 values('2021-05-05 05:05:05','2021-06-06 06:06:00');
insert into t1 values('2021-07-07 07:07:07','2021-08-08 08:08:00');
insert into t1 values('2021-09-09 09:09:09','2021-10-10 10:10:00');
insert into t1 values(20220606,20200707);
commit;

delimiter //;
delete from t1 where c1 = '2020-08-08';delete from t1 where c1 = '2020-10-10 10:10:00';delete from t1 where c1 = '2021-09-09 09:09:09';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
select * from t1;
rollback;


alter system flush plan cache global;
delimiter //;
delete from t1 where c1 = 20220606;delete from t1 where c1 = 20200808;delete from t1 where c1 = 20201010101000;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
select * from t1;
rollback;


alter system flush plan cache global;
delimiter //;
delete from t1 where c1 = 20220606;delete from t1 where c1 = '2020-08-08';delete from t1 where c1 = 20201010;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
select * from t1;
rollback;

drop table t1;


drop table if exists t2;
create table t2 (c1 time(6) not null primary key,c2 time(4) not null unique key);
create index index_c1_C2 on t2(c1,c2);
insert into t2 values('123:59:59.5555555','222:22:22.2222222');
insert into t2 values('333:33:33.33333','555:55:55.234');
insert into t2 values('80:08:08.22222','80:08:08.2222');
insert into t2 values('90:09:09.66666','90:09:09.3333');
insert into t2 values('-90:09:09.666','-90:09:09.3333');
commit;


alter system flush plan cache global;
delimiter //;
delete from t2 where c1 = '333:33:33.33333';delete from t2 where c1 = '80:08:08.22222';delete from t2 where c1 = '90:09:09.66666';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
select * from t2;
rollback;


--echo  #精度不同测试
alter system flush plan cache global;
delimiter //;
delete from t2 where c1 = '123:59:59.5555555';delete from t2 where c1 = '80:08:08.22222';delete from t2 where c1 = '90:09:09.66666';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
select * from t2;
rollback;


--echo  #符号不同测试
alter system flush plan cache global;
delimiter //;
delete from t2 where c1 = '123:59:59.5555555';delete from t2 where c1 = '80:08:08.22222';delete from t2 where c1 = '-90:09:09.666';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
select * from t2;
rollback;
drop table t2;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


