##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete在不同约束中测试
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;



--echo  #default
create table t7(c1 int default '2',c2 varchar(30));
insert into t7 values(1,'NULL'),(2,'AA'),(3,'AA'),(4,'CC'),(6,'6A'),(7,'端午'),(8,'￥%…………'),(9,'123'),(10,'【AA】'),(11,'ash#2'),(12,'cc');
insert into t7(c2) values('123'),('abc');
commit;
drop table if exists t2;
create table t8(c1 int,c2 int);
insert into t8 values(1,1),(2,2),(3,3),(5,5),(6,6),(7,7),(8,8),(9,9),(10,10),(12,12);
commit;

alter system flush plan cache global;
delimiter //;
delete from t7 where c1 =1;delete from t7 where c1 =2;delete from t7 where c1 =3;//
delimiter ;//
select * from t7;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t7 where c1 =%'order by hit_count;
rollback;

--echo  #delete ..right join...
alter system flush plan cache global;
delimiter //;
delete t7,t8 from t7 right join t8 on t7.c1 = t8.c1 where t7.c1 = 1;delete t7,t8 from t7 right join t8 on t7.c1 = t8.c1 where t7.c1 = 2;delete t7,t8 from t7 right join t8 on t7.c1 = t8.c1 where t7.c1 = 3;//
delimiter ;//
delete t7,t8 from t7 right join t8 on t7.c1 = t8.c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t7,t8 from t7 right join t8 on t7.c1 = t8.c1 where t7.c1 = %'order by hit_count;
rollback;


--echo  #foreign key

CREATE TABLE t9 (
    building_no INT PRIMARY KEY AUTO_INCREMENT,
    building_name VARCHAR(255) NOT NULL,
    address VARCHAR(255) NOT NULL
);
CREATE TABLE t10 (
    room_no INT PRIMARY KEY AUTO_INCREMENT,
    room_name VARCHAR(255) NOT NULL,
    building_no INT NOT NULL,
    FOREIGN KEY (building_no)
        REFERENCES t9 (building_no)
        ON DELETE CASCADE
);
INSERT INTO t9(building_name,address)
VALUES('海南大厦','海口市国兴大道1234号'),
      ('万达水城','海口市大同路1200号'),('黄龙时代','天目山路'),('古荡新村','文三西路'),('古荡新村555','文三西路555');
commit;
INSERT INTO t10(room_name,building_no)
VALUES('Amazon',1),
      ('War Room',1),
      ('Office of CEO',1),
      ('Marketing',2),
      ('Showroom',2),('aaa',3),('aaa',4),('aaa',5);
commit;

alter system flush plan cache global;
delimiter //;
delete from t9 where building_no = 1;delete from t9 where building_no = 2;delete from t9 where building_no = 3;//
delimiter ;//
select * from t9;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t9 where building_no = %' order by hit_count;
rollback;


--echo  #delete重复行
alter system flush plan cache global;
delimiter //;
delete from t9 where building_no = 1;delete from t9 where building_no = 2;delete from t9 where building_no = 1;//
delimiter ;//
select * from t9;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t9 where building_no = %'order by hit_count;
rollback;
alter system flush plan cache global;


delimiter //;

delete  from t9,t10 using t9,t10 where t9.building_no=t10.building_no and t9.building_no=1;delete  from t9,t10 using t9,t10 where t9.building_no=t10.building_no and t9.building_no=2;delete  from t9,t10 using t9,t10 where t9.building_no=t10.building_no and t9.building_no=3;//
delimiter ;//
select * from t9,t10 where t9.building_no=t10.building_no;
rollback;

drop table t10;
drop table t9;



alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;



