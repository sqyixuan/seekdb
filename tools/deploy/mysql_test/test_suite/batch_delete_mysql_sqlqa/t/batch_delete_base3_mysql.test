##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete +关联子查询
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int primary key,c2 varchar(60));
insert into t1 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t2 (a1 int primary key auto_increment,a2 varchar(60) not null);
insert into t2(a2) values('AA'),('BB'),('正在'),('单独'),('方法'),('算数'),('##$$'),(';;l'),('3121/+651'),('mgsg《'),('asd123'),('王w@'),('ACD啊#￥');
commit;

--echo  #delete+非关联子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from t2 as a where a.a1 = (select c1 from t1 where t1.c1 = a.a1 and a.a1 = 1);delete a from t2 as a where a.a1 = (select c1 from t1 where t1.c1 = a.a1 and a.a1 = 2);delete a from t2 as a where a.a1 = (select c1 from t1 where t1.c1 = a.a1 and a.a1 = 3);//
delete a from t2 as a where a.a1 > (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 6);delete a from t2 as a where a.a1 > (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 8);delete a from t2 as a where a.a1 > (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 10);//
delete a from t2 as a where a.a1 >= (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 6);delete a from t2 as a where a.a1 >= (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 8);delete a from t2 as a where a.a1 >= (select min(c1) from t1 where t1.c1 = a.a1 and c1 > 10);//
delete a from t2 as a where a.a1 < any(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 5);delete a from t2 as a where a.a1 < any(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 6);delete a from t2 as a where a.a1 < any(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 7);//
delete a from t2 as a where a.a1 <= all(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 5 and c1 > 3);delete a from t2 as a where a.a1 <= all(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 6 and c1 >1);delete a from t2 as a where a.a1 <= all(select max(c1) from t1 where t1.c1 = a.a1 and c1 < 7 and c1 > 4);//
delimiter ;//
select * from t2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t2 as a where %' order by hit_count;
rollback;
drop table t1;
drop table t2;




create table t3(c1 char(10) not null,c2 varchar(10));
create table t4(a1 char(10) not null,a2 varchar(10));
insert into t3 values('aa','张三'),('bb','李四'),('cc','王五'),('dd','马六'),('ee','田七');
insert into t4 values('aa','张三'),('bb','四'),('cc','王五'),('dd','六'),('ee','田七');
commit;

--echo  #delete + in关键字子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from t4 as a where a.a1 in (select c1 from t3 where t3.c1 = a.a1 and t3.c1 = 'aa');delete a from t4 as a where a.a1 in (select c1 from t3 where t3.c1 = a.a1 and t3.c1 = 'bb');delete a from t4 as a where a.a1 in (select c1 from t3 where t3.c1 = a.a1 and t3.c1 = 'cc');//
delete a from t4 as a where a.a1 not in (select c1 from t3 where t3.c1 = a.a1 and t3.c1 = 'aa');delete a from t4 as a where a.a1 not in (select c1 from t3 where t3.c1 = a.a1 and t3.c1 = 'dd');//
delimiter ;//
select * from t4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t4 as a where a.a1 in %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t4 as a where a.a1 not in %' order by hit_count;
rollback;
drop table t3;
drop table t4;


create table t5(c1 varbinary(30) primary key,c2 binary(30));
create table t6(a1 varbinary(30) not null ,a2 binary(30));
insert into t5 values(101,101),(202,202),(303,303),(404,404),(505,505),(606,606);
insert into t6 values(101,101),(202,202),(303,303),(505,505),(606,606);
commit;

--echo  #delete+any子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from t6 as a where a.a1 = any (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 101);delete a from t6 as a where a.a1 = any (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 202);delete a from t6 as a where a.a1 = any (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 303);//
delete a from t6 as a where a.a1 = all (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 202);delete a from t6 as a where a.a1 = all (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 303);delete a from t6 as a where a.a1 = all (select c1 from t5 where t5.c1 = a.a1 and t5.c1 = 404);//
delimiter ;//
select * from t6;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t6 as a where a.a1 = %' order by hit_count;
rollback;
drop table t5;
drop table t6;



create table t7(c1 year not null primary key , c2 date not null,index index_c1(c1));
create table t8(a1 year not null primary key , a2 date not null,index index_a1(a1));
insert into t7 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into t8 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');
commit;

--echo  #delete+some子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from t8 as a where a.a1 = some (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2017);delete a from t8 as a where a.a1 = some (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2019);delete a from t8 as a where a.a1 = some (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2020);//
delimiter ;//
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t8 as a where a.a1 = %' order by hit_count;
rollback;


--echo  #delete+exists子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from t8 as a where a.a1 = exists (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2017);delete a from t8 as a where a.a1 = exists (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2020);delete a from t8 as a where a.a1 = exists (select c1 from t7 where t7.c1 = a.a1 and t7.c1 = 2019);//
delete a from t8 as a where  not exists (select c1 from t7 where t7.c1 = a.a1 and t7.c2 = '2017-08-08');delete a from t8 as a where  not exists (select c1 from t7 where t7.c1 = a.a1 and t7.c2 = '2019-08-08');delete a from t8 as a where  not exists (select c1 from t7 where t7.c1 = a.a1 and t7.c2 = '2020-08-08');//
delimiter ;//
select * from t8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t8 as a where a.a1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t8 as a where  %' order by hit_count;
rollback;
drop table t7;
drop table t8;



create table t9(c1 decimal(10,3) , c2 decimal(10,3) unsigned);
create table t10(a1 decimal(10,3) , a2 decimal(10,3) unsigned);
insert into t9 values (-1001,20001),(1002,20002),(1003,20003),(-1004,20004),(1005,20005);

insert into t10 values (null,20001),(1002,20002),(1003,20003),(-1004,20004),(1005,null);
commit;

--echo  #精度不同batch场景回退
alter system flush plan cache global;
delimiter //;
delete a from t10 as a where a.a1 like (select c1 from t9 where t9.c1 = a.a1 and t9.c1 = -1001);delete a from t10 as a where a.a1 like (select c1 from t9 where t9.c1 = a.a1 and t9.c1 = 1002);delete a from t10 as a where a.a1 like (select c1 from t9 where t9.c1 = a.a1 and t9.c1 = 1003.000);//
delimiter ;//
select * from t10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from t10 as a where a.a1 like %' order by hit_count;
rollback;
drop table t9;
drop table t10;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
