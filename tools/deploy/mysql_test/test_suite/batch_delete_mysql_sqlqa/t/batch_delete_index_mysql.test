##owner: laibingzheng.lbz
##owner group: SQL2
##description: batch delete在不同索引中测试
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

--echo  #index
create table t11(c1 int not null primary key auto_increment,c2 varchar(60))partition by range(c1)
(partition p1 values less than(5),
partition p2 values less than(10),
partition p3 values less than(maxvalue)
);
create index index_c1 on t11(c1);

insert into t11 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;

alter system flush plan cache global;
delimiter //;
delete from t11 where c1 = 1+1+1;delete from t11 where c1 = 2+2+2;delete from t11 where c1 = 3+3+3;//
delimiter ;//
select * from t11 order by c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t11 where c1 = %'order by hit_count;
rollback;


create table t12 (a1 int primary key auto_increment,a2 varchar(60) not null) partition by list(a1)
(partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9),
partition p3 values in(10,11,12,13)
);

insert into t12(a2) values('AA'),('BB'),('正在'),('单独'),('方法'),('算数'),('##$$'),(';;l'),('3121/+651'),('mgsg《'),('asd123'),('王w@'),('ACD啊#￥');
commit;
create unique index index_a1 on t12(a1);

alter system flush plan cache global;
delimiter //;
delete from t12 where a1 = 1*2+1;delete from t12 where a1 = 2*2+1;delete from t12 where a1 = 3*2+1;//
delimiter ;//
select * from t12 order by a1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t12 where a1 = %'order by hit_count;
rollback;


create table t13(b1 int  auto_increment,b2 datetime not null) partition by hash(b1)
(partition p1,
partition p2,
partition p3
);
create index index_b1 on t13(b1,b2);
insert into t13(b2) values('2022-05-31'),('2022-06-01'),('2022-06-02'),('2022-06-03'),('2022-06-04'),('2022-06-05'),('2022-06-06'),('2022-06-07'),('2022-06-08'),('2022-06-09'),('2022-06-10'),('2022-06-11'),('2022-06-12'),('2022-06-13');
commit;


alter system flush plan cache global;
delimiter //;
delete from t13 where b1 = 4/2/2;delete from t13 where b1 = 6/3/1;delete from t13 where b1 = 9/3/1;//
delimiter ;//
select * from t13 order by b1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t13 where b1 = %'order by hit_count;
rollback;



--echo  #没有进行batch 优化
alter system flush plan cache global;
delimiter //;
delete from t11 where c1 = (select max(a1)-1 from t12);delete from t11 where c1 = (select max(a1)-2 from t12);delete from t11 where c1 = (select max(a1)-3 from t12);//
delimiter ;//
select * from t11 order by c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t11 where c1 = %'order by hit_count;
rollback;

--echo  #delete ..right join... 没有进行batch 优化
alter system flush plan cache global;
delimiter //;
delete t11,t12 from t11 right join t12 on t11.c1 = t12.a1 where t11.c1 = 1;delete t11,t12 from t11 right join t12 on t11.c1 = t12.a1 where t11.c1 = 2;delete t11,t12 from t11 right join t12 on t11.c1 = t12.a1 where t11.c1 = 3;//
delimiter ;//
select * from t11 right join t12 on t11.c1 = t12.a1 order by t11.c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t11,t12 from t11 right join t12 on t11.c1 = t12.a1 where t11.c1 = %'order by hit_count;
rollback;

--echo  #3表 (没有进行batch 优化)
alter system flush plan cache global;
delimiter //;
delete from t11,t12 using t11,t12,t13 where t11.c1 = t12.a1 and t11.c1 = t13.b1 and t12.a1 = 1;delete from t11,t12 using t11,t12,t13 where t11.c1 = t12.a1 and t11.c1 = t13.b1 and t12.a1 = 5;delete from t11,t12 using t11,t12,t13 where t11.c1 = t12.a1 and t11.c1 = t13.b1 and t12.a1 = 7;//
delimiter ;//
select * from t11,t12,t13 where t11.c1 = t12.a1 and t11.c1 = t13.b1 order by t11.c1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t11,t12 using t11,t12,t13 where t11.c1 = %'order by hit_count;
rollback;


drop table t11;
drop table t12;
drop table t13;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
