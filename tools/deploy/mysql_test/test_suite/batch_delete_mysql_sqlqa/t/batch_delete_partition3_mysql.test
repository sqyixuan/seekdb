##owner: laibingzheng.lbz
##owner group: SQL2
##description: 分区表
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

--echo  #range and hash
drop table if exists t1;
CREATE TABLE  t1
(
     c1 int  NOT NULL auto_increment,
     c2 VARCHAR(20) ,
     c3 INT ,
     c4 DATE NOT NULL ,
     c5 VARCHAR(20)
)
PARTITION BY RANGE(c1)
SUBPARTITION BY HASH(YEAR(c4))
SUBPARTITIONS 3
(
  PARTITION P1 VALUES LESS THAN(200) ,
  PARTITION P2 VALUES LESS THAN MAXVALUE
) ;
alter table t1 add index index_c1(c1);
alter system flush plan cache global;
delimiter //;
insert into t1 values(1,'a',1001,'2022-01-01','一月');insert into t1 values(2,'b',1002,'2022-02-02','二月');insert into t1 values(3,'c',1003,'2022-03-03','三月');//
insert into t1 values(204,'d',1004,'2022-04-04','四月');insert into t1 values(205,'e',1005,'2022-05-05','五月');insert into t1 values(206,'f',1006,'2022-06-06','六月');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
select * from t1;
commit;

delimiter //;
insert into t1 partition(p1) values(99,'ll',1099,'2018-08-08','八月');insert into t1 partition(p1) values(100,'ss',1100,'2018-09-09','九月');insert into t1 partition(p1) values(101,'kk',1101,'2019-10-10','十月');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 partition(p1) values%' order by hit_count;
select * from t1 partition(p1) order by c1;
commit;


delimiter //;
delete from t1 where c1 = 1;delete from t1 where c1 = 2;delete from t1 where c1 = 3;//
delete from t1 where c1 = 100+1;delete from t1 where c1 = 98+1;delete from t1 where c1 = 99+1;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where c1 = %' order by hit_count;
select * from t1 order by c1;
rollback;

delimiter //;
delete from t1 partition(p2) where c1 = 204;delete from t1 partition(p2) where c1 = 205;delete from t1 partition(p2) where c1 = 206;//
delete from t1 partition(p1) where c1 = 99 and c2 = 'll';delete from t1 partition(p1) where c1 = 100 and c2 = 'ss';delete from t1 partition(p1) where c1 = 101 and c2 = 'kk';//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 partition(p2) where c1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 partition(p1) where c1 = % and c2 = %' order by hit_count;
select * from t1 order by c1;
rollback;

drop table t1;

--echo  #range and key
drop table if exists t2;
CREATE TABLE  t2
(
     c1 int ,
     c2 float not null,
     c3 decimal(5,2),
     c4 DATE NOT NULL,
     c5  timestamp,
     primary key(c1,c2)
)
PARTITION BY RANGE(c1)
SUBPARTITION BY KEY(c2)
SUBPARTITIONS 3
(
  PARTITION P1 VALUES LESS THAN(10) ,
  PARTITION P2 VALUES LESS THAN MAXVALUE
) ;

delimiter //;
insert into t2 values(1,1.111,1.11,'2020-02-02','2020-02-02 02:02:02');insert into t2 values(2,2.222,20.12,'2020-03-03','2020-03-03 03:03:03');insert into t2 values(3,3.333,33.45,'2020-04-04','2020-04-04 04:04:04');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 values%' order by hit_count;
select * from t2;
commit;


delimiter //;
delete from t2 where c1 = 1 and c2 = 1.111;delete from t2 where c1 = 2 and c2 = 2.222;delete from t2 where c1 = 3 and c2 = 3.333;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = % and c2 = %' order by hit_count;
select * from t2;
rollback;

alter system flush plan cache global;
delimiter //;
delete from t2 where c1 = 1;delete from t2 where c1 = 2;delete from t2 where c1 = 3;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t2 where c1 = %' order by hit_count;
select * from t2;
rollback;



--echo  #range and range
drop table if exists t3;

CREATE TABLE t3(c1 INT not null  auto_increment,c2 INT not null,c3 varchar(20) default'A1',primary key(c1,c2),index index_c1(c1))
PARTITION BY RANGE(c1)
SUBPARTITION BY RANGE(c2)
SUBPARTITION TEMPLATE
(SUBPARTITION mp1 VALUES LESS THAN(100),
SUBPARTITION mp2 VALUES LESS THAN(200),
SUBPARTITION mp3 VALUES LESS THAN(300)
)
(PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300)
);

delimiter //;
insert into t3 values(1,1,'AAa1');insert into t3 values(2,2,'BBb2');insert into t3 values(3,3,'CCc3');//
insert into t3 values(111,1,'AAa1');insert into t3 values(112,202,'BBb2');insert into t3 values(113,203,'CCc3');//
insert into t3 values(211,1,'AAa1');insert into t3 values(212,202,'BBb2');insert into t3 values(213,203,'CCc3');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 values%' order by hit_count;
select * from t3;
commit;


delimiter //;
insert into t3 partition(p0smp1) values(4,60,'李二');insert into t3 partition(p0smp1) values(5,61,'张三');insert into t3 partition(p0smp1) values(6,62,'王五');//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 partition(p0smp1) values%' order by hit_count;
select * from t3 partition(p0smp1);
commit;


delimiter //;
delete from t3 where c1 = 1 and c2 = 1;delete from t3 where c1 = 111 and c2 = 1;delete from t3 where c1 = 211 and c2 = 1;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where c1 = % and c2 = %' order by hit_count;
select * from t3;
rollback;



delimiter //;
delete from t3 partition(p0smp1) where c1 = 1 or c1 = 2;delete from t3 partition(p0smp1) where c1 = 3 or c1 = 4;delete from t3 partition(p0smp1) where c1 = 5 or c1 = 6;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 partition(p0smp1) where c1 = % or c1 = %' order by hit_count;
select * from t3 partition(p0smp1);
rollback;

drop table t3;





--echo  #range list
drop table if exists t4;
CREATE TABLE t4(c1 INT not null auto_increment,c2 INT,primary key(c1,c2),key index_c1_c2(c1,c2))
PARTITION BY RANGE COLUMNS(c1)
SUBPARTITION BY LIST COLUMNS(c2)
SUBPARTITION TEMPLATE
(SUBPARTITION mp0 VALUES IN(1,2,3),
SUBPARTITION mp1 VALUES IN(4,5,6),
SUBPARTITION mp2 VALUES IN(7,8,9)
)
(PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300)
);

delimiter //;
insert into t4 values(50,1);insert into t4 values(150,2);insert into t4 values(250,3);//
insert into t4 values(51,4);insert into t4 values(151,5);insert into t4 values(251,6);//
insert into t4 values(52,7);insert into t4 values(152,8);insert into t4 values(252,9);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 values%' order by hit_count;
select * from t4 order by c1;
commit;

delimiter //;
insert into t4 partition(p0smp0) values(22,2);insert into t4 partition(p0smp0) values(23,3);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 partition(p0smp1) values%' order by hit_count;
select * from t4 partition(p0smp0) order by c1;
commit;


delimiter //;
delete from t4 where c1 = 50 or c1 = 51;delete from t4 where c1 = 150 or c1 = 151;delete from t4 where c1 = 250 or c1 = 251;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 where c1 = % or c1 = %' order by hit_count;
select * from t4 order by c1;
rollback;


delimiter //;
delete from t4 partition(p0smp0) where c2 = 1;delete from t4 partition(p0smp0) where c2 = 2;delete from t4 partition(p0smp0) where c2 = 3;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t4 partition(p0smp0) where c2 = %' order by hit_count;
select * from t4 partition(p0smp0) order by c1;
rollback;

drop table t4;


drop table if exists t5;
CREATE TABLE t5(c1 INT default '66',c2 INT not null)
PARTITION BY RANGE (c1)
SUBPARTITION BY RANGE COLUMNS(c2)
SUBPARTITION TEMPLATE
(SUBPARTITION mp0 VALUES LESS THAN(1000),
SUBPARTITION mp1 VALUES LESS THAN(2000),
SUBPARTITION mp2 VALUES LESS THAN(3000)
)
(PARTITION p0 VALUES LESS THAN(100),
PARTITION p1 VALUES LESS THAN(200),
PARTITION p2 VALUES LESS THAN(300)
);
delimiter //;
insert into t5 values(99,999);insert into t5 values(199,1999);insert into t5 values(299,2999);//
insert into t5 values(66,666);insert into t5 values(166,1666);insert into t5 values(266,2666);//
insert into t5 values(33,333);insert into t5 values(133,1333);insert into t5 values(233,2333);//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5 values%' order by hit_count;
select * from t5 order by c1;
commit;


delimiter //;
delete from t5 where c1 = 33 and c2 = 333;delete from t5 where c1 = 166 and c2 = 1666;delete from t5 where c1 = 99 and c2 = 999;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 where c1 = % and c2 = %' order by hit_count;
select * from t5 order by c1;
rollback;


delimiter //;
delete from t5 partition(p0smp0) where c2 = 999;delete from t5 partition(p0smp0) where c2 = 333;delete from t5 partition(p0smp0) where c2 = 666;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t5 partition(p0smp0) where c2 = %' order by hit_count;
select * from t5 partition(p0smp0) order by c1;
rollback;
drop table t5;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;

