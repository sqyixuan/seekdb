##owner: laibingzheng.lbz
##owner group: SQL2
##description: 复制表中测试
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;
alter system set _rowsets_enabled=false;
sleep 3;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


create table t1(c1 int primary key,c2 varchar(60));
create table tt1 as select * from t1;
insert into tt1 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;

--echo  #delete...order by...limit ?,?/limit ? 没有进行batch 优化
delimiter //;
delete from tt1 order by c1 limit 1;delete from tt1 order by c1 limit 1;delete from tt1 order by c1 limit 1;//
delete from tt1 order by c1 limit 1;delete from tt1 order by c1 limit 1;delete from tt1 order by c1 limit 1;//
delimiter ;//
select * from tt1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt1 order by c1 limit %' order by hit_count;
rollback;

drop table tt1;



--echo  #delete ..where
create table t2(c1 decimal(5,3) not null,c2 double);
create table tt2 as select * from t2;
insert into tt2 values(10.222,1.123),(20.222,2.234),(30.333,3.456),(1.1234,5.2);
commit;

--echo  #where条件精度不同场景回退
delimiter //;
delete from tt2 where c1 = 10.222;delete from tt2 where c1 = 20.222;delete from tt2 where c1 = 30.333;//
delete from tt2 where c1 = 10.222;delete from tt2 where c1 = 1.1234;delete from tt2 where c1 = 30.333;//
delimiter ;//
select * from tt2;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt2 where c1 = %' order by hit_count;
rollback;
drop table tt2;


create table t3(c1 decimal(5,3) not null,c2 double);
create table tt3 as select * from t3;
insert into tt3 values(10.222,1.123),(20.222,2.234),(30.333,3.456),(1.1234,5.2);
commit;

--echo  #delete ...where c1 = ?+?
alter system flush plan cache global;
delimiter //;
delete from tt3 where c2 = 1+0.123;delete from tt3 where c2 = 2+0.234;delete from tt3 where c2 = 3+0.456;//
delete from tt3 where c2 = 1+0.123;delete from tt3 where c2 = 5+0.2;delete from tt3 where c2 = 3+0.456;//
delimiter ;//
select * from tt3;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt3 where c2 = %' order by hit_count;
rollback;
drop table tt3;


create table t4(c1 int not null default '8',c2 char(20));
create table tt4 as select * from t4;
insert into tt4 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
insert into tt4 values(8,'2020-02-02'),(8,'2021');
commit;

--echo  #delete ...where c1 = ?*?*? or ?/?/? or ?%?%?
delimiter //;
delete from tt4 where c1 = 6-1-1;delete from tt4 where c1 = 10-2-1;delete from tt4 where c1 = 8-3-0;//
delete from tt4 where c1 = 1*2*3;delete from tt4 where c1 = 2*2*2;delete from tt4 where c1 = 3*1*3;//
delete from tt4 where c1 = 9/3/3;delete from tt4 where c1 = 8/2/2;delete from tt4 where c1 = 12/2/2;//
delete from tt4 where c1 = 9%6%2;delete from tt4 where c1 = 11%6%3;delete from tt4 where c1 = 25%9%4;//
delimiter ;//
select * from tt4;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt4 where c1 = %' order by hit_count;
rollback;
drop table tt4;



create table t5(c1 int primary key auto_increment,c2 varchar(60))partition by hash(c1)
(partition p1,
partition p2,
partition p3
);
create table tt5 as select * from t5;
insert into tt5 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;

--echo  #delete ...where ..and....
delimiter //;
delete from tt5 where c1 = 4 and c2 = 'DD';delete from tt5 where c1 = 2 and c2 = 'AA';delete from tt5 where c1 = 3 and c2 = 'CC';//
delimiter ;//
select * from tt5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt5 where c1 = % and c2 = %' order by hit_count;
rollback;

alter system flush plan cache global;
delimiter //;
delete from tt5 where c1 = 4 and c2 = 'DD';delete from tt5 where c1 = 2 and c2 = 'AD';delete from tt5 where c1 = 3 and c2 = 'CC';//
delimiter ;//
select * from tt5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt5 where c1 = % and c2 = %' order by hit_count;
rollback;


#--echo  #delete ...where ..or....
#delimiter //;
#delete from tt5 where c1 = 1 or c1 = 3;delete from tt5 where c1 = 2 or c1 = 5;delete from tt5 where c1 = 7 or c1 = 9;//
#delete from tt5 where c1 = 1 or c1 = 3 and c2 = 'CC';delete from tt5 where c1 = 2 or c1 = 5 and c2 = '杭州';delete from tt5 where c1 = 7 or c1 = 9 and c2 = 'JJJ';//
#delimiter ;//
#select * from tt5;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt5 where c1 = % or c1 = %' order by hit_count;
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt5 where c1 = % or c1 = % and c2 = %' order by hit_count;
#rollback;

--echo  #delete 重复行(batch场景回退)
alter system flush plan cache global;
delimiter //;
delete from tt5 where c1 = 1 or c1 = 3;delete from tt5 where c1 = 2 or c1 = 3;delete from tt5 where c1 = 7 or c1 = 9;//
delimiter ;//
select * from tt5;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt5 where c1 = % or c1 = %' order by hit_count;
rollback;
drop table tt5;


create table t6(c1 float not null,c2 datetime not null);
create table tt6 as select * from t6;
insert into tt6 values(2.222,'2022-06-09'),(3.333,'2022-07-09'),(5.555,'2022-08-08'),(6.678,'1998-09-09'),(7.221,'2000-10-10'),(8.666,'2001-01-01'),(9.678,'2002-02-02'),(10.001,'2010-10-10'),(11.645,'2016-06-06'),(12.111,'2018-08-08');
commit;

--echo  #delete...where...and...order by...limit  没有进行batch优化
delimiter //;
delete from tt6 where c1 > 3 and c1 < 5 order by c1 desc limit 1;delete from tt6 where c1 > 6 and c1 < 8 order by c1 desc limit 1;delete from tt6 where c1 > 10 and c1 < 12 order by c1 desc limit 1;//
delimiter ;//
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from tt6 where c1 > % and c1 < % order by c1 desc limit %' order by hit_count;
select * from tt6;
rollback;
drop table tt6;


create table t7(c1 int primary key,c2 varchar(60));
create table tt7 as select * from t7;
insert into tt7 values(1,null),(2,'AA'),(3,'CC'),(4,'DD'),(5,'杭州 '),(6,'LLLL'),(7,'QQQ'),(8,'BBB'),(9,'JJJ'),(10,'SSSSA'),(11,'SSSS###'),(12,'SSSSkkj');
commit;
create table t8 (a1 int primary key auto_increment,a2 varchar(60) not null);
create table tt8 as select * from t8;
insert into tt8 values(1,'AA'),(2,'BB'),(3,'正在'),(4,'单独'),(5,'方法'),(6,'算数'),(7,'##$$'),(8,';;l'),(9,'3121/+651'),(10,'mgsg《'),(11,'asd123'),(12,'王w@'),(13,'ACD啊#￥');
commit;

--echo  #delete+非关联子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt8 as a where a.a1 = (select c1 from tt7 where c1 = 1);delete a from tt8 as a where a.a1 = (select c1 from tt7 where c1 = 2);delete a from tt8 as a where a.a1 = (select c1 from tt7 where c1 = 3);//
delete a from tt8 as a where a.a1 > (select min(c1) from tt7 where c1 > 6);delete a from tt8 as a where a.a1 > (select min(c1) from tt7 where c1 > 8);delete a from tt8 as a where a.a1 > (select min(c1) from tt7 where c1 > 10);//
delete a from tt8 as a where a.a1 >= (select min(c1) from tt7 where c1 > 6);delete a from tt8 as a where a.a1 >= (select min(c1) from tt7 where c1 > 8);delete a from tt8 as a where a.a1 >= (select min(c1) from tt7 where c1 > 10);//
delete a from tt8 as a where a.a1 < any(select max(c1) from tt7 where c1 < 5);delete a from tt8 as a where a.a1 < any(select max(c1) from tt7 where c1 < 6);delete a from tt8 as a where a.a1 < any(select max(c1) from tt7 where c1 < 7);//
delete a from tt8 as a where a.a1 <= all(select max(c1) from tt7 where c1 < 5 and c1 > 3);delete a from tt8 as a where a.a1 <= all(select max(c1) from tt7 where c1 < 6 and c1 >1);delete a from tt8 as a where a.a1 <= all(select max(c1) from tt7 where c1 < 7 and c1 > 4);//
delimiter ;//
select * from tt8;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt8 as a where %' order by hit_count;
rollback;
drop table tt7;
drop table tt8;




create table t9(c1 char(10) not null,c2 varchar(10));
create table tt9 as select * from t9;
create table t10(a1 char(10) not null,a2 varchar(10));
create table tt10 as select * from t10;
insert into tt9 values('aa','张三'),('bb','李四'),('cc','王五'),('dd','马六'),('ee','田七');
insert into tt10 values('aa','张三'),('bb','四'),('cc','王五'),('dd','六'),('ee','田七');
commit;

--echo  #delete + in关键字子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt10 as a where a.a1 in (select c1 from tt9 where c1 = 'aa');delete a from tt10 as a where a.a1 in (select c1 from tt9 where c1 = 'bb');delete a from tt10 as a where a.a1 in (select c1 from tt9 where c1 = 'cc');//
delete a from tt10 as a where a.a1 not in (select c1 from tt9 where c1 = 'aa');delete a from tt10 as a where a.a1 not in (select c1 from tt9 where c1 = 'dd');//
delimiter ;//
select * from tt10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt10 as a where a.a1 in %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt10 as a where a.a1 not in %' order by hit_count;
rollback;
drop table tt9;
drop table tt10;


create table t11(c1 varbinary(30) primary key,c2 binary(30));
create table tt11 as select * from t11;
create table t12(a1 varbinary(30) not null ,a2 binary(30));
create table tt12 as select * from t12;
insert into tt11 values(101,101),(202,202),(303,303),(404,404),(505,505),(606,606);
insert into tt12 values(101,101),(202,202),(303,303),(505,505),(606,606);
commit;

--echo  #delete+any子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt12 as a where a.a1 = any (select c1 from tt11 where c1 = 101);delete a from tt12 as a where a.a1 = any (select c1 from tt11 where c1 = 202);delete a from tt12 as a where a.a1 = any (select c1 from tt11 where c1 = 303);//
delete a from tt12 as a where a.a1 = all (select c1 from tt11 where c1 = 202);delete a from tt12 as a where a.a1 = all (select c1 from tt11 where c1 = 303);delete a from tt12 as a where a.a1 = all (select c1 from tt11 where c1 = 404);//
delimiter ;//
select * from tt12;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt12 as a where a.a1 = %' order by hit_count;
rollback;

drop table tt11;
drop table tt12;



create table t13(c1 year not null primary key , c2 date not null,index index_c1(c1));
create table tt13 as select * from t13;
create table t14(a1 year not null primary key , a2 date not null,index index_a1(a1));
create table tt14 as select * from t14;
insert into tt13 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08');
insert into tt14 values('2017','2017-08-08'),('2018','2018-08-08'),('2019','2019-08-08'),('2020','2020-08-08'),('2021','2021-08-08');
commit;

--echo  #delete+some子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt14 as a where a.a1 = some (select c1 from tt13 where c1 = 2017);delete a from tt14 as a where a.a1 = some (select c1 from tt13 where c1 = 2019);delete a from tt14 as a where a.a1 = some (select c1 from tt13 where c1 = 2020);//
delimiter ;//
select * from tt14;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt14 as a where a.a1 = %' order by hit_count;
rollback;


--echo  #delete+exists子查询(没有进行batch优化)
alter system flush plan cache global;
delimiter //;
delete a from tt14 as a where a.a1 = exists (select c1 from tt13 where c1 = 2018);delete a from tt14 as a where a.a1 = exists (select c1 from tt13 where c1 = 2020);delete a from tt14 as a where a.a1 = exists (select c1 from tt13 where c1 = 2019);//
delete a from tt14 as a where  not exists (select c1 from tt13 where c2 = '2017-08-08');delete a from tt14 as a where  not exists (select c1 from tt13 where c2 = '2019-08-08');delete a from tt14 as a where  not exists (select c1 from tt13 where c2 = '2020-08-08');//

delimiter ;//
select * from tt14;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt14 as a where a.a1 = %' order by hit_count;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a from tt14 as a where  %' order by hit_count;
rollback;
drop table tt13;
drop table tt14;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


