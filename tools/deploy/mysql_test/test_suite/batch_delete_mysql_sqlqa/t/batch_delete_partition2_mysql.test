--echo  #delete where +子查询
alter system flush plan cache global;
delimiter //;
delete from t13 where c1 = (select a1 from t14 where a2 =2);delete from t13 where c1 = (select a1 from t14 where a2 =5);delete from t13 where c1 = (select a1 from t14 where a2 =8);delete from t13 where c1 = (select a1 from t14 where a2 =11);//
delimiter ;//
select * from t13;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t13 where c1 = %' order by hit_count;
rollback;


--echo #delete join
delimiter //;
delete t13,t14 from t13 left join t14 on t13.c1 = t14.a1 where t13.c1 = 1;delete t13,t14 from t13 left join t14 on t13.c1 = t14.a1 where t13.c1 = 6;delete t13,t14 from t13 left join t14 on t13.c1 = t14.a1 where t13.c1 = 8;delete t13,t14 from t13 left join t14 on t13.c1 = t14.a1 where t13.c1 = 11;//
delimiter ;//
select * from t13;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t13,t14 from t13 left join t14 on t13.c1 = t14.a1 where t13.c1 = %' order by hit_count;
rollback;


delimiter //;
delete t13,t14,t15 from t13 left join t14 on t13.c1 = t14.a1 left join t15 on t13.c1 = t15.b1 where t13.c1 = 1;delete t13,t14,t15 from t13 left join t14 on t13.c1 = t14.a1 left join t15 on t13.c1 = t15.b1 where t13.c1 = 6;delete t13,t14,t15 from t13 left join t14 on t13.c1 = t14.a1 left join t15 on t13.c1 = t15.b1 where t13.c1 = 8;delete t13,t14,t15 from t13 left join t14 on t13.c1 = t14.a1 left join t15 on t13.c1 = t15.b1 where t13.c1 = 11;//
delimiter ;//
select * from t13;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t13,t14,t15 from t13 left join t14 on t13.c1 = t14.a1 left join t15 on t13.c1 = t15.b1 where t13.c1 = %' order by hit_count;
rollback;

drop table t13;
drop table t14;
drop table t15;





--echo  #range columns
create table t16(c1 int not null,c2 int not null,primary key (c1,c2),key index_c1_c2(c1,c2)) partition by range columns(c1)
(
partition p1 values less than(5),
partition p2 values less than(10),
partition p3 values less than(maxvalue)
);
insert into t16 values(1,1),(3,3),(6,6),(9,9),(11,11),(17,17);
commit;
insert into t16 values(4,1),(2,3),(5,6),(8,9),(12,5),(16,9);
commit;

create table t17(a1 int,a2 int);
insert into t17 values(1,1),(2,5),(3,3),(6,6),(9,9),(11,11),(17,17),(4,1),(5,6),(8,9),(12,5),(16,9);
commit;
create table t18(b1 int,b2 int);
insert into t18 values(1,1),(2,6),(3,3),(6,6),(9,9),(11,11),(15,15),(4,1),(5,6),(8,9),(12,5),(16,9);
commit;

alter system flush plan cache global;
delimiter //;
delete from t16 where c1 = 1;delete from t16 where c1 = 2;delete from t16 where c1 = 3;//
delimiter ;//
select * from t16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t16 where c1 = %' order by hit_count;
rollback;


delimiter //;
delete from t16 partition(p1) where c1 = 1;delete from t16 partition(p1) where c1 = 2;delete from t16 partition(p1) where c1 = 3;//
delimiter ;//
select * from t16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t16 partition(p1) where c1 = %' order by hit_count;
rollback;


--echo  #delete where +子查询
alter system flush plan cache global;
delimiter //;
delete from t16 where c1 = (select a1 from t17 where a1 =5);delete from t16 where c1 = (select a1 from t17 where a1 =1);delete from t16 where c1 = (select a1 from t17 where a1 =3);//
delimiter ;//
select * from t16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t16 where c1 = %' order by hit_count;
rollback;


--echo #delete join
delimiter //;
delete t16,t17 from t16 inner join t17 on t16.c1 = t17.a1 where t16.c1 = 1;delete t16,t17 from t16 inner join t17 on t16.c1 = t17.a1 where t16.c1 = 6;delete t16,t17 from t16 inner join t17 on t16.c1 = t17.a1 where t16.c1 = 11;//
delimiter ;//
select * from t16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t16,t17 from t16 inner join t17 on t16.c1 = t17.a1 where t16.c1 = %' order by hit_count;
rollback;


delimiter //;
delete t16,t17,t18 from t16 inner join t17 on t16.c1 = t17.a1 inner join t18 on t16.c1 = t18.b1 where t16.c1 = 1;delete t16,t17,t18 from t16 inner join t17 on t16.c1 = t17.a1 inner join t18 on t16.c1 = t18.b1 where t16.c1 = 6;delete t16,t17,t18 from t16 inner join t17 on t16.c1 = t17.a1 inner join t18 on t16.c1 = t18.b1 where t16.c1 = 11;//
delimiter ;//
select * from t16;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete t16,t17,t18 from t16 inner join t17 on t16.c1 = t17.a1 inner join t18 on t16.c1 = t18.b1 where t16.c1 = %' order by hit_count;
rollback;

drop table t16;
drop table t17;
drop table t18;



alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;


