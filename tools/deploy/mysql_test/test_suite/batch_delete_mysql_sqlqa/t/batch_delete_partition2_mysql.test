#delete from t13 partition(p0) where c1 = 1;delete from t13 partition(p0) where c1 = 2;delete from t13 partition(p0) where c1 = 3;//
#delimiter ;//
#select * from t13 partition(p0);
#select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t13 partition(p0) where c1 = %' order by hit_count;
