##owner: laibingzheng.lbz
##owner group: SQL2
##description: 分区表中测试batch delete
##tags: batch delete
##author : wb-zwc01059807

--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--enable_info

--result_format 4

alter system flush plan cache global;
sleep 3;

alter system set _rowsets_enabled=false;
sleep 3;

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;


--echo  #key分区
drop table if exists t10,t11,t12;
create table t10(c1 year not null primary key , c2 datetime not null,index index_c1(c1))
partition by key(c1)
partitions 3;
insert into t10 values(2001,'2001-01-01'),(2002,'2002-02-02'),(2003,'2003-03-03'),(2004,'2004-04-04'),(2005,'2005-05-05'),(2006,'2006-06-06'),(2007,'2007-07-07'),(2008,'2008-08-08'),(2009,'2009-09-09'),(2010,'2010-10-10'),(2011,'2011-11-11'),(2012,'2012-12-12');
commit;

create table t11(a1 varchar(20),a2 datetime not null);
insert into t11 values(2001,'2001-01-01'),(2002,'2002-02-02'),(2003,'2003-03-03'),(2004,'2004-04-04'),(2005,'2005-05-05'),(2006,'2006-06-06'),(2007,'2007-07-07'),(2008,'2008-08-08'),(2009,'2009-09-09'),(2010,'2010-10-10'),(2011,'2011-11-11'),(2012,'2012-12-12');
commit;
create table t12(b1 int,b2 datetime not null);
insert into t12 values(2001,'2001-01-01'),(2002,'2002-02-02'),(2003,'2003-03-03'),(2004,'2004-04-04'),(2005,'2005-05-05'),(2006,'2006-06-06'),(2007,'2007-07-07'),(2008,'2008-08-08'),(2009,'2009-09-09'),(2010,'2010-10-10'),(2011,'2011-11-11'),(2012,'2012-12-12');
commit;


alter system flush plan cache global;
delimiter //;
delete from t10 where c1 = 5;delete from t10 where c1 = 6;delete from t10 where c1 = 8;//
delimiter ;//
select * from t10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t10 where c1 = %' order by hit_count;
rollback;


delimiter //;
delete from t10 partition(p0) where c1 = 5;delete from t10 partition(p0) where c1 = 6;delete from t10 partition(p0) where c1 = 8;//
delimiter ;//
select * from t10;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t10 partition(p0) where c1 = %' order by hit_count;
rollback;


--echo  #delete ...join...
delimiter //;
delete a,b from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 where a.c1 = 4;delete a,b from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 where a.c1 = 5;delete a,b from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 where a.c1 = 10;//
delimiter ;//
select * from t10 partition(p0);
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a,b from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 where a.c1 = %' order by hit_count;
rollback;


--echo  #delete ...join...
delimiter //;
delete a,b,c from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 inner join t12 as c on a.c1 = c.b1 where a.c1 = 4;delete a,b,c from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 inner join t12 as c on a.c1 = c.b1 where a.c1 = 5;delete a,b,c from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 inner join t12 as c on a.c1 = c.b1 where a.c1 = 10;//
delimiter ;//
select * from t10 partition(p0);
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete a,b,c from t10 partition(p0) as a inner join t11 as b on a.c1 = b.a1 inner join t12 as c on a.c1 = c.b1 where a.c1 = %' order by hit_count;
rollback;

drop table t10;
drop table t11;
drop table t12;




--echo  #list columns 分区
drop table if exists t13,t14,t15;
create table t13(c1 int not null default 7,c2 varchar(60))
partition by list columns(c1)
(
partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9),
partition p3 values in(10,11,12)
);
create index index_c1 on t13(c1);
insert into t13 values(1,'A'),(1,'A2'),(1,'A3'),(2,'B'),(2,'B2'),(3,'C'),(3,'C2'),(3,'C3'),(3,'C4'),(4,'D'),(5,'E'),(6,'F'),(7,'G'),(8,'H'),(9,'I'),(10,'J'),(11,'K'),(12,'L');
commit;

create table t14(a1 int  not null,a2 decimal(10,5) not null);
insert into t14 values(1,1.1),(2,2.22),(3,4.44),(4,4.444),(5,5.23),(6,6.45),(7,7.456),(8,8.4563),(9,9.432),(10,10.134),(11,11.456),(12,12.121);
commit;

create table t15(b1 int not null,b2 double not null);
insert into t15 values(1,1.1),(2,2.22),(3,4.44),(4,4.444),(5,5.23),(6,6.45),(7,7.456),(8,8.4563),(9,9.432),(10,10.134),(11,11.456),(12,12.121);
commit;

