INSERT INTO T1 VALUES (NULL,NULL,NULL,NULL);
INSERT INTO T1 VALUES (1E+125,1E+8-1,1E+38-1,9);
INSERT INTO T1 VALUES (-1E+125,-1E+8+1,-1E+38+1,-9);
INSERT INTO T1 VALUES (1E-130,0.99,0.9,0.9);
INSERT INTO T1 VALUES (-1E-130,-0.99,-0.9,-0.9);
INSERT INTO T1 VALUES (0,0,0,0);

CREATE OR REPLACE FUNCTION FUNC01(PAR T1.C3%TYPE) RETURN number AS 
TYPE TYP01 IS VARRAY(6) OF T1%ROWTYPE;
A TYP01;
BEGIN
    SELECT * BULK COLLECT INTO A FROM T1;
    IF PAR = 1 THEN
    RETURN A(PAR).C1;
    ELSIF PAR = 2 THEN
    RETURN A(PAR).C2;
    ELSIF PAR = 3 THEN
    RETURN A(PAR).C3;
    ELSIF PAR = 4 THEN
    RETURN A(PAR).C4;
    END IF;
END;
/


