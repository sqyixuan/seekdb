|         NULL |    NULL |    NULL |
+--------------+---------+---------+

## round ob_expr_func_round.cpp
select round(c1), round(c2), round(c3) from t1;
+-----------+-----------+-----------+
| round(c1) | round(c2) | round(c3) |
+-----------+-----------+-----------+
|     12346 |     23456 |     34567 |
|     12345 |     23456 |     34567 |
|    -12346 |    -23456 |    -34567 |
|         0 |         0 |         0 |
|      NULL |      NULL |      NULL |
+-----------+-----------+-----------+
select round(c1, 2), round(c2, 2), round(c3, 2) from t1;
+--------------+--------------+--------------+
| round(c1, 2) | round(c2, 2) | round(c3, 2) |
+--------------+--------------+--------------+
|     12345.68 |        23456 |        34567 |
|     12345.00 |        23456 |        34567 |
|    -12345.68 |       -23456 |       -34567 |
|         0.00 |            0 |            0 |
|         NULL |         NULL |         NULL |
+--------------+--------------+--------------+
select round(c1, -2), round(c2, -2), round(c3, -2) from t1;
+---------------+---------------+---------------+
| round(c1, -2) | round(c2, -2) | round(c3, -2) |
+---------------+---------------+---------------+
|         12300 |         23500 |         34600 |
|         12300 |         23500 |         34600 |
|        -12300 |        -23500 |        -34600 |
|             0 |             0 |             0 |
|          NULL |          NULL |          NULL |
+---------------+---------------+---------------+

## truncate ob_expr_truncate.cpp
select truncate(c1, 0), truncate(c2, 0), truncate(c3, 0) from t1;
+-----------------+-----------------+-----------------+
| truncate(c1, 0) | truncate(c2, 0) | truncate(c3, 0) |
+-----------------+-----------------+-----------------+
|           12345 |           23456 |           34567 |
|           12345 |           23456 |           34567 |
|          -12345 |          -23456 |          -34567 |
|               0 |               0 |               0 |
|            NULL |            NULL |            NULL |
+-----------------+-----------------+-----------------+
select truncate(c1, 2), truncate(c2, 2), truncate(c3, 2) from t1;
+-----------------+-----------------+-----------------+
| truncate(c1, 2) | truncate(c2, 2) | truncate(c3, 2) |
+-----------------+-----------------+-----------------+
|        12345.67 |        23456.00 |        34567.00 |
|        12345.00 |        23456.00 |        34567.00 |
|       -12345.67 |       -23456.00 |       -34567.00 |
|            0.00 |            0.00 |            0.00 |
|            NULL |            NULL |            NULL |
+-----------------+-----------------+-----------------+
select truncate(c1, -2), truncate(c2, -2), truncate(c3, -2) from t1;
+------------------+------------------+------------------+
| truncate(c1, -2) | truncate(c2, -2) | truncate(c3, -2) |
+------------------+------------------+------------------+
|            12300 |            23400 |            34500 |
|            12300 |            23400 |            34500 |
|           -12300 |           -23400 |           -34500 |
|                0 |                0 |                0 |
|             NULL |             NULL |             NULL |
+------------------+------------------+------------------+

## mod ob_expr_mod.cpp
select mod(c1, 0), mod(c2, 3.5), mod(c3, -4.3) from t1;
