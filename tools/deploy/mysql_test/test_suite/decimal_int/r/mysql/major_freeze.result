result_format: 4

drop table if exists merge_t1;
drop table if exists merge_t2;
drop table if exists merge_t3;
drop sequence if exists m_seq1;
drop sequence if exists m_seq2;
drop sequence if exists m_seq3;
create table merge_t1(pk decimal(10, 2) primary key);
create table merge_t2(a decimal(10, 2));
create index idx_merge_a on merge_t2(a);
create table merge_t3(a decimal(10, 3));

create sequence m_seq1;
create sequence m_seq2;
create sequence m_seq3;

insert into merge_t1 select cast(m_seq1.nextval as decimal(10, 2)) as a from table(generator(10000));
insert into merge_t2 select cast(m_seq2.nextval as decimal(10, 2)) as a from table(generator(10000));
insert /*+query_timeout(10000000000) */into merge_t3 select (m_seq3.nextval + 0.12) as a from table(generator(110000));

select * from merge_t1;
