result_format: 4
drop table if exists t;
create table t(a int);
set div_precision_increment = 0;
explain basic SELECT /*+ NO_REWRITE USE_PLAN_CACHE(NONE) DBMS_STATS OPT_PARAM('ROWSETS_MAX_ROWS', 32) FULL(`tree`)  USE_PX, PARALLEL(64)*/  TOP_K_FRE_HIST(0.001000, `a`, 254, 1) FROM t;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |SCALAR GROUP BY          |        |
|1 |└─PX COORDINATOR         |        |
|2 |  └─EXCHANGE OUT DISTR   |:EX10000|
|3 |    └─MERGE GROUP BY     |        |
|4 |      └─PX BLOCK ITERATOR|        |
|5 |        └─TABLE FULL SCAN|t       |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), t.a, 254, 1), 
      254, 1)]), filter(nil), rowset=32
      group(nil), agg_func([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), 
      t.a, 254, 1), 254, 1)])
  1 - output([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), t.a, 254, 1)]), filter(nil), rowset=32
  2 - output([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), t.a, 254, 1)]), filter(nil), rowset=32
      dop=64
  3 - output([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), t.a, 254, 1)]), filter(nil), rowset=32
      group(nil), agg_func([T_FUN_TOP_FRE_HIST((cast(1, DECIMAL_INT(35, 15)) / 0.001000), t.a, 254, 1)])
  4 - output([t.a]), filter(nil), rowset=32
  5 - output([t.a]), filter(nil), rowset=32
      access([t.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t.__pk_increment]), range(MIN ; MAX)always true

