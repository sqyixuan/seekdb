drop table t1;
create table t1 (c1 int, PRIMARY KEY (`c1`)) partition by hash(c1) (partition p0, partition p1, partition p2);
insert into t1 values (1),(2),(3),(4),(5),(6);
explain select sum(c1) as b from t1 having b > 1;
