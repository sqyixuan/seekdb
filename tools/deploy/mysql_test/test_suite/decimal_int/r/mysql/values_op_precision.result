result_format: 4
alter system set _min_const_integer_precision = 1;
alter system flush plan cache global;

drop table if exists t;
create table t (a bigint);

insert into t values (1);
insert into t values (10000);
insert into t values (100000000);
insert into t values (100000000000000000);

select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t values (?)';
+--------------------------+-----------+--------------------------+
| statement                | hit_count | query_sql                |
+--------------------------+-----------+--------------------------+
| insert into t values (?) |         3 | insert into t values (1) |
+--------------------------+-----------+--------------------------+

insert into t values (1 + 1);
insert into t values (1000000 + 1);
insert into t values (1 + 100000000000000000);
insert into t values (100000000 + 100000000000000000);

select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t values (? + ?)';
+------------------------------+-----------+------------------------------+
| statement                    | hit_count | query_sql                    |
+------------------------------+-----------+------------------------------+
| insert into t values (? + ?) |         3 | insert into t values (1 + 1) |
+------------------------------+-----------+------------------------------+

insert into t values (case when 1 = 1 then 1 else 2 end);
insert into t values (case when 10000 = 10000000 then 1 else 2 end);
insert into t values (case when 100000000000000000 = 10000000 then 1 else 2 end);

select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'insert into t values (case when ? = ? then ? else ? end)';
+----------------------------------------------------------+-----------+----------------------------------------------------------+
| statement                                                | hit_count | query_sql                                                |
+----------------------------------------------------------+-----------+----------------------------------------------------------+
| insert into t values (case when ? = ? then ? else ? end) |         2 | insert into t values (case when 1 = 1 then 1 else 2 end) |
+----------------------------------------------------------+-----------+----------------------------------------------------------+

select * from t;
+--------------------+
| a                  |
+--------------------+
|                  1 |
|              10000 |
|          100000000 |
| 100000000000000000 |
|                  2 |
|            1000001 |
| 100000000000000001 |
| 100000000100000000 |
|                  1 |
|                  2 |
|                  2 |
+--------------------+

drop table t;

drop table if exists t5;
create table t5 (c1 BIGINT(2147483643) ,c2 BIGINT(2147483643) ,c3 DATE,c4 DATETIME,c5 DATETIME,c6 YEAR(4) ,c7 TIME,c8 TIMESTAMP NOT NULL default 0,c9 TIME,c10 INTEGER(2147483640) ,c11 CHAR(152) ,c12 VARCHAR(86) ,c13 TIMESTAMP(3)  NOT NULL default 0,c14 CHAR(152) ,c15 INT(2147483645) ,c16 TIMESTAMP(2)  NOT NULL default 0,c17 CHAR(152) ,c18 DATETIME, primary key(c11,c14,c12,c2))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ;
create unique index u_0_ZflxDtHRAq on t5(c2,c11,c14,c12);
create unique index g_u_1_AhdDrByyBw on t5(c17,c2) global;
create index g_i_0_GMjEUekUmm on t5(c11,c12,c14) global;
create index g_i_1_BYNWTWVZDu on t5(c1,c10) global;

select statement, hit_count, is_batched_multi_stmt from oceanbase.gv$ob_plan_cache_plan_stat where statement like 'REPLACE INTO t5 (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18) VALUES%';
+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------------+
| statement                                                                                                                                                                                                                                                                                                                                           | hit_count | is_batched_multi_stmt |
+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------------+
| REPLACE INTO t5 (c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17, c18) VALUES ( ( (?+?-? ) +?-? ) , ( ( ?+?-? ) +?-? ), ?, ?, ?, ?, ?, ?, ?, ( (?+?-? ) +?-? ), repeat( repeat( ? , ? ) , ?) , repeat( repeat ( ?, ?) , ? ) , ?, repeat( repeat ( ? , ? ) , ? ), ( ( ?+?-?)+?-?) , ?, repeat (repeat ( ? , ?) , ? ) , ?) |         0 |                     1 |
+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+-----------+-----------------------+

alter system set _inlist_rewrite_threshold = 1;
alter system flush plan cache global;
create table t(
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_timestamp` timestamp NULL DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_double` double DEFAULT NULL,
  `pk` int(11) NOT NULL,
  PRIMARY KEY (`pk`),
  KEY `in_expr_idx3` (`col_double`, `col_varchar_20`, `col_timestamp`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range(pk)
(partition `p1` values less than (50),
partition `p2` values less than (MAXVALUE));

insert into t values
('english', NULL, '2003-07-17 12:48:23', -7922957644451545088, 0, 1),
('english', -45, '2001-07-12 01:53:52', 42, 0, 2),
('', -121, '2005-08-26 07:14:10', 3, 0, 3),
('i', NULL, '2000-04-28 23:45:43', -2657968205078724608, 0, 4);

explain basic SELECT
/*+
  BEGIN_OUTLINE_DATA
  LEADING(@"SEL$78C52BFB" ("VIEW2"@"SEL$1" "test"."t"@"SEL$1"))
  USE_NL(@"SEL$78C52BFB" "test"."t"@"SEL$1")
  PQ_DISTRIBUTE(@"SEL$78C52BFB" "test"."t"@"SEL$1" LOCAL LOCAL)
  USE_HASH_DISTINCT(@"SEL$2")
  INDEX(@"SEL$78C52BFB" "test"."t"@"SEL$1" "in_expr_idx3")
  UNNEST(@"SEL$2")
  SEMI_TO_INNER(@"SEL$6FCAE2AA" "VIEW2")
  OPTIMIZER_FEATURES_ENABLE('')
  END_OUTLINE_DATA
*/
* FROM t WHERE (col_double,col_decimal_20_0) IN ((1,1),(1,1)) order by 1,2,3,4,5,6;
Query Plan
==================================================
|ID|OPERATOR                     |NAME           |
--------------------------------------------------
|0 |SORT                         |               |
|1 |└─NESTED-LOOP JOIN           |               |
|2 |  ├─SUBPLAN SCAN             |VIEW2          |
|3 |  │ └─HASH DISTINCT          |               |
|4 |  │   └─VALUES TABLE ACCESS  |VALUES_TABLE1  |
|5 |  └─PX COORDINATOR           |               |
|6 |    └─EXCHANGE OUT DISTR     |:EX10000       |
|7 |      └─PX PARTITION ITERATOR|               |
|8 |        └─TABLE RANGE SCAN   |t(in_expr_idx3)|
==================================================
Outputs & filters:
-------------------------------------
  0 - output([t.col_varchar_20], [t.col_decimal_20_0], [t.col_timestamp], [t.col_bigint], [t.col_double], [t.pk]), filter(nil), rowset=16
      sort_keys([t.col_varchar_20, ASC], [t.col_decimal_20_0, ASC], [t.col_timestamp, ASC], [t.col_bigint, ASC], [t.col_double, ASC], [t.pk, ASC])
  1 - output([t.col_varchar_20], [t.col_decimal_20_0], [t.col_timestamp], [t.col_bigint], [t.col_double], [t.pk]), filter(nil), rowset=16
      conds(nil), nl_params_([VIEW2.column_0(:0)], [VIEW2.column_1(:1)]), use_batch=false
  2 - output([VIEW2.column_0], [VIEW2.column_1]), filter(nil), rowset=16
      access([VIEW2.column_0], [VIEW2.column_1])
  3 - output([cast(VALUES_TABLE1.column_0, DOUBLE(-1, -1))], [cast(VALUES_TABLE1.column_1, DECIMAL_INT(20, 0))]), filter(nil), rowset=16
      distinct([cast(VALUES_TABLE1.column_0, DOUBLE(-1, -1))], [cast(VALUES_TABLE1.column_1, DECIMAL_INT(20, 0))])
  4 - output([VALUES_TABLE1.column_0], [VALUES_TABLE1.column_1]), filter(nil)
      access([VALUES_TABLE1.column_0], [VALUES_TABLE1.column_1])
  5 - output([t.col_varchar_20], [t.col_decimal_20_0], [t.col_timestamp], [t.col_bigint], [t.col_double], [t.pk]), filter(nil), rowset=16
  6 - output([t.col_varchar_20], [t.col_decimal_20_0], [t.col_timestamp], [t.col_bigint], [t.col_double], [t.pk]), filter(nil), rowset=16
      dop=1
  7 - output([t.pk], [t.col_double], [t.col_decimal_20_0], [t.col_varchar_20], [t.col_timestamp], [t.col_bigint]), filter(nil), rowset=16
      force partition granule
  8 - output([t.pk], [t.col_double], [t.col_decimal_20_0], [t.col_varchar_20], [t.col_timestamp], [t.col_bigint]), filter([t.col_decimal_20_0 = :1]), rowset=16
      access([t.pk], [t.col_double], [t.col_decimal_20_0], [t.col_varchar_20], [t.col_timestamp], [t.col_bigint]), partitions(p[0-1])
      is_index_back=true, is_global_index=false, filter_before_indexback[false], 
      range_key([t.col_double], [t.col_varchar_20], [t.col_timestamp], [t.pk]), range(MIN ; MAX), 
      range_cond([t.col_double = :0])

