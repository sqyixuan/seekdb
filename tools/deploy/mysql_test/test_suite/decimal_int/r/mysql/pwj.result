drop table pwj_t1;
drop table pwj_t2;
drop table pwj_t3;
drop table pwj_t4;

create table pwj_t1 (pk1 number(10, 2)) partition by key(pk1) partitions 3;
create table pwj_t2 (pk2 number(10, 2)) partition by key(pk2) partitions 3;
create table pwj_t3 (pk3 number(38, 2)) partition by key(pk3) partitions 3;
create table pwj_t4 (pk4 number(10, 3)) partition by key(pk4) partitions 3;

