result_format: 4
alter system set _min_const_integer_precision = 1;
alter system flush plan cache global;
select 1 as zz from dual;
+----+
| zz |
+----+
|  1 |
+----+
select 100 as zz from dual;
+-----+
| zz  |
+-----+
| 100 |
+-----+
select 10000 as zz from dual;
+-------+
| zz    |
+-------+
| 10000 |
+-------+
select 100000 as zz from dual;
+--------+
| zz     |
+--------+
| 100000 |
+--------+
select 10000000000 as zz from dual;
+-------------+
| zz          |
+-------------+
| 10000000000 |
+-------------+
select 100000000000 as zz from dual;
+--------------+
| zz           |
+--------------+
| 100000000000 |
+--------------+
select 100000000000000000 as zz from dual;
+--------------------+
| zz                 |
+--------------------+
| 100000000000000000 |
+--------------------+
select 1000000000000000000 as zz from dual;
+---------------------+
| zz                  |
+---------------------+
| 1000000000000000000 |
+---------------------+

select 1 * 1.0 from dual;
+---------+
| 1 * 1.0 |
+---------+
|     1.0 |
+---------+
select 10 * 1.0 from dual;
+----------+
| 10 * 1.0 |
+----------+
|     10.0 |
+----------+
select 10000 * 1.0 from dual;
+-------------+
| 10000 * 1.0 |
+-------------+
|     10000.0 |
+-------------+
select 100000000 * 1.0 from dual;
+-----------------+
| 100000000 * 1.0 |
+-----------------+
|     100000000.0 |
+-----------------+
select 100000000000000000 * 1.0 from dual;
+--------------------------+
| 100000000000000000 * 1.0 |
+--------------------------+
|     100000000000000000.0 |
+--------------------------+

select 1 from dual where 2 in (123, 1234, 12345, 123456);
+---+
| 1 |
+---+
+---+
select 1 from dual where 2 in (1234, 12345, 1234567, 1234567890011);
+---+
| 1 |
+---+
+---+
select 1 from dual where 2 in (100000000000000, 10000000000, 1234567898765432, 1);
+---+
| 1 |
+---+
+---+

select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'select ? as zz from dual';
+--------------------------+-----------+--------------------------+
| statement                | hit_count | query_sql                |
+--------------------------+-----------+--------------------------+
| select ? as zz from dual |         7 | select 1 as zz from dual |
+--------------------------+-----------+--------------------------+
select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'select ? * ? from dual';
+------------------------+-----------+-------------------------------------------+
| statement              | hit_count | query_sql                                 |
+------------------------+-----------+-------------------------------------------+
| select ? * ? from dual |         1 | select 1 * 1.0 from dual                  |
| select ? * ? from dual |         0 | select 10000 * 1.0 from dual              |
| select ? * ? from dual |         0 | select 100000000 * 1.0 from dual          |
| select ? * ? from dual |         0 | select 100000000000000000 * 1.0 from dual |
+------------------------+-----------+-------------------------------------------+
select statement, hit_count, query_sql from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'select ? from dual where ? in (?, ?, ?, ?)';
+--------------------------------------------+-----------+----------------------------------------------------------+
| statement                                  | hit_count | query_sql                                                |
+--------------------------------------------+-----------+----------------------------------------------------------+
| select ? from dual where ? in (?, ?, ?, ?) |         2 | select 1 from dual where 2 in (123, 1234, 12345, 123456) |
+--------------------------------------------+-----------+----------------------------------------------------------+
alter system set _min_const_integer_precision = 8;
