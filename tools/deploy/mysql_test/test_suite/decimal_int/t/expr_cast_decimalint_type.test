#bug 54343096
--disable_warnings
drop table if exists t9;
--enable_warnings
create table t9 (c11  decimal(64,7) DEFAULT NULL, c47 decimal(64,16) DEFAULT NULL, c34 int(127) DEFAULT NULL);
create index u_3_JRh on t9(c11, c34, c47);
insert into t9 values (17551.9221266197930001, 17550.9221266197930000, 99705318);
insert into t9 values (17550.9221266197930001, 17550.9221266197930000, 99705318);
explain SELECT /* expect one row */
  t9_25.c11,
  t9_25.c47,
  t9_25.c34
FROM t9 AS t9_25
WHERE
 t9_25.c11 >= (
   (
     SELECT t9_25.c47 FROM t9 AS t9_25 ORDER BY 1 ASC LIMIT 1
   )
   UNION
   (
     SELECT t9_25.c34 FROM t9 AS t9_25 ORDER BY 1 DESC LIMIT 1
   )
   ORDER BY 1 LIMIT 1
 );

SELECT /* expect one row */
  t9_25.c11,
  t9_25.c47,
  t9_25.c34
FROM t9 AS t9_25
WHERE
 t9_25.c11 >= (
   (
     SELECT t9_25.c47 FROM t9 AS t9_25 ORDER BY 1 ASC LIMIT 1
   )
   UNION
   (
     SELECT t9_25.c34 FROM t9 AS t9_25 ORDER BY 1 DESC LIMIT 1
   )
   ORDER BY 1 LIMIT 1
 );

SELECT /* expect one row */
  t9_25.c11,
  t9_25.c47,
  t9_25.c34
FROM t9 AS t9_25
WHERE
 t9_25.c11 <= (
   (
     SELECT t9_25.c47 FROM t9 AS t9_25 ORDER BY 1 ASC LIMIT 1
   )
   UNION
   (
     SELECT t9_25.c34 FROM t9 AS t9_25 ORDER BY 1 DESC LIMIT 1
   )
   ORDER BY 1 LIMIT 1
 );

drop table t9;

create table t9(c1 number(10, 2), c2 number(10, 3), c3 int);
create index idx_t9 on t9(c1, c2, c3);

insert into t9 values (100, 8888888.999, 100);

select * from t9 where c1 != (select c2 from t9 limit 1);
select * from t9 where c1 = (select c2 from t9 limit 1);

select * from t9 where c1 >= (select c2 from t9 limit 1);
select * from t9 where c1 <= (select c2 from t9 limit 1);

select * from t9 where c1 < (select c2 from t9 limit 1);
select * from t9 where c1 > (select c2 from t9 limit 1);

select * from t9 where c1 != (select c3 from t9 limit 1);
select * from t9 where c1 = (select c3 from t9 limit 1);

select * from t9 where c1 >= (select c3 from t9 limit 1);
select * from t9 where c1 <= (select c3 from t9 limit 1);

select * from t9 where c1 < (select c3 from t9 limit 1);
select * from t9 where c1 > (select c3 from t9 limit 1);

drop table t9;

