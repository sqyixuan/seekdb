#case0: cast expr with const values
--enable_warnings
select cast(12.3456 as number(10, 3)) from dual;
select cast(12.2354 as number(10, 3)) from dual;
select cast(12.2545 as number(4, 2)) from dual;
select cast(12.2555 as number(4, 2)) from dual;
select cast(123.456 as number(4, 2)) from dual;
select cast(99999.999994 as number(10, 5)) from dual;
select cast(99999.999999 as number(10, 5)) from dual;
select cast(-99999.999994 as number(10, 5)) from dual;
select cast(-99999.999995 as number(10, 5)) from dual;

explain select cast(12.3456 as number(10, 3)) from dual;
explain select cast(12.2545 as number(4, 2)) from dual;
explain select cast(99999.999994 as number(10, 5)) from dual;

select cast(1234567890123456789.1234567890123456789 as character(32)) from dual;
select cast(1234567890123456789.1234567890123456789 as character(38)) from dual;
select cast(1234567890123456789.1234567890123456789 as character(39)) from dual;

select cast(99.49 as signed) from dual;
select cast(99.54 as signed) from dual;
select cast(-99.49 as signed) from dual;
select cast(-99.54 as signed) from dual;

select cast(999.49 as unsigned) from dual;
select cast(-999.49 as unsigned) from dual;
select cast(999.59 as unsigned) from dual;
select cast(-999.59 as unsigned) from dual;

explain select cast(1234567890123456789.1234567890123456789 as character(32)) from dual;
explain select cast(99.49 as signed) from dual;
explain select cast(999.49 as unsigned) from dual;

select cast(12 as binary(4)) from dual;
select cast(123 as binary(1)) from dual;
select cast(12.234 as binary(4)) from dual;
select cast(123.34 as binary(1)) from dual;

select cast(99999.99999 as double) from dual;
select cast(9999999999999999999999999999999999999.9 as double) from dual;
select cast(9999999999999999999999999999999999999.9 as float(5)) from dual;

--disable_warnings
drop table if exists decimalint_t;
--enable_warnings
#case1
create table decimalint_t(c0 number(10, 5));
insert into decimalint_t values (1.12345);
insert into decimalint_t values (1.123456);
insert into decimalint_t values (1.123454);
insert into decimalint_t values ('1.23e4');
insert into decimalint_t values (1.23e4);
insert into decimalint_t values ('00012.345');
insert into decimalint_t values ('   001.2345e3  ');
insert into decimalint_t values (+.12e-3);
insert into decimalint_t values (-.23e+5);
insert into decimalint_t values (99999.999994);
insert into decimalint_t values (-99999.999994);
--error 1264
insert into decimalint_t values (1.23e5);
--error 1366
insert into decimalint_t values ('1e4;');
--error 1366
insert into decimalint_t values ('1;.23e4');
--error 1366
insert into decimalint_t values ('  ');
--error 1264
insert into decimalint_t values (99999.999995);
--error 1264
insert into decimalint_t values (-99999.999995);
select * from decimalint_t;
--explain_protocol 1
select * from decimalint_t where c0 = 1.12345;
select * from decimalint_t where c0 = 1.123451;
select * from decimalint_t where c0 = '1.123454123456789';
select * from decimalint_t where c0 = '1.123455';
select * from decimalint_t where c0 = 1.23e4;

drop table decimalint_t;
--explain_protocol 0
create table decimalint_t(c0 number(10, 5), c1 number(15, 6));
insert into decimalint_t values (1234.123, 112345.1234567);
insert into decimalint_t values (99999.99999, 100);
insert into decimalint_t values (100, 999999999.999999);
insert into decimalint_t values (99999.99999, 999999999.999999);
select * from decimalint_t;
--explain_protocol 1
select * from decimalint_t where c0 + 1 = 1235.123;
select * from decimalint_t where c0 + 100.12345678 = 1334.24645678;
select * from decimalint_t where c0 + c1 = 100099.99999 or c0 + c1 = 1000000099.999999;
select * from decimalint_t where c0 + c1 = 1000099999.999989;
--explain_protocol 0

drop table decimalint_t;
create table decimalint_t (pk number(9, 5) primary key, c1 number(10, 5));
insert into decimalint_t values (100.0, 1234.12345);
insert into decimalint_t values (111.222, 10000.1234);
insert into decimalint_t values (200.0, 1.12345);
insert into decimalint_t values (1.0, 100);

--explain_protocol 3
select * from decimalint_t where pk > 100.12;
select * from decimalint_t where pk >= 100 and pk < 111.22194;
select * from decimalint_t where pk = 200 or pk >= 200;
select * from decimalint_t where pk = 100 or pk = 200 or pk > 300;
select * from decimalint_t where pk = 100;
select * from decimalint_t where pk = 111.222;
select * from decimalint_t where pk = 100.000000000;
select * from decimalint_t where pk = '100.00';
select * from decimalint_t where pk = '100.00000000000';
select * from decimalint_t where pk = '-4294967295';
select * from decimalint_t where pk = '99.9999999';

--explain_protocol 0
drop table decimalint_t;
create table decimalint_t(pk number(10, 3) primary key, c0 number(10, 3));
insert into decimalint_t values (12.234, 12.234);
insert into decimalint_t values (-12.234, -12.234);
insert into decimalint_t values (12.235, 12.235);
insert into decimalint_t values (-12.235, -12.245);

--explain_protocol 3
select * from decimalint_t where pk = 12.2341;
select * from decimalint_t where pk = '12.2345';
select * from decimalint_t where pk = '-12.2341';
select * from decimalint_t where pk = '-12.2345';
select * from decimalint_t where pk = 10000000;

select * from decimalint_t where pk != 12.2341;
select * from decimalint_t where pk != '12.2345';
select * from decimalint_t where pk != '-12.2341';
select * from decimalint_t where pk != '-12.2345';
select * from decimalint_t where pk != 10000000;

select * from decimalint_t where pk >=12.2341;
select * from decimalint_t where pk > 12.2345;
select * from decimalint_t where pk >='-12.2345';
select * from decimalint_t where pk > '-12.2341';
select * from decimalint_t where pk > 12345678;
select * from decimalint_t where pk > 12345678.0;
select * from decimalint_t where pk < -12345678.0;
select * from decimalint_t where pk > -12345678;

select * from decimalint_t where pk < 12.2345;
select * from decimalint_t where pk < '-12.2341';
select * from decimalint_t where pk <= 12.2341;
select * from decimalint_t where pk < '-12.2345';
select * from decimalint_t where pk < 12345678;
select * from decimalint_t where pk < '-12345678';

--explain_protocol 0
drop table decimalint_t;

--disable_warnings
drop table if exists decimalint_t1;
drop table if exists decimalint_t2;
--enable_warnings

create table decimalint_t1(c0 number(12, 2));
create table decimalint_t2(pk int(10) primary key, c1 number(12, 2));

insert into decimalint_t1 values (1), (2), (3);
insert into decimalint_t2 values (3, 3), (4, 4);

--explain_protocol 3
select * from decimalint_t2 where pk = (select max(c0) from decimalint_t1);

select * from decimalint_t2 where cast(pk as number(12, 2)) >= 3;
select * from decimalint_t2 where cast(pk as number(11, 2)) >= 3;

--explain_protocol 0
drop table decimalint_t1, decimalint_t2;

create table decimalint_t1 as select 0/1 as c0 from dual;

insert into decimalint_t1 values (1), (2), (3);
explain select * from decimalint_t1 where c0 = 1.0;

alter system flush plan cache global;
sleep 1;
create table decimalint_t2(pk number primary key, c1 number);
insert into decimalint_t2 values (3, 3), (4, 4);
explain select * from decimalint_t2 where c1 = 3.0;

explain select * from decimalint_t2 where pk = (select max(c0) from decimalint_t1);

drop table decimalint_t1, decimalint_t2;

--disable_warnings
drop table if exists decimalint_misc_t;
--enable_warnings

create table decimalint_misc_t (a decimal(10, 2));
select cast('1e1234' as decimal(10, 2)) from dual;
select cast('100000000000000000000000' as decimal(10, 2)) from dual;
select cast(0.000000 as decimal) from dual;
--error 1366
insert into decimalint_misc_t values ('');
--error 1366
insert into decimalint_misc_t values ('112.12.11');
drop table decimalint_misc_t;

--disable_warnings
drop table if exists decint_misc0;
drop table if exists decint_misc1;
drop table if exists decint_misc2;
drop table if exists decint_misc3;
--enable_warnings

create table decint_misc0 as select 0.035 as a from dual;
create table decint_misc1 as select 00.0035 as a from dual;
create table decint_misc2 as select 12.003500 as a from dual;
create table decint_misc3 as select 0012.003500 as a from dual;
desc decint_misc0;
desc decint_misc1;
desc decint_misc2;
desc decint_misc3;

drop table decint_misc0;
drop table decint_misc1;
drop table decint_misc2;

--disable_warnings
drop table if exists decint_in_t;
--enable_warnings

create table decint_in_t (a number(10, 2), b varchar(10));

insert into decint_in_t values (1.1, '1.1');


--explain_protocol 1
select * from decint_in_t where a in (1.234, 2.345, 1.100000);
select * from decint_in_t where (a, b) in ((1.1, 1.1), (1.2, 1.2));

drop table decint_in_t;

--disable_warnings
drop table if exists decint_btw_t;
--enable_warnings

--explain_protocol 0
create table decint_btw_t (pk decimal(10, 2) primary key, a decimal(10, 2), b varchar(64));

insert into decint_btw_t values (1.23, 1.23, '1.23');
insert into decint_btw_t values (1.24, 1.24, '1.24');
--explain_protocol 1
select * from decint_btw_t where pk between 1.23 and 1.235;
select * from decint_btw_t where pk between 1.231 and 1.245;
select * from decint_btw_t where pk between '1.235' and 1.241;
select * from decint_btw_t where b between '1.221' and 1.234;

drop table decint_btw_t;

select cast(-3.4 as decimal(2, 1));
select cast(-13.4 as decimal(2, 1));
select cast(3.4 as decimal(2, 1));
select cast(13.4 as decimal(2, 1));

--disable_warnings
drop table if exists decint_t;
--enable_warnings

create table decint_t (a bigint unsigned);

insert into decint_t values (1), (2), (3), (1234), (5678), (12345678), (12345678901);

select cast(a as decimal(10, 0)) from decint_t;
select cast(a as decimal(4, 0)) from decint_t;
select cast(a as decimal(19, 0)) from decint_t;
select cast(a as decimal(10, 2)) from decint_t;
select cast(a as decimal(4, 2)) from decint_t;
select cast(a as decimal(19, 2)) from decint_t;

drop table decint_t;

create table decint_t(a number(10, 2), b varchar(128));

insert into decint_t values (1.23, '1.231');
insert into decint_t values (1.24, '1.235');

--explain_protocol 1
select * from decint_t where a > b;
select * from decint_t where a <= b;

select * from decint_t where b >= 1.24;
select * from decint_t where b >= 1.23;

select * from decint_t where a > 1.230;
select * from decint_t where a > 1.240;
select * from decint_t where a < '1.230';
select * from decint_t where a < '1.240';

select * from decint_t where a >= 1.230;
select * from decint_t where a >= 1.240;
select * from decint_t where a <= '1.230';
select * from decint_t where a <= '1.240';

select * from decint_t where a not between '1.234' and 1.245;
select * from decint_t where a not between 1.241 and '1.242';

--explain_protocol 0
drop table decint_t;

