create table decint_t as select 1234 as a from dual;
desc decint_t;
drop table decint_t;

create table decint_t as select -1234 as a from dual;
desc decint_t;
drop table decint_t;

create table decint_t as select 1.23 + 1234 as a from dual;
desc decint_t;
drop table decint_t;

create table decint_t as select 1.23 * 1234 as a from dual;
desc decint_t;
drop table decint_t;

--disable_warnings
drop table if exists decint_t2;
--enable_warnings

create table decint_t(a int(10), b bigint(10), c decimal(10, 2));

create table decint_t2 as select a as a0, a + 123 as a1, a + 1.23 as a2, a * 123 as a3, a * 1.23 as a4, b as b0, b + 123 as b1, b + 1.23 as b2,  b * 123 as b3, b * 1.23 as b4, c + 123 as c0, c + 1.23 as c1, c * 123 as c2, c * 1.23 as c3 from decint_t;
desc decint_t2;

create view decint_v as select a as a0, a + 123 as a1, a + 1.23 as a2, a * 123 as a3, a * 1.23 as a4, b as b0, b + 123 as b1, b + 1.23 as b2,  b * 123 as b3, b * 1.23 as b4, c + 123 as c0, c + 1.23 as c1, c * 123 as c2, c * 1.23 as c3 from decint_t;
desc decint_v;

drop view decint_v;

# cast to json
--disable_warnings
DROP TABLE IF EXISTS T1;
DROP TABLE IF EXISTS T2;
--enable_warnings
CREATE TABLE T1(C1 DECIMAL,C2 DECIMAL(10,10),C3 DECIMAL(0)UNSIGNED,C4 DECIMAL(65),C5 DECIMAL(65,30),C6 DECIMAL(3,2),C7 DECIMAL(0,0)ZEROFILL);
INSERT INTO T1 VALUES (NULL,NULL,NULL,NULL,NULL,NULL,NULL);
INSERT INTO T1 VALUES (0,0,0,0,0,0,0);

CREATE TABLE T2(C1 JSON);
INSERT INTO T2 SELECT C1 FROM T1 WHERE C1 = 0;

SELECT CAST(C1 AS DECIMAL),CAST(C1 AS DECIMAL(65,0)) FROM T2;

DROP TABLE T1;
DROP TABLE T2;

--disable_warnings
DROP TABLE IF EXISTS T4;
--enable_warnings
CREATE TABLE T4(C1 DECIMAL(10,10));
INSERT INTO T4 VALUES (-0.1);
SELECT CASE WHEN ! C1 NOT LIKE (1) THEN 1 END RE FROM T4;
SELECT CASE WHEN NOT C1 NOT LIKE (1) THEN 1 END RE FROM T4;

SELECT !C1 from t4;

DROP TABLE T4;

