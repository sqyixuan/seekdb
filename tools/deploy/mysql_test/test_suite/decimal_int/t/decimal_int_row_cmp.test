#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: decimal int bug fix
#tags: decimal
#author: zuojiao.hzj


--disable_warnings
drop database if exists decimal_int;
--enable_warnings
create database decimal_int;
use decimal_int;


--echo basic
create table t1 (c1 decimal(10, 0), c2 decimal(10, 0), c3 decimal(10, 0), primary key(c1, c2, c3));
insert into t1 values (1, 2, 3);
insert into t1 values (0, 1, 2);
insert into t1 values (2, 3, 4);
insert into t1 values (2, 1, 0);
insert into t1 values (2, 2, 0);
insert into t1 values (2, 3, 0);
insert into t1 values (2, 1, 1);
insert into t1 values (2, 2, 1);
insert into t1 values (2, 3, 1);
insert into t1 values (2, 1, 2);
insert into t1 values (2, 2, 2);
insert into t1 values (2, 2, 3);
insert into t1 values (1, 1, 0);
insert into t1 values (1, 2, 0);
insert into t1 values (1, 3, 0);
insert into t1 values (1, 1, 1);
insert into t1 values (1, 2, 1);
insert into t1 values (1, 3, 1);
insert into t1 values (1, 1, 2);
insert into t1 values (1, 2, 2);
insert into t1 values (0, 1, 0);
insert into t1 values (0, 2, 0);
insert into t1 values (0, 3, 0);
insert into t1 values (0, 1, 1);
insert into t1 values (0, 2, 1);
insert into t1 values (0, 3, 1);
insert into t1 values (0, 2, 2);
insert into t1 values (0, 2, 3);

--explain_protocol 2
select * from t1 where (c1, c2) < (1.1, 2.2);
select * from t1 where (c1, c2) < (1.0, 2.2);
select * from t1 where (c1, c2) < (1.0, 2.0);
select * from t1 where (1.1, 2.2) > (c1, c2);
select * from t1 where (1.0, 2.2) > (c1, c2);
select * from t1 where (1.0, 2.0) > (c1, c2);

select * from t1 where (c1, c2) > (1.1, 2.2);
select * from t1 where (c1, c2) > (1.0, 2.2);
select * from t1 where (c1, c2) > (1.0, 2.0);
select * from t1 where (1.1, 2.2) < (c1, c2);
select * from t1 where (1.0, 2.2) < (c1, c2);
select * from t1 where (1.0, 2.0) < (c1, c2);

select * from t1 where (c1, c2) <= (1.1, 2.2);
select * from t1 where (c1, c2) <= (1.0, 2.2);
select * from t1 where (c1, c2) <= (1.0, 2.0);
select * from t1 where (1.1, 2.2) >= (c1, c2);
select * from t1 where (1.0, 2.2) >= (c1, c2);
select * from t1 where (1.0, 2.0) >= (c1, c2);

select * from t1 where (c1, c2) >= (1.1, 2.2);
select * from t1 where (c1, c2) >= (1.0, 2.2);
select * from t1 where (c1, c2) >= (1.0, 2.0);
select * from t1 where (1.1, 2.2) <= (c1, c2);
select * from t1 where (1.0, 2.2) <= (c1, c2);
select * from t1 where (1.0, 2.0) <= (c1, c2);

select * from t1 where (c1, c2, c3) < (1.1, 2.2, 3.3);
select * from t1 where (1.1, 2.2, 3.3) > (c1, c2, c3);
select * from t1 where (c1, c2, c3) > (1.1, 2.2, 3.3);
select * from t1 where (1.1, 2.2, 3.3) < (c1, c2, c3);

--echo row with null
select * from t1 where (c1, c2, c3) < (null, 2.2, 3.3);
select * from t1 where (1.1, null, 3.3) > (c1, c2, c3);
select * from t1 where (c1, c2, c3) > (1.1, 2.2, null);
select * from t1 where (null, null, 3.3) < (c1, c2, c3);

--echo row with string type
select * from t1 where (c1, c2, c3) < ("1.1", 2.2, 3.3);
select * from t1 where (1.1, "2.2", 3.3) > (c1, c2, c3);
select * from t1 where (c1, c2, c3) > (1.1, 2.2, "3.3");
select * from t1 where ("1.1", "2.2", 3.3) < (c1, c2, c3);

--explain_protocol 0
drop table t1;

create table t1 (c1 decimal(10, 0), c2 char(100), c3 decimal(10, 0), primary key(c1, c2, c3));
insert into t1 values (1, "2", 3);
insert into t1 values (0, "1", 2);
insert into t1 values (2, "3", 4);

--explain_protocol 2
select * from t1 where (c1, c2, c3) < (1.1, "2", 3.3);
select * from t1 where (1.1, "2", 3.3) > (c1, c2, c3);
select * from t1 where (c1, c2, c3) > (1.1, "2", 3.3);
select * from t1 where (1.1, "2", 3.3) < (c1, c2, c3);
--explain_protocol 0
drop table t1;

--echo negative
create table t1 (c1 decimal(10, 0), c2 decimal(10, 0), c3 decimal(10, 0), primary key(c1, c2, c3));
insert into t1 values (-1, -2, -3);
insert into t1 values (0, -1, -2);
insert into t1 values (-2, -3, -4);

--explain_protocol 2
select * from t1 where (c1, c2, c3) < (-1.1, -2.2, -3.3);
select * from t1 where (-1.1, -2.2, -3.3) > (c1, c2, c3);
select * from t1 where (c1, c2, c3) > (-1.1, -2.2, -3.3);
select * from t1 where (1.1, 2.2, 3.3) < (c1, c2, c3);
--explain_protocol 0
drop table t1;

--echo lossless cast
create table t1 (c1 decimal(10, 2), c2 decimal(10, 2), c3 decimal(10, 2), primary key(c1, c2, c3));
insert into t1 values (1, 2, 3);
insert into t1 values (0, 1, 2);
insert into t1 values (2, 3, 4);

--explain_protocol 2
select * from t1 where (c1, c2) < (1.1, 2.2);
select * from t1 where (c1, c2) < (1.0, 2.2);
select * from t1 where (c1, c2) < (1.0, 2.0);
select * from t1 where (c1, c2) > (1.1, 2.2);
select * from t1 where (c1, c2) > (1.0, 2.2);
select * from t1 where (c1, c2) > (1.0, 2.0);
drop table t1;
--explain_protocol 0

create table t (a decimal(10, 2), b decimal(10, 2), c decimal(10, 3));
create index idx_t on t(a, c);
explain select * from t where (a, b) < (1.231, 2.345) and b = c;
select * from t where (a, b) < (1.231, 2.345) and b = c;
drop table t;

create table t1 (c1 decimal(10,0), c2 decimal(10,0), c3 decimal(10, 0), c4 varchar(10), c5 varchar(10), primary key(c1, c2, c3));
insert into t1 values (4, 6, 1, '3.2', '6.2');
explain select * from t1 where (c1, c2) < (c4, c5);
select * from t1 where (c1, c2) < (c4, c5);
drop table t1;

create table t1 (c1 decimal(10,0), c2 decimal(10,0), c3 decimal(10, 0), c4 decimal(10,2), c5 decimal(10,2), primary key(c1, c2, c3));
insert into t1 values (4, 6, 1, 3.2, 6.2);
explain select * from t1 where (c1, c2) < (c4, c5);
select * from t1 where (c1, c2) < (c4, c5);

create table t2 (c1 decimal(10,2));
insert into t2 values (3.2);
explain select * from t1 where (c1, c2) < (select min(c1), min(c1) from t2);
select * from t1 where (c1, c2) < (select min(c1), min(c1) from t2);
explain select * from t1 where (c1, c2) < (select 3.2, 6.4 from t2);
select * from t1 where (c1, c2) < (select 3.2, 6.4 from t2);
explain select * from t1 where (3.2, 6.4) > (select min(c1), min(c2) from t1);
select * from t1 where (3.2, 6.4) > (select min(c1), min(c2) from t1);

explain select * from t1 where (select min(c1), min(c1) from t2) > (c1, c2);
select * from t1 where (select min(c1), min(c1) from t2) > (c1, c2);
explain select * from t1 where (select 3.2, 6.4 from t2) > (c1, c2);
select * from t1 where (select 3.2, 6.4 from t2) > (c1, c2);
explain select * from t1 where (select min(c1), min(c2) from t1) < (3.2, 6.4);
select * from t1 where (select min(c1), min(c2) from t1) < (3.2, 6.4);

drop table t2;
drop table t1;

create table t1(c1 decimal(10, 2), c2 decimal(10,2));
create table t2(c1 decimal(10, 0), c2 decimal(10, 0));
create table t3(c1 varchar(10), c2 varchar(10));
insert into t1 values (1,1);
insert into t2 values (4,6);
insert into t3 values ('3.2', '6.4');
explain select * from t1 where (select c1, c2 from t2) < (select c1, c2 from t3);
select * from t1 where (select c1, c2 from t2) < (select c1, c2 from t3);
drop table t1, t2, t3;

create table t1(c1 int primary key, c2 decimal(10,5), c3 decimal(10,5));
explain select * FROM t1  where (c3, NULL) > ('c','c');
select * FROM t1  where (c3, NULL) > ('c','c');
set names latin1;
explain select * FROM t1  where (c3, NULL) > ('c','c');
select * FROM t1  where (c3, NULL) > ('c','c');
set names utf8mb4;
drop table t1;

create table t1 (c1 decimal(20, 0), c2 decimal(65, 30));
insert into t1 values (2, NULL);
select c1, c2 from t1 where (c1, c2) >= (1.2, 0);
select c1, c2 from t1 where (c1, c2) <= (1.2, 0);
select c1, c2 from t1 where (c1, c2) >= (2.2, 0);
select c1, c2 from t1 where (c1, c2) <= (2.2, 0);
drop table t1;

create table t1 (c1 decimal(20, 0), c2 decimal(65, 30));
insert into t1 values (2, 0);
select c1, c2 from t1 where (c1, c2) >= (1.2, NULL);
select c1, c2 from t1 where (c1, c2) <= (1.2, NULL);
select c1, c2 from t1 where (c1, c2) >= (2.2, NULL);
select c1, c2 from t1 where (c1, c2) <= (2.2, NULL);
drop table t1;

create table t1 (c1 decimal(20, 0), c2 decimal(65, 30));
insert into t1 values (2, -1);
select c1, c2 from t1 where (c1, c2) >= (1.2, 0);
select c1, c2 from t1 where (c1, c2) <= (1.2, 0);
select c1, c2 from t1 where (c1, c2) >= (2.2, 0);
select c1, c2 from t1 where (c1, c2) <= (2.2, 0);
drop table t1;

create table t1 (c1 decimal(20, 0), c2 decimal(65, 30), primary key (c1, c2));
insert into t1 values (2, -1);
explain select c1, c2 from t1 where (c1, c2) >= (1.2, 0);
select c1, c2 from t1 where (c1, c2) >= (1.2, 0);
explain select c1, c2 from t1 where (c1, c2) >= (2.0, 0);
select c1, c2 from t1 where (c1, c2) >= (2.0, 0);
explain select c1, c2 from t1 where (c1, c2) <= (2.0, 0);
select c1, c2 from t1 where (c1, c2) <= (2.0, 0);
explain select c1, c2 from t1 where (c1, c2) <= (2.2, 0);
select c1, c2 from t1 where (c1, c2) <= (2.2, 0);
drop table t1;

drop database decimal_int;
