#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: decimal int arithmetics
#tags: decimal
#author: zuojiao.hzj

alter system set _enable_decimal_int_type = true;

--disable_warnings
drop database if exists decimal_int;
--enable_warnings
create database decimal_int;
use decimal_int;

--echo int32_t
create table t1 (c1 decimal(4, 2), c2 decimal(4, 2), c3 decimal(5, 3));
insert into t1 values(1.23, 2.34, 3.456);
insert into t1 values(-1.23, -2.34, -3.456);
insert into t1 values(-1.23, 2.34, -3.456);
insert into t1 values(1.23, -2.34, 3.456);
insert into t1 values(0, 2.34, -3.456);
insert into t1 values(1, 0, -1);
select c1 + c2, c2 + c3, c3 + c1 from t1;
select c1 - c2, c2 - c3, c3 - c1 from t1;
select c1 * c2, c2 * c3, c3 * c1 from t1;
select c1 / c2, c2 / c3, c3 / c1 from t1;
select c2 / c1, c3 / c2, c1 / c3 from t1;
drop table t1;

--echo int64_t
create table t1 (c1 decimal(10, 2), c2 decimal(10, 2), c3 decimal(15, 3));
insert into t1 values(1.23, 2.34, 3.456);
insert into t1 values(-1.23, -2.34, -3.456);
insert into t1 values(-1.23, 2.34, -3.456);
insert into t1 values(1.23, -2.34, 3.456);
insert into t1 values(0, 2.34, -3.456);
insert into t1 values(1, 0, -1);
select c1 + c2, c2 + c3, c3 + c1 from t1;
select c1 - c2, c2 - c3, c3 - c1 from t1;
select c1 * c2, c2 * c3, c3 * c1 from t1;
select c1 / c2, c2 / c3, c3 / c1 from t1;
select c2 / c1, c3 / c2, c1 / c3 from t1;
drop table t1;

--echo int128_t
create table t1 (c1 decimal(20, 10), c2 decimal(30, 16), c3 decimal(35, 17));
insert into t1 values(1234567890.987654321, 1234567890123.987654321012345, 123456789012345.98765432101234578);
insert into t1 values(-1234567890.987654321, -1234567890123.987654321012345, -123456789012345.98765432101234578);
insert into t1 values(1234567890.987654321, -1234567890123.987654321012345, 123456789012345.98765432101234578);
insert into t1 values(-1.23, 2.34, -3.456);
insert into t1 values(0, 2.34, -3.456);
insert into t1 values(1, 0, -1);
select c1 + c2, c2 + c3, c3 + c1 from t1;
select c1 - c2, c2 - c3, c3 - c1 from t1;
select c1 * c2, c2 * c3, c3 * c1 from t1;
select c1 / c2, c2 / c3, c3 / c1 from t1;
select c2 / c1, c3 / c2, c1 / c3 from t1;
drop table t1;

--echo int256_t
create table t1 (c1 decimal(65, 10), c2 decimal(65, 30), c3 decimal(60, 15));
insert into t1 values(1234567890.987654321, 1234567890123.987654321012345, 123456789012345.98765432101234578);
insert into t1 values(-1234567890.987654321, -1234567890123.987654321012345, -123456789012345.98765432101234578);
insert into t1 values(1234567890.987654321, -1234567890123.987654321012345, 123456789012345.98765432101234578);
insert into t1 values(-1.23, 2.34, -3.456);
insert into t1 values(0, 2.34, -3.456);
insert into t1 values(1, 0, -1);
select c1 + c2, c2 + c3, c3 + c1 from t1;
select c1 - c2, c2 - c3, c3 - c1 from t1;
select c1 * c2, c2 * c3, c3 * c1 from t1;
select c1 / c2, c2 / c3, c3 / c1 from t1;
select c2 / c1, c3 / c2, c1 / c3 from t1;
drop table t1;

--echo mixed
create table t1(c1 decimal(4, 2), c2 decimal(10, 2), c3 decimal(35, 17), c4 decimal(65, 30));
insert into t1 values (-1.23, 2.34, 1234567890.987654321, 123456789012345.98765432101234578);
select c1 + c2, c1 + c3, c1 + c4, c2 + c3, c2 + c4, c3 + c4, c4 + c2 from t1;
select c1 - c2, c1 - c3, c1 - c4, c2 - c3, c2 - c4, c3 - c4, c4 - c2 from t1;
select c1 * c2, c1 * c3, c1 * c4, c2 * c3, c2 * c4, c3 * c4, c4 * c2 from t1;
select c1 / c2, c1 / c3, c1 / c4, c2 / c3, c2 / c4, c3 / c4, c4 / c2 from t1;
select c2 / c1, c3 / c1, c4 / c1, c3 / c2, c4 / c2, c4 / c3, c2 / c4 from t1;
drop table t1;

--echo div
create table t1(c1 decimal(8, 2), c2 decimal(18, 2), c3 decimal(38, 2), c4 decimal(65, 0));
insert into t1 values (1, 1, 1, 3);
select c1/c4, c2/c4, c3/c4, c4/c4 from t1;
select c1/c4*c4, c2/c4*c4, c3/c4*c4, c4/c4*c4 from t1;
drop table t1;

--echo precision fix
create table t1(c1 bigint(1), c2 decimal(1, 0));
insert into t1 values (999999999999999999, 1);
create table t2 as select c1+c2 from t1;
desc t2;
select * from t2;
drop table t1, t2;

--echo mul
--explain_protocol 0
create table t1 (c1 int, c2 bigint, c3 int(100), c4 bigint(100),
                 c5 decimal(1, 0), c6 decimal(9, 0), c7 decimal(1, 1), c8 decimal(9, 9), 
                 c9 decimal(10, 0), c10 decimal(18, 0), c11 decimal(10, 10), c12 decimal(18, 18), 
                 c13 decimal(19, 0), c14 decimal(38, 0), c15 decimal(19, 19), c16 decimal(38, 30), 
                 c17 decimal(39, 0), c18 decimal(65, 0), c19 decimal(39, 30), c20 decimal(65, 30));

insert into t1 values (1.23, 2.34, 3.45, 4.56, 5.67, 6.78, 0.789, 0.890, 9.01, 10.12, 0.1123, 0.1234, 13.45, 14.56, 0.1567, 0.1678, 17.89, 18.90, 19.01, 20.12);
select * from t1;
--explain_protocol 2
select c1 * c1, c1 * c2, c1 * c3, c1 * c4, c1 * c5, c1 * c6, c1 * c7, c1 * c8, c1 * c9, c1 * c10, c1 * c11, c1 * c12, c1 * c13, c1 * c14, c1 * c15, c1 * c16, c1 * c17, c1 * c18, c1 * c19, c1 * c20 from t1;
select c2 * c1, c2 * c2, c2 * c3, c2 * c4, c2 * c5, c2 * c6, c2 * c7, c2 * c8, c2 * c9, c2 * c10, c2 * c11, c2 * c12, c2 * c13, c2 * c14, c2 * c15, c2 * c16, c2 * c17, c2 * c18, c2 * c19, c2 * c20 from t1;
select c3 * c1, c3 * c2, c3 * c3, c3 * c4, c3 * c5, c3 * c6, c3 * c7, c3 * c8, c3 * c9, c3 * c10, c3 * c11, c3 * c12, c3 * c13, c3 * c14, c3 * c15, c3 * c16, c3 * c17, c3 * c18, c3 * c19, c3 * c20 from t1;
select c4 * c1, c4 * c2, c4 * c3, c4 * c4, c4 * c5, c4 * c6, c4 * c7, c4 * c8, c4 * c9, c4 * c10, c4 * c11, c4 * c12, c4 * c13, c4 * c14, c4 * c15, c4 * c16, c4 * c17, c4 * c18, c4 * c19, c4 * c20 from t1;
select c5 * c1, c5 * c2, c5 * c3, c5 * c4, c5 * c5, c5 * c6, c5 * c7, c5 * c8, c5 * c9, c5 * c10, c5 * c11, c5 * c12, c5 * c13, c5 * c14, c5 * c15, c5 * c16, c5 * c17, c5 * c18, c5 * c19, c5 * c20 from t1;
select c6 * c1, c6 * c2, c6 * c3, c6 * c4, c6 * c5, c6 * c6, c6 * c7, c6 * c8, c6 * c9, c6 * c10, c6 * c11, c6 * c12, c6 * c13, c6 * c14, c6 * c15, c6 * c16, c6 * c17, c6 * c18, c6 * c19, c6 * c20 from t1;
select c7 * c1, c7 * c2, c7 * c3, c7 * c4, c7 * c5, c7 * c6, c7 * c7, c7 * c8, c7 * c9, c7 * c10, c7 * c11, c7 * c12, c7 * c13, c7 * c14, c7 * c15, c7 * c16, c7 * c17, c7 * c18, c7 * c19, c7 * c20 from t1;
select c8 * c1, c8 * c2, c8 * c3, c8 * c4, c8 * c5, c8 * c6, c8 * c7, c8 * c8, c8 * c9, c8 * c10, c8 * c11, c8 * c12, c8 * c13, c8 * c14, c8 * c15, c8 * c16, c8 * c17, c8 * c18, c8 * c19, c8 * c20 from t1;
select c9 * c1, c9 * c2, c9 * c3, c9 * c4, c9 * c5, c9 * c6, c9 * c7, c9 * c8, c9 * c9, c9 * c10, c9 * c11, c9 * c12, c9 * c13, c9 * c14, c9 * c15, c9 * c16, c9 * c17, c9 * c18, c9 * c19, c9 * c20 from t1;
select c10 * c1, c10 * c2, c10 * c3, c10 * c4, c10 * c5, c10 * c6, c10 * c7, c10 * c8, c10 * c9, c10 * c10, c10 * c11, c10 * c12, c10 * c13, c10 * c14, c10 * c15, c10 * c16, c10 * c17, c10 * c18, c10 * c19, c10 * c20 from t1;
select c11 * c1, c11 * c2, c11 * c3, c11 * c4, c11 * c5, c11 * c6, c11 * c7, c11 * c8, c11 * c9, c11 * c10, c11 * c11, c11 * c12, c11 * c13, c11 * c14, c11 * c15, c11 * c16, c11 * c17, c11 * c18, c11 * c19, c11 * c20 from t1;
select c12 * c1, c12 * c2, c12 * c3, c12 * c4, c12 * c5, c12 * c6, c12 * c7, c12 * c8, c12 * c9, c12 * c10, c12 * c11, c12 * c12, c12 * c13, c12 * c14, c12 * c15, c12 * c16, c12 * c17, c12 * c18, c12 * c19, c12 * c20 from t1;
select c13 * c1, c13 * c2, c13 * c3, c13 * c4, c13 * c5, c13 * c6, c13 * c7, c13 * c8, c13 * c9, c13 * c10, c13 * c11, c13 * c12, c13 * c13, c13 * c14, c13 * c15, c13 * c16, c13 * c17, c13 * c18, c13 * c19, c13 * c20 from t1;
select c14 * c1, c14 * c2, c14 * c3, c14 * c4, c14 * c5, c14 * c6, c14 * c7, c14 * c8, c14 * c9, c14 * c10, c14 * c11, c14 * c12, c14 * c13, c14 * c14, c14 * c15, c14 * c16, c14 * c17, c14 * c18, c14 * c19, c14 * c20 from t1;
select c15 * c1, c15 * c2, c15 * c3, c15 * c4, c15 * c5, c15 * c6, c15 * c7, c15 * c8, c15 * c9, c15 * c10, c15 * c11, c15 * c12, c15 * c13, c15 * c14, c15 * c15, c15 * c16, c15 * c17, c15 * c18, c15 * c19, c15 * c20 from t1;
