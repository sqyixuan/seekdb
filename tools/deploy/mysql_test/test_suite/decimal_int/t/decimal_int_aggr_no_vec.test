drop table t1;

--echo int to decimal
create table t1 (p1 int, p2 int, c1 int, c2 bigint, c3 int unsigned, c4 bigint unsigned);
insert into t1 values (1, 1, 12, 34, 45, 67);
insert into t1 values (1, 1, -34, -56, 78, 90);
insert into t1 values (1, 2, -2147483648, -9223372036854775808, 4294967295, 18446744073709551615);
insert into t1 values (2, 1, 2147483647, 9223372036854775807, 4294967295, 18446744073709551615);
insert into t1 values (2, 2, 2147483647, 9223372036854775807, 4294967295, 18446744073709551615);
insert into t1 values (2, 2, 0, 0, 0, 0);
insert into t1 values(null, null, null, null, null, null);

## no group
select sum(c1), sum(c2), sum(c3), sum(c4) from t1;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1;
select count(c1), count(c2), count(c3), count(c4) from t1;

## group
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p1;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p1;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p1;
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p2;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p2;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p2;
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p1, p2;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p1, p2;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p1, p2;

## rollup
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p1 with rollup;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p1 with rollup;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p1 with rollup;
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p2 with rollup;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p2 with rollup;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p2 with rollup;
select sum(c1), sum(c2), sum(c3), sum(c4) from t1 group by p1, p2 with rollup;
select avg(c1), avg(c2), avg(c3), avg(c4) from t1 group by p1, p2 with rollup;
select count(c1), count(c2), count(c3), count(c4) from t1 group by p1, p2 with rollup;

drop table t1;

create table t1 (c1 int, PRIMARY KEY (`c1`)) partition by hash(c1) (partition p0, partition p1, partition p2);
insert into t1 values (1),(2),(3),(4),(5),(6);
explain select sum(c1) as b from t1 having b > 1;
select sum(c1) as b from t1 having b > 1;
drop table t1;

alter system set _enable_decimal_int_type = true;
alter system set _rowsets_enabled = true;
