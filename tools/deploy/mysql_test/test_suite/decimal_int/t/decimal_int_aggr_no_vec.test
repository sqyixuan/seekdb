select count(c1), count(c2), count(c3) from t1 group by p1 with rollup;
select min(c1), min(c2), min(c3) from t1 group by p2 with rollup;
select max(c1), max(c2), max(c3) from t1 group by p2 with rollup;
select sum(c1), sum(c2), sum(c3) from t1 group by p2 with rollup;
