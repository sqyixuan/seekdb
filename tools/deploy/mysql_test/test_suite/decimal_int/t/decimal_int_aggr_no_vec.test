#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: decimal int aggregation
#tags: decimal, aggregate
#author: zuojiao.hzj

alter system set _rowsets_enabled = false;
alter system set _enable_decimal_int_type = true;

--disable_warnings
drop database if exists decimal_int;
--enable_warnings
create database decimal_int;
use decimal_int;

--echo int32_t
create table t1 (p1 int, p2 int, c1 decimal(4, 2), c2 decimal(5, 3), c3 decimal(9, 4));
insert into t1 values(1, 1, 1.23, 2.34, 3.456);
insert into t1 values(1, 1, -1.23, -2.34, -3.456);
insert into t1 values(1, 2, -1.23, 2.34, -3.456);
insert into t1 values(2, 1, 1.23, -2.34, 3.456);
insert into t1 values(2, 2, 0, 2.34, -3.456);
insert into t1 values(2, 2, 1, 0, -1);
insert into t1 values(null, null, null, null, null);

## no group
select min(c1), min(c2), min(c3) from t1;
select max(c1), max(c2), max(c3) from t1;
select sum(c1), sum(c2), sum(c3) from t1;
select avg(c1), avg(c2), avg(c3) from t1;
select count(c1), count(c2), count(c3) from t1;

## group
select min(c1), min(c2), min(c3) from t1 group by p1;
select max(c1), max(c2), max(c3) from t1 group by p1;
select sum(c1), sum(c2), sum(c3) from t1 group by p1;
select avg(c1), avg(c2), avg(c3) from t1 group by p1;
select count(c1), count(c2), count(c3) from t1 group by p1;
select min(c1), min(c2), min(c3) from t1 group by p2;
select max(c1), max(c2), max(c3) from t1 group by p2;
select sum(c1), sum(c2), sum(c3) from t1 group by p2;
select avg(c1), avg(c2), avg(c3) from t1 group by p2;
select count(c1), count(c2), count(c3) from t1 group by p2;
select min(c1), min(c2), min(c3) from t1 group by p1, p2;
select max(c1), max(c2), max(c3) from t1 group by p1, p2;
select sum(c1), sum(c2), sum(c3) from t1 group by p1, p2;
select avg(c1), avg(c2), avg(c3) from t1 group by p1, p2;
select count(c1), count(c2), count(c3) from t1 group by p1, p2;

## rollup
select min(c1), min(c2), min(c3) from t1 group by p1 with rollup;
select max(c1), max(c2), max(c3) from t1 group by p1 with rollup;
select sum(c1), sum(c2), sum(c3) from t1 group by p1 with rollup;
select avg(c1), avg(c2), avg(c3) from t1 group by p1 with rollup;
select count(c1), count(c2), count(c3) from t1 group by p1 with rollup;
select min(c1), min(c2), min(c3) from t1 group by p2 with rollup;
select max(c1), max(c2), max(c3) from t1 group by p2 with rollup;
select sum(c1), sum(c2), sum(c3) from t1 group by p2 with rollup;
select avg(c1), avg(c2), avg(c3) from t1 group by p2 with rollup;
select count(c1), count(c2), count(c3) from t1 group by p2 with rollup;
select min(c1), min(c2), min(c3) from t1 group by p1, p2 with rollup;
select max(c1), max(c2), max(c3) from t1 group by p1, p2 with rollup;
select sum(c1), sum(c2), sum(c3) from t1 group by p1, p2 with rollup;
select avg(c1), avg(c2), avg(c3) from t1 group by p1, p2 with rollup;
select count(c1), count(c2), count(c3) from t1 group by p1, p2 with rollup;

drop table t1;

