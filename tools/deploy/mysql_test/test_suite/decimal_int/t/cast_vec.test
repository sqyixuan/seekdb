#owner: zongmei.zzm
#owner group: sql2
#tags: datatype

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--result_format 4
connection default;
--disable_warnings
drop table if exists decimalint_t;
--enable_warnings

create table decimalint_t(c0 number(10, 5));
insert into decimalint_t values (1.12345);
insert into decimalint_t values (1.123456);
insert into decimalint_t values (1.123454);
insert into decimalint_t values ('1.23e4');
insert into decimalint_t values (1.23e4);
insert into decimalint_t values ('00012.345');
insert into decimalint_t values ('   001.2345e3  ');
insert into decimalint_t values (+.12e-3);
insert into decimalint_t values (-.23e+5);
insert into decimalint_t values (99999.999994);
insert into decimalint_t values (-99999.999994);

--explain_protocol 1
select cast(c0 as decimal(10, 2)) from decimalint_t;
select cast(c0 as decimal(9, 2)) from decimalint_t;
select cast(c0 as decimal(9, 6)) from decimalint_t;
select cast(c0 as signed) from decimalint_t;
select cast(c0 as unsigned) from decimalint_t;

--explain_protocol 0
drop table decimalint_t;
create table decimalint_t(a int, b int unsigned);

insert into decimalint_t values(1, 1), (10, 10), (100, 100), (1000, 1000), (10000, 10000), (100000, 100000);
insert into decimalint_t values(-1, 1), (-10, 10), (-100, 100), (-1000, 1000), (-10000, 10000), (-100000, 100000);

--explain_protocol 1
select cast(a as decimal(4, 2)),cast(b as decimal(4, 2)) from decimalint_t;

drop table decimalint_t;

--explain_protocol 0
--disable_warnings
drop table if exists decimalint_t1;
drop table if exists decimalint_t2;
--enable_warnings

create table decimalint_t1(a decimal(10, 3));
alter system set _enable_decimal_int_type = false;
--sleep 5
create table decimalint_t2(a decimal(9, 2));
alter system set _enable_decimal_int_type = true;
--sleep 5

insert into decimalint_t1 values (1.234), (1.23), (1.233), (1.235), (1.241), (1.240), (9999999.990), (-9999999.991);
insert into decimalint_t2 values (1.23), (1.24), (1.22), (9999999.99), (-9999999.99);

--explain_protocol 1
select decimalint_t1.a as a1, decimalint_t2.a as a2 from decimalint_t1, decimalint_t2 where decimalint_t1.a = decimalint_t2.a;

--explain_protocol 0
--disable_warnings
drop table if exists decint_t1;
drop table if exists decint_t2;
drop table if exists decint_t3;
--enable_warnings

create table decint_t1(a number(9, 3));
create table decint_t2(a int);
create table decint_t3(a int(128) zerofill);

insert into decint_t1 values (1.234), (999999.999), (-999999.999), (1234.456), (235678.123);

select cast(a as number(8, 1)) from decint_t1;
select cast(a as number(8, 4)) from decint_t1;
select cast(a as number(10, 4)) from decint_t1;
select cast(a as number(18, 14)) from decint_t1;
select cast(a as number(19, 4)) from decint_t1;
select cast(a as number(25, 21)) from decint_t1;
select cast(a as number(39, 4)) from decint_t1;

insert into decint_t2 values (1), (1234), (12345), (999999), (-123456);

select cast(a as number(11, 6)) from decint_t2;
select cast(a as number(15, 4)) from decint_t2;
select cast(a as number(25, 20)) from decint_t2;
select cast(a as number(25, 14)) from decint_t2;
select cast(a as number(39, 28)) from decint_t2;

insert into decint_t3 values (1), (1234), (12345), (999999);

select cast(a as number(11, 6)) from decint_t3;
select cast(a as number(15, 4)) from decint_t3;
select cast(a as number(25, 20)) from decint_t3;
select cast(a as number(25, 14)) from decint_t3;
select cast(a as number(39, 29)) from decint_t3;

drop table decint_t1;
drop table decint_t2;
drop table decint_t3;

create table decint_t1(a number(15, 5));
insert into decint_t1 values (1234567890.12345), (9999999999.99999), (-9999999999.99999), (12345.67891);

select cast(a as number(13, 2)) from decint_t1;
select cast(a as number(18, 6)) from decint_t1;
select cast(a as number(25, 5)) from decint_t1;
select cast(a as number(40, 10)) from decint_t1;

drop table decint_t1;
create table decint_t1(a number(25, 5));
insert into decint_t1 values (12345678901234567890.12345), (99999999999999999999.99999), (-99999999999999999999.99999), (123456789012345.67891);

select cast(a as number(23, 2)) from decint_t1;
select cast(a as number(27, 6)) from decint_t1;
select cast(a as number(39, 5)) from decint_t1;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int(255));
create table t2(c1 tinyint(1));
insert into t2 values (53);
insert into t1 values (16);
select c1 / (select sum(c1) from t1) from t2;

drop table t1;
drop table t2;

explain SELECT MIN(GET_LOCK('aaaaaaaaaaaaaaaaa',0) / '0b1111111111111111111111111111111111111111111111111111111111111111111111111' ^ (RAND(2)));
--disable_result_log
SELECT MIN(GET_LOCK('aaaaaaaaaaaaaaaaa',0) / '0b1111111111111111111111111111111111111111111111111111111111111111111111111' ^ (RAND(2)));
--enable_result_log

alter system set _enable_decimal_int_type = false;
alter system flush plan cache global;
--sleep 5
explain SELECT MIN(GET_LOCK('aaaaaaaaaaaaaaaaa',0) / '0b1111111111111111111111111111111111111111111111111111111111111111111111111' ^ (RAND(2)));
--disable_result_log
SELECT MIN(GET_LOCK('aaaaaaaaaaaaaaaaa',0) / '0b1111111111111111111111111111111111111111111111111111111111111111111111111' ^ (RAND(2)));
--enable_result_log

alter system set _enable_decimal_int_type = true;
alter system flush plan cache global;
--sleep 5

--disable_warnings
drop table if exists test_t;
--enable_warnings

create table test_t(c1 decimal(22, 2), c2 decimal(22, 2), c3 decimal(22, 2));
insert into test_t values (382.53, 1002.64, 614.34), ( 308.14 , 838.95 ,  746.92),(165.92,  401.18,  336.01),
  (862.40,   56.39,  244.40),
  (284.18,  338.17,   16.79),
  (461.69,   31.12,  770.73),
  (556.90,  638.86,  120.22),
  (472.62,  896.90,  877.25),
  (987.91,  380.74,    0.53),
  (133.35,    0.39,  508.33),
  (250.88,  668.94,  324.49),
  (719.77,    7.84, 1198.23),
  (463.15,  341.81,  834.30),
  (842.07,  845.07,  358.44),
  (934.53,  540.54,  400.61),
  (562.31,   36.66,  963.28);

select sum((c1*c2)/(c3+1)) from test_t;
set div_precision_increment = 3;
select sum((c1*c2)/(c3+1)) from test_t;
set div_precision_increment = 2;
select sum((c1*c2)/(c3+1)) from test_t;
set div_precision_increment = 8;
select sum((c1*c2)/(c3+1)) from test_t;
set div_precision_increment = 4;

select count(*) from oceanbase.gv$ob_plan_cache_plan_stat where statement = 'select sum((c1*c2)/(c3+?)) from test_t';

