#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: decimal int ddl
#tags: ddl,decimal
#author: zuojiao.hzj

alter system set _enable_decimal_int_type = true;

--disable_warnings
drop database if exists decimal_int;
--enable_warnings
create database decimal_int;
use decimal_int;

--echo same type
create table t1 (c1 decimal(6, 2));
insert into t1 values (9999.99);
select * from t1;
alter table t1 change column c1 c1 decimal(6, 2);
select * from t1;
alter table t1 change column c1 c1 decimal(8, 2);
select * from t1;
alter table t1 change column c1 c1 decimal(8, 3);
select * from t1;
alter table t1 change column c1 c1 decimal(18, 3);
select * from t1;
alter table t1 change column c1 c1 decimal(30, 3);
select * from t1;
alter table t1 change column c1 c1 decimal(65, 20);
select * from t1;
alter table t1 change column c1 c1 decimal(6, 2);
select * from t1;
drop table t1;

create table t1 (c1 decimal(18, 3));
insert into t1 values (999999999999999.999);
select * from t1;
--error 1264
alter table t1 change column c1 c1 decimal(8, 2);
select * from t1;
alter table t1 change column c1 c1 decimal(30, 3);
select * from t1;
alter table t1 change column c1 c1 decimal(65, 20);
select * from t1;
--error 1264
alter table t1 change column c1 c1 decimal(6, 2);
select * from t1;
drop table t1;

create table t1 (c1 decimal(30, 3), c2 decimal(63, 20));
insert into t1 values (999999999999999999999999999.999, 9999999999999999999999999999999999999999999.99999999999999999999);
select * from t1;
alter table t1 change column c1 c1 decimal(36, 4);
alter table t1 change column c2 c2 decimal(65, 22);
select * from t1;
alter table t1 change column c1 c1 decimal(30, 3);
alter table t1 change column c2 c2 decimal(63, 20);
select * from t1;
--error 1264
alter table t1 change column c1 c1 decimal(20, 3);
--error 1264
alter table t1 change column c2 c2 decimal(40, 20);
select * from t1;
drop table t1;

--echo decimal int to numeric type
create table t1 (c1 number(6, 3));
insert into t1 values (999.999);
select * from t1;
alter table t1 change column c1 c1 int;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 BIGINT;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 BIGINT unsigned;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 FLOAT;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 DOUBLE;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
drop table t1;

--echo decimal int to date type
create table t1 (c1 number(11, 3));
insert into t1 values (20170829);
select * from t1;
alter table t1 change column c1 c1 DATE;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
--error 1292
alter table t1 change column c1 c1 TIME;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
--error 1264
alter table t1 change column c1 c1 YEAR;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 DATETIME;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 TIMESTAMP;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
drop table t1;

--echo decimal int to string type
create table t1 (c1 number(6, 3));
insert into t1 values (999.999);
select * from t1;
alter table t1 change column c1 c1 CHAR(20);
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 VARCHAR(20);
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 TINYBLOB;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 TINYTEXT;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 TEXT;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
alter table t1 change column c1 c1 LONGBLOB;
select * from t1;
alter table t1 change column c1 c1 decimal(20, 3);
select * from t1;
drop table t1;

create table t1 (c1 decimal(10, 2) primary key, c2 decimal(10, 3), c3 decimal(10, 5));
insert into t1 values (1.2,3,4);
insert into t1 values (1.3,3,4);
alter table t1 drop column c2;
select * from t1;
drop table t1;

--echo decimal int add column
create table t1 (a decimal(10, 2) not null);

alter table t1 add column b decimal(10, 3) not null before a;
alter table t1 add column c decimal(20, 4) default '1.2345' before b;

desc t1;

alter system set _enable_decimal_int_type = true;
