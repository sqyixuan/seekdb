#owner: zuojiao.hzj
#owner group: SQL-SQL2
#description: cast decimal to float/double
#tags: decimal
#author: zuojiao.hzj

alter system set _enable_decimal_int_type = true;

--disable_warnings
drop table if exists table_decimal1;
drop table if exists table_decimal2;
drop table if exists table_decimal3;
--enable_warnings
create table table_decimal1(c1 decimal(65,30));
create table table_decimal2(c1 decimal(65,0));
create table table_decimal3(c1 decimal(27,9));
--disable_query_log

