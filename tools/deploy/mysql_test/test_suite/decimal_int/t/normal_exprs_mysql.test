--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: xiaofeng.lby
#### owner group: sql2
#### description: exprs for decimal int
--result_format 4

## 调整以下两个开关后，预期结果一致(decimal int 开关、向量化开关)
--disable_query_log
alter system set _enable_decimal_int_type = true;
alter system set _rowsets_enabled = true;
alter system flush plan cache;
--enable_query_log

--disable_warnings
drop database if exists decimal_int_exprs_db;
--enable_warnings
create database decimal_int_exprs_db;
use decimal_int_exprs_db;

create table t1(
  c1 number(10, 5),
  c2 number,
  c3 number(10));

insert into t1 values(
  12345.67890,
  23456,
  34567);
insert into t1 values(
  12345.0,
  23456,
  34567);
insert into t1 values(
  -12345.67890,
  -23456,
  -34567);
insert into t1 values(
  0,
  0,
  0);
insert into t1 values(
  NULL,
  NULL,
  NULL);

## You can use following sql to make sure column type is decimal int :
## select column_name, data_type, data_precision, data_scale, data_length from oceanbase.__all_column where table_id = (select table_id from oceanbase.__all_table where table_name = 't1');


## field ob_expr_field.cpp
select field(c1, 123, 456, 789) from t1;
select field(c1, 123, 12345.67890, 456) from t1;


## ceil/floor ob_expr_func_ceil.cpp
select ceil(c1), ceil(c2), ceil(c3) from t1;
select floor(c1), floor(c2), floor(c3) from t1;

create table t_ceil_floor(
  c1 number(9, 4),
  c2 number(18, 5),
  c3 number(38, 10));

insert into t_ceil_floor values(
  12345.6780,
  1234567890.67890,
  12345678901234567890.67890);

insert into t_ceil_floor values(
  -12345.6780,
  -1234567890.67890,
  -12345678901234567890.67890);

insert into t_ceil_floor values(
  12345.0000,
  1234567890.00000,
  12345678901234567890.00000);

insert into t_ceil_floor values(
  12345,
  1234567890,
  12345678901234567890);

insert into t_ceil_floor values(
  0,
  0,
  0);

insert into t_ceil_floor values(
  NULL,
  NULL,
  NULL);

select ceil(c1), ceil(c2), ceil(c3) from t_ceil_floor;

select floor(c1), floor(c2), floor(c3) from t_ceil_floor;




## sign ob_expr_sign.cpp
select sign(c1), sign(c2), sign(c3) from t1;


## hex ob_expr_hex.cpp
select hex(c1), hex(c2), hex(c3) from t1;
### hex 的边界值
create table t_hex(
  c1 number(30, 5));
insert into t_hex values
  (18446744073709551614.4),
  (18446744073709551614.5),
  (18446744073709551615.5),
  (-9223372036854775808.4),
  (-9223372036854775808.5),
  (-9223372036854775809.5);
select c1, hex(c1) from t_hex;


## format ob_expr_format.cpp
select format(c1, 1), format(c2, 2), format(c3, 3) from t1;

create table t_format(c1 decimal(6, 3));
insert into t_format values(123.456), (-123.456), (999.999), (-999.999);
select format(c1, -2), format(c1, -1), format(c1, 0), format(c1, 1), format(c1, 2), format(c1, 3), format(c1, 4) from t_format;


## ob_expr_interval.cpp
SELECT INTERVAL(c1, 1, 2, 12345, 12346, 12347) from t1;


## least/greatest ob_expr_least.cpp
select least(c1, 12345.67891), least(c1, 12345.67889), least(c1, 1), least(c1, c2), least(c2, c3) from t1;
select greatest(c1, 12345.67891), greatest(c1, 12345.67889), greatest(c1, 1), greatest(c1, c2), greatest(c2, c3) from t1;


## nvl ob_expr_nvl.cpp ob_expr_nvl.cpp
select nvl(c1, 123) from t1;


## ifnull ob_expr_ifnull.cpp
select ifnull(c1, 123) from t1;


## cast ob_expr_cast.cpp
select cast(123 as number);
select cast(123 as number(15, 10));
select cast(c1 as number(5, 3)) from t1;
select cast(c1 as number(15, 3)) from t1;


## case/arg_case ob_expr_case.cpp
select case when c1 + 1 > 10 then c1 else c2 end from t1;
select case when c1 = 1 then c1 when c1 > 1 then c2 else c3 end from t1;
select case c1 when 1 then c1 else c2 end from t1;
select coalesce(c1, c2) from t1;


## abs ob_expr_abs.cpp
select abs(c1), abs(c2), abs(c3) from t1;


## neg ob_expr_neg.cpp
select neg(c1), neg(c2), neg(c3) from t1;


## round ob_expr_func_round.cpp
select round(c1), round(c2), round(c3) from t1;
select round(c1, 2), round(c2, 2), round(c3, 2) from t1;
select round(c1, -2), round(c2, -2), round(c3, -2) from t1;


## truncate ob_expr_truncate.cpp
select truncate(c1, 0), truncate(c2, 0), truncate(c3, 0) from t1;
select truncate(c1, 2), truncate(c2, 2), truncate(c3, 2) from t1;
select truncate(c1, -2), truncate(c2, -2), truncate(c3, -2) from t1;


## mod ob_expr_mod.cpp
select mod(c1, 0), mod(c2, 3.5), mod(c3, -4.3) from t1;


## dump
create table t_dump(
  c1 number(5, 2),
  c2 number(10, 5),
  c3 number(20, 10),
  c4 number(38, 20));

insert into t_dump values
  (123.45, 123.45, 123.45, 123.45),
  (-123.45, -123.45, -123.45, -123.45);

select dump(c1), dump(c2), dump(c3), dump(c4) from t_dump;


## json_value
SELECT JSON_VALUE('{"data": 123.45}', '$.data' RETURNING decimal) v from dual;
SELECT JSON_VALUE('{"data": 123.45}', '$.data' RETURNING decimal(6, 4)) v from dual;
SELECT JSON_VALUE('{"data": 123.45}', '$.data' RETURNING decimal(7, 4)) v from dual;
select JSON_VALUE('[123.45]', '$[*]' RETURNING decimal) v from dual;
select JSON_VALUE('[123.45, 123.45]', '$[*]' RETURNING decimal) v from dual;

--error 1264
select JSON_VALUE('{}', '$.a' RETURNING decimal DEFAULT 123.45 ON EMPTY) v from dual;
## mysql is error no 1690, origin ob error no is 1264
--error 1264
select JSON_VALUE('{}', '$.a' RETURNING decimal(5, 3) DEFAULT 123.45 ON EMPTY) v from dual;
select JSON_VALUE('{}', '$.a' RETURNING decimal(5, 2) DEFAULT 123.45 ON EMPTY) v from dual;

--error 1264
## mysql is 1690
select JSON_VALUE('not json', '$.x'  RETURNING decimal DEFAULT 123.45 ON ERROR) v from dual;
--error 1264
## mysql is 1690
select JSON_VALUE('not json', '$.x'  RETURNING decimal(5, 3) DEFAULT 99.9999 ON ERROR) v from dual;
select JSON_VALUE('not json', '$.x'  RETURNING decimal(5, 3) DEFAULT 99.999 ON ERROR) v from dual;

--disable_warnings
DROP TABLE IF EXISTS T4;
--enable_warnings
CREATE TABLE T4(C1 DECIMAL,C2 DECIMAL(10,10),C3 DECIMAL(0));
INSERT INTO T4 VALUES(0.123, 0.123 ,0.123);

SELECT INTERVAL(C1,C2,C3) FROM T4;

DROP TABLE IF EXISTS T4;
CREATE TABLE T4(C1 DECIMAL(3,2),C2 DECIMAL(0));
INSERT INTO T4 VALUES(01, 01);
INSERT INTO T4 VALUES(-1, -1);

SELECT NULLIF(C1,C2) FROM T4;

DROP TABLE IF EXISTS T4;
CREATE TABLE T4(C1 DECIMAL(3,2),C2 DECIMAL(65,30),C3 DECIMAL(65));
INSERT INTO T4(C3) VALUES(1E+64);
INSERT INTO T4(C3) VALUES(-1E+64);

SELECT IF(C1,C2,C3) FROM T4;

select FIELD(0,0.123000000000000000000000000000,0);

## clean up
drop database decimal_int_exprs_db;
alter system set _enable_decimal_int_type = true;
