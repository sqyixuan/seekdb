obmysql-rpad-4-2
#定义一个无参的函数
drop function f_test;//
CREATE  FUNCTION f_test()
returns varchar(200)
begin
declare a varchar(200);
SELECT  rpad(datetime2,20,sal)  FROM t1 e WHERE rpad(e.price,20,e.sal)  like '%7000%' INTO a;
return a;
END;
//
SELECT  f_test();//
f_test()
20200923121200500050
#定义一个有参的函数
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) like samplename into a ;
return a;
END ;
//
SELECT  f_test(20200923121200);//
f_test(20200923121200)
NULL
#定义函数用while循环
drop function f_test;//
CREATE  FUNCTION f_test(samplename  varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) like samplename into a ;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) like samplename1 into b ;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
END while;
return a;
END ;
//
SELECT  f_test(20190821101159,20200228101159)  FROM  dual;//
f_test(20190821101159,20200228101159)
NULL
select count(*) from t1;//
count(*)
26
#定义函数用repeat循环
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) = samplename into a ;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) = samplename1 into b ;
repeat 	
INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
until i >= 10	
end	 repeat;
return a;
END;
//
SELECT  f_test(20190821101159,20200228101159)  FROM  dual;//
f_test(20190821101159,20200228101159)
NULL
SELECT COUNT(*) FROM t1; //
COUNT(*)
46
#定义函数用loop循环
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) = samplename into a ;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) = samplename1 into b ;
lp1 : loop
set i := i + 1;
INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
if i > 10 then
leave lp1;
end if;
end loop;
return b;
END;
//
SELECT  f_test(20200922121159,20200921101159)  FROM  dual;//
f_test(20200922121159,20200921101159)
NULL
SELECT COUNT(*) FROM t1;//
COUNT(*)
68
