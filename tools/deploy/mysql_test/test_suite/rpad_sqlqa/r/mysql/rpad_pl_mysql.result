obmysql-rpad-4-1
#游标
DROP TABLE test1;
DROP TABLE test2;
CREATE TABLE test1(f1 decimal(5,1),f2 decimal(5,1));
INSERT INTO test1 VALUES('20.1','10');
INSERT INTO test1 VALUES('20.1','30');
INSERT INTO test1 VALUES('20.1','40');
INSERT INTO test1 VALUES(NULL,NULL);
CREATE TABLE test2(f1 decimal(5,1),f2 decimal(5,1));
DROP PROCEDURE test_pro;
CREATE PROCEDURE test_pro()
BEGIN
DECLARE v1 decimal(5,1);
DECLARE v2 decimal(5,1);
DECLARE done INT DEFAULT 0;
DECLARE result_cursor CURSOR FOR SELECT DISTINCT f1,f2 FROM test1 WHERE f2>10 GROUP BY f1,f2 HAVING rpad(f1,20,f2) like '%20.1%';
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN result_cursor;
FETCH result_cursor INTO v1,v2;
WHILE done<>1 DO
INSERT INTO test2 VALUES(v1,v2);
FETCH result_cursor INTO v1,v2;
END WHILE;
CLOSE result_cursor;
END;
//
CALL test_pro();
SELECT * FROM test1;
f1	f2
20.1	10.0
20.1	30.0
20.1	40.0
NULL	NULL
SELECT * FROM test2;
f1	f2
20.1	30.0
20.1	40.0
DROP TABLE test1;
DROP TABLE test2;
DROP PROCEDURE test_pro;
# Clean up users
drop user lina@'%' ;
