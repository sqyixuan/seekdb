#无参的存储过程
drop procedure p_test;//
CREATE  PROCEDURE p_test()
begin
declare a varchar(200);
declare b varchar(200);
declare i int default 0;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%苹果%' into a ;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%小米%' into b ;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
END while;
END ;
//
SELECT COUNT(*) FROM t1;//
COUNT(*)
68
CALL p_test();//
SELECT COUNT(*) FROM t1;//
COUNT(*)
90
#只有一个in参数的存储过程
drop procedure p_test;//
CREATE PROCEDURE p_test(in samplename  varchar(200))
begin
declare i int;
declare a varchar(200);
declare b varchar(200);
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) like  samplename into a ;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(datetime2,20,sal) like  samplename into b ;
set i := 1;
repeat
INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
set i := i+1;
until i >= 10	
end	 repeat;
END ;
//
SELECT COUNT(*) FROM t1; //
COUNT(*)
90
CALL p_test(20190821101159); //
SELECT COUNT(*) FROM t1;//
COUNT(*)
108
#包含out参数的存储过程
drop procedure p_test;//
CREATE  PROCEDURE p_test(out wb  varchar(200),OUT wb1  varchar(200))
begin
declare i int;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%苹果%' into wb;
SELECT  rpad(e.price,20,e.sal)	FROM t1 e WHERE  rpad(consumer,20,sal) like '%小米%' into wb1 ;
set i :=  1; 
while i <= 10 do
INSERT INTO t1 VALUES(5,'哼哈二将','600',7000,'2020-08-21 10:11:59',20190821101159);
set i := i + 1;
end while;
END;
//
SELECT COUNT(*) FROM t1;//
COUNT(*)
108
call p_test(@wb,@wb1);//
SELECT COUNT(*) FROM t1;//
COUNT(*)
118
#包含in out参数的存储过程
drop procedure p_test;//
CREATE  PROCEDURE p_test( out wb varchar(200),inout  wb1 varchar(200))
begin
declare i int;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%苹果%' into wb;
SELECT  rpad(e.price,20,e.sal)	FROM t1 e WHERE  rpad(consumer,20,sal) like '%小米%' into wb1;
set i := 1;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,'哼哈二将','600',7000,'2020-08-21 10:11:59',20190821101159);
set i := i+1;
END while;
END;
//
call p_test(@wb,@wb1);//
SELECT COUNT(*) FROM t1;//
COUNT(*)
128
#in out参数作 in 使用
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(200),inout wb1 int ,in wb2  int)
begin
declare i int;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%小米%' into wb;
set i := 1;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,'哼哈二将','600',wb1,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,'原始天尊','19111',wb2,'2020-02-29 10:11:59',20200228101159);
set i := i + 1;
END while;
END;
//
SELECT COUNT(*) FROM t1;//
COUNT(*)
128
call p_test(@wb,@wb1,80000);//
ERROR 22003: Out of range value for column
SELECT COUNT(*) FROM t1;//
COUNT(*)
128
#存储过程用循环
drop procedure p_test;//
create  PROCEDURE p_test(in wb int)
begin
declare i int;
set i := 1;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,'哼哈二将','600',wb+100,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,'原始天尊','19111',wb+2000,'2020-02-29 10:11:59',20200228101159);
set i := i+1;
END while;
END;
//
CALL p_test(rpad(20,5,10));//
SELECT COUNT(*)  FROM  t1;//
COUNT(*)
148
#存储过程和函数的结果作为参数传递
drop function f_test;//
CREATE FUNCTION f_test()
returns int
begin
declare a int;
SELECT  rpad(e.price,20,e.sal) FROM t1 e WHERE  rpad(consumer,20,sal) like '%小米%' into a ;
RETURN a;
END;
//
SELECT f_test()  FROM  dual;//
ERROR 22003: Out of range value for column
drop procedure p_test;//
create  PROCEDURE p_test(in wb int)
begin
declare i int;
set i := 1;
WHILE i <= 10 do
INSERT INTO t1 VALUES(5,'哼哈二将','600',wb+100,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(6,'原始天尊','19111',wb+2000,'2020-02-29 10:11:59',20200228101159);
set i := i+1;
END while;
END;
//
CALL p_test(f_test());//
ERROR 22003: Out of range value for column
SELECT COUNT(*)  FROM t1;//
COUNT(*)
148
DROP TABLE t1;
DROP FUNCTION f_test;
