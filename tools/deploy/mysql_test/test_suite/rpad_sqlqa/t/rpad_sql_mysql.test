CREATE TABLE t1(id int,consumer char(20), brand varchar(20),sal int);
INSERT INTO t1 VALUES(1,'苹果','apple',5000);
INSERT INTO t1 VALUES(2,'小米','xiaomi',4000);
INSERT INTO t1 VALUES(3,'OPPO','oppo',3000);
INSERT INTO t1 VALUES(4,'华为','huawei',6000);

CREATE TABLE t2(id int,model varchar(200),price int);
INSERT INTO t2 VALUES(1,'apple 12',6500);
INSERT INTO t2 VALUES(2,'xiaomi 9',5000);
INSERT INTO t2 VALUES(3,'oppo findx',6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);

CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;


--echo #SELECT
--error 1582
SELECT rpad(e.id,e.consumer,e.brand,e.sal) FROM t1_view e;
SELECT rpad(e.consumer,e.id,e.sal) FROM t1_view e;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1_view e INNER JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT * FROM (SELECT e.id,rpad(e.sal,20,p.price) price,rpad(e.brand,20,p.model)model FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ) e ORDER BY e.id;

--echo #ANY
SELECT *  FROM t1_view e WHERE rpad(e.id,20,e.sal) < ANY (SELECT rpad(p.id,20,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE rpad(e.id,20,e.sal) = ANY (SELECT rpad(p.id,20,p.price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE rpad(e.consumer,20,e.sal) > ANY (SELECT rpad(p.model,20,p.price) FROM t2_view p) ORDER BY e.id;

--echo #ALL 
SELECT *  FROM t1_view e WHERE rpad(e.id,20,e.sal) < ALL (SELECT rpad(p.id,20,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE rpad(e.consumer,20,e.sal) > ALL (SELECT rpad(p.model,20,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE rpad(e.id,20,e.sal) = ALL (SELECT rpad(p.id,20,p.price) FROM t2_view p WHERE p.model = 'oppo findx') ORDER BY e.id;


--echo #EXISTS AND NOT EXISTS
SELECT *  FROM t1_view e WHERE EXISTS (SELECT rpad(p.id,20,p.price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE EXISTS (SELECT rpad(p.model,20,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE EXISTS (SELECT rpad(p.model,p.id,p.price) FROM t2_view p) ORDER BY e.id;
SELECT rpad(e.consumer,20,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE rpad(p.id,20,p.price) like '%6500%') ORDER BY e.id;
SELECT rpad(e.consumer,20,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE rpad(p.model,20,p.price) like 'apple 12' ) ORDER BY e.id;
SELECT rpad(e.consumer,20,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE rpad(p.model,20,p.price) like 'apple 12 ' ) ORDER BY e.id;


