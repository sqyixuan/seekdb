SELECT id,consumer,rpad(price,20,sal) FROM t1 WHERE rpad(price,20,sal) like '%5000%' ORDER BY rpad(price,20,sal);
SELECT id,SUM(rpad(price,20,sal)) FROM t1 WHERE  rpad(price,20,sal) like '%5000%' GROUP BY id HAVING SUM(rpad(price,20,sal)) > 5000 ORDER BY id;


--echo #update 
