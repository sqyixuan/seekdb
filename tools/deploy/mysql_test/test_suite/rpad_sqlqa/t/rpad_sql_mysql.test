CREATE TABLE t1(id int,consumer char(20), brand varchar(20),sal int);
INSERT INTO t1 VALUES(1,'苹果','apple',5000);
INSERT INTO t1 VALUES(2,'小米','xiaomi',4000);
INSERT INTO t1 VALUES(3,'OPPO','oppo',3000);
INSERT INTO t1 VALUES(4,'华为','huawei',6000);

CREATE TABLE t2(id int,model varchar(200),price int);
INSERT INTO t2 VALUES(1,'apple 12',6500);
INSERT INTO t2 VALUES(2,'xiaomi 9',5000);
INSERT INTO t2 VALUES(3,'oppo findx',6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);



--echo obmysql-rpad-3
--echo obmysql-rpad-3-1
--echo #SELECT
SELECT rpad(e.id,20,e.sal) FROM t1 e;
SELECT rpad(e.consumer,e.id,e.brand) FROM t1 e;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1 e LEFT JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1 e RIGHT JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT rpad(e.sal,20,p.price) money,rpad(e.brand,20,p.model) model FROM t1 e INNER JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT * FROM (SELECT e.id,rpad(e.sal,20,p.price) price,rpad(e.brand,20,p.model)model FROM t1 e LEFT JOIN t2 p ON e.id = p.id ) e ORDER BY e.id;

--echo #ANY
SELECT *  FROM t1 e WHERE rpad(e.id,20,e.sal) = ANY (SELECT rpad(p.id,20,p.price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE rpad(e.id,20,e.sal) < ANY (SELECT rpad(p.id,20,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE rpad(e.consumer,20,e.sal) > ANY (SELECT rpad(p.model,20,p.price) FROM t2 p) ORDER BY e.id;

--echo #ALL 
SELECT *  FROM t1 e WHERE rpad(e.id,20,e.sal) < ALL (SELECT rpad(p.id,20,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE rpad(e.consumer,20,e.sal) > ALL (SELECT rpad(p.model,20,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE rpad(e.id,20,e.sal) = ALL (SELECT rpad(p.id,20,p.price) FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

--echo #EXISTS AND NOT EXISTS
SELECT *  FROM t1 e WHERE EXISTS (SELECT rpad(p.id,20,p.price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE EXISTS (SELECT rpad(p.model,20,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE EXISTS (SELECT rpad(p.model,p.id,p.price) FROM t2 p) ORDER BY e.id;

SELECT rpad(e.consumer,20,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE rpad(p.id,20,p.price) = 7500 ) ORDER BY e.id;
SELECT rpad(e.consumer,20,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE rpad(p.model,20,p.price) like '%apple 12%' ) ORDER BY e.id;
SELECT rpad(e.consumer,20,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE rpad(p.model,20,p.price) like '%apple 12%' ) ORDER BY e.id;


--echo #CREATE AS 
CREATE TABLE t3 AS SELECT rpad(e.consumer,20,e.brand)  FROM t1 e WHERE rpad(e.id,20,e.sal) like '%6000%';
select * from t3;
drop table t3;
CREATE TABLE t3 AS SELECT rpad(e.consumer,20,e.brand) name  FROM t1 e WHERE rpad(e.id,20,e.sal) like '%6000%';
SELECT *  FROM t3;



--echo #LIKE 
SELECT rpad(e.brand,20,e.consumer) FROM t1 e WHERE rpad(e.brand,20,e.consumer) LIKE '%米%';
SELECT rpad(e.sal,20,p.price) FROM t1 e LEFT JOIN t2 p ON e.id = p.id WHERE rpad(e.sal,20,p.price) LIKE '%00%';

--echo #WHERE
SELECT * FROM t1 e WHERE rpad(e.consumer,20,e.brand) like '%苹果%';
SELECT * FROM t1 e WHERE rpad(e.consumer,20,e.brand) like '%小米%';
SELECT * FROM t1 e WHERE rpad(e.id,20,e.sal) > 4000 ORDER BY e.id;
SELECT * FROM t1 e WHERE rpad(e.id,20,e.sal) < 5000 ORDER BY e.id;
SELECT * FROM t1 e WHERE rpad(e.id,20,e.sal) = 3000 ORDER BY e.id;


--echo #ORDER BY 
SELECT e.id,rpad(e.brand,20,e.consumer) FROM t1 e WHERE rpad(e.id,20,e.sal) like '%4000%' ORDER BY rpad(e.id,20,e.sal);
SELECT e.id,rpad(e.brand,20,e.consumer) FROM t1 e WHERE rpad(e.id,20,e.sal) like '%4000%' ORDER BY rpad(e.id,20,e.sal) DESC;
SELECT e.id,rpad(e.brand,20,e.consumer) FROM t1 e WHERE rpad(e.id,20,e.sal) like '%4000%' ORDER BY rpad(e.brand,20,e.consumer);
SELECT e.id,rpad(e.brand,20,e.consumer) FROM t1 e WHERE rpad(e.id,20,e.sal) like '%4000%' ORDER BY rpad(e.brand,20,e.consumer) DESC;




--echo #GROUP BY HAVING
SELECT SUM(rpad(e.sal,20,p.price)) FROM t1 e LEFT JOIN t2 p ON e.id = p.id GROUP BY rpad(e.sal,20,p.price),e.id ORDER BY e.id ;
SELECT SUM(rpad(e.sal,20,p.price)) FROM t1 e LEFT JOIN t2 p ON e.id = p.id GROUP BY rpad(e.sal,20,p.price),e.id HAVING SUM(rpad(e.sal,20,p.price)) > 5000 ORDER BY e.id;



--echo #CASE WHEN
SELECT id,rpad(consumer,20,CASE WHEN sal < 4000 THEN NULL ELSE sal END) name FROM t1 ORDER BY id;
SELECT id,CASE rpad(id,20,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END FROM t1 ORDER BY id; 
SELECT (CASE rpad(id,20,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END) FROM t1 GROUP BY (CASE rpad(id,20,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END),id ORDER BY id ; 


--echo obmysql-rpad-3-2
--echo #INSERT 
INSERT INTO t2 SELECT *  FROM t2 WHERE rpad(id,20,price) LIKE '%5000%';
SELECT COUNT(*) FROM t2;

INSERT INTO t2 SELECT *  FROM t2 WHERE rpad(id,20,price) > 6000; 
SELECT COUNT(*) FROM t2;


INSERT INTO t3 SELECT rpad(model,20,price) FROM t2 WHERE price > 6500 ORDER BY rpad(model,20,price) DESC;
SELECT *  FROM  t3;


--echo obmysql-rpad-3-3
--echo #UPDATE
UPDATE t2 SET MODEL = 'xiaomi 10' WHERE rpad(id,20,price) LIKE '%5000%';
SELECT model FROM t2;

UPDATE t2 SET price = '9000' WHERE rpad(id,20,price) < 6500;
SELECT price FROM t2;

--error 1242
UPDATE t2 SET price = (SELECT rpad(id,20,sal) FROM t1 WHERE rpad(id,20,sal) > 5000) WHERE id = 1 ;
SELECT price FROM t2;


--echo obmysql-rpad-3-4
--echo #DELETE 
DELETE FROM t2 WHERE rpad(model,20,price) like 'oppo findx';
SELECT COUNT(*) FROM t2;

DELETE FROM t2 WHERE rpad(id,20,price) like '%9000%';
SELECT COUNT(*) FROM t2;

DELETE FROM t2 WHERE rpad(id,20,price) <= 8000 ;
SELECT COUNT(*) FROM t2;



