--echo obmysql-rpad-6
--echo #函数嵌套
SELECT rpad(rpad(consumer,20,price),40,datetime1) FROM t1;
SELECT rpad(rpad(rpad(consumer,20,price),40,datetime1),40,datetime2) FROM t1;

SELECT SUM(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(sal,20,SUM(price)) FROM t1 ORDER BY id;
SELECT rpad(SUM(sal),20,SUM(price)) FROM t1 ORDER BY id;


SELECT COUNT(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(COUNT(sal),20,COUNT(price)) FROM t1 ORDER BY id;

SELECT MAX(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(MAX(sal),20,MAX(price)) FROM t1 ORDER BY id;

SELECT MIN(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(MIN(sal),20,MIN(price)) FROM t1 ORDER BY id;

SELECT AVG(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(AVG(sal),20,AVG(price)) FROM t1 ORDER BY id;

SELECT ABS(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(ABS(sal),20,ABS(price)) FROM t1 ORDER BY id;

SELECT CEIL(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(CEIL(sal),20,CEIL(price)) FROM t1 ORDER BY id;

SELECT FLOOR(rpad(price,20,sal)) FROM t1 ORDER BY id;
SELECT rpad(FLOOR(sal),20,FLOOR(price)) FROM t1 ORDER BY id;

SELECT MOD(rpad(price,20,sal),33) FROM t1 ORDER BY id;
SELECT rpad(MOD(sal,3),20,MOD(price,7)) FROM t1 ORDER BY id;


SELECT LENGTH(rpad(consumer,40,datetime2)) FROM t1;
SELECT rpad(LENGTH(consumer),40,LENGTH(datetime1)) FROM t1;


SELECT INSTR(rpad(consumer,40,datetime2),'米') FROM t1;
SELECT rpad(INSTR(consumer,'米'),40,INSTR(datetime1,'2')) FROM t1;


SELECT rpad(consumer,40,CAST(datetime1 AS CHAR(200))) FROM t1;
SELECT CAST(rpad(consumer,40,datetime2) AS CHAR(200)) FROM t1;


--echo obmysql-rpad-7
--echo #运算符
SELECT rpad(price * 10,20,sal / 21) FROM t1;
SELECT rpad(price + 1500,20,sal - 1000) FROM t1;
SELECT rpad(price + 1500 * 10,20,sal - 1000 *20) FROM t1;
SELECT rpad(price * 10 - 10000,20,sal / 21 + 1000) FROM t1;
SELECT rpad(consumer||price,40,datetime1 || datetime2) FROM t1;


SELECT rpad(price,20,sal) FROM t1;
SELECT rpad(consumer,40,datetime2) FROM t1;

SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) = 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) < 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) > 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) >= 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) <= 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) != 6500;
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) <> 6500;


SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) = 6500 OR  rpad(consumer,40,datetime2) like '%OPPO%';
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) = 6500 AND rpad(consumer,40,datetime2) like '%苹果%';
SELECT id,sal,datetime1 FROM t1 WHERE rpad(price,20,sal) = 6500  OR  rpad(consumer,40,datetime2) like '%OPPO%' AND rpad(consumer,40,datetime2) like '%苹果%';

SELECT LPAD('',10,'') ;
SELECT RPAD('',10,'') ;


