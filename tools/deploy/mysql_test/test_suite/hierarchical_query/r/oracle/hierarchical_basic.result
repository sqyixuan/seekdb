drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists hiedb;
create database hiedb;
use hiedb;
result_format: 4
explain_protocol: 2
create table t0(pk int primary key, c1 int, c2 int, a3 int);
create table t7(c1 int primary key, c2 int);
create table t8(c1 int primary key, c2 int);
create table t9(c1 int primary key, c2 int not null default 1, c3 int default 2);


######################### test for empty result ###################################
### 单表测试 ###
EXPLAIN select prior c2, c1 from t0 start with c1 = 1 connect by prior c1 = c2;
Query Plan
===============================================
|ID|OPERATOR              |NAME|EST. ROWS|COST|
-----------------------------------------------
|0 |NESTED-LOOP CONNECT BY|    |0        |1963|
|1 | TABLE SCAN           |t0  |2        |622 |
|2 | TABLE SCAN           |t0  |1000     |455 |
===============================================

Outputs & filters: 
-------------------------------------
  0 - output([t0.c2], [t0.c1]), filter(nil), 
      conds([t0.c1 = t0.c2]), nl_params_(nil)
  1 - output([t0.c1], [t0.c2]), filter([t0.c1 = 1]), 
      access([t0.c1], [t0.c2]), partitions(p0)
  2 - output([t0.c1], [t0.c2]), filter(nil), 
      access([t0.c1], [t0.c2]), partitions(p0)

