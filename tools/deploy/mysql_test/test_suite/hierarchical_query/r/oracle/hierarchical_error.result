drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists hiedb;
create database hiedb;
use hiedb;
result_format: 4
explain_protocol: 2

######################### test for connect_by_root ##################################
create table rtable(c1 int, c2 int);
select connect_by_root(c1) from rtable;
ERROR HY000: CONNECT BY clause required in this query block
update  rtable set c1 = 1 where connect_by_root(c1) = 1;
ERROR HY000: CONNECT BY clause required in this query block

select c1 from rtable start with connect_by_root(c1) = 1 connect by prior c1 = c2;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1 from rtable start with  c1 = 1 connect by prior c1 = connect_by_root(c1);
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1 from rtable start with  c1 = 1 connect by prior c1 = c2 order siblings by connect_by_root(c1);
ERROR HY000: Specified pseudocolumn, operator or function not allowed here

select connect_by_root(prior c1) from rtable start with c1 = 1 connect by prior c1 = c2;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select connect_by_root(max(c1)) from rtable start with c1 = 1 connect by prior c1 = c2;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select connect_by_root(select max(c1) from rtable) from rtable start with c1 = 1 connect by prior c1 = c2;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here


######################### test for sys_connect_by_path ##################################
select c1 from rtable start with sys_connect_by_path(c1, 1) = 1 connect by prior c1 = c2;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1 from rtable start with  c1 = 1 connect by prior c1 = sys_connect_by_path(c1, 1);
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1 from rtable start with  c1 = 1 connect by prior c1 = c2 order siblings by sys_connect_by_path(c1, 1);
ERROR HY000: Specified pseudocolumn, operator or function not allowed here

select sys_connect_by_path(max(c1), 1) from rtable start with c1 = 1 connect by prior c1 = c2;
ERROR 0A000: Subquery or aggregate function in sys_connect_by_path  is not supported
select sys_connect_by_path((select max(c1) from rtable), 1) from rtable start with  c1 = 1 connect by prior c1 = c2;
ERROR 0A000: Subquery or aggregate function in sys_connect_by_path  is not supported

select sys_connect_by_path(c1, NULL) from rtable start with  c1 = 1 connect by prior c1 = c2;
ERROR HY000: Incorrect arguments to SYS_CONNECT_BY_PATH
select sys_connect_by_path(c1, "") from rtable start with  c1 = 1 connect by prior c1 = c2;
ERROR HY000: Incorrect arguments to SYS_CONNECT_BY_PATH

drop database hiedb;
drop tenant ora_tt force;
drop resource pool pool1;
drop resource unit box1;

