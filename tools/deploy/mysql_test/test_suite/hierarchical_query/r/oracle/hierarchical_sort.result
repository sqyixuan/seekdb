-------------------------------------
  0 - output([siblingst.c1], [siblingst.c2], [LEVEL], [CONNECT_BY_ISLEAF], [CONNECT_BY_ISCYCLE]), filter(nil), 
      conds([siblingst.c1 = siblingst.c2]), nl_params_(nil)
  1 - output([siblingst.c1], [siblingst.c2]), filter([siblingst.c1 = 1]), 
      access([siblingst.c1], [siblingst.c2]), partitions(p0)
