drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists hiedb;
create database hiedb;
use hiedb;
result_format: 4
explain_protocol: 2

######################### test for order siblings by ##################################
create table siblingst(c1 int, c2 int);
EXPLAIN insert into siblingst values(1, 4);
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |INSERT     |    |0        |0   |
|1 | EXPRESSION|    |0        |0   |
====================================

