# test for pseudo column in order by #
select c1, c2, level, connect_by_isleaf, connect_by_iscycle from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by connect_by_isleaf;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1, c2, level, connect_by_isleaf, connect_by_iscycle from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by connect_by_iscycle;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1, c2, level, connect_by_isleaf, connect_by_iscycle from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by level;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here
select c1, c2, level, connect_by_isleaf, connect_by_iscycle from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by prior c1;
ERROR HY000: Specified pseudocolumn, operator or function not allowed here

# test for not supported #
select c1, c2, level, connect_by_isleaf, connect_by_iscycle from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by (select c1 from siblingst);
ERROR 0A000: Subquery or aggregate function in order siblings by clause is not supported
select max(c1) from siblingst start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by max(c1);
ERROR 0A000: Subquery or aggregate function in order siblings by clause is not supported

