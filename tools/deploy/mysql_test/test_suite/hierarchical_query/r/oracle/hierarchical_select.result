drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists hiedb;
create database hiedb;
use hiedb;
result_format: 4
explain_protocol: 2
## drop table troot;
## drop table t2;
## drop table t3;
## drop table t9;
create table troot(c1 int primary key, c2 int, c3 int unique);

create table t2(id int, f_id int);
EXPLAIN insert into t2 values(1,1);
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |INSERT     |    |0        |0   |
|1 | EXPRESSION|    |0        |0   |
====================================

Outputs & filters: 
-------------------------------------
  0 - output([nextval(1)], [?], [()], [__values.id], [__values.f_id]), filter(nil), 
      columns([t2.__pk_increment], [t2.__pk_cluster_id], [t2.__pk_partition_id], [t2.id], [t2.f_id]), partitions(p0)
  1 - output([__values.id], [__values.f_id]), filter(nil)
      values({1, 1})

