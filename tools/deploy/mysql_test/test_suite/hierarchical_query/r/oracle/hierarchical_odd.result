insert into tlimit values(5, 3);
EXPLAIN select c1, c2, level, sys_connect_by_path(c1, '/') from tlimit start with c1 = 1 connect by prior c1 = c2 limit 1;
Query Plan
==================================================
|ID|OPERATOR               |NAME  |EST. ROWS|COST|
--------------------------------------------------
|0 |LIMIT                  |      |0        |39  |
|1 | NESTED-LOOP CONNECT BY|      |0        |39  |
|2 |  TABLE SCAN           |tlimit|1        |38  |
|3 |  TABLE SCAN           |tlimit|5        |37  |
==================================================

Outputs & filters: 
-------------------------------------
  0 - output([tlimit.c1], [tlimit.c2], [LEVEL], [sys_connect_by_path(tlimit.c1, '/')]), filter(nil), limit(1), offset(nil)
  1 - output([tlimit.c1], [tlimit.c2], [LEVEL], [sys_connect_by_path(tlimit.c1, '/')]), filter(nil), 
      conds([tlimit.c1 = tlimit.c2]), nl_params_(nil)
  2 - output([tlimit.c1], [tlimit.c2]), filter([tlimit.c1 = 1]), 
      access([tlimit.c1], [tlimit.c2]), partitions(p0)
  3 - output([tlimit.c1], [tlimit.c2]), filter(nil), 
      access([tlimit.c1], [tlimit.c2]), partitions(p0)

select c1, c2, level, sys_connect_by_path(c1, '/') from tlimit start with c1 = 1 connect by prior c1 = c2 limit 1;
