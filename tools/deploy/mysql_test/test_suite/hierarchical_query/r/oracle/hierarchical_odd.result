drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists hiedb;
create database hiedb;
use hiedb;
result_format: 4
explain_protocol: 2

######################### test for limit clause ###################################
create table tlimit(c1 int, c2 int);
EXPLAIN insert into tlimit values(1, 0);
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |INSERT     |    |0        |0   |
|1 | EXPRESSION|    |0        |0   |
====================================

Outputs & filters: 
-------------------------------------
  0 - output([nextval(1)], [?], [()], [__values.c1], [__values.c2]), filter(nil), 
      columns([tlimit.__pk_increment], [tlimit.__pk_cluster_id], [tlimit.__pk_partition_id], [tlimit.c1], [tlimit.c2]), partitions(p0)
  1 - output([__values.c1], [__values.c2]), filter(nil)
      values({1, 0})

