##test three tables join
select t1.a from t1 inner join t2 using(a) inner join t3 using(c);
+------+
| a    |
+------+
+------+
select t2.a from t1 inner join t2 using(a) inner join t3 using(c);
+------+
| a    |
+------+
+------+
select t2.c from t1 inner join t2 using(a) inner join t3 using(c);
+------+
| c    |
+------+
+------+
select t3.c from t1 inner join t2 using(a) inner join t3 using(c);
+------+
| c    |
+------+
+------+
select * from t1 inner join t2 using(a) inner join t3 using(c) where t1.a = 1;
+------+------+------+------+
| c    | a    | b    | b    |
+------+------+------+------+
+------+------+------+------+
select * from t1 inner join t2 using(a) inner join t3 using(c) where t2.a = 1;
+------+------+------+------+
| c    | a    | b    | b    |
+------+------+------+------+
+------+------+------+------+
select * from t1 inner join t2 using(a) inner join t3 using(c) where t2.c = 1;
+------+------+------+------+
| c    | a    | b    | b    |
+------+------+------+------+
+------+------+------+------+
select * from t1 inner join t2 using(a) inner join t3 using(c) where t3.c = 1;
+------+------+------+------+
| c    | a    | b    | b    |
+------+------+------+------+
+------+------+------+------+

select t1.a from t1 left join t2 using(a) right join t3 using(c);
