--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhenling.zzg
#owner group: sql1
# tags: optimizer
#this file try to test the ansi-join semantic

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(a int, b int);
create table t2(a int, c int);
create table t3(b int, c int);

--result_format 4
##test two tables join
select a from t1 inner join t2 using(a);
select t1.b from t1 inner join t2 using(a);
select * from t1 inner join t2 using(a);

select t1.a from t1 inner join t2 using(a);
select t2.* from t1 inner join t2 using(a);
select a, t2.* from t1 inner join t2 using(a);
select * from t1 inner join t2 using(a) where t1.a = 1;
select avg(t1.a) over (order by t2.c rows between 1 preceding and 2 preceding) from t1 inner join t2 using(a);
select avg(t1.b) over (order by t1.a rows between 1 preceding and 2 preceding) from t1 inner join t2 using(a);
select t1.a, sum(t1.b) from t1 inner join t2 using(a) group by t1.a;
select t1.b, sum(t1.a) from t1 inner join t2 using(a) group by t1.b;
select * from t1 inner join t2 using(a) order by t1.a;

select t1.a from t1 left join t2 using(a);
select t2.* from t1 left join t2 using(a);
select a, t2.* from t1 left join t2 using(a);
select * from t1 left join t2 using(a) where t1.a = 1;
select avg(t1.a) over (order by t2.c rows between 1 preceding and 2 preceding) from t1 left join t2 using(a);
select avg(t1.b) over (order by t1.a rows between 1 preceding and 2 preceding) from t1 left join t2 using(a);
select t1.a, sum(t1.b) from t1 left join t2 using(a) group by t1.a;
select t1.b, sum(t1.a) from t1 left join t2 using(a) group by t1.b;
select * from t1 left join t2 using(a) order by t1.a;

select t1.a from t1 right join t2 using(a);
select t2.* from t1 right join t2 using(a);
select a, t2.* from t1 right join t2 using(a);
select * from t1 right join t2 using(a) where t1.a = 1;
select avg(t1.a) over (order by t2.c rows between 1 preceding and 2 preceding) from t1 right join t2 using(a);
select avg(t1.b) over (order by t1.a rows between 1 preceding and 2 preceding) from t1 right join t2 using(a);
select t1.a, sum(t1.b) from t1 right join t2 using(a) group by t1.a;
select t1.b, sum(t1.a) from t1 right join t2 using(a) group by t1.b;
select * from t1 right join t2 using(a) order by t1.a;

--error 5619
select t1.a from t1 full join t2 using(a);
--error 5619
select t2.* from t1 full join t2 using(a);
--error 5619
select a, t2.* from t1 full join t2 using(a);
--error 5619
select * from t1 full join t2 using(a) where t1.a = 1;
--error 5619
select avg(t1.a) over (order by t2.c rows between 1 preceding and 2 preceding) from t1 full join t2 using(a);
--error 5619
select avg(t1.b) over (order by t1.a rows between 1 preceding and 2 preceding) from t1 full join t2 using(a);
--error 5619
select t1.a, sum(t1.b) from t1 full join t2 using(a) group by t1.a;
--error 5619
select t1.b, sum(t1.a) from t1 full join t2 using(a) group by t1.b;
--error 5619
select * from t1 full join t2 using(a) order by t1.a;

##test three tables join
select t1.a from t1 inner join t2 using(a) inner join t3 using(c);
select t2.a from t1 inner join t2 using(a) inner join t3 using(c);
select t2.c from t1 inner join t2 using(a) inner join t3 using(c);
select t3.c from t1 inner join t2 using(a) inner join t3 using(c);
select * from t1 inner join t2 using(a) inner join t3 using(c) where t1.a = 1;
select * from t1 inner join t2 using(a) inner join t3 using(c) where t2.a = 1;
select * from t1 inner join t2 using(a) inner join t3 using(c) where t2.c = 1;
select * from t1 inner join t2 using(a) inner join t3 using(c) where t3.c = 1;

select t1.a from t1 left join t2 using(a) right join t3 using(c);
select t2.a from t1 left join t2 using(a) right join t3 using(c);
select t2.c from t1 left join t2 using(a) right join t3 using(c);
select t3.c from t1 left join t2 using(a) right join t3 using(c);
select * from t1 left join t2 using(a) right join t3 using(c) where t1.a = 1;
select * from t1 left join t2 using(a) right join t3 using(c) where t2.a = 1;
select * from t1 left join t2 using(a) right join t3 using(c) where t2.c = 1;
select * from t1 left join t2 using(a) right join t3 using(c) where t3.c = 1;

--error 5619
select t1.a from t1 full join t2 using(a) full join t3 using(c);
--error 5619
select t2.a from t1 full join t2 using(a) full join t3 using(c);
--error 5619
select t2.c from t1 full join t2 using(a) full join t3 using(c);
--error 5619
select t3.c from t1 full join t2 using(a) full join t3 using(c);
--error 5619
select * from t1 full join t2 using(a) full join t3 using(c) where t1.a = 1;
--error 5619
select * from t1 full join t2 using(a) full join t3 using(c) where t2.a = 1;
--error 5619
select * from t1 full join t2 using(a) full join t3 using(c) where t2.c = 1;
--error 5619
select * from t1 full join t2 using(a) full join t3 using(c) where t3.c = 1;