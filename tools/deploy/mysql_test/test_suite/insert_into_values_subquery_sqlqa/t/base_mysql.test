--disable_warnings
--error 0,1396
drop user 'yyl_mysql'@'%';
--enable_warnings
create user 'yyl_mysql'@'%' IDENTIFIED BY 'yyl_mysql';
grant all on *.* to 'yyl_mysql'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,yyl_mysql,yyl_mysql,test,$OBMYSQL_PORT);
connection conn;


--echo #sub-1	基本功能测试
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 0,1051
drop table test3;
create table test1 (f1 int, f2 char(10), f3 varchar(10));
create table test2 (f1 int, f2 char(10), f3 varchar(10));
create table test3 (f1 int);
insert into test1 values(1,'aaa','a1');
insert into test1 values(2,'bbb','b1');
insert into test1 values(null,null,null);

--echo #sub-1-1	values中的subquery是否用单独的()括起来
--echo #未使用单独的()
--error 1064
insert into test2 values(1,select f2 from test1 where f1=1,'a1' );
--error 1064
insert into test2 values(select f1 from test1 where f2='bbb','bbb','b1');
--error 1064
insert into test2 values(3,'ccc',select f3 from test1 where f2='ccc');
--error 1064
insert into test2(f2) values(select f2 from test1 where f1=1);
--error 1064
insert into test3 values(select * from (select avg(f1) from test1));
select * from test2;
select * from test3;
--echo #使用单独的()
DELETE FROM test2;
DELETE FROM test3;
insert into test2 values(1,(select f2 from test1 where f1=1),'a1');
insert into test2 values((select f1 from test1 where f2='bbb'),'bbb','b1');
insert into test2 values(3,'ccc',(select f3 from test1 where f2='ccc'));
insert into test2(f2) values((select f2 from test1 where f1=1));
insert into test3 values((select * from (select avg(f1) from test1) t));
select * from test2;
select * from test3;

--echo #sub-1-2	子查询返回内容
delete from test2;
delete from test3;
--echo #返回一行一列
insert into test2 values((select f1 from test1 where f2='bbb'),(select f2 from test1 where f1=1),'z1');
--echo #返回一行多列
--error 1064
insert into test2 values(select * from test1 where f1=1);
--error 1136
insert into test2 values((select * from test1 where f1=1));
--error 1241
insert into test2 values((select * from test1 where f1=1),'bbb','v1');
--echo #返回一列多行
--error 1242
insert into test2 values((select f1 from test1),'bbb','v1');
--echo #返回多行多列
--error 1064
insert into test2 values(select * from test1);
--error 1136
insert into test2 values((select * from test1));
--error 1241
insert into test2 values((select * from test1),'bbb','v1');
--echo #返回空
--error 1241
insert into test2 values((select * from test1 where f1=5),'bbb','v1');
insert into test2 values((select f1 from test1 where f1=5),'bbb','v1');
insert into test2 values((select f2 from test1 where f1=5),'bbb','v1');
select * from test2;
--echo #返回null
delete from test2;
--error 1241
insert into test2 values((select * from test1 where f1 is null),'bbb','v1');
insert into test2 values((select f1 from test1 where f1 is null),'bbb','v1');
insert into test2 values((select f2 from test1 where f1 is null),'bbb','v1');
select * from test2;

--echo #sub-1-3	subquery查询的表与insert的表是否为同一个表
delete from test2;
--echo #不为同一个表
insert into test2 values((select f1 from test1 where f2='bbb'),'bbb','b1');
--echo #为同一个表
#mysql报错ERROR 1093 (HY000): You can''t specify target table 'test1' for update in FROM clause
#但是如果把如下第一个subquery的test1改成test2就可以正常执行了
#ob是都可以正常执行的，询问RD，ob不兼容mysql的这种行为，按照ob可以正常执行的来
insert into test1 values((select f1 from test1 where f3='a1'),
(select max(concat(trim(a.f2),b.f3)) from test1 a,test1 b where a.f1=b.f1),
(select concat(a.f3,trim(b.f2)) from test1 a,test2 b where a.f1=b.f1));
SELECT * FROM test1;
SELECT * FROM test2;

--echo #sub-1-4	插入目标
--echo #向表中指定列插入数据
DELETE FROM test1;
delete from test2;
insert into test1 values(1,'aaa','a1');
insert into test1 values(2,'bbb','b1');
insert into test1 values(null,null,null);
insert into test2(f1,f2) values(1,(select f2 from test1 where f1=1));
insert into test2(f1,f2) values((select f1 from test1 where f1=1),(select f2 from test1 where f1=1));
SELECT * FROM test2;
--echo #向表中所有列插入数据
delete from test2;
insert into test2(f1,f2,f3) values(1,(select f2 from test1 where f1=1),'test');
insert into test2 values((select f1 from test1 where f1=1),(select f2 from test1 where f1=1),(select f3 from test1 where f1=1));
SELECT * FROM test2;
--echo #向表中指定分区插入数据
--error 0,1051
drop table test2;
create table test2(f1 int, f2 char(10), f3 varchar(10) default 'admin')
partition by range(f1) (partition p1 values less than(5), partition p2 values less than (maxvalue));
--error 1748
insert into test2 partition(p2) values((select f1 from test1 where f2='bbb'),'aaa','a1');
insert into test2 partition(p1) values((select f1 from test1 where f2='bbb'),'aaa','a1');
select * from test2;

--echo #补充测试
delete from test2;
INSERT INTO test2 VALUES
((select f1 from test1 where f2='bbb'),'aaa','a1'),
((select f1 from test1 where f1=1),(select f2 from test1 where f1=1),(select f3 from test1 where f1=1)),
((select f1 from test1 where f1=2),(select f2 from test1 where f1=2),NULL),
((select f1 from test1 where f3='a1'),(select max(concat(trim(a.f2),b.f3)) from test1 a,test1 b where a.f1=b.f1),(select concat(a.f3,trim(b.f2)) from test1 a,test1 b where a.f1=b.f1 AND a.f1>1));
#ob不支持，报语法错误
#INSERT INTO test2 VALUES
#row((select f1 from test1 where f2='bbb'),'aaa','a1'),
#row((select f1 from test1 where f1=1),(select f2 from test1 where f1=1),(select f3 from test1 where f1=1)),
#row((select f1 from test1 where f1=2),(select f2 from test1 where f1=2),NULL),
#row((select f1 from test1 where f3='a1'),(select max(concat(trim(a.f2),b.f3)) from test1 a,test1 b where a.f1=b.f1),(select concat(a.f3,trim(b.f2)) from test1 a,test1 b where a.f1=b.f1 AND a.f1>1));
SELECT * FROM test2;

--echo #sub-1-5	values中除subquery外，还存在default、null等需要插入的特殊值
delete from test2;
insert into test2 values(null,(select f2 from test1 where f1=2),default);
SELECT * FROM test2;


--echo #sub-2	运算符与条件
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
create table test1 (f1 int, f2 char(10), f3 varchar(10));
create table test2 (f1 int, f2 char(10), f3 varchar(10));
insert into test1 values(1,'aaa','a1');
insert into test1 values(2,'bbb','b1');
insert into test1 values(null,null,null);

--echo #sub-2-1	运算符（+、-、*、/）
--echo #子查询中使用运算符
delete from test2;
insert into test2 values((select f1-3/(f1*0.02)+2 from test1 where f1=2),(select f2 from test1 where f1*f1-1*2+1<3),(select concat(trim(f2),f3) from test1 where f1=2));
select * from test2;

--echo #子查询外使用运算符
delete from test2;
insert into test2 VALUES
(5+(select f1 from test1 where f1=1),5-(select f1 from test1 where f1=1),5*(select f1 from test1 where f1=1)),
(5/(select f1 from test1 where f1=1),null,null),
((select f1 from test1 where f1=1)+5,(select f1 from test1 where f1=1)-5,(select f1 from test1 where f1=1)*5),
((select f1 from test1 where f1=1)/5,null,null),
((select f1 from test1 where f1=1)/5+3*(2-5),concat('t_',(select trim(f2) from test1 where f1=1)),concat((select trim(f2) from test1 where f1=1),'t_'));
select * from test2;


--echo #sub-2-2	子查询中使用各种条件
--echo #>、>=、<、<=、=、!=、<>（选择其中某几个进行测试）
delete from test2;
insert into test2(f1,f2) values((select f1 from test1 where f2>='abc'),(select f2 from test1 group by f2 having f2<'abc'));
insert into test2(f1,f2) values((select f1 from test1 where f1>1.5),(select f2 from test1 group by f2 having f2<='aaa'));
insert into test2(f1,f2) values((select f1 from test1 where f1<>1),(select f2 from test1 group by f2 having f2!='bbb'));
insert into test2 values((select f1 from test1 where (f1,f2,f3)=((1,'aaa','a1'))),null,null);
select * from test2;

--echo #any,some,all
delete from test2;
insert into test2 values((select f1 from test1 where f1!=all(SELECT 2 FROM DUAL UNION SELECT 3 FROM DUAL UNION SELECT 4 FROM dual)),
(select f2 from test1 where f3=some(SELECT 'b1' FROM DUAL UNION SELECT 'test' FROM DUAL UNION SELECT null FROM dual)),
(select f3 from test1 where f2>=any(SELECT 'bbb' FROM DUAL UNION SELECT 'test' FROM DUAL UNION SELECT null FROM dual)));
insert into test2 values((select f1 from test1 where (f3,f2)=some(SELECT null,null FROM DUAL UNION SELECT 'admin','test' FROM DUAL UNION SELECT 'b1','bbb' FROM dual)),
(select f2 from test1 where (f1,f3)=any(SELECT 1,'a' FROM DUAL UNION SELECT 1,'a1' FROM DUAL)),
(select f3 from test1 where (f1,f2)!=all(SELECT 1,'aaa' FROM DUAL UNION SELECT 2,'bbb' FROM DUAL)));
select * from test2;

--echo #like,regexp
delete from test2;
insert into test2 values((select f1 from test1 where f2 like '%a%'),
(select f2 from test1 where f2 like 'a_a%'),
(select f3 from test1 where f1>0 group by f3 having f3 like 'b_'));
insert into test2 values((select f1 from test1 where f2 regexp 'aaa|ccc|ddd'),
(select f2 from test1 where f2 regexp '^a.*'),
(select f3 from test1 where f2 regexp '.*a$'));
select * from test2;

--echo #exists
delete from test2;
insert into test2 values((select min(f1) from test1 where exists(select f2 from test1 where f1>0)),
null,
null);
select * from test2;

--echo #is [not] null
delete from test2;
insert into test2 values((select f1 from test1 where f2 is null),
(select max(f2) from test1 where f3 is not null),
null);
select * from test2;

--echo #[not] in
delete from test2;
insert into test2 values((select f1 from test1 where f2 in ('aa','bb','cc','bbb')),
null,
(select f3 from test1 where f2 not in ('aa','bb','cc','bbb')));
select * from test2;

--echo #[not] between and
delete from test2;
insert into test2 values((SELECT f1 FROM test1 WHERE f1 BETWEEN 1 AND 1.5),
(SELECT f2 FROM test1 WHERE f2 NOT BETWEEN 'aaa' AND 'abc'),
null);
select * from test2;

--echo #and,or,not
delete from test2;
insert into test2 values((SELECT f1 FROM test1 WHERE f1>0 AND f1<=1),
(SELECT max(f2) FROM test1 WHERE f1>0 OR f2>'aaa'),
(SELECT max(f3) FROM test1 WHERE NOT f2>'aaa'));
insert into test2 values((SELECT min(f1) FROM test1 WHERE f1>0 AND f1<=1 OR f2>'aaa'),
(SELECT max(f2) FROM test1 WHERE f1>0 OR f2>'aaa' AND NOT (f2<'bbb')),
NULL);
select * from test2;


--echo #sub-3	常用系统函数
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
create table test1 (f1 int, f2 char(10), f3 varchar(10), f4 date);
create table test2 (f1 int, f2 char(10), f3 varchar(10), f4 date);
insert into test1 values(1,'abc','a1','19700101');
insert into test1 values(2,'bcd','b1','19800101');
insert into test1 values(3,'cde','c1','19900101');
insert into test1 values(4,'def','d1','20000101');
insert into test1 values(5,'efg','e1','20100101');
insert into test1 values(6,'fgh','f1','20200101');
insert into test1 values(null,null,NULL,NULL);

--echo #sub-3-1	子查询中使用常用系统函数
--echo #字符类函数
DELETE FROM test2;
insert into test2(f2,f3) values(
(SELECT concat(trim(f2),f3) FROM test1 WHERE LENGTH(f2)>2 AND LENGTH(f3)<3 AND f1=4),
(SELECT concat(trim(upper(f2)),lower(f3)) FROM test1 WHERE f2='Efg'));
insert into test2(f2,f3) values(
(SELECT concat(upper(f2),lower(f3)) FROM test1 WHERE f2='Efg'),
(SELECT ascii(f2)+ascii(f3) FROM test1 WHERE f1=5));
insert into test2(f2,f3) values(
(SELECT substr(f2,2) FROM test1 WHERE f1=2),
(SELECT substr(f3,1) FROM test1 WHERE substr(f2,2,2)='de'));
select * from test2;
--echo #数字类函数
DELETE FROM test2;
INSERT INTO test2(f1) VALUES((SELECT round(f1/2.5) FROM test1 WHERE MOD(f1,4)=0));
INSERT INTO test2(f1) VALUES((SELECT f1/2.5 FROM test1 WHERE MOD(f1,4)=0));
INSERT INTO test2(f1) VALUES((SELECT CEIL(f1/1.5) FROM test1 WHERE floor(f1/3)=1 AND FLOOR(f1/2)=1));
SELECT * FROM test2;
--echo #日期和时间函数
DELETE FROM test2;
INSERT INTO test2(f4) VALUES((SELECT f4 FROM test1 WHERE SYSDATE()-f4>0 ORDER BY 1 DESC LIMIT 1));
INSERT INTO test2(f1) VALUES((SELECT MONTH(f4) FROM test1 WHERE f4>'20100101'));
SELECT * FROM test2;
--echo #聚合函数
DELETE FROM test2;
INSERT INTO test2 VALUES(
(SELECT avg(f1) FROM test1 WHERE f1>3),
(SELECT min(f2) FROM test1 WHERE f1>3),
(SELECT max(f3) FROM test1 WHERE f1>3),
(SELECT min(f4) FROM test1 WHERE f1>3));
INSERT INTO test2 VALUES(
(SELECT sum(f1) FROM test1 WHERE f1>3),
(SELECT count(f2) FROM test1 WHERE f1>3),
NULL,NULL);
SELECT * FROM test2;

--echo #sub-3-2	values中使用常用系统函数，且其参数为subquery
DELETE FROM test2;
INSERT INTO test2 VALUES(
mod((SELECT f1 FROM test1 WHERE f1>5)+1,(SELECT f1 FROM test1 WHERE f2='cde'))*100,
concat(concat((SELECT min(UPPER(trim(f2))) FROM test1),'a'),(SELECT max(lower(trim(f2))) FROM test1)),
(SELECT f2 FROM test1 WHERE f1=2),
(SELECT f4 FROM test1 WHERE f1=3)+10);
INSERT INTO test2(f2) VALUES(
SUBSTRING((SELECT f2 FROM test1 WHERE f1=5),(SELECT f1 FROM test1 WHERE f3='b1'),(SELECT f1 FROM test1 WHERE f2='bcd')));
SELECT * FROM test2;


--echo #sub-4	表约束类型
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
--error 0,1051
drop table test3;

create table test1 (id int primary key);
INSERT INTO test1 VALUES(1001);
INSERT INTO test1 VALUES(1002);
INSERT INTO test1 VALUES(1003);

create table test2 (
id int primary key, 
name char(10) unique, 
name_1 varchar(10) not null, 
birthday DATE DEFAULT '20000101', 
age decimal(2,0),
p_id int,
foreign KEY(p_id) REFERENCES test1(id));
INSERT INTO test2 VALUES(1,'stu1','aaa','19700101',18,1001);
INSERT INTO test2 VALUES(2,'stu2','bbb','19800101',28,1001);
INSERT INTO test2 VALUES(3,'stu3','ccc','19900101',38,1002);
INSERT INTO test2 VALUES(4,'stu4','ddd','20000101',48,1002);
INSERT INTO test2 VALUES(5,'stu5','eee','20100101',58,1003);
INSERT INTO test2 VALUES(6,NULL,'fff','20200101',68,1003);

create table test3 (
id int primary key, 
name char(10) unique, 
name_1 varchar(10) not null, 
birthday DATE DEFAULT '20000101', 
age decimal(2,0),
p_id int,
foreign KEY(p_id) REFERENCES test1(id));

--echo #sub-4-1	primary key
DELETE FROM test3;
INSERT INTO test3(id,name_1) VALUES((SELECT id FROM test2 WHERE id<2),'test1');
--error 1062
INSERT INTO test3(id,name_1) VALUES((SELECT id FROM test2 WHERE id<2),'test2');
--error 1048
INSERT INTO test3(id,name_1) VALUES((SELECT id FROM test2 WHERE id<1),'test3');
SELECT * FROM test3;

--echo #sub-4-2	unique
DELETE FROM test3;
INSERT INTO test3(id,name,name_1) VALUES(10,(SELECT name FROM test2 WHERE name LIKE '%4%'),'test1');
--error 1062
INSERT INTO test3(id,name,name_1) VALUES(11,(SELECT name FROM test2 WHERE name LIKE '%4%'),'test2');
INSERT INTO test3(id,name,name_1) VALUES(12,(SELECT name FROM test2 WHERE name LIKE '%9%'),'test3');
SELECT * FROM test3;

--echo #sub-4-3	[not] null
DELETE FROM test3;
INSERT INTO test3(id,name_1) VALUES(10,(SELECT name_1 FROM test2 WHERE name_1 in ('abc','acd','aaa')));
INSERT INTO test3(id,name_1) VALUES(11,(SELECT name_1 FROM test2 WHERE name_1 in ('abc','acd','aaa')));
--error 1048
INSERT INTO test3(id,name_1) VALUES(12,(SELECT name_1 FROM test2 WHERE name_1 in ('abc','acd','ade')));
SELECT * FROM test3;

--echo #sub-4-4	default
DELETE FROM test3;
INSERT INTO test3(id,name_1,birthday) VALUES(10,'test1',(SELECT birthday FROM test2 WHERE birthday>'19800101' AND birthday<'20000101'));
INSERT INTO test3(id,name_1,birthday) VALUES(11,'test2',(SELECT birthday FROM test2 WHERE birthday>'19900101' AND birthday<'20100101'));
INSERT INTO test3(id,name_1,birthday) VALUES(12,'test3',(SELECT birthday FROM test2 WHERE birthday>'19900101' AND birthday<'20000101'));
SELECT * FROM test3;

--echo #sub-4-5	foreign key
DELETE FROM test3;
INSERT INTO test3(id,name_1,p_id) VALUES(10,'test1',(SELECT min(p_id) FROM test2 WHERE p_id>1002));
--error 1452
INSERT INTO test3(id,name_1,p_id) VALUES(11,'test2',(SELECT min(p_id)+100 FROM test2 WHERE p_id>1002));
INSERT INTO test3(id,name_1,p_id) VALUES(12,'test3',(SELECT min(p_id) FROM test2 WHERE p_id>1002));
INSERT INTO test3(id,name_1,p_id) VALUES(13,'test4',(SELECT min(p_id) FROM test2 WHERE p_id>1003));
SELECT * FROM test3;


