drop user 'yyl_mysql'@'%';
create user 'yyl_mysql'@'%' IDENTIFIED BY 'yyl_mysql';
grant all on *.* to 'yyl_mysql'@'%' WITH GRANT OPTION;
#sub-6	表类型与子查询类型
#sub-6-1	普通表+无索引+无主键
DROP TABLE test1;
DROP TABLE test2;
DROP TABLE test3;
CREATE TABLE test1(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int);
INSERT INTO test1 VALUES(101, 'test1', 'admin1', '19700101', 50.5, NULL);
INSERT INTO test1 VALUES(102, 'test2', 'admin2', '19800101', 55.5, 101);
INSERT INTO test1 VALUES(103, 'test3', 'admin3', '19900101', 60.5, 101);
INSERT INTO test1 VALUES(104, 'test4', 'admin4', '20000101', 65.5, 102);
INSERT INTO test1 VALUES(105, 'test5', 'admin5', '20100101', 70.5, 102);
INSERT INTO test1 VALUES(106, 'test6', 'admin6', '20200101', 75.5, 103);
INSERT INTO test1 VALUES(107, 'test7', 'admin7', '20300101', 80.5, 103);
INSERT INTO test1 VALUES(108, NULL, NULL, '20400101', NULL, NULL);
CREATE TABLE test2(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int);
INSERT INTO test2 VALUES(101, 'test1', 'admin1', '19700101', 50.5, NULL);
INSERT INTO test2 VALUES(102, 'test2', 'admin2', '19800101', 55.5, 101);
INSERT INTO test2 VALUES(103, 'test3', 'admin3', '19900101', 60.5, 101);
INSERT INTO test2 VALUES(104, 'test4', 'admin4', '20000101', 65.5, 102);
INSERT INTO test2 VALUES(105, 'test5', 'admin5', '20100101', 70.5, 102);
INSERT INTO test2 VALUES(106, 'test6', 'admin6', '20200101', 75.5, 103);
INSERT INTO test2 VALUES(107, 'test7', 'admin7', '20300101', 80.5, 103);
INSERT INTO test2 VALUES(108, NULL, NULL, '20400101', NULL, NULL);
CREATE TABLE test3(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int);
#sub-6-1-1	普通查询
DELETE FROM test3;
INSERT INTO test3(id,name,birthday) VALUES(
(SELECT min(id) FROM test1),
(SELECT max(name) FROM test1),
(SELECT max(birthday) FROM test1));
INSERT INTO test3 VALUES(
(SELECT DISTINCT p_id FROM test1 WHERE id>=104 AND name<='test6' AND birthday<'20200101'),
(SELECT concat(trim(name),name_1) FROM test2 WHERE id=105),
(SELECT name_1 FROM test1 WHERE birthday='20200101'),
(SELECT date_add(birthday,INTERVAL 1 YEAR) FROM test2 GROUP BY birthday HAVING birthday<'19800101'),
(SELECT weight FROM test1 ORDER BY 1 DESC LIMIT 1),
(SELECT p_id FROM test2 ORDER BY 1 LIMIT 1));
INSERT INTO test3(id,birthday) VALUES(
(SELECT (CASE id WHEN 103 THEN 120 WHEN 105 THEN id+8 END) FROM test1 WHERE name='test5'),
5+date_add((SELECT birthday FROM test1 WHERE id=107), INTERVAL (SELECT max(id-100) FROM test1 WHERE (CASE WHEN id>105 THEN 20 ELSE -20 END)>0) YEAR));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	NULL	2040-01-01	NULL	NULL
102	test5admin5	admin6	1971-01-01	80	NULL
113	NULL	NULL	2038-01-06	NULL	NULL
#sub-6-1-2	连接查询
DELETE FROM test3;
INSERT INTO test3 VALUES(
(SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT MAX(a.name) FROM test1 a, test2 b WHERE a.birthday=b.birthday),
(SELECT a.name_1 FROM test1 a INNER JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.birthday FROM test1 a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'),
(SELECT a.weight FROM test1 a LEFT JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.p_id FROM test1 a LEFT OUTER JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	admin5	2030-01-01	70	103
DELETE FROM test3;
INSERT INTO test3 VALUES(
(SELECT b.id FROM test1 a RIGHT JOIN test1 b ON a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT MAX(a.name) FROM test1 a RIGHT OUTER JOIN test2 b ON a.birthday=b.birthday),
(SELECT a.name_1 FROM test1 a FULL JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.birthday FROM test1 a FULL OUTER JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'),
(SELECT a.weight FROM test1 a CROSS JOIN test2 b WHERE a.name=b.name AND b.id IN (105,110,120)),
(SELECT DISTINCT a.p_id FROM test1 a CROSS JOIN test1 b WHERE a.name>b.name AND b.name LIKE '%6%'));
INSERT INTO test3(id,birthday) VALUES(
concat((SELECT MAX(id) FROM test1 a NATURAL JOIN test1 b WHERE id IS NOT NULL AND p_id IS NOT NULL),'111'),
(SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual)));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	admin5	2030-01-01	70	103
107111	NULL	NULL	1980-01-01	NULL	NULL
#sub-6-1-3	集合查询
DELETE FROM test3;
INSERT INTO test3(id,birthday) VALUES(
(SELECT id FROM test1 WHERE name='test1' UNION SELECT id FROM test1 WHERE name='test9' UNION
SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT DISTINCT a.birthday FROM test1 a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%' UNION ALL
SELECT birthday FROM test1 WHERE id=111 UNION ALL SELECT birthday FROM test1 WHERE birthday>'20400101'));
INSERT INTO test3(id,birthday) VALUES(
2+(SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102 MINUS
SELECT id FROM test1 WHERE name IS NOT NULL AND name='test2'),
(SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual) INTERSECT
SELECT birthday FROM test1 WHERE name IS NOT NULL AND name='test2'));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	NULL	NULL	2030-01-01	NULL	NULL
103	NULL	NULL	1980-01-01	NULL	NULL
#sub-6-1-4	上述查询类型相互嵌套查询测试
DELETE FROM test3;
INSERT INTO test3 VALUES(
(SELECT max(id) FROM (SELECT b.id FROM test1 a RIGHT JOIN test1 b ON a.id=b.id GROUP BY b.id) t WHERE id>101),
(SELECT DISTINCT SUBSTR((SELECT name FROM test1 WHERE id=105),(SELECT id-100 FROM test1 WHERE name='test2'),id-100) FROM test1 WHERE name_1='admin3'),
(SELECT max(name_1) FROM test1 WHERE id IN (SELECT id FROM test2 WHERE id>102 AND id<105)),
(SELECT birthday FROM test1 WHERE (id,name,name_1)=(SELECT a.id,b.name,a.name_1 FROM test1 a,test2 b WHERE a.id=b.id AND a.name=b.name AND a.birthday=b.birthday AND a.name_1<'admin2')),
(SELECT weight FROM test1 GROUP BY weight HAVING weight>=
(SELECT weight FROM test2 WHERE id>106 AND weight IS NOT NULL UNION
SELECT weight FROM test1 WHERE name IS NOT NULL AND name='test7')),
(SELECT DISTINCT p_id FROM test1 WHERE id=(SELECT id FROM test1 WHERE name='test1' UNION SELECT id FROM test1 WHERE name='test9' UNION
SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102)));
INSERT INTO test3(id,name,name_1,birthday) VALUES(
(SELECT min(a.id) FROM test1 a JOIN (SELECT * FROM test2 WHERE id>101) b ON a.id=b.id WHERE a.birthday>'19900101'),
(SELECT a.name FROM (SELECT a.* FROM test1 a right JOIN test2 b ON a.name=b.name WHERE b.id IN (105,106,120)) a RIGHT JOIN test2 b ON a.id=b.id WHERE a.name>'test5'),
(SELECT min(b.name_1) FROM (SELECT id FROM (SELECT id,name,birthday FROM test1) a WHERE name>'test1') a,(SELECT * FROM test2) b WHERE a.id=b.id),
(SELECT a.birthday FROM (SELECT id,birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin3' FROM dual UNION SELECT 'test8' FROM dual)) a JOIN 
(SELECT DISTINCT b.id,a.birthday FROM test1 a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%' UNION ALL
SELECT id,birthday FROM test1 WHERE id=111 UNION ALL SELECT id,birthday FROM test1 WHERE birthday>'20400101') b ON a.id<b.id));
INSERT INTO test3(id,birthday) VALUES(
CONCAT((SELECT MAX(a.id) FROM test1 a LEFT OUTER JOIN test2 b ON a.birthday=b.birthday 
UNION
SELECT a.id+3 FROM test1 a RIGHT JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),'111'),
(SELECT date_add(birthday,INTERVAL 10 YEAR) FROM test2 GROUP BY birthday HAVING birthday<'19800101'
UNION
SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual)));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
108	est	admin4	1970-01-01	80	NULL
104	test6	admin2	1980-01-01	NULL	NULL
108111	NULL	NULL	1980-01-01	NULL	NULL
