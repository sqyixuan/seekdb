drop table DemoOrganization;
create table DemoOrganization 
(
OrgID     decimal(20,0) not null,
OrgName   VARCHAR(10),
OrgPath   VARCHAR(10),
ParentID  INTEGER,
OLevel    INTEGER default 0,
AddTime   DATE);
