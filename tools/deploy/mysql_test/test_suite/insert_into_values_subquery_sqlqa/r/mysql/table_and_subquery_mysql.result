CREATE TABLE test3(id int PRIMARY KEY, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int)
PARTITION BY RANGE(id) 
(PARTITION p1 VALUES less than(103), PARTITION p2 VALUES less than(105), PARTITION p3 VALUES less than(MAXVALUE));
CREATE INDEX idx_3 ON test3(birthday) GLOBAL;
#普通查询
DELETE FROM test3;
INSERT INTO test3(id,name,birthday) VALUES(
(SELECT min(id) FROM test1),
(SELECT max(name) FROM test1),
(SELECT max(birthday) FROM test1));
INSERT INTO test3 VALUES(
(SELECT DISTINCT p_id FROM test1 WHERE id>=104 AND name<='test6' AND birthday<'20200101'),
(SELECT concat(trim(name),name_1) FROM test2 PARTITION(p3) WHERE id=105),
(SELECT name_1 FROM test1 WHERE birthday='20200101'),
(SELECT date_add(birthday,INTERVAL 1 YEAR) FROM test2 GROUP BY birthday HAVING birthday<'19800101'),
(SELECT weight FROM test1 ORDER BY 1 DESC LIMIT 1),
(SELECT p_id FROM test2 ORDER BY 1 LIMIT 1));
INSERT INTO test3(id,birthday) VALUES(
(SELECT (CASE id WHEN 103 THEN 120 WHEN 105 THEN id+8 END) FROM test1 PARTITION(p3) WHERE name='test5'),
5+date_add((SELECT birthday FROM test1 WHERE id=107), INTERVAL (SELECT max(id-100) FROM test1 PARTITION(p3) WHERE (CASE WHEN id>105 THEN 20 ELSE -20 END)>0) YEAR));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	NULL	2040-01-01	NULL	NULL
102	test5admin5	admin6	1971-01-01	80	NULL
113	NULL	NULL	2038-01-06	NULL	NULL
#连接查询
DELETE FROM test3;
INSERT INTO test3 VALUES(
(SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT MAX(a.name) FROM test1 a, test2 PARTITION(p3) b WHERE a.birthday=b.birthday),
(SELECT a.name_1 FROM test1 a INNER JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.birthday FROM test1 PARTITION(p3) a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'),
(SELECT a.weight FROM test1 a LEFT JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.p_id FROM test1 a LEFT OUTER JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	admin5	2030-01-01	70	103
DELETE FROM test3;
INSERT INTO test3 VALUES(
(SELECT b.id FROM test1 a RIGHT JOIN test1 b ON a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT MAX(a.name) FROM test1 a RIGHT OUTER JOIN test2 b ON a.birthday=b.birthday),
(SELECT a.name_1 FROM test1 a FULL JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.birthday FROM test1 a FULL OUTER JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'),
(SELECT a.weight FROM test1 a CROSS JOIN test2 b WHERE a.name=b.name AND b.id IN (105,110,120)),
(SELECT DISTINCT a.p_id FROM test1 PARTITION(p3) a CROSS JOIN test1 b WHERE a.name>b.name AND b.name LIKE '%6%'));
INSERT INTO test3(id,birthday) VALUES(
concat((SELECT MAX(id) FROM test1 a NATURAL JOIN test1 b WHERE id IS NOT NULL AND p_id IS NOT NULL),'111'),
(SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual)));
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	admin5	2030-01-01	70	103
107111	NULL	NULL	1980-01-01	NULL	NULL
#集合查询
DELETE FROM test3;
INSERT INTO test3(id,birthday) VALUES(
(SELECT id FROM test1 WHERE name='test1' UNION SELECT id FROM test1 WHERE name='test9' UNION
SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT DISTINCT a.birthday FROM test1 a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%' UNION ALL
SELECT birthday FROM test1 WHERE id=111 UNION ALL SELECT birthday FROM test1 PARTITION(p3) WHERE birthday>'20400101'));
INSERT INTO test3(id,birthday) VALUES(
2+(SELECT b.id FROM test1 PARTITION(p1) a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102 MINUS
SELECT id FROM test1 WHERE name IS NOT NULL AND name='test2'),
(SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual) INTERSECT
SELECT birthday FROM test1 WHERE name IS NOT NULL AND name='test2'));
SELECT * FROM test3;
