CREATE TABLE test3(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int)
PARTITION BY RANGE(id) 
(PARTITION p1 VALUES less than(103), PARTITION p2 VALUES less than(105), PARTITION p3 VALUES less than(MAXVALUE));
