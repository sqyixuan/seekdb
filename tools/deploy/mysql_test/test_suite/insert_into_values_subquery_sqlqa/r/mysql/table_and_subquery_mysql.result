#sub-6-3	分区表+无索引+无主键
DROP TABLE test1;
DROP TABLE test2;
DROP TABLE test3;
CREATE TABLE test1(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int)
PARTITION BY RANGE(id) 
(PARTITION p1 VALUES less than(103), PARTITION p2 VALUES less than(105), PARTITION p3 VALUES less than(MAXVALUE));
INSERT INTO test1 VALUES(101, 'test1', 'admin1', '19700101', 50.5, NULL);
INSERT INTO test1 VALUES(102, 'test2', 'admin2', '19800101', 55.5, 101);
INSERT INTO test1 VALUES(103, 'test3', 'admin3', '19900101', 60.5, 101);
INSERT INTO test1 VALUES(104, 'test4', 'admin4', '20000101', 65.5, 102);
INSERT INTO test1 VALUES(105, 'test5', 'admin5', '20100101', 70.5, 102);
INSERT INTO test1 VALUES(106, 'test6', 'admin6', '20200101', 75.5, 103);
INSERT INTO test1 VALUES(107, 'test7', 'admin7', '20300101', 80.5, 103);
INSERT INTO test1 VALUES(108, NULL, NULL, '20400101', NULL, NULL);
CREATE TABLE test2(id int, name char(20), name_1 varchar(20), birthday DATE, weight float(3,0), p_id int)
PARTITION BY RANGE(id) 
(PARTITION p1 VALUES less than(103), PARTITION p2 VALUES less than(105), PARTITION p3 VALUES less than(MAXVALUE));
INSERT INTO test2 VALUES(101, 'test1', 'admin1', '19700101', 50.5, NULL);
