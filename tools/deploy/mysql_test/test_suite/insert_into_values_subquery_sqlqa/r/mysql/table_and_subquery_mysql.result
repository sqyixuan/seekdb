select 3,'组织机构3',1,'0',0,'20100101' from dual union all
select 4,'组织机构4',2,'1',1,'20200101' from dual union all
select 5,'组织机构5',2,'2',2,'20300101' from dual union all
select 6,'组织机构6',3,'1/4',4,'20400101' from dual union all
select 7,'组织机构7',3,'1/4',4,'20500101' from dual union all
select 8,'组织机构8',3,'2/5',5,'20600101' from dual union all
select 9,'组织机构9',4,'1/4/6',6,'20700101' from dual union all
select 10,'组织机构10',4,'1/4/6',6,'20800101' from dual union all
