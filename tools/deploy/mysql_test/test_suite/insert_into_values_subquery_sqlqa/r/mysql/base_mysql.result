6	4	5
5	NULL	NULL
6	-4	5
0	NULL	NULL
-9	t_aaa	aaat_
#sub-2-2	子查询中使用各种条件
#>、>=、<、<=、=、!=、<>（选择其中某几个进行测试）
delete from test2;
insert into test2(f1,f2) values((select f1 from test1 where f2>='abc'),(select f2 from test1 group by f2 having f2<'abc'));
insert into test2(f1,f2) values((select f1 from test1 where f1>1.5),(select f2 from test1 group by f2 having f2<='aaa'));
insert into test2(f1,f2) values((select f1 from test1 where f1<>1),(select f2 from test1 group by f2 having f2!='bbb'));
insert into test2 values((select f1 from test1 where (f1,f2,f3)=((1,'aaa','a1'))),null,null);
select * from test2;
f1	f2	f3
2	aaa	NULL
2	aaa	NULL
2	aaa	NULL
1	NULL	NULL
#any,some,all
delete from test2;
insert into test2 values((select f1 from test1 where f1!=all(SELECT 2 FROM DUAL UNION SELECT 3 FROM DUAL UNION SELECT 4 FROM dual)),
(select f2 from test1 where f3=some(SELECT 'b1' FROM DUAL UNION SELECT 'test' FROM DUAL UNION SELECT null FROM dual)),
(select f3 from test1 where f2>=any(SELECT 'bbb' FROM DUAL UNION SELECT 'test' FROM DUAL UNION SELECT null FROM dual)));
insert into test2 values((select f1 from test1 where (f3,f2)=some(SELECT null,null FROM DUAL UNION SELECT 'admin','test' FROM DUAL UNION SELECT 'b1','bbb' FROM dual)),
(select f2 from test1 where (f1,f3)=any(SELECT 1,'a' FROM DUAL UNION SELECT 1,'a1' FROM DUAL)),
(select f3 from test1 where (f1,f2)!=all(SELECT 1,'aaa' FROM DUAL UNION SELECT 2,'bbb' FROM DUAL)));
select * from test2;
f1	f2	f3
1	bbb	b1
2	aaa	NULL
#like,regexp
delete from test2;
insert into test2 values((select f1 from test1 where f2 like '%a%'),
(select f2 from test1 where f2 like 'a_a%'),
(select f3 from test1 where f1>0 group by f3 having f3 like 'b_'));
insert into test2 values((select f1 from test1 where f2 regexp 'aaa|ccc|ddd'),
(select f2 from test1 where f2 regexp '^a.*'),
(select f3 from test1 where f2 regexp '.*a$'));
select * from test2;
f1	f2	f3
1	aaa	b1
1	aaa	a1
#exists
delete from test2;
insert into test2 values((select min(f1) from test1 where exists(select f2 from test1 where f1>0)),
null,
null);
select * from test2;
f1	f2	f3
1	NULL	NULL
#is [not] null
delete from test2;
insert into test2 values((select f1 from test1 where f2 is null),
(select max(f2) from test1 where f3 is not null),
null);
select * from test2;
f1	f2	f3
NULL	bbb	NULL
#[not] in
delete from test2;
insert into test2 values((select f1 from test1 where f2 in ('aa','bb','cc','bbb')),
null,
(select f3 from test1 where f2 not in ('aa','bb','cc','bbb')));
select * from test2;
f1	f2	f3
2	NULL	a1
#[not] between and
delete from test2;
insert into test2 values((SELECT f1 FROM test1 WHERE f1 BETWEEN 1 AND 1.5),
(SELECT f2 FROM test1 WHERE f2 NOT BETWEEN 'aaa' AND 'abc'),
null);
select * from test2;
f1	f2	f3
1	bbb	NULL
#and,or,not
delete from test2;
insert into test2 values((SELECT f1 FROM test1 WHERE f1>0 AND f1<=1),
(SELECT max(f2) FROM test1 WHERE f1>0 OR f2>'aaa'),
(SELECT max(f3) FROM test1 WHERE NOT f2>'aaa'));
insert into test2 values((SELECT min(f1) FROM test1 WHERE f1>0 AND f1<=1 OR f2>'aaa'),
(SELECT max(f2) FROM test1 WHERE f1>0 OR f2>'aaa' AND NOT (f2<'bbb')),
NULL);
select * from test2;
f1	f2	f3
1	bbb	a1
1	bbb	NULL
#sub-3	常用系统函数
drop table test1;
drop table test2;
create table test1 (f1 int, f2 char(10), f3 varchar(10), f4 date);
create table test2 (f1 int, f2 char(10), f3 varchar(10), f4 date);
