insert into test2(f2,f3) values(
(SELECT concat(trim(f2),f3) FROM test1 WHERE LENGTH(f2)>2 AND LENGTH(f3)<3 AND f1=4),
(SELECT concat(trim(upper(f2)),lower(f3)) FROM test1 WHERE f2='Efg'));
insert into test2(f2,f3) values(
(SELECT concat(upper(f2),lower(f3)) FROM test1 WHERE f2='Efg'),
(SELECT ascii(f2)+ascii(f3) FROM test1 WHERE f1=5));
insert into test2(f2,f3) values(
(SELECT substr(f2,2) FROM test1 WHERE f1=2),
(SELECT substr(f3,1) FROM test1 WHERE substr(f2,2,2)='de'));
