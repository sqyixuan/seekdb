DROP TABLE test4;
CREATE TABLE test3(id int, name char(20), name_1 varchar(20), birthday DATE, weight float, p_id int)
PARTITION BY RANGE(id) 
(PARTITION p1 VALUES less than(103), PARTITION p2 VALUES less than(105), PARTITION p3 VALUES less than(MAXVALUE));
CREATE TABLE test4 AS SELECT * FROM test1 WHERE 1=0;
CREATE INDEX idx_3 ON test3(birthday) GLOBAL;
DELETE FROM test3;
DELETE FROM test4;
DROP FUNCTION func1;
DROP FUNCTION func2;
CREATE FUNCTION func1(i int) RETURNS int
BEGIN
RETURN i/0.5;
END;
//
CREATE FUNCTION func2(i int) RETURNS int
BEGIN
INSERT INTO test3(id,name,birthday) VALUES(
(SELECT min(id) FROM test1),
(SELECT max(name) FROM test1),
(SELECT max(birthday) FROM test1));
RETURN i/0.5;
END;
//
INSERT INTO test4(id,birthday) VALUES(
(SELECT max(id)+10 FROM test2 WHERE p_id>func1(51)),
(SELECT max(date_add(birthday,INTERVAL func2(10) YEAR)) FROM test2 WHERE id IS NOT NULL AND name>'test5'));
