func1((SELECT DISTINCT a.p_id+10 FROM test2 a JOIN test2 b ON a.id=b.p_id WHERE a.p_id IS NOT NULL))/2,
date_add((SELECT min(birthday) FROM test2),INTERVAL (func2((SELECT max(p_id) FROM test2 WHERE id>=(SELECT min(id) FROM test2) AND p_id IS NOT NULL))/2) YEAR));
