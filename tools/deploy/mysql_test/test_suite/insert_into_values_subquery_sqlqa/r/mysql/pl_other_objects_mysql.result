drop table DemoOrganization;
create table DemoOrganization 
(
OrgID     int not null,
OrgName   VARCHAR(10),
OrgPath   VARCHAR(10),
ParentID  INTEGER,
OLevel    INTEGER default 0,
AddTime   DATE,
primary key (OrgID)) 
PARTITION BY RANGE(OrgID) (PARTITION p1 VALUES less than(7), PARTITION p2 VALUES less than(MAXVALUE));
CREATE INDEX in_1 ON DemoOrganization(AddTime) GLOBAL;
