#sub-7-1	PL中使用 insert into values(subquery)
#sub-7-1-1	function
DELETE FROM test3;
DROP FUNCTION func1;
CREATE FUNCTION func1() RETURNS int
BEGIN
DECLARE var int DEFAULT 10;
INSERT INTO test3(id,name,birthday) VALUES(
(SELECT min(id) FROM test1),
(SELECT max(name) FROM test1),
(SELECT max(birthday) FROM test1));
INSERT INTO test3 VALUES(
(SELECT DISTINCT p_id FROM test1 WHERE id>=104 AND name<='test6' AND birthday<'20200101'),
(SELECT concat(trim(name),name_1) FROM test2 PARTITION(p3) WHERE id=105),
(SELECT name_1 FROM test1 WHERE birthday='20200101'),
(SELECT date_add(birthday,INTERVAL 1 YEAR) FROM test2 GROUP BY birthday HAVING birthday<'19800101'),
(SELECT weight FROM test1 ORDER BY 1 DESC LIMIT 1),
(SELECT p_id FROM test2 ORDER BY 1 LIMIT 1));
WHILE var=10 DO
INSERT INTO test3(id,birthday) VALUES(
(SELECT (CASE id WHEN 103 THEN 120 WHEN 105 THEN id+8 END) FROM test1 PARTITION(p3) WHERE name='test5'),
5+date_add((SELECT birthday FROM test1 WHERE id=107), INTERVAL (SELECT max(id-100) FROM test1 PARTITION(p3) WHERE (CASE WHEN id>105 THEN 20 ELSE -20 END)>0) YEAR));
SET var=var-10;
END WHILE;
RETURN 120;
END;
//
SELECT func1() FROM dual;
func1()
120
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	NULL	2040-01-01	NULL	NULL
102	test5admin5	admin6	1971-01-01	80.5	NULL
113	NULL	NULL	2038-01-06	NULL	NULL
DELETE FROM test3;
DROP FUNCTION func1;
CREATE FUNCTION func1() RETURNS int
BEGIN
DECLARE var int DEFAULT 10;
INSERT INTO test3 VALUES(
(SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT MAX(a.name) FROM test1 a, test2 PARTITION(p3) b WHERE a.birthday=b.birthday),
(SELECT a.name_1 FROM test1 a INNER JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.birthday FROM test1 PARTITION(p3) a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'),
(SELECT a.weight FROM test1 a LEFT JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),
(SELECT DISTINCT a.p_id FROM test1 a LEFT OUTER JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%'));
IF var=10 THEN
INSERT INTO test3(id,birthday) VALUES(
concat((SELECT MAX(id) FROM test1 a NATURAL JOIN test1 b WHERE id IS NOT NULL AND p_id IS NOT NULL),'111'),
(SELECT birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual)));
END IF;
RETURN 120;
END;
//
SELECT func1() FROM dual;
func1()
120
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	test7	admin5	2030-01-01	70.5	103
107111	NULL	NULL	1980-01-01	NULL	NULL
#sub-7-1-2	procedure
DELETE FROM test3;
DROP PROCEDURE pro1;
CREATE PROCEDURE pro1()
BEGIN
DECLARE var int DEFAULT 10;
INSERT INTO test3(id,birthday) VALUES(
(SELECT id FROM test1 WHERE name='test1' UNION SELECT id FROM test1 WHERE name='test9' UNION
SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102),
(SELECT DISTINCT a.birthday FROM test1 a JOIN test1 b ON a.name>b.name WHERE b.name LIKE '%6%' UNION ALL
SELECT birthday FROM test1 WHERE id=111 UNION ALL SELECT birthday FROM test1 PARTITION(p3) WHERE birthday>'20400101'));
loop1:LOOP
INSERT INTO test3 VALUES(
(SELECT max(id) FROM (SELECT b.id FROM test1 a RIGHT JOIN test1 PARTITION(p3) b ON a.id=b.id GROUP BY b.id) t WHERE id>101),
(SELECT DISTINCT SUBSTR((SELECT name FROM test1 WHERE id=105),(SELECT id-100 FROM test1 WHERE name='test2'),id-100) FROM test1 WHERE name_1='admin3'),
(SELECT max(name_1) FROM test1 WHERE id IN (SELECT id FROM test2 WHERE id>102 AND id<105)),
(SELECT birthday FROM test1 WHERE (id,name,name_1)=(SELECT a.id,b.name,a.name_1 FROM test1 a,test2 b WHERE a.id=b.id AND a.name=b.name AND a.birthday=b.birthday AND a.name_1<'admin2')),
(SELECT weight FROM test1 GROUP BY weight HAVING weight>=
(SELECT weight FROM test2 WHERE id>106 AND weight IS NOT NULL UNION
SELECT weight FROM test1 WHERE name IS NOT NULL AND name='test7')),
(SELECT DISTINCT p_id FROM test1 WHERE id=(SELECT id FROM test1 WHERE name='test1' UNION SELECT id FROM test1 WHERE name='test9' UNION
SELECT b.id FROM test1 a, test1 b WHERE a.id=b.id GROUP BY b.id HAVING b.id<102)));
SET var=var-10;
IF var<>10 THEN
leave loop1;
END IF;
END LOOP;
END;
//
CALL pro1();
SELECT * FROM test3;
id	name	name_1	birthday	weight	p_id
101	NULL	NULL	2030-01-01	NULL	NULL
108	est	admin4	1970-01-01	80.5	NULL
DELETE FROM test3;
DROP PROCEDURE pro1;
CREATE PROCEDURE pro1()
BEGIN
DECLARE var int DEFAULT 10;
INSERT INTO test3(id,name,name_1,birthday) VALUES(
(SELECT min(a.id) FROM test1 a JOIN (SELECT * FROM test2 WHERE id>101) b ON a.id=b.id WHERE a.birthday>'19900101'),
(SELECT a.name FROM (SELECT a.* FROM test1 a right JOIN test2 b ON a.name=b.name WHERE b.id IN (105,106,120)) a RIGHT JOIN test2 b ON a.id=b.id WHERE a.name>'test5'),
(SELECT min(b.name_1) FROM (SELECT id FROM (SELECT id,name,birthday FROM test1) a WHERE name>'test1') a,(SELECT * FROM test2) b WHERE a.id=b.id),
(SELECT a.birthday FROM (SELECT id,birthday FROM test1 a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin3' FROM dual UNION SELECT 'test8' FROM dual)) a JOIN 
(SELECT DISTINCT b.id,a.birthday FROM test1 a JOIN test1 PARTITION(p3) b ON a.name>b.name WHERE b.name LIKE '%6%' UNION ALL
SELECT id,birthday FROM test1 WHERE id=111 UNION ALL SELECT id,birthday FROM test1 WHERE birthday>'20400101') b ON a.id<b.id));
INSERT INTO test3(id,birthday) VALUES(
CONCAT((SELECT MAX(a.id) FROM test1 a LEFT OUTER JOIN test2 b ON a.birthday=b.birthday 
UNION
SELECT a.id+3 FROM test1 a RIGHT JOIN test2 b ON a.name=b.name WHERE b.id IN (105,110,120)),'111'),
(SELECT date_add(birthday,INTERVAL 10 YEAR) FROM test2 PARTITION(p1) GROUP BY birthday HAVING birthday<'19800101'
UNION
SELECT birthday FROM test1  PARTITION(p3) a NATURAL JOIN test2 b WHERE name=SOME(SELECT 'test2' FROM dual UNION SELECT 'admin5' FROM dual UNION SELECT 'test8' FROM dual)));
REPEAT
INSERT INTO test3(id,name,name_1,birthday) VALUES(
(SELECT count(*) FROM
(SELECT ORGNAME as ORGNAME,
(Select ORGNAME from DemoOrganization s where s.ORGID=c.PARENTID) as PARENTNAME,
ORGPATH as ORGPATH,OLEVEL
from DemoOrganization c where ORGPATH like'2/%' and OLEVEL<=3) t),
NULL,
NULL,
(SELECT max(AddTime) FROM DemoOrganization D
WHERE ORGID IN (SELECT ORGID FROM DemoOrganization WHERE ORGID = 12 ORDER BY 1)));
until var=10 END REPEAT;
END;
//
CALL pro1();
SELECT * FROM test3;
