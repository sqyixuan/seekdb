--echo ######################## range分区 - microsecond(time) ########################
drop table if exists t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (microsecond(c2))
(partition p0 values less than (microsecond('12:00:00.10000')),
 partition p1 values less than (microsecond('12:00:00.20000')),
 partition p2 values less than maxvalue);

