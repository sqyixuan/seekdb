explain select c1,c2 from t_part_range where c1 = '2020-01-01' and c4 = c1;
explain select c1,c4 from t_part_range group by c4 having c4 in ('2000-01-10','2000-01-19') order by c2;
explain select c1,c2 from t_part_range where c4 < '2000-02-10';
explain select c1,c2 from t_part_range where c4 between '2021-02-10' and '2021-03-15';
explain select * from t_part_range where c4 >= '2021-04-04' and c4 <= '2021-04-08';
explain select c1,c2 from t_part_range where (c4 >= '2021-02-11' and c4 <= '2021-02-15') or (c4 >= '2021-03-11' and c4 <= '2021-03-15');


