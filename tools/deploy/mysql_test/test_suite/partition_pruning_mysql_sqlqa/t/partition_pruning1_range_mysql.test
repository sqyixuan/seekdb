explain select c1,c2 from t_part_range where c2 between '08:00:00' and '12:00:00';
explain select c1,c2 from t_part_range where (c2 >= '08:00:00' and c2 < '12:00:00') or (c2 >= '23:00:00' and c2 <= '23:59:00');


