explain select c1,c2 from t_part_range where c4 < '2021-02-10 12:30:00';
explain select c1,c2 from t_part_range where c4 between '2021-02-10 12:30:00' and '2021-05-15 12:30:00';
explain select c1,c2 from t_part_range where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-04-12 12:30:00');
explain select c1,c2 from t_part_range where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-04-12 12:30:00') or (c4 >= '2021-05-11 12:30:00' and c4 <= '2021-06-12 12:30:00');


