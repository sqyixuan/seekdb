--echo ######################## range分区 - hour(time) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (hour(c2))
(partition p0 values less than (hour('12:00:00')),
 partition p1 values less than (hour('23:00:00')),
 partition p2 values less than maxvalue);

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_range where c2 = '12:00:00';
explain select c1,c2 from t_part_range where c2 in ('12:00:00','15:00:00');
