explain delete from t_part_range where c4 between '2021-01-10 12:00:00'and '2021-02-10 12:00:00';
explain delete from t_part_range where (c4 >= '2021-02-11 12:00:00' and c4 <= '2021-03-15 12:00:00') or (c4 >= '2021-03-11 12:00:00' and c4 <= '2021-04-15 12:00:00');


