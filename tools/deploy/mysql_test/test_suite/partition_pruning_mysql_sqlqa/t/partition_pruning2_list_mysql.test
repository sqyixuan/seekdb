--echo ######################## list分区 - extract(date) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (extract(year from c1))
(partition p0 values in (2000,2002,2004),
 partition p1 values in (2010,2012,2014),
 partition p2 values in (2020,2022,2024));

