(partition p0 values in (yearweek('2000-01-01'),yearweek('2010-01-01')),
 partition p1 values in (yearweek('2010-06-01'),yearweek('2020-06-01')),
 partition p2 values in (yearweek('2021-06-01'),yearweek('2022-06-01')));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_list where yearweek(c4) = yearweek('2020-01-01') limit 5;
explain select c1,c4 from t_part_list group by c4 having c4 = '2021-06-01';
explain select c1,c2 from t_part_list where c1 = '2021-06-01' and c4 = c1;
explain select c1,c4 from t_part_list group by c4 having c4 in ('2000-01-10','2020-06-01') order by c2;
explain select c1,c2 from t_part_list where c4 < '2000-02-10';
explain select c1,c2 from t_part_list where c4 between '2021-02-10' and '2021-03-15';
explain select * from t_part_list where c4 >= '2021-04-04' and c4 <= '2021-04-08';
explain select c1,c2 from t_part_list where (c4 >= '2021-02-11' and c4 <= '2021-02-15') or (c4 >= '2021-03-11' and c4 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
