--echo ######################## list分区 - hour(time) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (hour(c2))
(partition p0 values in (hour('12:00:00')),
 partition p1 values in (hour('20:00:00')),
 partition p2 values in (hour('23:00:00')));

