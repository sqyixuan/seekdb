drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (second(c2))
(partition p0 values in (10,20,second('12:30:30.10000')),
 partition p1 values in (40,second('12:59:50.20000')),
 partition p2 values in (60));

