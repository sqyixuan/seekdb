--echo ######################## list分区 - to_days(date) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (to_days(c1))
(partition p0 values in (to_days('1994-01-01'),to_days('2000-01-01')),
 partition p1 values in (to_days('2010-01-01'),to_days('2020-01-01')),
 partition p2 values in (to_days('2021-01-01'),to_days('2022-01-01')));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_list group by c1 having c1 = '2021-01-01';
