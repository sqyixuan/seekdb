--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 分区裁剪-分区类型-一级分区-list分区 --------------------------------------------------
--echo ### 用例：list分区，数值/日期数据类型，自定义表达式，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
--echo ### 标签：partition_type-1-2，partition_key_type-1/2，partition_fn-3，partition_pruning_dml，partition_where-1，partition_pruning_invalid
--echo -----------------------------------------------------------------------------------------------------------------
--echo # 公共表
drop table t_testdata;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);

insert into t_testdata values('2021-12-01','12:00:00.1000','2021','2021-12-01 12:00:00.1000','2021-12-01 12:00:00.1000');

--echo ######################## 分区键是表列间表达式 c1-c2 ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 date, c3 time, c4 year, c5 datetime, c6 datetime) 
partition by list (c1 - c2)
(partition p0 values in (10,15),
 partition p1 values in (0,20,25),
 partition p2 values in (null,30,35));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_list where c1 = '2021-06-01' and c2 = c1;
explain select c1,c2 from t_part_list where c1 = '2021-06-26' and c2 = '2021-06-01' limit 5;
explain select c1,c2 from t_part_list where c1 = '2021-02-11' and c2 = '2021-02-01' group by c1 having c1 < '2021-12-31';
explain select c1,c2 from t_part_list where c1 in ('2021-02-11','2021-02-15') and c2 in ('2021-01-15','2021-02-01');

--echo # 查询条件- fn(col) 简单形式等值比较的查询条件   (mysql分区裁剪失效,ob(mysql)分区裁剪成功)
explain select c1,c2 from t_part_list where c1 - c2 = 15;
explain select c1,c2 from t_part_list where (c1 - c2) * 2 =30 order by c1;
explain select c1,c2 from t_part_list where (c1 between '2021-02-21'and '2021-02-26') and (c2 between '2021-02-01'and '2021-02-11');
explain select c1,c2 from t_part_list where (c1 >= '2021-02-11' and c1 <= '2021-02-15') and (c2 >= '2021-02-12' and c2 <=  '2021-02-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_list set c1 = '2021-12-29' where c1 = '2021-03-31' and c2 = '2021-03-01';
explain update t_part_list set c1 = '2021-12-29' where abs(c1 - c2) = 30;
explain update t_part_list set c1 = '2021-12-29' where (c1 between '2021-02-10'and '2021-02-15') and (c2 between '2021-02-08'and '2021-02-10');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_list where c1 = '2021-02-12' and c2 = '2021-02-02';
explain delete from t_part_list where c1 in ('2021-01-20','2021-01-16') and c2 in ('2021-01-10','2021-01-11');
explain delete from t_part_list where datediff(c1,c2) = 25;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_list(c1,c2) values (NULL,NULL);
explain insert into t_part_list(c1,c2) values ('2021-02-01',NULL);
explain insert into t_part_list(c1,c2) values (NULL,'2021-03-01');
explain insert into t_part_list(c1,c2) values ('2021-03-31','2021-03-01');
explain insert into t_testdata(c1,c2) select c2,c3 from t_part_list where c1 = '2021-03-31' and c2 = '2021-03-11' limit 5;
explain insert into t_part_list(c1,c2) select c1,'2021-02-01' from t_testdata where c1 = '2021-02-11';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_list t2 where t1.c1 > t2.c1 and t2.c1 = '2021-01-26' and t2.c2 = '2021-01-01');
explain select * from (select t2.c3 from t_part_list t2 where t2.c1 = '2021-01-16' and t2.c2 = '2021-01-01') t1;


--echo ######################## 分区键是自定义分区表达式 2 * n0 ########################
--echo # 公共表
drop table t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);

insert into t_testdata values(1,true,true,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);

drop table t_part_list;
create table t_part_list (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by list (2 * n0)
(partition p0 values in (0,2,4),
 partition p1 values in (6,8,10),
 partition p2 values in (12,14,16));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_list where n3 = 5 and n0 = n3;
explain select n0,n1,n2 from t_part_list where n0 = 5 limit 5;
explain select n0,n1,n2 from t_part_list where n0 in (1,2,3) order by n0;
explain select n0,n1,n2 from t_part_list group by n0 having n0 = 4;
--echo # issue:39111439  bug10: 创建分区表达式是(abs(tinyint))的range分区表，范围查询时，mysql分区裁剪成功，ob分区裁剪失败
explain select n0,n1,n2 from t_part_list where n0 = 7 group by n0 having n0 < 10;
explain select n0,n1,n2 from t_part_list where n0 > 0 and n0 < 3;
explain select n0,n1,n2 from t_part_list where n0 between 1 and 4;


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_list set n1 = 1 where n0 = 1 or n0 = 3 or n0 = 2;
explain update t_part_list set n1 = 1 where n0 in (1,2,3);
explain update t_part_list set n1 = 1 where abs(n0) = 2;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_list where n0 <= 3;
explain delete from t_part_list where n0 between 3 and 5;
explain delete from t_part_list where n0+n2 = 8;
explain delete from t_part_list where 2 * n0 = 20;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_list(n0) values (NULL);
explain insert into t_part_list(n0) values (8);
explain insert into t_testdata(n0) select n0 from t_part_list where n0 = 0;
explain insert into t_part_list(n0) select n0 from t_testdata where n0 in (1,2,3);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select t1.n0,t1.n1 from t_testdata t1 where n3 > (select t2.n3 from t_part_list t2 where t1.n0 > t2.n0 and t2.n0 = 6);


--echo ######################## 分区键是非单调表达式 (n0 * n0 - n3) ########################
--echo # 公共表
drop table t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);

insert into t_testdata values(3,true,true,1,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);


drop table t_part_list;
create table t_part_list (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by list (n0 * n0 - n3)
(partition p0 values in (4,8),
 partition p1 values in (15,20),
 partition p2 values in (24,35));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_list where n0 = 5 and n3 = n0;
explain select n0,n1,n2 from t_part_list where n0 = -10 and n3 = 80 limit 5;
explain select n0,n1,n2 from t_part_list where n0 in (3,4) and n3 in (0,1) order by n0;
explain select n0,n1,n2 from t_part_list group by n0,n3 having n0 = 5 and n3 = 1;
explain select n0,n1,n2 from t_part_list where n0 >= 3 and n0 <= 4 and n3 >= 0 and n3 <= 1;
explain select n0,n1,n2 from t_part_list where n0 between 1 and 6 and n3 between 1 and 5;
explain select n0,n1,n2 from t_part_list where (n0 between 1 and 4) or (n0 between 0 and 1);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_list set n1 = 1 where n0 = -3  and n3 = 1;
explain update t_part_list set n1 = 1 where n0 in (2,3,4) and n3 in (1,2);
explain update t_part_list set n1 = 1 where n0 * n0  = 6 and n3 = 1;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_list where n0 <= 5 and n3<= 2;
explain delete from t_part_list where n0 between 1 and 4 and n3 between 0 and 1;
explain delete from t_part_list where (n0 * n0 - n3) = 20;
explain delete from t_part_list where (n0 * n0 + n3) = 20 and n3 = 5;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_list(n0,n3) values (NULL,NULL);
explain insert into t_part_list(n0,n3) values (5,10);
explain insert into t_testdata(n0,n3) select n0,n3 from t_part_list where n0 = 4 and n3 in (0,1);
explain insert into t_part_list(n0,n3) select n0,n3 from t_testdata where n0 in (4,5,6) and n3 in (1);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select t1.n0,t1.n1 from t_testdata t1 where n3 > (select t2.n3 from t_part_list t2 where t1.n0 > t2.n0 and t2.n0 = 6 and t2.n3 = 1);


--echo ######## 清空回收站，删除测试数据，表等 ########
--disable_warnings
--error 0,1051
drop table t_testdata;
--error 0,1051
drop table t_part_list;
drop database if exists whhtest;
--enable_warnings
purge recyclebin;

