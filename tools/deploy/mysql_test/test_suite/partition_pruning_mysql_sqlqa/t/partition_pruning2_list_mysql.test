--echo ######################## list分区 - weekday(date) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (weekday(c1))
(partition p0 values in (1,2,3),
 partition p1 values in (4,5),
 partition p2 values in (6,0));

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_list where c4 = '2000-06-01' and c1 = c4;
explain select c1,c2 from t_part_list group by c1 having c1 = '2000-06-01' ;
