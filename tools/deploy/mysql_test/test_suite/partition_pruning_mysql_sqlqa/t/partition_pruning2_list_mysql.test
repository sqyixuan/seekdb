--echo ######################## list分区 - time_to_sec(time) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (time_to_sec(c2))
(partition p0 values in (time_to_sec('08:59:59.10000'),time_to_sec('10:59:59.10000')),
 partition p1 values in (time_to_sec('12:59:59.20000'),time_to_sec('14:59:59.10000')),
 partition p2 values in (time_to_sec('20:59:59.20000'),time_to_sec('23:59:59.10000')));
 
