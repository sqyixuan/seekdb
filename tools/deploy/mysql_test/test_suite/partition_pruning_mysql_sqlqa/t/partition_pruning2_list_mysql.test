--echo ######################## list分区 - dayofyear(datetime) ########################
drop table t_part_list;
create table t_part_list (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list (dayofyear(c4))
(partition p0 values in (100,120,150),
 partition p1 values in (200,220,250),
 partition p2 values in (300,320,350));

