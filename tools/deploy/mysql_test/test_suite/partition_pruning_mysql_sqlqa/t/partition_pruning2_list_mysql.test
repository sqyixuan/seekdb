explain select c1,c2 from t_part_list where c1 >= '2020-01-01' and c1 <= '2020-01-10';
explain select c1,c2 from t_part_list where (c1 >= '2021-01-01' and c1 <= '2021-02-15') or (c1 >= '2020-01-01' and c1 <= '2020-03-15');


