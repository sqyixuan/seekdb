explain 
select t_left.n1, t_left.c1 from t_left  full outer join t_right 
on t_left.n1 = t_right.n1 and t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含副表分区键
explain 
select t_left.n1, t_left.c1 from t_left  full outer join t_right 
on t_left.n1 = t_right.n1 and t_left.c1 = '2022-01-13' ;


--echo ****** 标签partition_where-3-2-1 (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键
explain 
select t_left.n1, t_left.c1 from t_left full outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13' and t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含主表分区键 
explain 
select t_left.n1, t_left.c1 from t_left  full outer join t_right on t_left.n1 = t_right.n1 
where t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含副表分区键 
explain 
select t_left.n1, t_left.c1 from t_left  full outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13';


--echo ######################## 标签：partition_where-3-5 （union [all | distinct]）########################
--echo ######################## Rang分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);

drop table t_right;
create table t_right (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);
 

--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2022-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2022-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13';


--echo ######################## List分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by list (abs(n0))
(partition p0 values in (0,4,8),
 partition p1 values in (10,14,18),
 partition p2 values in (20,24,28));

drop table t_right;
create table t_right (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by list (abs(n0))
(partition p0 values in (0,4,8),
 partition p1 values in (10,14,18),
 partition p2 values in (20,24,28));
 

--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
where t_left.n0 = 14
union distinct 
select t_right.n1, t_right.n0 from t_right
where t_right.n0 = 14;

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
where t_left.n0 = 14 
union distinct 
select t_right.n1, t_right.n0 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
union distinct 
select t_right.n1, t_right.n0 from t_right
where t_right.n0 = 14;


--echo ######################## RANGE COLUMNS 分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(PARTITION p0 VALUES LESS THAN ('2000-01-01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01'),
  PARTITION p2 VALUES LESS THAN (MAXVALUE));

drop table t_right;
create table t_right (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(PARTITION p0 VALUES LESS THAN ('2000-01-01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01'),
  PARTITION p2 VALUES LESS THAN (MAXVALUE));

--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2000-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2000-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13';


--echo ######################## LIST COLUMNS 分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list columns(c1)
(PARTITION p0 VALUES IN ('2000-01-01','2000-06-01','2000-12-01'),
  PARTITION p1 VALUES IN ('2010-01-01','2010-06-01','2010-12-01'),
  PARTITION p2 VALUES IN ('2020-01-01','2020-06-01','2020-12-01'));

drop table t_right;
create table t_right (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by list columns(c1)
(PARTITION p0 VALUES IN ('2000-01-01','2000-06-01','2000-12-01'),
  PARTITION p1 VALUES IN ('2010-01-01','2010-06-01','2010-12-01'),
  PARTITION p2 VALUES IN ('2020-01-01','2020-06-01','2020-12-01'));

--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2000-06-01' 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2020-06-01';

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2000-06-01' 
union all 
select t_right.n1, t_right.c1 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2020-06-01';


--echo ######################## Hash分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by hash (abs(n0)) partitions 4;

drop table t_right;
create table t_right (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by hash (abs(n0)) partitions 4;
 
--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
where t_left.n0 = 14
union distinct 
select t_right.n1, t_right.n0 from t_right
where t_right.n0 = 24;

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
where t_left.n0 = 14 
union distinct 
select t_right.n1, t_right.n0 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.n0 from t_left 
union distinct 
select t_right.n1, t_right.n0 from t_right
where t_right.n0 = 24;


--echo ######################## Key分区 / union [all | distinct] ########################
drop table t_left;
create table t_left (n1 int, c1 date  NOT NULL PRIMARY KEY, c2 time, c3 year, c4 datetime, c5 timestamp) partition by key()
partitions 4;

drop table t_right;
create table t_right (n1 int, c1 date  NOT NULL PRIMARY KEY, c2 time, c3 year, c4 datetime, c5 timestamp) partition by key()
partitions 4;

--echo ****** 分区裁剪条件包含两个表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2021-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含左边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
where t_left.c1 = '2021-01-13' 
union all 
select t_right.n1, t_right.c1 from t_right;

--echo ****** 分区裁剪条件只包含右边表分区键
explain 
select t_left.n1, t_left.c1 from t_left 
union all 
select t_right.n1, t_right.c1 from t_right
where t_right.c1 = '2022-01-13'
order by n1;


--echo ----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 分区裁剪-分区类型-一级分区-补充用例 --------------------------------------------------
--echo ----------------------------------------------------------------------------------------------------------------

--echo ######################## RANGE分区 ########################
--disable_warnings
drop table if exists t_table;
--enable_warnings
CREATE TABLE t_table (a int, b varchar(255))
PARTITION BY RANGE (a)
(PARTITION p0 VALUES LESS THAN (1),
 PARTITION p1 VALUES LESS THAN (2),
 partition p2 values less than maxvalue);

--echo ###查询条件(如 not in /!= )
--echo # issue:39271748 bug18: 创建Rang/list分区，查询条件是NOT IN 或 != ，mysql进行分区裁剪，ob没有进行分区裁剪。
explain select * from t_table where a != 1;
explain select * from t_table where a not in (-1,1);


--echo ###区间比较的查询条件(如 between...and, >, <,  >=, <= ))
EXPLAIN select * from t_table where t_table.a between 1 and 2;
EXPLAIN select * from t_table where t_table.a>= 1 and t_table.a<= 2;


--echo ######################## LIST分区 ########################
drop table t_table;
create table t_table (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by list (n0)
(partition p0 values in (0),
 partition p1 values in (1),
 partition p2 values in (2));

--echo ###查询条件(如 not in /!= )
--echo # issue:39271748 bug18: 创建Rang/list分区，查询条件是NOT IN 或 != ，mysql进行分区裁剪，ob没有进行分区裁剪。
EXPLAIN SELECT * FROM t_table WHERE n0 != 1;
EXPLAIN SELECT * FROM t_table WHERE n0 NOT IN (-1,1);


--echo ###区间比较的查询条件(如 between...and, >, <,  >=, <= ))
EXPLAIN select * from t_table where t_table.n0 between 1 and 2;
EXPLAIN select * from t_table where t_table.n0>= 1 and t_table.n0<= 2;


--echo ######################## Hash分区 ########################
drop table t_table;
create table t_table (a int, b bigint) 
partition by hash(a) partitions 10;

--echo ###查询条件(如 not in /!= )
EXPLAIN SELECT * FROM t_table WHERE a != 1;
EXPLAIN SELECT * FROM t_table WHERE a NOT IN (-1,1);


--echo ###区间比较的查询条件(如 between...and, >, <,  >=, <= ))
--echo # 在 ob 的分区裁剪实现中，list/hash 分区是无法使用非 single value range 做分区裁剪的
EXPLAIN select * from t_table where t_table.a between 10 and 15;
EXPLAIN select * from t_table where t_table.a>= 10 and t_table.a<= 15;


