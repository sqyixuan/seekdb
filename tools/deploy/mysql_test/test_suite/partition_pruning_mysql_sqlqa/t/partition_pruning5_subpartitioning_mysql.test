--echo ######################## 标签：partition_where-3-2（left outer join）########################
--echo ######################## Rang分区 / left outer join ########################
drop table t_left;
create table t_left (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);

drop table t_right;
create table t_right (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);
 
--echo ****** 标签partition_where-3-2-1 (分区裁剪条件放在on中)
--echo ****** 分区裁剪条件包含主/副表分区键  (主表x   副表 v)
explain 
select t_left.n1, t_left.c1 from t_left  left outer join t_right 
on t_left.n1 = t_right.n1 and t_left.c1 = '2022-01-13' and t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件包含主表分区键 (主表 x   副表 x)
explain 
select t_left.n1, t_left.c1 from t_left  left outer join t_right 
on t_left.n1 = t_right.n1 and t_left.c1 = '2022-01-13';

--echo ****** 分区裁剪条件包含副表分区键 (主表 x   副表 v)
explain 
select t_left.n1, t_left.c1 from t_left  left outer join t_right 
on t_left.n1 = t_right.n1 and t_right.c1 = '2022-01-13' ;


--echo ****** 标签partition_where-3-2-1 (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键  mysql(主表 v   副表 v)  ob(主表 v   副表 x)
--echo # bug14: 两个Rang分区表left outer join，分区剪裁条件放在where中,mysql两张表都走分区裁剪,ob主表走分区裁剪，而副表不走分区裁剪.
explain 
select t_left.n1, t_left.c1 from t_left left outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13' and t_right.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含主表分区键 (主表 v   副表 x)
explain 
select t_left.n1, t_left.c1 from t_left  left outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13';

--echo ****** 分区裁剪条件只包含副表分区键 mysql(主表 x   副表 v)  ob(主表 x   副表 x)
--echo # bug14: 两个Rang分区表left outer join，分区剪裁条件放在where中,分区裁剪条件包含副表分区键,mysql副表走分区裁剪,ob主副表都不走分区裁剪.
explain 
select t_left.n1, t_left.c1 from t_left  left outer join t_right on t_left.n1 = t_right.n1 
where t_right.c1 = '2022-01-13';


--echo ######################## List分区 / left outer join ########################
drop table t_left;
create table t_left (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by list (abs(n0))
(partition p0 values in (0,4,8),
 partition p1 values in (10,14,18),
 partition p2 values in (20,24,28));

drop table t_right;
create table t_right (n0 tinyint, n1 smallint,n2 mediumint, n3 int, n4 integer,n5 bigint)
partition by list (abs(n0))
(partition p0 values in (0,4,8),
 partition p1 values in (10,14,18),
 partition p2 values in (20,24,28));
 
