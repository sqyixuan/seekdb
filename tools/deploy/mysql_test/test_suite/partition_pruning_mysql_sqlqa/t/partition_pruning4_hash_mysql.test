explain select c1,c4 from t_part_hash group by c4 having c4 in ('2000-01-10','2000-01-19') order by c2;
explain select c1,c2 from t_part_hash where c4 < '2000-02-10';
explain select c1,c2 from t_part_hash where c4 between '2021-02-10' and '2021-02-15';
explain select * from t_part_hash where c4 >= '2020-04-04' and c4 <= '2021-04-08';


--echo ****** 标签partition_pruning_dml-2（update语句）
