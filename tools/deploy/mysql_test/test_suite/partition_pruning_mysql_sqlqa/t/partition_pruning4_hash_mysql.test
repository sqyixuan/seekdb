--echo ######################## hash分区 - yearweek(date) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(yearweek(c1))
partitions 3;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2000-01-01' group by c1;
explain select c1,c2 from t_part_hash where c4 = '2020-01-01' and c1 = c4;
explain select c1,c2 from t_part_hash where c1 in ('2021-06-01','2022-06-01') order by c2;
