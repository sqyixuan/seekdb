explain select c1,c2 from t_part_hash group by c1 having c1 in ('2010-01-10','2021-06-01') order by c2;
explain select c1,c2 from t_part_hash where c1 < '2000-02-10';
explain select c1,c2 from t_part_hash where c1 between '2020-02-10' and '2021-02-11';
explain select * from t_part_hash where c1 >= '2021-04-04' and c1 <= '2021-04-05';


--echo ****** 标签partition_pruning_dml-2（update语句）
