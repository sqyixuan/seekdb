explain update t_part_hash set c2 = '2021-12-29' where c1 in ('2021-08-31','2022-10-01');
explain update t_part_hash set c2 = '2021-12-29' where c1 between '2020-02-10' and '2020-02-11';


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where year(c1) = 2000;
explain delete from t_part_hash where c1 between '2021-02-10' and '2021-12-11';
explain delete from t_part_hash where (c1 >= '2020-06-01' and c1 < '2020-07-01') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1) values (NULL);
explain insert into t_part_hash(c1) values ('2009-02-01');
explain insert into t_part_hash(c1) select c1 from t_testdata where c1 = '2021-02-10';
explain insert into t_testdata(c1) select c1 from t_part_hash where c1 = '2021-02-10';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 = '2022-01-15');
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 between '2001-02-10' and '2002-02-15');


--echo ######################## hash分区 - year(datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(year(c4))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2020-01-01' and c4 = c1;
explain select c1,c2 from t_part_hash where year(c4) = year('2020-01-01') limit 5;
