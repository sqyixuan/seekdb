explain update t_part_hash set c2 = '2021-12-29' where (c1 >= '2000-06-01' and c1 < '2020-01-01') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where yearweek(c1) = 200001;
explain delete from t_part_hash where c1 >= '2021-04-04' and c1 <= '2021-04-08';
explain delete from t_part_hash where c1 in ('2021-06-01','2022-06-01');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1) values (NULL);
