explain insert into t_part_hash(c1) select c1 from t_testdata where c1 = '2021-02-10';
explain insert into t_testdata(c1) select c1 from t_part_hash where c1 = '2021-02-10';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 = '2020-06-01');
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 between '2001-02-10' and '2002-02-15');


--echo ######################## hash分区 - yearweek(datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(yearweek(c4))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2020-01-01' and c4 = c1;
explain select c1,c2 from t_part_hash where yearweek(c4) = yearweek('2020-01-01') limit 5;
explain select c1,c4 from t_part_hash group by c4 having c4 = '2021-06-01';
explain select c1,c4 from t_part_hash group by c4 having c4 in ('2000-01-10','2020-06-01') order by c2;
explain select c1,c2 from t_part_hash where c4 < '2000-02-10';
explain select c1,c2 from t_part_hash where c4 between '2021-02-10' and '2021-03-15';
explain select * from t_part_hash where c4 >= '2021-04-04' and c4 <= '2021-04-08';


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c2 = '2021-12-29' where yearweek(c4) = 202010;
explain update t_part_hash set c2 = '2021-12-29' where c4 in ('2022-06-01');
explain update t_part_hash set c2 = '2021-12-29' where c4 = '2021-02-15' limit 2;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c4 between '2020-02-10' and '2021-02-15';
explain delete from t_part_hash where c4 in ('2010-06-01','2021-01-15') or c4 in ('2021-01-10','2021-01-11');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c4) values (NULL);
explain insert into t_part_hash(c4) values ('2020-06-01');
explain insert into t_testdata(c4) select c4 from t_part_hash where c4 in ('2022-06-01');
explain insert into t_part_hash(c4) select c4 from t_testdata where c4 = '2022-06-01';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c4 = '2022-01-15');
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c4 in ('2022-06-01'));


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 分区裁剪-分区类型-一级分区-hash分区 --------------------------------------------------
--echo ### 用例：hash分区，数值/日期数据类型，自定义表达式，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
--echo ### 标签：partition_type-1-4，partition_key_type-1/2，partition_fn-3，partition_pruning_dml，partition_where-1，partition_pruning_invalid
--echo -----------------------------------------------------------------------------------------------------------------
--echo # 公共表
drop table t_testdata;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);

insert into t_testdata values('2021-12-01','12:00:00.1000','2021','2021-12-01 12:00:00.1000','2021-12-01 12:00:00.1000');

--echo ######################## 分区键是表列间表达式 c1-c2 ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 date, c3 time, c4 year, c5 datetime, c6 datetime) 
partition by hash (c1 - c2)
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-06-01' and c2 = c1;
explain select c1,c2 from t_part_hash where c1 = '2021-06-01' and c2 = '2021-04-01' limit 5;
explain select c1,c2 from t_part_hash where c1 = '2021-02-01' and c2 = '2021-01-01' group by c1 having c1 < '2021-12-31';
explain select c1,c2 from t_part_hash where c1 in ('2021-01-10','2021-01-15') and c2 in ('2021-01-10','2021-01-01');

--echo # 查询条件- fn(col) 简单形式等值比较的查询条件 (mysql分区裁剪失效,ob(mysql)分区裁剪成功)
explain select c1,c2 from t_part_hash where c1 - c2 = 15;
explain select c1,c2 from t_part_hash where (c1 - c2) * 2 =30 order by c1;
explain select c1,c2 from t_part_hash where (c1 between '2021-02-10'and '2021-02-15') and (c2 between '2021-02-08'and '2021-02-10');
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') and (c2 >= '2021-02-12' and c2 <= '2021-02-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c1 = '2021-12-29' where c1 = '2021-02-01' and c2 = '2021-03-01';
explain update t_part_hash set c1 = '2021-12-29' where abs(c1 - c2) = 15;
explain update t_part_hash set c1 = '2021-12-29' where (c1 between '2021-02-10'and '2021-02-15') and (c2 between '2021-02-08'and '2021-02-10');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c1 = '2021-02-12' and c2 = '2021-02-12';
explain delete from t_part_hash where c1 in ('2021-01-10','2021-01-15') and c2 in ('2021-01-10','2021-01-11');
explain delete from t_part_hash where datediff(c1,c2) =29;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1,c2) values (NULL,NULL);
explain insert into t_part_hash(c1,c2) values ('2021-02-01',NULL);
explain insert into t_part_hash(c1,c2) values (NULL,'2021-03-01');
explain insert into t_part_hash(c1,c2) values ('2021-03-01','2021-01-01');
explain insert into t_testdata(c1,c2) select c2,c3 from t_part_hash where c1 = '2021-02-01' and c2 = '2021-03-01' limit 5;
explain insert into t_part_hash(c1,c2) select c1,'2021-02-01' from t_testdata where c1 = '2021-02-10';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 = '2022-01-15' and t2.c2 = '2021-03-01');
explain select * from (select t2.c3 from t_part_hash t2 where t2.c1 = '2022-01-15' and t2.c2 = '2021-03-01') t1;


--echo ######################## 分区键是自定义分区表达式 2 * n0 ########################
--echo # 公共表
drop table t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);

insert into t_testdata values(1,true,true,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);

drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (2 * n0)
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_hash where n3 = 5 and n0 = n3;
explain select n0,n1,n2 from t_part_hash where n0 = -10 limit 5;
explain select n0,n1,n2 from t_part_hash where n0 in (12,2,3) order by n0;
explain select n0,n1,n2 from t_part_hash group by n0 having n0=20;
explain select n0,n1,n2 from t_part_hash where n0 = -10 group by n0 having n0 < 10;
--echo # issue:39138189 bug12: 创建分区表达式是(floor(tinyint)参数是整型的range分区表，范围查询时，mysql分区裁剪成功，ob分区裁剪失效。
explain select n0,n1,n2 from t_part_hash where n0 > -10 and n0 < 10;
explain select n0,n1,n2 from t_part_hash where n0 between 1 and 9;
explain select n0,n1,n2 from t_part_hash where (n0 between 1 and 9) or (n0 between -1 and -9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n0 = -2 or n0 = -8 or n0 = 9;
explain update t_part_hash set n1 = 1 where n0 in (-12,12,15);
explain update t_part_hash set n1 = 1 where abs(n0) = 15;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n0 >= 20;
explain delete from t_part_hash where n0 between 10 and 19;
explain delete from t_part_hash where n0+n2 = 8;
explain delete from t_part_hash where 2 * n0 = 20;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n0) values (NULL);
explain insert into t_part_hash(n0) values (52);
explain insert into t_testdata(n0) select n0 from t_part_hash where n0 = 0;
explain insert into t_part_hash(n0) select n0 from t_testdata where n0 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select t1.n0,t1.n1 from t_testdata t1 where n3 > (select t2.n3 from t_part_hash t2 where t1.n0 > t2.n0 and t2.n0 = 19);


--echo ######################## 分区键是非单调表达式 (n0 * n0 - n3) ########################
--echo # 公共表
drop table t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);

insert into t_testdata values(1,true,true,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);

drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (n0 * n0 - n3)
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_hash where n0 = 5 and n3 = n0;
explain select n0,n1,n2 from t_part_hash where n0 = -10 and n3 = 80 limit 5;
explain select n0,n1,n2 from t_part_hash where n0 in (4,10) and n3 in (80,0) order by n0;
explain select n0,n1,n2 from t_part_hash group by n0,n3 having n0 = 5 and n3 = 5;
explain select n0,n1,n2 from t_part_hash where n0 >= -10 and n0 <= 10 and n3 >= 80 and n3 <= 90;
explain select n0,n1,n2 from t_part_hash where n0 between 1 and 9 and n3 between 61 and 65;
explain select n0,n1,n2 from t_part_hash where (n0 between 1 and 9) or (n0 between -1 and -9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n0 = -2 and n3 = 1;
explain update t_part_hash set n1 = 1 where n0 in (-4,5,3) and n3 in (10,20);
explain update t_part_hash set n1 = 1 where n0 * n0 = 100 and n3 = 81;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n0 <= 5 and n3<= 15;
explain delete from t_part_hash where n0 between 1 and 9 and n3 between 61 and 65;
explain delete from t_part_hash where (n0 * n0 - n3) = 20;
explain delete from t_part_hash where (n0 * n0 + n3) = 20;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n0,n3) values (NULL,NULL);
explain insert into t_part_hash(n0,n3) values (5,10);
explain insert into t_testdata(n0,n3) select n0,n3 from t_part_hash where n0 = 4 and n3 in (10,20);
explain insert into t_part_hash(n0,n3) select n0,n3 from t_testdata where n0 in (-5,5,3) and n3 in (10);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select t1.n0,t1.n1 from t_testdata t1 where n3 > (select t2.n3 from t_part_hash t2 where t1.n0 > t2.n0 and t2.n0 = 10 and t2.n3 = 50);


--echo ######## 清空回收站，删除测试数据，表等 ########
--disable_warnings
--error 0,1051
drop table t_testdata;
--error 0,1051
drop table t_part_hash;
drop database if exists whhtest;
--enable_warnings
purge recyclebin;

