# owner: sean.yyj
# owner group: sql-sql4
# description: mysql分区裁剪-hash分区
# tags: ddl,dml,delete,group_by,order_by, optimizer
# author: whh01047778


purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists whhtest;
--enable_warnings
create database whhtest;
use whhtest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 分区裁剪-分区类型-一级分区-hash分区 --------------------------------------------------
--echo ### 用例：hash分区，数值数据类型，数学函数，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
--echo ### 标签：partition_type-1-4，partition_key_type-1，partition_fn-2-1，partition_pruning_dml，partition_where-1，partition_pruning_invalid
--echo -----------------------------------------------------------------------------------------------------------------
--echo # 公共表
--disable_warnings
drop table if exists t_testdata;
--enable_warnings
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);

insert into t_testdata values(2,1,1,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);

--echo ######################## linear hash分区 ########################
--disable_warnings
drop table if exists t_part_hash;
--enable_warnings
--error 1064
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by linear hash (abs(n0)) partitions 4;


--echo ######################## hash分区 - abs(tinyint) ########################
--disable_warnings
drop table if exists t_part_hash;
--enable_warnings
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (abs(n0)) partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_hash where n0 = -10 limit 5;
explain select n0,n1,n2 from t_part_hash where n3 = -10 and n0 = n3;
explain select n0,n1,n2 from t_part_hash where n3 = -10 and n0 = n3+20;
explain select n0,n1,n2 from t_part_hash where n0 in (12,2,3) order by n0;
explain select n0,n1,n2 from t_part_hash group by n0 having n0=20;
explain select n0,n1,n2 from t_part_hash where n0 = -10 group by n0 having n0 < 10;
explain select n0,n1,n2 from t_part_hash where n0 > -10 and n0 < 10;
explain select n0,n1,n2 from t_part_hash where n0 between 10 and 14;
explain select n0,n1,n2 from t_part_hash where (n0 between 1 and 9) or (n0 between -1 and -9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n0 = -2 or n0 = -8 or n0 = 9;
explain update t_part_hash set n1 = 1 where n0 in (-12,12,16);
explain update t_part_hash set n1 = 1 where abs(n0) = 18;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n0 >= 20;
explain delete from t_part_hash where n0 between 10 and 19;
explain delete from t_part_hash where n0+n2 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n0) values (NULL);
explain insert into t_part_hash(n0) values (20);
explain insert into t_testdata(n0) select n0 from t_part_hash where n0 = 0;
explain insert into t_part_hash(n0) select n0 from t_testdata where n0 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_hash t2 where t1.n0 > t2.n0 and t2.n0 = 14);


--echo ######################## hash分区 - abs(smallint) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (abs(n3)) partitions 5;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n3,n1,n2 from t_part_hash where n3 = -10 limit 5;
explain select n0,n1,n2 from t_part_hash where n0 = 10 and n3 = n0;
explain select n3,n1,n2 from t_part_hash where n3 in (12,2,3) order by n3;
explain select n3,n1,n2 from t_part_hash group by n3 having n3=20;
explain select n3,n1,n2 from t_part_hash where n3 = -10 group by n3 having n3 < 10;
explain select n3,n1,n2 from t_part_hash where n3 > -10 and n3 < 10;
explain select n3,n1,n2 from t_part_hash where n3 between 10 and 15;
explain select n3,n1,n2 from t_part_hash where (n3 between 1 and 9) or (n3 between -1 and -9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n3 = -2 or n3 = -8 or n3 = 9;
explain update t_part_hash set n1 = 1 where n3 in (-12,12,15);
explain update t_part_hash set n1 = 1 where abs(n3) = 16;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n3 >= 20;
explain delete from t_part_hash where n3 between 10 and 19;
explain delete from t_part_hash where n3+1 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n3) values (NULL);
explain insert into t_part_hash(n3) values (10);
explain insert into t_testdata(n3) select n3 from t_part_hash where n3 = 0;
explain insert into t_part_hash(n3) select n3 from t_testdata where n3 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_hash t2 where t1.n3 > t2.n3 and t2.n3 = 14);


--echo ######################## hash分区 - ceiling(mediumint) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (ceiling(n4)) partitions 5;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n9,n1,n2 from t_part_hash where n4 = 10 limit 5;
explain select n9,n1,n2 from t_part_hash where n4 = 10.1;
explain select n9,n1,n2 from t_part_hash where n4 = 10.5;
explain select n0,n1,n2 from t_part_hash where n0 = -10 and n4 = n0;
explain select n4,n1,n2 from t_part_hash where n4 in (12,50) order by n4;
explain select n4,n1,n2 from t_part_hash group by n4 having n4 = 50;
explain select n4,n1,n2 from t_part_hash where n4 = 13 group by n4 having n4 < 10;
--echo # issue:39138189 bug12: 创建分区表达式是(floor(tinyint)参数是整型的range/hash分区表，范围查询时，mysql分区裁剪成功，ob分区裁剪失效。
explain select n4,n1,n2 from t_part_hash where n4 > 10 and n4 < 14;
explain select n4,n1,n2 from t_part_hash where n4 between 30 and 31;
explain select n4,n1,n2 from t_part_hash where (n4 between 3 and 5) or (n4 between 30 and 31);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n4 = -10 or n4 = 8 or n4 = 19;
explain update t_part_hash set n1 = 1 where n4 in (-12,12,15);
explain update t_part_hash set n1 = 1 where ceiling(n4) = 15;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n4 >= 30;
explain delete from t_part_hash where n4 between 29 and 30;
explain delete from t_part_hash where n4+n2 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n4) values (NULL);
explain insert into t_part_hash(n4) values (19);
explain insert into t_testdata(n4) select n4 from t_part_hash where n4 = 10;
explain insert into t_part_hash(n4) select n4 from t_testdata where n4 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n4 > (select t2.n4 from t_part_hash t2 where t1.n4 > t2.n4 and t2.n4 = 20);


--echo ######################## hash分区 - ceiling(decimal) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (ceiling(n8)) partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n8,n1,n2 from t_part_hash where n8 = 29.4 limit 5;
explain select n8,n1,n2 from t_part_hash where n8 = 29.5 limit 5;
explain select n8,n1,n2 from t_part_hash where n9 = 20 and n8 = n9;
explain select n8,n1,n2 from t_part_hash where n8 in (12.4, 2.5, 3.6);
explain select n8,n1,n2 from t_part_hash group by n8 having n8 = 19.9;
explain select n8,n1,n2 from t_part_hash where n8 = 9.8 group by n8 having n8 < 10;
explain select n8,n1,n2 from t_part_hash where n8 > 10.5 and n8 < 14;
explain select n8,n1,n2 from t_part_hash where n8 between 8.0 and 9.0;
explain select n8,n1,n2 from t_part_hash where (n8 between 1.1 and 8.5) or (n8 between 1.2 and 8.9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n8 = 12.2 or n8 = 18.1 or n8 = 9.3;
explain update t_part_hash set n1 = 1 where n8 in (13.5,12,15);
explain update t_part_hash set n1 = 1 where ceiling(n8) = 15;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n8 >= 20;
explain delete from t_part_hash where n8 between 29 and 30;
explain delete from t_part_hash where n8+n2 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n8) values (NULL);
explain insert into t_part_hash(n8) values (29.4);
explain insert into t_testdata(n8) select n8 from t_part_hash where n8 = 20.45;
explain insert into t_part_hash(n8) select n8 from t_testdata where n8 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_hash t2 where t1.n8 > t2.n8 and t2.n8 = 40);


--echo ######################## hash分区 - floor(mediumint) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (floor(n4)) partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n9,n1,n2 from t_part_hash where n4 = 10 limit 5;
explain select n9,n1,n2 from t_part_hash where n4 = 10.5 limit 5;
explain select n8,n1,n2 from t_part_hash where n3 = 20 and n4 = n3;
explain select n4,n1,n2 from t_part_hash where n4 in (12,50) order by n4;
explain select n4,n1,n2 from t_part_hash group by n4 having n4 = 50;
explain select n4,n1,n2 from t_part_hash where n4 = 19;
explain select n4,n1,n2 from t_part_hash where n4 > 4 and n4 < 10;
explain select n4,n1,n2 from t_part_hash where n4 between 25 and 29;
explain select n4,n1,n2 from t_part_hash where (n4 between 1 and 9) or (n4 between -1 and -9);


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where n4 = -10 or n4 = -8 or n4 = 9;
explain update t_part_hash set n1 = 1 where n4 in (-12,12,15);
explain update t_part_hash set n1 = 1 where floor(n4) = 15;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n4 >= 30;
explain delete from t_part_hash where n4 between 30 and 40;
explain delete from t_part_hash where n4+n2 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n4) values (NULL);
explain insert into t_part_hash(n4) values (19);
explain insert into t_testdata(n4) select n4 from t_part_hash where n4 = 10;
explain insert into t_part_hash(n4) select n4 from t_testdata where n4 in (-12,12,15);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n4 > (select t2.n4 from t_part_hash t2 where t1.n4 > t2.n4 and t2.n4 = 20);


--echo ######################## hash分区 - mod(tinyint,smallint) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (mod(n0,n3)) partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n0,n1,n2 from t_part_hash where n0 = 10 and n3 = 3 limit 5;
explain select n8,n1,n2 from t_part_hash where n0 = 20 and n3 = n0;
explain select n8,n1,n2 from t_part_hash where n0 = 20 and n3 = n0+3;
explain select n0,n1,n2 from t_part_hash where n0 in (10,11) and n3 in (2,3) order by n11;
explain select n0,n1,n2 from t_part_hash group by n0,n3 having n0 = 22 and n3 = 6;
explain select n0,n1,n2 from t_part_hash where n0 >= 10 and n0 <= 11 and n3 >= 2 and n3 <= 3;
explain select n0,n1,n2 from t_part_hash where n0 between 1 and 9 and n3 between 2 and 3;
explain select n0,n1,n2 from t_part_hash where mod(n0,n3) = 3;


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where (n0 = 10 and n3 = 3) or (n0 = 13 and n3 = 3);
explain update t_part_hash set n1 = 1 where n0 in (-12,13,17) and n3 in (2,3);
explain update t_part_hash set n1 = 1 where mod(n0,n3) = 2;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n0 <= 11 and n3 <= 3;
explain delete from t_part_hash where n0 between 7 and 9 and n3 between 2 and 3;
explain delete from t_part_hash where n0 + n3 = 8;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n0,n3) values (NULL,3);
explain insert into t_part_hash(n0,n3) values (3,NULL);
explain insert into t_part_hash(n0,n3) values (13,5);
explain insert into t_testdata(n0,n3) select n0,n3 from t_part_hash where n0 = 13 and n3 = 5;
explain insert into t_part_hash(n0,n3) select n0,n3 from t_testdata where n0 in (10,11) and n3 in (2,3);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n11 > (select t2.n11 from t_part_hash t2 where t1.n11 > t2.n11 and t2.n0 = 17 and t2.n3 = 5);


--echo ######################## hash分区 - mod(bigint,int) ########################
drop table t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (mod(n7,n5)) partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select n7,n1,n2 from t_part_hash where n7 = 17 and n5 = 3 limit 5;
explain select n8,n1,n2 from t_part_hash where n5 = 20 and n7 = n5;
explain select n7,n1,n2 from t_part_hash where n7 in (17,19) and n5 in (2,3) order by n11;
explain select n7,n1,n2 from t_part_hash group by n7,n5 having n7 = 22 and n5 = 6;
explain select n7,n1,n2 from t_part_hash where n7 >= 10 and n7 <= 11 and n5 >= 2 and n5 <= 3;
explain select n7,n1,n2 from t_part_hash where n7 between 1 and 9 and n5 between 2 and 3;
explain select n7,n1,n2 from t_part_hash where mod(n7,n5) = 5;


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set n1 = 1 where (n7 = 11 and n5 = 3) or (n7 = 13 and n5 = 3);
explain update t_part_hash set n1 = 1 where n7 in (-12,13,17) and n5 in (2,3);
explain update t_part_hash set n1 = 1 where mod(n7,n5) = 2;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where n7 <= 11 and n5 <= 3;
explain delete from t_part_hash where n7 between 7 and 9 and n5 between 2 and 3;
explain delete from t_part_hash where n7 + 1 = 8 and n5 = 3;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(n7,n5) values (NULL,3);
explain insert into t_part_hash(n7,n5) values (3,0);
explain insert into t_part_hash(n7,n5) values (19,5);
explain insert into t_testdata(n7,n5) select n7,n5 from t_part_hash where n7 = 13 and n5 = 5;
explain insert into t_part_hash(n7,n5) select n7,n5 from t_testdata where n7 in (10,11) and n5 in (2,3);


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where n11 > (select t2.n11 from t_part_hash t2 where t1.n11 > t2.n11 and t2.n7 = 17 and t2.n5 = 5);


--echo ****** 标签partition_pruning_invalid（分区裁剪失效场景）
--echo # 查询条件不包含分区键
explain select n0,n1,n2 from t_part_hash where n3 = 3;

--echo # 查询条件包含部分分区键
explain select n0,n1,n2 from t_part_hash where n7 = 7;
explain select n0,n1,n2 from t_part_hash where n5 = 5;

--echo # 没有查询条件
explain select n0,n1,n2 from t_part_hash limit 2;
explain select n0,n1,n2 from t_part_hash order by n7,n5;

--echo # 查询范围大于分区数
explain select n0,n1,n2 from t_part_hash where n7 > 1 and n5 > 1;

--echo # 查询条件(如 not in/!= )
explain delete from t_part_hash where n7 != 9 and n5 != 4;
explain delete from t_part_hash where n7 not in (19,29) and n5 not in (3,13);

--echo # range分区，如果分区表达式是一个函数并且查询条件是一个范围
explain select n0,n1,n2 from t_part_hash where (n7 >= 7 and n7 <= 11) and (n5 >= 3 and n5 <= 4);

--echo # 分区表达式 fn(col)形式 ,查询条件也是 fn(col) 形式指定范围
explain select n0,n1,n2 from t_part_hash where mod(n7,n5) < 0;


--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- 分区裁剪-分区类型-一级分区-hash分区 --------------------------------------------------
--echo ### 用例：hash分区，日期数据类型，日期时间函数，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
--echo ### 标签：partition_type-1-4，partition_key_type-2，partition_fn-2-2，partition_pruning_dml，partition_where-1，partition_pruning_invalid
--echo -----------------------------------------------------------------------------------------------------------------
--echo # 公共表
drop table t_testdata;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);

insert into t_testdata values('2021-12-01','12:00:00.1000','2021','2021-12-01 12:00:00.1000','2021-12-01 12:00:00.1000');
insert into t_testdata values('2021-12-02','12:00:00.1000','2021','2021-12-02 12:00:00.1000','2021-12-02 12:00:00.1001');

--echo ######################## hash分区 - datediff(date,date) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 date, c3 time, c4 year, c5 datetime, c6 timestamp) partition by hash(datediff(c1,c2))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-02-01' and c2 = c1;
explain select c1,c2 from t_part_hash group by c1,c2 having c1 = '2021-02-01' and c2 = '2021-02-01' limit 5;
explain select c1,c2 from t_part_hash where c1 = '2021-02-12' and c2 = '2021-02-01' group by c1;
explain select c1,c2 from t_part_hash where c1 = '2021-02-12' and c2 = '2021-02-02' group by c1 having c1 < '2021-12-31';
explain select c1,c2 from t_part_hash where c1 in ('2021-01-16','2021-01-15') and c2 in ('2021-01-15','2021-01-11');
explain select c1,c2 from t_part_hash where datediff(c1,c2) = 2;
explain select c1,c2 from t_part_hash where datediff(c1,c2) = 10 order by c1;
explain select c1,c2 from t_part_hash where datediff(c1,c2) = 29;
explain select c1,c2 from t_part_hash where (c1 between '2021-02-10'and '2021-02-15') and (c2 between '2021-02-08'and '2021-02-10');
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') and (c2 >= '2021-02-12' and c2 <= '2021-02-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c1 = '2021-12-29' where c1 = '2021-02-02' and c2 = '2021-02-01';
explain update t_part_hash set c1 = '2021-12-29' where c1 in ('2021-01-10','2021-01-15') and c2 in ('2021-01-10','2021-01-11');
explain update t_part_hash set c1 = '2021-12-29' where datediff(c1,c2) = 3;
explain update t_part_hash set c1 = '2021-12-29' where (c1 between '2021-02-10'and '2021-02-15') and (c2 between '2021-02-08'and '2021-02-10');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c1 = '2021-01-14' and c2 = '2021-01-12';
explain delete from t_part_hash where c1 in ('2021-01-10','2021-01-15') or c2 in ('2021-01-10','2021-01-11');
explain delete from t_part_hash where (c1 >= '2021-02-14' and c1 <= '2021-02-15') and (c2 >= '2021-02-12' and c2 <= '2021-02-15');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1,c2) values (null,null);
explain insert into t_part_hash(c1,c2) values (null,'2021-02-10');
explain insert into t_part_hash(c1,c2) values ('2021-02-10',null);
explain insert into t_part_hash(c1,c2) values ('2021-02-12','2021-02-10');
explain insert into t_testdata(c1,c2) select c2,c3 from t_part_hash where c1 = '2021-02-01' and c2 = '2021-03-01' limit 5;
explain insert into t_part_hash(c1,c2) select c1,'2021-02-01' from t_testdata where c1 = '2021-02-10';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 = '2022-01-15' and t2.c2 = '2021-03-01');


--echo ****** 标签partition_pruning_invalid（分区裁剪失效场景）
--echo # 查询条件不包含分区键
explain select c1,c2 from t_part_hash where c3 = '2022-01-01';

--echo # 查询条件包含部分分区键
explain select c1,c2 from t_part_hash where c1 = '2021-01-01';
explain select c1,c2 from t_part_hash where c2 = '2021-02-01';
explain select c1,c2 from t_part_hash having c1 < '2021-12-31';
explain select c1,c2 from t_part_hash group by c2 having c1 = '2021-02-12' and c2 = '2021-02-01';

--echo # 没有查询条件
explain select c1,c2 from t_part_hash limit 2;
explain select c1,c2 from t_part_hash group by c1,c2;

--echo # 查询范围大于分区数
explain select c1,c2 from t_part_hash where c1 > '2021-01-01' and c2 > '2021-02-01';

--echo # 查询条件(如 not in/!= )
explain delete from t_part_hash where c1 != '2021-02-01' and c2 != '2021-01-01';
explain delete from t_part_hash where c1 not in ('2021-01-10','2021-01-15') and c2 not in ('2021-01-10','2021-01-11');

--echo # 分区表达式 fn(col)形式 ,查询条件也是 fn(col) 形式指定范围
explain select c1,c2 from t_part_hash where datediff(c1,c2) < 0;

--echo # INSERT ... SELECT 常数
explain insert into t_part_hash(c1,c2) select '2021-02-11','2021-02-10';


--echo ######################## hash分区 - datediff(datetime,datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 date, c3 time, c4 year, c5 datetime, c6 datetime) partition by hash(datediff(c5,c6))
partitions 3;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c5 = '2021-02-01 12:00:00' and c6 = c5;
explain select c5,c6 from t_part_hash group by c5,c6 having c5 = '2021-02-01' and c6 = '2021-02-01' limit 5;
explain select c1,c2 from t_part_hash where c5 in ('2021-01-11','2021-01-12') and c6 in ('2021-01-10','2021-01-11') limit 5;
explain select c5,c6 from t_part_hash group by c5,c6 having datediff(c5,c6) = 10 order by c1;
explain select c1,c2 from t_part_hash where (c5 between '2021-02-10'and '2021-02-15') and (c6 between '2021-02-08'and '2021-02-10');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c1 = '2021-12-29' where c5 = '2021-02-01' and c6 = '2021-03-01';
explain update t_part_hash set c1 = '2021-12-29' where datediff(c5,c6) = 0;
explain update t_part_hash set c1 = '2021-12-29' where (c5 >= '2021-02-14' and c5 <= '2021-02-15') and (c6 >= '2021-02-12' and c6 <= '2021-02-15');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c5 = '2021-02-01' and c6 = '2021-03-01';
explain delete from t_part_hash where c5 in ('2021-01-10','2021-01-15') or c6 in ('2021-01-10','2021-01-11');
explain delete from t_part_hash where datediff(c5,c6) = 16;
explain delete from t_part_hash where c5 between '2021-02-10'and '2021-02-15';


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c5,c6) values (null,null);
explain insert into t_part_hash(c5,c6) values ('2021-02-01',null);
explain insert into t_part_hash(c5,c6) values (null,'2021-02-01');
explain insert into t_part_hash(c5,c6) values ('2021-02-11','2021-02-10');


--echo ######################## hash分区 - day(date) ########################
--echo ※mysql支持，ob(mysql)不支持该分区函数，报1564
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(day(c1))
partitions 3;

--echo ****** 标签partition_pruning_dml-1（select语句）
--echo # 查询条件-等值比较的查询条件(如 in/= )
explain select c1,c2 from t_part_hash where c1 = '2021-02-01' limit 5;
explain select c1,c2 from t_part_hash where c1 in ('2021-01-10','2021-01-15');
explain select c1,c2 from t_part_hash where day(c1) = 10;
explain select c1,c2 from t_part_hash where c1 <= '2021-02-09';
explain select c1,c2 from t_part_hash where c1 between '2021-02-10' and '2021-02-15';
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-13' and c1 <= '2021-03-15');


--echo ######################## hash分区 - day(datetime) ########################
--disable_warnings
drop table if exists t_part_hash;
--enable_warnings
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(day(c4))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c4 = '2021-02-01' group by c1;
explain select c1,c2 from t_part_hash where c4 in ('2021-01-10','2021-01-15');
explain select c1,c2 from t_part_hash where day(c1) = 10;
explain select c1,c2 from t_part_hash where c1 <= '2021-02-09';
explain select c1,c2 from t_part_hash where c1 between '2021-02-10' and '2021-02-15';
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-13' and c1 <= '2021-03-15');


--echo ######################## hash分区 - dayofmonth(date) ########################
--disable_warnings
drop table if exists t_part_hash;
--enable_warnings
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofmonth(c1))
partitions 3;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c4 = '2021-02-20' and c1 = c4;
explain select c1,c2 from t_part_hash where c1 = '2021-02-01' limit 2;
explain select c1,c2 from t_part_hash where c1 = '2021-02-20' group by c1 having c2 < '2022-02-20';
explain select c1,c2 from t_part_hash where c1 in ('2021-01-10','2021-01-19') order by c1;
explain select c1,c2 from t_part_hash where dayofmonth(c1) = 4;
explain select c1,c2 from t_part_hash group by c1 having c1 = '2022-01-15';
explain select c1,c2 from t_part_hash where c1 < '2021-02-10';
explain select c1,c2 from t_part_hash where c1 between '2021-02-10' and '2021-02-15';
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c2 = '2021-12-29' where c1 = '2021-02-15';
explain update t_part_hash set c2 = '2021-12-29' where c1 in ('2021-01-10','2021-01-19');
explain update t_part_hash set c1 = '2021-12-29' where dayofmonth(c1) = 14;
explain update t_part_hash set c2 = '2021-12-29' where c1 < '2021-02-05';
explain update t_part_hash set c2 = '2021-12-29' where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c1 between '2021-02-10'and '2021-02-15';
explain delete from t_part_hash where c1 in ('2021-01-10','2021-01-15') or c1 in ('2021-01-10','2021-01-11');
explain delete from t_part_hash where dayofmonth(c1) = 26;


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1) values (NULL);
explain insert into t_part_hash(c1) select c1 from t_testdata where c1 = '2021-02-10';
explain insert into t_testdata(c1) select c1 from t_part_hash where c1 = '2021-02-10';


--echo ****** 标签partition_pruning_dml-5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_part_hash t2 where t1.c1 > t2.c1 and t2.c1 = '2022-01-16');


--echo ######################## hash分区 - dayofmonth(datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofmonth(c4))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-02-20' and c4 = c1;
explain select c1,c4 from t_part_hash group by c4 having c4 = '2021-02-05 12:30:00';
explain select c1,c2 from t_part_hash where c4 in ('2021-01-10 12:30:00','2021-01-19 12:30:00') order by c1;
explain select c1,c2 from t_part_hash where dayofmonth(c4) = 15;
explain select c1,c2 from t_part_hash where c4 < '2021-02-10 12:30:00' limit 5;
explain select c1,c2 from t_part_hash where c4 between '2021-02-10 12:30:00' and '2021-02-15 12:30:00';
explain select c1,c2 from t_part_hash where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-02-15 12:30:00') or (c4 >= '2021-03-11 12:30:00' and c4 <= '2021-03-15 12:30:00');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c2 = '2021-12-29' where c4 = '2021-02-05 12:30:00' limit 5;
explain update t_part_hash set c2 = '2021-12-29' where c4 in ('2021-01-10 12:30:00','2021-01-19 12:30:00') order by c1;
explain update t_part_hash set c2 = '2021-12-29' where dayofmonth(c4) = 16;


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c4 < '2022-02-02 12:00:00';
explain delete from t_part_hash where c4 between '2021-02-02 12:00:00'and '2021-02-05 12:00:00';
explain delete from t_part_hash where (c4 >= '2021-02-11 12:00:00' and c4 <= '2021-02-15 12:00:00') or (c4 >= '2021-03-11 12:00:00' and c4 <= '2021-03-15 12:00:00');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c4) values (NULL);
explain insert into t_part_hash(c4) values ('2022-02-05 12:00:00');
explain insert into t_part_hash(c4) select c4 from t_testdata where c4 = '2021-02-10';
explain insert into t_testdata(c4) select c4 from t_part_hash where c4 = '2021-02-10';
explain insert into t_part_hash(c4) select '2021-02-11';


--echo ######################## hash分区 - dayofweek(date) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofweek(c1))
partitions 4;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c4 = '2021-02-20' and c1 = c4;
explain select c1,c2 from t_part_hash where c1 = '2021-02-01' order by c1 limit 3;
explain select c1,c2 from t_part_hash where c1 in ('2021-02-02','2021-01-05') group by c1;
explain select c1,c2 from t_part_hash where dayofweek(c1) = 5;
explain select c1,c2 from t_part_hash group by c1 having c1 = '2021-02-10';
explain select c1,c2 from t_part_hash where c1 < '2021-02-10';
explain select c1,c2 from t_part_hash where c1 between '2021-02-10' and '2021-02-15';
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c1 = '2021-12-29' where dayofweek(c1) = 2;
explain update t_part_hash set c2 = '2021-12-29' where c1 < '2021-02-05';
explain update t_part_hash set c2 = '2021-12-29' where c1 between '2021-02-10'and '2021-02-15';
explain update t_part_hash set c2 = '2021-12-29' where (c1 >= '2021-02-11' and c1 <= '2021-02-15') or (c1 >= '2021-03-11' and c1 <= '2021-03-15');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c1 in ('2021-01-10','2021-01-15') or c1 in ('2021-01-10','2021-01-11');
explain delete from t_part_hash where dayofweek(c1) = 5;
explain delete from t_part_hash where dayofweek(c1) = dayofweek('2022-02-03');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1) values (NULL);
explain insert into t_part_hash(c1) values ('2022-02-01');
explain insert into t_part_hash(c1) select c1 from t_testdata where c1 = '2021-02-10';
explain insert into t_testdata(c1) select c1 from t_part_hash where c1 = '2021-02-10';


--echo ######################## hash分区 - dayofweek(datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofweek(c4))
partitions 5;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-02-20' and c4 = c1;
explain select c1,c2 from t_part_hash where c4 = '2021-02-05 12:30:00' order by c4;
explain select c1,c4 from t_part_hash where c4 in ('2021-01-10 12:30:00','2021-01-11 12:30:00') group by c4;
explain select c1,c2 from t_part_hash where dayofweek(c4) = 5;
explain select c1,c4 from t_part_hash group by c4 having c4 = '2021-02-10 12:30:00';
explain select c1,c2 from t_part_hash where c4 between '2021-02-10 12:30:00' and '2021-02-15 12:30:00';
explain select c1,c2 from t_part_hash where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-02-12 12:30:00');
explain select c1,c2 from t_part_hash where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-02-12 12:30:00') or (c4 >= '2021-03-11 12:30:00' and c4 <= '2021-03-12 12:30:00');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c1 = '2021-12-29' where dayofweek(c4) = 6 limit 5;
explain update t_part_hash set c2 = '2021-12-29' where c4 < '2021-02-05 12:00:00';
explain update t_part_hash set c2 = '2021-12-29' where c4 between '2021-02-10 12:00:00' and '2021-02-15 12:00:00';


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where dayofweek(c4) = dayofweek('2021-02-05 12:30:00');
explain delete from t_part_hash where c4 in ('2021-01-10 12:30:00','2021-01-11 12:30:00');
explain delete from t_part_hash where (c4 >= '2021-02-11 12:00:00' and c4 <= '2021-02-15 12:00:00') or (c4 >= '2021-03-11 12:00:00' and c4 <= '2021-03-15 12:00:00');


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c4) values (NULL);
explain insert into t_part_hash(c4) values ('2022-02-01 12:00:00');
explain insert into t_part_hash(c4) select c4 from t_testdata where c4 = '2021-02-10';
explain insert into t_testdata(c4) select c4 from t_part_hash where c4 = '2021-02-10';


--echo ######################## hash分区 - dayofyear(date) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofyear(c1))
partitions 5;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-03-01' limit 5;
explain select c1,c2 from t_part_hash where c4 = '2021-02-20' and c1 = c4;
explain select c1,c2 from t_part_hash where c1 in ('2021-05-30','2021-06-30') order by c2;
explain select c1,c2 from t_part_hash where dayofyear(c1) = 100;
explain select c1,c2 from t_part_hash group by c1 having c1 < '2021-02-10';
explain select c1,c2 from t_part_hash where c1 between '2021-02-10' and '2021-03-15';
explain select c1,c2 from t_part_hash where (c1 >= '2021-02-11' and c1 <= '2021-03-15') or (c1 >= '2021-03-11' and c1 <= '2021-04-15');


--echo ****** 标签partition_pruning_dml-2（update语句）
explain update t_part_hash set c2 = '2021-12-29' where c1 = '2021-09-15';
explain update t_part_hash set c2 = '2021-12-29' where c1 in ('2021-01-10','2021-02-19');
explain update t_part_hash set c1 = '2021-12-29' where dayofyear(c1) = dayofyear('2021-09-16');


--echo ****** 标签partition_pruning_dml-3（delete语句）
explain delete from t_part_hash where c1 <= '2022-01-01';
explain delete from t_part_hash where c1 between '2021-02-10'and '2021-03-15';
explain delete from t_part_hash where c1 >= '2021-01-11' and c1 <= '2021-02-15';


--echo ****** 标签partition_pruning_dml-4（insert语句）
explain insert into t_part_hash(c1) values (NULL);
explain insert into t_part_hash(c1) values ('2022-08-08');
explain insert into t_part_hash(c1) select c1 from t_testdata where c1 = '2021-02-10';
explain insert into t_testdata(c1) select c1 from t_part_hash where c1 = '2021-02-10';


--echo ######################## hash分区 - dayofyear(datetime) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(dayofyear(c4))
partitions 6;

--echo ****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_hash where c1 = '2021-02-20' and c4 = c1;
explain select c1,c4 from t_part_hash group by c4 having c4 = '2021-02-05 12:30:00';
explain select c1,c2 from t_part_hash where c4 in ('2021-10-10 12:30:00','2021-11-11 12:30:00') order by c4;
explain select c1,c2 from t_part_hash where dayofyear(c4) = 100;
explain select c1,c2 from t_part_hash where c4 < '2021-02-10 12:30:00' limit 5;
explain select c1,c2 from t_part_hash where c4 between '2021-02-10 12:30:00' and '2021-05-15 12:30:00';
explain select c1,c2 from t_part_hash where (c4 >= '2021-02-11 12:30:00' and c4 <= '2021-04-12 12:30:00') or (c4 >= '2021-05-11 12:30:00' and c4 <= '2021-06-12 12:30:00');


--echo ****** 标签partition_pruning_dml-2（update语句）
