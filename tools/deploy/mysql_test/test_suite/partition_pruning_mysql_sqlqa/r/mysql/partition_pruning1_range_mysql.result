######################## range分区 - time_to_sec(time) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (time_to_sec(c2))
(partition p0 values less than (time_to_sec('08:30:30.10000')),
 partition p1 values less than (time_to_sec('16:59:59.20000')),
 partition p2 values less than maxvalue);
