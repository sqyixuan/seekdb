######################## range分区 - month(date) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (month(c1))
(partition p0 values less than (month('1994-04-01')),
 partition p1 values less than (month('1994-08-01')),
 partition p2 values less than maxvalue);
