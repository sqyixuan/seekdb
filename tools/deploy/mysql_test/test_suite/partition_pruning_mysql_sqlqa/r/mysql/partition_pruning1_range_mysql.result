drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (minute(c2))
(partition p0 values less than (minute('12:30:00.10000')),
 partition p1 values less than (minute('12:59:00.20000')),
 partition p2 values less than maxvalue);
