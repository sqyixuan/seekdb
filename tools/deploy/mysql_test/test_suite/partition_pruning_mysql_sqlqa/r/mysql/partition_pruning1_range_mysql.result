######################## range分区 - yearweek(datetime) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (yearweek(c4))
(partition p0 values less than (yearweek('2000-01-04 12:00:00')),
 partition p1 values less than (yearweek('2020-01-07 12:00:00')),
 partition p2 values less than maxvalue);
