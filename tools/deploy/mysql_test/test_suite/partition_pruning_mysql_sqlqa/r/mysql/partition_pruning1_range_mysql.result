######################## range分区 - unix_timestamp(timestamp) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (unix_timestamp(c5))
(partition p0 values less than (unix_timestamp('2000-06-01 12:00:00')),
 partition p1 values less than (unix_timestamp('2020-01-01 12:00:00')),
 partition p2 values less than maxvalue);
