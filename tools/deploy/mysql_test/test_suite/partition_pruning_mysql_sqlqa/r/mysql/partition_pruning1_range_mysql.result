######################## range分区 - quarter(date) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (quarter(c1))
(partition p0 values less than (2),
 partition p1 values less than (3),
 partition p2 values less than maxvalue);
