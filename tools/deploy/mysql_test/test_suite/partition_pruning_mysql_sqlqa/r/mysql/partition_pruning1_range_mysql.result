######################## range分区 - to_seconds(date) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (to_seconds(c1))
(partition p0 values less than (to_seconds('2000-06-01')),
 partition p1 values less than (to_seconds('2020-01-01')),
 partition p2 values less than maxvalue);
