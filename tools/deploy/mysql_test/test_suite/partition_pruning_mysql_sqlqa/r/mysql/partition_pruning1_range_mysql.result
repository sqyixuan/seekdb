-----------------------------------------------------------------------------------------------------------------
------------------------- 分区裁剪-分区类型-一级分区-range分区 --------------------------------------------------
### 用例：range分区，数值/日期数据类型，自定义表达式，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
### 标签：partition_type-1-1，partition_key_type-1/2，partition_fn-3，partition_pruning_dml，partition_where-1，partition_pruning_invalid
-----------------------------------------------------------------------------------------------------------------
# 公共表
drop table t_testdata;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);
insert into t_testdata values('2021-12-01','12:00:00.1000','2021','2021-12-01 12:00:00.1000','2021-12-01 12:00:00.1000');
######################## 分区键是表列间表达式 c1-c2 ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 date, c3 time, c4 year, c5 datetime, c6 datetime) 
partition by range (c1 - c2)
(partition p0 values less than (15),
 partition p1 values less than (60),
 partition p2 values less than maxvalue);
****** 标签partition_pruning_dml-1（select语句）
