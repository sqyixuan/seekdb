######################## range分区 - extract(datetime) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (extract(day_minute from c4))
(partition p0 values less than (10101),
 partition p1 values less than (150101),
 partition p2 values less than maxvalue);
