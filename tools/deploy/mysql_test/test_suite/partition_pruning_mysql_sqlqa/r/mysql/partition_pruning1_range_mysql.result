      sort_keys([t_part_range.n0, ASC])
  1 - output([t_part_range.n0], [t_part_range.n1], [t_part_range.n2]), filter([t_part_range.n0 IN (12, 2, 3)]), rowset=16
      access([t_part_range.n0], [t_part_range.n1], [t_part_range.n2]), partitions(p2)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
