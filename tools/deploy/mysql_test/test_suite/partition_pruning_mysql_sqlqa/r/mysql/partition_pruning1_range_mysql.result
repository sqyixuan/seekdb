######################## range分区 - dayofyear(date) ########################
drop table t_part_range;
create table t_part_range (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (dayofyear(c1))
(partition p0 values less than (150),
 partition p1 values less than (250),
 partition p2 values less than maxvalue);
