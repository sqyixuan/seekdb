  2 - output([t_table.n0], [t_table.n1], [t_table.n2], [t_table.n3], [t_table.n4], [t_table.n5], [t_table.n6], [t_table.n7], [t_table.n8], [t_table.n9],
       [t_table.n10], [t_table.n11], [t_table.n12], [t_table.n13], [t_table.n14]), filter(nil), rowset=16
      force partition granule
  3 - output([t_table.n0], [t_table.n1], [t_table.n2], [t_table.n3], [t_table.n4], [t_table.n5], [t_table.n6], [t_table.n7], [t_table.n8], [t_table.n9],
       [t_table.n10], [t_table.n11], [t_table.n12], [t_table.n13], [t_table.n14]), filter([t_table.n0 >= 1], [t_table.n0 <= 2]), rowset=16
      access([t_table.n0], [t_table.n1], [t_table.n2], [t_table.n3], [t_table.n4], [t_table.n5], [t_table.n6], [t_table.n7], [t_table.n8], [t_table.n9],
       [t_table.n10], [t_table.n11], [t_table.n12], [t_table.n13], [t_table.n14]), partitions(p[1-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t_table.__pk_increment]), range(MIN ; MAX)always true
######################## Hash分区 ########################
drop table t_table;
create table t_table (a int, b bigint) 
partition by hash(a) partitions 10;
###查询条件(如 not in /!= )
EXPLAIN SELECT * FROM t_table WHERE a != 1;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |22          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |22          |
|2 |  └─PX PARTITION ITERATOR|        |1       |22          |
|3 |    └─TABLE FULL SCAN    |t_table |1       |22          |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t_table.a], [t_table.b]), filter(nil), rowset=16
      force partition granule
  3 - output([t_table.a], [t_table.b]), filter([t_table.a != 1]), rowset=16
      access([t_table.a], [t_table.b]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_table.__pk_increment]), range(MIN ; MAX)always true
EXPLAIN SELECT * FROM t_table WHERE a NOT IN (-1,1);
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |22          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |22          |
|2 |  └─PX PARTITION ITERATOR|        |1       |22          |
|3 |    └─TABLE FULL SCAN    |t_table |1       |22          |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t_table.a], [t_table.b]), filter(nil), rowset=16
      force partition granule
  3 - output([t_table.a], [t_table.b]), filter([(T_OP_NOT_IN, t_table.a, (-1, 1))]), rowset=16
      access([t_table.a], [t_table.b]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_table.__pk_increment]), range(MIN ; MAX)always true
###区间比较的查询条件(如 between...and, >, <,  >=, <= ))
# 在 ob 的分区裁剪实现中，list/hash 分区是无法使用非 single value range 做分区裁剪的
EXPLAIN select * from t_table where t_table.a between 10 and 15;
