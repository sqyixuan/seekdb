      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_left.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t_right.n1]), filter([t_right.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))]), rowset=16
      access([t_right.c1], [t_right.n1]), partitions(p2)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_right.__pk_increment]), range(MIN ; MAX)always true
