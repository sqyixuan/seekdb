# bug14: 两个Rang分区表left outer join，分区剪裁条件放在where中,分区裁剪条件包含主/副表分区键 ,mysql两张表都走分区裁剪,ob主表走分区裁剪，而副表不走分区裁剪.
explain 
select t_left.n1, t_left.c1 from t_left right outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13' and t_right.c1 = '2022-01-13';
Query Plan
==============================================
|ID|OPERATOR   |NAME   |EST.ROWS|EST.TIME(us)|
----------------------------------------------
|0 |MERGE JOIN |       |1       |10          |
|1 |├─TABLE GET|t_right|1       |5           |
|2 |└─TABLE GET|t_left |1       |5           |
==============================================
Outputs & filters:
-------------------------------------
  0 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
      equal_conds([t_left.n1 = t_right.n1]), other_conds(nil)
      merge_directions([ASC])
  1 - output([t_right.n1]), filter(nil), rowset=16
      access([t_right.n1]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([t_right.c1]), range[2022-01-13 ; 2022-01-13], 
      range_cond([t_right.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))])
  2 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      access([t_left.c1], [t_left.n1]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([t_left.c1]), range[2022-01-13 ; 2022-01-13], 
      range_cond([t_left.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))])
