######################## RANGE分区 ########################
drop table if exists t_table;
CREATE TABLE t_table (a int, b varchar(255))
PARTITION BY RANGE (a)
(PARTITION p0 VALUES LESS THAN (1),
 PARTITION p1 VALUES LESS THAN (2),
 partition p2 values less than maxvalue);
###查询条件(如 not in /!= )
# issue:39271748 bug18: 创建Rang/list分区，查询条件是NOT IN 或 != ，mysql进行分区裁剪，ob没有进行分区裁剪。
explain select * from t_table where a != 1;
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |8           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |8           |
|2 |  └─PX PARTITION ITERATOR|        |1       |7           |
|3 |    └─TABLE FULL SCAN    |t_table |1       |7           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_table.a, t_table.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t_table.a], [t_table.b]), filter(nil), rowset=16
      force partition granule
  3 - output([t_table.a], [t_table.b]), filter([t_table.a != 1]), rowset=16
      access([t_table.a], [t_table.b]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_table.__pk_increment]), range(MIN ; MAX)always true
explain select * from t_table where a not in (-1,1);
