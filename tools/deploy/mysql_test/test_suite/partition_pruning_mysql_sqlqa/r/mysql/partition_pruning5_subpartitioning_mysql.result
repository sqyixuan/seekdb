######################## List + Key 分区 ########################
drop table t_part_sub;
CREATE TABLE t_part_sub (empno varchar(20),empname varchar(20) ,deptno int,birthdate date NOT NULL,salary int)
PARTITION BY list (deptno)
subpartition by key(birthdate)
subpartitions 3
 (PARTITION p0 VALUES in (null,10,15),
  PARTITION p1 VALUES in (20,25),
  PARTITION p2 VALUES in (30,35));
