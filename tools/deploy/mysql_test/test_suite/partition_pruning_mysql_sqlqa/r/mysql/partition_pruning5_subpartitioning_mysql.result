===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |HASH FULL OUTER JOIN       |        |1       |16          |
|1 |├─PX COORDINATOR           |        |1       |8           |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|1       |8           |
|3 |│   └─PX PARTITION ITERATOR|        |1       |7           |
|4 |│     └─TABLE FULL SCAN    |t_left  |1       |7           |
|5 |└─PX COORDINATOR           |        |1       |8           |
|6 |  └─EXCHANGE OUT DISTR     |:EX20000|1       |8           |
|7 |    └─PX PARTITION ITERATOR|        |1       |7           |
|8 |      └─TABLE FULL SCAN    |t_right |1       |7           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
      equal_conds([t_left.n1 = t_right.n1]), other_conds([t_left.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))], [t_right.c1 = demote_cast('2022-01-13',
       MYSQL_DATE(10, 0))])
  1 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
  2 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
      dop=1
  3 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      force partition granule
  4 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      access([t_left.c1], [t_left.n1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t_left.__pk_increment]), range(MIN ; MAX)always true
  5 - output([t_right.c1], [t_right.n1]), filter(nil), rowset=16
  6 - output([t_right.c1], [t_right.n1]), filter(nil), rowset=16
      dop=1
  7 - output([t_right.c1], [t_right.n1]), filter(nil), rowset=16
      force partition granule
  8 - output([t_right.c1], [t_right.n1]), filter(nil), rowset=16
      access([t_right.c1], [t_right.n1]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t_right.__pk_increment]), range(MIN ; MAX)always true
