      access([t_right.n1]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([t_right.c1]), range[2022-01-13 ; 2022-01-13], 
      range_cond([t_right.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))])
  2 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
  3 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
      dop=1
  4 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      force partition granule
  5 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      access([t_left.c1], [t_left.n1]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t_left.c1]), range(MIN ; MAX)always true
****** 分区裁剪条件包含副表分区键 mysql(主表 x   副表 v)  ob(主表 x   副表 x)
# bug14: 两个Rang分区表left outer join，分区剪裁条件放在where中,分区裁剪条件包含副表分区键,mysql副表走分区裁剪,ob主副表都不走分区裁剪.
explain 
select t_left.n1, t_left.c1 from t_left  right outer join t_right on t_left.n1 = t_right.n1 
where t_left.c1 = '2022-01-13' ;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |HASH JOIN                  |        |1       |14          |
|1 |├─PX COORDINATOR           |        |1       |9           |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|1       |9           |
|3 |│   └─PX PARTITION ITERATOR|        |1       |9           |
|4 |│     └─TABLE FULL SCAN    |t_right |1       |9           |
|5 |└─TABLE GET                |t_left  |1       |5           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([t_left.n1], [t_left.c1]), filter(nil), rowset=16
      equal_conds([t_left.n1 = t_right.n1]), other_conds(nil)
  1 - output([t_right.n1]), filter(nil), rowset=16
  2 - output([t_right.n1]), filter(nil), rowset=16
      dop=1
  3 - output([t_right.n1]), filter(nil), rowset=16
      force partition granule
  4 - output([t_right.n1]), filter(nil), rowset=16
      access([t_right.n1]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t_right.c1]), range(MIN ; MAX)always true
  5 - output([t_left.c1], [t_left.n1]), filter(nil), rowset=16
      access([t_left.c1], [t_left.n1]), partitions(p1)
      is_index_back=false, is_global_index=false, 
      range_key([t_left.c1]), range[2022-01-13 ; 2022-01-13], 
      range_cond([t_left.c1 = demote_cast('2022-01-13', MYSQL_DATE(10, 0))])
######################## 标签：partition_where-3-4 （full outer join）########################
######################## Rang分区 / full outer join ########################
drop table t_left;
create table t_left (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);
drop table t_right;
create table t_right (n1 int, c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range (year(c1))
(partition p0 values less than (2000),
 partition p1 values less than (2020),
 partition p2 values less than maxvalue);
****** 标签partition_where-3-2-1 (分区裁剪条件放在on中)
****** 分区裁剪条件包含主/副表分区键
explain 
select t_left.n1, t_left.c1 from t_left full outer join t_right 
on t_left.n1 = t_right.n1 and t_left.c1 = '2022-01-13' and t_right.c1 = '2022-01-13';
