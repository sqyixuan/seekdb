purge recyclebin;
drop database if exists whhtest;
create database whhtest;
use whhtest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
-----------------------------------------------------------------------------------------------------------------
------------------------- 分区裁剪-分区类型-二级分区 --------------------------------------------------
### 用例：二级分区，分区裁剪sql语句，查询条件/二级分区场合，分区裁剪失效场景
### 标签：partition_type-2，partition_key_type，partition_fn-1，partition_fn-2，partition_pruning_dml，partition_where-2，partition_pruning_invalid
-----------------------------------------------------------------------------------------------------------------
# 公共表
drop table if exists t_testdata;
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);
insert into t_testdata values('2022-12-01','12:00:00.1000','2020','2022-12-01 12:00:00.1000','2022-12-01 12:00:00.1000');
insert into t_testdata values('2022-12-02','13:00:00.1000','2021','2022-12-02 13:00:00.1000','2022-12-02 12:00:00.1001');
######################## Range + Hash 分区 ########################
drop table if exists t_part_sub;
create table t_part_sub (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp)
partition by range (YEAR(c4))
  subpartition by hash( to_days(c1) )
  subpartitions 3 
  (partition p0 values less than (2000),
   partition p1 values less than (2010),
   partition p2 values less than maxvalue);
****** 标签partition_pruning_dml-1（select语句）
explain select c1,c2 from t_part_sub where c1 = '1994-06-01' group by c1;
Query Plan
===================================================================
|ID|OPERATOR                     |NAME      |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------------
|0 |MERGE GROUP BY               |          |1       |8           |
|1 |└─PX COORDINATOR             |          |1       |8           |
|2 |  └─EXCHANGE OUT DISTR       |:EX10000  |1       |8           |
|3 |    └─MERGE GROUP BY         |          |1       |7           |
|4 |      └─PX PARTITION ITERATOR|          |1       |7           |
|5 |        └─TABLE FULL SCAN    |t_part_sub|1       |7           |
===================================================================
Outputs & filters:
-------------------------------------
  0 - output([t_part_sub.c1], [t_part_sub.c2]), filter(nil), rowset=16
      group(nil), agg_func(nil)
  1 - output([t_part_sub.c1], [t_part_sub.c2]), filter(nil), rowset=16
  2 - output([t_part_sub.c1], [t_part_sub.c2]), filter(nil), rowset=16
      dop=1
  3 - output([t_part_sub.c1], [t_part_sub.c2]), filter(nil), rowset=16
      group(nil), agg_func(nil)
  4 - output([t_part_sub.c1], [t_part_sub.c2]), filter(nil), rowset=16
      force partition granule
  5 - output([t_part_sub.c1], [t_part_sub.c2]), filter([t_part_sub.c1 = demote_cast('1994-06-01', MYSQL_DATE(10, 0))]), rowset=16
      access([t_part_sub.c1], [t_part_sub.c2]), partitions(p0sp0, p1sp0, p2sp0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_part_sub.__pk_increment]), range(MIN ; MAX)always true
