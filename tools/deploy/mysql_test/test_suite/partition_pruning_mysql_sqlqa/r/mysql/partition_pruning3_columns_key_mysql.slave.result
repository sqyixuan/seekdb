######################## key分区 - 分区键 varchar ########################
drop table t_part_key;
create table t_part_key (s0 char(10), s1 varchar(10),s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
partition by key (s1) partitions 4;
