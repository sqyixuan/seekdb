######################## hash分区 - unix_timestamp(timestamp) ########################
drop table t_part_hash;
create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash(unix_timestamp(c5))
partitions 4;
