purge recyclebin;
drop database if exists whhtest;
create database whhtest;
use whhtest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
-----------------------------------------------------------------------------------------------------------------
------------------------- 分区裁剪-分区类型-一级分区-hash分区 --------------------------------------------------
### 用例：hash分区，数值数据类型，数学函数，分区裁剪sql语句，查询条件/一级分区场合，分区裁剪失效场景
### 标签：partition_type-1-4，partition_key_type-1，partition_fn-2-1，partition_pruning_dml，partition_where-1，partition_pruning_invalid
-----------------------------------------------------------------------------------------------------------------
# 公共表
drop table if exists t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);
insert into t_testdata values(2,1,1,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);
######################## linear hash分区 ########################
drop table if exists t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by linear hash (abs(n0)) partitions 4;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'linear hash (abs(n0)) partitions 4' at line 2
######################## hash分区 - abs(tinyint) ########################
drop table if exists t_part_hash;
create table t_part_hash (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by hash (abs(n0)) partitions 4;
