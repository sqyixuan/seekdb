#owner: fanfangzhou.ffz
#owner group: RS
#tags: rs
#description:
# test tenant with tenant id bigger than 10w could run normally

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
drop tenant tt1 force;
drop resource pool tenant_tt1_pool;
drop resource unit tenant_tt1_unit;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error


--source mysql_test/include/modify_tenant_id_10w.inc


#create resource unit if not exists tenant_tt1_unit max_cpu=1,memory_size='2G';
#create resource pool if not exists tenant_tt1_pool unit='tenant_tt1_unit', unit_num=1;
#create tenant if not exists tt1 RESOURCE_POOL_LIST=('tenant_tt1_pool')
#set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';

let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);

use test;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (col1 int);
create index i1 on t1(col1);
insert into t1 values(1);
select * from t1;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

connection sys;

#drop tenant tt1 force;
#drop resource pool tenant_tt1_pool;
#drop resource unit tenant_tt1_unit;
