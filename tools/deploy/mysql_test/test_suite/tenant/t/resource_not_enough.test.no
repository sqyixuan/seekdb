--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zongmei.zzm
#owner group:sql1
#--disable_abort_on_error

let $zone1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1);

let $zone2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 2);

alter system set resource_hard_limit = 100;
sleep 10;

## exception 1: resource pool资源分配不足
eval create resource unit unit_3 MAX_CPU=5, MEMORY_SIZE '1G';
let $pool_cnt = 3;
while ($pool_cnt > 0)
{
  eval create resource pool pool$pool_cnt unit='unit_3',unit_num=1,zone_list=('$zone2');
  dec $pool_cnt;
}

#--error 4624
eval create resource pool pool_4 unit='unit_3',unit_num=2,zone_list=('$zone2');

let $pool_cnt = 3;
while ($pool_cnt > 0)
{
  eval drop resource pool pool$pool_cnt;
  dec $pool_cnt;
}

#drop resource unit unit_3;

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id
select * from oceanbase.__all_resource_pool;
--replace_column 1 create_time 2 modify_time 3 unit_config_id 11 max_disk_size
select * from oceanbase.__all_unit_config;

