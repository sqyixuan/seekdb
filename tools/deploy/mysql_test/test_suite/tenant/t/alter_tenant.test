--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner      : beity.lhy
# owner group: storage
# description: check alter unknown tenant when setting progressive_merge_num
#--disable_abort_on_error


connect(my_sys,$OBMYSQL_MS0,root,,,$OBMYSQL_PORT);

# ========= alter exist tenant config ========
--error 1235
alter tenant sys set progressive_merge_num = 2;

# ========= alter non-exist tenant config ========
-- error 5157
alter tenant t1 set progressive_merge_num = 2;

disconnect my_sys;
connection default;
