--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: rongxuan.lc
#owner group:rs
#--disable_abort_on_error

alter system set resource_hard_limit = 300;

let $pcount = 100;
let $ucount = 100;
eval CREATE RESOURCE UNIT unit$ucount MAX_CPU=1, MEMORY_SIZE='1G';

## 1.创建resource pool
eval create resource pool pool$pcount unit='unit$pcount', unit_num = 2, zone_list = ('zone1');


#eval CREATE RESOURCE POOL pool$pcount unit='unit$pcount', Unit_num=2, Zone_list=('zone2');

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id
select * from oceanbase.__all_resource_pool;


select name,unit_count,zone_list from oceanbase.__all_resource_pool where name='pool93';

## 2. 不指定zone_list, 将zone_list设置为所有zone
--error 4648
create resource pool empty_zone_list_pool unit='unit92', unit_num=1;

## 3. unit不存，应该报错
--error 4648
create resource pool pool90 unit='unit90', unit_num=1, zone_list=('zone1');

## 4.创建同名的resource pool
--error 4648
create resource pool pool100 unit='unit91', unit_num = 2, zone_list = ('zone1');

## 6.语法错误
--error 1210
create resource pool pool90 unit='unit91', unit_num=0, zone_list=('zone1');

--error 1210
create resource pool pool89;

--error 4530
create resource pool pool89 unit='unit92', unit_num=1, zone_list=('');

--error 4530
create resource pool pool89 unit='unit92', unit_num=1, zone_list=('zone5');

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id
select * from oceanbase.__all_resource_pool;

select name,unit_count,zone_list from oceanbase.__all_resource_pool where name='pool92' and zone_list='test5';

select name from oceanbase.__all_resource_pool where name='pool89' and zone_list='zone1';

## 7.resource pool有想同的unit
#while ($pcount > 88)
#{
--error 4648
eval CREATE RESOURCE POOL pool$pcount UNIT='unit99', UNIT_NUM=2, ZONE_LIST=('zone2');
#dec $pcount;
#}

## 8.删除resource pool
#let $pcount = 100;
#while ($pcount > 95)
#{
  eval drop resource pool pool$pcount;
#  dec $pcount;
#}

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id
select * from oceanbase.__all_resource_pool;
--replace_column 1 create_time 2 modify_time 3 unit_config_id 11 max_disk_size
select * from oceanbase.__all_unit_config;

## 9.删除不存在的resource pool
--error 4650
drop resource pool pool0;

## 10.删除在使用的resource unit应该报错
--error 4648
drop resource unit unit95;

## 删除不被使用的resource unit
drop resource unit unit100;

## 11.语法错误
--error 1064
drop resource pool pool94, pool93;

## 12.pool_name名字字符限制
--error 4648
create resource pool pool_1 unit='unit99', unit_num=1, zone_list=('zone1');
--error 4650
drop resource pool pool_1;

--error 1064
create resource pool unit%(1) unit='unit99', unit_num=1, zone_list=('zone1');

--error 1064
create resource pool pool.pool unit='unit99', unit_num=1, zone_list=('zone1');

--error 1064
create resource pool pool。unit unit='unit99', unit_num=1, zone_list=('zone1');

--error 1064
create resource pool my/unit unit='unit99', unit_num=1, zone_list=('zone1');

--error 1064
create resource pool pool\unit unit='unit99', unit_num=1, zone_list=('zone1');

--error 4648
create resource pool 12_pooL unit='unit99', unit_num=1, zone_list=('zone2');

--error 4648
create resource pool _pooL12 unit='unit99', unit_num=1, zone_list=('zone2');

# 大小写敏感
--error 4648
create resource pool PooL91 unit='unit100', unit_num=1, zone_list=('zone2');

## 5.unit_num设置很大的值
--error 4656
create resource pool pool111 unit='unit91', unit_num=10, zone_list=('zone1');

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id
select * from oceanbase.__all_resource_pool;

