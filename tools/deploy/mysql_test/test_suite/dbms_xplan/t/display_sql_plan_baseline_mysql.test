#owner: zhenling.zzg
#owner group: sqlqa
#description:dbms_xplan
#tags:pl,optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
create table t1(c1 int, c2 int);

set @use_spb = @@optimizer_use_sql_plan_baselines;
set @cap_spb = @@optimizer_capture_sql_plan_baselines;
set session optimizer_use_sql_plan_baselines = 'ON';
set session optimizer_capture_sql_plan_baselines = 'ON';

select count(*) from t1;

--let $trace_id=query_get_value(select last_trace_id() trace from dual, trace, 1)
--let $sql_handle=69AE2D9E3BF106CE009F93EFAF925EC8
--let $svr_ip=query_get_value(select svr_ip from oceanbase.__all_virtual_sql_audit where trace_id='$trace_id' limit 1, svr_ip, 1)
--let $svr_port=query_get_value(select svr_port from oceanbase.__all_virtual_sql_audit where trace_id='$trace_id' limit 1, svr_port, 1)
--let $tenant_id=1004

--let $plan_name=query_get_value(select plan_name from oceanbase.DBA_SQL_PLAN_BASELINES where sql_handle = '$sql_handle' limit 1, plan_name, 1)
--let $sql=select dbms_xplan.display_sql_plan_baseline('$sql_handle','$plan_name') plan;
--replace_regex /\|[0-9]+[ ]+/|x/g
eval $sql;

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection sys;
--let $sql=select dbms_xplan.display_sql_plan_baseline('$sql_handle','$plan_name', 'all', '$svr_ip', $svr_port, $tenant_id) plan;
--replace_regex /\|[0-9]+[ ]+/|x/g
eval $sql;

connect (oracle,$OBMYSQL_MS0,sys@oracle,,test,$OBMYSQL_PORT);
connection oracle;
--let $sql=select * from table(dbms_xplan.display_sql_plan_baseline('$sql_handle','$plan_name', 'typical', '$svr_ip', $svr_port, $tenant_id));
eval $sql;

connection default;

alter system flush plan cache;
--let $sql=select dbms_xplan.display_sql_plan_baseline('$sql_handle','$plan_name', 'all') plan;
eval $sql;

--let $sql=select dbms_xplan.display_sql_plan_baseline('$sql_handle') plan;
--error 5343
eval $sql;

--let $sql=select dbms_xplan.display_sql_plan_baseline(null,'$plan_name') plan;
eval $sql;

drop table t1;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 int);

select count(*) from t1, t2;

call dbms_spm.BATCH_LOAD_PLANS_FROM_CURSOR_CACHE('YES');
alter system flush plan cache;
insert into t2 select random()%100 from table(generator(4000));
select count(*) from t1, t2;
--replace_regex /\|[0-9]+[ ]+/|x/g
select dbms_xplan.display_cursor(0, 'all');

set session optimizer_use_sql_plan_baselines = @use_spb;
set session optimizer_capture_sql_plan_baselines = @cap_spb;
