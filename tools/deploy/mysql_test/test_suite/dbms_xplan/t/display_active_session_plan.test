#owner: zhenling.zzg
#owner group: sqlqa
#description:dbms_xplan
#tags:pl,optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
create table t1(c1 int, c2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,4);
insert into t1 values(5,5);

select * from t1;

--let $session_id=query_get_value(show full processlist, Id, 1)

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--let $sql=select dbms_xplan.display_active_session_plan($session_id) as plan from dual;
eval $sql;
connection default;

select * from t1;


--replace_regex /\|[0-9]+[ ]+|cast\([0-9]+/|x/g
eval $sql;
--replace_regex /\|[0-9]+[ ]+|cast\([0-9]+/|x/g
eval $sql;
connection default;

explain select * from t1;

connection sys;
eval $sql;
connection default;
