#description:dbms_xplan
#tags:pl,optimizer

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
create table t1(c1 int, c2 int);
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,4);
insert into t1 values(5,5);

alter system flush plan cache;

select * from t1;

--let $trace_id=query_get_value(select last_trace_id() trace from dual, trace, 1)
--let $svr_ip=query_get_value(select svr_ip from oceanbase.__all_virtual_server_stat limit 1, svr_ip, 1)
--let $svr_port=query_get_value(select svr_port from oceanbase.__all_virtual_server_stat limit 1, svr_port, 1)
--let $tenant_id=1
--let $plan_id=query_get_value(select plan_id from oceanbase.__all_virtual_sql_audit where trace_id='$trace_id' order by plan_id asc limit 1, plan_id, 1)
--let $inner_sql_plan_id=query_get_value(select plan_id from oceanbase.__all_virtual_sql_audit where trace_id='$trace_id' order by plan_id desc limit 1, plan_id, 1)

--let $sql=select dbms_xplan.display_cursor($plan_id, 'typical', '$svr_ip', $svr_port, $tenant_id) as plan from dual;
--replace_regex /\|[0-9]+[ ]+/|x/g
eval $sql;

--let $sql=select dbms_xplan.display_cursor($inner_sql_plan_id, 'typical', '$svr_ip', $svr_port, $tenant_id) as plan from dual;
--replace_regex /\|[0-9]+[ ]+/|x/g /[0-9]{6}/XXXXXX/
eval $sql;

connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--let $sql=select dbms_xplan.display_cursor($plan_id, 'typical', '$svr_ip', $svr_port, $tenant_id) as plan from dual;
--replace_regex /\|[0-9]+[ ]+/|x/g
eval $sql;

--let $sql=select dbms_xplan.display_cursor($inner_sql_plan_id, 'typical', '$svr_ip', $svr_port, $tenant_id) as plan from dual;
--replace_regex /\|[0-9]+[ ]+/|x/g /[0-9]{6}/XXXXXX/
eval $sql;

--echo "系统租户能查到所有租户的信息"

connection default;

--echo "普通租户只能查到当前租户信息"

select * from t1;
--replace_regex /\|[0-9]+[ ]+/|x/g
select dbms_xplan.display_cursor() from dual;

alter system flush plan cache;
--let $sql=select dbms_xplan.display_cursor($plan_id) as plan from dual;
eval $sql;
