# owner: xiaoyi.xy
#tags: optimizer
# owner group: SQL2
# description: 测试老的分布式框架下，batch nested loop join的运行

--result_format 4

--disable_warnings
drop table if exists t_h3_01_20, t_h5_09_28;
--enable_warnings
create table t_h3_01_20(a int, b int, c datetime, primary key (a)) partition by hash(a) partitions 3;
create table t_h5_09_28(a int, b int, c datetime, primary key (a)) partition by hash(a) partitions 5;

insert into t_h3_01_20 values ( 1,  1, 20161101), ( 2,  2, 20161102), ( 3,  3, 20161103), ( 4,  4, 20161104),
                              ( 5,  5, 20161105), ( 6,  6, 20161106), ( 7,  7, 20161107), ( 8,  8, 20161108),
                              ( 9,  9, 20161109), (10, 10, 20161110), (11, 11, 20161111), (12, 12, 20161112),
                              (13, 13, 20161113), (14, 14, 20161114), (15, 15, 20161115), (16, 16, 20161116),
                              (17, 17, 20161117), (18, 18, 20161118), (19, 19, 20161119), (20, 20, 20161120);
insert into t_h5_09_28 values ( 9,  9, 20161109), (10, 10, 20161110), (11, 11, 20161111), (12, 12, 20161112),
                              (13, 13, 20161113), (14, 14, 20161114), (15, 15, 20161115), (16, 16, 20161116),
                              (17, 17, 20161117), (18, 18, 20161118), (19, 19, 20161119), (20, 20, 20161120),
                              (21, 21, 20161121), (22, 22, 20161122), (23, 23, 20161123), (24, 24, 20161124),
                              (25, 25, 20161125), (26, 26, 20161126), (27, 27, 20161127), (28, 28, 20161128);
explain select /*+no_use_px use_nl(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 left join t_h5_09_28 t2 on t1.b = t2.a and t2.a in (1, 2, 6, 7) where t1.a = 3 order by t1.a desc, t2.a desc;
select /*+no_use_px use_nl(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 left join t_h5_09_28 t2 on t1.b = t2.a and t2.a in (1, 2, 6, 7) where t1.a = 3 order by t1.a desc, t2.a desc;

--echo // use px
explain select t1.a, t2.a from t_h3_01_20 t1 left join t_h5_09_28 t2 on t1.b = t2.a and t2.a in (1, 2, 6, 7) where t1.a = 3 order by t1.a desc, t2.a desc;
select t1.a, t2.a from t_h3_01_20 t1 left join t_h5_09_28 t2 on t1.b = t2.a and t2.a in (1, 2, 6, 7) where t1.a = 3 order by t1.a desc, t2.a desc;
