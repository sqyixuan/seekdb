#owner: wenkai.cwk

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
--disable_warnings
drop table if exists hwx1;
--enable_warnings

--disable_query_log
--disable_result_log
DROP TABLE IF EXISTS `hwx1`;
CREATE TABLE `hwx1` (
  `time` varchar(30) DEFAULT NULL,
  `level` varchar(10) DEFAULT NULL,
  `module` varchar(30) DEFAULT NULL,
  `event` varchar(100) DEFAULT NULL,
  `errcode` int(11) DEFAULT NULL,
  `ip` varchar(100) DEFAULT NULL,
  `port` varchar(100) DEFAULT NULL,
  `tenant_id` int(11) DEFAULT NULL,
  `thread_id` int(11) DEFAULT NULL,
  `thread_name` varchar(50) DEFAULT NULL,
  `trace_id` varchar(50) DEFAULT NULL,
  `func_name` varchar(100) DEFAULT NULL,
  `code_location` varchar(100) DEFAULT NULL,
  `message` longtext DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
LOCK TABLES `hwx1` WRITE;
