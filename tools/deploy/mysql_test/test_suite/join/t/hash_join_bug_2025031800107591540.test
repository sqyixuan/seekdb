select distinct  ref_1.level as c0,  case when 51 - 51 then ref_1.thread_name else cast(null as CHAR) end  as c2 from  (hwx1 as ref_0 left join hwx1  as ref_1 on (ref_0.errcode = ref_1.errcode )) limit 121;
drop table if exists hwx1;