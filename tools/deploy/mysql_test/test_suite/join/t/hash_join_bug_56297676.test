#owner: xiaoyi.xy

--result_format 4
--explain_protocol 2

--disable_warnings
drop table if exists t_fml;
--enable_warnings

# sql 1
create table t_fml (  c_f int ,  c_fn1 text ,  c__fp3p743z int ,  c_jm6e3zxuvp int ,  primary key(c__fp3p743z, c_f, c_jm6e3zxuvp),  unique(c__fp3p743z, c_f, c_jm6e3zxuvp),  index main_index (c__fp3p743z)) partition by hash(c__fp3p743z) partitions 9;

--echo insert data

--disable_query_log
--disable_result_log

