--disable_warnings
drop table if exists d1;
--enable_warnings

CREATE TABLE `d1` (
  `c1` int(11) NOT NULL,
  `c2` text DEFAULT NULL,
  `c3` int(11) NOT NULL,
  `c4` int(11) NOT NULL,
  PRIMARY KEY (`c3`, `c1`, `c4`),
  UNIQUE KEY `c3` (`c3`, `c1`, `c4`) BLOCK_SIZE 16384 LOCAL,
  KEY `main_index` (`c3`) BLOCK_SIZE 16384 LOCAL
);

insert into d1 select c_f, c_fn1, c__fp3p743z, c_jm6e3zxuvp from t_fml;

--enable_query_log
--enable_result_log

--echo
select /*+leading(ref_2 ref_1)*/  cc1 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 where cc1 in (select c2 from d1 as ref_1) order by 1;

--echo
select /*+leading(ref_2 ref_1)*/  cc1 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 where cc1 not in (select c2 from d1 as ref_1) order by 1;

--echo
select /*+leading(ref_2 ref_1)*/  cc1, ref_1.c2 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 , d1 as ref_1 where cc1 = c2 order by 1;

--echo
select /*+leading(ref_2 ref_1)*/  cc1, ref_1.c2 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 left join d1 as ref_1 on cc1 = c2 order by 1;

--echo
select /*+leading(ref_2 ref_1)*/  cc1, ref_1.c2 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 right join d1 as ref_1 on cc1 = c2 order by 1;

--echo
select /*+leading(ref_2 ref_1)*/  cc1, ref_1.c2 from (SELECT trim(c2) as cc1 FROM d1 as ref_2 where c2 > 'z2') as ref_0 full join d1 as ref_1 on cc1 = c2 order by 1;

drop table t_fml, d1;
