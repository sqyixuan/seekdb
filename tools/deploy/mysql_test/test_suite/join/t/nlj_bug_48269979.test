--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:jingfeng.jf
#owner group: sql2

--disable_warnings
drop table if EXISTS v1, d3, d4;
--enable_warnings

create table v1 (c1 decimal(64,14), pk int primary key);
insert into v1 values (1,1),(2,2);

create table d3(c2 int(127), c3 binary(93));
insert into d3 values (1, 'nYkTtavBDPyabTLmxECmMetBcknuhReAMtQwmvimTk01'),(6, 'AqvUWnxOsRssYSjQQYiKsvJLHqnjSGXRtpDGPxIqRiBOPKSLRjZ06');

create table d4(c2 int(127) not null, c3 binary(93), c5 bigint(127) NOT NULL, primary key (c2, c5)) partition by hash(c2+c5) partitions 10; 

SELECT * from(
SELECT /*+ use_nl(t14_46 t39_861_1) leading(t14_46) */
t14_46.c1 = t39_861_1.c2, c2, c3
FROM (SELECT c1
FROM v1 AS t14_46) AS t14_46,
((SELECT c2, c3
FROM d3 limit 9 )
UNION ALL
(SELECT c2, c3
FROM d4)) AS t39_861_1
WHERE t14_46.c1 = t39_861_1.c2
) where c3 LIKE '%YkTtavBDPyabTLmxECmMetBcknuhReAMtQwmvimTk%';

