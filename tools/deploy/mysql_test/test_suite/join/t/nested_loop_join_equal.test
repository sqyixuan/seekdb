select/*+use_nl(nlj_equal_2) leading(nlj_equal_1 nlj_equal_2)*/ * from nlj_equal_1, nlj_equal_2 where nlj_equal_1.c4 < 9999 and nlj_equal_1.c1 = nlj_equal_2.c1;
