--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL1
# description:
#新增case覆盖OB的内部表做join
#覆盖的bug:6405670
# Initialization

--disable_warnings
set @@recyclebin=off;
drop database if exists xy_db;
create database xy_db;
use xy_db;
set collation_connection='utf8mb4_general_ci';
drop table if exists t100_1, t200_2;
--enable_warnings
use test;
--disable_warnings
drop table if exists t100_1, t200_2;
--enable_warnings

set @@ob_read_consistency='weak';

#初始化表
use xy_db;
create table t100_1(c1 int, c2 int);
use test;
create table t200_2(c1 int, c2 int);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
#### oceanbase库内查询
use oceanbase;
# case 1-1 inner join
connection obsys;
select /*+ use_merge(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;
select /*+ use_nl(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;

select /*+ use_merge(a b)*/ a.table_name, b.ls_id from (select tenant_id, table_name, table_id from oceanbase.__all_virtual_table order by table_id) as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;
select /*+ use_nl(a b)*/ a.table_name, b.ls_id from (select tenant_id, table_name, table_id from oceanbase.__all_virtual_table order by table_id) as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;

select a.table_name, b.ls_id from (select table_id,tenant_id,table_name from oceanbase.__all_virtual_table) as a, (select tenant_id, table_id,ls_id from oceanbase.__all_virtual_tablet_to_ls) as b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;

# case 1-2 left join
select /*+ use_merge(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a left join oceanbase.__all_virtual_tablet_to_ls as b on a.tenant_id = b.tenant_id and a.table_id=b.table_id where a.table_name in ('__all_virtual_tablet_to_ls','__all_user','t100_1','t200_2') group by a.tenant_id, a.table_id order by a.table_name;
select /*+ use_nl(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a left join oceanbase.__all_virtual_tablet_to_ls as b on a.tenant_id = b.tenant_id and a.table_id=b.table_id where a.table_name in ('__all_virtual_tablet_to_ls','__all_user','t100_1','t200_2') group by a.tenant_id, a.table_id order by a.table_name;

# case 1-3 right join
select /*+ use_merge(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a right join oceanbase.__all_virtual_tablet_to_ls as b on a.tenant_id = b.tenant_id and a.table_id=b.table_id where a.table_name in ('__all_virtual_tablet_to_ls','__all_user','t100_1','t200_2') group by a.tenant_id, a.table_id order by a.table_name;
select /*+ use_nl(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a right join oceanbase.__all_virtual_tablet_to_ls as b on a.tenant_id = b.tenant_id and a.table_id=b.table_id where a.table_name in ('__all_virtual_tablet_to_ls','__all_user','t100_1','t200_2') group by a.tenant_id, a.table_id order by a.table_name;

#### test库内查询
use test;
# case 1-1 inner join
select /*+ use_merge(a b)*/ a.table_name, b.ls_id from oceanbase.__all_virtual_table as a, oceanbase.__all_virtual_tablet_to_ls b where a.tenant_id = b.tenant_id and a.table_id=b.table_id and (a.table_name='t100_1' or a.table_name='t200_2') group by a.table_id order by a.table_name;
