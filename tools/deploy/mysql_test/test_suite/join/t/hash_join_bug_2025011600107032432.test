#owner: wenkai.cwk

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_query_log
--disable_result_log
set sql_mode = '';
CREATE TABLE t1(a TIMESTAMP, b TIMESTAMP);
insert into t1(b) values('5_no'),('6_no'),('7_no'),('8_no');
INSERT INTO t1 VALUES (127, null);
ALTER TABLE t1 convert to CHARACTER SET binary;
insert into t1 values (0,'mysql');
insert into t1 values (1, 'aaaaaa'), (3, 'bbbbbb'), (5, 'cccccc');
ALTER TABLE t1 CONVERT TO CHARACTER SET 'GB18030' COLLATE 'GB18030_CHINESE_CI';
insert into t1 values(5,'五六');
INSERT INTO t1 (a, b) VALUES( 'plfcz2', 'CL');
insert into t1 values('2020-10-10 10:10:00','2020-11-11');
update t1 set b=0 where a=1;
insert into t1 values (444, 'weeknights');
INSERT INTO t1 VALUES (1,'\Z\Z\Z\Z');
insert into  t1 values(2, 'asdg');
INSERT INTO t1 VALUES (3, '2001-01-01 10:11:02.000001');
INSERT INTO t1 VALUES (1, 1), (2, 2), (2, 3);
insert into t1 values ('foo', 1);
INSERT INTO t1 VALUES('企鹅','鹅');
Insert into t1 values (300,433334);
insert into t1 values (123012345678901234567890123456789012345676767676767676767, 123012345678901234567890123456789012345676767676767676767);
insert into t1 values(1,'["\\b","\\f","\\n","\\r","\\t","\\u0032","\", "\\"",10, null, true, {"b": [1, 2]}, [3, 4]]');
INSERT INTO t1 VALUES(4,  'abc\def,klm \ \ ');
insert into t1 values(1,55);

--enable_query_log
--enable_result_log
select SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 2,1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 5,3;
select found_rows();
select /*+leading(t2 t1)*/SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 2,1;
select found_rows();
select /*+leading(t2 t1)*/SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 5,3;
select found_rows();

connection syscon;
alter system set_tp tp_no = 2202, error_code = 4019, frequency = 1;
--sleep 1
connection default;
--sleep 1

select SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 2,1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 5,3;
select found_rows();
select /*+ leading(t2 t1)*/ SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 2,1;
select found_rows();
select /*+ leading(t2 t1)*/ SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 5,3;
select found_rows();

drop table if exists t1;

connection syscon;
alter system set_tp tp_no = 2202, error_code = 4019, frequency = 0;
