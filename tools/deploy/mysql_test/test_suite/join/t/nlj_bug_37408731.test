--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:yht146439
#owner group: sql1

--disable_warnings
drop table if exists t0,t1,t2;
--enable_warnings

create table t0(a int);
create table t1(a int, b varchar(100));
create table t2(a int, b int, c varchar(100), primary key(a,b)) block_size = 2048;

--disable_query_log
--disable_result_log
--let $count = 1
while($count < 101)
{
  --let $stmt=insert into t0(a) values ($count)
  eval $stmt;
  inc $count;
}
insert into t2 select 1,a, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa' from t0 limit 10;
insert into t2 select 2,a, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa' from t0 limit 10;
insert into t2 select 3,a, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa' from t0 limit 10;
insert into t2 select 4,a, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa' from t0 limit 10;
insert into t2 select 5,a, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa' from t0 limit 10;
insert into t1 values(4,'a');
insert into t1 values(1,'a');

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select/*+ leading(t1,t2) use_nl(t1,t2) */* from t1,t2 where t1.a = t2.a;

