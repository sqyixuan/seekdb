result_format: 4
drop table if exists t_h3_01_20, t_h5_09_28;
create table t_h3_01_20(a int, b int, c datetime, primary key (a)) partition by hash(a) partitions 3;
create table t_h5_09_28(a int, b int, c datetime, primary key (a)) partition by hash(a) partitions 5;

insert into t_h3_01_20 values ( 1,  1, 20161101), ( 2,  2, 20161102), ( 3,  3, 20161103), ( 4,  4, 20161104),
                              ( 5,  5, 20161105), ( 6,  6, 20161106), ( 7,  7, 20161107), ( 8,  8, 20161108),
                              ( 9,  9, 20161109), (10, 10, 20161110), (11, 11, 20161111), (12, 12, 20161112),
                              (13, 13, 20161113), (14, 14, 20161114), (15, 15, 20161115), (16, 16, 20161116),
                              (17, 17, 20161117), (18, 18, 20161118), (19, 19, 20161119), (20, 20, 20161120);
insert into t_h5_09_28 values ( 9,  9, 20161109), (10, 10, 20161110), (11, 11, 20161111), (12, 12, 20161112),
                              (13, 13, 20161113), (14, 14, 20161114), (15, 15, 20161115), (16, 16, 20161116),
                              (17, 17, 20161117), (18, 18, 20161118), (19, 19, 20161119), (20, 20, 20161120),
                              (21, 21, 20161121), (22, 22, 20161122), (23, 23, 20161123), (24, 24, 20161124),
                              (25, 25, 20161125), (26, 26, 20161126), (27, 27, 20161127), (28, 28, 20161128);
explain select /*+no_use_px use_nl(t1 t2)*/ t1.a, t2.a from t_h3_01_20 t1 left join t_h5_09_28 t2 on t1.b = t2.a and t2.a in (1, 2, 6, 7) where t1.a = 3 order by t1.a desc, t2.a desc;
Query Plan
========================================================================
|ID|OPERATOR                         |NAME       |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------------------
|0 |PX COORDINATOR                   |           |1       |26          |
|1 |└─EXCHANGE OUT DISTR             |:EX10001   |1       |25          |
|2 |  └─NESTED-LOOP OUTER JOIN       |           |1       |25          |
|3 |    ├─EXCHANGE IN DISTR          |           |1       |6           |
|4 |    │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000   |1       |6           |
|5 |    │   └─TABLE GET              |t1         |1       |5           |
|6 |    └─PX PARTITION ITERATOR      |           |1       |36          |
|7 |      └─TABLE GET                |t2(Reverse)|1       |36          |
========================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.a, t2.a)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.a, t2.a)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.a], [t2.a]), filter(nil), rowset=16
      conds(nil), nl_params_([t1.b(:0)]), use_batch=false
  3 - output([PARTITION_ID], [t1.b], [t1.a]), filter(nil), rowset=16
  4 - output([PARTITION_ID], [t1.b], [t1.a]), filter(nil), rowset=16
      (#keys=1, [t1.b]), is_single, dop=1
  5 - output([t1.a], [t1.b]), filter(nil), rowset=16
      access([t1.a], [t1.b]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.a]), range[3 ; 3], 
      range_cond([t1.a = 3])
  6 - output([t2.a]), filter(nil), rowset=16
      affinitize, force partition granule
  7 - output([t2.a]), filter([t2.a IN (1, 2, 6, 7)]), rowset=16
      access([t2.a]), partitions(p[1-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.a]), range(MIN ; MAX), 
      range_cond([:0 = t2.a])
