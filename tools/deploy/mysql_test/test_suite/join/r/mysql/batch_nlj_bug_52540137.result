drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
create table t1(a int primary key, b int);
insert into t1 values(1, 1), (2, 2), (3, 3), (4, 4);
create table t2(a int, b int, c int) partition by hash(a) partitions 2;
create index i2 on t2(b) global;
insert into t2 values(1, 1, 1), (2, 2, 2), (2, 2, 2), (2, 2, 2), (3, 3, 3), (3, 3, 3), (3, 3, 3), (4, 4, 4);
create table t3(a int, b int, c int) partition by hash(a) partitions 2;
create index i3 on t3(b) global;
insert into t3 values(1, 1, 1), (2, 2, 2), (2, 2, 2), (2, 2, 2), (3, 3, 3), (3, 3, 3), (3, 3, 3), (4, 4, 4);
create table t4(a int, b int);
create index i4 on t4(a);
insert into t4 values(1, 1), (2, 2), (3, 3);
explain select /*+use_nl(t1 VIEW1)*/ * from t1 where exists(select /*+index(t3 i3), use_nl(t3, t2, t4), leading(t3, t2, t4)*/ t2.c from t2, t3, t4 where t3.b=t1.a and t3.c=t2.b and t2.c=t4.a and t4.b=t1.a);
