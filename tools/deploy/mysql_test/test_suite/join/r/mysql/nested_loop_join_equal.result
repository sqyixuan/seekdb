set _nlj_batching_enabled = true;
drop table if exists nlj_equal_1, nlj_equal_2, nlj_equal_3;
result_format: 4

############################################### create table for nlj equal ###############################################

create table nlj_equal_1(c1 int, c2 int, c3 int, c4 int, c5 int);
insert into nlj_equal_1 values(1001,1002,1003,1004,1005);
insert into nlj_equal_1 values(NULL,1002,1003,1004,1005);
insert into nlj_equal_1 values(1001,NULL,1003,1004,1005);
insert into nlj_equal_1 values(1001,1002,NULL,1004,1005);
insert into nlj_equal_1 values(1001,1002,1003,NULL,1005);
insert into nlj_equal_1 values(1001,1002,1003,1004,NULL);

create table nlj_equal_2(c1 int primary key, c2 int, c3 int, c4 int, c5 int, index idx1(c2,c3,c4), index idx2(c5));
insert into nlj_equal_2 values(1001,1002,1003,1004,1005);
insert into nlj_equal_2 values(2001,NULL,1003,1004,1005);
insert into nlj_equal_2 values(3001,1002,NULL,1004,1005);
insert into nlj_equal_2 values(4001,1002,1003,NULL,1005);
insert into nlj_equal_2 values(5001,1002,1003,1004,NULL);

create table nlj_equal_3(c1 int, c2 int, c3 int, c4 int, c5 int, index idx1(c1,c2), index idx2(c3,c4,c5), index idx3(c5));
insert into nlj_equal_3 values(1001,1002,1003,1004,1005);
insert into nlj_equal_3 values(NULL,1002,1003,1004,1005);
insert into nlj_equal_3 values(1001,NULL,1003,1004,1005);
insert into nlj_equal_3 values(1001,1002,NULL,1004,1005);
insert into nlj_equal_3 values(1001,1002,1003,NULL,1005);
insert into nlj_equal_3 values(1001,1002,1003,1004,NULL);


