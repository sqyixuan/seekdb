result_format: 3
DROP DATABASE IF EXISTS HJ_LEFT_EMPTY;
CREATE DATABASE HJ_LEFT_EMPTY;
USE HJ_LEFT_EMPTY;
create table T1 (c1 int, c2 int);
create table T2 (d1 int, d2 int);
explain select /*+ use_hash(T1 T2) leading(T1 T2) */ * from T1, T2 where T1.c1 = T2.d1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH JOIN        |    |2       |13441       |
|1 |├─TABLE FULL SCAN|t1  |1       |3           |
|2 |└─TABLE FULL SCAN|t2  |101300  |4959        |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.d1], [t2.d2]), filter(nil), rowset=256
      equal_conds([t1.c1 = t2.d1]), other_conds(nil)
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=256
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.d1], [t2.d2]), filter(nil), rowset=256
      access([t2.d1], [t2.d2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+ use_hash(T1 T2) leading(T1 T2) */ * from T1, T2 where T1.c1 = T2.d1;
