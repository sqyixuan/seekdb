drop table xy_c;
drop table xy_d;
create table xy_c ("PID" VARCHAR2(14) NOT NULL, "DID" VARCHAR2(12), "T01STATUS" VARCHAR2(1) NOT NULL, CONSTRAINT "PK_T01_PSN" PRIMARY KEY ("PID"));
CREATE TABLE xy_d (
  "DID" VARCHAR2(12),
  "OP_TYPE" VARCHAR2(2) NOT NULL,
  "DATA_TYPE" VARCHAR2(1) NOT NULL,
  "BRANCH_NO" VARCHAR2(6) NOT NULL,
  "FRAME_NO" VARCHAR2(5),
  "AGENT_REG_NO" VARCHAR2(8) NOT NULL,
  "CONTRACTS_NUM" NUMBER(10),
  "START_DATE" DATE NOT NULL,
  "END_DATE" DATE NOT NULL,
  "PREMIUM" NUMBER(14,2)
);

