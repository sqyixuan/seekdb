      :0 => 'YYYY-MM-DD'
      :1 => 'YYYY-MM-DD'
      :2 => 8
      :3 => '0'
  Note:
      Degree of Parallelisim is 1 because of table property
select /*+no_rewrite*/ count(*) from (SELECT/*+use_nl(a) leading(b a)*/  a.pid, b.branch_no, b.agent_reg_no,        to_char(Start_Date,'YYYY-MM-DD'),         to_char(End_Date,'YYYY-MM-DD')       FROM     xy_d b  , xy_c a    WHERE      a.pid = b.Branch_No||lpad(b.Agent_Reg_No,8,'0')) t;
+----------+
| COUNT(*) |
+----------+
|      997 |
+----------+

drop table xy_c;
drop table xy_d;
