desc oceanbase.DBA_OB_TABLE_LOCATIONS;
Field	Type	Null	Key	Default	Extra
DATABASE_NAME	varchar(128)	NO			
TABLE_NAME	varchar(256)	NO			
TABLE_ID	bigint(20)	NO			
TABLE_TYPE	varchar(21)	NO			
PARTITION_NAME	varchar(64)	NO			
SUBPARTITION_NAME	varchar(64)	NO			
INDEX_NAME	varchar(256)	NO			
DATA_TABLE_ID	bigint(20)	NO			
TABLET_ID	bigint(20)	NO			
LS_ID	bigint(20)	NO			
ZONE	varchar(128)	NO			
SVR_IP	varchar(46)	NO			
SVR_PORT	bigint(20)	NO			
ROLE	varchar(8)	NO			
REPLICA_TYPE	varchar(18)	NO			
DUPLICATE_SCOPE	varchar(7)	NO			
DUPLICATE_READ_CONSISTENCY	varchar(6)	NO			
OBJECT_ID	bigint(20)	NO			
TABLEGROUP_NAME	varchar(128)	NO		NULL	
TABLEGROUP_ID	bigint(20)	NO		NULL	
SHARDING	varchar(10)	NO			
use test;
create table tb (c1 int primary key, c2 int, c3 longtext, unique key tb_uk (c2));
create materialized view log on tb with primary key including new values;
select distinct DATABASE_NAME, TABLE_NAME, TABLE_TYPE, PARTITION_NAME, SUBPARTITION_NAME, INDEX_NAME, DATA_TABLE_ID, TABLEGROUP_NAME, SHARDING from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = "tb";
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	DATA_TABLE_ID	TABLEGROUP_NAME	SHARDING
test	tb	USER TABLE	NULL	NULL	NULL	NULL	NULL	NULL
select distinct c1.DATABASE_NAME, c1.TABLE_TYPE, c1.PARTITION_NAME, c1.SUBPARTITION_NAME, c1.INDEX_NAME, c2.table_name as data_table_name from oceanbase.DBA_OB_TABLE_LOCATIONS c1, oceanbase.DBA_OB_TABLE_LOCATIONS c2 where c1.index_name = "tb_uk" and c1.data_table_id = c2.table_id;
DATABASE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	data_table_name
test	INDEX	NULL	NULL	tb_uk	tb
call dbms_stats.delete_table_stats('oceanbase','__all_virtual_core_all_table');
select /*+use_hash() */ distinct c2.DATABASE_NAME, substr(c2.TABLE_NAME, 1, 15) TABLE_NAME, c2.TABLE_TYPE, c2.PARTITION_NAME, c2.SUBPARTITION_NAME, c2.INDEX_NAME, c1.table_name as data_table_name from oceanbase.DBA_OB_TABLE_LOCATIONS c1, oceanbase.DBA_OB_TABLE_LOCATIONS c2 where c1.table_name = 'tb' and c1.table_id = c2.data_table_id and c2.table_type = 'LOB AUX TABLE' order by 2;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	data_table_name
test	__AUX_LOB_META_	LOB AUX TABLE	NULL	NULL	NULL	tb
test	__AUX_LOB_PIECE	LOB AUX TABLE	NULL	NULL	NULL	tb
call dbms_stats.gather_table_stats('oceanbase','__all_virtual_core_all_table');
select distinct c1.DATABASE_NAME, c1.TABLE_NAME, c1.TABLE_TYPE, c1.PARTITION_NAME, c1.SUBPARTITION_NAME, c2.table_name as data_table_name from oceanbase.DBA_OB_TABLE_LOCATIONS c1, oceanbase.DBA_OB_TABLE_LOCATIONS c2 where c1.table_type = "MATERIALIZED VIEW LOG" and c1.data_table_id = c2.table_id;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	data_table_name
test	mlog$_tb	MATERIALIZED VIEW LOG	NULL	NULL	tb
create table tb_part (c1 int primary key) partition by hash(c1) partitions 2;
create materialized view log on tb_part with primary key including new values;
select distinct DATABASE_NAME, TABLE_NAME, TABLE_TYPE, PARTITION_NAME, SUBPARTITION_NAME, INDEX_NAME, DATA_TABLE_ID, TABLEGROUP_NAME, SHARDING from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = "tb_part" order by partition_name;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	DATA_TABLE_ID	TABLEGROUP_NAME	SHARDING
test	tb_part	USER TABLE	p0	NULL	NULL	NULL	NULL	NULL
test	tb_part	USER TABLE	p1	NULL	NULL	NULL	NULL	NULL
select distinct DATABASE_NAME, TABLE_NAME, TABLE_TYPE, PARTITION_NAME, SUBPARTITION_NAME, INDEX_NAME, TABLEGROUP_NAME, SHARDING from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = "mlog$_tb_part" order by partition_name;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	TABLEGROUP_NAME	SHARDING
test	mlog$_tb_part	MATERIALIZED VIEW LOG	p0	NULL	NULL	NULL	NULL
test	mlog$_tb_part	MATERIALIZED VIEW LOG	p1	NULL	NULL	NULL	NULL
create table tb_subpart (c1 int, c2 int, primary key(c1,c2)) partition by hash(c1) subpartition by hash(c2) subpartitions 1 partitions 2;
create materialized view log on tb_subpart with primary key including new values;
select distinct DATABASE_NAME, TABLE_NAME, TABLE_TYPE, PARTITION_NAME, SUBPARTITION_NAME, INDEX_NAME, DATA_TABLE_ID, TABLEGROUP_NAME, SHARDING from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = "tb_subpart" order by partition_name, subpartition_name;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	DATA_TABLE_ID	TABLEGROUP_NAME	SHARDING
test	tb_subpart	USER TABLE	p0	p0sp0	NULL	NULL	NULL	NULL
test	tb_subpart	USER TABLE	p1	p1sp0	NULL	NULL	NULL	NULL
select distinct DATABASE_NAME, TABLE_NAME, TABLE_TYPE, PARTITION_NAME, SUBPARTITION_NAME, INDEX_NAME, TABLEGROUP_NAME, SHARDING from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = "mlog$_tb_subpart" order by partition_name, subpartition_name;
DATABASE_NAME	TABLE_NAME	TABLE_TYPE	PARTITION_NAME	SUBPARTITION_NAME	INDEX_NAME	TABLEGROUP_NAME	SHARDING
test	mlog$_tb_subpart	MATERIALIZED VIEW LOG	p0	p0sp0	NULL	NULL	NULL
test	mlog$_tb_subpart	MATERIALIZED VIEW LOG	p1	p1sp0	NULL	NULL	NULL
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_partition sharding = 'PARTITION';
create tablegroup tg_adaptive sharding = 'ADAPTIVE';
alter tablegroup tg_none add tb;
ERROR 0A000: alter tablegroup of table with materialized view log is not supported
alter tablegroup tg_partition add tb_part;
ERROR 0A000: alter tablegroup of table with materialized view log is not supported
alter tablegroup tg_adaptive add tb_subpart;
ERROR 0A000: alter tablegroup of table with materialized view log is not supported
drop materialized view log on tb;
drop materialized view log on tb_part;
drop materialized view log on tb_subpart;
alter tablegroup tg_none add tb;
alter tablegroup tg_partition add tb_part;
alter tablegroup tg_adaptive add tb_subpart;
