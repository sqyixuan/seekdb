select tenant_id is null, scope from GV$OB_PARAMETERS where scope = 'CLUSTER' group by tenant_id, scope;
tenant_id is null	scope
1	CLUSTER
select count(distinct(tenant_id)) from GV$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id in (1, 1004, 1004 - 1, 1002, 1002 - 1);
count(distinct(tenant_id))
5
select count(*) from (select distinct(zone) from  GV$OB_PARAMETERS);
count(*)
2
alter system set max_stale_time_for_weak_consistency = '9s' tenant = mysql;
alter system set max_stale_time_for_weak_consistency = '8s' tenant = oracle;
alter system set max_stale_time_for_weak_consistency = '7s' tenant = sys;
select distinct(value) from GV$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;
value
7s
select distinct(value) from GV$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1004;
value
9s
select distinct(value) from GV$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1002;
value
8s
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port();
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	max_stale_time_for_weak_consistency	TIME	7s	the max data stale time that cluster weak read version behind current timestamp,no smaller than weak_read_version_refresh_interval, range: [5s, +∞)	TENANT	TENANT	DEFAULT	DYNAMIC_EFFECTIVE	5s	0
