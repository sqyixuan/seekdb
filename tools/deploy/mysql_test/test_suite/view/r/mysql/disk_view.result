drop database if exists feidu_disk_view_test_db;
create database feidu_disk_view_test_db;
use feidu_disk_view_test_db;
create sequence s1 cache 1000000 noorder;
create table feidu_t1 (a bit(20) primary key, b text,
                index l1 (a),
                index l2 (a),
                index l3 (a),
                index l4 (a),
                index l5 (a),
                index l6 (a)) PARTITION BY hash (a) partitions 10;
insert into feidu_t1 select s1.nextval, s1.nextval from table(generator(30000));
alter system major freeze;

select DATABASE_NAME, TABLE_NAME from oceanbase.DBA_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name = 'feidu_t1';
+-------------------------+------------+
| DATABASE_NAME           | TABLE_NAME |
+-------------------------+------------+
| feidu_disk_view_test_db | feidu_t1   |
+-------------------------+------------+

select DATABASE_NAME, TABLE_NAME from oceanbase.CDB_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name IN ('feidu_t1', 'feidu_disk_view_test');
+-------------------------+------------+
| DATABASE_NAME           | TABLE_NAME |
+-------------------------+------------+
| feidu_disk_view_test_db | feidu_t1   |
+-------------------------+------------+
