drop table if exists t1;
drop view if exists v1, v2;
drop database if exists MySQLTest;
create database MySQLTest;
use MySQLTest;
create table t1(c1 int);
create view v1 as select c1 from t1;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select `mysqltest`.`t1`.`c1` AS `c1` from `mysqltest`.`t1`	utf8mb4	utf8mb4_general_ci
alter view v1 as select 1 from dual;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select 1 AS `1`	utf8mb4	utf8mb4_general_ci
alter view v2 as select 1 from dual;
ERROR 42S02: Table 'mysqltest.v2' doesn't exist
drop view v1;
drop table t1;
drop database MySQLTest;
