select count(*) from GV$OB_SERVERS where (svr_ip, svr_port, zone, sql_port) not in (select svr_ip, svr_port, zone, inner_port as sql_port from __all_server);
count(*)
0
SELECT DISTINCT(CPU_CAPACITY >= CPU_ASSIGNED) FROM GV$OB_SERVERS;
(CPU_CAPACITY >= CPU_ASSIGNED)
1
SELECT DISTINCT(CPU_ASSIGNED_MAX <= CPU_CAPACITY_MAX) FROM GV$OB_SERVERS;
(CPU_ASSIGNED_MAX <= CPU_CAPACITY_MAX)
1
SELECT DISTINCT(MEM_ASSIGNED <= MEM_CAPACITY) FROM GV$OB_SERVERS;
(MEM_ASSIGNED <= MEM_CAPACITY)
1
ALTER SYSTEM SET resource_hard_limit = 99;
ERROR HY000: Invalid config
ALTER SYSTEM SET resource_hard_limit = 100;
SELECT DISTINCT(CPU_CAPACITY_MAX = CPU_CAPACITY * 100 / 100) CPU_CAPACITY_MAX_EQ FROM GV$OB_SERVERS;
CPU_CAPACITY_MAX_EQ
1
ALTER SYSTEM SET resource_hard_limit = 167;
SELECT DISTINCT(CPU_CAPACITY_MAX = CPU_CAPACITY * 167 / 100) CPU_CAPACITY_MAX_EQ FROM GV$OB_SERVERS;
CPU_CAPACITY_MAX_EQ
1
USE TEST;
select count(*) >= 1 from oceanbase.GV$OB_SERVERS;
count(*) >= 1
1
select count(*) >= 1 from oceanbase.V$OB_SERVERS;
count(*) >= 1
1
