select owner, object_name, subobject_name, (case when object_id > 0 then 1000 else object_id end) as object_id, (case when data_object_id > 0 then 1000 else data_object_id end) as data_object_id, object_type, status, temporary, "GENERATED", secondary, namespace, edition_name from SYS.ALL_OBJECTS where object_type = 'INDEX' and object_name like '%YANMU' order by owner, object_name;
OWNER	OBJECT_NAME	SUBOBJECT_NAME	OBJECT_ID	DATA_OBJECT_ID	OBJECT_TYPE	STATUS	TEMPORARY	GENERATED	SECONDARY	NAMESPACE	EDITION_NAME
select object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, "GENERATED", secondary, namespace, edition_name from SYS.USER_OBJECTS where object_type = 'INDEX' and object_id < 200000 order by object_id;
OBJECT_NAME	SUBOBJECT_NAME	OBJECT_ID	DATA_OBJECT_ID	OBJECT_TYPE	STATUS	TEMPORARY	GENERATED	SECONDARY	NAMESPACE	EDITION_NAME
select object_name, subobject_name, (case when object_id > 0 then 1000 else object_id end) as object_id, (case when data_object_id > 0 then 1000 else data_object_id end) as data_object_id, object_type, status, temporary, "GENERATED", secondary, namespace, edition_name from SYS.USER_OBJECTS where object_type = 'INDEX' and object_name like '%YANMU' order by object_name;
OBJECT_NAME	SUBOBJECT_NAME	OBJECT_ID	DATA_OBJECT_ID	OBJECT_TYPE	STATUS	TEMPORARY	GENERATED	SECONDARY	NAMESPACE	EDITION_NAME
select con_id, owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.CDB_OBJECTS where con_id in (1, 1002, 1002 - 1) and object_type = 'INDEX' and object_id < 200000 order by con_id, object_id;
