create table list_columns_tb_yanmu (c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1, c2, c3, c4, c5)) partition by list columns(c1, c2) (partition p0 values in ((100, 100)), partition p1 values in ((200, 200)));
