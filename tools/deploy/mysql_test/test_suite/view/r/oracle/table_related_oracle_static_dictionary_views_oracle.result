select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, table_type, uniqueness, compression, tablespace_name, status, degree, partitioned, funcidx_status, dropped, visibility from OCEANBASE.CDB_INDEXES where table_owner != 'oceanbase' and table_name not like '%virtual%' and table_name like '%yanmu%'  and con_id in (1, 1002, 1002 - 1) order by con_id, owner, table_name, index_name;
