select index_owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, column_name, column_position, column_length, char_length from SYS.DBA_IND_COLUMNS where table_owner != 'oceanbase' and table_name not like '%VIRTUAL%' and table_name like '%YANMU%' order by table_name, index_name, column_position;
