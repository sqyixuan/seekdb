#owner: wangzhennan.wzn 
#owner group: RS
#tags: rs
#description:
# DBA_OB_TABLET_TO_LS/CDB_OB_TABLET_TO_LS
# DBA_OB_TABLET_REPLICAS/CDB_OB_TABLET_REPLICATIONS

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection sys;
let $sys_tenant_id = 1;
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);

let $postfix = yanmu;

# cleanup
--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
connection mysql;
set @@session.recyclebin = off;
eval drop table test.t1_$postfix;

connection sys;
set @@session.recyclebin = off;
eval drop table test.t1_$postfix;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error

# case 0: sys tenant, check DBA_OB_xxx
connection sys;
eval create table test.t1_$postfix (c1 int primary key, c2 int);

select if (count(*)> 0, 'True', 'False') as core_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id < 100;
select if (count(*)> 0, 'True', 'False') as sys_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 100 and tablet_id < 10000;
select if (count(*)> 0, 'True', 'False') as sys_lob_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 50000 and tablet_id < 70000;
select if (count(*)> 0, 'True', 'False') as sys_index_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 100000 and tablet_id < 200000;
select if (count(*)> 0, 'True', 'False') as user_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 200000;

select if (count(*)> 0, 'True', 'False') as core_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id < 100;
select if (count(*)> 0, 'True', 'False') as sys_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 100 and tablet_id < 10000;
select if (count(*)> 0, 'True', 'False') as sys_lob_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 50000 and tablet_id < 70000;
select if (count(*)> 0, 'True', 'False') as sys_index_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 100000 and tablet_id < 200000;
select if (count(*)> 0, 'True', 'False') as user_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 200000;

# case 1: mysql tenant, check DBA_OB_xxx no mysql tenant 
--disable_parsing
connection mysql;
eval create table test.t1_$postfix (c1 int primary key, c2 int);

select if (count(*)> 0, 'True', 'False') as core_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id < 100;
select if (count(*)> 0, 'True', 'False') as sys_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 100 and tablet_id < 10000;
select if (count(*)> 0, 'True', 'False') as sys_lob_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 50000 and tablet_id < 70000;
select if (count(*)> 0, 'True', 'False') as sys_index_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 100000 and tablet_id < 200000;
select if (count(*)> 0, 'True', 'False') as user_tablet_exist from oceanbase.DBA_OB_TABLET_TO_LS where tablet_id > 200000;

select if (count(*)> 0, 'True', 'False') as core_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id < 100;
select if (count(*)> 0, 'True', 'False') as sys_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 100 and tablet_id < 10000;
select if (count(*)> 0, 'True', 'False') as sys_lob_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 50000 and tablet_id < 70000;
select if (count(*)> 0, 'True', 'False') as sys_index_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 100000 and tablet_id < 200000;
select if (count(*)> 0, 'True', 'False') as user_tablet_replicas_exist from oceanbase.DBA_OB_TABLET_REPLICAS where tablet_id > 200000;

--error 1146
select count(*) from oceanbase.CDB_OB_TABLET_TO_LS;
--error 1146
select count(*) from oceanbase.CDB_OB_TABLET_REPLICAS;
--enable_parsing
# case 2: sys tenant, check CDB_OB_xxx
connection sys;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as core_tablet_exist from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id < 100 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_tablet_exist from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 100 and tablet_id < 10000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_lob_tablet_exist from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 50000 and tablet_id < 70000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_index_tablet_exist from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 100000 and tablet_id < 200000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as user_tablet_exist from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 200000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as core_tablet_replicas_exist from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id < 100 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_tablet_replicas_exist from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 100 and tablet_id < 10000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_lob_tablet_replicas_exist from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 50000 and tablet_id < 70000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as sys_index_tablet_replicas_exist from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 100000 and tablet_id < 200000 group by tenant_id order by tenant_id;
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*)> 0, 'True', 'False') as user_tablet_replicas_exist from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and tablet_id > 200000 group by tenant_id order by tenant_id;

# case 3: for sys tables cnt: sys tenant > meta tenant > user tenant
connection sys;
# sys > meta tenant(mysql)
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*) > 0, 'True', 'False') as passed from (select * from oceanbase.CDB_OB_TABLET_TO_LS as a where a.tenant_id = $sys_tenant_id and tablet_id not in (select tablet_id from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id = $mysql_tenant_id - 1 and tablet_id < 10000) and tablet_id < 10000);
eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*) = 0, 'True', 'False') as passed from (select * from oceanbase.CDB_OB_TABLET_TO_LS as a where a.tenant_id = $mysql_tenant_id - 1 and tablet_id not in (select tablet_id from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id = $sys_tenant_id and tablet_id < 10000) and tablet_id < 10000);
# meta tenant(mysql) > user tenant(mysql)
#eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*) > 0, 'True', 'False') as passed from (select * from oceanbase.CDB_OB_TABLET_TO_LS as a where a.tenant_id = $mysql_tenant_id - 1 and tablet_id not in (select tablet_id from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id = $mysql_tenant_id and tablet_id < 10000) and tablet_id < 10000);
#eval select /*+QUERY_TIMEOUT(60000000)*/ if (count(*) = 0, 'True', 'False') as passed from (select * from oceanbase.CDB_OB_TABLET_TO_LS as a where a.tenant_id = $mysql_tenant_id and tablet_id not in (select tablet_id from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id = $mysql_tenant_id - 1 and tablet_id < 10000) and tablet_id < 10000);

# cleanup
--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
#connection mysql;
#set @@session.recyclebin = off;
#eval drop table test.t1_$postfix;

connection sys;
set @@session.recyclebin = off;
eval drop table test.t1_$postfix;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error
