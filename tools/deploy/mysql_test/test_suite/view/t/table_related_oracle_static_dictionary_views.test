#owner: zhaoziqian.zzq
#owner group: RS
#tags: schema
#description: Test the behaviour of static dictionary views in sys/mysql tenant.

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
let $mysql_tenant_id = `select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys'`;
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

let $postfix = yanmu;
# prepare env
--source mysql_test/include/drop_basic_table_mysql.inc
--source mysql_test/include/create_basic_table_and_index_mysql.inc
connection sys;
call dbms_stats.gather_table_stats('oceanbase', '__all_virtual_table');
call dbms_stats.gather_table_stats('oceanbase', '__all_virtual_database');
call dbms_stats.gather_table_stats('oceanbase', '__all_virtual_column');
call dbms_stats.gather_table_stats('oceanbase', '__all_virtual_constraint');

# case 1:
# sys: CDB_TABLES
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select con_id, owner, table_name, tablespace_name, pct_free, partitioned, temporary, duration, dropped from oceanbase.CDB_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_core_table' order by con_id;
--replace_column 1 con_id
eval select con_id, owner, table_name, tablespace_name, pct_free, partitioned, temporary, duration, dropped from oceanbase.CDB_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ddl_operation' order by con_id;
--replace_column 1 con_id
eval select con_id, owner, table_name, tablespace_name, pct_free, partitioned, temporary, duration, dropped from oceanbase.CDB_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_dummy' order by con_id;
--replace_column 1 con_id
eval select con_id, owner, table_name, tablespace_name, pct_free, partitioned, temporary, duration, dropped from oceanbase.CDB_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ls_meta_table' order by con_id;
--replace_column 1 con_id
eval select con_id, owner, table_name, tablespace_name, pct_free, partitioned, temporary, duration, dropped from oceanbase.CDB_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu' order by con_id, owner, table_name;

# case 2:
# sys: CDB_TAB_COLS_V$
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS_V\$ where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_core_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS_V\$ where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ddl_operation') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS_V\$ where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_dummy') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS_V\$ where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ls_meta_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, IF(position('__idx' in table_name) > 0, substr(table_name, 7 + position('_' in substr(table_name, 7))), table_name) as table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS_V\$ where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu') a where a.rank_id = 1 order by con_id, owner, table_name;

# case 3:
# sys: CDB_TAB_COLS
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_core_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ddl_operation') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_dummy') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ls_meta_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, IF(position('__idx' in table_name) > 0, substr(table_name, 7 + position('_' in substr(table_name, 7))), table_name) as table_name, column_name, data_type, data_length, data_precision, data_scale, nullable, column_id, default_length, character_set_name, char_length, char_used, hidden_column, virtual_column, qualified_col_name, rank() over (partition by con_id, owner, table_name order by column_id asc) as rank_id from OCEANBASE.CDB_TAB_COLS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu') a where a.rank_id = 1 order by con_id, owner, table_name;

# case 4:
# sys: CDB_TAB_COL_STATISTICS
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, rank() over(partition by con_id, owner, table_name order by column_name asc) as rank_id from OCEANBASE.CDB_TAB_COL_STATISTICS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_core_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, rank() over(partition by con_id, owner, table_name order by column_name asc) as rank_id from OCEANBASE.CDB_TAB_COL_STATISTICS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ddl_operation') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, rank() over(partition by con_id, owner, table_name order by column_name asc) as rank_id from OCEANBASE.CDB_TAB_COL_STATISTICS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_dummy') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, table_name, column_name, rank() over(partition by con_id, owner, table_name order by column_name asc) as rank_id from OCEANBASE.CDB_TAB_COL_STATISTICS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name = '__all_ls_meta_table') a where a.rank_id = 1 order by con_id, owner, table_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ * from (select con_id, owner, IF(position('__idx' in table_name) > 0, substr(table_name, 7 + position('_' in substr(table_name, 7))), table_name) as table_name, column_name, rank() over(partition by con_id, owner, table_name order by column_name asc) as rank_id from OCEANBASE.CDB_TAB_COL_STATISTICS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu') a where a.rank_id = 1 order by con_id, owner, table_name;

# case 5:
# sys: CDB_INDEXES
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, table_type, uniqueness, compression, tablespace_name, status, degree, partitioned, funcidx_status, dropped, visibility from OCEANBASE.CDB_INDEXES where (table_owner = 'oceanbase' or table_name like '%virtual%') and con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) order by con_id, owner, table_name, index_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, table_type, uniqueness, compression, tablespace_name, status, degree, partitioned, funcidx_status, dropped, visibility from OCEANBASE.CDB_INDEXES where table_owner != 'oceanbase' and table_name not like '%virtual%' and table_name like '%yanmu%'  and con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) order by con_id, owner, table_name, index_name;

# case 6:
# sys: CDB_IND_COLUMNS
# mysql: NONE
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, index_owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, column_name, column_position, column_length, char_length from OCEANBASE.CDB_IND_COLUMNS where (table_owner = 'oceanbase' or table_name like '%virtual%') and con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) order by con_id, table_name, index_name, column_position;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, index_owner, (case when position('OBPK' in index_name) > 0 then substr(index_name, 1, position('OBPK' in index_name) + 3) else index_name end) as index_name, table_owner, table_name, column_name, column_position, column_length, char_length from OCEANBASE.CDB_IND_COLUMNS where table_owner != 'oceanbase' and table_name not like '%virtual%' and table_name like '%yanmu%' and con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) order by con_id, table_name, index_name, column_position;

# cleanup
--source mysql_test/include/drop_basic_table_mysql.inc
