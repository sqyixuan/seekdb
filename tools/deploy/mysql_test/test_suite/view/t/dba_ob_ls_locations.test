#owner group: RS
#tags: rs
#description:
# DBA_OB_LS_LOCATIONS/CDB_OB_LS_LOCATIONS

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection sys;
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);

# case 0: sys tenant
select distinct(ls_id) from oceanbase.DBA_OB_LS_LOCATIONS;
eval select count(*) from (select /*+QUERY_TIMEOUT(60000000)*/ tenant_id, ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id in (1, $mysql_tenant_id - 1) group by tenant_id, ls_id);
eval select /*+QUERY_TIMEOUT(60000000)*/ count(distinct(tenant_id)) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id in ($mysql_tenant_id) group by tenant_id having count(*) > 1;

# case 1: mysql tenant
connection mysql;

#--error 1146
#select count(*) from oceanbase.CDB_OB_LS_LOCATIONS;

select distinct(ls_id) from oceanbase.DBA_OB_LS_LOCATIONS where ls_id = 1;
select if(count(*) > 0, 'True', 'False') as passed from oceanbase.DBA_OB_LS_LOCATIONS where ls_id != 1;
