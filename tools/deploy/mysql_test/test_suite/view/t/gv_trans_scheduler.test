#owner: wuyuefei.wyf
#owner group: transaction
#tags: views
#description:
# V$OB_TRANSACTION_SCHEDULERS / GV$OB_TRANSACTION_SCHEDULERS

--disable_abort_on_error

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys;

## case 1: under sys tenant, show all trans schedulers at all servers

DESC GV$OB_TRANSACTION_SCHEDULERS;
DESC V$OB_TRANSACTION_SCHEDULERS;

## mysql租户开启一个事务，在事务结束前进行查询
connection mysql;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table if not exists t1(col1 int primary key auto_increment, col2 varchar(1));

begin;
insert into t1 values(NULL, 'a');


connection sys;

## mysql租户上的事务状态应为EXPLICIT_ACTIVE
eval SELECT count(1) > 0 FROM GV\$OB_TRANSACTION_SCHEDULERS;

## case 2: other database can access
USE TEST;

eval SELECT count(1) > 0 FROM oceanbase.GV\$OB_TRANSACTION_SCHEDULERS;

## case 3: mysql tenant can access
connection mysql;
DESC oceanbase.GV$OB_TRANSACTION_SCHEDULERS;
DESC oceanbase.V$OB_TRANSACTION_SCHEDULERS;

eval SELECT count(1) > 0 FROM oceanbase.GV\$OB_TRANSACTION_SCHEDULERS;

commit;
drop table if exists t1;
