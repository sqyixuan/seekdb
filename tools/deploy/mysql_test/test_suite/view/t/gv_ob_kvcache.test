#owner: chaser.ch
#owner group: storage
#tags: views
#description:
# V$OB_KVCACHE / GV$OB_KVCACHE

--disable_abort_on_error

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection sys;
# case 1: under sys tenant, show all tenants at all server infos
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='sys', tenant_id, 1);

DESC GV$OB_KVCACHE;
DESC V$OB_KVCACHE;

eval SELECT tenant_id, count(*) >= 1  FROM GV\$OB_KVCACHE where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) group by tenant_id order by tenant_id;

# case 2: other database can access
USE TEST;

eval SELECT tenant_id, count(*) >= 1  FROM oceanbase.GV\$OB_KVCACHE where tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) group by tenant_id order by tenant_id;

# case 3: mysql tenant can access
connection mysql;
DESC GV$OB_KVCACHE;
DESC V$OB_KVCACHE;

eval SELECT tenant_id, count(*) >= 1  FROM oceanbase.GV\$OB_KVCACHE group by tenant_id order by tenant_id;
