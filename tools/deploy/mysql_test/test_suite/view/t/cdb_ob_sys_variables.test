#owner:  wanhong.wwh
#owner group: SQL
#tags: views
#description:
# CDB_OB_SYS_VARIABLES

--disable_abort_on_error

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

connection sys;
# case 1: 系统租户看到所有租户的系统变量
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='sys', tenant_id, 1);

DESC CDB_OB_SYS_VARIABLES;

# 验证租户级别的配置项是准确的
set global autocommit=0;
--replace_column 1 CREATE_TIME 2 MODIFY_TIME
select * from CDB_OB_SYS_VARIABLES WHERE TENANT_ID=1 and name = 'autocommit';
set global autocommit=1;
--replace_column 1 CREATE_TIME 2 MODIFY_TIME
select * from CDB_OB_SYS_VARIABLES WHERE TENANT_ID=1 and name = 'autocommit';
#     mysql下系统变量也可以看到
connection mysql;
set global autocommit=0;
connection sys;
--replace_column 1 CREATE_TIME 2 MODIFY_TIME
eval select * from CDB_OB_SYS_VARIABLES WHERE TENANT_ID=$mysql_tenant_id AND NAME = 'autocommit';
connection mysql;
set global autocommit=1;
connection sys;
--replace_column 1 CREATE_TIME 2 MODIFY_TIME
eval select * from CDB_OB_SYS_VARIABLES WHERE TENANT_ID=$mysql_tenant_id AND NAME = 'autocommit';

# case 2: 在其他database下也可以访问
connection sys;
USE TEST;
select count(*) >= 1 from oceanbase.CDB_OB_SYS_VARIABLES;

# case 3: 验证SCOPE
connection sys;
# GLOBAL_ONLY
SELECT SCOPE FROM oceanbase.CDB_OB_SYS_VARIABLES WHERE TENANT_ID=1 AND NAME = 'auto_increment_cache_size';
# SESSION_ONLY
SELECT SCOPE FROM oceanbase.CDB_OB_SYS_VARIABLES WHERE TENANT_ID=1 AND NAME = 'debug_sync';
# GLOBAL | SESSION
SELECT SCOPE FROM oceanbase.CDB_OB_SYS_VARIABLES WHERE TENANT_ID=1 AND NAME = 'autocommit';
