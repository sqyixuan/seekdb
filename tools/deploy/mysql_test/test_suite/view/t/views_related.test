#owner: zhaoziqian.zzq
#owner group: RS
#tags: schema
#description: Test the behaviour of "view" related views.
connect (sys,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

let $postfix = yanmu;

# cleanup
--disable_query_log
--disable_result_log
--disable_warnings
--disable_abort_on_error

connection sys;
set @@session.recyclebin = off;
eval drop view if exists view_$postfix;
eval drop table if exists non_partitioned_tb_$postfix;

connection mysql;
set @@session.recyclebin = off;
eval drop view if exists view_$postfix;
eval drop table if exists non_partitioned_tb_$postfix;

--enable_query_log
--enable_result_log
--enable_warnings
--enable_abort_on_error

# prepare env
connection mysql;
eval create table non_partitioned_tb_$postfix (c1 int);
eval create view view_$postfix as select * from non_partitioned_tb_$postfix;

#connection sys;
#eval create table non_partitioned_tb_$postfix (c1 int);
#eval create view view_$postfix as select * from non_partitioned_tb_$postfix;

# case 0: mysql
connection mysql;
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'SCHEMATA';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'SESSION_VARIABLES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'CDB_TABLES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'DBA_OB_DATABASES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'VIEW' and table_name like '%yanmu';

select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'SCHEMATA';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'SESSION_VARIABLES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'CDB_TABLES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'DBA_OB_DATABASES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name like '%yanmu';

# case 1: sys
connection sys;
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'SCHEMATA';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'SESSION_VARIABLES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'CDB_TABLES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM VIEW' and table_name = 'DBA_OB_DATABASES';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'VIEW' and table_name like '%yanmu';

select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'SCHEMATA';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'SESSION_VARIABLES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'CDB_TABLES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name = 'DBA_OB_DATABASES';
select table_schema, table_name, check_option, is_updatable, definer, character_set_client, collation_connection from information_schema.views where table_name like '%yanmu';

# cleanup
--disable_query_log
--disable_result_log
--disable_warnings
--disable_abort_on_error

connection sys;
set @@session.recyclebin = off;
eval drop view if exists view_$postfix;
eval drop table if exists non_partitioned_tb_$postfix;

#connection mysql;
#set @@session.recyclebin = off;
#eval drop view if exists view_$postfix;
#eval drop table if exists non_partitioned_tb_$postfix;

--enable_query_log
--enable_result_log
--enable_warnings
--disable_abort_on_error
