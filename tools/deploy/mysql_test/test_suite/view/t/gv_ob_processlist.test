#owner:  wanhong.wwh
#owner group: SQL
#tags: views
#description:
# V$OB_PROCESSLIST / GV$OB_PROCESSLIST

--disable_abort_on_error

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection sys;
# case 1: under sys tenant, show all tenants at all server infos
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);

DESC GV$OB_PROCESSLIST;
DESC V$OB_PROCESSLIST;

SELECT count(distinct(tenant)) >= 1  FROM GV$OB_PROCESSLIST;
SELECT count(distinct(tenant)) >= 1 FROM V$OB_PROCESSLIST;

# case 2: other database can access
USE TEST;

SELECT count(distinct(tenant)) >= 1  FROM oceanbase.GV$OB_PROCESSLIST;
SELECT count(distinct(tenant)) >= 1 FROM oceanbase.V$OB_PROCESSLIST;

# case 3: mysql tenant can access
connection mysql;
DESC GV$OB_PROCESSLIST;
DESC V$OB_PROCESSLIST;

SELECT tenant, count(*) >= 1  FROM GV$OB_PROCESSLIST group by tenant;
SELECT tenant, count(*) >= 1 FROM V$OB_PROCESSLIST group by tenant;

