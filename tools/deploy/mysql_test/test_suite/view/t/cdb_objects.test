#owner: zhaoziqian.zzq
#owner group: RS
#tags: rs
#description:
# CDB_OBJECTS/DBA_OBJECTS/USER_OBJECTS/DBA_OBJECTS

let $postfix = yanmu;

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
let $mysql_tenant_id = `select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys'`;
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

# cleanup
--source mysql_test/include/drop_basic_objects_mysql.inc
# prepare env
--source mysql_test/include/create_basic_objects_mysql.inc

connection mysql;
--error 1146
select * from oceanbase.CDB_OBJECTS;

# case 1: core table
connection mysql;
select owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.DBA_OBJECTS where object_type = 'TABLE' and object_name = '__all_core_table';
select owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.DBA_OBJECTS where object_type = 'TABLE' and object_name = '__all_table';

connection sys;
--replace_column 1 tenant_id
eval select con_id, owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.CDB_OBJECTS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and object_type = 'TABLE' and object_name = '__all_core_table' order by con_id, object_id;
--replace_column 1 tenant_id
eval select con_id, owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.CDB_OBJECTS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and object_type = 'TABLE' and object_name = '__all_table' order by con_id, object_id;

select owner, object_name, subobject_name, object_id, data_object_id, object_type, status, temporary, `generated`, secondary, namespace, edition_name from oceanbase.DBA_OBJECTS where object_type = 'TABLE' and object_name = '__all_core_table';
