#owner: gaishun.gs
#owner group: storage
#tags: storage
#description: ob do mysqltest --suite=view --test_set=disk_view -n disk_view
# DBA_OB_TABLE_SAPCE_USAGE



--result_format 4

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);


connection mysql;
--disable_warnings
drop database if exists feidu_disk_view_test_db;
--enable_warnings
create database feidu_disk_view_test_db;
use feidu_disk_view_test_db;
create table feidu_disk_view_test (a int);
select DATABASE_NAME, TABLE_NAME from oceanbase.DBA_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name = 'feidu_disk_view_test';

connection sys;
--disable_warnings
drop database if exists feidu_disk_view_test_db;
--enable_warnings
create database feidu_disk_view_test_db;
use feidu_disk_view_test_db;
create table feidu_disk_view_test (a int);
select DATABASE_NAME, TABLE_NAME from oceanbase.DBA_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name = 'feidu_disk_view_test';

use oceanbase;
select DATABASE_NAME, TABLE_NAME from oceanbase.CDB_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name = 'feidu_disk_view_test';
select DATABASE_NAME, TABLE_NAME from oceanbase.CDB_OB_TABLE_SPACE_USAGE where database_name = 'SYS' and table_name = 'feidu_disk_view_test';

connection mysql;
--disable_warnings
drop database if exists feidu_disk_view_test_db;
--enable_warnings
create database feidu_disk_view_test_db;
use feidu_disk_view_test_db;
create sequence s1 cache 1000000 noorder;
create table feidu_t1 (a bit(20) primary key, b text,
                index l1 (a),
                index l2 (a),
                index l3 (a),
                index l4 (a),
                index l5 (a),
                index l6 (a)) PARTITION BY hash (a) partitions 10;
insert into feidu_t1 select s1.nextval, s1.nextval from table(generator(30000));
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

select DATABASE_NAME, TABLE_NAME from oceanbase.DBA_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name = 'feidu_t1';

connection sys;
select DATABASE_NAME, TABLE_NAME from oceanbase.CDB_OB_TABLE_SPACE_USAGE where database_name = 'feidu_disk_view_test_db' and table_name IN ('feidu_t1', 'feidu_disk_view_test');
