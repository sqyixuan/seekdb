#owner: zhaoziqian.zzq
#owner group: RS
#tags: rs
#description:
# DBA_OB_TABLEGROUPS/DBA_OB_TABLEGROUP_PARTITIONS/DBA_OB_TABLEGROUP_SUBPARTITIONS/
# CDB_OB_TABLEGROUPS/CDB_OB_TABLEGROUP_PARTITIONS/DBA_OB_TABLEGROUP_SUBPARTITIONS

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

let $postfix = yanmu;

# cleanup
#connection mysql;
#set @@session.recyclebin = off;
#--disable_result_log
#--disable_abort_on_error
#eval drop table test.non_partitioned_tb_$postfix;
#--enable_result_log
#--enable_abort_on_error
#--source mysql_test/include/drop_basic_tablegroups_mysql.inc

connection sys;
set @@session.recyclebin = off;
--disable_result_log
--disable_abort_on_error
eval drop table test.non_partitioned_tb_$postfix;
--enable_result_log
--enable_abort_on_error
--source mysql_test/include/drop_basic_tablegroups_mysql.inc

let $mysql_tenant_id = `select 1 as tenant_id`;

# case 1: mysql
#connection mysql;
#--disable_warnings
#--source mysql_test/include/create_basic_tablegroups_mysql.inc
#--enable_warnings
#select * from OCEANBASE.DBA_OB_TABLEGROUPS where tablegroup_name like "%yanmu" order by tablegroup_name;
#select * from OCEANBASE.DBA_OB_TABLEGROUP_PARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position;
#select * from OCEANBASE.DBA_OB_TABLEGROUP_SUBPARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position, subpartition_position;

#--error 1146
#select * from OCEANBASE.CDB_OB_TABLEGROUPS where tablegroup_name like "%yanmu";
#--error 1146
#select * from OCEANBASE.CDB_OB_TABLEGROUP_PARTITIONS where tablegroup_name like "%yanmu";
#--error 1146
#select * from OCEANBASE.CDB_OB_TABLEGROUP_SUBPARTITIONS where tablegroup_name like "%yanmu";

#eval create table test.non_partitioned_tb_$postfix (c1 int primary key, c2 int, index i1(c2)) tablegroup 'non_partitioned_tg_$postfix';
#select * from OCEANBASE.DBA_OB_TABLEGROUP_TABLES where tablegroup_name like "%yanmu";

# case 2: sys
connection sys;
--disable_warnings
--source mysql_test/include/create_basic_tablegroups_mysql.inc
--enable_warnings
select * from OCEANBASE.DBA_OB_TABLEGROUPS where tablegroup_name like "%yanmu" order by tablegroup_name;
select * from OCEANBASE.DBA_OB_TABLEGROUP_PARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position;
select * from OCEANBASE.DBA_OB_TABLEGROUP_SUBPARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position, subpartition_position;

eval select * from OCEANBASE.CDB_OB_TABLEGROUPS where tablegroup_name like "%yanmu" order by tablegroup_name;
eval select * from OCEANBASE.CDB_OB_TABLEGROUP_PARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position;
eval select * from OCEANBASE.CDB_OB_TABLEGROUP_SUBPARTITIONS where tablegroup_name like "%yanmu" order by tablegroup_name, partition_position, subpartition_position;

eval create table test.non_partitioned_tb_$postfix (c1 int primary key, c2 int, index i1(c2)) tablegroup 'non_partitioned_tg_$postfix';
select * from OCEANBASE.DBA_OB_TABLEGROUP_TABLES where tablegroup_name like "%yanmu" order by tablegroup_name;
eval select * from OCEANBASE.CDB_OB_TABLEGROUP_TABLES where tablegroup_name like "%yanmu" order by tablegroup_name;

# cleanup
#connection mysql;
#set @@session.recyclebin = off;
#--disable_result_log
#--disable_abort_on_error
#eval drop table test.non_partitioned_tb_$postfix;
#--enable_result_log
#--enable_abort_on_error
#--source mysql_test/include/drop_basic_tablegroups_mysql.inc

connection sys;
set @@session.recyclebin = off;
--disable_result_log
--disable_abort_on_error
eval drop table test.non_partitioned_tb_$postfix;
--enable_result_log
--enable_abort_on_error
--source mysql_test/include/drop_basic_tablegroups_mysql.inc
