#owner: zhaoziqian.zzq
#owner group: RS
#tags: rs
#description:
# DBA_OB_DATABASES/CDB_OB_DATABASES

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);

connection sys;
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);

let $postfix = yanmu;

# cleanup
--disable_result_log
--disable_abort_on_error
connection mysql;
set @@session.recyclebin = off;
eval drop database db_$postfix;

connection sys;
set @@session.recyclebin = off;
eval drop database db_$postfix;
--enable_result_log
--enable_abort_on_error

# case 1: mysql tenant
connection mysql;
eval create database db_$postfix;
select * from oceanbase.DBA_OB_DATABASES where database_name like "db_yanmu";
#--error 1146
#select * from oceanbase.CDB_OB_DATABASES;

# 验证READ_ONLY
eval alter database db_$postfix READ ONLY;
select * from oceanbase.DBA_OB_DATABASES where database_name like "db_yanmu";

# case 2: sys tenant
connection sys;
eval drop database db_$postfix;
eval create database db_$postfix;
select * from oceanbase.DBA_OB_DATABASES where database_name like "db_yanmu";
--replace_column 1 tenant_id
select * from oceanbase.CDB_OB_DATABASES where database_name like "db_yanmu" order by tenant_id;

# cleanup
--disable_result_log
--disable_abort_on_error
connection mysql;
set @@session.recyclebin = off;
eval drop database db_$postfix;

connection sys;
set @@session.recyclebin = off;
eval drop database db_$postfix;
--enable_result_log
--enable_abort_on_error
