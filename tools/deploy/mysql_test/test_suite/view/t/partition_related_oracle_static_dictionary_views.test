# case 11:
# sys: information_schema.partitions
# mysql: information_schema.partitions
connection sys;
--replace_column 20 CREATE_TIME
select * from information_schema.partitions where table_name like '%yanmu' order by table_schema, table_name, partition_ordinal_position, subpartition_ordinal_position, data_length, index_length;
connection mysql;
--replace_column 20 CREATE_TIME
select * from information_schema.partitions where table_name like '%yanmu' order by table_schema, table_name, partition_ordinal_position, subpartition_ordinal_position, data_length, index_length;

