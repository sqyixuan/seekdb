#select * from oceanbase.CDB_TAB_SUBPARTITIONS;
select table_owner, table_name, partition_name, subpartition_name, high_value, high_value_length, partition_position, subpartition_position, tablespace_name, compression, compress_for from oceanbase.DBA_TAB_SUBPARTITIONS where table_name like '%yanmu' order by table_owner, table_name, partition_position, subpartition_position;

# case 4:
# sys: CDB_SUBPARTITION_TEMPLATES/DBA_SUBPARTITION_TEMPLATES
# mysql: DBA_SUBPARTITION_TEMPLATES
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, user_name, table_name, subpartition_name, subpartition_position, tablespace_name, high_bound from oceanbase.CDB_SUBPARTITION_TEMPLATES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu' order by con_id, user_name, table_name, subpartition_position;
select user_name, table_name, subpartition_name, subpartition_position, tablespace_name, high_bound from oceanbase.DBA_SUBPARTITION_TEMPLATES where table_name like '%yanmu' order by user_name, table_name, subpartition_position;

connection mysql;
#--error 1146
select * from oceanbase.CDB_SUBPARTITION_TEMPLATES;
#select * from oceanbase.CDB_SUBPARTITION_TEMPLATES;
select user_name, table_name, subpartition_name, subpartition_position, tablespace_name, high_bound from oceanbase.DBA_SUBPARTITION_TEMPLATES where table_name like '%yanmu' order by user_name, table_name, subpartition_position;

# case 5:
# sys: CDB_PART_INDEXES/DBA_PART_INDEXES
# mysql: DBA_PART_INDEXES
connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner, index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.CDB_PART_INDEXES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%virtual%' order by con_id, owner, table_name, index_name;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner,  index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.CDB_PART_INDEXES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu' order by con_id, owner, table_name, index_name;

select owner, index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.DBA_PART_INDEXES where table_name like '%virtual%' order by owner, table_name, index_name;
select owner, index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.DBA_PART_INDEXES where table_name like '%yanmu' order by owner, table_name, index_name;

connection mysql;
#--error 1146
select * from oceanbase.CDB_PART_INDEXES;
#select * from oceanbase.CDB_PART_INDEXES;
select owner, index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.DBA_PART_INDEXES where table_name like '%virtual%'  order by owner, table_name, index_name;
select owner, index_name, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, locality, alignment, def_tablespace_name from oceanbase.DBA_PART_INDEXES where table_name like '%yanmu' order by owner, table_name, index_name;

