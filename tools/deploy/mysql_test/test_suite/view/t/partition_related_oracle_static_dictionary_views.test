#owner: zhaoziqian.zzq
#owner group: RS
#tags: schema
#description: Test the behaviour of static dictionary views in sys/mysql tenant.
connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
let $mysql_tenant_id = `select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys'`;
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);

let $postfix = yanmu;

# prepare env
--source mysql_test/include/drop_basic_table_mysql.inc
--source mysql_test/include/create_basic_table_and_index_mysql.inc

# case 0:
# sys: information_schema.tables
# mysql: information_schema.tables
connection mysql;

select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_core_table';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_ddl_operation';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_dummy';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_ls_meta_table';

select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_virtual_upgrade_inspection';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_virtual_unit';

select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'BASE TABLE' and table_name like '%yanmu' order by table_schema, table_name;

connection sys;
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_core_table';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_ddl_operation';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_dummy';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_ls_meta_table';

select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_virtual_upgrade_inspection';
select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'SYSTEM TABLE' and table_name = '__all_virtual_unit';

select table_schema, table_name, table_type, table_collation, table_comment from information_schema.tables where table_type = 'BASE TABLE' and table_name like '%yanmu' order by table_schema, table_name;

# case 1:
# sys: CDB_PART_TABLES/DBA_PART_TABLES
# mysql: DBA_PART_TABLES

connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, owner, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, def_tablespace_name, def_compression, def_compress_for, `interval` from oceanbase.CDB_PART_TABLES where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu' order by con_id, owner, table_name;
select owner, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, def_tablespace_name, def_compression, def_compress_for, `interval` from oceanbase.DBA_PART_TABLES where table_name like '%yanmu' order by owner, table_name;

connection mysql;
#--error 1146
#select * from oceanbase.CDB_PART_TABLES;
select owner, table_name, partitioning_type, subpartitioning_type, partition_count, def_subpartition_count, partitioning_key_count, subpartitioning_key_count, def_tablespace_name, def_compression, def_compress_for, `interval` from oceanbase.DBA_PART_TABLES where table_name like '%yanmu' order by owner, table_name;

# case 2:
# sys: CDB_TAB_PARTITIONS/DBA_TAB_PARTITIONS
# mysql: DBA_TAB_PARTITIONS

connection sys;
--replace_column 1 con_id
eval select /*+QUERY_TIMEOUT(60000000)*/ con_id, table_owner, table_name, composite, partition_name, subpartition_count, high_value, high_value_length, partition_position, tablespace_name, compression, compress_for, `interval` from oceanbase.CDB_TAB_PARTITIONS where con_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1) and table_name like '%yanmu' order by con_id, table_owner, table_name, partition_position;
select table_owner, table_name, composite, partition_name, subpartition_count, high_value, high_value_length, partition_position, tablespace_name, compression, compress_for, `interval` from oceanbase.DBA_TAB_PARTITIONS where table_name like '%yanmu' order by table_owner, table_name, partition_position;

connection mysql;
#--error 1146
select * from oceanbase.CDB_TAB_PARTITIONS;
#select * from oceanbase.CDB_TAB_PARTITIONS;
select table_owner, table_name, composite, partition_name, subpartition_count, high_value, high_value_length, partition_position, tablespace_name, compression, compress_for, `interval` from oceanbase.DBA_TAB_PARTITIONS where table_name like '%yanmu' order by table_owner, table_name, partition_position;

