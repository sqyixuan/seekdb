#owner: msy164651 
#owner group: RS
#tags: views
#description:
# V$OB_PARAMETERS / GV$OB_PARAMETERS

--disable_abort_on_error

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (mysql,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connect (oracle,$OBMYSQL_MS0,SYS@oracle,,SYS,$OBMYSQL_PORT);

connection sys;
# case 1: under sys tenant, show all tenants at all servers parameters
let $mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='oracle', tenant_id, 1);

DESC GV$OB_PARAMETERS;
DESC V$OB_PARAMETERS;

# 验证集群级别配置项的租户ID为NULL
select tenant_id is null, scope from GV$OB_PARAMETERS where scope = 'CLUSTER' group by tenant_id, scope;

# 验证可以看到所有租户级配置项
# 包括用户租户和对应的Meta租户
eval select count(distinct(tenant_id)) from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id in (1, $mysql_tenant_id, $mysql_tenant_id - 1, $oracle_tenant_id, $oracle_tenant_id - 1);

# 验证可以看到zone
select count(*) from (select distinct(zone) from  GV$OB_PARAMETERS);


# 验证租户级别的配置项是准确的
let $mysql_pm = '9s';
eval alter system set max_stale_time_for_weak_consistency = $mysql_pm tenant = mysql;
let $oracle_pm = '8s';
eval alter system set max_stale_time_for_weak_consistency = $oracle_pm tenant = oracle;
let $sys_pm = '7s';
eval alter system set max_stale_time_for_weak_consistency = $sys_pm tenant = sys;
# 保证max_stale_time_for_weak_consistency在所有server上都刷到最新
let $v1_mysql=0;
let $v1_oracle=0;
let $v1_sys=0;
while($v1_mysql != 1)
{
  sleep 1;

  let $v1_mysql = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = $mysql_tenant_id and VALUE= $mysql_pm) T2", v, 1);
}


while($v1_oracle != 1)
{
  sleep 1;

  let $v1_oracle = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = $oracle_tenant_id and VALUE= $oracle_pm) T2", v, 1);

}


while($v1_sys != 1)
{
  sleep 1;

  let $v1_sys = query_get_value("SELECT (T1.svr_cnt = T2.p_cnt) v from (SELECT count(*) svr_cnt from DBA_OB_SERVERS) T1, (select count(*) p_cnt from __all_virtual_tenant_parameter_stat WHERE NAME LIKE 'max_stale_time_for_weak_consistency' and tenant_id = 1 and VALUE= $sys_pm) T2", v, 1);
}

#  echo "begin mysql";
#  echo $v1_mysql;
#  echo $v2_mysql;
#  echo $v3_mysql;
#  echo "end mysql";
#
#  echo "begin oracle";
#  echo $v1_oracle;
#  echo $v2_oracle;
#  echo $v3_oracle;
#  echo "end oracle";
#
#  echo "begin sys";
#  echo $v1_sys;
#  echo $v2_sys;
#  echo $v3_sys;
#  echo "end sys";

eval select distinct(value) from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = 1;
eval select distinct(value) from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = $mysql_tenant_id;
eval select distinct(value) from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency' and tenant_id  = $oracle_tenant_id;

# 验证show parameters命令可以正常工作
# show parameters 与 GV$OB_PARAMETERS 共用一套底层虚拟表实现
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port();

# 验证系统租户看用户租户的配置项信息
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port() tenant = mysql;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port() tenant = oracle;

# 验证系统租户看SEED配置项信息
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port() tenant = seed;

# case 2: other database can access
USE TEST;
select count(*) >= 1 from oceanbase.GV$OB_PARAMETERS;
select count(*) >= 1 from oceanbase.V$OB_PARAMETERS;

# case 3: mysql tenant can access
connection mysql;
DESC GV$OB_PARAMETERS;
DESC V$OB_PARAMETERS;

# 验证集群级别配置项的租户ID为NULL
select tenant_id is null, scope from GV$OB_PARAMETERS where scope = 'CLUSTER' group by tenant_id, scope;

# 验证可以看到zone
select count(*) from (select distinct(zone) from GV$OB_PARAMETERS);

# 验证可以看到本租户的配置项
eval select distinct(tenant_id) = $mysql_tenant_id from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency';
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port();

# case 4: oracle tenant can access
connection oracle;
DESC GV$OB_PARAMETERS;
DESC V$OB_PARAMETERS;

# 验证集群级别配置项的租户ID为NULL
select tenant_id, scope from GV$OB_PARAMETERS where scope = 'CLUSTER' group by tenant_id, scope;

# 验证可以看到zone
select count(*) from (select distinct(zone) from  GV$OB_PARAMETERS);

# 验证可以看到本租户的配置项
eval select distinct(tenant_id) from GV\$OB_PARAMETERS WHERE NAME = 'max_stale_time_for_weak_consistency';
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'max_stale_time_for_weak_consistency' and svr_port = rpc_port();

connection sys;
#  还原配置项
alter system set max_stale_time_for_weak_consistency = '5s' tenant = sys;
alter system set max_stale_time_for_weak_consistency = '5s' tenant = all_user;
alter system set max_stale_time_for_weak_consistency = '5s' tenant = all_meta;
