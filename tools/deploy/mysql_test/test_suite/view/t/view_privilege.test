--disable_warnings
--error 0,1396
drop user user1;
--error 0,1396
drop user user2;

create user user1 identified by '123';
create user user2 identified by '123';
grant all on *.* to user1 with grant option;
grant create on *.* to user2;
drop database if exists db;

connect(conn1,$OBMYSQL_MS0,user1,123,test,$OBMYSQL_PORT);
connect(conn2,$OBMYSQL_MS0,user2,123,test,$OBMYSQL_PORT);

connection conn1;
drop database if exists db;
create database db;
use db;
drop table if exists t;
drop view if exists v;
create table t(c1 int);
create view v as select c1 from t;

create view v1 as select * from oceanbase.__all_user;
