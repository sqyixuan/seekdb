--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#tags: view
## 测试 mysql 模式下的 alter view 功能

--disable_warnings
drop table if exists t1;
drop view if exists v1, v2;
drop database if exists MySQLTest;
--enable_warnings

create database MySQLTest;
use MySQLTest;
create table t1(c1 int);
create view v1 as select c1 from t1;
show create view v1;
alter view v1 as select 1 from dual;
show create view v1;
--error 1146
alter view v2 as select 1 from dual;

drop view v1;
drop table t1;
drop database MySQLTest;