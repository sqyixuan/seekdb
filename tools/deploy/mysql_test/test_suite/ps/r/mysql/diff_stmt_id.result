alter system set _ob_enable_prepared_statement = true;
alter system flush plan cache global;
drop table if exists t1;
create table t1(c1 int);
insert into t1 values(1);

// for now, cannot check diff client stmt id, need add view.
prepare stmt1 from select c1 from t1;
select ps_sql, stmt_id from oceanbase.GV$OB_PS_ITEM_INFO where ps_sql = 'select c1 from t1';
ps_sql	stmt_id
select c1 from t1	3463
prepare stmt1 from select c1 from t1;
select ps_sql, stmt_id from oceanbase.GV$OB_PS_ITEM_INFO where ps_sql = 'select c1 from t1';
ps_sql	stmt_id
select c1 from t1	3463
alter system set _ob_enable_prepared_statement = false;
