alter system set _ob_enable_prepared_statement = true;
alter system flush plan cache global;
drop table if exists t1;
create table t1(c1 varchar(100));
insert into t1 values('abc');

// Case1: test first param of like expr should param
prepare stmt1 from select * from t1 where ? like 't%';
set @val1 = 'test1';
execute stmt1 using @val1;
c1
abc
// expect hit_count is 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like \'t%\'';
query_sql	statement	hit_count
select * from t1 where ? like 't%'	select * from t1 where ? like 't%'	0
set @val2 = 'test2';
execute stmt1 using @val2;
c1
abc
// expect hit_count is 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like \'t%\'';
query_sql	statement	hit_count
select * from t1 where ? like 't%'	select * from t1 where ? like 't%'	1

// Case2: test second param of like expr should not param
set @pat1 = '%a%';
prepare stmt1 from select * from t1 where c1 like ?;
execute stmt1 using @pat1;
c1
abc
// expect hit_count 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where c1 like ?';
query_sql	statement	hit_count
select * from t1 where c1 like ?	select * from t1 where c1 like ?	0
set @pat2 = '%b%';
execute stmt1 using @pat2;
c1
abc
// expect hit_count 0 0. should not paramterize like parttern
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where c1 like ?';
query_sql	statement	hit_count
select * from t1 where c1 like ?	select * from t1 where c1 like ?	0
select * from t1 where c1 like ?	select * from t1 where c1 like ?	0

// Case3: test third param of like expr should not param
prepare stmt1 from select * from t1 where ? like ? escape ?;
set @val1 = 'test1';
set @pat1 = 't%';
set @esc1 = '|';
execute stmt1 using @val1, @pat1, @esc1;
c1
abc
// expect hit count is 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
query_sql	statement	hit_count
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	0
set @val2 = 'test2';
execute stmt1 using @val2, @pat1, @esc1;
c1
abc
// hit count is 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
query_sql	statement	hit_count
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
set @pat2 = 'b%';
execute stmt1 using @val2, @pat2, @esc1;
c1
// should not paramterize pattern. hit_counot is 0 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
query_sql	statement	hit_count
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	0
// should not paramterize pattern. hit_counot is 1 1
execute stmt1 using @val1, @pat2, @esc1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
c1
set @esc2 = '_';
execute stmt1 using @val2, @pat2, @esc2;
c1
// should not paramterize escape. hit_counot is 0 1 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
query_sql	statement	hit_count
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	0
execute stmt1 using @val1, @pat2, @esc2;
c1
// should not paramterize escape. hit_counot is 1 1 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
query_sql	statement	hit_count
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
select * from t1 where ? like ? escape ?	select * from t1 where ? like ? escape ?	1
alter system set _ob_enable_prepared_statement = false;
