alter system set _ob_enable_prepared_statement = true;
drop table if exists t1;
drop outline ol1;
drop outline ol2;
drop outline ol3;
create table t1(c1 int primary key, c2 int unique key, c3 int  unique key);
insert into t1 values(1 , 2, 3),(2, 3, 1),(3, 1,2);
prepare stmt1 from select c1, c2, c3 from t1 order by c1;
execute stmt1;
c1	c2	c3
1	2	3
2	3	1
3	1	2
create outline ol1 on '858B1DA4A95601D1E9B5A985FD966B35' using hint /*+index(t1 c2)*/;
execute stmt1;
c1	c2	c3
1	2	3
2	3	1
3	1	2
deallocate prepare stmt1;
prepare stmt1 from select c1, c2, c3 from t1 where c1 > ? order by c1;
set @a=0;
execute stmt1 using @a;
c1	c2	c3
1	2	3
2	3	1
3	1	2
create outline ol2 on '477F8A7070C945429144AB5CB510E879' using hint /*+index(t1 c2)*/;
set @a=-10;
execute stmt1 using @a;
c1	c2	c3
1	2	3
2	3	1
3	1	2
deallocate prepare stmt1;
prepare stmt1 from select c1, c2, c3 from t1 where c1 > ? order by c1;
set @a=0;
execute stmt1 using @a;
c1	c2	c3
1	2	3
2	3	1
3	1	2
drop outline ol2;
prepare stmt1 from select ?, c1, c2, c3 from t1 order by c1;
set @a=11111;
execute stmt1 using @a;
?	c1	c2	c3
11111	1	2	3
11111	2	3	1
11111	3	1	2
create outline ol3 on 'BD4F1833F564C206655AB4EF7F85FE98' using hint /*+index(t1 c3)*/;
set @a=22222;
execute stmt1 using @a;
?	c1	c2	c3
22222	1	2	3
22222	2	3	1
22222	3	1	2
drop outline ol3;
set @a=33333;
execute stmt1 using @a;
?	c1	c2	c3
33333	1	2	3
33333	2	3	1
33333	3	1	2
deallocate prepare stmt1;
alter system set _ob_enable_prepared_statement = false;
