alter system set _ob_enable_prepared_statement = true;
create table t1(pk int primary key, a int, b int, c int, d int);
create index i1 on t1(b, c) storing(d);
prepare trx1stmt1 from select pk, b, c, d from t1 where b between ? and ?;
prepare trx1stmt2 from select pk, a, b from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
prepare trx1itmt1 from insert into t1(pk, a, b, c, d) values(?,1,1,1,1);
prepare trx1rtmt1 from replace into t1(pk, a, b, c, d) values(?,?,?,?,?);
prepare trx1utmt1 from update t1 set a=a+?, b=b+?, c=c+?, d=d+? where pk=?;
prepare trx1dtmt1 from delete from t1 where pk=?;
prepare trx2stmt1 from select pk, b, c, d from t1 where b between ? and ?;
prepare trx2stmt2 from select * from t1 where pk>? and pk<?;
prepare trx2stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
set autocommit=0;
set @i1=1;
set @i2=2;
set @i3=3;
execute trx1itmt1 using @i1;
execute trx1itmt1 using @i2;
execute trx1itmt1 using @i3;
commit;
set autocommit=0;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	1	1	1
2	1	1	1
3	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
3	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
3	1	1	1	1
set @i4=4;
execute trx1itmt1 using @i4;
commit;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	1	1	1
2	1	1	1
3	1	1	1
4	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
3	1	1	1	1
4	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
3	1	1	1	1
4	1	1	1	1
set @r1=1;
set @r2=2;
execute trx1rtmt1 using @r1, @r2, @r2, @r2, @r2;
commit;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	2	2	2
2	1	1	1
3	1	1	1
4	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	1	1	1	1
3	1	1	1	1
4	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	1	1	1	1
3	1	1	1	1
4	1	1	1	1
set @u1=1;
set @u2=2;
execute trx1utmt1 using @u1, @u1, @u1, @u1 ,@u2;
commit;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	2	2	2
2	2	2	2
3	1	1	1
4	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
3	1	1	1	1
4	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
3	1	1	1	1
4	1	1	1	1
set @d1=3;
execute trx1dtmt1 using @d1;
commit;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	2	2	2
2	2	2	2
4	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
4	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
4	1	1	1	1
commit;
execute trx2stmt1 using @a1, @a2;
pk	b	c	d
1	2	2	2
2	2	2	2
4	1	1	1
execute trx2stmt2 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
4	1	1	1	1
execute trx2stmt3 using @a1, @a2;
pk	a	b	c	d
1	2	2	2	2
2	2	2	2	2
4	1	1	1	1
drop table t1;
alter system set _ob_enable_prepared_statement = false;
