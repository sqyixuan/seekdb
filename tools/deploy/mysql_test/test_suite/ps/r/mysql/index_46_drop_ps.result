alter system set _ob_enable_prepared_statement = true;
// here
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop database if exists ps_test;
create database ps_test;
use ps_test;
drop table if exists t1,t2,t3,t4,t5;
create table t1(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t1(key1);
insert into t1 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');
prepare stmt11 from select * from t1 where key1>=? and key1<?;
prepare stmt12 from select /*+ index(t1 i1)*/ * from t1 where key1>=? and key1<?;
set @a1=1;
set @a2=6;
execute stmt11 using @a1, @a2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
execute stmt12 using @a1, @a2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
drop index i1 on t1;
execute stmt11 using @a1, @a2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
execute stmt12 using @a1, @a2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
replace into t1 values(1,5,2,'aa');
execute stmt11 using @a1, @a2;
pk	key1	key2	v3
1	5	2	aa
2	5	2	b
4	5	2	c
execute stmt12 using @a1, @a2;
pk	key1	key2	v3
1	5	2	aa
2	5	2	b
4	5	2	c
drop table t1;
create table t2(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t2(key1);
prepare stmt21 from select * from t2 where key1>=? and key1<?;
prepare stmt22 from select /*+ index(t2 i1)*/ * from t2 where key1>=? and key1<?;
set @b1=1;
set @b2=6;
insert into t2 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');
drop index i1 on t2;
execute stmt21 using @b1, @b2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
execute stmt22 using @b1, @b2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
create index i2 on t2(key1);
drop index i2 on t2;
execute stmt21 using @b1, @b2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
execute stmt22 using @b1, @b2;
pk	key1	key2	v3
1	5	2	a
2	5	2	b
4	5	2	c
create index i1 on t2(key1);
replace into t2 values(1,5,2,'aaa');
execute stmt21 using @b1, @b2;
pk	key1	key2	v3
1	5	2	aaa
2	5	2	b
4	5	2	c
execute stmt22 using @b1, @b2;
pk	key1	key2	v3
1	5	2	aaa
