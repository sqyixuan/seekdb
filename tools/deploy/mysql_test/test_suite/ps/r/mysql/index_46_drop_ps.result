drop table t2;
drop table if exists t3;
create table t3(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t3(key1);
create index i2 on t3(key1,key2);
prepare stmt31 from select * from t3 where key1>=? and key1<?;
prepare stmt32 from select /*+ index(t3 i1)*/ * from t3 where key1>=? and key1<?;
prepare stmt33 from select /*+ index(t3 i2)*/ * from t3 where key1>=? and key1<?;
set @c1=1;
set @c2=6;
insert into t3 values(1,5,2,'a'),(2,3,2,'b'),(4,1,2,'c');
execute stmt31 using @c1, @c2;
pk	key1	key2	v3
1	5	2	a
2	3	2	b
4	1	2	c
execute stmt32 using @c1, @c2;
pk	key1	key2	v3
4	1	2	c
2	3	2	b
1	5	2	a
