alter system set _ob_enable_prepared_statement = true;
drop table if exists t1;
create table t1(pk1 int, pk2 varchar(10), c1 int, c2 int, c3 varchar(20), c4  timestamp(6) default "2012-01-01 12:00:00", c5 int, primary key(pk1, pk2,c1));
insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(0,'0',0,0,'0','2014-11-03 08:00:00',0),
(0,'0',10,1,'-10','2014-11-03 08:00:01',0),
(0,'0',1,2,'1','2014-11-03 08:00:03',1),
(0,'0',-1,3,'-1','2014-11-03 08:00:04',1);
insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(1,'1',2,10,'2','2014-11-03 08:00:05',2),
(1,'1',-2,-1,'-2','2014-11-03 08:00:05',2),
(1,'1',3,-2,'3','2014-11-03 08:00:05',3),
(1,'1',-3,-3,'-3','2014-11-03 08:00:05',3);

prepare stmt1 from  select * from t1 where pk1 = ? order by pk2,c1;
set @a=1;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
1	1	-3	-3	-3	2014-11-03 08:00:05.0	3
1	1	-2	-1	-2	2014-11-03 08:00:05.0	2
1	1	2	10	2	2014-11-03 08:00:05.0	2
1	1	3	-2	3	2014-11-03 08:00:05.0	3
set @a=0;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
0	0	-1	3	-1	2014-11-03 08:00:04.0	1
0	0	0	0	0	2014-11-03 08:00:00.0	0
0	0	1	2	1	2014-11-03 08:00:03.0	1
0	0	10	1	-10	2014-11-03 08:00:01.0	0

prepare stmt1 from  select * from t1 where pk1 = ? order by pk2,c1 limit 1;
set @a=1;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
1	1	-3	-3	-3	2014-11-03 08:00:05.0	3
set @a=0;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
0	0	-1	3	-1	2014-11-03 08:00:04.0	1

prepare stmt1 from  select * from t1 where pk1 = ? and pk2 in ('0') order by c1;
set @a=1;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
set @a=0;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
0	0	-1	3	-1	2014-11-03 08:00:04.0	1
0	0	0	0	0	2014-11-03 08:00:00.0	0
0	0	1	2	1	2014-11-03 08:00:03.0	1
0	0	10	1	-10	2014-11-03 08:00:01.0	0

prepare stmt1 from  select * from t1 where pk1 = ? and pk2 in ('1') order by c1 limit 1;
set @a=1;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
1	1	-3	-3	-3	2014-11-03 08:00:05.0	3
set @a=0;
execute stmt1 using @a;
pk1	pk2	c1	c2	c3	c4	c5
alter system set _ob_enable_prepared_statement = false;
