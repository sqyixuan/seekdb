alter system set _ob_enable_prepared_statement = true;
create table t1 (pk int primary key, key1 int, v1 varchar(50), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(key1) storing(v1);
insert into t1 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13');
prepare trx1stmt1 from select key1, v1 from t1 where key1>? and key1<?;
prepare trx1stmt2 from select * from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where key1>? and key1<?;
set @s11=0;
set @s12=100;
prepare trx2stmt1 from select * from t1 where pk=? for update;
set @s1=1;
set @s2='when-select-update-insert1';
set @s3=5;
set @s4='when-select-update-insert2';
set @s5='2013-12-16';
prepare trx2utmt1 from update t1 set v1=? where pk=?;
set @u1='when-update-insert1';
set @u2=2;
set @u3='when-update-insert2';
set @u4='2013-12-16';
set autocommit=0;
execute trx1stmt1 using @s11, @s12;
key1	v1
1	a
2	b
3	c
4	d
execute trx1stmt2 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	b	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
execute trx1stmt3 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	b	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
set autocommit=0;
execute trx2stmt1 using @s1;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
execute trx2utmt1 using @u1,@u2;
execute trx1stmt1 using @s11, @s12;
key1	v1
1	a
2	b
3	c
4	d
execute trx1stmt2 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	b	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
execute trx1stmt3 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	b	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
commit;
execute trx1stmt1 using @s11, @s12;
key1	v1
1	a
2	when-update-insert1
3	c
4	d
execute trx1stmt2 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	when-update-insert1	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
execute trx1stmt3 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	when-update-insert1	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
commit;
execute trx1stmt1 using @s11, @s12;
key1	v1
1	a
2	when-update-insert1
3	c
4	d
execute trx1stmt2 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	when-update-insert1	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
execute trx1stmt3 using @s11, @s12;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
2	2	when-update-insert1	2013-12-11 00:00:00.0
3	3	c	2013-12-12 00:00:00.0
4	4	d	2013-12-13 00:00:00.0
commit;
alter system set _ob_enable_prepared_statement = false;
