alter system set _ob_enable_prepared_statement = true;
drop table if exists t1;
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
create table t1 (pk int primary key, key1 int, v1 varchar(20), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(key1) storing(v1,t1);
insert into t1 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13'),(5,5,'e','2013-12-14');
prepare stmt1 from select v1,t1 from t1 where key1=?;
set @a=1;
execute stmt1 using @a;
v1	t1
a	2013-12-10 00:00:00.0
prepare stmt2 from select * from t1 where key1=?;
set @b=1;
execute stmt2 using @b;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
prepare stmt3 from update t1 set v1=? where pk=?;
set @c1='update';
set @c2=1;
execute stmt3 using @c1,@c2;
drop table if exists t2;
create table t2 (pk int primary key, key1 int, v1 varchar(20), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t2(key1) storing(v1);
insert into t2 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13'),(5,5,'e','2013-12-14');
prepare stmt4 from select v1 from t2 where key1=?;
set @aa=1;
execute stmt4 using @aa;
v1
a
prepare stmt5 from select * from t2 where key1=?;
set @bb=1;
execute stmt5 using @bb;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
prepare stmt6 from update t2 set v1=? where pk=?;
set @cc1='update';
set @cc2=1;
execute stmt6 using @cc1,@cc2;
drop table if exists t3;
create table t3 (pk int primary key, key1 int, v1 varchar(20), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t3(key1) storing(v1);
insert into t3 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13'),(5,5,'e','2013-12-14');
prepare stmt7 from select v1 from t3 where key1=?;
set @aaa=1;
execute stmt7 using @aaa;
v1
a
prepare stmt8 from select * from t3 where key1=?;
set @bbb=1;
execute stmt8 using @bbb;
pk	key1	v1	t1
1	1	a	2013-12-10 00:00:00.0
prepare stmt9 from update t3 set v1=? where pk=?;
set @ccc1='update';
set @ccc2=1;
execute stmt9 using @ccc1,@ccc2;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter table t1 drop t1;
alter system set _ob_enable_prepared_statement = false;
