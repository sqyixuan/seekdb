alter system set _ob_enable_prepared_statement = true;
alter system flush plan cache global;
alter system flush ps cache global;
alter system flush pl cache global;
alter system set plan_cache_evict_interval = '60s';
drop table if exists t1,t2;
create table t1(c1 int, c2 int);
create table t2(c1 int);
set autocommit  = 0;
insert into t1 values(1,1);
select * from t1 where c1 = 1;
c1	c2
1	1
select * from t2;
c1
select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id;
expired	ps_sql	stmt_info_ref_count
0	create table t1(c1 int, c2 int)	2
0	create table t2(c1 int)	2
0	insert into t1 values(1,1)	2
0	select * from t1 where c1 = 1	2
0	select * from t2	2
0	select expired, ps_sql, stmt_info_ref_count from oceanbase.V$OB_PS_ITEM_INFO order by stmt_id	3

*** test drop table ***
