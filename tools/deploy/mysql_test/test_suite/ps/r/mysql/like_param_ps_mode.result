alter system set _ob_enable_prepared_statement = true;
*************** create table t(c1 varchar(20) primary key, c2 varchar(20), c3 varchar(20), c4 varchar(20)) ***********
*************** create index idx_c2 on t(c2) *************************************************************************
*************** create index idx_c2_c3 on t(c2, c3) ******************************************************************
********************* general const value ******************************
pk
precise(non filter)
******************* select * from t where c1 like '1%' *****************
imprecise(has filter)
******************* select * from t where c1 like '%3' *****************
******************* select * from t where c1 like '%2%' ****************
******************* select * from t where c1 like '1%3' ****************
******************* select * from t where c1 like '123' ****************
hit_count	query_sql	statement
0	select * from t where c1 like ?	select * from t where c1 like ?
3	select * from t where c1 like ?	select * from t where c1 like ?

index
precise(non filter)
******************* select * from t where c2 like 'a%' *****************
imprecise(has filter)
******************* select * from t where c2 like '%c' *****************
******************* select * from t where c2 like '%b%' ****************
******************* select * from t where c2 like 'a%c' ****************
******************* select * from t where c2 like 'abc' ****************
hit_count	query_sql	statement
0	select * from t where c2 like ?	select * from t where c2 like ?
3	select * from t where c2 like ?	select * from t where c2 like ?

normal column
imprecise(has filter)
******************* select * from t where c3 like 'a%' *****************
******************* select * from t where c3 like '%e' *****************
******************* select * from t where c3 like '%pp%' ***************
******************* select * from t where c3 like 'a%e' ****************
******************* select * from t where c3 like 'apple' **************
hit_count	query_sql	statement
0	select * from t where c3 like ?	select * from t where c3 like ?
3	select * from t where c3 like ?	select * from t where c3 like ?

********* pre-calculable expression ************************************
index\pk
precise(no filter)
********* select * from t where c2 like concat('a','b','%') ************
********* select * from t where c2 like concat('%','b','c') ************
********* select * from t where c2 like concat('%','b','%') ************
********* select * from t where c2 like concat('a','%','c') ************
********* select * from t where c2 like concat('a','b','c') ************
hit_count	query_sql	statement

************** implicit cast *******************************************
************** select * from t where c1 like 123 ***********************
************** select * from t where c1 like 1 *************************
hit_count	query_sql	statement
0	select * from t where c1 like ?	select * from t where c1 like ?
3	select * from t where c1 like ?	select * from t where c1 like ?
1	select * from t where c1 like ?	select * from t where c1 like ?

************************** some small tests ****************************
******************* select * from t where c1 like '1' ******************
******************* select * from t where c1 like '2' ******************
expect 1
hit_count	query_sql	statement
1	select * from t where  c1 like ?	select * from t where  c1 like ?

******************* select * from t where c1 like '1%' ******************
******************* select * from t where c1 like '4%' ******************
expect 1
hit_count	query_sql	statement
1	select * from t where c1  like ?	select * from t where c1  like ?

******************* select * from t where c1 like '%3' ******************
******************* select * from t where c1 like '%6' ******************
expect 1
hit_count	query_sql	statement
1	select * from t where c1   like ?	select * from t where c1   like ?

******************* select * from t where c1 like '%2%' ******************
******************* select * from t where c1 like '%5%' ******************
expect 1
hit_count	query_sql	statement
