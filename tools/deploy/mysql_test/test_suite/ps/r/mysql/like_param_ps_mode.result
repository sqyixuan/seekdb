******************* select * from t where c1 like '%2' ******************
******************* select * from t where c1 like '%5%' *****************
expect 1
hit_count	query_sql	statement
1	select * from  t  where c1   like ?	select * from  t  where c1   like ?

******************* select * from t where c1 like '2%' ******************
******************* select * from t where c1 like '%5%' *****************
expect 0
hit_count	query_sql	statement
0	select * from  t  where c1 like ?	select * from  t  where c1 like ?
0	select * from  t  where c1 like ?	select * from  t  where c1 like ?

******************* select * from t where c1 like 2 ******************
******************* select * from t where c1 like '2' ******************
expect 0
hit_count	query_sql	statement
0	select * from t where c1 like  ?	select * from t where c1 like  ?
0	select * from t where c1 like  ?	select * from t where c1 like  ?

******************* select * from t where c1 like 'null' ******************
******************* select * from t where c1 like null ******************
expect 0
hit_count	query_sql	statement
1	select *  from t where c1 like ?	select *  from t where c1 like ?

******************* select * from t where '123' like null ******************
******************* select * from t where null like null ******************
expect 0
hit_count	query_sql	statement
1	select  * from t where ? like ?	select  * from t where ? like ?

always true and always false
******************* select * from t where 'a' like 'a%' ******************
******************* select * from t where 'b' like 'a%' ******************
expect 0
hit_count	query_sql	statement
0	select * from t where ? like ?	select * from t where ? like ?
0	select * from t where ? like ?	select * from t where ? like ?

always true
******************* select * from t where 'a' like '%' ******************
******************* select * from t where 'a' like 'a%' *****************
******************* select * from t where 'a' like '%a' *****************
******************* select * from t where 'a' like '%a%' ****************
expect 3
hit_count	query_sql	statement
3	select * from  t where ? like ?	select * from  t where ? like ?

always false
******************* select * from t where 'b' like 'a%' *****************
******************* select * from t where 'b' like '%a' *****************
******************* select * from t where 'b' like '%a%' ****************
expect 2
hit_count	query_sql	statement
2	select * from t  where ? like ?	select * from t  where ? like ?

pre cal expr
******** select * from t where c1 like concat('a',concat('%','c')) ******
******** select * from t where c1 like concat('%',concat('b','c')) ******
expect 1
hit_count	query_sql	statement
1	select * from t where c1 like concat(?,concat(?,?))	select * from t where c1 like concat(?,concat(?,?))

pre cal expr
******** select * from t where c1 like concat(1 like 3, '0') ************
******** select * from t where c1 like concat('1' like '3', '0') **********
expect 0
hit_count	query_sql	statement
0	select * from t where c1 like concat(? like ?, ?)	select * from t where c1 like concat(? like ?, ?)
0	select * from t where c1 like concat(? like ?, ?)	select * from t where c1 like concat(? like ?, ?)
