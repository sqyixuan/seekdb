alter system set _ob_enable_prepared_statement = true;
create table t1(pk int primary key, a int, b int, c int, d int, e int);
create index i1 on t1(b,c) storing(d,e);
insert into t1 values(1,1,1,1,1,1),(2,1,1,1,1,1),(3,1,1,1,1,1),(4,1,1,1,1,1);
prepare trx1stmt1 from select pk, b, c, d, e from t1 where b between ? and ?;
prepare trx1stmt2 from select pk, a, b, c, d, e from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
set @a3=1000;
prepare trx1utmt1 from update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=?;
prepare trx2stmt1 from select pk, b, c, d, e from t1 where b between ? and ?;
prepare trx2stmt2 from select pk, a, b, c, d, e from t1 where pk>? and pk<?;
prepare trx2stmt3 from select * from t1 where b>? and b<?;
set @a1=0;
set @a2=10;
set @a3=1000;
prepare trx2utmt1 from update t1 set a=pk+10, b=pk+10, c=pk+10, d=pk+10, e=pk+10 where pk=?;
prepare trx2dtmt1 from delete from t1 where pk=?;
prepare trx2itmt1 from insert into t1 values(?,1,1,1,1,1);
prepare trx2rtmt1 from replace into t1 values(?,1,1,1,1,1);
set autocommit=0;
execute trx1stmt1 using @a1, @a3;
pk	b	c	d	e
1	1	1	1	1
2	1	1	1	1
3	1	1	1	1
4	1	1	1	1
execute trx1stmt2 using @a1, @a2;
