alter system set _ob_enable_prepared_statement = true;
drop database if exists ps_db;
create database ps_db;
use ps_db;
create table time_t(c1 int, c2 time(6));
insert into time_t values(1, "11:11:11.12345");
insert into time_t values(3, "24:59:59");
insert into time_t values(4, "00:00:00");
insert into time_t values(5, "11:11:11");
insert into time_t values(6, "11:11:11.654321");
select * from time_t;
c1	c2
1	11:11:11
3	00:59:59
4	00:00:00
5	11:11:11
6	11:11:11
create table date_t(c1 int, c2 date);
insert into date_t values(1, "1000-01-01"), (2, "1990-01-01");
select * from date_t;
c1	c2
1	1000-01-01
2	1990-01-01
create table year_t(c1 int, c2 year);
insert into year_t values(1, "2155"),(2, "1990");
select * from year_t;
c1	c2
1	2155-01-01
2	1990-01-01
create table datetime_t(c1 int, c2 datetime(6), c3 timestamp(6));
insert into datetime_t values(1, "1900-01-01 00:00:00","1900-01-01 00:00:00");
insert into datetime_t values(2, "2018-01-01 11:11:11.123456","2018-01-01 11:11:11.123456");
select * from datetime_t;
c1	c2	c3
1	1900-01-01 00:00:00.0	1900-01-01 00:00:00.0
2	2018-01-01 11:11:11.123456	2018-01-01 11:11:11.123456
create table null_t(c1 int, c2 int);
insert into null_t values(1, NULL),(2,NULL);
select * from null_t;
c1	c2
1	NULL
2	NULL
create table bit_t(c1 int, c2 bit(8));
insert into bit_t values(1, 97),(2, 49);
select * from bit_t;
c1	c2
1	a
2	1
create table enum_t(c1 int, c2 enum('a','b','c'));
insert into enum_t values(1, 1), (2, 3);
select * from enum_t;
c1	c2
1	a
2	c
create table set_t(c1 int, c2 set('a','b','c'));
insert into set_t values(1, 1), (2, 3);
select * from set_t;
c1	c2
1	a
2	a,b
create table decimal_t(c1 int, c2 decimal(10,3));
insert into decimal_t values(1, 11111), (2,11111.111);
select * from decimal_t;
c1	c2
1	11111.000
2	11111.111
create table float_t(c1 int, c2 float);
insert into float_t values(1, 11111), (2,11111.111);
select * from float_t;
c1	c2
1	11111.0
2	11111.111
create table double_t(c1 int, c2 double);
insert into double_t values(1, 11111), (2,11111.111);
select * from double_t;
c1	c2
1	11111.0
2	11111.111
drop database ps_db;
alter system set _ob_enable_prepared_statement = false;
