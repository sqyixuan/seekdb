update  tbl1 set i1=i1+1-1 where i1>10 and i1<=1000 order by i1 limit 3,10;
delete from tbl1  where i1>10 and i1<=1000 order by i1 limit 10,10;
update  tbl1 set i1=i1+1-1 where  i1>10+1 and i1<1000 order by i1;
update  tbl1  set i1=i1+1-1 where i1 between 10+1 and 1000 order by i1 limit 3,10;
