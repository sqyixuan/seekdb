prepare stmt1 from update tbl1 set i1=i1-100 where i1>?+1 and i1<?-10 order by ? limit ?,?;
set @a=10;
set @b=1000;
set @c='i1';
set @d=0;
set @e=10;
execute stmt1 using @a, @b,@c,@d,@e;
set @c='v2';
set @a=10;
set @b=1000;
execute stmt1 using @a, @b,@c,@d,@e;
