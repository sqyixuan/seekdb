alter system set _ob_enable_prepared_statement = true;
// Case1: check desc
// check desc in obsys
desc oceanbase.__all_virtual_ps_stat;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO		NULL	
svr_ip	varchar(46)	NO		NULL	
svr_port	bigint(20)	NO		NULL	
stmt_count	bigint(20)	NO		NULL	
hit_count	bigint(20)	NO		NULL	
access_count	bigint(20)	NO		NULL	
mem_hold	bigint(20)	NO		NULL	

// check desc in MySQL tenant
desc oceanbase.GV$OB_PS_STAT;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO		NULL	
svr_ip	varchar(46)	NO		NULL	
svr_port	bigint(20)	NO		NULL	
stmt_count	bigint(20)	NO		NULL	
hit_count	bigint(20)	NO		NULL	
access_count	bigint(20)	NO		NULL	
mem_hold	bigint(20)	NO		NULL	
desc oceanbase.V$OB_PS_STAT;
Field	Type	Null	Key	Default	Extra
tenant_id	bigint(20)	NO			
svr_ip	varchar(46)	NO			
svr_port	bigint(20)	NO			
stmt_count	bigint(20)	NO			
hit_count	bigint(20)	NO			
access_count	bigint(20)	NO			
mem_hold	bigint(20)	NO			

// virtual table is only visiable by sys tenant
desc oceanbase.__all_virtual_ps_stat;
ERROR 42S02: Table doesn't exist

// only one row. because in mysql tenant, only this tenant itself is visible
select count(stmt_count) from oceanbase.GV$OB_PS_STAT;
count(stmt_count)
1

prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
?
1
// init stmt_count and hit_count
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_1, @hit_count_1;
// prepare same stmt again
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
?
1
// check here. stmt_count should be same as above. hit_count should inc by 1
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_2, @hit_count_2;
select "succeed" from dual where @stmt_count_2 - @stmt_count_1 = 0 and @hit_count_2 - @hit_count_1 = 1;
succeed

// close stmt1
deallocate prepare stmt1;
// check here. after deallocate. stmt_count should be same as above. hit_count should be same
// because we prepare stmt1 twice. and only deallocate once
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_3, @hit_count_3;
select "succeed" from dual where @stmt_count_3 - @stmt_count_2= 0 and @hit_count_3 - @hit_count_2 = 0;
succeed

prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
?
1
// check here. stmt_count should be same. hit_count should inc by 1.
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_4, @hit_count_4;
select "succeed" from dual where @stmt_count_4 - @stmt_count_3 = 0 and @hit_count_4 - @hit_count_3 = 1;
succeed

// prepare stmt1 again
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
?
1
// check here. stmt_count should be same. hit_count should inc by 1
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_5, @hit_count_5;
select "succeed" from dual where @stmt_count_5 - @stmt_count_4 = 0 and @hit_count_5 - @hit_count_4 = 1;
succeed
alter system set _ob_enable_prepared_statement = false;
