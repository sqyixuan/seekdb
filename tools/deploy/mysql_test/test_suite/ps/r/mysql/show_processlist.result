alter system set _ob_enable_prepared_statement = true;
alter system flush plan cache global;
set @x = 10;
prepare stmt1 from select user, tenant, db, command, state, info from oceanbase.__all_virtual_processlist where info like 'select%shaoge%from oceanbase.__all_virtual_processlist%';
execute stmt1;
user	tenant	db	command	state	info
admin	sys	test	Execute	ACTIVE	select user, tenant, db, command, state, info from oceanbase.__all_virtual_processlist where info like 'select%shaoge%from oceanbase.__all_virtual_processlist%'
alter system set _ob_enable_prepared_statement = false;
