alter system set _ob_enable_prepared_statement = true;
alter system flush plan cache global;
drop table if exists t1, tbl_for_check;
create table t1 (c1 varchar(10));
create table tbl_for_check(idx int auto_increment, hit_count int, plan_id int, ps_stmt_id int, primary key(idx));
set @x = 'abc';
prepare stmt1 from select substr(c1, 1, ?) from t1;
execute stmt1 using @x;
substr(c1, 1, ?)
Warnings:
Warning	1292	Truncated incorrect INTEGER value: 'abc'
insert into tbl_for_check (hit_count, plan_id, ps_stmt_id) select hit_count, plan_id, ps_stmt_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select substr(c1, 1, ?) from t1' order by ps_stmt_id desc limit 1;
// check here!!! first execute, count(*) should be 1
select count(*) from tbl_for_check;
count(*)
1
// check here!!! check hit_count
select case a.hit_count = 0 when 1 then "succeed, this is first executation" else "Failed, hit_count should be 0" end from (select * from tbl_for_check where idx = 1) a;
case a.hit_count = 0 when 1 then "succeed, this is first executation" else "Failed, hit_count should be 0" end
succeed, this is first executation
set @x = 'abc';
prepare stmt1 from select substr(c1, 1, ?) from t1;
execute stmt1 using @x;
substr(c1, 1, ?)
Warnings:
Warning	1292	Truncated incorrect INTEGER value: 'abc'
insert into tbl_for_check (hit_count, plan_id, ps_stmt_id) select hit_count, plan_id, ps_stmt_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select substr(c1, 1, ?) from t1' order by ps_stmt_id desc limit 1;
// check here!!! count(*) should be 2
select count(*) from tbl_for_check;
count(*)
2
// check here!!! check plan_id
select case a.plan_id = b.plan_id when 1 then "succeed, same ps stmt hit same plan" else "Failed, plan_id should be same" end from (select * from tbl_for_check where idx = 1) a, (select * from tbl_for_check where idx = 2) b;
case a.plan_id = b.plan_id when 1 then "succeed, same ps stmt hit same plan" else "Failed, plan_id should be same" end
succeed, same ps stmt hit same plan
// check here!!! check ps_stmt_id
select case a.ps_stmt_id = b.ps_stmt_id when 1 then "succeed, same ps stmt from same session should got same ps stmt_id" else "Failed, ps_stmt_id should be same" end from (select * from tbl_for_check where idx = 1) a, (select * from tbl_for_check where idx = 2) b;
case a.ps_stmt_id = b.ps_stmt_id when 1 then "succeed, same ps stmt from same session should got same ps stmt_id" else "Failed, ps_stmt_id should be same" end
succeed, same ps stmt from same session should got same ps stmt_id
deallocate prepare stmt1;

// another session
set @x = 'abc';
prepare stmt1 from select substr(c1, 1, ?) from t1;
execute stmt1 using @x;
substr(c1, 1, ?)
Warnings:
Warning	1292	Truncated incorrect INTEGER value: 'abc'
insert into tbl_for_check (hit_count, plan_id, ps_stmt_id) select hit_count, plan_id, ps_stmt_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'select substr(c1, 1, ?) from t1' order by ps_stmt_id desc limit 1;
// check here!!! count(*) should be 3
select count(*) from tbl_for_check;
count(*)
3
// check here!!! hit_count should hit plan in last session
select case a.hit_count = 2 when 1 then "succeed, same ps stmt from different session hit same plan" else "Failed, hit_count should be 2" end from (select * from tbl_for_check where idx = 3) a;
case a.hit_count = 2 when 1 then "succeed, same ps stmt from different session hit same plan" else "Failed, hit_count should be 2" end
succeed, same ps stmt from different session hit same plan
// check here!!! check plan_id
select case a.plan_id = b.plan_id when 1 then "succeed, same ps stmt from different session hit same plan" else "Failed, plan_id should be same" end from (select * from tbl_for_check where idx = 2) a, (select * from tbl_for_check where idx = 3) b;
case a.plan_id = b.plan_id when 1 then "succeed, same ps stmt from different session hit same plan" else "Failed, plan_id should be same" end
succeed, same ps stmt from different session hit same plan
// check here!!! check ps_stmt_id
select case a.ps_stmt_id != b.ps_stmt_id when 1 then "succeed, ps_stmt_id from different session is different" else "Failed, ps_stmt_id should not be same" end from (select * from tbl_for_check where idx = 2) a, (select * from tbl_for_check where idx = 3) b;
case a.ps_stmt_id != b.ps_stmt_id when 1 then "succeed, ps_stmt_id from different session is different" else "Failed, ps_stmt_id should not be same" end
succeed, ps_stmt_id from different session is different
deallocate prepare stmt1;
alter system set _ob_enable_prepared_statement = false;
