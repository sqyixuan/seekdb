--source mysql_test/test_suite/ps/t/enable_ps.sql
#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(i int primary key, c1 char(1), c256 char(256), dt datetime(6), d  datetime(6), ct datetime default now(), mt datetime default now());
create table t2(i int primary key, c1 char(1), c256 char(256), dt datetime(6), d  datetime(6), ct datetime default now(), mt datetime default now());
replace into t1(i,c1,c256,dt,d) values(0,'1','xqy','2012-10-10 12:00:00','2012-10-10');
replace into t1(i,c1,c256,dt,d) values(1,'1','xqy','2012-10-10 12:00:00','2012-10-10');
replace into t1(i,c1,c256,dt,d) values(2,'1','xqy','2012-10-10 12:00:00','2012-10-10');
replace into t1(i,c1,c256,dt,d) values(3,'1','xqy','2012-10-10 12:00:00','2012-10-10');
replace into t1(i,c1,c256,dt,d) values(4,'1','xqy','2012-10-10 12:00:00','2012-10-10');
let $i=0;
--disable_query_log
--disable_result_log

#muti conn execute  select sql repeatedly
connection conn1;
prepare stmt1 from select c1,dt from t1 where c256=?;
connection conn2;
prepare stmt1 from select c1,dt from t1 where c256=?;
connection conn1;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}
connection conn2;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}

#muti conn execute repalce sql repeatedly
connection conn1;
prepare stmt1 from replace into t1(i,c1,c256,dt,d) values (5,'1',?,'2012-10-10 12:00:00','2012-10-10');
connection conn2;
prepare stmt1 from replace into t1(i,c1,c256,dt,d) values (5,'1',?,'2012-10-10 12:00:00','2012-10-10');
connection conn1;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}
connection conn2;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}

#muti conn execute update sql repeatedly
connection conn1;
prepare stmt1 from update t1 set c256=? where i=6;
connection conn2;
prepare stmt1 from update t1 set c256=? where i=6;

connection conn1;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}
connection conn2;
let $i=0;
while($i<1000)
{

	set @c256='xqy';
	execute stmt1 using @c256;
	inc $i;
}

#muti conn execute update sql repeatedly
connection conn1;
prepare stmt1 from delete from  t1 where i=?;
connection conn2;
prepare stmt1 from delete from  t1 where i=?;
connection conn1;
let $i=0;
while($i<1000)
{

	set @a=2;
	execute stmt1 using @a;
	inc $i;
}
connection conn2;
let $i=0;
while($i<1000)
{

	set @a=2;
	execute stmt1 using @a;
	inc $i;
}
--source mysql_test/test_suite/ps/t/disable_ps.sql
