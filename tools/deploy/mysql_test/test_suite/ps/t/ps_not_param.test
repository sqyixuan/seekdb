--source mysql_test/test_suite/ps/t/enable_ps.sql

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system flush plan cache global;
sleep 2;
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 varchar(100));
insert into t1 values('abc');

--echo
--echo // Case1: test first param of like expr should param
prepare stmt1 from select * from t1 where ? like 't%';
set @val1 = 'test1';
execute stmt1 using @val1;
--echo // expect hit_count is 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like \'t%\'';

set @val2 = 'test2';
execute stmt1 using @val2;
--echo // expect hit_count is 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like \'t%\'';

--echo
--echo // Case2: test second param of like expr should not param
set @pat1 = '%a%';
prepare stmt1 from select * from t1 where c1 like ?;
execute stmt1 using @pat1;
--echo // expect hit_count 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where c1 like ?';
set @pat2 = '%b%';
execute stmt1 using @pat2;
--echo // expect hit_count 0 0. should not paramterize like parttern
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where c1 like ?';

--echo
--echo // Case3: test third param of like expr should not param
prepare stmt1 from select * from t1 where ? like ? escape ?;
set @val1 = 'test1';
set @pat1 = 't%';
set @esc1 = '|';
execute stmt1 using @val1, @pat1, @esc1;
--echo // expect hit count is 0
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';

set @val2 = 'test2';
execute stmt1 using @val2, @pat1, @esc1;
--echo // hit count is 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';

set @pat2 = 'b%';
execute stmt1 using @val2, @pat2, @esc1;
--echo // should not paramterize pattern. hit_counot is 0 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
execute stmt1 using @val1, @pat2, @esc1
--echo // should not paramterize pattern. hit_counot is 1 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';

set @esc2 = '_';
execute stmt1 using @val2, @pat2, @esc2;
--echo // should not paramterize escape. hit_counot is 0 1 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';
execute stmt1 using @val1, @pat2, @esc2;
--echo // should not paramterize escape. hit_counot is 1 1 1
select query_sql, statement, hit_count from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql = 'select * from t1 where ? like ? escape ?';

--source mysql_test/test_suite/ps/t/disable_ps.sql
