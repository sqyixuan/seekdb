--source mysql_test/test_suite/ps/t/enable_ps.sql
# owner: xiaoyi.xy
# owner group: SQL2
# description: test for ps + outline

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 0, 5265
drop outline ol1;
--error 0, 5265
drop outline ol2;
--error 0, 5265
drop outline ol3;

create table t1(c1 int primary key, c2 int unique key, c3 int  unique key);
insert into t1 values(1 , 2, 3),(2, 3, 1),(3, 1,2);

###### test for no question mark ######
prepare stmt1 from select c1, c2, c3 from t1 order by c1;
execute stmt1;
create outline ol1 on '858B1DA4A95601D1E9B5A985FD966B35' using hint /*+index(t1 c2)*/;
execute stmt1;
deallocate prepare stmt1;

###### test for normal question mark ######
prepare stmt1 from select c1, c2, c3 from t1 where c1 > ? order by c1;
set @a=0;
execute stmt1 using @a;
create outline ol2 on '477F8A7070C945429144AB5CB510E879' using hint /*+index(t1 c2)*/;

set @a=-10;
execute stmt1 using @a;
deallocate prepare stmt1;

####### test for reprepare stmt ######
prepare stmt1 from select c1, c2, c3 from t1 where c1 > ? order by c1;
set @a=0;
execute stmt1 using @a;
drop outline ol2;

###### test for not param question mark ######
prepare stmt1 from select ?, c1, c2, c3 from t1 order by c1;
set @a=11111;
execute stmt1 using @a;
create outline ol3 on 'BD4F1833F564C206655AB4EF7F85FE98' using hint /*+index(t1 c3)*/;

set @a=22222;
execute stmt1 using @a;

###### test for drop outline  ######
drop outline ol3;
set @a=33333;
execute stmt1 using @a;
deallocate prepare stmt1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
