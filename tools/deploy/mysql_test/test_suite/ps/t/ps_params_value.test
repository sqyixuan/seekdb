--source mysql_test/test_suite/ps/t/enable_ps.sql

#owner: luofan.zp
#owner group: SQL2
##tags: ps
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists luofan_t1;
--enable_warnings


connect (conn, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection conn;
alter system flush sql audit global;

--sleep 1
connection default;

##
# Case1
##

create table luofan_t1 (c1 int, c2 int unsigned,
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned,
    c15 double, c16 double unsigned,
    c17 decimal(30, 20), c18 decimal(30, 20) unsigned,
    c19 datetime, c20 timestamp,
    c21 year, c22 date, c23 time,
    c24 varchar(30), c25 char(30),
    c26 varbinary(30),
    c27 enum("","0","1","2","3","5","6","7","8","9"),
    c28 set("","0","1","2","3","5","6","7","8","9"),
    c29 bit
    );

prepare stmt1 from insert into luofan_t1 values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

set @i1=1;
set @i2=2;
set @i3=3;
set @i4=4;
set @i5=5;
set @i6=6;
set @i7=7;
set @i8=8;
set @i9=9;
set @i10=10;
set @i11=11;
set @i12=12;
set @i13=3.1;
set @i14=4.1;
set @i15=5.1;
set @i16=6.1;
set @i17=7.1;
set @i18=8.1;
set @i19='2019-12-01 12:00:00';
set @i20='2019-12-13 06:00:00';
set @i21=2020;
set @i22='2020-01-01';
set @i23='12:34:56';
set @i24='luofan test';
set @i25='luofan test2';
set @i26='testtest';
set @i27='0';
set @i28='6';
set @i29=0;

execute stmt1 using @i1, @i2, @i3, @i4, @i5, @i6, @i7, @i8, @i9, @i10, @i11, @i12, @i13, @i14, @i15, @i16, @i17, @i18, @i19, @i20, @i21, @i22, @i23, @i24, @i25, @i26, @i27, @i28, @i29;

select query_sql, params_value from oceanbase.GV$OB_SQL_AUDIT where query_sql='insert into luofan_t1 values (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)' and request_type=6;

drop table luofan_t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql

connection conn;
alter system flush sql audit global;
