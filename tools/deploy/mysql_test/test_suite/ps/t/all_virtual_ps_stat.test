--source mysql_test/test_suite/ps/t/enable_ps.sql
# owner: xiaoyi.xy
# owner group: SQL2
# description: 测试__all_virtual_ps_stat虚拟表

--echo // Case1: check desc
--echo // check desc in obsys
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
desc oceanbase.__all_virtual_ps_stat;
alter system flush ps cache global;

--echo
--echo // check desc in MySQL tenant
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
desc oceanbase.GV$OB_PS_STAT;
desc oceanbase.V$OB_PS_STAT;
--echo
--echo // virtual table is only visiable by sys tenant
--error 1146
desc oceanbase.__all_virtual_ps_stat;

connection conn1;
--echo 
--echo // only one row. because in mysql tenant, only this tenant itself is visible
select count(stmt_count) from oceanbase.GV$OB_PS_STAT;

--echo
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
--echo // init stmt_count and hit_count
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_1, @hit_count_1;

--echo // prepare same stmt again
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
--echo // check here. stmt_count should be same as above. hit_count should inc by 1
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_2, @hit_count_2;
select "succeed" from dual where @stmt_count_2 - @stmt_count_1 = 0 and @hit_count_2 - @hit_count_1 = 1;

--echo
--echo // close stmt1
deallocate prepare stmt1;

--echo // check here. after deallocate. stmt_count should be same as above. hit_count should be same
--echo // because we prepare stmt1 twice. and only deallocate once
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_3, @hit_count_3;
select "succeed" from dual where @stmt_count_3 - @stmt_count_2= 0 and @hit_count_3 - @hit_count_2 = 0;

--echo
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
--echo // check here. stmt_count should be same. hit_count should inc by 1.
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_4, @hit_count_4;
select "succeed" from dual where @stmt_count_4 - @stmt_count_3 = 0 and @hit_count_4 - @hit_count_3 = 1;

--echo
--echo // prepare stmt1 again
prepare stmt1 from select ? from dual;
set @x = 1;
execute stmt1 using @x;
--echo // check here. stmt_count should be same. hit_count should inc by 1
select stmt_count, hit_count from oceanbase.GV$OB_PS_STAT into @stmt_count_5, @hit_count_5;
select "succeed" from dual where @stmt_count_5 - @stmt_count_4 = 0 and @hit_count_5 - @hit_count_4 = 1;

connection conn_admin;
select tenant_id, stmt_count from oceanbase.GV$OB_PS_STAT;
alter system flush ps cache global;
select tenant_id, stmt_count from oceanbase.GV$OB_PS_STAT;

--source mysql_test/test_suite/ps/t/disable_ps.sql
