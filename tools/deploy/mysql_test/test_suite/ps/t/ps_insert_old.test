#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
# description: ps模式下insert的测试. 
# jdbc_ps_insert.test
# ps_complex_insert.test
# ps_lose_insert.test
# ps_lose_cur_time.test

# jdbc_ps_insert.test
--echo case 1
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(pk int primary key, c1 int);
prepare stmt from insert into t1 values(?,?);
set autocommit=0;
set @a=1;
set @b=1;
execute stmt using @a,@b;
set @a=2;
set @b=2;
execute stmt using @a,@b;
set @a=3;
set @b=3;
execute stmt using @a,@b;
set @a=4;
set @b=4;
execute stmt using @a,@b;
commit;
set autocommit=1;
select * from t1;

--echo case 2:
create table t2(pk int primary key, c1 int);
prepare stmt from insert into t2 values(?,?),(?,?);
set autocommit=0;
set @a=1;
set @b=1;
set @c=2;
set @d=2;
execute stmt using @a,@b,@c,@d;
set @a=3;
set @b=3;
set @c=1;
set @d=1;
--error 1062
execute stmt using @a,@b,@c,@d;
rollback;
set autocommit=1;
select * from t2;

# ps_complex_insert.test
drop table if exists t1, t2;
create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
prepare stmt_insert from insert into t1 values(?,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l+abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l+abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}
select * from t1;

--echo
create table t2(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
prepare stmt_insert1 from  insert into t2 values(100000000,?,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @f1=$l.5;
    eval set @s1='$l-abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l-abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert1 using @f1,@s1,@d1,@i2,@f2,@s2,@d2;
}
select * from t2;
drop table t1;
drop table t2;

--echo
create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
# 这里需要注意下，跑farm时，reject文件的select结果是10000，不是10000.005，目前先忽略该错误
# 有可能是java format程序的问题
prepare stmt_insert from insert into t1 values(?,10000.005,?,?,?,?,?,?);
# prepare stmt_insert from insert into t1 values(?,10000,?,?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @s1='$l@abcdefg';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l@abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert using @i1,@s1,@d1,@i2,@f2,@s2,@d2;
}
select * from t1;
drop table t1;

create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
prepare stmt_insert from replace into t1 values(?,?,'abcdefghijklmn',?,?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l#abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert using @i1,@f1,@d1,@i2,@f2,@s2,@d2;
}
select * from t1;
drop table t1;

create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
prepare stmt_insert from insert into t1 values(?,?,?,'2012-12-12 10:20:01',?,?,?,?);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l,abcdefg';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l,abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert using @i1,@f1,@s1,@i2,@f2,@s2,@d2;
}
select * from t1;
drop table t1;

create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, f2 float,s2 varchar(1024), d2 datetime,primary key(i1,s1,d1));
prepare stmt_replace from replace into t1 values(12341234,1234.1234,'1234.1234','2012-03-04 12:03:04',?,?,?,?);
--let $l=10
while($l)
{
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l.abcdefg';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_replace using @i2,@f2,@s2,@d2;
}
select * from t1;
drop table t1;

create table t1(i1 int, f1 float, s1 varchar(1024), d1 datetime, i2 int, primary key(i1,s1,d1));
prepare stmt_insert from insert into t1 values(?,?,?,?,0),(?,?,?,?,0);
--let $l=10
while($l)
{
    eval set @i1=$l;
    eval set @f1=$l.5;
    eval set @s1='$l[abcdefg]';
    eval set @d1=timestamp'2020-02-02 20:00:00';
    dec $l;
    eval set @i2=$l;
    eval set @f2=$l.5;
    eval set @s2='$l[abcdefg]';
    eval set @d2=timestamp'2020-02-01 20:00:00';
    execute stmt_insert using @i1,@f1,@s1,@d1,@i2,@f2,@s2,@d2;
}
select * from t1;
drop table t1;

# ps_lose_insert.test
--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add a new column
prepare stmt1 from insert into t1 values (?,'d',2);
set @x=4;
execute stmt1 using @x;
alter table t1 add d int;
--real_sleep 1
set @x=5;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt1 using @x;
select * from t1;
deallocate prepare stmt1;

drop table t1;
create table t1(a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3);

#drop a no exist column
prepare stmt2 from insert into t1 values (?,'d',3);
set @x=3;
execute stmt2 using @x;
--error ER_CANT_DROP_FIELD_OR_KEY
alter table t1 drop q;
--real_sleep 1
set @x=4;
execute stmt2 using @x;
select * from t1;
deallocate prepare stmt2;

#drop a exist column
prepare stmt3 from insert into t1 values (?,'d',3);
set @x=5;
execute stmt3 using @x;
alter table t1 drop c;
--real_sleep 1
set @x=6;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt3 using @x;
select * from t1;
deallocate prepare stmt3;

#add a new column and drop it
prepare stmt4 from insert into t1 values (?,'d');
set @x=7;
execute stmt4 using @x;
alter table t1 add c int;
--real_sleep 1
alter table t1 drop c;
--real_sleep 1
set @x=8;
execute stmt4 using @x ;
select * from t1;
deallocate prepare stmt4;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop a exist column,and add it which have same type with before
prepare stmt5 from insert into t1 values (?,'d',4);
set @x=4;
execute stmt5 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b varchar(255);
--real_sleep 1
# prepare stmt5 from insert into t1 values (?,4,'d');
# desc t1;
# --real_sleep 1
# set @x=5;
# execute stmt5 using @x;
# select * from t1;
# deallocate prepare stmt5;

#drop a exist column,add it which have different type with before
prepare stmt6 from insert into t1 values (?,2,'d');
set @x=6;
execute stmt6 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
desc t1;
set @x=7;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt6 using @x;
select * from t1;
deallocate prepare stmt6;

#drop table t1;
prepare stmt7 from insert into t1 values (?,2,6);
set @x=8;
execute stmt7 using @x;
drop table t1;
set @x=9;
--error 1146
execute stmt7 using @x;
deallocate prepare stmt7;

create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop table and create it again
prepare stmt8 from insert into t1 values (?,2,3);
set @x=4;
execute stmt8 using @x;
drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
set @x=5;
execute stmt8 using @x ;
select * from t1;
deallocate prepare stmt8;

#drop table and create it with diff shema
prepare stmt9 from insert into t1 values (?,2,5);
set @x=4;
execute stmt9 using @x;
drop table t1;
create table t1( a int primary key,b varchar(255));
set @x=5;
--error ER_WRONG_VALUE_COUNT_ON_ROW
execute stmt9 using @x;
select * from t1;
deallocate prepare stmt9;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add column
prepare stmt10 from insert into t1(a,b,c) values (?,'d',6);
set @x=4;
execute stmt10 using @x;
alter table t1 add d int;
--real_sleep 1
set @x=5;
execute stmt10 using @x;
select * from t1;
deallocate prepare stmt10;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
alter table t1 add d int;
--real_sleep 1

#drop no use column
prepare stmt11 from insert into t1(a,b,c) values (?,'d',3);
set @x=4;
execute stmt11 using @x;
alter table t1 drop d;
--real_sleep 1
set @x=5;
execute stmt11 using @x;
select * from t1;
deallocate prepare stmt11;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);
alter table t1 add d int;
--real_sleep 1

#drop use column
prepare stmt12 from insert into t1(a,b,c) values (?,'d',2);
set @x=4;
execute stmt12 using @x;
alter table t1 drop c;
--real_sleep 1
set @x=5;
--error ER_BAD_FIELD_ERROR
execute stmt12 using @x;
select * from t1;
deallocate prepare stmt12;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#have problem
prepare stmt13 from insert into t1(a,b) values (?,'d');
set @x=4;
execute stmt13 using @x;
alter table t1 drop c;
--real_sleep 1
set @x=5;
execute stmt13 using @x;
select * from t1;
deallocate prepare stmt13;

drop table t1;
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop column add it again with same type
prepare stmt14 from insert into t1(a,b,c) values (?,'d',1);
set @x=4;
execute stmt14 using @x;
alter table t1 drop c;
--real_sleep 1
alter table t1 add c int;
--real_sleep 1
set @x=5;
execute stmt14 using @x;
select * from t1;
deallocate prepare stmt14;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#drop column add it again with diff type
prepare stmt15 from insert into t1(a,b,c) values (?,'d',1);
set @x=4;
execute stmt15 using @x;
alter table t1 drop b;
--real_sleep 1
alter table t1 add b int;
--real_sleep 1
set @x=5;
--error ER_TRUNCATED_WRONG_VALUE_FOR_FIELD
execute stmt15 using @x;
select * from t1;
deallocate prepare stmt15;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1( a int primary key,b varchar(255),c int);
insert into t1 values(1,'a',2),(2,'b',3),(3,'c',4);

#add column drop it again
prepare stmt16 from insert into t1(a,b,c) values (?,'d',1);
set @x=4;
execute stmt16 using @x;
alter table t1 add d int;
--real_sleep 1
alter table t1 drop d;
--real_sleep 1
set @x=5;
execute stmt16 using @x;
select * from t1;
deallocate prepare stmt16;

# ps_lose_cur_time.test
--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1 (c1 int primary key, c2 timestamp default now(), c3 int not null);
replace into t1 values(1,'1986-05-24',2);
prepare p1 from replace into t1(c1,c2,c3) values(?,?,?);
set @a = 1;
set @b = '1986-01-14';
set @c = 3;
alter table t1 alter column c2 drop default;
execute p1 using @a,@b,@c;
execute p1 using @a,@b,@c;
drop table t1;
--source mysql_test/test_suite/ps/t/disable_ps.sql
