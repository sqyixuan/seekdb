--source mysql_test/test_suite/ps/t/enable_ps.sql
# owner: xiaoyi.xy
# owner group: SQL2
# description: prepare same sql shoudle return different stmt id

--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;

alter system flush plan cache global;

connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1 values(1);

--echo
--echo // for now, cannot check diff client stmt id, need add view.
prepare stmt1 from select c1 from t1;
select ps_sql, stmt_id from oceanbase.GV$OB_PS_ITEM_INFO where ps_sql = 'select c1 from t1';
prepare stmt1 from select c1 from t1;
select ps_sql, stmt_id from oceanbase.GV$OB_PS_ITEM_INFO where ps_sql = 'select c1 from t1';

--source mysql_test/test_suite/ps/t/disable_ps.sql
