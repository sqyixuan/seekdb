--source mysql_test/test_suite/ps/t/enable_ps.sql

#owner: xiaoyi.xy
#owner group: SQL2
##tags: ps
#####
## 不支持row count
####
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####2014.12¡£08modified:ÊÂÎñ¹ýÆÚ£¬psÓï¾äÖÐ£»
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--source mysql_test/include/index_quick_major.inc
--real_sleep 1

#case 1
create table t1 (pk int primary key, key1 int, v1 varchar(50), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(key1) storing(v1,t1);
create table t2 (pk int primary key, key1 int, v1 varchar(50), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i2 on t2(key1) storing(v1,t1);
--source mysql_test/include/check_all_idx_ok.inc


insert into t1 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13'),(5,5,'e','2013-12-14');

prepare stmt1 from replace into t1 values(?,?,?,?);
set @a1=5;
set @a2='replace';
set @a3='2013-12-15';
execute stmt1 using @a1,@a1,@a2,@a3;

prepare stmt2 from insert into t1 values(?,?,?,?);
set @b1=6;
set @b2='insert';
set @b3='2013-12-16';
execute stmt1 using @b1,@b1,@b2,@b3;

prepare stmt3 from update t1 set v1=? where pk=?;
set @c1='update';
set @c2=6;
execute stmt3 using @c1,@c2;

prepare stmt4 from delete from t1 where pk=?;
set @d1=1;
execute stmt4 using @d1;

